# hexa-lang /.loop — recurring loop / cron / schedule SSOT
# Declarative loop-task registry for /loop, cron, ScheduleWakeup, RemoteTrigger.
# raw#16 enforced. Format spec: self/raw_loader.hexa (same grammar as .raw).
#
# Format:
#   loop <id> <status> "<name>"
#     interval  <60s|5m|1h|daily|cron(...)>
#     cmd       <shell or /slash-command>
#     <key>     <value>
#
# status (locked, 5): live warn new deferred convention
# required keys: interval cmd why
# standard keys (common): since until owner proof note

loop 1 live "daily fixpoint drift check"
  interval  daily
  cmd       ./build/hexa_stage0 tool/verify_fixpoint.hexa --quick
  why       raw#17 수렴 강제 자동화. drift 발생 시 audit append.

loop 2 planned "weekly fixpoint archive snapshot"
  interval   weekly
  cmd        ./build/hexa_stage0 tool/fixpoint_archive.hexa snapshot
  depends-on roadmap#17 fixpoint archive 구현
  why        raw#9 proof-carrying evidence 축적

# NOTE: Linux sandbox — self/raw_cli.hexa verify 실행 불가. Mac 에서 verify 필수.
