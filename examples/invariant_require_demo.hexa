// examples/invariant_require_demo.hexa — T3 Phase A: require predicate
//
// 본 예제는 require predicate 의 violation 감지를 확인한다.
//   ./hexa check examples/invariant_require_demo.hexa
//     → 1 violation (I4) + exit 1
//
// require(target="_FEATURE_FLAG_") 은 이 파일에 반드시 해당 substring 이
// 있어야 한다는 의미. 아래에는 해당 flag 가 없으므로 위반.

@invariant {
    id: "I4",
    name: "must_contain_feature_flag",
    predicate: "require",
    pattern: { target: "_FEATURE_FLAG_", context: "" },
    exempt: []
}

fn demo() {
    // no flag here — require 위반
    return 1
}

demo()
