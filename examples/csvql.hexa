// csvql — CSV 간이 쿼리 도구
// 사용:
//   csvql sum <col> <file>               : 컬럼 합계
//   csvql avg <col> <file>               : 컬럼 평균
//   csvql filter <col> <value> <file>    : col == value 행 출력

fn col_index(header: string, name: string) {
    let cols = header.split(",")
    let mut i = 0
    while i < len(cols) {
        if cols[i].trim() == name {
            return i
        }
        i = i + 1
    }
    return -1
}

fn main() {
    if argc() < 4 {
        println("사용:")
        println("  csvql sum <col> <file>")
        println("  csvql avg <col> <file>")
        println("  csvql filter <col> <value> <file>")
        return 1
    }

    let mode = arg(1)
    let col_name = arg(2)

    if mode == "sum" || mode == "avg" {
        let path = arg(3)
        let content = read_file(path)
        let lines = content.split("\n")
        if len(lines) < 2 {
            println("empty or header only")
            return 1
        }
        let idx = col_index(lines[0], col_name)
        if idx < 0 {
            println("column not found:", col_name)
            return 1
        }
        let mut total = 0
        let mut count = 0
        let mut i = 1
        while i < len(lines) {
            let line = lines[i]
            if line.trim().len() > 0 {
                let cells = line.split(",")
                if idx < len(cells) {
                    total = total + parse_int(cells[idx])
                    count = count + 1
                }
            }
            i = i + 1
        }
        if mode == "sum" {
            println(col_name, "sum =", total, "(rows:", count, ")")
        } else {
            if count > 0 {
                println(col_name, "avg =", total / count, "(rows:", count, ")")
            } else {
                println("no rows")
            }
        }
        return 0
    }

    if mode == "filter" {
        if argc() < 5 {
            println("usage: csvql filter <col> <value> <file>")
            return 1
        }
        let val = arg(3)
        let path = arg(4)
        let content = read_file(path)
        let lines = content.split("\n")
        let idx = col_index(lines[0], col_name)
        if idx < 0 {
            println("column not found:", col_name)
            return 1
        }
        println(lines[0])
        let mut matched = 0
        let mut i = 1
        while i < len(lines) {
            let line = lines[i]
            if line.trim().len() > 0 {
                let cells = line.split(",")
                if idx < len(cells) && cells[idx].trim() == val {
                    println(line)
                    matched = matched + 1
                }
            }
            i = i + 1
        }
        println("--", matched, "rows --")
        return 0
    }

    println("unknown mode:", mode)
    return 1
}
