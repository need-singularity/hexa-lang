// Self-hosting experiment: HEXA lexer written in HEXA
// This tokenizes a simple HEXA program

fn is_letter(c: string) -> bool {
    let code = to_int(c)
    if code >= 65 && code <= 90 { return true }   // A-Z
    if code >= 97 && code <= 122 { return true }  // a-z
    if c == "_" { return true }
    false
}

fn is_digit_char(c: string) -> bool {
    let code = to_int(c)
    code >= 48 && code <= 57
}

fn is_whitespace_char(c: string) -> bool {
    c == " " || c == "\n" || c == "\t" || c == "\r"
}

fn tokenize(source: string) -> array {
    let mut tokens = []
    let chars = source.chars()
    let i = 0
    let len = chars.len()

    while i < len {
        let c = chars[i]

        // Skip whitespace
        if is_whitespace_char(c) {
            i = i + 1
            continue
        }

        // Skip comments
        if c == "/" && i + 1 < len && chars[i + 1] == "/" {
            while i < len && chars[i] != "\n" {
                i = i + 1
            }
            continue
        }

        // Numbers
        if is_digit_char(c) {
            let num = ""
            while i < len && is_digit_char(chars[i]) {
                num = num + chars[i]
                i = i + 1
            }
            tokens = tokens.push("INT:" + num)
            continue
        }

        // Identifiers and keywords
        if is_letter(c) {
            let word = ""
            while i < len && (is_letter(chars[i]) || is_digit_char(chars[i])) {
                word = word + chars[i]
                i = i + 1
            }
            // Check keywords
            if word == "let" || word == "fn" || word == "if" || word == "else" ||
               word == "while" || word == "for" || word == "return" || word == "true" ||
               word == "false" || word == "break" || word == "continue" || word == "loop" {
                tokens = tokens.push("KW:" + word)
            } else {
                tokens = tokens.push("ID:" + word)
            }
            continue
        }

        // Strings
        if c == "\"" {
            let s = ""
            i = i + 1
            while i < len && chars[i] != "\"" {
                s = s + chars[i]
                i = i + 1
            }
            i = i + 1  // skip closing quote
            tokens = tokens.push("STR:" + s)
            continue
        }

        // Operators and punctuation
        if c == "=" && i + 1 < len && chars[i + 1] == "=" {
            tokens = tokens.push("OP:==")
            i = i + 2
            continue
        }
        if c == "!" && i + 1 < len && chars[i + 1] == "=" {
            tokens = tokens.push("OP:!=")
            i = i + 2
            continue
        }
        if c == "<" && i + 1 < len && chars[i + 1] == "=" {
            tokens = tokens.push("OP:<=")
            i = i + 2
            continue
        }
        if c == ">" && i + 1 < len && chars[i + 1] == "=" {
            tokens = tokens.push("OP:>=")
            i = i + 2
            continue
        }
        if c == "&" && i + 1 < len && chars[i + 1] == "&" {
            tokens = tokens.push("OP:&&")
            i = i + 2
            continue
        }
        if c == "|" && i + 1 < len && chars[i + 1] == "|" {
            tokens = tokens.push("OP:||")
            i = i + 2
            continue
        }
        if c == "-" && i + 1 < len && chars[i + 1] == ">" {
            tokens = tokens.push("OP:->")
            i = i + 2
            continue
        }

        // Single char operators
        if c == "+" || c == "-" || c == "*" || c == "/" || c == "%" ||
           c == "=" || c == "<" || c == ">" || c == "!" ||
           c == "(" || c == ")" || c == "{" || c == "}" ||
           c == "[" || c == "]" || c == "," || c == ":" || c == "." {
            tokens = tokens.push("OP:" + c)
            i = i + 1
            continue
        }

        // Unknown character
        tokens = tokens.push("UNK:" + c)
        i = i + 1
    }

    tokens
}

// Test: tokenize a simple program
let source = "fn add(a: int, b: int) -> int { return a + b }\nlet x = add(3, 4)\nprintln(x)"
let tokens = tokenize(source)

println("=== HEXA Self-Host Lexer ===")
println("Source: " + source)
println("Tokens: " + to_string(tokens.len()))
for t in tokens {
    println("  " + t)
}
