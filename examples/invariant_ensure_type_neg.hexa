// examples/invariant_ensure_type_neg.hexa — ensure_type negative case
//
//   ./hexa check examples/invariant_ensure_type_neg.hexa
//     → 0 violation + exit 0
//
// 아래 모든 `counter` occurrence 는 `Int` 로 일관 — 위반 없음.

@invariant {
    id: "I3",
    name: "counter_is_int",
    predicate: "ensure_type",
    pattern: { target: "counter", context: "Int" },
    exempt: []
}

fn increment(counter: Int) {
    return counter
}

fn consumer() {
    let counter: Int = 0
    return counter
}

consumer()
