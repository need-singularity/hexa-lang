// N1.1i: for-in range
let mut total = 0
for i in 1..11 {
    total += i
}
println("sum 1..10 =", total)

let mut sq = 0
for k in 1..6 {
    sq += k * k
}
println("sum k² (1..5) =", sq)

// 중첩
let mut cross = 0
for a in 1..4 {
    for b in 1..4 {
        cross += a * b
    }
}
println("nested cross =", cross)
println("done")
