// test_async.hexa — Async/await and concurrency tests
// Tests: async fn, await, spawn, channel, select

println("=== Async / Concurrency Tests ===")

// --- 1. Basic spawn with channel ---
let pair1 = channel()
let tx1 = pair1[0]
let rx1 = pair1[1]

spawn {
    tx1.send(42)
}
let v1 = rx1.recv()
println("spawn+channel basic:", v1)
assert v1 == 42

// --- 2. Multiple values through channel ---
let pair2 = channel()
let tx2 = pair2[0]
let rx2 = pair2[1]

spawn {
    tx2.send(10)
    tx2.send(20)
    tx2.send(30)
}
let a = rx2.recv()
let b = rx2.recv()
let c = rx2.recv()
println("multi-send:", a, b, c)
assert a + b + c == 60

// --- 3. Spawn computing a value ---
let pair3 = channel()
let tx3 = pair3[0]
let rx3 = pair3[1]

spawn {
    let mut sum = 0
    for i in 1..11 {
        sum = sum + i
    }
    tx3.send(sum)
}
let total = rx3.recv()
println("spawn compute sum(1..10):", total)
assert total == 55

// --- 4. Multiple spawns ---
let pair4a = channel()
let tx4a = pair4a[0]
let rx4a = pair4a[1]

let pair4b = channel()
let tx4b = pair4b[0]
let rx4b = pair4b[1]

spawn {
    tx4a.send(100)
}
spawn {
    tx4b.send(200)
}
let va = rx4a.recv()
let vb = rx4b.recv()
println("two spawns:", va, vb)
assert va + vb == 300

// --- 5. Spawn with captured variable ---
let multiplier = 7
let pair5 = channel()
let tx5 = pair5[0]
let rx5 = pair5[1]

spawn {
    tx5.send(6 * multiplier)
}
let v5 = rx5.recv()
println("spawn capture:", v5)
assert v5 == 42

// --- 6. Async fn declaration and await ---
async fn compute_async(x: int) -> int {
    return x * x
}

let future = compute_async(6)
let result = await future
println("async fn await:", result)
assert result == 36

// --- 7. Multiple async calls ---
async fn add_async(a: int, b: int) -> int {
    return a + b
}

let f1 = add_async(10, 20)
let f2 = add_async(30, 40)
let r1 = await f1
let r2 = await f2
println("multiple async:", r1, r2)
assert r1 == 30
assert r2 == 70

// --- 8. Spawn with loop and accumulation ---
let pair8 = channel()
let tx8 = pair8[0]
let rx8 = pair8[1]

spawn {
    let mut fib_a = 0
    let mut fib_b = 1
    for i in 0..10 {
        let tmp = fib_b
        fib_b = fib_a + fib_b
        fib_a = tmp
    }
    tx8.send(fib_a)
}
let fib10 = rx8.recv()
println("spawn fib(10):", fib10)
assert fib10 == 55

println("")
println("=== All async tests passed! ===")
