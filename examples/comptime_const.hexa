// ComptimeConst const-fold demo
//
// `comptime const X = expr` is folded at codegen time to a literal — every
// reference to X is inlined as the folded value (no runtime variable, no
// initialization in main).
//
// Expected output:
//   6.28
//   9
//   42
//   -7

comptime const TAU = 2 * 3.14
comptime const N = 8
comptime const ANSWER = 6 * 7
comptime const NEG = -(3 + 4)

println(TAU)
println(N + 1)
println(ANSWER)
println(NEG)
