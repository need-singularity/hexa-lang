// rt 32-L benchmark — fib(20) × K=30 = 437K recursive calls.
// Mirrors the pod measurement (v3=27.0s, RSS=855MB) so before/after
// numbers are directly comparable to the bottleneck registry.
fn fib(n: int) -> int {
    if n <= 1 {
        return n
    }
    return fib(n - 1) + fib(n - 2)
}

let mut sum = 0
for k in 0..30 {
    sum = sum + fib(20)
}
println("fib bench done, sum=", sum)
