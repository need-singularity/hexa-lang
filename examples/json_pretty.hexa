// json_pretty.hexa — JSON pretty-printer
// 사용: echo '{"a":1,"b":[2,3]}' | ./json_pretty

fn indent(depth) {
    let mut s = ""
    let mut i = 0
    while i < depth {
        s = s + "  "
        i = i + 1
    }
    return s
}

fn format_json(src: string) {
    let n = src.len()
    let mut out = ""
    let mut depth = 0
    let mut i = 0
    let mut in_str = 0
    let mut prev_bs = 0

    while i < n {
        let c = src.substring(i, i + 1)

        if in_str == 1 {
            out = out + c
            if c == "\\" && prev_bs == 0 {
                prev_bs = 1
            } else if c == "\"" && prev_bs == 0 {
                in_str = 0
                prev_bs = 0
            } else {
                prev_bs = 0
            }
            i = i + 1
            continue
        }

        // 공백 skip
        if c == " " || c == "\t" || c == "\n" || c == "\r" {
            i = i + 1
            continue
        }

        if c == "\"" {
            in_str = 1
            out = out + c
            i = i + 1
            continue
        }

        if c == "{" || c == "[" {
            out = out + c
            depth = depth + 1
            out = out + "\n" + indent(depth)
            i = i + 1
            continue
        }
        if c == "}" || c == "]" {
            depth = depth - 1
            out = out + "\n" + indent(depth) + c
            i = i + 1
            continue
        }
        if c == "," {
            out = out + ",\n" + indent(depth)
            i = i + 1
            continue
        }
        if c == ":" {
            out = out + ": "
            i = i + 1
            continue
        }
        out = out + c
        i = i + 1
    }
    return out
}

let input = read_stdin()
if input.len() == 0 {
    println("usage: echo '<json>' | json_pretty")
    exit(1)
}

let pretty = format_json(input)
println(pretty)
