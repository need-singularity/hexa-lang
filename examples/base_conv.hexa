// base_conv.hexa — 진수 변환기 (2/8/10/16)
// 사용: ./base_conv <n>  (10진 정수 입력)

let digits = "0123456789ABCDEF"

fn to_base(n, base) {
    if n == 0 {
        return "0"
    }
    let mut num = n
    let mut neg = 0
    if num < 0 {
        neg = 1
        num = 0 - num
    }
    let mut out = ""
    while num > 0 {
        let d = num % base
        out = digits.substring(d, d + 1) + out
        num = num / base
    }
    if neg == 1 {
        out = "-" + out
    }
    return out
}

fn from_base(s: string, base) {
    let mut result = 0
    let n = s.len()
    let mut start = 0
    let mut neg = 0
    if n > 0 {
        if s.substring(0, 1) == "-" {
            neg = 1
            start = 1
        }
    }
    let mut i = start
    while i < n {
        let c = s.substring(i, i + 1)
        let d = digits.index_of(c)
        if d >= 0 {
            if d < base {
                result = result * base + d
            }
        }
        i = i + 1
    }
    if neg == 1 {
        result = 0 - result
    }
    return result
}

if argc() < 2 {
    println("usage: base_conv <n>")
    exit(1)
}

let n = parse_int(arg(1))
println("n =", n)
println("bin (2)  =", to_base(n, 2))
println("oct (8)  =", to_base(n, 8))
println("dec (10) =", to_base(n, 10))
println("hex (16) =", to_base(n, 16))

// round-trip
let hex = to_base(n, 16)
let back = from_base(hex, 16)
println("")
println("round-trip: n =", n, "→ hex", hex, "→ dec", back, if back == n { "✓" } else { "✗" })
