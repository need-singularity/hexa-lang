// ══════════════════════════════════════════════════════════════════
// @memoize Performance Test — O(2^n) vs O(n)
// Demonstrates the AI-native compiler's algorithm-level optimization
// ══════════════════════════════════════════════════════════════════

println("=== @memoize Performance Comparison ===")
println("")

// ── Without @memoize: naive recursive fibonacci ────────────────
// fib(35) without memoize is O(2^35) ~ 34 billion operations
// Should take measurable time

fn naive_fib(n) {
    if n <= 1 { return n }
    return naive_fib(n - 1) + naive_fib(n - 2)
}

println("[1] naive_fib(35) — O(2^n), no caching...")
let t0 = clock()
let r1 = naive_fib(35)
let t1 = clock()
let naive_ms = (t1 - t0) * 1000.0
println("    result:", r1)
println("    time:", naive_ms, "ms")
println("")

// ── With @memoize: cached fibonacci ────────────────────────────
// fib(35) with memoize is O(35) = 35 operations
// Should be instant

@memoize fn memo_fib(n) {
    if n <= 1 { return n }
    return memo_fib(n - 1) + memo_fib(n - 2)
}

println("[2] memo_fib(35) — O(n), with @memoize...")
let t2 = clock()
let r2 = memo_fib(35)
let t3 = clock()
let memo_ms = (t3 - t2) * 1000.0
println("    result:", r2)
println("    time:", memo_ms, "ms")
println("")

// Verify same result
assert r1 == r2

// ── @memoize with larger N ─────────────────────────────────────
// fib(80) is impossible without memoize (2^80 ~ 10^24 ops)
// With memoize it's just 80 operations

println("[3] memo_fib(80) — impossible without memoize...")
let t4 = clock()
let r3 = memo_fib(80)
let t5 = clock()
let big_ms = (t5 - t4) * 1000.0
println("    result:", r3)
println("    time:", big_ms, "ms")
println("")

// ── Summary ────────────────────────────────────────────────────
println("═══════════════════════════════════════════")
println("Performance Summary:")
println("  naive fib(35):     ", naive_ms, "ms  O(2^n)")
println("  @memoize fib(35):  ", memo_ms, "ms  O(n)")
println("  @memoize fib(80):  ", big_ms, "ms  O(n)")
println("")

if naive_ms > 0.0 {
    if memo_ms > 0.0 {
        let speedup = naive_ms / memo_ms
        println("  @memoize speedup:  ~", round(speedup), "x faster")
    } else {
        println("  @memoize speedup:  instant (< 1us)")
    }
}
println("═══════════════════════════════════════════")
println("")
println("Traditional compiler: O(2^n) code -> O(2^n) machine code (faster 2^n)")
println("AI-native compiler:   O(2^n) code -> O(n) or O(log n) machine code")
println("The algorithm itself is replaced, not just optimized.")
