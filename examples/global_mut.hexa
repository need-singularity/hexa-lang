// 전역 mut 상태를 fn에서 R/W
let mut counter = 0
let mut history = []

fn bump() {
    counter = counter + 1
    history = history + [counter]
}

bump()
bump()
bump()
bump()
bump()

println("counter =", counter)
println("history len =", len(history))
let mut i = 0
while i < len(history) {
    println("history[", i, "] =", history[i])
    i = i + 1
}
println("done")
