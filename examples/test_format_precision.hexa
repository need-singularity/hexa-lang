// test_format_precision.hexa — format() with precision specifiers
// Tests: {}, {:.N} for floats and ints, multi-arg, edge cases

println("=== Format Precision Tests ===")

// --- 1. Basic format with {} ---
let s1 = format("x={}", 42)
println("basic int:", s1)
assert s1 == "x=42"

// --- 2. Multiple args ---
let s2 = format("{} + {} = {}", 1, 2, 3)
println("multi-arg:", s2)
assert s2 == "1 + 2 = 3"

// --- 3. Float with 2 decimal places ---
let pi = 3.14159265
let s3 = format("{:.2}", pi)
println("pi 2dp:", s3)
assert s3 == "3.14"

// --- 4. Float with 6 decimal places ---
let s4 = format("{:.6}", pi)
println("pi 6dp:", s4)
assert s4 == "3.141593"

// --- 5. Float with 0 decimal places ---
let s5 = format("{:.0}", pi)
println("pi 0dp:", s5)
assert s5 == "3"

// --- 6. Float with 1 decimal place ---
let s6 = format("{:.1}", 2.75)
println("2.75 1dp:", s6)
assert s6 == "2.8"

// --- 7. Int formatted as float precision ---
let s7 = format("{:.2}", 42)
println("int 42 as 2dp:", s7)
assert s7 == "42.00"

// --- 8. Negative float ---
let s8 = format("{:.3}", -1.23456)
println("negative 3dp:", s8)
assert s8 == "-1.235"

// --- 9. Zero ---
let s9 = format("{:.4}", 0.0)
println("zero 4dp:", s9)
assert s9 == "0.0000"

// --- 10. Mixed precision and plain ---
let s10 = format("val={:.2}, count={}", 3.14159, 10)
println("mixed:", s10)
assert s10 == "val=3.14, count=10"

// --- 11. String interpolation ---
let s11 = format("hello {}", "world")
println("string arg:", s11)
assert s11 == "hello world"

// --- 12. Large float ---
let s12 = format("{:.2}", 123456.789)
println("large float:", s12)
assert s12 == "123456.79"

// --- 13. Very small float ---
let s13 = format("{:.6}", 0.000001)
println("tiny float:", s13)
assert s13 == "0.000001"

// --- 14. Multiple precision specs ---
let s14 = format("{:.1} and {:.3}", 1.0, 2.0)
println("multi-prec:", s14)
assert s14 == "1.0 and 2.000"

// --- 15. Format in a loop ---
println("--- loop format ---")
for i in 0..5 {
    let f = to_float(i) * 0.1
    let s = format("{:.2}", f)
    println("  i=", i, "-> f=", s)
}

// --- 16. E constant precision ---
let e_str = format("{:.4}", E)
println("E 4dp:", e_str)
assert e_str == "2.7183"

// --- 17. PI constant precision ---
let pi_str = format("{:.10}", PI)
println("PI 10dp:", pi_str)

println("")
println("=== All format precision tests passed! ===")
