// P13 회귀 테스트 — Value::Error string-method fallback
// ossified_at: src/interpreter.rs:3790 (Value::Error match arm)
// 실행: hexa examples/test_p13_error_fallback.hexa
// 기대: ✅ 8건, ❌ 0건

let mut pass = 0
let mut fail = 0

fn assert_eq(label: string, got: any, want: any) {
    if to_string(got) == to_string(want) {
        println("✅ " + label)
        pass = pass + 1
    } else {
        println("❌ " + label + ": got=" + to_string(got) + " want=" + to_string(want))
        fail = fail + 1
    }
}

println("═══ P13 Value::Error fallback 회귀 테스트 ═══")
println("")

// ─── 1. exec("false").trim() == "" (B change — exec returns Str("") on failure)
let r1 = exec("false")
assert_eq("1. exec('false').trim() == ''", r1.trim(), "")

// ─── 2. read_file("/nonexistent").contains("x") == false
// read_file는 실패 시 Value::Error 반환 → P13 fallback 경로
let r2 = read_file("/nonexistent_file_for_p13_test_12345")
assert_eq("2. read_file(missing).contains('x') == false", r2.contains("x"), false)

// ─── 3. read_file(missing).to_string() 원본 에러 메시지 보존
let r3 = read_file("/nonexistent_file_for_p13_test_67890")
let msg = to_string(r3)
assert_eq("3. read_file(missing).to_string() contains 'No such file'",
          msg.contains("No such file") || msg.contains("os error") || msg.contains("error"),
          true)

// ─── 4. Error.to_lower() == "" + 경고는 1회만
let r4 = read_file("/nonexistent_for_lower_test_a")
assert_eq("4a. Error.to_lower() == ''", r4.to_lower(), "")
// 같은 method + 같은 msg prefix → 경고 억제 (silent 통과)
let r4b = read_file("/nonexistent_for_lower_test_a")
assert_eq("4b. Error.to_lower() 2회차도 ''", r4b.to_lower(), "")

// ─── 5. Error chaining 복합 — exec("cat missing 2>/dev/null").split("\n").len() == 1
// (exec는 Str("") 반환 → "".split("\n") == [""] → len 1)
let r5 = exec("cat /nonexistent_probe 2>/dev/null")
assert_eq("5. exec(missing 2>/dev/null).split('\\n').len() == 1",
          r5.split("\n").len(), 1)

// ─── 6. len()/is_empty() 정상 동작
let r6 = read_file("/nonexistent_for_len")
assert_eq("6a. Error.len() == 0", r6.len(), 0)
assert_eq("6b. Error.is_empty() == true", r6.is_empty(), true)

println("")
println("═══ 결과: " + to_string(pass) + " pass / " + to_string(fail) + " fail ═══")
if fail > 0 { exit(1) }
