// HEXA-IR 벤치마크 — fn main() 래핑, println 없이 return
// 6종 테스트: 소수체/피보나치/GCD/콜라츠/제곱근/해시

fn count_primes(limit: int) -> int {
    let count = 0
    let n = 2
    while n < limit {
        let is_prime = 1
        let d = 2
        while d * d <= n {
            if n % d == 0 {
                is_prime = 0
            }
            d = d + 1
        }
        count = count + is_prime
        n = n + 1
    }
    count
}

fn fib_iter(n: int) -> int {
    let a = 0
    let b = 1
    let i = 0
    while i < n {
        let t = a + b
        a = b
        b = t
        i = i + 1
    }
    a
}

fn gcd(a: int, b: int) -> int {
    let x = a
    let y = b
    while y != 0 {
        let t = y
        y = x % y
        x = t
    }
    x
}

fn collatz_steps(n: int) -> int {
    let steps = 0
    let v = n
    while v != 1 {
        if v % 2 == 0 {
            v = v / 2
        } else {
            v = v * 3 + 1
        }
        steps = steps + 1
    }
    steps
}

fn isqrt(n: int) -> int {
    if n < 2 {
        return n
    }
    let x = n
    let y = (x + 1) / 2
    while y < x {
        x = y
        y = (x + n / x) / 2
    }
    x
}

fn main() -> int {
    let iterations = 10000
    let result = 0

    // [1] count_primes(100) = 25
    let i = 0
    while i < iterations {
        result = result + count_primes(100)
        i = i + 1
    }

    // [2] fib(30) = 832040
    i = 0
    while i < iterations {
        result = result + fib_iter(30)
        i = i + 1
    }

    // [3] gcd(48,18) = 6
    i = 0
    while i < iterations * 10 {
        result = result + gcd(48, 18)
        i = i + 1
    }

    // [4] collatz(27) = 111
    i = 0
    while i < iterations {
        result = result + collatz_steps(27)
        i = i + 1
    }

    // [5] isqrt(1000000) = 1000
    i = 0
    while i < iterations * 10 {
        result = result + isqrt(1000000)
        i = i + 1
    }

    result
}
