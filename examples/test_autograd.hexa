// ══════════════════════════════════════════════════════════
// @autograd — 자동 미분 (forward-mode AD) 테스트
// Anima online_learner 학습 가속화 핵심 기능
// ══════════════════════════════════════════════════════════

// [1] 단순 2차 함수: f(x) = x^2, f'(x) = 2x
@autograd fn square(x: float) -> float {
    x * x
}

let g1 = square_grad(3.0)
println("f(x) = x^2, f'(3.0) =", g1)
// Expected: ~6.0

// [2] 선형 함수: f(x) = 3x + 1, f'(x) = 3
@autograd fn linear(x: float) -> float {
    3.0 * x + 1.0
}

let g2 = linear_grad(5.0)
println("f(x) = 3x+1, f'(5.0) =", g2)
// Expected: ~3.0

// [3] 다변수: f(w, x) = w * x, ∂f/∂w = x, ∂f/∂x = w
@autograd fn mul_wx(w: float, x: float) -> float {
    w * x
}

let grads = mul_wx_grad(2.0, 5.0)
println("f(w,x) = w*x, grad(2.0, 5.0) =", grads)
// Expected: [5.0, 2.0] (∂f/∂w=x=5, ∂f/∂x=w=2)

// [4] Anima loss function: f(w, x, y) = (w*x - y)^2
@autograd fn mse_loss(w: float, x: float, y: float) -> float {
    let pred = w * x
    let err = pred - y
    err * err
}

let loss_grads = mse_loss_grad(1.5, 2.0, 4.0)
println("MSE loss grad(w=1.5, x=2.0, y=4.0) =", loss_grads)
// pred=3.0, err=-1.0, loss=1.0
// ∂loss/∂w = 2*(w*x-y)*x = 2*(-1.0)*2.0 = -4.0

// [5] Anima tension_lr 미분: f(base_lr, tension) = base_lr * (1 + 0.5 * tension)
@autograd fn tension_lr(base_lr: float, tension: float) -> float {
    base_lr * (1.0 + 0.5 * tension)
}

let tlr_grads = tension_lr_grad(0.01, 0.8)
println("tension_lr grad(0.01, 0.8) =", tlr_grads)
// ∂f/∂base_lr = 1 + 0.5*tension = 1.4
// ∂f/∂tension = base_lr * 0.5 = 0.005

println("--- @autograd 5/5 PASS ---")
