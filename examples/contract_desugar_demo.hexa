// @contract Option A (parser desugar) phase 1 demo
// - requires → 함수 진입 시 assert 로 prepend
// - ensures  → 함수 body 끝에 assert 로 append (phase 1 단순화)
// 주의: 이른 return 이 있으면 ensures 체크는 누락됨 (phase 2 에서 해결 예정)

@contract(requires: x > 0, ensures: x + 1 > 1)
fn inc_positive(x: Int) -> Int {
    return x + 1
}

fn main() {
    let r = inc_positive(3)
    print(r)
}
