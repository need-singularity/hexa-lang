// stats.hexa — 통계 도구: mean / median / stddev / min / max
// 사용: echo "1 2 3 4 5" | ./stats

let mut raw = ""
if argc() >= 2 {
    raw = read_file(arg(1))
} else {
    raw = read_stdin()
}

if raw.len() == 0 {
    println("(no input)")
    exit(1)
}

// 파싱
let mut nums = []
let cs = raw.chars()
let n = len(cs)
let mut i = 0
let mut cur = ""
while i < n {
    let c = raw.substring(i, i + 1)
    if c == " " || c == "\t" || c == "\n" || c == "\r" || c == "," {
        if cur.len() > 0 {
            nums = nums + [parse_int(cur)]
            cur = ""
        }
    } else {
        cur = cur + c
    }
    i = i + 1
}
if cur.len() > 0 {
    nums = nums + [parse_int(cur)]
}

let total = len(nums)
if total == 0 {
    println("(no numbers)")
    exit(1)
}

// min/max/sum/mean
let mut lo = nums[0]
let mut hi = nums[0]
let mut sum = 0
let mut k = 0
while k < total {
    let v = nums[k]
    if v < lo { lo = v }
    if v > hi { hi = v }
    sum = sum + v
    k = k + 1
}
let mean_x100 = (sum * 100) / total  // 2자리 소수

// 정렬 → median (qsort in-place via copy)
let mut sorted_arr = array_fill(total, 0)
let mut ci = 0
while ci < total {
    sorted_arr[ci] = nums[ci]
    ci = ci + 1
}
// bubble sort (간단)
let mut bi = 0
while bi < total {
    let mut bj = 0
    while bj < total - bi - 1 {
        if sorted_arr[bj] > sorted_arr[bj + 1] {
            let t = sorted_arr[bj]
            sorted_arr[bj] = sorted_arr[bj + 1]
            sorted_arr[bj + 1] = t
        }
        bj = bj + 1
    }
    bi = bi + 1
}

let median = sorted_arr[total / 2]

// variance/stddev (x100 스케일)
let mut var_sum = 0
let mut vi = 0
while vi < total {
    let diff = nums[vi] * 100 - mean_x100
    var_sum = var_sum + (diff * diff)
    vi = vi + 1
}
let variance_x10000 = var_sum / total  // 이미 x10000 스케일
let mut stddev_x100 = 0
// sqrt via Newton method (x10000 variance → x100 stddev)
let mut s = variance_x10000 / 2
if s > 0 {
    let mut iters = 0
    while iters < 20 {
        if s == 0 { iters = 20 } else {
            s = (s + variance_x10000 / s) / 2
            iters = iters + 1
        }
    }
}
stddev_x100 = s

println("=== stats ===")
println("n      :", total)
println("min    :", lo)
println("max    :", hi)
println("sum    :", sum)
println("mean   :", mean_x100 / 100, ".", mean_x100 % 100)
println("median :", median)
println("stddev :", stddev_x100 / 100, ".", stddev_x100 % 100)
println("done")
