// test_http_server.hexa — basic HTTP server test
// Starts on port 9999, responds with "Hello from Hexa!" to any request.
// Stops when it receives a request to /stop.

fn handler(req) {
    let path = req.path
    if path == "/stop" {
        return "__stop__"
    }
    return "Hello from Hexa!"
}

println("Starting HTTP server on 127.0.0.1:9999...")
http_serve("127.0.0.1:9999", handler)
println("Server stopped.")
