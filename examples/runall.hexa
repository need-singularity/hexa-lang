// runall — hexa self-host 데모 전체 빌드/실행 러너
// 사용: ./runall

let targets = ["hello_min", "calc_min", "fizzbuzz_min", "factorial_min", "array_sum", "sieve_min", "struct_min", "float_min", "forin_min", "match_min", "dynarr_min", "method_min", "strcat_min", "strops_min", "strarr_min", "split_min", "strmethods_min", "mini_transpiler", "physics"]

let mut passed = 0
let mut failed = 0

println("═══════════════════════════════════════")
println("  hexa self-host 전체 실행 러너")
println("═══════════════════════════════════════")

for name in targets {
    let bin = "./build/" + name
    let rc_str = exec("test -x " + bin + " && echo yes || echo no")
    if rc_str == "yes" {
        let out = exec(bin + " 2>&1 | head -1")
        println("✓", name, "→", out)
        passed = passed + 1
    } else {
        println("✗", name, "(not built)")
        failed = failed + 1
    }
}

println("═══════════════════════════════════════")
println("  PASS:", passed, "  FAIL:", failed)
println("═══════════════════════════════════════")
