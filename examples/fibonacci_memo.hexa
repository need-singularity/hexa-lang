// fibonacci_memo.hexa — Fibonacci with @memoize: O(2^n) -> O(n)
// Demonstrates AI-native algorithm replacement via @memoize attribute

println("=== Fibonacci with @memoize ===")
println("")

// ── Naive recursive fibonacci (exponential time) ───────────
fn naive_fib(n: int) -> int {
    if n <= 1 { return n }
    return naive_fib(n - 1) + naive_fib(n - 2)
}

// ── Memoized fibonacci (linear time) ───────────────────────
@memoize fn memo_fib(n: int) -> int {
    if n <= 1 { return n }
    return memo_fib(n - 1) + memo_fib(n - 2)
}

// ── Print first 20 fibonacci numbers ───────────────────────
println("First 20 Fibonacci numbers:")
for i in 0..20 {
    let val = memo_fib(i)
    println("  fib(", i, ") =", val)
}
println("")

// ── Performance comparison ─────────────────────────────────
// naive_fib(35) is O(2^35) ~ billions of calls
// memo_fib(35) is O(35) = 35 lookups

println("--- Performance Comparison ---")
println("")

println("[Naive] Computing fib(35) without memoization...")
let t0 = clock()
let r_naive = naive_fib(35)
let t1 = clock()
let naive_ms = (t1 - t0) * 1000.0
println("  fib(35) =", r_naive)
println("  Time:", naive_ms, "ms")
println("")

println("[@memoize] Computing fib(35) with memoization...")
let t2 = clock()
let r_memo = memo_fib(35)
let t3 = clock()
let memo_ms = (t3 - t2) * 1000.0
println("  fib(35) =", r_memo)
println("  Time:", memo_ms, "ms")
println("")

// Verify correctness
assert r_naive == r_memo

// Show the dramatic difference
println("[@memoize] Computing fib(70) — impossible without memoize...")
let t4 = clock()
let r_big = memo_fib(70)
let t5 = clock()
let big_ms = (t5 - t4) * 1000.0
println("  fib(70) =", r_big)
println("  Time:", big_ms, "ms")
println("")

// ── Summary ────────────────────────────────────────────────
println("=========================================")
println("Summary:")
println("  naive fib(35):    ", naive_ms, "ms")
println("  @memoize fib(35): ", memo_ms, "ms")
println("  @memoize fib(70): ", big_ms, "ms")
if naive_ms > 0.0 {
    if memo_ms > 0.0 {
        let speedup = naive_ms / memo_ms
        println("  Speedup: ~", round(speedup), "x")
    } else {
        println("  Speedup: instant (< 1us)")
    }
}
println("=========================================")
println("")
println("The AI-native compiler replaces the algorithm itself,")
println("not just the machine code. O(2^n) -> O(n).")
