// ══════════════════════════════════════════════════════════════════
// AI-Native @attr E2E Tests — All 13+ Attribute Types
// Tests every attr in the Hexa AI-native system (docs/ai-native.md)
// ══════════════════════════════════════════════════════════════════

let mut passed = 0
let mut failed = 0
let total = 26

fn check(name, got, expected) {
    if got == expected {
        println("  PASS:", name, "->", got)
        passed = passed + 1
    } else {
        println("  FAIL:", name, "-> got", got, "expected", expected)
        failed = failed + 1
    }
}

fn check_approx(name, got, expected, eps) {
    let diff = got - expected
    if diff < 0.0 { diff = -diff }
    if diff < eps {
        println("  PASS:", name, "->", got, "(~=", expected, ")")
        passed = passed + 1
    } else {
        println("  FAIL:", name, "-> got", got, "expected ~=", expected)
        failed = failed + 1
    }
}

// ══════════════════════════════════════════════════════════════════
// [1] @pure — No side effects, function works normally
// ══════════════════════════════════════════════════════════════════
println("=== [1] @pure ===")

@pure fn add(a, b) { return a + b }
@pure fn mul(a, b) { return a * b }
@pure fn identity(x) { return x }

check("pure add(2,3)", add(2, 3), 5)
check("pure mul(4,5)", mul(4, 5), 20)
check("pure identity(42)", identity(42), 42)

// ══════════════════════════════════════════════════════════════════
// [2] @memoize — Automatic result caching (O(2^n) -> O(n))
// ══════════════════════════════════════════════════════════════════
println("")
println("=== [2] @memoize ===")

@memoize fn fib(n) {
    if n <= 1 { return n }
    return fib(n - 1) + fib(n - 2)
}

check("memoize fib(0)", fib(0), 0)
check("memoize fib(1)", fib(1), 1)
check("memoize fib(10)", fib(10), 55)
check("memoize fib(30)", fib(30), 832040)
// fib(45) would take ~7 seconds without memoize, instant with it
check("memoize fib(45)", fib(45), 1134903170)

// ══════════════════════════════════════════════════════════════════
// [3] @optimize — Algorithm replacement (recurrence -> matrix exp)
//     O(2^n) -> O(log n) via matrix exponentiation
// ══════════════════════════════════════════════════════════════════
println("")
println("=== [3] @optimize ===")

@optimize fn opt_fib(n) {
    if n <= 1 { return n }
    return opt_fib(n - 1) + opt_fib(n - 2)
}

check("optimize fib(10)", opt_fib(10), 55)
check("optimize fib(45)", opt_fib(45), 1134903170)
// fib(90) = 2880067194370816120 — only possible with O(log n)
check("optimize fib(90)", opt_fib(90), 2880067194370816120)

// Pell numbers: P(n) = 2*P(n-1) + P(n-2)
@optimize fn pell(n) {
    if n <= 1 { return n }
    return 2 * pell(n - 1) + pell(n - 2)
}

check("optimize pell(10)", pell(10), 2378)

// ══════════════════════════════════════════════════════════════════
// [4] @evolve — Self-modifying function registration
// ══════════════════════════════════════════════════════════════════
println("")
println("=== [4] @evolve ===")

@evolve fn morph(x) {
    return x * 3
}

check("evolve morph(7)", morph(7), 21)

// ══════════════════════════════════════════════════════════════════
// [5] @inline — Inline hint (function works normally)
// ══════════════════════════════════════════════════════════════════
println("")
println("=== [5] @inline ===")

@inline fn square(x) { return x * x }

check("inline square(7)", square(7), 49)

// ══════════════════════════════════════════════════════════════════
// [6] @hot — Hot path hint
// ══════════════════════════════════════════════════════════════════
println("")
println("=== [6] @hot ===")

@hot fn hot_sum(a, b) { return a + b }

check("hot hot_sum(100, 200)", hot_sum(100, 200), 300)

// ══════════════════════════════════════════════════════════════════
// [7] @cold — Cold path hint
// ══════════════════════════════════════════════════════════════════
println("")
println("=== [7] @cold ===")

@cold fn cold_error(code) { return code * -1 }

check("cold cold_error(404)", cold_error(404), -404)

// ══════════════════════════════════════════════════════════════════
// [8] @simd — Vectorization hint
// ══════════════════════════════════════════════════════════════════
println("")
println("=== [8] @simd ===")

@simd fn vec_dot(a, b) { return a * b }

check("simd vec_dot(3, 4)", vec_dot(3, 4), 12)

// ══════════════════════════════════════════════════════════════════
// [9] @parallel — Parallelization hint
// ══════════════════════════════════════════════════════════════════
println("")
println("=== [9] @parallel ===")

@parallel fn par_square(x) { return x * x }

check("parallel par_square(9)", par_square(9), 81)

// ══════════════════════════════════════════════════════════════════
// [10] @bounded(N) — Loop bound hint
// ══════════════════════════════════════════════════════════════════
println("")
println("=== [10] @bounded ===")

@bounded(1000) fn bounded_sum(n) {
    let mut s = 0
    let mut i = 0
    while i < n {
        s = s + i
        i = i + 1
    }
    return s
}

check("bounded sum(10)", bounded_sum(10), 45)
check("bounded sum(100)", bounded_sum(100), 4950)

// ══════════════════════════════════════════════════════════════════
// [11] @autograd — Automatic differentiation (numerical)
//      f_grad(x) returns derivative via finite differences
// ══════════════════════════════════════════════════════════════════
println("")
println("=== [11] @autograd ===")

@autograd fn f_square(x: float) -> float {
    x * x
}

// f(x) = x^2, f'(x) = 2x, so f'(3.0) ~ 6.0
let grad_val = f_square_grad(3.0)
check_approx("autograd f'(3.0) = 2x = 6.0", grad_val, 6.0, 0.001)

@autograd fn f_linear(x: float) -> float {
    5.0 * x + 3.0
}

// f(x) = 5x + 3, f'(x) = 5
let grad_lin = f_linear_grad(10.0)
check_approx("autograd f'(10.0) = 5", grad_lin, 5.0, 0.001)

// ══════════════════════════════════════════════════════════════════
// [12] @vectorize — Scalar fn auto-lifted to array ops
// ══════════════════════════════════════════════════════════════════
println("")
println("=== [12] @vectorize ===")

@vectorize fn dbl(x) { return x * 2 }

// Scalar mode
check("vectorize dbl(5)", dbl(5), 10)

// Array mode — auto-lifts to element-wise
let arr = [10, 20, 30]
let result = dbl(arr)
check("vectorize dbl([10,20,30])[0]", result[0], 20)
check("vectorize dbl([10,20,30])[1]", result[1], 40)
check("vectorize dbl([10,20,30])[2]", result[2], 60)

// ══════════════════════════════════════════════════════════════════
// [13] @lazy — Deferred evaluation (thunk)
//      Returns a zero-arg closure; call it to evaluate
// ══════════════════════════════════════════════════════════════════
println("")
println("=== [13] @lazy ===")

@lazy fn cube(x) {
    return x * x * x
}

let thunk = cube(5)
// thunk is a function, call it to get the value
let val = thunk()
check("lazy cube(5)() = 125", val, 125)

@lazy fn lazy_add(a, b) {
    return a + b
}
let thunk2 = lazy_add(10, 20)
check("lazy lazy_add(10,20)() = 30", thunk2(), 30)

// ══════════════════════════════════════════════════════════════════
// [14] @deprecated("msg") — Deprecation marker (parses, no warning)
// ══════════════════════════════════════════════════════════════════
println("")
println("=== [14] @deprecated ===")

@deprecated("use new_calc instead") fn old_calc(x) {
    return x + 1
}

check("deprecated old_calc(9)", old_calc(9), 10)

// ══════════════════════════════════════════════════════════════════
// Multi-attr combinations
// ══════════════════════════════════════════════════════════════════
println("")
println("=== Multi-attr combinations ===")

@pure @inline fn fast_add(a, b) { return a + b }
check("pure+inline fast_add(7,8)", fast_add(7, 8), 15)

@pure @memoize fn memo_factorial(n) {
    if n <= 1 { return 1 }
    return n * memo_factorial(n - 1)
}
check("pure+memoize factorial(10)", memo_factorial(10), 3628800)

