// sieve_era.hexa — Sieve of Eratosthenes (대규모 배열 + 인덱스 할당)
// 사용: ./sieve_era [limit]  (기본 1000)

let mut limit = 1000
if argc() >= 2 {
    limit = parse_int(arg(1))
}

// sieve 배열 — 0=소수, 1=합성수 (array_fill로 O(n) 할당)
let mut sieve = array_fill(limit + 1, 0)

sieve[0] = 1
sieve[1] = 1

let mut i = 2
while i * i <= limit {
    if sieve[i] == 0 {
        let mut j = i * i
        while j <= limit {
            sieve[j] = 1
            j = j + i
        }
    }
    i = i + 1
}

// 결과
let mut primes_count = 0
let mut sum_primes = 0
let mut k = 2
while k <= limit {
    if sieve[k] == 0 {
        primes_count = primes_count + 1
        sum_primes = sum_primes + k
    }
    k = k + 1
}

println("Sieve of Eratosthenes up to", limit)
println("─────────────")
println("primes found:", primes_count)
println("sum of primes:", sum_primes)

// 처음 20 + 마지막 10 표시
if primes_count <= 30 {
    let mut idx = 0
    let mut line = ""
    let mut n = 2
    while n <= limit {
        if sieve[n] == 0 {
            line = line + to_string(n) + " "
            idx = idx + 1
            if idx % 10 == 0 {
                println(line)
                line = ""
            }
        }
        n = n + 1
    }
    if line.len() > 0 {
        println(line)
    }
}
println("done")
