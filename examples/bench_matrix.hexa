// bench_matrix — 컴파일러 성능 증명용 벤치마크

fn fib(n) {
    if n < 2 {
        return n
    }
    return fib(n - 1) + fib(n - 2)
}

fn is_prime(n) {
    if n < 2 { return 0 }
    if n == 2 { return 1 }
    if n % 2 == 0 { return 0 }
    let mut i = 3
    while i * i <= n {
        if n % i == 0 { return 0 }
        i = i + 2
    }
    return 1
}

let t0 = clock()
let r = fib(30)
let t1 = clock()
println("fib(30) =", r, " time =", t1 - t0, "s")

let t2 = clock()
let mut s = 0
let mut i = 0
while i < 10000000 {
    s = s + i
    i = i + 1
}
let t3 = clock()
println("sum 1..10M =", s, " time =", t3 - t2, "s")

let t4 = clock()
let mut count = 0
let mut k = 2
while k <= 200000 {
    if is_prime(k) == 1 { count = count + 1 }
    k = k + 1
}
let t5 = clock()
println("primes <= 200k =", count, " time =", t5 - t4, "s")

let t6 = clock()
let mut ss = 0.0
let mut j = 1
while j < 1000000 {
    ss = ss + sqrt(j * 1.0)
    j = j + 1
}
let t7 = clock()
println("sum sqrt(1..1M) =", ss, " time =", t7 - t6, "s")
println("done")
