// calc.hexa — 간이 expression 파서 + 평가기 (+ - * / 괄호)
// 사용: ./calc "1 + 2 * (3 + 4)"

let mut pos = 0
let mut src = ""

fn skip_ws() {
    while pos < src.len() {
        let c = src.substring(pos, pos + 1)
        if c == " " || c == "\t" {
            pos = pos + 1
        } else {
            return 0
        }
    }
    return 0
}

fn parse_num() {
    skip_ws()
    let mut n = 0
    let mut started = 0
    while pos < src.len() {
        let c = src.substring(pos, pos + 1)
        if c >= "0" {
            if c <= "9" {
                n = n * 10 + parse_int(c)
                pos = pos + 1
                started = 1
            } else {
                return n
            }
        } else {
            return n
        }
    }
    return n
}

fn parse_expr() {
    let mut left = parse_term()
    skip_ws()
    while pos < src.len() {
        let c = src.substring(pos, pos + 1)
        if c == "+" {
            pos = pos + 1
            left = left + parse_term()
        } else if c == "-" {
            pos = pos + 1
            left = left - parse_term()
        } else {
            return left
        }
        skip_ws()
    }
    return left
}

fn parse_term() {
    let mut left = parse_factor()
    skip_ws()
    while pos < src.len() {
        let c = src.substring(pos, pos + 1)
        if c == "*" {
            pos = pos + 1
            left = left * parse_factor()
        } else if c == "/" {
            pos = pos + 1
            left = left / parse_factor()
        } else {
            return left
        }
        skip_ws()
    }
    return left
}

fn parse_factor() {
    skip_ws()
    if pos >= src.len() {
        return 0
    }
    let c = src.substring(pos, pos + 1)
    if c == "(" {
        pos = pos + 1
        let v = parse_expr()
        skip_ws()
        if pos < src.len() {
            if src.substring(pos, pos + 1) == ")" {
                pos = pos + 1
            }
        }
        return v
    }
    if c == "-" {
        pos = pos + 1
        return 0 - parse_factor()
    }
    return parse_num()
}

if argc() < 2 {
    println("usage: calc <expression>")
    exit(1)
}

src = arg(1)
pos = 0
let result = parse_expr()
println(src, "=", result)
