// N1.2 Test: struct + break/continue
// Target: self-host C transpiler codegen_c2.hexa

struct Point {
    x: int,
    y: int
}

fn distance_sq(p: Point) -> int {
    return p.x * p.x + p.y * p.y
}

let p = Point { x: 3, y: 4 }
println(p.x)
println(p.y)
println(distance_sq(p))

// Sum 1..10
let mut sum = 0
let mut i = 1
while i <= 10 {
    sum = sum + i
    i = i + 1
}
println(sum)

// Break
let mut found = -1
let mut j = 0
while j < 100 {
    if j * j > 50 {
        found = j
        break
    }
    j = j + 1
}
println(found)

// Continue
let mut even_sum = 0
let mut k = 0
while k < 10 {
    k = k + 1
    if k % 2 != 0 {
        continue
    }
    even_sum = even_sum + k
}
println(even_sum)
