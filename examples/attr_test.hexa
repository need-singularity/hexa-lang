// @test 검증 — 자동 수집/실행/리포트
fn add(a, b) { return a + b }
fn mul(a, b) { return a * b }

@test
fn test_add() {
    if add(2, 3) != 5 { return 1 }
    if add(-1, 1) != 0 { return 1 }
    return 0
}

@test
fn test_mul() {
    if mul(3, 4) != 12 { return 1 }
    if mul(0, 99) != 0 { return 1 }
    return 0
}

@test
fn test_fail_demo() {
    return 42
}

println("done")
