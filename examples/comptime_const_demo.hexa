// ComptimeConst const-fold demo — extended operator coverage.
//
// `comptime const X = expr` is folded at codegen time. Every reference to
// X gets inlined as the folded literal value — no runtime variable, no
// main() initialization.
//
// Each block below demonstrates one family of folds added on top of the
// base evaluator (IntLit/FloatLit/StringLit/BoolLit/Ident/UnaryOp-/BinOp
// arithmetic). Expected output is noted inline.

// ── (1) BinOp comparison — int ──
comptime const CMP_LT = 3 < 5           // true
comptime const CMP_EQ = 7 == 7          // true
comptime const CMP_NE = 7 != 8          // true
comptime const CMP_GE = 9 >= 9          // true
comptime const CMP_LE = 2 <= 1          // false
comptime const CMP_GT = 4 > 10          // false

// ── (2) BinOp comparison — float ──
comptime const CMP_FLT  = 3.14 < 3.15    // true
comptime const CMP_FGE  = 3.0 >= 3.0     // true
comptime const CMP_FNE  = 2.0 != 3.0     // true

// ── (3) BinOp comparison — string (== / !=) ──
comptime const CMP_STR_EQ = "foo" == "foo"   // true
comptime const CMP_STR_NE = "foo" != "bar"   // true

// ── (4) BinOp comparison — bool (== / !=) ──
comptime const CMP_BOOL_EQ = true == true    // true
comptime const CMP_BOOL_NE = true != false   // true

// ── (5) BinOp logical && — short-circuit ──
comptime const AND_TT = true && true          // true
comptime const AND_TF = true && false         // false
comptime const AND_FX = false && true         // false (short-circuit LHS false)

// ── (6) BinOp logical || — short-circuit ──
comptime const OR_TX = true || false          // true (short-circuit LHS true)
comptime const OR_FF = false || false         // false
comptime const OR_FT = false || true          // true

// ── (7) UnaryOp ! on bool const ──
comptime const NOT_T = !true                  // false
comptime const NOT_F = !false                 // true
comptime const NOT_CHAIN = !!true             // true (nested)

// ── (8) BinOp + on strings — concat ──
comptime const HELLO = "hello" + " " + "world"    // "hello world"
comptime const PREFIX = "hx" + "-lang"            // "hx-lang"

// ── (9) Ternary via IfExpr (c ? a : b) with const cond ──
comptime const TERNARY_INT = if true  { 42 } else { 0 }     // 42
comptime const TERNARY_NEG = if false { 100 } else { -5 }   // -5

// ── (10) Cross-referencing const chain exercising multiple folds ──
comptime const BASE = 10
comptime const DOUBLED = BASE * 2               // 20
comptime const GATE = DOUBLED > 15              // true
comptime const PICK = if GATE { "big" } else { "small" }    // "big"

// ── Output ──
println(CMP_LT)       ; println(CMP_EQ)   ; println(CMP_NE)
println(CMP_GE)       ; println(CMP_LE)   ; println(CMP_GT)
println(CMP_FLT)      ; println(CMP_FGE)  ; println(CMP_FNE)
println(CMP_STR_EQ)   ; println(CMP_STR_NE)
println(CMP_BOOL_EQ)  ; println(CMP_BOOL_NE)
println(AND_TT)       ; println(AND_TF)   ; println(AND_FX)
println(OR_TX)        ; println(OR_FF)    ; println(OR_FT)
println(NOT_T)        ; println(NOT_F)    ; println(NOT_CHAIN)
println(HELLO)        ; println(PREFIX)
println(TERNARY_INT)  ; println(TERNARY_NEG)
println(DOUBLED)      ; println(GATE)     ; println(PICK)
