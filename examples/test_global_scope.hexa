// test_global_scope.hexa — Global scope access tests (B-28)
// Tests: fn accessing top-level let, global mut, while loops with globals

println("=== Global Scope Tests ===")

// --- 1. Function accessing global let ---
let MAGIC = 42

fn get_magic() -> int {
    return MAGIC
}
println("global let:", get_magic())
assert get_magic() == 42

// --- 2. Global mutable variable ---
let mut counter = 0

fn increment() {
    counter = counter + 1
}
increment()
increment()
increment()
println("counter after 3 increments:", counter)
assert counter == 3

// --- 3. Global in while loop ---
let mut total = 0
let mut i = 1
while i <= 10 {
    total = total + i
    i = i + 1
}
println("sum 1..10:", total)
assert total == 55

// --- 4. Function reading and writing globals ---
let mut state = "init"

fn update_state(new_state: str) {
    state = new_state
}

fn get_state() -> str {
    return state
}

update_state("running")
println("state:", get_state())
assert get_state() == "running"

update_state("done")
println("state:", get_state())
assert get_state() == "done"

// --- 5. Multiple globals used together ---
let RATE = 0.1
let mut balance = 1000.0

fn apply_interest() {
    balance = balance + balance * RATE
}

apply_interest()
println("balance after 1 interest:", balance)
apply_interest()
println("balance after 2 interest:", balance)

// --- 6. Global array modified by function ---
let mut log = []

fn log_event(msg: str) {
    log = log.push(msg)
}

log_event("start")
log_event("process")
log_event("end")
println("log:", log)
assert log.len() == 3
assert log[0] == "start"
assert log[2] == "end"

// --- 7. Nested function calls all using globals ---
let mut accumulator = 0

fn add_to_acc(n: int) {
    accumulator = accumulator + n
}

fn add_range(start: int, end_val: int) {
    let mut j = start
    while j < end_val {
        add_to_acc(j)
        j = j + 1
    }
}

add_range(1, 6)
println("accumulator 1..5:", accumulator)
assert accumulator == 15

// --- 8. Global used in conditional ---
let THRESHOLD = 50

fn classify(x: int) -> str {
    if x > THRESHOLD {
        return "high"
    }
    return "low"
}

println("classify(30):", classify(30))
println("classify(80):", classify(80))
assert classify(30) == "low"
assert classify(80) == "high"

// --- 9. Global mut in for loop ---
let mut sum_squares = 0
for k in 1..11 {
    sum_squares = sum_squares + k * k
}
println("sum of squares 1..10:", sum_squares)
assert sum_squares == 385

// --- 10. Global with complex while loop ---
let mut fib_a = 0
let mut fib_b = 1
let mut fib_count = 0
while fib_count < 10 {
    let tmp = fib_b
    fib_b = fib_a + fib_b
    fib_a = tmp
    fib_count = fib_count + 1
}
println("fib(10) via globals:", fib_a)
assert fib_a == 55

// --- 11. Function modifying global and returning value ---
let mut call_count = 0

fn tracked_add(a: int, b: int) -> int {
    call_count = call_count + 1
    return a + b
}

let r1 = tracked_add(3, 4)
let r2 = tracked_add(10, 20)
let r3 = tracked_add(100, 200)
println("tracked results:", r1, r2, r3, "calls:", call_count)
assert call_count == 3
assert r1 == 7
assert r2 == 30
assert r3 == 300

// --- 12. Global constants used in computation ---
let WIDTH = 6
let HEIGHT = 6

fn area() -> int {
    return WIDTH * HEIGHT
}

fn perimeter() -> int {
    return 2 * (WIDTH + HEIGHT)
}

println("area:", area())
println("perimeter:", perimeter())
assert area() == 36
assert perimeter() == 24

println("")
println("=== All global scope tests passed! ===")
