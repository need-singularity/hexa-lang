// N1.1t: trim/to_upper/to_lower/parse_int
let s = "   hello WORLD  "
println("orig     =[", s, "]")
println("trim     =[", s.trim(), "]")
println("upper    =[", s.to_upper(), "]")
println("lower    =[", s.to_lower(), "]")
println("trim+up  =[", s.trim().to_upper(), "]")

println("parse_int('42')     =", parse_int("42"))
println("parse_int('-17')    =", parse_int("-17"))
println("parse_int('  99  ') =", parse_int("  99  "))
println("parse_int('abc')    =", parse_int("abc"))
println("done")
