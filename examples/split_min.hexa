// N1.1q: split 메서드
let csv = "apple,banana,cherry,date,elderberry"
let parts = csv.split(",")
println("parts len =", len(parts))
let mut i = 0
while i < len(parts) {
    println(i, ":", parts[i])
    i = i + 1
}

// 줄 단위
let text = "line1\nline2\nline3"
let lines = text.split("\n")
println("lines =", len(lines))
let mut j = 0
while j < len(lines) {
    println("  [", j, "]", lines[j])
    j = j + 1
}
println("done")
