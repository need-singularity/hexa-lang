// wc — 줄/단어/바이트 카운트 (hexa로 작성한 실전 CLI 도구)
// 사용: ./wc <file>

fn main_wc() {
    if argc() < 2 {
        println("usage: wc <file>")
        return 0
    }
    let path = arg(1)
    let content = read_file(path)
    let cs = content.chars()
    let n = len(cs)

    let mut lines = 0
    let mut words = 0
    let mut in_word = 0
    let mut i = 0
    while i < n {
        let c = cs[i]
        let mut is_sep = 0
        if c == 32 {
            is_sep = 1
        }
        if c == 9 {
            is_sep = 1
        }
        if c == 10 {
            is_sep = 1
            lines = lines + 1
        }
        if c == 13 {
            is_sep = 1
        }
        if is_sep == 1 {
            if in_word == 1 {
                words = words + 1
                in_word = 0
            }
        } else {
            in_word = 1
        }
        i = i + 1
    }
    if in_word == 1 {
        words = words + 1
    }
    println("lines =", lines)
    println("words =", words)
    println("bytes =", n)
    return 0
}

let _ = main_wc()
