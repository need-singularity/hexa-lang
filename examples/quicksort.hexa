// quicksort.hexa — in-place 퀵소트 (전역 배열)

let mut arr = [5, 2, 8, 1, 9, 3, 7, 4, 6, 0, 15, 11, 13, 10, 12, 14]
let N = 16

fn swap(i, j) {
    let t = arr[i]
    arr[i] = arr[j]
    arr[j] = t
}

fn partition(lo, hi) {
    let pivot = arr[hi]
    let mut i = lo - 1
    let mut j = lo
    while j < hi {
        if arr[j] <= pivot {
            i = i + 1
            let _s = swap(i, j)
        }
        j = j + 1
    }
    let _s = swap(i + 1, hi)
    return i + 1
}

fn qs(lo, hi) {
    if lo < hi {
        let p = partition(lo, hi)
        let _r1 = qs(lo, p - 1)
        let _r2 = qs(p + 1, hi)
    }
    return 0
}

fn print_arr(label: string) {
    print(label)
    print(": ")
    let mut i = 0
    while i < N {
        print(arr[i])
        print(" ")
        i = i + 1
    }
    println("")
}

print_arr("before")
let _r = qs(0, N - 1)
print_arr("after ")

// 검증: 정렬됐는지 확인
let mut sorted = 1
let mut i = 1
while i < N {
    if arr[i] < arr[i - 1] {
        sorted = 0
    }
    i = i + 1
}
if sorted == 1 {
    println("sorted: ✓")
} else {
    println("sorted: ✗")
}
println("done")
