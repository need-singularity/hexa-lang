// bf.hexa — Brainfuck 인터프리터
// 사용: ./bf "<code>"
// 명령: > < + - . , [ ]

fn bf_run(code: string) {
    let mut tape = []
    let mut t = 0
    while t < 30000 {
        tape = tape + [0]
        t = t + 1
    }
    let mut ptr = 0
    let mut pc = 0
    let n = code.len()

    while pc < n {
        let c = code.substring(pc, pc + 1)
        if c == ">" {
            ptr = ptr + 1
        } else if c == "<" {
            ptr = ptr - 1
        } else if c == "+" {
            tape[ptr] += 1
        } else if c == "-" {
            tape[ptr] -= 1
        } else if c == "." {
            // 단일 문자 출력 — substring으로 char 변환
            let ch_code = tape[ptr]
            // ASCII only; 직접 printf할 수 없으므로 단일 문자 string 만들기 불가
            // 대신 int 값으로 출력
            print(ch_code)
            print(" ")
        } else if c == "[" {
            if tape[ptr] == 0 {
                let mut depth = 1
                let mut scan = pc + 1
                while scan < n {
                    let c2 = code.substring(scan, scan + 1)
                    if c2 == "[" {
                        depth = depth + 1
                    } else if c2 == "]" {
                        depth = depth - 1
                        if depth == 0 {
                            pc = scan
                            scan = n
                        }
                    }
                    scan = scan + 1
                }
            }
        } else if c == "]" {
            if tape[ptr] != 0 {
                let mut depth = 1
                let mut scan = pc - 1
                while scan >= 0 {
                    let c2 = code.substring(scan, scan + 1)
                    if c2 == "]" {
                        depth = depth + 1
                    } else if c2 == "[" {
                        depth = depth - 1
                        if depth == 0 {
                            pc = scan
                            scan = 0 - 1
                        }
                    }
                    scan = scan - 1
                }
            }
        }
        pc = pc + 1
    }
    return 0
}

// "Hello World" BF (classic)
// 출력: 72 101 108 108 111 32 87 111 114 108 100 33 10 (ASCII codes)
if argc() < 2 {
    // 테스트: 5+5 = 10
    println("=== test: ++++++++++. (should print 10) ===")
    let r1 = bf_run("++++++++++.")
    println("")
    println("=== test: +++++[>+++++<-]>. (5*5=25) ===")
    let r2 = bf_run("+++++[>+++++<-]>.")
    println("")
    println("=== test: ++++++++[>++++++++<-]>+. (8*8+1=65 = 'A') ===")
    let r3 = bf_run("++++++++[>++++++++<-]>+.")
    println("")
} else {
    let code = arg(1)
    let r4 = bf_run(code)
    println("")
}
println("done")
