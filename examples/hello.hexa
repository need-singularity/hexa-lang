// HEXA-LANG -- The Perfect Number Language
// sigma(n)*phi(n) = n*tau(n) iff n = 6

println("Hello, HEXA-LANG!")
println("sigma(6) =", sigma(6))
println("phi(6) =", phi(6))
println("tau(6) =", tau(6))
println("sigma(6)*phi(6) =", sigma(6) * phi(6))
println("6*tau(6) =", 6 * tau(6))
println("Both equal 24 = J2(6)")
