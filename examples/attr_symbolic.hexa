// @symbolic PoC — Phase 1 single rule:
//   Binary(x, Mul, IntLit(2))  =>  Binary(x, Add, x)
//
// double(x) is rewritten at FnDecl registration so that `x * 2`
// becomes `x + x` before execution. Behavior is unchanged — this is
// a semantics-preserving algebraic rewrite (Phase 1 scope: 1 rule).

@symbolic
fn double(x: Int) -> Int {
    x * 2
}

fn main() {
    let a = double(21)
    print(a)       // 42
    print(double(7))   // 14
    print(double(0))   // 0
}
