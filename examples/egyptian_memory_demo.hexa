// Egyptian Fraction Memory Demo
// 1/2 + 1/3 + 1/6 = 1 (the only 3-way unit fraction decomposition of n=6)

// Stack allocations (value types)
let x = 42
let y = 3.14
let z = true

// Heap allocations (dynamic objects)
let arr = [1, 2, 3, 4, 5, 6]
let matrix = [[1, 2], [3, 4], [5, 6]]

// Arena allocations (strings/temporaries)
let name = "Egyptian"
let greeting = "Hello from the Egyptian Fraction allocator!"

// Function calls push stack frames
fn fibonacci(n: int) -> int {
    if n <= 1 { return n }
    return fibonacci(n - 1) + fibonacci(n - 2)
}

let fib6 = fibonacci(6)
println("fibonacci(6) =", fib6)

// Show memory stats
let stats = mem_stats()
println("Stack used:", stats.stack_used, "bytes")
println("Heap used:", stats.heap_used, "bytes")
println("Arena used:", stats.arena_used, "bytes")
println("Total allocations:", stats.total_allocs)

// Show budget fractions
let budget = mem_budget()
println("Budget identity:", budget.identity)
println("Stack fraction:", budget.stack_fraction, "=", budget.stack, "bytes")
println("Heap fraction:", budget.heap_fraction, "=", budget.heap, "bytes")
println("Arena fraction:", budget.arena_fraction, "=", budget.arena, "bytes")

// Region classification
println("Region of 42:", mem_region(42))
println("Region of [1,2,3]:", mem_region([1, 2, 3]))
println("Region of 'hello':", mem_region("hello"))
