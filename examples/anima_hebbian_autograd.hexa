// ══════════════════════════════════════════════════════════
// Anima Hebbian + @autograd — 학습 규칙 자동 미분
// Target: crates/online-learner/src/hebbian.rs
// Δw = η × (cosine_sim - decay × w) → gradient w.r.t. η, decay
// ══════════════════════════════════════════════════════════

fn dot(a, b) {
    let sum = 0.0
    let i = 0
    while i < len(a) {
        sum = sum + a[i] * b[i]
        i = i + 1
    }
    sum
}

fn norm(a) {
    let sum = 0.0
    let i = 0
    while i < len(a) {
        sum = sum + a[i] * a[i]
        i = i + 1
    }
    sqrt(sum)
}

fn cosine_sim(a, b) {
    let d = dot(a, b)
    let na = norm(a)
    let nb = norm(b)
    if na < 0.0001 { return 0.0 }
    if nb < 0.0001 { return 0.0 }
    d / (na * nb)
}

// ── @fuse: Hebbian delta computation (cosine + delta rule in single pass) ──
@fuse fn hebbian_delta(sim: float, w: float, lr: float, decay: float) -> float {
    lr * (sim - decay * w)
}

// ── @autograd: differentiate Hebbian loss w.r.t. learning rate ──
// Loss = Σ (Δw)² = Σ (lr * (sim - decay * w))²
// Used for meta-learning: optimize lr/decay for Φ maximization
@autograd fn hebbian_loss(lr: float, decay: float) -> float {
    // Simulated: 4-cell network, fixed sims and weights
    let s1 = 0.85
    let s2 = 0.15
    let s3 = 0.92
    let s4 = 0.45
    let w1 = 0.3
    let w2 = -0.1
    let w3 = 0.7
    let w4 = 0.2
    let d1 = lr * (s1 - decay * w1)
    let d2 = lr * (s2 - decay * w2)
    let d3 = lr * (s3 - decay * w3)
    let d4 = lr * (s4 - decay * w4)
    d1 * d1 + d2 * d2 + d3 * d3 + d4 * d4
}

// ── Test: 4 cells, Anima-scale ──
let cell0 = [0.1, 0.2, -0.1, 0.3]
let cell1 = [-0.2, 0.4, 0.1, -0.1]
let cell2 = [0.3, -0.1, 0.2, 0.4]
let cell3 = [0.0, 0.1, -0.3, 0.2]

// [1] Pairwise cosine similarities
let sim01 = cosine_sim(cell0, cell1)
let sim02 = cosine_sim(cell0, cell2)
let sim12 = cosine_sim(cell1, cell2)
let sim23 = cosine_sim(cell2, cell3)
println("[1] Cosine sims: 01=", round(sim01 * 1000) / 1000, "02=", round(sim02 * 1000) / 1000)

// [2] Fused Hebbian delta (batch all pairs at once)
let sims = [sim01, sim02, sim12, sim23]
let weights = [0.3, 0.1, -0.2, 0.5]
let lr = 0.015317  // PSI_COUPLING
let decay = 0.01
let deltas = hebbian_delta(sims, weights, lr, decay)
println("[2] Fused deltas:", deltas)

// [3] LTP/LTD classification
let i = 0
while i < 4 {
    let label = if sims[i] > 0.8 { "LTP" } else { if sims[i] < 0.2 { "LTD" } else { "neutral" } }
    println("    pair", i, "sim=", round(sims[i] * 1000) / 1000, "->", label)
    i = i + 1
}

// [4] @autograd: meta-learning gradient ∂loss/∂lr, ∂loss/∂decay
let grads = hebbian_loss_grad(0.015, 0.01)
println("[4] Hebbian meta-gradient:")
println("    ∂loss/∂lr =", grads[0])
println("    ∂loss/∂decay =", grads[1])
println("    → meta-learning: adjust lr/decay to minimize weight oscillation")

// [5] Φ-gated update: only apply if Φ safe (ratchet pattern)
let phi_current = 0.42
let phi_ema = 0.38
let phi_safe = phi_current > phi_ema * 0.8
println("[5] Φ ratchet: current=", phi_current, "ema=", phi_ema, "safe=", phi_safe)
if phi_safe {
    println("    → Hebbian update APPLIED (Φ safe)")
} else {
    println("    → Hebbian update BLOCKED (Φ collapse risk)")
}

println("--- Hebbian+autograd PASS ---")
