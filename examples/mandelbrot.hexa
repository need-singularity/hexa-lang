// mandelbrot.hexa — ASCII 만델브로 집합
let W = 60
let H = 24
let MAX_ITER = 50

fn mandel(cr: float, ci: float) {
    let mut zr = 0.0
    let mut zi = 0.0
    let mut i = 0
    while i < 50 {
        let zr2 = zr * zr
        let zi2 = zi * zi
        if zr2 + zi2 > 4.0 {
            return i
        }
        let new_zr = zr2 - zi2 + cr
        let new_zi = 2.0 * zr * zi + ci
        zr = new_zr
        zi = new_zi
        i = i + 1
    }
    return 50
}

fn shade(it) {
    if it == 50 {
        return " "
    }
    if it > 40 {
        return "."
    }
    if it > 30 {
        return ":"
    }
    if it > 20 {
        return "-"
    }
    if it > 15 {
        return "="
    }
    if it > 10 {
        return "+"
    }
    if it > 5 {
        return "*"
    }
    if it > 2 {
        return "#"
    }
    return "@"
}

println("=== Mandelbrot (ASCII) ===")
let mut row = 0
while row < 24 {
    let ci = 0.0 - 1.2 + (row * 0.1)
    let mut line = ""
    let mut col = 0
    while col < 60 {
        let cr = 0.0 - 2.2 + (col * 0.05)
        let it = mandel(cr, ci)
        line = line + shade(it)
        col = col + 1
    }
    println(line)
    row = row + 1
}
println("done")
