// Concurrency example: spawn + channel

let pair = channel()
let tx = pair[0]
let rx = pair[1]

// Spawn a worker that sends values
spawn {
    tx.send(10)
    tx.send(20)
    tx.send(30)
}

// Receive values from the spawned task
let a = rx.recv()
let b = rx.recv()
let c = rx.recv()

println("Received:", a, b, c)
println("Sum:", a + b + c)
