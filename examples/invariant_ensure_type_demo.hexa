// examples/invariant_ensure_type_demo.hexa — T3 Phase A: ensure_type predicate
//
// 본 예제는 ensure_type predicate 의 violation 감지를 확인한다.
//   ./hexa check examples/invariant_ensure_type_demo.hexa
//     → 1 violation (I3) + exit 1
//
// ensure_type(symbol="counter", type_name="Int") 은 `counter: Int` 으로만
// 쓰이길 기대하지만, 아래 fn 시그니처에서 `counter: String` 으로 어긋나
// 위반을 보고한다.

@invariant {
    id: "I3",
    name: "counter_is_int",
    predicate: "ensure_type",
    pattern: { target: "counter", context: "Int" },
    exempt: []
}

fn increment(counter: String) {
    return counter
}

fn consumer() {
    let counter: Int = 0
    return counter
}

consumer()
