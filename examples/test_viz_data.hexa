// ══════════════════════════════════════════════════════════
// ASCII 시각화 + 데이터 유틸 + 모델 요약
// Anima 개발자 경험 완성
// ══════════════════════════════════════════════════════════

// ═══ [1] ASCII Loss Curve ═══
let losses = [2.5, 2.3, 2.0, 1.8, 1.5, 1.3, 1.1, 0.9, 0.8, 0.7, 0.65, 0.6, 0.55, 0.52, 0.5]
println("[1] Training Loss Curve:")
ascii_plot(losses, 40, 8, "Loss over epochs")

// ═══ [2] ASCII Φ History ═══
let phi_hist = [0.1, 0.15, 0.2, 0.18, 0.25, 0.3, 0.28, 0.35, 0.4, 0.38, 0.42, 0.45]
println("\n[2] Φ History:")
ascii_plot(phi_hist, 40, 6, "Phi(IIT) evolution")

// ═══ [3] ASCII Bar Chart ═══
let labels = ["sigmoid", "gelu", "relu", "softmax", "attention"]
let times = [3.6, 4.1, 1.2, 1.8, 16.0]
println("\n[3] Op Benchmarks (ms):")
ascii_bar(labels, times, 30)

// ═══ [4] Data Split ═══
let dataset = arange(20)
let split = data_split(dataset, 0.8)
println("\n[4] Data split (80/20):")
println("    train:", len(split[0]), "samples")
println("    test:", len(split[1]), "samples")

// ═══ [5] Shuffle ═══
let data = [1, 2, 3, 4, 5, 6, 7, 8]
let shuffled = shuffle(data, 42)
println("[5] Shuffle:", data, "→", shuffled)

// ═══ [6] One-Hot ═══
let oh = one_hot(3, 5)
println("[6] one_hot(3, 5):", oh)

// ═══ [7] Model Summary ═══
println("\n[7] Model Summary:")
let W1 = xavier_init(4, 16)
let b1 = zeros(16)
let W2 = xavier_init(16, 8)
let b2 = zeros(8)
let W3 = xavier_init(8, 4)
let b3 = zeros(4)

let total = param_count(W1, b1, W2, b2, W3, b3)
let size = model_size_kb(total)
println("    Layer 1: Linear(4→16)  params:", len(W1) + len(b1))
println("    Layer 2: Linear(16→8)  params:", len(W2) + len(b2))
println("    Layer 3: Linear(8→4)   params:", len(W3) + len(b3))
println("    ─────────────────────────────")
println("    Total params:", total)
println("    Model size:", round(size * 100) / 100, "KB (fp32)")
println("    INT8 size:", round(size * 100 / 4) / 100, "KB")

// ═══ [8] Full Anima Training Dashboard ═══
println("\n[8] === Anima Training Dashboard ===")
let epoch_losses = [2.5, 2.1, 1.8, 1.5, 1.3, 1.1, 0.9, 0.8, 0.7, 0.65]
let epoch_phis = [0.1, 0.15, 0.22, 0.28, 0.35, 0.38, 0.42, 0.45, 0.47, 0.48]
let epoch_acc = [25, 35, 50, 55, 65, 70, 75, 80, 82, 85]

ascii_plot(epoch_losses, 35, 6, "Loss")
println("")
ascii_plot(epoch_phis, 35, 6, "Phi(IIT)")

let stats = running_stats(epoch_losses)
let phi_stats = running_stats(epoch_phis)
println("\n  Loss:  mean=", round(stats[0] * 1000) / 1000, "trend=", round(stats[4] * 10000) / 10000)
println("  Phi:   mean=", round(phi_stats[0] * 1000) / 1000, "trend=", round(phi_stats[4] * 10000) / 10000)
println("  Acc:   final=", epoch_acc[9], "%")

let labels2 = ["W1", "W2", "W3", "bias"]
let param_sizes = [64, 128, 32, 28]
println("\n  Parameter distribution:")
ascii_bar(labels2, [64.0, 128.0, 32.0, 28.0], 25)

// ═══ @test ═══
@test fn test_data_split_ratio() {
    let s = data_split(arange(100), 0.8)
    assert(len(s[0]) == 80, "80% train")
    assert(len(s[1]) == 20, "20% test")
}
@test fn test_one_hot_correct() {
    let oh = one_hot(2, 4)
    assert(oh[2] == 1.0, "index 2 should be 1")
    assert(oh[0] == 0.0, "others should be 0")
}
@test fn test_shuffle_preserves_length() {
    let s = shuffle(arange(10), 1)
    assert(len(s) == 10, "shuffle should preserve length")
}
@test fn test_param_count_sums() {
    assert(param_count([1.0, 2.0], [3.0]) == 3, "should sum array lengths")
}
run_tests()

println("\n--- viz+data+summary PASS ---")
