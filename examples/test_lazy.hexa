// ══════════════════════════════════════════════════════════
// @lazy — 지연 평가 (deferred computation) 테스트
// Anima 대규모 데이터 파이프라인 메모리 절약
// ══════════════════════════════════════════════════════════

// [1] 기본 lazy: 호출 시 thunk 반환, ()로 force
@lazy fn expensive(x: float) -> float {
    x * x * x + 100.0
}

let thunk = expensive(5.0)
println("[1] thunk type: fn")
let result = thunk()
println("[1] forced:", result)
// Expected: 225.0

// [2] lazy로 조건부 실행 — 불필요한 계산 스킵
@lazy fn heavy_calc(a: float, b: float) -> float {
    a * a + b * b + a * b
}

let t1 = heavy_calc(3.0, 4.0)
let t2 = heavy_calc(10.0, 20.0)
// 조건부로 하나만 force
let need_first = true
let chosen = if need_first { t1() } else { t2() }
println("[2] chosen:", chosen)
// Expected: 9 + 16 + 12 = 37.0

// [3] Anima pattern: lazy gradient — 필요할 때만 미분 계산
@lazy fn compute_grad(w: float, x: float, y: float) -> float {
    2.0 * (w * x - y) * x
}

let grad_thunk = compute_grad(1.5, 2.0, 4.0)
println("[3] grad thunk created")
let grad_val = grad_thunk()
println("[3] grad forced:", grad_val)
// 2*(1.5*2.0-4.0)*2.0 = 2*(-1.0)*2.0 = -4.0

// [4] 다중 thunk 배열화
let thunks = [expensive(1.0), expensive(2.0), expensive(3.0)]
let i = 0
let results = []
while i < 3 {
    results = results + [thunks[i]()]
    i = i + 1
}
println("[4] batch forced:", results)
// [101.0, 108.0, 127.0]

println("--- @lazy 4/4 PASS ---")
