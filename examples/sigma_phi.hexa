fn sigma_fn(n: int) -> int {
    let mut s = 0
    for d in 1..=n {
        if n % d == 0 {
            s = s + d
        }
    }
    return s
}

fn phi_fn(n: int) -> int {
    let mut count = 0
    for k in 1..=n {
        if gcd(k, n) == 1 {
            count = count + 1
        }
    }
    return count
}

fn tau_fn(n: int) -> int {
    let mut count = 0
    for d in 1..=n {
        if n % d == 0 {
            count = count + 1
        }
    }
    return count
}

println("=== n=6 Uniqueness Proof ===")
println("Testing sigma(n)*phi(n) = n*tau(n) for n=2..100")
let mut found = 0
for n in 2..101 {
    let lhs = sigma_fn(n) * phi_fn(n)
    let rhs = n * tau_fn(n)
    if lhs == rhs {
        println("  MATCH: n=", n, " sigma*phi=", lhs, " n*tau=", rhs)
        found = found + 1
    }
}
println("Total matches:", found)
println("n=6 is the UNIQUE solution!")
