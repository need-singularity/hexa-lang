// N1.2 transpile test — struct + field access + break + continue
struct Vec2 {
    x: int,
    y: int
}

fn dot(a: Vec2, b: Vec2) -> int {
    return a.x * b.x + a.y * b.y
}

let v1 = Vec2 { x: 3, y: 4 }
let v2 = Vec2 { x: 1, y: 2 }
println(dot(v1, v2))

// Find first prime > 10
let mut n = 11
let mut result = 0
while n < 100 {
    let mut is_prime = true
    let mut d = 2
    while d * d <= n {
        if n % d == 0 {
            is_prime = false
            break
        }
        d = d + 1
    }
    if is_prime {
        result = n
        break
    }
    n = n + 2
}
println(result)
