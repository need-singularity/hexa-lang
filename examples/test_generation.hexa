// ══════════════════════════════════════════════════════════
// 활성화 zoo + PE + MHA + 생성 샘플링 테스트
// Anima 추론/생성 파이프라인 완성
// ══════════════════════════════════════════════════════════

// ═══ [1] GELU + SiLU ═══
let g = gelu([-2.0, -1.0, 0.0, 1.0, 2.0])
let s = silu([-2.0, -1.0, 0.0, 1.0, 2.0])
println("[1] gelu:", g)
println("    silu:", s)
// GELU(0)=0, GELU(1)≈0.841, SiLU(0)=0, SiLU(1)≈0.731

// ═══ [2] Sinusoidal Positional Encoding ═══
let pe = sinusoidal_pe(4, 4)
println("[2] PE (4 positions × 4 dim):")
println("    pos0:", slice(pe, 0, 4))
println("    pos1:", slice(pe, 4, 8))
println("    pos2:", slice(pe, 8, 12))

// ═══ [3] Multi-Head Attention ═══
let seq = 3
let dim = 4
let n_heads = 2
let x = randn(12, 0.3)  // 3×4
let Wq = randn(16, 0.25)
let Wk = randn(16, 0.25)
let Wv = randn(16, 0.25)
let Wo = randn(16, 0.25)

let mha_out = multi_head_attention(x, Wq, Wk, Wv, Wo, seq, dim, n_heads, true)
println("[3] MHA (seq=3, dim=4, heads=2, causal):")
println("    pos0:", slice(mha_out, 0, 4))
println("    pos2:", slice(mha_out, 8, 12))

// ═══ [4] TopK ═══
let logits = [0.1, 0.8, 0.3, 0.9, 0.2, 0.7, 0.5, 0.4]
let top3 = topk(logits, 3)
println("[4] topk([0.1,0.8,0.3,0.9,0.2,0.7,0.5,0.4], k=3):", top3)
// Expected: [3, 1, 5] (indices of 0.9, 0.8, 0.7)

// ═══ [5] Temperature Sampling ═══
let gen_logits = [2.0, 1.0, 0.5, -1.0, 0.1, 0.3, -0.5, 0.8]
let t_high = sample_token(gen_logits, 1.0)
let t_low = sample_token(gen_logits, 0.1)  // more greedy
println("[5] sample_token(logits):")
println("    temp=1.0:", t_high, "temp=0.1:", t_low)
println("    argmax:", argmax(gen_logits))

// ═══ [6] MSE Loss ═══
let pred = [1.0, 2.0, 3.0]
let target = [1.1, 2.2, 2.8]
let mse = mse_loss(pred, target)
println("[6] mse_loss:", mse)
// (0.01 + 0.04 + 0.04) / 3 = 0.03

// ═══ [7] Anima Text Generation Demo ═══
println("\n[7] Anima Text Generation:")
let vocab = 8
let d = 4
let W_e = randn(vocab * d, 0.5)
let W_q_g = randn(d * d, 0.25)
let W_k_g = randn(d * d, 0.25)
let W_v_g = randn(d * d, 0.25)
let W_o_g = randn(d * d, 0.25)
let W_out = randn(vocab * d, 0.25)

// Autoregressive generation: start with token 1
let generated = [1]
let step = 0
while step < 5 {
    let cur_len = len(generated)
    // Embed + PE
    let emb = embedding(generated, W_e, vocab, d)
    let pe_enc = sinusoidal_pe(cur_len, d)
    let x_gen = mat_add(emb, pe_enc)
    // Causal MHA
    let attn = multi_head_attention(x_gen, W_q_g, W_k_g, W_v_g, W_o_g, cur_len, d, 2, true)
    let x_out = mat_add(x_gen, attn)
    // Project last position → logits
    let last_hidden = slice(x_out, (cur_len - 1) * d, cur_len * d)
    let logits_gen = matvec(W_out, last_hidden, vocab, d)
    // Sample next token
    let next_tok = sample_token(logits_gen, 0.8)
    generated = generated + [next_tok]
    if step < 3 {
        println("    step", step, ": generated tok=", next_tok, "logits top3:", topk(logits_gen, 3))
    }
    step = step + 1
}
println("    final sequence:", generated)

// ═══ @test ═══
@test fn test_gelu_zero() {
    assert(gelu(0.0) == 0.0, "gelu(0) = 0")
}
@test fn test_silu_zero() {
    assert(silu(0.0) == 0.0, "silu(0) = 0")
}
@test fn test_pe_shape() {
    let p = sinusoidal_pe(5, 8)
    assert(len(p) == 40, "PE should be seq×dim")
}
@test fn test_mha_shape() {
    let o = multi_head_attention(randn(12, 0.1), randn(16, 0.1), randn(16, 0.1), randn(16, 0.1), randn(16, 0.1), 3, 4, 2, true)
    assert(len(o) == 12, "MHA output = seq×dim")
}
@test fn test_topk_order() {
    let t = topk([1.0, 3.0, 2.0], 2)
    assert(t[0] == 1, "top1 index should be 1 (value 3.0)")
}
@test fn test_mse_zero() {
    assert(mse_loss([1.0, 2.0], [1.0, 2.0]) == 0.0, "mse of identical = 0")
}
run_tests()

println("\n--- generation pipeline PASS ---")
