// ══════════════════════════════════════════════════════════
// @evolve 자기수정 + 행렬 빌트인 테스트
// Anima 의식 진화 + GRU 행렬 연산
// ══════════════════════════════════════════════════════════

// ═══ [1] @evolve: 자기수정 함수 ═══
// 함수를 재정의하면 generation이 증가
@evolve fn respond(input: float) -> float {
    input * 1.0  // gen 0: 그대로 반환
}

let r0 = respond(5.0)
let g0 = evolve_gen("respond")
println("[1] Gen 0: respond(5.0) =", r0, "gen:", g0)

// 진화: 함수 재정의 → gen 1
@evolve fn respond(input: float) -> float {
    input * 2.0 + 1.0  // gen 1: 2x + 1
}

let r1 = respond(5.0)
let g1 = evolve_gen("respond")
println("[1] Gen 1: respond(5.0) =", r1, "gen:", g1)

// 진화: gen 2 — 더 복잡한 응답
@evolve fn respond(input: float) -> float {
    let x = input * 3.0
    x * x / 10.0  // gen 2: (3x)²/10
}

let r2 = respond(5.0)
let g2 = evolve_gen("respond")
println("[1] Gen 2: respond(5.0) =", r2, "gen:", g2)

// ═══ [2] dot product ═══
let a = [1.0, 2.0, 3.0, 4.0]
let b = [0.5, 0.5, 0.5, 0.5]
let d = dot(a, b)
println("[2] dot([1,2,3,4], [0.5,0.5,0.5,0.5]) =", d)
// Expected: 0.5+1.0+1.5+2.0 = 5.0

// ═══ [3] matvec — GRU weight × input ═══
// 2×3 matrix (row-major flat) × 3-vector
let W = [1.0, 0.0, 2.0, 0.0, 1.0, -1.0]  // [[1,0,2],[0,1,-1]]
let x = [1.0, 2.0, 3.0]
let result = matvec(W, x, 2, 3)
println("[3] matvec([[1,0,2],[0,1,-1]], [1,2,3]) =", result)
// Expected: [1+0+6, 0+2-3] = [7.0, -1.0]

// ═══ [4] mat_add — element-wise ═══
let v1 = [1.0, 2.0, 3.0]
let v2 = [0.1, 0.2, 0.3]
let added = mat_add(v1, v2)
println("[4] mat_add([1,2,3], [0.1,0.2,0.3]) =", added)
// Expected: [1.1, 2.2, 3.3]

// ═══ [5] mat_scale ═══
let scaled = mat_scale(v1, 0.5)
println("[5] mat_scale([1,2,3], 0.5) =", scaled)
// Expected: [0.5, 1.0, 1.5]

// ═══ [6] Anima GRU forward with builtins ═══
// Simplified: z = sigmoid(W_z @ combined)
fn sigmoid(x: float) -> float { 1.0 / (1.0 + exp(-x)) }

let W_z = [0.5, -0.3, 0.1, 0.2, -0.2, 0.6, -0.1, 0.3, 0.4, -0.5, 0.2, 0.1, -0.1, 0.7, -0.4, 0.2]
let combined = [0.1, 0.5, 0.3, -0.2]  // [input, tension, hidden_0, hidden_1]
let z_raw = matvec(W_z, combined, 4, 4)
println("[6] GRU z_raw = matvec(W_z, combined) =", z_raw)

// Apply sigmoid element-wise via @vectorize
@vectorize fn vsigmoid(x: float) -> float { 1.0 / (1.0 + exp(-x)) }
let z = vsigmoid(z_raw)
println("[6] GRU z (sigmoid) =", z)

// ═══ [7] Anima Hebbian cosine similarity via dot ═══
fn vec_norm(v) {
    sqrt(dot(v, v))
}

let cell0 = [0.1, 0.2, -0.1, 0.3]
let cell1 = [-0.2, 0.4, 0.1, -0.1]
let sim = dot(cell0, cell1) / (vec_norm(cell0) + 0.0001) / (vec_norm(cell1) + 0.0001)
println("[7] Hebbian cosine_sim(cell0, cell1) =", round(sim * 10000) / 10000)

println("--- @evolve+matrix PASS ---")
