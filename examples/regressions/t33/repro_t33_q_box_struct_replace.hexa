// repro_t33_q_box_struct_replace.hexa — 2026-04-16 ROI #87
//
// Symptom: module-level box containing a struct, whose box[0] is overwritten
// with a struct LITERAL from INSIDE a fn, corrupts after fn return.
//
// Under HEXA_VAL_ARENA=1 (or unset, as was default): after fn returns,
// type_of(box[0]) == "string", box[0].a == void. Matches T33 symptom class
// (arena-allocated struct vals not heapified on escape via IndexAssign).
//
// Fix: default flip to HEXA_VAL_ARENA=0 in runtime.c + ./hexa wrapper;
// proper fix is heapify RHS in interpreter.hexa IndexAssign before
// array_store writeback.
//
// Expected (arena OFF or fixed interpreter):
//   A.box[0] = struct
//   B.box[0] = struct
//   B.box[0].a = int
//   len = 1
//
// Buggy (arena ON + unpatched interpreter):
//   A.box[0] = struct
//   B.box[0] = string
//   B.box[0].a = void
//   len = 1

struct S {
  a: int
  b: int
}

let box = [S { a: 0, b: 0 }]

fn wreplace() {
  box[0] = S { a: 1, b: 10 }
}

fn main() {
  println("A.box[0] = " + type_of(box[0]))
  wreplace()
  println("B.box[0] = " + type_of(box[0]))
  println("B.box[0].a = " + type_of(box[0].a))
  println("len = " + to_string(len(box)))
}
