// T33 repro I — even more minimal; just ml_trim_left inside a loop that reads from split
fn ml_trim_left(s) { return s.trim_start() }

fn ml_split_lines(s) { return s.split("\n") }

fn ml_resolve(src) {
    let lines = ml_split_lines(src)
    let mut out_parts = []
    let n = len(lines)
    let mut i = 0
    while i < n {
        let line = lines[i]
        let trimmed = ml_trim_left(line)
        out_parts = out_parts.push(trimmed)
        out_parts = out_parts.push("\n")
        i = i + 1
    }
    return out_parts.join("")
}

fn load_module(path) {
    let src = read_file(path)
    return ml_resolve(src)
}

fn main() {
    let expanded = load_module("/tmp/t33_input.hexa")
    println("[repro_t33_i] len=" + to_string(len(expanded)))
}

main()
