// T33 repro J — strip more; inline the call
fn ml_trim_left(s) { return s.trim_start() }

fn ml_resolve(src) {
    let lines = src.split("\n")
    let n = len(lines)
    let mut i = 0
    while i < n {
        let line = lines[i]
        let trimmed = ml_trim_left(line)
        i = i + 1
    }
    return "done"
}

fn main() {
    let src = read_file("/tmp/t33_input.hexa")
    let r = ml_resolve(src)
    println("[j] " + r)
}

main()
