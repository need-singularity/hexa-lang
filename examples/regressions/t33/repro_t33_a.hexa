// T33 repro candidate A — minimal nested use/import chain
// Exercises the module_loader ml_trim_left loop with HEXA_VAL_ARENA=1.

fn ml_trim_left(s) { return s.trim_start() }

fn ml_resolve(src) {
    let lines = src.split("\n")
    let n = len(lines)
    let mut out = ""
    let mut i = 0
    while i < n {
        let line = lines[i]
        let trimmed = ml_trim_left(line)
        out = out + trimmed + "\n"
        i = i + 1
    }
    return out
}

fn main() {
    // Build a large-ish input to stress the split/trim loop.
    let mut src = ""
    let mut k = 0
    while k < 200 {
        src = src + "   line " + to_string(k) + " content\n"
        k = k + 1
    }
    let out = ml_resolve(src)
    println("[repro_t33_a] out_len=" + to_string(len(out)))
}

main()
