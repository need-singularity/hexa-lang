// T33 repro N — return array from fn, iterate, check tags
fn ml_split_lines(s) { return s.split("\n") }

fn main() {
    let src = "a\nbb\nccc\n"
    let lines = ml_split_lines(src)
    let n = len(lines)
    println("n=" + to_string(n))
    let mut i = 0
    while i < n {
        let line = lines[i]
        println("tag=" + type_of(line) + " val=" + to_string(line))
        i = i + 1
    }
}

main()
