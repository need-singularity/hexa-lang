// T52 #1 — STORE_UPVAL minimal smoke.
// Mutable capture — counter-style closure.
let mut counter = 0
let inc = |x| counter = counter + x
inc(5)
print(counter)   // 5
inc(10)
print(counter)   // 15

// Multi-capture store — both vars mutable.
let mut a = 100
let mut b = 20
let swap_into_a = |v| a = b + v
swap_into_a(7)
print(a)   // 27
print(b)   // 20
