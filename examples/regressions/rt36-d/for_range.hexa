// T61 — for-range loop smoke test.
// Expected output: 0 1 2 3 4 10 55 hello world done

// (1) Basic range (exclusive)
for i in 0..5 {
    print(i)
}

// (2) Accumulator with for-range
let mut sum = 0
for i in 1..5 {
    sum += i
}
print(sum)

// (3) Inclusive range
let mut total = 0
for i in 1..=10 {
    total += i
}
print(total)

// (4) For-array iteration
let words = ["hello", "world", "done"]
for w in words {
    print(w)
}
