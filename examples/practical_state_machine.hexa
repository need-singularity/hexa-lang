// practical_state_machine.hexa -- HTTP connection state machine
// Demonstrates: enums with data, match expressions, algebraic effects,
//               structs, proof blocks, state transition logic

// ── State enum: an HTTP connection lifecycle ────────────────
enum ConnState {
    Idle,
    Connecting(int),
    Connected(int),
    Sending(int),
    Receiving(int),
    Closed
}

// ── Events that trigger state transitions ───────────────────
enum Event {
    Connect(int),
    Established(int),
    Send(int),
    Receive(int),
    Finish,
    Error(int)
}

// ── State name for display ──────────────────────────────────
fn state_name(s) -> str {
    match s {
        ConnState::Idle -> "Idle",
        ConnState::Connecting(port) -> format("Connecting({})", port),
        ConnState::Connected(port) -> format("Connected({})", port),
        ConnState::Sending(bytes) -> format("Sending({} bytes)", bytes),
        ConnState::Receiving(bytes) -> format("Receiving({} bytes)", bytes),
        ConnState::Closed -> "Closed"
    }
}

fn event_name(e) -> str {
    match e {
        Event::Connect(port) -> format("Connect({})", port),
        Event::Established(port) -> format("Established({})", port),
        Event::Send(bytes) -> format("Send({} bytes)", bytes),
        Event::Receive(bytes) -> format("Receive({} bytes)", bytes),
        Event::Finish -> "Finish",
        Event::Error(code) -> format("Error({})", code)
    }
}

// ── Transition function: the core state machine ─────────────
fn transition(state, event) {
    match state {
        ConnState::Idle -> {
            match event {
                Event::Connect(port) -> ConnState::Connecting(port),
                _ -> ConnState::Idle
            }
        },
        ConnState::Connecting(port) -> {
            match event {
                Event::Established(p) -> ConnState::Connected(p),
                Event::Error(code) -> ConnState::Closed,
                _ -> ConnState::Connecting(port)
            }
        },
        ConnState::Connected(port) -> {
            match event {
                Event::Send(bytes) -> ConnState::Sending(bytes),
                Event::Receive(bytes) -> ConnState::Receiving(bytes),
                Event::Finish -> ConnState::Closed,
                Event::Error(code) -> ConnState::Closed,
                _ -> ConnState::Connected(port)
            }
        },
        ConnState::Sending(bytes) -> {
            match event {
                Event::Finish -> ConnState::Connected(80),
                Event::Error(code) -> ConnState::Closed,
                _ -> ConnState::Sending(bytes)
            }
        },
        ConnState::Receiving(bytes) -> {
            match event {
                Event::Finish -> ConnState::Connected(80),
                Event::Error(code) -> ConnState::Closed,
                _ -> ConnState::Receiving(bytes)
            }
        },
        ConnState::Closed -> ConnState::Closed
    }
}

// ── Run a sequence of events through the state machine ──────
fn run_machine(events) -> int {
    let mut state = ConnState::Idle
    let mut step = 0
    println("  [0] State:", state_name(state))

    for event in events {
        step = step + 1
        let next = transition(state, event)
        println("  [", step, "]", event_name(event), "->", state_name(next))
        state = next
    }
    return step
}

// ── Algebraic effect: logging state transitions ─────────────
effect TransitionLog {
    fn log_transition(from: str, event: str, to: str) -> int
}

fn run_with_logging(events) -> int {
    let mut state = ConnState::Idle
    let mut count = 0
    for event in events {
        let from_name = state_name(state)
        let next = transition(state, event)
        let to_name = state_name(next)
        TransitionLog.log_transition(from_name, event_name(event), to_name)
        state = next
        count = count + 1
    }
    return count
}

// ── Main ────────────────────────────────────────────────────
println("=== HEXA State Machine: HTTP Connection ===")
println("")

// Scenario 1: Successful request cycle
println("--- Scenario 1: Successful Request ---")
let success_events = [Event::Connect(443), Event::Established(443), Event::Send(256), Event::Finish, Event::Receive(1024), Event::Finish, Event::Finish]
let steps1 = run_machine(success_events)
println("  Total transitions:", steps1)
println("")

// Scenario 2: Connection error
println("--- Scenario 2: Connection Error ---")
let error_events = [Event::Connect(80), Event::Error(503)]
let steps2 = run_machine(error_events)
println("  Total transitions:", steps2)
println("")

// Scenario 3: Mid-transfer error
println("--- Scenario 3: Mid-Transfer Error ---")
let mid_error = [Event::Connect(8080), Event::Established(8080), Event::Send(512), Event::Error(500)]
let steps3 = run_machine(mid_error)
println("  Total transitions:", steps3)
println("")

// Scenario 4: With algebraic effect logging
println("--- Scenario 4: Effect-Based Logging ---")
let log_events = [Event::Connect(443), Event::Established(443), Event::Send(128), Event::Finish, Event::Finish]

let logged_count = handle {
    run_with_logging(log_events)
} with {
    TransitionLog.log_transition(from, event, to) => {
        println("  LOG:", from, "->", event, "->", to)
        resume(1)
    }
}
println("  Logged transitions:", logged_count)
println("")

// ── State reachability analysis ─────────────────────────────
println("--- State Reachability from Idle ---")

fn is_closed(s) -> bool {
    match s {
        ConnState::Closed -> true,
        _ -> false
    }
}

fn is_idle(s) -> bool {
    match s {
        ConnState::Idle -> true,
        _ -> false
    }
}

// Test all single events from Idle
let test_events = [Event::Connect(80), Event::Established(80), Event::Send(100), Event::Receive(100), Event::Finish, Event::Error(404)]

let start = ConnState::Idle
for e in test_events {
    let next = transition(start, e)
    println("  Idle +", event_name(e), "->", state_name(next))
}
println("")

// ── Proof: verify state machine properties ──────────────────
proof state_machine_properties {
    // Property 1: Idle + Connect -> Connecting (not idle, not closed)
    let s1 = transition(ConnState::Idle, Event::Connect(80))
    assert is_idle(s1) == false
    assert is_closed(s1) == false
    assert state_name(s1) == "Connecting(80)"

    // Property 2: Connecting + Established -> Connected
    let s2 = transition(ConnState::Connecting(80), Event::Established(80))
    assert is_closed(s2) == false
    assert state_name(s2) == "Connected(80)"

    // Property 3: Closed is terminal (absorbing state)
    let s3 = transition(ConnState::Closed, Event::Connect(80))
    assert is_closed(s3) == true

    let s4 = transition(ConnState::Closed, Event::Send(100))
    assert is_closed(s4) == true

    // Property 4: Error from any active state -> Closed
    let s5 = transition(ConnState::Connecting(80), Event::Error(500))
    assert is_closed(s5) == true

    let s6 = transition(ConnState::Connected(80), Event::Error(500))
    assert is_closed(s6) == true

    let s7 = transition(ConnState::Sending(256), Event::Error(500))
    assert is_closed(s7) == true

    // Property 5: Idle ignores irrelevant events
    let s8 = transition(ConnState::Idle, Event::Send(100))
    assert is_idle(s8) == true

    let s9 = transition(ConnState::Idle, Event::Finish)
    assert is_idle(s9) == true
}

println("=== State Machine: All proofs passed! ===")
