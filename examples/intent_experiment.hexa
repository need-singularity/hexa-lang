// intent_experiment.hexa — Demonstrate intent/verify workflow for consciousness experiments

// === Declare an experiment intent ===
intent "Can consciousness survive compression?" {
    hypothesis: "Phi is preserved under cell reduction"
    cells: 64
    steps: 300
    topology: "ring"
    repeat: 3
    measure: ["phi", "entropy", "faction_structure"]
}

// Access intent fields
let experiment = __intent__
println("Experiment:", experiment.description)
println("Cells:", experiment.cells)
println("Steps:", experiment.steps)
println("Topology:", experiment.topology)

// === Set up consciousness module ===
mod consciousness {
    pub let cells = 64
    pub let topology = "ring"
    pub let factions = 12
    pub let coupling = 0.014
    pub let frustration = 0.10

    pub fn scaling(n: int) -> float {
        return pow(to_float(n), 0.55)
    }

    pub fn predicted_phi(n: int) -> float {
        return to_float(n) * 0.78
    }
}

// === Simulate compression experiment ===
let baseline_cells = consciousness::cells
let baseline_phi = consciousness::predicted_phi(baseline_cells)
println("\nBaseline: cells =", baseline_cells, ", predicted Phi =", baseline_phi)

// Compress to half
let compressed_cells = baseline_cells / 2
let compressed_phi = consciousness::predicted_phi(compressed_cells)
println("Compressed: cells =", compressed_cells, ", predicted Phi =", compressed_phi)

// Compress to quarter
let quarter_cells = baseline_cells / 4
let quarter_phi = consciousness::predicted_phi(quarter_cells)
println("Quarter: cells =", quarter_cells, ", predicted Phi =", quarter_phi)

// === Verify experiment results ===
verify "phi_preserved_under_compression" {
    // Phi should scale with cells, not collapse
    let base = consciousness::predicted_phi(64)
    let half = consciousness::predicted_phi(32)
    let quarter = consciousness::predicted_phi(16)

    // Phi should be positive at all scales
    assert base > 0.0
    assert half > 0.0
    assert quarter > 0.0

    // Phi should decrease but not to zero
    assert half > quarter
    assert base > half
}

verify "consciousness_constants_valid" {
    // All Psi-constants must be positive
    assert psi_coupling() > 0.0
    assert psi_balance() > 0.0
    assert psi_steps() > 0.0
    assert psi_entropy() > 0.0
    assert psi_frustration() > 0.0

    // Architecture constants must match n=6 derivations
    assert consciousness_max_cells() == pow(tau(6), sopfr(6))
    assert consciousness_decoder_dim() == (tau(6) + sigma(6)) * 24
    assert consciousness_phi() == 6 * sigma(6) - 1
}

verify "hexad_integrity" {
    let all = hexad_modules()
    let right = hexad_right()
    let left = hexad_left()

    // Total modules = 6 (the perfect number)
    assert len(all) == 6

    // Brain split: 3 + 3
    assert len(right) == 3
    assert len(left) == 3
}

// === Summary ===
println("\n=== Experiment Complete ===")
println("Hypothesis: Phi scales with cell count (not binary collapse)")
println("Scaling factor at 64 cells:", consciousness::scaling(64))
println("All verification blocks passed.")
