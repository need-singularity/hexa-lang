// physics.hexa — 간단한 물리 계산 (hexa → C → native)
// float 산술 + println 혼합 검증

fn square(x) {
    return x * x
}

fn approx_pi() {
    // 라이프니츠 급수 π/4 = 1 - 1/3 + 1/5 - 1/7 + ...
    // 수렴 느리지만 float 산술 검증용
    let mut s = 0.0
    let mut sign = 1.0
    let mut k = 0
    while k < 100000 {
        let denom = 2.0 * k + 1.0
        s = s + sign / denom
        sign = 0.0 - sign
        k = k + 1
    }
    return 4.0 * s
}

fn circle_area(r) {
    let pi = 3.141592653589793
    return pi * r * r
}

fn kinetic(m, v) {
    return 0.5 * m * v * v
}

println("== 물리 계산 (hexa self-host compiled) ==")
println("square(12) =", square(12))
println("circle_area(10) =", circle_area(10.0))
println("kinetic(2kg, 3m/s) =", kinetic(2.0, 3.0), "J")
println("π ≈", approx_pi())
println("done")
