// N1.1n: 함수 매개변수 타입 추론 — Str/DynArr 테스트

fn sum_arr(xs) {
    let mut total = 0
    let mut i = 0
    while i < len(xs) {
        total += xs[i]
        i += 1
    }
    return total
}

fn first_word(s) {
    // 공백 이전까지 substring
    let mut i = 0
    while i < s.len() {
        let c = s.substring(i, i + 1)
        if c == " " {
            return i
        }
        i += 1
    }
    return s.len()
}

let nums = [1, 2, 3, 4, 5, 100]
println("sum_arr =", sum_arr(nums))

let msg = "hello world"
let w = first_word(msg)
println("first word len =", w)
let first = msg.substring(0, w)
println("first word =", first)

// 빈 배열에 push해서 전달
let mut built = []
let mut j = 10
while j <= 50 {
    built = built.push(j)
    j += 10
}
println("built sum =", sum_arr(built))
println("done")
