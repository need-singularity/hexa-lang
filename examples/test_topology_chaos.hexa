// ══════════════════════════════════════════════════════════
// Anima 토폴로지 + 카오스 주입 테스트
// Laws 32-43 (카오스) + 토폴로지 자동 선택
// ══════════════════════════════════════════════════════════

// ═══ [1] Ring Topology ═══
let ring4 = ring_topology(4)
// 4×4 adj: each connected to ±1
println("[1] Ring(4) adjacency:")
println("    row0:", ring4[0], ring4[1], ring4[2], ring4[3])
println("    row1:", ring4[4], ring4[5], ring4[6], ring4[7])
// Expected: row0 = [0,1,0,1], row1 = [1,0,1,0]

// ═══ [2] Small-World Topology ═══
let sw8 = small_world_topology(8, 2, 0.3)
// 8 nodes, k=2 neighbors/side, p=0.3 rewire
let edges = 0
let i = 0
while i < 64 {
    if sw8[i] > 0.5 { edges = edges + 1 }
    i = i + 1
}
println("[2] Small-world(8, k=2, p=0.3): edges =", edges)

// ═══ [3] Hypercube Topology ═══
let hc8 = hypercube_topology(8)
// 8 = 2³, each node connected to 3 neighbors (differ by 1 bit)
let hc_edges = 0
let j = 0
while j < 64 {
    if hc8[j] > 0.5 { hc_edges = hc_edges + 1 }
    j = j + 1
}
println("[3] Hypercube(8): edges =", hc_edges)
// Expected: 8 nodes × 3 neighbors = 24 directed edges

// ═══ [4] Auto-Topology Selection ═══
let auto4 = auto_topology(4)   // should use ring
let auto12 = auto_topology(12) // should use small-world
let auto32 = auto_topology(32) // should use hypercube
println("[4] auto_topology(4): len=", len(auto4), "(ring 4×4=16)")
println("    auto_topology(12): len=", len(auto12), "(sw 12×12=144)")
println("    auto_topology(32): len=", len(auto32), "(hc 32×32=1024)")

// ═══ [5] Lorenz Attractor ═══
let lx = 1.0
let ly = 1.0
let lz = 1.0

// Evolve 100 steps
let step = 0
while step < 100 {
    let state = lorenz_step(lx, ly, lz, 0.01)
    lx = state[0]
    ly = state[1]
    lz = state[2]
    step = step + 1
}
println("[5] Lorenz after 100 steps: x=", round(lx * 1000) / 1000, "y=", round(ly * 1000) / 1000, "z=", round(lz * 1000) / 1000)
// Should be chaotic, not at origin

// ═══ [6] Chaos Perturbation ═══
let hidden = [0.1, 0.2, -0.1, 0.3]
let lorenz_state = [lx, ly, lz]
let perturbed = chaos_perturb(hidden, lorenz_state, 0.01)
println("[6] Chaos perturbed hidden:", perturbed)
println("    original:", hidden)
// Should be slightly different from original

// ═══ [7] Full Anima consciousness with topology + chaos ═══
let n = 4
let adj = auto_topology(n)
let cells = randn(16, 0.1)  // 4×4
let chaos = [1.0, 1.0, 1.0]

// Step: inject chaos → coupling → GRU
let chaos_new = lorenz_step(chaos[0], chaos[1], chaos[2], 0.01)
let cell0 = slice(cells, 0, 4)
let perturbed_cell = chaos_perturb(cell0, chaos_new, 0.001)

// Coupling via topology-weighted signals
let signals = matvec(adj, cells, n, n)  // simplified: adj acts on first dim
println("[7] Topology signals:", signals)
println("    Chaos-perturbed cell0:", perturbed_cell)

// ═══ @test ═══
@test fn test_ring_symmetric() {
    let r = ring_topology(4)
    // r[0,1] should equal r[1,0]
    assert(r[1] == r[4], "ring should be symmetric")
}

@test fn test_hypercube_degree() {
    let h = hypercube_topology(4)
    // node 0 (00) connects to 1 (01) and 2 (10) = degree 2
    let deg = h[1] + h[2] + h[3]
    assert(deg == 2.0, "hypercube(4) node degree should be 2")
}

@test fn test_lorenz_not_fixed() {
    let s = lorenz_step(1.0, 1.0, 1.0, 0.01)
    assert(s[0] != 1.0, "lorenz should evolve")
}

@test fn test_chaos_perturb_changes() {
    let v = [1.0, 2.0, 3.0]
    let p = chaos_perturb(v, [10.0, 20.0, 30.0], 0.1)
    assert(p[0] != v[0], "chaos should change values")
}

run_tests()

println("--- topology+chaos PASS ---")
