    let c2 = 3
    let c3 = 4
    let c4 = 5
    let c5 = 6
    let c6 = 7
    let c7 = 8

    // One GRU update step
    let c0_new = gru_step(c0, 0, 1)
    let c1_new = gru_step(c1, 0, 1)
    let c2_new = gru_step(c2, 0, 1)
    let c3_new = gru_step(c3, 0, 1)
    let c4_new = gru_step(c4, 0, 1)
    let c5_new = gru_step(c5, 0, 1)
    let c6_new = gru_step(c6, 0, 1)
    let c7_new = gru_step(c7, 0, 1)

    let total = c0_new + c1_new + c2_new + c3_new + c4_new + c5_new + c6_new + c7_new
    println("  Total state after update:", total)

    // Phi proxy: integration over fragmentation
    let phi_measured = compute_phi_proxy(total, 12)
