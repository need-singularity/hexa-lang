// diff.hexa — 두 파일의 라인 단위 차이 (간이)
// 사용: ./diff <file1> <file2>

// 본 fn 인라인 사용 (fn 매개변수 추론 우회)
fn main_diff() {
    if argc() < 3 {
        println("usage: diff <file1> <file2>")
        return 1
    }
    let a_path = arg(1)
    let b_path = arg(2)
    let a = read_file(a_path)
    let b = read_file(b_path)

    let a_lines = a.split("\n")
    let b_lines = b.split("\n")

    println("─── diff", a_path, "→", b_path, "───")

    let mut deleted = 0
    let mut i = 0
    while i < len(a_lines) {
        let line_a = a_lines[i]
        if line_a.len() > 0 {
            // b_lines에 있는지 확인
            let mut found = 0
            let mut j = 0
            while j < len(b_lines) {
                let line_b = b_lines[j]
                if line_a == line_b {
                    found = 1
                }
                j = j + 1
            }
            if found == 0 {
                println("-", line_a)
                deleted = deleted + 1
            }
        }
        i = i + 1
    }

    let mut added = 0
    let mut k = 0
    while k < len(b_lines) {
        let line_b = b_lines[k]
        if line_b.len() > 0 {
            let mut found = 0
            let mut m = 0
            while m < len(a_lines) {
                let line_a = a_lines[m]
                if line_b == line_a {
                    found = 1
                }
                m = m + 1
            }
            if found == 0 {
                println("+", line_b)
                added = added + 1
            }
        }
        k = k + 1
    }

    println("─── summary ───")
    println("- deleted:", deleted)
    println("+ added:  ", added)
    if deleted == 0 {
        if added == 0 {
            println("  (no differences)")
        }
    }
    return 0
}

let _r = main_diff()
