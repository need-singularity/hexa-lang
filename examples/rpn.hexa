// rpn.hexa — 역폴란드 표기법 계산기
// 사용: ./rpn "3 4 + 2 *"
// 지원: + - * / 정수

let mut stack = array_fill(100, 0)
let mut sp = 0

fn push(v) {
    stack[sp] = v
    sp = sp + 1
    return 0
}

fn pop() {
    sp = sp - 1
    return stack[sp]
}

fn is_digit_str(s: string) {
    if s.len() == 0 { return 0 }
    let c = s.substring(0, 1)
    if c >= "0" && c <= "9" { return 1 }
    if c == "-" && s.len() > 1 { return 1 }
    return 0
}

fn eval_rpn(expr: string) {
    sp = 0
    let tokens = expr.split(" ")
    let mut i = 0
    while i < len(tokens) {
        let tok = tokens[i]
        if tok.len() > 0 {
            if is_digit_str(tok) == 1 {
                let _r = push(parse_int(tok))
            } else if tok == "+" {
                let b = pop()
                let a = pop()
                let _r = push(a + b)
            } else if tok == "-" {
                let b = pop()
                let a = pop()
                let _r = push(a - b)
            } else if tok == "*" {
                let b = pop()
                let a = pop()
                let _r = push(a * b)
            } else if tok == "/" {
                let b = pop()
                let a = pop()
                if b != 0 {
                    let _r = push(a / b)
                } else {
                    println("error: div by zero")
                    return 0
                }
            }
        }
        i = i + 1
    }
    if sp == 1 {
        return pop()
    }
    println("error: stack not consumed, sp =", sp)
    return 0
}

if argc() >= 2 {
    let expr = arg(1)
    println(expr, "=", eval_rpn(expr))
} else {
    println("=== RPN tests ===")
    println("3 4 +          →", eval_rpn("3 4 +"))
    println("3 4 + 2 *      →", eval_rpn("3 4 + 2 *"))
    println("5 1 2 + 4 * + 3 - →", eval_rpn("5 1 2 + 4 * + 3 -"))
    println("100 5 /        →", eval_rpn("100 5 /"))
    println("2 3 * 4 5 * +  →", eval_rpn("2 3 * 4 5 * +"))
    println("expected: 7, 14, 14, 20, 26")
}
println("done")
