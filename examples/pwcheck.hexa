// pwcheck.hexa — 비밀번호 강도 검사
// 사용: ./pwcheck <password>

fn score_password(pw: string) {
    let mut score = 0
    let cs = pw.chars()
    let n = len(cs)

    // 길이 점수
    if n >= 8 { score = score + 1 }
    if n >= 12 { score = score + 1 }
    if n >= 16 { score = score + 1 }

    // 문자 종류 감지
    let mut has_lower = 0
    let mut has_upper = 0
    let mut has_digit = 0
    let mut has_special = 0
    let mut i = 0
    while i < n {
        let c = cs[i]
        if c >= 97 && c <= 122 { has_lower = 1 }
        if c >= 65 && c <= 90 { has_upper = 1 }
        if c >= 48 && c <= 57 { has_digit = 1 }
        if c < 48 || (c > 57 && c < 65) || (c > 90 && c < 97) || c > 122 {
            if c > 32 { has_special = 1 }
        }
        i = i + 1
    }
    score = score + has_lower + has_upper + has_digit + has_special

    // 반복 문자 패널티
    let mut repeat_count = 0
    let mut j = 1
    while j < n {
        if pw.substring(j, j + 1) == pw.substring(j - 1, j) {
            repeat_count = repeat_count + 1
        }
        j = j + 1
    }
    if repeat_count >= 3 { score = score - 1 }

    if score < 0 { score = 0 }
    return score
}

fn strength_label(s) {
    if s <= 2 { return "WEAK" }
    if s <= 4 { return "FAIR" }
    if s <= 6 { return "STRONG" }
    return "EXCELLENT"
}

fn check(pw: string) {
    let s = score_password(pw)
    let label = strength_label(s)
    println("'", pw, "' score =", s, " [", label, "]")
}

if argc() >= 2 {
    check(arg(1))
} else {
    println("=== password strength tests ===")
    check("abc")
    check("password")
    check("Password1")
    check("P@ssw0rd!")
    check("MyStr0ng!Pass")
    check("X7#kL9!mQ4@rP2$z")
    check("aaaaaaaa")
    check("12345678")
}
println("done")
