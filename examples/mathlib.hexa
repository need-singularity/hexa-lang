// 수학 라이브러리 전체 테스트
println("sqrt(2) =", sqrt(2.0))
println("sqrt(16) =", sqrt(16.0))
println("pow(2, 10) =", pow(2.0, 10.0))
println("pow(e, 1) =", exp(1.0))
println("log(e) =", log(exp(1.0)))
println("log10(1000) =", log10(1000.0))
println("sin(0) =", sin(0.0))
println("cos(0) =", cos(0.0))
println("floor(3.7) =", floor(3.7))
println("ceil(3.2) =", ceil(3.2))
println("round(3.5) =", round(3.5))
println("abs(-5) =", abs(0 - 5))
println("abs(-3.14) =", abs(0.0 - 3.14))
println("min(3, 7) =", min(3, 7))
println("max(3, 7) =", max(3, 7))
println("min(3.5, 2.1) =", min(3.5, 2.1))
println("done")
