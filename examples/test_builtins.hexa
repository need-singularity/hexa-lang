// Test file for --test mode: standard library builtins

// Helper function
fn double(x: int) -> int {
    return x * 2
}

// Math builtins
proof test_abs {
    assert abs(-6) == 6
    assert abs(6) == 6
}

proof test_min_max {
    assert min(3, 7) == 3
    assert max(3, 7) == 7
}

proof test_floor_ceil_round {
    assert floor(3.7) == 3
    assert ceil(3.2) == 4
    assert round(3.5) == 4
}

proof test_sqrt {
    assert sqrt(9) == 3.0
}

proof test_pow {
    assert pow(2, 10) == 1024
}

proof test_trig {
    assert sin(0.0) == 0.0
    assert cos(0.0) == 1.0
}

proof test_log {
    assert log2(8) == 3.0
}

proof test_constants {
    assert PI > 3.14
    assert PI < 3.15
    assert E > 2.71
    assert E < 2.72
}

// Format builtins
proof test_format {
    assert format("x={}", 42) == "x=42"
    assert format("{} + {} = {}", 1, 2, 3) == "1 + 2 = 3"
}

// Conversion builtins
proof test_conversions {
    assert to_string(42) == "42"
    assert to_int("123") == 123
    assert to_int(3.7) == 3
}

// OS builtins
proof test_clock {
    let t = clock()
    assert t > 0.0
}

// sigma(6) = 12, the perfect property
proof test_sigma_six {
    assert sigma(6) == 12
    assert sigma(6) * phi(6) == 6 * tau(6)
}
