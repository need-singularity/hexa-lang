// rot13.hexa — ROT13 암호 (자기역함수: 같은 함수로 암복호화)
// 사용: ./rot13 "text"

fn rot13_char(c) {
    // 'a'=97, 'z'=122, 'A'=65, 'Z'=90
    if c >= 97 {
        if c <= 122 {
            return ((c - 97 + 13) % 26) + 97
        }
    }
    if c >= 65 {
        if c <= 90 {
            return ((c - 65 + 13) % 26) + 65
        }
    }
    return c
}

// 단일 int → 1-char string (ASCII)
fn char_from_code(n) {
    // 간이: 아스키 문자만. ASCII 한 글자를 C가 어떻게 낼지 tricky.
    // 대신 lookup table 사용
    let abc = " !\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_`abcdefghijklmnopqrstuvwxyz{|}~"
    if n >= 32 {
        if n < 127 {
            let idx = n - 32
            return abc.substring(idx, idx + 1)
        }
    }
    return "?"
}

fn rot13(s: string) {
    let mut out = ""
    let cs = s.chars()
    let n = len(cs)
    let mut i = 0
    while i < n {
        let c = cs[i]
        let r = rot13_char(c)
        out = out + char_from_code(r)
        i = i + 1
    }
    return out
}

if argc() < 2 {
    println("=== built-in tests ===")
    println("hello     →", rot13("hello"))
    println("world     →", rot13("world"))
    println("HEXA      →", rot13("HEXA"))
    println("rot13!    →", rot13("rot13!"))
    println("round-trip:")
    let enc = rot13("Hello, World!")
    println("  enc     →", enc)
    println("  dec     →", rot13(enc))
} else {
    let txt = arg(1)
    println(rot13(txt))
}
println("done")
