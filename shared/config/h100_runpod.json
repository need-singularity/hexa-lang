{
  "id": "h100_runpod_policy",
  "kind": "gpu_activation_policy",
  "role": "RunPod H100 임대 제한 체크 + 자동 활성화 정책",
  "updated": "2026-04-11",
  "rule_refs": ["R5 SSOT", "R14"],

  "limits": {
    "max_pods": 3,
    "max_pods_base": 2,
    "max_pods_ml": 1,
    "gpu_type": "H100 SXM 80GB",
    "max_hourly_cost_usd": 8.49,
    "max_daily_budget_usd": 204.0,
    "max_monthly_budget_usd": 2100.0,
    "auto_terminate_idle_minutes": 15,
    "max_runtime_hours_per_pod": 48
  },

  "activation": {
    "auto_activate": true,
    "pre_check": [
      "현재 활성 pod 수 < max_pods",
      "일일 누적 비용 < max_daily_budget_usd",
      "월 누적 비용 < max_monthly_budget_usd",
      "작업 큐에 GPU 필요 항목 존재"
    ],
    "command": "runpodctl create pod --gpuType 'NVIDIA H100 80GB HBM3' --gpuCount 1 --imageName needsingularity/anima-h100:latest --name hexa-ml-{id} --volumeInGb 50",
    "post_activate": [
      "git pull hexa-lang",
      "git pull anima",
      "./hexa --version",
      "gpu_smoke_test.hexa"
    ],
    "on_complete": "runpodctl remove pod {pod_id}",
    "on_idle": "runpodctl stop pod {pod_id}"
  },

  "cost_tracking": {
    "provider": "runpod",
    "gpu_cost_per_hour_usd": 2.49,
    "storage_cost_per_month_gb_usd": 0.07,
    "history_file": "shared/hexa-lang/h100_cost_history.json",
    "alert_threshold_pct": 80
  },

  "current_state": {
    "active_pods": 0,
    "total_hours_used": 4.2,
    "total_cost_usd": 10.46,
    "last_pod_terminated": "2026-04-11",
    "sessions": [
      {"round": 3, "pod": "uu8ebnawzg1qwp", "hours": 0.5, "result": "smoke 36.41 TFLOPS"},
      {"round": 7, "pod": "q9esca195nq70k", "hours": 0.5, "result": "smoke 36.41 TFLOPS"},
      {"round": 8, "pod": "5gopnamsavv7se", "hours": 3.2, "result": "bench 52.29 TFLOPS + train step 1"}
    ]
  },

  "cross_refs": {
    "p5_zeta": "shared/roadmaps/p5_zeta.json",
    "ml_roadmap": "shared/hexa-lang/ml-next-level.json",
    "perf_tracker": "shared/hexa-lang/ml-perf-tracker.json"
  }
}
