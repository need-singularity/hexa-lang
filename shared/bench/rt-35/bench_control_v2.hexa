// Bench: mix of stmt kinds — let, assign, if, while, return, call
fn run(n) {
    let mut sum = 0
    let mut i = 0
    while i < n {
        let x = i * 2
        if x % 3 == 0 {
            sum = sum + x
        } else {
            sum = sum - 1
        }
        i = i + 1
    }
    return sum
}
let r = run(50000)
println(r)
