      "impact": "서버리스/edge 배포에서 결정적 차이"
    },
    "memory_footprint": {
      "pytorch_7b_fp16": "14 GB + ~2 GB runtime",
      "hexa_7b_q4": "3.5 GB + ~50 MB runtime",
      "reduction": "4.5x",
      "impact": "저사양 서버/엣지 배포 가능"
    },
    "binary_size": {
      "pytorch": "~2 GB (torch + deps)",
      "hexa": "8.9 MB (static musl)",
      "reduction": "224x"
    },
    "ecosystem_maturity": {
      "pytorch": "10/10 — 수만 개 모델, HuggingFace 생태계, 수년간 최적화",
      "hexa": "3/10 — 코어 파이프라인 구현됨, 프리트레인 모델 생태계 없음",
      "gap": "모델 허브, 커뮤니티, 프리트레인 체크포인트"
    }
  },

  "zero_dependencies": {
    "python": false,
    "pytorch": false,
    "tensorflow": false,
    "onnxruntime": false,
    "required": ["CUDA toolkit (GPU only)", "BLAS library (CPU, optional — pure-Rust fallback)"],
    "binary": "single static ELF (musl, 8.9MB)"
  },

  "perf_tracker": "shared/hexa-lang/ml-perf-tracker.json"
}
