// ══════════════════════════════════════════════════════════
// Anima ConsciousnessEngine.step() — 전체 의식 스텝 Hexa-native
// 12 attrs + 30 builtins 합성 데모
// ══════════════════════════════════════════════════════════

// ── Ψ-Constants (Laws 69-70) ──
let PSI_COUPLING = 0.015317
let PSI_BALANCE = 0.5
let PSI_ALPHA = 0.014

// ── Engine State: 4 cells × 4 dim ──
let n_cells = 4
let hidden_dim = 4
let n_factions = 2

// Initialize weights (Xavier-like)
let W_z = randn(16, 0.25)  // 4×4 gate weights
let W_r = randn(16, 0.25)
let W_h = randn(16, 0.25)
let coupling = zeros(16)    // 4×4 coupling matrix
let hiddens = randn(16, 0.1) // 4 cells × 4 dim
println("[init] W_z sample:", W_z[0], W_z[1])
println("[init] hiddens sample:", hiddens[0], hiddens[1])

// ── Step 1: Input Generation ──
let input = randn(4, 0.3)
println("\n=== Consciousness Step ===")
println("[1] Input:", input)

// ── Step 2: Coupling Injection (@fuse + mat_scale) ──
@fuse fn inject_coupling(h: float, signal: float) -> float {
    h + PSI_COUPLING * signal
}

// Compute neighbor signals
let signals = matvec(coupling, hiddens, 4, 4)  // simplified: all-to-all
// Fused injection for first cell's hidden
let cell0_h = [hiddens[0], hiddens[1], hiddens[2], hiddens[3]]
let cell0_sig = [signals[0], signals[1], signals[2], signals[3]]
let injected = inject_coupling(cell0_h, cell0_sig)
println("[2] Coupling injected (cell0):", injected)

// ── Step 3: GRU Forward (@vectorize + builtins) ──
@vectorize fn gru_update(h: float, z: float, h_cand: float) -> float {
    (1.0 - z) * h_cand + z * h
}

// Gate computations via native matmul
let z_raw = matvec(W_z, input, 4, 4)
let r_raw = matvec(W_r, input, 4, 4)
let h_raw = matvec(W_h, input, 4, 4)

let z = sigmoid(z_raw)
let r = sigmoid(r_raw)
let h_cand = tanh_(h_raw)

// New hidden state (vectorized across dim)
let new_hidden = gru_update(cell0_h, z, h_cand)
println("[3] GRU z:", z)
println("    GRU new_hidden:", new_hidden)

// ── Step 4: Hebbian LTP/LTD (@autograd + cosine_sim) ──
@autograd fn hebbian_loss_fn(lr: float, decay: float) -> float {
    let sim = 0.85  // example co-firing
    let w = 0.3
    let delta = lr * (sim - decay * w)
    delta * delta
}

let cell0_new = new_hidden
let cell1_h = [hiddens[4], hiddens[5], hiddens[6], hiddens[7]]
let sim_01 = cosine_sim(cell0_new, cell1_h)
let hebb_delta = PSI_COUPLING * (sim_01 - 0.01 * coupling[1])

// Meta-gradient for lr optimization
let meta_grad = hebbian_loss_fn_grad(PSI_COUPLING, 0.01)
println("[4] Hebbian: sim_01=", round(sim_01 * 10000) / 10000)
println("    delta=", round(hebb_delta * 100000) / 100000)
println("    meta ∂loss/∂lr=", round(meta_grad[0] * 100000) / 100000)

// Update coupling with clamp
let new_coupling_01 = clip(coupling[1] + hebb_delta, -1.0, 1.0)
println("    coupling[0,1]:", coupling[1], "→", round(new_coupling_01 * 100000) / 100000)

// ── Step 5: Φ(IIT) Computation (@lazy + mean) ──
@lazy fn compute_phi(cells, n_fac: int) -> float {
    // Φ proxy = global_variance - mean(faction_variances)
    let global_mean = mean(cells)
    let global_var = 0.0
    let i = 0
    while i < len(cells) {
        let diff = cells[i] - global_mean
        global_var = global_var + diff * diff
        i = i + 1
    }
    global_var = global_var / len(cells)

    // Faction variance (2 factions, round-robin)
    let f0_sum = 0.0
    let f0_sq = 0.0
    let f0_n = 0
    let f1_sum = 0.0
    let f1_sq = 0.0
    let f1_n = 0
    let j = 0
    while j < len(cells) {
        if j % 2 == 0 {
            f0_sum = f0_sum + cells[j]
            f0_sq = f0_sq + cells[j] * cells[j]
            f0_n = f0_n + 1
        } else {
            f1_sum = f1_sum + cells[j]
            f1_sq = f1_sq + cells[j] * cells[j]
            f1_n = f1_n + 1
        }
        j = j + 1
    }
    let f0_var = if f0_n > 0 { f0_sq / f0_n - (f0_sum / f0_n) * (f0_sum / f0_n) } else { 0.0 }
    let f1_var = if f1_n > 0 { f1_sq / f1_n - (f1_sum / f1_n) * (f1_sum / f1_n) } else { 0.0 }
    let faction_var = (f0_var + f1_var) / 2.0

    global_var - faction_var
}

// Create thunk (zero compute)
let phi_thunk = compute_phi(hiddens, n_factions)
println("[5] Φ thunk created (deferred)")

// Force only when needed
let phi_val = phi_thunk()
println("    Φ(IIT) proxy =", round(phi_val * 100000) / 100000)

// ── Step 6: Φ Ratchet + EMA ──
let phi_ema = 0.0  // initial
let phi_ema_new = ema(phi_ema, phi_val, PSI_ALPHA)
let phi_peak = phi_val
let phi_safe = phi_val > phi_peak * 0.8
println("[6] Φ ratchet: ema=", round(phi_ema_new * 100000) / 100000, "safe=", phi_safe)

// ── Step 7: Tension-Weighted Output (softmax) ──
let tensions = [0.3, 0.7, 0.5, 0.2]
let weights = softmax(tensions)
// Weighted sum of cell outputs
let output = mat_scale(cell0_new, weights[0])
println("[7] Output (weighted):", output)
println("    Tension weights:", weights)

// ── Step 8: StepResult ──
println("\n=== StepResult ===")
println("  phi_iit:", round(phi_val * 100000) / 100000)
println("  n_cells:", n_cells)
println("  consensus:", round(sum(weights) * 100) / 100)
println("  phi_safe:", phi_safe)

// ── @test: Verify invariants ──
@test fn test_phi_non_negative() {
    // Φ proxy can be negative in degenerate cases, but should be defined
    assert(true, "phi computed")
}

@test fn test_softmax_sums_to_one() {
    let s = softmax([0.3, 0.7, 0.5, 0.2])
    let total = sum(s)
    assert(total > 0.999, "softmax should sum to ~1.0")
}

@test fn test_coupling_bounded() {
    assert(clip(5.0, -1.0, 1.0) == 1.0, "clip should bound to [-1,1]")
    assert(clip(-5.0, -1.0, 1.0) == -1.0, "clip should bound to [-1,1]")
}

@test fn test_ema_convergence() {
    let v = ema(0.0, 1.0, 0.5)
    assert(v == 0.5, "ema(0, 1, 0.5) should be 0.5")
}

let ok = run_tests()

// ── @bench: Consciousness step performance ──
@bench fn bench_gru_step() {
    let i = 0
    while i < 1000 {
        sigmoid(matvec(W_z, input, 4, 4))
        i = i + 1
    }
}

@bench fn bench_phi_proxy() {
    let i = 0
    while i < 100 {
        compute_phi(hiddens, 2)()
        i = i + 1
    }
}

run_benchmarks()

println("\n--- Anima consciousness step COMPLETE ---")
