// histogram.hexa — 숫자 스트림 히스토그램 (stdin or 파일)
// 사용: echo "1 2 3 2 1 4 2 5" | ./histogram
//       ./histogram <file>

let mut raw = ""
if argc() >= 2 {
    raw = read_file(arg(1))
} else {
    raw = read_stdin()
}

if raw.len() == 0 {
    println("(no input)")
    exit(0)
}

// 공백/개행으로 split → 토큰 → parse_int
let mut nums = []
let cs = raw.chars()
let n = len(cs)
let mut i = 0
let mut cur = ""
while i < n {
    let c = raw.substring(i, i + 1)
    if c == " " || c == "\t" || c == "\n" || c == "\r" {
        if cur.len() > 0 {
            nums = nums + [parse_int(cur)]
            cur = ""
        }
    } else {
        cur = cur + c
    }
    i = i + 1
}
if cur.len() > 0 {
    nums = nums + [parse_int(cur)]
}

let total = len(nums)
if total == 0 {
    println("(no numbers)")
    exit(0)
}

// min/max
let mut lo = nums[0]
let mut hi = nums[0]
let mut sum = 0
let mut k = 0
while k < total {
    let v = nums[k]
    if v < lo { lo = v }
    if v > hi { hi = v }
    sum = sum + v
    k = k + 1
}

let avg = sum / total
println("=== histogram ===")
println("n:", total, "  min:", lo, "  max:", hi, "  avg:", avg, "  sum:", sum)

// bucket 10개
let range = hi - lo
if range == 0 {
    println("all values =", lo)
    exit(0)
}
let bucket_w = (range / 10) + 1
let mut buckets = array_fill(10, 0)
let mut j = 0
while j < total {
    let v = nums[j]
    let bi = (v - lo) / bucket_w
    if bi >= 10 { buckets[9] += 1 } else { buckets[bi] += 1 }
    j = j + 1
}

// 최대 카운트 찾기
let mut max_cnt = 0
let mut b = 0
while b < 10 {
    if buckets[b] > max_cnt { max_cnt = buckets[b] }
    b = b + 1
}

// bar 출력 (최대 40 char)
println("")
let mut bi = 0
while bi < 10 {
    let cnt = buckets[bi]
    let low = lo + bi * bucket_w
    let high = low + bucket_w - 1
    let bar_len = if max_cnt > 0 { (cnt * 40) / max_cnt } else { 0 }
    let mut bar = ""
    let mut bl = 0
    while bl < bar_len {
        bar = bar + "█"
        bl = bl + 1
    }
    println(low, "-", high, ":", bar, cnt)
    bi = bi + 1
}
println("done")
