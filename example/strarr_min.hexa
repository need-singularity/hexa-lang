// N1.1p: 문자열 배열
let words = ["apple", "banana", "cherry", "date"]
println("words len =", len(words))
let mut i = 0
while i < len(words) {
    println(i, "->", words[i])
    i = i + 1
}

// 런타임 concat으로 문장 조립
let mut joined = ""
let mut j = 0
while j < len(words) {
    if j > 0 {
        joined = joined + ", "
    }
    joined = joined + words[j]
    j = j + 1
}
println("joined:", joined)
println("done")
