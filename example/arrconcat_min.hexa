// 배열 concat via +
let a = [1, 2, 3]
let b = [4, 5, 6]
let c = a + b
println("a+b len =", len(c))
let mut i = 0
while i < len(c) {
    println(i, "=", c[i])
    i = i + 1
}

// Str 배열 concat
let x = ["foo", "bar"]
let y = ["baz", "qux"]
let z = x + y
println("str len =", len(z))
for s in z {
    println(s)
}

// build up via concat
let mut acc = []
acc = acc + [10]
acc = acc + [20]
acc = acc + [30]
println("acc:", len(acc), acc[0], acc[1], acc[2])
println("done")
