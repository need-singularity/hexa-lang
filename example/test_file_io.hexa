// File I/O end-to-end test
let test_path = "/tmp/hexa_file_io_test.txt"
let passed = 0
let failed = 0

// Test 1: write_file
write_file(test_path, "hello hexa")
println("Test 1 write_file: OK")
passed = passed + 1

// Test 2: file_exists (true)
if file_exists(test_path) {
    println("Test 2 file_exists(true): OK")
    passed = passed + 1
} else {
    println("Test 2 file_exists(true): FAIL")
    failed = failed + 1
}

// Test 3: read_file
let content = read_file(test_path)
if content == "hello hexa" {
    println("Test 3 read_file: OK")
    passed = passed + 1
} else {
    println("Test 3 read_file: FAIL — got: " + content)
    failed = failed + 1
}

// Test 4: append_file
append_file(test_path, "\nworld")
let content2 = read_file(test_path)
if content2 == "hello hexa\nworld" {
    println("Test 4 append_file: OK")
    passed = passed + 1
} else {
    println("Test 4 append_file: FAIL — got: " + content2)
    failed = failed + 1
}

// Test 5: delete_file
delete_file(test_path)
if file_exists(test_path) == false {
    println("Test 5 delete_file: OK")
    passed = passed + 1
} else {
    println("Test 5 delete_file: FAIL — file still exists")
    failed = failed + 1
}

// Test 6: file_exists (false after delete)
if file_exists("/tmp/hexa_nonexistent_xyz_abc.txt") == false {
    println("Test 6 file_exists(false): OK")
    passed = passed + 1
} else {
    println("Test 6 file_exists(false): FAIL")
    failed = failed + 1
}

// Test 7: read_file error handling (non-existent file)
let err_result = read_file("/tmp/hexa_nonexistent_xyz_abc.txt")
println("Test 7 read_file error: " + type_of(err_result))

// Test 8: env_var
let home = env_var("HOME")
if type_of(home) == "string" {
    println("Test 8 env_var(HOME): OK — " + home)
    passed = passed + 1
} else {
    println("Test 8 env_var(HOME): FAIL")
    failed = failed + 1
}

// Test 9: args
let a = args()
if type_of(a) == "array" {
    println("Test 9 args(): OK — length " + to_string(len(a)))
    passed = passed + 1
} else {
    println("Test 9 args(): FAIL")
    failed = failed + 1
}

// Summary
println("")
println("=== File I/O Tests: " + to_string(passed) + " passed, " + to_string(failed) + " failed ===")

if failed > 0 {
    exit(1)
}
