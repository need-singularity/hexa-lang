// N1.1m: 동적 배열 + push
let mut xs = []
let mut i = 1
while i <= 5 {
    xs.push(i * i)
    i += 1
}
println("len =", len(xs))
let mut j = 0
while j < len(xs) {
    println("xs[", j, "] =", xs[j])
    j += 1
}

// 리터럴 + push
let mut ys = [10, 20, 30]
ys.push(40)
ys.push(50)
println("ys len =", ys.len())
println("ys last =", ys[4])
println("done")
