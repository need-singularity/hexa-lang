// struct_patterns.hexa — Struct patterns: builder, impl, method chaining
// Demonstrates: struct, impl, builder pattern, generic-like any type

println("=== Struct Patterns in HEXA ===")
println("")

// ── 1. Basic struct with impl ──────────────────────────────
println("--- 1. Point with impl ---")

struct Point {
    x: float,
    y: float
}

impl Point {
    fn display(self) -> str {
        return format("({}, {})", self.x, self.y)
    }

    fn distance_to(self, other: Point) -> float {
        let dx = self.x - other.x
        let dy = self.y - other.y
        return sqrt(dx * dx + dy * dy)
    }

    fn translate(self, dx: float, dy: float) -> Point {
        return Point { x: self.x + dx, y: self.y + dy }
    }

    fn scale(self, factor: float) -> Point {
        return Point { x: self.x * factor, y: self.y * factor }
    }
}

let origin = Point { x: 0.0, y: 0.0 }
let p1 = Point { x: 3.0, y: 4.0 }
println("  Origin:", origin.display())
println("  P1:    ", p1.display())
println("  Distance origin->P1:", p1.distance_to(origin))
assert p1.distance_to(origin) == 5.0

// Method chaining: translate then scale
let p2 = p1.translate(1.0, 1.0).scale(2.0)
println("  P1.translate(1,1).scale(2):", p2.display())
println("")

// ── 2. Builder pattern ─────────────────────────────────────
println("--- 2. Builder Pattern ---")

struct Config {
    host: str,
    port: int,
    max_retries: int,
    timeout_ms: int,
    verbose: bool
}

struct ConfigBuilder {
    host: str,
    port: int,
    max_retries: int,
    timeout_ms: int,
    verbose: bool
}

impl ConfigBuilder {
    fn set_host(self, h: str) -> ConfigBuilder {
        return ConfigBuilder {
            host: h,
            port: self.port,
            max_retries: self.max_retries,
            timeout_ms: self.timeout_ms,
            verbose: self.verbose
        }
    }

    fn set_port(self, p: int) -> ConfigBuilder {
        return ConfigBuilder {
            host: self.host,
            port: p,
            max_retries: self.max_retries,
            timeout_ms: self.timeout_ms,
            verbose: self.verbose
        }
    }

    fn set_retries(self, r: int) -> ConfigBuilder {
        return ConfigBuilder {
            host: self.host,
            port: self.port,
            max_retries: r,
            timeout_ms: self.timeout_ms,
            verbose: self.verbose
        }
    }

    fn set_timeout(self, t: int) -> ConfigBuilder {
        return ConfigBuilder {
            host: self.host,
            port: self.port,
            max_retries: self.max_retries,
            timeout_ms: t,
            verbose: self.verbose
        }
    }

    fn set_verbose(self, v: bool) -> ConfigBuilder {
        return ConfigBuilder {
            host: self.host,
            port: self.port,
            max_retries: self.max_retries,
            timeout_ms: self.timeout_ms,
            verbose: v
        }
    }

    fn build(self) -> Config {
        return Config {
            host: self.host,
            port: self.port,
            max_retries: self.max_retries,
            timeout_ms: self.timeout_ms,
            verbose: self.verbose
        }
    }

    fn display(self) -> str {
        return format("Config({}:{}, retries={}, timeout={}ms, verbose={})", self.host, self.port, self.max_retries, self.timeout_ms, self.verbose)
    }
}

fn new_config_builder() -> ConfigBuilder {
    return ConfigBuilder {
        host: "localhost",
        port: 8080,
        max_retries: 3,
        timeout_ms: 5000,
        verbose: false
    }
}

// Chain builder methods
let cfg = new_config_builder().set_host("api.example.com").set_port(443).set_retries(5).set_timeout(10000).set_verbose(true).build()

println("  Built config:")
println("    Host:       ", cfg.host)
println("    Port:       ", cfg.port)
println("    Max retries:", cfg.max_retries)
println("    Timeout:    ", cfg.timeout_ms, "ms")
println("    Verbose:    ", cfg.verbose)

assert cfg.host == "api.example.com"
assert cfg.port == 443
assert cfg.max_retries == 5
println("")

// ── 3. Linked list with struct ─────────────────────────────
println("--- 3. Stack (array-based) ---")

struct Stack {
    items: any,
    size: int
}

impl Stack {
    fn push_val(self, val) -> Stack {
        return Stack {
            items: self.items.push(val),
            size: self.size + 1
        }
    }

    fn peek(self) {
        if self.size == 0 {
            return nil
        }
        return self.items[self.size - 1]
    }

    fn pop_val(self) -> Stack {
        if self.size == 0 {
            return self
        }
        let mut new_items = []
        let mut i = 0
        while i < self.size - 1 {
            new_items.push(self.items[i])
            i = i + 1
        }
        return Stack { items: new_items, size: self.size - 1 }
    }

    fn is_empty(self) -> bool {
        return self.size == 0
    }

    fn display(self) -> str {
        if self.size == 0 {
            return "Stack[]"
        }
        let mut s = "Stack["
        let mut i = 0
        while i < self.size {
            if i > 0 { s = s + ", " }
            s = s + to_string(self.items[i])
            i = i + 1
        }
        return s + "]"
    }
}

fn new_stack() -> Stack {
    return Stack { items: [], size: 0 }
}

let mut stack = new_stack()
println("  Empty:", stack.display())

stack = stack.push_val(10).push_val(20).push_val(30)
println("  After push 10, 20, 30:", stack.display())
println("  Peek:", stack.peek())
assert stack.peek() == 30

stack = stack.pop_val()
println("  After pop:", stack.display())
println("  Peek:", stack.peek())
assert stack.peek() == 20

stack = stack.push_val(99)
println("  After push 99:", stack.display())
assert stack.size == 3
println("")

// ── 4. Generic-like with any type ──────────────────────────
println("--- 4. Pair (any type) ---")

struct Pair {
    first: any,
    second: any
}

impl Pair {
    fn display(self) -> str {
        return format("({}, {})", self.first, self.second)
    }

    fn swap(self) -> Pair {
        return Pair { first: self.second, second: self.first }
    }

    fn map_first(self, f) -> Pair {
        return Pair { first: f(self.first), second: self.second }
    }

    fn map_second(self, f) -> Pair {
        return Pair { first: self.first, second: f(self.second) }
    }

    fn map_both(self, f) -> Pair {
        return Pair { first: f(self.first), second: f(self.second) }
    }
}

// Works with ints
let int_pair = Pair { first: 10, second: 20 }
println("  Int pair:", int_pair.display())
println("  Swapped: ", int_pair.swap().display())

// Works with strings
let str_pair = Pair { first: "hello", second: "world" }
println("  Str pair:", str_pair.display())
println("  Swapped: ", str_pair.swap().display())

// Works with mixed types
let mixed = Pair { first: "answer", second: 42 }
println("  Mixed:   ", mixed.display())

// Higher-order: map
let doubled = int_pair.map_both(|x| x * 2)
println("  Doubled: ", doubled.display())
assert doubled.first == 20
assert doubled.second == 40
println("")

// ── 5. Iterator pattern ────────────────────────────────────
println("--- 5. Range Iterator ---")

struct Range {
    current: int,
    end_val: int,
    step: int
}

impl Range {
    fn has_next(self) -> bool {
        if self.step > 0 {
            return self.current < self.end_val
        }
        return self.current > self.end_val
    }

    fn next(self) -> Range {
        return Range {
            current: self.current + self.step,
            end_val: self.end_val,
            step: self.step
        }
    }

    fn value(self) -> int {
        return self.current
    }
}

fn make_range(start: int, end_val: int, step: int) -> Range {
    return Range { current: start, end_val: end_val, step: step }
}

// Forward range
let mut r = make_range(0, 10, 2)
let mut vals = []
while r.has_next() {
    vals.push(r.value())
    r = r.next()
}
println("  Range(0, 10, 2):", vals)

// Backward range
let mut r2 = make_range(10, 0, -2)
let mut vals2 = []
while r2.has_next() {
    vals2.push(r2.value())
    r2 = r2.next()
}
println("  Range(10, 0, -2):", vals2)
println("")

println("=== Struct patterns complete! ===")
