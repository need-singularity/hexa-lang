// ══════════════════════════════════════════════════════════
// Hexa Standard Library 통합 테스트
// ══════════════════════════════════════════════════════════

import "../stdlib/nn.hexa"
import "../stdlib/optim.hexa"
import "../stdlib/consciousness.hexa"

let PSI_ALPHA = 0.014
let PSI_COUPLING = 0.015317
println("\n=== Stdlib Integration ===")

// [1] nn: MLP forward
let W1 = xavier_init(2, 4)
let b1 = zeros(4)
let W2 = xavier_init(4, 3)
let b2 = zeros(3)
let logits = mlp2([1.0, 0.5], W1, b1, W2, b2, 2, 4, 3)
println("[1] MLP2:", logits, "pred:", argmax(logits))

// [2] nn: Hexad loss
let loss = hex_loss(logits, 1, 0.5, PSI_ALPHA)
println("[2] Hexad loss:", round(loss * 1000) / 1000)

// [3] optim: scheduled LR
let lr = scheduled_lr(0.001, 50, 1000, 100)
println("[3] LR(step=50):", lr)

// [4] optim: safe Adam update
let p = randn(8, 0.5)
let g = randn(8, 1.0)
let m = zeros(8)
let v = zeros(8)
let r = safe_update(p, g, m, v, 0.001, 1, 1.0)
let new_p = slice(r, 0, 8)
println("[4] Adam (clipped): changed=", new_p[0] != p[0])

// [5] consciousness: step
let h = randn(16, 0.1)
let adj = auto_topology(4)
let chaos = [1.0, 1.0, 1.0]
let cs = cons_step(h, adj, chaos, 4, 4)
println("[5] Consciousness step:")
println("    tensions:", cs[2])
println("    Φ:", round(cs[3] * 100000) / 100000)
println("    weights:", cs[4])

// [6] Full Anima pipeline via stdlib
println("\n[6] Full Pipeline:")
let input = randn(4, 0.3)
let mW1 = xavier_init(4, 8)
let mb1 = zeros(8)
let mW2 = xavier_init(8, 4)
let mb2 = zeros(4)

let pred = mlp2(input, mW1, mb1, mW2, mb2, 4, 8, 4)
let cs2 = cons_step(h, adj, chaos, 4, 4)
let phi = cs2[3]
let final_loss = hex_loss(pred, 2, phi, PSI_ALPHA)
let lr2 = scheduled_lr(0.001, 10, 100, 20)

println("    pred:", argmax(pred), "loss:", round(final_loss * 1000) / 1000, "Φ:", round(phi * 100000) / 100000, "lr:", lr2)

// [7] Hebbian
let c0 = slice(h, 0, 4)
let c1 = slice(h, 4, 8)
let delta = hebb_delta(c0, c1, 0.0, PSI_COUPLING)
println("[7] Hebbian delta:", round(delta * 100000) / 100000)

@test fn test_mlp_shape() {
    let out = mlp2([1.0, 2.0], xavier_init(2, 4), zeros(4), xavier_init(4, 5), zeros(5), 2, 4, 5)
    assert(len(out) == 5, "output dim should be 5")
}
@test fn test_hex_loss_less_than_ce() {
    let l = [2.0, 0.5, 1.0]
    assert(hex_loss(l, 0, 0.5, 0.014) < ce_loss(l, 0), "hexad < CE when Φ>0")
}
@test fn test_consciousness_phi() {
    let r = cons_step(randn(8, 0.1), ring_topology(2), [1.0, 1.0, 1.0], 2, 4)
    assert(len(r) == 5, "cons_step returns 5-element array")
}
run_tests()

println("\n--- stdlib PASS ---")
