// test_closures.hexa — Closure/lambda tests (B-series blockers)
// Tests: |x| syntax, variable capture, higher-order functions, nested closures

println("=== Closure / Lambda Tests ===")

// --- 1. Basic lambda with single param ---
let double = |x| x * 2
println("double(6) =", double(6))
assert double(6) == 12

// --- 2. Multi-param lambda ---
let add = |x, y| x + y
println("add(3, 4) =", add(3, 4))
assert add(3, 4) == 7

// --- 3. Lambda with block body ---
let calc = |x, y| {
    let sum = x + y
    return sum * 2
}
println("calc(3, 4) =", calc(3, 4))
assert calc(3, 4) == 14

// --- 4. Closure capturing outer variable ---
let factor = 6
let mul = |x| x * factor
println("mul(7) with factor=6 =", mul(7))
assert mul(7) == 42

// --- 5. Closure capturing multiple variables ---
let base = 100
let offset = 5
let compute = |x| base + x * offset
println("compute(3) with base=100, offset=5 =", compute(3))
assert compute(3) == 115

// --- 6. Passing lambda as argument (higher-order) ---
fn apply(f, x: int) -> int {
    return f(x)
}
let inc = |x| x + 1
println("apply(inc, 5) =", apply(inc, 5))
assert apply(inc, 5) == 6

// --- 7. Composing: apply twice ---
fn twice(f, x: int) -> int {
    return f(f(x))
}
println("twice(inc, 5) =", twice(inc, 5))
assert twice(inc, 5) == 7

// --- 8. Lambda returning from function ---
fn make_adder(n: int) {
    return |x| x + n
}
let add10 = make_adder(10)
println("make_adder(10)(32) =", add10(32))
assert add10(32) == 42

// --- 9. Lambda in array ---
let ops = [|x| x + 1, |x| x * 2, |x| x - 3]
let val = ops[1](6)
println("ops[1](6) =", val)
assert val == 12

// --- 10. Nested lambda ---
let outer = |x| {
    let inner = |y| x + y
    return inner(10)
}
println("outer(5) =", outer(5))
assert outer(5) == 15

// --- 11. Lambda with conditional ---
let abs_val = |x| {
    if x < 0 {
        return -x
    }
    return x
}
println("abs_val(-7) =", abs_val(-7))
assert abs_val(-7) == 7
assert abs_val(3) == 3

// --- 13. Map-like pattern with lambda ---
fn map_array(arr, f) {
    let mut result = []
    for item in arr {
        result.push(f(item))
    }
    return result
}
let nums = [1, 2, 3, 4, 5]
let doubled = map_array(nums, |x| x * 2)
println("map [1..5] *2 =", doubled)
assert doubled[0] == 2
assert doubled[4] == 10

// --- 14. Filter-like pattern ---
fn filter_array(arr, pred) {
    let mut result = []
    for item in arr {
        if pred(item) {
            result.push(item)
        }
    }
    return result
}
let evens = filter_array([1, 2, 3, 4, 5, 6], |x| x % 2 == 0)
println("filter evens from [1..6] =", evens)
assert evens.len() == 3
assert evens[0] == 2

// --- 15. Reduce-like pattern ---
fn reduce(arr, init, f) {
    let mut acc = init
    for item in arr {
        acc = f(acc, item)
    }
    return acc
}
let sum = reduce([1, 2, 3, 4, 5], 0, |a, b| a + b)
println("reduce sum [1..5] =", sum)
assert sum == 15

let product = reduce([1, 2, 3, 4, 5], 1, |a, b| a * b)
println("reduce product [1..5] =", product)
assert product == 120

println("")
println("=== All closure tests passed! ===")
