// ── Algebraic Effects Test Suite ────────────────────────────
// Tests: effect declaration, handling, resume, nesting, pure fn

// ── Test 1: Define an effect with 2 operations ──────────────
effect Console {
    fn log(msg: str) -> ()
    fn read_line() -> str
}

// ── Test 2: Handle an effect (override behavior) ────────────
let collected = handle {
    Console.log("hello")
    42
} with {
    Console.log(msg) => {
        resume(0)
    }
}
assert collected == 42

// ── Test 3: Resume with a value ─────────────────────────────
effect Ask {
    fn question(prompt: str) -> str
}

let answer = handle {
    Ask.question("name?")
} with {
    Ask.question(prompt) => {
        resume("Alice")
    }
}
assert answer == "Alice"

// ── Test 4: Multiple effect calls in sequence ───────────────
effect Counter {
    fn next() -> int
}

let sum = handle {
    let a = Counter.next()
    let b = Counter.next()
    a + b
} with {
    Counter.next() => {
        resume(10)
    }
}
assert sum == 20

// ── Test 5: Pure function rejects effects ───────────────────
pure fn add(a: int, b: int) -> int {
    a + b
}
let result = add(3, 4)
assert result == 7

// Test that pure functions work for normal computation
pure fn double(x: int) -> int {
    x * 2
}
assert double(21) == 42

// ── Test 6: Nested handle blocks ────────────────────────────
effect Outer {
    fn get_outer() -> int
}

effect Inner {
    fn get_inner() -> int
}

let nested = handle {
    let o = Outer.get_outer()
    let i = handle {
        Inner.get_inner()
    } with {
        Inner.get_inner() => {
            resume(200)
        }
    }
    o + i
} with {
    Outer.get_outer() => {
        resume(100)
    }
}
assert nested == 300

// ── Test 7: Effect with multiple parameters ─────────────────
effect Math {
    fn compute(a: int, b: int) -> int
}

let computed = handle {
    Math.compute(10, 20)
} with {
    Math.compute(a, b) => {
        resume(a + b)
    }
}
assert computed == 30

// ── Test 8: Handle replaces behavior ────────────────────────
effect Logger {
    fn write(msg: str) -> int
}

let count = handle {
    let x = Logger.write("first")
    let y = Logger.write("second")
    x + y
} with {
    Logger.write(msg) => {
        resume(1)
    }
}
assert count == 2

// ── Test 9: Effect call in a function ───────────────────────
fn use_ask() -> str {
    Ask.question("what?")
}

let fn_answer = handle {
    use_ask()
} with {
    Ask.question(prompt) => {
        resume("Bob")
    }
}
assert fn_answer == "Bob"

// ── Test 10: Handler without resume returns handler value ───
effect Choice {
    fn pick() -> int
}

let picked = handle {
    Choice.pick()
} with {
    Choice.pick() => {
        99
    }
}
assert picked == 99

// All tests passed
println("All 10 effect tests passed!")
