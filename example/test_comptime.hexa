// ── Test: Compile-Time Execution (comptime) ─────────────────

// === 1. comptime block returns a literal ===
proof test_comptime_literal {
    let x = comptime { 42 }
    assert x == 42
}

// === 2. comptime with arithmetic ===
proof test_comptime_arithmetic {
    let x = comptime { 6 * 7 + 1 }
    assert x == 43
}

// === 3. comptime with loops — build a lookup table ===
proof test_comptime_loop_table {
    let table = comptime {
        let result = []
        for i in 0..10 {
            result = result.push(i * i)
        }
        result
    }
    assert len(table) == 10
    assert table[0] == 0
    assert table[1] == 1
    assert table[4] == 16
    assert table[9] == 81
}

// === 4. comptime fn definition and call ===
comptime fn factorial(n: int) -> int {
    if n <= 1 { return 1 }
    return n * factorial(n - 1)
}

proof test_comptime_fn {
    let f5 = comptime { factorial(5) }
    assert f5 == 120
}

// === 5. comptime fn nested calls ===
comptime fn double(x: int) -> int {
    return x * 2
}

comptime fn quad(x: int) -> int {
    return double(double(x))
}

proof test_comptime_nested_fn {
    let q = comptime { quad(3) }
    assert q == 12
}

// === 6. comptime array construction with function ===
proof test_comptime_array_with_fn {
    let facts = comptime {
        let result = []
        for i in 1..8 {
            result = result.push(factorial(i))
        }
        result
    }
    assert len(facts) == 7
    assert facts[0] == 1
    assert facts[1] == 2
    assert facts[2] == 6
    assert facts[3] == 24
    assert facts[4] == 120
    assert facts[5] == 720
    assert facts[6] == 5040
}

// === 7. const with comptime expression ===
const CT_VALUE = comptime { 2 + 3 + 5 + 7 }

proof test_const_comptime {
    assert CT_VALUE == 17
}

// === 8. comptime string operations ===
proof test_comptime_string {
    let s = comptime { "hello" + " " + "world" }
    assert s == "hello world"
}

// === 9. comptime boolean logic ===
proof test_comptime_bool {
    let b = comptime {
        let x = 10
        x > 5 && x < 20
    }
    assert b == true
}

// === 10. comptime with conditional ===
proof test_comptime_if {
    let val = comptime {
        let n = 7
        if n > 5 {
            "big"
        } else {
            "small"
        }
    }
    assert val == "big"
}

// === 11. comptime I/O error — println is forbidden ===
proof test_comptime_io_error {
    let caught = false
    try {
        let x = comptime { println("should fail") }
    } catch e {
        caught = true
    }
    assert caught == true
}

// === 12. comptime I/O error — read_file is forbidden ===
proof test_comptime_read_file_error {
    let caught = false
    try {
        let x = comptime { read_file("test.txt") }
    } catch e {
        caught = true
    }
    assert caught == true
}
