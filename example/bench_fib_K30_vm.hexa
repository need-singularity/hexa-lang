// VM-compatible fib bench: while-loop + fn main().
// bench_fib_K30.hexa 는 for-range 를 쓰는데 rt#36-E 현재 emitter 는
// For/Range 가 bridged out (self/bc_emitter.hexa:2488 미지원 목록).
// bt#85 측정 전용으로 같은 워크로드(fib(20) × K=30 = 437K calls)를
// while-loop 로 동형 표현.

fn fib(n: int) -> int {
    if n <= 1 {
        return n
    }
    return fib(n - 1) + fib(n - 2)
}

fn main() {
    let mut sum = 0
    let mut k = 0
    while k < 30 {
        sum = sum + fib(20)
        k = k + 1
    }
    print(sum)
}
