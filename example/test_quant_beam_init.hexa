// ══════════════════════════════════════════════════════════
// 양자화 + 빔 서치 + gradient clipping + weight init
// Anima 배포 + 생성 품질 + 학습 안정성
// ══════════════════════════════════════════════════════════

// ═══ [1] INT8 Quantization ═══
let weights = [0.5, -0.3, 1.2, -0.8, 0.1, 0.7, -1.0, 0.4]
let q_result = quantize_int8(weights)
let q_ints = q_result[0]
let scale = q_result[1]
let zp = q_result[2]
println("[1] Quantize INT8:")
println("    original:", weights)
println("    quantized:", q_ints, "scale:", scale, "zp:", zp)

// Dequantize
let recovered = dequantize_int8(q_ints, scale, zp)
println("    recovered:", recovered)

// Quantization error
let err = mse_loss(weights, recovered)
println("    quant error (MSE):", err)

// ═══ [2] Beam Search ═══
println("\n[2] Beam Search (width=3, vocab=4):")
let bw = 3
let vs = 4

// Initial: 3 beams, each starting with token 0
let seqs = [0, 0, 0]  // 3 beams × 1 token
let scores = [0.0, 0.0, 0.0]

// Fake logits for each beam (3 beams × 4 vocab)
let logits = [2.0, 0.1, 1.0, 0.5, 0.3, 2.5, 0.8, 0.1, 1.5, 0.2, 0.1, 2.0]

let result = beam_search_step(seqs, scores, logits, bw, vs)
let new_seqs = result[0]
let new_scores = result[1]
println("    top beams:", new_seqs)
println("    scores:", new_scores)

// Second step
let logits2 = [1.0, 2.0, 0.5, 0.3, 0.1, 0.3, 2.5, 1.0, 2.0, 0.1, 0.5, 1.5]
let r2 = beam_search_step(new_seqs, new_scores, logits2, bw, vs)
println("    step 2 beams:", r2[0])

// ═══ [3] Gradient Clipping ═══
println("\n[3] Gradient Clipping:")
let grads = [10.0, -20.0, 15.0, -5.0]
let clipped = grad_clip_norm(grads, 1.0)
println("    original grads:", grads)
println("    clipped (max_norm=1.0):", clipped)

// Verify norm ≤ 1.0
let clipped_norm = sqrt(dot(clipped, clipped))
println("    clipped norm:", round(clipped_norm * 10000) / 10000)

// Small grads should pass through
let small_grads = [0.1, -0.2, 0.15]
let not_clipped = grad_clip_norm(small_grads, 1.0)
println("    small grads (no clip):", not_clipped)

// ═══ [4] Xavier Init ═══
println("\n[4] Xavier Init (fan_in=4, fan_out=8):")
let w_xavier = xavier_init(4, 8)
println("    first 8:", slice(w_xavier, 0, 8))
println("    size:", len(w_xavier))
let x_mean = mean(w_xavier)
println("    mean:", round(x_mean * 10000) / 10000, "(should be ~0)")

// ═══ [5] Kaiming Init ═══
println("\n[5] Kaiming/He Init (fan_in=4, fan_out=8):")
let w_kaiming = kaiming_init(4, 8)
println("    first 8:", slice(w_kaiming, 0, 8))
let k_mean = mean(w_kaiming)
println("    mean:", round(k_mean * 10000) / 10000, "(should be ~0)")

// ═══ [6] Full deployment pipeline ═══
println("\n[6] Anima Deployment Pipeline:")
// Train weights
let W_train = xavier_init(4, 4)
println("    trained weights (16 params)")

// Quantize for deployment
let q = quantize_int8(W_train)
println("    quantized:", len(q[0]), "int8 params")

// Save quantized model
save_array(W_train, "/tmp/hexa_model.json")
println("    saved model")

// Load and dequantize
let loaded = load_array("/tmp/hexa_model.json")
println("    loaded:", len(loaded), "params")
println("    deploy ready!")

// ═══ @test ═══
@test fn test_quantize_roundtrip() {
    let w = [1.0, -1.0, 0.5, -0.5]
    let q = quantize_int8(w)
    let r = dequantize_int8(q[0], q[1], q[2])
    let err = mse_loss(w, r)
    assert(err < 0.01, "quantization error should be small")
}
@test fn test_grad_clip_bounded() {
    let c = grad_clip_norm([100.0, 200.0], 1.0)
    let n = sqrt(dot(c, c))
    assert(n < 1.01, "clipped norm should be ≤ 1.0")
}
@test fn test_xavier_size() {
    let w = xavier_init(3, 5)
    assert(len(w) == 15, "xavier should produce fan_in*fan_out weights")
}
@test fn test_beam_expands() {
    let r = beam_search_step([0], [0.0], [1.0, 2.0, 0.5], 1, 3)
    assert(len(r[1]) == 1, "beam width should stay 1")
}
run_tests()

println("\n--- quant+beam+clip+init PASS ---")
