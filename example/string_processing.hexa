// string_processing.hexa — String manipulation showcase
// Demonstrates: split, join, replace, trim, reverse, word count, palindrome

println("=== String Processing in HEXA ===")
println("")

// ── 1. Basic string operations ─────────────────────────────
println("--- 1. Basic Operations ---")
let greeting = "  Hello, World!  "
println("  Original:   '", greeting, "'")
println("  Trimmed:    '", greeting.trim(), "'")
println("  Upper:      '", greeting.trim().to_upper(), "'")
println("  Lower:      '", greeting.trim().to_lower(), "'")
println("  Length:     ", greeting.len())
println("  Trimmed len:", greeting.trim().len())
println("")

// ── 2. Split and Join ──────────────────────────────────────
println("--- 2. Split and Join ---")
let csv_line = "alice,bob,charlie,diana,eve"
println("  CSV input:", csv_line)

let names = csv_line.split(",")
println("  Split by ',':")
let mut i = 0
while i < len(names) {
    println("    [", i, "]", names[i])
    i = i + 1
}

// Join back with different separator
let rejoined = names.join(" | ")
println("  Joined with ' | ':", rejoined)
println("")

// ── 3. Replace ─────────────────────────────────────────────
println("--- 3. Replace ---")
let template = "Hello NAME, welcome to PLACE!"
println("  Template:", template)
let filled = template.replace("NAME", "Alice").replace("PLACE", "HEXA-land")
println("  Filled:  ", filled)

let messy = "too   many   spaces   here"
println("  Messy:  '", messy, "'")
let clean = messy.replace("   ", " ")
println("  Clean:  '", clean, "'")
println("")

// ── 4. Contains, starts_with, ends_with ────────────────────
println("--- 4. Search ---")
let sentence = "The quick brown fox jumps over the lazy dog"
println("  Sentence: '", sentence, "'")
println("  Contains 'fox':    ", sentence.contains("fox"))
println("  Contains 'cat':    ", sentence.contains("cat"))
println("  Starts with 'The': ", sentence.starts_with("The"))
println("  Ends with 'dog':   ", sentence.ends_with("dog"))
println("  Ends with 'cat':   ", sentence.ends_with("cat"))
println("")

// ── 5. Reverse a string character by character ─────────────
println("--- 5. String Reverse ---")
fn reverse_string(s: str) -> str {
    let chars = s.chars()
    let mut result = ""
    let mut i = len(chars) - 1
    while i >= 0 {
        result = result + to_string(chars[i])
        i = i - 1
    }
    return result
}

let original = "Hello, HEXA!"
let reversed = reverse_string(original)
println("  Original:", original)
println("  Reversed:", reversed)
println("  Re-reversed:", reverse_string(reversed))
assert reverse_string(reversed) == original
println("")

// ── 6. Word count ──────────────────────────────────────────
println("--- 6. Word Count ---")
fn word_count(s: str) -> int {
    let trimmed = s.trim()
    if trimmed.len() == 0 {
        return 0
    }
    let words = trimmed.split(" ")
    // Filter out empty strings from multiple spaces
    let mut count = 0
    for w in words {
        if w.trim().len() > 0 {
            count = count + 1
        }
    }
    return count
}

let text1 = "The quick brown fox"
let text2 = "   spaces   everywhere   "
let text3 = "single"
let text4 = ""

println("  '", text1, "' ->", word_count(text1), "words")
println("  '", text2, "' ->", word_count(text2), "words")
println("  '", text3, "' ->", word_count(text3), "words")
println("  '", text4, "' ->", word_count(text4), "words")
println("")

// ── 7. Palindrome check ────────────────────────────────────
println("--- 7. Palindrome Check ---")
fn is_palindrome(s: str) -> bool {
    let cleaned = s.to_lower().replace(" ", "")
    let chars = cleaned.chars()
    let n = len(chars)
    let mut i = 0
    while i < n / 2 {
        if chars[i] != chars[n - 1 - i] {
            return false
        }
        i = i + 1
    }
    return true
}

let palindromes = ["racecar", "madam", "level", "rotor", "kayak"]
let non_palindromes = ["hello", "world", "hexa", "language"]

println("  Palindromes:")
for p in palindromes {
    println("    '", p, "' ->", is_palindrome(p))
    assert is_palindrome(p) == true
}

println("  Non-palindromes:")
for np in non_palindromes {
    println("    '", np, "' ->", is_palindrome(np))
    assert is_palindrome(np) == false
}

// Case-insensitive palindrome
println("  Case-insensitive: 'RaceCar' ->", is_palindrome("RaceCar"))
assert is_palindrome("RaceCar") == true
println("")

// ── 8. Substring extraction ────────────────────────────────
println("--- 8. Substring ---")
let path = "/home/user/documents/report.txt"
println("  Path:", path)

// Find filename: split by /
let parts = path.split("/")
let filename = parts[len(parts) - 1]
println("  Filename:", filename)

// Find extension: split by .
let dot_parts = filename.split(".")
let ext = dot_parts[len(dot_parts) - 1]
println("  Extension:", ext)

// Find basename
let basename = dot_parts[0]
println("  Basename:", basename)
println("")

// ── 9. Character frequency ─────────────────────────────────
println("--- 9. Character Analysis ---")
let sample = "hello world"
println("  Text: '", sample, "'")

let chars = sample.chars()
let mut vowel_count = 0
let mut consonant_count = 0
let vowels = "aeiou"

for c in chars {
    let ch = to_string(c)
    if ch == " " {
        // skip space
    } else {
        if vowels.contains(ch.to_lower()) {
            vowel_count = vowel_count + 1
        } else {
            consonant_count = consonant_count + 1
        }
    }
}
println("  Vowels:    ", vowel_count)
println("  Consonants:", consonant_count)
println("  Total chars:", sample.len())
println("")

println("=== String processing complete! ===")
