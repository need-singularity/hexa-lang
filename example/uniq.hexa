// uniq.hexa — 파일에서 고유 라인 추출 (count 포함)
// 사용: ./uniq <file>  또는  stdin 입력

let mut content = ""
if argc() >= 2 {
    content = read_file(arg(1))
} else {
    content = read_stdin()
}

if content.len() == 0 {
    println("(empty)")
    exit(0)
}

let lines = content.split("\n")
let n = len(lines)

// 병렬 배열: 고유 라인 + 카운트
let mut seen = []
let mut counts = array_fill(10000, 0)
let mut unique_n = 0

let mut i = 0
while i < n {
    let line = lines[i]
    if line.len() > 0 {
        // 이미 seen에 있는지 확인
        let mut found = -1
        let mut j = 0
        while j < unique_n {
            if seen[j] == line {
                found = j
            }
            j = j + 1
        }
        if found >= 0 {
            counts[found] += 1
        } else {
            seen = seen + [line]
            counts[unique_n] = 1
            unique_n = unique_n + 1
        }
    }
    i = i + 1
}

println("─── unique lines (", unique_n, ") ───")
let mut k = 0
while k < unique_n {
    let cnt = counts[k]
    let line = seen[k]
    println(cnt, " ", line)
    k = k + 1
}
println("total input lines:", n)
