// test_ptr_arith.hexa — Test G5 pointer arithmetic builtins
println("=== Pointer Arithmetic (G5) tests ===")

// Test 1: ptr_alloc / ptr_free
let buf = ptr_alloc(64)
assert(ptr_addr(buf) > 0, "ptr_alloc failed")
println("[PASS] ptr_alloc(64)")

// Test 2: ptr_write / ptr_read — int
ptr_write(buf, 0, 42)
let v0 = ptr_read(buf, 0)
assert(v0 == 42, "ptr_read i64 failed: " + str(v0))
println("[PASS] ptr_write/ptr_read i64 = " + str(v0))

// Test 3: ptr_write / ptr_read — second slot
ptr_write(buf, 8, 99)
let v1 = ptr_read(buf, 8)
assert(v1 == 99, "ptr_read slot 1 failed: " + str(v1))
println("[PASS] ptr_write/ptr_read i64 offset=8 => " + str(v1))

// Test 4: ptr_write / ptr_read_f64 — float
ptr_write(buf, 16, 3.14)
let vf = ptr_read_f64(buf, 16)
assert(vf > 3.13, "ptr_read_f64 failed")
assert(vf < 3.15, "ptr_read_f64 failed")
println("[PASS] ptr_write/ptr_read_f64 = " + str(vf))

// Test 5: ptr_write_f32 / ptr_read_f32
ptr_write_f32(buf, 24, 2.5)
let vf32 = ptr_read_f32(buf, 24)
assert(vf32 > 2.4, "ptr_read_f32 failed")
assert(vf32 < 2.6, "ptr_read_f32 failed")
println("[PASS] ptr_write_f32/ptr_read_f32 = " + str(vf32))

// Test 6: ptr_write_i32 / ptr_read_i32
ptr_write_i32(buf, 28, 12345)
let vi32 = ptr_read_i32(buf, 28)
assert(vi32 == 12345, "ptr_read_i32 failed: " + str(vi32))
println("[PASS] ptr_write_i32/ptr_read_i32 = " + str(vi32))

// Test 7: ptr_offset
let p2 = ptr_offset(buf, 8)
let v_off = deref(p2)
assert(v_off == 99, "ptr_offset+deref failed: " + str(v_off))
println("[PASS] ptr_offset(buf, 8) + deref = " + str(v_off))

// Test 8: Simulate C struct — NSRect { x: f64, y: f64, w: f64, h: f64 } = 32 bytes
let rect = ptr_alloc(32)
ptr_write(rect, 0, 10.0)   // x
ptr_write(rect, 8, 20.0)   // y
ptr_write(rect, 16, 800.0) // width
ptr_write(rect, 24, 600.0) // height
let rx = ptr_read_f64(rect, 0)
let ry = ptr_read_f64(rect, 8)
let rw = ptr_read_f64(rect, 16)
let rh = ptr_read_f64(rect, 24)
assert(rx == 10.0, "NSRect x failed")
assert(ry == 20.0, "NSRect y failed")
assert(rw == 800.0, "NSRect w failed")
assert(rh == 600.0, "NSRect h failed")
println("[PASS] NSRect struct { " + str(rx) + ", " + str(ry) + ", " + str(rw) + ", " + str(rh) + " }")

// Test 9: ptr_write pointer value
let inner = ptr_alloc(8)
ptr_write(inner, 0, 777)
ptr_write(buf, 0, inner)  // store pointer in buf
let recovered = ptr_read(buf, 0)
// recovered is the address of inner as an int
assert(recovered == ptr_addr(inner), "ptr store/load pointer failed")
println("[PASS] ptr_write/ptr_read pointer value")

// Cleanup
ptr_free(rect, 32)
ptr_free(inner, 8)
ptr_free(buf, 64)
println("[PASS] ptr_free cleanup")

println("=== All pointer arithmetic tests passed ===")
