// Test: const and static keywords

// ── const: compile-time constant, immutable ──

const PI_APPROX = 3.14159
const MAX_SIZE: int = 1024
const GREETING = "hello"

proof const_value_works {
    assert PI_APPROX > 3.14
    assert MAX_SIZE == 1024
    assert GREETING == "hello"
}

// ── static: module-level global variable ──

static counter = 0
static name = "anima"

proof static_value_works {
    assert counter == 0
    assert name == "anima"
}

// ── static is mutable (can be reassigned) ──

proof static_is_mutable {
    counter = 42
    assert counter == 42
    counter = 100
    assert counter == 100
}

// ── static accessible from functions ──

fn increment_counter() {
    counter = counter + 1
}

fn get_counter() -> int {
    return counter
}

proof static_accessible_from_functions {
    counter = 0
    increment_counter()
    assert get_counter() == 1
    increment_counter()
    increment_counter()
    assert get_counter() == 3
}

// ── const prevents reassignment (error case) ──

proof const_prevents_reassignment {
    let caught = false
    try {
        PI_APPROX = 2.0
    } catch e {
        caught = true
    }
    assert caught == true
}

// ── const with expressions ──

const DOUBLE_MAX = 1024 * 2
const IS_BIG = true

proof const_expressions {
    assert DOUBLE_MAX == 2048
    assert IS_BIG == true
}
