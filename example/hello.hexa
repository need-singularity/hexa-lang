println("=== HEXA-LANG: The Perfect Number Language ===")
println("")
println("n=6 Constants:")
println("  sigma(6) =", sigma(6))
println("  phi(6)   =", phi(6))
println("  tau(6)   =", tau(6))
println("  J2(6)    =", sigma(6) * phi(6))
println("")
println("Proof: sigma(6) * phi(6) =", sigma(6) * phi(6))
println("       6 * tau(6)        =", 6 * tau(6))
println("       Equal?            ", sigma(6) * phi(6) == 6 * tau(6))
