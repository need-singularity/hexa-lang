// P11 회귀 테스트 — parser Newline line continuation
// ossified_at: src/parser.rs (skip_newlines_if_continuation + 5 parse_* loops)

let mut pass = 0
let mut fail = 0

fn assert_eq(label: string, got: any, want: any) {
    if to_string(got) == to_string(want) {
        println("✅ " + label)
        pass = pass + 1
    } else {
        println("❌ " + label + ": got=" + to_string(got) + " want=" + to_string(want))
        fail = fail + 1
    }
}

println("═══ P11 Newline continuation 회귀 테스트 ═══")
println("")

// ─── 1. 메서드 체인 `.` 앞 줄바꿈
let s = "hello world"
let r1 = s
    .trim()
    .to_upper()
assert_eq("1. method chain `.` 앞 줄바꿈", r1, "HELLO WORLD")

// ─── 2. && 앞 줄바꿈
let a = true
let b = true
let r2 = a
    && b
assert_eq("2. && 앞 줄바꿈", r2, true)

// ─── 3. || 앞 줄바꿈
let c = false
let r3 = c
    || a
assert_eq("3. || 앞 줄바꿈", r3, true)

// ─── 4. + 앞 줄바꿈
let n1 = 10
let r4 = n1
    + 5
assert_eq("4. + 앞 줄바꿈", r4, 15)

// ─── 5. * 앞 줄바꿈
let r5 = n1
    * 3
assert_eq("5. * 앞 줄바꿈", r5, 30)

// ─── 6. == 앞 줄바꿈
let r6 = n1
    == 10
assert_eq("6. == 앞 줄바꿈", r6, true)

// ─── 7. 복합 — if 조건 multiline
let x = 5
let y = 10
let mut hit = false
if x > 0
    && y > 0
    && x + y == 15
{
    hit = true
}
assert_eq("7. if multiline 조건", hit, true)

// ─── 8. 체인 + 산술 혼합
let r8 = "  hello  "
    .trim()
    .len()
    + 5
assert_eq("8. 체인+산술 혼합", r8, 10)

println("")
println("═══ 결과: " + to_string(pass) + " pass / " + to_string(fail) + " fail ═══")
if fail > 0 { exit(1) }
