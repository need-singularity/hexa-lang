// ══════════════════════════════════════════════════════════
// Anima GRU Forward — @fuse + @vectorize gate fusion
// 3× matvec + sigmoid/tanh → single fused pass per cell
// Target: crates/core/src/gru.rs GruCell::process()
// ══════════════════════════════════════════════════════════

// ── Primitives ──
fn dot(a, b) {
    let sum = 0.0
    let i = 0
    while i < len(a) {
        sum = sum + a[i] * b[i]
        i = i + 1
    }
    sum
}

fn sigmoid(x: float) -> float {
    1.0 / (1.0 + exp(-x))
}

fn tanh_f(x: float) -> float {
    let e2x = exp(2.0 * x)
    (e2x - 1.0) / (e2x + 1.0)
}

// ── @fuse: GRU gate computation (z, r, h_cand → new hidden) ──
// Fuses 3 matvec + 2 sigmoid + 1 tanh + element-wise ops into single pass
@fuse fn gru_gate_fused(hidden_i: float, z_raw: float, r_raw: float, h_raw: float) -> float {
    let z = sigmoid(z_raw)
    let r = sigmoid(r_raw)
    // h_cand uses r-gated hidden, but we approximate with pre-computed h_raw
    let h_cand = tanh_f(h_raw)
    // new_hidden = (1-z) * h_cand + z * hidden
    (1.0 - z) * h_cand + z * hidden_i
}

// ── @vectorize: batch matvec across cells ──
@vectorize fn scale_add(a: float, b: float, s: float) -> float {
    a + s * b
}

// ── Anima GRU Step: 4 cells × 4-dim hidden ──
let n_cells = 4
let hidden_dim = 4

// Cell hidden states (flat: n_cells × hidden_dim)
let hiddens = [0.1, 0.2, -0.1, 0.3, -0.2, 0.4, 0.1, -0.1, 0.3, -0.1, 0.2, 0.4, 0.0, 0.1, -0.3, 0.2]

// Simulated gate pre-activations (from W @ [input, tension, hidden])
let z_raw = [0.5, -0.3, 0.1, 0.8, -0.2, 0.6, -0.1, 0.3, 0.4, -0.5, 0.2, 0.1, -0.1, 0.7, -0.4, 0.2]
let r_raw = [0.3, 0.1, -0.2, 0.4, 0.5, -0.3, 0.2, 0.1, -0.1, 0.4, 0.3, -0.2, 0.2, -0.1, 0.5, 0.3]
let h_raw = [-0.1, 0.3, 0.5, -0.2, 0.4, -0.1, 0.3, 0.6, -0.3, 0.2, -0.1, 0.4, 0.1, 0.5, -0.2, 0.3]

// [1] Fused GRU gate: all 16 elements in single pass (no intermediate arrays)
let new_hiddens = gru_gate_fused(hiddens, z_raw, r_raw, h_raw)
println("[1] GRU fused gate (4 cells × 4 dim):")
println("    cell0:", new_hiddens[0], new_hiddens[1], new_hiddens[2], new_hiddens[3])
println("    cell1:", new_hiddens[4], new_hiddens[5], new_hiddens[6], new_hiddens[7])

// [2] Coupling injection: scale_add vectorized
// coupling[i,j] * PSI_COUPLING * neighbor_hidden → add to cell input
let psi_coupling = 0.015317
let coupling = [0.0, 0.8, 0.3, 0.1, 0.8, 0.0, 0.5, 0.2, 0.3, 0.5, 0.0, 0.7, 0.1, 0.2, 0.7, 0.0]
let neighbor_signal = [0.0, 0.32, 0.06, 0.03, 0.16, 0.0, 0.05, 0.02, 0.09, 0.05, 0.0, 0.28, 0.01, 0.02, 0.21, 0.0]
let injected = scale_add(hiddens, neighbor_signal, psi_coupling)
println("[2] Coupling injected (first 4):", injected[0], injected[1], injected[2], injected[3])

// [3] Tension-weighted output (softmax)
let tensions = [0.3, 0.7, 0.5, 0.2]
let exp_sum = exp(tensions[0]) + exp(tensions[1]) + exp(tensions[2]) + exp(tensions[3])
let w0 = exp(tensions[0]) / exp_sum
let w1 = exp(tensions[1]) / exp_sum
let w2 = exp(tensions[2]) / exp_sum
let w3 = exp(tensions[3]) / exp_sum
println("[3] Softmax weights:", round(w0 * 1000) / 1000, round(w1 * 1000) / 1000, round(w2 * 1000) / 1000, round(w3 * 1000) / 1000)

println("--- GRU fused gate PASS ---")
