// test_contract.hexa — @contract Option A (parser desugar) validation
// Tests requires precondition, ensures postcondition, combined, branching,
// complex expressions, and error message format.

// ── Test 1: requires — happy path ────────────────────────
@contract(requires: x > 0)
fn inc_req(x) {
  return x + 1
}
assert inc_req(5) == 6
println("PASS 1: requires happy path")

// ── Test 2: requires — violation throws ──────────────────
let mut t2_caught = false
try {
  inc_req(-1)
} catch e {
  t2_caught = true
  let msg = to_string(e)
  assert contains(msg, "contract violation")
  assert contains(msg, "requires")
}
assert t2_caught
println("PASS 2: requires violation caught")

// ── Test 3: ensures — happy path ─────────────────────────
@contract(ensures: result > 0)
fn inc_ens(x) {
  return x + 1
}
assert inc_ens(5) == 6
println("PASS 3: ensures happy path")

// ── Test 4: ensures — violation throws ───────────────────
let mut t4_caught = false
try {
  inc_ens(-10)
} catch e {
  t4_caught = true
  let msg = to_string(e)
  assert contains(msg, "contract violation")
  assert contains(msg, "ensures")
}
assert t4_caught
println("PASS 4: ensures violation caught")

// ── Test 5: requires + ensures combined ──────────────────
@contract(requires: x > 0, ensures: result > x)
fn inc_both(x) {
  return x + 1
}
assert inc_both(10) == 11
println("PASS 5: requires + ensures combined")

// ── Test 6-7: ensures catches early return in if branch ──
@contract(ensures: result > 0)
fn guarded(x) {
  if x > 100 {
    return -1
  }
  return x + 1
}
assert guarded(5) == 6
println("PASS 6: ensures early-return happy")

let mut t7_caught = false
try {
  guarded(200)
} catch e {
  t7_caught = true
}
assert t7_caught
println("PASS 7: ensures early-return violation caught")

// ── Test 8-9: requires with complex expression ──────────
@contract(requires: x > 0 && x < 100)
fn bounded(x) {
  return x * 2
}
assert bounded(50) == 100
println("PASS 8: complex requires happy")

let mut t9_caught = false
try {
  bounded(200)
} catch e {
  t9_caught = true
}
assert t9_caught
println("PASS 9: complex requires violation caught")

// ── Test 10: ensures referencing params ──────────────────
@contract(ensures: result >= x * 2)
fn double_plus(x) {
  return x * 2 + 1
}
assert double_plus(5) == 11
println("PASS 10: ensures with param reference")

println("")
println("ALL 10 @contract TESTS PASSED")
