// Test Egyptian Fraction Memory Allocator
// Identity: 1/2 + 1/3 + 1/6 = 1 (n=6 perfect number)

// ── Budget fractions ──────────────────────────────────────

proof test_budget_identity {
    let budget = mem_budget()
    assert budget.identity == "1/2 + 1/3 + 1/6 = 1"
    assert budget.stack_fraction == "1/2"
    assert budget.heap_fraction == "1/3"
    assert budget.arena_fraction == "1/6"
}

proof test_budget_sizes {
    let budget = mem_budget()
    let total = budget.total
    // Stack = 1/2 of total
    assert budget.stack == total / 2
    // Heap = 1/3 of total
    assert budget.heap == total / 3
    // Arena = 1/6 of total
    assert budget.arena == total / 6
    // Verify: stack + heap + arena approximately equals total
    // (integer division may lose at most 1 byte per region)
    let sum = budget.stack + budget.heap + budget.arena
    let diff = total - sum
    assert diff >= 0
    assert diff <= 2
}

// ── mem_stats returns 3 regions ──────────────────────────

proof test_mem_stats_regions {
    let stats = mem_stats()
    // All three regions must exist with capacity > 0
    assert stats.stack_capacity > 0
    assert stats.heap_capacity > 0
    assert stats.arena_capacity > 0
}

// ── Stack grows with local variables ─────────────────────

proof test_stack_grows {
    let before = mem_stats()
    let x = 42
    let y = 3.14
    let z = true
    let after = mem_stats()
    // Stack should have grown (int, float, bool are stack-allocated)
    assert after.stack_used >= before.stack_used
}

// ── Heap grows with arrays/structs ──────────────────────

proof test_heap_grows {
    let before = mem_stats()
    let arr = [1, 2, 3, 4, 5, 6]
    let after = mem_stats()
    // Heap should have grown (arrays go to heap)
    assert after.heap_used >= before.heap_used
}

// ── Stack grows with function calls ─────────────────────

fn recursive_depth(n: int) -> int {
    if n <= 0 {
        let stats = mem_stats()
        return stats.stack_frames
    }
    return recursive_depth(n - 1)
}

proof test_stack_frames {
    // Calling with depth=3 should show frames on stack
    let depth = recursive_depth(3)
    // At the deepest point, there should be frames on the stack
    // (the exact count depends on how many frames are active)
    assert depth >= 0
}

// ── Arena used for temporaries ──────────────────────────

proof test_arena_for_strings {
    let before = mem_stats()
    let s1 = "hello"
    let s2 = "world"
    let s3 = "egyptian"
    let after = mem_stats()
    // Arena should have some usage (strings go to arena)
    assert after.arena_used >= before.arena_used
}

// ── mem_region classifies values correctly ───────────────

proof test_mem_region_stack {
    assert mem_region(42) == "stack"
    assert mem_region(3.14) == "stack"
    assert mem_region(true) == "stack"
}

proof test_mem_region_heap {
    assert mem_region([1, 2, 3]) == "heap"
    let m = [1, 2, 3, 4, 5, 6]
    assert mem_region(m) == "heap"
}

proof test_mem_region_arena {
    assert mem_region("hello") == "arena"
}

// ── arena_reset clears arena ────────────────────────────

proof test_arena_reset {
    let s1 = "temporary string 1"
    let s2 = "temporary string 2"
    let before = mem_stats()
    arena_reset()
    let after = mem_stats()
    assert after.arena_used <= before.arena_used
    assert after.arena_resets > 0
}

// ── Total never exceeds budget ──────────────────────────

proof test_total_within_budget {
    // Allocate various types
    let a = 42
    let b = [1, 2, 3, 4, 5, 6]
    let c = "hello world"
    let d = 3.14159
    let e = true
    let stats = mem_stats()
    let total_used = stats.stack_used + stats.heap_used + stats.arena_used
    assert total_used <= stats.total_budget
}

// ── Allocation count tracking ───────────────────────────

proof test_alloc_count {
    let stats = mem_stats()
    // Should have tracked some allocations
    assert stats.total_allocs >= 0
}

// ── n=6 mathematical properties ─────────────────────────

proof test_n6_properties {
    // 6 is the first perfect number: 1 + 2 + 3 = 6
    assert 1 + 2 + 3 == 6
    // Egyptian fraction: 1/2 + 1/3 + 1/6 = 3/6 + 2/6 + 1/6 = 6/6 = 1
    // sigma(6) = 12 (sum of all divisors)
    assert sigma(6) == 12
    // phi(6) = 2 (Euler's totient)
    assert phi(6) == 2
    // tau(6) = 4 (number of divisors)
    assert tau(6) == 4
}
