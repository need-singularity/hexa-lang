// sudoku.hexa — 백트래킹 Sudoku 솔버 (9x9 그리드, long[81] 전역)
// hexa로 작성, self-host 컴파일러로 native 빌드

let mut grid = [5,3,0, 0,7,0, 0,0,0,
                6,0,0, 1,9,5, 0,0,0,
                0,9,8, 0,0,0, 0,6,0,

                8,0,0, 0,6,0, 0,0,3,
                4,0,0, 8,0,3, 0,0,1,
                7,0,0, 0,2,0, 0,0,6,

                0,6,0, 0,0,0, 2,8,0,
                0,0,0, 4,1,9, 0,0,5,
                0,0,0, 0,8,0, 0,7,9]

fn at(r, c) {
    return grid[r * 9 + c]
}

fn set_at(r, c, v) {
    grid[r * 9 + c] = v
}

fn valid(r, c, v) {
    let mut i = 0
    while i < 9 {
        if at(r, i) == v { return 0 }
        if at(i, c) == v { return 0 }
        i = i + 1
    }
    let br = (r / 3) * 3
    let bc = (c / 3) * 3
    let mut dr = 0
    while dr < 3 {
        let mut dc = 0
        while dc < 3 {
            if at(br + dr, bc + dc) == v { return 0 }
            dc = dc + 1
        }
        dr = dr + 1
    }
    return 1
}

fn find_empty() {
    let mut r = 0
    while r < 9 {
        let mut c = 0
        while c < 9 {
            if at(r, c) == 0 {
                return r * 9 + c
            }
            c = c + 1
        }
        r = r + 1
    }
    return -1
}

fn solve() {
    let pos = find_empty()
    if pos < 0 {
        return 1
    }
    let r = pos / 9
    let c = pos - r * 9
    let mut v = 1
    while v <= 9 {
        if valid(r, c, v) == 1 {
            set_at(r, c, v)
            if solve() == 1 {
                return 1
            }
            set_at(r, c, 0)
        }
        v = v + 1
    }
    return 0
}

fn print_grid() {
    let mut r = 0
    while r < 9 {
        if r == 3 {
            println("------+-------+------")
        }
        if r == 6 {
            println("------+-------+------")
        }
        let mut line = ""
        let mut c = 0
        while c < 9 {
            if c == 3 {
                line = line + "| "
            }
            if c == 6 {
                line = line + "| "
            }
            line = line + to_string(at(r, c)) + " "
            c = c + 1
        }
        println(line)
        r = r + 1
    }
}

println("=== Sudoku input ===")
print_grid()
let ok = solve()
println("")
if ok == 1 {
    println("=== solved ===")
    print_grid()
} else {
    println("no solution")
}
