// examples/invariant_test.hexa — T3 Phase A: @invariant DSL smoke
//
// 본 예제는 아래 두 가지 시나리오를 한 파일에 포함한다:
//   1) @invariant DSL 블록 (I1 deny push) 선언
//   2) 의도적으로 invariant 를 위반하는 push 호출 (bad section)
//
// 사용:
//   ./hexa check examples/invariant_test.hexa
//     → 두 줄 violation 보고 + exit 1
//
// 정상 동작 (push 없는 코드만) 검증은 examples/hello.hexa 에 대해 수행.
//   ./hexa check examples/hello.hexa  → OK: all invariants passed

@invariant {
    id: "I1",
    name: "pass_by_value",
    predicate: "deny_method",
    pattern: { target: "push", context: "statement" },
    exempt: []
}

fn append_demo() {
    let mut arr = []
    // bad: statement-level push (mutation 의도) — I1 위반
    // hexa 의 push 는 새 배열 반환이라 결과 폐기 = 기능 손실.
    // 올바른 형태는 `arr.push(x)` (값 재할당 — pass-by-value).
    arr.push(1)
    arr.push(2)
    return arr
}

fn good_demo() {
    let mut arr = []
    // ok — value reassignment (push as expression, result captured)
    arr.push(10)
    arr.push(20)
    return arr
}

fn main_demo() {
    let r = append_demo()
    let g = good_demo()
    println("len=", len(r), len(g))
}

main_demo()
