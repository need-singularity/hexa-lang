// maze.hexa — 간단한 미로 생성 + 출력 (격자 벽 모양)
// 크기: 10x5 셀, 벽 그리기

let W = 15
let H = 8
let SIZE = 120  // W * H

// 1 = wall, 0 = open
let mut grid = array_fill(120, 1)

fn idx(r, c) {
    return r * 15 + c
}

fn inbounds(r, c) {
    if r < 0 || r >= 8 { return 0 }
    if c < 0 || c >= 15 { return 0 }
    return 1
}

// 의사 난수 — LCG
let mut rng_state = 12345

fn next_rand() {
    rng_state = (rng_state * 1103515245 + 12345) % 2147483647
    if rng_state < 0 { rng_state = 0 - rng_state }
    return rng_state
}

// 시작점 (1,1)에서 DFS
fn carve(r, c) {
    grid[idx(r, c)] = 0
    // 4방향 (r,c±2) 랜덤 순서
    let mut order = [0, 1, 2, 3]
    // 셔플 (간이 Fisher-Yates)
    let mut k = 3
    while k > 0 {
        let j = next_rand() % (k + 1)
        let t = order[k]
        order[k] = order[j]
        order[j] = t
        k = k - 1
    }
    let mut i = 0
    while i < 4 {
        let d = order[i]
        let mut dr = 0
        let mut dc = 0
        if d == 0 { dr = 0 - 2 }
        if d == 1 { dr = 2 }
        if d == 2 { dc = 0 - 2 }
        if d == 3 { dc = 2 }
        let nr = r + dr
        let nc = c + dc
        if inbounds(nr, nc) == 1 {
            if grid[idx(nr, nc)] == 1 {
                // 벽 뚫기
                grid[idx(r + dr / 2, c + dc / 2)] = 0
                let _rr = carve(nr, nc)
            }
        }
        i = i + 1
    }
    return 0
}

let _r = carve(1, 1)

// 출력
println("=== maze (seed 12345) ===")
let mut r = 0
while r < H {
    let mut line = ""
    let mut c = 0
    while c < W {
        if grid[idx(r, c)] == 1 {
            line = line + "██"
        } else {
            line = line + "  "
        }
        c = c + 1
    }
    println(line)
    r = r + 1
}
println("done")
