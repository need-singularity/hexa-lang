// bt#85 — call_heavy bench. NK_CALL-dominated: tiny function invoked
// 50K × 10 = 500K times. Target: ≥3× VM speedup vs interpreter.
fn tiny(x: int) -> int {
    return x + 1
}

fn main() {
    let mut sum = 0
    let mut i = 0
    while i < 50000 {
        sum = sum + tiny(i) + tiny(i) + tiny(i) + tiny(i) + tiny(i)
        sum = sum + tiny(i) + tiny(i) + tiny(i) + tiny(i) + tiny(i)
        i = i + 1
    }
    print(sum)
}
