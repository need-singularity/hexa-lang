// ── Neural Ops ──
@bench fn bench_sigmoid_10k() {
    let i = 0
    while i < 10000 { sigmoid(i * 0.001)
        i = i + 1
    }
}

@bench fn bench_gelu_10k() {
    let i = 0
    while i < 10000 { gelu(i * 0.001)
        i = i + 1
    }
}

@bench fn bench_softmax_1k() {
    let v = randn(64, 1.0)
    let i = 0
    while i < 1000 { softmax(v)
        i = i + 1
    }
}

// ── Matrix Ops ──
@bench fn bench_matvec_16x16_1k() {
    let W = randn(256, 0.25)
    let x = randn(16, 0.3)
    let i = 0
    while i < 1000 { matvec(W, x, 16, 16)
        i = i + 1
    }
}

@bench fn bench_matmul_8x8_100() {
    let A = randn(64, 0.25)
    let B = randn(64, 0.25)
    let i = 0
    while i < 100 { matmul(A, B, 8, 8, 8)
        i = i + 1
    }
}

// ── Attention ──
@bench fn bench_attention_16x8_100() {
    let q = randn(128, 0.1)
    let k = randn(128, 0.1)
    let v = randn(128, 0.1)
    let i = 0
    while i < 100 { attention(q, k, v, 16, 8, true)
        i = i + 1
    }
}

@bench fn bench_mha_8x4_2h_100() {
    let x = randn(32, 0.1)
    let wq = randn(16, 0.1)
    let wk = randn(16, 0.1)
    let wv = randn(16, 0.1)
    let wo = randn(16, 0.1)
    let i = 0
    while i < 100 { multi_head_attention(x, wq, wk, wv, wo, 8, 4, 2, true)
        i = i + 1
    }
}

// ── GRU ──
@bench fn bench_gru_cell_4x8_100() {
    let inp = randn(4, 0.1)
    let h = randn(8, 0.1)
    let wz = randn(96, 0.1)
    let wr = randn(96, 0.1)
    let wh = randn(96, 0.1)
    let i = 0
    while i < 100 { gru_cell(inp, h, wz, wr, wh, 4, 8)
        i = i + 1
    }
}

// ── Consciousness Engine ──
@bench fn bench_consciousness_64cell() {
    let h = randn(256, 0.1)
    let t = tension(h, 64, 4)
    let fc = faction_consensus(h, 64, 4, 4)
    softmax(t)
}

@bench fn bench_topology_create() {
    ring_topology(8)
    small_world_topology(16, 2, 0.3)
    hypercube_topology(32)
}

@bench fn bench_lorenz_100() {
    let x = 1.0
    let y = 1.0
    let z = 1.0
    let i = 0
    while i < 100 {
        let s = lorenz_step(x, y, z, 0.01)
        x = s[0]
        y = s[1]
        z = s[2]
        i = i + 1
    }
}

// ── Training ──
@bench fn bench_adam_step_64() {
    let p = randn(64, 0.5)
    let g = randn(64, 0.1)
    let m = zeros(64)
    let v = zeros(64)
    let i = 0
    while i < 100 { adam_step(p, g, m, v, 0.001, 0.9, 0.999, 0.00000001, i + 1)
        i = i + 1
    }
}

@bench fn bench_cross_entropy_1k() {
    let logits = randn(32, 1.0)
    let i = 0
    while i < 1000 { cross_entropy(logits, 0)
        i = i + 1
    }
}

// ── Functional ──
@bench fn bench_map_reduce_10k() {
    let arr = arange(10000)
    let s = reduce(arr, 0.0, |acc, x| acc + x)
}

// ── KV Cache Generation ──
@bench fn bench_kv_cached_gen_10() {
    let d = 8
    let kc = []
    let vc = []
    let i = 0
    while i < 10 {
        let k = randn(d, 0.3)
        let v = randn(d, 0.3)
        kc = kv_cache_append(kc, k, d)
        vc = kv_cache_append(vc, v, d)
        let q = randn(d, 0.3)
        attention_cached(q, kc, vc, i + 1, d)
        i = i + 1
    }
}

run_benchmarks()

println("\n=== Benchmark Complete ===")
