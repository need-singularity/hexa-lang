// Test file for generate and optimize keywords
// All tests work in offline mode (no API key needed)

// ── Test 1: generate fn (offline fallback) ──

generate fn greet(name: str) -> str {
    "Return a greeting string for the given name"
}

// In offline mode, greet() will panic with LLM not available message
// We verify it was registered as a function
let greeting_type = type_of(greet)
assert greeting_type == "fn"

// ── Test 2: generate expression (offline fallback) ──

generate str {
    "email validation regex pattern"
}

// ── Test 3: optimize fn (offline keeps original) ──

optimize fn fibonacci(n: int) -> int {
    if n <= 1 { return n }
    return fibonacci(n - 1) + fibonacci(n - 2)
}

// In offline mode, fibonacci keeps its original implementation
let fib10 = fibonacci(10)
assert fib10 == 55

let fib0 = fibonacci(0)
assert fib0 == 0

let fib1 = fibonacci(1)
assert fib1 == 1

// ── Test 4: optimize preserves behavior ──

optimize fn double(x: int) -> int {
    return x + x
}

assert double(5) == 10
assert double(0) == 0
assert double(100) == 200

// ── Test 5: generate fn with no return type ──

generate fn do_something(x: int) {
    "Print the value of x"
}

let do_type = type_of(do_something)
assert do_type == "fn"

// ── Test 6: generate with type hint ──

generate int {
    "the answer to life, the universe, and everything"
}

// ── Verification ──

verify "generate_offline" {
    // fibonacci should work after optimize (offline keeps original)
    assert fibonacci(5) == 5
    assert fibonacci(7) == 13

    // double should work after optimize
    assert double(21) == 42

    // generated functions should be callable (type is fn)
    assert type_of(greet) == "fn"
    assert type_of(do_something) == "fn"
}

println("All generate/optimize tests passed!")
