// hanoi.hexa — Tower of Hanoi 재귀 솔버
// 사용: ./hanoi [n]  (기본 4)

let mut move_count = 0

fn hanoi(n, src, dst, via) {
    if n == 1 {
        move_count = move_count + 1
        println("move", move_count, ":  disk 1  ", src, "→", dst)
        return 0
    }
    hanoi(n - 1, src, via, dst)
    move_count = move_count + 1
    println("move", move_count, ":  disk", n, " ", src, "→", dst)
    hanoi(n - 1, via, dst, src)
    return 0
}

let n = if argc() >= 2 { parse_int(arg(1)) } else { 4 }
println("Tower of Hanoi: n =", n)
println("─────────────")
let _ = hanoi(n, "A", "C", "B")
println("─────────────")
// 2^n 계산
let mut optimal = 1
let mut p = 0
while p < n {
    optimal = optimal * 2
    p = p + 1
}
println("total moves:", move_count, "  (optimal 2^n - 1 =", optimal - 1, ")")
