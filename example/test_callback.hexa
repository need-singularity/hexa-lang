// test_callback.hexa — G4 Callback Trampoline Pool test
// Tests callback_create / callback_free / callback_invoke
// In interpreter mode, callbacks are slot IDs (0..15).
// In compiled mode, they are actual C function pointers.

fn my_compare(a, b) {
    if a < b { return -1 }
    if a > b { return 1 }
    return 0
}

fn my_doubler(x) {
    return x * 2
}

fn greeting(code) {
    if code == 1 { return 42 }
    if code == 2 { return 99 }
    return 0
}

// Test 1: Create and invoke a callback
println("=== G4 Callback Trampoline Tests ===")

let cb1 = callback_create(my_compare)
println("callback_create(my_compare) -> slot " + to_string(cb1))

// In interpreter mode, we can invoke via callback_invoke
let r1 = callback_invoke(cb1, 3, 5)
println("my_compare(3, 5) via callback -> " + to_string(r1))  // -1

let r2 = callback_invoke(cb1, 7, 2)
println("my_compare(7, 2) via callback -> " + to_string(r2))  // 1

let r3 = callback_invoke(cb1, 4, 4)
println("my_compare(4, 4) via callback -> " + to_string(r3))  // 0

// Test 2: Multiple callbacks
let cb2 = callback_create(my_doubler)
println("callback_create(my_doubler) -> slot " + to_string(cb2))

let r4 = callback_invoke(cb2, 21)
println("my_doubler(21) via callback -> " + to_string(r4))    // 42

// Test 3: Free and reuse
callback_free(cb1)
println("callback_free(slot " + to_string(cb1) + ") -> freed")

let cb3 = callback_create(greeting)
println("callback_create(greeting) -> slot " + to_string(cb3))
// Should reuse slot 0

let r5 = callback_invoke(cb3, 1)
println("greeting(1) via callback -> " + to_string(r5))       // 42

let r6 = callback_invoke(cb3, 2)
println("greeting(2) via callback -> " + to_string(r6))       // 99

// Cleanup
callback_free(cb2)
callback_free(cb3)

println("=== All G4 tests passed ===")
