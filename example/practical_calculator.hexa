// practical_calculator.hexa -- Expression calculator with error handling
// Demonstrates: functions, pattern matching, try/catch, string processing,
//               type conversion, proof blocks for verification

// ── Token types ─────────────────────────────────────────────
enum Token {
    Num(int),
    Plus,
    Minus,
    Mul,
    Div
}

// ── Classify a single character ─────────────────────────────
fn classify_char(c: str) -> str {
    if c == "+" { return "op" }
    if c == "-" { return "op" }
    if c == "*" { return "op" }
    if c == "/" { return "op" }
    if c == " " { return "space" }
    return "digit"
}

// ── Parse a simple expression: "num op num" ─────────────────
// Returns [left, op_code, right] where op_code: 1=+, 2=-, 3=*, 4=/
fn parse_expr(left: int, op: str, right: int) -> int {
    if op == "+" { return left + right }
    if op == "-" { return left - right }
    if op == "*" { return left * right }
    if op == "/" {
        if right == 0 {
            println("  ERROR: division by zero!")
            return 0
        }
        return left / right
    }
    println("  ERROR: unknown operator:", op)
    return 0
}

// ── Calculator with error handling ──────────────────────────
fn safe_calc(left: int, op: str, right: int) -> int {
    let mut result = 0
    let mut ok = true
    try {
        result = parse_expr(left, op, right)
    } catch e {
        println("  Caught error:", e)
        ok = false
    }
    if ok {
        println("  ", left, op, right, "=", result)
    }
    return result
}

// ── Evaluate a chain: a op1 b op2 c (left-to-right) ────────
fn chain_eval(a: int, op1: str, b: int, op2: str, c: int) -> int {
    let first = parse_expr(a, op1, b)
    return parse_expr(first, op2, c)
}

// ── Main: run the calculator ────────────────────────────────
println("=== HEXA Practical Calculator ===")
println("")

// Basic operations
println("--- Basic Operations ---")
safe_calc(42, "+", 18)
safe_calc(100, "-", 37)
safe_calc(12, "*", 6)
safe_calc(144, "/", 12)
println("")

// Error handling: division by zero
println("--- Error Handling ---")
safe_calc(10, "/", 0)
println("")

// Chain evaluations
println("--- Chained Expressions ---")
let r1 = chain_eval(2, "+", 3, "*", 4)
println("  (2 + 3) * 4 =", r1)

let r2 = chain_eval(10, "*", 10, "-", 1)
println("  (10 * 10) - 1 =", r2)

let r3 = chain_eval(100, "/", 5, "+", 80)
println("  (100 / 5) + 80 =", r3)
println("")

// Build a multiplication table
println("--- Multiplication Table (1..6) ---")
for i in 1..7 {
    let mut row = ""
    for j in 1..7 {
        let product = i * j
        let cell = format("{}", product)
        if product < 10 {
            row = row + " " + cell + " "
        } else {
            row = row + cell + " "
        }
    }
    println("  ", row)
}
println("")

// Power calculator
println("--- Power Calculator ---")
fn power_table(base: int, max_exp: int) {
    let mut i = 0
    while i <= max_exp {
        println("  ", base, "^", i, "=", pow(base, i))
        i = i + 1
    }
}
power_table(2, 10)
println("")

// ── Proof: verify all calculator operations ─────────────────
proof calculator_correctness {
    // Basic arithmetic
    assert parse_expr(3, "+", 4) == 7
    assert parse_expr(10, "-", 3) == 7
    assert parse_expr(6, "*", 7) == 42
    assert parse_expr(24, "/", 6) == 4

    // Chain evaluation
    assert chain_eval(2, "+", 3, "*", 4) == 20
    assert chain_eval(10, "*", 10, "-", 1) == 99
    assert chain_eval(100, "/", 5, "+", 80) == 100

    // Division by zero returns 0 (safe fallback)
    assert parse_expr(10, "/", 0) == 0

    // Powers of 2
    assert pow(2, 0) == 1
    assert pow(2, 10) == 1024

    // n=6 identity holds in calculator
    assert parse_expr(sigma(6), "*", phi(6)) == parse_expr(6, "*", tau(6))
}

println("=== Calculator: All proofs passed! ===")
