// tree.hexa — 간이 tree 명령 (find + 들여쓰기)
// 사용: ./tree [dir] [max_depth]

fn count_slashes(s: string) {
    let mut n = 0
    let mut i = 0
    let cs = s.chars()
    while i < len(cs) {
        if s.substring(i, i + 1) == "/" {
            n = n + 1
        }
        i = i + 1
    }
    return n
}

fn last_component(s: string) {
    let mut i = s.len() - 1
    while i >= 0 {
        if s.substring(i, i + 1) == "/" {
            return s.substring(i + 1, s.len())
        }
        i = i - 1
    }
    return s
}

if argc() < 2 {
    println("usage: tree <dir> [max_depth]")
    exit(1)
}

let dir = arg(1)
let mut max_depth = 3
if argc() >= 3 {
    max_depth = parse_int(arg(2))
}

let base_slashes = count_slashes(dir)
let cmd = "find " + dir + " -maxdepth " + to_string(max_depth) + " 2>/dev/null | sort"
let output = exec(cmd)
let lines = output.split("\n")

let mut files = 0
let mut dirs = 0
for line in lines {
    if line.len() == 0 {
        continue
    }
    let depth = count_slashes(line) - base_slashes
    let name = last_component(line)
    // 들여쓰기
    let mut indent = ""
    let mut d = 0
    while d < depth {
        indent = indent + "  "
        d = d + 1
    }
    // 파일 vs 디렉토리 판별
    let is_dir = exec("test -d '" + line + "' && echo d || echo f")
    if is_dir == "d" {
        println(indent + "📁 " + name + "/")
        dirs = dirs + 1
    } else {
        println(indent + "  " + name)
        files = files + 1
    }
}

println("─────")
println("dirs:", dirs, " files:", files)
