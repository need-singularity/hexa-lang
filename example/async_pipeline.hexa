// async_pipeline.hexa — Async data processing: fan-out/fan-in
// Demonstrates: spawn, channel, concurrent workers, result collection

println("=== Async Data Pipeline ===")
println("")

// ── 1. Fan-out/Fan-in: distribute work across workers ──────
println("--- 1. Fan-Out / Fan-In ---")
println("  Distributing computation across 4 workers...")
println("")

// Each worker computes sum of a range
fn compute_range_sum(start: int, end_val: int) -> int {
    let mut sum = 0
    let mut i = start
    while i < end_val {
        sum = sum + i
        i = i + 1
    }
    return sum
}

// Spawn 4 workers, each sums a quarter of 1..1000
let p1 = channel()
let tx1 = p1[0]
let rx1 = p1[1]

let p2 = channel()
let tx2 = p2[0]
let rx2 = p2[1]

let p3 = channel()
let tx3 = p3[0]
let rx3 = p3[1]

let p4 = channel()
let tx4 = p4[0]
let rx4 = p4[1]

spawn {
    let result = compute_range_sum(1, 251)
    tx1.send(result)
}

spawn {
    let result = compute_range_sum(251, 501)
    tx2.send(result)
}

spawn {
    let result = compute_range_sum(501, 751)
    tx3.send(result)
}

spawn {
    let result = compute_range_sum(751, 1001)
    tx4.send(result)
}

// Fan-in: collect all results
let r1 = rx1.recv()
let r2 = rx2.recv()
let r3 = rx3.recv()
let r4 = rx4.recv()
let total = r1 + r2 + r3 + r4

println("  Worker 1 (1..250):    ", r1)
println("  Worker 2 (251..500):  ", r2)
println("  Worker 3 (501..750):  ", r3)
println("  Worker 4 (751..1000): ", r4)
println("  Total sum:            ", total)

// Verify: sum(1..1000) = 1000*1001/2 = 500500
let expected = 1000 * 1001 / 2
println("  Expected:             ", expected)
assert total == expected
println("")

// ── 2. Pipeline stages: producer -> transformer -> consumer ─
println("--- 2. Pipeline: Producer -> Transformer -> Consumer ---")

let prod_ch = channel()
let prod_tx = prod_ch[0]
let prod_rx = prod_ch[1]

let trans_ch = channel()
let trans_tx = trans_ch[0]
let trans_rx = trans_ch[1]

let done_ch = channel()
let done_tx = done_ch[0]
let done_rx = done_ch[1]

// Stage 1: Producer — generates data
spawn {
    let mut i = 1
    while i <= 10 {
        prod_tx.send(i)
        i = i + 1
    }
    prod_tx.send(-1)  // sentinel: end of stream
}

// Stage 2: Transformer — squares each value
spawn {
    let mut running = true
    while running {
        let val = prod_rx.recv()
        if val == -1 {
            trans_tx.send(-1)
            running = false
        } else {
            trans_tx.send(val * val)
        }
    }
}

// Stage 3: Consumer — accumulates results
spawn {
    let mut sum = 0
    let mut count = 0
    let mut running = true
    while running {
        let val = trans_rx.recv()
        if val == -1 {
            running = false
        } else {
            sum = sum + val
            count = count + 1
        }
    }
    done_tx.send(sum)
    done_tx.send(count)
}

let pipeline_sum = done_rx.recv()
let pipeline_count = done_rx.recv()

println("  Produced 1..10")
println("  Transformed: squared each value")
println("  Sum of squares:", pipeline_sum)
println("  Items processed:", pipeline_count)
// sum(i^2, i=1..10) = 385
assert pipeline_sum == 385
assert pipeline_count == 10
println("")

// ── 3. Parallel map: apply function to array concurrently ──
println("--- 3. Parallel Map ---")

let data = [2, 5, 8, 11, 14, 17, 20, 23]
println("  Input:", data)

// Spawn a worker for each pair
fn heavy_compute(x: int) -> int {
    // Simulate some computation
    return x * x + 2 * x + 1  // (x+1)^2
}

let ch_a = channel()
let ch_a_tx = ch_a[0]
let ch_a_rx = ch_a[1]

let ch_b = channel()
let ch_b_tx = ch_b[0]
let ch_b_rx = ch_b[1]

// Worker A: first half
spawn {
    let mut results = []
    let mut i = 0
    while i < 4 {
        results.push(heavy_compute(data[i]))
        i = i + 1
    }
    ch_a_tx.send(results)
}

// Worker B: second half
spawn {
    let mut results = []
    let mut i = 4
    while i < 8 {
        results.push(heavy_compute(data[i]))
        i = i + 1
    }
    ch_b_tx.send(results)
}

let results_a = ch_a_rx.recv()
let results_b = ch_b_rx.recv()

// Merge results
let mut all_results = []
for v in results_a {
    all_results.push(v)
}
for v in results_b {
    all_results.push(v)
}

println("  f(x) = (x+1)^2")
println("  Results:", all_results)

// Verify
let mut i = 0
while i < len(data) {
    let expected_val = (data[i] + 1) * (data[i] + 1)
    assert all_results[i] == expected_val
    i = i + 1
}
println("  All results verified!")
println("")

// ── 4. Async aggregation with multiple metrics ─────────────
println("--- 4. Multi-Metric Aggregation ---")

let values = [15, 27, 42, 8, 63, 31, 56, 19, 44, 37]
println("  Data:", values)

// Worker: compute sum
let sum_ch = channel()
let sum_tx = sum_ch[0]
let sum_rx = sum_ch[1]
spawn {
    let mut s = 0
    for v in values {
        s = s + v
    }
    sum_tx.send(s)
}

// Worker: find max
let max_ch = channel()
let max_tx = max_ch[0]
let max_rx = max_ch[1]
spawn {
    let mut m = values[0]
    for v in values {
        if v > m { m = v }
    }
    max_tx.send(m)
}

// Worker: find min
let min_ch = channel()
let min_tx = min_ch[0]
let min_rx = min_ch[1]
spawn {
    let mut m = values[0]
    for v in values {
        if v < m { m = v }
    }
    min_tx.send(m)
}

// Worker: count above average (pre-computed avg = 34.2)
let above_ch = channel()
let above_tx = above_ch[0]
let above_rx = above_ch[1]
spawn {
    let mut count = 0
    for v in values {
        if v > 34 {
            count = count + 1
        }
    }
    above_tx.send(count)
}

// Collect all metrics
let metric_sum = sum_rx.recv()
let metric_max = max_rx.recv()
let metric_min = min_rx.recv()
let metric_above = above_rx.recv()

println("  Sum:          ", metric_sum)
println("  Max:          ", metric_max)
println("  Min:          ", metric_min)
println("  Above avg(34):", metric_above, "/ 10")
println("  Average:      ", metric_sum / len(values))

assert metric_sum == 342
assert metric_max == 63
assert metric_min == 8
println("")

println("=== Async pipeline complete! ===")
