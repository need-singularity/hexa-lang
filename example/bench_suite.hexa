// ══════════════════════════════════════════════════════════
// HEXA-IR Benchmark Suite — n=6 파생 실전 벤치마크
// 6개 테스트 × 다양한 패턴 (루프/재귀/분기/수학/해싱)
// Expected: 각 결과 합산 → 검증 가능한 단일 값
// ══════════════════════════════════════════════════════════

// [1] 소수 체 (Sieve) — 분기 + 중첩 루프
fn count_primes(limit: int) -> int {
    let count = 0
    let n = 2
    while n < limit {
        let is_prime = 1
        let d = 2
        while d * d <= n {
            if n % d == 0 {
                is_prime = 0
            }
            d = d + 1
        }
        count = count + is_prime
        n = n + 1
    }
    count
}

// [2] 피보나치 반복 — 단순 루프 성능
fn fib_iter(n: int) -> int {
    let a = 0
    let b = 1
    let i = 0
    while i < n {
        let t = a + b
        a = b
        b = t
        i = i + 1
    }
    a
}

// [3] GCD 반복 (유클리드) — while + 조건 분기
fn gcd(a: int, b: int) -> int {
    let x = a
    let y = b
    while y != 0 {
        let t = y
        y = x % y
        x = t
    }
    x
}

// [4] 콜라츠 추측 — 불규칙 분기 + 카운트
fn collatz_steps(n: int) -> int {
    let steps = 0
    let v = n
    while v != 1 {
        if v % 2 == 0 {
            v = v / 2
        } else {
            v = v * 3 + 1
        }
        steps = steps + 1
    }
    steps
}

// [5] 정수 제곱근 (뉴턴법) — 수렴 루프
fn isqrt(n: int) -> int {
    if n < 2 {
        return n
    }
    let x = n
    let y = (x + 1) / 2
    while y < x {
        x = y
        y = (x + n / x) / 2
    }
    x
}

// [6] 해시 누적 (FNV-1a 변형) — 비트 연산 + 루프
fn hash_range(start: int, end: int) -> int {
    let hash = 2166136261
    let i = start
    while i < end {
        // FNV-1a: hash = (hash ^ byte) * prime
        hash = hash * 16777619
        hash = hash + i
        i = i + 1
    }
    // 양수로 변환
    if hash < 0 {
        hash = 0 - hash
    }
    hash % 1000000007
}

// ══════════════════════════════════════════════════════════
// Main: 각 벤치 N회 반복 후 결과 합산
// ══════════════════════════════════════════════════════════
let iterations = 10000
let result = 0

// [1] 소수 개수: count_primes(100) = 25
let i = 0
while i < iterations {
    result = result + count_primes(100)
    i = i + 1
}

// [2] fib(30) = 832040
i = 0
while i < iterations {
    result = result + fib_iter(30)
    i = i + 1
}

// [3] GCD(48, 18) = 6  (n=6 다시!)
i = 0
while i < iterations * 10 {
    result = result + gcd(48, 18)
    i = i + 1
}

// [4] collatz_steps(27) = 111
i = 0
while i < iterations {
    result = result + collatz_steps(27)
    i = i + 1
}

// [5] isqrt(1000000) = 1000
i = 0
while i < iterations * 10 {
    result = result + isqrt(1000000)
    i = i + 1
}

// [6] hash_range(0, 100) — 해시 누적
i = 0
while i < iterations {
    result = result + hash_range(0, 100)
    i = i + 1
}

println(result)
// Verification: 미리 계산된 expected value
// 25*10K + 832040*10K + 6*100K + 111*10K + 1000*100K + hash*10K
