// test_float_ffi.hexa — G3: Float argument support for extern FFI
// Tests that float/double arguments are passed in SIMD registers (d0-d7)
// on ARM64, not integer registers (x0-x7).
//
// Uses C math library functions that take double args.
// On macOS, math functions are in libSystem (dlopen(NULL) finds them).

@symbol("sin")
extern fn math_sin(x: Float) -> Float

@symbol("cos")
extern fn math_cos(x: Float) -> Float

@symbol("pow")
extern fn math_pow(base: Float, exp: Float) -> Float

@symbol("fma")
extern fn math_fma(x: Float, y: Float, z: Float) -> Float

// Test 1: sin(0.0) == 0.0
let s0 = math_sin(0.0)
println("sin(0.0) = " + to_string(s0))
assert abs(s0) < 0.0001

// Test 2: cos(0.0) == 1.0
let c0 = math_cos(0.0)
println("cos(0.0) = " + to_string(c0))
assert abs(c0 - 1.0) < 0.0001

// Test 3: pow(2.0, 10.0) == 1024.0
let p = math_pow(2.0, 10.0)
println("pow(2.0, 10.0) = " + to_string(p))
assert abs(p - 1024.0) < 0.0001

// Test 4: fma(2.0, 3.0, 4.0) = 2*3+4 = 10.0 (3 float args)
let f = math_fma(2.0, 3.0, 4.0)
println("fma(2.0, 3.0, 4.0) = " + to_string(f))
assert abs(f - 10.0) < 0.0001

// Test 5: Mixed int/float — getpid returns Int, no float args
extern fn getpid() -> Int
let pid = getpid()
println("getpid() = " + to_string(pid))
assert pid > 0

println("=== G3: ALL FLOAT FFI TESTS PASSED ===")
