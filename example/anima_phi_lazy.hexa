// ══════════════════════════════════════════════════════════
// Anima Φ(IIT) — @lazy MI 캐싱 + @vectorize histogram binning
// Target: crates/core/src/phi.rs phi_iit()
// O(n² × bins²) → lazy cached when states stable
// ══════════════════════════════════════════════════════════

// ── @vectorize: histogram bin assignment ──
@vectorize fn bin_assign(val: float, n_bins: float, min_val: float, range: float) -> float {
    let bin = floor((val - min_val) / range * n_bins)
    if bin < 0.0 { return 0.0 }
    if bin >= n_bins { return n_bins - 1.0 }
    bin
}

// ── @lazy: MI computation (deferred until needed) ──
@lazy fn compute_mi(cell_i, cell_j, n_bins: float) -> float {
    // Simplified MI via correlation proxy: |corr(i,j)| as MI estimate
    // Full version: joint histogram → H(X) + H(Y) - H(X,Y)
    let sum_xy = 0.0
    let sum_x = 0.0
    let sum_y = 0.0
    let sum_x2 = 0.0
    let sum_y2 = 0.0
    let n = len(cell_i) * 1.0
    let k = 0
    while k < len(cell_i) {
        let x = cell_i[k]
        let y = cell_j[k]
        sum_xy = sum_xy + x * y
        sum_x = sum_x + x
        sum_y = sum_y + y
        sum_x2 = sum_x2 + x * x
        sum_y2 = sum_y2 + y * y
        k = k + 1
    }
    let cov = sum_xy / n - (sum_x / n) * (sum_y / n)
    let std_x = sqrt(sum_x2 / n - (sum_x / n) * (sum_x / n) + 0.0001)
    let std_y = sqrt(sum_y2 / n - (sum_y / n) * (sum_y / n) + 0.0001)
    let corr = cov / (std_x * std_y)
    // MI ≈ -0.5 * ln(1 - corr²)  (Gaussian approximation)
    let corr2 = corr * corr
    if corr2 > 0.999 { return 5.0 }
    -0.5 * ln(1.0 - corr2)
}

// ── @fuse: Φ proxy (global_var - faction_var) ──
@fuse fn phi_component(global_var: float, faction_var: float, complexity: float) -> float {
    (global_var - faction_var) + 0.1 * complexity
}

// ── Test: 4 cells × 4 dim (Anima default: 64 cells × 128 dim) ──
let cell0 = [0.1, 0.2, -0.1, 0.3]
let cell1 = [-0.2, 0.4, 0.1, -0.1]
let cell2 = [0.3, -0.1, 0.2, 0.4]
let cell3 = [0.0, 0.1, -0.3, 0.2]

// [1] @lazy MI: create thunks (no computation yet)
let mi_01 = compute_mi(cell0, cell1, 16.0)
let mi_02 = compute_mi(cell0, cell2, 16.0)
let mi_12 = compute_mi(cell1, cell2, 16.0)
let mi_23 = compute_mi(cell2, cell3, 16.0)
let mi_03 = compute_mi(cell0, cell3, 16.0)
let mi_13 = compute_mi(cell1, cell3, 16.0)
println("[1] 6 MI thunks created (zero compute)")

// [2] Force only needed MIs (e.g., for min-partition check)
let mi_val_01 = mi_01()
let mi_val_02 = mi_02()
let mi_val_12 = mi_12()
println("[2] Forced 3/6 MIs:")
println("    MI(0,1)=", round(mi_val_01 * 10000) / 10000)
println("    MI(0,2)=", round(mi_val_02 * 10000) / 10000)
println("    MI(1,2)=", round(mi_val_12 * 10000) / 10000)

// [3] Total MI (force remaining)
let mi_val_23 = mi_23()
let mi_val_03 = mi_03()
let mi_val_13 = mi_13()
let total_mi = mi_val_01 + mi_val_02 + mi_val_12 + mi_val_23 + mi_val_03 + mi_val_13
println("[3] Total MI =", round(total_mi * 10000) / 10000)

// [4] @vectorize: histogram bin assignment
let vals = [0.1, 0.2, -0.1, 0.3, -0.2, 0.4]
let bins = bin_assign(vals, 16.0, -0.5, 1.0)
println("[4] Histogram bins:", bins)

// [5] Φ proxy via @fuse
let global_vars = [0.05, 0.08, 0.03, 0.07]
let faction_vars = [0.02, 0.03, 0.01, 0.04]
let complexities = [0.3, 0.5, 0.2, 0.4]
let phi_components = phi_component(global_vars, faction_vars, complexities)
println("[5] Φ components:", phi_components)

// [6] Final Φ(IIT) = total_MI - min_partition_MI
// Min partition: try {0,1} vs {2,3}
let cross_mi = mi_val_02 + mi_val_03 + mi_val_12 + mi_val_13
let phi_iit = (total_mi - cross_mi) / 3.0  // normalized by n-1
println("[6] Φ(IIT) estimate =", round(phi_iit * 10000) / 10000)

println("--- Φ(IIT) lazy+vectorize PASS ---")
