// text_tools.hexa — 텍스트 유틸 모음

fn reverse_str(s: string) {
    let mut out = ""
    let n = s.len()
    let mut i = n - 1
    while i >= 0 {
        out = out + s.substring(i, i + 1)
        i = i - 1
    }
    return out
}

fn is_palindrome(s: string) {
    let lo = s.to_lower()
    let rev = reverse_str(lo)
    if lo == rev {
        return 1
    }
    return 0
}

fn count_vowels(s: string) {
    let lo = s.to_lower()
    let cs = lo.chars()
    let n = len(cs)
    let mut count = 0
    let mut i = 0
    while i < n {
        let c = lo.substring(i, i + 1)
        if c == "a" || c == "e" || c == "i" || c == "o" || c == "u" {
            count = count + 1
        }
        i = i + 1
    }
    return count
}

fn char_freq_sum(s: string) {
    // 문자열의 charcode 합 — anagram 간이 검사
    let cs = s.to_lower().chars()
    let n = len(cs)
    let mut sum = 0
    let mut i = 0
    while i < n {
        sum = sum + cs[i]
        i = i + 1
    }
    return sum
}

fn is_anagram(a: string, b: string) {
    if a.len() != b.len() {
        return 0
    }
    if char_freq_sum(a) == char_freq_sum(b) {
        return 1
    }
    return 0
}

// 테스트
println("=== reverse ===")
println("'hello' →", reverse_str("hello"))
println("'HEXA'  →", reverse_str("HEXA"))

println("")
println("=== palindrome ===")
println("'racecar' →", is_palindrome("racecar"))
println("'hello'   →", is_palindrome("hello"))
println("'Aba'     →", is_palindrome("Aba"))
println("'noon'    →", is_palindrome("noon"))

println("")
println("=== vowel count ===")
println("'Hello World'    →", count_vowels("Hello World"))
println("'programming'    →", count_vowels("programming"))
println("'rhythm'         →", count_vowels("rhythm"))

println("")
println("=== anagram (간이) ===")
println("listen vs silent →", is_anagram("listen", "silent"))
println("hello  vs world  →", is_anagram("hello", "world"))
println("evil   vs vile   →", is_anagram("evil", "vile"))
println("done")
