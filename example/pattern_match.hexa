println("=== Pattern Matching + Control Flow ===")

fn fizzbuzz(n: int) -> string {
    if n % 6 == 0 {
        return "FizzBuzz (n=6!)"
    }
    if n % 3 == 0 {
        return "Fizz"
    }
    if n % 2 == 0 {
        return "Buzz"
    }
    return "."
}

println("FizzBuzz with n=6 alignment:")
for i in 1..25 {
    println("  ", i, ":", fizzbuzz(i))
}
println("Note: every 6th number = FizzBuzz (n=6)")
