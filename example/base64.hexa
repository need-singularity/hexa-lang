// base64.hexa — 순수 hexa base64 인코더
let alphabet = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"

fn b64_char(n) {
    return alphabet.substring(n, n + 1)
}

fn encode(s: string) {
    let cs = s.chars()
    let n = len(cs)
    let mut out = ""
    let mut i = 0
    while i < n {
        let b0 = cs[i]
        let mut b1 = 0
        let mut b2 = 0
        let mut have1 = 0
        let mut have2 = 0
        if i + 1 < n {
            b1 = cs[i + 1]
            have1 = 1
        }
        if i + 2 < n {
            b2 = cs[i + 2]
            have2 = 1
        }
        // 24비트 묶음 → 6비트 x 4
        let tri = b0 * 65536 + b1 * 256 + b2
        let v0 = tri / 262144
        let v1 = (tri / 4096) % 64
        let v2 = (tri / 64) % 64
        let v3 = tri % 64

        out = out + b64_char(v0)
        out = out + b64_char(v1)
        if have1 == 1 {
            out = out + b64_char(v2)
        } else {
            out = out + "="
        }
        if have2 == 1 {
            out = out + b64_char(v3)
        } else {
            out = out + "="
        }
        i = i + 3
    }
    return out
}

println("=== base64 tests ===")
println("'hello' →", encode("hello"))
println("'Hi' →", encode("Hi"))
println("'' →", encode(""))
println("'HEXA' →", encode("HEXA"))
println("'The quick brown fox' →", encode("The quick brown fox"))
println("done")
