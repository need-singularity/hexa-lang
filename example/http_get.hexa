// http_get.hexa — curl 래핑 + HTML 요약
// 사용: ./http_get <url>

fn strip_tags(s: string) {
    let mut out = ""
    let cs = s.chars()
    let n = len(cs)
    let mut in_tag = 0
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "<" {
            in_tag = 1
        } else if c == ">" {
            in_tag = 0
        } else if in_tag == 0 {
            out = out + c
        }
        i = i + 1
    }
    return out
}

fn extract_title(html: string) {
    let lo = html.to_lower()
    let start = lo.index_of("<title>")
    if start < 0 {
        return "(no title)"
    }
    let open_end = start + 7
    let end = lo.index_of("</title>")
    if end < 0 {
        return "(broken title)"
    }
    return html.substring(open_end, end).trim()
}

if argc() < 2 {
    println("usage: http_get <url>")
    exit(1)
}

let url = arg(1)
println("fetching:", url)

let cmd = "curl -sL --max-time 10 " + url
let body = exec(cmd)

if body.len() == 0 {
    println("(empty response)")
    exit(1)
}

println("─────────────")
println("status: OK (", body.len(), "bytes )")
println("title:", extract_title(body))

// 먼저 1000자만 텍스트 추출
let head = body.substring(0, min(1000, body.len()))
let text = strip_tags(head)
let trimmed = text.trim()
println("─── preview ───")
if trimmed.len() > 400 {
    println(trimmed.substring(0, 400) + "...")
} else {
    println(trimmed)
}
println("done")
