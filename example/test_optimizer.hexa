// ══════════════════════════════════════════════════════════
// SGD/Adam 옵티마이저 + numerical_grad 테스트
// Anima 학습 루프 완성 — 완전 gradient descent
// ══════════════════════════════════════════════════════════

// ═══ [1] SGD Step ═══
let params = [1.0, 2.0, 3.0, 4.0]
let grads = [0.1, -0.2, 0.3, -0.1]
let lr = 0.01
let updated = sgd_step(params, grads, lr)
println("[1] SGD: params", params, "→", updated)
// Expected: [0.999, 2.002, 2.997, 4.001]

// ═══ [2] Adam Step ═══
let p = [1.0, 2.0]
let g = [0.5, -0.3]
let m = zeros(2)
let v = zeros(2)
let result = adam_step(p, g, m, v, 0.001, 0.9, 0.999, 0.00000001, 1)
// Result layout: [new_params(2), new_m(2), new_v(2)]
let new_p = slice(result, 0, 2)
let new_m = slice(result, 2, 4)
let new_v = slice(result, 4, 6)
println("[2] Adam step 1:")
println("    params:", p, "→", new_p)
println("    m:", new_m)
println("    v:", new_v)

// Multi-step Adam
let step = 2
while step <= 5 {
    let r = adam_step(new_p, g, new_m, new_v, 0.001, 0.9, 0.999, 0.00000001, step)
    new_p = slice(r, 0, 2)
    new_m = slice(r, 2, 4)
    new_v = slice(r, 4, 6)
    step = step + 1
}
println("    after 5 steps:", new_p)

// ═══ [3] numerical_grad with lambda ═══
// f(x) = x^2, f'(x) = 2x
let grad_at_3 = numerical_grad(|x| x * x, [3.0], 0)
println("[3] numerical_grad(x², at x=3) =", grad_at_3)
// Expected: ~6.0

// f(x, y) = x*y + x^2
let grad_x = numerical_grad(|x, y| x * y + x * x, [2.0, 3.0], 0)
let grad_y = numerical_grad(|x, y| x * y + x * x, [2.0, 3.0], 1)
println("    ∂(xy+x²)/∂x at (2,3) =", grad_x, "(expected: y+2x = 7)")
println("    ∂(xy+x²)/∂y at (2,3) =", grad_y, "(expected: x = 2)")

// ═══ [4] Full gradient descent: minimize f(x) = (x-3)^2 ═══
println("\n[4] Gradient descent: min (x-3)²")
let x = [0.0]  // start at 0
let m_opt = zeros(1)
let v_opt = zeros(1)

let t = 1
while t <= 50 {
    let g_val = numerical_grad(|x| (x - 3.0) * (x - 3.0), x, 0)
    let r = adam_step(x, [g_val], m_opt, v_opt, 0.1, 0.9, 0.999, 0.00000001, t)
    x = slice(r, 0, 1)
    m_opt = slice(r, 1, 2)
    v_opt = slice(r, 2, 3)
    if t % 10 == 0 {
        println("    t=", t, "x=", round(x[0] * 10000) / 10000, "loss=", round((x[0] - 3.0) * (x[0] - 3.0) * 10000) / 10000)
    }
    t = t + 1
}
println("    final x =", round(x[0] * 10000) / 10000, "(target: 3.0)")

// ═══ [5] Anima: optimize Hebbian lr via gradient descent ═══
println("\n[5] Anima Hebbian lr optimization")
fn hebbian_objective(lr) {
    // Minimize: oscillation of weight updates
    let sims = [0.85, 0.15, 0.92, 0.45]
    let weights = [0.3, -0.1, 0.7, 0.2]
    let total = 0.0
    let i = 0
    while i < 4 {
        let delta = lr * (sims[i] - 0.01 * weights[i])
        total = total + delta * delta
        i = i + 1
    }
    total
}

let opt_lr = [0.1]  // start high
let m_lr = zeros(1)
let v_lr = zeros(1)
let t2 = 1
while t2 <= 30 {
    let g_lr = numerical_grad(hebbian_objective, opt_lr, 0)
    let r2 = adam_step(opt_lr, [g_lr], m_lr, v_lr, 0.001, 0.9, 0.999, 0.00000001, t2)
    opt_lr = slice(r2, 0, 1)
    m_lr = slice(r2, 1, 2)
    v_lr = slice(r2, 2, 3)
    t2 = t2 + 1
}
println("    optimized lr =", round(opt_lr[0] * 100000) / 100000)
println("    objective =", round(hebbian_objective(opt_lr[0]) * 100000) / 100000)

// ═══ @test ═══
@test fn test_sgd_direction() {
    let p = sgd_step([1.0], [1.0], 0.1)
    assert(p[0] < 1.0, "SGD should decrease params when grad > 0")
}
@test fn test_adam_converges() {
    // After optimization, x should be close to 3
    assert(x[0] > 2.5, "Adam should converge toward 3")
}
@test fn test_numerical_grad_quadratic() {
    let g = numerical_grad(|x| x * x, [5.0], 0)
    assert(g > 9.9, "grad of x² at 5 should be ~10")
}
run_tests()

println("\n--- optimizer PASS ---")
