// ══════════════════════════════════════════════════════════
// Anima OnlineLearner — 4종 attr 합성 파이프라인
// Target: crates/online-learner/src/updater.rs
// 전체 학습 루프: reward → hebbian → Φ ratchet → output
// <1ms/turn 목표 (64 cells × 128 dim)
// ══════════════════════════════════════════════════════════

// ── @vectorize: reward normalization ──
@vectorize fn normalize(x: float, mean: float, std: float) -> float {
    (x - mean) / (std + 0.0001)
}

// ── @fuse: reward computation (curiosity 70% + dialogue 30%) ──
@fuse fn compute_reward(curiosity: float, dialogue: float) -> float {
    0.7 * curiosity + 0.3 * dialogue
}

// ── @autograd: differentiable reward for meta-learning ──
@autograd fn reward_fn(curiosity_w: float, dialogue_w: float) -> float {
    // Parameterized reward: learn optimal weights
    let c = 0.6  // normalized curiosity score
    let d = 0.4  // normalized dialogue score
    curiosity_w * c + dialogue_w * d
}

// ── @lazy: expensive Φ ratchet check (defer until needed) ──
@lazy fn phi_ratchet_check(phi_current: float, phi_ema: float, phi_peak: float) -> float {
    // Returns: 1.0 if safe, 0.0 if collapse, -1.0 if needs restore
    let threshold = phi_peak * 0.8
    if phi_current > phi_ema * 0.8 {
        return 1.0  // safe
    }
    if phi_current < threshold {
        return -1.0  // needs restore
    }
    0.0  // collapse warning
}

// ── @fuse: Hebbian weight clamp ──
@fuse fn clamp_weight(w: float, delta: float, lo: float, hi: float) -> float {
    let new_w = w + delta
    if new_w < lo { return lo }
    if new_w > hi { return hi }
    new_w
}

// ══════════════════════════════════════════════════════════
// Full Online Learning Step (mimics OnlineLearner::step)
// ══════════════════════════════════════════════════════════

println("=== Anima OnlineLearner Step ===")

// Step 1: Reward computation
let prediction_errors = [0.3, 0.5, 0.1, 0.8, 0.2]
let ce_losses = [2.1, 1.8, 1.9, 1.5, 1.7]

// Curiosity = z-score normalized prediction error
let pe_mean = 0.38
let pe_std = 0.24
let curiosity_scores = normalize(prediction_errors, pe_mean, pe_std)
println("[1] Curiosity z-scores:", curiosity_scores)

// Dialogue = CE trend (first-half vs second-half improvement)
let ce_first_half = (ce_losses[0] + ce_losses[1]) / 2.0
let ce_second_half = (ce_losses[3] + ce_losses[4]) / 2.0
let dialogue_score = ce_first_half - ce_second_half  // positive = improving
println("[2] Dialogue score:", round(dialogue_score * 1000) / 1000)

// Fused reward (batch of 5 turns)
let dialogues = [dialogue_score, dialogue_score, dialogue_score, dialogue_score, dialogue_score]
let rewards = compute_reward(curiosity_scores, dialogues)
println("[3] Fused rewards:", rewards)

// Step 2: @autograd meta-gradient for reward weights
let reward_grads = reward_fn_grad(0.7, 0.3)
println("[4] Meta-gradient ∂reward/∂curiosity_w =", round(reward_grads[0] * 10000) / 10000)
println("    Meta-gradient ∂reward/∂dialogue_w =", round(reward_grads[1] * 10000) / 10000)

// Step 3: Φ ratchet (lazy — only force when needed)
let phi_current = 0.42
let phi_ema = 0.38
let phi_peak = 0.55
let ratchet = phi_ratchet_check(phi_current, phi_ema, phi_peak)
// Only force if we're about to update weights
let step_count = 5
let update_interval = 5
if step_count % update_interval == 0 {
    let safety = ratchet()
    println("[5] Φ ratchet forced: safety =", safety)

    if safety >= 0.0 {
        // Step 4: Hebbian weight update (fused clamp)
        let weights = [0.3, -0.1, 0.7, 0.2, 0.5, -0.3]
        let deltas = [0.01, -0.005, 0.003, -0.002, 0.008, -0.001]
        let updated = clamp_weight(weights, deltas, -1.0, 1.0)
        println("[6] Updated weights:", updated)

        // Delta norm
        let delta_norm = 0.0
        let j = 0
        while j < len(deltas) {
            delta_norm = delta_norm + deltas[j] * deltas[j]
            j = j + 1
        }
        println("[7] Delta norm:", round(sqrt(delta_norm) * 10000) / 10000)
    } else {
        println("[6] RESTORE: Φ collapsed, reverting to checkpoint")
    }
} else {
    println("[5] Φ ratchet DEFERRED (not update step)")
}

println("=== OnlineLearner step complete ===")
println("--- online_learner 4-attr pipeline PASS ---")
