// examples/invariant_require_neg.hexa — require negative case
//
//   ./hexa check examples/invariant_require_neg.hexa
//     → 0 violation + exit 0
//
// 아래에 require 가 요구하는 `_FEATURE_FLAG_` 가 실제 코드에 존재 —
// 위반 없음.

@invariant {
    id: "I4",
    name: "must_contain_feature_flag",
    predicate: "require",
    pattern: { target: "_FEATURE_FLAG_", context: "" },
    exempt: []
}

fn demo() {
    let _FEATURE_FLAG_ = 1
    return _FEATURE_FLAG_
}

demo()
