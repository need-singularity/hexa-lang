// 중첩 if-expression
fn classify(x) {
    return if x > 0 {
        if x > 10 {
            2
        } else {
            1
        }
    } else {
        if x < 0 - 10 {
            0 - 2
        } else {
            0 - 1
        }
    }
}

let mut i = 0 - 15
while i <= 15 {
    println("classify(", i, ") =", classify(i))
    i = i + 5
}
println("done")
