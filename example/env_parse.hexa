// env_parse.hexa — .env 파일 파서
// 사용: ./env_parse <file>
// 형식: KEY=value (주석 #, 공백 라인 무시)

if argc() < 2 {
    println("usage: env_parse <file>")
    exit(1)
}

let path = arg(1)
let content = read_file(path)
if content.len() == 0 {
    println("(empty or missing)")
    exit(1)
}

let lines = content.split("\n")
let mut count = 0
let mut i = 0
println("─── parsed .env ───")
while i < len(lines) {
    let raw = lines[i]
    let line = raw.trim()
    i = i + 1

    // 주석 및 빈 줄 skip
    if line.len() == 0 {
        continue
    }
    if line.starts_with("#") == 1 {
        continue
    }

    // KEY=VALUE 분리
    let eq_pos = line.index_of("=")
    if eq_pos < 0 {
        println("? malformed:", line)
        continue
    }
    let key = line.substring(0, eq_pos).trim()
    let val = line.substring(eq_pos + 1, line.len()).trim()

    // 따옴표 제거 (간이)
    let mut clean_val = val
    if clean_val.len() >= 2 {
        let first = clean_val.substring(0, 1)
        let last = clean_val.substring(clean_val.len() - 1, clean_val.len())
        if first == "\"" {
            if last == "\"" {
                clean_val = clean_val.substring(1, clean_val.len() - 1)
            }
        }
    }

    println(count + 1, ".", key, "=", clean_val)
    count = count + 1
}

println("─── summary ───")
println("entries:", count)
