// ══════════════════════════════════════════════════════════
// @pure CSE + @inline 호출 최적화 테스트
// Anima topology dispatch + microfunctions 가속
// ══════════════════════════════════════════════════════════

// [1] @pure: Common Sub-Expression Elimination
// 같은 인자로 호출 시 캐시에서 반환 (재계산 0)
@pure fn expensive_calc(n: int) -> int {
    // "비싼" 계산 시뮬레이션
    let result = 0
    let i = 0
    while i < n {
        result = result + i * i
        i = i + 1
    }
    result
}

let r1 = expensive_calc(100)
let r2 = expensive_calc(100)  // CSE: 캐시 히트
let r3 = expensive_calc(100)  // CSE: 캐시 히트
println("[1] @pure CSE: r1=", r1, "r2=", r2, "r3=", r3)
println("    all equal:", r1 == r2)

// [2] @pure: 다른 인자 → 새 계산
let r4 = expensive_calc(50)
println("[2] @pure different args:", r4)
println("    r4 != r1:", r4 != r1)

// [3] @inline: 마이크로함수 인라인 (scope push/pop 제거)
@inline fn add1(x: int) -> int { x + 1 }
@inline fn double(x: int) -> int { x * 2 }
@inline fn square(x: int) -> int { x * x }

let v = 5
let v1 = add1(v)
let v2 = double(v1)
let v3 = square(v2)
println("[3] @inline chain: add1(5)=", v1, "double(6)=", v2, "square(12)=", v3)

// [4] @inline + @pure 조합: Anima ring_neighbors 패턴
@pure @inline fn ring_neighbors(cell_id: int, n_cells: int) -> int {
    let left = (cell_id - 1 + n_cells) % n_cells
    let right = (cell_id + 1) % n_cells
    left + right  // simplified: return sum of neighbor ids
}

let n = ring_neighbors(3, 8)
let n2 = ring_neighbors(3, 8)  // CSE hit + inline
println("[4] ring_neighbors(3, 8):", n, "cached:", n2, "equal:", n == n2)

// [5] @inline 루프 성능: 10000번 호출
@inline fn fast_scale(x: float, s: float) -> float { x * s }

let sum = 0.0
let j = 0
while j < 10000 {
    sum = sum + fast_scale(j * 1.0, 0.001)
    j = j + 1
}
println("[5] @inline 10K calls, sum:", sum)
// Expected: sum of j*0.001 for j=0..9999 = 0.001 * 9999*10000/2 = 49995.0

println("--- @pure+@inline PASS ---")
