// n6_emergence.hexa — Emergent properties of n=6 discovered by HEXA itself
// HEXA uses its own computation to find relationships in its design number.
// Some of these are well-known; others emerge from systematic exploration.

// ── Number theory toolkit ────────────────────────────────────

fn sopfr_fn(n: int) -> int {
    let mut sum = 0
    let mut val = n
    let mut d = 2
    while d <= val {
        while val % d == 0 {
            sum = sum + d
            val = val / d
        }
        d = d + 1
    }
    return sum
}

fn jordan_j2(n: int) -> int {
    let mut result = n * n
    let mut val = n
    let mut d = 2
    while d * d <= val {
        if val % d == 0 {
            result = result / (d * d)
            result = result * (d * d - 1)
            while val % d == 0 {
                val = val / d
            }
        }
        d = d + 1
    }
    if val > 1 {
        result = result / (val * val)
        result = result * (val * val - 1)
    }
    return result
}

fn is_prime(n: int) -> bool {
    if n < 2 {
        return false
    }
    let mut d = 2
    while d * d <= n {
        if n % d == 0 {
            return false
        }
        d = d + 1
    }
    return true
}

fn factorial(n: int) -> int {
    let mut result = 1
    let mut i = 2
    while i <= n {
        result = result * i
        i = i + 1
    }
    return result
}

fn divisor_sigma_k(n: int, k: int) -> int {
    // sigma_k(n) = sum of d^k for d | n
    let mut sum = 0
    let mut d = 1
    while d <= n {
        if n % d == 0 {
            sum = sum + pow(d, k)
        }
        d = d + 1
    }
    return sum
}

fn harmonic_numerator(n: int) -> int {
    // H(n) numerator when H(n) = sum(1/k, k=1..n) expressed over lcm
    // For n=6: H(6) = 1 + 1/2 + 1/3 + 1/4 + 1/5 + 1/6 = 49/20
    // We compute numerator*denominator product style
    // Actually, let's compute 60*H(6) = 60 + 30 + 20 + 15 + 12 + 10 = 147
    let lcm_6 = 60  // lcm(1,2,3,4,5,6)
    let mut sum = 0
    let mut k = 1
    while k <= n {
        sum = sum + lcm_6 / k
        k = k + 1
    }
    return sum
}

fn count_divisors_up_to(limit: int) -> int {
    // Count how many n in [1, limit] have exactly tau(6)=4 divisors
    let mut count = 0
    let mut n = 1
    while n <= limit {
        if tau(n) == 4 {
            count = count + 1
        }
        n = n + 1
    }
    return count
}

// ══════════════════════════════════════════════════════════════
// EXPLORATION 1: Complete number-theoretic profile of 6
// ══════════════════════════════════════════════════════════════

println("=== Complete Number-Theoretic Profile of 6 ===")
println("")

let n = 6
let s = sigma(n)        // 12
let t = tau(n)          // 4
let p = phi(n)          // 2
let sp = sopfr_fn(n)    // 5
let j2 = jordan_j2(n)   // 24

println("Basic functions:")
println("  sigma(6)  =", s, "     (sum of divisors)")
println("  tau(6)    =", t, "      (number of divisors)")
println("  phi(6)    =", p, "      (Euler's totient)")
println("  sopfr(6)  =", sp, "      (sum of prime factors)")
println("  J_2(6)    =", j2, "     (Jordan's totient)")

// Higher-order divisor functions
let s0 = divisor_sigma_k(n, 0)  // = tau(n) = 4
let s1 = divisor_sigma_k(n, 1)  // = sigma(n) = 12
let s2 = divisor_sigma_k(n, 2)  // = 1+4+9+36 = 50
let s3 = divisor_sigma_k(n, 3)  // = 1+8+27+216 = 252

println("")
println("Divisor power sums:")
println("  sigma_0(6) =", s0, "= tau(6)")
println("  sigma_1(6) =", s1, "= sigma(6)")
println("  sigma_2(6) =", s2)
println("  sigma_3(6) =", s3)

// ══════════════════════════════════════════════════════════════
// EXPLORATION 2: Relationships between functions of 6
// ══════════════════════════════════════════════════════════════

println("")
println("=== Emergent Relationships ===")
println("")

// Known: sigma*phi = n*tau = J_2 = 24
println("Core identity: sigma*phi = n*tau = J_2(6)")
println("  ", s, "*", p, "=", s * p, "=", n, "*", t, "=", n * t, "=", j2)

// Discovery 1: 6! = 720 = 30 * J_2(6)
let f6 = factorial(n)
println("")
println("Discovery 1: 6! = 720 =", f6 / j2, "* J_2(6)")
assert f6 == 720
assert f6 / j2 == 30

// Discovery 2: sigma_3(6) = 252 = 6! / (tau(6) - 1) + 12
// Actually: 252 = 7 * 36 = 7 * 6^2
println("Discovery 2: sigma_3(6) =", s3, "= 7 * 6^2 =", 7 * n * n)
assert s3 == 7 * n * n

// Discovery 3: sigma(6)^2 = 144 = 6 * J_2(6)
println("Discovery 3: sigma(6)^2 =", s * s, "= 6 * J_2(6) =", n * j2)
assert s * s == n * j2

// Discovery 4: sopfr(6) = 5 is the largest prime less than 6
println("Discovery 4: sopfr(6) =", sp, "(largest prime < 6)")
assert is_prime(sp)

// Discovery 5: tau(6)^sopfr(6) = 1024 = 2^10
let max_cells = pow(t, sp)
println("Discovery 5: tau^sopfr = 4^5 =", max_cells, "= 2^10")
assert max_cells == pow(2, 10)

// Discovery 6: phi(6) + sopfr(6) = 7, the next prime after 6's constituents
let ps = p + sp
println("Discovery 6: phi(6) + sopfr(6) =", ps, "(prime)")
assert is_prime(ps)

// Discovery 7: sigma(6) * tau(6) = 48, and 48 + sopfr(6) = 53 (prime!)
let keywords = s * t + sp
println("Discovery 7: sigma*tau + sopfr =", keywords, "(prime = keyword count)")
assert is_prime(keywords)

// Discovery 8: The 53 keywords are prime -- HEXA's keyword count is prime
println("Discovery 8: 53 keywords is the 16th prime")
let mut prime_count = 0
let mut k = 2
while k <= 53 {
    if is_prime(k) {
        prime_count = prime_count + 1
    }
    k = k + 1
}
println("  Primes up to 53:", prime_count)

// Discovery 9: 24 operators = 4! = tau(6)!
println("Discovery 9: 24 operators = tau(6)! =", factorial(t))
assert j2 == factorial(t)

// Discovery 10: sigma_2(6) = 50 = 2 * J_2(6) + phi(6)
println("Discovery 10: sigma_2(6) =", s2, "= 2*J_2(6) + phi(6) =", 2 * j2 + p)
assert s2 == 2 * j2 + p

// ══════════════════════════════════════════════════════════════
// EXPLORATION 3: The uniqueness landscape
// ══════════════════════════════════════════════════════════════

println("")
println("=== Uniqueness Landscape ===")
println("")

// How close do other numbers get to satisfying sigma*phi = n*tau?
println("Deviation |sigma*phi - n*tau| for n near 6:")
for k in 2..12 {
    let lhs = sigma(k) * phi(k)
    let rhs = k * tau(k)
    let mut diff = lhs - rhs
    if diff < 0 {
        diff = 0 - diff
    }
    let marker = ""
    if k == 6 {
        println("  n=", k, ": |", lhs, "-", rhs, "| =", diff, " <-- ZERO (perfect)")
    } else {
        println("  n=", k, ": |", lhs, "-", rhs, "| =", diff)
    }
}

