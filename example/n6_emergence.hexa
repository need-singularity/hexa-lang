// EXPLORATION 4: Perfect number properties
// ══════════════════════════════════════════════════════════════

println("")
println("=== Perfect Number Properties ===")
println("")

// 6 = 2^(p-1) * (2^p - 1) where p=2, and 2^p-1 = 3 (Mersenne prime)
println("6 = 2^1 * 3 = 2^(2-1) * (2^2 - 1)")
assert n == pow(2, 1) * (pow(2, 2) - 1)

// Proper divisors sum to n
println("1 + 2 + 3 = 6 (proper divisors sum)")
assert 1 + 2 + 3 == n

// sigma(n) = 2n for all perfect numbers
println("sigma(6) = 12 = 2*6")
assert sigma(n) == 2 * n

// 6 is a triangular number: T(3) = 3*4/2 = 6
println("6 = T(3) = 3*4/2 (triangular)")
assert n == 3 * 4 / 2

// 6 is a hexagonal number: H(2) = 2*(2*2-1) = 6
println("6 = H(2) = 2*(2*2-1) (hexagonal)")
assert n == 2 * (2 * 2 - 1)

// 6 is a factorial: 3! = 6
println("6 = 3! (factorial)")
assert n == factorial(3)

// 6 is a primorial: 2*3 = 6 = 3#
println("6 = 2*3 = 3# (primorial)")
assert n == 2 * 3

