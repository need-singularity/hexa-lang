// T46 rt#36-D Exception opcodes MVP smoke.
// Covers: try/catch basic (TRY/ENDTRY), throw-and-catch (THROW),
// nested try, throw-through-call, try without throw.
//
// Expected VM output (one value per line):
//   before
//   caught: bang
//   after
//   100
//   caught: nested
//   -5
//   inner_caught: boom
//   outer: done
//   normal

// 1) Basic try/catch
print("before")
try {
    throw "bang"
    print("unreachable")
} catch e {
    print("caught: " + e)
}
print("after")

// 2) Try without throw — body runs, catch skipped
try {
    print(100)
} catch e {
    print("shouldnt: " + e)
}

// 3) Nested throw — outer catches
try {
    try {
        throw "nested"
    } catch e {
        throw e
    }
} catch outer {
    print("caught: " + outer)
}

// 4) Throw through function call
fn bad(x) {
    if x < 0 {
        throw "negative"
    }
    return x
}
try {
    let _ = bad(-5)
    print("unreachable2")
} catch e {
    print(-5)
}

// 5) Inner try catches, outer continues
try {
    try {
        throw "boom"
    } catch e {
        print("inner_caught: " + e)
    }
    print("outer: done")
} catch outer {
    print("unreachable3")
}

// 6) No-throw baseline
print("normal")
