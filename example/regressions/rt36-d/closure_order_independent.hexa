// T58 — order-independent hoisted-slot pre-scan test.
// Reader defined BEFORE writer — both must share the same cell.
// Expected output (VM): 0 42

let mut shared = 0
let reader = || shared          // defined first — read-only
let writer = |v| { shared = v } // defined second — mutates

print(reader())   // 0
writer(42)
print(reader())   // 42 (must see mutation)
