// T51 (rt#36-E #1) — Lambda emit MVP smoke.
// Covers: AST Lambda node → bc_emitter proto registration,
//         free-var analysis, OP_CLOSURE + OP_NEW_CLOSURE_UPVAL
//         outer-emit, inner-body OP_LOAD_UPVAL routing, indirect
//         OP_CALL via BC_CALL_INDIRECT sentinel + per-frame
//         closure binding.
//
// Expected output (HEXA_VM=1 or interpreter both):
//   10
//   8
//   15
//   180
//   37
//   42
//
// Out of scope (T52):
//   - STORE_UPVAL (mutable captures)
//   - Block-body lambdas `|x| { let y = x; y + 1 }`
//   - Nested lambdas capturing the outer lambda's upvals

// (1) No-capture lambda — zero free vars, pure proto dispatch.
let inc = |x| x + 1
print(inc(9))

// (2) Single capture — free var `c` interned in both inner consts
//     (LOAD_UPVAL) and outer consts (NEW_CLOSURE_UPVAL).
let c = 5
let add_c = |x| x + c
print(add_c(3))
print(add_c(10))

// (3) Two captures — ordering preserved in upval_names[] (emit order).
let a = 100
let b = 20
let lin = |x| a + b * x
print(lin(4))

// (4) Two-arg lambda with one capture — both params bind as locals
//     0..1, free var routes through upval table.
let mul = 10
let scaled = |x, y| mul * x + y
print(scaled(3, 7))

// (5) Zero-arg lambda with capture — validates `||` lambda form.
let z = 42
let getz = || z
print(getz())
