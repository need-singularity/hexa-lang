// T51 후속 fix — free-var 수집기 kind 문자열 정합.
// 이전 draft 는 `Array`/`Index`/`Field` 를 매칭했지만 constructor
// (bc_mk_arraylit / bc_mk_index / bc_mk_field_access) 가 쓰는 실제
// kind 는 `ArrayLit`/`IndexExpr`/`FieldAccess`. 이 불일치로 lambda
// body 내부에서 ArrayLit/IndexExpr/FieldAccess 를 경유해 참조되던
// 자유변수가 free-var 테이블에 수집되지 못하고 LOAD_GLOBAL 로
// 새어나갔다. Top-level capture 는 outer var 가 global 이라 값이
// 맞아 bug 가 숨었고, 함수-내부 capture 에서만 깨졌다.
//
// Expected output (VM: println, interpreter: print — values identical):
//   7
//   8
//   9
//   110
//   140
//   1005
// rt 36-D fix: interpreter previously crashed with "index N out of bounds
// (len 0)" because arena-allocated captured values in closure_store were
// invalidated on scope pop. Fixed by heapifying captured_env in val_closure
// + adding struct_store heapify to runtime.c hexa_val_heapify.

fn make_arr_builder() {
    let base = 7
    return || [base, base + 1, base + 2]
}

fn make_picker() {
    let base = 100
    let xs = [10, 20, 30, 40]
    return |i| xs[i] + base
}

struct Pt { x: int, y: int }

fn make_shifter() {
    let origin = Pt { x: 1000, y: 2000 }
    return |d| origin.x + d
}

fn main() {
    let mk_arr = make_arr_builder()
    let a = mk_arr()
    print(a[0])
    print(a[1])
    print(a[2])

    let pick = make_picker()
    print(pick(0))
    print(pick(3))

    let shift = make_shifter()
    print(shift(5))
}
