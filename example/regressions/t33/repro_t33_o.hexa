// T33 repro O — same as N but inline split (no fn wrapper)
fn main() {
    let src = "a\nbb\nccc\n"
    let lines = src.split("\n")
    let n = len(lines)
    println("n=" + to_string(n))
    let mut i = 0
    while i < n {
        let line = lines[i]
        println("tag=" + type_of(line) + " val=" + to_string(line))
        i = i + 1
    }
}

main()
