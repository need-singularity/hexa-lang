// T33 repro candidate B — with array accumulator + join
// Exercises out_parts.push(line) pattern similar to ml_resolve.

fn ml_trim_left(s) { return s.trim_start() }

fn ml_starts_with(s, prefix) {
    let pn = len(prefix)
    let sn = len(s)
    if pn > sn { return false }
    let mut i = 0
    while i < pn {
        if s[i] != prefix[i] { return false }
        i = i + 1
    }
    return true
}

fn ml_parse_import(line) {
    let trimmed = ml_trim_left(line)
    if ml_starts_with(trimmed, "import ") { return "yes" }
    if ml_starts_with(trimmed, "use ") { return "yes" }
    return ""
}

fn ml_resolve(src, visited) {
    let lines = src.split("\n")
    let mut out_parts = []
    let n = len(lines)
    let mut i = 0
    while i < n {
        let line = lines[i]
        let imp = ml_parse_import(line)
        if imp == "" {
            out_parts.push(line)
            out_parts.push("\n")
        } else {
            let vs2 = visited.push("child")
            out_parts.push("// begin")
            out_parts.push("\n")
            let expanded = ml_resolve("inner content\n", vs2)
            out_parts.push(expanded)
            out_parts.push("// end")
            out_parts.push("\n")
        }
        i = i + 1
    }
    return out_parts.join("")
}

fn main() {
    let mut src = ""
    let mut k = 0
    while k < 50 {
        src = src + "   line " + to_string(k) + "\n"
        k = k + 1
    }
    // Mix in some import lines to trigger recursion
    src = src + "import \"a.hexa\"\n"
    src = src + "use \"b.hexa\"\n"
    src = src + "regular line\n"
    let out = ml_resolve(src, [])
    println("[repro_t33_b] out_len=" + to_string(len(out)))
}

main()
