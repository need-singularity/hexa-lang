// T33 repro H — minimize: drop ml_resolve_path, ml_contains, ml_dirname, ml_join_path
fn ml_trim_left(s) { return s.trim_start() }

fn ml_starts_with(s, prefix) {
    let pn = len(prefix)
    let sn = len(s)
    if pn > sn { return false }
    let mut i = 0
    while i < pn {
        if s[i] != prefix[i] { return false }
        i = i + 1
    }
    return true
}

fn ml_split_lines(s) { return s.split("\n") }

fn ml_parse_import(line) {
    let trimmed = ml_trim_left(line)
    let mut prefix_len = 0
    if ml_starts_with(trimmed, "import ") { prefix_len = 7 }
    else if ml_starts_with(trimmed, "use ") { prefix_len = 4 }
    else { return "" }
    let n = len(trimmed)
    if prefix_len >= n { return "" }
    let rest = ml_trim_left(trimmed.substring(prefix_len, n))
    let rn = len(rest)
    if rn < 2 { return "" }
    if rest[0] != '"' { return "" }
    let mut i = 1
    while i < rn {
        if rest[i] == '"' { return rest.substring(1, i) }
        i = i + 1
    }
    return ""
}

fn ml_resolve(src) {
    let lines = ml_split_lines(src)
    let mut out_parts = []
    let n = len(lines)
    let mut i = 0
    while i < n {
        let line = lines[i]
        let imp = ml_parse_import(line)
        out_parts.push(line)
        out_parts.push("\n")
        i = i + 1
    }
    return out_parts.join("")
}

fn load_module(path) {
    let src = read_file(path)
    return ml_resolve(src)
}

fn main() {
    let expanded = load_module("/tmp/t33_input.hexa")
    println("[repro_t33_h] len=" + to_string(len(expanded)))
}

main()
