// T33 repro C — mimic module_loader load_module() but without write_file
fn ml_trim_left(s) { return s.trim_start() }

fn ml_starts_with(s, prefix) {
    let pn = len(prefix)
    let sn = len(s)
    if pn > sn { return false }
    let mut i = 0
    while i < pn {
        if s[i] != prefix[i] { return false }
        i = i + 1
    }
    return true
}

fn ml_parse_import(line) {
    let trimmed = ml_trim_left(line)
    let mut prefix_len = 0
    if ml_starts_with(trimmed, "import ") {
        prefix_len = 7
    } else if ml_starts_with(trimmed, "use ") {
        prefix_len = 4
    } else {
        return ""
    }
    let n = len(trimmed)
    if prefix_len >= n { return "" }
    let rest = ml_trim_left(trimmed.substring(prefix_len, n))
    let rn = len(rest)
    if rn < 2 { return "" }
    if rest[0] != '"' { return "" }
    let mut i = 1
    while i < rn {
        if rest[i] == '"' {
            return rest.substring(1, i)
        }
        i = i + 1
    }
    return ""
}

fn ml_resolve(src, base_dir, visited) {
    let lines = src.split("\n")
    let mut out_parts = []
    let n = len(lines)
    let mut i = 0
    while i < n {
        let line = lines[i]
        let imp = ml_parse_import(line)
        if imp == "" {
            out_parts = out_parts.push(line)
            out_parts = out_parts.push("\n")
        } else {
            out_parts = out_parts.push("// import " + imp)
            out_parts = out_parts.push("\n")
        }
        i = i + 1
    }
    return out_parts.join("")
}

fn load_module(src) {
    let visited = ["root"]
    return ml_resolve(src, ".", visited)
}

fn main() {
    let src = "// dummy input\nfn foo() { return 1 }\nfn bar() { return 2 }\n"
    let expanded = load_module(src)
    println("[repro_t33_c] len=" + to_string(len(expanded)))
    println(expanded)
}

main()
