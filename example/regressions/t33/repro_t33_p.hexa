// T33 repro P — minimum surface for ARENA=1 OOB on use-path.
// Bisected from repro_t33_g (2026-04-14): all imports/visited/parse_import
// helpers stripped; the trigger is just (a) load_module wrapper that calls
// ml_dirname(path), (b) ml_dirname has `let n = len(path)` + `substring(0, 1)`,
// (c) the result is forwarded into ml_resolve which builds out_parts via push.
//
// ARENA=0 → "len=23". ARENA=1 → "index <raw_ptr> out of bounds (len 0)".
//
// Removing `let n = len(path)` flips to a different garbage shape
// ("len=<__not_builtin__>") rather than OOB — confirms the local-stack-frame
// layout (two locals + arena substring) is what desyncs heapify on return.
//
// Track: T37 (call_method + eval_effect_call envelope heapify audit).

fn ml_dirname(path) {
    let n = len(path)
    return path.substring(0, 1)
}

fn ml_starts_with(s, prefix) {
    let pn = len(prefix)
    let sn = len(s)
    if pn > sn { return false }
    let mut i = 0
    while i < pn {
        if s[i] != prefix[i] { return false }
        i = i + 1
    }
    return true
}

fn ml_parse_import(line) {
    let trimmed = line.trim_start()
    if ml_starts_with(trimmed, "import ") { return "x" }
    return ""
}

fn ml_resolve(src, base_dir, visited) {
    let lines = src.split("\n")
    let mut out_parts = []
    let n = len(lines)
    let mut i = 0
    while i < n {
        let line = lines[i]
        let imp = ml_parse_import(line)
        if imp == "" {
            out_parts.push(line)
            out_parts.push("\n")
        }
        i = i + 1
    }
    return out_parts.join("")
}

fn load_module(path) {
    let src = read_file(path)
    let dir = ml_dirname(path)
    let visited = [path]
    return ml_resolve(src, dir, visited)
}

fn main() {
    // Inline content so this repro is self-contained (no external file).
    write_file("/tmp/t33_p_input.hexa", "println(\"standalone\")\n")
    let expanded = load_module("/tmp/t33_p_input.hexa")
    println("[repro_t33_p] len=" + to_string(len(expanded)))
}

main()
