// test_struct_pack.hexa — G2: Struct value passing via struct packing builtins
// Tests struct_pack, struct_unpack, struct_rect, struct_point, struct_size, struct_free
println("=== G2: Struct Packing tests ===")

// Test 1: struct_pack — pack 4 f64 values (NSRect-like)
let rect = struct_pack(10.0, 20.0, 800.0, 600.0)
assert(rect > 0, "struct_pack returned null")
println("[PASS] struct_pack(10.0, 20.0, 800.0, 600.0)")

// Test 2: struct_unpack — read back each field
let x = struct_unpack(rect, 0)
let y = struct_unpack(rect, 1)
let w = struct_unpack(rect, 2)
let h = struct_unpack(rect, 3)
assert(x == 10.0, "struct_unpack[0] failed: " + to_string(x))
assert(y == 20.0, "struct_unpack[1] failed: " + to_string(y))
assert(w == 800.0, "struct_unpack[2] failed: " + to_string(w))
assert(h == 600.0, "struct_unpack[3] failed: " + to_string(h))
println("[PASS] struct_unpack all 4 fields correct")

// Test 3: struct_free
struct_free(rect)
println("[PASS] struct_free(rect)")

// Test 4: struct_rect convenience
let r2 = struct_rect(100.0, 200.0, 1024.0, 768.0)
assert(r2 > 0, "struct_rect returned null")
let rx = struct_unpack(r2, 0)
let ry = struct_unpack(r2, 1)
let rw = struct_unpack(r2, 2)
let rh = struct_unpack(r2, 3)
assert(rx == 100.0, "struct_rect x failed")
assert(ry == 200.0, "struct_rect y failed")
assert(rw == 1024.0, "struct_rect w failed")
assert(rh == 768.0, "struct_rect h failed")
println("[PASS] struct_rect(100, 200, 1024, 768)")
struct_free(r2)

// Test 5: struct_point convenience (2x f64 = 16 bytes)
let pt = struct_point(42.5, 99.9)
assert(pt > 0, "struct_point returned null")
let px = struct_unpack(pt, 0)
let py = struct_unpack(pt, 1)
assert(px == 42.5, "struct_point x failed")
assert(py == 99.9, "struct_point y failed")
println("[PASS] struct_point(42.5, 99.9)")
struct_free(pt)

// Test 6: struct_size convenience (2x f64 = 16 bytes)
let sz = struct_size(1920.0, 1080.0)
assert(sz > 0, "struct_size returned null")
let sw = struct_unpack(sz, 0)
let sh = struct_unpack(sz, 1)
assert(sw == 1920.0, "struct_size w failed")
assert(sh == 1080.0, "struct_size h failed")
println("[PASS] struct_size(1920, 1080)")
struct_free(sz)

// Test 7: struct_pack with integer args (auto-converted to f64)
let ints = struct_pack(1, 2, 3)
let v0 = struct_unpack(ints, 0)
let v1 = struct_unpack(ints, 1)
let v2 = struct_unpack(ints, 2)
assert(v0 == 1.0, "struct_pack int->f64 [0] failed")
assert(v1 == 2.0, "struct_pack int->f64 [1] failed")
assert(v2 == 3.0, "struct_pack int->f64 [2] failed")
println("[PASS] struct_pack with int args auto-converts to f64")
struct_free(ints)

// Test 8: struct_pack_f32 — pack as 32-bit floats
let f32s = struct_pack_f32(1.5, 2.5, 3.5, 4.5)
assert(f32s > 0, "struct_pack_f32 returned null")
let f0 = struct_unpack_f32(f32s, 0)
let f1 = struct_unpack_f32(f32s, 1)
let f2 = struct_unpack_f32(f32s, 2)
let f3 = struct_unpack_f32(f32s, 3)
assert(f0 > 1.4, "struct_unpack_f32[0] failed")
assert(f0 < 1.6, "struct_unpack_f32[0] failed")
assert(f1 > 2.4, "struct_unpack_f32[1] failed")
assert(f1 < 2.6, "struct_unpack_f32[1] failed")
assert(f2 > 3.4, "struct_unpack_f32[2] failed")
assert(f2 < 3.6, "struct_unpack_f32[2] failed")
assert(f3 > 4.4, "struct_unpack_f32[3] failed")
assert(f3 < 4.6, "struct_unpack_f32[3] failed")
println("[PASS] struct_pack_f32 / struct_unpack_f32")
struct_free(f32s)

// Test 9: struct_pack single value
let single = struct_pack(3.14159)
let sv = struct_unpack(single, 0)
assert(sv > 3.14, "struct_pack single failed")
assert(sv < 3.15, "struct_pack single failed")
println("[PASS] struct_pack single value")
struct_free(single)

// Test 10: Use struct_rect pointer with ptr_read_f64 (cross-check with G5)
let r3 = struct_rect(0.0, 0.0, 640.0, 480.0)
let check_w = ptr_read_f64(r3, 16)  // offset 16 = 3rd f64 = width
let check_h = ptr_read_f64(r3, 24)  // offset 24 = 4th f64 = height
assert(check_w == 640.0, "ptr_read_f64 cross-check width failed")
assert(check_h == 480.0, "ptr_read_f64 cross-check height failed")
println("[PASS] struct_rect + ptr_read_f64 cross-check")
struct_free(r3)

println("=== All G2 struct packing tests passed ===")
