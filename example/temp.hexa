// temp.hexa — 온도 변환 (C/F/K)
// 사용: ./temp <value> <from_unit>
//   ex: ./temp 100 C  → 모든 단위로 변환

fn c_to_f(c) {
    return (c * 9.0 / 5.0) + 32.0
}

fn f_to_c(f) {
    return (f - 32.0) * 5.0 / 9.0
}

fn c_to_k(c) {
    return c + 273.15
}

fn k_to_c(k) {
    return k - 273.15
}

fn convert(value, unit: string) {
    let mut c = 0.0
    if unit == "C" {
        c = value
    } else if unit == "F" {
        c = f_to_c(value)
    } else if unit == "K" {
        c = k_to_c(value)
    } else {
        println("unknown unit:", unit)
        return 0
    }
    let f = c_to_f(c)
    let k = c_to_k(c)
    println(value, unit)
    println("  =", c, "°C")
    println("  =", f, "°F")
    println("  =", k, "K")
    return 0
}

if argc() >= 3 {
    let v = to_float(arg(1))
    let u = arg(2)
    let _r = convert(v, u)
} else {
    println("=== temperature tests ===")
    let _r1 = convert(0.0, "C")
    let _r2 = convert(100.0, "C")
    let _r3 = convert(32.0, "F")
    let _r4 = convert(212.0, "F")
    let _r5 = convert(273.15, "K")
    let _r6 = convert(0.0, "K")
}
println("done")
