// N1.1f: else if 체인
fn classify(n) {
    if n < 0 {
        return 0
    } else if n == 0 {
        return 1
    } else if n < 10 {
        return 2
    } else if n < 100 {
        return 3
    } else {
        return 4
    }
}

println("classify(-5)=", classify(-5))
println("classify(0) =", classify(0))
println("classify(7) =", classify(7))
println("classify(50)=", classify(50))
println("classify(500)=", classify(500))
