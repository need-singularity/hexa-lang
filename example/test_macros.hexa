// ── Test: Hygienic Macro System ─────────────────────────

// === 1. Simple macro (no arguments) ===
macro! hello {
    () => {
        "hello from macro"
    }
}

proof test_simple_macro {
    let result = hello!()
    assert result == "hello from macro"
}

// === 2. Macro with single expr argument ===
macro! double {
    ($x:expr) => {
        $x + $x
    }
}

proof test_expr_arg_macro {
    let result = double!(5)
    assert result == 10
    let result2 = double!(3 + 1)
    assert result2 == 8
}

// === 3. Macro with multiple expr arguments ===
macro! add3 {
    ($a:expr, $b:expr, $c:expr) => {
        $a + $b + $c
    }
}

proof test_multi_arg_macro {
    let result = add3!(10, 20, 30)
    assert result == 60
}

// === 4. Macro with repetition ===
macro! sum {
    ($($x:expr),*) => {
        let acc = 0
        $(acc = acc + $x)*
        acc
    }
}

proof test_repetition_macro {
    let result = sum!(1, 2, 3, 4, 5)
    assert result == 15
}

// === 5. Hygienic scoping — macro vars don't leak ===
macro! make_val {
    ($v:expr) => {
        let temp = $v * 2
        temp
    }
}

proof test_hygiene {
    let temp = 100
    let result = make_val!(5)
    assert result == 10
    // Our outer 'temp' should be unaffected by the macro's internal 'temp'
    assert temp == 100
}

// === 6. Macro with bracket invocation syntax ===
proof test_bracket_syntax {
    let result = double![7]
    assert result == 14
}

// === 7. Macro with ident fragment ===
macro! greet {
    ($name:ident) => {
        "hello " + $name
    }
}

proof test_ident_macro {
    let world = "world"
    let result = greet!(world)
    assert result == "hello world"
}

// === 8. derive(Display) on a struct ===
struct Point {
    x: float,
    y: float
}

derive(Display) for Point

proof test_derive_display {
    let p = Point { x: 3, y: 4 }
    let s = p.display()
    // display() should return a string representation
    assert s == "Point{ x: 3, y: 4 }"
}

// === 9. derive(Debug) on a struct ===
struct Color {
    r: int,
    g: int,
    b: int
}

derive(Debug) for Color

proof test_derive_debug {
    let c = Color { r: 255, g: 128, b: 0 }
    let s = c.debug()
    assert s == "Color{ r: 255, g: 128, b: 0 }"
}

// === 10. derive(Eq) on a struct ===
struct Vec2 {
    x: int,
    y: int
}

derive(Eq) for Vec2

proof test_derive_eq {
    let a = Vec2 { x: 1, y: 2 }
    let b = Vec2 { x: 1, y: 2 }
    let c = Vec2 { x: 3, y: 4 }
    assert a.eq(b) == true
    assert a.eq(c) == false
}

// === 11. Nested macro invocation ===
proof test_nested_macro {
    let result = double!(double!(3))
    assert result == 12
}
