// regex.hexa — 미니 정규식 매처 (*, ?, ., literal)
// 구문:
//   .  임의의 한 글자
//   *  직전 글자 0개 이상
//   ?  직전 글자 0개 또는 1개
//   리터럴

fn ch_at(s, i) {
    return s.substring(i, i + 1)
}

fn match_char(p, t) {
    if p == "." {
        return 1
    }
    if p == t {
        return 1
    }
    return 0
}

fn match_here(pat, pi, txt, ti) {
    let pn = pat.len()
    let tn = txt.len()
    // pat 끝 → 매치 성공
    if pi >= pn {
        return 1
    }
    // 다음 패턴 문자가 * 인 경우
    if pi + 1 < pn {
        let next_pc = ch_at(pat, pi + 1)
        if next_pc == "*" {
            let cur_pc = ch_at(pat, pi)
            // 0개 매치 시도
            let zero = match_here(pat, pi + 2, txt, ti)
            if zero == 1 {
                return 1
            }
            // 1개 이상 매치
            let mut k = ti
            while k < tn {
                if match_char(cur_pc, ch_at(txt, k)) == 0 {
                    return 0
                }
                let more = match_here(pat, pi + 2, txt, k + 1)
                if more == 1 {
                    return 1
                }
                k = k + 1
            }
            return 0
        }
        if next_pc == "?" {
            let cur_pc = ch_at(pat, pi)
            // 0개
            let zero = match_here(pat, pi + 2, txt, ti)
            if zero == 1 {
                return 1
            }
            // 1개
            if ti < tn {
                if match_char(cur_pc, ch_at(txt, ti)) == 1 {
                    return match_here(pat, pi + 2, txt, ti + 1)
                }
            }
            return 0
        }
    }
    // 일반 문자
    if ti >= tn {
        return 0
    }
    let cur_pc = ch_at(pat, pi)
    if match_char(cur_pc, ch_at(txt, ti)) == 1 {
        return match_here(pat, pi + 1, txt, ti + 1)
    }
    return 0
}

fn regex_match(pat: string, txt: string) {
    // ^pat$ 전체 매치
    return match_here(pat, 0, txt, 0)
}

fn test_case(pat, txt, expected) {
    let result = regex_match(pat, txt)
    let mut status = "FAIL"
    if result == expected {
        status = "PASS"
    }
    println(status, " : /", pat, "/ on '", txt, "' → ", result, " (expected ", expected, ")")
}

println("=== regex tests ===")
test_case("hello", "hello", 1)
test_case("hello", "world", 0)
test_case("h.llo", "hello", 1)
test_case("h.llo", "hallo", 1)
test_case("h.llo", "hxllo", 1)
test_case("h.llo", "help", 0)
test_case("ab*c", "ac", 1)
test_case("ab*c", "abc", 1)
test_case("ab*c", "abbbbc", 1)
test_case("ab*c", "ad", 0)
test_case("a?b", "b", 1)
test_case("a?b", "ab", 1)
test_case("a?b", "aab", 0)
test_case(".*", "anything", 1)
test_case(".*b", "aaab", 1)
test_case("x.*y", "x123y", 1)
test_case("x.*y", "xy", 1)
test_case("x.*y", "xyz", 0)
println("done")
