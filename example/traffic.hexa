// traffic.hexa — 교통 신호 상태 기계 (2교차로 동기화)
// RED → GREEN → YELLOW → RED

let mut light_a = 0  // 0=RED, 1=GREEN, 2=YELLOW
let mut light_b = 1  // 반대 위상
let mut timer = 0

fn state_name(s) {
    if s == 0 { return "RED" }
    if s == 1 { return "GREEN" }
    if s == 2 { return "YELLOW" }
    return "?"
}

fn state_icon(s) {
    if s == 0 { return "🔴" }
    if s == 1 { return "🟢" }
    if s == 2 { return "🟡" }
    return "?"
}

fn state_duration(s) {
    if s == 0 { return 4 }
    if s == 1 { return 4 }
    if s == 2 { return 1 }
    return 0
}

fn next_state(s) {
    if s == 0 { return 1 }
    if s == 1 { return 2 }
    if s == 2 { return 0 }
    return 0
}

// 시뮬: 20 tick 실행, 충돌 감지
let mut t = 0
let mut conflicts = 0
let mut cycles = 0

println("=== traffic sim (20 ticks) ===")
println("tick | A           | B           | conflict")
println("─────┼─────────────┼─────────────┼─────────")

let mut dur_a = state_duration(light_a)
let mut dur_b = state_duration(light_b)
let mut elapsed_a = 0
let mut elapsed_b = 0

while t < 20 {
    // 충돌 체크: A가 GREEN이고 B도 GREEN이면 안됨
    let conflict = if light_a == 1 && light_b == 1 { 1 } else { 0 }
    if conflict == 1 {
        conflicts = conflicts + 1
    }
    let cflag = if conflict == 1 { " ⚠" } else { "" }
    println(t, " | ", state_icon(light_a), " ", state_name(light_a), " | ", state_icon(light_b), " ", state_name(light_b), " |", cflag)

    // 타이머 진행
    elapsed_a = elapsed_a + 1
    elapsed_b = elapsed_b + 1

    if elapsed_a >= dur_a {
        light_a = next_state(light_a)
        dur_a = state_duration(light_a)
        elapsed_a = 0
        if light_a == 0 { cycles = cycles + 1 }
    }
    if elapsed_b >= dur_b {
        light_b = next_state(light_b)
        dur_b = state_duration(light_b)
        elapsed_b = 0
    }
    t = t + 1
}

println("─────────────")
println("cycles:", cycles)
println("conflicts:", conflicts)
println("done")
