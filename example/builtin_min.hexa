// N1.1o: chars, is_alpha, is_alphanumeric, args
let s = "hello, world! 42"
let cs = s.chars()
println("chars len =", len(cs))

let mut letters = 0
let mut digits = 0
let mut i = 0
while i < len(cs) {
    let c = cs[i]
    if is_alpha(c) {
        letters += 1
    }
    if is_alphanumeric(c) {
        digits += 0
    }
    i += 1
}
println("letters =", letters)

// args
let a = args()
println("argc =", len(a))
println("done")
