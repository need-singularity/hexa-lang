// bank.hexa — 다중 계좌 은행 시뮬 (병렬 배열)

let mut acc_names = ["alice", "bob", "charlie"]
let mut acc_balances = [1000, 500, 0]

fn find_acc(name: string) {
    let mut i = 0
    while i < len(acc_names) {
        if acc_names[i] == name {
            return i
        }
        i = i + 1
    }
    return -1
}

fn deposit(name: string, amount) {
    let i = find_acc(name)
    if i < 0 {
        println("error: account not found:", name)
        return -1
    }
    acc_balances[i] = acc_balances[i] + amount
    println("deposit", amount, "→", name, "(new balance:", acc_balances[i], ")")
    return acc_balances[i]
}

fn withdraw(name: string, amount) {
    let i = find_acc(name)
    if i < 0 {
        println("error: account not found:", name)
        return -1
    }
    if acc_balances[i] < amount {
        println("error: insufficient funds for", name, "(have:", acc_balances[i], ", need:", amount, ")")
        return -1
    }
    acc_balances[i] = acc_balances[i] - amount
    println("withdraw", amount, "←", name, "(new balance:", acc_balances[i], ")")
    return acc_balances[i]
}

fn transfer(from_n: string, to_n: string, amount) {
    let _w = withdraw(from_n, amount)
    if _w < 0 { return -1 }
    let _d = deposit(to_n, amount)
    println("  ↳ transferred", amount, "from", from_n, "to", to_n)
    return 0
}

fn show_all() {
    println("─── balances ───")
    let mut total = 0
    let mut i = 0
    while i < len(acc_names) {
        println(" ", acc_names[i], ":", acc_balances[i])
        total = total + acc_balances[i]
        i = i + 1
    }
    println("  ── total:", total)
}

show_all()

println("")
println("=== transactions ===")
let _t1 = deposit("bob", 200)
let _t2 = withdraw("alice", 300)
let _t3 = transfer("alice", "charlie", 400)
let _t4 = withdraw("charlie", 1000)
let _t5 = transfer("bob", "alice", 50)

println("")
show_all()
println("done")
