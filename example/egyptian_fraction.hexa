println("=== Egyptian Fraction Memory Model ===")
println("1/2 + 1/3 + 1/6 = 1 (Perfect Number 6)")
println("")
let half = 1.0 / 2.0
let third = 1.0 / 3.0
let sixth = 1.0 / 6.0
let total = half + third + sixth
println("  Stack:  1/2 =", half)
println("  Heap:   1/3 =", third)
println("  Arena:  1/6 =", sixth)
println("  Total:      =", total)
let mut diff = total - 1.0
if diff < 0.0 {
    diff = 0.0 - diff
}
assert diff < 0.0001
println("  Error:      <", 0.0001)
println("")
println("Memory allocation verified!")
