// @contract Option A (parser desugar) demo
// - requires → ContractAssert(Requires) prepended at function entry
// - ensures  → return rewriting with `result` binding + ContractAssert(Ensures)
// Violation produces: "contract violation in 'fn_name': requires/ensures condition failed"

@contract(requires: x > 0, ensures: result > 0)
fn inc_positive(x) {
    return x + 1
}

let r = inc_positive(3)
println(r)  // 4

// ensures with early return — both branches are checked
@contract(ensures: result >= 0)
fn abs_val(x) {
    if x >= 0 {
        return x
    }
    return 0 - x
}

let a = abs_val(-7)
println(a)  // 7

// multiple requires clauses
@contract(requires: x > 0, requires: x < 100)
fn bounded(x) {
    return x * 2
}

let b = bounded(50)
println(b)  // 100
