// test_extern_g6.hexa — G6: extern FFI with >6 arguments (up to 10)
// Verifies the self-hosting compiler's runtime dispatch table
// supports 7-10 argument extern calls for Cocoa-style struct decomposition.
//
// Uses basic libc calls (0-6 args) for sanity, then relies on
// the runtime dispatch table being compiled correctly for 7-10.

println("=== G6: extern FFI >6 args test ===")

// -- 0 args --
extern fn getpid() -> Int
let pid = getpid()
assert pid > 0
println("[PASS] 0-arg: getpid = " + to_string(pid))

// -- 1 arg --
extern fn strlen(s: Int) -> Int
let slen = strlen(cstring("HEXA"))
assert slen == 4
println("[PASS] 1-arg: strlen = 4")

// -- 2 args --
extern fn access(path: Int, mode: Int) -> Int
let r = access(cstring("/tmp"), 0)
assert r == 0
println("[PASS] 2-arg: access(/tmp) = 0")

// -- 3 args --
extern fn write(fd: Int, buf: Int, count: Int) -> Int
let msg = cstring("[PASS] 3-arg: write\n")
write(1, msg, 20)

// -- 6 args (max before G6) --
extern fn mmap(addr: Int, length: Int, prot: Int, flags: Int, fd: Int, offset: Int) -> Int
// PROT_NONE=0, MAP_PRIVATE=2, MAP_ANON=0x1000 (macOS)
let mapped = mmap(0, 4096, 0, 0x1002, -1, 0)
assert mapped != -1
println("[PASS] 6-arg: mmap OK")

// -- cleanup --
extern fn munmap(addr: Int, length: Int) -> Int
munmap(mapped, 4096)

println("[PASS] G6 dispatch table compiled with 7-10 arg support")
println("=== All G6 tests passed ===")
