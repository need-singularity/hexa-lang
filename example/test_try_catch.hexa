// test_try_catch.hexa — try/catch error handling tests
// Tests: basic try/catch, throw, nested, error propagation, recovery

println("=== Try/Catch Tests ===")

// --- 1. Basic try/catch with no error ---
let mut r1 = 0
try {
    r1 = 42
} catch e {
    r1 = -1
}
println("no-error:", r1)
assert r1 == 42

// --- 2. Catch a thrown error ---
let mut r2 = 0
try {
    throw "something went wrong"
    r2 = 99
} catch e {
    r2 = -1
    println("caught:", e)
}
println("after throw:", r2)
assert r2 == -1

// --- 3. Division by zero handling ---
fn safe_div(a: int, b: int) -> int {
    if b == 0 {
        throw "division by zero"
    }
    return a / b
}

let mut r3 = 0
try {
    r3 = safe_div(10, 2)
} catch e {
    r3 = -1
}
println("safe_div(10,2):", r3)
assert r3 == 5

let mut r4 = 0
try {
    r4 = safe_div(10, 0)
} catch e {
    r4 = -1
    println("caught div/0:", e)
}
println("safe_div(10,0):", r4)
assert r4 == -1

// --- 4. Try/catch in a loop ---
let mut errors = 0
for i in 0..5 {
    try {
        if i == 2 {
            throw "bad index"
        }
    } catch e {
        errors = errors + 1
    }
}
println("errors in loop:", errors)
assert errors == 1

// --- 5. Nested try/catch ---
let mut r5 = ""
try {
    try {
        throw "inner error"
    } catch e {
        r5 = "inner caught"
    }
} catch e {
    r5 = "outer caught"
}
println("nested:", r5)
assert r5 == "inner caught"

// --- 6. Inner throw propagates to outer ---
let mut r6 = ""
try {
    try {
        throw "level 1"
    } catch e {
        throw "level 2 from inner"
    }
} catch e {
    r6 = to_string(e)
    println("propagated:", r6)
}
// Error values are wrapped; just check we caught the outer throw
assert r6 != ""

// --- 7. Try/catch with function call ---
fn might_fail(x: int) -> int {
    if x < 0 {
        throw "negative input"
    }
    return x * x
}

let mut r7a = 0
try {
    r7a = might_fail(5)
} catch e {
    r7a = -1
}
println("might_fail(5):", r7a)
assert r7a == 25

let mut r7b = 0
try {
    r7b = might_fail(-3)
} catch e {
    r7b = -1
}
println("might_fail(-3):", r7b)
assert r7b == -1

// --- 8. Error message preservation ---
let mut msg = ""
try {
    throw "error code 42"
} catch e {
    msg = to_string(e)
}
println("error msg:", msg)
// caught error is wrapped as Error(...)
assert msg != ""

// --- 9. Try/catch with computation before throw ---
let mut r9 = 0
try {
    r9 = r9 + 10
    r9 = r9 + 20
    throw "stop"
    r9 = r9 + 100
} catch e {
    r9 = r9 + 1
}
println("partial compute:", r9)
assert r9 == 31

// --- 10. Try/catch as expression-like pattern ---
fn try_parse(s: str) -> int {
    if s == "42" {
        return 42
    }
    throw "parse error: " + s
}

let mut r10 = 0
try {
    r10 = try_parse("42")
} catch e {
    r10 = 0
}
println("try_parse(42):", r10)
assert r10 == 42

let mut r11 = 0
try {
    r11 = try_parse("abc")
} catch e {
    r11 = -1
}
println("try_parse(abc):", r11)
assert r11 == -1

println("")
println("=== All try/catch tests passed! ===")
