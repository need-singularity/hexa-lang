// N1.1v: exec + args StrArr + append_file
let a = args()
println("argc =", len(a))
let mut i = 0
while i < len(a) {
    println("arg", i, "=", a[i])
    i = i + 1
}

// exec
let date = exec("date '+%Y-%m-%d'").trim()
println("today =", date)

let ls = exec("ls /tmp 2>/dev/null | wc -l").trim()
println("/tmp entries =", ls)

// append_file
let log_path = "/tmp/hexa_log.txt"
write_file(log_path, "first line\n")
append_file(log_path, "second line\n")
append_file(log_path, "third line\n")
let got = read_file(log_path)
println("log content:")
println(got)
println("done")
