// HEXA-IR vs Cranelift JIT 벤치마크
// n=6 파생 연산 100만 루프

fn sigma(n: int) -> int {
    let sum = 0
    let i = 1
    while i <= n {
        if n % i == 0 {
            sum = sum + i
        }
        i = i + 1
    }
    sum
}

fn phi(n: int) -> int {
    let count = 0
    let i = 1
    while i < n {
        let a = i
        let b = n
        while b != 0 {
            let t = b
            b = a % b
            a = t
        }
        if a == 1 {
            count = count + 1
        }
        i = i + 1
    }
    count
}

fn fib(n: int) -> int {
    let a = 0
    let b = 1
    let i = 0
    while i < n {
        let t = a + b
        a = b
        b = t
        i = i + 1
    }
    a
}

// Main benchmark: 100K iterations of n=6 math
let iterations = 100000
let total = 0
let i = 0
while i < iterations {
    total = total + sigma(6)   // σ(6) = 12
    total = total + phi(6)     // φ(6) = 2
    total = total + fib(20)    // fib(20) = 6765
    i = i + 1
}
println(total)
// Expected: (12 + 2 + 6765) * 100000 = 677900000
