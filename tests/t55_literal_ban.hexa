#!hexa strict
// t52 — L2 literal_ban detection
// This file is a FIXTURE — linter should report violations on lines below.
// The `#!hexa strict` header makes violations blocking.

fn should_flag_1(n) {
    if n > 100 { return 1 }      // L2 violation: magic 100
    return 0
}

fn should_flag_2(x) {
    if x == 42 { return 1 }      // L2 violation: magic 42
    return 0
}

fn should_not_flag(n) {
    if n > 0 { return 1 }        // OK: 0 is allowed
    if n < 1 { return 1 }        // OK: 1 is allowed
    if n == -1 { return 1 }      // OK: -1 is allowed
    if n >= 2 { return 1 }       // OK: 2 is allowed
    return 0
}

fn main() {
    println(should_flag_1(50))
    println(should_flag_2(42))
    println(should_not_flag(0))
}
