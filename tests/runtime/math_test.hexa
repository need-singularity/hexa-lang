// tests/runtime/math_test.hexa — P7-7b chunk 3 validation
//
// 검증 대상: self/runtime/math.hexa 의 10 함수 — C runtime.c 의 hexa_abs /
// hexa_mod / hexa_pow 와 byte-semantic 동일성. 각 @test fn 은 0 / 음수 /
// 큰 수 / 경계를 커버한다.
//
// 실행
//   hexa test tests/runtime/math_test.hexa
//
// 왜 함수 본문이 또 들어가 있나? (strings_test 와 동일)
//   self/test_runner.hexa 의 _write_driver 는 테스트 소스를 그대로 이어붙여
//   `<fn_name>()` 를 호출한다. import 해석은 러너가 관여하지 않으므로
//   테스트 파일이 함수 정의를 직접 포함해야 한다.


// ═══════ UNDER TEST — self/runtime/math.hexa 사본 ═══════

pub fn int_abs(n) {
    if n < 0 { return -n }
    n
}

pub fn int_neg(n) {
    -n
}

pub fn int_min(a, b) {
    if a < b { return a }
    b
}

pub fn int_max(a, b) {
    if a > b { return a }
    b
}

pub fn int_mod(a, b) {
    if b == 0 { return 0 }
    a % b
}

pub fn int_pow(base, exp) {
    if exp < 0 { return 0 }
    let mut r = 1
    let mut i = 0
    while i < exp {
        r = r * base
        i = i + 1
    }
    r
}

pub fn float_abs(x) {
    if x < 0.0 { return -x }
    x
}

pub fn float_min(a, b) {
    if a < b { return a }
    b
}

pub fn float_max(a, b) {
    if a > b { return a }
    b
}

pub fn float_pow(base, exp) {
    if exp < 0 { return 0.0 }
    let mut r = 1.0
    let mut i = 0
    while i < exp {
        r = r * base
        i = i + 1
    }
    r
}


// ═══════ TESTS ═══════

@test
fn test_int_abs() {
    // 0 / 양수 / 음수 / 큰 수
    assert(int_abs(0) == 0)
    assert(int_abs(1) == 1)
    assert(int_abs(-1) == 1)
    assert(int_abs(42) == 42)
    assert(int_abs(-42) == 42)
    // 큰 수
    assert(int_abs(1000000) == 1000000)
    assert(int_abs(-1000000) == 1000000)
}

@test
fn test_int_neg() {
    assert(int_neg(0) == 0)
    assert(int_neg(1) == -1)
    assert(int_neg(-1) == 1)
    assert(int_neg(42) == -42)
    assert(int_neg(-42) == 42)
    // 두 번 적용 = 항등
    assert(int_neg(int_neg(7)) == 7)
}

@test
fn test_int_min() {
    // 경계 — 동일 값
    assert(int_min(0, 0) == 0)
    assert(int_min(5, 5) == 5)
    // a < b / a > b
    assert(int_min(1, 2) == 1)
    assert(int_min(2, 1) == 1)
    // 음수
    assert(int_min(-1, 1) == -1)
    assert(int_min(-5, -3) == -5)
    // 0 경계
    assert(int_min(0, -1) == -1)
    assert(int_min(0, 1) == 0)
}

@test
fn test_int_max() {
    assert(int_max(0, 0) == 0)
    assert(int_max(5, 5) == 5)
    assert(int_max(1, 2) == 2)
    assert(int_max(2, 1) == 2)
    assert(int_max(-1, 1) == 1)
    assert(int_max(-5, -3) == -3)
    assert(int_max(0, -1) == 0)
    assert(int_max(0, 1) == 1)
}

@test
fn test_int_mod() {
    // b == 0 → 0 (C guard)
    assert(int_mod(5, 0) == 0)
    assert(int_mod(0, 0) == 0)
    // 양수 / 양수
    assert(int_mod(10, 3) == 1)
    assert(int_mod(9, 3) == 0)
    assert(int_mod(7, 2) == 1)
    // a == 0
    assert(int_mod(0, 5) == 0)
    // 경계 — a < b
    assert(int_mod(3, 10) == 3)
    // 큰 수
    assert(int_mod(1000000, 7) == 1000000 % 7)
}

@test
fn test_int_pow() {
    // exp == 0 → 1 (수학 관례)
    assert(int_pow(0, 0) == 1)
    assert(int_pow(5, 0) == 1)
    assert(int_pow(-3, 0) == 1)
    // base == 0, exp > 0 → 0
    assert(int_pow(0, 1) == 0)
    assert(int_pow(0, 5) == 0)
    // base == 1 → 1
    assert(int_pow(1, 100) == 1)
    // 기본
    assert(int_pow(2, 1) == 2)
    assert(int_pow(2, 10) == 1024)
    assert(int_pow(3, 4) == 81)
    // 음수 base, 짝/홀 exp
    assert(int_pow(-2, 2) == 4)
    assert(int_pow(-2, 3) == -8)
    // exp < 0 → 0 (포팅 규약)
    assert(int_pow(2, -1) == 0)
}

@test
fn test_float_abs() {
    assert(float_abs(0.0) == 0.0)
    assert(float_abs(1.5) == 1.5)
    assert(float_abs(-1.5) == 1.5)
    assert(float_abs(-0.001) == 0.001)
    assert(float_abs(3.14) == 3.14)
    assert(float_abs(-3.14) == 3.14)
}

@test
fn test_float_min() {
    assert(float_min(0.0, 0.0) == 0.0)
    assert(float_min(1.0, 2.0) == 1.0)
    assert(float_min(2.0, 1.0) == 1.0)
    assert(float_min(-1.5, 1.5) == -1.5)
    assert(float_min(-3.0, -2.0) == -3.0)
    // 인접 — 작은 차이
    assert(float_min(0.1, 0.2) == 0.1)
}

@test
fn test_float_max() {
    assert(float_max(0.0, 0.0) == 0.0)
    assert(float_max(1.0, 2.0) == 2.0)
    assert(float_max(2.0, 1.0) == 2.0)
    assert(float_max(-1.5, 1.5) == 1.5)
    assert(float_max(-3.0, -2.0) == -2.0)
    assert(float_max(0.1, 0.2) == 0.2)
}

@test
fn test_float_pow() {
    // exp == 0 → 1.0
    assert(float_pow(0.0, 0) == 1.0)
    assert(float_pow(2.5, 0) == 1.0)
    // base == 0.0, exp > 0 → 0.0
    assert(float_pow(0.0, 3) == 0.0)
    // base == 1.0 → 1.0
    assert(float_pow(1.0, 100) == 1.0)
    // 기본
    assert(float_pow(2.0, 1) == 2.0)
    assert(float_pow(2.0, 3) == 8.0)
    assert(float_pow(1.5, 2) == 2.25)
    // 음수 base, 홀/짝
    assert(float_pow(-2.0, 2) == 4.0)
    assert(float_pow(-2.0, 3) == -8.0)
    // exp < 0 → 0.0
    assert(float_pow(2.0, -1) == 0.0)
}
