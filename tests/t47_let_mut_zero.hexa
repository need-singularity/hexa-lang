// t47_let_mut_zero.hexa — T39 regression: let mut x = 0 cache contamination
// Bug: val_int(0) returns a shared singleton from __VAL_INT_CACHE.
// If a mutable binding stores the cached pointer, downstream
// hexa_valstruct_set_by_key can mutate the cache entry, causing
// subsequent `let mut y = 0` or reads to inherit a wrong type/value.
//
// Fix: exec_stmt_at copies the Val for LetMutStmt via val_copy().

let mut pass = true

// Case 1: basic — string before let mut 0
let s1 = "LEAK"
let mut x1 = 0
if typeof(x1) != "int" { println("FAIL case1: typeof=" + typeof(x1)); pass = false }
if x1 != 0 { println("FAIL case1: val=" + to_string(x1)); pass = false }

// Case 2: multiple mut 0 after string
let s2 = "/tmp/hexa_regress_stage1"
let mut total = 0
let mut passed_count = 0
let mut failed_count = 0
let mut skipped_count = 0
if typeof(total) != "int" { println("FAIL case2a: total type=" + typeof(total)); pass = false }
if typeof(passed_count) != "int" { println("FAIL case2b: passed type=" + typeof(passed_count)); pass = false }
if typeof(failed_count) != "int" { println("FAIL case2c: failed type=" + typeof(failed_count)); pass = false }
if typeof(skipped_count) != "int" { println("FAIL case2d: skipped type=" + typeof(skipped_count)); pass = false }

// Case 3: mutation after init should not affect other bindings
let mut a = 0
let mut b = 0
a = 42
if b != 0 { println("FAIL case3: b contaminated by a, b=" + to_string(b)); pass = false }

// Case 4: inside function scope
fn check_fn() {
    let msg = "hello"
    let mut n = 0
    if typeof(n) != "int" { println("FAIL case4: fn scope type=" + typeof(n)); return false }
    if n != 0 { println("FAIL case4: fn scope val=" + to_string(n)); return false }
    n = n + 1
    return n == 1
}
if !check_fn() { println("FAIL case4"); pass = false }

// Case 5: repeated calls — cache should stay clean
fn repeated() {
    let tag = "STR"
    let mut c = 0
    return typeof(c) + ":" + to_string(c)
}
let mut i = 0
while i < 10 {
    let r = repeated()
    if r != "int:0" { println("FAIL case5 iter " + to_string(i) + ": " + r); pass = false }
    i = i + 1
}

// Case 6: val_int(0) vs val_int(1) — both should be independent
let s6 = "CONTAMINATOR"
let mut z = 0
let mut o = 1
if typeof(z) != "int" { println("FAIL case6a: z type=" + typeof(z)); pass = false }
if typeof(o) != "int" { println("FAIL case6b: o type=" + typeof(o)); pass = false }
if z != 0 { println("FAIL case6c: z=" + to_string(z)); pass = false }
if o != 1 { println("FAIL case6d: o=" + to_string(o)); pass = false }

// Case 7: immutable let 0 is also safe (should never regress)
let s7 = "IMMUTABLE_TEST"
let imm = 0
if typeof(imm) != "int" { println("FAIL case7: imm type=" + typeof(imm)); pass = false }

if pass {
    println("PASS t47_let_mut_zero (7/7 cases)")
} else {
    println("FAIL t47_let_mut_zero")
}
