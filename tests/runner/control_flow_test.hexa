// tests/runner/control_flow_test.hexa — hexa `if`/`while`/`for` 제어흐름 스모크
//
// 실행: `hexa test tests/runner/control_flow_test.hexa`
// 기대: 3 PASS / 0 FAIL / 0 SKIP
//
// 배경 (P7-6):
//   scripts/native_build.hexa 의 nb_lower_expr / nb_lower_stmt 에 If/While/For
//   디스패처 추가. 본 스위트는 hexa 표면 언어 수준에서 세 제어흐름이
//   살아 있는지 스모크 테스트한다. 네이티브 코덖젠 회귀는 seed-freeze 해제 후
//   native_build 를 통해 별도 검증될 예정.

@test
fn test_if_expr_value() {
    // 값-생성 if — ternary 형태
    let x = if 3 < 5 { 10 } else { 20 }
    assert(x == 10)
    let y = if 5 < 3 { 10 } else { 20 }
    assert(y == 20)
    // 중첩
    let z = if 1 == 1 {
        if 2 == 2 { 100 } else { 200 }
    } else {
        300
    }
    assert(z == 100)
}

@test
fn test_while_loop() {
    // 누적합 0+1+..+9 = 45
    let mut i = 0
    let mut s = 0
    while i < 10 {
        s = s + i
        i = i + 1
    }
    assert(s == 45)
    assert(i == 10)

    // 조기 종료 조건 — cond 가 false 면 body 진입 0회
    let mut j = 100
    while j < 10 {
        j = j + 1
    }
    assert(j == 100)
}

@test
fn test_for_range() {
    // 0..5 = 0,1,2,3,4 합 = 10
    let mut total = 0
    for i in 0..5 {
        total = total + i
    }
    assert(total == 10)

    // 빈 range — start == end
    let mut count = 0
    for k in 3..3 {
        count = count + 1
    }
    assert(count == 0)

    // 중첩 for — 3x3 = 9회
    let mut hits = 0
    for a in 0..3 {
        for b in 0..3 {
            hits = hits + 1
        }
    }
    assert(hits == 9)
}
