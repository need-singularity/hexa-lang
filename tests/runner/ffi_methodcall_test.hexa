// tests/runner/ffi_methodcall_test.hexa — P7-6 FFI + MethodCall AST 커버
//
// scripts/native_build.hexa 의 nb_lower_expr 에 추가된 핸들러 3 종:
//   1. ExternFnDecl pre-registration (parse_and_lower Pass 1)
//   2. MethodCall runtime dispatch   (nb_method_runtime_sym)
//   3. CharLit / FloatLit            (nb_lower_expr)
//
// 러너는 stage0 인터프리터 경로이므로 lowering 단 직접 검증은
// scripts/native_build.hexa 를 인풋 삼아 별도 수행. 여기서는 문법
// 파싱 + 인터프리터 평가가 정상임을 보여 lowering 단 AST 소비의
// 사전 조건을 확보한다.

// ── MethodCall (runtime sym dispatch) ─────────────────────────

@test
fn t_method_str_starts_ends() {
    let s = "hello_world"
    assert(s.starts_with("hello"))
    assert(s.ends_with("world"))
    assert(len(s) == 11)
}

@test
fn t_method_str_trim_replace() {
    let s = "  abc  "
    let t = s.trim()
    assert(t == "abc")
    let r = "banana".replace("a", "o")
    assert(r == "bonono")
}

@test
fn t_method_array_push_pop() {
    let a = [1, 2, 3]
    let b = a.push(4)
    assert(len(b) == 4)
    assert(b[3] == 4)
}

// ── FloatLit / CharLit parse — 인터프리터 평가 ─────────────────

@test
fn t_float_lit_basic() {
    // FloatLit AST 가 최소 parse + 산술 OK.
    let x = 1.5
    let y = 2.5
    // interpreter float arithmetic (lowering path truncates to i64).
    let z = x + y
    // interpreter preserves float semantics — 4.0
    assert(z > 3.9)
    assert(z < 4.1)
}

@test
fn t_char_lit_basic() {
    // CharLit AST 가 parse + 평가 OK. 인터프리터는 char 를 1-byte
    // 문자열처럼 다루므로 정확한 동등 비교 대신 길이 검사.
    let c = 'x'
    // single-char string 의 len 은 1.
    assert(len(c) == 1)
}
