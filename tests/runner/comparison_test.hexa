// tests/runner/comparison_test.hexa — P7-6 BinOp comparison 커버리지
//
// 실행: `hexa test tests/runner/comparison_test.hexa`
// 기대: 6 PASS / 0 FAIL
//
// 6 comparators: == != < <= > >=
// 엣지: 같은 값, 서로 다른 부호, 0 경계.

@test
fn test_eq() {
    // equal ints
    assert((1 == 1))
    assert((0 == 0))
    assert((-5 == -5))
    // unequal ints
    assert(!(1 == 2))
    assert(!(-1 == 1))
    // sign boundary
    assert(!(0 == -1))
}

@test
fn test_ne() {
    // not-equal
    assert((1 != 2))
    assert((-1 != 1))
    assert((0 != -1))
    // equal → false
    assert(!(42 != 42))
    assert(!(-7 != -7))
}

@test
fn test_lt() {
    // strict less-than
    assert((1 < 2))
    assert((-5 < -1))
    assert((-1 < 0))
    // equal → false
    assert(!(5 < 5))
    // reverse order → false
    assert(!(10 < 3))
    // sign boundary
    assert((-1 < 1))
}

@test
fn test_le() {
    // less-or-equal: strict and equal both true
    assert((1 <= 2))
    assert((5 <= 5))
    assert((-3 <= -3))
    assert((-5 <= 5))
    // strictly greater → false
    assert(!(10 <= 3))
}

@test
fn test_gt() {
    // strict greater-than
    assert((3 > 1))
    assert((0 > -1))
    assert((5 > -5))
    // equal → false
    assert(!(5 > 5))
    // reverse → false
    assert(!(1 > 3))
}

@test
fn test_ge() {
    // greater-or-equal: strict and equal both true
    assert((3 >= 1))
    assert((5 >= 5))
    assert((-3 >= -3))
    assert((5 >= -5))
    // strictly less → false
    assert(!(1 >= 10))
}
