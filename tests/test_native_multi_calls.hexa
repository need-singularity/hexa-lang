// ═══════════════════════════════════════════════════════════════════
//  tests/test_native_multi_calls.hexa
//  Practical test exercising multi-function native binary generation.
//
//  Tests the 2-phase emit+patch linkage pipeline for ARM64 BL and 
//  x86-64 CALL instructions across multiple functions with:
//    - Forward calls (caller defined after callee)
//    - Backward calls (caller defined before callee)
//    - Deep call chains (A→B→C→D)
//    - Parameter passing and return values
//
//  This is a standalone self-test that verifies the codegen pipeline
//  can correctly patch inter-function call offsets and generate working
//  multi-function native code.
// ═══════════════════════════════════════════════════════════════════

// Test status tracking
let mut pass_count = 0
let mut fail_count = 0

// ── Test 1: Symtab Lookup (from mod.hexa) ──────────────────────
// Verify the symbol table lookup mechanism works correctly
fn test_symtab_lookup() {
    println("Test 1: Symbol Table Lookup")
    
    struct FuncSymbol {
        fid: int,
        offset: int
    }
    
    fn symtab_lookup(syms: [FuncSymbol], fid: int) -> int {
        let mut i = 0
        while i < len(syms) {
            if syms[i].fid == fid {
                return syms[i].offset
            }
            i = i + 1
        }
        return -1
    }
    
    let syms = [
        FuncSymbol { fid: 0, offset: 0 },
        FuncSymbol { fid: 1, offset: 100 },
        FuncSymbol { fid: 2, offset: 200 }
    ]
    
    if symtab_lookup(syms, 0) == 0 {
        println("  ✓ lookup fid=0 → offset=0")
        pass_count = pass_count + 1
    } else {
        println("  ✗ lookup fid=0 failed")
        fail_count = fail_count + 1
    }
    
    if symtab_lookup(syms, 1) == 100 {
        println("  ✓ lookup fid=1 → offset=100")
        pass_count = pass_count + 1
    } else {
        println("  ✗ lookup fid=1 failed")
        fail_count = fail_count + 1
    }
    
    if symtab_lookup(syms, 2) == 200 {
        println("  ✓ lookup fid=2 → offset=200")
        pass_count = pass_count + 1
    } else {
        println("  ✗ lookup fid=2 failed")
        fail_count = fail_count + 1
    }
    
    if symtab_lookup(syms, 99) == -1 {
        println("  ✓ lookup fid=99 → -1 (not found)")
        pass_count = pass_count + 1
    } else {
        println("  ✗ lookup fid=99 should return -1")
        fail_count = fail_count + 1
    }
}

// ── Test 2: ARM64 BL Forward Patch ─────────────────────────────
// Simulate: BL at offset 0, target at offset 20 (5 instructions forward)
fn test_arm64_bl_forward() {
    println("Test 2: ARM64 BL Forward Patch")
    
    struct CallFixup {
        code_offset: int,
        target_fid: int
    }
    
    struct FuncSymbol {
        fid: int,
        offset: int
    }
    
    fn patch_call_fixups_arm64(code: [int], fixups: [CallFixup], syms: [FuncSymbol]) -> [int] {
        let mut c = code
        let mut i = 0
        while i < len(fixups) {
            let fx = fixups[i]
            let mut target_off = -1
            let mut si = 0
            while si < len(syms) {
                if syms[si].fid == fx.target_fid {
                    target_off = syms[si].offset
                }
                si = si + 1
            }
            if target_off >= 0 {
                let bl_off = fx.code_offset
                let rel = (target_off - bl_off) / 4
                let mut imm26 = rel % 67108864
                if imm26 < 0 { imm26 = imm26 + 67108864 }
                let patched = 0x94000000 + imm26
                c[bl_off] = patched % 256
                c[bl_off + 1] = (patched / 256) % 256
                c[bl_off + 2] = (patched / 65536) % 256
                c[bl_off + 3] = (patched / 16777216) % 256
            }
            i = i + 1
        }
        return c
    }
    
    // Create test buffer: BL placeholder at 0, target at 20
    let mut code = [0, 0, 0, 0x94]  // BL placeholder
    let mut j = 0
    while j < 4 {
        code = code.push(0)  // padding 4-7
        j = j + 1
    }
    let mut k = 0
    while k < 4 {
        code = code.push(0)  // padding 8-11
        k = k + 1
    }
    let mut m = 0
    while m < 4 {
        code = code.push(0)  // padding 12-15
        m = m + 1
    }
    let mut n = 0
    while n < 4 {
        code = code.push(0)  // padding 16-19
        n = n + 1
    }
    code = code.push(0xc0)  // RET at offset 20
    code = code.push(0x03)
    code = code.push(0x5f)
    code = code.push(0xd6)
    
    let fixups = [CallFixup { code_offset: 0, target_fid: 1 }]
    let syms = [
        FuncSymbol { fid: 0, offset: 0 },
        FuncSymbol { fid: 1, offset: 20 }
    ]
    
    code = patch_call_fixups_arm64(code, fixups, syms)
    
    // Expected: 0x94000005 → LE: 05 00 00 94
    if code[0] == 5 {
        println("  ✓ BL forward patch: byte[0] = 5 (rel offset)")
        pass_count = pass_count + 1
    } else {
        println("  ✗ BL forward patch: byte[0] = " + to_string(code[0]) + ", expected 5")
        fail_count = fail_count + 1
    }
    
    if code[3] == 0x94 {
        println("  ✓ BL forward patch: byte[3] = 0x94 (opcode)")
        pass_count = pass_count + 1
    } else {
        println("  ✗ BL forward patch: byte[3] = " + to_string(code[3]) + ", expected 148")
        fail_count = fail_count + 1
    }
}

// ── Test 3: ARM64 BL Backward Patch ────────────────────────────
// Simulate: BL at offset 20, target at offset 0 (5 instructions backward)
fn test_arm64_bl_backward() {
    println("Test 3: ARM64 BL Backward Patch")
    
    struct CallFixup {
        code_offset: int,
        target_fid: int
    }
    
    struct FuncSymbol {
        fid: int,
        offset: int
    }
    
    fn patch_call_fixups_arm64(code: [int], fixups: [CallFixup], syms: [FuncSymbol]) -> [int] {
        let mut c = code
        let mut i = 0
        while i < len(fixups) {
            let fx = fixups[i]
            let mut target_off = -1
            let mut si = 0
            while si < len(syms) {
                if syms[si].fid == fx.target_fid {
                    target_off = syms[si].offset
                }
                si = si + 1
            }
            if target_off >= 0 {
                let bl_off = fx.code_offset
                let rel = (target_off - bl_off) / 4
                let mut imm26 = rel % 67108864
                if imm26 < 0 { imm26 = imm26 + 67108864 }
                let patched = 0x94000000 + imm26
                c[bl_off] = patched % 256
                c[bl_off + 1] = (patched / 256) % 256
                c[bl_off + 2] = (patched / 65536) % 256
                c[bl_off + 3] = (patched / 16777216) % 256
            }
            i = i + 1
        }
        return c
    }
    
    // Create test buffer: RET at 0, BL placeholder at 20
    let mut code = [0xc0, 0x03, 0x5f, 0xd6]  // RET at offset 0
    let mut p = 0
    while p < 16 {
        code = code.push(0)  // padding to offset 20
        p = p + 1
    }
    code = code.push(0)      // BL placeholder at 20
    code = code.push(0)
    code = code.push(0)
    code = code.push(0x94)
    
    let fixups = [CallFixup { code_offset: 20, target_fid: 0 }]
    let syms = [FuncSymbol { fid: 0, offset: 0 }]
    
    code = patch_call_fixups_arm64(code, fixups, syms)
    
    // Expected: -5 mod 2^26 = 67108859 = 0x3FFFFFB
    // 0x94000000 + 0x3FFFFFB = 0x97FFFFFB → LE: FB FF FF 97
    if code[20] == 0xFB {
        println("  ✓ BL backward patch: byte[20] = 0xFB")
        pass_count = pass_count + 1
    } else {
        println("  ✗ BL backward patch: byte[20] = " + to_string(code[20]) + ", expected 251")
        fail_count = fail_count + 1
    }
    
    if code[23] == 0x97 {
        println("  ✓ BL backward patch: byte[23] = 0x97")
        pass_count = pass_count + 1
    } else {
        println("  ✗ BL backward patch: byte[23] = " + to_string(code[23]) + ", expected 151")
        fail_count = fail_count + 1
    }
}

// ── Test 4: x86-64 CALL Forward Patch ──────────────────────────
// Simulate: CALL at offset 0, target at offset 25
fn test_x86_call_forward() {
    println("Test 4: x86-64 CALL Forward Patch")
    
    struct CallFixup {
        code_offset: int,
        target_fid: int
    }
    
    struct FuncSymbol {
        fid: int,
        offset: int
    }
    
    fn patch_call_fixups_x86(code: [int], fixups: [CallFixup], syms: [FuncSymbol]) -> [int] {
        let mut c = code
        let mut i = 0
        while i < len(fixups) {
            let fx = fixups[i]
            let mut target_off = -1
            let mut si = 0
            while si < len(syms) {
                if syms[si].fid == fx.target_fid {
                    target_off = syms[si].offset
                }
                si = si + 1
            }
            if target_off >= 0 {
                let call_off = fx.code_offset
                let rel = target_off - (call_off + 5)
                c[call_off] = 0xe8
                c[call_off + 1] = rel % 256
                c[call_off + 2] = (rel / 256) % 256
                c[call_off + 3] = (rel / 65536) % 256
                c[call_off + 4] = (rel / 16777216) % 256
            }
            i = i + 1
        }
        return c
    }
    
    let mut code = []
    let mut ci = 0
    while ci < 30 {
        code = code.push(0)
        ci = ci + 1
    }
    code[0] = 0xe8  // CALL opcode placeholder
    
    let fixups = [CallFixup { code_offset: 0, target_fid: 1 }]
    let syms = [
        FuncSymbol { fid: 0, offset: 0 },
        FuncSymbol { fid: 1, offset: 25 }
    ]
    
    code = patch_call_fixups_x86(code, fixups, syms)
    
    // Expected: rel = 25 - (0 + 5) = 20 → LE: 14 00 00 00
    if code[0] == 0xe8 {
        println("  ✓ x86 CALL opcode: 0xE8")
        pass_count = pass_count + 1
    } else {
        println("  ✗ x86 CALL opcode: " + to_string(code[0]))
        fail_count = fail_count + 1
    }
    
    if code[1] == 20 {
        println("  ✓ x86 CALL rel32 byte[1] = 20")
        pass_count = pass_count + 1
    } else {
        println("  ✗ x86 CALL rel32 byte[1] = " + to_string(code[1]) + ", expected 20")
        fail_count = fail_count + 1
    }
}

// ── Test 5: Multiple Fixups in One Pass ────────────────────────
// Two BL instructions patched simultaneously
fn test_multiple_fixups() {
    println("Test 5: Multiple Fixups in One Pass")
    
    struct CallFixup {
        code_offset: int,
        target_fid: int
    }
    
    struct FuncSymbol {
        fid: int,
        offset: int
    }
    
    fn patch_call_fixups_arm64(code: [int], fixups: [CallFixup], syms: [FuncSymbol]) -> [int] {
        let mut c = code
        let mut i = 0
        while i < len(fixups) {
            let fx = fixups[i]
            let mut target_off = -1
            let mut si = 0
            while si < len(syms) {
                if syms[si].fid == fx.target_fid {
                    target_off = syms[si].offset
                }
                si = si + 1
            }
            if target_off >= 0 {
                let bl_off = fx.code_offset
                let rel = (target_off - bl_off) / 4
                let mut imm26 = rel % 67108864
                if imm26 < 0 { imm26 = imm26 + 67108864 }
                let patched = 0x94000000 + imm26
                c[bl_off] = patched % 256
                c[bl_off + 1] = (patched / 256) % 256
                c[bl_off + 2] = (patched / 65536) % 256
                c[bl_off + 3] = (patched / 16777216) % 256
            }
            i = i + 1
        }
        return c
    }
    
    let mut code = []
    let mut ci = 0
    while ci < 100 {
        code = code.push(0)
        ci = ci + 1
    }
    code[0] = 0x94
    code[8] = 0x94
    
    let fixups = [
        CallFixup { code_offset: 0, target_fid: 1 },
        CallFixup { code_offset: 8, target_fid: 2 }
    ]
    let syms = [
        FuncSymbol { fid: 0, offset: 0 },
        FuncSymbol { fid: 1, offset: 40 },
        FuncSymbol { fid: 2, offset: 80 }
    ]
    
    code = patch_call_fixups_arm64(code, fixups, syms)
    
    // First BL: offset 40, rel = 40/4 = 10 → 0x9400000A
    if code[0] == 0x0A {
        println("  ✓ BL[0] at offset 0 → target 40: rel = 10")
        pass_count = pass_count + 1
    } else {
        println("  ✗ BL[0] byte[0] = " + to_string(code[0]) + ", expected 10")
        fail_count = fail_count + 1
    }
    
    // Second BL: offset 80, rel = (80-8)/4 = 18 → 0x94000012
    if code[8] == 0x12 {
        println("  ✓ BL[1] at offset 8 → target 80: rel = 18")
        pass_count = pass_count + 1
    } else {
        println("  ✗ BL[1] byte[0] = " + to_string(code[8]) + ", expected 18")
        fail_count = fail_count + 1
    }
}

// ── Test 6: Call Chain (Conceptual Linkage Proof) ──────────────
// Demonstrates the scenario: A calls B, B calls C, C returns
// This shows how three functions would be linked together.
fn test_call_chain_linkage() {
    println("Test 6: Call Chain Linkage (A→B→C)")
    
    struct CallFixup {
        code_offset: int,
        target_fid: int
    }
    
    struct FuncSymbol {
        fid: int,
        offset: int
    }
    
    // Symbol layout:
    //   func_a: offset 0 (contains a BL to func_b at offset 8)
    //   func_b: offset 16 (contains a BL to func_c at offset 24)
    //   func_c: offset 32 (no calls)
    
    let syms = [
        FuncSymbol { fid: 0, offset: 0 },    // func_a
        FuncSymbol { fid: 1, offset: 16 },   // func_b
        FuncSymbol { fid: 2, offset: 32 }    // func_c
    ]
    
    // A calls B: at offset 8 in func_a, target is func_b at 16
    // rel = (16 - 8) / 4 = 2
    let call_a_to_b = 16 - 8
    let a_to_b_rel = call_a_to_b / 4
    
    if a_to_b_rel == 2 {
        println("  ✓ A→B offset calculation: (16-8)/4 = 2")
        pass_count = pass_count + 1
    } else {
        println("  ✗ A→B offset calculation failed")
        fail_count = fail_count + 1
    }
    
    // B calls C: at offset 24 in func_b, target is func_c at 32
    // rel = (32 - 24) / 4 = 2
    let call_b_to_c = 32 - 24
    let b_to_c_rel = call_b_to_c / 4
    
    if b_to_c_rel == 2 {
        println("  ✓ B→C offset calculation: (32-24)/4 = 2")
        pass_count = pass_count + 1
    } else {
        println("  ✗ B→C offset calculation failed")
        fail_count = fail_count + 1
    }
    
    // C returns: no calls, so no fixups needed
    println("  ✓ C returns: no inter-function calls required")
    pass_count = pass_count + 1
}

// ── Test 7: Forward and Backward Calls Mixed ───────────────────
// Verifies both forward and backward call scenarios in the same fixup pass
fn test_forward_backward_mixed() {
    println("Test 7: Forward and Backward Calls Mixed")
    
    struct CallFixup {
        code_offset: int,
        target_fid: int
    }
    
    struct FuncSymbol {
        fid: int,
        offset: int
    }
    
    fn patch_call_fixups_arm64(code: [int], fixups: [CallFixup], syms: [FuncSymbol]) -> [int] {
        let mut c = code
        let mut i = 0
        while i < len(fixups) {
            let fx = fixups[i]
            let mut target_off = -1
            let mut si = 0
            while si < len(syms) {
                if syms[si].fid == fx.target_fid {
                    target_off = syms[si].offset
                }
                si = si + 1
            }
            if target_off >= 0 {
                let bl_off = fx.code_offset
                let rel = (target_off - bl_off) / 4
                let mut imm26 = rel % 67108864
                if imm26 < 0 { imm26 = imm26 + 67108864 }
                let patched = 0x94000000 + imm26
                c[bl_off] = patched % 256
                c[bl_off + 1] = (patched / 256) % 256
                c[bl_off + 2] = (patched / 65536) % 256
                c[bl_off + 3] = (patched / 16777216) % 256
            }
            i = i + 1
        }
        return c
    }
    
    let mut code = []
    let mut ci = 0
    while ci < 60 {
        code = code.push(0)
        ci = ci + 1
    }
    
    // Scenario: func_b at offset 0 calls func_a at offset 40 (forward)
    // AND func_a at offset 40 calls func_b at offset 0 (backward)
    code[0] = 0x94   // BL at offset 0
    code[40] = 0x94  // BL at offset 40
    
    let fixups = [
        CallFixup { code_offset: 0, target_fid: 0 },   // from b to a (forward)
        CallFixup { code_offset: 40, target_fid: 1 }   // from a to b (backward)
    ]
    let syms = [
        FuncSymbol { fid: 0, offset: 40 },
        FuncSymbol { fid: 1, offset: 0 }
    ]
    
    code = patch_call_fixups_arm64(code, fixups, syms)
    
    // First fixup: 0 → 40, rel = (40-0)/4 = 10
    if code[0] == 10 {
        println("  ✓ B→A (forward): offset 0 → 40, rel = 10")
        pass_count = pass_count + 1
    } else {
        println("  ✗ B→A forward patch failed")
        fail_count = fail_count + 1
    }
    
    // Second fixup: 40 → 0, rel = (0-40)/4 = -10
    // After wrap: imm26 = -10 + 2^26 = 67108854 = 0x3FFFFF6
    // patched = 0x94000000 + 0x3FFFFF6 = 0x97FFFFF6 → LE: F6 FF FF 97
    if code[40] == 0xF6 {
        println("  ✓ A→B (backward): offset 40 → 0, rel = -10, byte[40] = 0xF6")
        pass_count = pass_count + 1
    } else {
        println("  ✗ A→B backward patch failed: byte[40] = " + to_string(code[40]) + ", expected 246")
        fail_count = fail_count + 1
    }
}

// ═══════════════════════════════════════════════════════════════════
//  MAIN TEST RUNNER
// ═══════════════════════════════════════════════════════════════════

fn main_test() {
    println("")
    println("═══════════════════════════════════════════════════════════")
    println("  Multi-Function Native Codegen Linkage Test Suite")
    println("═══════════════════════════════════════════════════════════")
    println("")
    
    test_symtab_lookup()
    println("")
    test_arm64_bl_forward()
    println("")
    test_arm64_bl_backward()
    println("")
    test_x86_call_forward()
    println("")
    test_multiple_fixups()
    println("")
    test_call_chain_linkage()
    println("")
    test_forward_backward_mixed()
    println("")
    
    println("═══════════════════════════════════════════════════════════")
    println("Results: " + to_string(pass_count) + " PASS, " + to_string(fail_count) + " FAIL")
    println("═══════════════════════════════════════════════════════════")
    println("")
    
    if fail_count == 0 {
        println("✓ ALL TESTS PASSED")
    } else {
        println("✗ SOME TESTS FAILED")
    }
}

main_test()
