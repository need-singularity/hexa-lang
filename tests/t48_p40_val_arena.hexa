// t48_p40_val_arena.hexa — regression for pitfall P40 (2026-04-16)
//
// P40: HEXA_VAL_ARENA=1 (default) corrupts arrays returned from helper
// fn A and consumed inside helper fn B.
//
// Minimum reproducer (also triggers the SIGSEGV in runtime_arm64.hexa):
//   fn A() { let mut c = []; c = c.push(X); return c }
//   fn B() { let r = A(); println(to_string(len(r))) }
//   B()
//
// Expected output under correct behavior:  "len=1"
// Broken behavior (arena ON, pre-fix):     "len=Val{tag=3,i=<pointer>}"
//
// WORKAROUND: run with HEXA_VAL_ARENA=0 until the interpreter is fixed.
// See shared/hexa-lang/grammar.jsonl P40 for the full investigation.
// Sibling: P16 (argv()[N] NaN-box pointer corruption under arena ON).

fn inner() {
    let mut c = []
    c = c.push(42)
    return c
}

fn outer() {
    let r = inner()
    let n = len(r)
    // Under the bug, `n` is a TAG_STR VALSTRUCT (not TAG_INT) and
    // to_string(n) leaks "Val{tag=3,i=...}". Fix MUST make type_of(n) == "int"
    // AND the concat+to_string path produce exactly "len=1".
    let nt = type_of(n)
    println("type_of_len=" + nt)
    println("len=" + to_string(n))
    if nt == "int" {
        println("PASS")
    } else {
        println("FAIL — len(r) returned " + nt + " (expected int). P40 arena bug active; rerun with HEXA_VAL_ARENA=0 until interpreter is fixed.")
    }
}

outer()
