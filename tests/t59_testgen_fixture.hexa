// t59 — fixture for ai_native_testgen.hexa
// Has @pure, @memoize, @limit annotations for testgen to pick up.
// S-4b-final: ALL three fns carry explicit parameter types so the
// AST-typed signature path emits typed literals for every call site.
//   add_pure(a: int, b: int) -> int
//   fib_memo(n: int)         -> int
//   singleton_f(x: int)      -> int   // return type arbitrary for testgen

@pure fn add_pure(a: int, b: int) {
    return a + b
}

@memoize fn fib_memo(n: int) {
    if n < 2 { return n }
    return fib_memo(n - 1) + fib_memo(n - 2)
}

@limit fn singleton_f(x: int) {
    return x * 2
}

fn main() {
    println(add_pure(3, 4))
    println(fib_memo(10))
    println(singleton_f(5))
}
