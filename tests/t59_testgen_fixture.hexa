// t59 — fixture for ai_native_testgen.hexa
// Has @pure, @memoize, @limit annotations for testgen to pick up.
// S-4b: fib_memo has a typed `n: int` param so the AST-typed signature
// path can extract a real int type instead of the heuristic fallback.

@pure fn add_pure(a, b) {
    return a + b
}

@memoize fn fib_memo(n: int) {
    if n < 2 { return n }
    return fib_memo(n - 1) + fib_memo(n - 2)
}

@limit fn singleton_f(x) {
    return x * 2
}

fn main() {
    println(add_pure(3, 4))
    println(fib_memo(10))
    println(singleton_f(5))
}
