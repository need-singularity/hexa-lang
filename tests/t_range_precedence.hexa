// G38 / pitfall P10-slice-precedence regression test
//
// Before fix: `arr[i + 1..j]` parsed as `arr[i + (1..j)]` → runtime type error
// After fix:  `arr[i + 1..j]` parses as `arr[(i+1)..j]`  → slice [2,3]
//
// Requires stage0 rebuild via `scripts/rebuild_stage0.hexa` to take effect.
// Expected output:
//   len=4
//   slice=[2, 3]
//   slice2=[2, 3, 4]
//   for_sum=9

fn main() {
    let arr = [0, 1, 2, 3, 4, 5]
    let i = 1
    let j = 4
    println("len=" + to_string(len(arr)))

    // exclusive range with additive lhs — the P10 case
    let s = arr[i + 1..j]
    println("slice=" + to_string(s))

    // inclusive range with additive lhs
    let s2 = arr[i + 1..=j]
    println("slice2=" + to_string(s2))

    // for-loop range with additive bound
    let mut sum = 0
    for k in i + 1..=j {
        sum = sum + arr[k]
    }
    println("for_sum=" + to_string(sum))
}

main()
