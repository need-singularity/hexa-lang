// tests/t35_hxqwen14b_abi_smoke.hexa — B2 stub ABI round-trip smoke.
// Verifies libhxqwen14b.{so,dylib} symbol surface + packed-args ABI.
// Expects the v1 skeleton: generate() returns -4, writes "[hxqwen14b:stub:v0]".
// Run:
//   DYLD_LIBRARY_PATH=$PWD/self/native/build \
//     ./hexa run tests/t35_hxqwen14b_abi_smoke.hexa
//
// B5 fix (runtime.c hexa_val_arena_scope_pop heapifies __VAL_INT_CACHE)
// cleared the T33-class int64 return arena dangle. HEXA_VAL_ARENA=0
// no longer required.

@link("hxqwen14b")
extern fn hxqwen14b_version() -> int

@link("hxqwen14b")
extern fn hxqwen14b_load(ckpt_path_p: *Void) -> int

@link("hxqwen14b")
extern fn hxqwen14b_generate(args_p: *Void) -> int

@link("hxqwen14b")
extern fn hxqwen14b_free(h: int) -> int

let mut ok = true
fn must(label, cond) {
    if cond { println("PASS " + label) } else { ok = false; println("FAIL " + label) }
}

let v = hxqwen14b_version()
must("abi_version>=1 (v1 skeleton)", v >= 1)

let h = hxqwen14b_load(cstring("/tmp/fake_ckpt"))
must("load handle>0", h > 0)

let out_cap = 128
let out_buf = alloc_raw(out_cap)
let args = alloc_raw(96)
ptr_write(args, 0,  h)
ptr_write(args, 8,  cstring("hi"))
ptr_write(args, 16, 2)
ptr_write(args, 24, 4)
ptr_write(args, 32, 0.0)
ptr_write(args, 40, 1.0)
ptr_write(args, 48, 0)
ptr_write(args, 56, out_buf)
ptr_write(args, 64, out_cap)
ptr_write(args, 72, 0)
ptr_write(args, 80, 0)
ptr_write(args, 88, 0)

let rc = hxqwen14b_generate(args)
let out_str = from_cstring(out_buf)
must("stub sentinel in out buf", out_str == "[hxqwen14b:stub:v0]")
println("  rc=" + to_string(rc) + " out=" + out_str)

must("free rc==0", hxqwen14b_free(h) == 0)

if ok { println("PASS t35_hxqwen14b_abi_smoke") } else { println("FAIL t35_hxqwen14b_abi_smoke") }
