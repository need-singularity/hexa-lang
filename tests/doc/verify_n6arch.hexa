// tests/doc/verify_n6arch.hexa — n6-architecture 9 paper @own 검증

use "self/attrs/own"

fn _check(p: string) {
    let raw = to_string(read_file(p))
    let lines = raw.split("\n")
    let msgs = check_own(p, lines)
    let decl = parse_own_decl(lines)
    let mut status = "PASS"
    if len(msgs) > 0 { status = "FAIL" }
    println("  " + status + "  " + p)
    if len(msgs) > 0 {
        for m in msgs { println("    " + m.ref + ": " + m.msg) }
    } else if decl["found"] {
        println("    sections=" + to_string(len(decl["sections"])) + " strict=" + to_string(decl["strict"]) + " order=" + decl["order"] + " prefix=" + decl["prefix"])
    }
}

fn main() {
    let base = "/home/aiden/mac_home/dev/n6-architecture/domains/"
    println("@own 검증 — n6-architecture 9 paper")
    println("--------------------------------------")
    _check(base + "life/dog-robot-test/dog-robot-test.md")
    _check(base + "compute/sscb/sscb.md")
    _check(base + "sf-ufo/hexa-ufo/hexa-ufo.md")
    _check(base + "physics/meta-closure-nav/meta-closure-nav.md")
    _check(base + "physics/tabletop-blackhole/tabletop-blackhole.md")
    _check(base + "physics/calabi-yau-nav/calabi-yau-nav.md")
    _check(base + "physics/warp-drive/warp-drive.md")
    _check(base + "physics/wormhole/wormhole.md")
    _check(base + "physics/m-theory-11d/m-theory-11d.md")
    _check(base + "physics/multiverse-nav/multiverse-nav.md")
    println("--------------------------------------")
}

main()
