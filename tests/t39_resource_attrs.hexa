// Tests for @close, @pin, @limit

@pin let pinned = [10, 20, 30]
// pinned should survive scope changes

@close fn auto_cleanup() {
    // v1: just verifies the attr is recognized without error
    println("PASS @close recognized")
    return 42
}

@limit fn limited_work() {
    // v1: just verifies the attr is recognized
    let mut s = 0
    let mut i = 0
    while i < 100 { s = s + i; i = i + 1 }
    println("PASS @limit recognized, sum=" + to_string(s))
    return s
}

fn main() {
    println("pinned=" + to_string(pinned))
    auto_cleanup()
    limited_work()
    println("PASS t39_resource_attrs")
}

main()
