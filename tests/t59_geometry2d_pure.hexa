// t59_geometry2d_pure — verifies self/runtime/geometry2d_pure.hexa
// EXPECTED: ALL PASS
//
// Covers the 5 net-new 2D integer geometry helpers. Fns are inlined
// because stage0's interpreter does not currently parse import-paths
// (see t49_runtime_string_pure header).
//
// Well-known fixtures used below:
//   3-4-5 right triangle → L1=7, L∞=4
//   Unit square vertices → shoelace × 2 = 2 (CCW), -2 (CW)
//   Collinear (0,0), (1,1), (2,2) → cross = 0

fn iabs(n) {
    if n < 0 { return 0 - n }
    return n
}

fn imax(a, b) {
    if a > b { return a }
    return b
}

fn manhattan_distance_pure(p1, p2) {
    let dx = p1[0] - p2[0]
    let dy = p1[1] - p2[1]
    return iabs(dx) + iabs(dy)
}

fn chebyshev_distance_pure(p1, p2) {
    let dx = p1[0] - p2[0]
    let dy = p1[1] - p2[1]
    return imax(iabs(dx), iabs(dy))
}

fn cross_product_2d_pure(v1, v2) {
    return v1[0] * v2[1] - v1[1] * v2[0]
}

fn bounding_box_pure(points) {
    let n = len(points)
    if n == 0 { return nil }
    let mut minx = points[0][0]
    let mut miny = points[0][1]
    let mut maxx = points[0][0]
    let mut maxy = points[0][1]
    let mut i = 1
    while i < n {
        let p = points[i]
        if p[0] < minx { minx = p[0] }
        if p[1] < miny { miny = p[1] }
        if p[0] > maxx { maxx = p[0] }
        if p[1] > maxy { maxy = p[1] }
        i = i + 1
    }
    return [minx, miny, maxx, maxy]
}

fn polygon_signed_area_x2_pure(points) {
    let n = len(points)
    if n < 3 { return 0 }
    let mut s = 0
    let mut i = 0
    while i < n {
        let j = (i + 1) % n
        let xi = points[i][0]
        let yi = points[i][1]
        let xj = points[j][0]
        let yj = points[j][1]
        s = s + (xi * yj - xj * yi)
        i = i + 1
    }
    return s
}

let mut fail = 0

// ── manhattan_distance_pure (6) ────────────────────────────────────
// 1: same point → 0
if manhattan_distance_pure([0, 0], [0, 0]) != 0 { fail = fail + 1; println("FAIL mh same") }
// 2: 3-4-5 triangle → 7
if manhattan_distance_pure([0, 0], [3, 4]) != 7 { fail = fail + 1; println("FAIL mh 3-4") }
// 3: negative quadrant
if manhattan_distance_pure([0, 0], [0 - 3, 0 - 4]) != 7 { fail = fail + 1; println("FAIL mh neg") }
// 4: axis-aligned
if manhattan_distance_pure([5, 5], [5, 9]) != 4 { fail = fail + 1; println("FAIL mh axis") }
// 5: symmetry
if manhattan_distance_pure([10, 2], [3, 7]) != manhattan_distance_pure([3, 7], [10, 2]) { fail = fail + 1; println("FAIL mh sym") }
// 6: mixed signs
if manhattan_distance_pure([0 - 1, 5], [4, 0 - 2]) != 12 { fail = fail + 1; println("FAIL mh mixed") }

// ── chebyshev_distance_pure (5) ────────────────────────────────────
// 7: same point → 0
if chebyshev_distance_pure([7, 7], [7, 7]) != 0 { fail = fail + 1; println("FAIL cb same") }
// 8: 3-4-5 → 4
if chebyshev_distance_pure([0, 0], [3, 4]) != 4 { fail = fail + 1; println("FAIL cb 3-4") }
// 9: king's diagonal
if chebyshev_distance_pure([0, 0], [5, 5]) != 5 { fail = fail + 1; println("FAIL cb diag") }
// 10: dx > dy
if chebyshev_distance_pure([0, 0], [8, 2]) != 8 { fail = fail + 1; println("FAIL cb dx") }
// 11: negative delta
if chebyshev_distance_pure([10, 10], [2, 3]) != 8 { fail = fail + 1; println("FAIL cb negdelta") }

// ── cross_product_2d_pure (6) ──────────────────────────────────────
// 12: i × j = +1 (z component)
if cross_product_2d_pure([1, 0], [0, 1]) != 1 { fail = fail + 1; println("FAIL cr i×j") }
// 13: j × i = -1
if cross_product_2d_pure([0, 1], [1, 0]) != 0 - 1 { fail = fail + 1; println("FAIL cr j×i") }
// 14: collinear → 0
if cross_product_2d_pure([2, 2], [4, 4]) != 0 { fail = fail + 1; println("FAIL cr colin") }
// 15: anti-parallel → 0
if cross_product_2d_pure([3, 0], [0 - 5, 0]) != 0 { fail = fail + 1; println("FAIL cr anti") }
// 16: self-cross → 0
if cross_product_2d_pure([7, 11], [7, 11]) != 0 { fail = fail + 1; println("FAIL cr self") }
// 17: known value 2*5 - 3*4 = -2
if cross_product_2d_pure([2, 3], [4, 5]) != 0 - 2 { fail = fail + 1; println("FAIL cr val") }

// ── bounding_box_pure (5) ──────────────────────────────────────────
// 18: empty → nil (use type_of void per ipv4_pure header note)
let bb_empty = bounding_box_pure([])
if type_of(bb_empty) != "void" { fail = fail + 1; println("FAIL bb empty type=" + type_of(bb_empty)) }
// 19: single point → degenerate box
let bb1 = bounding_box_pure([[3, 7]])
if bb1[0] != 3 { fail = fail + 1; println("FAIL bb single x") }
if bb1[2] != 3 { fail = fail + 1; println("FAIL bb single maxx") }
// 20: unit square vertices
let bb2 = bounding_box_pure([[0, 0], [1, 0], [1, 1], [0, 1]])
if bb2[0] != 0 { fail = fail + 1; println("FAIL bb sq minx") }
// 21: unit square maxx/maxy
if bb2[2] != 1 { fail = fail + 1; println("FAIL bb sq maxx") }
if bb2[3] != 1 { fail = fail + 1; println("FAIL bb sq maxy") }
// 22: mixed signs
let bb3 = bounding_box_pure([[0 - 3, 2], [4, 0 - 5], [1, 1]])
if bb3[0] != 0 - 3 { fail = fail + 1; println("FAIL bb mx minx") }
if bb3[1] != 0 - 5 { fail = fail + 1; println("FAIL bb mx miny") }
if bb3[2] != 4 { fail = fail + 1; println("FAIL bb mx maxx") }
if bb3[3] != 2 { fail = fail + 1; println("FAIL bb mx maxy") }

// ── polygon_signed_area_x2_pure (6) ────────────────────────────────
// 23: degenerate (<3 verts)
if polygon_signed_area_x2_pure([]) != 0 { fail = fail + 1; println("FAIL poly empty") }
// 24: two-point edge → 0
if polygon_signed_area_x2_pure([[0, 0], [1, 1]]) != 0 { fail = fail + 1; println("FAIL poly edge") }
// 25: unit square CCW → area=1, ×2 → 2
if polygon_signed_area_x2_pure([[0, 0], [1, 0], [1, 1], [0, 1]]) != 2 { fail = fail + 1; println("FAIL poly sq CCW") }
// 26: unit square CW → -2 (reverse winding)
if polygon_signed_area_x2_pure([[0, 0], [0, 1], [1, 1], [1, 0]]) != 0 - 2 { fail = fail + 1; println("FAIL poly sq CW") }
// 27: right triangle (0,0),(4,0),(0,3) → area=6, ×2 → 12
if polygon_signed_area_x2_pure([[0, 0], [4, 0], [0, 3]]) != 12 { fail = fail + 1; println("FAIL poly tri") }
// 28: collinear triangle → 0 (degenerate but legal)
if polygon_signed_area_x2_pure([[0, 0], [1, 1], [2, 2]]) != 0 { fail = fail + 1; println("FAIL poly colin") }

if fail == 0 {
    println("ALL PASS")
}
