// t43_closures_hof — closures and higher-order functions
// EXPECTED: ALL PASS

// --- basic lambda ---
let double = |x| x * 2
if double(5) == 10 {
    println("PASS lambda double(5)=10")
} else {
    println("FAIL lambda double(5)=" + to_string(double(5)))
}

// --- multi-param lambda ---
let add = |a, b| a + b
if add(3, 4) == 7 {
    println("PASS lambda add(3,4)=7")
} else {
    println("FAIL lambda add(3,4)=" + to_string(add(3, 4)))
}

// --- closure capturing outer variable ---
fn make_adder(x) {
    return |y| x + y
}
let add10 = make_adder(10)
if add10(5) == 15 && add10(20) == 30 {
    println("PASS closure make_adder(10)(5)=15, (20)=30")
} else {
    println("FAIL closure add10(5)=" + to_string(add10(5)))
}

// --- function as argument (higher-order) ---
fn apply(f, x) {
    return f(x)
}
if apply(double, 7) == 14 {
    println("PASS higher-order apply(double,7)=14")
} else {
    println("FAIL higher-order apply=" + to_string(apply(double, 7)))
}

// --- function composition ---
fn compose(f, g) {
    return |x| f(g(x))
}
let inc = |x| x + 1
let double_then_inc = compose(inc, double)
if double_then_inc(5) == 11 {
    println("PASS compose inc(double(5))=11")
} else {
    println("FAIL compose=" + to_string(double_then_inc(5)))
}

// --- closure used with array.map ---
let multiplier = 3
let arr = [1, 2, 3, 4]
let result = arr.map(|x| x * multiplier)
if result.join(",") == "3,6,9,12" {
    println("PASS closure in map with captured var")
} else {
    println("FAIL closure in map=" + result.join(","))
}

// --- returning function from conditional ---
fn pick_op(name) {
    if name == "double" {
        return |x| x * 2
    } else {
        return |x| x + 1
    }
}
let op1 = pick_op("double")
let op2 = pick_op("inc")
if op1(5) == 10 && op2(5) == 6 {
    println("PASS conditional fn return")
} else {
    println("FAIL conditional fn return op1(5)=" + to_string(op1(5)) + " op2(5)=" + to_string(op2(5)))
}

println("ALL PASS")
