// t33-reproduce-unit: minimal repro for rt#32/T33 _ic_def_parts aliasing bug.
// Goal: emit many `__hexa_ic_N` slots via Field accesses.

struct Inner {
    a: int,
    b: int,
    c: int
}

struct Outer {
    x: Inner,
    y: Inner,
    z: Inner,
    count: int
}

fn mk_inner(a, b, c) {
    return Inner { a: a, b: b, c: c }
}

fn mk_outer() {
    let ix = mk_inner(1, 2, 3)
    let iy = mk_inner(4, 5, 6)
    let iz = mk_inner(7, 8, 9)
    return Outer { x: ix, y: iy, z: iz, count: 42 }
}

fn sum_outer(o) {
    let mut s = 0
    s = s + o.x.a
    s = s + o.x.b
    s = s + o.x.c
    s = s + o.y.a
    s = s + o.y.b
    s = s + o.y.c
    s = s + o.z.a
    s = s + o.z.b
    s = s + o.z.c
    s = s + o.count
    return s
}

fn check_outer(o) {
    if o.count > 0 {
        let ax = o.x.a
        let bx = o.x.b
        let ay = o.y.a
        let by = o.y.b
        let az = o.z.a
        let bz = o.z.b
        return ax + bx + ay + by + az + bz
    }
    return 0
}

fn chain_sum(o) {
    return sum_outer(o) + check_outer(o) + o.x.c + o.y.c + o.z.c
}

let o = mk_outer()
let s = chain_sum(o)
println(s)
