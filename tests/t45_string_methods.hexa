// t45_string_methods — comprehensive string method coverage
// EXPECTED: ALL PASS

let s = "Hello, World!"

// --- contains ---
if s.contains("World") && !s.contains("xyz") {
    println("PASS contains")
} else {
    println("FAIL contains")
}

// --- starts_with / ends_with ---
if s.starts_with("Hello") && s.ends_with("!") {
    println("PASS starts_with/ends_with")
} else {
    println("FAIL starts_with/ends_with")
}

// --- to_upper / to_lower ---
if s.to_upper() == "HELLO, WORLD!" && s.to_lower() == "hello, world!" {
    println("PASS to_upper/to_lower")
} else {
    println("FAIL to_upper=" + s.to_upper() + " to_lower=" + s.to_lower())
}

// --- replace ---
let replaced = s.replace("World", "Hexa")
if replaced == "Hello, Hexa!" {
    println("PASS replace")
} else {
    println("FAIL replace=" + replaced)
}

// --- split / join ---
let parts = "a-b-c-d".split("-")
if len(parts) == 4 && parts.join("+") == "a+b+c+d" {
    println("PASS split/join")
} else {
    println("FAIL split/join")
}

// --- trim ---
let padded = "  hello  "
if padded.trim() == "hello" {
    println("PASS trim")
} else {
    println("FAIL trim=" + padded.trim())
}

// --- is_empty ---
if "".is_empty() && !"x".is_empty() {
    println("PASS is_empty")
} else {
    println("FAIL is_empty")
}

// --- index_of ---
if "abcdef".index_of("cd") == 2 {
    println("PASS index_of")
} else {
    println("FAIL index_of=" + to_string("abcdef".index_of("cd")))
}

// --- substring ---
if "Hello, World!".substring(0, 5) == "Hello" {
    println("PASS substring")
} else {
    println("FAIL substring=" + "Hello, World!".substring(0, 5))
}

// --- repeat ---
if "ab".repeat(3) == "ababab" {
    println("PASS repeat")
} else {
    println("FAIL repeat=" + "ab".repeat(3))
}

// --- chars ---
let ch = "abc".chars()
if len(ch) == 3 && ch[0] == "a" && ch[1] == "b" && ch[2] == "c" {
    println("PASS chars")
} else {
    println("FAIL chars len=" + to_string(len(ch)))
}

// --- len ---
if len("hello") == 5 && len("") == 0 {
    println("PASS len")
} else {
    println("FAIL len")
}

println("ALL PASS")
