#!hexa strict
// t58 — L4 O(n^2) concat detection
// Linter should flag both `s = s + c` and `arr = arr + [x]` patterns
// inside for/while loops.

fn bad_str_concat(xs) {
    let mut s = ""
    let mut i = 0
    while i < len(xs) {
        s = s + xs[i]            // L4 violation: O(n^2) str concat
        i = i + 1
    }
    return s
}

fn bad_arr_concat(xs) {
    let mut out = []
    for x in xs {
        out = out + [x]          // L4 violation: O(n^2) arr concat
    }
    return out
}

fn ok_push(xs) {
    let mut out = []
    for x in xs {
        out = out.push(x)        // OK — push is O(1) amortized
    }
    return out
}

fn ok_outside_loop(a, b) {
    let mut out = a + b          // OK — not in loop
    return out
}

fn main() {
    println(bad_str_concat(["a", "b"]))
    println(len(bad_arr_concat([1, 2])))
}
