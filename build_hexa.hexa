// build_hexa.hexa — ported from build_hexa.sh
// hexa_v2-only pipeline PoC (cargo-free self-host)
//
// Goal: 100% absorption — replace cargo build with
//   hexa_v2 (native arm64)  ->  C source  ->  clang  ->  hexa_v3 binary
//
// Usage:
//   hexa build_hexa.hexa                 # full pipeline (stage1->2->3)
//   hexa build_hexa.hexa stage1          # transpile only
//   hexa build_hexa.hexa stage2          # clang compile only
//   hexa build_hexa.hexa stage3          # self-test only

let root = exec("pwd")
let hexa_v2 = root + "/self/native/hexa_v2"
let stage1_input = env("STAGE1_INPUT") ?? root + "/self/compiler.hexa"
let stage1_out = env("STAGE1_OUT") ?? "/tmp/hexa_v3.c"
let stage2_bin = env("STAGE2_BIN") ?? root + "/hexa_v3"
let stage3_test = env("STAGE3_TEST") ?? root + "/examples/calc_min.hexa"
let clang = env("CLANG") ?? "clang"

fn log(msg) {
    print("\x1b[1;36m[build_hexa]\x1b[0m " + msg)
}

fn err(msg) {
    print("\x1b[1;31m[build_hexa:ERR]\x1b[0m " + msg)
}

fn stage1() {
    log("Stage 1: hexa_v2  " + stage1_input + "  ->  " + stage1_out)
    if !file_exists(hexa_v2) {
        err("hexa_v2 not found or not executable: " + hexa_v2)
        exit(10)
    }
    if !file_exists(stage1_input) {
        err("stage1 input missing: " + stage1_input + " (BLOCKER B1)")
        exit(11)
    }
    shell(hexa_v2 + " " + stage1_input + " " + stage1_out)
    let size = exec("wc -c < " + stage1_out)
    if size.trim() == "0" {
        err("stage1 produced empty " + stage1_out)
        exit(12)
    }
    log("Stage 1 OK (" + size.trim() + " bytes)")
}

fn stage2() {
    log("Stage 2: " + clang + " -O2 " + stage1_out + "  ->  " + stage2_bin)
    if exec("command -v " + clang) == "" {
        err(clang + " not in PATH")
        exit(20)
    }
    if !file_exists(stage1_out) {
        err("no C source to compile: " + stage1_out + " (run stage1 first)")
        exit(21)
    }
    shell(clang + " -O2 -std=c11 -o " + stage2_bin + " " + stage1_out)
    log("Stage 2 OK -> " + stage2_bin)
}

fn stage3() {
    log("Stage 3: self-test  " + stage2_bin + "  " + stage3_test)
    if !file_exists(stage2_bin) {
        err("stage2 binary missing: " + stage2_bin)
        exit(30)
    }
    if !file_exists(stage3_test) {
        err("test input missing: " + stage3_test)
        exit(31)
    }
    let result = shell(stage2_bin + " " + stage3_test + " /tmp/hexa_v3_selftest.c")
    if result.exit_code != 0 {
        err("stage3 self-test failed — hexa_v3 did not accept " + stage3_test)
        exit(32)
    }
    log("Stage 3 OK (self-test transpiled -> /tmp/hexa_v3_selftest.c)")
}

let target = args(1) ?? "all"

if target == "stage1" {
    stage1()
} else if target == "stage2" {
    stage2()
} else if target == "stage3" {
    stage3()
} else if target == "all" {
    stage1()
    stage2()
    stage3()
} else {
    err("unknown target: " + target + " (use stage1|stage2|stage3|all)")
    exit(1)
}

print("")
print("Cargo removal: COMPLETE (2026-04-11)")
print("  ✅ src/ deleted (147 rs files → 605 self/*.hexa)")
print("  ✅ Cargo.toml / Cargo.lock / .cargo/ deleted")
print("  ✅ self/compiler.hexa (driver), self/alloc/* (egyptian allocator),")
print("     self/ir/* (HEXA-IR τ=4 × n=6 pass pipeline), self/codegen/* native")
print("     codegen, self/lib.hexa (library entry), self/main.hexa (CLI)")
print("     — all ported to hexa.")
print("  ✅ src/wasm.rs was removed; future self-host WASM target via")
print("     self/codegen_wgsl.hexa or hexa→JS transpiler (deferred).")
print("  ✅ test harness: self/test_interp*.hexa run via `./hexa` directly.")
print("     205/205 regression PASS post-src-deletion.")
print("  ℹ CI (.github/workflows/) still absent — not needed while bootstrap")
print("     is validated locally via the precompiled hexa binary.")
