#!/bin/bash
# hx — hexa package manager
# Usage: hx install <pkg> | hx run <pkg> | hx list | hx remove <pkg>
set -e

HX_HOME="${HX_HOME:-$HOME/.hx}"
HX_BIN="$HX_HOME/bin"
HX_PKG="$HX_HOME/packages"
HX_CACHE="$HX_HOME/cache/resolve.tsv"
REGISTRY_REMOTE="https://raw.githubusercontent.com/need-singularity/hexa-lang/main/pkg/registry.tsv"
HX_SCRIPT="$(readlink "$0" 2>/dev/null || echo "$0")"
HX_DIR="$(cd "$(dirname "$HX_SCRIPT")" && pwd)"
REGISTRY_LOCAL="${HX_DIR}/registry.tsv"
[ ! -f "$REGISTRY_LOCAL" ] && REGISTRY_LOCAL="${HX_DIR}/../pkg/registry.tsv"

# AI-native convention: probe these orgs in order. No central list.
# Override with HX_ORGS="org1 org2 ..." env var.
HX_ORGS_DEFAULT="hexa-pkg need-singularity dancinlife"
HX_ORGS="${HX_ORGS:-$HX_ORGS_DEFAULT}"

mkdir -p "$HX_BIN" "$HX_PKG" "$(dirname "$HX_CACHE")"

red()   { printf '\033[31m%s\033[0m\n' "$*"; }
green() { printf '\033[32m%s\033[0m\n' "$*"; }
dim()   { printf '\033[2m%s\033[0m\n' "$*"; }

usage() {
  echo "hx — hexa package manager"
  echo ""
  echo "  hx install <target>      Install a package (brew-style)"
  echo "                             <target> can be:"
  echo "                               name              registry package"
  echo "                               user/repo         GitHub shortform"
  echo "                               https://...       full git URL"
  echo "                               git@host:...      ssh git URL"
  echo "                               ./path | /path    local directory"
  echo "  hx update [<pkg>]        Refresh shims (git pull for cloned pkgs)"
  echo "  hx run <pkg> [args...]   Run installed package"
  echo "  hx list                  List installed packages"
  echo "  hx remove <pkg>          Remove a package"
  echo "  hx search                Show available packages"
  echo "  hx info <pkg>            Show package detail"
  echo "  hx where <name>          Resolve a name to a repo URL (no install)"
  echo "  hx orgs                  List/manage probe orgs (HX_ORGS env)"
  echo ""
  echo "options:"
  echo "  --entry <path>           Override entry script (relative to pkg root)"
  echo "  --as <name>              Override installed name"
  echo "  --no-cache               Skip resolve cache (force re-probe)"
  echo ""
  echo "AI-native resolution: bare names (e.g. 'hx install airgenome') are"
  echo "resolved by probing github.com/<org>/<name> for orgs in HX_ORGS."
  echo "No central list — successful resolutions are cached at $HX_CACHE."
  echo ""
}

fetch_registry() {
  # local first, remote fallback
  if [ -f "$REGISTRY_LOCAL" ]; then
    cat "$REGISTRY_LOCAL"
  elif command -v curl >/dev/null; then
    curl -sL "$REGISTRY_REMOTE"
  elif command -v wget >/dev/null; then
    wget -qO- "$REGISTRY_REMOTE"
  else
    red "error: curl or wget required"
    exit 1
  fi
}

# Pure-bash TSV registry reader (zero external deps).
# Format: name<TAB>version<TAB>entry<TAB>repo<TAB>local<TAB>desc
# Columns: 1=name 2=version 3=entry 4=repo 5=local 6=desc
#
# Usage: pkg_field <pkg> <field> <tsv_content>
#   field ∈ {version, entry, repo, local, desc}
pkg_field() {
  local pkg="$1" field="$2" tsv="$3"
  local col
  case "$field" in
    version) col=2 ;;
    entry)   col=3 ;;
    repo)    col=4 ;;
    local)   col=5 ;;
    desc)    col=6 ;;
    *)       return 1 ;;
  esac
  echo "$tsv" | awk -F'\t' -v p="$pkg" -v c="$col" '
    /^#/ { next }
    /^$/ { next }
    $1 == p { print $c; found=1; exit }
    END { if (!found) exit 1 }
  '
}

# AI-native name resolution cache (pure-bash TSV: name<TAB>url)
cache_get() {
  local name="$1"
  [ -f "$HX_CACHE" ] || return 1
  local line
  line=$(awk -F'\t' -v n="$name" '$1 == n { print $2; found=1; exit } END { if (!found) exit 1 }' "$HX_CACHE")
  [ -n "$line" ] || return 1
  printf '%s' "$line"
}

cache_put() {
  local name="$1" url="$2"
  [ -f "$HX_CACHE" ] || touch "$HX_CACHE"
  # Remove existing entry if present, then append new
  local tmp="$HX_CACHE.tmp.$$"
  awk -F'\t' -v n="$name" '$1 != n' "$HX_CACHE" > "$tmp"
  printf '%s\t%s\n' "$name" "$url" >> "$tmp"
  mv "$tmp" "$HX_CACHE"
}

resolve_name() {
  local name="$1" no_cache="$2"
  if [ -z "$no_cache" ]; then
    local cached
    if cached=$(cache_get "$name"); then
      echo "$cached"
      return 0
    fi
  fi
  for org in $HX_ORGS; do
    local url="https://github.com/$org/$name"
    if git ls-remote --exit-code "$url" >/dev/null 2>&1; then
      cache_put "$name" "$url"
      echo "$url"
      return 0
    fi
  done
  return 1
}

# detect entry script in a directory (brew-like auto-detect)
detect_entry() {
  local dir="$1" name="$2"
  local candidates=(
    "run.sh" "start.sh" "main.sh" "$name.sh"
    "bin/$name" "bin/run" "$name"
    "run.hexa" "main.hexa" "$name.hexa" "start.hexa"
    "run" "main" "start"
  )
  for c in "${candidates[@]}"; do
    if [ -f "$dir/$c" ]; then
      echo "$c"
      return 0
    fi
  done
  return 1
}

# classify install target
classify_target() {
  local t="$1"
  case "$t" in
    https://*|http://*|git@*|ssh://*|*.git) echo "url" ;;
    ./*|/*|~*) echo "path" ;;
    */*)
      # github shortform user/repo (single slash, no spaces)
      if [[ "$t" =~ ^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$ ]]; then
        echo "github"
      else
        echo "name"
      fi
      ;;
    *) echo "name" ;;
  esac
}

cmd_install() {
  local target="" entry_override="" name_override="" no_cache=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --entry)    entry_override="$2"; shift 2 ;;
      --as)       name_override="$2"; shift 2 ;;
      --no-cache) no_cache="1"; shift ;;
      -*)         red "unknown option: $1"; exit 1 ;;
      *)          target="$1"; shift ;;
    esac
  done
  [ -z "$target" ] && { red "usage: hx install <target>"; exit 1; }

  local kind
  kind=$(classify_target "$target")

  local pkg="" repo="" entry="" desc="" src_path=""
  case "$kind" in
    name)
      green "⬡ fetching registry..."
      local reg
      reg=$(fetch_registry)
      pkg="$target"
      repo=$(pkg_field "$pkg" "repo" "$reg") || true
      local local_field
      local_field=$(pkg_field "$pkg" "local" "$reg") || true
      entry=$(pkg_field "$pkg" "entry" "$reg") || true
      desc=$(pkg_field "$pkg" "desc" "$reg") || true
      if [ -z "$repo" ] && [ -z "$local_field" ]; then
        # AI-native fallback: probe convention orgs (no central list needed)
        green "⬡ resolving '$pkg' via convention orgs..."
        if repo=$(resolve_name "$pkg" "$no_cache"); then
          dim "  ↳ $repo"
        else
          red "package '$pkg' not found"
          dim "  probed orgs: $HX_ORGS"
          dim "  hint: hx install <user>/$pkg  or  HX_ORGS=\"myorg $HX_ORGS\" hx install $pkg"
          exit 1
        fi
      fi
      if [ -n "$local_field" ]; then
        # registry-local: relative to registry directory
        if [ "${local_field#/}" = "$local_field" ]; then
          src_path="$(cd "$(dirname "$REGISTRY_LOCAL")" && pwd)/$local_field"
        else
          src_path="$local_field"
        fi
      fi
      ;;
    github)
      pkg="${target##*/}"
      repo="https://github.com/$target"
      ;;
    url)
      pkg="${target##*/}"
      pkg="${pkg%.git}"
      repo="$target"
      ;;
    path)
      # expand ~
      local p="${target/#\~/$HOME}"
      [ -d "$p" ] || { red "path not found: $p"; exit 1; }
      src_path="$(cd "$p" && pwd)"
      pkg="$(basename "$src_path")"
      ;;
  esac

  [ -n "$name_override" ] && pkg="$name_override"
  [ -n "$desc" ] && dim "  $desc"

  local dest="$HX_PKG/$pkg"
  rm -rf "$dest"

  # $WS/<name> override (legacy convenience for github/name kinds)
  if [ -z "$src_path" ] && [ -d "$WS/$pkg" ] && [ "$kind" != "url" ]; then
    src_path="$WS/$pkg"
    dim "  found local: $src_path"
  fi

  if [ -n "$src_path" ]; then
    green "⬡ linking $pkg ($src_path)..."
    ln -s "$src_path" "$dest"
  else
    green "⬡ cloning $pkg ($repo)..."
    git clone --depth 1 --quiet "$repo" "$dest" || { red "git clone failed"; exit 1; }
  fi

  # ── build hook (Option 3) ──────────────────────────────────────
  # bin/build.hexa 또는 install.hexa 가 있으면 hexa 로 실행. .sh fallback 유지.
  # Env: HX_PKG_DIR (패키지 소스), HX_BIN_DIR (~/.hx/bin), HX_PKG_NAME.
  # 관례: build hook 은 $HX_PKG_DIR 안에 빌드 산출물 배치 (또는 $HX_BIN_DIR 직접).
  local hook=""
  local hook_runner="bash"
  for cand in "bin/build.hexa" "install.hexa" "bin/build.sh" "install.sh"; do
    if [ -f "$dest/$cand" ]; then
      case "$cand" in
        *.hexa) hook_runner="hexa" ;;
        *)      hook_runner="bash"; chmod +x "$dest/$cand" 2>/dev/null || true ;;
      esac
      hook="$dest/$cand"
      break
    fi
  done
  if [ -n "$hook" ]; then
    green "⬡ build hook: $(basename "$hook")"
    if ! HX_PKG_DIR="$dest" HX_BIN_DIR="$HX_BIN" HX_PKG_NAME="$pkg" $hook_runner "$hook"; then
      red "build hook failed — rolling back"
      rm -rf "$dest"
      # 설치 전 bin 파일 남아있으면 정리 (sym-link 만 제거; real file 은 건너뜀)
      [ -L "$HX_BIN/$pkg" ] && rm -f "$HX_BIN/$pkg"
      exit 1
    fi
  fi

  # entry resolution: --entry > registry > auto-detect
  [ -n "$entry_override" ] && entry="$entry_override"
  if [ -z "$entry" ] || [ ! -f "$dest/$entry" ]; then
    local detected
    if detected=$(detect_entry "$dest" "$pkg"); then
      [ -n "$entry" ] && [ ! -f "$dest/$entry" ] && dim "  registry entry '$entry' missing, auto-detected '$detected'"
      entry="$detected"
    fi
  fi

  if [ -n "$entry" ] && [ -f "$dest/$entry" ]; then
    chmod +x "$dest/$entry" 2>/dev/null || true
    rm -f "$HX_BIN/$pkg"
    case "$entry" in
      *.hexa)
        # .hexa entry: generate a wrapper shim that invokes the hexa interpreter
        cat > "$HX_BIN/$pkg" <<EOF
#!/bin/bash
# hx-generated shim for $pkg ($entry)
HEXA="\${HEXA:-}"
if [ -z "\$HEXA" ]; then
  for c in "\$WS/airgenome/nexus/shared/bin/hexa" "\$HOME/.hx/bin/hexa" "\$(command -v hexa 2>/dev/null)"; do
    if [ -n "\$c" ] && [ -x "\$c" ]; then HEXA="\$c"; break; fi
  done
fi
if [ -z "\$HEXA" ]; then
  echo "⬡ FATAL: hexa interpreter not found" >&2
  exit 1
fi
exec "\$HEXA" "$dest/$entry" "\$@"
EOF
        chmod +x "$HX_BIN/$pkg"
        ;;
      *)
        ln -sf "$dest/$entry" "$HX_BIN/$pkg"
        ;;
    esac
    green "⬡ installed: $pkg"
    dim "  entry: $entry"
    dim "  run with: hx run $pkg  (or: $pkg)"
  else
    red "warning: no entry script found in $dest"
    dim "  re-install with --entry <path> to specify"
  fi
}

cmd_info() {
  local pkg="$1"
  [ -z "$pkg" ] && { red "usage: hx info <pkg>"; exit 1; }
  local dest="$HX_PKG/$pkg" bin="$HX_BIN/$pkg"
  if [ ! -e "$dest" ]; then
    red "'$pkg' not installed"
    exit 1
  fi
  green "⬡ $pkg"
  if [ -L "$dest" ]; then
    dim "  source: $(readlink "$dest") (linked)"
  else
    dim "  source: $dest (cloned)"
  fi
  [ -L "$bin" ] && dim "  entry:  $(readlink "$bin")"
}

cmd_run() {
  local pkg="$1"; shift 2>/dev/null || true
  [ -z "$pkg" ] && { red "usage: hx run <pkg>"; exit 1; }

  local bin="$HX_BIN/$pkg"
  [ -x "$bin" ] || { red "'$pkg' not installed. Run: hx install $pkg"; exit 1; }
  exec "$bin" "$@"
}

cmd_list() {
  if [ -d "$HX_BIN" ] && [ "$(ls -A "$HX_BIN" 2>/dev/null)" ]; then
    green "⬡ installed packages:"
    for f in "$HX_BIN"/*; do
      echo "  $(basename "$f")"
    done
  else
    dim "  no packages installed"
  fi
}

cmd_remove() {
  local pkg="$1"
  [ -z "$pkg" ] && { red "usage: hx remove <pkg>"; exit 1; }

  rm -f "$HX_BIN/$pkg"
  rm -rf "$HX_PKG/$pkg"
  green "⬡ removed: $pkg"
}

# Refresh shim from current registry/source state.
# Symlinked pkgs: source file changes reflect immediately, but if the
# registry `entry` column changed we must regenerate the shim to point
# at the new entry. Cloned pkgs: same, after git pull.
refresh_shim() {
  local pkg="$1" dest="$2"
  local reg entry=""
  if [ -f "$REGISTRY_LOCAL" ]; then
    reg=$(cat "$REGISTRY_LOCAL")
    entry=$(pkg_field "$pkg" "entry" "$reg" 2>/dev/null) || true
  fi
  if [ -z "$entry" ] || [ ! -f "$dest/$entry" ]; then
    local detected
    if detected=$(detect_entry "$dest" "$pkg"); then
      entry="$detected"
    fi
  fi
  if [ -z "$entry" ] || [ ! -f "$dest/$entry" ]; then
    red "  no entry detected for $pkg"
    return 1
  fi
  chmod +x "$dest/$entry" 2>/dev/null || true
  rm -f "$HX_BIN/$pkg"
  case "$entry" in
    *.hexa)
      cat > "$HX_BIN/$pkg" <<EOF
#!/bin/bash
# hx-generated shim for $pkg ($entry)
HEXA="\${HEXA:-}"
if [ -z "\$HEXA" ]; then
  for c in "\$WS/airgenome/nexus/shared/bin/hexa" "\$HOME/.hx/bin/hexa" "\$(command -v hexa 2>/dev/null)"; do
    if [ -n "\$c" ] && [ -x "\$c" ]; then HEXA="\$c"; break; fi
  done
fi
if [ -z "\$HEXA" ]; then
  echo "⬡ FATAL: hexa interpreter not found" >&2
  exit 1
fi
exec "\$HEXA" "$dest/$entry" "\$@"
EOF
      chmod +x "$HX_BIN/$pkg"
      ;;
    *)
      ln -sf "$dest/$entry" "$HX_BIN/$pkg"
      ;;
  esac
  dim "  entry: $entry"
  return 0
}

update_one() {
  local pkg="$1"
  local dest="$HX_PKG/$pkg"
  if [ ! -e "$dest" ]; then
    red "  '$pkg' not installed"
    return 1
  fi
  if [ -L "$dest" ]; then
    local target
    target="$(readlink "$dest")"
    if [ ! -d "$target" ]; then
      red "⬡ $pkg: symlink source missing ($target)"
      return 1
    fi
    green "⬡ refresh $pkg (symlink → $target)"
    refresh_shim "$pkg" "$dest"
  elif [ -d "$dest/.git" ]; then
    green "⬡ pulling $pkg"
    if ! (cd "$dest" && git pull --quiet --ff-only 2>&1); then
      red "  git pull failed"
      return 1
    fi
    refresh_shim "$pkg" "$dest"
  else
    dim "⬡ $pkg: not git, not symlink — shim refresh only"
    refresh_shim "$pkg" "$dest"
  fi
}

cmd_update() {
  local pkg="$1"
  if [ -n "$pkg" ]; then
    update_one "$pkg"
    return $?
  fi
  # all packages
  if [ ! -d "$HX_PKG" ] || [ -z "$(ls -A "$HX_PKG" 2>/dev/null)" ]; then
    dim "  no packages installed"
    return 0
  fi
  local failed=0
  for d in "$HX_PKG"/*; do
    [ -e "$d" ] || continue
    update_one "$(basename "$d")" || failed=$((failed + 1))
  done
  if [ "$failed" -gt 0 ]; then
    red "⬡ $failed package(s) failed to update"
    return 1
  fi
  green "⬡ all packages updated"
}

cmd_where() {
  local name="$1"
  [ -z "$name" ] && { red "usage: hx where <name>"; exit 1; }
  green "⬡ resolving '$name'..."
  local cached
  if cached=$(cache_get "$name"); then
    dim "  cache: $cached"
  fi
  local url
  if url=$(resolve_name "$name" "1"); then
    green "  found: $url"
  else
    red "  not found in: $HX_ORGS"
    exit 1
  fi
}

cmd_orgs() {
  green "⬡ probe orgs (in order):"
  for org in $HX_ORGS; do
    echo "  $org"
  done
  dim ""
  dim "  override: HX_ORGS=\"org1 org2 ...\" hx install <name>"
  dim "  cache:    $HX_CACHE"
  if [ -f "$HX_CACHE" ]; then
    dim ""
    green "⬡ resolved cache:"
    awk -F'\t' '{ print "  " $1 " → " $2 }' "$HX_CACHE"
  fi
}

cmd_search() {
  green "⬡ available packages:"
  local reg
  reg=$(fetch_registry)
  echo "$reg" | awk -F'\t' '
    /^#/ { next }
    /^$/ { next }
    { printf "  %s (%s) — %s\n", $1, $2, $6 }
  '
}

case "${1:-}" in
  install) shift; cmd_install "$@" ;;
  update)  cmd_update "$2" ;;
  run)     shift; cmd_run "$@" ;;
  list)    cmd_list ;;
  remove)  cmd_remove "$2" ;;
  search)  cmd_search ;;
  info)    cmd_info "$2" ;;
  where)   cmd_where "$2" ;;
  orgs)    cmd_orgs ;;
  *)       usage ;;
esac
