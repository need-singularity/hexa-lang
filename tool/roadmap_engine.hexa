// tool/roadmap_engine.hexa — single CLI orchestrator for the hexa-native
// roadmap engine (raw#9 hexa-only, deterministic, no LLM, no Python).
//
// BEHAVIOR (from the user directive)
//   1. Parses 3 repo .roadmap (anima / airgenome / hexa-lang)
//   2. Builds cross-repo DAG
//   3. Computes critical path (span)
//   4. Identifies ready entries (depends-on satisfied)
//   5. Reports Day-by-Day parallel groups
//   6. --advance flag flips status if Phase Gate 100% PASSes
//
// SUB-TOOL COMPOSITION
//   tool/roadmap_parse.hexa          — lossless parser
//   tool/roadmap_validate.hexa       — raw#15 field validator
//   tool/roadmap_dag.hexa            — depends-on DAG + cycle check
//   tool/roadmap_critical_path.hexa  — longest-path + span
//   tool/roadmap_parallel.hexa       — depth → Day-by-Day groups
//   tool/roadmap_status_flip.hexa    — proof-driven flips (dry-run / apply)
//   tool/roadmap_evidence.hexa       — proof + SHA reachability
//   tool/roadmap_progress.hexa       — pivot by phase/track/repo
//   tool/roadmap_phase_gate.hexa     — Tier1#9★ 100% ε-strict gate
//   tool/roadmap_span_dag.hexa       — Brent/Graham T_p bounds
//   tool/roadmap_bottleneck.hexa     — Ω 5-axis cost
//   tool/roadmap_ready_set.hexa      — Kahn |R(t)| ≥ 1 invariant
//   tool/roadmap_info_account.hexa   — Σ_k ΔI_k ≥ K(G|S₀) invariant
//   tool/roadmap_stagnation.hexa     — η_k > 0 invariant
//   tool/roadmap_t_star.hexa         — inf_π span(π) multi-path optimizer
//   tool/verify_gate_dsl.hexa        — Tier3#19 gate DSL → structured JSON
//   tool/verify_cert_linker.hexa     — Tier3#20/#25 cert ↔ gate auto-flip
//   tool/verify_adversarial.hexa     — Tier3#21/#24 raw#12 cherry-pick immunity
//   tool/verify_meta2_chain.hexa     — Tier3#22/#23 chain integrity + audit append
//   tool/verify_multi_path_phi.hexa  — Tier3#26 4-path Φ ≥3 + substrate invariance
//
// CLI
//   hexa tool/roadmap_engine.hexa status           — full report (default)
//   hexa tool/roadmap_engine.hexa parse            — JSON dump
//   hexa tool/roadmap_engine.hexa dag              — DAG JSON
//   hexa tool/roadmap_engine.hexa critical-path    — span + path
//   hexa tool/roadmap_engine.hexa ready            — R(t)
//   hexa tool/roadmap_engine.hexa day-groups       — parallel layers MD
//   hexa tool/roadmap_engine.hexa progress         — phase/track pivots
//   hexa tool/roadmap_engine.hexa invariants       — all 3 invariants
//   hexa tool/roadmap_engine.hexa t-star           — multi-path compare
//   hexa tool/roadmap_engine.hexa verify-gates <repo>
//                                                  — Tier3 verification engine
//                                                    (gate DSL + cert linker +
//                                                     adversarial + meta² chain +
//                                                     4-path Φ)
//   hexa tool/roadmap_engine.hexa --advance <repo> <id>
//                                                  — Phase Gate 100% + flip
//   hexa tool/roadmap_engine.hexa selftest         — cascade-run all modules

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _tool(name: string) -> string {
    return _home() + "/core/hexa-lang/tool/" + name
}

// Resolve to AOT binary at core/hexa-lang/bin/<stem> if present and newer than
// its .hexa source; otherwise empty string → fall back to interpreter.
// Caches per-name decision for the engine process lifetime.
fn _bin_for(name: string) -> string {
    let stem = name
    if stem.ends_with(".hexa") { stem = stem.substring(0, len(stem) - 5) }
    let bin_path = _home() + "/core/hexa-lang/bin/" + stem
    let src_path = _tool(name)
    // prefer bin if exists AND not older than source
    let r = exec_with_status("test -x '" + bin_path + "' && [ '" + bin_path + "' -nt '" + src_path + "' ] || [ '" + bin_path + "' -ef '" + bin_path + "' ] && test -x '" + bin_path + "'")
    if r[1] == 0 { return bin_path }
    return ""
}

fn _run_tool(name: string, args: string) -> array {
    let bin = _bin_for(name)
    let mut cmd = ""
    if len(bin) > 0 {
        cmd = "'" + bin + "' " + args
    } else {
        cmd = "hexa '" + _tool(name) + "' " + args
    }
    let r = exec_with_status(cmd)
    return r
}

fn _run_tool_capture(name: string, args: string) -> string {
    let bin = _bin_for(name)
    let mut cmd = ""
    if len(bin) > 0 {
        cmd = "'" + bin + "' " + args + " 2>&1"
    } else {
        cmd = "hexa '" + _tool(name) + "' " + args + " 2>&1"
    }
    return to_string(exec(cmd))
}

// ───────────────────── airgenome hook CLI bridge ─────────────────────
// CLI-only per raw#15 — never touches .hook-commands/active.json or
// <chain>/findings.jsonl directly. If airgenome is absent or the `hook`
// sub-dispatcher is broken, every call gracefully returns 0 (no-op).
// Prefers tool/airgenome_hook.hexa wrapper (when landed from worktree
// agent-a5f0e320); falls back to direct `airgenome hook <sub>` exec.

fn _sh_q(s: string) -> string {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _ag_wrapper_path() -> string {
    let p = _tool("airgenome_hook.hexa")
    let r = exec_with_status("test -f " + _sh_q(p))
    if r[1] == 0 { return p }
    return ""
}

fn _ag_bin() -> string {
    let ov = env("AIRGENOME_BIN")
    if len(ov) > 0 {
        let chk = exec_with_status("test -x " + _sh_q(ov))
        if chk[1] == 0 { return ov }
        return ""
    }
    let r = exec_with_status("command -v airgenome 2>/dev/null")
    if r[1] != 0 { return "" }
    return to_string(r[0]).trim()
}

fn _ag_available() -> bool {
    let w = _ag_wrapper_path()
    if len(w) > 0 {
        let r = exec_with_status("hexa " + _sh_q(w) + " --available 2>/dev/null")
        return r[1] == 0
    }
    let bin = _ag_bin()
    if len(bin) == 0 { return false }
    let r = exec_with_status(_sh_q(bin) + " hook status >/dev/null 2>&1")
    return r[1] == 0
}

fn _ag_activate(chain: string, seed: string, command: string) -> int {
    if !_ag_available() { return 0 }
    let w = _ag_wrapper_path()
    if len(w) > 0 {
        // wrapper exposes library API; use direct airgenome CLI for shell call
    }
    let bin = _ag_bin()
    if len(bin) == 0 { return 0 }
    let cmd = _sh_q(bin) + " hook activate " + _sh_q(chain) + " " + _sh_q(seed) + " " + _sh_q(command) + " >/dev/null 2>&1"
    let r = exec_with_status(cmd)
    return r[1]
}

fn _ag_touch(chain: string, kind: string, payload: string) -> int {
    if !_ag_available() { return 0 }
    let bin = _ag_bin()
    if len(bin) == 0 { return 0 }
    let cmd = _sh_q(bin) + " hook touch " + _sh_q(chain) + " " + _sh_q(kind) + " " + _sh_q(payload) + " >/dev/null 2>&1"
    let r = exec_with_status(cmd)
    return r[1]
}

fn _ag_release(chain: string, reason: string) -> int {
    if !_ag_available() { return 0 }
    let bin = _ag_bin()
    if len(bin) == 0 { return 0 }
    let cmd = _sh_q(bin) + " hook release " + _sh_q(chain) + " " + _sh_q(reason) + " >/dev/null 2>&1"
    let r = exec_with_status(cmd)
    return r[1]
}

fn _head_sha() -> string {
    let r = exec_with_status("git -C " + _sh_q(_home() + "/core/hexa-lang") + " rev-parse --short=12 HEAD 2>/dev/null")
    if r[1] != 0 { return "unknown" }
    let s = to_string(r[0]).trim()
    if len(s) == 0 { return "unknown" }
    return s
}

fn _pass_fail(rc: int) -> string {
    if rc == 0 { return "pass" }
    return "fail"
}

fn _banner(s: string) -> void {
    println("")
    println("═══════════════════════════════════════════════════════════════════")
    println(" " + s)
    println("═══════════════════════════════════════════════════════════════════")
}

fn _cmd_status() -> int {
    _banner("ROADMAP ENGINE — status (3 repos)")

    _banner("1. Parse — 3-repo lossless")
    let pr = _run_tool("roadmap_parse.hexa", "--selftest")
    if pr[1] != 0 { eprintln("parse FAIL") } else { println(to_string(pr[0])) }

    _banner("2. Validate — raw#15 contract")
    let vr = _run_tool_capture("roadmap_validate.hexa", "--selftest")
    println(vr)

    _banner("3. DAG — cross-repo cycle check")
    let dr = _run_tool_capture("roadmap_dag.hexa", "--selftest")
    println(dr)

    _banner("4. Critical path — span(DAG), Path B = 6d")
    let cp = _run_tool_capture("roadmap_critical_path.hexa", "--selftest")
    println(cp)

    _banner("5. Parallel groups — Day-by-Day")
    let pg = _run_tool_capture("roadmap_parallel.hexa", "--selftest")
    println(pg)

    _banner("6. Ready set — Kahn |R(t)| ≥ 1")
    let rs = _run_tool_capture("roadmap_ready_set.hexa", "--selftest")
    println(rs)

    _banner("7. Progress — phase / track / repo pivot")
    let pp = _run_tool_capture("roadmap_progress.hexa", "--selftest")
    println(pp)

    _banner("8. Evidence — proof + SHA reachability")
    let ev = _run_tool_capture("roadmap_evidence.hexa", "--selftest")
    println(ev)

    _banner("9. Invariants — T* theory checks")
    let ib = _run_tool_capture("roadmap_bottleneck.hexa", "--selftest")
    println(ib)
    let ii = _run_tool_capture("roadmap_info_account.hexa", "--selftest")
    println(ii)
    let ist = _run_tool_capture("roadmap_stagnation.hexa", "--selftest")
    println(ist)

    _banner("10. Span / T* — Brent/Graham + path comparison")
    let sp = _run_tool_capture("roadmap_span_dag.hexa", "--selftest")
    println(sp)
    let tsx = _run_tool_capture("roadmap_t_star.hexa", "--selftest")
    println(tsx)

    _banner("DONE — engine status complete")
    return 0
}

fn _cmd_parse() -> int {
    let home = _home()
    for r in ["anima", "airgenome", "hexa-lang"] {
        println("// " + r)
        let out = _run_tool_capture("roadmap_parse.hexa", home + "/core/" + r + "/.roadmap")
        println(out)
    }
    return 0
}

fn _cmd_dag() -> int {
    println(_run_tool_capture("roadmap_dag.hexa", ""))
    return 0
}

fn _cmd_critical_path() -> int {
    println(_run_tool_capture("roadmap_critical_path.hexa", "--scope PathB"))
    println(_run_tool_capture("roadmap_critical_path.hexa", ""))
    return 0
}

fn _cmd_ready() -> int {
    println(_run_tool_capture("roadmap_ready_set.hexa", ""))
    return 0
}

fn _cmd_day_groups() -> int {
    println("## Full graph\n")
    println(_run_tool_capture("roadmap_parallel.hexa", "--md"))
    println("\n## Path B\n")
    println(_run_tool_capture("roadmap_parallel.hexa", "--md --path-b"))
    return 0
}

fn _cmd_progress() -> int {
    println(_run_tool_capture("roadmap_progress.hexa", ""))
    return 0
}

fn _cmd_invariants() -> int {
    _banner("Invariant 1: |R(t)| ≥ 1 (Kahn)")
    println(_run_tool_capture("roadmap_ready_set.hexa", ""))
    _banner("Invariant 2: Σ_k ΔI_k ≥ K(G|S₀)")
    println(_run_tool_capture("roadmap_info_account.hexa", "--path-b"))
    _banner("Invariant 3: η_k > 0 (bottleneck movement)")
    println(_run_tool_capture("roadmap_stagnation.hexa", "--path-b"))
    return 0
}

fn _cmd_tstar() -> int {
    println(_run_tool_capture("roadmap_t_star.hexa", "--compare A,B,All"))
    return 0
}

// verify-gates <repo>: Tier3 verification engine — 5 sub-tools + integration.
// Wrapped with airgenome hook chain "vg-<repo>":
//   activate on entry → 5× touch(module, result=pass|fail) → release on 5/5 PASS.
fn _cmd_verify_gates(repo: string) -> int {
    let chain = "vg-" + repo
    let _a = _ag_activate(chain, "verify_gates", "roadmap")

    _banner("Tier3 Verification Engine — " + repo)

    _banner("#19 gate DSL — structured JSON")
    let r1 = _run_tool("verify_gate_dsl.hexa", "--selftest")
    if r1[1] != 0 { eprintln("gate_dsl FAIL") }
    println(to_string(r1[0]))
    let _t1 = _ag_touch(chain, "gate_dsl", "result=" + _pass_fail(r1[1]))

    _banner("#20/#25 cert linker — gate auto-satisfied flip")
    let r2 = _run_tool("verify_cert_linker.hexa", "--selftest")
    if r2[1] != 0 { eprintln("cert_linker FAIL") }
    println(to_string(r2[0]))
    let _t2 = _ag_touch(chain, "cert_linker", "result=" + _pass_fail(r2[1]))

    _banner("#21/#24 adversarial — raw#12 cherry-pick immunity")
    let r3 = _run_tool("verify_adversarial.hexa", "--selftest")
    if r3[1] != 0 { eprintln("adversarial FAIL") }
    println(to_string(r3[0]))
    let _t3 = _ag_touch(chain, "adversarial", "result=" + _pass_fail(r3[1]))

    _banner("#22/#23 meta² chain integrity + raw-audit append")
    let r4 = _run_tool("verify_meta2_chain.hexa", "--selftest")
    if r4[1] != 0 { eprintln("meta2_chain FAIL") }
    println(to_string(r4[0]))
    let _t4 = _ag_touch(chain, "meta2_chain", "result=" + _pass_fail(r4[1]))

    _banner("#26 multi-path Φ — 4-path ≥3 + substrate invariance")
    let r5 = _run_tool("verify_multi_path_phi.hexa", "--selftest")
    if r5[1] != 0 { eprintln("multi_path_phi FAIL") }
    println(to_string(r5[0]))
    let _t5 = _ag_touch(chain, "multi_path_phi", "result=" + _pass_fail(r5[1]))

    _banner("Per-repo cert link — " + repo)
    let r6 = _run_tool_capture("verify_cert_linker.hexa", "--repo " + repo)
    println(r6)

    let ok_count = 0
    let mut ok = 0
    if r1[1] == 0 { ok = ok + 1 }
    if r2[1] == 0 { ok = ok + 1 }
    if r3[1] == 0 { ok = ok + 1 }
    if r4[1] == 0 { ok = ok + 1 }
    if r5[1] == 0 { ok = ok + 1 }

    _banner("Tier3 verify-gates summary")
    println("  modules passing: " + to_string(ok) + "/5")
    if ok == 5 {
        let _r = _ag_release(chain, "5/5 PASS sha=" + _head_sha())
        println("  Tier 3 verification engine 8 기능 LIVE")
        return 0
    }
    let _r = _ag_release(chain, to_string(ok) + "/5 PASS — not released clean")
    eprintln("  Tier 3 verification: " + to_string(5 - ok) + " module(s) failed")
    return 1
}

// --advance <repo> <id> : Phase Gate 100% → status flip (no bypass)
// Wrapped with airgenome hook chain "ra-<repo>-<id>":
//   activate on entry → touch(gate, result=pass|fail) → release on flip success.
fn _cmd_advance(repo: string, id: string) -> int {
    let chain = "ra-" + repo + "-" + id
    let _a = _ag_activate(chain, "advance", "roadmap")

    _banner("Phase Gate 100% check — " + repo + "#" + id)
    let gate = _run_tool("roadmap_phase_gate.hexa", "--check " + repo + " " + id)
    if gate[1] != 0 {
        let _t = _ag_touch(chain, "gate", "result=fail")
        let _r = _ag_release(chain, "gate_rejected")
        eprintln("Phase Gate REJECTED — advance blocked (no bypass).")
        eprintln(to_string(gate[0]))
        return 1
    }
    let _t = _ag_touch(chain, "gate", "result=pass")
    println(to_string(gate[0]))
    _banner("Phase Gate 100% PASS — applying status flip")
    let flip = _run_tool("roadmap_status_flip.hexa", "--repo " + repo + " --apply")
    if flip[1] != 0 {
        let _r = _ag_release(chain, "flip_failed")
        eprintln("status flip failed:")
        eprintln(to_string(flip[0]))
        return 1
    }
    println(to_string(flip[0]))
    let sha = _head_sha()
    let _r = _ag_release(chain, "flipped sha=" + sha)
    println("advance complete")
    return 0
}

fn _selftest() -> int {
    // Minimal engine smoke test — runs one cheap sub-tool selftest per
    // critical module. Full cascade is reachable via `status` cmd.
    _banner("Engine selftest — module smoke")
    let mods = ["roadmap_parse.hexa", "roadmap_dag.hexa", "roadmap_critical_path.hexa", "roadmap_parallel.hexa", "roadmap_ready_set.hexa", "roadmap_span_dag.hexa", "roadmap_t_star.hexa", "roadmap_phase_gate.hexa"]
    let mut all_ok = true
    for m in mods {
        let r = _run_tool(m, "--selftest")
        if r[1] != 0 {
            eprintln("  FAIL " + m)
            all_ok = false
        } else {
            println("  OK   " + m)
        }
    }
    if !all_ok {
        eprintln("engine selftest FAIL")
        return 1
    }
    println("engine selftest PASS — 8 modules OK")
    return 0
}

fn main() {
    let av = argv()
    let mut args = []
    let mut i = 2
    while i < len(av) { args.push(av[i]); i = i + 1 }

    if len(args) == 0 {
        exit(_cmd_status())
    }
    let cmd = args[0]

    if cmd == "status" { exit(_cmd_status()) }
    if cmd == "parse" { exit(_cmd_parse()) }
    if cmd == "dag" { exit(_cmd_dag()) }
    if cmd == "critical-path" { exit(_cmd_critical_path()) }
    if cmd == "ready" { exit(_cmd_ready()) }
    if cmd == "day-groups" { exit(_cmd_day_groups()) }
    if cmd == "progress" { exit(_cmd_progress()) }
    if cmd == "invariants" { exit(_cmd_invariants()) }
    if cmd == "t-star" { exit(_cmd_tstar()) }
    if cmd == "selftest" { exit(_selftest()) }

    if cmd == "verify-gates" {
        let mut repo = "anima"
        if len(args) >= 2 { repo = args[1] }
        exit(_cmd_verify_gates(repo))
    }

    if cmd == "--advance" {
        if len(args) < 3 {
            eprintln("usage: --advance <repo> <id>")
            exit(1)
        }
        exit(_cmd_advance(args[1], args[2]))
    }

    // Phase 1-3 automation subcommands (stubs — see
    // docs/roadmap_engine_continuous_meta_proposal_20260422.md).
    if cmd == "blockers" {
        let mut repo = "anima"
        if len(args) >= 2 { repo = args[1] }
        let r = _run_tool("blocker_inventory_scan.hexa", "--repo " + repo)
        println(to_string(r[0]))
        exit(r[1])
    }
    if cmd == "roi" {
        let mut repo = "anima"
        if len(args) >= 2 { repo = args[1] }
        let r = _run_tool("loss_free_roi_scan.hexa", "--repo " + repo)
        println(to_string(r[0]))
        exit(r[1])
    }
    if cmd == "health" {
        let mut repo = "anima"
        if len(args) >= 2 { repo = args[1] }
        let r = _run_tool("roadmap_health_score.hexa", "--repo " + repo)
        println(to_string(r[0]))
        exit(r[1])
    }
    if cmd == "next" {
        let mut repo = "anima"
        if len(args) >= 2 { repo = args[1] }
        let r = _run_tool("roadmap_next_action.hexa", "--repo " + repo)
        println(to_string(r[0]))
        exit(r[1])
    }
    if cmd == "drift" {
        let mut repo = "anima"
        if len(args) >= 2 { repo = args[1] }
        let r = _run_tool("roadmap_drift_detector.hexa", "--repo " + repo)
        println(to_string(r[0]))
        exit(r[1])
    }
    if cmd == "velocity" {
        let mut repo = "anima"
        if len(args) >= 2 { repo = args[1] }
        let r = _run_tool("roadmap_velocity.hexa", "--repo " + repo)
        println(to_string(r[0]))
        exit(r[1])
    }
    if cmd == "deps" {
        let r = _run_tool("roadmap_dep_graph.hexa", "")
        println(to_string(r[0]))
        exit(r[1])
    }
    if cmd == "propose" {
        let mut repo = "anima"
        if len(args) >= 2 { repo = args[1] }
        let r = _run_tool("status_transition_proposer.hexa", "--repo " + repo)
        println(to_string(r[0]))
        exit(r[1])
    }
    if cmd == "release" {
        let mut repo = "anima"
        if len(args) >= 2 { repo = args[1] }
        let r = _run_tool("roadmap_release_plan.hexa", "--repo " + repo)
        println(to_string(r[0]))
        exit(r[1])
    }
    if cmd == "continuous-scan" {
        let r = _run_tool("roadmap_continuous_scan.hexa", "")
        println(to_string(r[0]))
        // commit + push pass-through (2026-04-23 user ask).
        // roadmap_continuous_scan 산출물 (state/roadmap_*.json, inventory 갱신) 을
        // 선택적으로 자동 commit/push. state/ 가 gitignored 인 repo 에서는
        // inventory 만 force-add.
        let mut do_commit = false
        let mut do_push = false
        let mut k = 2
        while k < len(args) {
            if args[k] == "--commit" { do_commit = true }
            if args[k] == "--push"   { do_push = true }
            k = k + 1
        }
        if do_commit {
            let repo_root = env("HOME") + "/core/hexa-lang"
            let inv = repo_root + "/state/proposals/inventory.json"
            let add_cmd = "cd '" + repo_root + "' && git add -f '" + inv + "' 2>&1"
            let _add = exec(add_cmd)
            let any = exec_with_status("cd '" + repo_root + "' && git diff --cached --quiet")
            if any[1] == 1 {
                let msg = "chore(roadmap): continuous-scan sweep (auto)"
                let cr = exec("cd '" + repo_root + "' && git commit -m '" + msg + "' 2>&1 | tail -3")
                println("roadmap_engine: commit → " + to_string(cr).trim())
                if do_push {
                    let pr = exec("cd '" + repo_root + "' && git push 2>&1 | tail -2")
                    println("roadmap_engine: push → " + to_string(pr).trim())
                }
            } else {
                println("roadmap_engine: --commit: no changes")
            }
        }
        exit(r[1])
    }

    eprintln("unknown command: " + cmd)
    eprintln("commands: status | parse | dag | critical-path | ready | day-groups | progress | invariants | t-star | verify-gates <repo> | selftest | --advance <repo> <id>")
    eprintln("          blockers <repo> | roi <repo> | health <repo> | next <repo> | drift <repo> | velocity <repo> | deps | propose <repo> | release <repo> | continuous-scan [--commit] [--push]")
    exit(1)
}
