#!hexa strict
// tool/cmd_go.hexa — `go` command stub
//
// The real `go` (loop harness full-cycle) is driven by the Claude Code
// dispatcher today. This hexa-side command exists so (a) the SSOT schema
// stays complete, (b) shim installers produce a working binary, and
// (c) the native port has a ready skeleton to fill in.

use "tool/commands_loader"

fn main() -> int {
    let cmds = load_commands("shared/config/.commands")
    let c = find_command(cmds, "go")
    if c.name != "" {
        println("go: " + c.description)
    }
    println("go harness delegation is handled by Claude Code loop; hexa native impl pending")
    return 0
}

exit(main())
