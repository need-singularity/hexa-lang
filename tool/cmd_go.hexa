#!hexa strict
// tool/cmd_go.hexa — `go` command stub
//
// The real `go` (loop harness full-cycle) is driven by the Claude Code
// dispatcher today. This hexa-side command exists so (a) the SSOT schema
// stays complete, (b) shim installers produce a working binary, and
// (c) the native port has a ready skeleton to fill in.

use "tool/commands_loader"

@pure
fn _go_stub_label() -> string { return "go" }

fn cmd_selftest() -> int {
    println("[cmd_go selftest]")
    // T1: stub label is stable
    if _go_stub_label() != "go" { println("FAIL: stub label"); return 1 }
    // T2: string concat is well-formed (used by banner line)
    let s = "go: " + "description"
    if s != "go: description" { println("FAIL: concat"); return 1 }
    println("[cmd_go selftest] OK")
    return 0
}

fn main() -> int {
    let av0 = argv()
    if len(av0) > 2 {
        let s0 = av0[2]
        if s0 == "--selftest" || s0 == "selftest" { return cmd_selftest() }
    }
    let cmds = load_commands(".commands")
    let c = find_command(cmds, "go")
    if c.name != "" {
        println("go: " + c.description)
    }
    println("go harness delegation is handled by Claude Code loop; hexa native impl pending")
    return 0
}

exit(main())
