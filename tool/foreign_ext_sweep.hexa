// tool/foreign_ext_sweep.hexa — raw#8 working-tree enforcer.
//
// Companion to tool/hexa_only_lint.hexa (which covers git-staged files only).
// This watcher scans the working tree for NEW .py/.rs/.sh/.toml files and
// removes them — existing git-tracked foreign files are grandfathered
// (rust_baseline bench, emergency scripts, launchd plist launcher).
//
// usage:
//   hexa tool/foreign_ext_sweep.hexa [<root>]           — scan + JSON report, exit 0
//   hexa tool/foreign_ext_sweep.hexa --sweep [<root>]   — rm untracked hits
//   hexa tool/foreign_ext_sweep.hexa --strict [<root>]  — exit 1 on any hit
//
// enforcement model:
//   - launchd (dev.hexa-lang.foreign-ext-sweep.plist, 30s StartInterval)
//     runs --sweep mode continuously → any file Claude Code writes with
//     a banned extension is rm'd within ~30s (post-hoc ms latency).
//   - git-tracked foreign-ext files are LEFT ALONE (untouched). Only
//     untracked violations are swept — safe fallback if this watcher
//     picks up a legit addition during development.
//   - true write-time block would require fanotify (linux) or sandbox-exec
//     (macOS); see native.hexa for that roadmap. This sweep is phase-1
//     OS-level enforcement that works without kernel capabilities.
//
// rule: raw#8 (HEXA-ONLY) — .rs/.toml/.py/.sh 신규 파일 금지.
// SSOT: airgenome/rules/airgenome.json#AG10 + self/attrs/native.hexa.

fn _default_root() -> string {
    return to_string(exec("pwd")).trim()
}

fn _banned_exts() -> array {
    return [".py", ".rs", ".sh", ".toml"]
}

fn _excludes_clause() -> string {
    // Prune hot dirs so the scan stays cheap.
    let parts = [
        "-path '*/.git' -prune",
        "-path '*/.claude' -prune",
        "-path '*/.claude-*' -prune",
        "-path '*/node_modules' -prune",
        "-path '*/target' -prune",
        "-path '*/.hexa-cache' -prune",
        "-path '*/build/deps' -prune",
        "-path '*/archive' -prune",
        "-path '*/hexa.bak*' -prune",
    ]
    let mut s = "\\("
    let mut i = 0
    while i < len(parts) {
        if i > 0 { s = s + " -o " }
        s = s + parts[i]
        i = i + 1
    }
    s = s + " \\)"
    return s
}

fn _name_clause() -> string {
    let exts = _banned_exts()
    let mut s = ""
    let mut i = 0
    while i < len(exts) {
        if i > 0 { s = s + " -o " }
        s = s + "-name '*" + exts[i] + "'"
        i = i + 1
    }
    return s
}

fn _scan(root: string) -> array {
    let excludes = _excludes_clause()
    let names = _name_clause()
    let cmd = "find " + root + " " + excludes + " -o \\( " + names + " \\) -type f -print 2>/dev/null"
    let raw_out = to_string(exec(cmd))
    let lines = split(raw_out, "\n")
    let hits = []
    for ln in lines {
        let t = ln.trim()
        if t == "" { continue }
        hits.push(t)
    }
    return hits
}

// Filter hits to git-untracked only — tracked files are grandfathered.
// Relative-path check via `git ls-files --error-unmatch <path>` (exit 0 = tracked).
fn _untracked(hits: array, root: string) -> array {
    let out = []
    let mut i = 0
    while i < len(hits) {
        let p = hits[i]
        // git ls-files expects path relative to the repo root that resolves
        // the file — let the shell compute it (repo-root-relative) then
        // pass to `git -C <repo>`. A non-git tree is treated as "all
        // untracked" (no git → fatal → treated as untracked).
        let probe = "f='" + p + "'; repo=$(git -C \"$(dirname \"$f\")\" rev-parse --show-toplevel 2>/dev/null); " +
                    "if [ -z \"$repo\" ]; then echo untracked; " +
                    "else rel=${f#$repo/}; git -C \"$repo\" ls-files --error-unmatch \"$rel\" >/dev/null 2>&1 && echo tracked || echo untracked; " +
                    "fi"
        let state = to_string(exec(probe)).trim()
        if state == "untracked" { out.push(p) }
        i = i + 1
    }
    return out
}

fn _sweep(hits: array) -> int {
    let mut removed = 0
    let mut i = 0
    while i < len(hits) {
        let p = hits[i]
        let cmd = "chflags nouchg '" + p + "' 2>/dev/null; rm -f '" + p + "' 2>/dev/null && echo ok || echo fail"
        let r = to_string(exec(cmd)).trim()
        if r == "ok" { removed = removed + 1 }
        i = i + 1
    }
    return removed
}

fn _esc(s: string) -> string {
    let mut r = s.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    return r
}

fn _render(hits: array, mode: string, root: string, removed: int) -> string {
    let mut s = "{\"schema\":\"hexa.foreign_ext_sweep.v1\""
    s = s + ",\"tool\":\"tool/foreign_ext_sweep.hexa\""
    s = s + ",\"rule\":\"raw#8\""
    s = s + ",\"rule_slug\":\"hexa-only\""
    s = s + ",\"mode\":\"" + mode + "\""
    s = s + ",\"root\":\"" + _esc(root) + "\""
    s = s + ",\"violation_count\":" + to_string(len(hits))
    s = s + ",\"removed_count\":" + to_string(removed)
    if len(hits) > 0 {
        s = s + ",\"severity\":\"block\""
        s = s + ",\"error\":{"
        s = s + "\"code\":\"FOREIGN_EXT_UNTRACKED\""
        s = s + ",\"message\":\".py/.rs/.sh/.toml untracked file in working tree. Port to .hexa — Rust/Python/Shell dependencies disallowed outside grandfathered bench + emergency paths.\""
        s = s + ",\"canonical_recovery\":\"rewrite logic in hexa (see self/native/ for FFI shim precedents)\""
        s = s + ",\"how_to_avoid\":\"Claude Write/Edit should refuse these extensions; this sweep catches any that slip through\""
        s = s + ",\"auto_sweep_cmd\":\"hexa tool/foreign_ext_sweep.hexa --sweep\""
        s = s + "}"
    } else {
        s = s + ",\"severity\":\"pass\""
    }
    s = s + ",\"violations\":["
    let mut i = 0
    while i < len(hits) {
        if i > 0 { s = s + "," }
        s = s + "\"" + _esc(hits[i]) + "\""
        i = i + 1
    }
    s = s + "]}"
    return s
}

fn cmd_selftest() -> int {
    println("[foreign_ext_sweep selftest]")
    // pure-fn assertions on banned ext list + json escape
    let exts = _banned_exts()
    if len(exts) != 4 { eprintln("FAIL banned ext count"); return 1 }
    if _esc("a\"b") != "a\\\"b" { eprintln("FAIL _esc quote"); return 1 }
    if _esc("c\\d") != "c\\\\d" { eprintln("FAIL _esc backslash"); return 1 }
    println("[foreign_ext_sweep selftest] OK")
    return 0
}

fn main() -> int {
    let _av_st = args()
    if _av_st.len() > 2 && (_av_st[2] == "--selftest" || _av_st[2] == "selftest") { return cmd_selftest() }
    let argv = args()
    let mut mode = "warn"
    let mut root = ""
    let mut i = 0
    while i < len(argv) {
        let a = argv[i]
        if a == "--sweep" { mode = "sweep" }
        else if a == "--strict" { mode = "strict" }
        else if a == "--warn" { mode = "warn" }
        else if a.ends_with(".hexa") == false && a.starts_with("/") { root = a }
        i = i + 1
    }
    if root == "" { root = _default_root() }

    let all_hits = _scan(root)
    let hits = _untracked(all_hits, root)
    let mut removed = 0
    if mode == "sweep" { removed = _sweep(hits) }

    println(_render(hits, mode, root, removed))

    if mode == "strict" && len(hits) > 0 { return 1 }
    return 0
}
