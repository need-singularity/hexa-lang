// ═══════════════════════════════════════════════════════════════
//  build_hexa_cli_linux.hexa — cross-build the hexa CLI dispatcher
//  (self/main.hexa → build/hexa_linux) for linux/x86_64 from macOS.
//
//  Pairs with build_hexa_v2_linux.hexa:
//    - build_hexa_v2_linux.hexa    transpiler only    (.hexa → .c)
//    - build_hexa_cli_linux.hexa   full CLI driver    (run/build/cc/…)
//
//  Output: self-contained static ELF, drop-in replacement for the
//  Rust /opt/homebrew/bin/hexa driver — closes anima roadmap-67 M5
//  deliverable (hxa-20260423-003 결손-A / 결손-F) on Linux side.
//
//  Usage:
//    hexa tool/build_hexa_cli_linux.hexa [-o build/hexa_linux]
//
//  Env:
//    LINUX_CC      compiler (default x86_64-linux-musl-gcc on Darwin)
//    EXTRA_CFLAGS  append to cflags
//
//  Pipeline:
//    1. self/native/hexa_v2 self/main.hexa build/stage1/main.c
//       (regenerates the stage1 C from the current main.hexa SSOT)
//    2. x86_64-linux-musl-gcc -static -I self build/stage1/main.c → ELF
// ═══════════════════════════════════════════════════════════════

fn run_ok(cmd) {
    let r = exec_with_status(cmd)
    if r[1] != 0 {
        eprintln("FAILED: " + cmd)
        if r[0] != "" { eprintln(r[0]) }
        exit(1)
    }
    r[0]
}

fn main() {
    let args = argv()
    let mut out_path = ""
    let mut ai = 2
    while ai < len(args) {
        let a = args[ai]
        if a == "-o" && (ai + 1) < len(args) {
            ai = ai + 1
            out_path = args[ai]
        }
        ai = ai + 1
    }

    let repo_root = exec_with_status("pwd")[0].trim()
    let uname = exec_with_status("uname -s")[0].trim()

    if out_path == "" {
        out_path = repo_root + "/build/hexa_linux"
    }

    let mut cc = env("LINUX_CC")
    if cc == "" {
        if uname == "Darwin" {
            cc = "x86_64-linux-musl-gcc"
        } else {
            cc = "cc"
        }
    }

    let extra_cflags = env("EXTRA_CFLAGS")
    let hexa_v2 = repo_root + "/self/native/hexa_v2"
    let main_hexa = repo_root + "/self/main.hexa"
    let stage1_c = repo_root + "/build/stage1/main.c"
    let inc = repo_root + "/self"

    println("=== hexa CLI → linux/x86_64 (static ELF) ===")
    println("  source : " + main_hexa)
    println("  stage1 : " + stage1_c)
    println("  output : " + out_path)
    println("  cc     : " + cc)

    if !file_exists(hexa_v2) {
        eprintln("error: self/native/hexa_v2 missing — run tool/build_hexa_v2_linux.hexa or bootstrap first")
        exit(1)
    }
    if !file_exists(main_hexa) {
        eprintln("error: source missing: " + main_hexa)
        exit(1)
    }

    let cc_check = exec_with_status("which " + cc + " 2>/dev/null")
    if cc_check[1] != 0 || cc_check[0].trim() == "" {
        eprintln("error: compiler not found: " + cc)
        eprintln("  brew install FiloSottile/musl-cross/musl-cross")
        exit(1)
    }

    run_ok("mkdir -p " + exec_with_status("dirname '" + out_path + "'")[0].trim())
    run_ok("mkdir -p " + repo_root + "/build/stage1")

    // Step 1: regenerate stage1 C from main.hexa via the host hexa_v2.
    //   Using the host binary (arm64 on macOS) is fine — it's a pure
    //   text-to-text transpile; the output .c is platform-neutral.
    println("")
    println("[1/2] transpile main.hexa → stage1/main.c (host hexa_v2)")
    run_ok(hexa_v2 + " " + main_hexa + " " + stage1_c)

    // Step 2: cross-compile with musl static.
    //   -D_GNU_SOURCE + -std=gnu11 : glibc/musl POSIX+GNU extensions
    //      (strdup/popen/pclose/fopen_w etc. expected by runtime.c)
    //   -static -lm -ldl : self-contained ELF, no runtime deps
    //   -Wno-trigraphs : hexa codegen emits `??` byte patterns in regexes
    let cflags = "-O2 -std=gnu11 -D_GNU_SOURCE -Wno-trigraphs"
    let ldflags = "-static -lm -ldl"
    let cmd = cc + " " + cflags + " " + extra_cflags + " -I " + inc + " " + stage1_c + " -o " + out_path + " " + ldflags
    println("")
    println("[2/2] cross-compile")
    println("  " + cmd)
    run_ok(cmd)

    let file_info = exec_with_status("file " + out_path)[0].trim()
    let size = exec_with_status("wc -c < '" + out_path + "' | tr -d ' '")[0].trim()
    let sha = exec_with_status("shasum -a 256 " + out_path + " | awk '{print $1}'")[0].trim()

    println("")
    println("=== BUILD OK ===")
    println("  path   : " + out_path)
    println("  size   : " + size + " bytes")
    println("  sha256 : " + sha)
    println("  file   : " + file_info)
    println("")
    println("deploy (replaces anima tool/hexa_linux_shim.bash):")
    println("  scp " + out_path + " root@<pod>:/opt/hexa/bin/hexa")
    println("  ssh root@<pod> 'chmod +x /opt/hexa/bin/hexa && /opt/hexa/bin/hexa version'")
    println("")
    println("smoke on pod:")
    println("  echo 'fn main() { println(\"hello from linux\") }' > /tmp/hi.hexa")
    println("  /opt/hexa/bin/hexa run /tmp/hi.hexa")
}
