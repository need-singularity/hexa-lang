// build_hxqwen14b_linux.hexa — build libhxqwen14b.so on Linux (H100 pod)
// OR run a syntactic/link cross-verify on Mac before push.
//
// Companion to build_hxlmhead_linux.hexa / build_hxflash_linux.hexa /
// build_hxccl_linux.hexa. Same flag layout, same --mac-xverify /
// --mac-native contract, so H100 operators do not have to learn a new
// recipe.
//
// v0 STATUS: SKELETON. Builds the stub shim against libm only (no CUDA
// linked by default) so the symbol surface can be verified end-to-end.
// Set HXQWEN14B_CUDA=1 to enable the real CUDA + cuBLAS path once
// Day-1 kernels are in place.
//
// Prerequisites (Linux stub build, runpod/pytorch:2.4.0 image):
//   apt install gcc
//
// Prerequisites (Linux CUDA build, HXQWEN14B_CUDA=1):
//   apt install gcc
//   CUDA 11.8 toolkit at /usr/local/cuda-11.8
//
// Prerequisites (Mac cross-verify):
//   Xcode command line tools
//
// Usage:
//   hexa tool/build_hxqwen14b_linux.hexa                   // stub Linux build
//   hexa tool/build_hxqwen14b_linux.hexa --debug           // -O0 -g stub
//   HXQWEN14B_CUDA=1 hexa tool/build_hxqwen14b_linux.hexa  // real CUDA path
//   hexa tool/build_hxqwen14b_linux.hexa --mac-xverify     // syntactic on Mac
//   hexa tool/build_hxqwen14b_linux.hexa --mac-native      // Mac .dylib stub
//   CC=clang hexa tool/build_hxqwen14b_linux.hexa          // swap compiler
//   DEPLOY=/usr/local/lib hexa tool/build_hxqwen14b_linux.hexa  // install
//
// Outputs (Linux mode):
//   self/native/build/libhxqwen14b.so
//
// Outputs (--mac-xverify mode):
//   self/native/build/xverify/libhxqwen14b_xverify.dylib
//
// Outputs (--mac-native mode):
//   self/native/build/libhxqwen14b.dylib

fn run(cmd) {
    let result = exec_with_status(cmd)
    if result[1] != 0 {
        eprintln("FAILED: " + cmd)
        exit(1)
    }
    result[0]
}

fn check_symbol_gU(lib_path, sym) {
    let result = exec_with_status("nm -gU " + lib_path + " | grep -q '" + sym + "'")
    if result[1] == 0 {
        println("  " + sym + " SYMBOL=PRESENT")
        true
    } else {
        eprintln("  " + sym + " SYMBOL=MISSING")
        false
    }
}

fn check_symbol_D(lib_path, sym) {
    let result = exec_with_status("nm -D " + lib_path + " 2>/dev/null | grep -q ' " + sym + "'")
    if result[1] == 0 {
        println("  " + sym + " SYMBOL=PRESENT")
        true
    } else {
        eprintln("  " + sym + " SYMBOL=MISSING (nm -D failed; check ldd/readelf)")
        false
    }
}

fn cmd_selftest() -> i64 {
    println("[build_hxqwen14b_linux selftest]")
    let mut fails = 0

    // T1: v5 symbol list must contain the core 5 base symbols
    let syms = ["hxqwen14b_load", "hxqwen14b_generate", "hxqwen14b_version",
                "hxqwen14b_smoke_v5", "hxqwen14b_smoke_v54"]
    if len(syms) != 5 { eprintln("  FAIL T1 len"); fails = fails + 1 }
    else if syms[2] != "hxqwen14b_version" { eprintln("  FAIL T1 sym[2]"); fails = fails + 1 }
    else { println("  OK   T1 core symbol list") }

    // T2: CUDA_HOME fallback literal chain
    let cuda_env = ""
    let cuda_home = if cuda_env != "" { cuda_env } else { "/usr/local/cuda" }
    if cuda_home != "/usr/local/cuda" { eprintln("  FAIL T2"); fails = fails + 1 }
    else { println("  OK   T2 CUDA_HOME fallback") }

    // T3: --mac-xverify branch string
    let mode = "--mac-xverify"
    if mode != "--mac-xverify" { eprintln("  FAIL T3"); fails = fails + 1 }
    else { println("  OK   T3 --mac-xverify mode") }

    if fails != 0 { return 1 }
    println("[build_hxqwen14b_linux selftest] OK")
    return 0
}

fn main() {
    let args = argv()
    let mut _sti = 2
    while _sti < len(args) {
        if args[_sti] == "--selftest" || args[_sti] == "selftest" {
            exit(cmd_selftest())
        }
        _sti = _sti + 1
    }
    let hexa_dir = exec("cd \"$(dirname '" + args[1] + "')/../\" && pwd").trim()
    let src_dir = hexa_dir + "/self/native"
    let out_dir = hexa_dir + "/self/native/build"
    let cc = if env("CC") != "" { env("CC") } else { "gcc" }
    let mode = if len(args) > 2 { args[2] } else { "build" }
    // Pod image runpod/pytorch:2.4.0-py3.11-cuda12.4.1 ships nvcc 12.4 at
    // /usr/local/cuda (→ cuda-12.4 symlink). Fall through to legacy 11.8
    // only if neither CUDA_HOME nor /usr/local/cuda exists.
    let cuda_home = if env("CUDA_HOME") != "" { env("CUDA_HOME") }
                    else if file_exists("/usr/local/cuda") { "/usr/local/cuda" }
                    else { "/usr/local/cuda-11.8" }

    exec("mkdir -p " + out_dir)

    // v5 symbol surface: v4 (12) + Day-2 standalone kernels (4) = 16
    //   Day-2 adds per-adapter LoRA fwd/bwd + frozen base GEMM (cuBLAS on
    //   device, CPU reference on host) + smoke_v5 self-test driver.
    // v5.2 Day-3: CPU reference attn (rmsnorm/rope/gqa/swiglu) +1 smoke
    // v5.3       : CUDA dispatch wrappers for the 4 kernels +1 smoke
    // v5.4 (2026-04-20): real 48-layer base forward + tied lm_head + CE +
    //                    weight-orchestrator (load_all_weights). Adds 5
    //                    extern symbols + 1 v54 version probe.
    let symbols = [
        "hxqwen14b_load",
        "hxqwen14b_generate",
        "hxqwen14b_compute_phi_holo",
        "hxqwen14b_free",
        "hxqwen14b_version",
        "hxqwen14b_forward_with_lora",
        "hxqwen14b_backward_lora_only",
        "hxqwen14b_apply_lora_delta",
        "hxqwen14b_lora_init_A",
        "hxqwen14b_lora_init_B",
        "hxqwen14b_adamw_step_cpu",
        "hxqwen14b_safetensors_probe",
        "hxqwen14b_lora_fwd_single",
        "hxqwen14b_lora_bwd_single",
        "hxqwen14b_base_gemm",
        "hxqwen14b_smoke_v5",
        // v5.2 / v5.3 attention kernel surface
        "hxqwen14b_rmsnorm_fwd",
        "hxqwen14b_rope_fwd",
        "hxqwen14b_gqa_attn_fwd",
        "hxqwen14b_swiglu_fwd",
        "hxqwen14b_smoke_v52",
        "hxqwen14b_rmsnorm_fwd_v53",
        "hxqwen14b_rope_fwd_v53",
        "hxqwen14b_gqa_attn_fwd_v53",
        "hxqwen14b_swiglu_fwd_v53",
        "hxqwen14b_smoke_v53",
        "hxqwen14b_version_v53",
        "hxqwen14b_shard_tensor_info",
        // v5.4 — full 48-layer base forward + weight orchestrator + CE
        "hxqwen14b_version_v54",
        "hxqwen14b_load_all_weights",
        "hxqwen14b_base_forward_v54",
        "hxqwen14b_ce_loss_v54",
        "hxqwen14b_smoke_v54",
        "hxqwen14b_free_all_weights_v54"
    ]
    // v5.4 CUDA-only symbols (only present when nvcc TU is linked, i.e.,
    // HXQWEN14B_CUDA=1 Linux build). Mac stub paths skip this list.
    let cuda_symbols = [
        "hxqwen14b_cu_launch_rmsnorm",
        "hxqwen14b_cu_launch_rope",
        "hxqwen14b_cu_launch_gqa",
        "hxqwen14b_cu_launch_swiglu",
        "hxqwen14b_cu_launch_bf16_to_fp32",
        "hxqwen14b_cu_launch_embed_lookup",
        "hxqwen14b_cu_launch_residual_add",
        "hxqwen14b_cu_launch_add_bias_1d",
        "hxqwen14b_cu_launch_sgemm_rowmajor_xwt",
        "hxqwen14b_cu_launch_tied_lm_head",
        "hxqwen14b_cu_launch_softmax_ce",
        "hxqwen14b_cu_malloc_bytes",
        "hxqwen14b_cu_free_ptr",
        "hxqwen14b_cu_memcpy_h2d",
        "hxqwen14b_cu_memcpy_d2h",
        "hxqwen14b_cu_device_sync",
        "hxqwen14b_cu_cublas_destroy"
    ]

    // ────────────────────────────────────────────────────────────────
    // --mac-xverify : compile on Mac to validate the Linux source is
    // syntactically clean BEFORE committing or pushing to the H100 pod.
    // Stub path only — no CUDA on Mac, so HXQWEN14B_CUDA is ignored here.
    // ────────────────────────────────────────────────────────────────
    if mode == "--mac-xverify" {
        let uname = exec("uname -s").trim()
        if uname != "Darwin" {
            eprintln("--mac-xverify requires macOS, got " + uname)
            exit(2)
        }
        let xv_dir = out_dir + "/xverify"
        exec("mkdir -p " + xv_dir)
        let cc_x = if env("CC") != "" { env("CC") } else { "clang" }
        println("[xverify] linking hxqwen14b.c -> libhxqwen14b_xverify.dylib (stub, no CUDA)")
        run(cc_x + " -O3 -fPIC -dynamiclib " + src_dir + "/hxqwen14b.c -lm -o " + xv_dir + "/libhxqwen14b_xverify.dylib")

        for sym in symbols {
            if !check_symbol_gU(xv_dir + "/libhxqwen14b_xverify.dylib", "_" + sym) {
                exit(4)
            }
        }
        println("── xverify output ──")
        println(exec("ls -la " + xv_dir + "/libhxqwen14b_xverify.dylib").trim())
        println("done — Linux source compiles + links on Mac; ready to push")
        exit(0)
    }

    // ────────────────────────────────────────────────────────────────
    // --mac-native : build libhxqwen14b.dylib on Mac for ABI smoke tests
    // by ./hexa (interpreter) from ~/Dev/hexa-lang. Stub path only — no
    // CUDA on Mac, so real generation always returns -4 here.
    // ────────────────────────────────────────────────────────────────
    if mode == "--mac-native" {
        let uname = exec("uname -s").trim()
        if uname != "Darwin" {
            eprintln("--mac-native requires macOS, got " + uname)
            exit(2)
        }
        let cc_m = if env("CC") != "" { env("CC") } else { "clang" }
        println("[mac-native] building libhxqwen14b.dylib (stub, no CUDA)")
        run(cc_m + " -O3 -fPIC -dynamiclib " + src_dir + "/hxqwen14b.c -lm -o " + out_dir + "/libhxqwen14b.dylib")

        for sym in symbols {
            if !check_symbol_gU(out_dir + "/libhxqwen14b.dylib", "_" + sym) {
                exit(4)
            }
        }
        println("── mac-native output ──")
        println(exec("ls -la " + out_dir + "/libhxqwen14b.dylib").trim())
        println("done — load with DYLD_LIBRARY_PATH=" + out_dir)
        exit(0)
    }

    // ────────────────────────────────────────────────────────────────
    // Normal build mode — Linux only.
    // ────────────────────────────────────────────────────────────────
    let uname = exec("uname -s").trim()
    if uname != "Linux" {
        eprintln("build_hxqwen14b_linux: expected Linux for normal build, got " + uname)
        eprintln("  - On Linux:        hexa tool/build_hxqwen14b_linux.hexa")
        eprintln("  - CUDA (H100):     HXQWEN14B_CUDA=1 hexa tool/build_hxqwen14b_linux.hexa")
        eprintln("  - On Mac xverify:  hexa tool/build_hxqwen14b_linux.hexa --mac-xverify")
        eprintln("  - Mac live stub:   hexa tool/build_hxqwen14b_linux.hexa --mac-native")
        exit(2)
    }

    let mut cflags_base = "-O3 -fPIC -shared -march=native"
    if mode == "--debug" {
        cflags_base = "-O0 -g -fPIC -shared"
    }

    // ── libhxqwen14b.so ─────────────────────────────────────────────
    if env("HXQWEN14B_CUDA") == "1" {
        // v5.4 real CUDA path — cuBLAS + bf16 Tensor Core + 48-layer fwd.
        // Two TUs:
        //   hxqwen14b.c       — gcc (host control flow + cuBLAS Sgemm calls)
        //   hxqwen14b_cuda.cu — nvcc (CUDA kernels: rmsnorm/rope/gqa/swiglu
        //                       /embed_lookup/residual_add/bias_1d/softmax_ce
        //                       /bf16_to_fp32/sgemm wrapper/tied_lm_head)
        // Linked together via gcc -shared into libhxqwen14b.so. nvcc is
        // used in -c mode only (compile, not link) so cuBLAS and cudart
        // are linked at the gcc step, keeping the recipe simple.
        if !file_exists(cuda_home) {
            eprintln("[ERROR] HXQWEN14B_CUDA=1 but CUDA_HOME=" + cuda_home + " not found")
            eprintln("  Override with CUDA_HOME=/path/to/cuda")
            exit(3)
        }
        let nvcc = if env("NVCC") != "" { env("NVCC") } else { cuda_home + "/bin/nvcc" }
        if !file_exists(nvcc) {
            eprintln("[ERROR] nvcc not found at " + nvcc)
            eprintln("  Set NVCC=/path/to/nvcc or ensure CUDA_HOME points at a SDK")
            exit(3)
        }
        // CUDA TU exists?
        if !file_exists(src_dir + "/hxqwen14b_cuda.cu") {
            eprintln("[ERROR] expected " + src_dir + "/hxqwen14b_cuda.cu but file missing")
            exit(3)
        }

        let host_obj = out_dir + "/hxqwen14b.host.o"
        let cuda_obj = out_dir + "/hxqwen14b_cuda.cu.o"

        // H100 = sm_90; A100 = sm_80; pass both for portability across pods.
        // Allow override via NVCC_ARCH env.
        let nvcc_arch = if env("NVCC_ARCH") != "" { env("NVCC_ARCH") }
                        else { "-gencode arch=compute_80,code=sm_80 -gencode arch=compute_90,code=sm_90" }

        println("[1/3] compiling hxqwen14b.c → " + host_obj + " (gcc -DHXQWEN14B_CUDA)")
        // -fPIC -c (no -shared) — produces a relocatable host object.
        let host_cflags = if mode == "--debug" { "-O0 -g -fPIC -c" }
                          else { "-O3 -fPIC -c -march=native" }
        run(cc + " " + host_cflags + " -DHXQWEN14B_CUDA -I" + cuda_home + "/include " +
            src_dir + "/hxqwen14b.c -o " + host_obj)

        println("[2/3] compiling hxqwen14b_cuda.cu → " + cuda_obj + " (nvcc)")
        // -Xcompiler -fPIC so the resulting object can be linked into a .so.
        // -lineinfo lets cuda-gdb / nsight map back to source.
        let nvcc_flags = if mode == "--debug" { "-O0 -g -G -Xcompiler -fPIC -c" }
                         else { "-O3 -Xcompiler -fPIC -c -lineinfo" }
        run(nvcc + " " + nvcc_flags + " " + nvcc_arch + " " +
            src_dir + "/hxqwen14b_cuda.cu -o " + cuda_obj)

        println("[3/3] linking libhxqwen14b.so (gcc -shared, cudart + cublas)")
        run(cc + " -shared -fPIC " + host_obj + " " + cuda_obj +
            " -L" + cuda_home + "/lib64 -lcudart -lcublas -lm" +
            " -o " + out_dir + "/libhxqwen14b.so")
    } else {
        // v0 stub path — no CUDA linked. Symbol surface only.
        println("[1/1] building libhxqwen14b.so (stub path — no CUDA)")
        run(cc + " " + cflags_base + " " + src_dir + "/hxqwen14b.c -o " + out_dir + "/libhxqwen14b.so -lm")
    }

    for sym in symbols {
        check_symbol_D(out_dir + "/libhxqwen14b.so", sym)
    }
    if env("HXQWEN14B_CUDA") == "1" {
        println("── checking CUDA-only symbols (extern from hxqwen14b_cuda.cu) ──")
        for sym in cuda_symbols {
            check_symbol_D(out_dir + "/libhxqwen14b.so", sym)
        }
        // Also probe for the actual cudart launch symbol — the watchdog
        // (anima/training/r11_ffi_watchdog.hexa) keys off this to detect
        // a real CUDA-linked .so vs the stub.
        let probe = exec_with_status("nm -D " + out_dir + "/libhxqwen14b.so 2>/dev/null | grep -E 'cudaLaunchKernel|cuLaunchKernel' | head -1")
        if probe[1] == 0 {
            println("  cudaLaunchKernel SYMBOL=PRESENT (watchdog probe will pass)")
        } else {
            eprintln("  cudaLaunchKernel SYMBOL=MISSING (watchdog will retry forever)")
        }
    }

    println("built:")
    println(exec("ls -la " + out_dir + "/libhxqwen14b.so").trim())

    // ── Optional: deploy to system lib path ─────────────────────────
    let deploy = env("DEPLOY")
    if deploy != "" {
        println("deploying to " + deploy)
        run("cp " + out_dir + "/libhxqwen14b.so " + deploy + "/")
        exec_with_status("command -v ldconfig >/dev/null && ldconfig")
    }

    println("done — set LD_LIBRARY_PATH=" + out_dir + " (or DEPLOY=/usr/local/lib)")
}

