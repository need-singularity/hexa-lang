#!hexa lax
// rebuild_stage0.hexa — safe wrapper around build_stage0.hexa with layered cache
//
// WHY: 이번 세션(2026-04-15)에서 stage0 재빌드가 5~10초마다 반복되어
//   flatten_imports -> hexa_v2 -> clang -> cc1 -> linker 6-8 child x 누적
//   -> macOS xpcproxy 폭주 -> system load 24->112. 근본 원인:
//   (1) 동시 claude 세션 다중 재빌드
//   (2) 입력 변경 없이도 매번 풀 파이프라인 실행
//   (3) 재빌드마다 smoke test 또 스폰
//
// 이 wrapper 가 해결:
//   - mkdir lock (atomic, macOS-safe) -> 동시 재빌드 차단
//   - LAYERED CONTENT CACHE (2026-04-16) — 각 파이프라인 단계 독립 fingerprint:
//       * flatten/<key>.hexa   key = sha256(flatten_imports + hexa_full + 모든 `use` 의존 .hexa)
//       * transpile/<key>.c    key = sha256(flatten_key + hexa_v2 바이너리)
//       * link/<key>.bin       key = sha256(transpile_key + runtime.c + CFLAGS + LDFLAGS + uname)
//     -> touch 없으면 cache hit 복사 (clang/hexa_v2 모두 skip), 단일 stage 변경 시 해당 stage 부터 재실행.
//   - NO_SMOKE 기본 on -> smoke 스폰 제거 (호출측이 필요하면 본인 테스트 1회)
//   - 실패 시 lock 자동 해제
//
// 사용:
//   ./hexa tool/rebuild_stage0.hexa               # layered cache + per-file incremental
//   FORCE=1 ./hexa tool/rebuild_stage0.hexa       # 캐시 무시 강제 rebuild
//   WITH_SMOKE=1 ./hexa tool/rebuild_stage0.hexa  # smoke test 포함
//   NO_CACHE=1 ./hexa tool/rebuild_stage0.hexa    # 캐시 read/write 전체 비활성 (legacy 경로)
//
// 캐시 레이아웃 (HEXA_CACHE_DIR, 기본값 /tmp/hexa-cache):
//   flatten/
//     <hash>.hexa            flatten_imports 산출물
//     <hash>.key             (디버그용) 키 구성 요소 메타
//   transpile/
//     <hash>.c               hexa_v2 트랜스파일 산출물
//     <hash>.key
//   link/
//     <hash>.bin             clang 링크 결과 (최종 stage0)
//     <hash>.key
//   meta/
//     last_build.json        마지막 빌드의 키 체인 + 통계 (hit/miss)
//   file_hashes.manifest     per-file sha256 for incremental diff
//
// 반환 코드:
//   0 — rebuilt or cache hit
//   1 — build failed
//   2 — another session holds the lock (caller should wait or abort)

// ── Helper functions ──────────────────────────────────────────

fn sha256_cmd_name() {
    let check = exec_with_status("command -v shasum >/dev/null 2>&1")
    if check[1] == 0 {
        "shasum -a 256"
    } else {
        "sha256sum"
    }
}

fn hash_of_files(file_paths) {
    // Concat files in order, pipe to sha256, strip filename
    // NOTE: parts.push() returns a NEW array in HEXA — must rebind via `let mut`.
    // Previously: `let parts = []` + `parts.push(...)` silently discarded inputs,
    // making files_str empty and the link_key insensitive to runtime.c changes.
    let mut parts = []
    let mut idx = 0
    while idx < len(file_paths) {
        parts = parts.push(file_paths[idx])
        idx = idx + 1
    }
    let files_str = parts.join(" ")
    exec("cat " + files_str + " 2>/dev/null | " + sha256_cmd_name() + " | cut -d' ' -f1").trim()
}

fn hash_of_file(fpath) {
    exec(sha256_cmd_name() + " < " + fpath + " 2>/dev/null | cut -d' ' -f1").trim()
}

fn hash_of_strings(strs) {
    // Hash a sequence of strings joined by newlines
    // Same .push() rebind requirement as hash_of_files — see note above.
    let mut parts = []
    let mut idx = 0
    while idx < len(strs) {
        parts = parts.push(strs[idx])
        idx = idx + 1
    }
    let joined = parts.join("\\n")
    exec("printf '%s\\n' " + joined + " | " + sha256_cmd_name() + " | cut -d' ' -f1").trim()
}

fn hash_of_strings_safe(strs) {
    // Write strings to a temp file then hash, avoiding shell quoting issues
    let tmpf = exec("mktemp /tmp/hx_hash_input.XXXXXX").trim()
    let mut parts = []
    let mut idx = 0
    while idx < len(strs) {
        parts = parts.push(strs[idx])
        idx = idx + 1
    }
    let content = parts.join("\n") + "\n"
    write_file(tmpf, content)
    let h = exec(sha256_cmd_name() + " < " + tmpf + " | cut -d' ' -f1").trim()
    exec("rm -f " + tmpf)
    h
}

fn cleanup_lock(lock_dir) {
    exec("rm -rf " + lock_dir + " 2>/dev/null")
    exec("rm -rf /tmp/hexa_flatten.lock 2>/dev/null")
}

// ── POC dispatcher auto-regen ──────────────────────────────────
// self/poc/_dispatch.hexa is generated by tool/poc_gen_dispatch.hexa from
// handlers under self/poc/{expr,stmt,builtin}/*.hexa. If any handler is newer
// than _dispatch.hexa (or FORCE=1 / _dispatch.hexa missing), regenerate.
// Runs BEFORE flatten_imports so downstream fingerprints naturally pick up
// the refreshed content.
//
// Returns true if regen happened (or was skipped cleanly), false on failure.
// On failure the caller should cleanup_lock + exit(1).
fn poc_dispatch_needs_regen(hexa_dir) {
    let dispatch_path = hexa_dir + "/self/poc/_dispatch.hexa"
    if !file_exists(dispatch_path) { return true }
    if env("FORCE") != "" { return true }
    // Find newest mtime across all handler files in expr/stmt/builtin.
    // Uses find+stat; if dispatch mtime < any handler mtime -> regen.
    let cmd = "find " + hexa_dir + "/self/poc/expr " + hexa_dir + "/self/poc/stmt " + hexa_dir + "/self/poc/builtin -name '*.hexa' -newer " + dispatch_path + " -print 2>/dev/null | head -1"
    let newer = exec(cmd).trim()
    if newer != "" { return true }
    return false
}

fn poc_regen_dispatch(hexa_dir, lock_dir) {
    let gen_script = hexa_dir + "/tool/poc_gen_dispatch.hexa"
    if !file_exists(gen_script) {
        // Gen script missing — nothing to do (not fatal).
        return
    }
    println("[rebuild_stage0] poc_dispatch: regenerating self/poc/_dispatch.hexa")
    // Run via the same interpreter convention used elsewhere in this file:
    // ./hexa <script>. cd into hexa_dir so relative paths ("self/poc/...")
    // inside poc_gen_dispatch.hexa resolve correctly.
    let gen_cmd = "cd " + hexa_dir + " && ./hexa " + gen_script
    let gen_result = exec_with_status(gen_cmd)
    if gen_result[1] != 0 {
        eprintln("[rebuild_stage0] poc_gen_dispatch FAILED (exit=" + str(gen_result[1]) + ")")
        eprintln("  stdout/stderr:")
        eprintln(gen_result[0])
        cleanup_lock(lock_dir)
        exit(1)
    }
}

// ── Sanity check: run a trivial program through the freshly built stage0
// and verify that output matches exactly what we expect. If it doesn't,
// roll back from `backup_path` (if it still exists) and exit(1).
// This catches "compiles but produces garbled output" bugs that slipped past
// the size guard (e.g. duplicated println, broken int_to_string, corrupt concat).
//
// Returns normally on success; calls exit(1) on failure.
// Side-effect: leaves /tmp/hx_sanity.{hexa,out} for post-mortem inspection.
fn sanity_check_stage0(out_path, backup_path, uname) {
    let sanity_hexa = "/tmp/hx_sanity.hexa"
    let sanity_out = "/tmp/hx_sanity.out"
    let sanity_src = "println(\"ok\")\nprintln(40+2)\n"
    write_file(sanity_hexa, sanity_src)
    exec("rm -f " + sanity_out)
    // Run subprocess, capture stdout+stderr to file. Timeout defense: 10s.
    // Use a POSIX-portable bounded wait (perl) since `timeout` is not on
    // default macOS and `gtimeout` may be absent.
    let run_cmd = out_path + " " + sanity_hexa + " > " + sanity_out + " 2>&1"
    // Bounded execution: background the sanity run, kill after 10s if it hangs.
    // Wrapped in `sh -c '...'` so all the backgrounding lives in a child shell.
    let guarded = "sh -c '( " + run_cmd + " ) & pid=$!; ( sleep 10 && kill -9 $pid 2>/dev/null ) & watcher=$!; wait $pid 2>/dev/null; rc=$?; kill $watcher 2>/dev/null; wait $watcher 2>/dev/null; exit $rc'"
    let run_result = exec_with_status(guarded)
    let rc = run_result[1]
    let mut got = ""
    if file_exists(sanity_out) {
        got = read_file(sanity_out)
    }
    // Accept either "ok\n42\n" or "ok\n42" (trailing newline optional).
    let expected_a = "ok\n42\n"
    let expected_b = "ok\n42"
    let pass = rc == 0 && (got == expected_a || got == expected_b)
    if pass {
        println("[rebuild_stage0] sanity: OK (ok/42)")
        return
    }
    // FAIL — print diagnostic
    eprintln("[rebuild_stage0] SANITY FAIL — rebuilt binary produced wrong output")
    eprintln("  command : " + out_path + " " + sanity_hexa)
    eprintln("  exit    : " + str(rc))
    eprintln("  expected: \"ok\\n42\\n\" (or without trailing newline)")
    eprintln("  got     : [" + got + "]")
    eprintln("  bytes   : " + str(len(got)))
    // Roll back
    if backup_path == "" {
        eprintln("[rebuild_stage0] sanity: no backup available (first-ever build?) — leaving broken binary in place for debug")
    } else if !file_exists(backup_path) {
        eprintln("[rebuild_stage0] sanity: backup " + backup_path + " missing — cannot roll back")
    } else {
        exec("cp -f " + backup_path + " " + out_path)
        if uname == "Darwin" {
            let cs = exec_with_status("command -v codesign >/dev/null 2>&1")
            if cs[1] == 0 {
                exec_with_status("codesign --force --sign - " + out_path + " 2>/dev/null")
            }
        }
        eprintln("[rebuild_stage0] sanity: rolled back to " + backup_path)
    }
    exit(1)
}

// ── Per-file manifest helpers ──────────────────────────────────
fn write_manifest(manifest_path, file_paths) {
    // Write sorted "hash  path" lines
    exec("mkdir -p \"$(dirname '" + manifest_path + "')\"")
    let mut parts = []
    let mut idx = 0
    while idx < len(file_paths) {
        let fpath = file_paths[idx]
        if file_exists(fpath) {
            let h = hash_of_file(fpath)
            parts = parts.push(h + "  " + fpath)
        }
        idx = idx + 1
    }
    let content = parts.join("\n") + "\n"
    write_file(manifest_path, content)
}

// Compare current file hashes against the stored manifest.
// Returns: [changed_files_array, changed_categories_string, any_changed_bool]
fn diff_manifest(manifest_path, file_paths) {
    let mut changed_files = []
    let mut cat_parts = []
    let mut any_changed = false

    if !file_exists(manifest_path) {
        // No manifest = treat everything as changed
        let mut idx = 0
        while idx < len(file_paths) {
            changed_files = changed_files.push(file_paths[idx])
            idx = idx + 1
        }
        return [changed_files, "hexa,runtime,tool", true]
    }

    let manifest_content = read_file(manifest_path)
    let manifest_lines = manifest_content.split("\n")

    let mut idx = 0
    while idx < len(file_paths) {
        let fpath = file_paths[idx]
        if file_exists(fpath) {
            let cur_hash = hash_of_file(fpath)
            // Look up stored hash for this file
            let mut stored_hash = ""
            let mut li = 0
            while li < len(manifest_lines) {
                let line = manifest_lines[li]
                if line.contains(fpath) {
                    let line_parts = line.split("  ")
                    if len(line_parts) >= 2 && line_parts[1] == fpath {
                        stored_hash = line_parts[0]
                    }
                }
                li = li + 1
            }
            if cur_hash != stored_hash {
                changed_files = changed_files.push(fpath)
                any_changed = true
                // Categorize the change
                if fpath.ends_with("/runtime.c") {
                    cat_parts = cat_parts.push("runtime")
                } else if fpath.ends_with("/flatten_imports.hexa") {
                    cat_parts = cat_parts.push("tool")
                } else if fpath.ends_with(".hexa") {
                    cat_parts = cat_parts.push("hexa")
                } else {
                    cat_parts = cat_parts.push("other")
                }
            }
        }
        idx = idx + 1
    }
    let categories = cat_parts.join(",")
    [changed_files, categories, any_changed]
}

// ── Discover transitive `use` imports from hexa_full.hexa ──────
fn discover_use_imports(root_path) {
    let mut queue = [root_path]
    let mut seen = [root_path]
    // O(1) lookup via pipe-delimited string set (기존 O(n²) 선형 탐색 대체)
    let mut seen_str = "|" + root_path + "|"
    let mut qi = 0
    while qi < len(queue) {
        let cur = queue[qi]
        qi = qi + 1
        if !file_exists(cur) {
            // skip missing
        } else {
            let dir = exec("cd \"$(dirname '" + cur + "')\" && pwd").trim()
            // Extract `use "name"` lines
            let grep_out = exec_with_status("grep -E '^use \"' " + cur + " 2>/dev/null")
            if grep_out[1] == 0 {
                let dep_lines = grep_out[0].trim().split("\n")
                let mut di = 0
                while di < len(dep_lines) {
                    let dep_line = dep_lines[di]
                    if dep_line.contains("use \"") {
                        let after_use = dep_line.split("\"")
                        if len(after_use) >= 2 {
                            let dep_name = after_use[1]
                            let cand = dir + "/" + dep_name + ".hexa"
                            if file_exists(cand) {
                                let needle = "|" + cand + "|"
                                if seen_str.index_of(needle) < 0 {
                                    seen = seen.push(cand)
                                    queue = queue.push(cand)
                                    seen_str = seen_str + cand + "|"
                                }
                            }
                        }
                    }
                    di = di + 1
                }
            }
        }
    }
    // Sort for determinism
    let sorted_str = exec("printf '%s\\n' " + seen.join(" ") + " | sort -u").trim()
    sorted_str.split("\n")
}

// ══════════════════════════════════════════════════════════════
// MAIN
// ══════════════════════════════════════════════════════════════

let _av = argv()
let script_path = _av[1]
let hexa_dir = exec("cd \"$(dirname '" + script_path + "')/../\" && pwd").trim()
let out = hexa_dir + "/build/hexa_stage0"
let lock_dir = "/tmp/hexa_rebuild_stage0.lock"
let lock_ttl_sec = 300
let cache_dir = if env("HEXA_CACHE_DIR") != "" { env("HEXA_CACHE_DIR") } else { "/tmp/hexa-cache" }
let cache_flatten_dir = cache_dir + "/flatten"
let cache_transpile_dir = cache_dir + "/transpile"
let cache_link_dir = cache_dir + "/link"
let cache_meta_dir = cache_dir + "/meta"

// ── 1. Lock 획득 (atomic mkdir) ─────────────────────────────
let lock_result = exec_with_status("mkdir " + lock_dir + " 2>/dev/null")
if lock_result[1] != 0 {
    let mut holder_pid = ""
    let mut holder_time = "0"
    if file_exists(lock_dir + "/pid") {
        holder_pid = exec("cat " + lock_dir + "/pid 2>/dev/null || echo '?'").trim()
    }
    let dir_check = exec_with_status("test -d " + lock_dir)
    if dir_check[1] == 0 {
        // macOS stat vs GNU stat 호환
        holder_time = exec("stat -f %m " + lock_dir + " 2>/dev/null || stat -c %Y " + lock_dir + " 2>/dev/null || echo 0").trim()
    }
    let now = to_int(exec("date +%s").trim())
    let ht_int = to_int(holder_time)
    let age = now - ht_int

    let alive_check = exec_with_status("kill -0 " + holder_pid + " 2>/dev/null")
    if holder_pid != "" && alive_check[1] == 0 && age < lock_ttl_sec {
        eprintln("[rebuild_stage0] another session is building (pid=" + holder_pid + ", age=" + str(age) + "s) — abort")
        exit(2)
    }

    // stale: holder 죽음 OR TTL 초과 -> 회수
    eprintln("[rebuild_stage0] stale lock (pid=" + holder_pid + ", age=" + str(age) + "s) — reclaiming")
    exec("rm -rf " + lock_dir)
    exec("mkdir " + lock_dir)
}
exec("echo $$ > " + lock_dir + "/pid")

// ── 1b. POC dispatcher auto-regen ─────────────────────────────
// Keep self/poc/_dispatch.hexa in sync with handler files under
// self/poc/{expr,stmt,builtin}/. Runs BEFORE flatten so the layered
// content cache (flatten_key) naturally picks up refreshed content.
if poc_dispatch_needs_regen(hexa_dir) {
    poc_regen_dispatch(hexa_dir, lock_dir)
} else {
    println("[rebuild_stage0] poc_dispatch: up-to-date (skip)")
}

// ── 2. SHA-256 helpers already defined above ──────────────────

// ── 3. Manifest file path ─────────────────────────────────────
let manifest_file = cache_dir + "/file_hashes.manifest"

// ── 4. Bail-out: NO_CACHE mode skips the layered cache entirely
if env("NO_CACHE") != "" {
    println("[rebuild_stage0] NO_CACHE=1 -> legacy single-hash path")
    let hash_file = hexa_dir + "/build/.rebuild_hash"

    let legacy_hash = exec("cat " + hexa_dir + "/self/hexa_full.hexa " + hexa_dir + "/self/runtime.c 2>/dev/null | " + sha256_cmd_name() + " | cut -d' ' -f1").trim()

    if env("FORCE") == "" {
        let out_check = exec_with_status("test -x " + out)
        if out_check[1] == 0 && file_exists(hash_file) {
            let stored_hash = read_file(hash_file).trim()
            if legacy_hash == stored_hash {
                println("[rebuild_stage0] content-hash unchanged (" + legacy_hash + "), skip")
                cleanup_lock(lock_dir)
                exit(0)
            }
        }
    }

    // Set NO_SMOKE by default
    if env("WITH_SMOKE") == "" {
        // Pass NO_SMOKE=1 via the command
    }

    let smoke_prefix = if env("WITH_SMOKE") == "" { "NO_SMOKE=1 " } else { "" }
    let build_result = exec_with_status(smoke_prefix + "./hexa " + hexa_dir + "/tool/build_stage0.hexa")
    if build_result[1] != 0 {
        cleanup_lock(lock_dir)
        exit(1)
    }
    exec("mkdir -p \"$(dirname '" + hash_file + "')\"")
    write_file(hash_file, legacy_hash + "\n")
    println("[rebuild_stage0] OK (legacy)")
    cleanup_lock(lock_dir)
    exit(0)
}

// ── 5. Compute FLATTEN key ──────────────────────────────────
let flatten_script = hexa_dir + "/tool/flatten_imports.hexa"
let root_hexa = hexa_dir + "/self/hexa_full.hexa"
if !file_exists(root_hexa) || !file_exists(flatten_script) {
    eprintln("[rebuild_stage0] missing root inputs — falling back to legacy")
    let fb = exec_with_status("./hexa " + hexa_dir + "/tool/build_stage0.hexa")
    cleanup_lock(lock_dir)
    exit(fb[1])
}

// Discover transitive use imports
let imports_sorted = discover_use_imports(root_hexa)
println("[rebuild_stage0] flatten inputs: " + str(len(imports_sorted)) + " .hexa files")

// ── 5b. Per-file incremental change detection ──────────────
let runtime_c = hexa_dir + "/self/runtime.c"
let mut all_build_inputs = [flatten_script]
let mut abi = 0
while abi < len(imports_sorted) {
    all_build_inputs = all_build_inputs.push(imports_sorted[abi])
    abi = abi + 1
}
all_build_inputs = all_build_inputs.push(runtime_c)

let mut changed_files = []
let mut changed_categories = ""
let mut runtime_only_changed = false
let mut hexa_only_changed = false
let mut tool_changed = false

if env("FORCE") == "" {
    let out_check = exec_with_status("test -x " + out)
    if out_check[1] == 0 {
        let diff_result = diff_manifest(manifest_file, all_build_inputs)
        changed_files = diff_result[0]
        changed_categories = diff_result[1]
        let any_changed = diff_result[2]

        if any_changed {
            println("[rebuild_stage0] per-file diff: " + str(len(changed_files)) + " file(s) changed:")
            let mut ci = 0
            while ci < len(changed_files) {
                let cf_base = exec("basename " + changed_files[ci]).trim()
                println("  * " + cf_base)
                ci = ci + 1
            }
            // Determine change category for partial-skip optimization
            if changed_categories == "runtime" {
                runtime_only_changed = true
                println("[rebuild_stage0] OPTIMIZATION: only runtime.c changed -> skip flatten+transpile")
            } else if changed_categories.starts_with("tool") {
                tool_changed = true
            } else if changed_categories == "hexa" {
                hexa_only_changed = true
            }
        } else {
            println("[rebuild_stage0] per-file manifest: 0 files changed")
        }
    }
}

// FLATTEN key 는 flatten_imports 스크립트 자체 + 전체 .hexa 의존 + flatten 지시자
let mut flatten_inputs = [flatten_script]
let mut fi = 0
while fi < len(imports_sorted) {
    flatten_inputs = flatten_inputs.push(imports_sorted[fi])
    fi = fi + 1
}
let flatten_key = hash_of_files(flatten_inputs)
println("[rebuild_stage0] flatten_key=" + flatten_key)

// ── 6. Compute TRANSPILE key ──────────────────────────────────
let hexa_v2_main = hexa_dir + "/self/native/hexa_v2"
let hexa_v2_dedup = hexa_dir + "/build/hexa_v2_dedup4"
let mut hexa_v2_effective = hexa_v2_main

if file_exists(hexa_dir + "/self/native/hexa_cc_dedup4.c") {
    let dedup_check = exec_with_status("test -x " + hexa_v2_dedup)
    if dedup_check[1] == 0 {
        hexa_v2_effective = hexa_v2_dedup
    }
}

let mut transpile_key_inputs = [flatten_key]
let v2_check = exec_with_status("test -x " + hexa_v2_effective)
if v2_check[1] == 0 {
    let hexa_v2_hash = hash_of_files([hexa_v2_effective])
    transpile_key_inputs = transpile_key_inputs.push(hexa_v2_hash)
}
// dedup4 .c 소스도 key 에 포함
if file_exists(hexa_dir + "/self/native/hexa_cc_dedup4.c") {
    transpile_key_inputs = transpile_key_inputs.push(hash_of_files([hexa_dir + "/self/native/hexa_cc_dedup4.c"]))
}
let transpile_key = hash_of_strings_safe(transpile_key_inputs)
println("[rebuild_stage0] transpile_key=" + transpile_key)

// ── 7. Compute LINK key ──────────────────────────────────────
let uname = exec("uname 2>/dev/null | tr -d ' \\n\\t'").trim()
let clang_bin = if env("CLANG") != "" { env("CLANG") } else { "clang" }
let clang_version = exec(clang_bin + " --version 2>/dev/null | head -1 || echo unknown").trim()

let mut link_cflags = ""
let mut link_ldflags = ""
if uname == "Linux" {
    link_cflags = "-O2 -std=gnu11 -D_GNU_SOURCE -Wno-trigraphs"
    link_ldflags = "-lm -ldl"
} else {
    link_cflags = "-O2 -std=c11 -Wno-trigraphs"
    link_ldflags = "-Wl,-stack_size,0x4000000"
}

let runtime_hash = hash_of_files([runtime_c])
let link_key_parts = [transpile_key, runtime_hash, link_cflags, link_ldflags, uname, clang_version]
let link_key = hash_of_strings_safe(link_key_parts)
println("[rebuild_stage0] link_key=" + link_key)

// ── 8. Fast path: LINK cache hit -> cp and done ─────────────
exec("mkdir -p " + cache_flatten_dir + " " + cache_transpile_dir + " " + cache_link_dir + " " + cache_meta_dir)
let link_cache_bin = cache_link_dir + "/" + link_key + ".bin"

let mut hit_flatten = false
let mut hit_transpile = false
let mut hit_link = false

if env("FORCE") == "" && file_exists(link_cache_bin) {
    // 산출물 손상 여부 체크: 최소 크기
    let min_size_str = if env("HEXA_STAGE0_MIN_SIZE") != "" { env("HEXA_STAGE0_MIN_SIZE") } else { "1000000" }
    let min_size = to_int(min_size_str)
    let csize = to_int(exec("wc -c < " + link_cache_bin + " | tr -d ' '").trim())
    if csize >= min_size {
        exec("mkdir -p " + hexa_dir + "/build")
        // Pre-copy backup so sanity check can roll back if cached bin is bad.
        let mut cache_backup = ""
        let cache_out_exists = exec_with_status("test -x " + out)
        if cache_out_exists[1] == 0 {
            let cache_old_size = to_int(exec("wc -c < " + out + " | tr -d ' '").trim())
            if cache_old_size >= min_size {
                let ch_pid = exec("echo $$").trim()
                cache_backup = "/tmp/hexa_stage0_backup_" + ch_pid
                exec("cp -f " + out + " " + cache_backup)
            }
        }
        exec("cp -f " + link_cache_bin + " " + out)
        // Darwin: codesign ad-hoc
        if uname == "Darwin" {
            let cs = exec_with_status("command -v codesign >/dev/null 2>&1")
            if cs[1] == 0 {
                exec_with_status("codesign --force --sign - " + out + " 2>/dev/null")
            }
        }
        // Legacy hash file 도 갱신
        exec("cat " + root_hexa + " " + runtime_c + " 2>/dev/null | " + sha256_cmd_name() + " | cut -d' ' -f1 > " + hexa_dir + "/build/.rebuild_hash 2>/dev/null || true")
        hit_flatten = true
        hit_transpile = true
        hit_link = true
        // Update per-file manifest on cache hit too
        write_manifest(manifest_file, all_build_inputs)
        let meta_json = "{\"flatten_key\":\"" + flatten_key + "\",\"transpile_key\":\"" + transpile_key + "\",\"link_key\":\"" + link_key + "\",\"hit\":{\"flatten\":1,\"transpile\":1,\"link\":1},\"uname\":\"" + uname + "\",\"incremental\":{\"runtime_only\":0,\"changed_files\":\"\",\"changed_count\":0}}"
        write_file(cache_meta_dir + "/last_build.json", meta_json + "\n")
        println("[rebuild_stage0] CACHE HIT (all 3 layers) -> cp " + link_cache_bin + " -> " + out + " (" + str(csize) + " bytes)")
        // Sanity-check cached binary (might be stale/corrupt from an older broken build)
        sanity_check_stage0(out, cache_backup, uname)
        if cache_backup != "" {
            exec("rm -f " + cache_backup)
        }
        // Re-install the flock+RSS-cap shim so cache-restored Mach-O
        // regains the layered defense (commit ca46279).
        let cache_shim_res = exec_with_status("./hexa " + hexa_dir + "/tool/install_stage0_shim.hexa")
        if cache_shim_res[1] != 0 {
            eprintln("[rebuild_stage0] WARN: install_stage0_shim failed after cache hit (rc=" + str(cache_shim_res[1]) + ")")
            eprintln(cache_shim_res[0])
        }
        println("[rebuild_stage0] OK (cache)")
        cleanup_lock(lock_dir)
        exit(0)
    } else {
        eprintln("[rebuild_stage0] link cache entry too small (" + str(csize) + " < " + min_size_str + ") — ignore and rebuild")
    }
}

// ── 9. Mid path: 부분 hit — flatten/transpile 단계별 재사용 ──
let flat_out = if env("HEXA_STAGE0_FLAT") != "" { env("HEXA_STAGE0_FLAT") } else { "/tmp/hexa_full_flat.hexa" }
let flat_cache = cache_flatten_dir + "/" + flatten_key + ".hexa"
let src_c = if env("HEXA_STAGE0_C") != "" { env("HEXA_STAGE0_C") } else { "/tmp/hexa_full_regen.c" }
let transpile_cache = cache_transpile_dir + "/" + transpile_key + ".c"

// 9-pre. Runtime-only fast path: reuse previous flatten+transpile artifacts.
if runtime_only_changed && env("FORCE") == "" {
    let mut reuse_transpile_c = ""
    // Try to find the previous transpile .c from the last build metadata
    if file_exists(cache_meta_dir + "/last_build.json") {
        let meta_content = read_file(cache_meta_dir + "/last_build.json")
        // Extract transpile_key from JSON (simple string search)
        let search = "\"transpile_key\":\""
        let tki = meta_content.index_of(search)
        if tki >= 0 {
            let after = meta_content.substring(tki + len(search), len(meta_content))
            let end_quote = after.index_of("\"")
            if end_quote >= 0 {
                let prev_transpile_key = after.substring(0, end_quote)
                let prev_cache = cache_transpile_dir + "/" + prev_transpile_key + ".c"
                if file_exists(prev_cache) {
                    reuse_transpile_c = prev_cache
                }
            }
        }
    }
    // Also try current transpile_key
    if reuse_transpile_c == "" && file_exists(transpile_cache) {
        reuse_transpile_c = transpile_cache
    }
    if reuse_transpile_c != "" {
        println("[rebuild_stage0] INCREMENTAL: runtime.c-only change -> reusing transpile from " + reuse_transpile_c)
        exec("cp -f " + reuse_transpile_c + " " + src_c)
        hit_flatten = true
        hit_transpile = true
        // Ensure runtime.c sibling is fresh
        let src_c_dir = exec("cd \"$(dirname '" + src_c + "')\" && pwd").trim()
        if src_c_dir != hexa_dir + "/self" {
            exec("cp -f " + runtime_c + " " + src_c_dir + "/runtime.c")
        }
    }
}

// 9a. FLATTEN — cache or re-run (skipped if runtime-only path already set hit_flatten)
if !hit_flatten {
    if env("FORCE") == "" && file_exists(flat_cache) {
        exec("cp -f " + flat_cache + " " + flat_out)
        hit_flatten = true
        println("[rebuild_stage0] CACHE HIT flatten -> " + flat_cache)
    } else {
        // flatten_imports
        // 2026-04-18: route through shim with HEXA_NO_LAUNCHD=1 (shim skips
        // launchd re-entry + execs REAL directly). rebuild_stage0 holds the
        // outer cache-level lock; the shim's inner mkdir lock uses a short
        // path and will either (a) succeed immediately if free, or (b) time
        // out and fall through — in practice uncontested because nothing else
        // in this critical section runs stage0.
        //
        // Previous design called build/hexa_stage0.real directly; that path
        // was fragile because .real can be replaced by a refuse shim on the
        // install side and it bypasses all layered defense.
        let stage0_shim = hexa_dir + "/build/hexa_stage0"
        let mut flatten_runner = ""
        let mut flatten_env_prefix = "HEXA_NO_LAUNCHD=1 "
        let s0_chk = exec_with_status("test -x " + stage0_shim)
        if s0_chk[1] == 0 {
            flatten_runner = stage0_shim
        } else {
            let hexa_chk = exec_with_status("test -x " + hexa_dir + "/hexa")
            if hexa_chk[1] == 0 {
                flatten_runner = hexa_dir + "/hexa"
                flatten_env_prefix = ""
            }
        }
        if flatten_runner == "" {
            eprintln("[rebuild_stage0] no flatten runner (build/hexa_stage0 or ./hexa) — falling back")
            // build_stage0.hexa 가 자체 flatten 을 수행하므로 진행
        } else {
            // ── Flatten lock (atomic mkdir) — prevents concurrent flatten_imports ──
            let flatten_lock = "/tmp/hexa_flatten.lock"
            let flatten_lock_ttl = 120
            let mut flatten_got_lock = false
            let fl_lock_res = exec_with_status("mkdir " + flatten_lock + " 2>/dev/null")
            if fl_lock_res[1] == 0 {
                exec("echo $$ > " + flatten_lock + "/pid")
                flatten_got_lock = true
            } else {
                let fl_pid = exec("cat " + flatten_lock + "/pid 2>/dev/null || echo ''").trim()
                let fl_time = exec("stat -f %m " + flatten_lock + " 2>/dev/null || stat -c %Y " + flatten_lock + " 2>/dev/null || echo 0").trim()
                let fl_now = to_int(exec("date +%s").trim())
                let fl_time_int = to_int(fl_time)
                let fl_age = fl_now - fl_time_int

                let fl_alive = exec_with_status("kill -0 " + fl_pid + " 2>/dev/null")
                if fl_pid != "" && fl_alive[1] == 0 && fl_age < flatten_lock_ttl {
                    eprintln("[rebuild_stage0] flatten: waiting for concurrent flatten (pid=" + fl_pid + ")")
                    let mut fl_wait = 0
                    while fl_wait < 60 {
                        let fl_dir_chk = exec_with_status("test -d " + flatten_lock)
                        if fl_dir_chk[1] != 0 {
                            fl_wait = 999
                        } else {
                            exec("sleep 1")
                            fl_wait = fl_wait + 1
                        }
                    }
                    let fl_still = exec_with_status("test -d " + flatten_lock)
                    if fl_still[1] == 0 {
                        eprintln("[rebuild_stage0] flatten: lock wait timeout — reclaiming")
                        exec("rm -rf " + flatten_lock)
                        let fl_reclaim = exec_with_status("mkdir " + flatten_lock)
                        if fl_reclaim[1] == 0 {
                            exec("echo $$ > " + flatten_lock + "/pid")
                            flatten_got_lock = true
                        }
                    }
                } else {
                    exec("rm -rf " + flatten_lock)
                    let fl_reclaim2 = exec_with_status("mkdir " + flatten_lock)
                    if fl_reclaim2[1] == 0 {
                        exec("echo $$ > " + flatten_lock + "/pid")
                        flatten_got_lock = true
                    }
                }
            }
            if flatten_got_lock {
                println("[rebuild_stage0] MISS flatten — running flatten_imports")
                let flatten_result = exec_with_status(flatten_env_prefix + "HEXA_VAL_ARENA=0 " + flatten_runner + " " + flatten_script + " " + root_hexa + " " + flat_out)
                if flatten_result[1] != 0 {
                    exec("rm -rf " + flatten_lock)
                    eprintln("[rebuild_stage0] flatten_imports failed")
                    cleanup_lock(lock_dir)
                    exit(1)
                }
                exec("rm -rf " + flatten_lock)
                if file_exists(flat_out) {
                    exec("cp -f " + flat_out + " " + flat_cache)
                }
            } else {
                eprintln("[rebuild_stage0] flatten: reusing output from concurrent run")
            }
        }
    }
}

// 9b. TRANSPILE — cache or re-run via hexa_v2 (skipped if runtime-only path already set hit_transpile)
if !hit_transpile {
    if env("FORCE") == "" && file_exists(transpile_cache) {
        exec("cp -f " + transpile_cache + " " + src_c)
        hit_transpile = true
        println("[rebuild_stage0] CACHE HIT transpile -> " + transpile_cache)
        // runtime.c sibling 복사
        let src_c_dir = exec("cd \"$(dirname '" + src_c + "')\" && pwd").trim()
        if src_c_dir != hexa_dir + "/self" {
            exec("cp -f " + runtime_c + " " + src_c_dir + "/runtime.c")
        }
    }
}

// ── 10. 빌드 위임 (smoke 기본 off) ──────────────────────────
let mut smoke_env = ""
if env("WITH_SMOKE") == "" {
    smoke_env = "NO_SMOKE=1 "
}

let mut skip_env = ""
if hit_transpile && file_exists(src_c) {
    skip_env = "SKIP_TRANSPILE=1 "
}

// pre-build backup — prefer `out`.real (post-shim-install layout: the
// real Mach-O lives at .real, `out` is the 6KB bash shim). Fall back to
// `out` itself for pristine layouts (first-ever build).
let min_size_val = if env("HEXA_STAGE0_MIN_SIZE") != "" { to_int(env("HEXA_STAGE0_MIN_SIZE")) } else { 1000000 }
let mut backup_path = ""
let real_path = out + ".real"
let backup_src = if file_exists(real_path) { real_path } else { out }
let backup_src_exists = exec_with_status("test -f " + backup_src)
if backup_src_exists[1] == 0 {
    let old_size = to_int(exec("wc -c < " + backup_src + " | tr -d ' '").trim())
    if old_size >= min_size_val {
        let pid = exec("echo $$").trim()
        backup_path = "/tmp/hexa_stage0_backup_" + pid
        exec("cp -f " + backup_src + " " + backup_path)
        println("[rebuild_stage0] backup: " + backup_path + " <- " + backup_src + " (" + str(old_size) + " bytes)")
    }
}

let hit_flatten_int = if hit_flatten { 1 } else { 0 }
let hit_transpile_int = if hit_transpile { 1 } else { 0 }
println("[rebuild_stage0] invoking build_stage0.hexa (flatten=" + str(hit_flatten_int) + " transpile=" + str(hit_transpile_int) + " link=0)")

// HEXA_SKIP_SHIM=1: let build_stage0 produce raw Mach-O at `out` without
// installing the shim internally. rebuild_stage0 handles shim install at
// the end (line 869) so the post-build size check and link-cache save
// below see the 2.7MB Mach-O, not the 6KB shim.
let build_cmd = "HEXA_SKIP_SHIM=1 " + smoke_env + skip_env + "./hexa " + hexa_dir + "/tool/build_stage0.hexa"
let build_result = exec_with_status(build_cmd)
if build_result[1] != 0 {
    eprintln("[rebuild_stage0] build FAILED")
    if backup_path != "" && file_exists(backup_path) {
        exec("cp -f " + backup_path + " " + out)
        eprintln("[rebuild_stage0] rolled back to backup")
    }
    cleanup_lock(lock_dir)
    exit(1)
}

// size guard
let out_check2 = exec_with_status("test -x " + out)
if out_check2[1] == 0 {
    let new_size = to_int(exec("wc -c < " + out + " | tr -d ' '").trim())
    if new_size < min_size_val {
        eprintln("[rebuild_stage0] ERROR: output too small (" + str(new_size) + " < " + str(min_size_val) + " bytes) — broken transpile?")
        if backup_path != "" && file_exists(backup_path) {
            exec("cp -f " + backup_path + " " + out)
            if uname == "Darwin" {
                let cs = exec_with_status("command -v codesign >/dev/null 2>&1")
                if cs[1] == 0 {
                    exec_with_status("codesign --force --sign - " + out + " 2>/dev/null")
                }
            }
            let rolled_size = exec("wc -c < " + out + " | tr -d ' '").trim()
            eprintln("[rebuild_stage0] rolled back to backup (" + rolled_size + " bytes)")
        }
        if backup_path != "" {
            exec("rm -f " + backup_path)
        }
        cleanup_lock(lock_dir)
        exit(1)
    }
}

// ── 10b. Sanity check — run a trivial .hexa through the new binary and
// verify output matches "ok\n42\n" exactly. Rolls back + exits(1) if it
// doesn't. Runs BEFORE cache save so a bad binary can't poison link cache.
sanity_check_stage0(out, backup_path, uname)

if backup_path != "" {
    exec("rm -f " + backup_path)
}

// ── 11. 캐시 저장 — 빌드 성공 + sanity PASS 이후에만 ───────
// IMPORTANT: cache the RAW Mach-O (still at `out` now), BEFORE installing
// the shim. If we shim first, link_cache_bin would contain the bash shim
// and a future cache HIT would restore the shim over the shim, losing the
// real binary.
if file_exists(src_c) && !file_exists(transpile_cache) {
    exec_with_status("cp -f " + src_c + " " + transpile_cache + " 2>/dev/null")
}
if file_exists(flat_out) && !file_exists(flat_cache) {
    exec_with_status("cp -f " + flat_out + " " + flat_cache + " 2>/dev/null")
}
let out_check3 = exec_with_status("test -x " + out)
if out_check3[1] == 0 {
    exec_with_status("cp -f " + out + " " + link_cache_bin + " 2>/dev/null")
}

// ── 11c. Re-install flock+RSS-cap shim (commit ca46279) ─────
// Moves the fresh Mach-O to build/hexa_stage0.real and restores the
// bash shim from git HEAD to build/hexa_stage0. Without this the next
// rebuild lands the Mac back in the 2026-04-18 panic trap (N parallel
// uncapped spawns → compressor blowup).
let shim_res = exec_with_status("./hexa " + hexa_dir + "/tool/install_stage0_shim.hexa")
if shim_res[1] != 0 {
    eprintln("[rebuild_stage0] WARN: install_stage0_shim failed (rc=" + str(shim_res[1]) + ")")
    eprintln(shim_res[0])
    eprintln("[rebuild_stage0] build/hexa_stage0 remains raw Mach-O — reinstall shim manually:")
    eprintln("  ./hexa tool/install_stage0_shim.hexa")
}

// ── 11b. Per-file manifest update ───────────────────────────
write_manifest(manifest_file, all_build_inputs)
println("[rebuild_stage0] manifest updated: " + str(len(all_build_inputs)) + " files -> " + manifest_file)

// meta / legacy hash file 갱신
let mut changed_list = ""
if len(changed_files) > 0 {
    let mut cf_names = []
    let mut cfi = 0
    while cfi < len(changed_files) {
        let cf_base = exec("basename " + changed_files[cfi]).trim()
        cf_names = cf_names.push(cf_base)
        cfi = cfi + 1
    }
    changed_list = cf_names.join(",")
}

let hit_flatten_v = if hit_flatten { 1 } else { 0 }
let hit_transpile_v = if hit_transpile { 1 } else { 0 }
let hit_link_v = if hit_link { 1 } else { 0 }
let runtime_only_v = if runtime_only_changed { 1 } else { 0 }

let meta_json_final = "{\"flatten_key\":\"" + flatten_key + "\",\"transpile_key\":\"" + transpile_key + "\",\"link_key\":\"" + link_key + "\",\"hit\":{\"flatten\":" + str(hit_flatten_v) + ",\"transpile\":" + str(hit_transpile_v) + ",\"link\":" + str(hit_link_v) + "},\"uname\":\"" + uname + "\",\"incremental\":{\"runtime_only\":" + str(runtime_only_v) + ",\"changed_files\":\"" + changed_list + "\",\"changed_count\":" + str(len(changed_files)) + "}}"
write_file(cache_meta_dir + "/last_build.json", meta_json_final + "\n")

exec("mkdir -p " + hexa_dir + "/build")
exec("cat " + root_hexa + " " + runtime_c + " 2>/dev/null | " + sha256_cmd_name() + " | cut -d' ' -f1 > " + hexa_dir + "/build/.rebuild_hash 2>/dev/null || true")

println("[rebuild_stage0] cache updated -> flatten=" + flatten_key + " transpile=" + transpile_key + " link=" + link_key)
println("[rebuild_stage0] OK")
cleanup_lock(lock_dir)
