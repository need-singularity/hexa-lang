// tool/ai_native_algo_lint.hexa — raw #2 entry (ai-native algorithm lint)
//
// usage:
//   hexa tool/ai_native_algo_lint.hexa                 — staged .hexa (git diff --cached)
//   hexa tool/ai_native_algo_lint.hexa <path...>       — explicit paths
//   hexa tool/ai_native_algo_lint.hexa --all           — self/serve/ + self/ml/ + anima/ tracked .hexa
//   hexa tool/ai_native_algo_lint.hexa --baseline      — 현재 violation 을 .ai-native-algo-baseline 에 기록 (grandfather)
//
// exit code:
//   0 — violation 0 (pass)  또는  status=new 단계에서 warn 모드 (항상 0)
//   1 — violation 1+ (block) — 현재 new 단계라 실행되지 않음
//
// delegates to self/raws/ai_native_algo.hexa scan logic.
//
// 현재 status = new (warn-only). block 승격은 baseline migration 후.

use "self/raws/ai_native_algo"
use "self/attrs/core"
use "self/stdlib/law_io"

let _raw_args = args()
let mut cli = []
let mut ai = 2
while ai < len(_raw_args) {
    cli.push(_raw_args[ai])
    ai = ai + 1
}

// ─── --selftest 분기 (synthetic fixture 로 rule 검출 검증) ─────
// raw 66 (ai-native error message) — fixture 출력은 fmt_msg(human) 으로
// hint:/fix:/ref: trailer 를 포함. PASS exit 0 / FAIL exit 1.
let mut is_selftest = false
let mut _si = 0
while _si < len(cli) {
    let _a = cli[_si]
    if _a == "--selftest" || _a == "selftest" { is_selftest = true; break }
    _si = _si + 1
}
if is_selftest {
    println("[ai_native_algo_lint selftest]")
    let mut pwd = env("PWD")
    if pwd == "" { pwd = to_string(exec("pwd")).trim() }
    let fix_dir = "/tmp/ai_native_algo_lint_selftest"
    let _mk = exec("mkdir -p '" + fix_dir + "/self/serve' 2>&1")

    // (1) naive-prefix violation fixture — 반드시 in-scope 경로 (self/serve/) + naive_ 접두사
    let bad_path = fix_dir + "/self/serve/bad_kernel.hexa"
    let bad_src = "// fixture — naive_ prefix in self/serve/\n" +
                  "fn naive_matmul(a, b) {\n" +
                  "    let mut c = []\n" +
                  "    return c\n" +
                  "}\n"
    safe_write_file(bad_path, bad_src)

    // (2) PASS fixture — @allow-naive-algo marker 존재
    let ok_path = fix_dir + "/self/serve/ok_kernel.hexa"
    let ok_src = "// fixture — opted out via marker\n" +
                 "// @allow-naive-algo selftest fixture\n" +
                 "fn naive_helper(x) {\n" +
                 "    return x\n" +
                 "}\n"
    safe_write_file(ok_path, ok_src)

    // baseline 파일 존재 시 fixture 가 grandfather 될 수 있음 — fix_dir 안에는
    // baseline 을 만들지 않으므로 안전. _load_baseline 은 PWD 기반이지만 PWD 가
    // 무엇이든 fixture 경로 (절대) 와 매치될 가능성은 없음 (fixture 가 /tmp/... 에 위치).
    let bad_msgs = ai_native_algo_enforce([bad_path])
    if len(bad_msgs) < 1 {
        eprintln("[ai_native_algo_lint selftest] FAIL: naive_matmul 미검출 (expected ≥1 violation)")
        let _rm0 = exec("rm -rf '" + fix_dir + "' 2>&1")
        exit(1)
    }

    let ok_msgs = ai_native_algo_enforce([ok_path])
    if len(ok_msgs) != 0 {
        eprintln("[ai_native_algo_lint selftest] FAIL: @allow-naive-algo marker 무시됨 (got " + to_string(len(ok_msgs)) + " violation)")
        let _rm1 = exec("rm -rf '" + fix_dir + "' 2>&1")
        exit(1)
    }

    // (3) AI-native trailer 확인 — fmt_msg 에 hint/fix/ref 포함
    let rendered = fmt_msg(bad_msgs[0])
    let has_hint = rendered.contains("hint:")
    let has_fix = rendered.contains("fix:")
    let has_ref = rendered.contains("ref:")
    if !(has_hint && has_fix && has_ref) {
        eprintln("[ai_native_algo_lint selftest] FAIL: AI-native trailer 누락 (hint/fix/ref 중 missing)")
        eprintln(rendered)
        let _rm2 = exec("rm -rf '" + fix_dir + "' 2>&1")
        exit(1)
    }

    let _rm3 = exec("rm -rf '" + fix_dir + "' 2>&1")
    println("[ai_native_algo_lint selftest] OK — naive-prefix 검출 + @allow-naive-algo opt-out + AI-native trailer (hint/fix/ref) 확인")
    exit(0)
}

let mut paths = []
let mut mode = "staged"
let mut do_baseline = false
let mut i = 0
while i < len(cli) {
    let a = cli[i]
    if a == "--all" { mode = "all" }
    else if a == "--staged" { mode = "staged" }
    else if a == "--baseline" { do_baseline = true; mode = "all" }
    else { paths.push(a); mode = "explicit" }
    i = i + 1
}

if mode == "staged" && len(paths) == 0 {
    let out = to_string(exec("git diff --cached --name-only --diff-filter=ACMR 2>/dev/null | grep '\\.hexa$' || true")).trim()
    if out != "" {
        let parts = split(out, "\n")
        for p in parts {
            let t = p.trim()
            if t != "" { paths.push(t) }
        }
    }
}

if mode == "all" {
    // scope 좁힘: self/serve/ + self/ml/ + anima/
    let out = to_string(exec("git ls-files 'self/serve/*.hexa' 'self/ml/*.hexa' 'anima/*.hexa' 2>/dev/null")).trim()
    if out != "" {
        let parts = split(out, "\n")
        for p in parts {
            let t = p.trim()
            if t != "" { paths.push(t) }
        }
    }
}

if len(paths) == 0 {
    println("raw#2: 대상 파일 없음 (mode=" + mode + ") — pass")
    exit(0)
}

let msgs = ai_native_algo_enforce(paths)

if do_baseline {
    // violation 나온 파일을 .ai-native-algo-baseline 에 기록 (grandfather)
    let mut pwd = env("PWD")
    if pwd == "" { pwd = to_string(exec("pwd")).trim() }
    let out_path = pwd + "/.ai-native-algo-baseline"
    let mut seen = #{}
    let mut lines = ""
    lines = lines + "# .ai-native-algo-baseline — raw #2 grandfather list\n"
    lines = lines + "# 생성: hexa tool/ai_native_algo_lint.hexa --baseline\n"
    lines = lines + "# 1 path/line. naive algorithm violation 파일들은 점진적으로 AI-native 로 rewrite.\n"
    lines = lines + "# 새 파일은 baseline 에 추가하지 말 것 — rule #2 strict 적용.\n"
    lines = lines + "\n"
    for m in msgs {
        let p = m.file
        if seen[p] == true { continue }
        seen[p] = true
        lines = lines + p + "\n"
    }
    try {
        safe_write_file(out_path, lines)
        println("baseline written: " + out_path + " (" + to_string(len(seen)) + " paths)")
    } catch e {
        eprintln("error: failed to write " + out_path)
        exit(1)
    }
    exit(0)
}

if len(msgs) == 0 {
    println("raw#2: OK — " + to_string(len(paths)) + " 파일 scan, 0 violation")
    exit(0)
}

// status=new 단계: warn-only (exit 0). block 승격은 migration 후.
eprintln("⚠ raw#2 ai_native_algo — " + to_string(len(msgs)) + " violation (" + to_string(len(paths)) + " 파일 scan) [warn-only]")
eprintln("")
for m in msgs {
    eprintln(fmt_msg(m))
    eprintln("")
}
eprintln("ref: self/raws/ai_native_algo.hexa — opt-out via @allow-naive-algo marker or .ai-native-algo-baseline")
eprintln("current status: new (warn-only). block 승격은 baseline migration 후.")
exit(0)
