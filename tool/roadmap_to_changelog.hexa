// tool/roadmap_to_changelog.hexa — Phase 3.7 changelog auto-feed (stub).
//
// SPEC: docs/roadmap_engine_continuous_meta_proposal_20260422.md §Phase 3.7.
// STATUS: stub — skeleton + --selftest only.
//
// PURPOSE
//   On .roadmap status → done transitions, prepend a conventional-commit
//   style entry (feat:/fix:/chore:/docs:) to docs/CHANGELOG.md with semver
//   bump hints derived from phase + track. Only mutates docs/CHANGELOG.md;
//   never touches .roadmap.
//
// CLI
//   hexa tool/roadmap_to_changelog.hexa --selftest
//   hexa tool/roadmap_to_changelog.hexa --repo <name> [--dry-run]
//
// OUTPUT
//   docs/CHANGELOG.md (prepend in --repo's tree; here stub emits meta only)
//   $HEXA_LANG/state/roadmap_changelog_feed_<repo>.json
//   schema = "hexa-lang/roadmap_changelog_feed/1"

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _iso_now() -> string {
    return to_string(exec("date -u +'%Y-%m-%dT%H:%M:%SZ'")).trim()
}

fn _arg_value(args: array, key: string, default: string) -> string {
    let mut i = 0
    while i < len(args) {
        if args[i] == key {
            let j = i + 1
            if j < len(args) { return args[j] }
        }
        i = i + 1
    }
    return default
}

fn _has_flag(args: array, key: string) -> bool {
    let mut i = 0
    while i < len(args) {
        if args[i] == key { return true }
        i = i + 1
    }
    return false
}

fn _selftest() -> int {
    if len(_iso_now()) < 10 {
        eprintln("roadmap_to_changelog: selftest FAIL (iso_now empty)")
        return 1
    }
    println("roadmap_to_changelog: selftest PASS (stub)")
    return 0
}

fn _emit(repo: string, dry: bool, out_path: string) -> int {
    let ts = _iso_now()
    let dry_str = "false"
    if dry { dry_str = "true" }
    let body = "{\n  \"schema\": \"hexa-lang/roadmap_changelog_feed/1\",\n  \"ts\": \"" + ts + "\",\n  \"repo\": \"" + repo + "\",\n  \"status\": \"stub\",\n  \"dry_run\": " + dry_str + ",\n  \"entries_prepended\": 0,\n  \"suggested_semver_bump\": \"none\"\n}\n"
    try {
        write_file(out_path, body)
    } catch e {
        eprintln("roadmap_to_changelog: write FAIL " + out_path)
        return 1
    }
    println("roadmap_to_changelog: wrote " + out_path + " (stub, 0 entries)")
    return 0
}

fn main() {
    let av = argv()
    let mut args = []
    let mut i = 2
    while i < len(av) { args.push(av[i]); i = i + 1 }

    if len(args) >= 1 && args[0] == "--selftest" {
        exit(_selftest())
    }

    let repo = _arg_value(args, "--repo", "anima")
    let dry = _has_flag(args, "--dry-run")
    let default_out = _home() + "/core/hexa-lang/state/roadmap_changelog_feed_" + repo + ".json"
    let out_path = _arg_value(args, "--out", default_out)
    exit(_emit(repo, dry, out_path))
}
