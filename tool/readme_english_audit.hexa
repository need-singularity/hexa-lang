// tool/readme_english_audit.hexa — public README English-only audit
//
// 목적:
//   need-singularity org 5개 repo (n6-architecture, nexus, hexa-lang, anima, papers)
//   의 루트 README.md 에 CJK (한글 / 일본어 / 중국어) 혼재 여부를 감지.
//   arXiv 호환 + 국제 기여 우선 정책 (.own #1 doc-english-required) 의 enforce path.
//
// 실행:
//   hexa tool/readme_english_audit.hexa               # 기본 (5 repo)
//   hexa tool/readme_english_audit.hexa --strict      # 임계값 0 (기본값과 동일)
//   N6_AUDIT_MAX_LINES=5 hexa tool/readme_english_audit.hexa   # 위반 라인 출력 제한
//
// 입력:
//   (없음 — 검사 대상은 $HOME/core/{repo}/README.md 로 고정. 설정 필요 시 코드 내 TARGETS 편집.)
//
// 출력:
//   stdout — per-file PASS/FAIL + 위반 라인 (line no + 60자 snippet)
//   stderr — FAIL 건마다 한 줄 JSON: N6_AUDIT_FAIL {"repo":..., "line":..., "class":..., "sample":...}
//
// 종료 코드:
//   0 — 5/5 PASS (모든 README 영어 전용)
//   1 — 1건 이상 CJK 검출
//   2 — 대상 README 파일 유실 등 구조 오류
//
// 검출 범위 (CJK):
//   Hangul Syllables      U+AC00..U+D7AF   "가-힣"
//   Hangul Jamo           U+1100..U+11FF
//   Hangul Compat Jamo    U+3130..U+318F   "ㄱ-ㅎ", "ㅏ-ㅣ"
//   Hiragana              U+3040..U+309F   "ぁ-ゖ"
//   Katakana              U+30A0..U+30FF   "゠-ヿ"
//   CJK Unified           U+4E00..U+9FFF   "一-龥"
//
// 허용 (PASS, 과학 표기):
//   Greek  σ φ τ λ μ ρ Ω      Math  J₂ σ² × ≤ ≥ → · ∞ √ ∑
//   기호   ✅ ❌ — – ‒ … 「」 『』  단위  ° ℃ μm Å
//
// 규칙:
//   raw#9  hexa only (grep 는 read-only 단일 도우미 exec; hexa 가 주어)
//   raw#10 proof-carrying — 각 FAIL 은 (repo, line, class, sample) 구조적 emit
//   raw#11 snake_case
//   own#1  doc-english-required enforce path
//   own#14 readme-sealed-required 위반 시 sealed hash 재계산 필요

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return to_string(x)
}

fn sh(cmd: string) -> string {
    return _str(exec(cmd + " 2>/dev/null")).trim()
}

fn file_exists(path: string) -> bool {
    let r = sh("test -f '" + path + "' && echo y || echo n")
    return r == "y"
}

// ── 대상 README 목록 ────────────────────────────────
// need-singularity org 공개 5 repo. 추가/변경 시 이 배열 편집.
let HOME = env("HOME")
let CORE = HOME + "/core"
let TARGETS = [
    "n6-architecture",
    "nexus",
    "hexa-lang",
    "anima",
    "papers"
]

// ── 검출 정규식 (확장 regex, BSD grep 호환) ─────────
// -E 모드 + UTF-8 로케일 필수 (BSD grep 은 -P 미지원)
let CJK_RE = "[가-힣ㄱ-ㅎㅏ-ㅣぁ-ゖ゠-ヿ一-龥]"

// ── 환경변수 기반 옵션 ──────────────────────────────
fn max_lines_to_show() -> int {
    let raw = env("N6_AUDIT_MAX_LINES")
    if raw == "" { return 10 }
    let n = to_int(raw)
    if n <= 0 { return 10 }
    return n
}

// ── 단일 README 검사 ───────────────────────────────
// return: (korean_line_count, korean_char_count)
fn count_cjk(path: string) -> string {
    // 라인 수
    let lc = sh("LC_ALL=en_US.UTF-8 grep -cE '" + CJK_RE + "' '" + path + "'")
    // 문자 수
    let cc = sh("LC_ALL=en_US.UTF-8 grep -oE '" + CJK_RE + "' '" + path + "' | wc -l | tr -d ' '")
    return lc + ":" + cc
}

fn sample_lines(path: string, limit: int) -> string {
    // 위반 라인 N개 (line_no + 60자 snippet)
    let cmd = "LC_ALL=en_US.UTF-8 grep -nE '" + CJK_RE + "' '" + path + "' | head -" + to_string(limit) + " | cut -c1-80"
    return sh(cmd)
}

fn classify_first_match(line: string) -> string {
    // line 에서 첫 CJK 문자의 블록 분류 (표시용)
    // Hangul 만 먼저 체크 (실제 사용량 대부분)
    let h = sh("printf '%s' " + shell_quote(line) + " | LC_ALL=en_US.UTF-8 grep -oE '[가-힣ㄱ-ㅎㅏ-ㅣ]' | head -1")
    if h != "" { return "hangul" }
    let j = sh("printf '%s' " + shell_quote(line) + " | LC_ALL=en_US.UTF-8 grep -oE '[ぁ-ゖ゠-ヿ]' | head -1")
    if j != "" { return "kana" }
    let c = sh("printf '%s' " + shell_quote(line) + " | LC_ALL=en_US.UTF-8 grep -oE '[一-龥]' | head -1")
    if c != "" { return "cjk_han" }
    return "unknown"
}

fn shell_quote(s: string) -> string {
    // 안전한 single-quote escaping
    let escaped = s.replace("'", "'\\''")
    return "'" + escaped + "'"
}

// ── 출력 헤더 ──────────────────────────────────────
println("── public README English-only audit ──")
println("core : " + CORE)
println("targets : " + to_string(len(TARGETS)) + " repos")
println("")

// ── 누적기 ─────────────────────────────────────────
let mut pass_count = 0
let mut fail_count = 0
let mut total_ko_lines = 0
let mut total_ko_chars = 0
let max_lines = max_lines_to_show()

// ── 대상 순회 ──────────────────────────────────────
let mut i = 0
while i < len(TARGETS) {
    let repo = TARGETS[i]
    let path = CORE + "/" + repo + "/README.md"

    println("[" + repo + "]  " + path)

    if !file_exists(path) {
        println("  [FAIL] README.md missing")
        eprintln("N6_AUDIT_FAIL {\"repo\":\"" + repo + "\",\"line\":0,\"class\":\"missing\",\"sample\":\"file not found\"}")
        fail_count = fail_count + 1
        println("")
        i = i + 1
        continue
    }

    let counts = count_cjk(path)
    let parts = counts.split(":")
    let lc = to_int(parts[0])
    let cc = to_int(parts[1])

    if lc == 0 {
        println("  [PASS] 0 CJK characters")
        pass_count = pass_count + 1
        println("")
        i = i + 1
        continue
    }

    println("  [FAIL] " + to_string(lc) + " lines, " + to_string(cc) + " CJK characters")
    total_ko_lines = total_ko_lines + lc
    total_ko_chars = total_ko_chars + cc
    fail_count = fail_count + 1

    let samples = sample_lines(path, max_lines)
    let sample_lines_arr = samples.split("\n")
    let mut si = 0
    while si < len(sample_lines_arr) {
        let ln = _str(sample_lines_arr[si])
        if ln != "" {
            println("    " + ln)
            // stderr JSON emit (proof-carrying)
            // line 형식: "NN:content" — colon 위치로 line_no 분리
            let colon = ln.find(":")
            let ln_no = "?"
            let ln_body = ln
            if colon >= 0 {
                ln_no = ln[0..colon]
                ln_body = ln[colon+1..len(ln)]
            }
            let cls = classify_first_match(ln_body)
            // JSON-safe snippet (quote escaping)
            let snippet = ln_body.replace("\\", "\\\\").replace("\"", "\\\"")
            eprintln("N6_AUDIT_FAIL {\"repo\":\"" + repo + "\",\"line\":" + ln_no + ",\"class\":\"" + cls + "\",\"sample\":\"" + snippet + "\"}")
        }
        si = si + 1
    }
    if lc > max_lines {
        println("    ... (" + to_string(lc - max_lines) + " more lines truncated; set N6_AUDIT_MAX_LINES=N to see more)")
    }
    println("")
    i = i + 1
}

// ── 최종 리포트 ────────────────────────────────────
println("═════════════════════════════════════════════")
println("English-only Audit Summary")
println("─────────────────────────────────────────────")
println("  repos PASS  : " + to_string(pass_count) + " / " + to_string(len(TARGETS)))
println("  repos FAIL  : " + to_string(fail_count))
println("  total CJK lines : " + to_string(total_ko_lines))
println("  total CJK chars : " + to_string(total_ko_chars))

if fail_count == 0 {
    println("  STATUS      : PASS (all public READMEs English-only)")
    println("═════════════════════════════════════════════")
    exit(0)
} else {
    println("  STATUS      : FAIL")
    println("  remediation : translate remaining fragments and re-run;")
    println("                for n6-architecture, also regen from n6shared SSOT")
    println("                (n6shared/n6/docs/domains.json + readme-data.json)")
    println("═════════════════════════════════════════════")
    exit(1)
}
