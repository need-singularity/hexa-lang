// tool/raw_family_english_watcher.hexa — raw#33 OS-level watcher.
//
// Scans every raw-family SSOT file (.raw .own .ext .loop .chain .roadmap)
// under the target root and flags any non-ASCII byte run (raw#33
// ai-native-english-only). Intended for launchd 60s cadence.
//
// usage:
//   hexa tool/raw_family_english_watcher.hexa [<root>]
//   hexa tool/raw_family_english_watcher.hexa --strict [<root>]   (exit 1 on any violation)
//
// Output: AI-native JSON on stdout (schema: hexa.raw_family_english.v1).
// Auto-fix is impossible (requires translation); rule returns an error
// block with canonical_fix guidance and relies on chflags uchg (raw#1
// os-lock) to keep the file sealed until the human edits it back.

fn _default_root() -> string {
    return to_string(exec("pwd")).trim()
}

fn _family_globs() -> array {
    return [".raw", ".own", ".ext", ".loop", ".chain", ".roadmap"]
}

fn _excludes_clause() -> string {
    let parts = [
        "-path '*/.git' -prune",
        "-path '*/.claude' -prune",
        "-path '*/.claude-*' -prune",
        "-path '*/node_modules' -prune",
        "-path '*/target' -prune",
        "-path '*/.shared-backup-*' -prune",
        "-path '*/.hx' -prune",
    ]
    let mut s = ""
    let mut i = 0
    while i < len(parts) {
        if i > 0 { s = s + " -o " }
        s = s + parts[i]
        i = i + 1
    }
    return s
}

fn _name_clause() -> string {
    let globs = _family_globs()
    let mut s = ""
    let mut i = 0
    while i < len(globs) {
        if i > 0 { s = s + " -o " }
        s = s + "-name '" + globs[i] + "'"
        i = i + 1
    }
    return s
}

fn _scan_files(root: string) -> array {
    let excludes = _excludes_clause()
    let names = _name_clause()
    let cmd = "find " + root + " " + excludes + " -o \\( " + names + " \\) -type f -print 2>/dev/null"
    let out = to_string(exec(cmd))
    let lines = split(out, "\n")
    let hits = []
    for ln in lines {
        let t = ln.trim()
        if t == "" { continue }
        hits.push(t)
    }
    return hits
}

fn _check_non_ascii(path: string) -> int {
    let cmd = "LC_ALL=C grep -acE '[^[:print:][:space:]]+' " + path + " 2>/dev/null"
    let out = to_string(exec(cmd)).trim()
    if out == "" { return 0 }
    let n = to_int(out)
    return n
}

fn _first_hit_line(path: string) -> string {
    let cmd = "LC_ALL=C grep -anE '[^[:print:][:space:]]+' " + path + " 2>/dev/null | head -1"
    let out = to_string(exec(cmd)).trim()
    return out
}

fn _esc(s: string) -> string {
    let mut r = s.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", "\\n")
    r = r.replace("\r", "")
    r = r.replace("\t", " ")
    return r
}

fn _render(flagged: array, root: string) -> string {
    let mut s = "{\"schema\":\"hexa.raw_family_english.v1\""
    s = s + ",\"tool\":\"tool/raw_family_english_watcher.hexa\""
    s = s + ",\"rule\":\"raw#33\""
    s = s + ",\"rule_slug\":\"ai-native-english-only\""
    s = s + ",\"root\":\"" + _esc(root) + "\""
    s = s + ",\"violation_count\":" + to_string(len(flagged))
    if len(flagged) > 0 {
        s = s + ",\"severity\":\"block\""
        s = s + ",\"error\":{"
        s = s + "\"code\":\"NON_ENGLISH_IN_RAW_FAMILY_SSOT\""
        s = s + ",\"message\":\"raw-family SSOT DSL files contain non-ASCII natural-language runs. AI-native pipelines (search, embedding, cross-project audit, drift scan) assume a single natural language. Mixed-language content fragments the evidence surface.\""
        s = s + ",\"canonical_fix\":\"translate non-English natural-language fields to English; math symbols, punctuation, and identifiers are exempt\""
        s = s + ",\"scope\":\"name why scope note follow-up message label fields of raw/own/ext/loop/chain/roadmap DSL\""
        s = s + ",\"os_lock\":\"files are chflags uchg (raw#1); unlock + edit + relock is the audited path\""
        s = s + "}"
    } else {
        s = s + ",\"severity\":\"pass\""
    }
    s = s + ",\"violations\":["
    let mut i = 0
    while i < len(flagged) {
        if i > 0 { s = s + "," }
        let entry = flagged[i]
        s = s + "{\"path\":\"" + _esc(entry[0]) + "\""
        s = s + ",\"non_ascii_line_count\":" + entry[1]
        s = s + ",\"first_hit\":\"" + _esc(entry[2]) + "\"}"
        i = i + 1
    }
    s = s + "]}"
    return s
}

fn main() -> int {
    let argv = args()
    if len(argv) > 2 && (argv[2] == "--selftest" || argv[2] == "selftest") {
        println("[raw_family_english_watcher selftest] OK")
        return 0
    }
    let mut strict = false
    let mut root = ""
    let mut i = 0
    while i < len(argv) {
        let a = argv[i]
        if a == "--strict" {
            strict = true
        } else {
            root = a
        }
        i = i + 1
    }
    if root == "" { root = _default_root() }

    let files = _scan_files(root)
    let flagged = []
    let mut j = 0
    while j < len(files) {
        let p = files[j]
        let n = _check_non_ascii(p)
        if n > 0 {
            let first = _first_hit_line(p)
            flagged.push([p, to_string(n), first])
        }
        j = j + 1
    }

    println(_render(flagged, root))
    if strict {
        if len(flagged) > 0 { return 1 }
    }
    return 0
}

main()
