// tool/tui_cold_start_smoke.hexa — minimal L1-L5 cold-start smoke
//
// Smallest valid TUI program: init render + paint one cell + flush + close.
// Used to measure cold-start latency (binary exec → exit) vs Ink/OpenTUI
// equivalents.
//
// Build:
//   ./hexa build tool/tui_cold_start_smoke.hexa -o /tmp/_cs_smoke
// Time:
//   for i in 1 2 3 4 5; do (time /tmp/_cs_smoke >/dev/null 2>&1); done

use "self/tui/render"

let _r1 = render_init()
let _r2 = render_put(0, 0, "*", -1, -1, 0)
let _r3 = render_flush()
let _r4 = render_close()
exit(0)
