// tool/hx_loss_free_roi_scan.hexa — Phase 2 loss-free ROI scanner (real-v1).
//
// SPEC: docs/hexa_lang_meta_evolution_proposal_20260422.md §Phase 2.
// STATUS: v1 real — dup_helper (helper name ≥3 files) + oversize (tool >500 LOC).
//         dead_fn / missing_selftest / aot_stale / stdlib_gap / bench_dormant
//         deferred to v2 (most need cross-tool call-graph + state inputs).
//
// CLI
//   hexa tool/hx_loss_free_roi_scan.hexa --selftest
//   hexa tool/hx_loss_free_roi_scan.hexa [--threshold N] [--loc N] [--out <path>]
//
// OUTPUT
//   $HEXA_LANG/state/hx_loss_free_roi.json  (schema hexa-lang/hx_loss_free_roi/1)

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _iso_now() -> string {
    return to_string(exec("date -u +'%Y-%m-%dT%H:%M:%SZ'")).trim()
}

fn _arg_value(args: array, key: string, default: string) -> string {
    let mut i = 0
    while i < len(args) {
        if args[i] == key {
            let j = i + 1
            if j < len(args) { return args[j] }
        }
        i = i + 1
    }
    return default
}

fn _atoi(s: string) -> int {
    if s == "" { return 0 }
    return s.parse_int()
}

fn _json_esc(s: string) -> string {
    let mut r = s.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", "\\n")
    r = r.replace("\r", "")
    r = r.replace("\t", " ")
    return r
}

fn _split_lines(s: string) -> array {
    let mut out = []
    let mut cur = ""
    let mut i = 0
    while i < len(s) {
        let c = s.substring(i, i + 1)
        if c == "\n" {
            if len(cur) > 0 { out.push(cur) }
            cur = ""
        } else {
            cur = cur + c
        }
        i = i + 1
    }
    if len(cur) > 0 { out.push(cur) }
    return out
}

fn _tool_dir() -> string {
    return _home() + "/core/hexa-lang/tool"
}

fn _index_of_str(arr: array, s: string) -> int {
    let mut i = 0
    while i < len(arr) {
        if arr[i] == s { return i }
        i = i + 1
    }
    return -1
}

fn _selftest() -> int {
    if _atoi("42") != 42 { eprintln("hx_loss_free_roi_scan: selftest FAIL (atoi)"); return 1 }
    let ln = _split_lines("a\nb\n")
    if len(ln) != 2 { eprintln("hx_loss_free_roi_scan: selftest FAIL (split)"); return 1 }
    let esc = _json_esc("a\"b")
    if esc != "a\\\"b" { eprintln("hx_loss_free_roi_scan: selftest FAIL (esc)"); return 1 }
    println("hx_loss_free_roi_scan: selftest PASS")
    return 0
}

// Returns array of "name|short_path" pairs (one per fn _<name>( definition).
fn _scan_helpers() -> array {
    let td = _tool_dir()
    let cmd = "grep -rE '^fn _[A-Za-z0-9_]+\\(' '" + td + "' 2>/dev/null"
    let raw = to_string(exec(cmd))
    let lines = _split_lines(raw)
    let mut pairs = []
    for ln in lines {
        let colon = ln.index_of(":fn ")
        if colon < 0 { continue }
        let file_path = ln.substring(0, colon)
        let tpos = file_path.index_of("/tool/")
        let short = if tpos >= 0 { file_path.substring(tpos + 1, len(file_path)) } else { file_path }
        let rest = ln.substring(colon + 4, len(ln))
        let mut name = ""
        let mut j = 0
        while j < len(rest) {
            let c = rest.substring(j, j + 1)
            if c == "(" || c == " " || c == "<" { break }
            name = name + c
            j = j + 1
        }
        if len(name) > 1 { pairs.push(name + "|" + short) }
    }
    return pairs
}

// Returns array of "loc|short_path" for each tool/*.hexa with loc >= threshold.
fn _scan_oversize(loc_threshold: int) -> array {
    let td = _tool_dir()
    let cmd = "wc -l '" + td + "'/*.hexa 2>/dev/null | grep -v ' total$'"
    let raw = to_string(exec(cmd))
    let lines = _split_lines(raw)
    let mut out = []
    for ln in lines {
        let t = ln.trim()
        if len(t) == 0 { continue }
        // format: "  1234 /abs/path/tool/foo.hexa"
        let sp = t.index_of(" ")
        if sp < 0 { continue }
        let loc_s = t.substring(0, sp)
        let path = t.substring(sp + 1, len(t)).trim()
        let loc = _atoi(loc_s)
        if loc < loc_threshold { continue }
        let tpos = path.index_of("/tool/")
        let short = if tpos >= 0 { path.substring(tpos + 1, len(path)) } else { path }
        out.push(to_string(loc) + "|" + short)
    }
    return out
}

fn main() {
    let av = argv()
    let mut args = []
    let mut i = 2
    while i < len(av) { args.push(av[i]); i = i + 1 }

    if len(args) >= 1 && args[0] == "--selftest" { exit(_selftest()) }

    let threshold = _atoi(_arg_value(args, "--threshold", "3"))
    let loc_thr = _atoi(_arg_value(args, "--loc", "500"))
    let default_out = _home() + "/core/hexa-lang/state/hx_loss_free_roi.json"
    let out_path = _arg_value(args, "--out", default_out)
    let ts = _iso_now()

    // 1. dup_helper candidates
    let pairs = _scan_helpers()
    let mut names = []
    let mut files_csv = []
    let mut counts = []
    for p in pairs {
        let bar = p.index_of("|")
        if bar < 0 { continue }
        let n = p.substring(0, bar)
        let f = p.substring(bar + 1, len(p))
        let idx = _index_of_str(names, n)
        if idx < 0 {
            names.push(n); files_csv.push(f); counts.push(1)
        } else {
            let existing = files_csv[idx]
            if existing.index_of(f) < 0 {
                files_csv[idx] = existing + "," + f
                counts[idx] = counts[idx] + 1
            }
        }
    }
    let mut cand_json = []
    let mut dup_count = 0
    let mut k = 0
    while k < len(names) {
        let c = counts[k]
        if c >= threshold {
            let savings = c - 1
            let id = "roi-dup-" + to_string(k)
            let entry = "{\"id\":\"" + id
                + "\",\"category\":\"dup_helper\",\"name\":\"" + _json_esc(names[k])
                + "\",\"occurrences\":" + to_string(c)
                + ",\"savings\":" + to_string(savings)
                + ",\"action\":\"promote to stdlib, remove " + to_string(savings) + " copies\""
                + ",\"files\":\"" + _json_esc(files_csv[k]) + "\"}"
            cand_json.push(entry)
            dup_count = dup_count + 1
        }
        k = k + 1
    }

    // 2. oversize candidates
    let oversize = _scan_oversize(loc_thr)
    let mut oversize_count = 0
    let mut m = 0
    while m < len(oversize) {
        let row = oversize[m]
        let bar = row.index_of("|")
        if bar < 0 { m = m + 1; continue }
        let loc = row.substring(0, bar)
        let path = row.substring(bar + 1, len(row))
        let id = "roi-oversize-" + to_string(m)
        let entry = "{\"id\":\"" + id
            + "\",\"category\":\"oversize\",\"file\":\"" + _json_esc(path)
            + "\",\"loc\":" + loc
            + ",\"threshold\":" + to_string(loc_thr)
            + ",\"action\":\"consider split — single-responsibility refactor\"}"
        cand_json.push(entry)
        oversize_count = oversize_count + 1
        m = m + 1
    }

    // 3. Emit JSON
    let mut body = "{\n  \"schema\": \"hexa-lang/hx_loss_free_roi/1\",\n"
    body = body + "  \"ts\": \"" + ts + "\",\n"
    body = body + "  \"status\": \"real-v1\",\n"
    body = body + "  \"thresholds\": {\"dup_helper\": " + to_string(threshold)
    body = body + ", \"oversize_loc\": " + to_string(loc_thr) + "},\n"
    body = body + "  \"candidates\": [\n"
    let mut first = true
    for j in cand_json {
        if !first { body = body + ",\n" }
        body = body + "    " + j
        first = false
    }
    body = body + "\n  ],\n"
    let tot = len(cand_json)
    body = body + "  \"summary\": {\"total\": " + to_string(tot)
    body = body + ", \"dup_helper\": " + to_string(dup_count)
    body = body + ", \"oversize\": " + to_string(oversize_count) + "}\n}\n"

    try { write_file(out_path, body) } catch e {
        eprintln("hx_loss_free_roi_scan: write FAIL " + out_path)
        exit(1)
    }

    println("hx_loss_free_roi_scan: " + to_string(tot) + " candidates ("
          + to_string(dup_count) + " dup_helper, "
          + to_string(oversize_count) + " oversize)")
    println("hx_loss_free_roi_scan: wrote " + out_path)
    exit(0)
}
