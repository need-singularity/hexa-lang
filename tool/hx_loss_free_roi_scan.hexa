// tool/hx_loss_free_roi_scan.hexa — Phase 2 hexa-lang loss-free ROI (stub).
//
// SPEC: docs/hexa_lang_meta_evolution_proposal_20260422.md §Phase 2.
// STATUS: stub — skeleton + --selftest only.
//
// PURPOSE
//   Scan tool/*.hexa + stdlib/ for dup_helper / dead_fn / missing_selftest /
//   missing_header_doc / missing_raw_ref / aot_bin_stale / stdlib_gap /
//   over_500_loc / doc_ref_dead / unused_stdlib / bench_dormant.
//
// CLI
//   hexa tool/hx_loss_free_roi_scan.hexa --selftest
//   hexa tool/hx_loss_free_roi_scan.hexa [--out <path>]
//
// OUTPUT
//   $HEXA_LANG/state/hx_loss_free_roi.json (schema hexa-lang/hx_loss_free_roi/1)

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _iso_now() -> string {
    return to_string(exec("date -u +'%Y-%m-%dT%H:%M:%SZ'")).trim()
}

fn _arg_value(args: array, key: string, default: string) -> string {
    let mut i = 0
    while i < len(args) {
        if args[i] == key {
            let j = i + 1
            if j < len(args) { return args[j] }
        }
        i = i + 1
    }
    return default
}

fn _selftest() -> int {
    if len(_iso_now()) < 10 {
        eprintln("hx_loss_free_roi_scan: selftest FAIL")
        return 1
    }
    println("hx_loss_free_roi_scan: selftest PASS (stub)")
    return 0
}

fn _emit(out_path: string) -> int {
    let ts = _iso_now()
    let body = "{\n  \"schema\": \"hexa-lang/hx_loss_free_roi/1\",\n  \"ts\": \"" + ts + "\",\n  \"status\": \"stub\",\n  \"candidates\": [],\n  \"summary\": {\"dup_helper\": 0, \"dead_fn\": 0, \"missing_selftest\": 0, \"stdlib_gap\": 0, \"aot_stale\": 0}\n}\n"
    try {
        write_file(out_path, body)
    } catch e {
        eprintln("hx_loss_free_roi_scan: write FAIL " + out_path)
        return 1
    }
    println("hx_loss_free_roi_scan: wrote " + out_path + " (stub)")
    return 0
}

fn main() {
    let av = argv()
    let mut args = []
    let mut i = 2
    while i < len(av) { args.push(av[i]); i = i + 1 }

    if len(args) >= 1 && args[0] == "--selftest" {
        exit(_selftest())
    }

    let default_out = _home() + "/core/hexa-lang/state/hx_loss_free_roi.json"
    let out_path = _arg_value(args, "--out", default_out)
    exit(_emit(out_path))
}
