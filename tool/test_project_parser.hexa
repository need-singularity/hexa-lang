// tool/test_project_parser.hexa — project_parser.hexa 검증 스위트
//
// 10+ 케이스: 빈 파일, @project only, 단일 블록, 다중 블록, selector 없음,
// nested list/bool/int/string, map literal, 주석 혼재, legacy ProjectMeta 공존,
// 4 preset (paper/lang/hub/minimal) 생성물, 3 예시 (hexa-lang/n6-arch/anima).
//
// 실행: hexa run tool/test_project_parser.hexa

use "self/attrs/_lib/project_parser"
use "tool/_init/preset_templates"
use "self/core/law_io"

fn assert_eq(label: string, got, expected) -> bool {
    let g = to_string(got)
    let e = to_string(expected)
    if g == e {
        print("  PASS: " + label)
        return true
    }
    print("  FAIL: " + label)
    print("    expected: " + e)
    print("    got:      " + g)
    return false
}

fn assert_true(label: string, cond: bool) -> bool {
    if cond {
        print("  PASS: " + label)
        return true
    }
    print("  FAIL: " + label)
    return false
}

fn case(name: string) {
    print("")
    print("=== " + name + " ===")
}

// ─── 케이스 실행 ─────────────────────────────────────────────

fn main() {
    let mut pass = 0
    let mut fail = 0

    // 1) 빈 content
    case("1) 빈 content")
    let b1 = parse_project_hexa("")
    if assert_eq("blocks.len == 0", len(b1), 0) { pass = pass + 1 } else { fail = fail + 1 }

    // 2) @project 만 — @<name>_rules 가 아니므로 수집 안됨
    case("2) @project 만 있는 파일")
    let src2 = "@project(name=\"x\")\nlet _m = #{\"name\": \"x\"}\n"
    let b2 = parse_project_hexa(src2)
    if assert_eq("blocks.len == 0 (project 는 _rules 아님)", len(b2), 0) { pass = pass + 1 } else { fail = fail + 1 }

    // 3) @doc_rules(type="paper") 단일 블록
    case("3) 단일 @doc_rules(type=\"paper\")")
    let src3 = "@doc_rules(type=\"paper\")\nlet _doc_rules_paper = #{\"sections\": [\"A\", \"B\"], \"require_verify\": true}\n"
    let b3 = parse_project_hexa(src3)
    if assert_eq("blocks.len == 1", len(b3), 1) { pass = pass + 1 } else { fail = fail + 1 }
    if assert_eq("attr == doc", b3[0]["attr"], "doc") { pass = pass + 1 } else { fail = fail + 1 }
    if assert_eq("selector.type == paper", b3[0]["selector"]["type"], "paper") { pass = pass + 1 } else { fail = fail + 1 }
    if assert_eq("body.sections == [A,B]", b3[0]["body"]["sections"], ["A", "B"]) { pass = pass + 1 } else { fail = fail + 1 }
    if assert_eq("body.require_verify == true", b3[0]["body"]["require_verify"], true) { pass = pass + 1 } else { fail = fail + 1 }

    // 4) @doc_rules 여러 블록 (type 별)
    case("4) 다중 @doc_rules(type=\"paper\"|\"rfc\"|\"adr\")")
    let src4 = "@doc_rules(type=\"paper\")\nlet _a = #{\"sections\": [\"WHY\"]}\n\n@doc_rules(type=\"rfc\")\nlet _b = #{\"sections\": [\"Status\"]}\n\n@doc_rules(type=\"adr\")\nlet _c = #{\"sections\": [\"Context\"]}\n"
    let b4 = parse_project_hexa(src4)
    if assert_eq("blocks.len == 3", len(b4), 3) { pass = pass + 1 } else { fail = fail + 1 }
    let paper = find_block(b4, "doc", #{"type": "paper"})
    if assert_eq("find paper", paper["sections"], ["WHY"]) { pass = pass + 1 } else { fail = fail + 1 }
    let rfc = find_block(b4, "doc", #{"type": "rfc"})
    if assert_eq("find rfc", rfc["sections"], ["Status"]) { pass = pass + 1 } else { fail = fail + 1 }
    let adr = find_block(b4, "doc", #{"type": "adr"})
    if assert_eq("find adr", adr["sections"], ["Context"]) { pass = pass + 1 } else { fail = fail + 1 }

    // 5) @readme_rules(scope="root")
    case("5) @readme_rules(scope=\"root\")")
    let src5 = "@readme_rules(scope=\"root\")\nlet _r = #{\"sections\": [\"Overview\", \"License\"], \"require_sealed\": true}\n"
    let b5 = parse_project_hexa(src5)
    if assert_eq("blocks.len == 1", len(b5), 1) { pass = pass + 1 } else { fail = fail + 1 }
    if assert_eq("attr == readme", b5[0]["attr"], "readme") { pass = pass + 1 } else { fail = fail + 1 }
    let rm = find_block(b5, "readme", #{"scope": "root"})
    if assert_eq("find readme/root", rm["require_sealed"], true) { pass = pass + 1 } else { fail = fail + 1 }

    // 6) nested list + bool + int + string
    case("6) nested list + bool + int + string")
    let src6 = "@domain_rules\nlet _d = #{\"axes\": [\"a\", \"b\", \"c\"], \"id_max_length\": 40, \"alien_target_default\": 10, \"require_prev\": false, \"registry_path\": \"n6shared/n6/docs/domains.json\"}\n"
    let b6 = parse_project_hexa(src6)
    let d = find_block(b6, "domain", #{})
    if assert_eq("axes len == 3", len(d["axes"]), 3) { pass = pass + 1 } else { fail = fail + 1 }
    if assert_eq("id_max_length == 40", d["id_max_length"], 40) { pass = pass + 1 } else { fail = fail + 1 }
    if assert_eq("alien_target_default == 10", d["alien_target_default"], 10) { pass = pass + 1 } else { fail = fail + 1 }
    if assert_eq("require_prev == false", d["require_prev"], false) { pass = pass + 1 } else { fail = fail + 1 }
    if assert_eq("registry_path string", d["registry_path"], "n6shared/n6/docs/domains.json") { pass = pass + 1 } else { fail = fail + 1 }

    // 7) map literal 중첩
    case("7) 중첩 map literal")
    let src7 = "@publish_rules\nlet _p = #{\"templates\": #{\"create\": \"feat\", \"update\": \"chore\"}, \"encoding\": \"utf-8\"}\n"
    let b7 = parse_project_hexa(src7)
    let p = find_block(b7, "publish", #{})
    if assert_eq("templates.create == feat", p["templates"]["create"], "feat") { pass = pass + 1 } else { fail = fail + 1 }
    if assert_eq("templates.update == chore", p["templates"]["update"], "chore") { pass = pass + 1 } else { fail = fail + 1 }
    if assert_eq("encoding", p["encoding"], "utf-8") { pass = pass + 1 } else { fail = fail + 1 }

    // 8) 주석 혼재
    case("8) // 주석 혼재")
    let src8 = "// top comment\n@sealed_rules\n// inline comment\nlet _s = #{\"hash_algorithm\": \"sdbm+len\", \"first_seal_severity\": \"info\"}\n// trailing\n"
    let b8 = parse_project_hexa(src8)
    let s = find_block(b8, "sealed", #{})
    if assert_eq("sealed hash_algorithm", s["hash_algorithm"], "sdbm+len") { pass = pass + 1 } else { fail = fail + 1 }
    if assert_eq("sealed first_seal_severity", s["first_seal_severity"], "info") { pass = pass + 1 } else { fail = fail + 1 }

    // 9) legacy ProjectMeta struct/fn 공존
    case("9) legacy ProjectMeta struct/fn 공존")
    let src9 = "struct ProjectMeta { name: string }\nfn project_meta() -> ProjectMeta { return ProjectMeta { name: \"x\" } }\n\n@doc_rules(type=\"spec\")\nlet _ds = #{\"sections\": [\"Overview\", \"Syntax\"]}\n"
    let b9 = parse_project_hexa(src9)
    if assert_eq("blocks.len == 1 (legacy 함께)", len(b9), 1) { pass = pass + 1 } else { fail = fail + 1 }
    let spec = find_block(b9, "doc", #{"type": "spec"})
    if assert_eq("spec sections", spec["sections"], ["Overview", "Syntax"]) { pass = pass + 1 } else { fail = fail + 1 }

    // 10) find_block — selector 매칭 엄격성
    case("10) selector 불일치 → empty map")
    let miss = find_block(b4, "doc", #{"type": "whitepaper"})
    if assert_eq("miss == empty", len(keys(miss)), 0) { pass = pass + 1 } else { fail = fail + 1 }

    // 11~14) 4 preset 생성물 — preset_templates 렌더러 직접 호출
    // (hexa init 서브커맨드는 별도 에이전트가 구현 중이므로 render 함수 직접 사용)
    case("11~14) 4 preset (paper/lang/hub/minimal) render + parse")
    let presets = ["paper", "lang", "hub", "minimal"]
    for pr in presets {
        let mut content = ""
        if pr == "minimal" { content = preset_minimal("test_" + pr, "/Users/ghost/core/hexa-lang") }
        else if pr == "paper" { content = preset_paper("test_" + pr, "/Users/ghost/core/hexa-lang") }
        else if pr == "lang" { content = preset_lang("test_" + pr, "/Users/ghost/core/hexa-lang") }
        else if pr == "hub" { content = preset_hub("test_" + pr, "/Users/ghost/core/hexa-lang") }
        let pf = "/tmp/_pp_test_preset_" + pr + ".hexa"
        safe_write_file(pf, content)
        // 1) hexa parse 자체 통과 필요
        let pr_rc = to_string(exec("hexa parse '" + pf + "' 2>&1"))
        let ok = pr_rc.contains("OK:")
        if assert_true("preset=" + pr + " hexa parse OK", ok) { pass = pass + 1 } else {
            fail = fail + 1
            print("    output: " + pr_rc)
        }
        // 2) project_parser 가 블록 추출 가능 (minimal 은 0 블록 정상)
        let blocks = parse_project_hexa_file(pf)
        if pr == "minimal" {
            if assert_eq("preset=minimal blocks == 0", len(blocks), 0) { pass = pass + 1 } else { fail = fail + 1 }
        } else {
            if assert_true("preset=" + pr + " blocks >= 1", len(blocks) >= 1) { pass = pass + 1 } else { fail = fail + 1 }
        }
    }

    // 15~17) 3 예시 파일 (hexa-lang / n6-architecture / anima) — β 형식 변환 후 parse
    case("15~17) 3 예시 파일 parse")
    let examples = ["hexa-lang", "n6-architecture", "anima"]
    for ex in examples {
        let path = "/Users/ghost/core/hexa-lang/docs/self_format_examples/" + ex + ".project.hexa"
        let exists = to_string(exec("test -f '" + path + "' && printf 1 || printf 0")).trim()
        if exists != "1" {
            print("  SKIP: " + ex + " — 파일 없음")
            continue
        }
        let blocks = parse_project_hexa_file(path)
        if assert_true(ex + " blocks >= 1", len(blocks) >= 1) { pass = pass + 1 } else { fail = fail + 1 }
    }

    print("")
    print("==========================================")
    print("총 " + to_string(pass + fail) + "건 — PASS " + to_string(pass) + " / FAIL " + to_string(fail))
    print("==========================================")
    if fail > 0 {
        exec("exit 1")
    }
}

main()
