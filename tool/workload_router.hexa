// tool/workload_router.hexa — emit docker-exec command for the top-ranked host
//
// @tool(slug="workload_router", desc="emit docker exec command line for the top-ranked host given a workload spec")
// @usage(hexa /Users/ghost/core/hexa-lang/tool/workload_router.hexa <capability_csv> <memory_hint_gib> [--path <file>] -- <workload_cmd...>)
// @example(workload_router.hexa gpu,cuda13 8 -- hexa nexus drill --seed foo → emits: docker -H ssh://ubu exec -i airgenome-claude hexa nexus drill --seed foo)
// @exit_codes(0=ok+command on stdout, 1=no host matches, 2=parse error, 3=top host unreachable / lookup failed)
//
// PROBLEM
//   Take a workload spec (required-capabilities, memory-hint, command +
//   args) and an inventory (.resource) and produce the canonical
//   `docker [-H ssh://<alias>] exec -i <container> <cmd...>` line for
//   the highest-scoring host. This is the hot-path entry point; the
//   docker-exec channel adapter (TS, control-plane glue) consumes the
//   tokens this script emits.
//
// HOT PATH BOUNDARY
//   Per raw.ai_native_algo: the algorithm core (scoring + selection) is
//   hexa-lang. TS only spawns docker. This script is the seam. Calling
//   convention: `--` separates router args from workload tokens so the
//   router never has to escape inner quoting.
//
// FALLBACK
//   resource_scorer is invoked via _exec_scorer rather than module
//   import (interp hexa-lang has no module loader at top-level user
//   scripts). Cost: one fork per dispatch; amortised by the docker-exec
//   channel reusing the resulting container connection across many
//   send() calls.

// ─── YAML SSOT loader (2026-05-07: raw-format DSL → YAML migration) ──────
//
// Sister to hive's tool/workload_router.hexa loader. Shells out to
// `python3 $HOME/.hx/packages/resource/tool/yaml_dump.py <path>` per
// dispatch.002 — emits flat ---ENTRY--- / key=value text stream that this
// loader reassembles into the canonical 4-tuple [id, status, name, keys].

fn _load_resource(path: string) -> array {
    let exists = to_string(exec("test -f '" + path + "' && echo y || echo n")).trim()
    if exists != "y" { return [] }
    let helper = env("HOME") + "/.hx/packages/resource/tool/yaml_dump.py"
    let helper_exists = to_string(exec("test -f '" + helper + "' && echo y || echo n")).trim()
    if helper_exists != "y" { return [] }
    let cmd = "python3 '" + helper + "' '" + path + "' 2>/dev/null"
    let raw = to_string(exec(cmd))
    let lines = split(raw, "\n")
    let mut rules = []
    let mut cur_id = ""
    let mut cur_status = ""
    let mut cur_name = ""
    let mut cur_keys = []
    let mut has_rule = false
    for line in lines {
        if line == "---ENTRY---" {
            if has_rule { rules.push([cur_id, cur_status, cur_name, cur_keys]) }
            cur_id = ""
            cur_status = ""
            cur_name = ""
            cur_keys = []
            has_rule = true
            continue
        }
        if !has_rule { continue }
        let eq = line.index_of("=")
        if eq <= 0 { continue }
        let key = line.substring(0, eq)
        let val = line.substring(eq + 1, len(line))
        if key == "num" { cur_id = val }
        else if key == "status" { cur_status = val }
        else if key == "name" { cur_name = val }
        else { cur_keys.push([key, val]) }
    }
    if has_rule { rules.push([cur_id, cur_status, cur_name, cur_keys]) }
    return rules
}

fn _keys_first(keys: array, k: string) -> string {
    for kv in keys {
        if kv[0] == k { return kv[1] }
    }
    return ""
}

fn _pwd() -> string {
    let mut p = env("PWD")
    if p == "" { p = to_string(exec("pwd")).trim() }
    return p
}

// Invoke resource_scorer.hexa, capture top slug. Forks one hexa
// subprocess per dispatch; the docker-exec channel amortises this by
// reusing the container connection across send() calls.
fn _top_slug(cap_csv: string, mem_hint_s: string, path: string) -> array {
    let scorer = "/Users/ghost/core/hexa-lang/tool/resource_scorer.hexa"
    let cmd = "hexa " + scorer + " '" + cap_csv + "' '" + mem_hint_s + "' --path '" + path + "'"
    let raw = to_string(exec(cmd))
    let out = raw.trim_end()
    if len(out) == 0 { return [] }
    let lines = split(out, "\n")
    if len(lines) == 0 { return [] }
    let first = lines[0].trim()
    if len(first) == 0 { return [] }
    let sp = first.index_of(" ")
    if sp < 0 { return [first, ""] }
    let score = first.substring(0, sp)
    let slug = first.substring(sp + 1, len(first)).trim()
    return [slug, score]
}

// Lookup a host entry by slug. Returns the keys array or [] on miss.
fn _lookup_host(rules: array, slug: string) -> array {
    for r in rules {
        let keys = r[3]
        let kind = _keys_first(keys, "kind")
        if kind != "host" { continue }
        let s = _keys_first(keys, "slug")
        if s == slug { return keys }
    }
    return []
}

// ─── argv parsing ────────────────────────────────────────────────
let _raw_args = args()
let mut cli = []
let mut _ai = 2
while _ai < len(_raw_args) {
    cli.push(_raw_args[_ai])
    _ai = _ai + 1
}

let mut router_args = []
let mut workload_args = []
let mut seen_sep = false
let mut path_arg = ""
let mut k = 0
while k < len(cli) {
    let a = cli[k]
    if !seen_sep && a == "--" { seen_sep = true; k = k + 1; continue }
    if seen_sep { workload_args.push(a); k = k + 1; continue }
    if a == "--path" {
        if k + 1 < len(cli) { path_arg = cli[k + 1]; k = k + 2; continue }
    }
    router_args.push(a)
    k = k + 1
}

if len(router_args) < 2 {
    eprintln("workload_router: usage — <capability_csv> <memory_hint_gib> [--path <file>] -- <cmd...>")
    eprintln("                 try: workload_router.hexa gpu,cuda13 8 -- hexa nexus drill")
    exit(2)
}
if len(workload_args) == 0 {
    eprintln("workload_router: missing workload command after `--`")
    eprintln("                 try: workload_router.hexa gpu,cuda13 8 -- echo hello")
    exit(2)
}

let cap_csv = router_args[0]
let mem_hint_s = router_args[1]
let path = if len(path_arg) > 0 { path_arg } else { _pwd() + "/.resource" }

let rules = _load_resource(path)
if len(rules) == 0 {
    eprintln("workload_router: no .resource entries at " + path +
             " — try: place a .resource at $PWD or pass --path <file>")
    exit(2)
}

let pick = _top_slug(cap_csv, mem_hint_s, path)
if len(pick) == 0 {
    eprintln("workload_router: scorer returned no candidate for caps='" + cap_csv +
             "' mem=" + mem_hint_s + " — try: hexa resource_scorer.hexa " + cap_csv +
             " " + mem_hint_s + " --path " + path)
    exit(1)
}

let slug = pick[0]
let host = _lookup_host(rules, slug)
if len(host) == 0 {
    eprintln("workload_router: top slug '" + slug + "' not present in " + path +
             " — try: re-run resource_lint to verify SSOT integrity")
    exit(3)
}

let ssh_alias = _keys_first(host, "ssh-alias")
let container = _keys_first(host, "container")
let mem_cap = _keys_first(host, "container-memory-cap")

if container == "" {
    eprintln("workload_router: host '" + slug + "' missing container — try: hexa resource_lint.hexa")
    exit(3)
}

// ─── emit docker exec command line ────────────────────────────────
//
// Form:
//   docker [-H ssh://<alias>] exec -i [-m <cap>g] <container> <cmd...>
//
// `-i` keeps stdin attached so the docker-exec channel can write
// frames. `-m <cap>g` enforces the cgroup memory cap from .resource
// (bare-host fork was banned post-2026-04-20 ubu2 OOM event).
let mut argv = ["docker"]
if ssh_alias != "" && ssh_alias != "localhost" {
    argv.push("-H"); argv.push("ssh://" + ssh_alias)
}
argv.push("exec"); argv.push("-i")
if len(mem_cap) > 0 {
    argv.push("-m"); argv.push(mem_cap + "g")
}
argv.push(container)
for w in workload_args { argv.push(w) }

println(argv.join(" "))
exit(0)
