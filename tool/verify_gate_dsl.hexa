// tool/verify_gate_dsl.hexa — Tier3#19: gate 정의 syntax (structured)
//
// PURPOSE
//   Parses .roadmap Verification-gates section (markdown → structured JSON):
//     ## P<N> gate (<label>)
//     # satisfied:
//     #   ✓ <item>
//     # pending:
//     #   □ <item>
//   Classifies each item as:
//     - satisfied / pending (status)
//     - hard (inside P<N> gate pending/satisfied) or soft (hints elsewhere)
//     - evidence refs (commit SHAs, cert slugs, anchor tokens)
//
// OUTPUT
//   JSON-like structured dump (deterministic key order).
//
// CLI
//   hexa tool/verify_gate_dsl.hexa --repo <name>
//   hexa tool/verify_gate_dsl.hexa --all
//   hexa tool/verify_gate_dsl.hexa --selftest

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _repo_root(name: string) -> string {
    return _home() + "/core/" + name
}

fn _rstrip(s: string) -> string {
    let mut end = len(s)
    while end > 0 {
        let c = s.substring(end - 1, end)
        if c == " " || c == "\t" || c == "\r" { end = end - 1 } else { break }
    }
    return s.substring(0, end)
}

// Extract commit SHA-like tokens from a string (7–40 hex run).
fn _extract_shas(note: string) -> array {
    let mut out = []
    if len(note) == 0 { return out }
    let hex = "0123456789abcdefABCDEF"
    let mut i = 0
    while i < len(note) {
        let c = note.substring(i, i + 1)
        if hex.contains(c) {
            let mut j = i
            while j < len(note) && hex.contains(note.substring(j, j + 1)) { j = j + 1 }
            let run = note.substring(i, j)
            let rl = len(run)
            if rl >= 7 && rl <= 40 { out.push(run) }
            i = j
        } else {
            i = i + 1
        }
    }
    return out
}

// Parse roadmap text → sections map: [ [phase_id, label, satisfied_list, pending_list] ... ]
fn parse_gates(src: string) -> array {
    let lines = split(src, "\n")
    let mut gates = []
    let mut cur_phase = ""
    let mut cur_label = ""
    let mut cur_sat = []
    let mut cur_pend = []
    let mut cur_mode = ""   // "" | "sat" | "pend"
    let mut i = 0
    while i < len(lines) {
        let raw_line = lines[i]
        let line = _rstrip(raw_line)
        i = i + 1

        // Section header: "## P1 gate (Mk.VI VERIFIED)"
        if line.starts_with("## P") && line.contains(" gate") {
            // flush current
            if len(cur_phase) > 0 {
                gates.push([cur_phase, cur_label, cur_sat, cur_pend])
            }
            cur_sat = []
            cur_pend = []
            cur_mode = ""
            // extract phase id (P1, P2, P3, P7-6, ...)
            let rest = line.substring(3, len(line))   // after "## "
            let sp = rest.index_of(" ")
            if sp < 0 { cur_phase = rest } else { cur_phase = rest.substring(0, sp) }
            // label from parentheses
            let p1 = line.index_of("(")
            let p2 = line.index_of(")")
            if p1 > 0 && p2 > p1 { cur_label = line.substring(p1 + 1, p2) } else { cur_label = "" }
            continue
        }

        // Stay inside a gate section only if line begins with '#' (commentary block)
        // An empty line or non-'#' line does NOT end the section — we only break on next '## '.
        if len(cur_phase) == 0 { continue }
        if len(line) == 0 { continue }

        if !line.starts_with("#") { continue }

        // Strip leading '#' + optional spaces
        let body = line.substring(1, len(line)).trim_start()
        if body == "satisfied:" { cur_mode = "sat"; continue }
        if body == "pending:" { cur_mode = "pend"; continue }

        // Item line
        if body.starts_with("✓ ") || body.starts_with("✓") {
            let txt = body.substring(1, len(body)).trim_start()
            let shas = _extract_shas(txt)
            cur_sat.push([txt, shas])
            continue
        }
        if body.starts_with("□ ") || body.starts_with("□") {
            let txt = body.substring(1, len(body)).trim_start()
            let shas = _extract_shas(txt)
            cur_pend.push([txt, shas])
            continue
        }
        // deps-internal / deps-external lines — ignored for item parse
    }
    if len(cur_phase) > 0 {
        gates.push([cur_phase, cur_label, cur_sat, cur_pend])
    }
    return gates
}

// JSON-serialize (deterministic, minimal)
fn _esc_json(s: string) -> string {
    let mut parts = []
    let mut i = 0
    while i < len(s) {
        let c = s.substring(i, i + 1)
        if c == "\\" { parts.push("\\\\") }
        else if c == "\"" { parts.push("\\\"") }
        else if c == "\n" { parts.push("\\n") }
        else if c == "\t" { parts.push("\\t") }
        else { parts.push(c) }
        i = i + 1
    }
    return parts.join("")
}

fn _items_json(items: array) -> string {
    let mut parts = []
    parts.push("[")
    let mut first = true
    for it in items {
        if !first { parts.push(",") }
        first = false
        parts.push("{\"text\":\"")
        parts.push(_esc_json(it[0]))
        parts.push("\",\"shas\":[")
        let mut fs = true
        for s in it[1] {
            if !fs { parts.push(",") }
            fs = false
            parts.push("\"")
            parts.push(s)
            parts.push("\"")
        }
        parts.push("],\"hard\":true}")
    }
    parts.push("]")
    return parts.join("")
}

fn gates_to_json(repo: string, gates: array) -> string {
    let mut parts = []
    parts.push("{\"repo\":\"")
    parts.push(_esc_json(repo))
    parts.push("\",\"gates\":[")
    let mut first = true
    for g in gates {
        if !first { parts.push(",") }
        first = false
        parts.push("{\"phase\":\"")
        parts.push(_esc_json(g[0]))
        parts.push("\",\"label\":\"")
        parts.push(_esc_json(g[1]))
        parts.push("\",\"satisfied\":")
        parts.push(_items_json(g[2]))
        parts.push(",\"pending\":")
        parts.push(_items_json(g[3]))
        parts.push(",\"counts\":{\"satisfied\":")
        parts.push(to_string(len(g[2])))
        parts.push(",\"pending\":")
        parts.push(to_string(len(g[3])))
        parts.push(",\"total\":")
        parts.push(to_string(len(g[2]) + len(g[3])))
        parts.push("}}")
    }
    parts.push("]}")
    return parts.join("")
}

fn load_gates(repo: string) -> array {
    let path = _repo_root(repo) + "/.roadmap"
    let r = exec_with_status("test -f '" + path + "'")
    if r[1] != 0 { return [] }
    return parse_gates(to_string(read_file(path)))
}

fn _selftest() -> int {
    // anima has 3 P-gates (P1, P2, P3) per session 2026-04-21.
    let a = load_gates("anima")
    if len(a) < 3 {
        eprintln("selftest FAIL: anima gates < 3 (got " + to_string(len(a)) + ")")
        return 1
    }
    let mut saw_p1 = false
    let mut saw_p2 = false
    let mut saw_p3 = false
    for g in a {
        if g[0] == "P1" { saw_p1 = true }
        if g[0] == "P2" { saw_p2 = true }
        if g[0] == "P3" { saw_p3 = true }
    }
    if !(saw_p1 && saw_p2 && saw_p3) {
        eprintln("selftest FAIL: missing P1/P2/P3 in anima")
        return 1
    }

    // Each gate must have at least 1 pending (hard-required).
    for g in a {
        if len(g[3]) == 0 {
            eprintln("selftest FAIL: " + g[0] + " has 0 pending")
            return 1
        }
    }

    // JSON output parseable shape — dump size > 100 bytes
    let js = gates_to_json("anima", a)
    if len(js) < 100 {
        eprintln("selftest FAIL: JSON dump too small")
        return 1
    }

    // hexa-lang also has 3 P-gates
    let h = load_gates("hexa-lang")
    if len(h) < 3 {
        eprintln("selftest FAIL: hexa-lang gates < 3 (got " + to_string(len(h)) + ")")
        return 1
    }

    println("verify_gate_dsl selftest PASS — anima 3 P gates + hexa-lang 3 P gates parsed → structured JSON")
    println("  anima P1 pending=" + to_string(len(a[0][3])) + " satisfied=" + to_string(len(a[0][2])))
    println("  anima P2 pending=" + to_string(len(a[1][3])) + " satisfied=" + to_string(len(a[1][2])))
    println("  anima P3 pending=" + to_string(len(a[2][3])) + " satisfied=" + to_string(len(a[2][2])))
    return 0
}

fn _cmd_repo(repo: string) -> int {
    let g = load_gates(repo)
    if len(g) == 0 {
        eprintln("no gates parsed for " + repo)
        return 1
    }
    println(gates_to_json(repo, g))
    return 0
}

fn main() {
    let av = argv()
    let mut args = []
    let mut i = 2
    while i < len(av) { args.push(av[i]); i = i + 1 }

    if len(args) == 0 {
        eprintln("usage: --repo <name> | --all | --selftest")
        exit(1)
    }
    if args[0] == "--selftest" { exit(_selftest()) }
    if args[0] == "--all" {
        let mut rc = 0
        for r in ["anima", "airgenome", "hexa-lang"] {
            let c = _cmd_repo(r)
            if c != 0 { rc = c }
        }
        exit(rc)
    }
    if args[0] == "--repo" && len(args) >= 2 {
        exit(_cmd_repo(args[1]))
    }
    eprintln("usage: --repo <name> | --all | --selftest")
    exit(1)
}
