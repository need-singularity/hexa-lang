#!hexa strict
// tool/aot_native_trivial.hexa — SH3 phase 1.C first prototype.
//
// Compiles a TRIVIAL .hexa source — exactly the pattern
//   println("<string-literal>")
// as a single top-level statement — straight to an ARM64 Mach-O
// executable without invoking clang, as, or ld. This is the first
// SH3 wedge that crosses the C-substrate boundary: hexa source →
// in-process AST → codegen_native helpers → Mach-O hex → binary.
//
// Usage:
//   hexa tool/aot_native_trivial.hexa <input.hexa> [<output>]
// Default output: /tmp/<basename>.native
//
// Phase 2.A: produced binary prints the actual literal up to 256
// bytes. Longer literals would prefer .rodata addressing — deferred
// to phase 3.
//
// Exit codes:
//   0 = native binary produced
//   2 = usage error
//   3 = source not in trivial subset (fallback expected)
//   4 = string literal too long for phase 2 (> 256 bytes)

use "self/lexer"
use "self/parser"
use "self/codegen_native"

// SH3 phase 2.C/F: constant-fold IntLit / BinOp(+−*/%) / Ident tree at
// compile time. `vars` is a name→int dictionary populated by LetStmt
// processing. Aborts with exit 3 on any non-const node or undefined
// Ident. Runtime evaluation (function calls, control flow, runtime
// arith) is later phases.
fn const_eval_int(node, vars) -> int {
    let k = node["kind"]
    if k == "IntLit" {
        return node["value"]
    }
    if k == "Ident" {
        let name = node["name"]
        // hexa map: missing key returns void + warning; we surface a
        // typed error instead of letting void leak into arith.
        let v = vars[name]
        if str(v) == "void" {
            eprintln("not trivial: undefined variable '" + name + "'")
            exit(3)
        }
        return v
    }
    if k == "BinOp" {
        let l = const_eval_int(node["left"], vars)
        let r = const_eval_int(node["right"], vars)
        let op = node["op"]
        if op == "+" { return l + r }
        if op == "-" { return l - r }
        if op == "*" { return l * r }
        // hexa's / produces float on int operands inside this fn; force
        // integer (truncation toward zero) via the modulo identity.
        if op == "/" { return (l - (l % r)) / r }
        if op == "%" { return l % r }
        eprintln("not trivial: unsupported BinOp '" + op + "'")
        exit(3)
    }
    eprintln("not trivial: const-eval expects IntLit / Ident / BinOp, got " + k)
    exit(3)
    return 0
}

// SH3 phase 2.E: const-fold comparison BinOp / BoolLit at compile
// time. Returns "true" or "false" as a string (matches hexa's
// println(bool) output exactly).
fn is_cmp_op(op: string) -> bool {
    return op == "==" || op == "!=" || op == "<" || op == ">" || op == "<=" || op == ">="
}

fn const_eval_bool_str(node, vars) -> string {
    let k = node["kind"]
    if k == "BoolLit" {
        // BoolLit value can be the boolean true/false or its string form;
        // normalize via str() so the comparison is unambiguous.
        if str(node["value"]) == "true" { return "true" }
        return "false"
    }
    if k == "BinOp" {
        let op = node["op"]
        if is_cmp_op(op) {
            let l = const_eval_int(node["left"], vars)
            let r = const_eval_int(node["right"], vars)
            if op == "==" { if l == r { return "true" } else { return "false" } }
            if op == "!=" { if l != r { return "true" } else { return "false" } }
            if op == "<"  { if l <  r { return "true" } else { return "false" } }
            if op == ">"  { if l >  r { return "true" } else { return "false" } }
            if op == "<=" { if l <= r { return "true" } else { return "false" } }
            if op == ">=" { if l >= r { return "true" } else { return "false" } }
        }
    }
    eprintln("not trivial: const-eval-bool expects BoolLit or comparison BinOp, got " + k)
    exit(3)
    return ""
}

fn is_arith_op(op: string) -> bool {
    return op == "+" || op == "-" || op == "*" || op == "/" || op == "%"
}

let av = real_args()
if len(av) < 1 {
    eprintln("usage: hexa tool/aot_native_trivial.hexa <input.hexa> [<output>]")
    exit(2)
}
let input = av[0]
let mut output = ""
if len(av) >= 2 {
    output = av[1]
} else {
    let base_cmd = "basename '" + input + "' .hexa | tr -d '\\n'"
    let base = exec(base_cmd)
    output = "/tmp/" + base + ".native"
}

let src = to_string(read_file(input))
let tokens = tokenize(src)
let ast = parse(tokens)

if len(ast) < 1 {
    eprintln("not trivial: empty AST")
    exit(3)
}

// Phase 2.F: any leading LetStmt(s) populate a const-vars dict;
// the final statement must be the println ExprStmt. The dict is
// keyed by Ident name → int.
//
// Known issue (queued for next quiet-binary cycle): hexa interp
// drops the map view when const_eval_int(ls["left"], vars) is
// called on certain hexa builds — node["kind"] no longer matches
// "BinOp" inside the fn body even though the same field access
// works at the top level. Same class of cross-fn type-inference
// drift that hit byte_len(s) in 1.D run-3 and the type-tag drop
// in 2.E. Workaround under investigation; phase 2.F functional
// witness is therefore deferred along with 2.E.
let mut vars = #{}
let mut idx = 0
while idx < len(ast) - 1 {
    let ls = ast[idx]
    if ls["kind"] != "LetStmt" {
        eprintln("not trivial: leading statements must be LetStmt, got " + ls["kind"] + " at index " + str(idx))
        exit(3)
    }
    let lname = ls["name"]
    // parser stores the binding's RHS expression in `left`.
    let lval = const_eval_int(ls["left"], vars)
    vars[lname] = lval
    idx = idx + 1
}
let stmt = ast[len(ast) - 1]
if stmt["kind"] != "ExprStmt" {
    eprintln("not trivial: final statement must be ExprStmt, got " + stmt["kind"])
    exit(3)
}
let expr = stmt["left"]
if expr["kind"] != "Call" {
    eprintln("not trivial: expected Call, got " + expr["kind"])
    exit(3)
}
let callee = expr["left"]
if callee["kind"] != "Ident" || callee["name"] != "println" {
    eprintln("not trivial: expected Ident('println') as callee")
    exit(3)
}
let call_args = expr["args"]
if len(call_args) != 1 {
    eprintln("not trivial: expected exactly 1 arg")
    exit(3)
}
let arg0 = call_args[0]
let mut lit = ""
if arg0["kind"] == "StringLit" {
    lit = arg0["value"]
    println("trivial-subset matched: println(\"" + lit + "\")")
} else if arg0["kind"] == "BoolLit" {
    // Phase 2.E: bool literal → 'true'/'false'.
    lit = const_eval_bool_str(arg0, vars)
    println("trivial-subset matched: println(<bool " + lit + ">)  // BoolLit")
} else if arg0["kind"] == "IntLit" {
    // Phase 2.B: int literal.
    lit = str(arg0["value"])
    println("trivial-subset matched: println(" + lit + ")  // IntLit")
} else if arg0["kind"] == "Ident" {
    // Phase 2.F: variable reference resolved through vars.
    let v = const_eval_int(arg0, vars)
    lit = str(v)
    println("trivial-subset matched: println(<vars " + arg0["name"] + "=" + lit + ">)  // Ident")
} else if arg0["kind"] == "BinOp" {
    // Phase 2.C arith / 2.E comparison — disambiguate by op kind.
    // Phase 2.F: BinOp can now reference vars vars via Ident.
    let op = arg0["op"]
    if is_cmp_op(op) {
        lit = const_eval_bool_str(arg0, vars)
        println("trivial-subset matched: println(<const-bool " + lit + ">)  // BinOp(" + op + ")")
    } else if is_arith_op(op) {
        let v = const_eval_int(arg0, vars)
        lit = str(v)
        println("trivial-subset matched: println(<const-int " + lit + ">)  // BinOp(" + op + ")")
    } else {
        eprintln("not trivial: unsupported BinOp '" + op + "'")
        exit(3)
    }
} else {
    eprintln("not trivial: expected StringLit, BoolLit, IntLit, Ident, or BinOp arg, got " + arg0["kind"])
    exit(3)
}

// 1.D: dynamic emit. Empty hex means "literal too long" → exit 4.
let hex = build_println_dyn(lit)
if hex == "" {
    eprintln("error: string literal too long for phase 2 (> 256 bytes); phase 3 .rodata path will lift this")
    exit(4)
}

// Materialize binary. Single-shot exec chain — no clang, no as, no ld.
let cmd1 = "printf '%s' '" + hex + "' | xxd -r -p > '" + output + "'"
let _r1 = exec(cmd1)
let _r2 = exec("chmod +x '" + output + "'")
let _r3 = exec("codesign -s - -f '" + output + "' 2>&1 1>/dev/null")
let test = exec("test -x '" + output + "' && printf yes || printf no")
if test != "yes" {
    eprintln("error: output not executable: " + output)
    exit(1)
}
println("native: " + output)
