// tool/regression_stdin.hexa — rt 35 regression
//
// `hexa run <script>` 의 부모 stdin → 자식 interp 전달 회귀 방지.
// main.hexa:cmd_run 에서 `( interp ) &` background 서브셸은 POSIX
// asynchronous_list 규칙상 자식 stdin 을 /dev/null 로 재지정. fd 3 복제로
// 우회. 이 테스트가 실패하면 Claude Code UserPromptSubmit hook 전체 사일런트.
//
// Usage: hexa run tool/regression_stdin.hexa
// Exit:  0 pass / 1 regression detected

use "self/core/law_io"

// HEXA 환경변수 우선: 과거 바이너리로 회귀 검증 시 `HEXA=./hexa.prev …`
let HEXA = env("HEXA") ?? (env("HOME") + "/Dev/hexa-lang/hexa")
let PROBE = "STDIN_ROUNDTRIP_OK_" + to_string(exec("echo $$")).trim()
let SCRIPT = "/tmp/rt35_stdin_probe.hexa"

fn log(tag, msg) {
    println("[rt35:" + tag + "] " + msg)
}

safe_write_file(SCRIPT, "let s = read_stdin()\nprintln(s)\n")

let cmd = "printf '%s' '" + PROBE + "' | '" + HEXA + "' run '" + SCRIPT + "' 2>&1"
let out = to_string(exec(cmd)).trim()
exec("rm -f '" + SCRIPT + "'")

if out == PROBE {
    log("PASS", "stdin round-trip OK (" + PROBE + ")")
    exit(0)
}

log("FAIL", "expected=[" + PROBE + "]")
log("FAIL", "got=[" + out + "]")
log("FAIL", "cmd_run stdin fd 3 regression — check self/main.hexa:561")
exit(1)
