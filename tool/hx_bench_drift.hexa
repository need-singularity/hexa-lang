// tool/hx_bench_drift.hexa — Phase 3.3 bench regression detector (real-v1).
//
// SPEC: docs/hexa_lang_meta_evolution_proposal_20260422.md §3.3.
// STATUS: v1 real — inventory bench/*.hexa + parse state/bench_history.jsonl
//         (if present), group by bench name, compare rolling 7d mean vs
//         last 24h sample. Regression when latest > mean × (1 + threshold%).
//         Actual benchmark execution (record subcommand) deferred to v2.
//
// CLI
//   hexa tool/hx_bench_drift.hexa --selftest
//   hexa tool/hx_bench_drift.hexa [--threshold-pct N] [--out <path>]
//
// INPUT
//   $HEXA_LANG/state/bench_history.jsonl  (append-only events, schema:
//     {"ts":"<iso>","bench":"<name>","runtime_ms":N,"mem_kb":N})
//
// OUTPUT
//   $HEXA_LANG/state/hx_bench_drift.json  (schema hexa-lang/hx_bench_drift/1)

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _iso_now() -> string {
    return to_string(exec("date -u +'%Y-%m-%dT%H:%M:%SZ'")).trim()
}

fn _arg_value(args: array, key: string, default: string) -> string {
    let mut i = 0
    while i < len(args) {
        if args[i] == key {
            let j = i + 1
            if j < len(args) { return args[j] }
        }
        i = i + 1
    }
    return default
}

fn _json_esc(s: string) -> string {
    let mut r = s.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", "\\n")
    r = r.replace("\r", "")
    r = r.replace("\t", " ")
    return r
}

fn _split_lines(s: string) -> array {
    let mut out = []
    let mut cur = ""
    let mut i = 0
    while i < len(s) {
        let c = s.substring(i, i + 1)
        if c == "\n" {
            if len(cur) > 0 { out.push(cur) }
            cur = ""
        } else {
            cur = cur + c
        }
        i = i + 1
    }
    if len(cur) > 0 { out.push(cur) }
    return out
}

fn _atoi(s: string) -> int {
    if s == "" { return 0 }
    return s.parse_int()
}

fn _sh_q(s: string) -> string {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _root() -> string {
    return _home() + "/core/hexa-lang"
}

fn _exists(path: string) -> bool {
    return to_string(exec("test -f " + _sh_q(path) + " && echo y || echo n")).trim() == "y"
}

fn _index_of_str(arr: array, s: string) -> int {
    let mut i = 0
    while i < len(arr) {
        if arr[i] == s { return i }
        i = i + 1
    }
    return -1
}

fn _selftest() -> int {
    if len(_iso_now()) < 10 { eprintln("hx_bench_drift: selftest FAIL (iso)"); return 1 }
    if _atoi("50") != 50 { eprintln("hx_bench_drift: selftest FAIL (atoi)"); return 1 }
    let esc = _json_esc("a\"b")
    if esc != "a\\\"b" { eprintln("hx_bench_drift: selftest FAIL (esc)"); return 1 }
    println("hx_bench_drift: selftest PASS")
    return 0
}

// Extract string field `"key":"<value>"` from a JSONL line.
fn _get_str(ln: string, key: string) -> string {
    let tag = "\"" + key + "\":\""
    let p = ln.index_of(tag)
    if p < 0 { return "" }
    let after = ln.substring(p + len(tag), len(ln))
    let q = after.index_of("\"")
    if q < 0 { return "" }
    return after.substring(0, q)
}

// Extract integer field `"key":N` from a JSONL line.
fn _get_int(ln: string, key: string) -> int {
    let tag = "\"" + key + "\":"
    let p = ln.index_of(tag)
    if p < 0 { return 0 }
    let after = ln.substring(p + len(tag), len(ln))
    let comma = after.index_of(",")
    let brace = after.index_of("}")
    let end = if comma >= 0 && (brace < 0 || comma < brace) { comma } else { brace }
    if end < 0 { return 0 }
    return _atoi(after.substring(0, end).trim())
}

fn main() {
    let av = argv()
    let mut args = []
    let mut i = 2
    while i < len(av) { args.push(av[i]); i = i + 1 }

    if len(args) >= 1 && args[0] == "--selftest" { exit(_selftest()) }

    let threshold = _atoi(_arg_value(args, "--threshold-pct", "10"))
    let default_out = _root() + "/state/hx_bench_drift.json"
    let out_path = _arg_value(args, "--out", default_out)
    let ts = _iso_now()

    // 1. Inventory bench/*.hexa
    let bench_dir = _root() + "/bench"
    let raw_ls = to_string(exec("ls " + _sh_q(bench_dir) + " 2>/dev/null | grep '\\.hexa$'"))
    let bench_files = _split_lines(raw_ls)
    let bench_count = len(bench_files)

    // 2. Parse history if present.
    let hist_path = _root() + "/state/bench_history.jsonl"
    let history_present = _exists(hist_path)

    let mut names = []
    let mut runtime_7d_sum = []   // aggregate over all samples (minimal v1 == all history, not just 7d)
    let mut runtime_7d_count = []
    let mut last_runtime = []
    let mut last_ts = []

    let mut event_count = 0
    if history_present {
        let raw = to_string(exec("cat " + _sh_q(hist_path) + " 2>/dev/null"))
        let lines = _split_lines(raw)
        for ln in lines {
            if len(ln.trim()) == 0 { continue }
            let name = _get_str(ln, "bench")
            if len(name) == 0 { continue }
            let rt = _get_int(ln, "runtime_ms")
            let ev_ts = _get_str(ln, "ts")
            event_count = event_count + 1

            let idx = _index_of_str(names, name)
            if idx < 0 {
                names.push(name)
                runtime_7d_sum.push(rt)
                runtime_7d_count.push(1)
                last_runtime.push(rt)
                last_ts.push(ev_ts)
            } else {
                runtime_7d_sum[idx] = runtime_7d_sum[idx] + rt
                runtime_7d_count[idx] = runtime_7d_count[idx] + 1
                // `last_*` = most recent sample (newest ts)
                if ev_ts > last_ts[idx] {
                    last_ts[idx] = ev_ts
                    last_runtime[idx] = rt
                }
            }
        }
    }

    // 3. Detect regressions: latest > mean × (1 + threshold%)
    let mut regressions = []
    let mut entries_json = []
    let mut j = 0
    while j < len(names) {
        let n = runtime_7d_count[j]
        let mean = if n > 0 { runtime_7d_sum[j] / n } else { 0 }
        let delta_pct = if mean > 0 { ((last_runtime[j] - mean) * 100) / mean } else { 0 }
        let is_reg = delta_pct >= threshold

        let entry = "{\"bench\":\"" + _json_esc(names[j])
            + "\",\"samples\":" + to_string(n)
            + ",\"mean_runtime_ms\":" + to_string(mean)
            + ",\"last_runtime_ms\":" + to_string(last_runtime[j])
            + ",\"last_ts\":\"" + _json_esc(last_ts[j])
            + "\",\"delta_pct\":" + to_string(delta_pct)
            + ",\"regression\":" + (if is_reg { "true" } else { "false" }) + "}"
        entries_json.push(entry)
        if is_reg {
            regressions.push("{\"bench\":\"" + _json_esc(names[j])
                + "\",\"delta_pct\":" + to_string(delta_pct)
                + ",\"mean_runtime_ms\":" + to_string(mean)
                + ",\"last_runtime_ms\":" + to_string(last_runtime[j]) + "}")
        }
        j = j + 1
    }

    // 4. Emit JSON
    let mut body = "{\n  \"schema\": \"hexa-lang/hx_bench_drift/1\",\n"
    body = body + "  \"ts\": \"" + ts + "\",\n"
    body = body + "  \"status\": \"real-v1\",\n"
    body = body + "  \"threshold_pct\": " + to_string(threshold) + ",\n"
    body = body + "  \"bench_file_count\": " + to_string(bench_count) + ",\n"
    body = body + "  \"history_present\": " + (if history_present { "true" } else { "false" }) + ",\n"
    body = body + "  \"history_events\": " + to_string(event_count) + ",\n"
    body = body + "  \"benches\": [\n"
    let mut first = true
    for e in entries_json {
        if !first { body = body + ",\n" }
        body = body + "    " + e
        first = false
    }
    body = body + "\n  ],\n"
    body = body + "  \"regressions\": [\n"
    first = true
    for r in regressions {
        if !first { body = body + ",\n" }
        body = body + "    " + r
        first = false
    }
    body = body + "\n  ],\n"
    body = body + "  \"summary\": {\"bench_files\": " + to_string(bench_count)
    body = body + ", \"distinct_benches_in_history\": " + to_string(len(names))
    body = body + ", \"regressions\": " + to_string(len(regressions)) + "}\n}\n"

    try { write_file(out_path, body) } catch e {
        eprintln("hx_bench_drift: write FAIL " + out_path)
        exit(1)
    }

    let hist_str = if history_present { "yes" } else { "no (bootstrap needed)" }
    println("hx_bench_drift: bench_files=" + to_string(bench_count)
          + " history=" + hist_str
          + " events=" + to_string(event_count)
          + " distinct=" + to_string(len(names))
          + " regressions=" + to_string(len(regressions)))
    println("hx_bench_drift: wrote " + out_path)
    exit(0)
}
