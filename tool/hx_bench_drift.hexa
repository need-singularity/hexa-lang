// tool/hx_bench_drift.hexa — Phase 3.3 bench regression detector (stub).
//
// SPEC: docs/hexa_lang_meta_evolution_proposal_20260422.md §3.3.
// STATUS: stub — skeleton + --selftest only.
//
// PURPOSE
//   Append bench/*.hexa measurements to state/bench_history.jsonl.
//   Compute rolling 7d mean/p95 vs last-24h sample. ≥10% regression →
//   alarm + bisect hint.
//
// CLI
//   hexa tool/hx_bench_drift.hexa --selftest
//   hexa tool/hx_bench_drift.hexa [--threshold-pct N] [--out <path>]
//
// OUTPUT
//   $HEXA_LANG/state/hx_bench_drift.json (schema hexa-lang/hx_bench_drift/1)

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _iso_now() -> string {
    return to_string(exec("date -u +'%Y-%m-%dT%H:%M:%SZ'")).trim()
}

fn _arg_value(args: array, key: string, default: string) -> string {
    let mut i = 0
    while i < len(args) {
        if args[i] == key {
            let j = i + 1
            if j < len(args) { return args[j] }
        }
        i = i + 1
    }
    return default
}

fn _selftest() -> int {
    if len(_iso_now()) < 10 {
        eprintln("hx_bench_drift: selftest FAIL")
        return 1
    }
    println("hx_bench_drift: selftest PASS (stub)")
    return 0
}

fn _emit(threshold: string, out_path: string) -> int {
    let ts = _iso_now()
    let body = "{\n  \"schema\": \"hexa-lang/hx_bench_drift/1\",\n  \"ts\": \"" + ts + "\",\n  \"status\": \"stub\",\n  \"threshold_pct\": " + threshold + ",\n  \"benches\": [],\n  \"regressions\": [],\n  \"summary\": {\"total_benches\": 0, \"regressions\": 0}\n}\n"
    try {
        write_file(out_path, body)
    } catch e {
        eprintln("hx_bench_drift: write FAIL " + out_path)
        return 1
    }
    println("hx_bench_drift: wrote " + out_path + " (stub)")
    return 0
}

fn main() {
    let av = argv()
    let mut args = []
    let mut i = 2
    while i < len(av) { args.push(av[i]); i = i + 1 }

    if len(args) >= 1 && args[0] == "--selftest" {
        exit(_selftest())
    }

    let threshold = _arg_value(args, "--threshold-pct", "10")
    let default_out = _home() + "/core/hexa-lang/state/hx_bench_drift.json"
    let out_path = _arg_value(args, "--out", default_out)
    exit(_emit(threshold, out_path))
}
