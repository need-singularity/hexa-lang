#!hexa strict
// tool/bracket.hexa — unimodal bracketing (천장·바닥 bad, 중간 good)
//
// PURPOSE
//   roadmap 3종 안정 로직 중 ② — 양끝 bad, 내부 유일 극값 찾기.
//   ① tool/fixpoint_bisect.hexa (good→bad 단조 전이) 와 대치.
//   ③ tool/roadmap_engine.hexa (Bellman + DAG atomization) 과 대치.
//   이건 "계곡 포위" — 양측 제약 하 interior optimum.
//
// API (reusable library — pub fn)
//   bracket_ternary(lo, hi, eval_fn, eps)  -> x*
//   bracket_golden(lo, hi, eval_fn, eps)   -> x*
//   bracket_discrete(lo, hi, eval_fn)      -> i*   (정수 인덱스용)
//
//   eval_fn : x -> cost (lower = better). unimodal 가정.
//   eps     : 구간 수렴 허용치 (|hi-lo| < eps 시 중단).
//
// USAGE
//   use "tool/bracket"
//   let cost = fn(x) { return (x - 3.7) * (x - 3.7) }
//   let x    = bracket_ternary(0.0, 10.0, cost, 0.001)   // ≈ 3.7
//
// INVARIANT
//   반환값은 항상 [lo, hi] 내부. eval_fn 가 unimodal 이 아니면
//   지역 극값 하나를 반환 (호출측이 단조성 보장 필요).
//
// SELFTEST
//   hexa tool/bracket.hexa --selftest

// ───────── ternary search ─────────
// 구간을 2 내점으로 3등분 → bad 쪽 1/3 버림 → 수렴.
pub fn bracket_ternary(lo, hi, eval_fn, eps) {
    let mut a = lo
    let mut b = hi
    let mut iters = 0
    while (b - a) > eps {
        if iters > 10000 { break }
        let third = (b - a) / 3.0
        let m1 = a + third
        let m2 = b - third
        let f1 = eval_fn(m1)
        let f2 = eval_fn(m2)
        if f1 < f2 { b = m2 } else { a = m1 }
        iters = iters + 1
    }
    return (a + b) / 2.0
}

// ───────── golden section search ─────────
// φ-비율 재사용으로 매 iter 1회만 eval_fn 호출 (ternary 는 2회).
pub fn bracket_golden(lo, hi, eval_fn, eps) {
    let phi = 0.6180339887498949   // 1/φ = (√5 - 1)/2
    let mut a = lo
    let mut b = hi
    let mut c = b - phi * (b - a)
    let mut d = a + phi * (b - a)
    let mut fc = eval_fn(c)
    let mut fd = eval_fn(d)
    let mut iters = 0
    while (b - a) > eps {
        if iters > 10000 { break }
        if fc < fd {
            b = d
            d = c
            fd = fc
            c = b - phi * (b - a)
            fc = eval_fn(c)
        } else {
            a = c
            c = d
            fc = fd
            d = a + phi * (b - a)
            fd = eval_fn(d)
        }
        iters = iters + 1
    }
    return (a + b) / 2.0
}

// ───────── discrete ternary (정수 인덱스 전용) ─────────
// DAG node rank, shard count, batch size 등 이산 unimodal 에 사용.
pub fn bracket_discrete(lo, hi, eval_fn) {
    let mut a = lo
    let mut b = hi
    while (b - a) > 2 {
        let m1 = a + (b - a) / 3
        let m2 = b - (b - a) / 3
        if eval_fn(m1) < eval_fn(m2) { b = m2 } else { a = m1 }
    }
    // 남은 3~4 지점 완전탐색.
    let mut best_i = a
    let mut best_v = eval_fn(a)
    let mut i = a + 1
    while i <= b {
        let v = eval_fn(i)
        if v < best_v { best_v = v; best_i = i }
        i = i + 1
    }
    return best_i
}

// ───────── selftest ─────────

fn _abs(x) { if x < 0.0 { return 0.0 - x } else { return x } }

fn _selftest() {
    let mut fails = 0

    // T1: parabola min @ 3.7
    let p = fn(x) { return (x - 3.7) * (x - 3.7) }
    let r1 = bracket_ternary(0.0, 10.0, p, 0.0001)
    if _abs(r1 - 3.7) > 0.001 {
        print("FAIL T1 ternary parabola: got "); println(r1)
        fails = fails + 1
    } else { println("OK   T1 ternary  parabola min ≈ 3.7") }

    // T2: golden same target
    let r2 = bracket_golden(0.0, 10.0, p, 0.0001)
    if _abs(r2 - 3.7) > 0.001 {
        print("FAIL T2 golden parabola: got "); println(r2)
        fails = fails + 1
    } else { println("OK   T2 golden   parabola min ≈ 3.7") }

    // T3: |ΔΦ|/Φ style — both ends bad, middle good
    //     cost(x) = |x - 0.025| in [0.001, 0.05]  (|ΔΦ|/Φ < 0.05 corridor)
    let corridor = fn(x) { return _abs(x - 0.025) }
    let r3 = bracket_ternary(0.001, 0.05, corridor, 0.00001)
    if _abs(r3 - 0.025) > 0.0001 {
        print("FAIL T3 corridor: got "); println(r3)
        fails = fails + 1
    } else { println("OK   T3 ternary  corridor min ≈ 0.025") }

    // T4: discrete — shard_cv ∈ [0.05, 3.0] 유사.
    //     integer grid: cost(i) = (i - 7)^2 on [0, 20]
    let disc = fn(i) { return (i - 7) * (i - 7) }
    let r4 = bracket_discrete(0, 20, disc)
    if r4 != 7 {
        print("FAIL T4 discrete: got "); println(r4)
        fails = fails + 1
    } else { println("OK   T4 discrete idx = 7") }

    if fails == 0 {
        println("PASS bracket.hexa selftest 4/4")
        exit(0)
    } else {
        print("FAIL bracket.hexa "); print(fails); println("/4")
        exit(1)
    }
}

fn main() {
    let av = argv()
    let mut i = 2
    while i < len(av) {
        if av[i] == "--selftest" {
            _selftest()
            return
        }
        i = i + 1
    }
    println("tool/bracket.hexa — unimodal bracketing library")
    println("  pub fn bracket_ternary(lo, hi, eval_fn, eps)")
    println("  pub fn bracket_golden(lo, hi, eval_fn, eps)")
    println("  pub fn bracket_discrete(lo, hi, eval_fn)")
    println("usage: hexa tool/bracket.hexa --selftest")
}
