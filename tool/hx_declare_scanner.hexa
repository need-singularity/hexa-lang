// tool/hx_declare_scanner.hexa — Phase 6.3 declarative scanner DSL loader (real-v1).
//
// SPEC: docs/hexa_lang_meta_evolution_proposal_20260422.md §6.3.
// STATUS: v1 real — walk `scanners/*.meta.hexa`, extract declared scanner
//         names + body, list + validate syntax (minimal DSL: `scanner "name" { ... }`).
//         Dynamic execution (`run <name>`) deferred to v2 when a DSL
//         interpreter lands. `register` copies a file into scanners/.
//
// DSL sketch (v1 parses the outer shell only):
//   scanner "dup_helper_home" {
//     pattern    ast_match("fn _home()")
//     threshold  sites >= 3
//     severity   low
//     category   stdlib_promote
//     propose    "promote to stdlib/os_home.hexa"
//   }
//
// CLI
//   hexa tool/hx_declare_scanner.hexa --selftest
//   hexa tool/hx_declare_scanner.hexa              # default: list
//   hexa tool/hx_declare_scanner.hexa list [--out <path>]
//   hexa tool/hx_declare_scanner.hexa register <path.meta.hexa>
//   hexa tool/hx_declare_scanner.hexa run <name>   # v1: not executed

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _iso_now() -> string {
    return to_string(exec("date -u +'%Y-%m-%dT%H:%M:%SZ'")).trim()
}

fn _arg_value(args: array, key: string, default: string) -> string {
    let mut i = 0
    while i < len(args) {
        if args[i] == key {
            let j = i + 1
            if j < len(args) { return args[j] }
        }
        i = i + 1
    }
    return default
}

fn _json_esc(s: string) -> string {
    let mut r = s.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", "\\n")
    r = r.replace("\r", "")
    r = r.replace("\t", " ")
    return r
}

fn _split_lines(s: string) -> array {
    let mut out = []
    let mut cur = ""
    let mut i = 0
    while i < len(s) {
        let c = s.substring(i, i + 1)
        if c == "\n" {
            out.push(cur)
            cur = ""
        } else {
            cur = cur + c
        }
        i = i + 1
    }
    if len(cur) > 0 { out.push(cur) }
    return out
}

fn _sh_q(s: string) -> string {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _exists(path: string) -> bool {
    return to_string(exec("test -e " + _sh_q(path) + " && echo y || echo n")).trim() == "y"
}

fn _root() -> string {
    return _home() + "/core/hexa-lang"
}

fn _scanners_dir() -> string {
    return _root() + "/scanners"
}

fn _selftest() -> int {
    if _json_esc("a\"b") != "a\\\"b" {
        eprintln("hx_declare_scanner: selftest FAIL (esc)"); return 1
    }
    if len(_iso_now()) < 10 {
        eprintln("hx_declare_scanner: selftest FAIL (iso)"); return 1
    }
    println("hx_declare_scanner: selftest PASS")
    return 0
}

// Extract a declared scanner name from a DSL file body.
//   Matches: scanner "<name>" {
// Returns empty string if no declaration found.
fn _extract_name(body: string) -> string {
    let tag = "scanner \""
    let p = body.index_of(tag)
    if p < 0 { return "" }
    let after = body.substring(p + len(tag), len(body))
    let q = after.index_of("\"")
    if q < 0 { return "" }
    return after.substring(0, q)
}

// Extract a single declared field like `severity  low` → "low".
// Accept any whitespace between key and value; stop at EOL.
fn _extract_field(body: string, key: string) -> string {
    let lines = _split_lines(body)
    for ln in lines {
        let t = ln.trim()
        if t.index_of(key) == 0 {
            let rest = t.substring(len(key), len(t)).trim()
            return rest
        }
    }
    return ""
}

fn _cmd_list(args: array) -> int {
    let default_out = _root() + "/state/hx_declared_scanners.json"
    let out_path = _arg_value(args, "--out", default_out)
    let ts = _iso_now()
    let sc_dir = _scanners_dir()

    let mut entries = []
    let mut total = 0
    let mut valid = 0
    let mut invalid = 0

    if _exists(sc_dir) {
        let raw = to_string(exec("ls " + _sh_q(sc_dir) + " 2>/dev/null | grep '\\.meta\\.hexa$'"))
        let files = _split_lines(raw)
        for fname in files {
            if len(fname) == 0 { continue }
            total = total + 1
            let path = sc_dir + "/" + fname
            let body = to_string(exec("cat " + _sh_q(path) + " 2>/dev/null"))
            let name = _extract_name(body)
            let severity = _extract_field(body, "severity")
            let category = _extract_field(body, "category")
            let propose = _extract_field(body, "propose")

            let is_valid = len(name) > 0
            if is_valid { valid = valid + 1 } else { invalid = invalid + 1 }

            let entry = "{\"file\":\"scanners/" + _json_esc(fname) + "\""
                + ",\"name\":\"" + _json_esc(name) + "\""
                + ",\"severity\":\"" + _json_esc(severity) + "\""
                + ",\"category\":\"" + _json_esc(category) + "\""
                + ",\"propose\":\"" + _json_esc(propose) + "\""
                + ",\"valid\":" + (if is_valid { "true" } else { "false" })
                + ",\"bytes\":" + to_string(len(body)) + "}"
            entries.push(entry)
        }
    }

    let mut body_out = "{\n  \"schema\": \"hexa-lang/hx_declared_scanners/1\",\n"
    body_out = body_out + "  \"ts\": \"" + ts + "\",\n"
    body_out = body_out + "  \"status\": \"real-v1\",\n"
    body_out = body_out + "  \"scanners_dir_exists\": " + (if _exists(sc_dir) { "true" } else { "false" }) + ",\n"
    body_out = body_out + "  \"scanners\": [\n"
    let mut first = true
    for e in entries {
        if !first { body_out = body_out + ",\n" }
        body_out = body_out + "    " + e
        first = false
    }
    body_out = body_out + "\n  ],\n"
    body_out = body_out + "  \"summary\": {\"total\": " + to_string(total)
    body_out = body_out + ", \"valid\": " + to_string(valid)
    body_out = body_out + ", \"invalid\": " + to_string(invalid) + "}\n}\n"

    try { write_file(out_path, body_out) } catch e {
        eprintln("hx_declare_scanner: write FAIL " + out_path)
        return 1
    }

    println("hx_declare_scanner: total=" + to_string(total)
          + " valid=" + to_string(valid)
          + " invalid=" + to_string(invalid)
          + " (dir exists=" + (if _exists(sc_dir) { "yes" } else { "no" }) + ")")
    println("hx_declare_scanner: wrote " + out_path)
    return 0
}

fn _cmd_register(args: array) -> int {
    if len(args) < 1 {
        eprintln("hx_declare_scanner register: path required")
        return 2
    }
    let src = args[0]
    if !_exists(src) {
        eprintln("hx_declare_scanner register: file not found: " + src)
        return 2
    }
    let body = to_string(exec("cat " + _sh_q(src) + " 2>/dev/null"))
    let name = _extract_name(body)
    if len(name) == 0 {
        eprintln("hx_declare_scanner register: no `scanner \"<name>\"` declaration found in " + src)
        return 2
    }
    let sc_dir = _scanners_dir()
    let _mk = exec("mkdir -p " + _sh_q(sc_dir))
    let target = sc_dir + "/" + name + ".meta.hexa"
    let _cp = exec_with_status("cp " + _sh_q(src) + " " + _sh_q(target))
    if _cp[1] != 0 {
        eprintln("hx_declare_scanner register: cp FAIL")
        return 1
    }
    println("hx_declare_scanner: registered " + name + " → scanners/" + name + ".meta.hexa")
    return 0
}

fn _cmd_run(args: array) -> int {
    if len(args) < 1 {
        eprintln("hx_declare_scanner run: name required")
        return 2
    }
    eprintln("hx_declare_scanner run: v1 does not execute DSL scanners (deferred to v2)")
    eprintln("  requested name: " + args[0])
    return 3
}

fn main() {
    let av = argv()
    let mut args = []
    let mut i = 2
    while i < len(av) { args.push(av[i]); i = i + 1 }

    if len(args) >= 1 && args[0] == "--selftest" { exit(_selftest()) }

    if len(args) >= 1 && args[0] == "register" {
        let mut rest = []
        let mut k = 1
        while k < len(args) { rest.push(args[k]); k = k + 1 }
        exit(_cmd_register(rest))
    }
    if len(args) >= 1 && args[0] == "run" {
        let mut rest = []
        let mut k = 1
        while k < len(args) { rest.push(args[k]); k = k + 1 }
        exit(_cmd_run(rest))
    }

    let mut rest = []
    let mut k = 0
    if len(args) >= 1 && args[0] == "list" { k = 1 }
    while k < len(args) { rest.push(args[k]); k = k + 1 }
    exit(_cmd_list(rest))
}
