// tool/hx_declare_scanner.hexa — Phase 6.3 declarative scanner DSL loader (stub).
//
// SPEC: docs/hexa_lang_meta_evolution_proposal_20260422.md §6.3.
// STATUS: stub — skeleton + --selftest only.
//
// PURPOSE
//   Read `scanners/*.meta.hexa` (declarative form) and register them in
//   the scanner runtime so Phase 3 dispatch can execute them alongside
//   hand-written scanners. Lowers entry barrier: new observer without
//   writing full hexa code.
//
//   Example .meta.hexa payload (future):
//     scanner "dup_helper_home" {
//       pattern    ast_match("fn _home()")
//       threshold  sites >= 3
//       severity   low
//       category   stdlib_promote
//       propose    "promote to stdlib/os_home.hexa"
//     }
//
// CLI
//   hexa tool/hx_declare_scanner.hexa --selftest
//   hexa tool/hx_declare_scanner.hexa list
//   hexa tool/hx_declare_scanner.hexa register <path.meta.hexa>
//   hexa tool/hx_declare_scanner.hexa run <name>
//
// OUTPUT
//   $HEXA_LANG/state/hx_declared_scanners.json
//   schema = "hexa-lang/hx_declared_scanners/1"

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _iso_now() -> string {
    return to_string(exec("date -u +'%Y-%m-%dT%H:%M:%SZ'")).trim()
}

fn _arg_value(args: array, key: string, default: string) -> string {
    let mut i = 0
    while i < len(args) {
        if args[i] == key {
            let j = i + 1
            if j < len(args) { return args[j] }
        }
        i = i + 1
    }
    return default
}

fn _selftest() -> int {
    if len(_iso_now()) < 10 {
        eprintln("hx_declare_scanner: selftest FAIL")
        return 1
    }
    println("hx_declare_scanner: selftest PASS (stub)")
    return 0
}

fn _emit_list(out_path: string) -> int {
    let ts = _iso_now()
    let body = "{\n  \"schema\": \"hexa-lang/hx_declared_scanners/1\",\n  \"ts\": \"" + ts + "\",\n  \"status\": \"stub\",\n  \"scanners\": [],\n  \"summary\": {\"total\": 0, \"active\": 0, \"deprecated\": 0}\n}\n"
    try {
        write_file(out_path, body)
    } catch e {
        eprintln("hx_declare_scanner: write FAIL " + out_path)
        return 1
    }
    println("hx_declare_scanner: wrote " + out_path + " (stub)")
    return 0
}

fn main() {
    let av = argv()
    let mut args = []
    let mut i = 2
    while i < len(av) { args.push(av[i]); i = i + 1 }

    if len(args) >= 1 && args[0] == "--selftest" {
        exit(_selftest())
    }

    // Sub-actions: list (default) | register | run — all no-op stubs for now.
    if len(args) >= 1 && args[0] == "register" {
        println("hx_declare_scanner: register (stub, no-op)")
        exit(0)
    }
    if len(args) >= 1 && args[0] == "run" {
        println("hx_declare_scanner: run (stub, no-op)")
        exit(0)
    }

    let default_out = _home() + "/core/hexa-lang/state/hx_declared_scanners.json"
    let out_path = _arg_value(args, "--out", default_out)
    exit(_emit_list(out_path))
}
