// tool/blocker_inventory_scan.hexa — Phase 1 blocker inventory scanner (stub).
//
// SPEC: docs/roadmap_engine_continuous_meta_proposal_20260422.md §Phase 1.
// STATUS: stub — skeleton + --selftest only. Full logic in follow-up session.
//
// PURPOSE
//   Scan <repo>/state/*.json (roadmap_progress, file_completion_ledger,
//   *_audit, *_dryrun, *_completion) for probe_fail / missing_artifact /
//   env_blocked / gap / review / partial / source_mismatch / auth_required
//   items, emit unified blocker inventory.
//
// CLI
//   hexa tool/blocker_inventory_scan.hexa --selftest
//   hexa tool/blocker_inventory_scan.hexa --repo <name> [--out <path>]
//
// OUTPUT
//   $HEXA_LANG/state/blocker_inventory_<repo>.json
//   schema = "hexa-lang/blocker_inventory/1"

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _iso_now() -> string {
    return to_string(exec("date -u +'%Y-%m-%dT%H:%M:%SZ'")).trim()
}

fn _arg_value(args: array, key: string, default: string) -> string {
    let mut i = 0
    while i < len(args) {
        if args[i] == key {
            let j = i + 1
            if j < len(args) { return args[j] }
        }
        i = i + 1
    }
    return default
}

fn _selftest() -> int {
    let ts = _iso_now()
    if len(ts) < 10 {
        eprintln("blocker_inventory_scan: selftest FAIL (iso_now empty)")
        return 1
    }
    if len(_home()) < 1 {
        eprintln("blocker_inventory_scan: selftest FAIL (HOME empty)")
        return 1
    }
    println("blocker_inventory_scan: selftest PASS (stub)")
    return 0
}

fn _emit(repo: string, out_path: string) -> int {
    let ts = _iso_now()
    let body = "{\n  \"schema\": \"hexa-lang/blocker_inventory/1\",\n  \"ts\": \"" + ts + "\",\n  \"repo\": \"" + repo + "\",\n  \"status\": \"stub\",\n  \"blockers\": [],\n  \"summary\": {\"total\": 0, \"high\": 0, \"med\": 0, \"low\": 0}\n}\n"
    try {
        write_file(out_path, body)
    } catch e {
        eprintln("blocker_inventory_scan: write FAIL " + out_path)
        return 1
    }
    println("blocker_inventory_scan: wrote " + out_path + " (stub, 0 blockers)")
    return 0
}

fn main() {
    let av = argv()
    let mut args = []
    let mut i = 2
    while i < len(av) { args.push(av[i]); i = i + 1 }

    if len(args) >= 1 && args[0] == "--selftest" {
        exit(_selftest())
    }

    let repo = _arg_value(args, "--repo", "anima")
    let default_out = _home() + "/core/hexa-lang/state/blocker_inventory_" + repo + ".json"
    let out_path = _arg_value(args, "--out", default_out)
    exit(_emit(repo, out_path))
}
