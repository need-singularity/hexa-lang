#!hexa strict
// tool/cmd_drill.hexa — F6 DRILL_GAP divergent seed stub
//
// Invoked as `hexa drill <topic...>` — placeholder level. Joins the
// user's arguments into a single topic string and emits N=5 divergent
// "angles" to stdout. The exact topic line is also written to
// $HOME/.hx/drill.last.txt so the loop harness (or humans) can re-enter.
//
// Real divergent seed generation (blowup engine bridge) is wired later;
// today this is a deterministic placeholder so shims/doctor pass.

fn _dr_home() -> string {
    let h = env("HOME")
    if h != "" { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _dr_quote(s: string) -> string {
    let mut out = "'"
    let n = len(s)
    let mut i = 0
    while i < n {
        let c = char_code(s, i)
        if c == 39 {
            out = out + "'\\''"
        } else {
            out = out + chr(c)
        }
        i = i + 1
    }
    out = out + "'"
    return out
}

fn _dr_angles() -> [string] {
    let mut a = []
    a = a.push("minimal-surface")
    a = a.push("alt-path")
    a = a.push("next-layer-predict")
    a = a.push("adjacent-speculation")
    a = a.push("singularity-extract")
    return a
}

fn _dr_collect_topic() -> string {
    let av = argv()
    let n = len(av)
    // Convention (matches hx_init.hexa): av[0] = interpreter, av[1] = script,
    // user args begin at av[2]. We accept both the direct-script form
    // (`hexa tool/cmd_drill.hexa <topic>`) and the shim dispatch form
    // (`drill <topic>` → dispatcher injects args the same way).
    let mut parts = []
    let mut i = 2
    while i < n {
        parts = parts.push(av[i])
        i = i + 1
    }
    return parts.join(" ")
}

fn main() -> int {
    let topic = _dr_collect_topic()
    if topic == "" {
        eprintln("drill: empty topic — usage: drill <topic ...>")
        return 1
    }

    let angles = _dr_angles()
    let mut i = 0
    while i < len(angles) {
        println("[drill] " + angles[i] + ": " + topic)
        i = i + 1
    }

    // Persist last topic for the loop harness.
    let last_path = _dr_home() + "/.hx/drill.last.txt"
    exec_with_status("mkdir -p " + _dr_quote(_dr_home() + "/.hx"))
    exec_with_status("printf '%s\n' " + _dr_quote(topic) + " > " + _dr_quote(last_path))

    return 0
}

exit(main())
