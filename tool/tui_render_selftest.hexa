// tool/tui_render_selftest.hexa — selftest entry for self/tui/render.hexa
//
// Library modules (self/tui/*) cannot define `fn main()` because hexa
// flatten concatenates module mains causing C duplicate-symbol errors.
// The selftest entry lives here so end users can run it without pulling
// the module's main into their flatten graph.

use "self/tui/render"

let rc = render_selftest()
exit(rc)
