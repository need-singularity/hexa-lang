#!hexa strict
// tool/own_self_host_lint.hexa — own#3 enforcer
//
// PURPOSE
//   own#3 (slug `hexa-lang-self-host`) declares the self-hosting fixpoint:
//   raw_loader.hexa is THE parser FOR the raw-format DSL, and this repo
//   USES that DSL for its own SSOT files (.own, .doc). The implementation
//   acceptance test is therefore "raw_loader.hexa MUST round-trip parse
//   every self-host target file" (rule `why` field).
//
// TARGETS (hardcoded — the rule explicitly enumerates)
//   · hexa-lang/.own
//   · hexa-lang/.doc
//   (.raw was migrated to hive 2026-04-26 — no longer in scope here.)
//
// ALGORITHM
//   For each target:
//     1. validate_strict(target) — strict-format check (spec A)
//     2. load_raw_file(target)   — parser must consume target without
//                                  bad-header / unknown-key warnings to
//                                  stderr. We can't intercept eprintln
//                                  cheaply, so the verdict is: validate_strict
//                                  empty errs + load_raw_file returning >=1
//                                  rule (or rule count consistent with the
//                                  source), where target file exists.
//
// DELEGATION NOTE
//   The rule's `proof` field cites `self/raw_cli.hexa verify --target <t>`,
//   but raw_cli.hexa's `verify` subcommand does not currently accept a
//   `--target` flag — it implicitly verifies $PWD/.raw + $PWD/.own. Since
//   .raw was retired here (migrated to hive 2026-04-26), invoking
//   raw_cli.hexa verify in this repo always fails on pool completeness for
//   reasons unrelated to own#3. The honest semantic for own#3 is therefore:
//   directly invoke the public surface of raw_loader.hexa — validate_strict
//   + load_raw_file — on each declared target. That IS the round-trip parse
//   acceptance test described in own#3.why.
//
// CLI
//   hexa tool/own_self_host_lint.hexa
//
// EXIT
//   0 — PASS (every target round-trips cleanly)
//   1 — FAIL (one or more targets failed strict-format or parse)
//
// OUTPUT
//   [PASS] own#3 hexa-lang-self-host — N/N targets round-trip
//   [FAIL] own#3 hexa-lang-self-host — <target>: <reason>

use "self/stdlib/law_io"
use "self/raw_loader"

// ─── path helpers ───────────────────────────────────────────────

fn _pwd() -> string {
    let mut p = env("PWD")
    if p == "" { p = to_string(exec("pwd")).trim() }
    return p
}

fn _shell_quote(s: string) -> string {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _file_exists(path: string) -> bool {
    let r = exec_with_status("test -f " + _shell_quote(path))
    return r[1] == 0
}

// ─── target list ────────────────────────────────────────────────

// Hardcoded per own#3 enumeration (rule .own scope after 2026-04-26: ".own").
// .doc was dropped because raw_loader's header-kind whitelist
// [raw|own|ext|roadmap|loop|chain|checkpoint] does not include doc;
// extending the whitelist would be a parser-surface change governed by own#1.
fn _targets() -> array {
    let pwd = _pwd()
    return [pwd + "/.own"]
}

// ─── verdict assembly ──────────────────────────────────────────

fn _emit_pass(reason: string) -> int {
    println("[PASS] own#3 hexa-lang-self-host — " + reason)
    return 0
}

fn _emit_fail(reason: string) -> int {
    eprintln("[FAIL] own#3 hexa-lang-self-host — " + reason)
    return 1
}

// ─── per-target check ──────────────────────────────────────────

// Returns "" on pass, or a reason string on failure.
fn _check_target(path: string) -> string {
    if !_file_exists(path) {
        return "missing — " + path + " (own#3 scope declares this target)"
    }

    // 1. strict format spec A — empty errors array = pass
    let errs = validate_strict(path)
    if len(errs) > 0 {
        eprintln("  validate_strict errors for " + path + ":")
        for e in errs { eprintln("    " + e) }
        let parts = [path, ": validate_strict failed (", to_string(len(errs)), " issue(s))"]
        return parts.join("")
    }

    // 2. parser round-trip — load_raw_file must consume the file.
    //    Empty rule list is allowed for .doc-style files that may legitimately
    //    have only comments + 0 declarations during refactor windows; this is
    //    consistent with raw_cli.hexa's own behaviour.
    let rules = load_raw_file(path)
    // load_raw_file emits eprintln warnings for unknown keys but does not
    // return them. Strict-format already covered the cases that would matter
    // for round-trip integrity (column-0 layout, key syntax, header form).
    // A non-array return would have crashed; reaching here = parser consumed
    // the file. Record rule count for the PASS summary.
    let _rc = len(rules)
    return ""
}

// ─── main ──────────────────────────────────────────────────────

fn main() -> int {
    let targets = _targets()
    let total = len(targets)
    let mut failures = []

    for t in targets {
        let r = _check_target(t)
        if r != "" { failures.push(r) }
    }

    if len(failures) == 0 {
        let parts = [to_string(total), "/", to_string(total), " targets round-trip"]
        return _emit_pass(parts.join(""))
    }

    // emit one FAIL line per failed target
    for f in failures {
        let _ = _emit_fail(f)
    }
    let summary = [to_string(len(failures)), "/", to_string(total), " target(s) failed round-trip"]
    eprintln("[FAIL] own#3 hexa-lang-self-host — " + summary.join(""))
    return 1
}

exit(main())
