// tool/roadmap_bottleneck.hexa — Tier6#52 (roadmap 47): bottleneck axis tracker
//
// PURPOSE
//   Implements max_{i∈Ω} c_i(S_k^π) from T*(S₀→G). Classifies each entry
//   into one of Ω = {build, exp, learn, boot, verify} and computes per-
//   step bottleneck cost.
//
// CLASSIFIER (deterministic, hexa-only — raw#9)
//   track ∈ {ffi, native, build, perf, bootstrap}          → build
//   track ∈ {ai-native, self-host}                          → build
//   track ∈ {hybrid, cell, lora}                            → learn
//   phase starts with "T1"-"T6"                             → verify
//   name contains "selftest|test|verify|audit|drill"        → verify
//   name contains "experiment|exp|measure"                  → exp
//   phase starts with "P0"                                  → boot
//   else                                                    → build (default)
//
// COST (c_i) — unit 1 per node unless `days` key present.
//
// OUTPUT
//   Per day bucket: {day, axis_max, axis_breakdown}
//   Summary:       {bottleneck_axis_trajectory: [...]}
//
// CLI
//   hexa tool/roadmap_bottleneck.hexa [--path-b]
//   hexa tool/roadmap_bottleneck.hexa --selftest

fn _rstrip(s: string) -> string {
    let mut end = len(s)
    while end > 0 {
        let c = s.substring(end - 1, end)
        if c == " " || c == "\t" || c == "\r" { end = end - 1 } else { break }
    }
    return s.substring(0, end)
}

fn _hdr(line: string) -> array {
    let sp1 = line.index_of(" ")
    if sp1 < 0 { return [] }
    if line.substring(0, sp1) != "roadmap" { return [] }
    let r1 = line.substring(sp1 + 1, len(line))
    let sp2 = r1.index_of(" ")
    if sp2 < 0 { return [] }
    let id = r1.substring(0, sp2)
    let r2 = r1.substring(sp2 + 1, len(r1))
    let sp3 = r2.index_of(" ")
    if sp3 < 0 { return [] }
    let st = r2.substring(0, sp3)
    let mut nm = r2.substring(sp3 + 1, len(r2)).trim()
    if len(nm) >= 2 && nm.substring(0, 1) == "\"" { nm = nm.substring(1, len(nm) - 1) }
    return [id, st, nm]
}

fn parse_roadmap(src: string) -> array {
    let lines = split(src, "\n")
    let mut rules = []
    let mut kind = ""
    let mut cid = ""; let mut cst = ""; let mut cnm = ""; let mut ck = []
    for raw_line in lines {
        let line = _rstrip(raw_line)
        if len(line) == 0 {
            if kind == "r" { rules.push([cid, cst, cnm, ck]) }
            kind = ""; ck = []
            continue
        }
        let f = line.substring(0, 1)
        if f == "#" { continue }
        if f == " " || f == "\t" {
            if kind == "" { continue }
            let s = line.trim_start()
            let sp = s.index_of(" ")
            if sp < 0 { continue }
            ck.push([s.substring(0, sp), s.substring(sp + 1, len(s)).trim()])
        } else {
            if kind == "r" { rules.push([cid, cst, cnm, ck]) }
            ck = []; kind = ""
            let fs = line.index_of(" ")
            if fs < 0 { continue }
            if line.substring(0, fs) == "roadmap" {
                let h = _hdr(line)
                if len(h) == 0 { continue }
                cid = h[0]; cst = h[1]; cnm = h[2]; kind = "r"
            }
        }
    }
    if kind == "r" { rules.push([cid, cst, cnm, ck]) }
    return rules
}

fn _load(path: string) -> array {
    let r = exec_with_status("test -f '" + path + "'")
    if r[1] != 0 { return [] }
    return parse_roadmap(to_string(read_file(path)))
}

fn _kv(keys: array, k: string) -> string {
    for kv in keys { if kv[0] == k { return kv[1] } }
    return ""
}

fn _is_int(s: string) -> bool {
    if len(s) == 0 { return false }
    let d = "0123456789"
    let mut i = 0
    while i < len(s) { if !d.contains(s.substring(i, i + 1)) { return false } i = i + 1 }
    return true
}

fn _parse_int(s: string) -> int {
    let mut n = 0
    let d = "0123456789"
    let mut i = 0
    while i < len(s) {
        let c = s.substring(i, i + 1)
        if !d.contains(c) { return n }
        n = n * 10 + d.index_of(c)
        i = i + 1
    }
    return n
}

fn classify(rule: array) -> string {
    let name = rule[2].to_lower()
    let keys = rule[3]
    let track = _kv(keys, "track").to_lower()
    let phase = _kv(keys, "phase").to_lower()

    // verify first (specific-est)
    if name.contains("selftest") || name.contains("verify") || name.contains("audit") || name.contains("drill") || name.contains("proof") { return "verify" }
    if phase.starts_with("t1") || phase.starts_with("t2") || phase.starts_with("t3") || phase.starts_with("t4") || phase.starts_with("t5") || phase.starts_with("t6") { return "verify" }

    // exp
    if name.contains("experiment") || name.contains("measure") || name.contains("bench") { return "exp" }

    // boot
    if phase.starts_with("p0") { return "boot" }
    if track == "ssot" { return "boot" }
    if track == "bootstrap" { return "boot" }

    // learn
    if track == "hybrid" || track == "cell" || track == "lora" { return "learn" }

    // build (default)
    return "build"
}

fn _cost(rule: array) -> int {
    let dv = _kv(rule[3], "days")
    if _is_int(dv) && _parse_int(dv) > 0 { return _parse_int(dv) }
    return 1
}

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _load_repos() -> array {
    let home = _home()
    let mut out = []
    for r in ["anima", "airgenome", "hexa-lang"] {
        out.push([r, _load(home + "/core/" + r + "/.roadmap")])
    }
    return out
}

fn _filter_pathB(repos: array) -> array {
    let mut out = []
    for rr in repos {
        if rr[0] != "anima" { continue }
        let mut kept = []
        for rule in rr[1] {
            if !_is_int(rule[0]) { continue }
            let n = _parse_int(rule[0])
            if n >= 22 && n <= 30 { kept.push(rule) }
        }
        out.push(["anima", kept])
    }
    return out
}

fn parse_deps(val: string, default_repo: string) -> array {
    let mut out = []
    if len(val) == 0 || val == "—" { return out }
    let cleaned = val.replace(",", " ").replace("+", " ")
    let toks = split(cleaned, " ")
    let mut current = default_repo
    for raw in toks {
        let t = raw.trim()
        if len(t) == 0 { continue }
        let at = t.index_of("@")
        if at > 0 && at < len(t) - 1 {
            let repo = t.substring(0, at)
            let id = t.substring(at + 1, len(t))
            if _is_int(id) { out.push([repo, id]); current = repo; continue }
        }
        if _is_int(t) { out.push([current, t]) }
    }
    return out
}

// Compute depth layers and bottleneck per layer.
// Returns [layers_with_axis_cost]: [[day_idx, axis_costs(map), max_axis, max_val]]
fn compute(repos: array) -> array {
    let mut keys = []
    let mut axes = []
    let mut costs = []
    let mut rules_flat = []
    for rr in repos {
        for rule in rr[1] {
            keys.push(rr[0] + "#" + rule[0])
            axes.push(classify(rule))
            costs.push(_cost(rule))
            rules_flat.push([rr[0], rule])
        }
    }
    let n = len(keys)
    let mut pred = []
    let mut succ = []
    let mut i = 0
    while i < n { pred.push([]); succ.push([]); i = i + 1 }
    for rr in repos {
        for rule in rr[1] {
            let sk = rr[0] + "#" + rule[0]
            let dep = _kv(rule[3], "depends-on")
            for pair in parse_deps(dep, rr[0]) {
                let tk = pair[0] + "#" + pair[1]
                let mut fi = -1
                let mut ti = -1
                let mut k = 0
                while k < n {
                    if keys[k] == sk { fi = k }
                    if keys[k] == tk { ti = k }
                    k = k + 1
                }
                if fi < 0 || ti < 0 { continue }
                let p = pred[fi]; p.push(ti); pred[fi] = p
                let s = succ[ti]; s.push(fi); succ[ti] = s
            }
        }
    }
    let mut indeg = []
    let mut j = 0
    while j < n { indeg.push(len(pred[j])); j = j + 1 }
    let mut q = []
    let mut topo = []
    let mut jj = 0
    while jj < n { if indeg[jj] == 0 { q.push(jj) } jj = jj + 1 }
    let mut qi = 0
    while qi < len(q) {
        let u = q[qi]
        topo.push(u)
        for v in succ[u] {
            indeg[v] = indeg[v] - 1
            if indeg[v] == 0 { q.push(v) }
        }
        qi = qi + 1
    }
    if len(topo) != n { return [[], true] }

    let mut depth = []
    let mut k2 = 0
    while k2 < n { depth.push(0); k2 = k2 + 1 }
    for u in topo {
        let mut best = -1
        for p in pred[u] { if depth[p] > best { best = depth[p] } }
        if best >= 0 { depth[u] = best + 1 } else { depth[u] = 0 }
    }
    let mut max_d = 0
    for d in depth { if d > max_d { max_d = d } }

    // bucket axis cost per layer
    let axis_list = ["build", "exp", "learn", "boot", "verify"]
    let mut layers = []
    let mut d = 0
    while d <= max_d {
        let mut counts = [0, 0, 0, 0, 0]
        let mut i2 = 0
        while i2 < n {
            if depth[i2] == d {
                let mut ai = 0
                while ai < len(axis_list) {
                    if axes[i2] == axis_list[ai] { counts[ai] = counts[ai] + costs[i2] }
                    ai = ai + 1
                }
            }
            i2 = i2 + 1
        }
        // max axis
        let mut best_i = 0
        let mut best_v = counts[0]
        let mut ai = 1
        while ai < 5 {
            if counts[ai] > best_v { best_v = counts[ai]; best_i = ai }
            ai = ai + 1
        }
        layers.push([d, axis_list[best_i], best_v, counts])
        d = d + 1
    }
    return [layers, false]
}

fn _je(s: string) -> string {
    let mut o = s.replace("\\", "\\\\")
    o = o.replace("\"", "\\\"")
    return o
}

fn _selftest() -> int {
    // Path B axis trajectory should include "learn" dominance (hybrid track)
    let pb = _filter_pathB(_load_repos())
    let r = compute(pb)
    if r[1] != false {
        eprintln("selftest FAIL: cycle on Path B")
        return 1
    }
    let layers = r[0]
    println("Path B axis trajectory (Ω={build,exp,learn,boot,verify}):")
    for L in layers {
        let c = L[3]
        println("  Day " + to_string(L[0] + 1) + " bottleneck=" + L[1] + " cost=" + to_string(L[2]) + " [build=" + to_string(c[0]) + " exp=" + to_string(c[1]) + " learn=" + to_string(c[2]) + " boot=" + to_string(c[3]) + " verify=" + to_string(c[4]) + "]")
    }
    // Check: at least one layer has learn as bottleneck (since hybrid/lora/cell → learn)
    let mut found_learn = false
    for L in layers { if L[1] == "learn" { found_learn = true } }
    if !found_learn {
        eprintln("selftest FAIL: Path B expected some learn-bottleneck days")
        return 1
    }
    println("selftest PASS — bottleneck axis per step")
    return 0
}

fn main() {
    let av = argv()
    let mut args = []
    let mut i = 2
    while i < len(av) { args.push(av[i]); i = i + 1 }
    if len(args) >= 1 && args[0] == "--selftest" { exit(_selftest()) }

    let mut pb = false
    let mut j = 0
    while j < len(args) { if args[j] == "--path-b" { pb = true } j = j + 1 }
    let mut repos = _load_repos()
    if pb { repos = _filter_pathB(repos) }
    let r = compute(repos)
    if r[1] == true { eprintln("CYCLE"); exit(1) }
    let layers = r[0]
    let mut p = []
    p.push("{\"layers\":[")
    let mut first = true
    for L in layers {
        if !first { p.push(",") }
        let c = L[3]
        p.push("{\"day\":")
        p.push(to_string(L[0] + 1))
        p.push(",\"axis\":\"")
        p.push(_je(L[1]))
        p.push("\",\"cost\":")
        p.push(to_string(L[2]))
        p.push(",\"breakdown\":{\"build\":" + to_string(c[0]) + ",\"exp\":" + to_string(c[1]) + ",\"learn\":" + to_string(c[2]) + ",\"boot\":" + to_string(c[3]) + ",\"verify\":" + to_string(c[4]) + "}}")
        first = false
    }
    p.push("]}")
    println(p.join(""))
}
