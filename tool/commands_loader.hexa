#!hexa strict
// tool/commands_loader.hexa — .commands 전용 파서
//
// SSOT: .commands (자체 규격, .raw/.own 과 동급 독립 포맷)
//
// 포맷:
//   command <name> <category> "<description>"
//     keywords <k1> <k2> ...
//     handler <relative/path.hexa>
//     shim <yes|no>
//   (빈 줄 = command 구분, # = 주석, column 0 = header, column 2 = key)
//
// 독립 loader — self/raw_loader.hexa 를 import 하지 않는다 (interp
// rebuild 트리거 회피). 필요 로직은 로컬에 복제.
//
// API:
//   pub struct HxCommand
//   pub fn load_commands(path: string) -> [HxCommand]
//   pub fn find_command(cmds: [HxCommand], name: string) -> HxCommand
//   pub fn shim_names(cmds: [HxCommand]) -> [string]

// ═══════════════════════════════════════════════════════════════════
// Record
// ═══════════════════════════════════════════════════════════════════

pub struct HxCommand {
    name: string,
    keywords: [string],
    description: string,
    category: string,
    shim: bool,
    handler: string
}

// ═══════════════════════════════════════════════════════════════════
// Local helpers (복제 from self/raw_loader.hexa)
// ═══════════════════════════════════════════════════════════════════

fn _cmd_rstrip(s: string) -> string {
    let mut end = len(s)
    while end > 0 {
        let c = s.substring(end - 1, end)
        if c == " " || c == "\t" || c == "\r" {
            end = end - 1
        } else {
            break
        }
    }
    return s.substring(0, end)
}

fn _cmd_count_leading_spaces(line: string) -> int {
    let mut i = 0
    let n = len(line)
    while i < n {
        let c = line.substring(i, i + 1)
        if c != " " { break }
        i = i + 1
    }
    return i
}

// split on single-space runs — returns non-empty tokens.
fn _cmd_split_ws(s: string) -> [string] {
    let mut out: [string] = []
    let n = len(s)
    let mut i = 0
    let mut start = -1
    while i < n {
        let c = s.substring(i, i + 1)
        if c == " " || c == "\t" {
            if start >= 0 {
                out.push(s.substring(start, i))
                start = -1
            }
        } else {
            if start < 0 { start = i }
        }
        i = i + 1
    }
    if start >= 0 { out.push(s.substring(start, n)) }
    return out
}

// Header: `command <name> <category> "<description>"`
// Returns [name, category, description] or [] on malformed.
fn _cmd_parse_header(line: string) -> [string] {
    let sp1 = line.index_of(" ")
    if sp1 < 0 { return [] }
    let kind = line.substring(0, sp1)
    if kind != "command" { return [] }

    let rest1 = line.substring(sp1 + 1, len(line))
    let sp2 = rest1.index_of(" ")
    if sp2 < 0 { return [] }
    let name = rest1.substring(0, sp2)
    if len(name) == 0 { return [] }

    let rest2 = rest1.substring(sp2 + 1, len(rest1))
    let sp3 = rest2.index_of(" ")
    if sp3 < 0 { return [] }
    let category = rest2.substring(0, sp3)
    if len(category) == 0 { return [] }

    let desc_part = rest2.substring(sp3 + 1, len(rest2)).trim()
    let dp = len(desc_part)
    let mut description = ""
    if dp >= 2 && desc_part.substring(0, 1) == "\"" && desc_part.substring(dp - 1, dp) == "\"" {
        description = desc_part.substring(1, dp - 1)
    } else {
        // tolerant: unquoted trailing text also accepted
        description = desc_part
    }
    return [name, category, description]
}

fn _cmd_empty() -> HxCommand {
    return HxCommand {
        name: "",
        keywords: [],
        description: "",
        category: "",
        shim: false,
        handler: ""
    }
}

// ═══════════════════════════════════════════════════════════════════
// Public API
// ═══════════════════════════════════════════════════════════════════

pub fn load_commands(path: string) -> [HxCommand] {
    let mut cmds: [HxCommand] = []

    let exists = to_string(exec("test -f '" + path + "' && echo y || echo n")).trim()
    if exists != "y" {
        eprintln("warn[commands_loader]: file not found: " + path)
        return cmds
    }

    let src = to_string(read_file(path))
    let lines = split(src, "\n")

    let mut cur_name = ""
    let mut cur_category = ""
    let mut cur_description = ""
    let mut cur_keywords: [string] = []
    let mut cur_handler = ""
    let mut cur_shim = false
    let mut has_cmd = false
    let mut line_no = 0

    for raw_line in lines {
        line_no = line_no + 1
        let line = _cmd_rstrip(raw_line)
        let ln = len(line)

        // blank line = command boundary
        if ln == 0 {
            if has_cmd {
                cmds.push(HxCommand {
                    name: cur_name,
                    keywords: cur_keywords,
                    description: cur_description,
                    category: cur_category,
                    shim: cur_shim,
                    handler: cur_handler
                })
                has_cmd = false
                cur_name = ""
                cur_category = ""
                cur_description = ""
                cur_keywords = []
                cur_handler = ""
                cur_shim = false
            }
            continue
        }

        // comment — column 0 starting with '#'
        if line.substring(0, 1) == "#" { continue }

        // tab forbidden
        if line.contains("\t") {
            eprintln("warn[commands_loader]: " + path + ":" + to_string(line_no) +
                     " tab forbidden — skipped: " + line)
            continue
        }

        let lead = _cmd_count_leading_spaces(line)

        if lead == 0 {
            // close previous command if header appears without blank-line separator
            if has_cmd {
                cmds.push(HxCommand {
                    name: cur_name,
                    keywords: cur_keywords,
                    description: cur_description,
                    category: cur_category,
                    shim: cur_shim,
                    handler: cur_handler
                })
                cur_keywords = []
                cur_handler = ""
                cur_shim = false
            }
            let hdr = _cmd_parse_header(line)
            if len(hdr) == 0 {
                eprintln("warn[commands_loader]: " + path + ":" + to_string(line_no) +
                         " bad header (expected `command <name> <category> \"<desc>\"`): " + line)
                has_cmd = false
                continue
            }
            cur_name = hdr[0]
            cur_category = hdr[1]
            cur_description = hdr[2]
            has_cmd = true
            continue
        }

        if lead != 2 {
            eprintln("warn[commands_loader]: " + path + ":" + to_string(line_no) +
                     " bad indent (only 0 or 2 spaces allowed, got " +
                     to_string(lead) + "): " + line)
            continue
        }

        // key line — column 2
        if !has_cmd {
            eprintln("warn[commands_loader]: " + path + ":" + to_string(line_no) +
                     " orphan key line (no active command): " + line)
            continue
        }

        let body = line.substring(2, ln)
        let sp = body.index_of(" ")
        let mut key = ""
        let mut val = ""
        if sp < 0 {
            key = body
            val = ""
        } else {
            key = body.substring(0, sp)
            val = body.substring(sp + 1, len(body)).trim()
        }

        if key == "keywords" {
            cur_keywords = _cmd_split_ws(val)
        } else if key == "handler" {
            cur_handler = val
        } else if key == "shim" {
            if val == "yes" {
                cur_shim = true
            } else if val == "no" {
                cur_shim = false
            } else {
                eprintln("warn[commands_loader]: " + path + ":" + to_string(line_no) +
                         " shim value must be yes|no (got '" + val + "')")
            }
        } else {
            // unknown key — future extension; silently ignore per spec
            continue
        }
    }

    // trailing command (no closing blank line)
    if has_cmd {
        cmds.push(HxCommand {
            name: cur_name,
            keywords: cur_keywords,
            description: cur_description,
            category: cur_category,
            shim: cur_shim,
            handler: cur_handler
        })
    }

    return cmds
}

// Returns the HxCommand whose name OR any keyword equals `name`.
// Miss → HxCommand with empty name.
pub fn find_command(cmds: [HxCommand], name: string) -> HxCommand {
    let n = len(cmds)
    let mut i = 0
    while i < n {
        let c = cmds[i]
        if c.name == name { return c }
        let ks = c.keywords
        let km = len(ks)
        let mut j = 0
        while j < km {
            if ks[j] == name { return c }
            j = j + 1
        }
        i = i + 1
    }
    return _cmd_empty()
}

// Returns names of commands with shim=true, in declaration order.
pub fn shim_names(cmds: [HxCommand]) -> [string] {
    let mut out: [string] = []
    let n = len(cmds)
    let mut i = 0
    while i < n {
        let c = cmds[i]
        if c.shim { out.push(c.name) }
        i = i + 1
    }
    return out
}
