// tool/hexa_init.hexa — 1회 bootstrap orchestrator
//
// 사용:
//   hexa tool/hexa_init.hexa            — 전체 설치 (idempotent)
//   hexa tool/hexa_init.hexa status     — 현재 설치 상태만 조회
//   hexa tool/hexa_init.hexa force      — stamp 무시하고 재설치
//
// 수행 순서:
//   1. raw install         — .git/hooks/pre-commit 에 @raw-stanza 주입 (6 규칙 중 3/5)
//   2. attr compile          — .hexa-attrs forbid/nonblock → .attr-generated/ codegen
//   3. attr seal             — .hexa-attrs seal = ... → chmod 0444 + chattr/chflags (OS raw)
//   4. stamp 기록            — .hexa-init/stamp (clone 후 1회 실행 흔적)
//   5. 요약 리포트            — 각 단계 성공/실패
//
// 원칙:
//   · 새 세션 인지 불필요 — init 1회면 pre-commit + FS seal + PreToolUse 자동 승계
//   · hexa-native + OS utility (chmod/chattr/chflags) + git 만 의존
//   · Claude Code CLI hook/settings 는 선택 (nonblock compile 할 때만)

use "self/core/law_io"

let _raw_args = args()
let mut cli_args = []
let mut _ai = 2
while _ai < len(_raw_args) {
    cli_args = cli_args.push(_raw_args[_ai])
    _ai = _ai + 1
}

fn _pwd() -> string {
    let mut p = env("PWD")
    if p == "" { p = to_string(exec("pwd")).trim() }
    return p
}

fn _stamp_path(root: string) -> string {
    return root + "/.hexa-init/stamp"
}

fn _stamp_exists(root: string) -> bool {
    let r = to_string(exec("test -f '" + _stamp_path(root) + "' && echo y || echo n")).trim()
    return r == "y"
}

fn _write_stamp(root: string) {
    try { exec("mkdir -p '" + root + "/.hexa-init'") } catch e {}
    let date = to_string(exec("date -u +%Y-%m-%dT%H:%M:%SZ")).trim()
    let body = "hexa-init stamp\ninstalled_at: " + date + "\nraw: rules loaded from /.raw (L0) + /.own (L1)\n"
    try { safe_write_file(_stamp_path(root), body) } catch e {}
}

fn _exec_step(label: string, cmd: string) -> bool {
    println("")
    println("── " + label + " ──")
    println("$ " + cmd)
    let out = to_string(exec(cmd + " 2>&1"))
    if len(out) > 0 { println(out.trim()) }
    // exec 성공 여부 판정은 출력 마지막 라인 + exit code 간접 — 단순히 진행
    return true
}

fn run_status(root: string) {
    println("── hexa-init status ──")
    println("root  : " + root)
    println("stamp : " + _stamp_path(root))

    let has_stamp = _stamp_exists(root)
    if has_stamp {
        println("")
        println("[installed]")
        let s = to_string(exec("cat '" + _stamp_path(root) + "' 2>/dev/null"))
        println(s.trim())
    } else {
        println("")
        println("[not installed] — hexa tool/hexa_init.hexa 를 1회 실행하세요")
    }

    // raw stanza 설치 여부
    let hook = root + "/.git/hooks/pre-commit"
    let hook_has = to_string(exec("grep -c '@raw-stanza' '" + hook + "' 2>/dev/null || echo 0")).trim()
    println("")
    println("raw (pre-commit) : " + (if hook_has != "0" { "✅ installed" } else { "❌ missing" }))

    // .attr-generated 존재 여부
    let attr_gen = to_string(exec("test -d '" + root + "/.attr-generated' && echo y || echo n")).trim()
    println("attr compile       : " + (if attr_gen == "y" { "✅ codegen present" } else { "❌ not compiled" }))

    // seal 상태 — .hexa-attrs seal = ... 중 하나만 샘플
    let attrs_exists = to_string(exec("test -f '" + root + "/.hexa-attrs' && echo y || echo n")).trim()
    if attrs_exists == "y" {
        let has_seal = to_string(exec("grep -c '^seal' '" + root + "/.hexa-attrs' 2>/dev/null || echo 0")).trim()
        println("seal declaration   : " + (if has_seal != "0" { "✅ declared" } else { "⚠ no seal tokens" }))
    } else {
        println("seal declaration   : ⚠ .hexa-attrs 없음")
    }
}

fn run_install(root: string, force: bool) {
    if _stamp_exists(root) && !force {
        println("already installed — stamp: " + _stamp_path(root))
        println("재설치: hexa tool/hexa_init.hexa force")
        exit(0)
    }

    println("──────────────────────────────────────────────")
    println("  hexa-init — 1회 bootstrap")
    println("  root: " + root)
    println("──────────────────────────────────────────────")

    // Step 1: raw install
    _exec_step(
        "[1/4] raw install (pre-commit 스탠자)",
        "cd '" + root + "' && hexa self/raw_cli.hexa install"
    )

    // Step 2: attr compile
    _exec_step(
        "[2/4] attr compile (.hexa-attrs → .attr-generated/)",
        "cd '" + root + "' && hexa self/attr_cli.hexa compile all"
    )

    // Step 3: attr seal
    _exec_step(
        "[3/4] attr seal (fs_seal — chmod/chattr/chflags)",
        "cd '" + root + "' && hexa self/attr_cli.hexa seal"
    )

    // Step 4: stamp
    _write_stamp(root)
    println("")
    println("── [4/4] stamp 기록 ──")
    println("✔ " + _stamp_path(root))

    // 요약
    println("")
    println("──────────────────────────────────────────────")
    println("  hexa-init 완료")
    println("──────────────────────────────────────────────")
    println("  상태 확인  : hexa tool/hexa_init.hexa status")
    println("  raw 조회 : hexa self/raw_cli.hexa")
    println("  seal 상태  : hexa self/attr_cli.hexa seal-status")
    println("  law check  : hexa tool/law_check.hexa  (Phase 2 — compile gate)")
    println("  drift scan : hexa tool/drift_scanner.hexa  (raw #8 proof-carrying)")
    println("")
    println("  (선택) Phase α — hexa wrapper (law_check 자동):")
    println("    hexa tool/install_wrapper.hexa         # 설치 가이드")
    println("    hexa tool/install_wrapper.hexa --verify  # 설치 확인")
    println("")
    println("  새 세션은 인지 없이도 pre-commit / fs_seal / compile gate 자동 승계")
}

// ─── dispatch ─────────────────────────────────────────────────
let root = _pwd()

if len(cli_args) == 0 {
    run_install(root, false)
    exit(0)
}

let sub = cli_args[0]

if sub == "status" {
    run_status(root)
    exit(0)
}

if sub == "force" {
    run_install(root, true)
    exit(0)
}

eprintln("usage:")
eprintln("  hexa tool/hexa_init.hexa           — 전체 설치")
eprintln("  hexa tool/hexa_init.hexa status    — 현재 상태")
eprintln("  hexa tool/hexa_init.hexa force     — 재설치")
exit(1)
