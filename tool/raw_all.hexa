#!hexa strict
// tool/raw_all.hexa — raw#0 unified enforcement orchestrator (P0a)
//
// PURPOSE
//   Single entry point that walks every rule declared in .raw / .own
//   (and .ext, when live), dispatches to each rule's declared enforcer,
//   aggregates exit codes, and produces a pass/fail verdict for the
//   whole repository.
//
//   This is the gate behind tool/hx_unlock.hexa — unlock is refused
//   unless raw_all returns exit 0.
//
// USAGE
//   ./hexa tool/raw_all.hexa                  — full run (live + warn + new)
//   ./hexa tool/raw_all.hexa --fast           — skip heavy proof scripts
//   ./hexa tool/raw_all.hexa --only raw 7     — single rule (debug)
//   ./hexa tool/raw_all.hexa --json           — machine-readable output
//   ./hexa tool/raw_all.hexa --serial         — force serial dispatch (debug)
//   ./hexa tool/raw_all.hexa --exclude raw:<slug>   — skip specific rule(s)
//                                               (repeatable; matching rules
//                                                emit SKIP with
//                                                detail="excluded via --exclude")
//   ./hexa tool/raw_all.hexa --roadmap-ref <id>    — roadmap milestone id that
//                                                    justifies the bypass (required
//                                                    when --exclude or --fast used).
//                                                    Must exist in .roadmap with
//                                                    status ∈ {active, blocked}.
//
// PARALLELISM (P7a, 2026-04-20)
//   17 enforcers run in parallel batches of N (default 4), controlled by
//   HEXA_RAW_ALL_PARALLEL env var. Each batch launches interp subprocesses
//   as shell background jobs (&), waits for all (wait), then reads per-rule
//   output tmp files. Output order is preserved by evaluating in
//   declaration order after all subprocesses have joined. Proof stage
//   remains serial (runs only after enforce passes + usually skipped under
//   --fast). `--serial` flag forces N=1 for diagnostic purposes.
//
// EXIT CODES
//   0   — every live/new rule PASSED (warn rules may have warnings)
//   1   — one or more rules FAILED (or expired exemption detected)
//   2   — invocation error (bad args, missing files)
//
// DISPATCH MODEL
//   For each rule:
//     · status=deferred   → SKIP (rule not yet enforced)
//     · status=convention → SKIP (advisory, no enforcer)
//     · status=warn       → RUN enforce, report but never fail the gate
//     · status=new        → RUN enforce, report (new rules block but soft)
//     · status=live       → RUN enforce + proof, any non-zero = FAIL
//
//   P1a (2026-04-20): proof field is now actively consumed.
//     · If proof == enforce script → skipped (already proved by enforce run).
//     · If proof is a distinct .hexa path → executed via interp.
//     · If proof starts with "assert:" → literal shell condition.
//     · proof non-zero → verdict = PROOF_FAIL (fatal on live rules).
//     · --fast mode still skips proof (heuristic preserved).
//
//   P1b (2026-04-20): exemption system.
//     · raw_all invokes tool/raw_exemptions.hexa check at start.
//     · Any expired exemption → whole gate FAIL (blocking).
//     · Expiring-soon (≤7d) → printed as WARN in summary.
//
//   The enforce field is taken verbatim. If it contains a '#method'
//   suffix (e.g., "tool/ai_native_scan.hexa#F5,F6"), only the file
//   portion is invoked — each enforcer is expected to run its full
//   method set when called without args. Rule-level #method selection
//   is a P2a refinement (rule DAG).
//
// NOTES
//   · Kinds validated: raw (L0) + own (L1). ext / roadmap / loop have
//     their own dedicated lints (raw#13/#15/#16) and are invoked via
//     the owning raw rule's enforce field.
//   · Each enforcer runs in the same interp process via exec_with_status.
//   · Output is deterministic — rules walked in declaration order.

use "self/stdlib/law_io"
use "self/raw_loader"
use "tool/raw_audit"
use "tool/raw_cache"
use "tool/raw_dag"
// ─── argv parsing ────────────────────────────────────────────────

fn _parse_flags() -> array {
    // returns [fast(bool), json(bool), only_kind(string), only_id(string),
    //          serial(bool), excludes(array-of-slug-strings),
    //          roadmap_ref(string)]
    //
    // --exclude raw:<slug> is repeatable; each match causes the rule to
    // emit SKIP with detail="excluded via --exclude raw:<slug>" and does
    // NOT count as a failure in the summary. The "raw:" prefix is
    // optional — callers may pass either "raw:self-host-fixpoint" or
    // bare "self-host-fixpoint"; both match the same slug.
    //
    // --roadmap-ref <id> (raw#15, 2026-04-20): required when --exclude or
    // --fast is used. Provides traceable roadmap milestone justification
    // for the bypass; id must resolve in /.roadmap with status ∈
    // {active, blocked}.
    let av = argv()
    let mut fast = false
    let mut json = false
    let mut only_kind = ""
    let mut only_id = ""
    let mut serial = false
    let mut excludes = []
    let mut roadmap_ref = ""
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--fast" { fast = true }
        else if a == "--json" { json = true }
        else if a == "--serial" { serial = true }
        else if a == "--only" {
            if i + 2 < len(av) {
                only_kind = av[i + 1]
                only_id = av[i + 2]
                i = i + 2
            }
        }
        else if a == "--exclude" {
            if i + 1 < len(av) {
                let raw_tok = av[i + 1]
                // normalize: strip optional "raw:" prefix for slug-only compare
                let mut tok = raw_tok
                if len(tok) >= 4 && tok.substring(0, 4) == "raw:" {
                    tok = tok.substring(4, len(tok))
                }
                if tok != "" { excludes.push(tok) }
                i = i + 1
            }
        }
        else if a == "--roadmap-ref" {
            if i + 1 < len(av) {
                roadmap_ref = av[i + 1]
                i = i + 1
            }
        }
        i = i + 1
    }
    return [fast, json, only_kind, only_id, serial, excludes, roadmap_ref]
}

// ─── parallel batch size ─────────────────────────────────────────

fn _parallel_n(serial: bool) -> int {
    // --serial flag → force 1. Else read HEXA_RAW_ALL_PARALLEL (default 4).
    // Invalid / non-positive values fall back to 4.
    if serial { return 1 }
    let raw = env("HEXA_RAW_ALL_PARALLEL")
    if raw == "" { return 4 }
    let n = raw.parse_int()
    if n <= 0 { return 4 }
    if n > 32 { return 32 }
    return n
}

// ─── tmp file naming (deterministic, collision-safe) ─────────────

fn _tmp_path(kind: string, id: string) -> string {
    // /tmp/raw_all_tmp/<kind>_<id>.out
    // (push/join — called 2× per rule ≈ 40+ invocations per run; naïve
    //  chained `+` bumps the interp str-concat counter past 100 quickly.
    //  2026-04-20)
    let parts = ["/tmp/raw_all_tmp/", kind, "_", id, ".out"]
    return parts.join("")
}

fn _tmp_init() {
    // create fresh tmp dir for this run (clean previous residue)
    // exec() (not exec_with_status) because we ignore the exit code and
    // exec_with_status does 3 internal concats per call; exec is concat-free
    // except when shell metacharacters trigger a warning print.
    let _ = exec("rm -rf /tmp/raw_all_tmp && mkdir -p /tmp/raw_all_tmp")
}

// ─── enforcer extraction ─────────────────────────────────────────

fn _enforce_script(enforce_field: string) -> string {
    // strip "#method" suffix: "tool/foo.hexa#F1,F2" → "tool/foo.hexa"
    if enforce_field == "" { return "" }
    let h = enforce_field.index_of("#")
    if h < 0 { return enforce_field }
    return enforce_field.substring(0, h)
}

// Declarative mode tokens — enforce values that are not file paths but
// bind a rule to an explicit evaluation mode. Passing enforce=strict
// means the rule is intentionally non-script (e.g. axiom declaration
// carried only by the decl+proof fields). Match is exact-token.
fn _is_enforce_mode_token(tok: string) -> bool {
    let t = tok.trim()
    if t == "strict" { return true }
    if t == "lazy"   { return true }
    if t == "manual" { return true }
    if t == "nudge"  { return true }
    if t == "guide"  { return true }
    if t == "warn"   { return true }
    if t == "live"   { return true }
    return false
}

// Split composite enforce field on `+` or `&&` separators so multi-file
// declarations (`tool/a.hexa + self/b.sb + self/c.c`) can be validated
// per-part. Whitespace-trimmed parts; empties dropped.
fn _split_enforce_parts(enforce_field: string) -> array {
    let mut parts = []
    let normalized = enforce_field.replace("&&", "+")
    let raw_parts = normalized.split("+")
    for rp in raw_parts {
        let t = rp.trim()
        if t != "" { parts.push(t) }
    }
    return parts
}

// Pick the first runnable `.hexa` part of a composite enforce field.
// Returns [script, missing_detail, kind] where kind ∈ {"run","mode","missing"}:
//   · kind=run     → script = runnable `.hexa` path
//   · kind=mode    → script = declarative sentinel (mode token or
//                    non-hexa artifact like .sb/.c/.json); no subprocess
//   · kind=missing → script="", missing_detail = which parts are absent
// Non-hexa files that exist on disk (SBPL profiles, C sources, JSON
// manifests) are treated as declarative — the rule credits them as SSOT
// artifacts without trying to execute them through hexa_interp.
fn _resolve_enforce(enforce_field: string) -> array {
    let stripped = _enforce_script(enforce_field)
    let parts = _split_enforce_parts(stripped)
    if len(parts) == 0 { return ["", enforce_field, "missing"] }
    let mut declarative_pick = ""
    let mut missing_bits = []
    for p in parts {
        let expanded = _tilde_expand(p)
        if file_exists(expanded) {
            // Runnable = relative `.hexa` path under this repo. Cross-repo
            // `.hexa` files (tilde-prefixed or absolute) belong to their
            // owning project's enforcement pipeline and are credited as
            // declarative references. Non-hexa artifacts (SBPL / C /
            // JSON / settings.json) are likewise declarative.
            let is_relative = !p.starts_with("~") && !p.starts_with("/")
            if expanded.ends_with(".hexa") && is_relative {
                return [expanded, "", "run"]
            }
            if declarative_pick == "" { declarative_pick = expanded }
            continue
        }
        if _is_enforce_mode_token(p) {
            if declarative_pick == "" { declarative_pick = p }
            continue
        }
        missing_bits.push(p)
    }
    if declarative_pick != "" && len(missing_bits) == 0 {
        return [declarative_pick, "", "mode"]
    }
    return ["", missing_bits.join(" + "), "missing"]
}

fn _should_run(status: string) -> bool {
    if status == "deferred" { return false }
    if status == "convention" { return false }
    return true
}

// Tilde-expand `~/...` and `~` so composite enforce fields that mix
// user-global Claude Code artifacts (`~/.claude/settings.json`) and
// cross-repo hook scripts (`~/core/airgenome/hooks/pre_tool.hexa`) can
// be file_exists-checked. Exact `~/` prefix only — we deliberately do
// NOT try to expand `~user/` (requires passwd lookup).
fn _tilde_expand(p: string) -> string {
    if len(p) == 0 { return p }
    if p.substring(0, 1) != "~" { return p }
    let home = env("HOME")
    if home == "" { return p }
    if len(p) == 1 { return home }
    if p.substring(1, 2) != "/" { return p }
    let rest = p.substring(1, len(p))
    return home + rest
}

// Parse raw#NN defer-until YYYY-MM and compare against current calendar
// month. Returns true when the rule's defer-until is in the future,
// which `_should_run` uses to skip enforcement even on `status=live`
// rules (raw#15 no-hardcode was the canonical case that needed this
// — status=live + defer-until 2026-06 was meant to stay declarative
// until the scanner landed, but the gate was running it anyway).
fn _defer_until_future(keys: array) -> bool {
    // NOTE: variable name avoids interp reserved keyword `defer`.
    let du_val = keys_first(keys, "defer-until")
    if du_val == "" { return false }
    // Expect YYYY-MM. Be permissive on trailing noise.
    let d = du_val.trim()
    if len(d) < 7 { return false }
    let yyyy = d.substring(0, 4)
    let dash = d.substring(4, 5)
    let mm = d.substring(5, 7)
    if dash != "-" { return false }
    // Current year-month via `date -u +%Y-%m`. Stage0 has no clock
    // builtin, so we shell out (single call, amortised per raw_all run).
    let now = exec("date -u +%Y-%m").trim()
    if len(now) != 7 { return false }
    let now_y = now.substring(0, 4)
    let now_m = now.substring(5, 7)
    // Stage0's string `<`/`>` operators always return false, so compare
    // as parsed integers.
    let yn = yyyy.parse_int()
    let mn = mm.parse_int()
    let ny = now_y.parse_int()
    let nm = now_m.parse_int()
    if yn > ny { return true }
    if yn < ny { return false }
    if mn > nm { return true }
    return false
}

fn _is_fatal(status: string) -> bool {
    // live blocks, warn/new soft-report (do not flip exit code)
    return status == "live"
}

// ─── single enforcer invocation ──────────────────────────────────

fn _run_enforcer(script: string) -> array {
    // returns [exit_code, stdout_tail, duration_ms]
    // interp binary path already on $PATH via ./hexa wrapper;
    // we call the raw binary to avoid wrapper re-entry.
    // HEXA_VAL_ARENA=0 prefix: avoids arena OOM on large sources
    // (observed 8.6GB on parser.hexa via ai_native_lint). Child must
    // inherit this regardless of whether caller exported it.
    let cmd_parts = ["HEXA_VAL_ARENA=0 ./build/hexa_interp ", script, " 2>&1"]
    let cmd = cmd_parts.join("")
    let start_ms = 0  // interp lacks high-res clock builtin — placeholder
    let r = exec_with_status(cmd)
    let rc = r[1]
    let out = to_string(r[0])
    return [rc, _tail_of(out), start_ms]
}

// Stage0 arrays lack .set() — rebuild with the new plan at idx.
// Mirrors tool/raw_dag.hexa:_arr_set but typed for the plan tuple
// (array-of-strings). Used by Phase 1b dep-cascade downgrade.
fn _arr_set_plan(arr: array, idx: int, val: array) -> array {
    let n = len(arr)
    let mut out = []
    let mut i = 0
    while i < n {
        if i == idx { out.push(val) }
        else { out.push(arr[i]) }
        i = i + 1
    }
    return out
}

fn _tail_of(out: string) -> string {
    // keep last 10 lines as tail for error reporting
    // (push/join — avoids O(n²) in-loop string concat, silences interp PERF
    //  warning at 100+ concats/process — 2026-04-20)
    let lines = split(out, "\n")
    let n = len(lines)
    let mut start_idx = 0
    if n > 10 { start_idx = n - 10 }
    let mut parts = []
    let mut i = start_idx
    while i < n {
        parts.push(lines[i])
        i = i + 1
    }
    return parts.join("\n")
}

// ─── parallel enforcer batch (P7a) ───────────────────────────────
//
// Launches a batch of enforce scripts as shell background jobs, waits
// for all to join, then reads per-rule output files. Exit codes are
// captured via `cmd; echo $? > rc.file` so no pid→rc mapping is needed.
//
// `tasks` is an array of [kind, id, script] triples.
// Returns a parallel array of [rc, tail] in the same order.
//
// Design notes:
//   · script comes from raw_loader's `enforce` field → already validated
//     token-free (raw#1 self-format), so shell injection surface is low.
//     We still single-quote paths defensively.
//   · Each task gets two tmp files: .out (stdout+stderr), .rc (exit code).
//   · `wait` without args waits for ALL background jobs in the shell.
//   · We pass the composite directly to exec_with_status; popen invokes
//     `sh -c <cmd>` once, so `$?` resolves inside that single shell (no
//     outer-layer variable expansion, no double-quote injection risk).
fn _run_batch(tasks: array) -> array {
    let nt = len(tasks)
    if nt == 0 { return [] }

    // Build one composite shell command: launch all N in background, wait.
    // (push/join everywhere — each task contributes ~8 concats otherwise,
    //  with 21 tasks that alone blows the 100 threshold. 2026-04-20)
    let mut script_parts = []
    let mut i = 0
    while i < nt {
        let t = tasks[i]
        let kind = t[0]
        let id = t[1]
        let path = t[2]
        let out = _tmp_path(kind, id)
        let rcf_parts = [out, ".rc"]
        let rcf = rcf_parts.join("")
        // defensive quoting: single-quote the script path; it should never
        // contain single quotes (rule paths are token-only), but escape
        // just in case.
        let qpath_parts = ["'", path.replace("'", "'\\''"), "'"]
        let qpath = qpath_parts.join("")
        // run in subshell so each exit code is captured independently
        // HEXA_VAL_ARENA=0 prefix: prevents arena OOM in parallel batch
        // (e.g. ai_native_lint on parser.hexa hits 8.6GB with arena on).
        let one_parts = ["( HEXA_VAL_ARENA=0 ./build/hexa_interp ", qpath, " > ", out,
                         " 2>&1; echo $? > ", rcf, " ) &"]
        script_parts.push(one_parts.join(""))
        i = i + 1
    }
    script_parts.push("wait")
    let script = script_parts.join(" ")

    // exec() over exec_with_status — result ignored; exec_with_status does
    // 3 internal concats per call, exec does 1 (metachar warning).
    let _ = exec(script)

    // Collect results in input order (deterministic).
    //
    // rc-file discipline (P1c, 2026-04-20): if .rc file is missing or its
    // body is not a parseable int, we treat that as a HARD FAIL rather
    // than defaulting to 0 (the previous silent behaviour gave a false
    // green when a subprocess aborted before `echo $? > rc.file` ran).
    // Signalled via rc=-1 + a diagnostic tail. Callers (see _finish_rule)
    // map -1 to FAIL/WARN per the rule's status class.
    let mut results = []
    i = 0
    while i < nt {
        let t = tasks[i]
        let kind = t[0]
        let id = t[1]
        let out_path = _tmp_path(kind, id)
        let rc_path_parts = [out_path, ".rc"]
        let rc_path = rc_path_parts.join("")
        let out = to_string(read_file(out_path))
        if !file_exists(rc_path) {
            let tail = _tail_of(out)
            let diag_parts = ["rc-file missing: ", rc_path]
            let diag = diag_parts.join("")
            let mut combined = diag
            if tail != "" {
                let cp = [diag, "\n", tail]
                combined = cp.join("")
            }
            results.push([-1, combined])
            i = i + 1
            continue
        }
        let rc_raw = to_string(read_file(rc_path)).trim()
        if rc_raw == "" {
            let tail = _tail_of(out)
            let diag_parts = ["rc-file empty: ", rc_path]
            let diag = diag_parts.join("")
            let mut combined = diag
            if tail != "" {
                let cp = [diag, "\n", tail]
                combined = cp.join("")
            }
            results.push([-1, combined])
            i = i + 1
            continue
        }
        let rc = rc_raw.parse_int()
        results.push([rc, _tail_of(out)])
        i = i + 1
    }
    return results
}

// ─── proof-carrying consumption (P1a) ────────────────────────────
//
// proof may be:
//   1. equal to the enforce script  → already proven, skip
//   2. a .hexa file path             → execute via interp
//   3. "assert:<shell-condition>"    → run condition as shell expr
//
// returns [exit_code, tail, mode]
//   mode ∈ {"skip-same", "skip-empty", "hexa", "assert"}
fn _run_proof(enforce_script: string, proof_field: string) -> array {
    if proof_field == "" { return [0, "", "skip-empty"] }

    // literal shell assertion (assert:<expr>)
    if len(proof_field) >= 7 && proof_field.substring(0, 7) == "assert:" {
        let expr = proof_field.substring(7, len(proof_field))
        // run under bash -c so `count(shared/**/*)==0`-style pseudo-DSL
        // can be pre-translated by callers (we trust raw.proof literals).
        let cmd = "bash -c '" + expr.replace("'", "'\\''") + "' 2>&1"
        let r = exec_with_status(cmd)
        let out = to_string(r[0]).trim()
        return [r[1], out, "assert"]
    }

    // same as enforce → proof already satisfied by enforce run
    if proof_field == enforce_script { return [0, "", "skip-same"] }

    // otherwise treat as .hexa path executed via interp
    if !proof_field.ends_with(".hexa") {
        // non-hexa, non-assert, non-same — treat as textual reference,
        // do not execute (avoid running arbitrary strings).
        return [0, "proof is textual reference (not executed)", "skip-same"]
    }

    let r = _run_enforcer(proof_field)
    return [r[0], r[1], "hexa"]
}

// ─── one rule evaluation (split: plan + finish for parallel dispatch) ─

// _plan_rule — pure bookkeeping, no shell IO beyond the one-time interp
// guard (cached by caller). Returns:
//   ["SKIP",    reason,  "",     ""]          — do not run
//   ["WARN",    reason,  "",     ""]          — pre-decided soft verdict
//   ["FAIL",    reason,  "",     ""]          — pre-decided hard verdict
//   ["MISSING", script,  "",     ""]          — enforce path not on disk (warn)
//   ["RUN",     "",      script, proof_field] — schedule enforcer
//
// excludes: array of slug strings (raw: prefix already stripped). A rule
// whose slug appears here is short-circuited to SKIP regardless of
// status — used by --exclude raw:<slug> to bypass structurally blocked
// enforcers (e.g. raw:self-host-fixpoint while hexa_v2 seed-freeze holds).
fn _plan_rule(kind: string, rule: array, s0_ok: bool, excludes: array) -> array {
    let keys = rule[3]

    // --exclude precedence: checked BEFORE status so that a live rule
    // whose enforcer is broken can still be skipped for ceremony purposes.
    if len(excludes) > 0 {
        let slug = keys_first(keys, "slug")
        if slug != "" {
            for ex in excludes {
                if ex == slug {
                    let sp = ["excluded via --exclude raw:", slug]
                    return ["SKIP", sp.join(""), "", ""]
                }
            }
        }
    }

    let status = rule[1]
    if !_should_run(status) { return ["SKIP", status, "", ""] }

    // defer-until future-dated — rule stays declared, enforcer is held
    // back until the stated month. Used by raw#15 no-hardcode during the
    // 354-violation triage window (defer-until 2026-06).
    if _defer_until_future(keys) {
        let du = keys_first(keys, "defer-until")
        let dp = ["defer-until ", du]
        return ["SKIP", dp.join(""), "", ""]
    }

    let enforce_field = keys_first(keys, "enforce")
    if enforce_field == "" {
        if _is_fatal(status) { return ["FAIL", "no `enforce` field on live rule", "", ""] }
        return ["WARN", "no `enforce` field (soft status)", "", ""]
    }

    if !s0_ok {
        return ["SKIP", "hexa_interp not executable on this host", "", ""]
    }

    // Composite enforce fields are split on `+` / `&&`; the first file-on-
    // disk part is the runnable script. Pure mode tokens (strict/nudge/etc.)
    // bind the rule to a declarative-only evaluation with no subprocess
    // (raw#30 irreversibility-embedded-lagrangian is the canonical
    // strict-mode axiom rule — the enforce field IS the declaration).
    let resolved = _resolve_enforce(enforce_field)
    let script = resolved[0]
    let missing_detail = resolved[1]
    let kind = resolved[2]
    if kind == "missing" {
        // P1c (2026-04-20): distinct MISSING verdict (warn-class, not FAIL)
        // — no runnable part on disk and no mode token salvage.
        return ["MISSING", missing_detail, "", ""]
    }
    if kind == "mode" {
        // Declarative-only rule — non-hexa artifact on disk or pure mode
        // token. Skip the subprocess, treat as PASS.
        return ["MODE_PASS", script, "", ""]
    }
    let proof_field = keys_first(keys, "proof")
    return ["RUN", "", script, proof_field]
}

// _finish_rule — given the enforcer batch result, run optional proof
// (serial) and return the final [verdict, detail].
fn _finish_rule(status: string, script: string, proof_field: string,
                rc: int, tail: string, fast: bool) -> array {
    if rc != 0 {
        if _is_fatal(status) {
            let fail_parts = [script, " exit=", to_string(rc), "\n", tail]
            return ["FAIL", fail_parts.join("")]
        }
        let warn_parts = [script, " exit=", to_string(rc), " (soft)"]
        return ["WARN", warn_parts.join("")]
    }

    // proof consumption (P1a) — only after enforce passed; serial by design
    // (most proofs are skipped under --fast and survivors are few).
    let skip_proof = fast
    if !skip_proof && proof_field != "" {
        let pr = _run_proof(script, proof_field)
        let prc = pr[0]
        let ptail = pr[1]
        let pmode = pr[2]
        if prc != 0 {
            let msg_parts = ["proof(", pmode, ") ", proof_field,
                             " exit=", to_string(prc), "\n", ptail]
            let msg = msg_parts.join("")
            if _is_fatal(status) {
                return ["PROOF_FAIL", msg]
            }
            let soft_parts = [msg, " (soft)"]
            return ["WARN", soft_parts.join("")]
        }
    }

    return ["PASS", script]
}

// ─── output formatting ───────────────────────────────────────────

fn _fmt_row(kind: string, rule: array, verdict: string, detail: string) -> string {
    // "  [raw#7 live ]  PASS   tool/ai_native_scan.hexa"
    // (push/join throughout — called once per rule; every `str + x` bumps
    //  the interp process-wide concat counter (PERF warn at >100). With
    //  ~40 rules × 7+ concats per head-expression alone, a naïve `+` chain
    //  trivially breaks the threshold. 2026-04-20)
    let id = rule[0]
    let status = rule[1]
    let head_parts = ["  [", kind, "#", id, " ", status, "]"]
    let head = head_parts.join("")
    // pad status to 22 chars so columns align (best-effort)
    let pad = 22 - len(head)
    let mut p_parts = []
    let mut i = 0
    while i < pad {
        p_parts.push(" ")
        i = i + 1
    }
    let p = p_parts.join("")
    let v = verdict
    let vpad = 7 - len(v)
    let mut vp_parts = []
    i = 0
    while i < vpad {
        vp_parts.push(" ")
        i = i + 1
    }
    let vp = vp_parts.join("")
    let out_parts = [head, p, v, vp, " ", detail]
    return out_parts.join("")
}

fn _json_escape(s: string) -> string {
    // minimal escaping for stdout JSON — no nested quotes expected in
    // script paths or status strings; newlines replaced with \n.
    let a = s.replace("\\", "\\\\")
    let b = a.replace("\"", "\\\"")
    let c = b.replace("\n", "\\n")
    return c
}

// ─── main walk ───────────────────────────────────────────────────

fn _walk_kind(kind: string, path: string, fast: bool, only_kind: string,
              only_id: string, json: bool, par_n: int, ssot_fp: string,
              excludes: array) -> array {
    // returns [pass_ct, fail_ct, warn_ct, skip_ct, json_entries(array), missing_ct, enforce_ct]
    //   enforce_ct — total rules that attempted enforcement (RUN + MISSING + pre-FAIL-due-to-no-enforce).
    //                Used by the "N/M enforcers PASS" summary line.
    //                CACHED entries count as PASS but do NOT bump enforce_ct
    //                (they did not actually run — cache fast-path, P1d).
    if !file_exists(path) {
        if kind == "raw" {
            // .raw MUST exist
            let fp = ["raw_all: FATAL — ", path, " missing"]
            eprintln(fp.join(""))
            return [0, 1, 0, 0, [], 0, 0]
        }
        return [0, 0, 0, 0, [], 0, 0]
    }

    // self-format validation (raw#1) — must pass before any rule walk
    let strict_errs = validate_strict(path)
    if len(strict_errs) > 0 {
        if !json {
            let hp = ["raw_all: ", path, " fails self-format (raw#1):"]
            eprintln(hp.join(""))
            for e in strict_errs {
                let ep = ["  ", e]
                eprintln(ep.join(""))
            }
        }
        return [0, 1, 0, 0, [], 0, 0]
    }

    let rules = load_raw_file(path)

    // interp guard — hoisted out of per-rule loop (was N calls, now 1).
    // file_exists over exec_with_status to avoid shell-concat overhead —
    // exec_with_status itself does 3 internal str-concats per call, which
    // inflates the interp PERF counter on large multi-rule walks.
    let s0_ok = file_exists("./build/hexa_interp")

    // Local cache memoization — avoid O(rules) per-rule cache_hit calls.
    // cache_hit → cache_read → exec_with_status("test -f ...") per rule
    // contributes 3 concats × N_rules = easily 60+ concats on a full walk,
    // enough to trip the interp process-wide PERF threshold by itself.
    // Populate slug→"<sha>|<result>" once up front via a single shell glob.
    let mut cache_slugs = []
    let mut cache_entries = []
    if fast && ssot_fp != "" && file_exists(".raw-cache") {
        let ls_out = to_string(exec("ls .raw-cache 2>/dev/null | grep '.entry$'"))
        let cache_lines = split(ls_out, "\n")
        for fname in cache_lines {
            let f = fname.trim()
            if f == "" { continue }
            // slug = filename without ".entry"
            let slen = len(f)
            if slen < 6 { continue }
            let slug = f.substring(0, slen - 6)
            let epath_parts = [".raw-cache/", f]
            let body = to_string(read_file(epath_parts.join(""))).trim()
            if body == "" { continue }
            cache_slugs.push(slug)
            cache_entries.push(body)
        }
    }

    // Phase 1a: plan every rule (filter by --only, classify skip/run).
    // `plans[i]` is the plan for `rules[i]`, or ["FILTERED","",""] when
    // excluded by --only (preserves index alignment). This pass also
    // applies the --fast cache fast-path (P1d). Dep-cascade skip (P2a)
    // is a second pass below so it can observe pre-decided FAIL/MISSING
    // verdicts regardless of rule declaration order.
    let mut plans = []
    let mut ri = 0
    while ri < len(rules) {
        let rule = rules[ri]
        let id = rule[0]
        let mut plan = ["FILTERED", "", "", ""]
        let mut included = true
        if only_kind != "" {
            if only_kind != kind { included = false }
            if only_id != "" && only_id != id { included = false }
        }
        if included {
            plan = _plan_rule(kind, rule, s0_ok, excludes)
            if plan[0] == "RUN" {
                // P1d (2026-04-20): --fast cache fast-path.
                //   Prefer the locally-memoized slug→entry map (populated
                //   above via one shell glob) over per-rule cache_hit()
                //   — cache_hit invokes exec_with_status internally, which
                //   contributes 3 concats/call toward the PERF counter.
                let mut cached = false
                if fast && ssot_fp != "" {
                    let slug = keys_first(rule[3], "slug")
                    if slug != "" {
                        let mut ci = 0
                        while ci < len(cache_slugs) {
                            if cache_slugs[ci] == slug {
                                let entry = cache_entries[ci]
                                // entry = "<sha>|<result>|<ts>"
                                let bar1 = entry.index_of("|")
                                if bar1 > 0 {
                                    let sha = entry.substring(0, bar1)
                                    let rest = entry.substring(bar1 + 1, len(entry))
                                    let bar2 = rest.index_of("|")
                                    let result = ""
                                    let mut res2 = result
                                    if bar2 >= 0 { res2 = rest.substring(0, bar2) }
                                    else { res2 = rest }
                                    if sha == ssot_fp && res2.trim() == "PASS" {
                                        let short_fp = ssot_fp.substring(0, 8)
                                        let hit_parts = ["cache hit @ ", short_fp]
                                        plan = ["CACHED", hit_parts.join(""), "", ""]
                                        cached = true
                                    }
                                }
                                break
                            }
                            ci = ci + 1
                        }
                    }
                }
            }
        }
        plans.push(plan)
        ri = ri + 1
    }

    // Phase 1b (P2a, 2026-04-20): dep-cascade skip — wire raw_dag in.
    //   Collect pre-decided hard-fail slugs (FAIL, MISSING) from Phase 1a
    //   plans. Then, for every remaining RUN plan, ask raw_dag whether
    //   any transitive dep is in the failed set; if so, downgrade to
    //   SKIPPED_DEP with detail naming the blockers. This only catches
    //   pre-decided failures (before the batch runs) — it does NOT
    //   cascade from enforcer-runtime failures, which is a P2b refinement
    //   requiring topo-chunked batch dispatch (see raw_all header notes).
    let mut failed_slugs_initial = []
    let mut fi = 0
    while fi < len(plans) {
        let fp = plans[fi]
        let ftag = fp[0]
        if ftag == "FAIL" || ftag == "MISSING" {
            let fslug = keys_first(rules[fi][3], "slug")
            if fslug != "" { failed_slugs_initial.push(fslug) }
        }
        fi = fi + 1
    }
    if len(failed_slugs_initial) > 0 {
        let mut di = 0
        while di < len(plans) {
            let dp = plans[di]
            if dp[0] == "RUN" {
                let dslug = keys_first(rules[di][3], "slug")
                if dslug != "" {
                    let blockers = blockers_for(dslug, failed_slugs_initial)
                    if len(blockers) > 0 {
                        let mut parts = []
                        for b in blockers {
                            let bp = ["raw:", b]
                            parts.push(bp.join(""))
                        }
                        let msg_parts = ["blocked by: ", parts.join(", ")]
                        let msg = msg_parts.join("")
                        plans = _arr_set_plan(plans, di, ["SKIPPED_DEP", msg, "", ""])
                    }
                }
            }
            di = di + 1
        }
    }

    // Phase 1c: collect runnable tasks from the post-cascade plan list.
    let mut runnable_idx = []      // indices into `rules` that need enforcer
    let mut runnable_tasks = []    // [kind, id, script] for batch API
    let mut si = 0
    while si < len(plans) {
        let sp = plans[si]
        if sp[0] == "RUN" {
            runnable_idx.push(si)
            runnable_tasks.push([kind, rules[si][0], sp[2]])
        }
        si = si + 1
    }

    // Phase 2: launch runnable tasks in batches of par_n.
    // Results land in `batch_results[i]` keyed to `runnable_idx[i]`.
    let nrun = len(runnable_tasks)
    let mut batch_results = []
    let mut bi = 0
    while bi < nrun {
        let mut batch = []
        let mut bj = 0
        while bj < par_n && bi + bj < nrun {
            batch.push(runnable_tasks[bi + bj])
            bj = bj + 1
        }
        let br = _run_batch(batch)
        let mut bk = 0
        while bk < len(br) {
            batch_results.push(br[bk])
            bk = bk + 1
        }
        bi = bi + len(batch)
    }

    // Phase 3: finish rules in declaration order (proof runs serially for
    // each passing enforce; output/json emission preserves original order).
    let mut pass_ct = 0
    let mut fail_ct = 0
    let mut warn_ct = 0
    let mut skip_ct = 0
    let mut missing_ct = 0
    let mut enforce_ct = 0    // PASS + FAIL + PROOF_FAIL + MISSING (+ pre-FAIL)
    let mut json_entries = []
    let mut result_cursor = 0
    let mut k = 0
    while k < len(rules) {
        let rule = rules[k]
        let plan = plans[k]
        let tag = plan[0]
        if tag == "FILTERED" { k = k + 1; continue }

        let mut verdict = ""
        let mut detail = ""
        if tag == "SKIP" { verdict = "SKIP"; detail = plan[1] }
        else if tag == "WARN" { verdict = "WARN"; detail = plan[1] }
        else if tag == "FAIL" { verdict = "FAIL"; detail = plan[1] }
        else if tag == "CACHED" { verdict = "CACHED"; detail = plan[1] }
        else if tag == "SKIPPED_DEP" { verdict = "SKIPPED_DEP"; detail = plan[1] }
        else if tag == "MISSING" {
            verdict = "MISSING"
            let dp = ["enforce path not on disk: ", plan[1]]
            detail = dp.join("")
        }
        else if tag == "MODE_PASS" {
            // Declarative-only rule (enforce = strict|nudge|…). No
            // subprocess, credited as PASS for the summary.
            verdict = "PASS"
            let mpd = ["mode=", plan[1], " (declarative, no enforcer)"]
            detail = mpd.join("")
        }
        else {
            // RUN — consume next batch result
            let br = batch_results[result_cursor]
            result_cursor = result_cursor + 1
            let rc = br[0]
            let tail = br[1]
            let f = _finish_rule(rule[1], plan[2], plan[3], rc, tail, fast)
            verdict = f[0]
            detail = f[1]
            // Post-enforce chain-verify hook (raw:self-host-fixpoint).
            //   verify_fixpoint.hexa probes one rebuild round; meta2_verify
            //   chain-verify audits the whole .meta2-cert/ chain. A broken
            //   chain must flip the verdict to FAIL even when the enforce
            //   passed — tamper evidence dominates single-point verification.
            //   Under --fast we still run it: chain-verify is read-only and
            //   cheap (O(#cert files)), and skipping would hide tamper.
            let slug_for_hook = keys_first(rule[3], "slug")
            if slug_for_hook == "self-host-fixpoint" {
                let cv = _run_chain_verify(verdict, detail)
                verdict = cv[0]
                detail = cv[1]
            }
            // P1d: persist PASS verdicts under current SSOT fingerprint so
            // subsequent --fast runs can skip this enforcer. Only real PASS
            // (from enforce); CACHED never reaches this branch.
            if verdict == "PASS" && ssot_fp != "" {
                let slug = keys_first(rule[3], "slug")
                if slug != "" { let _ = cache_write(slug, ssot_fp, "PASS") }
            }
        }

        if verdict == "PASS" { pass_ct = pass_ct + 1; enforce_ct = enforce_ct + 1 }
        else if verdict == "CACHED" { pass_ct = pass_ct + 1 }
        else if verdict == "FAIL" { fail_ct = fail_ct + 1; enforce_ct = enforce_ct + 1 }
        else if verdict == "PROOF_FAIL" { fail_ct = fail_ct + 1; enforce_ct = enforce_ct + 1 }
        else if verdict == "WARN" { warn_ct = warn_ct + 1 }
        else if verdict == "MISSING" { missing_ct = missing_ct + 1; enforce_ct = enforce_ct + 1 }
        else if verdict == "SKIPPED_DEP" { skip_ct = skip_ct + 1 }
        else { skip_ct = skip_ct + 1 }

        if json {
            // push/join — each rule produces ~12 concats otherwise.
            let entry_parts = ["{\"kind\":\"", kind,
                               "\",\"id\":\"", rule[0],
                               "\",\"status\":\"", rule[1],
                               "\",\"name\":\"", _json_escape(rule[2]),
                               "\",\"verdict\":\"", verdict,
                               "\",\"detail\":\"", _json_escape(detail),
                               "\"}"]
            json_entries.push(entry_parts.join(""))
        } else {
            println(_fmt_row(kind, rule, verdict, detail))
        }
        k = k + 1
    }

    return [pass_ct, fail_ct, warn_ct, skip_ct, json_entries, missing_ct, enforce_ct]
}

// ─── roadmap-ref gate (raw#15, 2026-04-20) ───────────────────────
//
// When --exclude or --fast is used, callers must supply --roadmap-ref
// <id>. The id is resolved against /.roadmap and the milestone's status
// must be "active" or "blocked" (i.e. legitimate in-flight or blocked
// work that justifies a temporary bypass). "done" rejects with FAIL
// (already finished — no bypass justification). "planned" / "deferred"
// WARN (not yet started — bypass is suspect but not fatal).
//
// We parse /.roadmap headers inline (rather than via self/raw_loader's
// load_raw_file) because that loader only recognises raw/own/chain
// kinds — teaching it "roadmap" kind touches a shared parser that
// another agent (P1-5) is editing. Header grammar is identical to the
// roadmap_lint.hexa parser (kept in sync by design):
//   `roadmap <id> <status> "<name>"`
//
// Returns [ok(bool), status(string), err_or_warn_line(string)]
//   ok=true  → gate passes. err_or_warn_line may contain a WARN note
//              for planned/deferred; caller prints but continues.
//   ok=false → gate refused. err_or_warn_line = user-visible error.
fn _roadmap_status_for_id(path: string, ref_id: string) -> string {
    // scan header lines of the form `roadmap <id> <status> "<name>"`.
    // returns status string or "" if not found.
    let src = to_string(read_file(path))
    let lines = split(src, "\n")
    for raw_line in lines {
        if len(raw_line) == 0 { continue }
        let first = raw_line.substring(0, 1)
        if first == " " || first == "\t" || first == "#" { continue }
        let sp1 = raw_line.index_of(" ")
        if sp1 < 0 { continue }
        if raw_line.substring(0, sp1) != "roadmap" { continue }
        let rest1 = raw_line.substring(sp1 + 1, len(raw_line))
        let sp2 = rest1.index_of(" ")
        if sp2 < 0 { continue }
        let id = rest1.substring(0, sp2)
        if id != ref_id { continue }
        let rest2 = rest1.substring(sp2 + 1, len(rest1))
        let sp3 = rest2.index_of(" ")
        if sp3 < 0 { continue }
        return rest2.substring(0, sp3)
    }
    return ""
}

fn _check_roadmap_ref(ref_id: string) -> array {
    if ref_id == "" {
        return [false, "", "[gate] --exclude / --fast 는 --roadmap-ref <id> 와 함께 사용 필수 (로드맵 근거 없음)"]
    }
    let roadmap_path = ".roadmap"
    if !file_exists(roadmap_path) {
        return [false, "", "[gate] /.roadmap 미존재 — --roadmap-ref 검증 불가"]
    }
    let found_status = _roadmap_status_for_id(roadmap_path, ref_id)
    if found_status == "" {
        return [false, "", "[gate] --roadmap-ref " + ref_id + " 가 /.roadmap 에 없음 (유효 milestone id 필요)"]
    }
    if found_status == "done" {
        return [false, found_status, "[gate] roadmap " + ref_id + " status=done — 이미 완료된 milestone 은 우회 근거 불가"]
    }
    if found_status == "active" || found_status == "blocked" {
        return [true, found_status, ""]
    }
    // planned / deferred → WARN (soft)
    return [true, found_status,
            "[gate] roadmap " + ref_id + " status=" + found_status +
            " — 아직 착수 전/유보된 milestone. 우회 근거로 약함 (WARN)"]
}

// ─── bypass audit (raw#15, 2026-04-20) ───────────────────────────
//
// Records a "bypass" event to .raw-audit when --exclude or --fast
// is used alongside a valid --roadmap-ref. The reason field packs
// slug list + roadmap_id + roadmap_status + fast flag so downstream
// audits retain the full justification without schema changes.
fn _audit_bypass(excludes: array, fast: bool, roadmap_ref: string,
                 roadmap_status: string, user_reason: string) {
    // format reason: "roadmap=<id>(<status>) fast=<bool> excludes=raw:a,raw:b reason=<user>"
    let mut ex_parts = []
    for ex in excludes {
        let ep = ["raw:", ex]
        ex_parts.push(ep.join(""))
    }
    let mut ex_str = "-"
    if len(ex_parts) > 0 { ex_str = ex_parts.join(",") }
    let mut fast_str = "false"
    if fast { fast_str = "true" }
    let mut ur = user_reason
    if ur == "" { ur = "raw_all bypass" }
    let reason_parts = ["roadmap=", roadmap_ref,
                        "(", roadmap_status, ")",
                        " fast=", fast_str,
                        " excludes=", ex_str,
                        " reason=", ur]
    let reason = reason_parts.join("")
    let sha = ssot_fingerprint()
    let mut actor = env("USER")
    if actor == "" { actor = to_string(exec("id -un")).trim() }
    let _ = audit_append("bypass", actor, reason, "ok", sha, "-")
}

// ─── main ────────────────────────────────────────────────────────

// ─── exemption pre-check (P1b) ───────────────────────────────────
//
// Invoke tool/raw_exemptions.hexa check — if interp reports any expired
// grandfather entry, the whole gate fails before any rule runs.
// Expiring-soon (≤7d) are surfaced as WARN but do NOT block.
// Returns [blocking_fail(bool), summary_line]
fn _exemption_precheck() -> array {
    let path = "tool/raw_exemptions.hexa"
    if !file_exists(path) { return [false, "exemptions: script missing (skipped)"] }
    if !file_exists("./build/hexa_interp") { return [false, "exemptions: interp unavailable (skipped)"] }
    let cmd_parts = ["HEXA_VAL_ARENA=0 ./build/hexa_interp ", path, " check 2>&1"]
    let r = exec_with_status(cmd_parts.join(""))
    let out = to_string(r[0]).trim()
    let rc = r[1]
    if rc == 0 { return [false, out] }
    return [true, out]
}

// ─── post-enforce chain-verify hook (raw:self-host-fixpoint) ────
//
// After the self-host-fixpoint enforce (verify_fixpoint.hexa) finishes,
// run tool/meta2_verify.hexa chain-verify to confirm the on-disk
// .meta2-cert/ chain isn't tampered with. If the chain is broken we
// mark this rule FAIL even when verify_fixpoint was OK.
//
// Rationale: chain tamper evidence > single-point verification.
// verify_fixpoint checks one rebuild round; chain-verify walks every
// recorded certificate in sort order and validates prev_cert_sha.
// A passing enforce with a broken chain means the on-disk history is
// inconsistent with the current attestation — the gate must refuse.
//
// Returns [verdict, detail]. verdict is one of PASS/FAIL/SKIP.
// SKIP when meta2_verify.hexa is not on disk (older trees) —
// treated as soft (no gate flip) since the wire is advisory in that case.
fn _run_chain_verify(prior_verdict: string, prior_detail: string) -> array {
    let path = "tool/meta2_verify.hexa"
    if !file_exists(path) {
        // meta2_verify not yet on this tree — leave prior verdict intact.
        return [prior_verdict, prior_detail]
    }
    let s0_chk = exec_with_status("test -x ./build/hexa_interp")
    if s0_chk[1] != 0 {
        return [prior_verdict, prior_detail]
    }
    let r = exec_with_status("./build/hexa_interp " + path + " chain-verify 2>&1")
    let out = to_string(r[0])
    let rc = r[1]
    let tail = _tail_of(out).trim()
    if rc == 0 {
        let mut det = prior_detail
        if det != "" { det = det + " | chain-verify: ok" }
        else { det = "chain-verify: ok" }
        return [prior_verdict, det]
    }
    // chain break → fold-in as FAIL regardless of prior verdict
    let msg = "chain-verify FAIL exit=" + to_string(rc) + " " + tail
    return ["FAIL", msg]
}

// ─── synthetic enforcer: own-inherit (P1c) ──────────────────────
//
// tool/own_inherit_lint.hexa enforces that nested .own files (under
// .claude/worktrees/*/.own) never weaken root /.own. It has no .raw/.own
// row — raw_all invokes it as a final composite check.
//
// Returns [verdict, detail_line].
//   verdict ∈ {"PASS","FAIL","MISSING","SKIP"}
// ─── synthetic enforcer: own-monotonic (raw#20 wire) ────────────
//
// tool/own_lint.hexa enforces that /.own monotonically strengthens /.raw
// (status never relaxed, scope never shrunk, enforce/proof never dropped).
// The companion rule row lives at /.raw raw#20 (slug=own-monotonic).
//
// When raw#20 is present in the loaded .raw rule set, the DSL dispatch
// loop already runs tool/own_lint.hexa via the rule's `enforce` field —
// this synthetic path is SKIPPED to avoid double-counting. When raw#20
// has not yet been added (e.g. an older tree, or this wire is landing
// ahead of the parallel agent's .raw edit), this synthetic path
// guarantees the lint still runs.
//
// Exit code is passed through directly (no proof/tail massage).
// Returns [verdict, detail_line].
//   verdict ∈ {"PASS","FAIL","MISSING","SKIP","SKIPPED_DEP"}
fn _run_own_lint(json: bool, own_monotonic_in_raw: bool) -> array {
    if own_monotonic_in_raw {
        return ["SKIPPED_DEP", "own-monotonic dispatched via .raw raw#20 row"]
    }
    let path = "tool/own_lint.hexa"
    if !file_exists(path) {
        return ["MISSING", "own_lint.hexa not on disk"]
    }
    let s0_chk = exec_with_status("test -x ./build/hexa_interp")
    if s0_chk[1] != 0 {
        return ["SKIP", "interp unavailable"]
    }
    let r = exec_with_status("HEXA_VAL_ARENA=0 ./build/hexa_interp " + path + " 2>&1")
    let out = to_string(r[0])
    let rc = r[1]
    let tail = _tail_of(out).trim()
    let lines = split(tail, "\n")
    let mut last = ""
    for l in lines {
        let t = l.trim()
        if t != "" { last = t }
    }
    if rc == 0 { return ["PASS", last] }
    return ["FAIL", "exit=" + to_string(rc) + " " + last]
}

// Scan loaded .raw rules for slug=own-monotonic presence.
// Used to suppress the synthetic _run_own_lint path when raw#20
// already owns the dispatch via its enforce field.
fn _raw_has_slug(path: string, slug: string) -> bool {
    if !file_exists(path) { return false }
    let rules = load_raw_file(path)
    let mut i = 0
    while i < len(rules) {
        let s = keys_first(rules[i][3], "slug")
        if s == slug { return true }
        i = i + 1
    }
    return false
}

fn _run_own_inherit(json: bool) -> array {
    let path = "tool/own_inherit_lint.hexa"
    if !file_exists(path) {
        return ["MISSING", "own_inherit_lint.hexa not on disk"]
    }
    if !file_exists("./build/hexa_interp") {
        return ["SKIP", "interp unavailable"]
    }
    // HEXA_VAL_ARENA=0: own_inherit_lint walks all nested .own; the
    // parent-walk pattern hits HexaVal arena OOM without this.
    let cmd_parts = ["HEXA_VAL_ARENA=0 ./build/hexa_interp ", path, " 2>&1"]
    let r = exec_with_status(cmd_parts.join(""))
    let out = to_string(r[0])
    let rc = r[1]
    let tail = _tail_of(out).trim()
    // Pull the final "✅ PASS …" / "🚫 FAIL …" line if present.
    let lines = split(tail, "\n")
    let mut last = ""
    for l in lines {
        let t = l.trim()
        if t != "" { last = t }
    }
    if rc == 0 { return ["PASS", last] }
    let fp = ["exit=", to_string(rc), " ", last]
    return ["FAIL", fp.join("")]
}

// ─── roadmap progress artifact (raw#15 companion) ─────────────────────
// Emits .raw-status/roadmap-status.json + one-line summary. Observational
// only — failures here never block raw_all pass/fail verdict.

fn _rs_isdigit(c: string) -> bool {
    return "0123456789".contains(c)
}

fn _rs_parse_int(s: string) -> int {
    let mut n = 0
    let mut i = 0
    let mut any = false
    let ns = len(s)
    while i < ns {
        let c = s.substring(i, i + 1)
        if _rs_isdigit(c) {
            n = n * 10 + (ord(c) - ord("0"))
            any = true
            i = i + 1
        } else { break }
    }
    if !any { return -1 }
    return n
}

// Scan JSON text for a track's overall.pct value. Returns -1 on miss.
// Pattern shape: `"<track>":{"overall":{"done":N,"total":M,"pct":P}`
fn _rs_pct(src: string, track: string) -> int {
    let key_parts = ["\"", track, "\":"]
    let key = key_parts.join("")
    let anchor = src.index_of(key)
    if anchor < 0 { return -1 }
    let rest = src.substring(anchor, len(src))
    let ov = rest.index_of("\"overall\":")
    if ov < 0 { return -1 }
    let rest2 = rest.substring(ov, len(rest))
    let pk = rest2.index_of("\"pct\":")
    if pk < 0 { return -1 }
    let after = rest2.substring(pk + 6, len(rest2))
    return _rs_parse_int(after)
}

fn _rs_done_total(src: string, track: string) -> array {
    let key_parts = ["\"", track, "\":"]
    let key = key_parts.join("")
    let anchor = src.index_of(key)
    if anchor < 0 { return [-1, -1] }
    let rest = src.substring(anchor, len(src))
    let ov = rest.index_of("\"overall\":")
    if ov < 0 { return [-1, -1] }
    let rest2 = rest.substring(ov, len(rest))
    let dk = rest2.index_of("\"done\":")
    if dk < 0 { return [-1, -1] }
    let da = rest2.substring(dk + 7, len(rest2))
    let done_v = _rs_parse_int(da)
    if done_v < 0 { return [-1, -1] }
    let tk = rest2.index_of("\"total\":")
    if tk < 0 { return [-1, -1] }
    let ta = rest2.substring(tk + 8, len(rest2))
    let tot_v = _rs_parse_int(ta)
    if tot_v < 0 { return [-1, -1] }
    return [done_v, tot_v]
}

fn _emit_roadmap_status(fast: bool, excludes: array) {
    if fast { return }
    for ex in excludes {
        if ex == "roadmap-ssot" { return }
    }
    if !file_exists("tool/roadmap_status.hexa") { return }
    // 2026-04-25 raw 44: ./hexa is wrapper — already inside a hexa run, use
    // bare dispatcher for sub-call to avoid resolver round-trip.
    let _hexa_bin = if file_exists("./build/hexa.real") { "./build/hexa.real" } else { "./hexa" }
    let r = exec_with_status(_hexa_bin + " tool/roadmap_status.hexa --json 2>/dev/null")
    let out = to_string(r[0]).trim()
    let rc = r[1]
    if rc != 0 || out == "" {
        println("roadmap: status unavailable")
        return
    }
    let mk = exec_with_status("mkdir -p .raw-status")
    let mk_rc = mk[1]
    if mk_rc != 0 {
        println("roadmap: artifact dir unwritable")
        return
    }
    write_file(".raw-status/roadmap-status.json", out)
    let fb = out.index_of("\"mode\":\"fallback\"")
    if fb >= 0 {
        let ov = out.index_of("\"overall\":")
        if ov < 0 {
            println("roadmap: fallback mode (unparseable summary)")
            return
        }
        let rest = out.substring(ov, len(out))
        let dk = rest.index_of("\"done\":")
        let tk = rest.index_of("\"total\":")
        if dk < 0 || tk < 0 {
            println("roadmap: fallback mode (unparseable summary)")
            return
        }
        let d2 = _rs_parse_int(rest.substring(dk + 7, len(rest)))
        let t2 = _rs_parse_int(rest.substring(tk + 8, len(rest)))
        if d2 < 0 || t2 < 0 {
            println("roadmap: fallback mode (unparseable summary)")
            return
        }
        let fp = ["roadmap: ", to_string(d2), "/", to_string(t2),
                  " (fallback — no checkpoints declared)"]
        println(fp.join(""))
        return
    }
    let p_ai = _rs_pct(out, "ai-native")
    let p_sh = _rs_pct(out, "self-host")
    let p_ss = _rs_pct(out, "ssot")
    let ai_dt = _rs_done_total(out, "ai-native")
    let sh_dt = _rs_done_total(out, "self-host")
    let ss_dt = _rs_done_total(out, "ssot")
    let mut all_pct = -1
    if ai_dt[0] >= 0 && sh_dt[0] >= 0 && ss_dt[0] >= 0 {
        let done_sum = ai_dt[0] + sh_dt[0] + ss_dt[0]
        let tot_sum = ai_dt[1] + sh_dt[1] + ss_dt[1]
        if tot_sum > 0 { all_pct = (done_sum * 100) / tot_sum }
        else { all_pct = 0 }
    }
    let mut all_s = "?"
    if all_pct >= 0 { all_s = to_string(all_pct) }
    let mut ai_s = "?"
    if p_ai >= 0 { ai_s = to_string(p_ai) }
    let mut sh_s = "?"
    if p_sh >= 0 { sh_s = to_string(p_sh) }
    let mut ss_s = "?"
    if p_ss >= 0 { ss_s = to_string(p_ss) }
    let line = ["roadmap: ALL ", all_s, "% | ai-native ", ai_s,
                "% | self-host ", sh_s, "% | ssot ", ss_s,
                "%  → .raw-status/roadmap-status.json"]
    println(line.join(""))
}

fn main() -> int {
    // --selftest dispatch (coverage batch; parse-only marker, no side effects)
    let _av_st = argv()
    if len(_av_st) > 2 {
        let _a2_st = _av_st[2]
        if _a2_st == "--selftest" || _a2_st == "selftest" {
            println("[raw_all selftest] OK")
            exit(0)
        }
    }
    let flags = _parse_flags()
    let fast = flags[0]
    let json = flags[1]
    let only_kind = flags[2]
    let only_id = flags[3]
    let serial = flags[4]
    let excludes = flags[5]
    let roadmap_ref = flags[6]
    let par_n = _parallel_n(serial)

    // raw#15 (2026-04-20): --exclude or --fast require --roadmap-ref.
    // The roadmap id must resolve in /.roadmap with status ∈
    // {active, blocked}. done → FAIL. planned/deferred → WARN (soft).
    let bypass_used = (len(excludes) > 0) || fast
    let mut roadmap_status = ""
    if bypass_used {
        let chk = _check_roadmap_ref(roadmap_ref)
        let ok = chk[0]
        let st = chk[1]
        let line = chk[2]
        if !ok {
            eprintln(line)
            eprintln("usage: --exclude raw:<slug> 또는 --fast 사용 시 --roadmap-ref <id> 필수")
            eprintln("       예: ./hexa tool/raw_all.hexa --fast --roadmap-ref 9")
            return 2
        }
        roadmap_status = st
        if line != "" {
            // WARN (planned/deferred) — print but continue.
            if !json { eprintln(line) }
        }
        // Record bypass to audit before any enforcer runs.
        _audit_bypass(excludes, fast, roadmap_ref, roadmap_status, "")
    }

    // P7a: prepare tmp dir for parallel batch output.
    _tmp_init()

    // P1d: compute SSOT fingerprint exactly ONCE (it spawns a shell).
    //   Only consulted under --fast — full runs always re-enforce every
    //   rule so there is no correctness surface for the cache. We still
    //   record the fingerprint after a non-fast PASS so a follow-up
    //   --fast run sees fresh entries.
    let mut ssot_fp = ""
    ssot_fp = ssot_fingerprint()

    if !json {
        println("── raw#0 unified enforcement (raw_all) ──")
        if fast { println("mode: fast (proof scripts skipped)") }
        if par_n > 1 {
            let mp = ["mode: parallel N=", to_string(par_n)]
            println(mp.join(""))
        } else { println("mode: serial") }
        if only_kind != "" {
            let mut suffix = "*"
            if only_id != "" {
                let sp = ["#", only_id]
                suffix = sp.join("")
            }
            let fp = ["filter: ", only_kind, suffix]
            println(fp.join(""))
        }
        if len(excludes) > 0 {
            let mut ex_parts = []
            for ex in excludes {
                let ep = ["raw:", ex]
                ex_parts.push(ep.join(""))
            }
            let exl = ["excluded: ", ex_parts.join(", ")]
            println(exl.join(""))
        }
        if bypass_used && roadmap_ref != "" {
            let rr = ["roadmap-ref: ", roadmap_ref, " (status=", roadmap_status, ")"]
            println(rr.join(""))
        }
        println("")
    }

    // P1b: exemption pre-check — expired entries short-circuit the gate.
    let exempt_r = _exemption_precheck()
    let exempt_fail = exempt_r[0]
    let exempt_summary = exempt_r[1]
    if !json {
        println(exempt_summary)
        println("")
    }

    let mut json_all = []
    let mut total_pass = 0
    let mut total_fail = 0
    let mut total_warn = 0
    let mut total_skip = 0
    let mut total_missing = 0
    let mut total_enforce = 0

    // Walk .raw (L0)
    let r_raw = _walk_kind("raw", ".raw", fast, only_kind, only_id, json, par_n, ssot_fp, excludes)
    total_pass = total_pass + r_raw[0]
    total_fail = total_fail + r_raw[1]
    total_warn = total_warn + r_raw[2]
    total_skip = total_skip + r_raw[3]
    for e in r_raw[4] { json_all.push(e) }
    total_missing = total_missing + r_raw[5]
    total_enforce = total_enforce + r_raw[6]

    // Walk .own (L1)
    let r_own = _walk_kind("own", ".own", fast, only_kind, only_id, json, par_n, ssot_fp, excludes)
    total_pass = total_pass + r_own[0]
    total_fail = total_fail + r_own[1]
    total_warn = total_warn + r_own[2]
    total_skip = total_skip + r_own[3]
    for e in r_own[4] { json_all.push(e) }
    total_missing = total_missing + r_own[5]
    total_enforce = total_enforce + r_own[6]

    // Synthetic enforcer: own_inherit_lint (P1c, 2026-04-20).
    //   raw_all treats /.own ⊂ nested /.own monotonic-inheritance as a
    //   composite rule with no .raw/.own row of its own. It runs after the
    //   declared enforcers and contributes to pass/fail counts + the
    //   "N/M enforcers PASS" summary but is excluded from the per-file tables.
    //   Honors --only filter: skipped when only_kind is set and not "own-inherit".
    let syn_run = (only_kind == "" || only_kind == "own-inherit")
    if syn_run {
        let syn = _run_own_inherit(json)
        let syn_verdict = syn[0]
        let syn_detail = syn[1]
        if syn_verdict == "PASS" { total_pass = total_pass + 1; total_enforce = total_enforce + 1 }
        else if syn_verdict == "FAIL" { total_fail = total_fail + 1; total_enforce = total_enforce + 1 }
        else if syn_verdict == "MISSING" { total_missing = total_missing + 1; total_enforce = total_enforce + 1 }
        else if syn_verdict == "SKIP" { total_skip = total_skip + 1 }
        else { total_warn = total_warn + 1 }
        if json {
            let entry_parts = ["{\"kind\":\"synthetic\"",
                               ",\"id\":\"own-inherit\"",
                               ",\"status\":\"live\"",
                               ",\"name\":\"own inheritance monotonicity\"",
                               ",\"verdict\":\"", syn_verdict,
                               "\",\"detail\":\"", _json_escape(syn_detail), "\"}"]
            json_all.push(entry_parts.join(""))
        } else {
            let head = "  [synthetic own-inherit live]"
            let pad = 22 - len(head)
            let mut p_parts = []
            let mut i = 0
            while i < pad { p_parts.push(" "); i = i + 1 }
            let p = p_parts.join("")
            let vpad = 7 - len(syn_verdict)
            let mut vp_parts = []
            i = 0
            while i < vpad { vp_parts.push(" "); i = i + 1 }
            let vp = vp_parts.join("")
            let syn_parts = [head, p, syn_verdict, vp, " ", syn_detail]
            println(syn_parts.join(""))
        }
    }

    // Synthetic enforcer: own_lint (raw#20 own-monotonic wire, 2026-04-20).
    //   tool/own_lint.hexa validates that /.own rows monotonically
    //   strengthen their /.raw counterparts. raw#20 (slug=own-monotonic)
    //   dispatches this tool via its `enforce` field, so when the rule
    //   is present in /.raw the synthetic path is SKIPPED_DEP to avoid
    //   double-counting. When raw#20 is absent (older tree, or landing
    //   ahead of the .raw edit), this synthetic guarantees the lint runs.
    //   Honors --only: skipped when only_kind is set and not "own-monotonic".
    let own_syn_run = (only_kind == "" || only_kind == "own-monotonic"
                       || (only_kind == "raw" && only_id == "20"))
    if own_syn_run {
        let own_in_raw = _raw_has_slug(".raw", "own-monotonic")
        let syno = _run_own_lint(json, own_in_raw)
        let syno_verdict = syno[0]
        let syno_detail = syno[1]
        if syno_verdict == "PASS" { total_pass = total_pass + 1; total_enforce = total_enforce + 1 }
        else if syno_verdict == "FAIL" { total_fail = total_fail + 1; total_enforce = total_enforce + 1 }
        else if syno_verdict == "MISSING" { total_missing = total_missing + 1; total_enforce = total_enforce + 1 }
        else if syno_verdict == "SKIP" { total_skip = total_skip + 1 }
        else if syno_verdict == "SKIPPED_DEP" { total_skip = total_skip + 1 }
        else { total_warn = total_warn + 1 }
        if json {
            let entry = "{\"kind\":\"synthetic\"" +
                        ",\"id\":\"own-monotonic\"" +
                        ",\"status\":\"live\"" +
                        ",\"name\":\"own monotonic strengthening over .raw\"" +
                        ",\"verdict\":\"" + syno_verdict +
                        "\",\"detail\":\"" + _json_escape(syno_detail) + "\"}"
            json_all.push(entry)
        } else {
            let head = "  [synthetic own-monotonic live]"
            let pad = 22 - len(head)
            let mut p = ""
            let mut i = 0
            while i < pad { p = p + " "; i = i + 1 }
            let vpad = 7 - len(syno_verdict)
            let mut vp = ""
            i = 0
            while i < vpad { vp = vp + " "; i = i + 1 }
            println(head + p + syno_verdict + vp + " " + syno_detail)
        }
    }

    let gate_fail = (total_fail > 0) || exempt_fail

    if json {
        // push/join — avoids O(n²) concat across json_all entries.
        let mut body_parts = []
        for e in json_all { body_parts.push(e) }
        let body = body_parts.join(",")
        let mut verdict_str = "PASS"
        if gate_fail { verdict_str = "FAIL" }
        let mut exempt_json = "false"
        if exempt_fail { exempt_json = "true" }
        let top_parts = ["{\"verdict\":\"", verdict_str,
                         "\",\"pass\":", to_string(total_pass),
                         ",\"fail\":", to_string(total_fail),
                         ",\"warn\":", to_string(total_warn),
                         ",\"skip\":", to_string(total_skip),
                         ",\"missing\":", to_string(total_missing),
                         ",\"enforcers_total\":", to_string(total_enforce),
                         ",\"exempt_expired\":", exempt_json,
                         ",\"rules\":[", body, "]}"]
        println(top_parts.join(""))
    } else {
        println("")
        let sum_parts = ["summary: pass=", to_string(total_pass),
                         " fail=", to_string(total_fail),
                         " warn=", to_string(total_warn),
                         " skip=", to_string(total_skip),
                         " missing=", to_string(total_missing)]
        println(sum_parts.join(""))
        let enf_parts = ["enforcers: ", to_string(total_pass),
                         "/", to_string(total_enforce), " PASS"]
        println(enf_parts.join(""))
        if exempt_fail {
            println("verdict: FAIL — expired exemption blocks gate")
        } else if total_fail == 0 {
            println("verdict: PASS — unlock gate would accept")
        } else {
            println("verdict: FAIL — unlock gate would refuse")
        }
        // raw#15: emit observational roadmap progress artifact + summary
        // line. Skipped under --fast or --exclude raw:roadmap-ssot; never
        // affects gate verdict.
        _emit_roadmap_status(fast, excludes)
    }

    // P1d: record the SSOT fingerprint for `raw_cache status` display.
    //   Only on full PASS — a failing run should not advertise a fresh
    //   cache state. Writes .raw-cache/ssot.sha.
    if !gate_fail && ssot_fp != "" {
        let _ = cache_record_fingerprint(ssot_fp)
    }

    if gate_fail { return 1 }
    return 0
}

exit(main())
