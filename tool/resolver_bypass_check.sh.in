# resolver_bypass_check.sh.in — SSOT for the Mac->Docker bypass marker scan
#
# WHY THIS FILE EXISTS
#   Two consumers used to carry their own copy of this logic and silently
#   diverged (FIX-5, commit 36a4a842). Now both source THIS file:
#
#     1. ~/.hx/bin/hexa::_darwin_bypass_check     (installed resolver)
#     2. tool/install_interp_shim.hexa            (embedded into the
#        build/hexa_interp shim at install time via iss_fallback_shim_content)
#
#   tool/lint_resolver_bypass.hexa diffs this SSOT against both consumers
#   and fails if either drifts.
#
# CONTRACT
#   Defines exactly one shell function: _hexa_bypass_marker_present "$@"
#   Returns 0 when the leading *.hexa argv has a bypass marker in its
#   first 100 lines, 1 otherwise. No side effects (just `head`+`grep`).
#
#   Callers wrap this with their own platform / env-var gating
#   (Darwin-only, HEXA_RESOLVER_NO_DARWIN_BYPASS, HEXA_SHIM_NO_DARWIN_LANDING,
#   etc.). This SSOT only owns the marker-scan, not the routing decision.
#
# WHEN YOU EDIT THIS FILE
#   * Re-run: hexa tool/install_interp_shim.hexa  (regenerates the shim)
#   * Re-run: hexa tool/lint_resolver_bypass.hexa (verifies ~/.hx/bin/hexa)
#   * If ~/.hx/bin/hexa is out of sync, the lint will tell you.

_hexa_bypass_marker_present() {
  for arg in "$@"; do
    case "$arg" in
      *.hexa)
        [ -f "$arg" ] || continue
        # Header zone (first 100 lines) — markers live in the comment block.
        # Read once to avoid 4x head invocations.
        local _hd
        _hd="$(head -n 100 "$arg" 2>/dev/null)"
        # Existing: explicit @resolver-bypass marker (highest signal).
        if printf '%s' "$_hd" | grep -qE '@resolver-bypass\('; then
          return 0
        fi
        # raw#84 (2026-04-27): @resolver-pure marker for non-mutating tools
        # — pure text->struct extraction, no host syscalls/fs writes. Same
        # bypass tier as @resolver-bypass; separate name documents intent.
        if printf '%s' "$_hd" | grep -qE '@resolver-pure\('; then
          return 0
        fi
        # Existing: darwin-native keywords inside @omega-saturation-exempt.
        if printf '%s' "$_hd" | grep -qE '@omega-saturation-exempt\([^)]*(chflags|launchctl|sandbox-exec|DYLD|SBPL|plutil|codesign)'; then
          return 0
        fi
        # raw#84 (2026-04-27): operational-utility carve-out. Tools that
        # advertise pure-parse / single-pass / read-only / operational-
        # utility semantics don't need Linux container semantics either.
        if printf '%s' "$_hd" | grep -qE '@omega-saturation-exempt\([^)]*(operational utility|pure[- ]text|single-pass|pure parse|read-only)'; then
          return 0
        fi
        return 1
        ;;
    esac
  done
  return 1
}
