// tool/hx_continuous_scan.hexa — Phase 5 continuous scan orchestrator (real-v1).
//
// SPEC: docs/hexa_lang_meta_evolution_proposal_20260422.md §Phase 5.
// STATUS: v1 real — sequential dispatch of real-v1 scanners with
//         runtime measurement + telemetry record + summary rollup.
//         Skips scanners that are still stubs (listed in SKIP set).
//         Slack notify on health-score change deferred to v2.
//
// CLI
//   hexa tool/hx_continuous_scan.hexa --selftest
//   hexa tool/hx_continuous_scan.hexa [--dry-run] [--history] [--out <path>]
//
// OUTPUT
//   $HEXA_LANG/state/hx_continuous_scan_<iso>.json
//   $HEXA_LANG/state/history/<date>/  (copies of each scanner's state
//                                       json when --history)
//   schema = "hexa-lang/hx_continuous_scan/1"

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _iso_now() -> string {
    return to_string(exec("date -u +'%Y-%m-%dT%H:%M:%SZ'")).trim()
}

fn _iso_compact() -> string {
    return to_string(exec("date -u +'%Y%m%dT%H%M%SZ'")).trim()
}

fn _iso_date() -> string {
    return to_string(exec("date -u +'%Y-%m-%d'")).trim()
}

fn _epoch_ms() -> int {
    // GNU date has %N, macOS doesn't; use python3 as fallback for sub-second.
    // Both hosts have python3 per CLAUDE conventions.
    return _atoi(to_string(exec("python3 -c 'import time;print(int(time.time()*1000))'")).trim())
}

fn _arg_value(args: array, key: string, default: string) -> string {
    let mut i = 0
    while i < len(args) {
        if args[i] == key {
            let j = i + 1
            if j < len(args) { return args[j] }
        }
        i = i + 1
    }
    return default
}

fn _has_flag(args: array, key: string) -> bool {
    let mut i = 0
    while i < len(args) {
        if args[i] == key { return true }
        i = i + 1
    }
    return false
}

fn _atoi(s: string) -> int {
    if s == "" { return 0 }
    return s.parse_int()
}

fn _sh_q(s: string) -> string {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _json_esc(s: string) -> string {
    let mut r = s.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", "\\n")
    r = r.replace("\r", "")
    r = r.replace("\t", " ")
    return r
}

fn _root() -> string {
    return _home() + "/core/hexa-lang"
}

fn _hexa_bin() -> string {
    return _root() + "/hexa"
}

fn _exists(path: string) -> bool {
    return to_string(exec("test -f " + _sh_q(path) + " && echo y || echo n")).trim() == "y"
}

fn _file_size(path: string) -> int {
    if !_exists(path) { return 0 }
    return _atoi(to_string(exec("stat -f %z " + _sh_q(path) + " 2>/dev/null")).trim())
}

fn _selftest() -> int {
    if len(_iso_now()) < 10 { eprintln("hx_continuous_scan: selftest FAIL (iso)"); return 1 }
    if _atoi("123") != 123 { eprintln("hx_continuous_scan: selftest FAIL (atoi)"); return 1 }
    let q = _sh_q("x'y")
    if q != "'x'\\''y'" { eprintln("hx_continuous_scan: selftest FAIL (sh_q)"); return 1 }
    println("hx_continuous_scan: selftest PASS")
    return 0
}

// Each tuple: [tool_stem, phase_label, out_filename (relative to state/)]
fn _scanner_table() -> array {
    return [
        ["hx_blocker_scan",       "1",   "hx_blockers.json"],
        ["hx_loss_free_roi_scan", "2",   "hx_loss_free_roi.json"],
        ["hx_stage_health",       "3.1", "hx_stage_health.json"],
        ["hx_stdlib_promote",     "3.2", "hx_stdlib_promote.json"],
        ["hx_bench_drift",        "3.3", "hx_bench_drift.json"],
        ["hx_coverage_scan",      "3.4", "hx_coverage.json"],
        ["hx_api_drift",          "3.5", "hx_api_drift.json"],
        ["hx_raw_coverage",       "3.6", "hx_raw_coverage.json"],
        ["hx_cert_chain",         "3.7", "hx_cert_chain.json"],
        ["hx_aot_stale",          "3.8", "hx_aot_stale.json"],
        ["hx_tool_graph",         "3.9", "hx_tool_graph.json"],
        ["hx_pattern_mine",       "3.10","hx_pattern_mine.json"],
        ["hx_meta_gap_proposer",  "6.2", "hx_meta_gap.json"]
    ]
}

fn main() {
    let av = argv()
    let mut args = []
    let mut i = 2
    while i < len(av) { args.push(av[i]); i = i + 1 }

    if len(args) >= 1 && args[0] == "--selftest" { exit(_selftest()) }

    let dry = _has_flag(args, "--dry-run")
    let history = _has_flag(args, "--history")
    let ts = _iso_now()
    let ts_compact = _iso_compact()
    let default_out = _root() + "/state/hx_continuous_scan_" + ts_compact + ".json"
    let out_path = _arg_value(args, "--out", default_out)

    let table = _scanner_table()
    let hb = _hexa_bin()
    let state_dir = _root() + "/state"
    let tel_tool = _root() + "/tool/hx_meta_telemetry.hexa"

    // Prepare history archive directory if requested.
    let hist_dir = state_dir + "/history/" + _iso_date() + "_" + ts_compact
    if history && !dry {
        let _unused = exec("mkdir -p " + _sh_q(hist_dir))
    }

    let mut results_json = []
    let mut total_runtime = 0
    let mut ran = 0
    let mut failed = 0

    let mut k = 0
    while k < len(table) {
        let row = table[k]
        let stem = row[0]
        let phase = row[1]
        let out_name = row[2]
        let tool_path = _root() + "/tool/" + stem + ".hexa"

        if !_exists(tool_path) {
            let skip = "{\"scanner\":\"" + _json_esc(stem)
                + "\",\"phase\":\"" + _json_esc(phase)
                + "\",\"status\":\"missing_source\"}"
            results_json.push(skip)
            k = k + 1
            continue
        }

        if dry {
            let d = "{\"scanner\":\"" + _json_esc(stem)
                + "\",\"phase\":\"" + _json_esc(phase)
                + "\",\"status\":\"dry_run\"}"
            results_json.push(d)
            k = k + 1
            continue
        }

        let out_json = state_dir + "/" + out_name
        let start_ms = _epoch_ms()
        let cmd = _sh_q(hb) + " " + _sh_q(tool_path) + " --out " + _sh_q(out_json) + " 2>&1"
        let r = exec_with_status(cmd)
        let end_ms = _epoch_ms()
        let rt_ms = end_ms - start_ms
        let rc = r[1]
        total_runtime = total_runtime + rt_ms
        ran = ran + 1
        if rc != 0 { failed = failed + 1 }

        let size = _file_size(out_json)

        // Telemetry record
        let _tel = exec_with_status(
            _sh_q(hb) + " " + _sh_q(tel_tool) + " record"
            + " --scanner " + _sh_q(stem)
            + " --runtime-ms " + to_string(rt_ms)
            + " --candidates 0"
            + " --rc " + to_string(rc)
            + " --out-size " + to_string(size)
            + " >/dev/null 2>&1"
        )

        // History archive copy
        if history && _exists(out_json) {
            let _cp = exec("cp " + _sh_q(out_json) + " " + _sh_q(hist_dir + "/" + out_name))
        }

        let entry = "{\"scanner\":\"" + _json_esc(stem)
            + "\",\"phase\":\"" + _json_esc(phase)
            + "\",\"rc\":" + to_string(rc)
            + ",\"runtime_ms\":" + to_string(rt_ms)
            + ",\"out_size\":" + to_string(size)
            + ",\"out_path\":\"state/" + _json_esc(out_name) + "\"}"
        results_json.push(entry)
        k = k + 1
    }

    let mut body = "{\n  \"schema\": \"hexa-lang/hx_continuous_scan/1\",\n"
    body = body + "  \"ts\": \"" + ts + "\",\n"
    body = body + "  \"status\": \"real-v1\",\n"
    body = body + "  \"dry_run\": " + (if dry { "true" } else { "false" }) + ",\n"
    body = body + "  \"history_archive\": " + (if history { "true" } else { "false" }) + ",\n"
    if history && !dry {
        body = body + "  \"history_dir\": \"" + _json_esc(hist_dir.replace(_home(), "~")) + "\",\n"
    }
    body = body + "  \"results\": [\n"
    let mut first = true
    for r in results_json {
        if !first { body = body + ",\n" }
        body = body + "    " + r
        first = false
    }
    body = body + "\n  ],\n"
    body = body + "  \"summary\": {\"scanners_ran\": " + to_string(ran)
    body = body + ", \"failed\": " + to_string(failed)
    body = body + ", \"total_runtime_ms\": " + to_string(total_runtime) + "}\n}\n"

    try { write_file(out_path, body) } catch e {
        eprintln("hx_continuous_scan: write FAIL " + out_path)
        exit(1)
    }

    println("hx_continuous_scan: ran=" + to_string(ran) + "/" + to_string(len(table))
          + " failed=" + to_string(failed)
          + " total_runtime=" + to_string(total_runtime) + "ms")
    println("hx_continuous_scan: wrote " + out_path)
    if failed > 0 { exit(1) }
    exit(0)
}
