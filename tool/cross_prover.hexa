// tool/cross_prover.hexa — cross-prover diagonal (nexus ↔ anima)
//
// PURPOSE
//   Circular-trap avoidance. A single prover can always accept its own
//   verdict; the cross-prover diagonal demands that TWO independent
//   provers — nexus (discovery / blowup side) and anima (consciousness
//   side) — each produce a PASS on the same claim, and that their
//   outputs agree structurally. Only when agreement ≥ 0.85 do we emit
//   verdict=PASS; any one-sided PASS degrades to UNCERTAIN.
//
// PROVER PATHS (literal; pre-checked before invocation)
//   nexus prover : /Users/ghost/core/nexus/tool/fixpoint_v3.hexa
//   anima prover : /Users/ghost/core/anima/tool/meta2_verify.hexa
//
//   If either is missing → FAIL early with explicit path. No speculative
//   fallback. No LLM. deterministic.
//
// CLI
//   ./hexa tool/cross_prover.hexa \
//       --dest <dest> --round r<N> \
//       --claim "<claim text>" \
//       --artifact <path>
//
// OUTPUT
//   shared/state/<dest>_r<N>_cross_prover.json
//   {
//     "dest":"…","round":"r…","ts":"…",
//     "claim":"…","artifact":"…",
//     "prover_a":{"id":"nexus","path":"…","exit":0,"sha":"…","tokens":N},
//     "prover_b":{"id":"anima","path":"…","exit":0,"sha":"…","tokens":N},
//     "agreement":0.93,
//     "hash_match":true,
//     "jaccard":0.87,
//     "verdict":"PASS"
//   }
//
// EXITS
//   0  PASS   — both provers succeeded and agreement ≥ 0.85
//   1  FAIL   — one/both provers exited non-zero OR agreement < 0.85
//   2  ERROR  — missing prover / bad CLI / IO
//
// CONSTRAINTS (raw:self-host-path, raw:11, raw:12)
//   - Pure hexa, parseable by ./build/hexa_stage0 (seed frozen).
//   - No `<<` / `>>`. No `c >= "0"` range-compare.
//   - No LLM / no network / deterministic.
//   - V8 SAFE_COMMIT: this file + manifest entries land in one commit.

// ─── helpers ────────────────────────────────────────────────────

fn _shell_quote(s) {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _iso_utc_now() {
    return exec("date -u +\"%Y-%m-%dT%H:%M:%SZ\"").trim()
}

fn _sha256_of_str(s) {
    // deterministic hash of stdout blob via shasum -a 256 on stdin.
    // stage0-safe: no heredoc, quoted printf %s body, fallback to sha256sum.
    let q = _shell_quote(s)
    let r = exec_with_status("printf %s " + q + " | shasum -a 256 2>/dev/null | cut -d' ' -f1")
    let out = r[0].trim()
    if r[1] == 0 && out != "" { return out }
    let r2 = exec_with_status("printf %s " + q + " | sha256sum 2>/dev/null | cut -d' ' -f1")
    return r2[0].trim()
}

fn _path_exists(path) {
    let r = exec_with_status("test -e " + _shell_quote(path))
    return r[1] == 0
}

fn _ensure_dir(path) {
    let r = exec_with_status("mkdir -p " + _shell_quote(path))
    return r[1] == 0
}

// ─── output normalization + tokenization ────────────────────────
//
// Goal: strip noise that differs across provers but does not change
// the semantic verdict. Normalization is idempotent + deterministic:
//   1. lowercase
//   2. drop blank lines
//   3. drop lines starting with "[" (progress/log prefixes)
//   4. drop ISO-8601 timestamp substrings (YYYY-MM-DDTHH:MM:SSZ-ish)
//   5. collapse runs of whitespace

fn _is_digit(c) { return "0123456789".contains(c) }

fn _looks_like_ts_token(tok) {
    // crude: a token is considered a timestamp if it has digit:digit:digit or
    // digit-digit-digit patterns (covers "12:34:56" and "2026-04-21T...Z").
    let n = len(tok)
    if n < 8 { return false }
    let mut i = 0
    let mut dig_runs = 0
    let mut sep_count = 0
    while i < n {
        let c = tok.substring(i, i + 1)
        if _is_digit(c) {
            dig_runs = dig_runs + 1
        } else if c == ":" || c == "-" || c == "T" || c == "Z" {
            sep_count = sep_count + 1
        } else {
            return false
        }
        i = i + 1
    }
    return dig_runs >= 4 && sep_count >= 2
}

fn _normalize(blob) {
    let lower = blob.to_lower()
    let lines = lower.split("\n")
    let mut keep = []
    let mut li = 0
    while li < len(lines) {
        let raw = lines[li].trim()
        li = li + 1
        if raw == "" { continue }
        let first = raw.substring(0, 1)
        if first == "[" { continue }
        // strip timestamp tokens
        let toks = raw.split(" ")
        let mut clean = []
        let mut ti = 0
        while ti < len(toks) {
            let t = toks[ti].trim()
            ti = ti + 1
            if t == "" { continue }
            if _looks_like_ts_token(t) { continue }
            clean.push(t)
        }
        if len(clean) > 0 { keep.push(clean.join(" ")) }
    }
    return keep.join("\n")
}

fn _tokens(norm) {
    // token = whitespace-separated word from the normalized blob
    let mut out = []
    let raw_toks = norm.replace("\n", " ").split(" ")
    let mut i = 0
    while i < len(raw_toks) {
        let t = raw_toks[i].trim()
        i = i + 1
        if t != "" { out.push(t) }
    }
    return out
}

fn _contains(arr, x) {
    let mut i = 0
    while i < len(arr) {
        if arr[i] == x { return true }
        i = i + 1
    }
    return false
}

// Jaccard similarity on multiset-as-set (deduplicated token universes).
fn _jaccard(toks_a, toks_b) {
    let mut uniq_a = []
    let mut i = 0
    while i < len(toks_a) {
        if !_contains(uniq_a, toks_a[i]) { uniq_a.push(toks_a[i]) }
        i = i + 1
    }
    let mut uniq_b = []
    i = 0
    while i < len(toks_b) {
        if !_contains(uniq_b, toks_b[i]) { uniq_b.push(toks_b[i]) }
        i = i + 1
    }
    if len(uniq_a) == 0 && len(uniq_b) == 0 { return 1.0 }
    let mut inter = 0
    i = 0
    while i < len(uniq_a) {
        if _contains(uniq_b, uniq_a[i]) { inter = inter + 1 }
        i = i + 1
    }
    let mut union = len(uniq_a)
    i = 0
    while i < len(uniq_b) {
        if !_contains(uniq_a, uniq_b[i]) { union = union + 1 }
        i = i + 1
    }
    if union == 0 { return 0.0 }
    return (inter + 0.0) / (union + 0.0)
}

// Agreement = 0.5 * hash_match + 0.5 * jaccard
// (hash_match = 1.0 if identical normalized blob, else 0.0).
fn _agreement(hash_match, jaccard) {
    let mut h = 0.0
    if hash_match { h = 1.0 }
    return 0.5 * h + 0.5 * jaccard
}

// ─── JSON emitter ───────────────────────────────────────────────

fn _json_esc(s) {
    // parts.push() + .join() to avoid O(n²) concat (perf raw_all).
    let mut parts = []
    let n = len(s)
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "\"" { parts.push("\\\"") }
        else if c == "\\" { parts.push("\\\\") }
        else if c == "\n" { parts.push("\\n") }
        else if c == "\t" { parts.push("\\t") }
        else if c == "\r" { parts.push("\\r") }
        else { parts.push(c) }
        i = i + 1
    }
    return parts.join("")
}

fn _fmt_float(f) {
    // 2-decimal deterministic format via awk (stage0 has no %.2f builtin).
    let r = exec_with_status("awk 'BEGIN{printf \"%.4f\", " + str(f) + "}'")
    let v = r[0].trim()
    if v == "" { return str(f) }
    return v
}

// ─── prover invocation ──────────────────────────────────────────

fn _run_prover(prover_path, claim, artifact) {
    // Returns [exit:int, stdout:string].
    // Stage0-safe: single exec_with_status, redirect stderr to stdout so
    // agreement calc covers both streams. HEXA_VAL_ARENA=0 + HEXA_NO_LAUNCHD=1
    // per raw:1 os-lock convention.
    let log = "/tmp/cross_prover_" + str(exec("date +%s%N").trim()) + ".log"
    let cmd = "HEXA_VAL_ARENA=0 HEXA_NO_LAUNCHD=1 "
        + "./build/hexa_stage0 " + _shell_quote(prover_path) + " "
        + _shell_quote(claim) + " " + _shell_quote(artifact)
        + " > " + log + " 2>&1"
    let r = exec_with_status(cmd)
    let blob = ""
    if _path_exists(log) {
        let rr = exec_with_status("cat " + log)
        if rr[1] == 0 { return [r[1], rr[0]] }
    }
    return [r[1], blob]
}

// ─── CLI parsing ────────────────────────────────────────────────

fn _usage() {
    eprintln("usage: hexa tool/cross_prover.hexa --dest <dest> --round r<N> \\")
    eprintln("           --claim <text> --artifact <path>")
    eprintln("")
    eprintln("  --dest      destination tag (e.g. alm, clm)")
    eprintln("  --round     round label (e.g. r12)")
    eprintln("  --claim     claim text to verify (passed to each prover as arg 1)")
    eprintln("  --artifact  artifact path (passed to each prover as arg 2)")
    eprintln("")
    eprintln("exits: 0 PASS  1 FAIL  2 ERROR")
}

fn cmd_selftest() -> i64 {
    println("[cross_prover selftest]")
    // pure-fn assertions against jaccard + agreement math
    let a = ["x", "y", "z"]
    let b = ["x", "y", "z"]
    let j = _jaccard(a, b)
    if j < 0.999 { eprintln("FAIL jaccard identity"); return 1 }
    let c = ["x", "y"]
    let d = ["y", "z"]
    let j2 = _jaccard(c, d)
    // |inter|=1, |union|=3 → 0.333...
    if j2 < 0.3 || j2 > 0.4 { eprintln("FAIL jaccard partial"); return 1 }
    let ag = _agreement(true, 1.0)
    if ag < 0.999 { eprintln("FAIL agreement full"); return 1 }
    println("[cross_prover selftest] OK")
    return 0
}

fn main() {
    let _av_st = args()
    if _av_st.len() > 2 && (_av_st[2] == "--selftest" || _av_st[2] == "selftest") { exit(cmd_selftest()) }
    let av = argv()
    let mut dest = ""
    let mut round = ""
    let mut claim = ""
    let mut artifact = ""

    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--dest" && i + 1 < len(av) { dest = av[i + 1]; i = i + 2; continue }
        if a == "--round" && i + 1 < len(av) { round = av[i + 1]; i = i + 2; continue }
        if a == "--claim" && i + 1 < len(av) { claim = av[i + 1]; i = i + 2; continue }
        if a == "--artifact" && i + 1 < len(av) { artifact = av[i + 1]; i = i + 2; continue }
        if a == "-h" || a == "--help" { _usage(); exit(2) }
        eprintln("[cross-prover] unknown arg: " + a)
        _usage()
        exit(2)
    }

    if dest == "" || round == "" || claim == "" || artifact == "" {
        eprintln("[cross-prover] missing required arg (--dest --round --claim --artifact all required)")
        _usage()
        exit(2)
    }

    // ─── pre-check: both provers + stage0 wrapper must exist ─────
    let nexus_prover = "/Users/ghost/core/nexus/tool/fixpoint_v3.hexa"
    let anima_prover = "/Users/ghost/core/anima/tool/meta2_verify.hexa"
    let stage0 = "build/hexa_stage0"

    let mut missing = []
    if !_path_exists(stage0) { missing.push("stage0:" + stage0) }
    if !_path_exists(nexus_prover) { missing.push("nexus:" + nexus_prover) }
    if !_path_exists(anima_prover) { missing.push("anima:" + anima_prover) }

    if len(missing) > 0 {
        eprintln("[cross-prover] FAIL early — prover(s) missing:")
        let mut mi = 0
        while mi < len(missing) {
            eprintln("  " + missing[mi])
            mi = mi + 1
        }
        eprintln("[cross-prover] verdict = ERROR (no speculative run)")
        exit(2)
    }

    // ─── artifact pre-check ──────────────────────────────────────
    // Artifact missing is not an error for this tool — the individual
    // prover will handle its own artifact semantics. We just record it.

    eprintln("[cross-prover] run A (nexus): " + nexus_prover)
    let ra = _run_prover(nexus_prover, claim, artifact)
    let exit_a = ra[0]
    let out_a = ra[1]

    eprintln("[cross-prover] run B (anima): " + anima_prover)
    let rb = _run_prover(anima_prover, claim, artifact)
    let exit_b = rb[0]
    let out_b = rb[1]

    let norm_a = _normalize(out_a)
    let norm_b = _normalize(out_b)
    let sha_a = _sha256_of_str(norm_a)
    let sha_b = _sha256_of_str(norm_b)
    let toks_a = _tokens(norm_a)
    let toks_b = _tokens(norm_b)
    let hash_match = (sha_a != "" && sha_a == sha_b)
    let jaccard = _jaccard(toks_a, toks_b)
    let agreement = _agreement(hash_match, jaccard)

    let mut verdict = "FAIL"
    let mut fail_reason = ""
    if exit_a != 0 || exit_b != 0 {
        fail_reason = "prover exit non-zero (a=" + str(exit_a) + " b=" + str(exit_b) + ")"
    } else if agreement < 0.85 {
        fail_reason = "agreement " + _fmt_float(agreement) + " < 0.85 threshold"
    } else {
        verdict = "PASS"
    }

    // ─── write output JSON ───────────────────────────────────────
    // Use parts.push() + .join() per perf(raw_all): avoid O(n²) concat.
    _ensure_dir("shared/state")
    let out_path = "shared/state/" + dest + "_" + round + "_cross_prover.json"
    let ts = _iso_utc_now()

    let mut parts = []
    parts.push("{")
    parts.push("\"dest\":\""); parts.push(_json_esc(dest)); parts.push("\",")
    parts.push("\"round\":\""); parts.push(_json_esc(round)); parts.push("\",")
    parts.push("\"ts\":\""); parts.push(ts); parts.push("\",")
    parts.push("\"claim\":\""); parts.push(_json_esc(claim)); parts.push("\",")
    parts.push("\"artifact\":\""); parts.push(_json_esc(artifact)); parts.push("\",")
    parts.push("\"prover_a\":{")
    parts.push("\"id\":\"nexus\",")
    parts.push("\"path\":\""); parts.push(_json_esc(nexus_prover)); parts.push("\",")
    parts.push("\"exit\":"); parts.push(str(exit_a)); parts.push(",")
    parts.push("\"sha\":\""); parts.push(sha_a); parts.push("\",")
    parts.push("\"tokens\":"); parts.push(str(len(toks_a)))
    parts.push("},")
    parts.push("\"prover_b\":{")
    parts.push("\"id\":\"anima\",")
    parts.push("\"path\":\""); parts.push(_json_esc(anima_prover)); parts.push("\",")
    parts.push("\"exit\":"); parts.push(str(exit_b)); parts.push(",")
    parts.push("\"sha\":\""); parts.push(sha_b); parts.push("\",")
    parts.push("\"tokens\":"); parts.push(str(len(toks_b)))
    parts.push("},")
    parts.push("\"hash_match\":")
    if hash_match { parts.push("true,") } else { parts.push("false,") }
    parts.push("\"jaccard\":"); parts.push(_fmt_float(jaccard)); parts.push(",")
    parts.push("\"agreement\":"); parts.push(_fmt_float(agreement)); parts.push(",")
    parts.push("\"threshold\":0.85,")
    parts.push("\"verdict\":\""); parts.push(verdict); parts.push("\"")
    if fail_reason != "" {
        parts.push(",\"fail_reason\":\""); parts.push(_json_esc(fail_reason)); parts.push("\"")
    }
    parts.push("}\n")
    let body = parts.join("")

    write_file(out_path, body)

    // Human-readable echo
    println("── cross-prover diagonal ──")
    println("dest      : " + dest + " " + round)
    println("claim     : " + claim)
    println("artifact  : " + artifact)
    println("prover_a  : nexus exit=" + str(exit_a) + " sha=" + sha_a.substring(0, 12))
    println("prover_b  : anima exit=" + str(exit_b) + " sha=" + sha_b.substring(0, 12))
    println("hash_match: " + str(hash_match))
    println("jaccard   : " + _fmt_float(jaccard))
    println("agreement : " + _fmt_float(agreement) + " (threshold 0.85)")
    println("verdict   : " + verdict)
    if fail_reason != "" { println("reason    : " + fail_reason) }
    println("report    : " + out_path)

    if verdict == "PASS" { exit(0) }
    exit(1)
}
