// tool/jit_selftest.hexa — F-JIT selftest entry
//
// @resolver-bypass(reason="JIT pipeline is mac-local: cc -O2 -dynamiclib produces a Mach-O .dylib that won't load inside the Linux hexa-exec container. Docker landing must be skipped.")
//
// Wraps tool/jit/jit_bench.hexa as a selftest. Pass criterion: speed-up
// >= 10× on 1M tight integer loop (interpreter vs JIT'd .dylib via FFI).
// Also runs a bail-out fixture to verify the lowering pass refuses
// unsupported constructs cleanly.

fn locate_project_root() {
    let mut cur = exec("pwd").trim()
    let mut steps = 0
    while steps < 30 {
        if file_exists(cur + "/hexa.toml") { return cur }
        if cur == "/" || cur == "" { return "" }
        cur = exec("dirname '" + cur + "'").trim()
        steps = steps + 1
    }
    return ""
}
let project_dir = locate_project_root()
if project_dir == "" {
    println("[jit-selftest] ERR: cannot locate hexa.toml")
    exit(2)
}

let hexa_real = "/Users/ghost/core/hexa-lang/hexa.real"
let bench = project_dir + "/tool/jit/jit_bench.hexa"
let compile = project_dir + "/tool/jit/jit_compile.hexa"
let build_dir = project_dir + "/build"
exec("mkdir -p " + build_dir)

// --- Test 1: bail-out fixture ---
let bail_src = build_dir + "/jit_selftest_bail.hexa"
write_file(bail_src,
    "@jit\n" +
    "fn ok(x: Int) -> Int { return x * 2 + 1 }\n\n" +
    "@jit\n" +
    "fn bad_string(s: String) -> Int { return 1 }\n\n" +
    "@jit\n" +
    "fn bad_unknown_call(x: Int) -> Int {\n    let y = totally_unknown_fn(x)\n    return y\n}\n\n" +
    "println(\"r=\" + to_string(ok(7)))\n")

let bail_runner = build_dir + "/jit_selftest_bail.runner.hexa"
// On Darwin hosts where the hexa AOT cache fast-path inherits
// container-routing env (LD_PRELOAD=/opt/hexa/native_gate.so,
// HEXA_RESOLVER_IN_CONTAINER=1), nested exec() lands in a Linux
// container — defeating mac-local cc -O2. We scrub the env explicitly
// so all JIT subprocess work runs on the Darwin host.
let env_clean = "env -i PATH=/usr/local/bin:/usr/bin:/bin HOME=" + exec("echo $HOME").trim() + " "
let bail_cmd = env_clean + hexa_real + " run " + compile + " " + bail_src + " -o " + bail_runner + " 2>&1"
let bail_log = exec(bail_cmd)
let mut bail_pass = true
if !bail_log.contains("bail: bad_string param-type=String") { bail_pass = false }
if !bail_log.contains("bail: bad_unknown_call") { bail_pass = false }
if !file_exists(bail_runner) { bail_pass = false }

println("[jit-selftest] bail-out fixture: " + (if bail_pass { "PASS" } else { "FAIL" }))
if !bail_pass {
    println(bail_log)
    exit(1)
}

// --- Test 2: speed-up benchmark (delegates to jit_bench.hexa, --runs 2) ---
let bench_cmd = env_clean + hexa_real + " run " + bench + " --runs 2 2>&1"
let bench_log = exec(bench_cmd)
let bench_pass = bench_log.contains("[jit-bench] PASS")
println(bench_log)
println("[jit-selftest] speed-up benchmark: " + (if bench_pass { "PASS" } else { "FAIL" }))

if !bench_pass { exit(2) }
println("__JIT_SELFTEST__ PASS mode=selftest")
exit(0)
