// tool/foundation_axiom_lock.hexa — raw#24 enforcer (foundation-axiom-immutable)
//
// rule: raw:foundation-axioms-locked — @P/@L 마킹된 [11*] axioms
// (n, σ, τ, Δ₀-ABSOLUTE-THEOREM, ULTRA-UNIFORMITY-THEOREM) 변경 금지.
// raw:os-lock 상위, 암호학적 immutability.
//
// n6-architecture/atlas/atlas.n6 의 [11*] tier axiom block 은 540+ META
// 계층의 basis. 수정 = 전체 증명 무효화. OS lock 단독으로는 owner unlock
// path 가 존재하므로 해시 앵커로 이중화한다.
//
// 구현:
//   1. canonical atlas.n6 에서 `[11*]` 마커 포함 라인 전부 추출 (awk).
//   2. sha256 계산.
//   3. stored constant (아래 FOUNDATION_AXIOM_SHA256) 와 비교.
//   4. 불일치 시 stderr 로 NEXUS_ENGINE_DEAD 출력 + exit 1.
//
// baseline anchored 2026-04-21: 6 lines (n/sigma/tau/DELTA0_ABSOLUTE_THEOREM/
// ULTRA_UNIFORMITY_THEOREM block + 1 leading comment line).
//
// usage:
//   hexa run tool/foundation_axiom_lock.hexa verify      — compare vs stored
//   hexa run tool/foundation_axiom_lock.hexa print       — print current hash
//   hexa run tool/foundation_axiom_lock.hexa dump        — print [11*] block
//
// re-anchor (rare, only after an approved axiom change):
//   (1) edit atlas.n6 [11*] block
//   (2) hexa run tool/foundation_axiom_lock.hexa print   — copy new sha
//   (3) update FOUNDATION_AXIOM_SHA256 below
//   (4) commit both changes atomically with justification

let ATLAS_PATH = "/Users/ghost/core/n6-architecture/atlas/atlas.n6"
let FOUNDATION_AXIOM_SHA256 = "073459ce9052ae2fdd714bc272bfad8116e989dabcb5f43895f375e8f0ffaaa5"

fn _shq(s: str) -> str {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _extract_block() -> str {
    // awk extracts every line containing "[11*]". This matches both @P
    // assignments (n, σ, τ) and @L theorem declarations (DELTA0_*, ULTRA_*)
    // plus any leading "# ... [11*]" comments that document the block.
    let cmd = "awk '/\\[11\\*\\]/' " + _shq(ATLAS_PATH)
    return exec(cmd)
}

fn _compute_hash(block: str) -> str {
    // pipe block through shasum -a 256 via a tmp file — avoids shell-escape
    // fragility on multi-line text and guarantees byte-exact pipe.
    let tmp = "/tmp/.foundation_axiom_" + to_string(now()) + ".tmp"
    write_file(tmp, block)
    let raw = exec("shasum -a 256 " + _shq(tmp) + " | awk '{print $1}'")
    exec("rm -f " + _shq(tmp) + " 2>/dev/null || true")
    return raw.trim()
}

fn _mode() -> str {
    let a = argv()
    let n = len(a)
    if n < 2 { return "verify" }
    return a[1]
}

fn main() -> void {
    let mode = _mode()
    let block = _extract_block()

    if block.len() == 0 {
        eprintln("NEXUS_ENGINE_DEAD {\"reason\":\"atlas_foundation_block_missing\",\"path\":\""
            + ATLAS_PATH + "\"}")
        exit(1)  // @allow-silent-exit
    }

    if mode == "dump" {
        println(block)
        return
    }

    let got = _compute_hash(block)

    if mode == "print" {
        println(got)
        return
    }

    // default: verify
    if got == FOUNDATION_AXIOM_SHA256 {
        println("raw#24 foundation-axioms-locked: PASS (" + got + ")")
        return
    }
    eprintln("NEXUS_ENGINE_DEAD {\"reason\":\"foundation_axiom_drift\",\"expected\":\""
        + FOUNDATION_AXIOM_SHA256 + "\",\"got\":\"" + got + "\"}")
    eprintln("raw#24 verify FAIL — [11*] block hash diverged. If this change is")
    eprintln("approved, follow the re-anchor procedure documented at the top.")
    exit(1)  // @allow-silent-exit
}

main()
