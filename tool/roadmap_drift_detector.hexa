// tool/roadmap_drift_detector.hexa — Phase 3.3 drift detector (stub).
//
// SPEC: docs/roadmap_engine_continuous_meta_proposal_20260422.md §Phase 3.3.
// STATUS: stub — skeleton + --selftest only.
//
// PURPOSE
//   Compare .roadmap vs actual code:
//     - evidence file path missing  → drift
//     - done entry + probe FAIL     → regression
//     - planned entry + probe 100% PASS → drift candidate
//     - evidence mtime > done_ts    → evidence_drifted
//
// CLI
//   hexa tool/roadmap_drift_detector.hexa --selftest
//   hexa tool/roadmap_drift_detector.hexa --repo <name> [--out <path>]
//
// OUTPUT
//   $HEXA_LANG/state/roadmap_drift_<repo>.json
//   $HEXA_LANG/docs/roadmap_drift_<repo>.md
//   schema = "hexa-lang/roadmap_drift/1"

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _iso_now() -> string {
    return to_string(exec("date -u +'%Y-%m-%dT%H:%M:%SZ'")).trim()
}

fn _arg_value(args: array, key: string, default: string) -> string {
    let mut i = 0
    while i < len(args) {
        if args[i] == key {
            let j = i + 1
            if j < len(args) { return args[j] }
        }
        i = i + 1
    }
    return default
}

fn _selftest() -> int {
    if len(_iso_now()) < 10 {
        eprintln("roadmap_drift_detector: selftest FAIL (iso_now empty)")
        return 1
    }
    println("roadmap_drift_detector: selftest PASS (stub)")
    return 0
}

fn _emit(repo: string, out_path: string) -> int {
    let ts = _iso_now()
    let body = "{\n  \"schema\": \"hexa-lang/roadmap_drift/1\",\n  \"ts\": \"" + ts + "\",\n  \"repo\": \"" + repo + "\",\n  \"status\": \"stub\",\n  \"drifts\": [],\n  \"regressions\": [],\n  \"summary\": {\"drift\": 0, \"regression\": 0, \"evidence_drifted\": 0}\n}\n"
    try {
        write_file(out_path, body)
    } catch e {
        eprintln("roadmap_drift_detector: write FAIL " + out_path)
        return 1
    }
    println("roadmap_drift_detector: wrote " + out_path + " (stub)")
    return 0
}

fn main() {
    let av = argv()
    let mut args = []
    let mut i = 2
    while i < len(av) { args.push(av[i]); i = i + 1 }

    if len(args) >= 1 && args[0] == "--selftest" {
        exit(_selftest())
    }

    let repo = _arg_value(args, "--repo", "anima")
    let default_out = _home() + "/core/hexa-lang/state/roadmap_drift_" + repo + ".json"
    let out_path = _arg_value(args, "--out", default_out)
    exit(_emit(repo, out_path))
}
