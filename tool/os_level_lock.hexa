#!hexa strict
// tool/os_level_lock.hexa — raw#0 OS-level file lock (chflags uchg)
//
// PURPOSE
//   Pre-commit hooks and PreToolUse hooks are bypassable. Kernel EPERM
//   (Operation not permitted, triggered by BSD `uchg` immutable flag) is
//   the only real enforcement for SSOT files.
//
//   This tool applies / removes / inspects the `uchg` user-immutable flag
//   on the raw#0 lock target set (5 SSOT + raw#12 grandfather list).
//
// USAGE
//   ./hexa tool/os_level_lock.hexa lock     — apply chflags uchg to all targets
//   ./hexa tool/os_level_lock.hexa unlock   — remove chflags uchg (owner-only)
//   ./hexa tool/os_level_lock.hexa status   — list each target + lock state
//   ./hexa tool/os_level_lock.hexa verify   — exit 1 if any SSOT is unlocked
//                                             (intended for pre-commit hook)
//
// PLATFORM
//   macOS only. Darwin `chflags uchg` sets BSD immutable flag; any write /
//   unlink / rename attempt returns EPERM until owner runs `chflags nouchg`.
//   Linux equivalent would be `chattr +i` (root only) — not implemented.
//   On non-Darwin OS the tool no-ops with a warning (does not fail).
//
// TARGETS
//   Split into two groups:
//     required : 5 SSOT — must exist; verify fails if missing or unlocked
//     optional : raw#12 grandfather bans — locked only if present on disk
//
//   Names are declared inline in _required_targets / _optional_targets
//   rather than hardcoded at call sites (raw#14 — values belong in SSOT,
//   but the target list IS an SSOT declaration here, so centralized).

// ─── target lists (raw#0 scope) ─────────────────────────────────

fn _required_targets() -> array {
    // 5 SSOT — raw/own/ext/roadmap/loop. MUST exist, MUST be locked.
    return [".raw", ".own", ".ext", ".roadmap", ".loop"]
}

fn _optional_targets() -> array {
    // raw#12 grandfather bans. Locked if present; skipped if absent.
    return [
        "CLAUDE.md",
        "AGENTS.md",
        "CODEX.md",
        ".cursorrules",
        ".cursor",
        ".windsurfrules",
        ".aider.conf.yml",
        ".continuerules",
        ".github/copilot-instructions.md",
        ".claude"
    ]
}

// ─── environment helpers ────────────────────────────────────────

fn _pwd() -> string {
    let mut p = env("PWD")
    if p == "" { p = to_string(exec("pwd")).trim() }
    return p
}

fn _path_exists(path: string) -> bool {
    // test -e handles both files and directories; `file_exists` builtin
    // is file-only in stage0.
    let r = to_string(exec("test -e '" + path + "' && echo y || echo n")).trim()
    return r == "y"
}

fn _is_darwin() -> bool {
    let uname = to_string(exec("uname -s")).trim()
    return uname == "Darwin"
}

// ─── lock state inspection ──────────────────────────────────────

fn _is_locked(path: string) -> bool {
    // `ls -lOd` prints flag column 5 on Darwin: "uchg" when immutable,
    // "-" when clear. We match on literal token "uchg" to avoid false
    // positives (filename containing 'uchg' would still land in a
    // different column).
    let r = exec_with_status("ls -lOd '" + path + "' 2>/dev/null")
    if r[1] != 0 { return false }
    let line = to_string(r[0])
    // Flag token is surrounded by whitespace — match " uchg " substring
    // to reject a filename accidentally called "uchg*".
    if line.contains(" uchg ") { return true }
    if line.contains(" uchg,") { return true }  // combined flag form
    return false
}

// ─── mutations ──────────────────────────────────────────────────

fn _apply_lock(path: string) -> int {
    let r = exec_with_status("chflags uchg '" + path + "' 2>&1")
    return r[1]
}

fn _remove_lock(path: string) -> int {
    let r = exec_with_status("chflags nouchg '" + path + "' 2>&1")
    return r[1]
}

// ─── command implementations ────────────────────────────────────

fn cmd_lock() -> int {
    if !_is_darwin() {
        eprintln("warn[os_level_lock]: non-Darwin OS — chflags uchg unavailable, no-op")
        return 0
    }
    let root = _pwd()
    let mut locked_count = 0
    let mut skipped_missing = 0
    let mut skipped_already = 0
    let mut failures = []

    let targets = _required_targets() + _optional_targets()
    for rel in targets {
        let abs = root + "/" + rel
        if !_path_exists(abs) {
            skipped_missing = skipped_missing + 1
            continue
        }
        if _is_locked(abs) {
            skipped_already = skipped_already + 1
            continue
        }
        let rc = _apply_lock(abs)
        if rc == 0 {
            locked_count = locked_count + 1
            println("  locked    " + rel)
        } else {
            failures = failures.push(rel)
            eprintln("  FAILED    " + rel + " (chflags exit " + to_string(rc) + ")")
        }
    }

    println("")
    println("summary: locked=" + to_string(locked_count)
            + " already=" + to_string(skipped_already)
            + " missing=" + to_string(skipped_missing)
            + " failed=" + to_string(len(failures)))
    if len(failures) > 0 { return 1 }
    return 0
}

fn cmd_unlock() -> int {
    if !_is_darwin() {
        eprintln("warn[os_level_lock]: non-Darwin OS — no-op")
        return 0
    }
    let root = _pwd()
    let mut unlocked_count = 0
    let mut skipped_missing = 0
    let mut skipped_already = 0
    let mut failures = []

    let targets = _required_targets() + _optional_targets()
    for rel in targets {
        let abs = root + "/" + rel
        if !_path_exists(abs) {
            skipped_missing = skipped_missing + 1
            continue
        }
        if !_is_locked(abs) {
            skipped_already = skipped_already + 1
            continue
        }
        let rc = _remove_lock(abs)
        if rc == 0 {
            unlocked_count = unlocked_count + 1
            println("  unlocked  " + rel)
        } else {
            failures = failures.push(rel)
            eprintln("  FAILED    " + rel + " (chflags exit " + to_string(rc) + ")")
        }
    }

    println("")
    println("summary: unlocked=" + to_string(unlocked_count)
            + " already=" + to_string(skipped_already)
            + " missing=" + to_string(skipped_missing)
            + " failed=" + to_string(len(failures)))
    if len(failures) > 0 { return 1 }
    return 0
}

fn cmd_status() -> int {
    let root = _pwd()
    let darwin = _is_darwin()

    println("── raw#0 os-level lock status ──")
    println("")
    println("required SSOT (5):")
    for rel in _required_targets() {
        let abs = root + "/" + rel
        if !_path_exists(abs) {
            println("  MISSING   " + rel)
            continue
        }
        if !darwin {
            println("  N/A       " + rel + " (non-Darwin)")
            continue
        }
        if _is_locked(abs) {
            println("  locked    " + rel)
        } else {
            println("  UNLOCKED  " + rel)
        }
    }

    println("")
    println("optional raw#12 bans (grandfather):")
    for rel in _optional_targets() {
        let abs = root + "/" + rel
        if !_path_exists(abs) {
            println("  absent    " + rel)
            continue
        }
        if !darwin {
            println("  N/A       " + rel + " (non-Darwin)")
            continue
        }
        if _is_locked(abs) {
            println("  locked    " + rel)
        } else {
            println("  UNLOCKED  " + rel)
        }
    }
    return 0
}

fn cmd_verify() -> int {
    // pre-commit mode: silent on pass, exit 1 with detail on fail.
    if !_is_darwin() {
        // Non-Darwin treated as pass (tool noop) — raw#0 note says macOS.
        return 0
    }
    let root = _pwd()
    let mut fails = []

    for rel in _required_targets() {
        let abs = root + "/" + rel
        if !_path_exists(abs) {
            fails = fails.push(rel + " (missing)")
            continue
        }
        if !_is_locked(abs) {
            fails = fails.push(rel + " (unlocked)")
        }
    }
    // Optional bans: if present, must be locked. If absent, skip.
    for rel in _optional_targets() {
        let abs = root + "/" + rel
        if !_path_exists(abs) { continue }
        if !_is_locked(abs) {
            fails = fails.push(rel + " (unlocked)")
        }
    }

    if len(fails) == 0 { return 0 }
    eprintln("raw#0 verify FAILED — the following targets are not OS-locked:")
    for f in fails { eprintln("  - " + f) }
    eprintln("")
    eprintln("Remedy: ./hexa tool/os_level_lock.hexa lock")
    return 1
}

// ─── CLI dispatch ───────────────────────────────────────────────

fn _usage() {
    eprintln("usage: hexa tool/os_level_lock.hexa <lock|unlock|status|verify>")
}

let _av = argv()
// `./hexa tool/os_level_lock.hexa <cmd>` → argv = [hexa, script, cmd, ...]
// when executed via the stage0 binary directly, argv = [stage0, script, cmd]
let mut cmd = ""
let mut i = 2
while i < len(_av) {
    let a = _av[i]
    if a == "lock" || a == "unlock" || a == "status" || a == "verify" {
        cmd = a
        break
    }
    i = i + 1
}

if cmd == "" {
    _usage()
    exit(2)
}

let mut rc = 0
if cmd == "lock"        { rc = cmd_lock() }
else if cmd == "unlock" { rc = cmd_unlock() }
else if cmd == "status" { rc = cmd_status() }
else if cmd == "verify" { rc = cmd_verify() }
else {
    _usage()
    exit(2)
}
exit(rc)
