// tool/hx_aot_stale.hexa — Phase 3.8 AOT binary freshness scanner (real-v1).
//
// SPEC: docs/hexa_lang_meta_evolution_proposal_20260422.md §3.8.
// STATUS: v1 real — mtime compare bin/<stem> vs tool/<stem>.hexa, skip
//         shell shims (#! header). Invocation frequency ranking from
//         launchd/git-hook logs deferred to v2.
//
// CLI
//   hexa tool/hx_aot_stale.hexa --selftest
//   hexa tool/hx_aot_stale.hexa [--out <path>]
//
// OUTPUT
//   $HEXA_LANG/state/hx_aot_stale.json  (schema hexa-lang/hx_aot_stale/1)

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _iso_now() -> string {
    return to_string(exec("date -u +'%Y-%m-%dT%H:%M:%SZ'")).trim()
}

fn _arg_value(args: array, key: string, default: string) -> string {
    let mut i = 0
    while i < len(args) {
        if args[i] == key {
            let j = i + 1
            if j < len(args) { return args[j] }
        }
        i = i + 1
    }
    return default
}

fn _json_esc(s: string) -> string {
    let mut r = s.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", "\\n")
    r = r.replace("\r", "")
    r = r.replace("\t", " ")
    return r
}

fn _split_lines(s: string) -> array {
    let mut out = []
    let mut cur = ""
    let mut i = 0
    while i < len(s) {
        let c = s.substring(i, i + 1)
        if c == "\n" {
            if len(cur) > 0 { out.push(cur) }
            cur = ""
        } else {
            cur = cur + c
        }
        i = i + 1
    }
    if len(cur) > 0 { out.push(cur) }
    return out
}

fn _root() -> string {
    return _home() + "/core/hexa-lang"
}

fn _exists(path: string) -> bool {
    return to_string(exec("test -f '" + path + "' && echo y || echo n")).trim() == "y"
}

fn _is_shell_shim(path: string) -> bool {
    let head = to_string(exec("head -c 2 '" + path + "' 2>/dev/null"))
    return head == "#!"
}

fn _src_newer_than(src: string, bin: string) -> bool {
    let r = to_string(exec("test '" + src + "' -nt '" + bin + "' && echo y || echo n")).trim()
    return r == "y"
}

fn _mtime_epoch(path: string) -> string {
    if !_exists(path) { return "0" }
    return to_string(exec("stat -f %m '" + path + "' 2>/dev/null")).trim()
}

fn _selftest() -> int {
    let esc = _json_esc("a\"b")
    if esc != "a\\\"b" { eprintln("hx_aot_stale: selftest FAIL (esc)"); return 1 }
    if len(_iso_now()) < 10 { eprintln("hx_aot_stale: selftest FAIL (iso)"); return 1 }
    println("hx_aot_stale: selftest PASS")
    return 0
}

fn main() {
    let av = argv()
    let mut args = []
    let mut i = 2
    while i < len(av) { args.push(av[i]); i = i + 1 }

    if len(args) >= 1 && args[0] == "--selftest" { exit(_selftest()) }

    let default_out = _root() + "/state/hx_aot_stale.json"
    let out_path = _arg_value(args, "--out", default_out)
    let ts = _iso_now()

    let bin_dir = _root() + "/bin"
    let tool_dir = _root() + "/tool"
    let raw = to_string(exec("ls '" + bin_dir + "' 2>/dev/null"))
    let files = _split_lines(raw)

    let mut scanned = 0
    let mut shim_count = 0
    let mut orphan = []
    let mut stale = []

    for name in files {
        let bin = bin_dir + "/" + name
        if !_exists(bin) { continue }
        if _is_shell_shim(bin) { shim_count = shim_count + 1; continue }
        scanned = scanned + 1
        let src = tool_dir + "/" + name + ".hexa"
        if !_exists(src) {
            orphan.push("{\"bin\":\"bin/" + _json_esc(name) + "\""
                + ",\"reason\":\"no matching tool/" + _json_esc(name) + ".hexa source\"}")
            continue
        }
        if _src_newer_than(src, bin) {
            stale.push("{\"bin\":\"bin/" + _json_esc(name) + "\""
                + ",\"src\":\"tool/" + _json_esc(name) + ".hexa\""
                + ",\"bin_mtime\":" + _mtime_epoch(bin)
                + ",\"src_mtime\":" + _mtime_epoch(src)
                + ",\"action\":\"rebuild AOT binary from source\"}")
        }
    }

    let mut body = "{\n  \"schema\": \"hexa-lang/hx_aot_stale/1\",\n"
    body = body + "  \"ts\": \"" + ts + "\",\n"
    body = body + "  \"status\": \"real-v1\",\n"
    body = body + "  \"bin_count\": " + to_string(len(files)) + ",\n"
    body = body + "  \"shim_count\": " + to_string(shim_count) + ",\n"
    body = body + "  \"aot_scanned\": " + to_string(scanned) + ",\n"
    body = body + "  \"stale\": [\n"
    let mut first = true
    for s in stale {
        if !first { body = body + ",\n" }
        body = body + "    " + s
        first = false
    }
    body = body + "\n  ],\n"
    body = body + "  \"orphan\": [\n"
    first = true
    for o in orphan {
        if !first { body = body + ",\n" }
        body = body + "    " + o
        first = false
    }
    body = body + "\n  ],\n"
    body = body + "  \"summary\": {\"stale\": " + to_string(len(stale))
    body = body + ", \"orphan\": " + to_string(len(orphan)) + "}\n}\n"

    try { write_file(out_path, body) } catch e {
        eprintln("hx_aot_stale: write FAIL " + out_path)
        exit(1)
    }

    println("hx_aot_stale: bin=" + to_string(len(files))
          + " (shim=" + to_string(shim_count)
          + ", AOT=" + to_string(scanned) + "); "
          + to_string(len(stale)) + " stale, "
          + to_string(len(orphan)) + " orphan")
    println("hx_aot_stale: wrote " + out_path)
    exit(0)
}
