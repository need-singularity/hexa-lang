#!hexa strict
// tool/own_inherit_lint.hexa — nested .own monotonic inheritance (P1c)
//
// PURPOSE
//   Enforce that worktree-local .own files (nested under
//   .claude/worktrees/*/.own) never weaken the root /.own. Nested entries
//   may match or strengthen, never relax.
//
//   This is complementary to (and succeeds) the older .own-vs-.raw check:
//   root .own is now considered the L1 truth; each worktree-local .own
//   must honor it or strengthen it.
//
// STRICTNESS LADDER (task spec)
//   live > warn > convention > deferred > new
//
//   Codified in `_status_strength(s) -> int`:
//     live=4, warn=3, convention=2, deferred=1, new=0, unknown=-1
//
//   A nested rule VIOLATES inheritance iff strength(nested) < strength(root).
//   Equal or greater is OK.
//
// MATCHING
//   For each nested rule r_n:
//     key = slug (if present) else rule name.
//     Look up the matching root rule r_r by same key.
//       · found    → compare _status_strength — must be ≥ root's.
//       · missing  → nested is independent; pass (not a violation).
//
// BFS SCAN
//   · roots:    /.own
//   · nested:   .claude/worktrees/*/.own  (list_dir on .claude/worktrees,
//                                         filter to dirs containing .own)
//   · path-sort is lexicographic so output is stable across runs.
//
// OUTPUT
//   Per violation:
//     [FAIL] <nested-path>#<slug> relaxes root <slug>
//            (root=<rootStatus> > nested=<nestedStatus>)
//   Final:
//     ✅ PASS — N nested .own files checked
//     🚫 FAIL — K violations
//
// EXIT
//   0 = no violations
//   1 = one or more violations
//
// USAGE
//   ./hexa tool/own_inherit_lint.hexa            — lint, exit nonzero on fail
//   ./hexa tool/own_inherit_lint.hexa --list     — dump discovered nested .own
//
// WIRING
//   Invoked by tool/raw_all.hexa as a synthetic enforcer (no .raw/.own row).

use "self/core/law_io"
use "self/raw_loader"
// ─── strictness ladder ──────────────────────────────────────────

fn _status_strength(s: string) -> int {
    if s == "live" { return 4 }
    if s == "warn" { return 3 }
    if s == "convention" { return 2 }
    if s == "deferred" { return 1 }
    if s == "new" { return 0 }
    return -1
}

// ─── path helpers ───────────────────────────────────────────────

let mut __pwd_cache = ""

fn _pwd() -> string {
    if __pwd_cache != "" { return __pwd_cache }
    let mut p = env("PWD")
    if p == "" { p = to_string(exec("pwd")).trim() }
    __pwd_cache = p
    return p
}

fn _root_own_path() -> string {
    let parts = [_pwd(), "/.own"]
    return parts.join("")
}
fn _worktrees_dir() -> string {
    let parts = [_pwd(), "/.claude/worktrees"]
    return parts.join("")
}

// ─── discovery: BFS nested .own list ────────────────────────────

fn _discover_nested_owns() -> array {
    // Returns array of absolute paths to nested .own files, sorted
    // lexicographically. Empty if .claude/worktrees is absent.
    let wt_dir = _worktrees_dir()
    if !file_exists(wt_dir) { return [] }
    let entries = list_dir(wt_dir)
    let mut paths = []
    let wt_slash = wt_dir + "/"
    for e in entries {
        if e == "." || e == ".." { continue }
        let parts = [wt_slash, e, "/.own"]
        let own_path = parts.join("")
        if file_exists(own_path) {
            paths = paths.push(own_path)
        }
    }
    // sort paths lexicographically (stable output)
    return _sort_strings(paths)
}

fn _sort_strings(arr: array) -> array {
    // insertion sort — N is small (< 20 worktrees)
    let n = len(arr)
    let mut out = []
    let mut i = 0
    while i < n {
        let v = arr[i]
        let mut inserted = false
        let mut res = []
        let mut j = 0
        while j < len(out) {
            if !inserted && v < out[j] {
                res = res.push(v)
                inserted = true
            }
            res = res.push(out[j])
            j = j + 1
        }
        if !inserted { res = res.push(v) }
        out = res
        i = i + 1
    }
    return out
}

// ─── rule key (slug | name) ─────────────────────────────────────

fn _rule_key(rule: array) -> string {
    // task spec: "matching slug (or matching name if slug absent)"
    let keys = rule[3]
    let slug = keys_first(keys, "slug")
    if slug != "" { return slug }
    return rule[2]   // rule[2] = name
}

fn _find_by_key(rules: array, key: string) -> array {
    for r in rules {
        if _rule_key(r) == key { return r }
    }
    return []
}

// ─── argv ───────────────────────────────────────────────────────

fn _parse_flags() -> array {
    // returns [list_mode(bool)]
    let av = args()
    let mut list_mode = false
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--list" { list_mode = true }
        i = i + 1
    }
    return [list_mode]
}

// ─── main ───────────────────────────────────────────────────────

fn main() -> int {
    let flags = _parse_flags()
    let list_mode = flags[0]

    let root_path = _root_own_path()
    if !file_exists(root_path) {
        println("── raw#0 own_inherit_lint (nested) ──")
        println("root .own missing — nothing to inherit from")
        println("")
        println("✅ PASS — 0 nested .own files checked")
        return 0
    }

    let root_rules = load_raw_file(root_path)
    let nested_paths = _discover_nested_owns()

    if list_mode {
        println("── nested .own discovery ──")
        println("root:   " + root_path + "  (" + to_string(len(root_rules)) + " rules)")
        if len(nested_paths) == 0 {
            println("nested: 0  (no worktree .own files)")
        } else {
            println("nested: " + to_string(len(nested_paths)))
            for p in nested_paths { println("  " + p) }
        }
        return 0
    }

    println("── raw#0 own_inherit_lint (nested) ──")
    println("root   : " + root_path)
    println("nested : " + to_string(len(nested_paths)) + " file(s)")

    let mut violations = []
    let mut files_checked = 0

    for np in nested_paths {
        files_checked = files_checked + 1
        let nrules = load_raw_file(np)
        for nr in nrules {
            let key = _rule_key(nr)
            let nstatus = nr[1]
            let rr = _find_by_key(root_rules, key)
            if len(rr) == 0 {
                // nested-only rule — independent, pass
                continue
            }
            let rstatus = rr[1]
            let rstr = _status_strength(rstatus)
            let nstr = _status_strength(nstatus)
            if rstr < 0 || nstr < 0 {
                let mparts = ["[FAIL] ", np, "#", key,
                              " unknown status (root=", rstatus,
                              ", nested=", nstatus, ")"]
                violations = violations.push(mparts.join(""))
                continue
            }
            if nstr < rstr {
                let mparts = ["[FAIL] ", np, "#", key,
                              " relaxes root ", key,
                              " (root=", rstatus, " > nested=", nstatus, ")"]
                violations = violations.push(mparts.join(""))
            }
        }
    }

    println("")
    if len(violations) == 0 {
        println("✅ PASS — " + to_string(files_checked) + " nested .own files checked")
        return 0
    }

    for v in violations { println(v) }
    println("")
    println("🚫 FAIL — " + to_string(len(violations)) + " violations")
    return 1
}

exit(main())
