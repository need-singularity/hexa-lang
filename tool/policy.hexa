// tool/policy.hexa — live policy emitter (HX4 self-host, 0% external dep)
//
// Reads:
//   - cwd/project.hexa  (optional — project marker + local overrides)
//   - $HEXA_LANG/self/attrs/*.hexa  (live SSOT — all active rules)
//
// Emits:
//   Active rule summary to stdout. Any LLM running `hexa run tool/policy.hexa`
//   (or the wrapper emitting on every `hexa` call) sees current policy without
//   any markdown/JSON file dependency.
//
// Usage:
//   hexa tool/policy.hexa              — full listing
//   hexa tool/policy.hexa banner       — 3-line terse banner (for stderr hook)
//   hexa tool/policy.hexa show <name>  — single rule detail
//
// Live: new .hexa file dropped into $HEXA_LANG/self/attrs/ = auto-visible on next call.

fn hexa_lang_root() -> string {
    let raw = env("HEXA_LANG")
    if raw != "" { return raw }
    return "/Users/ghost/core/hexa-lang"
}

fn list_attr_files() -> [string] {
    let dir = hexa_lang_root() + "/self/attrs"
    let cmd = "ls '" + dir + "'/*.hexa 2>/dev/null | sort"
    let raw = exec(cmd)
    let lines = split(raw, "\n")
    let mut out = []
    for ln in lines {
        let t = ln.trim()
        if t == "" { continue }
        if t.ends_with("/_naming.hexa") { out.push(t); continue }
        if t.ends_with("/_registry.hexa") { continue }
        if t.ends_with("/core.hexa") { continue }
        if t.ends_with("/policy.hexa") { continue }
        if t.ends_with(".hexa") { out.push(t) }
    }
    return out
}

fn extract_name_from_path(path: string) -> string {
    let parts = split(path, "/")
    let mut last = ""
    for p in parts {
        if p != "" { last = p }
    }
    if last.ends_with(".hexa") {
        return last.substring(0, len(last) - 5)
    }
    return last
}

fn extract_purpose(src: string) -> string {
    let lines = split(src, "\n")
    for ln in lines {
        let t = ln.trim()
        if t.starts_with("m.purpose") {
            let eq = t.index_of("=")
            if eq < 0 { continue }
            let after = t.substring(eq + 1, len(t)).trim()
            if after.starts_with("\"") {
                let rest = after.substring(1, len(after))
                let close = rest.index_of("\"")
                if close >= 0 { return rest.substring(0, close) }
            }
            return after
        }
    }
    let head = lines[0]
    if head.starts_with("//") {
        return head.substring(2, len(head)).trim()
    }
    return ""
}

fn extract_category(src: string) -> string {
    let lines = split(src, "\n")
    for ln in lines {
        let t = ln.trim()
        if t.starts_with("m.category") {
            let eq = t.index_of("=")
            if eq < 0 { continue }
            let after = t.substring(eq + 1, len(t)).trim()
            if after.starts_with("\"") {
                let rest = after.substring(1, len(after))
                let close = rest.index_of("\"")
                if close >= 0 { return rest.substring(0, close) }
            }
        }
    }
    return "(uncategorized)"
}

fn has_project_hexa() -> bool {
    try {
        let _ = read_file("project.hexa")
        return true
    } catch e {
        return false
    }
}

fn extract_project_name() -> string {
    try {
        let src = read_file("project.hexa")
        let lines = split(src, "\n")
        for ln in lines {
            let t = ln.trim()
            if t.starts_with("name:") {
                let c = t.index_of(":")
                let after = t.substring(c + 1, len(t)).trim()
                if after.starts_with("\"") {
                    let rest = after.substring(1, len(after))
                    let close = rest.index_of("\"")
                    if close >= 0 { return rest.substring(0, close) }
                }
            }
        }
    } catch e { }
    return "(anonymous)"
}

fn print_banner() {
    let paths = list_attr_files()
    let n = len(paths)
    let has_marker = has_project_hexa()
    let project = if has_marker { extract_project_name() } else { "(no project.hexa)" }
    println("hexa policy: " + to_string(n) + " active rules, project=" + project + ", ssot=" + hexa_lang_root() + "/self/attrs/")
    println("run `hexa run tool/policy.hexa` for full listing.")
}

fn print_full() {
    let paths = list_attr_files()
    println("─ hexa policy (live SSOT) ─────────────────────────────")
    println("ssot:    " + hexa_lang_root() + "/self/attrs/")
    println("active:  " + to_string(len(paths)) + " rules")
    if has_project_hexa() {
        println("project: " + extract_project_name() + " (project.hexa detected)")
    } else {
        println("project: (no project.hexa in cwd)")
    }
    println("")
    let mut rows = []
    for p in paths {
        let name = extract_name_from_path(p)
        let src = ""
        let mut s = ""
        try { s = read_file(p) } catch e { s = "" }
        let cat = extract_category(s)
        let purpose = extract_purpose(s)
        rows.push([cat, name, purpose])
    }
    for r in rows {
        let line = "  [" + r[0] + "] @" + r[1] + " — " + r[2]
        println(line)
    }
    println("")
    println("new rule = drop .hexa into self/attrs/ → live-visible on next `hexa policy`")
}

fn print_show(name: string) {
    let paths = list_attr_files()
    for p in paths {
        if extract_name_from_path(p) == name {
            let src = read_file(p)
            println("─ @" + name + " ─ " + p)
            println(src)
            return
        }
    }
    println("no such rule: @" + name)
    exit(1)
}

fn main() {
    let raw = args()
    let mut argv = []
    let mut i = 2
    while i < len(raw) {
        argv.push(raw[i])
        i = i + 1
    }
    if len(argv) == 0 {
        print_full()
        return
    }
    let sub = argv[0]
    if sub == "banner" {
        print_banner()
        return
    }
    if sub == "show" && len(argv) >= 2 {
        print_show(argv[1])
        return
    }
    println("usage: hexa tool/policy.hexa [banner | show <name>]")
    exit(1)
}
