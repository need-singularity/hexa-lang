// tool/tui_demo_editor_bridge.hexa — TUI-PRIM T1.C Surface 4 demo binary
//
// JSON-RPC editor bridge counterpart of tui_demo_pi_lines.hexa. Where
// the line-array demo emits plain rows + sentinel, this one emits
// JSON-RPC 2.0 envelopes for render/key/resize/quit methods.
//
// Wire (line-delimited JSON, both directions):
//   →  {"jsonrpc":"2.0","id":1,"method":"render"}
//   ←  {"jsonrpc":"2.0","id":1,"result":{"rows":24,"cols":80,"lines":[...]}}
//   →  {"jsonrpc":"2.0","id":2,"method":"key","params":[97,98,99]}
//   ←  {"jsonrpc":"2.0","id":2,"result":{"ok":true,"note":"forward-deferred"}}
//   →  {"jsonrpc":"2.0","id":3,"method":"quit"}
//   ←  {"jsonrpc":"2.0","id":3,"result":{"ok":true}}
//
// Build:
//   ./hexa build tool/tui_demo_editor_bridge.hexa -o /tmp/tui_eb_demo
// Test:
//   printf '{"jsonrpc":"2.0","id":1,"method":"render"}\n{"jsonrpc":"2.0","id":2,"method":"quit"}\n' \
//     | /tmp/tui_eb_demo

use "self/tui/wire/editor_bridge"

let rc = run_editor_bridge()
exit(rc)
