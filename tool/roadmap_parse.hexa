// tool/roadmap_parse.hexa — Tier1#1 (roadmap 33): entry parser
//
// PURPOSE
//   Deterministic hexa-native parser for .roadmap SSOT files. Converts
//   the grammar:
//     roadmap <id> <status> "<title>"
//       <key>  <value>
//       ...
//     checkpoint <ID> "<name>"
//       <key>  <value>
//
//   into JSON-serializable tuples. Works on hexa-lang/anima/airgenome
//   .roadmap files (all three repos) without heuristics beyond the
//   grammar itself. raw#9 hexa-only, raw#10 lossless (every parsed key
//   is round-trippable).
//
// CLI
//   hexa tool/roadmap_parse.hexa <path>          — emit JSON
//   hexa tool/roadmap_parse.hexa <path> --list   — plain list
//   hexa tool/roadmap_parse.hexa --selftest      — run embedded test
//
// EXIT
//   0 → parse OK
//   1 → file missing / fatal parse error

fn _rstrip(s: string) -> string {
    let mut end = len(s)
    while end > 0 {
        let c = s.substring(end - 1, end)
        if c == " " || c == "\t" || c == "\r" { end = end - 1 } else { break }
    }
    return s.substring(0, end)
}

fn _parse_roadmap_header(line: string) -> array {
    let sp1 = line.index_of(" ")
    if sp1 < 0 { return [] }
    if line.substring(0, sp1) != "roadmap" { return [] }
    let rest1 = line.substring(sp1 + 1, len(line))
    let sp2 = rest1.index_of(" ")
    if sp2 < 0 { return [] }
    let id = rest1.substring(0, sp2)
    let rest2 = rest1.substring(sp2 + 1, len(rest1))
    let sp3 = rest2.index_of(" ")
    if sp3 < 0 { return [] }
    let status = rest2.substring(0, sp3)
    let mut name = rest2.substring(sp3 + 1, len(rest2)).trim()
    if len(name) >= 2 && name.substring(0, 1) == "\"" {
        name = name.substring(1, len(name) - 1)
    }
    return [id, status, name]
}

fn _parse_checkpoint_header(line: string) -> array {
    let sp1 = line.index_of(" ")
    if sp1 < 0 { return [] }
    if line.substring(0, sp1) != "checkpoint" { return [] }
    let rest1 = line.substring(sp1 + 1, len(line))
    let sp2 = rest1.index_of(" ")
    if sp2 < 0 { return [] }
    let id = rest1.substring(0, sp2)
    let mut name = rest1.substring(sp2 + 1, len(rest1)).trim()
    if len(name) >= 2 && name.substring(0, 1) == "\"" {
        name = name.substring(1, len(name) - 1)
    }
    return [id, name]
}

// Parse .roadmap text → [rules, checkpoints].
//   rules       = [[id, status, name, keys], ...]
//   checkpoints = [[id, name, keys], ...]
//   keys        = [[k, v], ...]   (preserve insertion order)
fn parse_roadmap_text(src: string) -> array {
    let lines = split(src, "\n")
    let mut rules = []
    let mut checkpoints = []
    let mut kind = ""
    let mut cur_id = ""
    let mut cur_status = ""
    let mut cur_name = ""
    let mut cur_keys = []

    for raw_line in lines {
        let line = _rstrip(raw_line)
        if len(line) == 0 {
            if kind == "r" { rules.push([cur_id, cur_status, cur_name, cur_keys]) }
            if kind == "c" { checkpoints.push([cur_id, cur_name, cur_keys]) }
            kind = ""
            cur_keys = []
            continue
        }
        let first = line.substring(0, 1)
        if first == "#" { continue }

        if first == " " || first == "\t" {
            if kind == "" { continue }
            let stripped = line.trim_start()
            let sp = stripped.index_of(" ")
            if sp < 0 { continue }
            let key = stripped.substring(0, sp)
            let val = stripped.substring(sp + 1, len(stripped)).trim()
            cur_keys.push([key, val])
        } else {
            if kind == "r" { rules.push([cur_id, cur_status, cur_name, cur_keys]) }
            if kind == "c" { checkpoints.push([cur_id, cur_name, cur_keys]) }
            cur_keys = []
            kind = ""
            let first_sp = line.index_of(" ")
            if first_sp < 0 { continue }
            let tok = line.substring(0, first_sp)
            if tok == "roadmap" {
                let hdr = _parse_roadmap_header(line)
                if len(hdr) == 0 { continue }
                cur_id = hdr[0]
                cur_status = hdr[1]
                cur_name = hdr[2]
                kind = "r"
            }
            if tok == "checkpoint" {
                let chdr = _parse_checkpoint_header(line)
                if len(chdr) == 0 { continue }
                cur_id = chdr[0]
                cur_name = chdr[1]
                kind = "c"
            }
        }
    }
    if kind == "r" { rules.push([cur_id, cur_status, cur_name, cur_keys]) }
    if kind == "c" { checkpoints.push([cur_id, cur_name, cur_keys]) }
    return [rules, checkpoints]
}

fn load_roadmap(path: string) -> array {
    let r = exec_with_status("test -f '" + path + "'")
    if r[1] != 0 { return [[], []] }
    let src = to_string(read_file(path))
    return parse_roadmap_text(src)
}

// JSON escape minimal for string values that may carry " \\ or newlines.
fn _json_esc(s: string) -> string {
    let mut out = s.replace("\\", "\\\\")
    out = out.replace("\"", "\\\"")
    out = out.replace("\n", "\\n")
    out = out.replace("\r", "\\r")
    out = out.replace("\t", "\\t")
    return out
}

fn _keys_to_json(keys: array) -> string {
    let mut parts = []
    parts.push("{")
    let mut first = true
    for kv in keys {
        if !first { parts.push(",") }
        parts.push("\"")
        parts.push(_json_esc(kv[0]))
        parts.push("\":\"")
        parts.push(_json_esc(kv[1]))
        parts.push("\"")
        first = false
    }
    parts.push("}")
    return parts.join("")
}

fn rules_to_json(rules: array) -> string {
    let mut parts = []
    parts.push("[")
    let mut first = true
    for r in rules {
        if !first { parts.push(",") }
        parts.push("{\"id\":\"")
        parts.push(_json_esc(r[0]))
        parts.push("\",\"status\":\"")
        parts.push(_json_esc(r[1]))
        parts.push("\",\"name\":\"")
        parts.push(_json_esc(r[2]))
        parts.push("\",\"keys\":")
        parts.push(_keys_to_json(r[3]))
        parts.push("}")
        first = false
    }
    parts.push("]")
    return parts.join("")
}

fn checkpoints_to_json(cps: array) -> string {
    let mut parts = []
    parts.push("[")
    let mut first = true
    for c in cps {
        if !first { parts.push(",") }
        parts.push("{\"id\":\"")
        parts.push(_json_esc(c[0]))
        parts.push("\",\"name\":\"")
        parts.push(_json_esc(c[1]))
        parts.push("\",\"keys\":")
        parts.push(_keys_to_json(c[2]))
        parts.push("}")
        first = false
    }
    parts.push("]")
    return parts.join("")
}

fn to_json(rules: array, cps: array) -> string {
    let mut p = []
    p.push("{\"rules\":")
    p.push(rules_to_json(rules))
    p.push(",\"checkpoints\":")
    p.push(checkpoints_to_json(cps))
    p.push("}")
    return p.join("")
}

// ─── selftest ────────────────────────────────────────────────────────
fn _home() -> string {
    let h = env("HOME")
    if h != "" { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _selftest() -> int {
    let sample = "roadmap 1 done \"first\"\n  track ssot\n  phase P0\n\ncheckpoint CP1 \"ossification\"\n  condition exec \"hexa x.hexa\"\n"
    let parsed = parse_roadmap_text(sample)
    let rules = parsed[0]
    let cps = parsed[1]
    if len(rules) != 1 {
        eprintln("selftest FAIL: expected 1 rule, got " + to_string(len(rules)))
        return 1
    }
    if rules[0][0] != "1" || rules[0][1] != "done" || rules[0][2] != "first" {
        eprintln("selftest FAIL: header parse mismatch")
        return 1
    }
    if len(cps) != 1 || cps[0][0] != "CP1" {
        eprintln("selftest FAIL: checkpoint parse mismatch")
        return 1
    }

    // real repo check — lossless parse of 3 .roadmap files
    let home = _home()
    let repos = ["anima", "airgenome", "hexa-lang"]
    let mut total = 0
    for r in repos {
        let p = home + "/core/" + r + "/.roadmap"
        let out = load_roadmap(p)
        let n = len(out[0])
        total = total + n
        println("selftest: " + r + " rules=" + to_string(n) + " checkpoints=" + to_string(len(out[1])))
    }
    if total < 80 {
        eprintln("selftest FAIL: total rules < 80 (got " + to_string(total) + ")")
        return 1
    }
    println("selftest PASS (total rules=" + to_string(total) + ")")
    return 0
}

fn main() {
    let av = argv()
    // hexa stage0 argv layout: [0]=runner, [1]=script, [2..]=user
    let mut args = []
    let mut i = 2
    while i < len(av) { args.push(av[i]); i = i + 1 }

    if len(args) == 0 {
        eprintln("usage: hexa tool/roadmap_parse.hexa <path|--selftest> [--list]")
        exit(1)
    }
    if args[0] == "--selftest" {
        let rc = _selftest()
        exit(rc)
    }

    let path = args[0]
    let out = load_roadmap(path)
    let rules = out[0]
    let cps = out[1]

    let mut list = false
    let mut j = 1
    while j < len(args) {
        if args[j] == "--list" { list = true }
        j = j + 1
    }

    if list {
        for r in rules {
            println("#" + r[0] + " [" + r[1] + "] " + r[2])
        }
        for c in cps {
            println("checkpoint " + c[0] + " — " + c[1])
        }
        return
    }
    println(to_json(rules, cps))
}
