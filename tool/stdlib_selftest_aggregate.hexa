// tool/stdlib_selftest_aggregate.hexa — ST1 (.roadmap.stdlib) closure
//
// Runs every stdlib/**/*test*.hexa via the interp and aggregates PASS /
// FAIL / TIMEOUT / ERROR per file. Output is human-readable + jsonl side.
//
// Discovery rules (additive only — no module touched):
//   1. find stdlib self/stdlib -name '*_test.hexa' -o -name 'test_*.hexa'
//   2. exclude self/stdlib/test_runner.hexa (the harness itself)
//   3. exclude files marked `// @selftest_skip` in their first 10 lines
//
// Per-file evaluation:
//   * spawn `timeout 30 hexa <file>` and capture combined output + rc
//   * output contains "FAIL"  -> FAIL
//   * rc == 0 (and no FAIL)   -> PASS
//   * rc == 124               -> TIMEOUT (GNU timeout convention)
//   * rc != 0 (other)         -> ERROR
//
// Output:
//   stdout: per-file `STATUS  Nms  path`
//   final : `# summary pass=X fail=Y timeout=Z error=W total=N`
//   side  : state/stdlib_selftest_<iso>.jsonl
//
// CI gate (future): `--strict` exits non-zero if fail+timeout+error > 0.

fn discover_tests() {
    let cmd = "find stdlib self/stdlib -type f \\( -name '*_test.hexa' -o -name 'test_*.hexa' \\) | LC_ALL=C sort"
    let raw = exec(cmd)
    let lines = raw.split("\n")
    let mut out = []
    let mut i = 0
    while i < len(lines) {
        let p = lines[i]
        if len(p) > 0 && p != "self/stdlib/test_runner.hexa" {
            let head = exec("head -10 " + p + " 2>/dev/null")
            if !head.contains("@selftest_skip") {
                out.push(p)
            }
        }
        i = i + 1
    }
    return out
}

// Wraps `cmd` so the trailing `__RC=N` exit-code marker is captured even
// when the inner command fails — exec() drops rc otherwise. Returns the
// combined stdout/stderr as a single string with the marker on last line.
fn run_capture(cmd: string) {
    let wrapped = "(" + cmd + ") 2>&1; echo \"__RC=$?\""
    return exec(wrapped)
}

fn parse_rc(combined: string) -> int {
    // Find last "__RC=N" marker; rc is the integer after `=`.
    let idx = combined.last_index_of("__RC=")
    if idx < 0 { return -1 }
    let tail = combined.substring(idx + 5, len(combined))
    let trimmed = tail.trim()
    return to_int(trimmed)
}

fn classify(rc: int, combined: string) {
    if combined.contains("FAIL") { return "FAIL" }
    if rc == 0 { return "PASS" }
    if rc == 124 { return "TIMEOUT" }
    return "ERROR"
}

fn run_one(path: string) {
    let cmd = "timeout 30 /Users/ghost/.hx/bin/hexa " + path
    let combined = run_capture(cmd)
    let rc = parse_rc(combined)
    let status = classify(rc, combined)
    // tail = first 200 chars (sans rc marker) — debug aid in jsonl
    let cut_at = combined.last_index_of("__RC=")
    let body = combined
    if cut_at > 0 { body = combined.substring(0, cut_at) }
    let max = len(body)
    if max > 200 { max = 200 }
    return #{ "path": path, "status": status, "rc": rc, "tail": body.substring(0, max) }
}

fn main() {
    let argv = args()
    let mut strict = false
    let mut ai = 0
    while ai < len(argv) {
        if argv[ai] == "--strict" { strict = true }
        ai = ai + 1
    }

    let tests = discover_tests()
    let n = len(tests)
    println("# stdlib_selftest_aggregate  found=" + to_string(n) + "  strict=" + to_string(strict))

    let mut pass = 0
    let mut fail = 0
    let mut to = 0
    let mut err = 0
    let mut records = []
    let mut i = 0
    while i < n {
        let r = run_one(tests[i])
        let s = r["status"]
        if s == "PASS"    { pass = pass + 1 }
        if s == "FAIL"    { fail = fail + 1 }
        if s == "TIMEOUT" { to   = to   + 1 }
        if s == "ERROR"   { err  = err  + 1 }
        println(s + "\t" + r["path"])
        records.push(r)
        i = i + 1
    }

    println("# summary pass=" + to_string(pass) + " fail=" + to_string(fail) + " timeout=" + to_string(to) + " error=" + to_string(err) + " total=" + to_string(n))

    let iso = exec("date -u +%Y%m%dT%H%M%SZ").trim()
    let path_out = "state/stdlib_selftest_" + iso + ".jsonl"
    let mut buf = []
    let mut j = 0
    while j < len(records) {
        let r = records[j]
        buf.push("{\"path\":\"" + r["path"] + "\",\"status\":\"" + r["status"] + "\",\"rc\":" + to_string(r["rc"]) + "}\n")
        j = j + 1
    }
    write_file(path_out, buf.join(""))
    println("# wrote " + path_out)

    if strict { if (fail + to + err) > 0 { exit(1) } }
}
