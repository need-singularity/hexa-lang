// tool/airgenome_hook.hexa — thin CLI wrapper for `airgenome hook …`
//
// PURPOSE (raw#9 hexa-only, raw#11 snake_case, raw#15 no-hardcode)
//   roadmap/verify tool 들이 airgenome 의 hook stack (hook-commands/active.json,
//   <chain>/findings.jsonl, resolved.jsonl) 과 상호작용할 때 쓸 단 하나의
//   공식 게이트웨이. airgenome 의 state 파일은 owner 가 관리하므로 여기서는
//   절대로 직접 읽거나 쓰지 않는다. 오직 `airgenome hook <sub>` subcommand 만
//   exec 한다.
//
// CLI-ONLY 제약 (핵심)
//   · 절대 .hook-commands/active.json / <chain>/findings.jsonl / resolved.jsonl
//     파일에 touch 하지 않는다 (설령 CLI가 아직 없어도 I/O 금지).
//   · airgenome 바이너리 PATH 부재 → ag_available() = false → 나머지 함수 no-op.
//   · `airgenome hook <sub>` 자체가 없는 옛 빌드 → 마찬가지로 false.
//   · 실패 시 rc != 0 + stderr 로그. 호출자는 rc 로만 분기.
//
// PUBLIC API
//   ag_available()                                        -> bool
//   ag_status()                                           -> string   (JSON)
//   ag_top_chain()                                        -> string
//   ag_touch_count(chain)                                 -> int
//   ag_activate(chain, seed, command)                     -> int      (rc)
//   ag_touch(chain, kind, payload)                        -> int      (rc)
//   ag_release(chain, reason)                             -> int      (rc)
//   ag_is_active(chain)                                   -> bool
//
// CLI
//   hexa tool/airgenome_hook.hexa --selftest
//     · ag_available() 로 가드
//     · 가능 시 activate → touch → is-active → release 스모크 시퀀스
//     · 불가 시 "airgenome CLI unavailable — wrapper no-op path OK"
//     · wrapper 자체가 정상이면 exit 0 (airgenome 부재여도 PASS)

// ───────────────────────── shell quote / exec helpers ─────────────────────────

fn _sh_quote(s: string) -> string {
    // POSIX-safe: wrap in single quotes, escape embedded single quotes.
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _exec_rc(cmd: string) -> array {
    // returns [stdout:string, rc:int]
    let r = exec_with_status(cmd)
    return [to_string(r[0]), r[1]]
}

// 2026-04-21 fork-storm fix: memoize probes. Previously each ag_* call forked
// 2× subshells (command -v + `airgenome hook status`) via ag_available(); in a
// chain cascade with M touches this yielded 2M redundant forks per process.
// The binary path and feature-availability don't change mid-process — cache.
let mut __ag_bin_cache = ""
let mut __ag_bin_probed = false
let mut __ag_avail_cache = -1   // -1=unprobed, 0=false, 1=true

fn _which_airgenome() -> string {
    if __ag_bin_probed { return __ag_bin_cache }
    // Respect caller-provided AIRGENOME_BIN override (no-hardcode, raw#15).
    let ov = env("AIRGENOME_BIN")
    if ov != "" {
        let chk = exec_with_status("test -x " + _sh_quote(ov))
        if chk[1] == 0 {
            __ag_bin_cache = ov
            __ag_bin_probed = true
            return ov
        }
        __ag_bin_cache = ""
        __ag_bin_probed = true
        return ""
    }
    let r = exec_with_status("command -v airgenome 2>/dev/null")
    if r[1] != 0 {
        __ag_bin_cache = ""
        __ag_bin_probed = true
        return ""
    }
    __ag_bin_cache = to_string(r[0]).trim()
    __ag_bin_probed = true
    return __ag_bin_cache
}

fn _ag_bin() -> string { return _which_airgenome() }

fn _warn(msg: string) -> void { eprintln("airgenome_hook: " + msg) }

// Trim trailing newline from exec captures.
fn _trim(s: string) -> string { return s.trim() }

// ───────────────────────── PUBLIC: ag_available ─────────────────────────

pub fn ag_available() -> bool {
    if __ag_avail_cache >= 0 { return __ag_avail_cache == 1 }
    let bin = _ag_bin()
    if bin == "" {
        __ag_avail_cache = 0
        return false
    }
    // Probe: `airgenome hook status` must exit 0 on a binary that has the
    // `hook` subcommand. Older builds return rc!=0 on unknown subcommand.
    let r = exec_with_status(_sh_quote(bin) + " hook status >/dev/null 2>&1")
    if r[1] == 0 {
        __ag_avail_cache = 1
        return true
    }
    __ag_avail_cache = 0
    return false
}

// ───────────────────────── PUBLIC: ag_status ─────────────────────────

pub fn ag_status() -> string {
    if !ag_available() {
        return "{\"stack\":[]}"
    }
    let r = _exec_rc(_sh_quote(_ag_bin()) + " hook status 2>/dev/null")
    if r[1] != 0 { return "{\"stack\":[]}" }
    let out = _trim(r[0])
    if out == "" { return "{\"stack\":[]}" }
    return out
}

// ───────────────────────── PUBLIC: ag_top_chain ─────────────────────────

pub fn ag_top_chain() -> string {
    if !ag_available() { return "" }
    let js = ag_status()
    // Prefer jq if available for robust JSON parse.
    let has_jq = exec_with_status("command -v jq >/dev/null 2>&1")
    if has_jq[1] == 0 {
        let cmd = "printf %s " + _sh_quote(js) + " | jq -r '.stack[0].chain // \"\"' 2>/dev/null"
        let r = _exec_rc(cmd)
        if r[1] == 0 { return _trim(r[0]) }
    }
    // jq 부재 시 CLI 재확인 경로 — state 파일은 건드리지 않음.
    let r2 = _exec_rc(_sh_quote(_ag_bin()) + " hook top-chain 2>/dev/null")
    if r2[1] == 0 { return _trim(r2[0]) }
    return ""
}

// ───────────────────────── PUBLIC: ag_touch_count ─────────────────────────

pub fn ag_touch_count(chain: string) -> int {
    if !ag_available() { return 0 }
    if chain == "" { return 0 }
    // Direct count 구현 금지 → CLI subcommand 에 위임. 없으면 0 반환 (Agent 1 과 동기화 대기).
    let cmd = _sh_quote(_ag_bin()) + " hook touch-count " + _sh_quote(chain) + " 2>/dev/null"
    let r = _exec_rc(cmd)
    if r[1] != 0 { return 0 }
    let s = _trim(r[0])
    if s == "" { return 0 }
    return to_int(s)
}

// ───────────────────────── PUBLIC: ag_activate ─────────────────────────

pub fn ag_activate(chain: string, seed: string, command: string) -> int {
    if !ag_available() {
        _warn("unavailable — ag_activate no-op (chain=" + chain + ")")
        return 0
    }
    let cmd = _sh_quote(_ag_bin()) + " hook activate " +
              _sh_quote(chain) + " " + _sh_quote(seed) + " " + _sh_quote(command)
    let r = exec_with_status(cmd)
    if r[1] != 0 { _warn("activate rc=" + to_string(r[1]) + " chain=" + chain) }
    return r[1]
}

// ───────────────────────── PUBLIC: ag_touch ─────────────────────────

pub fn ag_touch(chain: string, kind: string, payload: string) -> int {
    if !ag_available() {
        _warn("unavailable — ag_touch no-op (chain=" + chain + ")")
        return 0
    }
    let cmd = _sh_quote(_ag_bin()) + " hook touch " +
              _sh_quote(chain) + " " + _sh_quote(kind) + " " + _sh_quote(payload)
    let r = exec_with_status(cmd)
    if r[1] != 0 { _warn("touch rc=" + to_string(r[1]) + " chain=" + chain + " kind=" + kind) }
    return r[1]
}

// ───────────────────────── PUBLIC: ag_release ─────────────────────────

pub fn ag_release(chain: string, reason: string) -> int {
    if !ag_available() {
        _warn("unavailable — ag_release no-op (chain=" + chain + ")")
        return 0
    }
    let cmd = _sh_quote(_ag_bin()) + " hook release " +
              _sh_quote(chain) + " " + _sh_quote(reason)
    let r = exec_with_status(cmd)
    if r[1] != 0 { _warn("release rc=" + to_string(r[1]) + " chain=" + chain) }
    return r[1]
}

// ───────────────────────── PUBLIC: ag_is_active ─────────────────────────

pub fn ag_is_active(chain: string) -> bool {
    if !ag_available() { return false }
    if chain == "" { return false }
    let cmd = _sh_quote(_ag_bin()) + " hook is-active " + _sh_quote(chain) + " 2>/dev/null"
    let r = _exec_rc(cmd)
    if r[1] != 0 { return false }
    return _trim(r[0]) == "1"
}

// ───────────────────────── Selftest ─────────────────────────

fn _selftest() -> int {
    println("airgenome_hook: selftest BEGIN")
    let bin = _ag_bin()
    if bin == "" {
        println("  [info] airgenome binary not on PATH")
    } else {
        println("  [info] airgenome binary: " + bin)
    }

    if !ag_available() {
        println("airgenome CLI unavailable — wrapper no-op path OK")
        // Assert no-op functions are well-behaved.
        if ag_top_chain() != "" { eprintln("no-op top_chain != \"\""); return 1 }
        if ag_touch_count("any") != 0 { eprintln("no-op touch_count != 0"); return 1 }
        if ag_is_active("any") != false { eprintln("no-op is_active != false"); return 1 }
        let st = ag_status()
        if st != "{\"stack\":[]}" { eprintln("no-op status wrong: " + st); return 1 }
        // Mutators must return 0 (graceful) without touching any state file.
        if ag_activate("c0", "s0", "cmd") != 0 { eprintln("no-op activate rc!=0"); return 1 }
        if ag_touch("c0", "probe", "p") != 0 { eprintln("no-op touch rc!=0"); return 1 }
        if ag_release("c0", "selftest") != 0 { eprintln("no-op release rc!=0"); return 1 }
        println("airgenome_hook: selftest PASS (no-op path)")
        return 0
    }

    // Live smoke sequence.
    let chain = "hexa_lang_wrapper_selftest_" + _trim(to_string(exec("echo $$")))
    println("  [1/5] ag_activate(" + chain + ")")
    let rc1 = ag_activate(chain, "seed_selftest", "noop")
    if rc1 != 0 { eprintln("activate rc=" + to_string(rc1)); return 1 }

    println("  [2/5] ag_touch(" + chain + ", probe)")
    let rc2 = ag_touch(chain, "probe", "{\"selftest\":true}")
    if rc2 != 0 { eprintln("touch rc=" + to_string(rc2)); return 1 }

    println("  [3/5] ag_is_active(" + chain + ")")
    if !ag_is_active(chain) {
        eprintln("expected is-active=true after activate")
        // best-effort cleanup before failing
        let _ = ag_release(chain, "selftest_cleanup_fail")
        return 1
    }

    println("  [4/5] ag_top_chain() sanity")
    let top = ag_top_chain()
    println("        top=" + top)

    println("  [5/5] ag_release(" + chain + ")")
    let rc3 = ag_release(chain, "selftest_done")
    if rc3 != 0 { eprintln("release rc=" + to_string(rc3)); return 1 }

    println("airgenome_hook: selftest PASS (live path)")
    return 0
}

fn main() {
    let av = argv()
    let mut args = []
    let mut i = 2
    while i < len(av) { args.push(av[i]); i = i + 1 }

    if len(args) == 0 {
        // Default: print availability + top-chain for quick introspection.
        if ag_available() {
            println("airgenome_hook: available")
            println("  top_chain=" + ag_top_chain())
            println("  status=" + ag_status())
        } else {
            println("airgenome_hook: unavailable (wrapper operating in no-op mode)")
        }
        exit(0)
    }

    let cmd = args[0]
    if cmd == "--selftest" || cmd == "selftest" { exit(_selftest()) }
    if cmd == "--available" { if ag_available() { exit(0) } else { exit(1) } }
    if cmd == "status" { println(ag_status()); exit(0) }
    if cmd == "top-chain" { println(ag_top_chain()); exit(0) }

    eprintln("usage: hexa tool/airgenome_hook.hexa [--selftest|--available|status|top-chain]")
    exit(2)
}
