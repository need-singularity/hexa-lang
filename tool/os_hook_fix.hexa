// tool/os_hook_fix.hexa — #16 hexa interp deadlock detector + auto-release
//
// PURPOSE (raw#9 strict, hexa-only, deterministic)
//   The canonical `hexa_interp` shim serializes all compiles through a single
//   mkdir-lock at /tmp/hexa_interp.lock.d. A hung / crashed holder leaves the
//   dir behind; callers then block up to LOCK_WAIT_SECS (default 300s). In
//   multi-agent environments (airgenome + nexus + hexa-lang hooks fired back-
//   to-back) this surfaces as a full deadlock.
//
// ROOT-CAUSE REPAIR (deterministic, minimal):
//   1. Read /tmp/hexa_interp.lock.d/pid.
//   2. If holder PID is no longer alive  → `rm -rf` the lock dir (stale reap).
//   3. If holder is alive AND older than HEXA_STAGE0_LOCK_HANG_SECS (default 60s),
//      AND the process is in 'S' or 'D' state with zero child activity for the
//      last 10s → declare HUNG and force-release with audit trail.
//   4. Emit a JSON report on stdout so callers (roadmap_watcher, pre-commit
//      wrappers) can decide whether to re-invoke with direct interp.real bypass.
//
// CLI
//   os_hook_fix.hexa                — run one diagnostic pass, report JSON.
//   os_hook_fix.hexa --release      — same as default but will actually remove
//                                     stale/hung locks (default is diagnose-only).
//   os_hook_fix.hexa --fallback-run <tool.hexa> [args...]
//                                   — run a hexa tool DIRECTLY via
//                                     hexa_interp.real with HEXA_STAGE0_NO_CAP=1
//                                     (absolute lock bypass). Used by other
//                                     Tier-2 tools in this family when they
//                                     must run inside a commit hook.
//   os_hook_fix.hexa --selftest     — simulate a stale-lock (dead PID) and a
//                                     self-held lock, verify reap + release.
//
// EXITS
//   0 — diagnostic pass complete (or selftest PASS).
//   1 — selftest FAIL, or --fallback-run inner tool returned non-zero.
//
// SAFETY
//   * Only the /tmp/hexa_interp.lock.d path is ever touched.
//   * Never kills another process — only reaps lock directories.
//   * Force-release of a live-but-hung PID requires BOTH staleness (age>threshold)
//     AND two consecutive ps snapshots showing zero delta in state column.
//     This avoids interrupting an ordinary long compile.

fn _now_epoch() -> int {
    let s = to_string(exec("date +%s 2>/dev/null")).trim()
    if len(s) == 0 { return 0 }
    return to_int(s)
}

fn _lock_dir() -> string {
    // Allow override for selftest / unit test isolation.
    let ov = env("HEXA_STAGE0_LOCK_DIR_OVERRIDE")
    if ov != "" { return ov }
    return "/tmp/hexa_interp.lock.d"
}
fn _interp_real() -> string { return env("HOME") + "/.hx/packages/hexa/build/hexa_interp.real" }

fn _lock_exists() -> bool {
    let r = exec_with_status("test -d '" + _lock_dir() + "'")
    return r[1] == 0
}

fn _lock_holder_pid() -> string {
    let p = _lock_dir() + "/pid"
    let r = exec_with_status("test -f '" + p + "'")
    if r[1] != 0 { return "" }
    return to_string(read_file(p)).trim()
}

fn _pid_alive(pid: string) -> bool {
    if pid == "" { return false }
    let r = exec_with_status("kill -0 " + pid + " 2>/dev/null")
    return r[1] == 0
}

// Returns epoch-seconds at which the lock directory was created (mtime of
// /tmp/hexa_interp.lock.d — OS preserves this across sleep/wake).
fn _lock_mtime_epoch() -> int {
    let cmd = "stat -f %m '" + _lock_dir() + "' 2>/dev/null"
    let s = to_string(exec(cmd)).trim()
    if s == "" {
        // linux fallback
        let cmd2 = "stat -c %Y '" + _lock_dir() + "' 2>/dev/null"
        let s2 = to_string(exec(cmd2)).trim()
        if s2 == "" { return 0 }
        return to_int(s2)
    }
    return to_int(s)
}

fn _pid_state(pid: string) -> string {
    if pid == "" { return "" }
    let cmd = "ps -p " + pid + " -o stat= 2>/dev/null"
    return to_string(exec(cmd)).trim()
}

fn _pid_cpu(pid: string) -> string {
    if pid == "" { return "" }
    let cmd = "ps -p " + pid + " -o %cpu= 2>/dev/null"
    return to_string(exec(cmd)).trim()
}

fn _hang_threshold_secs() -> int {
    let s = env("HEXA_STAGE0_LOCK_HANG_SECS")
    if s == "" { return 60 }
    let n = to_int(s)
    if n <= 0 { return 60 }
    return n
}

// Atomic-ish force-release. Double-checks caller-visible state before rm.
fn _force_release(reason: string) -> bool {
    let before = _lock_exists()
    if !before { return true }
    let r = exec_with_status("rm -rf '" + _lock_dir() + "' 2>/dev/null")
    let after = _lock_exists()
    if after {
        eprintln("os_hook_fix: force-release FAILED (still present): " + reason)
        return false
    }
    println("os_hook_fix: lock released (" + reason + ")")
    return true
}

// ---- Diagnostic result builder ----

fn _diagnose() -> array {
    // returns [state:string, pid:string, age_s:int, hung:bool]
    if !_lock_exists() { return ["clear", "", 0, false] }
    let pid = _lock_holder_pid()
    if pid == "" {
        // No pid file but lock dir present → definitely stale.
        return ["stale-nopid", "", 0, false]
    }
    let alive = _pid_alive(pid)
    let age = _now_epoch() - _lock_mtime_epoch()
    if !alive {
        return ["stale-dead", pid, age, false]
    }
    let thr = _hang_threshold_secs()
    if age < thr {
        return ["healthy", pid, age, false]
    }
    // Alive + old. Sample state twice 1s apart. Both samples must have CPU=0
    // AND state=="S" / "D" / "T" / "I" (sleeping/uninterruptible/stopped/idle)
    // → flag hung.
    let st1 = _pid_state(pid)
    let cpu1 = _pid_cpu(pid)
    let _ = exec_with_status("sleep 1")
    let st2 = _pid_state(pid)
    let cpu2 = _pid_cpu(pid)
    let sleepy = st1 != "" && st2 != "" &&
                 (st1.substring(0,1) == "S" || st1.substring(0,1) == "D" ||
                  st1.substring(0,1) == "T" || st1.substring(0,1) == "I") &&
                 (st2.substring(0,1) == "S" || st2.substring(0,1) == "D" ||
                  st2.substring(0,1) == "T" || st2.substring(0,1) == "I")
    let idle_cpu = cpu1 == "0.0" && cpu2 == "0.0"
    if sleepy && idle_cpu {
        return ["hung", pid, age, true]
    }
    return ["busy", pid, age, false]
}

fn _emit_json(state: string, pid: string, age: int, hung: bool, released: bool) -> void {
    let mut p = []
    p.push("{\"lock_state\":\"")
    p.push(state)
    p.push("\",\"holder_pid\":\"")
    p.push(pid)
    p.push("\",\"age_s\":")
    p.push(to_string(age))
    p.push(",\"hung\":")
    if hung { p.push("true") } else { p.push("false") }
    p.push(",\"released\":")
    if released { p.push("true") } else { p.push("false") }
    p.push("}")
    println(p.join(""))
}

// ---- Selftest ----

// Inline-path equivalents of the diagnose/release logic that operate on an
// explicit directory, used only by the selftest to avoid colliding with the
// real /tmp/hexa_interp.lock.d that a parent compile might hold.
fn _diag_at(dir: string) -> string {
    let chk = exec_with_status("test -d '" + dir + "'")
    if chk[1] != 0 { return "clear" }
    let pid_file = dir + "/pid"
    let chk2 = exec_with_status("test -f '" + pid_file + "'")
    if chk2[1] != 0 { return "stale-nopid" }
    let pid = to_string(read_file(pid_file)).trim()
    if pid == "" { return "stale-nopid" }
    let alive = exec_with_status("kill -0 " + pid + " 2>/dev/null")
    if alive[1] != 0 { return "stale-dead" }
    return "live"
}

fn _force_release_at(dir: string, reason: string) -> bool {
    let before = exec_with_status("test -d '" + dir + "'")
    if before[1] != 0 { return true }
    let _ = exec_with_status("rm -rf '" + dir + "' 2>/dev/null")
    let after = exec_with_status("test -d '" + dir + "'")
    if after[1] == 0 {
        eprintln("os_hook_fix: force-release FAILED (still present): " + reason)
        return false
    }
    println("os_hook_fix: lock released (" + reason + ")")
    return true
}

fn _selftest() -> int {
    println("os_hook_fix: selftest BEGIN")
    // Use an isolated test lock path so we do not collide with any real
    // interp compile happening in parallel (e.g. installer-driven selftest).
    let test_lock = "/tmp/hexa_interp_selftest_" + to_string(exec("echo $$")).trim() + ".d"
    let _ = exec_with_status("rm -rf '" + test_lock + "' 2>/dev/null")

    // 1. Clear state.
    if _diag_at(test_lock) != "clear" {
        eprintln("selftest FAIL: expected clear state")
        return 1
    }
    println("  [1/4] clear state  → OK")

    // 2. Simulate stale-dead lock (PID 999999 out of range on macOS).
    let _ = exec_with_status("mkdir -p '" + test_lock + "' && echo 999999 > '" + test_lock + "/pid'")
    if _diag_at(test_lock) != "stale-dead" {
        eprintln("selftest FAIL: expected stale-dead detection")
        let _x = exec_with_status("rm -rf '" + test_lock + "'")
        return 1
    }
    println("  [2/4] stale-dead detected  → OK")

    // 3. Force-release the stale-dead lock.
    if !_force_release_at(test_lock, "selftest-stale-dead") {
        eprintln("selftest FAIL: could not release stale-dead lock")
        return 1
    }
    println("  [3/4] stale-dead released  → OK")

    // 4. After release, state is clear.
    if _diag_at(test_lock) != "clear" {
        eprintln("selftest FAIL: lock not cleared after release")
        return 1
    }
    println("  [4/4] final state clear  → OK")

    // Also verify the public _diagnose() path does not crash on the real lock
    // (whose state may be any of clear/live/stale depending on environment).
    let d_real = _diagnose()
    let state = d_real[0]
    let allowed = state == "clear" || state == "healthy" || state == "busy" ||
                  state == "stale-nopid" || state == "stale-dead" || state == "hung"
    if !allowed {
        eprintln("selftest FAIL: real-lock diagnose returned unknown state: " + state)
        return 1
    }
    println("  [extra] real-lock diagnose ok (state=" + state + ")")

    println("os_hook_fix: selftest PASS")
    return 0
}

// ---- Fallback-run: execute a .hexa tool bypassing the interp lock entirely ----
fn _fallback_run(args: array) -> int {
    if len(args) < 1 {
        eprintln("os_hook_fix: --fallback-run needs <tool.hexa>")
        return 1
    }
    let tool = args[0]
    let chk = exec_with_status("test -f '" + tool + "'")
    if chk[1] != 0 {
        eprintln("os_hook_fix: tool not found: " + tool)
        return 1
    }
    let interp = _interp_real()
    let chk2 = exec_with_status("test -x '" + interp + "'")
    if chk2[1] != 0 {
        eprintln("os_hook_fix: hexa_interp.real not executable: " + interp)
        return 1
    }
    // Build argv: env prefix + interp + tool + passthrough args
    let mut cmd_parts = []
    cmd_parts.push("HEXA_STAGE0_NO_CAP=1 HEXA_LOCAL=1 HEXA_LOCAL_NO_CAP=1 ")
    cmd_parts.push("'")
    cmd_parts.push(interp)
    cmd_parts.push("' '")
    cmd_parts.push(tool)
    cmd_parts.push("'")
    let mut i = 1
    while i < len(args) {
        cmd_parts.push(" '")
        cmd_parts.push(args[i].replace("'", "'\\''"))
        cmd_parts.push("'")
        i = i + 1
    }
    let cmd = cmd_parts.join("")
    let r = exec_with_status(cmd)
    // stdout is already echoed by the subprocess via exec_with_status? No — it
    // captures. Print captured output for callers.
    print(to_string(r[0]))
    return r[1]
}

fn main() -> int {
    let av = argv()
    let mut do_release = false
    let mut do_selftest = false
    let mut do_fallback = false
    let mut fb_args = []
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--release" { do_release = true }
        else if a == "--selftest" { do_selftest = true }
        else if a == "--fallback-run" {
            do_fallback = true
            let mut j = i + 1
            while j < len(av) { fb_args.push(av[j]); j = j + 1 }
            break
        }
        i = i + 1
    }

    if do_selftest { return _selftest() }
    if do_fallback { return _fallback_run(fb_args) }

    let d = _diagnose()
    let state = d[0]
    let pid = d[1]
    let age = d[2]
    let hung = d[3]

    let mut released = false
    if do_release {
        if state == "stale-nopid" || state == "stale-dead" || state == "hung" {
            released = _force_release(state)
        }
    }

    _emit_json(state, pid, age, hung, released)
    return 0
}
