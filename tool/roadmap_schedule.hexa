// roadmap_schedule.hexa — CPM + RCPSP + b* (thin wrapper)
// @no-lock-needed
// @allow-bare-exec
// @no-sandbox
//
// 역할: roadmap_engine 의 schedule 단계만 JSON dispatch plan 으로 출력.
//       b* (dominant bottleneck) + T* + η + ready set + replan flag.
//
// CLI
//   hexa run roadmap_schedule.hexa <roadmap.json> [--events=<out>]
//
// 구현: roadmap_engine.hexa --dispatch 에 위임 (동일 로직, 재구현 회피).
//
// exit: 0 OK / 1 engine error / 2 usage

let HOME = env("HOME")
let HEXA_LANG = HOME + "/core/hexa-lang"
let ENGINE = HEXA_LANG + "/tool/roadmap_engine.hexa"
let HEXA = HEXA_LANG + "/hexa"

fn _str(x) -> string {
    let t = type_of(x)
    if t == "str" || t == "string" { return x }
    return ""
}

fn cmd_selftest() -> i64 {
    println("[roadmap_schedule selftest]")
    // 1) _str coercion
    if _str("x") != "x" { eprintln("FAIL: _str identity"); return 1 }
    if _str(0).len() != 0 { eprintln("FAIL: _str void → empty"); return 1 }
    // 2) ENGINE path resolves to roadmap_engine.hexa (thin-wrapper invariant)
    if ENGINE.ends_with("/tool/roadmap_engine.hexa") == false {
        eprintln("FAIL: ENGINE path invariant: " + ENGINE); return 1
    }
    // 3) HEXA binary path well-formed
    if HEXA.ends_with("/hexa") == false {
        eprintln("FAIL: HEXA path invariant: " + HEXA); return 1
    }
    println("[roadmap_schedule selftest] OK")
    return 0
}

fn main() {
    // argv 정규화 (2026-04-19): Mac=[hexa, script, user...] Linux-dispatch=[hexa, "run", script, user...]
    // 이전까지 Mac-only argv[2] 가정 → Linux 에서 argv[2] = script path 로 dispatch 실패.
    let _raw_argv = args()
    let mut _script_idx = -1
    let mut _scan_i = 0
    while _scan_i < _raw_argv.len() {
        if _raw_argv[_scan_i].ends_with(".hexa") { _script_idx = _scan_i; break }
        _scan_i = _scan_i + 1
    }
    let mut _user_start = 2
    let mut _script_token = ""
    if _script_idx >= 0 {
        _user_start = _script_idx + 1
        _script_token = _raw_argv[_script_idx]
    } else {
        if _raw_argv.len() >= 3 {
            if _raw_argv[1] == "run" { _user_start = 3 }
            if _raw_argv[1] == "eval" { _user_start = 3 }
        }
    }
    let mut argv: [str] = [_raw_argv[0], _script_token]
    let mut _ua_i = _user_start
    while _ua_i < _raw_argv.len() {
        argv = argv + [_raw_argv[_ua_i]]
        _ua_i = _ua_i + 1
    }
    if _script_token.len() > 0 && argv.len() >= 3 {
        if argv[2] == _script_token {
            let mut _a2: [str] = [_raw_argv[0], _script_token]
            let mut _j2 = 3
            while _j2 < argv.len() {
                _a2 = _a2 + [argv[_j2]]
                _j2 = _j2 + 1
            }
            argv = _a2
        }
    }
    let mut a: [string] = []
    let mut ai: i64 = 2
    while ai < argv.len() { a = a.push(_str(argv[ai])); ai = ai + 1 }

    if a.len() == 0 {
        eprintln("usage: roadmap_schedule <roadmap.json> [--events=<out>] | --selftest")
        exit(2)
    }
    let first = _str(a[0])
    if first == "--selftest" || first == "selftest" { exit(cmd_selftest()) }
    let path = first
    let mut extra = ""
    let mut k: i64 = 1
    while k < a.len() {
        extra = extra + " " + _str(a[k])
        k = k + 1
    }

    let cmd = HEXA + " run " + ENGINE + " " + path + " --dispatch" + extra + " 2>&1"
    let out = _str(exec(cmd))  // @allow-bare-exec
    print(out)
    if out.contains("REJECT") { exit(1) }
    exit(0)
}

main()
