// tool/bounded_loop_lint.hexa — RFC-010 (d) bounded-for + decreases-while lint.
//
// Stage 0 lint that checks two complementary things:
//   B1  unbounded_for      — `for x in iter`/`for x in stream(...)` where iter
//                            is not a const range, not `.take(N)`, not a known
//                            bounded helper. Heuristic; accepts:
//                              - 0..N / 1..N / a..b
//                              - <expr>.take(<n>)
//                              - <const-array literal>
//   B2  while_no_decreases — `while <cond>` body without a `// decreases`
//                            comment within 5 preceding lines, AND condition
//                            is not a clear monotonic comparison (`< > <= >=`)
//                            with an obvious mutated variable in the body.
//
// Conservative — Stage 0 warning only. Ignores `while true` (R1 of
// runaway_pattern_lint.hexa already flags those), and ignores `do ... while`
// pattern (rare in hexa). `@budget(cpu=…, mem=…, allocs=…)` is recognized as
// metadata (no enforcement yet — RFC-010 follow-on).
//
// Usage:
//   hexa run tool/bounded_loop_lint.hexa --selftest
//   hexa run tool/bounded_loop_lint.hexa --mode=warn  <file.hexa>...
//   hexa run tool/bounded_loop_lint.hexa --mode=error <file.hexa>...

fn _bl_is_digit(c) {
    let k = char_code(c, 0); return k >= 48 && k <= 57
}
fn _bl_is_alpha(c) {
    let k = char_code(c, 0); return (k >= 97 && k <= 122) || (k >= 65 && k <= 90) || (k == 95)
}
fn _bl_is_alnum(c) { return _bl_is_digit(c) || _bl_is_alpha(c) }
fn _bl_is_ws(c) { return c == " " || c == "\t" || c == "\r" }

fn _bl_strip(src) {
    let n = len(src)
    let mut i = 0
    let mut parts = []
    while i < n {
        let c = src[i]
        if c == "/" && i + 1 < n && src[i + 1] == "/" {
            while i < n && src[i] != "\n" { parts.push(" "); i = i + 1 }
        } else if c == "/" && i + 1 < n && src[i + 1] == "*" {
            parts.push("  "); i = i + 2
            while i + 1 < n && !(src[i] == "*" && src[i + 1] == "/") {
                if src[i] == "\n" { parts.push("\n") } else { parts.push(" ") }
                i = i + 1
            }
            if i + 1 < n { parts.push("  "); i = i + 2 }
        } else if c == "\"" {
            parts.push(c); i = i + 1
            while i < n && src[i] != "\"" {
                if src[i] == "\\" && i + 1 < n {
                    parts.push(" "); i = i + 1
                    if src[i] == "\n" { parts.push("\n") } else { parts.push(" ") }
                    i = i + 1
                } else {
                    if src[i] == "\n" { parts.push("\n") } else { parts.push(" ") }
                    i = i + 1
                }
            }
            if i < n { parts.push(src[i]); i = i + 1 }
        } else {
            parts.push(c); i = i + 1
        }
    }
    return parts.join("")
}

fn _bl_match_word(src, i, word) {
    let n = len(src)
    let wlen = len(word)
    if i + wlen > n { return 0 }
    if src.substring(i, i + wlen) != word { return 0 }
    if i > 0 && _bl_is_alnum(src[i - 1]) { return 0 }
    if i + wlen < n && _bl_is_alnum(src[i + wlen]) { return 0 }
    return wlen
}

fn _bl_line_of(src, idx) {
    let mut i = 0; let mut line = 1
    while i < idx && i < len(src) {
        if src[i] == "\n" { line = line + 1 }; i = i + 1
    }
    return line
}

fn _bl_has_decreases_witness(orig, line_no) {
    let n = len(orig)
    let mut i = 0; let mut cur_line = 1
    while i < n && cur_line < line_no {
        if orig[i] == "\n" { cur_line = cur_line + 1 }; i = i + 1
    }
    let line_start = i
    let mut back = line_start; let mut steps = 0
    while back > 0 && steps < 6 {
        back = back - 1
        if orig[back] == "\n" { steps = steps + 1 }
    }
    let mut eol = line_start
    while eol < n && orig[eol] != "\n" { eol = eol + 1 }
    let region = orig.substring(back, eol)
    if region.contains("// decreases") { return true }
    if region.contains("@bounded") { return true }
    if region.contains("@budget") { return true }
    if region.contains("@partial") { return true }
    return false
}

// B1 — unbounded for: `for x in <expr>` where <expr> is not bounded.
fn _bl_find_b1(orig, clean) {
    let n = len(clean)
    let mut out = []
    let mut i = 0
    while i < n {
        let flen = _bl_match_word(clean, i, "for")
        if flen > 0 {
            let mut j = i + flen
            while j < n && _bl_is_ws(clean[j]) { j = j + 1 }
            // expect identifier (loop var) then "in"
            let var_start = j
            while j < n && _bl_is_alnum(clean[j]) { j = j + 1 }
            let var_end = j
            if var_end > var_start {
                while j < n && _bl_is_ws(clean[j]) { j = j + 1 }
                let ilen = _bl_match_word(clean, j, "in")
                if ilen > 0 {
                    j = j + ilen
                    while j < n && _bl_is_ws(clean[j]) { j = j + 1 }
                    // collect iter expr until `{` at depth 0
                    let iter_start = j
                    let mut paren_depth = 0
                    while j < n {
                        let c = clean[j]
                        if c == "(" { paren_depth = paren_depth + 1 }
                        else if c == ")" { paren_depth = paren_depth - 1 }
                        else if c == "{" && paren_depth == 0 { break }
                        j = j + 1
                    }
                    if j < n && clean[j] == "{" {
                        let iter_expr = clean.substring(iter_start, j)
                        let line_no = _bl_line_of(clean, i)
                        // Bounded if any of: contains `..` (range), `.take(`,
                        // starts with `[` (array literal), is bare identifier
                        // referring to an array (we can't statically resolve;
                        // treat single-ident with parens as call → unbounded;
                        // treat single-ident without parens as bounded).
                        let bounded = iter_expr.contains("..")
                                     || iter_expr.contains(".take(")
                                     || iter_expr.contains(".keys()")
                                     || iter_expr.contains(".values()")
                                     || iter_expr.contains(".entries()")
                                     || iter_expr.contains(".chars()")
                                     || iter_expr.contains(".enumerate()")
                                     || iter_expr.contains(".filter(")
                                     || iter_expr.contains(".items()")
                                     || iter_expr.contains("[")
                                     // AST/node field access — `node.items` /
                                     // `node.handlers` / `node.elements` etc.
                                     // are bounded by the AST structure (a node
                                     // has finite child arrays).
                                     || iter_expr.contains(".items")
                                     || iter_expr.contains(".handlers")
                                     || iter_expr.contains(".elements")
                                     || iter_expr.contains(".args")
                                     || iter_expr.contains(".parts")
                                     || iter_expr.contains(".body")
                                     || iter_expr.contains(".params")
                                     || iter_expr.contains(".fields")
                                     || iter_expr.contains(".cases")
                                     || iter_expr.contains(".branches")
                                     || _bl_iter_is_bare_ident(iter_expr)
                        if !bounded && !_bl_has_decreases_witness(orig, line_no) {
                            out.push([line_no, "B1", "for ... in <unbounded?> — add @bounded / .take(N) / // decreases"])
                        }
                    }
                    i = j + 1
                    continue
                }
            }
            i = i + flen
            continue
        }
        i = i + 1
    }
    return out
}

fn _bl_iter_is_bare_ident(s) {
    // A bare identifier (no parens, no operators) is treated as bounded —
    // typically an array variable. Whitespace tolerated.
    let n = len(s)
    let mut p = 0
    while p < n && _bl_is_ws(s[p]) { p = p + 1 }
    let start = p
    while p < n && _bl_is_alnum(s[p]) { p = p + 1 }
    let end = p
    if end == start { return false }
    while p < n && _bl_is_ws(s[p]) { p = p + 1 }
    if p == n { return true }
    return false
}

// B2 — `while <cond>` body without a // decreases neighbor and the cond is
//      not a monotonic-comparison shape (already caught upstream by R3).
//      We only flag bodies of length > 50 and < 1000 to limit churn.
fn _bl_find_b2(orig, clean) {
    let n = len(clean)
    let mut out = []
    let mut i = 0
    while i < n {
        let wlen = _bl_match_word(clean, i, "while")
        if wlen > 0 {
            let mut j = i + wlen
            while j < n && _bl_is_ws(clean[j]) { j = j + 1 }
            let cond_start = j
            let mut paren_depth = 0
            while j < n {
                let c = clean[j]
                if c == "(" { paren_depth = paren_depth + 1 }
                else if c == ")" { paren_depth = paren_depth - 1 }
                else if c == "{" && paren_depth == 0 { break }
                j = j + 1
            }
            if j < n && clean[j] == "{" {
                let cond_txt = clean.substring(cond_start, j)
                let monotonic = cond_txt.contains("<") || cond_txt.contains(">")
                            || cond_txt.contains("!=")
                            // Parser/lexer queries: cond is a pure read; the body
                            // advances the token stream. Treat as monotonic.
                            || cond_txt.contains("p_at_end") || cond_txt.contains("p_eof")
                            || cond_txt.contains("p_check") || cond_txt.contains("p_match")
                            || cond_txt.contains("p_peek") || cond_txt.contains("peek_")
                            || cond_txt.contains("p_eat") || cond_txt.contains("p_consume")
                            || cond_txt.contains("p_kind") || cond_txt.contains("p_advance")
                            || cond_txt.contains("p_current") || cond_txt.contains("p_token")
                            // AST-walk traversal helpers.
                            || cond_txt.contains("type_of(")
                            || cond_txt.contains(".next") || cond_txt.contains(".left")
                            || cond_txt.contains(".right") || cond_txt.contains(".parent")
                            // pure-helper bool queries
                            || cond_txt.contains(" has_") || cond_txt.contains("!has_")
                            || cond_txt.contains(" is_") || cond_txt.contains("!is_")
                            || cond_txt.contains("contains")
                if !monotonic {
                    let line_no = _bl_line_of(clean, i)
                    if !_bl_has_decreases_witness(orig, line_no) {
                        out.push([line_no, "B2", "while <non-monotonic> — add // decreases <expr> or @partial"])
                    }
                }
            }
            i = i + wlen
            continue
        }
        i = i + 1
    }
    return out
}

fn _bl_lint_text(orig) {
    let clean = _bl_strip(orig)
    let v1 = _bl_find_b1(orig, clean)
    let v2 = _bl_find_b2(orig, clean)
    let mut all = []
    let mut k = 0
    while k < len(v1) { all.push(v1[k]); k = k + 1 }
    k = 0
    while k < len(v2) { all.push(v2[k]); k = k + 1 }
    return all
}

fn _bl_lint_file(path, mode) {
    let src = read_file(path)
    let v = _bl_lint_text(src)
    let mut k = 0
    let mut surviving = 0
    while k < len(v) {
        let row = v[k]
        // Final witness check — same suppression rule as runaway_pattern_lint:
        // any ±5-line // decreases / @total / @partial neighbor clears the hit.
        if !_bl_has_decreases_witness(src, row[0]) {
            let label = if mode == "error" { "error" } else { "warn " }
            println(path + ":" + to_string(row[0]) + ": [" + label + " " + row[1] + " bounded-loop-lint] " + row[2])
            surviving = surviving + 1
        }
        k = k + 1
    }
    return surviving
}

fn cmd_bl_selftest() -> i64 {
    println("[bounded_loop_lint selftest]")

    // B1 bad — for x in stream(...)
    let bad1 = "fn f() { for x in stream() { handle(x) } }\n"
    let v1 = _bl_lint_text(bad1)
    let mut got_b1 = 0
    let mut q = 0
    while q < len(v1) { if v1[q][1] == "B1" { got_b1 = got_b1 + 1 }; q = q + 1 }
    if got_b1 != 1 {
        println("[bounded_loop_lint selftest] FAIL B1 bad: expected 1 got " + to_string(got_b1))
        return 1
    }

    // B1 good — for i in 0..n
    let good1 = "fn f() { for i in 0..n { handle(i) } }\n"
    let v_g1 = _bl_lint_text(good1)
    q = 0; let mut g1 = 0
    while q < len(v_g1) { if v_g1[q][1] == "B1" { g1 = g1 + 1 }; q = q + 1 }
    if g1 != 0 {
        println("[bounded_loop_lint selftest] FAIL B1 good 0..n: expected 0 got " + to_string(g1))
        return 1
    }

    // B1 good — for x in arr.take(10)
    let good2 = "fn f() { for x in stream().take(10) { handle(x) } }\n"
    let v_g2 = _bl_lint_text(good2)
    q = 0; let mut g2 = 0
    while q < len(v_g2) { if v_g2[q][1] == "B1" { g2 = g2 + 1 }; q = q + 1 }
    if g2 != 0 {
        println("[bounded_loop_lint selftest] FAIL B1 good .take: expected 0 got " + to_string(g2))
        return 1
    }

    // B1 good — for x in items (bare ident)
    let good3 = "fn f() { for x in items { handle(x) } }\n"
    let v_g3 = _bl_lint_text(good3)
    q = 0; let mut g3 = 0
    while q < len(v_g3) { if v_g3[q][1] == "B1" { g3 = g3 + 1 }; q = q + 1 }
    if g3 != 0 {
        println("[bounded_loop_lint selftest] FAIL B1 good bare: expected 0 got " + to_string(g3))
        return 1
    }

    // B2 bad — while x.is_locked() { yield_now() }
    let bad2 = "fn f() { while x.is_locked() { yield_now() } }\n"
    let v_b2 = _bl_lint_text(bad2)
    q = 0; let mut got_b2 = 0
    while q < len(v_b2) { if v_b2[q][1] == "B2" { got_b2 = got_b2 + 1 }; q = q + 1 }
    if got_b2 != 1 {
        println("[bounded_loop_lint selftest] FAIL B2 bad: expected 1 got " + to_string(got_b2))
        return 1
    }

    // B2 good — // decreases neighbor
    let good_b2 = "// decreases x.depth\nfn f() { while x.is_locked() { yield_now() } }\n"
    let v_gb2 = _bl_lint_text(good_b2)
    q = 0; let mut gb2 = 0
    while q < len(v_gb2) { if v_gb2[q][1] == "B2" { gb2 = gb2 + 1 }; q = q + 1 }
    if gb2 != 0 {
        println("[bounded_loop_lint selftest] FAIL B2 good: expected 0 got " + to_string(gb2))
        return 1
    }

    println("[bounded_loop_lint selftest] OK")
    return 0
}

fn _bl_print_usage() {
    println("usage: hexa run tool/bounded_loop_lint.hexa [--mode=warn|error] <file.hexa>...")
    println("       hexa run tool/bounded_loop_lint.hexa --selftest")
}

fn main() {
    let argv = args()
    let mut mode = "warn"
    let mut do_selftest = false
    let mut files = []
    let mut i = 0
    while i < len(argv) {
        let a = argv[i]
        if a == "--selftest" || a == "selftest" { do_selftest = true }
        else if a.substring(0, 7) == "--mode=" { mode = a.substring(7, len(a)) }
        else if a == "--mode" { i = i + 1; if i < len(argv) { mode = argv[i] } }
        else if i > 0 && a.substring(0, 2) != "--" && !a.contains("bounded_loop_lint") {
            files.push(a)
        }
        i = i + 1
    }
    if do_selftest { exit(cmd_bl_selftest()) }
    if len(files) == 0 { _bl_print_usage(); return }
    let mut total = 0
    let mut k = 0
    while k < len(files) {
        try { total = total + _bl_lint_file(files[k], mode) }
        catch e { println(files[k] + ": [lint error] " + e) }
        k = k + 1
    }
    if total > 0 {
        println("")
        println("bounded-loop-lint: " + to_string(total) + " violations [mode=" + mode + "]")
        if mode == "error" { exit(1) }
    } else {
        println("bounded-loop-lint: CLEAN")
    }
}
