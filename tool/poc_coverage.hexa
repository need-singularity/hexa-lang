// tool/poc_coverage.hexa
//
// POC handler coverage report — how much of hexa's canonical AST
// (per doc/grammar.jsonl) does self/poc/{expr,stmt}/ cover?
//
// Schema:
//   grammar.jsonl contains spec entries with "section": "expressions"
//   and "section": "statements", each carrying a "variants": [...]
//   array of items like "IntLit(i64)", "Binary(Expr,BinOp,Expr)",
//   "Let(name,type?,init?,vis)". We extract the leading identifier.
//
//   self/poc/<cat>/<snake>.hexa line 2 is `// @kinds Foo[, Bar, ...]`.
//
// Coverage = implemented ∩ grammar  vs  grammar total.
//   missing = grammar \ implemented   (what we still need to build)
//   orphan  = implemented \ grammar   (typos or hexa-specific custom kinds)
//
// Always exits 0 — this is a report, not a gate.
//
// Usage: hexa tool/poc_coverage.hexa

let GRAMMAR_PATH = "doc/grammar.jsonl"
let CATS = ["expr", "stmt"]

fn strip(s) {
    let mut i = 0
    while i < len(s) && (s[i] == " " || s[i] == "\t") { i = i + 1 }
    let mut j = len(s) - 1
    while j >= i && (s[j] == " " || s[j] == "\t" || s[j] == "\r" || s[j] == "\n") { j = j - 1 }
    let mut out = ""
    let mut k = i
    while k <= j { out = out + s[k]; k = k + 1 }
    return out
}

fn starts_with(s, p) { return s.starts_with(p) }

fn contains(haystack, needle) { return haystack.contains(needle) }

fn split_by_comma(s) {
    let mut out = []
    let mut cur = ""
    let mut i = 0
    while i < len(s) {
        if s[i] == "," { out.push(strip(cur)); cur = "" } else { cur = cur + s[i] }
        i = i + 1
    }
    let last = strip(cur)
    if last != "" { out.push(last) }
    return out
}

fn list_dir_hexa(dir) {
    let raw = exec("ls " + dir + "/*.hexa 2>/dev/null")
    if raw == "" { return [] }
    let lines = raw.split("\n")
    let mut out = []
    let mut i = 0
    while i < len(lines) {
        let s = strip(lines[i])
        if s != "" { out.push(s) }
        i = i + 1
    }
    return out
}

// Push `v` into `arr` only if not already present. Returns updated arr.
fn push_uniq(arr, v) {
    let mut i = 0
    while i < len(arr) {
        if arr[i] == v { return arr }
        i = i + 1
    }
    return arr.push(v)
}

fn contains_item(arr, v) {
    let mut i = 0
    while i < len(arr) {
        if arr[i] == v { return true }
        i = i + 1
    }
    return false
}

// Extract leading identifier from a variant string like "IntLit(i64)" or "Wildcard".
// Stops at '(' or end of string; returns trimmed result.
fn variant_name(v) {
    let s = strip(v)
    let mut out = ""
    let mut i = 0
    while i < len(s) {
        let c = s[i]
        if c == "(" || c == " " || c == "\t" { break }
        out = out + c
        i = i + 1
    }
    return out
}

// Find the JSON-array payload following `"variants":` on a line.
// Returns the raw substring between the outermost [ and matching ], or "".
fn extract_variants_array(line) {
    let key = "\"variants\":"
    let mut kpos = -1
    // manual index_of — scan
    let n = len(line)
    let klen = len(key)
    let mut i = 0
    while i + klen <= n {
        let mut j = 0
        let mut ok = true
        while j < klen {
            if line[i + j] != key[j] { ok = false; break }
            j = j + 1
        }
        if ok { kpos = i; break }
        i = i + 1
    }
    if kpos < 0 { return "" }
    // Find '[' after the key.
    let mut p = kpos + klen
    while p < n && line[p] != "[" { p = p + 1 }
    if p >= n { return "" }
    // Walk forward tracking bracket depth, respecting strings.
    let start = p + 1
    let mut depth = 1
    let mut q = start
    let mut in_str = false
    let mut esc = false
    while q < n {
        let c = line[q]
        if in_str {
            if esc { esc = false } else if c == "\\" { esc = true } else if c == "\"" { in_str = false }
        } else {
            if c == "\"" { in_str = true }
            else if c == "[" { depth = depth + 1 }
            else if c == "]" {
                depth = depth - 1
                if depth == 0 { break }
            }
        }
        q = q + 1
    }
    if depth != 0 { return "" }
    // Return contents between start and q.
    let mut out = ""
    let mut r = start
    while r < q { out = out + line[r]; r = r + 1 }
    return out
}

// Split a JSON-string-array body into individual string literals (unquoted).
// Input example: `"IntLit(i64)", "FloatLit(f64)", "Wildcard"`
fn parse_string_array(body) {
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        // find next '"'
        while i < n && body[i] != "\"" { i = i + 1 }
        if i >= n { break }
        i = i + 1
        let mut s = ""
        let mut esc = false
        while i < n {
            let c = body[i]
            if esc { s = s + c; esc = false; i = i + 1; continue }
            if c == "\\" { esc = true; i = i + 1; continue }
            if c == "\"" { i = i + 1; break }
            s = s + c
            i = i + 1
        }
        out.push(s)
    }
    return out
}

// Collect grammar kinds from the JSONL file, keyed by section bucket
// ("expressions" | "statements"). Returns struct-ish via parallel arrays.
fn load_grammar_kinds() {
    let raw = read_file(GRAMMAR_PATH)
    if raw == "" { return [[], []] }
    let lines = raw.split("\n")
    let mut expr_kinds = []
    let mut stmt_kinds = []
    let mut i = 0
    while i < len(lines) {
        let line = lines[i]
        let has_expr = contains(line, "\"section\": \"expressions\"")
        let has_stmt = contains(line, "\"section\": \"statements\"")
        if has_expr || has_stmt {
            let body = extract_variants_array(line)
            if body != "" {
                let items = parse_string_array(body)
                let mut k = 0
                while k < len(items) {
                    let name = variant_name(items[k])
                    if name != "" {
                        if has_expr { expr_kinds = push_uniq(expr_kinds, name) }
                        else { stmt_kinds = push_uniq(stmt_kinds, name) }
                    }
                    k = k + 1
                }
            }
        }
        i = i + 1
    }
    return [expr_kinds, stmt_kinds]
}

// Scan self/poc/<cat>/*.hexa and collect @kinds keys from line 2 (or
// first non-empty line in first 5 lines, like poc_lint does).
fn load_poc_kinds(cat) {
    let dir = "self/poc/" + cat
    let files = list_dir_hexa(dir)
    let mut kinds = []
    let mut fi = 0
    while fi < len(files) {
        let path = files[fi]
        let src = read_file(path)
        if src != "" {
            let lines = src.split("\n")
            let mut li = 1
            while li < len(lines) && li < 5 {
                let s = strip(lines[li])
                if s != "" {
                    let prefix = "// @kinds"
                    if starts_with(s, prefix) {
                        let mut p = len(prefix)
                        while p < len(s) && (s[p] == " " || s[p] == "\t") { p = p + 1 }
                        let mut payload = ""
                        while p < len(s) { payload = payload + s[p]; p = p + 1 }
                        let ks = split_by_comma(payload)
                        let mut j = 0
                        while j < len(ks) {
                            if ks[j] != "" { kinds = push_uniq(kinds, ks[j]) }
                            j = j + 1
                        }
                        break
                    }
                    // non-matching non-empty line: keep scanning, poc_lint does too
                }
                li = li + 1
            }
        }
        fi = fi + 1
    }
    return kinds
}

fn join(arr, sep) {
    let mut out = ""
    let mut i = 0
    while i < len(arr) {
        if i > 0 { out = out + sep }
        out = out + arr[i]
        i = i + 1
    }
    return out
}

// Sort a string array in-place-ish (returns a new sorted array) using
// insertion sort — arrays here are tiny (< 60 entries).
fn sort_strs(arr) {
    let mut out = []
    let mut i = 0
    while i < len(arr) { out.push(arr[i]); i = i + 1 }
    let n = len(out)
    let mut x = 1
    while x < n {
        let key = out[x]
        let mut y = x - 1
        // shift greater elements right
        while y >= 0 && out[y] > key {
            out[y + 1] = out[y]
            y = y - 1
        }
        out[y + 1] = key
        x = x + 1
    }
    return out
}

// Compute overlap + diffs for a single category, print the report block,
// and return [implemented_count, grammar_count, intersection_count].
fn report_section(title, implemented, grammar) {
    let imp = sort_strs(implemented)
    let gr = sort_strs(grammar)
    let mut inter = []
    let mut missing = []
    let mut orphan = []
    let mut i = 0
    while i < len(gr) {
        if contains_item(imp, gr[i]) { inter.push(gr[i]) }
        else { missing.push(gr[i]) }
        i = i + 1
    }
    let mut j = 0
    while j < len(imp) {
        if !contains_item(gr, imp[j]) { orphan.push(imp[j]) }
        j = j + 1
    }
    let pct = if len(gr) == 0 { 0 } else { (len(inter) * 100) / len(gr) }
    println("")
    println("── " + title + " ──")
    println("implemented: " + str(len(imp)) + " kinds  [" + join(imp, ", ") + "]")
    println("in grammar:  " + str(len(gr)) + " kinds  [" + join(gr, ", ") + "]")
    println("coverage:    " + str(len(inter)) + " / " + str(len(gr)) + " = " + str(pct) + "%")
    println("missing (grammar \\ handled): [" + join(missing, ", ") + "]")
    println("orphan  (handled \\ grammar): [" + join(orphan, ", ") + "]  ← likely typos or hexa-specific custom kinds")
    return [len(imp), len(gr), len(inter), len(missing), len(orphan)]
}

fn cmd_selftest() -> i64 {
    println("[poc_coverage selftest]")
    // 1) strip — trims whitespace + CRLF at both ends
    if strip("  a b  \r\n") != "a b" { println("FAIL: strip"); return 1 }
    // 2) variant_name — stops at '(' and at end of string
    if variant_name("IntLit(i64)") != "IntLit" { println("FAIL: variant_name paren"); return 1 }
    if variant_name("Wildcard") != "Wildcard" { println("FAIL: variant_name plain"); return 1 }
    if variant_name("  Let(name)") != "Let" { println("FAIL: variant_name lead-ws"); return 1 }
    // 3) split_by_comma — trims + drops empty tail
    let parts = split_by_comma(" IntLit , FloatLit ")
    if len(parts) != 2 || parts[0] != "IntLit" || parts[1] != "FloatLit" {
        println("FAIL: split_by_comma")
        return 1
    }
    // 4) push_uniq — dedup
    let a = push_uniq(push_uniq(push_uniq([], "A"), "B"), "A")
    if len(a) != 2 || a[0] != "A" || a[1] != "B" { println("FAIL: push_uniq"); return 1 }
    // 5) contains_item
    if !contains_item(["x", "y"], "y") { println("FAIL: contains_item hit"); return 1 }
    if contains_item(["x", "y"], "z") { println("FAIL: contains_item miss"); return 1 }
    // 6) extract_variants_array + parse_string_array round-trip
    let line = "{\"section\": \"expressions\", \"variants\": [\"IntLit(i64)\", \"FloatLit(f64)\"]}"
    let body = extract_variants_array(line)
    let items = parse_string_array(body)
    if len(items) != 2 || items[0] != "IntLit(i64)" || items[1] != "FloatLit(f64)" {
        println("FAIL: variants round-trip")
        return 1
    }
    // 7) sort_strs — insertion sort over tiny array
    let s = sort_strs(["zeta", "alpha", "mu"])
    if s[0] != "alpha" || s[1] != "mu" || s[2] != "zeta" { println("FAIL: sort_strs"); return 1 }
    // 8) join — sep insertion
    if join(["a", "b", "c"], ", ") != "a, b, c" { println("FAIL: join"); return 1 }
    println("[poc_coverage selftest] OK")
    return 0
}

fn main() {
    let av = args()
    if len(av) > 2 {
        let sub = av[2]
        if sub == "--selftest" || sub == "selftest" {
            exit(cmd_selftest())
        }
    }
    println("=== POC Coverage ===")
    let grammar = load_grammar_kinds()
    let expr_gram = grammar[0]
    let stmt_gram = grammar[1]

    if len(expr_gram) == 0 && len(stmt_gram) == 0 {
        println("[warn] grammar.jsonl missing or contained no expressions/statements variants — reporting implemented only")
        let mut c = 0
        while c < len(CATS) {
            let cat = CATS[c]
            let imp = sort_strs(load_poc_kinds(cat))
            println("── " + cat + " (implemented only) ──")
            println("implemented: " + str(len(imp)) + " kinds  [" + join(imp, ", ") + "]")
            c = c + 1
        }
        exit(0)
    }

    let expr_imp = load_poc_kinds("expr")
    let stmt_imp = load_poc_kinds("stmt")

    let e = report_section("expr", expr_imp, expr_gram)
    let s = report_section("stmt", stmt_imp, stmt_gram)

    let total_imp = e[0] + s[0]
    let total_gr = e[1] + s[1]
    let total_inter = e[2] + s[2]
    let overall_pct = if total_gr == 0 { 0 } else { (total_inter * 100) / total_gr }
    println("")
    println("── total ──")
    println("coverage: " + str(total_inter) + " / " + str(total_gr) + " = " + str(overall_pct) + "%  (implemented=" + str(total_imp) + ")")
    exit(0)
}
