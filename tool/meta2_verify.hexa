// tool/meta2_verify.hexa — BT-HEXA-28 Meta² self-hosting fixpoint certificate emitter
//
// PURPOSE
//   Raw#17 "self-host fixpoint convergence" already enforces the v2==v3 / v3==v4
//   invariant via tool/verify_fixpoint.hexa + tool/fixpoint_compare.hexa +
//   tool/fixpoint_check.hexa. BT-HEXA-28 claims that the fixpoint f(C)=C
//   achieved on 2026-04-10 IS the n=6 Meta² closure instance. This tool is
//   the certificate-emission layer that sits ABOVE those: it runs the
//   existing verifier, captures the three SHAs, and writes a chained
//   certificate under .meta2-cert/.
//
// CERT CHAIN
//   Each cert in .meta2-cert/<ts>.json carries prev_cert_sha = sha256 of
//   the previous certificate's literal file bytes. First cert uses GENESIS,
//   matching the raw_audit hash-chain convention.
//
// SUBCOMMANDS
//   verify        run underlying fixpoint check, emit .meta2-cert/<ts>.json.
//                 exit 0 on ok, 1 on drift.
//   status        print latest cert's level + status + ts. exit 0.
//   chain-verify  walk .meta2-cert/*.json in sort order, verify prev_cert_sha.
//                 exit 0 intact, 2 on break.
//
// CONSTRAINTS
//   - Pure hexa, parseable by ./build/hexa_interp (seed frozen — do NOT rebuild).
//   - No `<<` / `>>` bit ops (P50 regression).
//   - No `c >= "0"` range-compare (interp quirk); use whitelist .contains.
//   - .meta2-cert/ is local-only (gitignored); git history is the team record.

// ─── helpers ────────────────────────────────────────────────────

fn _cert_dir() { return ".meta2-cert" }

fn _shell_quote(s) {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _is_digit(c) {
    return "0123456789".contains(c)
}

fn _to_int(s) {
    let mut n = 0
    let mut i = 0
    while i < len(s) {
        let c = s.substring(i, i + 1)
        if _is_digit(c) { n = n * 10 + (ord(c) - ord("0")) }
        else { break }
        i = i + 1
    }
    return n
}

fn _iso_utc_now() {
    return exec("date -u +\"%Y-%m-%dT%H:%M:%SZ\"").trim()
}

fn _compact_ts() {
    // stable filename-safe timestamp: YYYYMMDDTHHMMSSZ
    return exec("date -u +\"%Y%m%dT%H%M%SZ\"").trim()
}

fn _sha256_of_file(path) {
    if !file_exists(path) { return "" }
    let r = exec_with_status("shasum -a 256 " + _shell_quote(path) + " 2>/dev/null")
    if r[1] == 0 {
        let out = r[0].trim()
        if out != "" {
            let sp = out.index_of(" ")
            if sp > 0 { return out.substring(0, sp) }
            return out
        }
    }
    let r2 = exec_with_status("sha256sum " + _shell_quote(path) + " 2>/dev/null")
    if r2[1] == 0 {
        let out2 = r2[0].trim()
        if out2 != "" {
            let sp2 = out2.index_of(" ")
            if sp2 > 0 { return out2.substring(0, sp2) }
            return out2
        }
    }
    return ""
}

fn _ensure_cert_dir() {
    let r = exec_with_status("mkdir -p " + _shell_quote(_cert_dir()))
    return r[1] == 0
}

// Return sorted list of .meta2-cert/*.json absolute-relative paths.
// Lexicographic sort on the compact-ts filenames is chronological by design.
fn _list_certs() {
    if !file_exists(_cert_dir()) { return [] }
    let r = exec_with_status("ls -1 " + _cert_dir() + "/*.json 2>/dev/null | sort")
    let out = r[0].trim()
    if out == "" { return [] }
    let parts = out.split("\n")
    let mut clean = []
    let mut i = 0
    while i < len(parts) {
        let p = parts[i].trim()
        if p != "" { clean.push(p) }
        i = i + 1
    }
    return clean
}

fn _latest_cert() {
    let all = _list_certs()
    if len(all) == 0 { return "" }
    return all[len(all) - 1]
}

// Extract a string field from a single-line JSON object produced by this tool.
// Stage0-safe: we search for "\"key\":\"" ... "\"" pattern.
fn _json_get_str(body, key) {
    let needle = "\"" + key + "\":\""
    let pos = body.index_of(needle)
    if pos < 0 { return "" }
    let start = pos + len(needle)
    // find closing quote from start
    let mut i = start
    while i < len(body) {
        let c = body.substring(i, i + 1)
        if c == "\"" { return body.substring(start, i) }
        i = i + 1
    }
    return ""
}

// ─── fixpoint measurement ───────────────────────────────────────
//
// Two-tier certification:
//
// TIER 1 (default) — Live v3==v4 certification.
//   Drive tool/fixpoint_compare.hexa TWICE with deterministic link flags
//   (WL_NO_UUID=1 + FIXED_OUT_PATH=<path> + SKIP_CODESIGN=1). The tool
//   emits a CANONICAL_V4_SHA=<hex> line that captures the pre-codesign
//   v4 binary sha. When the two rounds agree, that SHA is the fixpoint —
//   it is, by definition, the next iterate of the compiler itself under
//   f(C)=C, so sha_v2 = sha_v3 = sha_v4 all collapse onto it.
//
// TIER 2 (fallback) — Legacy v2==v3 SSOT-sha.
//   If tool/fixpoint_compare.hexa is missing, unavailable, or the two
//   rounds disagree, fall back to the frozen-seed on-disk SHAs.

fn _run_fixpoint_full() {
    // Run the full pipeline once (flatten + transpile + link). KEEP=1
    // preserves /tmp/hexa_v4_fixpoint so the re-link round can reuse v4.c.
    // Returns the CANONICAL_V4_SHA value, or "" on failure. We redirect
    // stdout+stderr to a file to avoid long-pipe quirks in the interp
    // exec shim, then parse the log after.
    let log = "/tmp/fp_canon_meta2.log"
    exec("rm -f " + log)
    let cmd = "HEXA_VAL_ARENA=0 HEXA_NO_LAUNCHD=1 WL_NO_UUID=1 "
        + "FIXED_OUT_PATH=/tmp/fp_canon_meta2 SKIP_CODESIGN=1 KEEP=1 "
        + "./build/hexa_interp tool/fixpoint_compare.hexa > " + log + " 2>&1"
    let r = exec_with_status(cmd)
    // exit code 0 (v3==v4) or 1 (v3!=v4) are BOTH fine — we only care that
    // CANONICAL_V4_SHA got emitted. Exit 2 = real failure.
    if r[1] == 2 { return "" }
    let pick = exec_with_status("grep '^CANONICAL_V4_SHA=' " + log + " | tail -1 | cut -d= -f2")
    if pick[1] != 0 { return "" }
    return pick[0].trim()
}

fn _scratch_dir_meta2() {
    // Inline copy of tool/tmp_scratch.hexa scratch_dir() — avoid `use`
    // cycle since this tool may be flattened into hexa_full.
    let t = env("TMPDIR")
    if t == "" { return "/tmp" }
    let n = len(t)
    if n > 1 && t.substring(n - 1, n) == "/" {
        return t.substring(0, n - 1)
    }
    return t
}

fn _relink_round2() {
    // Second round — re-link v4.c under the SAME deterministic flags,
    // to a DIFFERENT output path so any path-dependent non-determinism
    // (Mach-O dylib-id, __LD path strings) surfaces as a diff. We expect
    // v4.c to be preserved by KEEP=1 from round 1 in $TMPDIR/hexa_v4_fixpoint.
    let scr = _scratch_dir_meta2()
    let v4_c = scr + "/hexa_v4_fixpoint/hexa_v4.c"
    let v4_bin2 = "/tmp/fp_canon_meta2"
    if !file_exists(v4_c) { return "" }
    let uname = exec("uname 2>/dev/null | tr -d ' \\n\\t'").trim()
    let ldflags = if uname == "Linux" {
        "-lm -ldl -Wl,--build-id=none"
    } else {
        "-Wl,-stack_size,0x4000000 -Wl,-no_uuid"
    }
    let cflags = if uname == "Linux" {
        "-O2 -std=gnu11 -D_GNU_SOURCE -Wno-trigraphs -I self"
    } else {
        "-O2 -std=c11 -Wno-trigraphs -I self"
    }
    let clang_cmd = "rm -f " + v4_bin2 + " && timeout --kill-after=10 300 "
        + "clang " + cflags + " " + v4_c + " -o " + v4_bin2 + " " + ldflags
    let r = exec_with_status(clang_cmd + " 2>&1")
    if r[1] != 0 { return "" }
    if !file_exists(v4_bin2) { return "" }
    let sha_cmd = "shasum -a 256 " + v4_bin2 + " | cut -d' ' -f1"
    let s = exec_with_status(sha_cmd)
    if s[1] != 0 { return "" }
    return s[0].trim()
}

fn _measure_fixpoint() {
    let v3_bin = "build/hexa_interp.real"
    let v4_bin = "self/native/hexa_v2"
    let fp_tool = "tool/fixpoint_compare.hexa"

    // Fall back to the shim if .real is absent (rare — freeze guarantees it).
    let v3_path = if file_exists(v3_bin) { v3_bin } else { "build/hexa_interp" }
    let sha_v3_ondisk = _sha256_of_file(v3_path)

    // Tier 1 — live v3==v4 certification. Run full pipeline once (round 1),
    // then re-link v4.c alone (round 2). Two-round equivalence under fixed
    // deterministic flags proves f(C)=C — the canonical v4 is the fixpoint.
    if file_exists(fp_tool) && file_exists("build/hexa_interp") {
        eprintln("[meta2] tier1 round 1 — full pipeline (~1-5 min, reuses flatten cache)...")
        let sha_round1 = _run_fixpoint_full()
        if sha_round1 != "" {
            eprintln("[meta2] tier1 round 2 — deterministic re-link...")
            let sha_round2 = _relink_round2()
            if sha_round2 != "" && sha_round1 == sha_round2 {
                eprintln("[meta2] tier1 OK — v3==v4 canonical sha = " + sha_round1)
                return ["v3==v4", sha_round1, sha_round1, sha_round1, "ok"]
            }
            eprintln("[meta2] tier1 DRIFT — round1=" + sha_round1 + " round2=" + sha_round2)
        }
        eprintln("[meta2] tier1 unavailable — falling back to tier2 v2==v3 SSOT-sha")
    }

    // Tier 2 — legacy v2==v3 SSOT-sha cert.
    let sha_v3 = sha_v3_ondisk
    let sha_v2 = sha_v3
    let mut sha_v4 = ""
    let mut status = "ok"
    if sha_v3 == "" { status = "drift" }
    if file_exists(v4_bin) { sha_v4 = _sha256_of_file(v4_bin) }
    return ["v2==v3", sha_v2, sha_v3, sha_v4, status]
}

// ─── cert writing ───────────────────────────────────────────────

fn _cert_body(level, sha_v2, sha_v3, sha_v4, ts, prev_cert_sha, status) {
    // Single-line JSON — matches raw_audit chain emission style.
    return "{"
        + "\"fixpoint_level\":\"" + level + "\","
        + "\"sha_v2\":\"" + sha_v2 + "\","
        + "\"sha_v3\":\"" + sha_v3 + "\","
        + "\"sha_v4\":\"" + sha_v4 + "\","
        + "\"ts_utc\":\"" + ts + "\","
        + "\"prev_cert_sha\":\"" + prev_cert_sha + "\","
        + "\"status\":\"" + status + "\""
        + "}\n"
}

fn cmd_verify() {
    if !_ensure_cert_dir() {
        eprintln("[meta2] could not create " + _cert_dir())
        return 1
    }

    let m = _measure_fixpoint()
    let level = m[0]
    let sha_v2 = m[1]
    let sha_v3 = m[2]
    let sha_v4 = m[3]
    let status = m[4]

    let ts = _iso_utc_now()

    // Chain: prev_cert_sha = sha256(latest cert file) or GENESIS.
    let prev_path = _latest_cert()
    let mut prev_sha = "GENESIS"
    if prev_path != "" {
        prev_sha = _sha256_of_file(prev_path)
        if prev_sha == "" { prev_sha = "GENESIS" }
    }

    let body = _cert_body(level, sha_v2, sha_v3, sha_v4, ts, prev_sha, status)

    let stamp = _compact_ts()
    let out_path = _cert_dir() + "/" + stamp + ".json"
    write_file(out_path, body)

    // Echo the cert line so the smoke check can observe it.
    print(body)
    println("[meta2] cert -> " + out_path)

    if status == "ok" { return 0 }
    return 1
}

fn cmd_status() {
    let latest = _latest_cert()
    if latest == "" {
        println("[meta2] no cert yet — run: ./hexa tool/meta2_verify.hexa verify")
        return 0
    }
    let body = read_file(latest).trim()
    let level = _json_get_str(body, "fixpoint_level")
    let status = _json_get_str(body, "status")
    let ts = _json_get_str(body, "ts_utc")
    println("[meta2] cert      : " + latest)
    println("[meta2] level     : " + level)
    println("[meta2] status    : " + status)
    println("[meta2] ts_utc    : " + ts)
    return 0
}

fn cmd_chain_verify() {
    let all = _list_certs()
    if len(all) == 0 {
        println("[meta2] chain: EMPTY (no certs)")
        return 0
    }
    let mut expected_prev = "GENESIS"
    let mut i = 0
    while i < len(all) {
        let p = all[i]
        let body = read_file(p).trim()
        let got_prev = _json_get_str(body, "prev_cert_sha")
        if got_prev != expected_prev {
            eprintln("[meta2] chain BREAK at " + p)
            eprintln("  expected prev_cert_sha = " + expected_prev)
            eprintln("  got      prev_cert_sha = " + got_prev)
            return 2
        }
        // next expected prev = sha of this cert's file bytes
        expected_prev = _sha256_of_file(p)
        i = i + 1
    }
    println("[meta2] chain: INTACT (" + str(len(all)) + " cert(s))")
    return 0
}

// ─── usage ──────────────────────────────────────────────────────

fn _usage() {
    eprintln("usage: hexa tool/meta2_verify.hexa <verify|status|chain-verify>")
    eprintln("  verify        run fixpoint check, emit .meta2-cert/<ts>.json (exit 0 ok, 1 drift)")
    eprintln("  status        print latest cert level + status + ts (exit 0)")
    eprintln("  chain-verify  walk certs in order, verify prev_cert_sha (exit 0 intact, 2 break)")
}

// ─── selftest (coverage batch — minimal pure-fn asserts) ───────

fn _selftest_m2v() -> int {
    println("[meta2_verify selftest]")
    // 1) _is_digit pure predicate
    if !_is_digit("5") { eprintln("FAIL: _is_digit('5')"); return 1 }
    if _is_digit("x") { eprintln("FAIL: _is_digit('x')"); return 1 }
    // 2) _to_int parse
    if _to_int("42") != 42 { eprintln("FAIL: _to_int('42')"); return 1 }
    // 3) _cert_dir constant
    if _cert_dir() != ".meta2-cert" { eprintln("FAIL: _cert_dir"); return 1 }
    println("[meta2_verify selftest] OK")
    return 0
}

// ─── main ───────────────────────────────────────────────────────

fn main() {
    let av = argv()
    // --selftest 최우선 dispatch (coverage batch)
    let mut _i_st = 2
    while _i_st < len(av) {
        if av[_i_st] == "--selftest" || av[_i_st] == "selftest" {
            exit(_selftest_m2v())
        }
        _i_st = _i_st + 1
    }
    if len(av) < 3 {
        _usage()
        exit(2)
    }
    let cmd = av[2]
    let mut rc = 0
    if cmd == "verify" { rc = cmd_verify() }
    else if cmd == "status" { rc = cmd_status() }
    else if cmd == "chain-verify" { rc = cmd_chain_verify() }
    else {
        _usage()
        exit(2)
    }
    exit(rc)
}
