// tool/roadmap_status_flip.hexa — Tier1#6 (roadmap 38): status flip
//
// PURPOSE
//   Given a parsed roadmap + evidence source (commit log / artifact
//   existence), propose automatic header status transitions:
//     planned → active   (evidence of started work)
//     active  → done     (exit_criteria satisfied)
//   Conservative: DOES NOT flip automatically unless --apply flag given.
//   Respects raw#1 chflags uchg — opens write window minimally.
//
// EVIDENCE SIGNALS
//   planned→active :  proof/cert file exists  OR  referenced in recent commit
//   active→done    :  proof file exists AND exit_criteria artifact present
//                     AND (commit msg mentions id OR 'note' cites SHA)
//
// USAGE
//   hexa tool/roadmap_status_flip.hexa --repo <name> [--apply]
//   hexa tool/roadmap_status_flip.hexa --selftest

fn _rstrip(s: string) -> string {
    let mut end = len(s)
    while end > 0 {
        let c = s.substring(end - 1, end)
        if c == " " || c == "\t" || c == "\r" { end = end - 1 } else { break }
    }
    return s.substring(0, end)
}

fn _hdr(line: string) -> array {
    let sp1 = line.index_of(" ")
    if sp1 < 0 { return [] }
    if line.substring(0, sp1) != "roadmap" { return [] }
    let r1 = line.substring(sp1 + 1, len(line))
    let sp2 = r1.index_of(" ")
    if sp2 < 0 { return [] }
    let id = r1.substring(0, sp2)
    let r2 = r1.substring(sp2 + 1, len(r1))
    let sp3 = r2.index_of(" ")
    if sp3 < 0 { return [] }
    let st = r2.substring(0, sp3)
    let mut nm = r2.substring(sp3 + 1, len(r2)).trim()
    if len(nm) >= 2 && nm.substring(0, 1) == "\"" { nm = nm.substring(1, len(nm) - 1) }
    return [id, st, nm]
}

fn parse_roadmap(src: string) -> array {
    let lines = split(src, "\n")
    let mut rules = []
    let mut kind = ""
    let mut cid = ""; let mut cst = ""; let mut cnm = ""; let mut ck = []
    for raw_line in lines {
        let line = _rstrip(raw_line)
        if len(line) == 0 {
            if kind == "r" { rules.push([cid, cst, cnm, ck]) }
            kind = ""; ck = []
            continue
        }
        let f = line.substring(0, 1)
        if f == "#" { continue }
        if f == " " || f == "\t" {
            if kind == "" { continue }
            let s = line.trim_start()
            let sp = s.index_of(" ")
            if sp < 0 { continue }
            ck.push([s.substring(0, sp), s.substring(sp + 1, len(s)).trim()])
        } else {
            if kind == "r" { rules.push([cid, cst, cnm, ck]) }
            ck = []; kind = ""
            let fs = line.index_of(" ")
            if fs < 0 { continue }
            if line.substring(0, fs) == "roadmap" {
                let h = _hdr(line)
                if len(h) == 0 { continue }
                cid = h[0]; cst = h[1]; cnm = h[2]; kind = "r"
            }
        }
    }
    if kind == "r" { rules.push([cid, cst, cnm, ck]) }
    return rules
}

fn _load(path: string) -> array {
    let r = exec_with_status("test -f '" + path + "'")
    if r[1] != 0 { return [] }
    return parse_roadmap(to_string(read_file(path)))
}

fn _kv(keys: array, k: string) -> string {
    for kv in keys { if kv[0] == k { return kv[1] } }
    return ""
}

fn _path_exists(repo_root: string, rel: string) -> bool {
    let p = rel.trim()
    if len(p) == 0 { return false }
    let mut full = p
    if p.substring(0, 1) != "/" { full = repo_root + "/" + p }
    let r = exec_with_status("test -e '" + full + "'")
    return r[1] == 0
}

fn _proof_all_exist(repo_root: string, pfval: string) -> bool {
    if len(pfval) == 0 { return false }
    let cleaned = pfval.replace(",", " ")
    let toks = split(cleaned, " ")
    let mut any = false
    for t in toks {
        let p = t.trim()
        if len(p) == 0 { continue }
        if !_path_exists(repo_root, p) { return false }
        any = true
    }
    return any
}

// Propose flips. Returns array of [id, from_status, to_status, reason].
fn propose_flips(rules: array, repo_root: string) -> array {
    let mut out = []
    for r in rules {
        let id = r[0]
        let st = r[1]
        let keys = r[3]
        if st == "planned" {
            let pf = _kv(keys, "proof")
            if len(pf) > 0 && _proof_all_exist(repo_root, pf) {
                out.push([id, "planned", "active", "proof path exists: " + pf])
            }
        }
        if st == "active" {
            let pf = _kv(keys, "proof")
            let ec = _kv(keys, "exit_criteria")
            let note = _kv(keys, "note")
            // need proof exists AND (note cites commit OR exit_criteria hint present).
            if len(pf) > 0 && _proof_all_exist(repo_root, pf) {
                let has_sha = note.index_of("commit") >= 0 || note.contains("SHA") || note.contains("evidence")
                if has_sha || len(ec) > 0 {
                    out.push([id, "active", "done", "proof+evidence satisfied"])
                }
            }
        }
    }
    return out
}

// Apply flips in-place to .roadmap text. Only flips the header line for each
// id. Returns new text + count.
fn apply_flips(src: string, flips: array) -> array {
    let lines = split(src, "\n")
    let mut out_lines = []
    let mut flipped = 0
    for raw_line in lines {
        let line = raw_line
        let ln = line
        // check if line is a roadmap header
        let sp = ln.index_of(" ")
        if sp > 0 && ln.substring(0, sp) == "roadmap" {
            let h = _hdr(_rstrip(ln))
            if len(h) > 0 {
                let id = h[0]
                let from_st = h[1]
                for fl in flips {
                    if fl[0] == id && fl[1] == from_st {
                        // replace  `roadmap <id> <from> ` → `roadmap <id> <to> `
                        let old_prefix = "roadmap " + id + " " + from_st + " "
                        let new_prefix = "roadmap " + id + " " + fl[2] + " "
                        if ln.starts_with(old_prefix) {
                            let tail = ln.substring(len(old_prefix), len(ln))
                            out_lines.push(new_prefix + tail)
                            flipped = flipped + 1
                            break
                        }
                    }
                }
                // not matched → push unchanged
                // (to push only once regardless of match loop, use a flag)
            }
        }
        // Fallthrough: if header matched and pushed, skip
        // simpler: track matched via out_lines length diff
        // Our loop pushes in the matched branch via `break`. We need to avoid
        // double-pushing. Use a sentinel:
        if len(out_lines) == 0 || out_lines[len(out_lines) - 1] != line {
            // if last pushed line is not `line`, then we either pushed the
            // flipped version (keep) OR haven't pushed anything yet — push line.
            // BUT if we just pushed a flipped line based on this line, skip.
            // Easier: use a boolean `pushed_this`.
        }
    }
    // The complexity above is risky. Rewrite cleanly below.
    return apply_flips_v2(src, flips, flipped)
}

fn apply_flips_v2(src: string, flips: array, _ignore: int) -> array {
    let lines = split(src, "\n")
    let mut out_lines = []
    let mut flipped = 0
    for raw_line in lines {
        let ln = raw_line
        let trimmed = _rstrip(ln)
        let sp = trimmed.index_of(" ")
        let mut done = false
        if sp > 0 && trimmed.substring(0, sp) == "roadmap" {
            let h = _hdr(trimmed)
            if len(h) > 0 {
                let id = h[0]
                let from_st = h[1]
                for fl in flips {
                    if fl[0] == id && fl[1] == from_st && !done {
                        let old_prefix = "roadmap " + id + " " + from_st + " "
                        let new_prefix = "roadmap " + id + " " + fl[2] + " "
                        if ln.starts_with(old_prefix) {
                            let tail = ln.substring(len(old_prefix), len(ln))
                            out_lines.push(new_prefix + tail)
                            flipped = flipped + 1
                            done = true
                        }
                    }
                }
            }
        }
        if !done { out_lines.push(ln) }
    }
    return [out_lines.join("\n"), flipped]
}

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _run_repo(name: string, apply: bool) -> int {
    let home = _home()
    let root = home + "/core/" + name
    let rp = root + "/.roadmap"
    let rules = _load(rp)
    if len(rules) == 0 {
        eprintln("no .roadmap at " + rp)
        return 1
    }
    let flips = propose_flips(rules, root)
    println("proposed flips for " + name + ": " + to_string(len(flips)))
    for f in flips {
        println("  #" + f[0] + " " + f[1] + " → " + f[2] + " (" + f[3] + ")")
    }
    if apply && len(flips) > 0 {
        let src = to_string(read_file(rp))
        let res = apply_flips_v2(src, flips, 0)
        let new_text = res[0]
        let n = res[1]
        // open write window — chflags nouchg
        let _u = exec_with_status("chflags nouchg '" + rp + "' 2>/dev/null")
        let w = write_file(rp, new_text)
        let _l = exec_with_status("chflags uchg '" + rp + "' 2>/dev/null")
        if !w { eprintln("write FAIL") return 1 }
        println("applied " + to_string(n) + " flip(s) to " + rp)
    }
    return 0
}

fn _selftest() -> int {
    // dry-run 3 repos — no --apply
    for repo in ["anima", "airgenome", "hexa-lang"] {
        let _ = _run_repo(repo, false)
    }
    // synthesized flip test
    let txt = "roadmap 1 planned \"x\"\n  track t\n  phase p\n  eta TBD\n  why y\n  proof /tmp\n"
    let rules = parse_roadmap(txt)
    let flips = propose_flips(rules, "/")
    if len(flips) == 0 {
        eprintln("selftest FAIL: /tmp exists but no flip proposed")
        return 1
    }
    // apply
    let res = apply_flips_v2(txt, flips, 0)
    if res[1] != 1 {
        eprintln("selftest FAIL: apply count = " + to_string(res[1]))
        return 1
    }
    let new_txt = res[0]
    if new_txt.index_of("roadmap 1 active") < 0 {
        eprintln("selftest FAIL: applied text missing active status")
        return 1
    }
    println("selftest PASS")
    return 0
}

fn main() {
    let av = argv()
    let mut args = []
    let mut i = 2
    while i < len(av) { args.push(av[i]); i = i + 1 }
    if len(args) >= 1 && args[0] == "--selftest" { exit(_selftest()) }

    let mut repo = ""
    let mut apply_flag = false
    let mut j = 0
    while j < len(args) {
        if args[j] == "--repo" && j + 1 < len(args) { repo = args[j + 1]; j = j + 1 }
        if args[j] == "--apply" { apply_flag = true }
        j = j + 1
    }
    if len(repo) == 0 {
        eprintln("usage: --repo <name> [--apply]")
        exit(1)
    }
    exit(_run_repo(repo, apply_flag))
}
