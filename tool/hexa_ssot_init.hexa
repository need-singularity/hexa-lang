// tool/hexa_ssot_init.hexa — project-level SSOT scaffold (`hexa init <project-path>`).
//
// 목적:
//   hexa-lang 외부 프로젝트 (nexus, anima, n6-architecture, airgenome, contact,
//   papers, hexa-os, ...) 에 canonical SSOT 골격을 1회 생성한다.
//
// 생성 대상 (각각 없을 때만, idempotent):
//   .raw-ref              — canonical hexa-lang `.raw` 추종 선언 (L0 mirror pin)
//   .own                  — project-local rules (3 필수 key: since/why/inherits)
//   .ext                  — optional (본 tool 은 생성하지 않음; nexus/airgenome 에 이미 있다고 가정)
//   .roadmap              — minimal checkpoint (1 done + 1 active)
//   .loop                 — minimal cron samples (daily 1 + weekly 1)
//   .hexa-init/stamp      — idempotency 마크 (timestamp + init-version metadata)
//
// Guard (덮어쓰기 금지):
//   README.md, LICENSE, CLAUDE.md, .hexa-attrs, 기존 .raw/.own/.ext/.roadmap/.loop
//   .claude/settings.json — merge only (본 tool 은 건드리지 않음)
//   .git/hooks/pre-commit — 있으면 @raw-stanza grep 후 없을 때만 append
//
// Idempotency:
//   .hexa-init/stamp 가 있으면 skip (--force 플래그 가능).
//
// 사용:
//   hexa tool/hexa_ssot_init.hexa <project-path>          — 1회 scaffold
//   hexa tool/hexa_ssot_init.hexa <project-path> force    — stamp 무시 재실행
//   hexa tool/hexa_ssot_init.hexa <project-path> status   — 현재 설치 상태
//
// Note:
//   `tool/hexa_init.hexa` 는 hexa-lang 자체의 bootstrap (raw install + attr
//   compile + fs seal) orchestrator. 본 도구는 *외부 프로젝트* 용 SSOT
//   scaffold 로 이름 공간을 분리한다.

use "self/core/law_io"

let _raw_args = args()
let mut cli_args = []
let mut _ai = 2
while _ai < len(_raw_args) {
    cli_args.push(_raw_args[_ai])
    _ai = _ai + 1
}

let INIT_VERSION = "hexa-ssot-init/1"

// ─────────────────────────────────────────────────────────────
// util
// ─────────────────────────────────────────────────────────────

fn _file_exists(path: string) -> bool {
    let r = to_string(exec("test -e '" + path + "' && echo y || echo n")).trim()
    return r == "y"
}

fn _dir_exists(path: string) -> bool {
    let r = to_string(exec("test -d '" + path + "' && echo y || echo n")).trim()
    return r == "y"
}

fn _today() -> string {
    return to_string(exec("date -u +%Y-%m-%d")).trim()
}

fn _now_iso() -> string {
    return to_string(exec("date -u +%Y-%m-%dT%H:%M:%SZ")).trim()
}

fn _basename(path: string) -> string {
    let parts = split(path, "/")
    let mut last = ""
    for p in parts {
        if p != "" { last = p }
    }
    return last
}

fn _grep_has(path: string, needle: string) -> bool {
    if !_file_exists(path) { return false }
    let r = to_string(exec("grep -c '" + needle + "' '" + path + "' 2>/dev/null || echo 0")).trim()
    return r != "0"
}

// ─────────────────────────────────────────────────────────────
// templates
// ─────────────────────────────────────────────────────────────

fn render_raw_ref(project: string) -> string {
    let lines = []
    lines.push("# .raw-ref — canonical hexa-lang .raw mirror pin (raw#0 P4)")
    lines.push("# Autogenerated by hexa-lang tool/hexa_ssot_init.hexa at " + _now_iso())
    lines.push("# Populate pinned-hash via: ./hexa tool/raw_sync.hexa check")
    lines.push("")
    lines.push("ref 1 live \"hexa-lang canonical (" + project + ")\"")
    lines.push("  source github.com/need-singularity/hexa-lang")
    lines.push("  branch main")
    lines.push("  path .raw")
    lines.push("  pinned-hash TO_BE_FILLED_ON_FIRST_SYNC")
    lines.push("  checked-at " + _now_iso())
    lines.push("")
    return lines.join("\n")
}

fn render_own(project: string) -> string {
    let lines = []
    lines.push("#!raw")
    lines.push("# " + project + " /.own — L1 project-local rules")
    lines.push("# Inherits L0 = hexa-lang /.raw via .raw-ref pin.")
    lines.push("")
    lines.push("since " + _today())
    lines.push("why \"Initial hexa init scaffold\"")
    lines.push("inherits hexa-lang/.raw")
    lines.push("")
    return lines.join("\n")
}

fn render_roadmap(project: string) -> string {
    let lines = []
    lines.push("# " + project + " /.roadmap — minimal checkpoint seed")
    lines.push("# Autogenerated by hexa-lang tool/hexa_ssot_init.hexa at " + _now_iso())
    lines.push("")
    lines.push("# checkpoint")
    lines.push("- done [C0] project-init — hexa init " + _today())
    lines.push("")
    lines.push("# active phase")
    lines.push("- active [P1] bootstrap")
    lines.push("  eta TBD")
    lines.push("  why \"establish SSOT foundation\"")
    lines.push("")
    return lines.join("\n")
}

fn render_loop(project: string) -> string {
    let lines = []
    lines.push("# " + project + " /.loop — minimal cron seed")
    lines.push("# Autogenerated by hexa-lang tool/hexa_ssot_init.hexa at " + _now_iso())
    lines.push("")
    lines.push("# daily")
    lines.push("- daily ssot-fingerprint — hexa tool/raw_audit.hexa status")
    lines.push("")
    lines.push("# weekly")
    lines.push("- weekly roadmap-review — manual check")
    lines.push("")
    return lines.join("\n")
}

fn render_stamp(project: string) -> string {
    let lines = []
    lines.push("# .hexa-init/stamp — idempotency marker")
    lines.push("init-version: " + INIT_VERSION)
    lines.push("installed-at: " + _now_iso())
    lines.push("project:      " + project)
    lines.push("scaffold:     .raw-ref .own .roadmap .loop (create-if-absent)")
    lines.push("")
    return lines.join("\n")
}

fn render_raw_stanza_hook(project: string) -> string {
    let lines = []
    lines.push("")
    lines.push("# ─── @raw-stanza (appended by hexa tool/hexa_ssot_init.hexa) ────────")
    lines.push("# WHY: raw#0 P4 — project 커밋은 .raw-ref drift 를 먼저 검증한다.")
    lines.push("RAW_REF=\"$(git rev-parse --show-toplevel 2>/dev/null)/.raw-ref\"")
    lines.push("if [ -f \"$RAW_REF\" ]; then")
    lines.push("    # Drift 검출 툴이 존재하면 실행, 없으면 skip (bootstrap 허용).")
    lines.push("    HEXA_CMD=\"$(command -v hexa)\"")
    lines.push("    if [ -n \"$HEXA_CMD\" ] && [ -f \"$WS/hexa-lang/tool/raw_sync.hexa\" ]; then")
    lines.push("        \"$HEXA_CMD\" run \"$WS/hexa-lang/tool/raw_sync.hexa\" status >/dev/null 2>&1 || true")
    lines.push("    fi")
    lines.push("fi")
    lines.push("# ─── /@raw-stanza ────────────────────────────────────────────────────")
    return lines.join("\n")
}

// ─────────────────────────────────────────────────────────────
// write helpers
// ─────────────────────────────────────────────────────────────

fn write_if_absent(path: string, content: string, created: [string], skipped: [string]) {
    if _file_exists(path) {
        skipped.push(path)
        return
    }
    // ensure parent
    let idx = path.chars()
    // use exec mkdir -p on dirname(path)
    let last = -1
    let mut i = 0
    let cs = path.chars()
    let mut li = len(cs) - 1
    while li >= 0 {
        if cs[li] == "/" { break }
        li = li - 1
    }
    if li > 0 {
        let d = path.substring(0, li)
        try { exec("mkdir -p '" + d + "'") } catch e {}
    }
    try {
        safe_write_file(path, content)
        created.push(path)
    } catch e {
        eprintln("[error] write " + path + ": " + e.to_string())
    }
}

fn append_raw_stanza_if_missing(hook_path: string, project: string, appended: [string], skipped: [string]) {
    if !_file_exists(hook_path) {
        // 훅이 없으면 본 tool 은 훅을 만들지 않음 (덮어쓰기 금지 원칙).
        return
    }
    if _grep_has(hook_path, "@raw-stanza") {
        skipped.push(hook_path + " (@raw-stanza already present)")
        return
    }
    let stanza = render_raw_stanza_hook(project)
    try {
        let old = read_file(hook_path)
        safe_write_file(hook_path, old + "\n" + stanza + "\n")
        appended.push(hook_path)
    } catch e {
        eprintln("[error] append hook " + hook_path + ": " + e.to_string())
    }
}

// ─────────────────────────────────────────────────────────────
// status / install
// ─────────────────────────────────────────────────────────────

fn run_status(root: string) {
    let project = _basename(root)
    println("── hexa ssot-init status ──")
    println("root    : " + root)
    println("project : " + project)
    println("")
    let files = [".raw-ref", ".own", ".ext", ".roadmap", ".loop", ".hexa-init/stamp", ".hexa-attrs"]
    let mut i = 0
    while i < len(files) {
        let f = files[i]
        let p = root + "/" + f
        let mark = if _file_exists(p) { "✓" } else { "·" }
        println("  " + mark + " " + f)
        i = i + 1
    }
    let hook = root + "/.git/hooks/pre-commit"
    if _file_exists(hook) {
        let has = _grep_has(hook, "@raw-stanza")
        println("  " + (if has { "✓" } else { "·" }) + " .git/hooks/pre-commit @raw-stanza")
    }
}

fn run_install(root: string, force: bool) {
    if !_dir_exists(root) {
        eprintln("error: project path not found — " + root)
        exit(1)
    }
    let project = _basename(root)
    let stamp = root + "/.hexa-init/stamp"
    if _file_exists(stamp) && !force {
        println("[skip] already installed — " + stamp)
        println("       재설치: hexa tool/hexa_ssot_init.hexa " + root + " force")
        exit(0)
    }

    let mut created = []
    let mut skipped = []
    let mut appended = []

    // 1. .raw-ref
    write_if_absent(root + "/.raw-ref", render_raw_ref(project), created, skipped)
    // 2. .own
    write_if_absent(root + "/.own", render_own(project), created, skipped)
    // 3. .roadmap
    write_if_absent(root + "/.roadmap", render_roadmap(project), created, skipped)
    // 4. .loop
    write_if_absent(root + "/.loop", render_loop(project), created, skipped)
    // 5. stamp (항상 기록 — force 시 덮어씀)
    if force && _file_exists(stamp) {
        try { exec("rm -f '" + stamp + "'") } catch e {}
    }
    write_if_absent(stamp, render_stamp(project), created, skipped)
    // 6. pre-commit @raw-stanza (있을 때만 append)
    append_raw_stanza_if_missing(root + "/.git/hooks/pre-commit", project, appended, skipped)

    println("")
    println("── hexa ssot-init complete — " + project + " ──")
    println("created (" + to_string(len(created)) + "):")
    let mut i = 0
    while i < len(created) {
        println("  + " + created[i])
        i = i + 1
    }
    println("skipped (" + to_string(len(skipped)) + "):")
    i = 0
    while i < len(skipped) {
        println("  = " + skipped[i])
        i = i + 1
    }
    if len(appended) > 0 {
        println("hook appended (" + to_string(len(appended)) + "):")
        i = 0
        while i < len(appended) {
            println("  > " + appended[i])
            i = i + 1
        }
    }
}

// ─── dispatch ─────────────────────────────────────────────────

fn usage() {
    eprintln("usage:")
    eprintln("  hexa tool/hexa_ssot_init.hexa <project-path>         — scaffold (idempotent)")
    eprintln("  hexa tool/hexa_ssot_init.hexa <project-path> status  — show state only")
    eprintln("  hexa tool/hexa_ssot_init.hexa <project-path> force   — re-scaffold")
}

if len(cli_args) == 0 {
    usage()
    exit(1)
}

let root = cli_args[0]

if len(cli_args) == 1 {
    run_install(root, false)
    exit(0)
}

let sub = cli_args[1]
if sub == "status" {
    run_status(root)
    exit(0)
}
if sub == "force" {
    run_install(root, true)
    exit(0)
}

usage()
exit(1)
