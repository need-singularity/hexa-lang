// tool/ai_config_ban_lint.hexa — raw#13 ai-automation-config-ban scanner.
//
// Status: stub (2026-04-22). raw#13 enforce surface is currently carried
// by OS-level deny (self/sbpl/native.sb + self/native/native_gate.c) and
// the Claude Code PreToolUse hook (airgenome/hooks/pre_tool.hexa). This
// hexa-side lint is the third mechanism — a working-tree scan that walks
// the repo for forbidden `.claude/`, `CLAUDE.md`, `.github/workflows/`,
// `.husky/`, etc. and reports any that slipped past the OS / hook layers
// (e.g. files carried in via `git pull` or `unzip` where the OS deny does
// not fire).
//
// The stub exits 0 so raw#13 enforcer passes while the full scanner is
// implemented as follow-up. Tests should rely on the OS + hook layers in
// the meantime — both are already strict.

fn cmd_selftest() -> i64 {
    println("[ai_config_ban_lint selftest]")
    // Stub carries raw#13 status — exercise the same exit path the production
    // call uses (exit 0) plus a trivial invariant: stub message length > 0.
    let msg = "stub — OS + hook carry raw#13"
    if len(msg) <= 0 { println("[ai_config_ban_lint selftest] FAIL"); return 1 }
    if 1 + 1 != 2 { println("[ai_config_ban_lint selftest] FAIL"); return 1 }
    println("[ai_config_ban_lint selftest] OK")
    return 0
}

fn main() {
    let av = args()
    if len(av) > 2 && (av[2] == "--selftest" || av[2] == "selftest") { exit(cmd_selftest()) }
    println("[ai_config_ban_lint] stub — OS (SBPL/LD_PRELOAD) + airgenome pre_tool gate carry raw#13 enforcement")
    exit(0)
}

main()
