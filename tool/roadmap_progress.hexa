// tool/roadmap_progress.hexa — Tier1#8 (roadmap 40): progress aggregation
//
// PURPOSE
//   For each phase / track, compute percent complete:
//     done   count
//     active count
//     planned+blocked count
//     total
//     percent = round(done * 100 / total)
//
// Also aggregates verification gate markers (□/✓) present in free-form
// roadmap prose (same metric that watcher uses).
//
// OUTPUT
//   JSON: { by_phase: {P1: {...}, ...}, by_track: {...}, by_repo: {...},
//          gate_markers: {total, satisfied, pending, percent} }

fn _rstrip(s: string) -> string {
    let mut end = len(s)
    while end > 0 {
        let c = s.substring(end - 1, end)
        if c == " " || c == "\t" || c == "\r" { end = end - 1 } else { break }
    }
    return s.substring(0, end)
}

fn _hdr(line: string) -> array {
    let sp1 = line.index_of(" ")
    if sp1 < 0 { return [] }
    if line.substring(0, sp1) != "roadmap" { return [] }
    let r1 = line.substring(sp1 + 1, len(line))
    let sp2 = r1.index_of(" ")
    if sp2 < 0 { return [] }
    let id = r1.substring(0, sp2)
    let r2 = r1.substring(sp2 + 1, len(r1))
    let sp3 = r2.index_of(" ")
    if sp3 < 0 { return [] }
    let st = r2.substring(0, sp3)
    let mut nm = r2.substring(sp3 + 1, len(r2)).trim()
    if len(nm) >= 2 && nm.substring(0, 1) == "\"" { nm = nm.substring(1, len(nm) - 1) }
    return [id, st, nm]
}

fn parse_roadmap(src: string) -> array {
    let lines = split(src, "\n")
    let mut rules = []
    let mut kind = ""
    let mut cid = ""; let mut cst = ""; let mut cnm = ""; let mut ck = []
    for raw_line in lines {
        let line = _rstrip(raw_line)
        if len(line) == 0 {
            if kind == "r" { rules.push([cid, cst, cnm, ck]) }
            kind = ""; ck = []
            continue
        }
        let f = line.substring(0, 1)
        if f == "#" { continue }
        if f == " " || f == "\t" {
            if kind == "" { continue }
            let s = line.trim_start()
            let sp = s.index_of(" ")
            if sp < 0 { continue }
            ck.push([s.substring(0, sp), s.substring(sp + 1, len(s)).trim()])
        } else {
            if kind == "r" { rules.push([cid, cst, cnm, ck]) }
            ck = []; kind = ""
            let fs = line.index_of(" ")
            if fs < 0 { continue }
            if line.substring(0, fs) == "roadmap" {
                let h = _hdr(line)
                if len(h) == 0 { continue }
                cid = h[0]; cst = h[1]; cnm = h[2]; kind = "r"
            }
        }
    }
    if kind == "r" { rules.push([cid, cst, cnm, ck]) }
    return rules
}

fn _load(path: string) -> array {
    let r = exec_with_status("test -f '" + path + "'")
    if r[1] != 0 { return [] }
    return parse_roadmap(to_string(read_file(path)))
}

fn _kv(keys: array, k: string) -> string {
    for kv in keys { if kv[0] == k { return kv[1] } }
    return ""
}

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

// map key → index; append if absent. Returns index.
fn _ensure_key(keys: array, vals_0: array, vals_1: array, vals_2: array, vals_3: array, vals_4: array, k: string) -> int {
    let mut i = 0
    while i < len(keys) { if keys[i] == k { return i } i = i + 1 }
    keys.push(k)
    vals_0.push(0) // done
    vals_1.push(0) // active
    vals_2.push(0) // planned
    vals_3.push(0) // blocked
    vals_4.push(0) // deferred
    return len(keys) - 1
}

// Pivot on arbitrary dimension: yields [[k, done, active, planned, blocked, deferred, total, pct]]
fn pivot(rules_by_repo: array, axis_key: string) -> array {
    let mut keys = []
    let mut v0 = []
    let mut v1 = []
    let mut v2 = []
    let mut v3 = []
    let mut v4 = []
    for rr in rules_by_repo {
        for rule in rr[1] {
            let bucket = _kv(rule[3], axis_key)
            let k = if len(bucket) > 0 { bucket } else { "<none>" }
            let idx = _ensure_key(keys, v0, v1, v2, v3, v4, k)
            let st = rule[1]
            if st == "done" { v0[idx] = v0[idx] + 1 }
            else if st == "active" { v1[idx] = v1[idx] + 1 }
            else if st == "planned" { v2[idx] = v2[idx] + 1 }
            else if st == "blocked" { v3[idx] = v3[idx] + 1 }
            else if st == "deferred" { v4[idx] = v4[idx] + 1 }
        }
    }
    let mut out = []
    let mut i = 0
    while i < len(keys) {
        let total = v0[i] + v1[i] + v2[i] + v3[i] + v4[i]
        let mut pct = 0
        if total > 0 { pct = (v0[i] * 100 + total / 2) / total }
        out.push([keys[i], to_string(v0[i]), to_string(v1[i]), to_string(v2[i]), to_string(v3[i]), to_string(v4[i]), to_string(total), to_string(pct)])
        i = i + 1
    }
    return out
}

fn pivot_by_repo(rules_by_repo: array) -> array {
    let mut out = []
    for rr in rules_by_repo {
        let mut d = 0; let mut a = 0; let mut p = 0; let mut b = 0; let mut f = 0
        for rule in rr[1] {
            let st = rule[1]
            if st == "done" { d = d + 1 }
            else if st == "active" { a = a + 1 }
            else if st == "planned" { p = p + 1 }
            else if st == "blocked" { b = b + 1 }
            else if st == "deferred" { f = f + 1 }
        }
        let total = d + a + p + b + f
        let mut pct = 0
        if total > 0 { pct = (d * 100 + total / 2) / total }
        out.push([rr[0], to_string(d), to_string(a), to_string(p), to_string(b), to_string(f), to_string(total), to_string(pct)])
    }
    return out
}

// Count gate markers in text
fn _count_occ(src: string, glyph: string) -> int {
    let n = len(src)
    let gl = len(glyph)
    if gl == 0 || n < gl { return 0 }
    let mut c = 0
    let mut i = 0
    while i <= n - gl {
        if src.substring(i, i + gl) == glyph { c = c + 1; i = i + gl }
        else { i = i + 1 }
    }
    return c
}

fn gate_markers_by_repo() -> array {
    let home = _home()
    let mut out = []
    for r in ["anima", "airgenome", "hexa-lang"] {
        let p = home + "/core/" + r + "/.roadmap"
        let chk = exec_with_status("test -f '" + p + "'")
        if chk[1] != 0 { continue }
        let src = to_string(read_file(p))
        let sat = _count_occ(src, "✓")
        let pend = _count_occ(src, "□")
        let tot = sat + pend
        let mut pct = 0
        if tot > 0 { pct = (sat * 100 + tot / 2) / tot }
        out.push([r, to_string(sat), to_string(pend), to_string(tot), to_string(pct)])
    }
    return out
}

fn _load_all() -> array {
    let home = _home()
    let mut out = []
    for r in ["anima", "airgenome", "hexa-lang"] {
        out.push([r, _load(home + "/core/" + r + "/.roadmap")])
    }
    return out
}

fn _je(s: string) -> string {
    let mut o = s.replace("\\", "\\\\")
    o = o.replace("\"", "\\\"")
    return o
}

fn _pivot_to_json(rows: array) -> string {
    let mut p = []; p.push("[")
    let mut first = true
    for r in rows {
        if !first { p.push(",") }
        p.push("{\"key\":\"")
        p.push(_je(r[0]))
        p.push("\",\"done\":")
        p.push(r[1])
        p.push(",\"active\":")
        p.push(r[2])
        p.push(",\"planned\":")
        p.push(r[3])
        p.push(",\"blocked\":")
        p.push(r[4])
        p.push(",\"deferred\":")
        p.push(r[5])
        p.push(",\"total\":")
        p.push(r[6])
        p.push(",\"pct\":")
        p.push(r[7])
        p.push("}")
        first = false
    }
    p.push("]")
    return p.join("")
}

fn _gate_to_json(rows: array) -> string {
    let mut p = []; p.push("[")
    let mut first = true
    for r in rows {
        if !first { p.push(",") }
        p.push("{\"repo\":\"")
        p.push(_je(r[0]))
        p.push("\",\"satisfied\":")
        p.push(r[1])
        p.push(",\"pending\":")
        p.push(r[2])
        p.push(",\"total\":")
        p.push(r[3])
        p.push(",\"pct\":")
        p.push(r[4])
        p.push("}")
        first = false
    }
    p.push("]")
    return p.join("")
}

fn _selftest() -> int {
    let all = _load_all()
    let phase = pivot(all, "phase")
    let track = pivot(all, "track")
    let repo = pivot_by_repo(all)
    let gm = gate_markers_by_repo()

    if len(phase) == 0 || len(track) == 0 {
        eprintln("selftest FAIL: empty pivots")
        return 1
    }

    // Ensure phase P1 rows exist (at least one in anima / hexa-lang).
    let mut has_p1 = false
    for r in phase { if r[0] == "P1" { has_p1 = true } }
    if !has_p1 {
        eprintln("selftest FAIL: P1 bucket missing")
        return 1
    }

    // Verify pct arithmetic: sum of done across repos should equal sum across phase rows
    let mut done_by_repo = 0
    for r in repo { done_by_repo = done_by_repo + parse_int(r[1]) }
    let mut done_by_phase = 0
    for r in phase { done_by_phase = done_by_phase + parse_int(r[1]) }
    if done_by_repo != done_by_phase {
        eprintln("selftest FAIL: done count mismatch " + to_string(done_by_repo) + " vs " + to_string(done_by_phase))
        return 1
    }

    println("phase rows: " + to_string(len(phase)))
    println("track rows: " + to_string(len(track)))
    for r in repo { println("  " + r[0] + " done=" + r[1] + " active=" + r[2] + " planned=" + r[3] + " blocked=" + r[4] + " def=" + r[5] + " total=" + r[6] + " pct=" + r[7]) }
    for g in gm { println("  gates " + g[0] + " sat=" + g[1] + " pend=" + g[2] + " pct=" + g[4]) }
    println("selftest PASS")
    return 0
}

fn parse_int(s: string) -> int {
    let mut n = 0
    let d = "0123456789"
    let mut i = 0
    let mut neg = false
    if len(s) > 0 && s.substring(0, 1) == "-" { neg = true; i = 1 }
    while i < len(s) {
        let c = s.substring(i, i + 1)
        if !d.contains(c) { break }
        n = n * 10 + d.index_of(c)
        i = i + 1
    }
    if neg { return 0 - n }
    return n
}

fn main() {
    let av = argv()
    let mut args = []
    let mut i = 2
    while i < len(av) { args.push(av[i]); i = i + 1 }
    if len(args) >= 1 && args[0] == "--selftest" { exit(_selftest()) }

    let all = _load_all()
    let phase = pivot(all, "phase")
    let track = pivot(all, "track")
    let repo = pivot_by_repo(all)
    let gm = gate_markers_by_repo()

    let mut p = []
    p.push("{\"by_phase\":")
    p.push(_pivot_to_json(phase))
    p.push(",\"by_track\":")
    p.push(_pivot_to_json(track))
    p.push(",\"by_repo\":")
    p.push(_pivot_to_json(repo))
    p.push(",\"gate_markers\":")
    p.push(_gate_to_json(gm))
    p.push("}")
    println(p.join(""))
}
