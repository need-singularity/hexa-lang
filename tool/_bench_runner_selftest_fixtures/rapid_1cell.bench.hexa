// rapid_1cell.bench.hexa — TUI-PRIM rapid 1-cell flush fixture
// @resolver-bypass(reason="bench fixture spawned by bench_runner.v0; subprocess of a tool-dir parent must bypass darwin landing")
//
// Workload: render_put 1 cell + render_flush, looped 100×. Mirrors
// packages/tui Level 2 rapid back-to-back single-cell change scenario.
//
// 3-way axis: hexa-native vs Ink rapid p50=16.33ms (16ms throttle).
// Prior in-process ns-bench (commit fca43e81 Mac arm64): p50 0.155ms (155µs)
//   → 105× over Ink. Per-fixture-spawn we expect process startup to dominate.
//
// raw 91 C3: ms-amortized hides the 100-iter inner-loop signal. The honest
// v0 reading is "startup + 100 flush union", which is still useful for the
// 3-way comparison since Ink/OpenTUI fixtures pay the same startup tax.

use "self/tui/render"

let _r1 = render_init()
let mut i = 0
while i < 100 {
    let cp = 33 + (i % 94)
    let _p = render_put(0, 0, chr(cp), -1, -1, 0)
    let _f = render_flush()
    i = i + 1
}
let _c = render_close()
exit(0)
