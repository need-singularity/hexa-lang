// fullscreen_rapid.bench.hexa — TUI-PRIM rapid fullscreen flush fixture
// @resolver-bypass(reason="bench fixture spawned by bench_runner.v0; subprocess of a tool-dir parent must bypass darwin landing")
//
// Workload: paint 80×24 once, then 100× rapid flushes. Each rapid flush
// changes a single cell relative to the prior frame (incremental diff).
//
// 3-way axis vs Ink rapid fullscreen p50 = 17.22ms.
// Prior in-process ns-bench (commits fca43e81 + 1e878482 Mac arm64):
//   p50 0.158ms → 109× over Ink.
//
// raw 91 C3: 100-iter inner loop is dominated by the 1920-cell initial paint.
// The "rapid" semantic at v0 (ms-amortized) is partially obscured; the
// in-process ns-bench remains the canonical signal for this metric.

use "self/tui/render"

let _r1 = render_init()
// Initial fullscreen paint
let mut y = 0
while y < 24 {
    let mut x = 0
    while x < 80 {
        let cp = 33 + ((x + y) % 94)
        let _p = render_put(x, y, chr(cp), -1, -1, 0)
        x = x + 1
    }
    y = y + 1
}
let _f0 = render_flush()
// Rapid loop: 1 cell change + flush, 100 iters
let mut iter = 0
while iter < 100 {
    let cp = 33 + (iter % 94)
    let _p = render_put(iter % 80, iter % 24, chr(cp), -1, -1, 0)
    let _f = render_flush()
    iter = iter + 1
}
let _c = render_close()
exit(0)
