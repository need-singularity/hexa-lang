// cold_start.bench.hexa — TUI-PRIM cold-start fixture
// @resolver-bypass(reason="bench fixture spawned by bench_runner.v0; subprocess of a tool-dir parent must bypass darwin landing")
//
// Workload: render_init + render_put + render_flush + render_close 1 round-trip.
// Bench runner (v0 ms-amortized) measures process-startup + parse + run union.
//
// raw 91 C3: ms granularity collapses sub-ms inner loop. The COLD-START bench
// is the one bench where ms granularity is honest — startup dominates flush.
//
// 3-way axis: hexa-native (this) vs Ink (packages/tui) vs OpenTUI (deferred).
//   - hexa-native AOT: dist_size 562560B (hive-hexa-bin), peak_rss measured separately
//   - prior measurement (TUI-PRIM .roadmap perf_results): cold start ~5ms Mac

use "self/tui/render"

let _r1 = render_init()
let _r2 = render_put(0, 0, "*", -1, -1, 0)
let _r3 = render_flush()
let _r4 = render_close()
exit(0)
