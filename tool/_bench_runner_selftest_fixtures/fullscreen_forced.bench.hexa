// fullscreen_forced.bench.hexa — TUI-PRIM forced fullscreen redraw fixture
// @resolver-bypass(reason="bench fixture spawned by bench_runner.v0; subprocess of a tool-dir parent must bypass darwin landing")
//
// Workload: 100× outer loop, each iter:
//   - render_clear (allocates blank back buffer)
//   - put 80×24 = 1920 cells (different glyph each row × col)
//   - render_flush (full diff, all cells changed)
//
// 3-way axis vs Ink fullscreen forced p50 = 0.294ms.
// Prior in-process ns-bench (commit 1e878482 Mac arm64): p50 0.236ms
//   → 1.25× over Ink baseline.
//
// raw 91 C3: ms-granularity outer measure of 100 iters → expect total in
// the tens of ms range; the per-iter signal is still recoverable via
// total_ms / 100 amortization at the bench_runner level.

use "self/tui/render"

let _r1 = render_init()
let mut iter = 0
while iter < 100 {
    let _c = render_clear()
    let mut y = 0
    while y < 24 {
        let mut x = 0
        while x < 80 {
            let cp = 33 + ((iter + x + y) % 94)
            let _p = render_put(x, y, chr(cp), -1, -1, 0)
            x = x + 1
        }
        y = y + 1
    }
    let _f = render_flush()
    iter = iter + 1
}
let _close = render_close()
exit(0)
