#!hexa strict
// tool/_spec_runner_selftest_fixtures/ok.spec.hexa — runner-selftest fixture (all-pass).
//
// Sentinel contract: last non-empty stdout line MUST be `selftest: PASS (n/n)`.
// This fixture emits `selftest: PASS (3/3)` so the runner tally counter
// reads total=3 / failed=0 for this spec.

let av = args()
let mut mode = ""
let mut i = 0
while i < len(av) {
    if av[i] == "selftest" { mode = "selftest" }
    i = i + 1
}

if mode == "selftest" {
    println("  PASS a")
    println("  PASS b")
    println("  PASS c")
    println("selftest: PASS (3/3)")
} else {
    println("ok.spec.hexa fixture — usage: hexa run <this> selftest")
}
