#!hexa strict
// tool/hx_downgrade.hexa — raw#0 tiered-lock Level 2 → Level 1 demotion
//
// PURPOSE
//   Undo `./hx harden`. Demotes the critical SSOT subset (default:
//   .raw .own) from Level 2 (chflags schg / root +i) back down to
//   Level 1 (chflags uchg / best-effort +i).
//
// USAGE
//   ./hexa tool/hx_downgrade.hexa --reason "unlock ceremony"
//
// FLOW
//   1. parse args, require --reason
//   2. probe `sudo -n true`; refuse on failure with instructions
//   3. sha fingerprint before
//   4. sudo chflags noschg / chattr -i on each critical target
//   5. chflags uchg / chattr +i (Level 1 restore)
//   6. sha fingerprint after
//   7. audit_append("downgrade", …)
//
// NOTE
//   On Linux the flag-level distinction collapses — `chattr +i` is
//   root-only either way. We still audit the transition so the event
//   record remains coherent across platforms.

use self.core.law_io
use tool.raw_audit
use tool.os_level_lock

fn _is_darwin() -> bool {
    let uname = to_string(exec("uname -s")).trim()
    return uname == "Darwin"
}

fn _is_linux() -> bool {
    let uname = to_string(exec("uname -s")).trim()
    return uname == "Linux"
}

fn _has_passwordless_sudo() -> bool {
    let r = exec_with_status("sudo -n true 2>/dev/null")
    return r[1] == 0
}

fn _current_user() -> string {
    let u = env("USER")
    if u != "" { return u }
    return to_string(exec("id -un")).trim()
}

fn _parse_args() -> array {
    // returns [reason, ok]
    let av = argv()
    let mut reason = ""
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--reason" {
            if i + 1 < len(av) { reason = av[i + 1]; i = i + 1 }
        }
        i = i + 1
    }
    let ok = reason != ""
    return [reason, ok]
}

fn _usage() {
    eprintln("usage: hexa tool/hx_downgrade.hexa --reason \"<text>\"")
    eprintln("")
    eprintln("  Demotes critical SSOT (.raw .own) from Level 2 → Level 1.")
    eprintln("  Requires passwordless sudo.")
}

// After clearing schg, re-apply Level 1 so the files never sit at Level 0
// (even briefly). On Darwin: chflags uchg. On Linux: chattr +i (root).
fn _reapply_level1(targets: array) -> int {
    let mut failures = 0
    for rel in targets {
        let mut rc = 0
        if _is_darwin() {
            let r = exec_with_status("chflags uchg '" + rel + "' 2>&1")
            rc = r[1]
        } else if _is_linux() {
            // best-effort first, then sudo
            let r = exec_with_status("chattr +i '" + rel + "' 2>/dev/null")
            if r[1] != 0 {
                let r2 = exec_with_status("sudo -n chattr +i '" + rel + "' 2>&1")
                rc = r2[1]
            }
        }
        if rc != 0 { failures = failures + 1 }
        else       { println("  L1        " + rel) }
    }
    return failures
}

fn main() -> int {
    let args = _parse_args()
    let reason = args[0]
    let ok = args[1]

    if !ok {
        _usage()
        return 2
    }

    if !_is_darwin() && !_is_linux() {
        eprintln("hx_downgrade: unsupported OS — no-op")
        return 0
    }

    if !_has_passwordless_sudo() {
        eprintln("hx_downgrade: passwordless sudo unavailable (`sudo -n true` failed).")
        eprintln("  Run `sudo -v` to cache credentials, then retry.")
        return 1
    }

    println("── hx downgrade (Level 2 → Level 1) ──")
    println("actor:   " + _current_user())
    println("reason:  " + reason)
    println("targets: " + _join(_critical_targets()))
    println("")

    let sha_before = ssot_fingerprint()

    // Step 1: clear Level 2 flag (schg / root +i)
    let rc1 = cmd_unlock_level2(_critical_targets())
    if rc1 != 0 {
        let sha_after_fail = ssot_fingerprint()
        audit_append("downgrade", _current_user(), reason, "fail",
                     sha_before, sha_after_fail)
        eprintln("hx_downgrade: FAILED clearing Level 2 — see errors above")
        return 1
    }

    // Step 2: restore Level 1 so we never leave targets fully unlocked
    println("")
    println("── restoring Level 1 ──")
    let nf = _reapply_level1(_critical_targets())
    let sha_after = ssot_fingerprint()

    if nf > 0 {
        audit_append("downgrade", _current_user(), reason,
                     "partial (L1 reapply failed on " + to_string(nf) + " target(s))",
                     sha_before, sha_after)
        eprintln("hx_downgrade: WARN — some targets left unlocked; run ./hx lock")
        return 1
    }

    audit_append("downgrade", _current_user(), reason, "ok", sha_before, sha_after)

    println("")
    println("── OK ──")
    println(".raw / .own demoted to Level 1 (user-removable uchg / best-effort +i).")
    println("Re-harden with: `./hx harden --reason \"...\"`")
    return 0
}

fn _join(a: array) -> string {
    let mut s = ""
    let mut first = true
    for x in a {
        if first { s = x; first = false }
        else     { s = s + " " + x }
    }
    return s
}

exit(main())
