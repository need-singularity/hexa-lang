// tool/roadmap_verify_pre_commit.hexa — OS-level pre-commit gate (raw#15 live doc)
//
// PURPOSE
//   git pre-commit hook entry. Runs deterministically (no Claude interpretation)
//   at commit time. Parses the current repo's .roadmap, detects gate tags in the
//   commit message (form: "[<CP_OR_RULE>]" — e.g. "[P1.AN11.c]", "[CP1]", "[raw#9]"),
//   verifies evidence, optionally flips □→✓ markers, and appends a raw_audit event.
//
// STDIN / ENV
//   env COMMIT_EDITMSG_PATH  — absolute path to COMMIT_EDITMSG. default .git/COMMIT_EDITMSG
//   env ROADMAP_VERIFY_DEBUG — if set, print debug lines to stderr.
//
// EXIT
//   0 → OK, commit proceeds.
//   1 → REJECT with reason printed to stderr.
//
// SIDE EFFECTS (ok path only)
//   - stage update to .roadmap if gate flips applied (□ → ✓ + SHA stamp)
//   - append 1 line to .raw-audit via tool/raw_audit.hexa (hash-chained)
//
// DESIGN
//   - Deterministic: uses only regex/contains on commit_msg + changed_files.
//   - Pass-through: if commit_msg has NO gate tags, exit 0 immediately (non-blocking).
//   - Conservative: evidence-missing → REJECT; malformed .roadmap → REJECT with diag.
//   - hexa-only (raw#9); bash shim is 1-liner (see tool/install_roadmap_hooks.hexa).

// raw_audit coupling is via CLI shell-out — avoids hexa `use` path friction
// from arbitrary repos (pre-commit runs with repo cwd, not hexa-lang).
fn _audit_append_cli(event: string, reason: string) -> bool {
    let ht = env("HOME") + "/core/hexa-lang/tool/raw_audit.hexa"
    let chk = exec_with_status("test -f '" + ht + "'")
    if chk[1] != 0 { return false }
    let hexa_bin = env("HOME") + "/.hx/bin/hexa"
    let cmd = hexa_bin + " " + ht + " append " + event +
              " pre-commit-hook '" + reason.replace("'", "\\'") + "' ok 2>/dev/null"
    let r = exec_with_status(cmd)
    return r[1] == 0
}

fn _rstrip(s: string) -> string {
    let mut end = len(s)
    while end > 0 {
        let c = s.substring(end - 1, end)
        if c == " " || c == "\t" || c == "\r" { end = end - 1 } else { break }
    }
    return s.substring(0, end)
}

fn _debug(msg: string) -> void {
    if env("ROADMAP_VERIFY_DEBUG") != "" {
        eprintln("roadmap_verify: " + msg)
    }
}

fn _commit_msg_path() -> string {
    let p = env("COMMIT_EDITMSG_PATH")
    if p != "" { return p }
    return ".git/COMMIT_EDITMSG"
}

fn _read_commit_msg() -> string {
    let p = _commit_msg_path()
    let chk = exec_with_status("test -f '" + p + "'")
    if chk[1] != 0 { return "" }
    return to_string(read_file(p))
}

fn _changed_files() -> array {
    let out = to_string(exec("git diff --cached --name-only 2>/dev/null"))
    let lines = split(out, "\n")
    let mut files = []
    for ln in lines {
        let t = ln.trim()
        if len(t) > 0 { files.push(t) }
    }
    return files
}

// Extract tags of the form "[...]" from the commit message.
// A gate tag must contain at least one '.' OR start with a known prefix
// ("CP", "raw#", "P0"-"P9"). This lets conventional-commit scopes like
// "[workspace_sync]" pass through without triggering gate verification.
fn _extract_gate_tags(msg: string) -> array {
    let mut tags = []
    let n = len(msg)
    let mut i = 0
    while i < n {
        let c = msg.substring(i, i + 1)
        if c == "[" {
            // find matching ]
            let mut j = i + 1
            let mut depth = 1
            while j < n && depth > 0 {
                let d = msg.substring(j, j + 1)
                if d == "[" { depth = depth + 1 }
                else if d == "]" { depth = depth - 1 }
                if depth > 0 { j = j + 1 }
            }
            if j < n && depth == 0 {
                let inner = msg.substring(i + 1, j)
                // discriminate: gate-like tag vs scope tag
                if _looks_gate_tag(inner) { tags.push(inner) }
                i = j + 1
                continue
            }
        }
        i = i + 1
    }
    return tags
}

fn _looks_gate_tag(s: string) -> bool {
    // accept: starts with "CP" / "raw#" / "P<digit>" / contains "AN" / contains "."
    if len(s) == 0 { return false }
    if s.starts_with("CP") { return true }
    if s.starts_with("raw#") { return true }
    if s.starts_with("FINAL") { return true }
    // P<digit>...
    if len(s) >= 2 {
        let p0 = s.substring(0, 1)
        let p1 = s.substring(1, 2)
        if p0 == "P" && p1 >= "0" && p1 <= "9" { return true }
    }
    if s.index_of("AN") >= 0 { return true }
    return false
}

// Verify evidence for a single claimed gate.
//   Rules (deterministic, conservative):
//     1. commit_msg must mention either a commit SHA reference OR "satisfied by"
//        OR a direct evidence path that exists in changed_files.
//     2. If tag references a CP id (e.g. "CP1"), a .roadmap entry with
//        `reaches CP1` must exist among changed or existing entries.
//     3. If tag references an AN id (e.g. "AN11.c"), a changed file path
//        matching "*an11_c*" (case-insensitive) must exist OR commit_msg
//        must contain "evidence:" field with a valid path.
fn _verify_evidence(tag: string, changed: array, msg: string) -> array {
    // returns [ok: bool, reason: string]
    let msg_l = msg.to_lower()
    // Rule 1: explicit "evidence:" field
    if msg.index_of("evidence:") >= 0 { return [true, "evidence-field"] }
    if msg.index_of("satisfied by") >= 0 { return [true, "satisfied-by"] }
    if msg.index_of("proof:") >= 0 { return [true, "proof-field"] }

    // Rule 2: AN tag heuristic — look for an11_<letter> substring in any changed file
    let low_tag = tag.to_lower()
    let an_idx = low_tag.index_of("an")
    if an_idx >= 0 {
        // extract digits+letter suffix after "an"
        let tail = low_tag.substring(an_idx, len(low_tag))
        // Find any changed file containing tail fragment
        for f in changed {
            let fl = f.to_lower()
            if fl.index_of(tail.replace(".", "_")) >= 0 { return [true, "file-match:" + f] }
            if fl.index_of(tail.replace(".", "")) >= 0 { return [true, "file-match:" + f] }
        }
    }

    // Rule 3: CP / raw# tag — changed .roadmap is sufficient as bookkeeping evidence
    if tag.starts_with("CP") || tag.starts_with("raw#") {
        for f in changed {
            if f == ".roadmap" { return [true, "roadmap-updated"] }
        }
    }

    // Rule 4: P<n> phase tag — require any change in shared/ or tool/ or docs/
    if len(tag) >= 2 {
        let p0 = tag.substring(0, 1)
        let p1 = tag.substring(1, 2)
        if p0 == "P" && p1 >= "0" && p1 <= "9" {
            for f in changed {
                if f.starts_with("shared/") || f.starts_with("tool/") ||
                   f.starts_with("docs/")   || f.starts_with("core/")  ||
                   f.starts_with("scripts/") || f == ".roadmap" {
                    return [true, "scope-match:" + f]
                }
            }
        }
    }

    return [false, "no evidence detected (expected: 'evidence:<path>' or 'satisfied by <sha>' in msg, or matching changed file)"]
}

// Flip "□ <tag>" markers → "✓ <tag> (commit:<sha>)" in .roadmap.
// Deterministic text replacement. The commit sha is unknown at pre-commit
// time, so we stamp "PENDING" and let post-commit or watcher resolve it.
fn _maybe_flip_roadmap(tags: array) -> bool {
    let chk = exec_with_status("test -f .roadmap")
    if chk[1] != 0 { return false }
    let src = to_string(read_file(".roadmap"))
    let mut out = src
    let mut flipped = false
    for tag in tags {
        // Match pattern "□ [<tag>]" literally → "✓ [<tag>] (commit:PENDING)".
        let needle = "□ [" + tag + "]"
        if out.index_of(needle) >= 0 {
            out = out.replace(needle, "✓ [" + tag + "] (commit:PENDING)")
            flipped = true
        }
    }
    if !flipped { return false }
    // .roadmap is chflags uchg — open append window.
    let _u = exec_with_status("chflags nouchg .roadmap 2>/dev/null")
    let w = write_file(".roadmap", out)
    let _r = exec_with_status("chflags uchg .roadmap 2>/dev/null")
    if !w { return false }
    // re-stage so the flip is part of this commit
    let _g = exec_with_status("git add .roadmap")
    return true
}

fn main() -> int {
    let msg = _read_commit_msg()
    if msg == "" {
        _debug("no commit msg found — pass-through")
        return 0
    }
    let tags = _extract_gate_tags(msg)
    if len(tags) == 0 {
        _debug("no gate tags — pass-through")
        return 0
    }
    _debug("found " + to_string(len(tags)) + " gate tag(s)")
    let changed = _changed_files()

    let mut failed = []
    let mut reasons = []
    for tag in tags {
        let v = _verify_evidence(tag, changed, msg)
        let ok = v[0]
        let reason = v[1]
        if !ok {
            failed.push(tag)
            reasons.push(reason)
        } else {
            _debug(tag + " → " + reason)
        }
    }

    if len(failed) > 0 {
        eprintln("roadmap_verify: REJECT — evidence missing for " + to_string(len(failed)) + " gate(s):")
        let mut i = 0
        while i < len(failed) {
            eprintln("  [" + failed[i] + "] " + reasons[i])
            i = i + 1
        }
        eprintln("")
        eprintln("To pass: include 'evidence:<path>' or 'satisfied by <sha>' in commit msg,")
        eprintln("or ensure a matching changed file is staged.")
        exit(1)
        return 1
    }

    // flip markers (best-effort; no-op if .roadmap lacks □ boxes)
    let _f = _maybe_flip_roadmap(tags)

    // raw_audit append — deterministic side effect (best-effort via CLI)
    let tag_list = tags.join(",")
    let _a = _audit_append_cli("roadmap_verify", "gates=" + tag_list)

    println("roadmap_verify: OK (" + to_string(len(tags)) + " gate(s) verified)")
    return 0
}
