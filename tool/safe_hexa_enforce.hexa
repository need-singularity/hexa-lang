// safe_hexa_enforce.hexa — shared harness library (import-safe, no top-level main)
// @allow-bare-exec
// @no-sandbox
//
// Philosophy: 2-line defense.
//   1st: shim ($HEXA_LANG/scripts/bin/hexa) — transparent wrap
//   2nd: this module — detects out-of-sandbox invocation in code → warn/block
//        absolute path ($HEXA_LANG/hexa) bypassing shim is caught here
//
// Usage:
//   import "../../hexa-lang/tool/safe_hexa_enforce.hexa"
//   fn main() { ensure_launchd_sandbox() ... }
//
// CLI mode: use safe_hexa_check.hexa (imports this library and runs CLI main)
//
// SAFE_HEXA_MODE:  strict(exit9) | warn(default, stderr only) | off(ignore)
// Legitimate bypass: HEXA_NO_LAUNCHD=1, XPC_SERVICE_NAME (launchd job), SAFE_HEXA_MODE=off

fn _in_launchd_sandbox() -> bool {
    if env("HEXA_NO_LAUNCHD") == "1" { return true }
    if env("XPC_SERVICE_NAME").len() > 0 { return true }
    return false
}

fn _safe_hexa_mode() -> string {
    let m = env("SAFE_HEXA_MODE")
    if m.len() == 0 { return "warn" }
    return m
}

// breach → sandbox_breaches.jsonl append. Silent on failure (protection intent is stderr).
// Path: $HEXA_LANG/state/sandbox_breaches.jsonl (append-only, standard hexa-lang convention)
// Schema: {ts, pid, ppid, mode, script, caller_cmd}
fn _log_breach(mode: string) {
    let home = env("HOME")
    if home.len() == 0 { return }
    let root = home + "/core/hexa-lang"
    let log = root + "/state/sandbox_breaches.jsonl"
    let ts = exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()  // @allow-bare-exec
    let pid = exec("echo $$").trim()  // @allow-bare-exec
    let ppid = exec("ps -o ppid= -p $$").trim()  // @allow-bare-exec
    let argv = args()
    let mut script = ""
    if argv.len() > 1 { script = argv[1] }
    // caller: ppid 의 커맨드라인 (shim 경유 추적)
    let caller_cmd = exec("ps -o command= -p " + ppid + " 2>/dev/null | head -c 120").trim().replace("\"", "\\\"")  // @allow-bare-exec
    let line = "{\"ts\":\"" + ts + "\",\"pid\":" + pid + ",\"ppid\":" + ppid +
               ",\"mode\":\"" + mode + "\",\"script\":\"" + script.replace("\"", "\\\"") +
               "\",\"caller\":\"" + caller_cmd + "\"}"
    // append-only, 실패 silent
    try { exec("printf '%s\\n' " + _shq(line) + " >> " + _shq(log)) } catch e {}  // @allow-bare-exec
}

fn _shq(s: string) -> string {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn ensure_launchd_sandbox() {
    let mode = _safe_hexa_mode()
    if mode == "off" { return }
    if _in_launchd_sandbox() { return }

    eprintln("[safe_hexa_enforce] WARN launchd sandbox not applied — raw hexa")
    eprintln("[safe_hexa_enforce]   jetsam=180 (Terminal-tier) → OOM may kill Terminal too")
    eprintln("[safe_hexa_enforce]   fix: use hexa shim ($HEXA_LANG/scripts/bin/hexa)")
    eprintln("[safe_hexa_enforce]   override: SAFE_HEXA_MODE=off")

    _log_breach(mode)

    if mode == "strict" {
        eprintln("[safe_hexa_enforce] STRICT — blocked, exit 9")
        exit(9)
    }
}
