#!hexa strict
// tool/hx_lock.hexa — blessed lock path (companion to hx_unlock)
//
// PURPOSE
//   Re-apply chflags uchg to all SSOT targets after an edit window.
//   Re-runs raw_all first — if rules are now broken, reports the
//   failure and LEAVES TREE UNLOCKED so the developer can fix rather
//   than losing work.
//
// FLOW
//   1. run raw_all (full)
//   2. on PASS → chflags uchg on all targets → audit "lock ok"
//   3. on FAIL → do NOT lock. audit "lock fail". exit 1.
//
// USAGE
//   ./hexa tool/hx_lock.hexa                 — explicit manual lock
//   ./hexa tool/hx_lock.hexa --auto          — invoked by relock daemon
//   ./hexa tool/hx_lock.hexa --force --reason "recovery"
//                                            — lock even if raw_all fails
//                                              (recovery path; audited as
//                                              FORCED; not recommended)

use "self/core/law_io"
use "tool/raw_audit"

fn _is_darwin() -> bool {
    let uname = to_string(exec("uname -s")).trim()
    return uname == "Darwin"
}

fn _parse_args() -> array {
    // returns [auto, force, reason]
    let av = argv()
    let mut auto = false
    let mut force = false
    let mut reason = ""
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--auto" { auto = true }
        else if a == "--force" { force = true }
        else if a == "--reason" {
            if i + 1 < len(av) { reason = av[i + 1]; i = i + 1 }
        }
        i = i + 1
    }
    return [auto, force, reason]
}

fn _run_raw_all() -> int {
    let r = exec_with_status("./build/hexa_stage0 tool/raw_all.hexa 2>&1")
    print(to_string(r[0]))
    return r[1]
}

fn _apply_lock() -> int {
    let r = exec_with_status("./build/hexa_stage0 tool/os_level_lock.hexa lock 2>&1")
    print(to_string(r[0]))
    return r[1]
}

fn main() -> int {
    let args = _parse_args()
    let auto = args[0]
    let force = args[1]
    let reason = args[2]

    if !_is_darwin() {
        eprintln("hx_lock: non-Darwin OS — no-op")
        return 0
    }

    let sha_before = ssot_fingerprint()

    let label = auto ? "auto-relock" : "manual-lock"
    if !auto { println("── hx lock (" + label + ") ──") }

    // gate: raw_all must pass, unless --force
    if !force {
        let rc = _run_raw_all()
        if rc != 0 {
            eprintln("")
            eprintln("hx_lock: raw_all exit=" + to_string(rc) + " — tree remains UNLOCKED.")
            eprintln("  Fix violations, then: ./hexa tool/hx_lock.hexa")
            eprintln("  Force (audited):     ./hexa tool/hx_lock.hexa --force --reason \"...\"")
            audit_append("lock", env("USER"),
                         auto ? "auto-relock after window" : "manual lock attempt",
                         "fail (raw_all " + to_string(rc) + ")",
                         sha_before, "-")
            return 1
        }
    }

    let lrc = _apply_lock()
    let sha_after = ssot_fingerprint()
    let tag = force ? "FORCED" : "ok"
    let why = force ? ("forced: " + reason) : (auto ? "auto-relock after window" : "manual lock")
    audit_append("lock", env("USER"), why, tag, sha_before, sha_after)

    if lrc != 0 {
        eprintln("hx_lock: chflags uchg failed exit=" + to_string(lrc))
        return 1
    }

    if !auto {
        println("")
        println("── OK ──")
        println("SSOT re-locked.")
    }
    return 0
}

exit(main())
