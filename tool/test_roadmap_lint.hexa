// tool/test_roadmap_lint.hexa — unit tests for checkpoint DSL (raw#15)
//
// Tests the new V1-V5 validations by invoking _parse_roadmap_text directly
// on synthetic inputs. Uses the same module functions as roadmap_lint.hexa.
// Exits 1 on failure, 0 on all-pass.
//
// Run: hexa tool/test_roadmap_lint.hexa
//
// NOTE: this file intentionally duplicates the helpers it needs rather than
// importing — stage0 interp has no module system. Keep in sync with
// tool/roadmap_lint.hexa.

fn _rstrip(s: string) -> string {
    let mut end = len(s)
    while end > 0 {
        let c = s.substring(end - 1, end)
        if c == " " || c == "\t" || c == "\r" { end = end - 1 } else { break }
    }
    return s.substring(0, end)
}

fn _parse_roadmap_header(line: string) -> array {
    let sp1 = line.index_of(" ")
    if sp1 < 0 { return [] }
    if line.substring(0, sp1) != "roadmap" { return [] }
    let rest1 = line.substring(sp1 + 1, len(line))
    let sp2 = rest1.index_of(" ")
    if sp2 < 0 { return [] }
    let id = rest1.substring(0, sp2)
    let rest2 = rest1.substring(sp2 + 1, len(rest1))
    let sp3 = rest2.index_of(" ")
    if sp3 < 0 { return [] }
    let status = rest2.substring(0, sp3)
    let mut name = rest2.substring(sp3 + 1, len(rest2)).trim()
    if len(name) >= 2 && name.substring(0, 1) == "\"" {
        name = name.substring(1, len(name) - 1)
    }
    return [id, status, name]
}

fn _parse_checkpoint_header(line: string) -> array {
    let sp1 = line.index_of(" ")
    if sp1 < 0 { return [] }
    if line.substring(0, sp1) != "checkpoint" { return [] }
    let rest1 = line.substring(sp1 + 1, len(line))
    let sp2 = rest1.index_of(" ")
    if sp2 < 0 { return [] }
    let id = rest1.substring(0, sp2)
    let mut name = rest1.substring(sp2 + 1, len(rest1)).trim()
    if len(name) >= 2 && name.substring(0, 1) == "\"" {
        name = name.substring(1, len(name) - 1)
    }
    return [id, name]
}

fn _parse_roadmap_text(src: string) -> array {
    let lines = split(src, "\n")
    let mut rules = []
    let mut checkpoints = []
    let mut kind = ""
    let mut cur_id = ""
    let mut cur_status = ""
    let mut cur_name = ""
    let mut cur_keys = []
    for raw_line in lines {
        let line = _rstrip(raw_line)
        if len(line) == 0 {
            if kind == "r" {
                rules.push([cur_id, cur_status, cur_name, cur_keys])
            }
            if kind == "c" {
                checkpoints.push([cur_id, cur_name, cur_keys])
            }
            kind = ""
            cur_keys = []
            continue
        }
        let first = line.substring(0, 1)
        if first == "#" { continue }
        if first == " " || first == "\t" {
            if kind == "" { continue }
            let stripped = line.trim_start()
            let sp = stripped.index_of(" ")
            if sp < 0 { continue }
            let key = stripped.substring(0, sp)
            let val = stripped.substring(sp + 1, len(stripped)).trim()
            cur_keys.push([key, val])
        } else {
            if kind == "r" {
                rules.push([cur_id, cur_status, cur_name, cur_keys])
            }
            if kind == "c" {
                checkpoints.push([cur_id, cur_name, cur_keys])
            }
            cur_keys = []
            kind = ""
            let first_sp = line.index_of(" ")
            if first_sp < 0 { continue }
            let tok = line.substring(0, first_sp)
            if tok == "roadmap" {
                let hdr = _parse_roadmap_header(line)
                if len(hdr) == 0 { continue }
                cur_id = hdr[0]
                cur_status = hdr[1]
                cur_name = hdr[2]
                kind = "r"
            }
            if tok == "checkpoint" {
                let chdr = _parse_checkpoint_header(line)
                if len(chdr) == 0 { continue }
                cur_id = chdr[0]
                cur_name = chdr[1]
                kind = "c"
            }
        }
    }
    if kind == "r" {
        rules.push([cur_id, cur_status, cur_name, cur_keys])
    }
    if kind == "c" {
        checkpoints.push([cur_id, cur_name, cur_keys])
    }
    return [rules, checkpoints]
}

fn _keys_first(keys: array, k: string) -> string {
    for kv in keys {
        if kv[0] == k { return kv[1] }
    }
    return ""
}

// ─── test harness ────────────────────────────────────────────────────

let mut fails = 0

fn expect_eq_int(name: string, got: int, want: int) -> int {
    if got == want {
        println("  ok  " + name + " = " + to_string(got))
        return 0
    }
    eprintln("  FAIL " + name + " got=" + to_string(got) + " want=" + to_string(want))
    return 1
}

fn expect_eq_str(name: string, got: string, want: string) -> int {
    if got == want {
        println("  ok  " + name + " = '" + got + "'")
        return 0
    }
    eprintln("  FAIL " + name + " got='" + got + "' want='" + want + "'")
    return 1
}

// T1: parse empty → empty rules + empty checkpoints
println("── T1 empty ──")
let t1 = _parse_roadmap_text("")
fails = fails + expect_eq_int("t1.rules_len", len(t1[0]), 0)
fails = fails + expect_eq_int("t1.cps_len", len(t1[1]), 0)

// T2: parse a valid rule + checkpoint block
println("── T2 rule + checkpoint ──")
let src2 = "checkpoint CP1 \"seed\"\n  condition  exec bench\n  gate       pass=1/1\n\nroadmap 1 active \"entry\"\n  track     ssot\n  phase     P0\n  eta       2026-04-19\n  why       test\n  reaches   CP1\n"
let t2 = _parse_roadmap_text(src2)
fails = fails + expect_eq_int("t2.rules_len", len(t2[0]), 1)
fails = fails + expect_eq_int("t2.cps_len", len(t2[1]), 1)
if len(t2[1]) == 1 {
    fails = fails + expect_eq_str("t2.cp_id", t2[1][0][0], "CP1")
    fails = fails + expect_eq_str("t2.cp_name", t2[1][0][1], "seed")
}
if len(t2[0]) == 1 {
    fails = fails + expect_eq_str("t2.rule_id", t2[0][0][0], "1")
    fails = fails + expect_eq_str("t2.rule_status", t2[0][0][1], "active")
    fails = fails + expect_eq_str("t2.rule_reaches", _keys_first(t2[0][0][3], "reaches"), "CP1")
}

// T3: multi-CP + FINAL detection
println("── T3 multi-CP ──")
let src3 = "checkpoint CP1 \"x\"\n  gate  a\n\ncheckpoint FINAL \"🧠 agi\"\n  gate  b\n"
let t3 = _parse_roadmap_text(src3)
fails = fails + expect_eq_int("t3.cps_len", len(t3[1]), 2)
if len(t3[1]) == 2 {
    let is_final = t3[1][1][1].contains("🧠")
    let got_final = 0
    if is_final { fails = fails + expect_eq_int("t3.final_detected", 1, 1) }
    else { fails = fails + expect_eq_int("t3.final_detected", 0, 1) }
}

// T4: backward compat — rule-only (no checkpoints)
println("── T4 rule-only backward compat ──")
let src4 = "roadmap 1 done \"x\"\n  track  ssot\n  phase  P0\n  eta    2026\n  why    seed\n  proof  .raw\n"
let t4 = _parse_roadmap_text(src4)
fails = fails + expect_eq_int("t4.rules_len", len(t4[0]), 1)
fails = fails + expect_eq_int("t4.cps_len", len(t4[1]), 0)

// T5: requires + verify + reaches multi-ref (comma split)
println("── T5 multi-ref CP keys ──")
let src5 = "checkpoint CP1 \"a\"\n  gate  x\n\ncheckpoint CP2 \"b\"\n  gate  y\n\nroadmap 9 active \"multi\"\n  track  ssot\n  phase  P0\n  eta    2026\n  why    test\n  reaches   CP1, CP2\n  requires  CP2\n  verify    CP1\n"
let t5 = _parse_roadmap_text(src5)
fails = fails + expect_eq_int("t5.rules_len", len(t5[0]), 1)
fails = fails + expect_eq_int("t5.cps_len", len(t5[1]), 2)
if len(t5[0]) == 1 {
    fails = fails + expect_eq_str("t5.reaches", _keys_first(t5[0][0][3], "reaches"), "CP1, CP2")
    fails = fails + expect_eq_str("t5.requires", _keys_first(t5[0][0][3], "requires"), "CP2")
    fails = fails + expect_eq_str("t5.verify", _keys_first(t5[0][0][3], "verify"), "CP1")
}

// ─── summary ────────────────────────────────────────────────────────
println("")
if fails == 0 {
    println("✅ ALL TESTS PASS")
    exit(0)
}
eprintln("🚫 " + to_string(fails) + " FAIL")
exit(1)
