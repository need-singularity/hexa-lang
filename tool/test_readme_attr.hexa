// tool/test_readme_attr.hexa — @readme attr 검증 실사례 테스트
// 실행: hexa run tool/test_readme_attr.hexa

use "self/attrs/core"
use "self/attrs/readme"

fn test_file(path: string, expected: string) {
    println("")
    println("━━━ " + path)
    println("    (예상: " + expected + ")")
    let mut raw = ""
    try {
        raw = to_string(read_file(path))
    } catch e {
        println("  [MISS] 파일 없음")
        return
    }
    let lines = raw.split("\n")
    println("  라인 수: " + to_string(len(lines)))

    let detected = detect_readme_marker(lines)
    println("  detected scope: '" + detected[0] + "'  found=" + to_string(detected[1]))

    let msgs = check_readme(path, lines)
    println("  위반 건수: " + to_string(len(msgs)))
    let mut i = 0
    for m in msgs {
        i = i + 1
        if i > 15 { println("  ... 생략"); break }
        println("  " + fmt_msg(m))
    }
}

// 실제 repo README 들 (마커 없음 → no-op 예상)
test_file("/Users/ghost/Dev/n6-architecture/README.md", "skip (마커없음)")
test_file("/Users/ghost/Dev/n6-architecture/domains/cognitive/hexa-speak/proto/README.md", "skip (마커없음)")
test_file("/Users/ghost/Dev/n6-architecture/experiments/anu_mc_verification/README.md", "skip (마커없음)")
test_file("/Users/ghost/Dev/n6-architecture/theory/roadmap-v2/README.md", "skip (마커없음)")

// 실제 repo README 에 강제로 marker 주입한 합성 체크 (in-memory)
fn test_with_injected_marker(path: string, sc: string) {
    println("")
    println("━━━ (주입 scope=" + sc + ") " + path)
    let mut raw = ""
    try {
        raw = to_string(read_file(path))
    } catch e {
        println("  [MISS] 파일 없음")
        return
    }
    let injected = "<!-- @readme(scope=" + sc + ") -->\n" + raw
    let lines = injected.split("\n")
    let msgs = check_readme(path, lines)
    println("  위반 건수: " + to_string(len(msgs)))
    let mut i = 0
    for m in msgs {
        i = i + 1
        if i > 10 { println("  ... 생략"); break }
        println("  " + fmt_msg(m))
    }
}

test_with_injected_marker("/Users/ghost/Dev/n6-architecture/README.md", "root")
test_with_injected_marker("/Users/ghost/Dev/n6-architecture/domains/cognitive/hexa-speak/proto/README.md", "domain")
test_with_injected_marker("/Users/ghost/Dev/n6-architecture/experiments/anu_mc_verification/README.md", "project")
test_with_injected_marker("/Users/ghost/Dev/n6-architecture/theory/roadmap-v2/README.md", "project")

// 합성 fixture — scope 별 동작 확인
test_file("/tmp/test_domain_readme.md",  "domain: 모든 단서 구비 → PASS")
test_file("/tmp/test_project_readme.md", "project: 모든 섹션 + bash 코드블록 → PASS")
test_file("/tmp/test_root_readme.md",    "root: 모든 섹션 구비 → PASS")
test_file("/tmp/test_noscope_readme.md", "scope 미지정 → warn + project default 적용")
test_file("/tmp/test_badscope_readme.md","unknown scope=library → error")
