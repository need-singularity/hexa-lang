// tool/migrate_fn_attr.hexa — Layer 3 (#4) migration helper
//
// Scans all active .hexa sources for naked `fn` / `pub fn` declarations
// and (in --apply mode) prepends `@lax` on the preceding line so the
// new parser gate (self/design/attr_mandatory_parser.md) accepts them.
//
// Default: DRY-RUN. Prints per-file count + totals. No writes.
// --apply: Actually rewrites files in place.
// --baseline: Write the naked-fn count to .hexa-lax-baseline (for CI).
//
// USAGE
//   hexa tool/migrate_fn_attr.hexa                # dry-run report
//   hexa tool/migrate_fn_attr.hexa --apply        # rewrite files
//   hexa tool/migrate_fn_attr.hexa --baseline     # write baseline
//
// SCOPE — active source dirs (excludes build/, target/, *.bak, *.hexanoport)
//   self/ tool/ stdlib/ bench/ examples/ tests/ tests_auto/
//
// SAFETY
//   - skips lines already preceded by an @attr line
//   - skips `fn` inside comment lines / blank lines handled by attr-line backtrack
//   - does NOT touch self/native/*.c (HX8 seed-freeze)
//   - does NOT run rebuild_stage0

use "self/stdlib/law_io"

fn _should_scan(path: string) -> bool {
    if path.contains("/build/")          { return false }
    if path.contains("/target/")         { return false }
    if path.contains(".bak")             { return false }
    if path.contains(".hexanoport")      { return false }
    if path.contains("/self/native/")    { return false }
    if !path.ends_with(".hexa")          { return false }
    return true
}

// Is this line a naked fn declaration (no preceding attr line)?
fn _is_naked_fn(lines: [string], idx: int) -> bool {
    if idx < 0 || idx >= len(lines) { return false }
    let t = lines[idx].trim()
    let is_fn = t.starts_with("fn ") || t.starts_with("pub fn ")
    if !is_fn { return false }
    // Walk backwards past blank / comment lines to find the nearest non-
    // trivial predecessor. If it starts with `@`, this fn is already
    // annotated — skip.
    let mut j = idx - 1
    while j >= 0 {
        let prev = lines[j].trim()
        if prev == ""                { j = j - 1; continue }
        if prev.starts_with("//")    { j = j - 1; continue }
        if prev.starts_with("@")     { return false }   // already annotated
        return true                                     // truly naked
    }
    return true
}

fn _scan_file(path: string) -> int {
    // Interpreter-native path kept for --apply (one file at a time), but
    // for dry-run/baseline totals we use _scan_all_awk() which delegates
    // to a single awk invocation over all files (see memory
    // feedback_interp_push_quadratic: per-file interp loops blow 4GB RSS
    // watchdog at N=2000+).
    let src = read_file(path)
    if type_of(src) != "string" { return 0 }
    let lines = src.split("\n")
    let mut count = 0
    let mut i = 0
    while i < len(lines) {
        if _is_naked_fn(lines, i) { count = count + 1 }
        i = i + 1
    }
    return count
}

// Scan all paths listed in `list_path` via a single awk invocation.
// Returns multiline "<count>  <path>\n...\n__TOTAL__ <grand_total>\n__FILES__ <n>".
// Each per-file line only emitted when count > 0.
fn _scan_all_awk(list_path: string) -> string {
    // awk replicates _is_naked_fn: at each non-blank/non-comment line,
    // check `last_attr` flag set by preceding `@...` lines. Count `fn`
    // / `pub fn` starts only when last_attr == 0.
    let prog = "awk 'BEGIN{tot=0;fc=0;files=0} FNR==1{if (prev!=\"\" && fc>0) print fc\"  \"prev; if (prev!=\"\") files++; fc=0; last_attr=0; prev=FILENAME} {s=$0; sub(/^[ \\t]+/,\"\",s); if (s==\"\") next; if (s ~ /^\\/\\//) next; if (s ~ /^@/) {last_attr=1; next} if (s ~ /^fn [A-Za-z_]/ || s ~ /^pub fn [A-Za-z_]/) {if (!last_attr) {fc++; tot++}} last_attr=0} END{if (prev!=\"\" && fc>0) print fc\"  \"prev; if (prev!=\"\") files++; print \"__TOTAL__ \" tot; print \"__FILES__ \" files}' $(cat " + list_path + ") 2>/dev/null"
    let mut raw = ""
    try { raw = exec(prog) } catch e { return "__TOTAL__ 0\n__FILES__ 0\n" }
    return raw
}

fn _apply_file(path: string) -> int {
    let src = read_file(path)
    if type_of(src) != "string" { return 0 }
    let lines = src.split("\n")
    let mut out = []
    let mut count = 0
    let mut i = 0
    while i < len(lines) {
        if _is_naked_fn(lines, i) {
            // Preserve fn's indentation on the @lax line
            let raw = lines[i]
            let mut ind = ""
            let mut k = 0
            while k < len(raw) {
                let ch = raw.substring(k, k + 1)
                if ch == " " || ch == "\t" { ind = ind + ch; k = k + 1; continue }
                break
            }
            out.push(ind + "@lax")
            count = count + 1
        }
        out.push(lines[i])
        i = i + 1
    }
    if count > 0 {
        safe_write_file(path, out.join("\n"))
    }
    return count
}

fn _gather_sources_listfile() -> string {
    // list_dir_recursive is not a runtime builtin, so shell out to find
    // and write results directly to a tmp file. Avoids constructing a
    // large interp array of path strings (see memory
    // feedback_interp_push_quadratic / feedback_hexa_on2_concat).
    // Returns the tmp path; empty string on failure.
    let list_path = "/tmp/migrate_fn_attr_list.txt"
    let cmd = "find self scripts stdlib bench examples tests tests_auto -type f -name '*.hexa' ! -path '*/build/*' ! -path '*/target/*' ! -name '*.bak' ! -name '*.hexanoport*' ! -path '*/self/native/*' 2>/dev/null > " + list_path
    try { let _ = exec(cmd) } catch e { return "" }
    return list_path
}

fn _gather_sources() -> [string] {
    // Legacy shim — reads the shell-built list file and returns its
    // lines as a hexa array. Used by --apply (one file at a time).
    let list_path = _gather_sources_listfile()
    if len(list_path) == 0 { return [] }
    let content = read_file(list_path)
    if type_of(content) != "string" { return [] }
    return content.split("\n")
}

fn main() {
    let argv = args()
    let mut apply = false
    let mut write_baseline = false
    let mut i = 1
    while i < len(argv) {
        let a = argv[i]
        if a == "--apply"    { apply = true }
        if a == "--baseline" { write_baseline = true }
        if a == "--help" {
            println("usage: hexa tool/migrate_fn_attr.hexa [--apply|--baseline]")
            return
        }
        i = i + 1
    }

    let mut total = 0
    let mut touched = 0
    let mut scanned = 0

    if apply {
        // Per-file interpreter path (one file mutated at a time; safe for
        // --apply since writes dominate cost).
        let files = _gather_sources()
        let mut fi = 0
        while fi < len(files) {
            let raw = files[fi]
            fi = fi + 1
            let path = raw.trim()
            if len(path) == 0 { continue }
            if !_should_scan(path) { continue }
            scanned = scanned + 1
            let n = _apply_file(path)
            if n > 0 {
                touched = touched + 1
                total = total + n
                println(to_string(n) + "  " + path)
            }
        }
    } else {
        // Dry-run / --baseline: shell out entirely — one find to build
        // the list file, one awk to count all fns. Interpreter never
        // iterates a 2000-entry string array (see memory
        // feedback_interp_push_quadratic).
        let list_path = _gather_sources_listfile()
        if len(list_path) == 0 {
            println("ERROR: _gather_sources_listfile failed")
            return
        }
        let report = _scan_all_awk(list_path)
        let rep_lines = report.split("\n")
        let mut li = 0
        while li < len(rep_lines) {
            let ln = rep_lines[li]
            li = li + 1
            if len(ln) == 0 { continue }
            if ln.starts_with("__TOTAL__ ") {
                total = to_int(ln.substring(10, len(ln)).trim())
            } else {
                if ln.starts_with("__FILES__ ") {
                    scanned = to_int(ln.substring(10, len(ln)).trim())
                } else {
                    touched = touched + 1
                    println(ln)
                }
            }
        }
    }

    println("")
    println("─── migrate_fn_attr summary ───────────────────────────")
    println("files scanned   : " + to_string(scanned))
    println("files with naked fn: " + to_string(touched))
    println("naked fn total  : " + to_string(total))
    if apply {
        println("mode            : APPLY (rewrote " + to_string(touched) + " files)")
    } else {
        println("mode            : DRY-RUN (no writes)")
    }

    if write_baseline {
        // Prefer safe_write_file (law-gated); fall back to shell if
        // module loader fails to resolve (preexisting interpreter bug
        // where `use "self/stdlib/law_io"` intermittently doesn't wire
        // up safe_write_file).
        let mut wrote = false
        try {
            let ok = safe_write_file(".hexa-lax-baseline", to_string(total) + "\n")
            wrote = ok
        } catch _e { wrote = false }
        if !wrote {
            let cmd = "printf '%s\\n' '" + to_string(total) + "' > .hexa-lax-baseline"
            try { let _ = exec(cmd); wrote = true } catch _e2 { wrote = false }
        }
        if wrote {
            println("baseline        : wrote " + to_string(total) + " to .hexa-lax-baseline")
        } else {
            println("baseline        : FAILED to write .hexa-lax-baseline")
        }
    }
}
