// tool/poc_gen_dispatch.hexa
//
// Generates self/poc/_dispatch.hexa from the filesystem layout:
//   self/poc/expr/<snake>.hexa     @kinds X[, Y]  → poc_ex_<snake>
//   self/poc/stmt/<snake>.hexa     @kinds X[, Y]  → poc_st_<snake>
//   self/poc/builtin/<snake>.hexa  @name X[, Y]   → poc_bi_<snake>
//                                  @method push   → method dispatch
//
// Emits 3 thin dispatcher fns:
//   fn poc_lower_expr(e) -> int         — routes by e.kind
//   fn poc_lower_stmt(stmt) -> int      — routes by stmt.kind
//   fn poc_ex_call(e) -> int            — routes by e.left.name (builtin)
//                                          + method dispatch + user fn fallback
//
// Usage:  hexa tool/poc_gen_dispatch.hexa
// Output: self/poc/_dispatch.hexa  (overwritten in place)

use "self/stdlib/law_io"

let CATS = [["expr", "ex"], ["stmt", "st"], ["builtin", "bi"]]

fn strip(s) {
    let mut i = 0
    while i < len(s) && (s[i] == " " || s[i] == "\t") { i = i + 1 }
    let mut j = len(s) - 1
    while j >= i && (s[j] == " " || s[j] == "\t" || s[j] == "\r" || s[j] == "\n") { j = j - 1 }
    let mut parts = []
    let mut k = i
    while k <= j { parts.push(s[k]); k = k + 1 }
    return parts.join("")
}

fn list_dir_hexa(dir) {
    let cmd_parts = ["ls ", dir, "/*.hexa 2>/dev/null"]
    let raw = exec(cmd_parts.join(""))
    if raw == "" { return [] }
    let lines = raw.split("\n")
    let mut out = []
    let mut i = 0
    while i < len(lines) {
        let s = strip(lines[i])
        if s != "" { out.push(s) }
        i = i + 1
    }
    return out
}

fn basename_noext(path) {
    let mut last = -1
    let mut i = 0
    while i < len(path) { if path[i] == "/" { last = i } ; i = i + 1 }
    let start = last + 1
    let mut parts = []
    let mut k = start
    while k < len(path) { parts.push(path[k]); k = k + 1 }
    let out = parts.join("")
    if len(out) > 5 {
        let n = len(out)
        let dot = out[n - 5]
        if dot == "." {
            let mut mparts = []
            let mut q = 0
            while q < n - 5 { mparts.push(out[q]); q = q + 1 }
            return mparts.join("")
        }
    }
    return out
}

// Extract the value after a "// @<tag>" prefix on `line`. `prefix` is the
// full literal (e.g. "// @kinds") so callers can hoist it across loop
// iterations and avoid O(calls) string concatenation building it here.
fn annot_val_p(line, prefix) {
    if !line.starts_with(prefix) { return "" }
    let mut i = len(prefix)
    while i < len(line) && (line[i] == " " || line[i] == "\t") { i = i + 1 }
    let mut parts = []
    while i < len(line) { parts.push(line[i]); i = i + 1 }
    return strip(parts.join(""))
}

fn split_by_comma(s) {
    let mut out = []
    let mut cur_parts = []
    let mut i = 0
    while i < len(s) {
        if s[i] == "," {
            out.push(strip(cur_parts.join("")))
            cur_parts = []
        } else {
            cur_parts.push(s[i])
        }
        i = i + 1
    }
    let last = strip(cur_parts.join(""))
    if last != "" { out.push(last) }
    return out
}

// Read file, extract (keys: string, is_method: bool, arity: string) from
// annotations near the top (scan first ~5 lines). arity is "" if not
// declared (current dispatcher behavior — no check), "*" for wildcard
// (variadic, e.g. syscall), or a decimal digit string like "1"/"2" for a
// fixed-arity guard. Only builtin files carry @arity.
// Returns ["", false, ""] if no @name/@method/@kinds annotation found.
fn read_annot(path, cat) {
    let src = read_file(path)
    if src == "" { return ["", false, ""] }
    let lines = src.split("\n")
    // Hoist prefix literals so we don't rebuild "// @tag" per call (was a
    // ~555-concat hotspot on 37 handler files × 5 lines × 3 tags).
    let P_ARITY = "// @arity"
    let P_NAME = "// @name"
    let P_METHOD = "// @method"
    let P_KINDS = "// @kinds"
    // First pass: scan for @arity anywhere in the top window (builtin only).
    let mut arity = ""
    if cat == "builtin" {
        let mut ai = 1
        while ai < len(lines) && ai < 5 {
            let sa = strip(lines[ai])
            if sa != "" {
                let av = annot_val_p(sa, P_ARITY)
                if av != "" { arity = av; ai = 5 }
            }
            ai = ai + 1
        }
    }
    // Second pass: resolve the primary annotation (@name/@method/@kinds).
    let mut i = 1
    while i < len(lines) && i < 5 {
        let s = strip(lines[i])
        if s != "" {
            if cat == "builtin" {
                let n = annot_val_p(s, P_NAME)
                if n != "" { return [n, false, arity] }
                let m = annot_val_p(s, P_METHOD)
                if m != "" { return [m, true, arity] }
            } else {
                let v = annot_val_p(s, P_KINDS)
                if v != "" { return [v, false, ""] }
            }
        }
        i = i + 1
    }
    return ["", false, ""]
}

// Pad a string to width `w` with trailing spaces, for column alignment.
fn pad(s, w) {
    let need = w - len(s)
    if need <= 0 { return s }
    let mut parts = [s]
    let mut i = 0
    while i < need { parts.push(" "); i = i + 1 }
    return parts.join("")
}

fn cmd_selftest() -> i64 {
    println("[poc_gen_dispatch selftest]")
    // 1) strip — trims whitespace + CRLF
    if strip("  ab \t\r\n") != "ab" { println("FAIL: strip"); return 1 }
    // 2) basename_noext — strips dir + .hexa (only the 5-char trailing case)
    if basename_noext("self/poc/expr/int_lit.hexa") != "int_lit" {
        println("FAIL: basename_noext long")
        return 1
    }
    // short path that lacks .hexa → passthrough
    if basename_noext("abc") != "abc" { println("FAIL: basename_noext short"); return 1 }
    // 3) annot_val_p — prefix hit + miss
    if annot_val_p("// @kinds IntLit, FloatLit", "// @kinds") != "IntLit, FloatLit" {
        println("FAIL: annot_val_p hit")
        return 1
    }
    if annot_val_p("// other", "// @kinds") != "" { println("FAIL: annot_val_p miss"); return 1 }
    // 4) split_by_comma
    let parts = split_by_comma(" Foo , Bar , Baz ")
    if len(parts) != 3 || parts[0] != "Foo" || parts[1] != "Bar" || parts[2] != "Baz" {
        println("FAIL: split_by_comma")
        return 1
    }
    // 5) pad — right-pad to width
    if pad("abc", 6) != "abc   " { println("FAIL: pad extend"); return 1 }
    if pad("abcdef", 3) != "abcdef" { println("FAIL: pad passthrough"); return 1 }
    println("[poc_gen_dispatch selftest] OK")
    return 0
}

fn main() {
    let av = args()
    if len(av) > 2 {
        let sub = av[2]
        if sub == "--selftest" || sub == "selftest" {
            exit(cmd_selftest())
        }
    }
    let mut parts = []
    parts.push("// self/poc/_dispatch.hexa\n")
    parts.push("//\n")
    parts.push("// AUTO-GENERATED by tool/poc_gen_dispatch.hexa — do not edit.\n")
    parts.push("// Regenerate: hexa tool/poc_gen_dispatch.hexa\n")
    parts.push("//\n")
    parts.push("// Dispatchers read from self/poc/<cat>/<snake>.hexa handlers via the\n")
    parts.push("// filename=dispatch-key convention. Adding a new kind = new file;\n")
    parts.push("// regenerating this file picks it up automatically.\n")
    parts.push("\n")

    // Collect per-cat: (kinds/names, fn_name) pairs.
    let mut expr_rows = []    // each: [kind, fn_name]
    let mut stmt_rows = []
    let mut bi_rows = []      // @name builtins
    let mut method_rows = []  // @method entries
    let mut c = 0
    while c < len(CATS) {
        let cat = CATS[c][0]
        let prefix = CATS[c][1]
        // Hoist "self/poc/" + cat and "poc_" + prefix + "_" via push/join.
        let dir_parts = ["self/poc/", cat]
        let dir = dir_parts.join("")
        let fn_head_parts = ["poc_", prefix, "_"]
        let fn_head = fn_head_parts.join("")
        let files = list_dir_hexa(dir)
        let mut fi = 0
        while fi < len(files) {
            let path = files[fi]
            let base = basename_noext(path)
            let fn_name_parts = [fn_head, base]
            let fn_name = fn_name_parts.join("")
            let r = read_annot(path, cat)
            let ann = r[0]
            let is_method = r[1]
            let arity = r[2]
            if ann == "" { fi = fi + 1; continue }
            let keys = split_by_comma(ann)
            let mut ki = 0
            while ki < len(keys) {
                let k = keys[ki]
                if k != "" {
                    if cat == "expr" { expr_rows.push([k, fn_name]) }
                    else if cat == "stmt" { stmt_rows.push([k, fn_name]) }
                    else if is_method { method_rows.push([k, fn_name]) }
                    else { bi_rows.push([k, fn_name, arity]) }
                }
                ki = ki + 1
            }
            fi = fi + 1
        }
        c = c + 1
    }

    // Emit fn poc_lower_expr.
    parts.push("fn poc_lower_expr(e) -> int {\n")
    let mut i = 0
    while i < len(expr_rows) {
        let k = expr_rows[i][0]
        let f = expr_rows[i][1]
        // Group Array + ArrayLit into a single OR row automatically? For now
        // the generator emits one line per kind — downstream short-circuit
        // evaluation means semantics are equivalent.
        let line_parts = ["    if e.kind == ", "\"", k, "\"", pad("", 13 - len(k)), " { return ", f, "(e) }\n"]
        parts.push(line_parts.join(""))
        i = i + 1
    }
    // Call bridges to the separately-emitted poc_ex_call below; it has no
    // self/poc/expr/call.hexa handler (intentionally removed e3cc6ae) because
    // its routing shape (method/builtin/user-fn) is fundamentally different
    // from other expr kinds. Without this line, `fn f()` call sites surface
    // as "unsupported expr kind: Call" (regression observed 2026-04-18).
    let call_parts = ["    if e.kind == ", "\"Call\"", pad("", 13 - 4), " { return poc_ex_call(e) }\n"]
    parts.push(call_parts.join(""))
    parts.push("    println(\"[poc] unsupported expr kind: \" + e.kind)\n")
    parts.push("    return -1\n")
    parts.push("}\n\n")

    // Emit fn poc_lower_stmt.
    parts.push("fn poc_lower_stmt(stmt) -> int {\n")
    let mut si = 0
    while si < len(stmt_rows) {
        let k = stmt_rows[si][0]
        let f = stmt_rows[si][1]
        let line_parts = ["    if stmt.kind == ", "\"", k, "\"", pad("", 17 - len(k)), " { return ", f, "(stmt) }\n"]
        parts.push(line_parts.join(""))
        si = si + 1
    }
    parts.push("    println(\"[poc] unsupported stmt kind: \" + stmt.kind)\n")
    parts.push("    return -1\n")
    parts.push("}\n\n")

    // Emit fn poc_ex_call — includes method dispatch + builtin dispatch + user fn fallback.
    parts.push("// Dispatcher for Call expressions: routes method calls, then named\n")
    parts.push("// builtins (from self/poc/builtin/), then user-defined fns.\n")
    parts.push("fn poc_ex_call(e) -> int {\n")
    // Method dispatch (for now only .push since that's the only @method).
    let mut mi = 0
    while mi < len(method_rows) {
        let k = method_rows[mi][0]       // e.g. ".push"
        let f = method_rows[mi][1]
        // Strip leading '.' if present.
        let name = if len(k) > 0 && k[0] == "." {
            let mut nparts = []
            let mut q = 1
            while q < len(k) { nparts.push(k[q]); q = q + 1 }
            nparts.join("")
        } else { k }
        let line_parts = ["    if e.left.kind == \"Field\" && e.left.name == \"", name, "\" && len(e.args) == 1 { return ", f, "(e) }\n"]
        parts.push(line_parts.join(""))
        mi = mi + 1
    }
    // Generic struct-method dispatch — obj.method(args) when obj is an
    // Ident whose struct type has an impl block registered. Methods are
    // registered as mangled fn ids "Struct__method" by poc_lower_program.
    parts.push("    if e.left.kind == \"Field\" && e.left.left.kind == \"Ident\" {\n")
    parts.push("        let struct_name = poc_var_struct_of(e.left.left.name)\n")
    parts.push("        if struct_name != \"\" {\n")
    parts.push("            let method_name = struct_name + \"__\" + e.left.name\n")
    parts.push("            let mid = poc_fn_id_for(method_name)\n")
    parts.push("            if mid >= 0 {\n")
    parts.push("                let self_vid = poc_lower_expr(e.left.left)\n")
    parts.push("                if self_vid < 0 { return -1 }\n")
    parts.push("                let mut arg_vids = [self_vid]\n")
    parts.push("                let mut ai = 0\n")
    parts.push("                while ai < len(e.args) {\n")
    parts.push("                    let av = poc_lower_expr(e.args[ai])\n")
    parts.push("                    if av < 0 { return -1 }\n")
    parts.push("                    arg_vids.push(av)\n")
    parts.push("                    ai = ai + 1\n")
    parts.push("                }\n")
    parts.push("                let mut mi = 0\n")
    parts.push("                while mi < len(arg_vids) {\n")
    parts.push("                    if arg_vids[mi] != mi { poc_emit(mn_mov(mi, arg_vids[mi])) }\n")
    parts.push("                    mi = mi + 1\n")
    parts.push("                }\n")
    parts.push("                poc_emit(mn_call(mid))\n")
    parts.push("                let result_vid = poc_fresh_vid()\n")
    parts.push("                if result_vid != 0 { poc_emit(mn_mov(result_vid, 0)) }\n")
    parts.push("                return result_vid\n")
    parts.push("            }\n")
    parts.push("        }\n")
    parts.push("    }\n")
    parts.push("    if e.left.kind != \"Ident\" {\n")
    parts.push("        println(\"[poc] call target must be Ident (PoC)\")\n")
    parts.push("        return -1\n")
    parts.push("    }\n")
    parts.push("    let name = e.left.name\n")
    let mut bi = 0
    // Group builtins with same fn (for min_max which has 2 names).
    // Emit fixed-arity guard when @arity <N> declared; skip guard for
    // wildcard ("*", e.g. syscall) or missing annotation (back-compat).
    while bi < len(bi_rows) {
        let k = bi_rows[bi][0]
        let f = bi_rows[bi][1]
        let a = bi_rows[bi][2]
        let has_arity = a != "" && a != "*"
        if has_arity {
            let line_parts = ["    if name == \"", k, "\"", pad("", 14 - len(k)), "&& len(e.args) == ", a, " { return ", f, "(e) }\n"]
            parts.push(line_parts.join(""))
        } else {
            let line_parts = ["    if name == \"", k, "\"", pad("", 14 - len(k)), "{ return ", f, "(e) }\n"]
            parts.push(line_parts.join(""))
        }
        bi = bi + 1
    }
    // User fn fallback.
    parts.push("    let target_fn_id = poc_fn_id_for(name)\n")
    parts.push("    if target_fn_id < 0 {\n")
    parts.push("        println(\"[poc] unbound fn: \" + name)\n")
    parts.push("        return -1\n")
    parts.push("    }\n")
    parts.push("    let mut arg_vids = []\n")
    parts.push("    let mut ai = 0\n")
    parts.push("    while ai < len(e.args) {\n")
    parts.push("        let av = poc_lower_expr(e.args[ai])\n")
    parts.push("        if av < 0 { return -1 }\n")
    parts.push("        arg_vids.push(av)\n")
    parts.push("        ai = ai + 1\n")
    parts.push("    }\n")
    parts.push("    let mut mi = 0\n")
    parts.push("    while mi < len(arg_vids) {\n")
    parts.push("        if arg_vids[mi] != mi { poc_emit(mn_mov(mi, arg_vids[mi])) }\n")
    parts.push("        mi = mi + 1\n")
    parts.push("    }\n")
    parts.push("    poc_emit(mn_call(target_fn_id))\n")
    parts.push("    let result_vid = poc_fresh_vid()\n")
    parts.push("    if result_vid != 0 { poc_emit(mn_mov(result_vid, 0)) }\n")
    parts.push("    return result_vid\n")
    parts.push("}\n")

    let out = parts.join("")
    let n_expr = str(len(expr_rows))
    let n_stmt = str(len(stmt_rows))
    let n_bi = str(len(bi_rows))
    let n_m = str(len(method_rows))
    safe_write_file("self/poc/_dispatch.hexa", out)
    let msg_parts = ["[poc-gen] wrote self/poc/_dispatch.hexa — ", n_expr, " expr kinds, ", n_stmt, " stmt kinds, ", n_bi, " builtins, ", n_m, " methods"]
    println(msg_parts.join(""))
}
