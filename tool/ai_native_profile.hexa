// ai_native_profile — source-transform profiler (S-1b safe track)
//
// Adds per-function call-count instrumentation to a .hexa source file
// WITHOUT modifying hexa_full.hexa or the interpreter. Works by text
// transformation: for each `fn name(...)`/`pub fn name(...)`, injects a
// single line at body entry that appends to a shared log file. After
// running the transformed program, the log is tallied and reported.
//
// Usage:
//   hexa tool/ai_native_profile.hexa <source.hexa>
//     → runs transformed source, emits top-K fn by call count
//
//   hexa tool/ai_native_profile.hexa <source.hexa> --top=20 --out=/tmp/prof.jsonl
//
// Output (stdout):
//   ═══ profile: <path> (elapsed Xs) ═══
//   rank  calls    fn
//      1    1024   tokenize
//      2     512   parse_stmt
//      ...
//   total <fn_count> distinct fns called, <call_total> invocations
//
// JSONL (optional): {fn, calls} per line.
//
// Limitations:
//   - Counts only (no per-fn timing — would need paired enter/exit hooks).
//     For timing, use tool/ai_native_bench.hexa on whole-file.
//   - Recursive fns counted correctly (each call increments).
//   - Anonymous/lambda fns skipped (transform only matches `fn name`).
//   - Transformed source written to /tmp/ai_native_prof_<stem>.hexa;
//     preserved for inspection.

use "self/core/law_io"

fn is_alpha(c) { let k = char_code(c, 0); return (k >= 97 && k <= 122) || (k >= 65 && k <= 90) || k == 95 }
fn is_alnum(c) { let k = char_code(c, 0); return (k >= 48 && k <= 57) || (k >= 97 && k <= 122) || (k >= 65 && k <= 90) || k == 95 }

fn match_word(src, i, word) {
    let n = len(src)
    let wn = len(word)
    if i + wn > n { return false }
    if src.substring(i, i + wn) != word { return false }
    if i > 0 && is_alnum(src[i - 1]) { return false }
    if i + wn < n && is_alnum(src[i + wn]) { return false }
    return true
}

// Insert a profile-append line right after the opening `{` of each fn body.
// Returns [transformed_src, fn_names_list]
fn transform(src, log_path) {
    let n = len(src)
    let mut i = 0
    let mut out = ""
    let mut fn_names = []
    while i < n {
        // detect `fn ` or `pub fn ` at start-of-token
        let at_tok_start = i == 0 || !is_alnum(src[i - 1])
        let mut is_fn = false
        let mut skip = 0
        if at_tok_start && match_word(src, i, "fn") { is_fn = true; skip = 2 }
        if at_tok_start && match_word(src, i, "pub") && i + 7 <= n && src.substring(i, i + 7) == "pub fn " { is_fn = true; skip = 7 }
        if !is_fn { out = out + src[i]; i = i + 1; continue }
        // capture the `fn ` (or `pub fn `) token
        out = out + src.substring(i, i + skip)
        i = i + skip
        // skip leading whitespace before fn name
        while i < n && src[i] == " " { out = out + src[i]; i = i + 1 }
        // collect fn name
        let name_start = i
        while i < n && is_alnum(src[i]) { i = i + 1 }
        let fn_name = src.substring(name_start, i)
        out = out + fn_name
        // skip until opening `(` of params, then matching `)`
        while i < n && src[i] != "(" { out = out + src[i]; i = i + 1 }
        if i >= n { break }
        out = out + src[i]; i = i + 1   // consume `(`
        let mut depth = 1
        while i < n && depth > 0 {
            let c = src[i]
            if c == "(" { depth = depth + 1 }
            if c == ")" { depth = depth - 1 }
            out = out + c
            i = i + 1
            if depth == 0 { break }
        }
        // scan to opening `{` of body (may be `-> type {` or just `{`)
        while i < n && src[i] != "{" && src[i] != "\n" && src[i] != ";" { out = out + src[i]; i = i + 1 }
        // tolerate return-type + braces on next line
        while i < n && src[i] != "{" {
            if src[i] == ";" { break }
            out = out + src[i]
            i = i + 1
        }
        if i >= n || src[i] == ";" { continue }
        // emit `{\n    exec(echo fn_name >> log)\n`
        out = out + "{\n"
        out = out + "    try { exec(\"echo " + fn_name + " >> " + log_path + "\") } catch e { }\n"
        i = i + 1
        fn_names.push(fn_name)
    }
    return [out, fn_names]
}

fn tally(log_path) {
    // Read the log and count occurrences of each fn name.
    // Returns list of [name, count] sorted desc by count.
    let mut names = []
    let mut counts = []
    try {
        let content = read_file(log_path)
        let lines = content.split("\n")
        let mut i = 0
        while i < len(lines) {
            let name = lines[i].trim()
            if name != "" {
                // find existing
                let mut found = false
                let mut j = 0
                while j < len(names) {
                    if names[j] == name { counts[j] = counts[j] + 1; found = true; j = len(names) }
                    j = j + 1
                }
                if !found { names.push(name); counts.push(1) }
            }
            i = i + 1
        }
    } catch e { }
    // insertion sort by count desc
    let n = len(counts)
    let mut i = 1
    while i < n {
        let ck = counts[i]
        let nk = names[i]
        let mut j = i - 1
        while j >= 0 && counts[j] < ck {
            counts[j + 1] = counts[j]
            names[j + 1] = names[j]
            j = j - 1
        }
        counts[j + 1] = ck
        names[j + 1] = nk
        i = i + 1
    }
    let mut out = []
    let mut k = 0
    while k < len(names) {
        out.push([names[k], counts[k]])
        k = k + 1
    }
    return out
}

fn basename(path) {
    let parts = path.split("/")
    return parts[len(parts) - 1]
}

fn cmd_selftest() -> i64 {
    println("[ai_native_profile selftest]")
    // Pure helpers: is_alpha, is_alnum, match_word, basename.
    if !is_alpha("q") { println("[ai_native_profile selftest] FAIL is_alpha"); return 1 }
    if !is_alnum("3") { println("[ai_native_profile selftest] FAIL is_alnum"); return 1 }
    if !match_word("fn foo(", 0, "fn") { println("[ai_native_profile selftest] FAIL match_word"); return 1 }
    if match_word("infn", 0, "fn")     { println("[ai_native_profile selftest] FAIL match_word boundary"); return 1 }
    if basename("/a/b/c.hexa") != "c.hexa" { println("[ai_native_profile selftest] FAIL basename"); return 1 }
    println("[ai_native_profile selftest] OK")
    return 0
}

fn main() {
    let argv = args()
    if len(argv) > 2 && (argv[2] == "--selftest" || argv[2] == "selftest") { exit(cmd_selftest()) }
    if len(argv) < 3 {
        println("usage: ai_native_profile.hexa <source.hexa> [--top=K] [--out=path.jsonl]")
        return
    }
    let src_path = argv[2]
    let mut top_k = 20
    let mut out_jsonl = ""
    let mut k = 3
    while k < len(argv) {
        let a = argv[k]
        if len(a) > 6 && a.substring(0, 6) == "--top=" { top_k = to_int(a.substring(6, len(a))) }
        if len(a) > 6 && a.substring(0, 6) == "--out=" { out_jsonl = a.substring(6, len(a)) }
        k = k + 1
    }

    let stem = basename(src_path)
    let log_path = "/tmp/ai_native_prof_" + stem + ".log"
    let xform_path = "/tmp/ai_native_prof_" + stem
    try { exec("rm -f '" + log_path + "'") } catch e { }

    let src = read_file(src_path)
    let result = transform(src, log_path)
    let xformed = result[0]
    let fn_count = len(result[1])
    safe_write_file(xform_path, xformed)

    // Run transformed source
    let hexa_bin = env_var("HEXA_LANG") + "/build/hexa_stage0"
    let t0 = timestamp()
    try {
        exec("'" + hexa_bin + "' '" + xform_path + "' >/dev/null 2>&1")
    } catch e { }
    let elapsed = timestamp() - t0

    // Tally
    let ranked = tally(log_path)
    println("═══ profile: " + src_path + " (elapsed " + to_string(elapsed) + "s) ═══")
    println("rank  calls     fn")
    let mut total_calls = 0
    let mut idx = 0
    while idx < len(ranked) && idx < top_k {
        let r = ranked[idx]
        let rank_str = to_string(idx + 1)
        let calls_str = to_string(r[1])
        // pad rank to 4, calls to 8
        let mut rp = rank_str
        while len(rp) < 4 { rp = " " + rp }
        let mut cp = calls_str
        while len(cp) < 8 { cp = " " + cp }
        println(rp + "  " + cp + "  " + r[0])
        total_calls = total_calls + r[1]
        idx = idx + 1
    }
    // Count ALL invocations (not just shown)
    let mut _ti = 0
    while _ti < len(ranked) {
        if _ti >= top_k { total_calls = total_calls + ranked[_ti][1] }
        _ti = _ti + 1
    }

    println("")
    println("ai-native-profile: " + to_string(len(ranked)) + " distinct fns called, " + to_string(total_calls) + " total invocations")
    println("  transformed source: " + xform_path)
    println("  raw log:            " + log_path)

    if out_jsonl != "" {
        let mut body = ""
        let mut j = 0
        while j < len(ranked) {
            body = body + "{\"fn\": \"" + ranked[j][0] + "\", \"calls\": " + to_string(ranked[j][1]) + "}\n"
            j = j + 1
        }
        safe_write_file(out_jsonl, body)
        println("  jsonl:              " + out_jsonl)
    }
}

