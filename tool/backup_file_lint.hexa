// tool/backup_file_lint.hexa — raw#34 enforcer (no-backup-files in working tree)
//
// usage:
//   hexa tool/backup_file_lint.hexa [<root>]        — scan (warn mode, exit 0)
//   hexa tool/backup_file_lint.hexa --sweep [<root>] — delete every match
//   hexa tool/backup_file_lint.hexa --strict [<root>] — exit 1 on any match
//
// rule: raw#34 no-backup-files — backups live in git history, not working tree.
// excludes: .git/, .claude/, .claude-*, node_modules/, target/, .shared-backup-*
//
// Output: JSON summary on stdout (schema: hexa.backup_file_lint.v1).
// raw#9 hexa-only, raw#10 proof-carrying, raw#12 empirical (direct fs scan).

fn _default_root() -> string {
    return to_string(exec("pwd")).trim()
}

fn _banned_patterns() -> array {
    // Glob patterns for `find -name` OR expression.
    return [
        "*.bak",
        "*.bak.*",
        "*-backup",
        "*-backup.*",
        "*-backup-*",
        "*.legacy-*",
        "*.orig",
        "*.pre-*",
    ]
}

fn _excludes_clause() -> string {
    // find -path '*/X' -prune OR chain; callers must wrap in parens with -o.
    let parts = [
        "-path '*/.git' -prune",
        "-path '*/.claude' -prune",
        "-path '*/.claude-*' -prune",
        "-path '*/node_modules' -prune",
        "-path '*/target' -prune",
        "-path '*/.shared-backup-*' -prune",
        "-path '*/.hx' -prune",
    ]
    let mut s = ""
    let mut i = 0
    while i < len(parts) {
        if i > 0 { s = s + " -o " }
        s = s + parts[i]
        i = i + 1
    }
    return s
}

fn _name_clause() -> string {
    let globs = _banned_patterns()
    let mut s = ""
    let mut i = 0
    while i < len(globs) {
        if i > 0 { s = s + " -o " }
        s = s + "-name '" + globs[i] + "'"
        i = i + 1
    }
    return s
}

fn _scan(root: string) -> array {
    let excludes = _excludes_clause()
    let names = _name_clause()
    let cmd = "find " + root + " " + excludes + " -o \\( " + names + " \\) -type f -print 2>/dev/null"
    let raw_out = to_string(exec(cmd))
    let lines = split(raw_out, "\n")
    let hits = []
    for ln in lines {
        let t = ln.trim()
        if t == "" { continue }
        hits.push(t)
    }
    return hits
}

fn _sweep(hits: array) -> int {
    let mut removed = 0
    let mut i = 0
    while i < len(hits) {
        let p = hits[i]
        let unlock = "chflags nouchg '" + p + "' 2>/dev/null; rm -f '" + p + "' 2>/dev/null && echo ok || echo fail"
        let r = to_string(exec(unlock)).trim()
        if r == "ok" { removed = removed + 1 }
        i = i + 1
    }
    return removed
}

fn _esc(s: string) -> string {
    let mut r = s.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    return r
}

fn _render(hits: array, mode: string, root: string, removed: int) -> string {
    let mut s = "{\"schema\":\"hexa.backup_file_lint.v1\""
    s = s + ",\"tool\":\"tool/backup_file_lint.hexa\""
    s = s + ",\"rule\":\"raw#34\""
    s = s + ",\"rule_slug\":\"no-backup-files\""
    s = s + ",\"mode\":\"" + mode + "\""
    s = s + ",\"root\":\"" + _esc(root) + "\""
    s = s + ",\"violation_count\":" + to_string(len(hits))
    s = s + ",\"removed_count\":" + to_string(removed)
    if len(hits) > 0 {
        s = s + ",\"severity\":\"block\""
        s = s + ",\"error\":{"
        s = s + "\"code\":\"BACKUP_FILE_IN_WORKING_TREE\""
        s = s + ",\"message\":\"Backup files detected in working tree. Git already preserves every prior revision; working-tree backup copies fragment SSOT and pollute grep/search results. Delete the listed files and rely on git log / git show for history.\""
        s = s + ",\"canonical_recovery\":\"git show <commit>:<path> or git log -- <path>\""
        s = s + ",\"how_to_avoid\":\"do not write files matching banned suffix patterns (.bak .bak.* -backup* .legacy-* .orig .pre-*); if prior revision is needed, open git log instead of copying the file\""
        s = s + ",\"auto_sweep_cmd\":\"hexa tool/backup_file_lint.hexa --sweep\""
        s = s + "}"
    } else {
        s = s + ",\"severity\":\"pass\""
    }
    s = s + ",\"violations\":["
    let mut i = 0
    while i < len(hits) {
        if i > 0 { s = s + "," }
        s = s + "\"" + _esc(hits[i]) + "\""
        i = i + 1
    }
    s = s + "]}"
    return s
}

fn main() -> int {
    let argv = args()
    let mut mode = "warn"
    let mut root = ""
    let mut i = 0
    while i < len(argv) {
        let a = argv[i]
        if a == "--sweep" {
            mode = "sweep"
        } else if a == "--strict" {
            mode = "strict"
        } else if a == "--warn" {
            mode = "warn"
        } else {
            root = a
        }
        i = i + 1
    }
    if root == "" { root = _default_root() }

    let hits = _scan(root)
    let mut removed = 0
    if mode == "sweep" { removed = _sweep(hits) }

    println(_render(hits, mode, root, removed))

    if mode == "strict" {
        if len(hits) > 0 { return 1 }
    }
    return 0
}

main()
