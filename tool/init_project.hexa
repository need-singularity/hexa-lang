// tool/init_project.hexa — scaffold a hexa project
//
// 정책 (HX4 self-host, 외부 의존 0):
//   풀 scaffold = project.hexa + README.md + .gitignore + (preset 따라) CLAUDE.md,
//   main.hexa, .gitkeep, LICENSE, 도메인 seed 등.
//   모든 hexa 코드는 .hexa, 비코드 컨텍스트 (README/.gitignore/LICENSE) 는 관례 파일명.
//
// Presets (see docs/hexa_init_scaffold_research.md §6, docs/hexa_init_examples/<preset>/):
//   minimum — project.hexa 만 (legacy/HX4 순혈)
//   basic (default 권장) — project.hexa + README.md + .gitignore
//   paper — 논문/도메인 중심 (paper+brief+academic 3 doc types)
//   lang  — hexa-lang 언어 도구 (self/ + main.hexa + tests/)
//   hub   — 허브/SSOT 리포 (shared/)
//   domain_only — 기존 프로젝트에 도메인 하나 추가 (merge)
//
// Usage (Q5: 범용):
//   hexa init [<target-dir>] [--preset <p>] [--name <n>]
//              [--license <SPDX>] [--register=<mode>]
//              [--no-git] [--migrate-from-json] [--axis <a>] [--id <id>]
//              [--force]
//
// target-dir 생략 = 현재 디렉토리.  flag 로 시작하면 target 은 "." 로 간주.
//
// Exit:
//   0 — 성공
//   1 — arg 오류 / 쓰기 실패

use "_init/preset_templates"
use "_init/license_templates"
use "_init/register"
use "self/core/law_io"

// ─────────────────────────────────────────────────────────────
// 환경/경로 유틸
// ─────────────────────────────────────────────────────────────

fn hexa_lang_root() -> string {
    let raw = env("HEXA_LANG")
    if raw != "" { return raw }
    return "/Users/ghost/Dev/hexa-lang"
}

fn basename(path: string) -> string {
    let parts = split(path, "/")
    let mut last = ""
    for p in parts {
        if p != "" { last = p }
    }
    return last
}

// ─────────────────────────────────────────────────────────────
// 플래그 파싱 helpers
// ─────────────────────────────────────────────────────────────

fn has_flag(argv: [string], flag: string) -> bool {
    let mut i = 0
    while i < len(argv) {
        if argv[i] == flag { return true }
        i = i + 1
    }
    return false
}

fn flag_value(argv: [string], flag: string) -> string {
    let mut i = 0
    while i < len(argv) {
        if argv[i] == flag && (i + 1) < len(argv) {
            return argv[i + 1]
        }
        // --flag=value 형식 지원
        let prefix = flag + "="
        if argv[i].starts_with(prefix) {
            return argv[i].substring(len(prefix), len(argv[i]))
        }
        i = i + 1
    }
    return ""
}

fn parse_preset(argv: [string]) -> string {
    let v = flag_value(argv, "--preset")
    if v != "" { return v }
    return "basic"
}

fn parse_project_name(argv: [string], target: string) -> string {
    let v = flag_value(argv, "--name")
    if v != "" { return v }
    // target 이 "." 이면 cwd 의 basename (PWD env 우선, fallback=`pwd`)
    if target == "." {
        let pwd_raw = env("PWD")
        if pwd_raw != "" {
            let b = basename(pwd_raw)
            if b != "" { return b }
        }
        let mut out = ""
        try { out = exec("pwd") } catch e { out = "" }
        let trimmed = out.trim()
        if trimmed != "" {
            let b = basename(trimmed)
            if b != "" { return b }
        }
        return "hexa_project"
    }
    let base = basename(target)
    if base != "" { return base }
    return "hexa_project"
}

fn preset_known(preset: string) -> bool {
    if preset == "minimum"     { return true }
    if preset == "minimal"     { return true }  // backward compat alias
    if preset == "basic"       { return true }
    if preset == "paper"       { return true }
    if preset == "lang"        { return true }
    if preset == "hub"         { return true }
    if preset == "domain_only" { return true }
    return false
}

// ─────────────────────────────────────────────────────────────
// Q1 — git 스마트 init
// ─────────────────────────────────────────────────────────────

fn is_inside_git_repo(dir: string) -> bool {
    let cmd = "git -C '" + dir + "' rev-parse --is-inside-work-tree 2>/dev/null"
    let mut out = ""
    try { out = exec(cmd) } catch e { return false }
    let trimmed = out.trim()
    if trimmed == "true" { return true }
    return false
}

fn auto_git_init(dir: string, no_git: bool) {
    if no_git {
        println("[git] --no-git 지정 — git init 건너뜀")
        return
    }
    if is_inside_git_repo(dir) {
        println("[git] 기존 git repo 내부 감지 — git init 건너뜀")
        return
    }
    try { exec("git -C '" + dir + "' init >/dev/null 2>&1") } catch e { }
    try { exec("git -C '" + dir + "' add -A >/dev/null 2>&1") } catch e { }
    // 첫 커밋 — author 설정이 없으면 실패할 수 있으므로 try-catch.
    let commit_cmd = "git -C '" + dir + "' commit -m '초기 scaffold (@hexa init)' >/dev/null 2>&1"
    let mut commit_ok = false
    try {
        exec(commit_cmd)
        commit_ok = true
    } catch e {
        commit_ok = false
    }
    if commit_ok {
        println("[git] git init + 첫 커밋 완료")
    } else {
        println("[git] git init 완료 (첫 커밋은 user.name/email 미설정 또는 기타 이유로 실패 — 수동 commit 필요)")
    }
}

// ─────────────────────────────────────────────────────────────
// 파일 쓰기 helpers — idempotent + --force 지원
// ─────────────────────────────────────────────────────────────

fn file_exists(path: string) -> bool {
    // `ls -d` 으로 존재 판정 — read_file 은 존재 안하는 파일에도 ""를 반환해서 부적합.
    // `2>/dev/null` 은 exec 보안 경고 회피 위해 shell wrapping 사용.
    let cmd = "ls -d " + path + " 2>/dev/null"
    let mut out = ""
    try { out = exec(cmd) } catch e { return false }
    return out.trim() != ""
}

fn last_slash_idx(path: string) -> int {
    // path 내 마지막 `/` 위치 탐색 (rfind 대체 — 수동 스캔).
    let cs = path.chars()
    let mut i = len(cs) - 1
    while i >= 0 {
        if cs[i] == "/" { return i }
        i = i - 1
    }
    return -1
}

fn ensure_parent_dir(path: string) {
    // path 의 마지막 / 이전까지 mkdir -p
    let idx = last_slash_idx(path)
    if idx <= 0 { return }
    let dir = path.substring(0, idx)
    try { exec("mkdir -p '" + dir + "'") } catch e { }
}

fn write_scaffold_file(target: string, rel_path: string, content: string, force: bool) -> int {
    // rel_path 끝이 `.gitkeep` 이면 빈 파일 생성.
    let full = target + "/" + rel_path
    if file_exists(full) && !force {
        // project.hexa 와 같은 핵심 파일 충돌 경고
        if rel_path == "project.hexa" {
            println("[skip] " + rel_path + " 이미 존재 (--force 로 덮어쓰기 가능)")
        } else {
            println("[skip] " + rel_path + " 이미 존재")
        }
        return 0
    }
    ensure_parent_dir(full)
    try {
        safe_write_file(full, content)
        println("[write] " + rel_path)
        return 1
    } catch e {
        println("[error] " + rel_path + " 쓰기 실패: " + e.to_string())
        return -1
    }
}

// ─────────────────────────────────────────────────────────────
// migrate helpers — .{attr}-rules.json → @<attr>_rules 블록 부가
// ─────────────────────────────────────────────────────────────

fn migrate_one(target: string, attr: string) -> string {
    let path = target + "/." + attr + "-rules.json"
    let mut raw = ""
    try { raw = read_file(path) } catch e { raw = "" }
    if raw == "" { return "" }
    return migrate_stub_block(attr, raw)
}

fn migrate_block(target: string) -> string {
    let attrs = ["doc", "readme", "domain", "sealed", "publish"]
    let mut parts = []
    let mut any = false
    let mut i = 0
    while i < len(attrs) {
        let piece = migrate_one(target, attrs[i])
        if piece != "" {
            if !any {
                parts.push("\n// ─────────────────────────────────────────────────────────────\n")
                parts.push("// Migrated blocks (from legacy .<attr>-rules.json files)\n")
                parts.push("// ─────────────────────────────────────────────────────────────\n\n")
                any = true
            }
            parts.push(piece)
        }
        i = i + 1
    }
    return parts.join("")
}

// ─────────────────────────────────────────────────────────────
// usage
// ─────────────────────────────────────────────────────────────

fn usage() {
    println("usage: hexa init [<target-dir>] [options]")
    println("")
    println("풀 scaffold = project.hexa + README.md + .gitignore + preset 에 따라 확장.")
    println("target-dir 생략 = 현재 디렉토리.")
    println("")
    println("Presets (--preset):")
    println("  minimum     — project.hexa 하나만 (HX4 순혈)")
    println("  basic       — project.hexa + README.md + .gitignore (default)")
    println("  paper       — 논문/도메인 중심 (@doc paper|brief|academic 3 type)")
    println("  lang        — hexa-lang 언어 도구 (self/ + main.hexa)")
    println("  hub         — 허브/SSOT (shared/config, shared/rules, shared/harness)")
    println("  domain_only — 기존 프로젝트에 도메인 하나 추가 (merge)")
    println("")
    println("Options:")
    println("  --name <n>              프로젝트명 (기본 = target basename)")
    println("  --license <SPDX>        MIT | Apache-2.0 | MPL-2.0 (LICENSE 생성)")
    println("  --register=<mode>       project | domain | none (nexus registry 등록)")
    println("  --no-git                git init 건너뜀")
    println("  --migrate-from-json     .<attr>-rules.json 기존 파일 merge")
    println("  --axis <a> --id <id>    domain_only 전용")
    println("  --force                 기존 파일 덮어쓰기")
    println("")
    println("See $HEXA_LANG/docs/hexa_init_scaffold_research.md for full spec.")
}

// ─────────────────────────────────────────────────────────────
// domain_only preset — merge mode
// ─────────────────────────────────────────────────────────────

fn run_domain_only(target: string, domain_id: string, axis: string, force: bool, register_mode: string) -> int {
    if domain_id == "" || axis == "" {
        println("error: --preset domain_only 는 --axis <a> --id <id> 필수")
        return 1
    }
    let rel = "domains/" + axis + "/" + domain_id + "/" + domain_id + ".md"
    let content = render_domain_seed_md(domain_id, axis)
    let wrote = write_scaffold_file(target, rel, content, force)
    if wrote < 0 { return 1 }
    // .sealed.hash placeholder
    let seal_rel = "domains/" + axis + "/" + domain_id + "/.sealed.hash"
    write_scaffold_file(target, seal_rel, "", force)
    println("")
    println("도메인 추가: " + axis + "/" + domain_id)
    println("  → " + target + "/" + rel)
    if register_mode == "domain" {
        register_domain(target, domain_id, axis)
    }
    return 0
}

// ─────────────────────────────────────────────────────────────
// selftest (coverage batch — minimal pure-fn asserts)
// ─────────────────────────────────────────────────────────────

fn _selftest() -> int {
    println("[init_project selftest]")
    // 1) hexa_lang_root returns a non-empty path
    let r = hexa_lang_root()
    if len(r) == 0 { eprintln("FAIL: hexa_lang_root empty"); return 1 }
    // 2) preset_known round-trip (pure)
    if !preset_known("minimum") { eprintln("FAIL: preset_known(minimum)"); return 1 }
    if preset_known("not_a_preset_xyz") { eprintln("FAIL: preset_known bogus"); return 1 }
    println("[init_project selftest] OK")
    return 0
}

// ─────────────────────────────────────────────────────────────
// main
// ─────────────────────────────────────────────────────────────

fn main() {
    let raw = args()
    let mut argv = []
    let mut i = 2
    while i < len(raw) {
        argv.push(raw[i])
        i = i + 1
    }

    // --selftest 최우선 dispatch (coverage batch)
    if has_flag(argv, "--selftest") || has_flag(argv, "selftest") {
        exit(_selftest())
    }

    // --help / -h 요청
    if has_flag(argv, "--help") || has_flag(argv, "-h") {
        usage()
        exit(0)
    }

    // Q5 — target 결정
    // argv[0] 이 flag (-- 로 시작) 또는 argv 비어있음 → target = "."
    let mut target = "."
    if len(argv) > 0 && !argv[0].starts_with("--") {
        target = argv[0]
    }

    let preset = parse_preset(argv)
    if !preset_known(preset) {
        println("error: unknown --preset '" + preset + "'")
        println("       (want: minimum|basic|paper|lang|hub|domain_only)")
        exit(1)
    }

    let project_name = parse_project_name(argv, target)
    let no_git = has_flag(argv, "--no-git")
    let want_migrate = has_flag(argv, "--migrate-from-json")
    let force = has_flag(argv, "--force")

    // Q2 — license
    let license_spdx = flag_value(argv, "--license")
    if license_spdx != "" && !license_known(license_spdx) {
        println("error: unsupported --license '" + license_spdx + "'")
        println("       (지원: MIT | Apache-2.0 | MPL-2.0)")
        exit(1)
    }
    let license_author = project_name
    let license_year = "2026"

    // Q4 — register
    let register_mode = flag_value(argv, "--register")
    if register_mode != "" && register_mode != "project" && register_mode != "domain" && register_mode != "none" {
        println("error: --register 값은 project|domain|none (입력: '" + register_mode + "')")
        exit(1)
    }

    // 도메인 관련
    let domain_id = flag_value(argv, "--id")
    let axis = flag_value(argv, "--axis")

    // target 디렉토리 생성
    try { exec("mkdir -p '" + target + "'") } catch e { }

    println("─── hexa init ───")
    println("target : " + target)
    println("name   : " + project_name)
    println("preset : " + preset)
    if license_spdx != "" { println("license: " + license_spdx) }
    if register_mode != "" && register_mode != "none" { println("register: " + register_mode) }
    println("")

    // domain_only 분기
    if preset == "domain_only" {
        let rc = run_domain_only(target, domain_id, axis, force, register_mode)
        exit(rc)
    }

    // render 풀 scaffold
    let hx = hexa_lang_root()
    let files = render_scaffold(preset, project_name, hx, domain_id, axis, license_spdx, license_author, license_year)

    // flat [path, content, path, content, ...] 순회
    let mut idx = 0
    let mut written = 0
    while idx + 1 < len(files) {
        let rel_path = files[idx]
        let mut content = files[idx + 1]
        // project.hexa 에 migrate 블록 부가
        if rel_path == "project.hexa" && want_migrate {
            content = content + migrate_block(target)
        }
        // merge-safe guard — .raw 와 .own 은 기존 파일이 있으면 --force 무시하고 스킵.
        // 이 두 파일은 프로젝트의 SSOT (enforcement 원점) 이므로 init 은 절대
        // 덮어쓰지 않는다. domain_only 이외의 preset 재실행도 안전하게 보존된다.
        if rel_path == ".raw" || rel_path == ".own" {
            let full = target + "/" + rel_path
            if file_exists(full) {
                println("[init] " + rel_path + " already present — skipped (merge-safe)")
                idx = idx + 2
                continue
            }
            // .raw 가 빈 문자열이면 render_raw_seed 가 fail 한 것 — 쓰기 중단.
            if rel_path == ".raw" && content == "" {
                println("[error] .raw seed empty (hexa-lang canonical read failed) — STOP")
                exit(1)
            }
        }
        let rc = write_scaffold_file(target, rel_path, content, force)
        if rc > 0 { written = written + 1 }
        idx = idx + 2
    }

    println("")
    println("scaffolded " + to_string(written) + " files at " + target)

    // Q1 — git 스마트
    auto_git_init(target, no_git)

    // Q4 — register
    if register_mode == "project" {
        register_project(target, project_name, preset)
    } else if register_mode == "domain" {
        if domain_id != "" && axis != "" {
            register_domain(target, domain_id, axis)
        } else {
            println("[register] warn: --register=domain 은 --axis --id 필요 — skip")
        }
    }

    println("")
    println("policy SSOT (live scan): " + hx + "/self/attrs/")
    if preset != "minimum" && preset != "minimal" {
        println("next: cd " + target + " && hexa policy")
        // day-zero enforcement hint — .raw+.own scaffolded for this preset.
        println("hint: run './hexa tool/own_lint.hexa' in " + target + " to verify .own is a monotonic strengthening of .raw")
    } else {
        println("next: cd " + target + " && cat project.hexa")
    }
}
