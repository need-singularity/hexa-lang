// tool/tui_demo_pi_lines.hexa — TUI-PRIM T1.C Surface 2 line-array demo
//
// Counterpart to tool/tui_demo_keypress.hexa (which emits ANSI to a real
// TTY). This variant emits the back buffer as plain UTF-8 lines + a
// frame sentinel — the wire format consumed by pi TUI Component
// adapters (packages/tui/src/components/hexa-tui-bridge.ts).
//
// Frame protocol (line-delimited stdout):
//   <row 0 glyphs>
//   <row 1 glyphs>
//   ...
//   <row N-1 glyphs>
//   __FRAME_END__
//
// Each frame is exactly ROWS + 1 lines. Parent side reads until the
// sentinel, treats the prior ROWS lines as the current frame.
//
// Input protocol (line-delimited stdin):
//   "key:<bytes>"      — forward bytes to L2 input decoder (raw bytes
//                        URL-encoded for safe newline transport)
//   "resize:R:C"       — set new dimensions
//   "quit"             — clean exit
//
// For T1.C scope this demo handles the OUTPUT side (frame emission)
// fully. The INPUT side reads stdin lines and emits a status frame
// (no real key decoding from stdin lines yet — adapter sends through
// term_read_byte which only fires on real TTY).

use "self/tui/render"
use "self/tui/wire"
use "self/tui/widget/box"
use "self/tui/widget/text"

let mut _counter = 0
let mut _last_input = ""

// Read a single \n-terminated line from stdin via L1 term_read_byte.
// Returns the line WITHOUT the trailing newline. Returns "" on EOF.
fn _read_line_from_stdin() -> string {
    let mut parts = []
    while true {
        let b = term_read_byte()
        if b < 0 { break }
        if b == 10 { break }       // \n — end of line
        if b == 13 { break }       // \r (some terminals)
        parts.push(chr(b))
    }
    return parts.join("")
}

fn draw_scene() -> int {
    let _c = render_clear()
    let dims = render_dims()
    let rows = dims[0]
    let cols = dims[1]
    let _b = box_draw(0, 0, cols, rows, -1, -1, 0, 1)
    let _t1 = text_label(2, 0, " HexaTuiBridge demo (line-array mode) ", -1, -1, 1)
    let _l1 = text_label(2, 2, "frame counter : " + to_string(_counter), -1, -1, 0)
    let _l2 = text_label(2, 3, "last input    : " + _last_input, -1, -1, 0)
    let _l3 = text_label(2, 4, "dims          : " + to_string(rows) + "x" + to_string(cols), -1, -1, 0)
    let _l4 = text_label(2, rows - 2, "wire surface 2: pi TUI Component compat", -1, -1, 0)
    return 0
}

fn emit_frame() {
    let lines = wire_pi_render_lines()
    let mut i = 0
    while i < len(lines) {
        println(lines[i])
        i = i + 1
    }
    println("__FRAME_END__")
}

let _av = argv()
let mut max_frames = 0
let mut i_av = 0
while i_av < len(_av) {
    if _av[i_av] == "--max-frames" {
        if i_av + 1 < len(_av) { max_frames = to_int(_av[i_av + 1]) }
    }
    if _av[i_av] == "--help" || _av[i_av] == "-h" {
        println("tui_demo_pi_lines — line-array Surface 2 demo")
        println("  Emits frame on stdout as ROWS lines + __FRAME_END__ sentinel.")
        println("  --max-frames N  : exit after N frames (default unbounded)")
        exit(0)
    }
    i_av = i_av + 1
}

let r = render_init()
if r != 0 { eprintln("render_init failed"); exit(3) }

// Frame loop — emit a frame, read stdin line, mutate state, repeat.
let mut running = 1
while running == 1 {
    _counter = _counter + 1
    let _ = draw_scene()
    emit_frame()

    if max_frames > 0 && _counter >= max_frames { running = 0 }
    if running == 1 {
        // Read one stdin line (blocks). This is the slow path — for a
        // real bridge the parent would write multiple input lines per
        // frame. For the demo we treat 1 input → 1 frame as the cycle.
        let line = _read_line_from_stdin()
        if line == "" { running = 0 }
        if line == "quit" { running = 0 }
        if line.substring(0, 4) == "key:" {
            _last_input = line.substring(4, len(line))
        }
        if line.substring(0, 7) == "resize:" {
            // Future: parse R:C, call render_resize. For now, just record.
            _last_input = line
        }
    }
}

let _close = render_close()
exit(0)
