#!hexa strict
// tool/doctor.hexa — 6-check self-diagnostic for the hexa shim ecosystem
//
// Checks (all plain-text OK/FAIL — no emojis):
//   1. shim-exist      — every shim_names() entry present in $HEXA_HOME/shared/bin
//   2. path-inject     — ~/.zshenv contains the shared/bin PATH export
//   3. launchd-plist   — ~/Library/LaunchAgents/io.hexa.watchd.plist exists
//   4. launchd-loaded  — launchctl list shows io.hexa.watchd
//   5. ssot-frozen     — .commands carries uchg flag
//   6. daemon-alive    — $HOME/.hx/watchd.log mtime is < 10 s old
//
// Exit 0 iff every check is OK. Otherwise exit 1.

use "tool/commands_loader"

// ─── helpers ───────────────────────────────────────────────────

fn _dr_home() -> string {
    let h = env("HOME")
    if h != "" { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _dr_hexa_home() -> string {
    let e = env("HEXA_HOME")
    if e != "" { return e }
    return _dr_home() + "/.hx"
}

fn _dr_quote(s: string) -> string {
    let mut out = "'"
    let n = len(s)
    let mut i = 0
    while i < n {
        let c = char_code(s, i)
        if c == 39 {
            out = out + "'\\''"
        } else {
            out = out + chr(c)
        }
        i = i + 1
    }
    out = out + "'"
    return out
}

fn _dr_path_exists(path: string) -> bool {
    let r = exec_with_status("test -L " + _dr_quote(path) + " -o -e " + _dr_quote(path))
    return r[1] == 0
}

fn _dr_emit(tag: string, ok: bool, detail: string) -> bool {
    let prefix = "[FAIL] "
    if ok { prefix = "[OK] " }
    println(prefix + tag + " " + detail)
    return ok
}

// ─── checks ────────────────────────────────────────────────────

fn _check_shim_exist(cmds: [HxCommand]) -> bool {
    let bin_dir = _dr_hexa_home() + "/shared/bin"
    let names = shim_names(cmds)
    let total = len(names)
    let mut ok = 0
    let mut i = 0
    while i < total {
        let p = bin_dir + "/" + names[i]
        if _dr_path_exists(p) { ok = ok + 1 }
        i = i + 1
    }
    let pass = (ok == total) && total > 0
    return _dr_emit("shim-exist", pass, "(" + str(ok) + "/" + str(total) + " in " + bin_dir + ")")
}

fn _check_path_inject() -> bool {
    let zshenv = _dr_home() + "/.zshenv"
    if !_dr_path_exists(zshenv) {
        return _dr_emit("path-inject", false, "(no " + zshenv + ")")
    }
    let r = exec_with_status("grep -qE 'HEXA_HOME/shared/bin|\\.hx/shared/bin' " + _dr_quote(zshenv))
    let pass = r[1] == 0
    return _dr_emit("path-inject", pass, "(~/.zshenv)")
}

fn _check_launchd_plist() -> bool {
    let path = _dr_home() + "/Library/LaunchAgents/io.hexa.watchd.plist"
    let pass = _dr_path_exists(path)
    return _dr_emit("launchd-plist", pass, "(" + path + ")")
}

fn _check_launchd_loaded() -> bool {
    let r = exec_with_status("launchctl list")
    let out = to_string(r[0])
    let pass = out.contains("io.hexa.watchd")
    return _dr_emit("launchd-loaded", pass, "(launchctl list)")
}

fn _check_ssot_frozen() -> bool {
    let r = exec_with_status("ls -lO .commands 2>&1")
    let out = to_string(r[0])
    let pass = out.contains("uchg")
    return _dr_emit("ssot-frozen", pass, "(chflags uchg)")
}

fn _check_daemon_alive() -> bool {
    let log = _dr_home() + "/.hx/watchd.log"
    if !_dr_path_exists(log) {
        return _dr_emit("daemon-alive", false, "(no " + log + ")")
    }
    // Age via `date +%s` minus `stat -f %m` (BSD) or `stat -c %Y` (GNU).
    let cmd = "echo $(( $(date +%s) - $(stat -f %m " + _dr_quote(log) + " 2>/dev/null || stat -c %Y " + _dr_quote(log) + " 2>/dev/null || echo 0) ))"
    let r = exec_with_status(cmd)
    let raw = to_string(r[0]).trim()
    let age = to_int(raw)
    let pass = age >= 0 && age < 10
    return _dr_emit("daemon-alive", pass, "(watchd.log age=" + str(age) + "s)")
}

// ─── main ──────────────────────────────────────────────────────

fn main() -> int {
    let cmds = load_commands(".commands")
    let mut all_ok = true
    if !_check_shim_exist(cmds) { all_ok = false }
    if !_check_path_inject()    { all_ok = false }
    if !_check_launchd_plist() { all_ok = false }
    if !_check_launchd_loaded(){ all_ok = false }
    if !_check_ssot_frozen()   { all_ok = false }
    if !_check_daemon_alive()  { all_ok = false }

    if all_ok {
        println("")
        println("doctor: all 6 checks OK")
        return 0
    }
    println("")
    eprintln("doctor: at least one check FAILED")
    return 1
}

exit(main())
