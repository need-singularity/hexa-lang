// tool/tui_widget_selftest.hexa — combined L4 widget selftest entry
//
// Library modules cannot define `fn main()` (flatten collision); this is
// the consolidated entry that exercises all L4 widgets including
// stage-2 (modal, table) per kick T1.A scope.

use "self/tui/widget/box"
use "self/tui/widget/text"
use "self/tui/widget/list"
use "self/tui/widget/input"
use "self/tui/widget/modal"
use "self/tui/widget/table"

let r1 = box_selftest()
if r1 != 0 { exit(100 + r1) }
let r2 = text_selftest()
if r2 != 0 { exit(200 + r2) }
let r3 = list_selftest()
if r3 != 0 { exit(300 + r3) }
let r4 = input_widget_selftest()
if r4 != 0 { exit(400 + r4) }
let r5 = modal_selftest()
if r5 != 0 { exit(500 + r5) }
let r6 = table_selftest()
if r6 != 0 { exit(600 + r6) }
println("=== L4 widget tree (incl. stage-2) selftest: ALL OK ===")
exit(0)
