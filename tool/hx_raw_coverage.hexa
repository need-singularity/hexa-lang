// tool/hx_raw_coverage.hexa — Phase 3.6 raw#N rule enforcement coverage (stub).
//
// SPEC: docs/hexa_lang_meta_evolution_proposal_20260422.md §3.6.
// STATUS: stub — skeleton + --selftest only.
//
// PURPOSE
//   For each raw#N rule, verify an enforcement scanner exists.
//   Flag "rule orphan" (rule stated in docs/.roadmap but no lint) and
//   "stale ref" (tool references raw#N but N is not a real rule).
//
// CLI
//   hexa tool/hx_raw_coverage.hexa --selftest
//   hexa tool/hx_raw_coverage.hexa [--out <path>]
//
// OUTPUT
//   $HEXA_LANG/state/hx_raw_coverage.json
//   schema = "hexa-lang/hx_raw_coverage/1"

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _iso_now() -> string {
    return to_string(exec("date -u +'%Y-%m-%dT%H:%M:%SZ'")).trim()
}

fn _arg_value(args: array, key: string, default: string) -> string {
    let mut i = 0
    while i < len(args) {
        if args[i] == key {
            let j = i + 1
            if j < len(args) { return args[j] }
        }
        i = i + 1
    }
    return default
}

fn _selftest() -> int {
    if len(_iso_now()) < 10 {
        eprintln("hx_raw_coverage: selftest FAIL")
        return 1
    }
    println("hx_raw_coverage: selftest PASS (stub)")
    return 0
}

fn _emit(out_path: string) -> int {
    let ts = _iso_now()
    let body = "{\n  \"schema\": \"hexa-lang/hx_raw_coverage/1\",\n  \"ts\": \"" + ts + "\",\n  \"status\": \"stub\",\n  \"rules_total\": 0,\n  \"rules_with_scanner\": 0,\n  \"rule_orphans\": [],\n  \"stale_refs\": [],\n  \"coverage_pct\": 0.0\n}\n"
    try {
        write_file(out_path, body)
    } catch e {
        eprintln("hx_raw_coverage: write FAIL " + out_path)
        return 1
    }
    println("hx_raw_coverage: wrote " + out_path + " (stub)")
    return 0
}

fn main() {
    let av = argv()
    let mut args = []
    let mut i = 2
    while i < len(av) { args.push(av[i]); i = i + 1 }

    if len(args) >= 1 && args[0] == "--selftest" {
        exit(_selftest())
    }

    let default_out = _home() + "/core/hexa-lang/state/hx_raw_coverage.json"
    let out_path = _arg_value(args, "--out", default_out)
    exit(_emit(out_path))
}
