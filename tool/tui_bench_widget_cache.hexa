// tool/tui_bench_widget_cache.hexa — L4 widget cache perf gain
//
// Compares two paths for a 10-widget UI where 1 widget changes per
// frame:
//   A. always_render : call all 10 widget renders (no cache)
//   B. cache_gated   : widget_should_render() per widget; only the
//                      changed widget calls render fns
//
// Expected outcome: B is ~10× faster than A because 9 widgets skip
// render_put loops entirely. Saves ~10×N_cells × ~100ns/cell.

use "self/tui/render"
use "self/tui/widget/box"
use "self/tui/widget/text"
use "self/tui/widget_cache"

let _N = 1000
let mut _samples_no_cache = []
let mut _samples_with_cache = []

fn _ns_to_us_str(ns: int) -> string {
    let us = ns / 1000
    let frac = ns - us * 1000
    return to_string(us) + "." + _pad3(to_string(frac)) + "us"
}

fn _pad3(s: string) -> string {
    let n = len(s)
    if n >= 3 { return s }
    if n == 2 { return "0" + s }
    if n == 1 { return "00" + s }
    return "000"
}

fn _sort(arr: array) -> array {
    let n = len(arr)
    let mut i = 1
    while i < n {
        let key = arr[i]
        let mut j = i - 1
        while j >= 0 && arr[j] > key {
            arr[j + 1] = arr[j]
            j = j - 1
        }
        arr[j + 1] = key
        i = i + 1
    }
    return arr
}

fn _percentile(sorted: array, pct: int) -> int {
    let n = len(sorted)
    let idx = (n * pct) / 100
    let i = if idx >= n { n - 1 } else { idx }
    return sorted[i]
}

// Render 10 widgets at fixed positions. iter param = which widget changes.
// Without cache: all 10 render every iter.
fn _render_all_widgets(iter: int) {
    let mut w = 0
    while w < 10 {
        // Each widget: a small 8-cell box + 6-char text. ~14 cells per widget.
        let x = (w % 5) * 16
        let y = (w / 5) * 8
        // The "changing" widget gets the iter counter; others have static state
        let label = if w == (iter % 10) { "w" + to_string(w) + "=" + to_string(iter) }
                    else { "w" + to_string(w) + "=k" }
        let _b = box_draw(x, y, 14, 4, w + 30, -1, 0, 0)
        let _t = text_label(x + 1, y + 1, label, -1, -1, 0)
        w = w + 1
    }
}

// With cache: only the changed widget's render runs.
fn _render_cached_widgets(iter: int) {
    let mut w = 0
    while w < 10 {
        let x = (w % 5) * 16
        let y = (w / 5) * 8
        let label = if w == (iter % 10) { "w" + to_string(w) + "=" + to_string(iter) }
                    else { "w" + to_string(w) + "=k" }
        let id = "widget-" + to_string(w)
        let h = widget_state_hash([label])
        if widget_should_render(id, h) {
            let _b = box_draw(x, y, 14, 4, w + 30, -1, 0, 0)
            let _t = text_label(x + 1, y + 1, label, -1, -1, 0)
        }
        w = w + 1
    }
}

fn run_bench() -> int {
    println("=== TUI-PRIM L4 widget cache bench ===")
    println("scenario: 10-widget UI, 1 widget changes per frame")

    let r = render_init()
    if r != 0 { return 1 }
    let dims = render_dims()
    println("dims: " + to_string(dims[0]) + "x" + to_string(dims[1]))

    // Warm both paths
    let mut w = 0
    while w < 50 {
        _render_all_widgets(w)
        _render_cached_widgets(w)
        w = w + 1
    }
    widget_cache_clear()

    // Measure A: no cache
    let mut samples_a = []
    let mut i = 0
    while i < _N {
        let t0 = mono_ns()
        _render_all_widgets(i)
        let t1 = mono_ns()
        samples_a = samples_a + [t1 - t0]
        i = i + 1
    }

    // Measure B: with cache
    widget_cache_clear()
    // Prime the cache with one full render (so subsequent calls have entries)
    _render_cached_widgets(0)

    let mut samples_b = []
    let mut k = 1
    while k < _N + 1 {
        let t0 = mono_ns()
        _render_cached_widgets(k)
        let t1 = mono_ns()
        samples_b = samples_b + [t1 - t0]
        k = k + 1
    }

    let _c = render_close()

    let sa = _sort(samples_a)
    let sb = _sort(samples_b)

    let a_p50 = _percentile(sa, 50)
    let a_p99 = _percentile(sa, 99)
    let b_p50 = _percentile(sb, 50)
    let b_p99 = _percentile(sb, 99)

    eprintln("")
    eprintln("samples per case: " + to_string(_N))
    eprintln("A (no cache):  p50=" + _ns_to_us_str(a_p50) + "  p99=" + _ns_to_us_str(a_p99))
    eprintln("B (cached) :  p50=" + _ns_to_us_str(b_p50) + "  p99=" + _ns_to_us_str(b_p99))
    let speedup = if b_p50 > 0 { a_p50 / b_p50 } else { 0 }
    eprintln("speedup p50:  ~" + to_string(speedup) + "x (cache wins on 9-of-10 unchanged widgets)")

    let stamp = utc_iso_now()
    let row = "{\"ts\":\"" + stamp + "\",\"bench\":\"l4_widget_cache\",\"samples\":" + to_string(_N) +
              ",\"no_cache_p50_ns\":" + to_string(a_p50) +
              ",\"no_cache_p99_ns\":" + to_string(a_p99) +
              ",\"cached_p50_ns\":" + to_string(b_p50) +
              ",\"cached_p99_ns\":" + to_string(b_p99) +
              ",\"speedup_x\":" + to_string(speedup) + "}"
    println(row)
    return 0
}

let _entry_rc = run_bench()
exit(_entry_rc)
