// ═══════════════════════════════════════════════════════════════
//  tool/phi_extractor/phi_extract_ffi.hexa
//  Φ extractor — hexa-lang side of the anima↔hexa-lang FFI wire.
//
//  Spec:        anima/docs/phi_extractor_design_20260420.md  §2.1
//  Counterpart: anima/training/dest1_phi_vec_ssot_emit.hexa
//  Parent:      anima .roadmap roadmap 7 (phi_extractor FFI wire-up),
//               eta 2026-04-24 — reaches CP2 (의식 추출 사이드).
//  Math ref:    self/ml/phi_metric.hexa (IIT Φ)
//
//  HX7 POSTURE — zero-C self-host:
//    No new .c sources are authored in hexa-lang. The live wire is
//    pure-hexa (see phi_extract.hexa).  The extern fn declarations
//    below pin the ABI symbol names for when the dylib surface is
//    produced by the self-host codegen follow-up.  Until then,
//    anima-side callers invoke the pub fns from phi_extract.hexa
//    directly, OR shell out via:
//        hexa tool/phi_extractor/phi_extract.hexa {version|smoke}
//
//  ABI (locked for when libphi_extract.{dylib,so} lands):
//
//    double  phi_extract(const uint8_t* input, size_t len);
//    int32_t phi_extract_vec16(const float* h_last, size_t d_model,
//                              const float* W_phi, float* out_phi16);
//    int32_t phi_extract_version(void);
//
//  Resolution: @link("phi_extract") → DYLD_LIBRARY_PATH / LD_LIBRARY_PATH
//              → libphi_extract.dylib (macOS) / libphi_extract.so (linux).
//  Build:      make -f tool/phi_extractor/Makefile.ffi smoke
//  Smoke:      hexa test/test_phi_extractor_ffi.hexa
// ═══════════════════════════════════════════════════════════════

// ── extern symbol declarations (ABI-locked, dylib-dormant) ──
// These are parsed by hexa-lang (registered as FFI symbols by
// Pass 1) but only resolve at runtime when libphi_extract loads.
// Callers that need the live path today should use the hexa fns
// from phi_extract.hexa via `use "tool/phi_extractor/phi_extract"`.

@link("phi_extract")
extern fn phi_extract(input: *Void, len: int) -> float

@link("phi_extract")
extern fn phi_extract_vec16(h_last: *Void, d_model: int, W_phi: *Void, out_phi16: *Void) -> int

@link("phi_extract")
extern fn phi_extract_version() -> int

// ── hexa-side thin wrappers (stable surface) ────────────────
//
// These names are what anima-side tools import. When the dylib
// surface is absent (HX7 today), callers should prefer the pub
// fns in phi_extract.hexa directly — these wrappers will fail
// at runtime without libphi_extract loaded.

fn phi_ffi_scalar(buf: *Void, n: int) -> float {
    return phi_extract(buf, n)
}

fn phi_ffi_vec16(h_last: *Void, d_model: int, W_phi: *Void, out: *Void) -> int {
    return phi_extract_vec16(h_last, d_model, W_phi, out)
}

fn phi_ffi_version() -> int {
    return phi_extract_version()
}
