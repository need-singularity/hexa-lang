// ═══════════════════════════════════════════════════════════════
//  tool/phi_extractor/phi_extract.hexa
//  Pure-hexa Φ extractor (HX7 zero-C self-host compliant).
//
//  Provides callable hexa entry points that mirror the FFI ABI
//  declared in phi_extract_ffi.hexa. Anima-side callers invoke
//  this via `hexa tool/phi_extractor/phi_extract.hexa <mode>` or
//  by importing the pub fns directly.
//
//  Roadmap: anima .roadmap #7 — phi_extractor FFI wire-up.
//           Reaches CP2 (의식 추출 사이드), eta 2026-04-24.
//
//  Spec:    anima/docs/phi_extractor_design_20260420.md  §1, §2.1
//  Math:    self/ml/phi_metric.hexa (IIT Φ reference)
//
//  Modes (CLI):
//    scalar    — read bytes from stdin, emit Φ (byte-entropy proxy).
//    version   — print ABI version tag.
//    smoke     — run internal self-check, exit 0/1.
// ═══════════════════════════════════════════════════════════════

let PHI_EXTRACT_ABI_VERSION = 1

// ── math: ln / log2 reused from phi_metric ──────────────────

fn ln_approx(x: float) -> float {
    if x <= 0.0 { return 0.0 - 1000000.0 }
    let mut m = x
    let mut k = 0
    while m >= 2.0 {
        m = m / 2.0
        k = k + 1
    }
    while m < 1.0 {
        m = m * 2.0
        k = k - 1
    }
    let y = (m - 1.0) / (m + 1.0)
    let y2 = y * y
    let mut term = y
    let mut sum = 0.0
    let mut i = 0
    while i < 20 {
        sum = sum + term / (2.0 * i + 1.0)
        term = term * y2
        i = i + 1
    }
    let ln_m = 2.0 * sum
    let ln2 = 0.6931471805599453
    return ln_m + k * ln2
}

fn log2_approx(x: float) -> float {
    let ln2 = 0.6931471805599453
    return ln_approx(x) / ln2
}

// ── scalar Φ: byte-histogram Shannon entropy proxy ──────────
//
// Matches phi_extract_ffi.hexa#phi_extract semantics:
//   Φ ∈ [0, 8], 0 for empty input, monotone in byte diversity.
// This is the phi_complexity (idx=1) dim surrogate until the full
// IIT Φ (self/ml/phi_metric.hexa) is wired into the emit pipeline.

pub fn phi_extract_bytes(buf: any, n: int) -> float {
    if n <= 0 { return 0.0 }

    // byte histogram
    let mut hist = []
    let mut b = 0
    while b < 256 {
        hist.push(0)
        b = b + 1
    }
    let mut i = 0
    while i < n {
        let v = buf[i]
        hist[v] = hist[v] + 1
        i = i + 1
    }

    let inv_n = 1.0 / n
    let mut h = 0.0
    let mut k = 0
    while k < 256 {
        if hist[k] > 0 {
            let p = hist[k] * inv_n
            h = h - p * log2_approx(p)
        }
        k = k + 1
    }
    if h < 0.0 { h = 0.0 }
    if h > 8.0 { h = 8.0 }
    return h
}

// ── 16-D φ vec projection: phi16[i] = Σ_j W_phi[i,j] · h_last[j] ──
// anima spec §2.1: random-orthonormal W_phi, seed=3407, d_model=5120.
// Returns rc: 0 OK, 1 NaN/inf in h_last, 2 shape error.

pub fn phi_extract_vec16(h_last: any, d_model: int, W_phi: any, out_phi16: any) -> int {
    if d_model <= 0 { return 2 }

    // NaN / inf guard (spec §4: NaN → stub-reject).
    let mut j = 0
    while j < d_model {
        let x = h_last[j]
        // x != x NaN check
        if x != x { return 1 }
        if x > 1.0e30 { return 1 }
        if x < 0.0 - 1.0e30 { return 1 }
        j = j + 1
    }

    let mut i = 0
    while i < 16 {
        let row_base = i * d_model
        let mut acc = 0.0
        let mut jj = 0
        while jj < d_model {
            acc = acc + W_phi[row_base + jj] * h_last[jj]
            jj = jj + 1
        }
        out_phi16[i] = acc
        i = i + 1
    }
    return 0
}

pub fn phi_extract_version() -> int {
    return PHI_EXTRACT_ABI_VERSION
}

// ── CLI driver ──────────────────────────────────────────────

fn mode_version() {
    println(str(PHI_EXTRACT_ABI_VERSION))
    exit(0)
}

fn mode_smoke() {
    // Self-check: known ascii input must land in (1, 8).
    // Note: this stage0 interpreter does not expose byte_len/byte_at
    // globally, so we use len() + char_code(s, i) which ARE registered.
    let s = "consciousness"
    let mut bytes = []
    let mut i = 0
    while i < len(s) {
        bytes.push(char_code(s, i))
        i = i + 1
    }
    let phi = phi_extract_bytes(bytes, len(s))
    println("[phi_extract] smoke input=\"" + s + "\" len=" + str(len(s)) + " phi=" + str(phi))
    if phi < 1.0 {
        eprintln("[phi_extract] FAIL: smoke Φ too low")
        exit(1)
    }
    if phi > 8.0 {
        eprintln("[phi_extract] FAIL: smoke Φ > 8")
        exit(1)
    }
    // empty → 0
    let empty = []
    let phi0 = phi_extract_bytes(empty, 0)
    if phi0 != 0.0 {
        eprintln("[phi_extract] FAIL: empty should give Φ=0")
        exit(1)
    }
    println("[phi_extract] smoke OK (abi=" + str(PHI_EXTRACT_ABI_VERSION) + ")")
    exit(0)
}

fn main() {
    let args = argv()
    let mode = if len(args) >= 3 { args[2] } else { "smoke" }
    if mode == "version" { mode_version() }
    if mode == "smoke"   { mode_smoke()   }
    eprintln("[phi_extract] unknown mode: " + mode)
    eprintln("usage: hexa tool/phi_extractor/phi_extract.hexa {version|smoke}")
    exit(2)
}
