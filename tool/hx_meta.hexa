// tool/hx_meta.hexa — hexa-lang self meta system CLI dispatcher.
//
// SPEC: docs/hexa_lang_meta_evolution_proposal_20260422.md §Phase 4.
// STATUS: stub — subcommand dispatch to 16 Phase 1-6 stubs.
//
// CLI
//   hexa tool/hx_meta.hexa doctor             # Phase 1-3 aggregated report
//   hexa tool/hx_meta.hexa health             # single health score 0-100
//   hexa tool/hx_meta.hexa blockers           # Phase 1
//   hexa tool/hx_meta.hexa roi                # Phase 2
//   hexa tool/hx_meta.hexa stage-health       # 3.1
//   hexa tool/hx_meta.hexa stdlib-gap         # 3.2
//   hexa tool/hx_meta.hexa bench-gate         # 3.3 (PR gate variant)
//   hexa tool/hx_meta.hexa coverage           # 3.4 --selftest coverage
//   hexa tool/hx_meta.hexa api-drift          # 3.5
//   hexa tool/hx_meta.hexa raw-coverage       # 3.6
//   hexa tool/hx_meta.hexa cert-chain         # 3.7
//   hexa tool/hx_meta.hexa aot-stale          # 3.8
//   hexa tool/hx_meta.hexa tool-graph         # 3.9
//   hexa tool/hx_meta.hexa pattern-mine       # 3.10
//   hexa tool/hx_meta.hexa continuous-scan    # Phase 5
//   hexa tool/hx_meta.hexa telemetry          # Phase 6.1
//   hexa tool/hx_meta.hexa gap                # Phase 6.2
//   hexa tool/hx_meta.hexa declare [list|register <f>|run <name>]  # Phase 6.3
//   hexa tool/hx_meta.hexa selftest           # cascade all 16

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _tool(name: string) -> string {
    return _home() + "/core/hexa-lang/tool/" + name
}

fn _run(name: string, args: string) -> array {
    let cmd = "hexa '" + _tool(name) + "' " + args
    return exec_with_status(cmd)
}

fn _banner(s: string) -> void {
    println("")
    println("═══════════════════════════════════════════════════════════════════")
    println(" " + s)
    println("═══════════════════════════════════════════════════════════════════")
}

fn _cmd_doctor() -> int {
    _banner("hexa-lang self meta — doctor (Phase 1-3)")
    let mut fail = 0

    _banner("1. Blocker inventory (Phase 1)")
    let r1 = _run("hx_blocker_scan.hexa", "")
    println(to_string(r1[0]))
    if r1[1] != 0 { fail = fail + 1 }

    _banner("2. Loss-free ROI (Phase 2)")
    let r2 = _run("hx_loss_free_roi_scan.hexa", "")
    println(to_string(r2[0]))
    if r2[1] != 0 { fail = fail + 1 }

    _banner("3. Stage health (3.1)")
    let r3 = _run("hx_stage_health.hexa", "")
    println(to_string(r3[0]))
    if r3[1] != 0 { fail = fail + 1 }

    _banner("4. Stdlib promotion candidates (3.2)")
    let r4 = _run("hx_stdlib_promote.hexa", "")
    println(to_string(r4[0]))
    if r4[1] != 0 { fail = fail + 1 }

    _banner("5. Bench drift (3.3)")
    let r5 = _run("hx_bench_drift.hexa", "")
    println(to_string(r5[0]))
    if r5[1] != 0 { fail = fail + 1 }

    _banner("6. --selftest coverage (3.4)")
    let r6 = _run("hx_coverage_scan.hexa", "")
    println(to_string(r6[0]))
    if r6[1] != 0 { fail = fail + 1 }

    _banner("7. API drift (3.5)")
    let r7 = _run("hx_api_drift.hexa", "")
    println(to_string(r7[0]))
    if r7[1] != 0 { fail = fail + 1 }

    _banner("8. raw#N coverage (3.6)")
    let r8 = _run("hx_raw_coverage.hexa", "")
    println(to_string(r8[0]))
    if r8[1] != 0 { fail = fail + 1 }

    _banner("9. Cert chain (3.7)")
    let r9 = _run("hx_cert_chain.hexa", "")
    println(to_string(r9[0]))
    if r9[1] != 0 { fail = fail + 1 }

    _banner("10. AOT stale (3.8)")
    let r10 = _run("hx_aot_stale.hexa", "")
    println(to_string(r10[0]))
    if r10[1] != 0 { fail = fail + 1 }

    _banner("11. Tool graph (3.9)")
    let r11 = _run("hx_tool_graph.hexa", "")
    println(to_string(r11[0]))
    if r11[1] != 0 { fail = fail + 1 }

    _banner("12. Pattern mine (3.10)")
    let r12 = _run("hx_pattern_mine.hexa", "")
    println(to_string(r12[0]))
    if r12[1] != 0 { fail = fail + 1 }

    _banner("DONE — doctor complete (" + to_string(fail) + " scanners failed)")
    if fail > 0 { return 1 }
    return 0
}

fn _cmd_health() -> int {
    _banner("hexa-lang self meta — health score (stub)")
    println("{\"schema\": \"hexa-lang/hx_meta_health/1\", \"status\": \"stub\", \"score\": null, \"breakdown\": {\"blockers\": null, \"coverage\": null, \"drift\": null, \"cert\": null}}")
    return 0
}

fn _selftest() -> int {
    _banner("hx_meta selftest — cascading all 16 meta scanners")
    let mods = ["hx_blocker_scan.hexa", "hx_loss_free_roi_scan.hexa",
                "hx_stage_health.hexa", "hx_stdlib_promote.hexa",
                "hx_bench_drift.hexa", "hx_coverage_scan.hexa",
                "hx_api_drift.hexa", "hx_raw_coverage.hexa",
                "hx_cert_chain.hexa", "hx_aot_stale.hexa",
                "hx_tool_graph.hexa", "hx_pattern_mine.hexa",
                "hx_continuous_scan.hexa", "hx_meta_telemetry.hexa",
                "hx_meta_gap_proposer.hexa", "hx_declare_scanner.hexa"]
    let mut all_ok = true
    for m in mods {
        let r = _run(m, "--selftest")
        if r[1] != 0 {
            eprintln("  FAIL " + m)
            all_ok = false
        } else {
            println("  OK   " + m)
        }
    }
    if !all_ok {
        eprintln("hx_meta selftest FAIL")
        return 1
    }
    println("hx_meta selftest PASS — 16 scanners OK")
    return 0
}

fn main() {
    let av = argv()
    let mut args = []
    let mut i = 2
    while i < len(av) { args.push(av[i]); i = i + 1 }

    if len(args) == 0 { exit(_cmd_doctor()) }
    let cmd = args[0]

    if cmd == "doctor"         { exit(_cmd_doctor()) }
    if cmd == "health"         { exit(_cmd_health()) }
    if cmd == "selftest"       { exit(_selftest()) }

    if cmd == "blockers"       { let r = _run("hx_blocker_scan.hexa", "");       println(to_string(r[0])); exit(r[1]) }
    if cmd == "roi"            { let r = _run("hx_loss_free_roi_scan.hexa", ""); println(to_string(r[0])); exit(r[1]) }
    if cmd == "stage-health"   { let r = _run("hx_stage_health.hexa", "");       println(to_string(r[0])); exit(r[1]) }
    if cmd == "stdlib-gap"     { let r = _run("hx_stdlib_promote.hexa", "");     println(to_string(r[0])); exit(r[1]) }
    if cmd == "bench-gate"     { let r = _run("hx_bench_drift.hexa", "");        println(to_string(r[0])); exit(r[1]) }
    if cmd == "coverage"       { let r = _run("hx_coverage_scan.hexa", "");      println(to_string(r[0])); exit(r[1]) }
    if cmd == "api-drift"      { let r = _run("hx_api_drift.hexa", "");          println(to_string(r[0])); exit(r[1]) }
    if cmd == "raw-coverage"   { let r = _run("hx_raw_coverage.hexa", "");       println(to_string(r[0])); exit(r[1]) }
    if cmd == "cert-chain"     { let r = _run("hx_cert_chain.hexa", "");         println(to_string(r[0])); exit(r[1]) }
    if cmd == "aot-stale"      { let r = _run("hx_aot_stale.hexa", "");          println(to_string(r[0])); exit(r[1]) }
    if cmd == "tool-graph"     { let r = _run("hx_tool_graph.hexa", "");         println(to_string(r[0])); exit(r[1]) }
    if cmd == "pattern-mine"   { let r = _run("hx_pattern_mine.hexa", "");       println(to_string(r[0])); exit(r[1]) }
    if cmd == "continuous-scan" { let r = _run("hx_continuous_scan.hexa", "");   println(to_string(r[0])); exit(r[1]) }
    if cmd == "telemetry"      { let r = _run("hx_meta_telemetry.hexa", "");     println(to_string(r[0])); exit(r[1]) }
    if cmd == "gap"            { let r = _run("hx_meta_gap_proposer.hexa", ""); println(to_string(r[0])); exit(r[1]) }
    if cmd == "declare" {
        let mut sub = ""
        if len(args) >= 2 { sub = args[1] }
        let mut rest = ""
        if len(args) >= 3 { rest = args[2] }
        let r = _run("hx_declare_scanner.hexa", sub + " " + rest)
        println(to_string(r[0]))
        exit(r[1])
    }

    eprintln("unknown command: " + cmd)
    eprintln("commands: doctor | health | selftest |")
    eprintln("          blockers | roi | stage-health | stdlib-gap | bench-gate |")
    eprintln("          coverage | api-drift | raw-coverage | cert-chain | aot-stale |")
    eprintln("          tool-graph | pattern-mine | continuous-scan | telemetry | gap |")
    eprintln("          declare [list|register <f>|run <name>]")
    exit(1)
}
