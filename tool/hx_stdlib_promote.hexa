// tool/hx_stdlib_promote.hexa — Phase 3.2 helper → stdlib promotion (real-v1).
//
// SPEC: docs/hexa_lang_meta_evolution_proposal_20260422.md §3.2.
// STATUS: v1 real — helper NAME frequency (no AST hash yet).
//         Full n-gram / AST-subtree clustering deferred to v2.
//
// PURPOSE
//   grep `^fn _<name>(` patterns across tool/*.hexa, count occurrences.
//   Helpers appearing in ≥threshold distinct files → stdlib promotion
//   candidates. First-iteration targets visible in this repo:
//     _home · _iso_now · _arg_value · _file_exists · _json_esc · _itoa
//
// CLI
//   hexa tool/hx_stdlib_promote.hexa --selftest
//   hexa tool/hx_stdlib_promote.hexa [--threshold N] [--out <path>]
//
// OUTPUT
//   $HEXA_LANG/state/hx_stdlib_promote.json
//   schema = "hexa-lang/hx_stdlib_promote/1"

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _iso_now() -> string {
    return to_string(exec("date -u +'%Y-%m-%dT%H:%M:%SZ'")).trim()
}

fn _arg_value(args: array, key: string, default: string) -> string {
    let mut i = 0
    while i < len(args) {
        if args[i] == key {
            let j = i + 1
            if j < len(args) { return args[j] }
        }
        i = i + 1
    }
    return default
}

fn _json_esc(s: string) -> string {
    let mut r = s.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", "\\n")
    r = r.replace("\r", "")
    r = r.replace("\t", " ")
    return r
}

fn _itoa(n: int) -> string {
    return to_string(n)
}

fn _atoi(s: string) -> int {
    if s == "" { return 0 }
    return s.parse_int()
}

fn _split_lines(s: string) -> array {
    let mut out = []
    let mut cur = ""
    let mut i = 0
    while i < len(s) {
        let c = s.substring(i, i + 1)
        if c == "\n" {
            if len(cur) > 0 { out.push(cur) }
            cur = ""
        } else {
            cur = cur + c
        }
        i = i + 1
    }
    if len(cur) > 0 { out.push(cur) }
    return out
}

fn _tool_dir() -> string {
    return _home() + "/core/hexa-lang/tool"
}

fn _selftest() -> int {
    if _atoi("42") != 42 { eprintln("hx_stdlib_promote: selftest FAIL (atoi 42)"); return 1 }
    if _atoi("0") != 0 { eprintln("hx_stdlib_promote: selftest FAIL (atoi 0)"); return 1 }
    if _itoa(-7) != "-7" { eprintln("hx_stdlib_promote: selftest FAIL (itoa -7)"); return 1 }
    let lines = _split_lines("a\nb\n")
    if len(lines) != 2 { eprintln("hx_stdlib_promote: selftest FAIL (split_lines)"); return 1 }
    println("hx_stdlib_promote: selftest PASS")
    return 0
}

// Parse grep output of form "tool/foo.hexa:fn _name(..." and return
// an array where each entry is "name|file".
fn _scan_helpers() -> array {
    // Match lines starting with `fn _` followed by an identifier and '('.
    // Private helpers use leading underscore; we skip `fn main` / exported.
    let td = _tool_dir()
    let cmd = "grep -rE '^fn _[A-Za-z0-9_]+\\(' '" + td + "' 2>/dev/null"
    let raw = to_string(exec(cmd))
    let lines = _split_lines(raw)
    let mut pairs = []
    for ln in lines {
        // ln example: /Users/.../tool/hx_meta.hexa:fn _home() -> string {
        let colon = ln.index_of(":fn ")
        if colon < 0 { continue }
        let file_path = ln.substring(0, colon)
        // strip directory prefix: keep "tool/<name>"
        let tpos = file_path.index_of("/tool/")
        let short = if tpos >= 0 { file_path.substring(tpos + 1, len(file_path)) } else { file_path }
        // after ":fn " comes "_name(..."
        let rest = ln.substring(colon + 4, len(ln))
        // extract up to '(' or whitespace
        let mut name = ""
        let mut j = 0
        while j < len(rest) {
            let c = rest.substring(j, j + 1)
            if c == "(" || c == " " || c == "<" { break }
            name = name + c
            j = j + 1
        }
        if len(name) > 1 {
            pairs.push(name + "|" + short)
        }
    }
    return pairs
}

fn _index_of_str(arr: array, s: string) -> int {
    let mut i = 0
    while i < len(arr) {
        if arr[i] == s { return i }
        i = i + 1
    }
    return -1
}

fn main() {
    let av = argv()
    let mut args = []
    let mut i = 2
    while i < len(av) { args.push(av[i]); i = i + 1 }

    if len(args) >= 1 && args[0] == "--selftest" { exit(_selftest()) }

    let threshold_s = _arg_value(args, "--threshold", "3")
    let threshold = _atoi(threshold_s)
    let default_out = _home() + "/core/hexa-lang/state/hx_stdlib_promote.json"
    let out_path = _arg_value(args, "--out", default_out)
    let ts = _iso_now()

    // 1. Collect (name, file) pairs across tool/*.hexa
    let pairs = _scan_helpers()

    // 2. Group by name: parallel arrays names[], files[] (files[k] = csv list).
    let mut names = []
    let mut files_csv = []
    let mut counts = []  // distinct file count per name
    for p in pairs {
        let bar = p.index_of("|")
        if bar < 0 { continue }
        let n = p.substring(0, bar)
        let f = p.substring(bar + 1, len(p))
        let idx = _index_of_str(names, n)
        if idx < 0 {
            names.push(n)
            files_csv.push(f)
            counts.push(1)
        } else {
            let existing = files_csv[idx]
            // dedupe: only append file if not already in csv
            if existing.index_of(f) < 0 {
                files_csv[idx] = existing + "," + f
                counts[idx] = counts[idx] + 1
            }
        }
    }

    // 3. Emit candidates with distinct-file count ≥ threshold
    let mut cand_json = []
    let mut total_candidates = 0
    let mut high_impact = 0
    let mut k = 0
    while k < len(names) {
        let c = counts[k]
        if c >= threshold {
            let entry = "{\"name\":\"" + _json_esc(names[k])
                + "\",\"occurrences\":" + _itoa(c)
                + ",\"files\":\"" + _json_esc(files_csv[k]) + "\"}"
            cand_json.push(entry)
            total_candidates = total_candidates + 1
            if c >= 10 { high_impact = high_impact + 1 }
        }
        k = k + 1
    }

    // 4. Emit JSON
    let mut body = "{\n  \"schema\": \"hexa-lang/hx_stdlib_promote/1\",\n"
    body = body + "  \"ts\": \"" + ts + "\",\n"
    body = body + "  \"status\": \"real-v1\",\n"
    body = body + "  \"threshold\": " + _itoa(threshold) + ",\n"
    body = body + "  \"unique_helpers\": " + _itoa(len(names)) + ",\n"
    body = body + "  \"candidates\": [\n"
    let mut first = true
    for j in cand_json {
        if !first { body = body + ",\n" }
        body = body + "    " + j
        first = false
    }
    body = body + "\n  ],\n"
    body = body + "  \"summary\": {\"total\": " + _itoa(total_candidates)
    body = body + ", \"high_impact\": " + _itoa(high_impact) + "}\n}\n"

    try { write_file(out_path, body) } catch e {
        eprintln("hx_stdlib_promote: write FAIL " + out_path)
        exit(1)
    }

    println("hx_stdlib_promote: scanned " + _itoa(len(names)) + " unique helpers across "
          + _itoa(len(pairs)) + " definitions; "
          + _itoa(total_candidates) + " candidates (≥" + _itoa(threshold) + " files; high_impact=" + _itoa(high_impact) + ")")
    println("hx_stdlib_promote: wrote " + out_path)
    exit(0)
}
