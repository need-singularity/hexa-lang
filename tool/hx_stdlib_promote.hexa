// tool/hx_stdlib_promote.hexa — Phase 3.2 helper → stdlib promotion detector (stub).
//
// SPEC: docs/hexa_lang_meta_evolution_proposal_20260422.md §3.2.
// STATUS: stub — skeleton + --selftest only.
//
// PURPOSE
//   Detect n-gram / AST-subtree duplication across tool/*.hexa. Helpers
//   appearing in ≥3 tool files with stable signatures → stdlib promotion
//   draft. First-iteration targets visible TODAY (from this session):
//     _home · _iso_now · _arg_value · _file_exists · _esc · _json_esc
//
// CLI
//   hexa tool/hx_stdlib_promote.hexa --selftest
//   hexa tool/hx_stdlib_promote.hexa [--threshold N] [--out <path>]
//
// OUTPUT
//   $HEXA_LANG/state/hx_stdlib_promote.json
//   $HEXA_LANG/docs/stdlib_promote_candidates.md (human review)
//   schema = "hexa-lang/hx_stdlib_promote/1"

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _iso_now() -> string {
    return to_string(exec("date -u +'%Y-%m-%dT%H:%M:%SZ'")).trim()
}

fn _arg_value(args: array, key: string, default: string) -> string {
    let mut i = 0
    while i < len(args) {
        if args[i] == key {
            let j = i + 1
            if j < len(args) { return args[j] }
        }
        i = i + 1
    }
    return default
}

fn _selftest() -> int {
    if len(_iso_now()) < 10 {
        eprintln("hx_stdlib_promote: selftest FAIL")
        return 1
    }
    println("hx_stdlib_promote: selftest PASS (stub)")
    return 0
}

fn _emit(threshold: string, out_path: string) -> int {
    let ts = _iso_now()
    let body = "{\n  \"schema\": \"hexa-lang/hx_stdlib_promote/1\",\n  \"ts\": \"" + ts + "\",\n  \"status\": \"stub\",\n  \"threshold\": " + threshold + ",\n  \"candidates\": [],\n  \"summary\": {\"total\": 0, \"high_impact\": 0}\n}\n"
    try {
        write_file(out_path, body)
    } catch e {
        eprintln("hx_stdlib_promote: write FAIL " + out_path)
        return 1
    }
    println("hx_stdlib_promote: wrote " + out_path + " (stub)")
    return 0
}

fn main() {
    let av = argv()
    let mut args = []
    let mut i = 2
    while i < len(av) { args.push(av[i]); i = i + 1 }

    if len(args) >= 1 && args[0] == "--selftest" {
        exit(_selftest())
    }

    let threshold = _arg_value(args, "--threshold", "3")
    let default_out = _home() + "/core/hexa-lang/state/hx_stdlib_promote.json"
    let out_path = _arg_value(args, "--out", default_out)
    exit(_emit(threshold, out_path))
}
