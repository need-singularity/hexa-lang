#!hexa lax
// tool/fixpoint_v3_v4.hexa — ROI #153 P7-7 self-host final fixpoint check
use "tool/tmp_scratch"
//
// PURPOSE
//   Verify v3 == v4 byte-identical:
//     v3 = current self-hosted compiler (build/hexa_stage0.real on disk)
//     v4 = new compiler produced by running the v3 pipeline on self/hexa_full.hexa
//
// STRATEGY (HX8 seed-freeze safe — never touches build/hexa_stage0*)
//   1. Flatten self/hexa_full.hexa + transitive `use`s -> flat.hexa
//      We PREFER reusing an existing /tmp/hexa-cache/flatten/*.hexa when
//      inputs are unchanged (avoids the known stage0 push-O(n²) trap).
//      Otherwise a lightweight shell-based flattener is used.
//   2. self/native/hexa_v2 flat.hexa -> v4.c
//   3. clang -O2 -std=c11 -Wno-trigraphs -I self (matches build_stage0.hexa)
//      v4.c + copy of self/runtime.c -> /tmp/hexa_v4_fixpoint/hexa_v4
//   4. codesign --force --sign - (Darwin)
//   5. v4 smoke (print "ok")
//   6. cmp v3 v4 -> IDENTICAL or DIFF (with diagnosis)
//
// EXITS
//   0 — v3 == v4 IDENTICAL (fixpoint closed)
//   1 — v3 != v4 DIFF (fixpoint open, diagnosis printed)
//   2 — build / prerequisite failure
//
// USAGE
//   ./hexa tool/fixpoint_v3_v4.hexa
//   FORCE_FLATTEN=1 ./hexa ...       # ignore cache, regenerate flat
//   KEEP=1 ./hexa ...                # preserve /tmp/hexa_v4_fixpoint

fn run_cmd(cmd) {
    let r = exec_with_status(cmd)
    if r[1] != 0 {
        eprintln("[fixpoint] FAIL cmd (exit " + str(r[1]) + "): " + cmd)
        eprintln("[fixpoint] output:")
        eprintln(r[0])
        exit(2)
    }
    r[0]
}

// ─── is_main guard (import side-effect firewall) ────────────────

let _av = argv()

fn _is_main() -> bool {
    if len(_av) < 2 { return false }
    let s = _av[1]
    if s.ends_with("/fixpoint_v3_v4.hexa") { return true }
    if s == "fixpoint_v3_v4.hexa" { return true }
    return false
}

if _is_main() {

let script_path = _av[1]
let hexa_dir = exec("cd \"$(dirname '" + script_path + "')/../\" && pwd").trim()

let v3 = hexa_dir + "/build/hexa_stage0.real"
let v3_shim = hexa_dir + "/build/hexa_stage0"
let hexa_v2 = hexa_dir + "/self/native/hexa_v2"
let runtime_c = hexa_dir + "/self/runtime.c"
let src_hexa = hexa_dir + "/self/hexa_full.hexa"
let flatten_script = hexa_dir + "/tool/flatten_imports.hexa"

let work_dir = scratch_dir() + "/hexa_v4_fixpoint"
exec("rm -rf " + work_dir)
exec("mkdir -p " + work_dir)

let flat_hexa = work_dir + "/hexa_full_flat.hexa"
let v4_c = work_dir + "/hexa_v4.c"
let v4_bin = work_dir + "/hexa_v4"
let diff_report = work_dir + "/diff_report.txt"

for needed in [v3, hexa_v2, runtime_c, src_hexa, flatten_script] {
    if !file_exists(needed) {
        eprintln("[fixpoint] missing: " + needed)
        exit(2)
    }
}

println("[fixpoint] ROI #153 — P7-7 v3==v4 fixpoint check")
println("[fixpoint] v3 binary        : " + v3)
println("[fixpoint] v3 transpiler    : " + hexa_v2)
println("[fixpoint] src              : " + src_hexa)
println("[fixpoint] work dir         : " + work_dir)
println("")

let v3_size = exec("wc -c < " + v3 + " | tr -d ' '").trim()
let v3_sha = exec("shasum -a 256 " + v3 + " 2>/dev/null | cut -d' ' -f1").trim()
println("[fixpoint] v3 size = " + v3_size + "  sha256 = " + v3_sha)

// ── Step 1: flatten ────────────────────────────────────────
// Strategy A: cached flatten reuse. tool/rebuild_stage0.hexa stores a
// cache at /tmp/hexa-cache/flatten/<sha>.hexa keyed on flatten_imports.hexa +
// all transitive .hexa sources. If the newest cache entry's mtime is at or
// after every .hexa file in the `use` graph, it's usable as-is.
println("[fixpoint] step 1/4 — flatten self/hexa_full.hexa")

let cache_dir = "/tmp/hexa-cache/flatten"
let mut used_cache = false
if env("FORCE_FLATTEN") == "" {
    let newest_cache = exec("ls -t " + cache_dir + "/*.hexa 2>/dev/null | head -1").trim()
    if newest_cache != "" && file_exists(newest_cache) {
        // Is any .hexa file under self/ newer than the cache?
        let newer_cnt = exec("find " + hexa_dir + "/self -name '*.hexa' -newer " + newest_cache + " 2>/dev/null | wc -l").trim()
        let newer_int = to_int(newer_cnt)
        // Filter: the cache's flat contains only files in the transitive `use`
        // graph of hexa_full.hexa. If newer files are only test_* we can still
        // reuse. We'll be strict for correctness: any `use`-referenced file
        // newer than cache = regenerate.
        let mut strict_newer = 0
        let use_names = exec("grep -E '^use \"' " + src_hexa + " | sed 's/^use \"//;s/\"$//'").trim().split("\n")
        let mut j = 0
        while j < len(use_names) {
            let uname = use_names[j].trim()
            if uname != "" {
                let full_path = hexa_dir + "/self/" + uname + ".hexa"
                if file_exists(full_path) {
                    let nw = exec("find " + full_path + " -newer " + newest_cache + " 2>/dev/null | wc -l").trim()
                    if to_int(nw) > 0 {
                        strict_newer = strict_newer + 1
                    }
                }
            }
            j = j + 1
        }
        // Also check the root file
        let root_newer = exec("find " + src_hexa + " -newer " + newest_cache + " 2>/dev/null | wc -l").trim()
        if to_int(root_newer) > 0 {
            strict_newer = strict_newer + 1
        }
        if strict_newer == 0 {
            println("[fixpoint] reusing cached flat: " + newest_cache)
            exec("cp -f " + newest_cache + " " + flat_hexa)
            used_cache = true
        } else {
            println("[fixpoint] cache stale: " + str(strict_newer) + " `use`-referenced file(s) newer than cache")
        }
    }
}

if !used_cache {
    // Strategy B: re-run flatten via stage0 interpreter. Note the known
    // push-O(n²) slowness — may take several minutes on large graphs.
    let flatten_runner = if file_exists(v3_shim) { v3_shim } else { v3 }
    let flatten_prefix = if file_exists(v3_shim) { "HEXA_NO_LAUNCHD=1 " } else { "" }
    println("[fixpoint] running flatten_imports via " + flatten_runner + " (may be slow)")
    let fl = exec_with_status(flatten_prefix + "HEXA_VAL_ARENA=0 timeout --kill-after=10 900 " + flatten_runner + " " + flatten_script + " " + src_hexa + " " + flat_hexa + " 2>&1")
    if fl[1] != 0 && !file_exists(flat_hexa) {
        eprintln("[fixpoint] FAIL flatten (exit=" + str(fl[1]) + ")")
        eprintln(fl[0])
        exit(2)
    }
}

if !file_exists(flat_hexa) {
    eprintln("[fixpoint] FAIL: flat.hexa missing after step 1")
    exit(2)
}
let flat_size = exec("wc -c < " + flat_hexa + " | tr -d ' '").trim()
let flat_sha  = exec("shasum -a 256 " + flat_hexa + " | cut -d' ' -f1").trim()
println("[fixpoint] flat: " + flat_size + " bytes  sha256 = " + flat_sha)

// ── Step 2: transpile via hexa_v2 ─────────────────────────
println("[fixpoint] step 2/4 — transpile: " + hexa_v2 + " -> " + v4_c)
run_cmd("timeout --kill-after=10 300 " + hexa_v2 + " " + flat_hexa + " " + v4_c)
if !file_exists(v4_c) {
    eprintln("[fixpoint] FAIL transpile: " + v4_c + " missing")
    exit(2)
}
let c_size = exec("wc -c < " + v4_c + " | tr -d ' '").trim()
let c_sha  = exec("shasum -a 256 " + v4_c + " | cut -d' ' -f1").trim()
let c_lines = exec("wc -l < " + v4_c + " | tr -d ' '").trim()
println("[fixpoint] v4.c: " + c_lines + " lines, " + c_size + " bytes  sha256 = " + c_sha)

exec("cp -f " + runtime_c + " " + work_dir + "/runtime.c")

// ── Step 3: clang link ─────────────────────────────────────
let uname = exec("uname 2>/dev/null | tr -d ' \\n\\t'").trim()
let clang = if env("CLANG") != "" { env("CLANG") } else { "clang" }
let cflags = if uname == "Linux" {
    "-O2 -std=gnu11 -D_GNU_SOURCE -Wno-trigraphs -I " + hexa_dir + "/self"
} else {
    "-O2 -std=c11 -Wno-trigraphs -I " + hexa_dir + "/self"
}
let ldflags = if uname == "Linux" {
    "-lm -ldl"
} else {
    "-Wl,-stack_size,0x4000000"
}

println("[fixpoint] step 3/4 — clang link")
println("[fixpoint] " + clang + " " + cflags + " " + v4_c + " -o " + v4_bin + " " + ldflags)
run_cmd("timeout --kill-after=10 300 " + clang + " " + cflags + " " + v4_c + " -o " + v4_bin + " " + ldflags)
if !file_exists(v4_bin) {
    eprintln("[fixpoint] FAIL clang: " + v4_bin + " missing")
    exit(2)
}

if uname == "Darwin" {
    let cs = exec_with_status("command -v codesign >/dev/null 2>&1")
    if cs[1] == 0 {
        exec_with_status("codesign --force --sign - " + v4_bin + " 2>/dev/null")
    }
}

let v4_size = exec("wc -c < " + v4_bin + " | tr -d ' '").trim()
let v4_sha  = exec("shasum -a 256 " + v4_bin + " | cut -d' ' -f1").trim()
println("[fixpoint] v4: " + v4_size + " bytes  sha256 = " + v4_sha)

// ── smoke ──────────────────────────────────────────────────
let smoke = work_dir + "/smoke.hexa"
write_file(smoke, "println(\"ok\")\n")
let smoke_r = exec_with_status("HEXA_VAL_ARENA=0 " + v4_bin + " " + smoke + " 2>&1")
let smoke_out = smoke_r[0].trim()
if smoke_r[1] != 0 || smoke_out != "ok" {
    eprintln("[fixpoint] FAIL v4 smoke — expected 'ok', got: [" + smoke_out + "] (exit=" + str(smoke_r[1]) + ")")
    exit(2)
}
println("[fixpoint] v4 smoke: OK")

// ── Step 4: diff ──────────────────────────────────────────
println("[fixpoint] step 4/4 — diff v3 vs v4")
println("")
println("        v3 sha256 = " + v3_sha + " (" + v3_size + " bytes)")
println("        v4 sha256 = " + v4_sha + " (" + v4_size + " bytes)")

if v3_sha == v4_sha && v3_size == v4_size {
    println("")
    println("[fixpoint] RESULT: v3 == v4  IDENTICAL")
    println("[fixpoint] P7-7 self-host fixpoint CLOSED (ROI #153)")
    if env("KEEP") == "" {
        exec("rm -rf " + work_dir)
    }
    exit(0)
}

println("")
println("[fixpoint] RESULT: v3 != v4  DIFF")

let cmp_r = exec_with_status("cmp " + v3 + " " + v4_bin + " 2>&1")
println("[fixpoint] cmp: " + cmp_r[0].trim())

let v3_size_i = to_int(v3_size)
let v4_size_i = to_int(v4_size)
let size_delta = v4_size_i - v3_size_i
println("[fixpoint] size delta (v4 - v3) = " + str(size_delta) + " bytes")

// Attempt to isolate section source of divergence (Mach-O only for now)
if uname == "Darwin" {
    println("")
    println("[fixpoint] otool section sizes:")
    let v3_sect = exec("otool -l " + v3 + " 2>/dev/null | awk '/sectname/ {sn=$2} /size 0x/ {printf \"%s %s\\n\", sn, $2}' | head -20").trim()
    let v4_sect = exec("otool -l " + v4_bin + " 2>/dev/null | awk '/sectname/ {sn=$2} /size 0x/ {printf \"%s %s\\n\", sn, $2}' | head -20").trim()
    println("  v3:")
    println(v3_sect)
    println("  v4:")
    println(v4_sect)
    // Mach-O UUID check (clang embeds a build-uuid; almost certainly differs)
    let v3_uuid = exec("otool -l " + v3 + " 2>/dev/null | awk '/LC_UUID/{getline; print $2}' | head -1").trim()
    let v4_uuid = exec("otool -l " + v4_bin + " 2>/dev/null | awk '/LC_UUID/{getline; print $2}' | head -1").trim()
    println("[fixpoint] LC_UUID  v3=" + v3_uuid + "  v4=" + v4_uuid)
}

// First divergence hex dump
let cmp_offset_raw = exec("cmp " + v3 + " " + v4_bin + " 2>&1 | awk '{print $5}' | head -1 | sed 's/,//g'").trim()
if cmp_offset_raw != "" {
    let off_i = to_int(cmp_offset_raw)
    let off_begin = if off_i > 16 { off_i - 16 } else { 1 }
    let dump_v3 = exec("xxd -s " + str(off_begin - 1) + " -l 48 " + v3 + " 2>/dev/null").trim()
    let dump_v4 = exec("xxd -s " + str(off_begin - 1) + " -l 48 " + v4_bin + " 2>/dev/null").trim()
    println("")
    println("[fixpoint] first divergence @ offset " + str(off_i) + " (hex, ±16 bytes):")
    println("--- v3 ---")
    println(dump_v3)
    println("--- v4 ---")
    println(dump_v4)
}

println("")
println("[fixpoint] diagnosis candidates:")
println("  * clang Mach-O LC_UUID non-determinism (typical)")
println("  * dsymutil path embedding")
println("  * hexa_v2 transpile ordering non-determinism")
println("  * flatten import ordering")
println("")
println("[fixpoint] Strategy to isolate:")
println("  1. Run 2x with IDENTICAL inputs (same flat.hexa, same v4.c):")
println("       clang " + cflags + " v4.c -o v4a " + ldflags)
println("       clang " + cflags + " v4.c -o v4b " + ldflags)
println("     If v4a != v4b -> clang non-determinism (UUID/timestamp)")
println("     If v4a == v4b -> transpile or flatten non-determinism")
println("  2. diff v4.c against earlier .c used for v3 (if preserved)")
println("")
println("[fixpoint] artifacts preserved at " + work_dir)
exit(1)

} // end if _is_main()
