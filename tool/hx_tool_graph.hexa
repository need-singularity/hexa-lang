// tool/hx_tool_graph.hexa — Phase 3.9 tool ecosystem graph (stub).
//
// SPEC: docs/hexa_lang_meta_evolution_proposal_20260422.md §3.9.
// STATUS: stub — skeleton + --selftest only.
//
// PURPOSE
//   Build a graph of tool/*.hexa → tool/*.hexa invocations and stdlib/
//   references. Detect cycles and orphan tools (never invoked by
//   anything). Emit mermaid for quick visual.
//
// CLI
//   hexa tool/hx_tool_graph.hexa --selftest
//   hexa tool/hx_tool_graph.hexa [--out <path>]
//
// OUTPUT
//   $HEXA_LANG/state/hx_tool_graph.json + docs/hx_tool_graph.md
//   schema = "hexa-lang/hx_tool_graph/1"

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _iso_now() -> string {
    return to_string(exec("date -u +'%Y-%m-%dT%H:%M:%SZ'")).trim()
}

fn _arg_value(args: array, key: string, default: string) -> string {
    let mut i = 0
    while i < len(args) {
        if args[i] == key {
            let j = i + 1
            if j < len(args) { return args[j] }
        }
        i = i + 1
    }
    return default
}

fn _selftest() -> int {
    if len(_iso_now()) < 10 {
        eprintln("hx_tool_graph: selftest FAIL")
        return 1
    }
    println("hx_tool_graph: selftest PASS (stub)")
    return 0
}

fn _emit(out_path: string) -> int {
    let ts = _iso_now()
    let body = "{\n  \"schema\": \"hexa-lang/hx_tool_graph/1\",\n  \"ts\": \"" + ts + "\",\n  \"status\": \"stub\",\n  \"nodes\": [],\n  \"edges\": [],\n  \"cycles\": [],\n  \"orphans\": []\n}\n"
    try {
        write_file(out_path, body)
    } catch e {
        eprintln("hx_tool_graph: write FAIL " + out_path)
        return 1
    }
    println("hx_tool_graph: wrote " + out_path + " (stub)")
    return 0
}

fn main() {
    let av = argv()
    let mut args = []
    let mut i = 2
    while i < len(av) { args.push(av[i]); i = i + 1 }

    if len(args) >= 1 && args[0] == "--selftest" {
        exit(_selftest())
    }

    let default_out = _home() + "/core/hexa-lang/state/hx_tool_graph.json"
    let out_path = _arg_value(args, "--out", default_out)
    exit(_emit(out_path))
}
