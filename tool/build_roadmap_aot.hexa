// tool/build_roadmap_aot.hexa — rebuild all AOT targets used by the roadmap
// engine and verification gate drills into bin/. Enforces HEXA_MAC_BUILD_OK=1
// on Darwin so /tmp-refuse policy doesn't block the build.
//
// Usage:
//   hexa tool/build_roadmap_aot.hexa         — build all targets
//   hexa tool/build_roadmap_aot.hexa --list  — print target list and exit
//
// Exit 0 on full success, 1 if any target fails (prints which).

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _targets() -> array {
    // (src_dir, stem)
    let repo = _home() + "/core/hexa-lang"
    let mut ts = []
    for s in [
        "roadmap_engine",
        "roadmap_parse", "roadmap_validate", "roadmap_dag",
        "roadmap_critical_path", "roadmap_parallel", "roadmap_ready_set",
        "roadmap_progress", "roadmap_evidence", "roadmap_bottleneck",
        "roadmap_info_account", "roadmap_stagnation", "roadmap_span_dag",
        "roadmap_t_star", "roadmap_phase_gate", "roadmap_status_flip",
        "verify_gate_dsl", "verify_cert_linker", "verify_adversarial",
        "verify_meta2_chain", "verify_multi_path_phi"
    ] {
        ts.push([repo + "/tool/" + s + ".hexa", repo + "/bin/" + s, s])
    }
    // [retired 2026-04-25] cross-repo airgenome hook AOT target removed (airgenome/hooks/ 폐기)
    return ts
}

fn cmd_selftest() -> i64 {
    println("[build_roadmap_aot selftest]")
    let mut fails = 0

    // T1: _home() returns non-empty string
    let h = _home()
    if len(h) == 0 { eprintln("  FAIL T1 empty home"); fails = fails + 1 }
    else { println("  OK   T1 _home() non-empty") }

    // T2: _targets() list is non-empty and well-formed (triple per row)
    let ts = _targets()
    if len(ts) < 10 {
        eprintln("  FAIL T2 too few targets"); fails = fails + 1
    } else if len(ts[0]) != 3 {
        eprintln("  FAIL T2 wrong arity"); fails = fails + 1
    } else { println("  OK   T2 _targets() shape OK") }

    // [retired 2026-04-25] T3 (airgenome cross-repo hook target) removed — target no longer exists.

    if fails != 0 { return 1 }
    println("[build_roadmap_aot selftest] OK")
    return 0
}

fn main() {
    let av = argv()
    let mut _sti = 2
    while _sti < len(av) {
        if av[_sti] == "--selftest" || av[_sti] == "selftest" {
            exit(cmd_selftest())
        }
        _sti = _sti + 1
    }
    let mut list_only = false
    let mut i = 2
    while i < len(av) {
        if av[i] == "--list" { list_only = true }
        i = i + 1
    }

    let ts = _targets()

    if list_only {
        for t in ts { println(t[2] + "  " + t[0] + " -> " + t[1]) }
        exit(0)
    }

    let repo = _home() + "/core/hexa-lang"
    // Ensure bin/ dir exists.
    exec_with_status("mkdir -p '" + repo + "/bin'")

    let mut ok = 0
    let mut fail = 0
    let mut failed_names = []
    for t in ts {
        let src = t[0]
        let out = t[1]
        let name = t[2]
        let cmd = "HEXA_MAC_BUILD_OK=1 hexa build '" + src + "' -o '" + out + "' 2>&1"
        let r = exec_with_status(cmd)
        if r[1] == 0 {
            println("  OK    " + name)
            ok = ok + 1
        } else {
            println("  FAIL  " + name)
            println(r[0])
            failed_names.push(name)
            fail = fail + 1
        }
    }

    println("")
    println("built " + to_string(ok) + "/" + to_string(ok + fail))
    if fail > 0 {
        eprintln("failed: " + to_string(fail))
        for n in failed_names { eprintln("  - " + n) }
        exit(1)
    }
    exit(0)
}
