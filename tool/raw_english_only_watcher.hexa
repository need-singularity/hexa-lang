#!hexa strict
// tool/raw_english_only_watcher.hexa — L2 launchd watcher for raw 33.
//
// Every StartInterval (60s by default), scans .raw for any non-English
// natural-language runs introduced since the last-seen checkpoint. Clean
// runs are no-ops; violations append an AI-native English JSON warning to
// .raw-english-violations.jsonl for downstream review (raw_audit hash-chain).
//
// Checkpoint file: .raw-english-checkpoint (contains last scanned mtime + sha1).
//
// Non-blocking: this watcher only observes and reports. Blocking is attempted
// by the airgenome post_tool Write/Edit filter (L4) upstream.

use "self/core/law_io"

fn _root() -> string {
    let mut r = env("CLAUDE_PROJECT_DIR")
    if r == "" { r = env("HEXA_LANG_ROOT") }
    if r == "" { r = to_string(exec("pwd")).trim() }
    return r
}

fn _raw_path()       -> string { return _root() + "/.raw" }
fn _log_path()       -> string { return _root() + "/.raw-english-violations.jsonl" }
fn _checkpoint_path() -> string { return _root() + "/.raw-english-checkpoint" }

fn _file_sha(path: string) -> string {
    let out = to_string(exec("shasum -a 256 '" + path + "' 2>/dev/null | awk '{print $1}'")).trim()
    return out
}

fn _read_checkpoint() -> string {
    let p = _checkpoint_path()
    let exists = to_string(exec("test -f '" + p + "' && echo y || echo n")).trim()
    if exists != "y" { return "" }
    return to_string(read_file(p)).trim()
}

fn _write_checkpoint(sha: string) -> void {
    write_file(_checkpoint_path(), sha + "\n")
}

fn _now_utc() -> string {
    return to_string(exec("date -u +%Y-%m-%dT%H:%M:%SZ")).trim()
}

fn main() -> void {
    let raw = _raw_path()
    let exists = to_string(exec("test -f '" + raw + "' && echo y || echo n")).trim()
    if exists != "y" {
        println("raw_english_only_watcher: .raw not found — " + raw)
        exit(0)
    }

    let cur_sha = _file_sha(raw)
    let last_sha = _read_checkpoint()
    if cur_sha != "" && cur_sha == last_sha {
        println("raw_english_only_watcher: no change (sha=" + cur_sha + ")")
        exit(0)
    }

    // Run the lint tool with warn severity; capture stdout JSON.
    let hx_root = env("HEXA_LANG_ROOT")
    let root = if hx_root != "" { hx_root } else { _root() }
    let lint_tool = root + "/tool/raw_english_only_lint.hexa"
    let cmd = "'" + hx_root + "/hexa' '" + lint_tool + "' '" + raw + "' --severity warn 2>/dev/null"
    let out = to_string(exec(cmd)).trim()
    if out == "" {
        // lint tool failed; record sentinel and continue
        let sentinel = "{\"ts\":\"" + _now_utc() + "\",\"rule\":\"raw:ai-native-english-only\",\"status\":\"lint-exec-failed\"}"
        let _ = exec("printf '%s\\n' '" + sentinel.replace("'", "'\\''") + "' >> '" + _log_path() + "'")
        exit(0)
    }

    // Extract verdict via jq
    let tmp = to_string(exec("mktemp -t english_watcher.XXXXXX")).trim()
    write_file(tmp, out)
    let verdict = to_string(exec("jq -r '.verdict // \"\"' '" + tmp + "' 2>/dev/null")).trim()
    let count = to_string(exec("jq -r '.violations_total // 0' '" + tmp + "' 2>/dev/null")).trim()
    let _ = exec("rm -f '" + tmp + "'")

    if verdict == "warn" {
        let record = "{\"ts\":\"" + _now_utc()
            + "\",\"rule\":\"raw:ai-native-english-only\",\"sha\":\"" + cur_sha
            + "\",\"violations\":" + count
            + ",\"report\":" + out + "}"
        let _ = exec("printf '%s\\n' '" + record.replace("'", "'\\''") + "' >> '" + _log_path() + "'")
    }

    _write_checkpoint(cur_sha)
    println("raw_english_only_watcher: scanned sha=" + cur_sha + " violations=" + count)
    exit(0)
}
