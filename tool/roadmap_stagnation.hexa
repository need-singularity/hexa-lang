// tool/roadmap_stagnation.hexa — Tier6#55 (roadmap 50): η_k bottleneck movement
//
// PURPOSE
//   Invariant 3: η_k > 0 — the bottleneck axis must move. If the same
//   axis i ∈ Ω remains the bottleneck for N consecutive layers, the
//   system has stagnated. Alarm raised with bypass suggestion.
//
//   η_k = 0 iff argmax_i c_i(S_k) == argmax_i c_i(S_{k-1}). We accept
//   runs up to N=4 (Path B has ≤4 learn-dominant days before Day 5
//   verify); alarm at N≥5 by default.
//
// CLI
//   hexa tool/roadmap_stagnation.hexa [--path-b] [--n 5]
//   hexa tool/roadmap_stagnation.hexa --selftest

fn _rstrip(s: string) -> string {
    let mut end = len(s)
    while end > 0 {
        let c = s.substring(end - 1, end)
        if c == " " || c == "\t" || c == "\r" { end = end - 1 } else { break }
    }
    return s.substring(0, end)
}

fn _hdr(line: string) -> array {
    let sp1 = line.index_of(" ")
    if sp1 < 0 { return [] }
    if line.substring(0, sp1) != "roadmap" { return [] }
    let r1 = line.substring(sp1 + 1, len(line))
    let sp2 = r1.index_of(" ")
    if sp2 < 0 { return [] }
    let id = r1.substring(0, sp2)
    let r2 = r1.substring(sp2 + 1, len(r1))
    let sp3 = r2.index_of(" ")
    if sp3 < 0 { return [] }
    let st = r2.substring(0, sp3)
    let mut nm = r2.substring(sp3 + 1, len(r2)).trim()
    if len(nm) >= 2 && nm.substring(0, 1) == "\"" { nm = nm.substring(1, len(nm) - 1) }
    return [id, st, nm]
}

fn parse_roadmap(src: string) -> array {
    let lines = split(src, "\n")
    let mut rules = []
    let mut kind = ""
    let mut cid = ""; let mut cst = ""; let mut cnm = ""; let mut ck = []
    for raw_line in lines {
        let line = _rstrip(raw_line)
        if len(line) == 0 {
            if kind == "r" { rules.push([cid, cst, cnm, ck]) }
            kind = ""; ck = []
            continue
        }
        let f = line.substring(0, 1)
        if f == "#" { continue }
        if f == " " || f == "\t" {
            if kind == "" { continue }
            let s = line.trim_start()
            let sp = s.index_of(" ")
            if sp < 0 { continue }
            ck.push([s.substring(0, sp), s.substring(sp + 1, len(s)).trim()])
        } else {
            if kind == "r" { rules.push([cid, cst, cnm, ck]) }
            ck = []; kind = ""
            let fs = line.index_of(" ")
            if fs < 0 { continue }
            if line.substring(0, fs) == "roadmap" {
                let h = _hdr(line)
                if len(h) == 0 { continue }
                cid = h[0]; cst = h[1]; cnm = h[2]; kind = "r"
            }
        }
    }
    if kind == "r" { rules.push([cid, cst, cnm, ck]) }
    return rules
}

fn _load(path: string) -> array {
    let r = exec_with_status("test -f '" + path + "'")
    if r[1] != 0 { return [] }
    return parse_roadmap(to_string(read_file(path)))
}

fn _kv(keys: array, k: string) -> string {
    for kv in keys { if kv[0] == k { return kv[1] } }
    return ""
}

fn _is_int(s: string) -> bool {
    if len(s) == 0 { return false }
    let d = "0123456789"
    let mut i = 0
    while i < len(s) { if !d.contains(s.substring(i, i + 1)) { return false } i = i + 1 }
    return true
}

fn _parse_int(s: string) -> int {
    let mut n = 0
    let d = "0123456789"
    let mut i = 0
    while i < len(s) {
        let c = s.substring(i, i + 1)
        if !d.contains(c) { return n }
        n = n * 10 + d.index_of(c)
        i = i + 1
    }
    return n
}

fn parse_deps(val: string, default_repo: string) -> array {
    let mut out = []
    if len(val) == 0 || val == "—" { return out }
    let cleaned = val.replace(",", " ").replace("+", " ")
    let toks = split(cleaned, " ")
    let mut current = default_repo
    for raw in toks {
        let t = raw.trim()
        if len(t) == 0 { continue }
        let at = t.index_of("@")
        if at > 0 && at < len(t) - 1 {
            let repo = t.substring(0, at)
            let id = t.substring(at + 1, len(t))
            if _is_int(id) { out.push([repo, id]); current = repo; continue }
        }
        if _is_int(t) { out.push([current, t]) }
    }
    return out
}

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _load_repos() -> array {
    let home = _home()
    let mut out = []
    for r in ["anima", "airgenome", "hexa-lang"] {
        out.push([r, _load(home + "/core/" + r + "/.roadmap")])
    }
    return out
}

fn _filter_pathB(repos: array) -> array {
    let mut out = []
    for rr in repos {
        if rr[0] != "anima" { continue }
        let mut kept = []
        for rule in rr[1] {
            if !_is_int(rule[0]) { continue }
            let n = _parse_int(rule[0])
            if n >= 22 && n <= 30 { kept.push(rule) }
        }
        out.push(["anima", kept])
    }
    return out
}

fn classify(rule: array) -> string {
    let name = rule[2].to_lower()
    let keys = rule[3]
    let track = _kv(keys, "track").to_lower()
    let phase = _kv(keys, "phase").to_lower()
    if name.contains("selftest") || name.contains("verify") || name.contains("audit") || name.contains("drill") || name.contains("proof") { return "verify" }
    if phase.starts_with("t1") || phase.starts_with("t2") || phase.starts_with("t3") || phase.starts_with("t4") || phase.starts_with("t5") || phase.starts_with("t6") { return "verify" }
    if name.contains("experiment") || name.contains("measure") || name.contains("bench") { return "exp" }
    if phase.starts_with("p0") { return "boot" }
    if track == "ssot" { return "boot" }
    if track == "bootstrap" { return "boot" }
    if track == "hybrid" || track == "cell" || track == "lora" { return "learn" }
    return "build"
}

// returns per-layer bottleneck axis [axis_str, ...]
fn layer_axes(repos: array) -> array {
    let mut keys = []
    let mut axes_each = []
    for rr in repos {
        for rule in rr[1] {
            keys.push(rr[0] + "#" + rule[0])
            axes_each.push(classify(rule))
        }
    }
    let n = len(keys)
    let mut pred = []
    let mut succ = []
    let mut i = 0
    while i < n { pred.push([]); succ.push([]); i = i + 1 }
    for rr in repos {
        for rule in rr[1] {
            let sk = rr[0] + "#" + rule[0]
            let dep = _kv(rule[3], "depends-on")
            for pair in parse_deps(dep, rr[0]) {
                let tk = pair[0] + "#" + pair[1]
                let mut fi = -1; let mut ti = -1
                let mut k = 0
                while k < n {
                    if keys[k] == sk { fi = k }
                    if keys[k] == tk { ti = k }
                    k = k + 1
                }
                if fi < 0 || ti < 0 { continue }
                let p = pred[fi]; p.push(ti); pred[fi] = p
                let s = succ[ti]; s.push(fi); succ[ti] = s
            }
        }
    }
    let mut indeg = []
    let mut j = 0
    while j < n { indeg.push(len(pred[j])); j = j + 1 }
    let mut q = []
    let mut topo = []
    let mut jj = 0
    while jj < n { if indeg[jj] == 0 { q.push(jj) } jj = jj + 1 }
    let mut qi = 0
    while qi < len(q) {
        let u = q[qi]
        topo.push(u)
        for v in succ[u] {
            indeg[v] = indeg[v] - 1
            if indeg[v] == 0 { q.push(v) }
        }
        qi = qi + 1
    }
    if len(topo) != n { return [[], true] }
    let mut depth = []
    let mut k2 = 0
    while k2 < n { depth.push(0); k2 = k2 + 1 }
    for u in topo {
        let mut best = -1
        for p in pred[u] { if depth[p] > best { best = depth[p] } }
        if best >= 0 { depth[u] = best + 1 } else { depth[u] = 0 }
    }
    let mut max_d = 0
    for d in depth { if d > max_d { max_d = d } }

    let axis_list = ["build", "exp", "learn", "boot", "verify"]
    let mut axes_per_layer = []
    let mut d = 0
    while d <= max_d {
        let mut counts = [0, 0, 0, 0, 0]
        let mut idx = 0
        while idx < n {
            if depth[idx] == d {
                let mut ai = 0
                while ai < 5 {
                    if axes_each[idx] == axis_list[ai] { counts[ai] = counts[ai] + 1 }
                    ai = ai + 1
                }
            }
            idx = idx + 1
        }
        let mut best_i = 0
        let mut best_v = counts[0]
        let mut ai = 1
        while ai < 5 { if counts[ai] > best_v { best_v = counts[ai]; best_i = ai } ai = ai + 1 }
        axes_per_layer.push(axis_list[best_i])
        d = d + 1
    }
    return [axes_per_layer, false]
}

// Find runs of identical axis. Returns [[axis, start, length], ...]
fn find_runs(axes: array) -> array {
    let mut runs = []
    if len(axes) == 0 { return runs }
    let mut cur = axes[0]
    let mut start = 0
    let mut i = 1
    while i < len(axes) {
        if axes[i] != cur {
            runs.push([cur, start, i - start])
            cur = axes[i]
            start = i
        }
        i = i + 1
    }
    runs.push([cur, start, len(axes) - start])
    return runs
}

fn _selftest() -> int {
    // Path B: likely 1 long run of "learn"
    let pb = _filter_pathB(_load_repos())
    let la = layer_axes(pb)
    if la[1] != false {
        eprintln("selftest FAIL: cycle")
        return 1
    }
    let axes = la[0]
    let runs = find_runs(axes)
    println("Path B axis trajectory: " + axes.join(" → "))
    println("runs:")
    for r in runs { println("  " + r[0] + " start=" + to_string(r[1]) + " len=" + to_string(r[2])) }
    // Assert at least one run ≥ 3 (Path B has ≥3 consecutive learn days)
    let mut longest = 0
    let mut longest_axis = ""
    for r in runs { if r[2] > longest { longest = r[2]; longest_axis = r[0] } }
    println("longest run: axis=" + longest_axis + " length=" + to_string(longest))
    // N=5 threshold — Path B is 6 days all learn. Should trigger alarm at
    // threshold 5.
    let threshold = 5
    let mut alarmed = false
    for r in runs { if r[2] >= threshold { alarmed = true } }
    if !alarmed {
        eprintln("selftest FAIL: Path B has 6 consecutive learn days, alarm threshold=5 not triggered")
        return 1
    }
    println("η_k ALARM: axis " + longest_axis + " stagnant for " + to_string(longest) + " layers (threshold=" + to_string(threshold) + ")")
    println("suggestion: interleave verify layer between learn layers (e.g. Day 3 or 4)")
    println("selftest PASS — η_k > 0 invariant check working")
    return 0
}

fn main() {
    let av = argv()
    let mut args = []
    let mut i = 2
    while i < len(av) { args.push(av[i]); i = i + 1 }
    if len(args) >= 1 && args[0] == "--selftest" { exit(_selftest()) }

    let mut pb = false
    let mut threshold = 5
    let mut j = 0
    while j < len(args) {
        if args[j] == "--path-b" { pb = true }
        if args[j] == "--n" && j + 1 < len(args) { threshold = _parse_int(args[j + 1]); j = j + 1 }
        j = j + 1
    }
    let mut repos = _load_repos()
    if pb { repos = _filter_pathB(repos) }
    let la = layer_axes(repos)
    if la[1] == true { eprintln("CYCLE"); exit(1) }
    let axes = la[0]
    let runs = find_runs(axes)

    let mut p = []
    p.push("{\"threshold\":"); p.push(to_string(threshold))
    p.push(",\"axes\":[")
    let mut first = true
    for a in axes { if !first { p.push(",") } p.push("\""); p.push(a); p.push("\""); first = false }
    p.push("],\"runs\":[")
    first = true
    for r in runs {
        if !first { p.push(",") }
        p.push("{\"axis\":\""); p.push(r[0]); p.push("\",\"start\":"); p.push(to_string(r[1])); p.push(",\"length\":"); p.push(to_string(r[2])); p.push("}")
        first = false
    }
    p.push("],\"alarms\":[")
    first = true
    for r in runs {
        if r[2] >= threshold {
            if !first { p.push(",") }
            p.push("{\"axis\":\""); p.push(r[0]); p.push("\",\"length\":"); p.push(to_string(r[2])); p.push("}")
            first = false
        }
    }
    p.push("]}")
    println(p.join(""))
}
