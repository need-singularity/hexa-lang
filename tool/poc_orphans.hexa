// tool/poc_orphans.hexa
//
// Orphan-kind detector for self/poc/<cat>/*.hexa handlers.
//
// An "orphan" = an AST kind declared in a handler's `// @kinds X[, Y]`
// annotation that does NOT appear in hexa's canonical AST-kind vocabulary.
// Such entries usually indicate a typo or a dropped feature: the handler
// will never be dispatched because the parser never emits that kind.
//
// Canonical source priority (first that succeeds wins):
//   1. self/hexa_full.hexa   — parser+AST in one file; richest signal.
//                              Extracts every "PascalCase" string literal.
//   2. self/parser.hexa      — fallback slice of the parser.
//   3. self/ast.hexa         — fallback AST definitions.
//   4. doc/grammar.jsonl — last-resort spec.
//
// Implemented kinds are taken from self/poc/{expr,stmt}/*.hexa using the
// same `// @kinds X[, Y]` extraction as tool/poc_lint.hexa.
//
// Usage:  hexa tool/poc_orphans.hexa
// Exit:   0 no orphans, 1 orphans found.

let CATS = [["expr", "ex"], ["stmt", "st"]]

fn strip(s) {
    let mut i = 0
    while i < len(s) && (s[i] == " " || s[i] == "\t") { i = i + 1 }
    let mut j = len(s) - 1
    while j >= i && (s[j] == " " || s[j] == "\t" || s[j] == "\r" || s[j] == "\n") { j = j - 1 }
    let mut out = ""
    let mut k = i
    while k <= j { out = out + s[k]; k = k + 1 }
    return out
}

fn starts_with(s, p) { return s.starts_with(p) }

fn list_dir_hexa(dir) {
    let raw = exec("ls " + dir + "/*.hexa 2>/dev/null")
    if raw == "" { return [] }
    let lines = raw.split("\n")
    let mut out = []
    let mut i = 0
    while i < len(lines) {
        let s = strip(lines[i])
        if s != "" { out = out.push(s) }
        i = i + 1
    }
    return out
}

fn split_by_comma(s) {
    let mut out = []
    let mut cur = ""
    let mut i = 0
    while i < len(s) {
        if s[i] == "," { out = out.push(strip(cur)); cur = "" } else { cur = cur + s[i] }
        i = i + 1
    }
    let last = strip(cur)
    if last != "" { out = out.push(last) }
    return out
}

// Extract annotation value after "// @<tag> " on a trimmed line.
fn annot_val(line, tag) {
    let prefix = "// @" + tag
    if !starts_with(line, prefix) { return "" }
    let mut i = len(prefix)
    while i < len(line) && (line[i] == " " || line[i] == "\t") { i = i + 1 }
    let mut out = ""
    while i < len(line) { out = out + line[i]; i = i + 1 }
    return strip(out)
}

fn contains_str(arr, s) {
    let mut i = 0
    while i < len(arr) { if arr[i] == s { return true } ; i = i + 1 }
    return false
}

// Harvest canonical AST kinds from a file by pulling every PascalCase
// string literal it contains. PascalCase = starts with an uppercase
// letter followed by any letters. This is a superset (it includes
// token names, enum tags, etc.), which is exactly what we want for a
// conservative orphan check — false negatives (missed orphans) are
// preferred over false positives.
fn harvest_kinds_from(path) {
    let src = read_file(path)
    if src == "" { return [] }
    let mut out = []
    let n = len(src)
    let mut i = 0
    while i < n {
        // Find a double-quote.
        if src[i] == "\"" {
            let start = i + 1
            let mut j = start
            while j < n && src[j] != "\"" { j = j + 1 }
            if j < n {
                // Extract token.
                let mut tok = ""
                let mut k = start
                while k < j { tok = tok + src[k]; k = k + 1 }
                // Must be PascalCase: len >= 2, first char A-Z, all alpha, no underscore/digit/space.
                let tl = len(tok)
                if tl >= 2 {
                    let c0 = tok[0]
                    let is_upper = c0 >= "A" && c0 <= "Z"
                    let mut ok = is_upper
                    let mut q = 0
                    while ok && q < tl {
                        let c = tok[q]
                        let lc = c >= "a" && c <= "z"
                        let uc = c >= "A" && c <= "Z"
                        if !lc && !uc { ok = false }
                        q = q + 1
                    }
                    if ok && !contains_str(out, tok) { out = out.push(tok) }
                }
                i = j + 1
                continue
            }
        }
        i = i + 1
    }
    return out
}

fn file_exists(path) {
    let r = exec("test -f '" + path + "' && echo yes")
    return strip(r) == "yes"
}

fn gather_canonical() {
    let candidates = [
        "self/hexa_full.hexa",
        "self/parser.hexa",
        "self/ast.hexa",
        "doc/grammar.jsonl"
    ]
    let mut kinds = []
    let mut used = []
    let mut i = 0
    while i < len(candidates) {
        let p = candidates[i]
        if file_exists(p) {
            let k = harvest_kinds_from(p)
            if len(k) > 0 {
                used = used.push(p + " (" + str(len(k)) + ")")
                // Merge.
                let mut j = 0
                while j < len(k) {
                    if !contains_str(kinds, k[j]) { kinds = kinds.push(k[j]) }
                    j = j + 1
                }
            }
        }
        i = i + 1
    }
    println("[poc-orphans] canonical sources:")
    let mut u = 0
    while u < len(used) { println("    " + used[u]) ; u = u + 1 }
    return kinds
}

fn gather_implemented() {
    // Returns [[kind, file], ...]
    let mut out = []
    let mut c = 0
    while c < len(CATS) {
        let cat = CATS[c][0]
        let dir = "self/poc/" + cat
        let files = list_dir_hexa(dir)
        let mut fi = 0
        while fi < len(files) {
            let path = files[fi]
            let src = read_file(path)
            if src != "" {
                let lines = src.split("\n")
                let mut ann = ""
                let mut i = 1
                while i < len(lines) && i < 5 {
                    let s = strip(lines[i])
                    if s != "" {
                        let v = annot_val(s, "kinds")
                        if v != "" { ann = v; break }
                    }
                    i = i + 1
                }
                if ann != "" {
                    let keys = split_by_comma(ann)
                    let mut ki = 0
                    while ki < len(keys) {
                        let k = keys[ki]
                        if k != "" { out = out.push([k, path]) }
                        ki = ki + 1
                    }
                }
            }
            fi = fi + 1
        }
        c = c + 1
    }
    return out
}

fn main() {
    let canonical = gather_canonical()
    println("[poc-orphans] canonical kinds: " + str(len(canonical)))

    let implemented = gather_implemented()
    println("[poc-orphans] implemented kinds: " + str(len(implemented)))

    let mut orphans = []
    let mut i = 0
    while i < len(implemented) {
        let kind = implemented[i][0]
        let path = implemented[i][1]
        if !contains_str(canonical, kind) {
            orphans = orphans.push([kind, path])
        }
        i = i + 1
    }

    if len(orphans) == 0 {
        println("[poc-orphans] OK — no orphans")
        exit(0)
    }

    println("[poc-orphans] FAIL — " + str(len(orphans)) + " orphan(s):")
    let mut j = 0
    while j < len(orphans) {
        println("    " + orphans[j][0] + "  (" + orphans[j][1] + ")")
        j = j + 1
    }
    exit(1)
}

main()
