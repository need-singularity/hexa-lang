// ai_native_scan — scan repo for ai-native naming violations (report-only)
//
// Rules checked:
//   F1  version suffix  _v\d+ _\d+ \d+$      codegen_v2.hexa   codegen2.hexa
//   F2  stage/phase #   stage\d phase\d p\d  rebuild_stage0    phase1.hexa
//   F3  temp suffix     _old _new _bak _tmp  foo_old.hexa
//   F4  generic dir     utils/ helpers/ common/ lib/ misc/ core/
//   F5  loner dir       folder with only 1 file  → flatten
//   F6  parent-child    parser/parser_*.hexa redundant
//
// Pure report. Exit 0 always. Does not modify anything.

fn strip_ext(name) {
    let mut i = len(name) - 1
    while i >= 0 {
        if name[i] == "." { return name.substring(0, i) }
        i = i - 1
    }
    return name
}

fn is_digit(c) {
    return c == "0" || c == "1" || c == "2" || c == "3" || c == "4" ||
           c == "5" || c == "6" || c == "7" || c == "8" || c == "9"
}

fn ends_with_digits(s) {
    if len(s) == 0 { return false }
    return is_digit(s[len(s) - 1])
}

fn has_version_suffix(stem) {
    // _v\d+ at end — flag
    // _\d+[kmb] (size: 512k, 330m, 7b) — allow
    // _\d+x\d+ (dims: 256x256) — allow (handled by trailing letter check)
    // _\d+ plain (256, 330) — allow (size param; humans use specific numbers)
    // Only _v\d+ is a true version marker
    let mut i = len(stem) - 1
    while i > 0 && is_digit(stem[i]) { i = i - 1 }
    if i < len(stem) - 1 {
        // had trailing digits; flag ONLY if preceded by _v
        if i >= 1 && stem[i] == "v" && stem[i - 1] == "_" { return true }
    }
    return false
}

fn is_product_name(stem) {
    // Exception: product-name identifiers that legitimately contain stage/phase
    // stage0 = self-host boot binary (L0/L1/L2 are architectural tiers)
    // build_stage0, rebuild_stage0, hexa_stage0 — product ops, not version
    if stem == "build_stage0" { return true }
    if stem == "build_stage1" { return true }
    if stem == "rebuild_stage0" { return true }
    if stem == "hexa_stage0" { return true }
    if stem == "regression_stage1" { return true }
    return false
}

fn has_stage_phase(stem) {
    if is_product_name(stem) { return false }
    // check segments separated by _
    let parts = stem.split("_")
    let mut i = 0
    while i < len(parts) {
        let p = parts[i]
        if p == "stage0" || p == "stage1" || p == "stage2" || p == "stage3" { return true }
        if p == "phase0" || p == "phase1" || p == "phase2" || p == "phase3" { return true }
        if len(p) >= 2 && p[0] == "p" && is_digit(p[1]) {
            if len(p) == 2 { return true }
            if len(p) == 3 && is_digit(p[2]) { return true }
        }
        i = i + 1
    }
    return false
}

fn has_temp_suffix(stem) {
    let suffixes = ["_old", "_new", "_bak", "_tmp", "_copy", "_backup", "_save"]
    let mut i = 0
    while i < len(suffixes) {
        let s = suffixes[i]
        if len(stem) > len(s) {
            if stem.substring(len(stem) - len(s), len(stem)) == s { return true }
        }
        i = i + 1
    }
    return false
}

fn is_generic_dir(name) {
    return name == "utils" || name == "helpers" || name == "common" ||
           name == "lib" || name == "misc" || name == "stuff" ||
           name == "core" || name == "base"
}

fn is_dir_shell(path) {
    try {
        let r = exec("test -d '" + path + "' && echo D || echo F").trim()
        return r == "D"
    } catch e { return false }
}

fn scan_dir(dir, violations) {
    let entries = list_dir(dir)
    let mut hexa_files = []
    let mut subdirs = []
    let mut i = 0
    while i < len(entries) {
        let name = entries[i]
        if name == "." || name == ".." { i = i + 1; continue }
        let full = dir + "/" + name
        if is_dir_shell(full) {
            if name[0] == "." { i = i + 1; continue }
            if name == "node_modules" || name == "target" || name == "build" { i = i + 1; continue }
            if is_generic_dir(name) {
                violations = violations.push(["F4-generic-dir", full])
            }
            subdirs = subdirs.push(full)
        } else {
            if len(name) >= 5 && name.substring(len(name) - 5, len(name)) == ".hexa" {
                hexa_files = hexa_files.push(name)
                let stem = strip_ext(name)
                if has_version_suffix(stem) {
                    violations = violations.push(["F1-version", full])
                }
                if has_stage_phase(stem) {
                    violations = violations.push(["F2-stage", full])
                }
                if has_temp_suffix(stem) {
                    violations = violations.push(["F3-temp", full])
                }
            }
        }
        i = i + 1
    }
    // F5: single-file directory
    if len(hexa_files) == 1 && len(subdirs) == 0 && dir != "." && dir != "./tests" {
        violations = violations.push(["F5-loner", dir + "/" + hexa_files[0]])
    }
    // Recurse
    let mut j = 0
    while j < len(subdirs) {
        violations = scan_dir(subdirs[j], violations)
        j = j + 1
    }
    return violations
}

fn main() {
    let roots = ["self", "scripts", "tests", "bench"]
    let mut violations = []
    let mut i = 0
    while i < len(roots) {
        if is_dir_shell(roots[i]) {
            violations = scan_dir(roots[i], violations)
        }
        i = i + 1
    }

    if len(violations) == 0 {
        println("ai-native-scan: CLEAN — 0 violations")
        return
    }

    println("ai-native-scan: " + to_string(len(violations)) + " violations")
    println("")
    let mut k = 0
    while k < len(violations) {
        println("  " + violations[k][0] + "  " + violations[k][1])
        k = k + 1
    }
    println("")
    println("Legend:")
    println("  F1  version suffix    _v\\d+ or _\\d+ at stem end")
    println("  F2  stage/phase #     stage0/phase1/p\\d segments")
    println("  F3  temp suffix       _old/_new/_bak/_tmp/_copy")
    println("  F4  generic dir       utils/helpers/common/lib/misc/core")
    println("  F5  loner dir         dir with single .hexa — flatten")
}

