// tool/roadmap_health_score.hexa — Phase 3.5 health score aggregator (stub).
//
// SPEC: docs/roadmap_engine_continuous_meta_proposal_20260422.md §Phase 3.5.
// STATUS: stub — skeleton + --selftest only.
//
// PURPOSE
//   Aggregate blocker_inventory + drift + velocity + roi_inventory into a
//   0–100 health score (per-repo + global rollup).
//     Weights: blocker -30, drift -20, stale -10, regression -40,
//              ROI-backlog -10, mean_pct +50.
//
// CLI
//   hexa tool/roadmap_health_score.hexa --selftest
//   hexa tool/roadmap_health_score.hexa --repo <name> [--out <path>]
//   hexa tool/roadmap_health_score.hexa --global [--out <path>]
//
// OUTPUT
//   $HEXA_LANG/state/roadmap_health_<repo>.json   (per-repo)
//   $HEXA_LANG/docs/roadmap_health_global.md       (global rollup)
//   schema = "hexa-lang/roadmap_health/1"

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _iso_now() -> string {
    return to_string(exec("date -u +'%Y-%m-%dT%H:%M:%SZ'")).trim()
}

fn _arg_value(args: array, key: string, default: string) -> string {
    let mut i = 0
    while i < len(args) {
        if args[i] == key {
            let j = i + 1
            if j < len(args) { return args[j] }
        }
        i = i + 1
    }
    return default
}

fn _has_flag(args: array, key: string) -> bool {
    let mut i = 0
    while i < len(args) {
        if args[i] == key { return true }
        i = i + 1
    }
    return false
}

fn _selftest() -> int {
    if len(_iso_now()) < 10 {
        eprintln("roadmap_health_score: selftest FAIL (iso_now empty)")
        return 1
    }
    println("roadmap_health_score: selftest PASS (stub)")
    return 0
}

fn _emit(repo: string, out_path: string) -> int {
    let ts = _iso_now()
    let body = "{\n  \"schema\": \"hexa-lang/roadmap_health/1\",\n  \"ts\": \"" + ts + "\",\n  \"repo\": \"" + repo + "\",\n  \"status\": \"stub\",\n  \"score\": 0,\n  \"components\": {\"blocker\": 0, \"drift\": 0, \"stale\": 0, \"regression\": 0, \"roi_backlog\": 0, \"mean_pct\": 0}\n}\n"
    try {
        write_file(out_path, body)
    } catch e {
        eprintln("roadmap_health_score: write FAIL " + out_path)
        return 1
    }
    println("roadmap_health_score: wrote " + out_path + " (stub)")
    return 0
}

fn main() {
    let av = argv()
    let mut args = []
    let mut i = 2
    while i < len(av) { args.push(av[i]); i = i + 1 }

    if len(args) >= 1 && args[0] == "--selftest" {
        exit(_selftest())
    }

    let mut repo = _arg_value(args, "--repo", "anima")
    if _has_flag(args, "--global") { repo = "_global" }
    let default_out = _home() + "/core/hexa-lang/state/roadmap_health_" + repo + ".json"
    let out_path = _arg_value(args, "--out", default_out)
    exit(_emit(repo, out_path))
}
