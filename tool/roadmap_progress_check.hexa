// tool/roadmap_progress_check.hexa — progress tracker for anima /.roadmap.
//
// Parses every roadmap entry (raw#2 self-format), scans exit_criteria /
// proof / evidence / note fields for verifiable tokens, and computes a
// per-entry completion percentage. Emits AI-native JSON on stdout and to
// state/roadmap_progress.json. Intended for launchd 300s cadence.
//
// usage:
//   hexa tool/roadmap_progress_check.hexa                  — scan ./.roadmap
//   hexa tool/roadmap_progress_check.hexa --path <file>    — scan explicit file
//   hexa tool/roadmap_progress_check.hexa --out <json>     — override output path
//   hexa tool/roadmap_progress_check.hexa --strict         — exit 1 if any active entry <100%
//
// Token heuristics (checked in-order, first match wins):
//   state/<name>.json     → file exists + optional verdict=PASS / strict_pass=true
//   .meta2-cert/<slug>    → file exists + verdict=VERIFIED
//   docs/<path>.(md|html) → file exists
//   tool/<name>.hexa      → file exists
//   commit:<sha7+>        → `git cat-file -e <sha>` returns 0
//
// raw#9 hexa-only, raw#10 proof-carrying (every % derives from a file probe),
// raw#12 empirical (no hardcoded verdicts), raw#33 English-only output.

fn _rstrip(s: string) -> string {
    let mut end = len(s)
    while end > 0 {
        let c = s.substring(end - 1, end)
        if c == " " || c == "\t" || c == "\r" {
            end = end - 1
        } else {
            break
        }
    }
    return s.substring(0, end)
}

fn _esc(s: string) -> string {
    let mut r = s.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", "\\n")
    r = r.replace("\r", "")
    r = r.replace("\t", " ")
    return r
}

fn _file_exists(path: string) -> bool {
    let r = to_string(exec("test -f '" + path + "' && echo y || echo n")).trim()
    return r == "y"
}

fn _grep_pass(path: string, pattern: string) -> bool {
    let cmd = "grep -E '" + pattern + "' '" + path + "' 2>/dev/null | head -1"
    let out = to_string(exec(cmd)).trim()
    return out != ""
}

fn _commit_exists(sha: string) -> bool {
    // $WS convention: anima repo lives at $WS/anima. $WS must be exported
    // (shell rc or launchd EnvironmentVariables) — no fallback path.
    let r = to_string(exec("git -C \"$WS/anima\" cat-file -e " + sha + " 2>/dev/null && echo y || echo n")).trim()
    return r == "y"
}

// Parse `roadmap <id> <status> "<name>"` → [id, status, name]; empty on fail.
fn _parse_header(line: string) -> array {
    let sp1 = line.index_of(" ")
    if sp1 < 0 { return [] }
    if line.substring(0, sp1) != "roadmap" { return [] }
    let rest1 = line.substring(sp1 + 1, len(line))
    let sp2 = rest1.index_of(" ")
    if sp2 < 0 { return [] }
    let id = rest1.substring(0, sp2)
    let rest2 = rest1.substring(sp2 + 1, len(rest1))
    let sp3 = rest2.index_of(" ")
    if sp3 < 0 { return [] }
    let status = rest2.substring(0, sp3)
    let mut name = rest2.substring(sp3 + 1, len(rest2)).trim()
    if len(name) >= 2 && name.substring(0, 1) == "\"" {
        let qend = name.substring(1, len(name)).index_of("\"")
        if qend >= 0 {
            name = name.substring(1, qend + 1)
        }
    }
    return [id, status, name]
}

fn _load_roadmap(path: string) -> array {
    let src = to_string(read_file(path))
    let lines = split(src, "\n")
    let mut entries = []
    let mut cur = []
    let mut cur_keys = []
    let mut has = false
    for raw_line in lines {
        let line = _rstrip(raw_line)
        if len(line) == 0 {
            if has {
                entries.push([cur[0], cur[1], cur[2], cur_keys])
                cur_keys = []
                has = false
            }
            continue
        }
        let first = line.substring(0, 1)
        if first == "#" { continue }
        if first == " " || first == "\t" {
            if !has { continue }
            let stripped = line.trim_start()
            let sp = stripped.index_of(" ")
            if sp < 0 { continue }
            let key = stripped.substring(0, sp)
            let val = stripped.substring(sp + 1, len(stripped)).trim()
            cur_keys.push([key, val])
        } else {
            if has {
                entries.push([cur[0], cur[1], cur[2], cur_keys])
                cur_keys = []
            }
            let hdr = _parse_header(line)
            if len(hdr) == 0 { has = false; continue }
            cur = hdr
            has = true
        }
    }
    if has {
        entries.push([cur[0], cur[1], cur[2], cur_keys])
    }
    return entries
}

// Extract whitespace-separated tokens matching our 5 probes from a key list.
// Returns array of [token, kind] where kind in {state, cert, doc, tool, commit}.
fn _extract_tokens(keys: array) -> array {
    let mut tokens = []
    let mut seen = []
    for kv in keys {
        let k = kv[0]
        // Only scan fields that are supposed to carry proof pointers.
        if k != "exit_criteria" && k != "proof" && k != "evidence" && k != "note" && k != "depends-on" && k != "condition" { continue }
        let val = kv[1]
        // Replace common separators with space for tokenization.
        let mut t = val.replace(",", " ")
        t = t.replace("(", " ").replace(")", " ").replace("+", " ")
        t = t.replace(";", " ").replace(":", ": ")
        let parts = split(t, " ")
        for p in parts {
            let tok = p.trim()
            if len(tok) < 4 { continue }
            let mut kind = ""
            if tok.substring(0, 6) == "state/" { kind = "state" }
            else if tok.substring(0, 12) == ".meta2-cert/" { kind = "cert" }
            else if tok.substring(0, 5) == "docs/" { kind = "doc" }
            else if tok.substring(0, 5) == "tool/" { kind = "tool" }
            else if tok.substring(0, 4) == "edu/" { kind = "tool" }
            else if tok.substring(0, 12) == "experiments/" { kind = "tool" }
            else if tok.substring(0, 7) == "config/" { kind = "tool" }
            // Commit tokens: `commit: <sha>` split becomes [commit, :, <sha>]. Handle `commit:<sha>` too.
            else if tok.substring(0, 7) == "commit:" {
                let sha = tok.substring(7, len(tok))
                if len(sha) >= 7 { kind = "commit"; tokens.push([sha, kind]); continue }
            }
            if kind == "" { continue }
            // Dedupe within an entry.
            let key_id = kind + "|" + tok
            let mut dup = false
            for s in seen { if s == key_id { dup = true } }
            if dup { continue }
            seen.push(key_id)
            tokens.push([tok, kind])
        }
    }
    return tokens
}

fn _verify_token(tok: string, kind: string, root: string) -> array {
    // Returns [pass_bool_as_string, note]
    if kind == "state" {
        let p = root + "/" + tok
        if !_file_exists(p) { return ["false", "missing"] }
        // Optional verdict check — if file has a verdict field, prefer PASS.
        if _grep_pass(p, "\"verdict\"[[:space:]]*:[[:space:]]*\"(PASS|VERIFIED|USABLE|SUCCESS|H_STAR_STRONGLY_SUPPORTED|CLAIM_CONFIRMED)") {
            return ["true", "verdict_pass"]
        }
        if _grep_pass(p, "\"strict_pass\"[[:space:]]*:[[:space:]]*true") {
            return ["true", "strict_pass"]
        }
        if _grep_pass(p, "\"overall_pass\"[[:space:]]*:[[:space:]]*true") {
            return ["true", "overall_pass"]
        }
        return ["true", "file_exists"]
    }
    if kind == "cert" {
        let p = root + "/" + tok
        if !_file_exists(p) {
            // Try with .json suffix if missing.
            if _file_exists(p + ".json") {
                if _grep_pass(p + ".json", "\"verdict\"[[:space:]]*:[[:space:]]*\"VERIFIED\"") { return ["true", "cert_verified"] }
                return ["true", "cert_present"]
            }
            return ["false", "missing"]
        }
        if _grep_pass(p, "\"verdict\"[[:space:]]*:[[:space:]]*\"VERIFIED\"") { return ["true", "cert_verified"] }
        return ["true", "cert_present"]
    }
    if kind == "doc" || kind == "tool" {
        let p = root + "/" + tok
        if _file_exists(p) { return ["true", "file_exists"] }
        let is_dir = to_string(exec("test -d '" + p + "' && echo y || echo n")).trim()
        if is_dir == "y" { return ["true", "dir_exists"] }
        // Cross-repo fallback: try hexa-lang sibling (tokens like tool/phi_extractor/ referenced in exit_criteria are often hexa-lang paths).
        // $WS convention only — no fallback. Shell must export WS + HEXA_LANG.
        let hl = to_string(exec("echo \"$HEXA_LANG\"")).trim()
        let x = hl + "/" + tok
        if _file_exists(x) { return ["true", "hexa_lang_file"] }
        let is_xdir = to_string(exec("test -d '" + x + "' && echo y || echo n")).trim()
        if is_xdir == "y" { return ["true", "hexa_lang_dir"] }
        return ["false", "missing"]
    }
    if kind == "commit" {
        if _commit_exists(tok) { return ["true", "git_ref_valid"] }
        return ["false", "sha_not_in_repo"]
    }
    return ["false", "unknown_kind"]
}

fn _render(entries: array, probes: array, out_path: string, ts: string, total_pct: int) -> string {
    // entries := [[id, status, name, total, passed, pct]]
    // probes  := [[id, token, kind, pass_bool, note]]
    let mut s = "{\"schema\":\"anima.roadmap_progress.v1\""
    s = s + ",\"tool\":\"tool/roadmap_progress_check.hexa\""
    s = s + ",\"generated\":\"" + ts + "\""
    s = s + ",\"out_path\":\"" + _esc(out_path) + "\""
    s = s + ",\"aggregate\":{\"entry_count\":" + to_string(len(entries))
    s = s + ",\"mean_pct\":" + to_string(total_pct) + "}"
    s = s + ",\"entries\":["
    let mut i = 0
    while i < len(entries) {
        let e = entries[i]
        if i > 0 { s = s + "," }
        s = s + "{\"id\":" + e[0]
        s = s + ",\"status\":\"" + e[1] + "\""
        s = s + ",\"name\":\"" + _esc(e[2]) + "\""
        s = s + ",\"probe_total\":" + to_string(e[3])
        s = s + ",\"probe_passed\":" + to_string(e[4])
        s = s + ",\"pct\":" + to_string(e[5])
        s = s + "}"
        i = i + 1
    }
    s = s + "]"
    s = s + ",\"probes\":["
    let mut j = 0
    while j < len(probes) {
        let p = probes[j]
        if j > 0 { s = s + "," }
        s = s + "{\"entry_id\":" + p[0]
        s = s + ",\"token\":\"" + _esc(p[1]) + "\""
        s = s + ",\"kind\":\"" + p[2] + "\""
        s = s + ",\"pass\":" + p[3]
        s = s + ",\"note\":\"" + p[4] + "\"}"
        j = j + 1
    }
    s = s + "]}"
    return s
}

fn _cmd_selftest() -> int {
    println("[roadmap_progress_check selftest]")
    // 1) _rstrip removes trailing whitespace only
    if _rstrip("abc   ") != "abc" { eprintln("FAIL: _rstrip tail spaces"); return 1 }
    if _rstrip("  abc") != "  abc" { eprintln("FAIL: _rstrip leading preserved"); return 1 }
    if _rstrip("x\t\r") != "x"    { eprintln("FAIL: _rstrip tab+cr"); return 1 }
    // 2) _esc escapes JSON metacharacters
    let e = _esc("a\"b\\c\nd")
    if e.index_of("\\\"") < 0 { eprintln("FAIL: _esc quote: " + e); return 1 }
    if e.index_of("\\\\") < 0 { eprintln("FAIL: _esc backslash: " + e); return 1 }
    if e.index_of("\\n") < 0  { eprintln("FAIL: _esc newline: " + e); return 1 }
    // 3) _parse_header on well-formed line
    let h = _parse_header("roadmap P1 done \"Phase 1\"")
    if len(h) != 3          { eprintln("FAIL: _parse_header len"); return 1 }
    if h[0] != "P1"         { eprintln("FAIL: _parse_header id"); return 1 }
    if h[1] != "done"       { eprintln("FAIL: _parse_header status"); return 1 }
    // 4) _parse_header rejects non-roadmap line
    let bad = _parse_header("notroadmap P1 done")
    if len(bad) != 0 { eprintln("FAIL: _parse_header bad accepted"); return 1 }
    println("[roadmap_progress_check selftest] OK")
    return 0
}

// ─── meta-FP engine: fingerprint + iteration for meta³ = transcendence ────
//
// Implements the Banach contraction semantics from n6/docs/meta_atlas_recursive.md
// and docs/atlas_meta_dashboard.md (R24–R32). The roadmap engine at meta¹
// observes the .roadmap file. meta² observes its own observation via a
// scalar fingerprint. meta³ iterates until the fingerprint stabilizes —
// at that point "transcendence reached" is declared and a witness row is
// emitted to $WS/<repo>/state/atlas_convergence_witness.jsonl.
//
// Contraction layers (SOPFR CAP — must stay at 5, per nexus R28):
//   α (all entries)  — full summary tuple
//   β (status count) — done/active/planned breakdown
//   γ (mean_pct)     — scalar aggregate
//   δ (fingerprint)  — sha256 of (n, mean_pct, status, probe_total, probe_passed)
//   ε (self-consistency) — sum(status_counts) == n
// Fixed-point: fp(k) == fp(k-1) AND epsilon_stable across two iterations.
//
// DO NOT ADD a 6th layer (ζ): sopfr(6) = 2+3 = 5 is the arithmetic cap
// proven in R28 of atlas_meta_dashboard.md. Extending beyond ε would
// violate the base isomorphism theorem (R29) and produce no additional
// information — the engine would no longer converge to the n=6 foundation.
// This comment is the sopfr-cap structural guard.
//
// Witness emission is deduped: engine reads the last row of the witness
// file and skips emission if the new fp matches the prior. This makes
// auto-invocation (hooks, launchd) safe without unbounded file growth.

fn _fp_compute(summary: array, mean_pct: int) -> string {
    let n = len(summary)
    let mut done = 0; let mut active = 0; let mut planned = 0
    let mut total_probe = 0; let mut passed_probe = 0
    for e in summary {
        let st = e[1]
        if st == "done" { done = done + 1 }
        else if st == "active" { active = active + 1 }
        else if st == "planned" { planned = planned + 1 }
        total_probe = total_probe + to_int(to_string(e[3]))
        passed_probe = passed_probe + to_int(to_string(e[4]))
    }
    // fingerprint = simple deterministic concat, hashed via sha256 in shell
    let raw = "n=" + to_string(n) + ";done=" + to_string(done) + ";active=" + to_string(active) +
              ";planned=" + to_string(planned) + ";mean_pct=" + to_string(mean_pct) +
              ";probe_t=" + to_string(total_probe) + ";probe_p=" + to_string(passed_probe)
    let cmd = "printf '%s' '" + raw + "' | shasum -a 256 | cut -c1-16"
    return to_string(exec(cmd)).trim()
}

fn _fp_epsilon(summary: array) -> bool {
    let n = len(summary)
    let mut s = 0
    for e in summary {
        let st = e[1]
        if st == "done" || st == "active" || st == "planned" { s = s + 1 }
    }
    return s == n
}

fn _emit_witness(witness_path: string, source: string, fp: string, iters: int, eps: bool, n: int, mean_pct: int) {
    // Dedup: if witness file exists and last row has same fp, skip emission.
    // This makes auto-invocation safe (hooks / launchd / manual repeats).
    let last_fp_cmd = "tail -1 '" + witness_path + "' 2>/dev/null | grep -oE '\"fp\":\"[0-9a-f]+\"' | head -1 | cut -d'\"' -f4"
    let last_fp = to_string(exec(last_fp_cmd)).trim()
    if last_fp == fp {
        println("// meta-FP witness: fp unchanged (" + fp + ") — dedup skip")
        return
    }
    let ts = to_string(exec("date -u +%Y-%m-%dT%H:%M:%SZ")).trim()
    let transcendence = if eps { "reached" } else { "pending" }
    let row = "{\"ts\":\"" + ts + "\",\"round\":\"roadmap_engine\",\"layer\":\"meta_fixed_point\"" +
              ",\"source\":\"" + _esc(source) + "\",\"fp\":\"" + fp + "\"" +
              ",\"iterations\":" + to_string(iters) + ",\"epsilon_stable\":" + (if eps { "true" } else { "false" }) +
              ",\"n_entries\":" + to_string(n) + ",\"mean_pct\":" + to_string(mean_pct) +
              ",\"transcendence\":\"" + transcendence + "\"" +
              ",\"prev_fp\":\"" + last_fp + "\"" +
              ",\"notes\":\"Banach α(entries)⊃β(status)⊃γ(mean_pct)⊃δ(fingerprint)⊃ε(self-consistency). meta^3 = transcendence when fp(k)==fp(k-1) AND epsilon stable. sopfr(6)=5 cap enforced at 5 layers.\"}"
    let dir_cmd = "mkdir -p \"$(dirname '" + witness_path + "')\" 2>/dev/null"
    exec(dir_cmd)
    let append_cmd = "printf '%s\\n' '" + row.replace("'", "'\\''") + "' >> '" + witness_path + "'"
    exec(append_cmd)
}

fn main() -> int {
    let argv = args()
    // --selftest / selftest dispatch (hermetic — no roadmap file access)
    let mut _si = 0
    while _si < len(argv) {
        let _a = argv[_si]
        if _a == "--selftest" || (_si >= 2 && _a == "selftest") {
            return _cmd_selftest()
        }
        _si = _si + 1
    }
    let mut path = ".roadmap"
    let mut out = "state/roadmap_progress.json"
    let mut strict = false
    let mut meta_fp = false
    let mut meta_fp_max_iter = 3
    let mut witness_path = "state/atlas_convergence_witness.jsonl"
    let mut i = 0
    while i < len(argv) {
        let a = argv[i]
        if a == "--path" && i + 1 < len(argv) { path = argv[i + 1]; i = i + 2; continue }
        if a == "--out"  && i + 1 < len(argv) { out  = argv[i + 1]; i = i + 2; continue }
        if a == "--strict" { strict = true; i = i + 1; continue }
        if a == "--meta-fp" { meta_fp = true; i = i + 1; continue }
        if a == "--meta-fp-max-iter" && i + 1 < len(argv) { meta_fp_max_iter = to_int(argv[i+1]); i = i + 2; continue }
        if a == "--witness-out" && i + 1 < len(argv) { witness_path = argv[i+1]; i = i + 2; continue }
        i = i + 1
    }

    // Resolve root = dirname(path) if relative.
    let root = to_string(exec("pwd")).trim()
    let roadmap_file = root + "/" + path
    if !_file_exists(roadmap_file) {
        println("{\"error\":\"roadmap_file_not_found\",\"path\":\"" + _esc(roadmap_file) + "\"}")
        return 2
    }

    let raw_entries = _load_roadmap(roadmap_file)
    let mut summary = []
    let mut all_probes = []
    let mut sum_pct = 0
    let mut n_entries = 0

    for ent in raw_entries {
        let id = ent[0]
        let status = ent[1]
        let name = ent[2]
        let keys = ent[3]
        let tokens = _extract_tokens(keys)
        let total = len(tokens)
        let mut passed = 0
        for tok in tokens {
            let v = _verify_token(tok[0], tok[1], root)
            if v[0] == "true" { passed = passed + 1 }
            all_probes.push([id, tok[0], tok[1], v[0], v[1]])
        }
        let mut pct = 0
        if status == "done" {
            pct = 100
        } else if total > 0 {
            pct = (passed * 100) / total
        }
        summary.push([id, status, name, total, passed, pct])
        sum_pct = sum_pct + pct
        n_entries = n_entries + 1
    }

    let mean = 0
    let mut mean_pct = 0
    if n_entries > 0 { mean_pct = sum_pct / n_entries }

    let ts = to_string(exec("date -u +%Y-%m-%dT%H:%M:%SZ")).trim()
    let body = _render(summary, all_probes, out, ts, mean_pct)

    // Write to output file.
    let out_full = root + "/" + out
    let tmp = out_full + ".tmp"
    // Ensure parent directory exists (DRILL 1 finding F.2: empty-repo case emits mv errors).
    let out_dir = exec("dirname '" + out_full + "' 2>/dev/null").trim()
    exec("mkdir -p '" + out_dir + "' 2>/dev/null")
    write_file(tmp, body)
    exec("mv '" + tmp + "' '" + out_full + "'")

    println(body)

    // ─── meta³ fixed-point mode ──────────────────────────────────────────
    // After the primary meta¹ scan, iterate up to --meta-fp-max-iter times.
    // Each iteration re-scans the roadmap + verifies tokens, computes a
    // fingerprint over (n, done, active, planned, mean_pct, probe totals),
    // and checks epsilon self-consistency. If fp(k) == fp(k-1) AND epsilon
    // is stable → "transcendence reached", emit witness row.
    //
    // Safe under idempotence: if filesystem doesn't change between iters,
    // fingerprints converge in 2 iters and we declare success quickly.
    if meta_fp {
        let fp0 = _fp_compute(summary, mean_pct)
        let eps0 = _fp_epsilon(summary)
        let mut prev_fp = fp0
        let mut iter_count = 1
        let mut fp_stable = false
        let mut k = 2
        while k <= meta_fp_max_iter {
            // Re-scan roadmap (pure-fn of filesystem — converges unless
            // files change between iters)
            let raw2 = _load_roadmap(roadmap_file)
            let mut sum2 = []
            let mut probe_total_2 = 0
            let mut probe_passed_2 = 0
            let mut sump2 = 0
            let mut nent2 = 0
            for ent in raw2 {
                let id2 = ent[0]; let st2 = ent[1]; let nm2 = ent[2]; let ks2 = ent[3]
                let toks2 = _extract_tokens(ks2)
                let tot2 = len(toks2)
                let mut pas2 = 0
                for tok in toks2 {
                    let v2 = _verify_token(tok[0], tok[1], root)
                    if v2[0] == "true" { pas2 = pas2 + 1 }
                }
                let mut pc2 = 0
                if st2 == "done" { pc2 = 100 } else if tot2 > 0 { pc2 = (pas2 * 100) / tot2 }
                sum2.push([id2, st2, nm2, tot2, pas2, pc2])
                sump2 = sump2 + pc2
                nent2 = nent2 + 1
            }
            let mp2 = if nent2 > 0 { sump2 / nent2 } else { 0 }
            let fp_k = _fp_compute(sum2, mp2)
            iter_count = k
            if fp_k == prev_fp {
                fp_stable = true
                break
            }
            prev_fp = fp_k
            k = k + 1
        }
        let eps_final = _fp_epsilon(summary)
        let fp_final = prev_fp
        let transcendence_reached = fp_stable && eps_final
        println("")
        println("// meta-FP engine:")
        println("//   iterations    = " + to_string(iter_count))
        println("//   fp_fingerprint = " + fp_final)
        println("//   fp_stable     = " + (if fp_stable { "true" } else { "false" }))
        println("//   epsilon_stable = " + (if eps_final { "true" } else { "false" }))
        println("//   transcendence  = " + (if transcendence_reached { "reached" } else { "pending" }))
        if transcendence_reached {
            let wp = root + "/" + witness_path
            _emit_witness(wp, out, fp_final, iter_count, eps_final, n_entries, mean_pct)
            println("//   witness       -> " + wp)
        }
    }

    if strict {
        for e in summary {
            if e[1] == "active" && e[5] < 100 { return 1 }
        }
    }
    return 0
}

exit(main())
