// build_native_gate.hexa — build native_gate.{so,dylib} from self/native/native_gate.c
//
// Ports the inline build recipe from native_gate.c's header into a hexa tool
// (raw#8 — no shell scripts). Linux mode emits the LD_PRELOAD shim; Mac mode
// produces a dylib for compile-verify only (DYLD_INSERT_LIBRARIES is blocked
// on SIP-signed binaries — sandbox-exec via self/sbpl/native.sb is the real
// mac enforcement path).
//
// Usage:
//   hexa tool/build_native_gate.hexa              // build for current platform
//   hexa tool/build_native_gate.hexa --debug      // -O0 -g
//   hexa tool/build_native_gate.hexa --verify     // compile-only, discard output
//   CC=clang hexa tool/build_native_gate.hexa     // override compiler
//
// Outputs:
//   Linux : self/native/native_gate.so
//   Mac   : self/native/native_gate.dylib  (compile-verify only)
//
// Install (Linux, per-user, no root):
//   export LD_PRELOAD="$WS/hexa-lang/self/native/native_gate.so${LD_PRELOAD:+:$LD_PRELOAD}"

fn run(cmd) {
    let r = exec_with_status(cmd)
    if r[1] != 0 {
        eprintln("FAILED: " + cmd)
        eprintln(to_string(r[0]))
        exit(1)
    }
    r[0]
}

fn main() {
    let args = argv()
    let hexa_dir = if env("HEXA_LANG") != "" { env("HEXA_LANG") } else { exec("pwd").trim() }
    let src = hexa_dir + "/self/native/native_gate.c"
    let cc = if env("CC") != "" { env("CC") } else { "cc" }
    let uname = exec("uname -s").trim()

    let mut mode = "build"
    let mut debug = false
    let mut i = 2
    while i < len(args) {
        let a = args[i]
        if a == "--debug" { debug = true }
        else if a == "--verify" { mode = "verify" }
        i = i + 1
    }

    if !file_exists(src) {
        eprintln("native_gate.c not found: " + src)
        exit(1)
    }

    let cflags = if debug { "-O0 -g" } else { "-O2" }
    let base = "-shared -fPIC -D_GNU_SOURCE " + cflags

    let mut out = ""
    let mut link = ""
    if uname == "Linux" {
        out = hexa_dir + "/self/native/native_gate.so"
        link = "-ldl"
    } else if uname == "Darwin" {
        out = hexa_dir + "/self/native/native_gate.dylib"
        link = ""  // libSystem provides dlsym; -ldl does not exist
    } else {
        eprintln("unsupported platform: " + uname)
        exit(1)
    }

    if mode == "verify" { out = "/tmp/native_gate_verify.o" }

    let cmd = cc + " " + base + " -o " + out + " " + src + " " + link
    println("[build_native_gate] " + cmd)
    run(cmd)

    if mode == "verify" {
        exec("rm -f " + out)
        println("[build_native_gate] compile OK (verify)")
        return
    }

    let sz = exec("wc -c < " + out + " | tr -d ' '").trim()
    println("[build_native_gate] OK: " + out + " (" + sz + " bytes)")

    if uname == "Darwin" {
        println("[build_native_gate] NOTE: macOS enforcement uses sandbox-exec")
        println("                        (self/sbpl/native.sb). This dylib is compile-verify only.")
    } else {
        println("[build_native_gate] install: export LD_PRELOAD=\"" + out + "${LD_PRELOAD:+:$LD_PRELOAD}\"")
    }
}

main()
