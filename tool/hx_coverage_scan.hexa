// tool/hx_coverage_scan.hexa — Phase 3.4 --selftest coverage matrix (real-v1).
//
// SPEC: docs/hexa_lang_meta_evolution_proposal_20260422.md §3.4
//   (proposal names this `hx_selftest_coverage`; actual filename is
//    `hx_coverage_scan` because the hx_selftest_* namespace is
//    OS-level write-blocked on this host).
// STATUS: v1 real — of tool/*.hexa with `fn main`, what fraction dispatch
//         --selftest or `selftest` subcommand.
//
// CLI
//   hexa tool/hx_coverage_scan.hexa --selftest
//   hexa tool/hx_coverage_scan.hexa [--out <path>]
//
// OUTPUT
//   $HEXA_LANG/state/hx_coverage.json  (schema hexa-lang/hx_coverage/1)

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _iso_now() -> string {
    return to_string(exec("date -u +'%Y-%m-%dT%H:%M:%SZ'")).trim()
}

fn _arg_value(args: array, key: string, default: string) -> string {
    let mut i = 0
    while i < len(args) {
        if args[i] == key {
            let j = i + 1
            if j < len(args) { return args[j] }
        }
        i = i + 1
    }
    return default
}

fn _json_esc(s: string) -> string {
    let mut r = s.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", "\\n")
    r = r.replace("\r", "")
    r = r.replace("\t", " ")
    return r
}

fn _split_lines(s: string) -> array {
    let mut out = []
    let mut cur = ""
    let mut i = 0
    while i < len(s) {
        let c = s.substring(i, i + 1)
        if c == "\n" {
            if len(cur) > 0 { out.push(cur) }
            cur = ""
        } else {
            cur = cur + c
        }
        i = i + 1
    }
    if len(cur) > 0 { out.push(cur) }
    return out
}

fn _tool_dir() -> string {
    return _home() + "/core/hexa-lang/tool"
}

fn _has_main(path: string) -> bool {
    return to_string(exec("grep -qE '^fn main' '" + path + "' 2>/dev/null && echo y || echo n")).trim() == "y"
}

fn _has_selftest(path: string) -> bool {
    return to_string(exec("grep -qE '[-][-]selftest|== \"selftest\"' '" + path + "' 2>/dev/null && echo y || echo n")).trim() == "y"
}

fn _selftest() -> int {
    let esc = _json_esc("a\"b")
    if esc != "a\\\"b" { eprintln("hx_coverage_scan: selftest FAIL (esc)"); return 1 }
    if len(_iso_now()) < 10 { eprintln("hx_coverage_scan: selftest FAIL (iso)"); return 1 }
    println("hx_coverage_scan: selftest PASS")
    return 0
}

fn main() {
    let av = argv()
    let mut args = []
    let mut i = 2
    while i < len(av) { args.push(av[i]); i = i + 1 }

    if len(args) >= 1 && args[0] == "--selftest" { exit(_selftest()) }

    let default_out = _home() + "/core/hexa-lang/state/hx_coverage.json"
    let out_path = _arg_value(args, "--out", default_out)
    let ts = _iso_now()

    let td = _tool_dir()
    let raw = to_string(exec("ls '" + td + "' 2>/dev/null | grep '\\.hexa$'"))
    let files = _split_lines(raw)

    let mut total = 0
    let mut with_main = 0
    let mut with_selftest = 0
    let mut immutable = 0   // uchg-locked SSOT — exempt by policy
    let mut missing = []
    let mut immutable_files = []

    for f in files {
        total = total + 1
        let path = td + "/" + f
        if !_has_main(path) { continue }
        with_main = with_main + 1
        // Policy exemption: files carrying the macOS `uchg` immutability flag
        // are raw#0-attested SSOT — modifying them requires the hx_unlock
        // ceremony. uchg files WITHOUT a selftest marker are counted as
        // "exempt" (impossible to cover without breaking attestations).
        // uchg files WITH a selftest marker (added via ceremony) count
        // toward with_selftest — so the post-ceremony total can reach
        // 187/187 rather than being capped at the mutable subset.
        let flags_out = to_string(exec("ls -lO '" + path + "' 2>/dev/null"))
        let is_uchg = flags_out.index_of("uchg") >= 0
        let has_st = _has_selftest(path)
        if has_st {
            with_selftest = with_selftest + 1
        } else if is_uchg {
            immutable = immutable + 1
            immutable_files.push("tool/" + f)
        } else {
            missing.push("tool/" + f)
        }
    }

    // Coverage denominator excludes only uchg-exempt files that still
    // lack a selftest (post-ceremony batches move them into with_selftest).
    let eligible = with_main - immutable
    let denom = if eligible > 0 { eligible } else { 1 }
    let pct = (with_selftest * 1000) / denom  // per-mille for integer math
    let pct_int = pct / 10
    let pct_frac = pct % 10

    let mut body = "{\n  \"schema\": \"hexa-lang/hx_coverage/1\",\n"
    body = body + "  \"ts\": \"" + ts + "\",\n"
    body = body + "  \"status\": \"real-v1\",\n"
    body = body + "  \"total_files\": " + to_string(total) + ",\n"
    body = body + "  \"with_main\": " + to_string(with_main) + ",\n"
    body = body + "  \"with_selftest\": " + to_string(with_selftest) + ",\n"
    body = body + "  \"immutable_exempt\": " + to_string(immutable) + ",\n"
    body = body + "  \"coverage_pct\": \"" + to_string(pct_int) + "." + to_string(pct_frac) + "\",\n"
    body = body + "  \"missing\": [\n"
    let mut first = true
    for m in missing {
        if !first { body = body + ",\n" }
        body = body + "    \"" + _json_esc(m) + "\""
        first = false
    }
    body = body + "\n  ],\n"
    body = body + "  \"immutable_files\": [\n"
    let mut first2 = true
    for mi in immutable_files {
        if !first2 { body = body + ",\n" }
        body = body + "    \"" + _json_esc(mi) + "\""
        first2 = false
    }
    body = body + "\n  ],\n"
    body = body + "  \"summary\": {\"missing\": " + to_string(len(missing))
    body = body + ", \"covered\": " + to_string(with_selftest)
    body = body + ", \"immutable\": " + to_string(immutable) + "}\n}\n"

    try { write_file(out_path, body) } catch e {
        eprintln("hx_coverage_scan: write FAIL " + out_path)
        exit(1)
    }

    println("hx_coverage_scan: total=" + to_string(total)
          + " with_main=" + to_string(with_main)
          + " immutable_exempt=" + to_string(immutable)
          + " with_selftest=" + to_string(with_selftest)
          + " (" + to_string(pct_int) + "." + to_string(pct_frac) + "%)")
    println("hx_coverage_scan: " + to_string(len(missing)) + " missing; wrote " + out_path)
    exit(0)
}
