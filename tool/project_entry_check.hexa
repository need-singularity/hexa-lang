// tool/project_entry_check.hexa — project-entry raw rule enforce tool.
//
// raw#<pending> (promotion via hx_unlock) — "project-entry: AI 세션은
// user 명시 지정 없이 새 project root 진입 금지. 코드 수준 + OS 수준."
//
// SSOT
//   self/sbpl/project_entry.sb     — macOS sandbox profile (kernel deny)
//   bin/project-safe-exec          — wrapper (sandbox-exec 주입)
//   self/native/project_entry.c    — Linux LD_PRELOAD (future)
//
// verify 모드: 프로파일/래퍼 존재 + 형식 sanity check.
// selftest 모드: sandbox-exec 실 기동 후 denied read 시도 → EPERM 확인.
//
// CLI
//   hexa tool/project_entry_check.hexa --selftest
//   hexa tool/project_entry_check.hexa verify
//   hexa tool/project_entry_check.hexa probe <target_repo>

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _exists(path: string) -> bool {
    let cmd = "test -e '" + path + "' && echo y || echo n"
    return to_string(exec(cmd)).trim() == "y"
}

fn _root() -> string {
    return _home() + "/core/hexa-lang"
}

fn _verify() -> int {
    let profile = _root() + "/self/sbpl/project_entry.sb"
    let wrapper = _root() + "/bin/project-safe-exec"
    let mut ok = 1
    if !_exists(profile) {
        eprintln("project_entry_check: MISSING " + profile)
        ok = 0
    }
    if !_exists(wrapper) {
        eprintln("project_entry_check: MISSING " + wrapper)
        ok = 0
    }
    if ok == 1 {
        println("project_entry_check: verify OK — profile + wrapper 존재")
        return 0
    }
    return 1
}

fn _selftest() -> int {
    // 1. artifacts 존재
    if _verify() != 0 { return 1 }

    // 2. sandbox-exec 사용 가능 여부 (macOS 만)
    let have_sbx = to_string(exec("command -v sandbox-exec >/dev/null 2>&1 && echo y || echo n")).trim()
    if have_sbx != "y" {
        println("project_entry_check: selftest SKIP — sandbox-exec 미탑재 (Linux 환경; LD_PRELOAD 경로 별도)")
        return 0
    }

    // 3. 기동 smoke — 환경에 따라 sandbox_apply 가 nested 차단될 수 있음
    //    (Claude Code 세션, 이미 sandboxed 환경 등). 그런 경우 SKIP.
    let wrapper = _root() + "/bin/project-safe-exec"
    let probe_cmd = "'" + wrapper + "' --allow hexa-lang /usr/bin/true 2>&1"
    let r = exec_with_status(probe_cmd)
    if r[1] != 0 {
        let err = to_string(r[0])
        // Nested-sandbox signals: explicit EPERM string, or SIGABRT (134) from
        // sandbox-exec refusing to install a second profile inside an already
        // sandboxed process (observed inside Claude Code sessions).
        if err.index_of("sandbox_apply: Operation not permitted") >= 0
            || err.index_of("Abort trap") >= 0
            || r[1] == 134 {
            println("project_entry_check: selftest SKIP — nested sandbox 감지 (현재 쉘이 이미 sandbox 내). artifacts 작성은 정상, 실 apply 는 non-sandboxed 환경에서 재검증 권장.")
            return 0
        }
        eprintln("project_entry_check: selftest FAIL — wrapper smoke rc=" + to_string(r[1]))
        eprintln(err)
        return 1
    }
    println("project_entry_check: selftest PASS — wrapper smoke OK")
    return 0
}

fn main() {
    let av = argv()
    let mut args = []
    let mut i = 2
    while i < len(av) { args.push(av[i]); i = i + 1 }

    if len(args) == 0 {
        exit(_verify())
    }
    let cmd = args[0]
    if cmd == "--selftest" { exit(_selftest()) }
    if cmd == "verify"     { exit(_verify()) }
    if cmd == "probe" {
        eprintln("project_entry_check probe: not yet implemented (향후 특정 repo deny 시도 + EPERM 확인)")
        exit(3)
    }
    eprintln("usage: project_entry_check [--selftest|verify|probe <repo>]")
    exit(2)
}
