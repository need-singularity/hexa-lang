// tool/_init/license_templates.hexa — LICENSE 파일 본문 템플릿
//
// 지원 SPDX ID: MIT / Apache-2.0 / MPL-2.0
// 호출: render_license(spdx_id, author, year) -> string
// 미지원 ID 는 빈 문자열 반환 (호출측에서 생성 skip).
//
// HX4 (코드는 .hexa) 준수 — 별도 .txt/.md 템플릿 파일 없이 문자열 상수만 사용.

// ─────────────────────────────────────────────────────────────
// MIT License — https://opensource.org/licenses/MIT
// ─────────────────────────────────────────────────────────────

pub fn mit_body(author: string, year: string) -> string {
    let mut parts = []
    parts.push("MIT License\n\n")
    parts.push("Copyright (c) ")
    parts.push(year)
    parts.push(" ")
    parts.push(author)
    parts.push("\n\n")
    parts.push("Permission is hereby granted, free of charge, to any person obtaining a copy\n")
    parts.push("of this software and associated documentation files (the \"Software\"), to deal\n")
    parts.push("in the Software without restriction, including without limitation the rights\n")
    parts.push("to use, copy, modify, merge, publish, distribute, sublicense, and/or sell\n")
    parts.push("copies of the Software, and to permit persons to whom the Software is\n")
    parts.push("furnished to do so, subject to the following conditions:\n\n")
    parts.push("The above copyright notice and this permission notice shall be included in all\n")
    parts.push("copies or substantial portions of the Software.\n\n")
    parts.push("THE SOFTWARE IS PROVIDED \"AS IS\", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR\n")
    parts.push("IMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY,\n")
    parts.push("FITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE\n")
    parts.push("AUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER\n")
    parts.push("LIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE, ARISING FROM,\n")
    parts.push("OUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DEALINGS IN THE\n")
    parts.push("SOFTWARE.\n")
    return parts.join("")
}

// ─────────────────────────────────────────────────────────────
// Apache License 2.0 — https://www.apache.org/licenses/LICENSE-2.0
// ─────────────────────────────────────────────────────────────

pub fn apache2_body(author: string, year: string) -> string {
    let mut parts = []
    parts.push("                                 Apache License\n")
    parts.push("                           Version 2.0, January 2004\n")
    parts.push("                        http://www.apache.org/licenses/\n\n")
    parts.push("   Copyright (c) ")
    parts.push(year)
    parts.push(" ")
    parts.push(author)
    parts.push("\n\n")
    parts.push("   Licensed under the Apache License, Version 2.0 (the \"License\");\n")
    parts.push("   you may not use this file except in compliance with the License.\n")
    parts.push("   You may obtain a copy of the License at\n\n")
    parts.push("       http://www.apache.org/licenses/LICENSE-2.0\n\n")
    parts.push("   Unless required by applicable law or agreed to in writing, software\n")
    parts.push("   distributed under the License is distributed on an \"AS IS\" BASIS,\n")
    parts.push("   WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n")
    parts.push("   See the License for the specific language governing permissions and\n")
    parts.push("   limitations under the License.\n\n")
    parts.push("   (Full license text: http://www.apache.org/licenses/LICENSE-2.0)\n")
    parts.push("   전문은 위 URL 을 참조하세요. 본 scaffold 는 요약 고지문만 포함합니다.\n")
    return parts.join("")
}

// ─────────────────────────────────────────────────────────────
// Mozilla Public License 2.0 — https://www.mozilla.org/en-US/MPL/2.0/
// ─────────────────────────────────────────────────────────────

pub fn mpl2_body(author: string, year: string) -> string {
    let mut parts = []
    parts.push("Mozilla Public License Version 2.0\n")
    parts.push("==================================\n\n")
    parts.push("Copyright (c) ")
    parts.push(year)
    parts.push(" ")
    parts.push(author)
    parts.push("\n\n")
    parts.push("This Source Code Form is subject to the terms of the Mozilla Public\n")
    parts.push("License, v. 2.0. If a copy of the MPL was not distributed with this\n")
    parts.push("file, You can obtain one at https://mozilla.org/MPL/2.0/.\n\n")
    parts.push("(Full license text: https://www.mozilla.org/en-US/MPL/2.0/)\n")
    parts.push("전문은 위 URL 을 참조하세요. 본 scaffold 는 요약 고지문만 포함합니다.\n")
    return parts.join("")
}

// ─────────────────────────────────────────────────────────────
// 공개 API — spdx_id 에 따라 본문 분기. 미지원 ID 는 "" 반환.
// ─────────────────────────────────────────────────────────────

pub fn render_license(spdx_id: string, author: string, year: string) -> string {
    if spdx_id == "MIT"        { return mit_body(author, year) }
    if spdx_id == "Apache-2.0" { return apache2_body(author, year) }
    if spdx_id == "MPL-2.0"    { return mpl2_body(author, year) }
    return ""
}

pub fn license_known(spdx_id: string) -> bool {
    if spdx_id == "MIT"        { return true }
    if spdx_id == "Apache-2.0" { return true }
    if spdx_id == "MPL-2.0"    { return true }
    return false
}
