// tool/hx_meta_telemetry.hexa — Phase 6.1 self-observing meta telemetry (real-v1).
//
// SPEC: docs/hexa_lang_meta_evolution_proposal_20260422.md §6.1.
// STATUS: v1 real — append-only JSONL events + summary rollup.
//         Automatic wrapper injection around Phase 1-3 scanners deferred
//         to v2 (requires hx_meta dispatcher integration).
//
// CLI
//   hexa tool/hx_meta_telemetry.hexa --selftest
//   hexa tool/hx_meta_telemetry.hexa record --scanner <name>
//                                           --runtime-ms N
//                                           --candidates N --rc N
//   hexa tool/hx_meta_telemetry.hexa summary [--out <path>]
//
// OUTPUT
//   $HEXA_LANG/state/hx_meta_telemetry.jsonl         (append-only events)
//   $HEXA_LANG/state/hx_meta_telemetry_summary.json  (rollup)
//   schema = "hexa-lang/hx_meta_telemetry/1"

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _iso_now() -> string {
    return to_string(exec("date -u +'%Y-%m-%dT%H:%M:%SZ'")).trim()
}

fn _arg_value(args: array, key: string, default: string) -> string {
    let mut i = 0
    while i < len(args) {
        if args[i] == key {
            let j = i + 1
            if j < len(args) { return args[j] }
        }
        i = i + 1
    }
    return default
}

fn _json_esc(s: string) -> string {
    let mut r = s.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", "\\n")
    r = r.replace("\r", "")
    r = r.replace("\t", " ")
    return r
}

fn _sh_q(s: string) -> string {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _split_lines(s: string) -> array {
    let mut out = []
    let mut cur = ""
    let mut i = 0
    while i < len(s) {
        let c = s.substring(i, i + 1)
        if c == "\n" {
            if len(cur) > 0 { out.push(cur) }
            cur = ""
        } else {
            cur = cur + c
        }
        i = i + 1
    }
    if len(cur) > 0 { out.push(cur) }
    return out
}

fn _atoi(s: string) -> int {
    if s == "" { return 0 }
    return s.parse_int()
}

fn _root() -> string {
    return _home() + "/core/hexa-lang"
}

fn _jsonl_path() -> string {
    return _root() + "/state/hx_meta_telemetry.jsonl"
}

fn _index_of_str(arr: array, s: string) -> int {
    let mut i = 0
    while i < len(arr) {
        if arr[i] == s { return i }
        i = i + 1
    }
    return -1
}

fn _selftest() -> int {
    if _atoi("7") != 7 { eprintln("hx_meta_telemetry: selftest FAIL (atoi)"); return 1 }
    let esc = _json_esc("a\"b")
    if esc != "a\\\"b" { eprintln("hx_meta_telemetry: selftest FAIL (esc)"); return 1 }
    let q = _sh_q("it's")
    if q != "'it'\\''s'" { eprintln("hx_meta_telemetry: selftest FAIL (sh_q)"); return 1 }
    println("hx_meta_telemetry: selftest PASS")
    return 0
}

fn _cmd_record(args: array) -> int {
    let scanner = _arg_value(args, "--scanner", "")
    if len(scanner) == 0 {
        eprintln("hx_meta_telemetry: record requires --scanner <name>")
        return 2
    }
    let runtime_ms = _arg_value(args, "--runtime-ms", "0")
    let candidates = _arg_value(args, "--candidates", "0")
    let rc = _arg_value(args, "--rc", "0")
    let out_size = _arg_value(args, "--out-size", "0")
    let ts = _iso_now()

    let line = "{\"schema\":\"hexa-lang/hx_meta_telemetry/1\""
             + ",\"ts\":\"" + ts + "\""
             + ",\"scanner\":\"" + _json_esc(scanner) + "\""
             + ",\"runtime_ms\":" + runtime_ms
             + ",\"candidates\":" + candidates
             + ",\"rc\":" + rc
             + ",\"out_size\":" + out_size + "}"

    let path = _jsonl_path()
    // Ensure state/ exists, then use native append_file (runtime.c:5857).
    // Previously used exec("printf ... >> path") workaround — replaced
    // after discovering append_file primitive (hxa-20260422-006 resolution).
    let _ignore = exec("mkdir -p " + _sh_q(_root() + "/state"))
    try {
        append_file(path, line + "\n")
    } catch e {
        eprintln("hx_meta_telemetry: append FAIL " + path)
        return 1
    }
    println("hx_meta_telemetry: recorded " + scanner + " rt=" + runtime_ms + "ms rc=" + rc)
    return 0
}

fn _cmd_summary(args: array) -> int {
    let default_out = _root() + "/state/hx_meta_telemetry_summary.json"
    let out_path = _arg_value(args, "--out", default_out)
    let ts = _iso_now()
    let path = _jsonl_path()

    let raw = to_string(exec("cat " + _sh_q(path) + " 2>/dev/null"))
    let lines = _split_lines(raw)

    // Group by scanner. Parallel arrays: names[], counts[], runtime_sum[],
    //   candidates_sum[], fail_count[], last_ts[].
    let mut names = []
    let mut counts = []
    let mut runtime_sum = []
    let mut cand_sum = []
    let mut fail_count = []
    let mut last_ts = []

    for ln in lines {
        // crude field extraction via substring between quotes / commas
        let sc_tag = "\"scanner\":\""
        let sc_pos = ln.index_of(sc_tag)
        if sc_pos < 0 { continue }
        let after = ln.substring(sc_pos + len(sc_tag), len(ln))
        let q = after.index_of("\"")
        if q < 0 { continue }
        let scanner = after.substring(0, q)

        let ts_tag = "\"ts\":\""
        let ts_pos = ln.index_of(ts_tag)
        let mut this_ts = ""
        if ts_pos >= 0 {
            let t_after = ln.substring(ts_pos + len(ts_tag), len(ln))
            let t_q = t_after.index_of("\"")
            if t_q >= 0 { this_ts = t_after.substring(0, t_q) }
        }

        let rt_tag = "\"runtime_ms\":"
        let rt_pos = ln.index_of(rt_tag)
        let mut rt = 0
        if rt_pos >= 0 {
            let r_after = ln.substring(rt_pos + len(rt_tag), len(ln))
            let comma = r_after.index_of(",")
            let brace = r_after.index_of("}")
            let end = if comma >= 0 && (brace < 0 || comma < brace) { comma } else { brace }
            if end >= 0 { rt = _atoi(r_after.substring(0, end)) }
        }

        let cd_tag = "\"candidates\":"
        let cd_pos = ln.index_of(cd_tag)
        let mut cd = 0
        if cd_pos >= 0 {
            let c_after = ln.substring(cd_pos + len(cd_tag), len(ln))
            let comma = c_after.index_of(",")
            let brace = c_after.index_of("}")
            let end = if comma >= 0 && (brace < 0 || comma < brace) { comma } else { brace }
            if end >= 0 { cd = _atoi(c_after.substring(0, end)) }
        }

        let rc_tag = "\"rc\":"
        let rc_pos = ln.index_of(rc_tag)
        let mut rc = 0
        if rc_pos >= 0 {
            let rc_after = ln.substring(rc_pos + len(rc_tag), len(ln))
            let comma = rc_after.index_of(",")
            let brace = rc_after.index_of("}")
            let end = if comma >= 0 && (brace < 0 || comma < brace) { comma } else { brace }
            if end >= 0 { rc = _atoi(rc_after.substring(0, end)) }
        }

        let idx = _index_of_str(names, scanner)
        if idx < 0 {
            names.push(scanner)
            counts.push(1)
            runtime_sum.push(rt)
            cand_sum.push(cd)
            fail_count.push(if rc == 0 { 0 } else { 1 })
            last_ts.push(this_ts)
        } else {
            counts[idx] = counts[idx] + 1
            runtime_sum[idx] = runtime_sum[idx] + rt
            cand_sum[idx] = cand_sum[idx] + cd
            if rc != 0 { fail_count[idx] = fail_count[idx] + 1 }
            if this_ts > last_ts[idx] { last_ts[idx] = this_ts }
        }
    }

    let mut body = "{\n  \"schema\": \"hexa-lang/hx_meta_telemetry/1\",\n"
    body = body + "  \"ts\": \"" + ts + "\",\n"
    body = body + "  \"status\": \"real-v1\",\n"
    body = body + "  \"event_count\": " + to_string(len(lines)) + ",\n"
    body = body + "  \"scanners\": [\n"
    let mut first = true
    let mut total_rt = 0
    let mut j = 0
    while j < len(names) {
        let n = counts[j]
        let avg = if n > 0 { runtime_sum[j] / n } else { 0 }
        total_rt = total_rt + runtime_sum[j]
        let entry = "{\"name\":\"" + _json_esc(names[j])
            + "\",\"count\":" + to_string(n)
            + ",\"avg_runtime_ms\":" + to_string(avg)
            + ",\"candidates_sum\":" + to_string(cand_sum[j])
            + ",\"fail_count\":" + to_string(fail_count[j])
            + ",\"last_ts\":\"" + _json_esc(last_ts[j]) + "\"}"
        if !first { body = body + ",\n" }
        body = body + "    " + entry
        first = false
        j = j + 1
    }
    body = body + "\n  ],\n"
    body = body + "  \"summary\": {\"distinct_scanners\": " + to_string(len(names))
    body = body + ", \"total_invocations\": " + to_string(len(lines))
    body = body + ", \"total_runtime_ms\": " + to_string(total_rt) + "}\n}\n"

    try { write_file(out_path, body) } catch e {
        eprintln("hx_meta_telemetry: write FAIL " + out_path)
        return 1
    }

    println("hx_meta_telemetry: " + to_string(len(lines)) + " events, "
          + to_string(len(names)) + " distinct scanners")
    println("hx_meta_telemetry: wrote " + out_path)
    return 0
}

fn main() {
    let av = argv()
    let mut args = []
    let mut i = 2
    while i < len(av) { args.push(av[i]); i = i + 1 }

    if len(args) >= 1 && args[0] == "--selftest" { exit(_selftest()) }
    if len(args) >= 1 && args[0] == "record" {
        let mut rest = []
        let mut k = 1
        while k < len(args) { rest.push(args[k]); k = k + 1 }
        exit(_cmd_record(rest))
    }
    if len(args) >= 1 && args[0] == "summary" {
        let mut rest = []
        let mut k = 1
        while k < len(args) { rest.push(args[k]); k = k + 1 }
        exit(_cmd_summary(rest))
    }
    // default: summary
    exit(_cmd_summary(args))
}
