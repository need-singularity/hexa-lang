#!/bin/bash
# tool/jit/run_selftest.sh — F-JIT selftest entry (Mac-local, no docker landing)
#
# The hexa AOT cache fast-path can be routed to a Linux Docker landing on
# this Darwin host (raw 44 hard-landing policy). The JIT pipeline is
# inherently mac-local — `cc -O2 -dynamiclib` on macOS produces a
# Mach-O .dylib that won't load inside the Linux container. This wrapper
# sets HEXA_LOCAL_NO_CAP=1 / HEXA_RESOLVER_NO_REROUTE=1 so all nested
# hexa calls stay on the Darwin host.

set -e
cd "$(dirname "$0")/../.."

export HEXA_LOCAL_NO_CAP=1
export HEXA_RESOLVER_NO_REROUTE=1

exec ./hexa.real run tool/jit_selftest.hexa "$@"
