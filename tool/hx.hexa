#!hexa strict
// tool/hx.hexa — SSOT unified entry point (raw#0 top-level wrapper)
//
// PURPOSE
//   Single developer-facing CLI that replaces bare `git` for the raw#0
//   SSOT workflow. Dispatches to raw_all, hx_unlock, hx_lock, git, and
//   raw_audit in the right order so every state transition is audited
//   and every commit/push carries a raw-all attestation trailer.
//
//   The philosophy: `git commit` and `git push` are dangerous because
//   they have no idea whether .raw / .own / .ext / .roadmap / .loop
//   are still consistent. `./hx commit` and `./hx push` refuse unless
//   raw_all exits 0, stamp the pre-push SSOT fingerprint into the
//   commit message, and append an audit line.
//
// USAGE
//   ./hx commit   -m "msg"          run raw_all → git commit → audit
//   ./hx push     [branch]          run raw_all → git push → audit
//   ./hx edit     <file>            hx_unlock → $EDITOR <file> → hx_lock
//   ./hx unlock   --reason "..."    delegate to tool/hx_unlock.hexa
//   ./hx lock                       delegate to tool/hx_lock.hexa
//   ./hx status                     chflags status + last audit + raw_all summary
//   ./hx verify                     raw_all --fast
//   ./hx init                       first-time install (delegate hx_init)
//   ./hx harden                     Level 1 → Level 2 promote (hx_harden)
//   ./hx downgrade                  Level 2 → Level 1 demote (hx_downgrade)
//   ./hx fixpoint <sub> [args...]   fixpoint verify/archive/bisect/check/promote
//   ./hx chain    <sub> [args...]   forward-chain run/status/list/reset (OS-level)
//   ./hx install  <target>          install external CLI as ~/.hx/bin shim (own#5)
//   ./hx update   [<name>]          refresh shim(s); git pull cloned pkgs
//   ./hx search / list / info / remove / where / orgs      pkg queries
//   ./hx help                       print usage
//
// FLOW (commit)
//   1. raw_all (full) → refuse on FAIL
//   2. sha_before = ssot_fingerprint()
//   3. augment -m message with HMAC-signed attestation trailer via
//      tool/raw_attestation.hexa (format matches .github/workflows/
//      raw-verify.yml verifier):
//        "\n\nraw-all-attest: raw-all-attest:v1:<sha>:<ts>:<hmac>"
//   4. git commit -m "<augmented>"
//   5. sha_after = ssot_fingerprint()   (may equal sha_before)
//   6. audit_append("commit", user, msg, "ok"|"fail", sha_before, sha_after)
//
// FLOW (push)
//   1. raw_all (full) → refuse on FAIL
//   2. collect to-be-pushed commits via `git log @{u}..HEAD --format=%H`
//   3. each commit: verify body contains "raw-all-attest: " trailer; warn if absent
//   4. git push origin <branch>
//   5. audit_append("push", user, "<N commits to <branch>>", result, -, -)
//
// FLOW (edit)
//   1. tool/hx_unlock.hexa --reason "edit <file>"
//   2. exec $EDITOR <file>   (fallback: vi)
//   3. tool/hx_lock.hexa
//
// EXIT CODES
//   0   — success
//   1   — subcommand failed (raw_all, git, editor non-zero)
//   2   — invocation error (bad args, missing flags)

use "self/stdlib/law_io"
use "tool/raw_audit"
// ─── env helpers ─────────────────────────────────────────────────

fn _current_user() -> string {
    let u = env("USER")
    if u != "" { return u }
    return to_string(exec("id -un")).trim()
}

fn _is_darwin() -> bool {
    let uname = to_string(exec("uname -s")).trim()
    return uname == "Darwin"
}

fn _iso_utc_now() -> string {
    return to_string(exec("date -u +\"%Y-%m-%dT%H:%M:%SZ\"")).trim()
}

fn _shell_quote(s: string) -> string {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _interp() -> string { return "./build/hexa_interp" }

fn _interp_ok() -> bool {
    let r = exec_with_status("test -x " + _interp())
    return r[1] == 0
}

// ─── raw_all gate ────────────────────────────────────────────────

fn _run_raw_all(fast: bool) -> int {
    // Echoes full raw_all output so developer sees what failed. Returns
    // raw_all's exit code verbatim (0 = PASS, 1 = FAIL, 2 = bad args).
    if !_interp_ok() {
        eprintln("hx: " + _interp() + " not executable — cannot run raw_all gate")
        return 1
    }
    let mut suffix = ""
    if fast { suffix = " --fast" }
    let r = exec_with_status(_interp() + " tool/raw_all.hexa" + suffix + " 2>&1")
    print(to_string(r[0]))
    return r[1]
}

// ─── git helpers ─────────────────────────────────────────────────

fn _git_current_branch() -> string {
    return to_string(exec("git rev-parse --abbrev-ref HEAD 2>/dev/null")).trim()
}

fn _git_has_upstream() -> bool {
    let r = to_string(exec("git rev-parse --abbrev-ref --symbolic-full-name @{u} 2>/dev/null")).trim()
    return r != ""
}

// ─── subcommand: commit ──────────────────────────────────────────

fn _cmd_commit(args: array) -> int {
    // expect -m "<msg>" (only form supported; other git commit flags
    // are intentionally not forwarded to keep the audit surface small)
    let mut msg = ""
    let mut i = 0
    while i < len(args) {
        let a = args[i]
        if a == "-m" || a == "--message" {
            if i + 1 < len(args) { msg = args[i + 1]; i = i + 1 }
        }
        i = i + 1
    }
    if msg == "" {
        eprintln("hx commit: -m \"<message>\" is required")
        return 2
    }

    // 1. gate
    println("── hx commit: gate raw_all ──")
    let rc = _run_raw_all(false)
    if rc != 0 {
        eprintln("")
        eprintln("hx commit: refused — raw_all exit=" + to_string(rc))
        let actor = _current_user()
        let sha = ssot_fingerprint()
        audit_append("commit", actor, msg, "blocked (raw_all " + to_string(rc) + ")", sha, "-")
        return 1
    }

    // 2. fingerprint + HMAC-signed attestation trailer
    // Delegate trailer construction to tool/raw_attestation.hexa so the
    // emitted format stays in lock-step with .github/workflows/raw-verify.yml
    // verifier (raw-all-attest:v1:<sha>:<ts>:<hmac>). Emitting the old
    // short-form here would pass the local gate but silently fail CI.
    let sha_before = ssot_fingerprint()
    let ts = _iso_utc_now()
    let tr_cmd = _interp() + " tool/raw_attestation.hexa trailer "
               + _shell_quote(msg) + " 2>&1"
    let tr = exec_with_status(tr_cmd)
    if tr[1] != 0 {
        eprintln("hx commit: raw_attestation trailer failed exit="
                 + to_string(tr[1]))
        eprintln(to_string(tr[0]))
        let actor2 = _current_user()
        audit_append("commit", actor2, msg,
                     "blocked (attestation " + to_string(tr[1]) + ")",
                     sha_before, "-")
        return 1
    }
    let full_msg = to_string(tr[0]).trim()

    // 3. git commit
    println("")
    println("── hx commit: git commit ──")
    let r = exec_with_status("git commit -m " + _shell_quote(full_msg) + " 2>&1")
    print(to_string(r[0]))
    let grc = r[1]

    // 4. audit
    let sha_after = ssot_fingerprint()
    let actor = _current_user()
    if grc != 0 {
        audit_append("commit", actor, msg, "fail (git " + to_string(grc) + ")", sha_before, sha_after)
        eprintln("")
        eprintln("hx commit: git commit exit=" + to_string(grc))
        return 1
    }
    audit_append("commit", actor, msg, "ok", sha_before, sha_after)

    println("")
    println("── OK ──")
    println("raw-all-attest: signed trailer embedded (sha=" + sha_before
            + " ts=" + ts + ")")
    return 0
}

// ─── subcommand: push ────────────────────────────────────────────

fn _cmd_push(args: array) -> int {
    let mut branch = ""
    if len(args) > 0 { branch = args[0] }
    if branch == "" { branch = _git_current_branch() }
    if branch == "" {
        eprintln("hx push: could not determine current branch")
        return 2
    }

    // 1. gate
    println("── hx push: gate raw_all ──")
    let rc = _run_raw_all(false)
    if rc != 0 {
        eprintln("")
        eprintln("hx push: refused — raw_all exit=" + to_string(rc))
        let actor = _current_user()
        audit_append("push", actor, "branch=" + branch, "blocked (raw_all " + to_string(rc) + ")", "-", "-")
        return 1
    }

    // 2. collect to-be-pushed commits
    let mut commit_count = 0
    let mut missing_trailer = 0
    if _git_has_upstream() {
        let shas = to_string(exec("git log @{u}..HEAD --format=%H 2>/dev/null"))
        let lines = split(shas, "\n")
        for ln in lines {
            let h = ln.trim()
            if h == "" { continue }
            commit_count = commit_count + 1
            // 3. check each for raw-all-attest trailer (HMAC-signed,
            //    matches CI verifier format)
            let body = to_string(exec("git log -1 --format=%B " + h + " 2>/dev/null"))
            if body.index_of("raw-all-attest: ") < 0 {
                eprintln("hx push: WARN — commit " + h.substring(0, 12)
                         + " missing raw-all-attest trailer")
                missing_trailer = missing_trailer + 1
            }
        }
    } else {
        eprintln("hx push: WARN — branch '" + branch + "' has no upstream; cannot diff against remote")
    }

    // 4. git push
    println("")
    println("── hx push: git push origin " + branch + " ──")
    let r = exec_with_status("git push origin " + _shell_quote(branch) + " 2>&1")
    print(to_string(r[0]))
    let grc = r[1]

    // 5. audit
    let actor = _current_user()
    let mut reason = "branch=" + branch + " commits=" + to_string(commit_count)
    if missing_trailer > 0 { reason = reason + " missing_trailer=" + to_string(missing_trailer) }
    if grc != 0 {
        audit_append("push", actor, reason, "fail (git " + to_string(grc) + ")", "-", "-")
        eprintln("")
        eprintln("hx push: git push exit=" + to_string(grc))
        return 1
    }
    audit_append("push", actor, reason, "ok", "-", "-")

    println("")
    println("── OK ──")
    println("pushed " + to_string(commit_count) + " commit(s) to origin/" + branch)
    if missing_trailer > 0 {
        println("(warn: " + to_string(missing_trailer) + " commit(s) had no raw-all trailer)")
    }
    return 0
}

// ─── subcommand: edit ────────────────────────────────────────────

fn _cmd_edit(args: array) -> int {
    if len(args) < 1 {
        eprintln("hx edit: <file> argument required")
        return 2
    }
    let file = args[0]

    if !_interp_ok() {
        eprintln("hx edit: " + _interp() + " not executable — cannot run unlock gate")
        return 1
    }

    // 1. unlock
    println("── hx edit: unlock ──")
    let u = exec_with_status(_interp() + " tool/hx_unlock.hexa --reason " + _shell_quote("edit " + file) + " 2>&1")
    print(to_string(u[0]))
    if u[1] != 0 {
        eprintln("hx edit: unlock failed exit=" + to_string(u[1]))
        return 1
    }

    // 2. editor
    let mut editor = env("EDITOR")
    if editor == "" { editor = "vi" }
    println("")
    println("── hx edit: " + editor + " " + file + " ──")
    let er = exec_with_status(editor + " " + _shell_quote(file))
    let erc = er[1]
    if erc != 0 {
        eprintln("hx edit: editor exit=" + to_string(erc) + " (will still attempt lock)")
    }

    // 3. lock (always try — we don't want to leave the tree unlocked)
    println("")
    println("── hx edit: lock ──")
    let l = exec_with_status(_interp() + " tool/hx_lock.hexa 2>&1")
    print(to_string(l[0]))
    if l[1] != 0 {
        eprintln("hx edit: lock failed exit=" + to_string(l[1]))
        return 1
    }

    if erc != 0 { return 1 }
    return 0
}

// ─── subcommand: unlock / lock (thin delegate) ───────────────────

fn _cmd_unlock(args: array) -> int {
    if !_interp_ok() {
        eprintln("hx unlock: " + _interp() + " not executable")
        return 1
    }
    let mut cmd = _interp() + " tool/hx_unlock.hexa"
    for a in args { cmd = cmd + " " + _shell_quote(a) }
    cmd = cmd + " 2>&1"
    let r = exec_with_status(cmd)
    print(to_string(r[0]))
    return r[1]
}

fn _cmd_lock(args: array) -> int {
    if !_interp_ok() {
        eprintln("hx lock: " + _interp() + " not executable")
        return 1
    }
    let mut cmd = _interp() + " tool/hx_lock.hexa"
    for a in args { cmd = cmd + " " + _shell_quote(a) }
    cmd = cmd + " 2>&1"
    let r = exec_with_status(cmd)
    print(to_string(r[0]))
    return r[1]
}

// ─── subcommand: status ──────────────────────────────────────────

fn _cmd_status() -> int {
    println("── hx status ──")
    println("user:   " + _current_user())
    println("pwd:    " + to_string(exec("pwd")).trim())
    println("branch: " + _git_current_branch())
    println("")

    // 1. chflags status (Darwin only)
    println("── chflags status ──")
    if _is_darwin() && _interp_ok() {
        let r = exec_with_status(_interp() + " tool/os_level_lock.hexa status 2>&1")
        print(to_string(r[0]))
    } else if !_is_darwin() {
        println("(non-Darwin — chflags unavailable)")
    } else {
        println("(" + _interp() + " not executable — skipping chflags probe)")
    }
    println("")

    // 2. last audit entry
    println("── last audit entry ──")
    let audit_check = exec_with_status("test -f .raw-audit")
    if audit_check[1] == 0 {
        let tail = to_string(exec("tail -n 3 .raw-audit"))
        print(tail)
    } else {
        println("(no .raw-audit yet)")
    }
    println("")

    // 3. raw_all summary (fast)
    println("── raw_all --fast ──")
    let rc = _run_raw_all(true)
    return rc
}

// ─── subcommand: verify ──────────────────────────────────────────

fn _cmd_verify() -> int {
    return _run_raw_all(true)
}

// ─── subcommand: init / harden / downgrade (thin delegates) ──────

fn _tool_exists(path: string) -> bool {
    let r = exec_with_status("test -f " + path)
    return r[1] == 0
}

fn _cmd_init(args: array) -> int {
    // 최초 설치 wrapper — delegate to tool/hx_init.hexa.
    // 이미 .raw-audit 있으면 초기화 완료 상태로 간주하고 경고 후 exit.
    let audited = exec_with_status("test -f .raw-audit")
    if audited[1] == 0 {
        eprintln("hx init: .raw-audit already present — repository already initialized")
        eprintln("hx init: use `./hx status` to inspect current level, or rm -rf state first")
        return 1
    }
    if !_interp_ok() {
        eprintln("hx init: " + _interp() + " not executable")
        return 1
    }
    if !_tool_exists("tool/hx_init.hexa") {
        eprintln("hx init: tool/hx_init.hexa not found — see doc/runbook/raw_install.md")
        return 1
    }
    let mut cmd = _interp() + " tool/hx_init.hexa"
    for a in args { cmd = cmd + " " + _shell_quote(a) }
    cmd = cmd + " 2>&1"
    let r = exec_with_status(cmd)
    print(to_string(r[0]))
    return r[1]
}

fn _cmd_harden(args: array) -> int {
    // Level 1 → Level 2 승격 wrapper (args 통과).
    if !_interp_ok() {
        eprintln("hx harden: " + _interp() + " not executable")
        return 1
    }
    if !_tool_exists("tool/hx_harden.hexa") {
        eprintln("hx harden: tool/hx_harden.hexa not found — see doc/runbook/raw_install.md")
        return 1
    }
    let mut cmd = _interp() + " tool/hx_harden.hexa"
    for a in args { cmd = cmd + " " + _shell_quote(a) }
    cmd = cmd + " 2>&1"
    let r = exec_with_status(cmd)
    print(to_string(r[0]))
    return r[1]
}

fn _cmd_downgrade(args: array) -> int {
    // Level 2 → Level 1 demote wrapper (args 통과).
    if !_interp_ok() {
        eprintln("hx downgrade: " + _interp() + " not executable")
        return 1
    }
    if !_tool_exists("tool/hx_downgrade.hexa") {
        eprintln("hx downgrade: tool/hx_downgrade.hexa not found — see doc/runbook/raw_install.md")
        return 1
    }
    let mut cmd = _interp() + " tool/hx_downgrade.hexa"
    for a in args { cmd = cmd + " " + _shell_quote(a) }
    cmd = cmd + " 2>&1"
    let r = exec_with_status(cmd)
    print(to_string(r[0]))
    return r[1]
}

// ─── subcommand: fixpoint <sub> ──────────────────────────────────

fn _fixpoint_usage() {
    eprintln("usage: ./hx fixpoint <subcommand> [args...]")
    eprintln("")
    eprintln("  verify                     tool/verify_fixpoint.hexa (3x chain)")
    eprintln("  archive                    tool/fixpoint_archive.hexa snapshot")
    eprintln("  bisect  <good> <bad>       tool/fixpoint_bisect.hexa binary search")
    eprintln("  check                      tool/fixpoint_check.hexa scaffold")
    eprintln("  promote <rule> <status>    tool/raw_all_promote.hexa apply")
}

fn _fixpoint_run(tool_path: string, tail_args: array, missing_hint: string) -> int {
    if !_interp_ok() {
        eprintln("hx fixpoint: " + _interp() + " not executable")
        return 1
    }
    if !_tool_exists(tool_path) {
        eprintln("hx fixpoint: " + missing_hint)
        eprintln("hx fixpoint: (" + tool_path + " not yet implemented — see doc/runbook/raw_install.md)")
        return 1
    }
    let mut cmd = _interp() + " " + tool_path
    for a in tail_args { cmd = cmd + " " + _shell_quote(a) }
    cmd = cmd + " 2>&1"
    let r = exec_with_status(cmd)
    print(to_string(r[0]))
    return r[1]
}

fn _cmd_fixpoint(args: array) -> int {
    if len(args) < 1 {
        _fixpoint_usage()
        return 2
    }
    let sub = args[0]
    let mut rest = []
    let mut i = 1
    while i < len(args) {
        rest.push(args[i])
        i = i + 1
    }

    if sub == "verify" {
        return _fixpoint_run("tool/verify_fixpoint.hexa", rest, "fixpoint verify not available")
    }
    if sub == "archive" {
        // tool/fixpoint_archive.hexa snapshot [extra...]
        let mut tail = ["snapshot"]
        for a in rest { tail.push(a) }
        return _fixpoint_run("tool/fixpoint_archive.hexa", tail, "fixpoint archive not yet implemented")
    }
    if sub == "bisect" {
        if len(rest) < 2 {
            eprintln("hx fixpoint bisect: <good> <bad> refs required")
            return 2
        }
        return _fixpoint_run("tool/fixpoint_bisect.hexa", rest, "fixpoint bisect not yet implemented")
    }
    if sub == "check" {
        // scaffold mode (default, no --live) — safe under seed-freeze.
        return _fixpoint_run("tool/fixpoint_check.hexa", rest, "fixpoint check not available")
    }
    if sub == "promote" {
        if len(rest) < 2 {
            eprintln("hx fixpoint promote: <rule> <status> required")
            return 2
        }
        let mut tail = ["apply"]
        for a in rest { tail.push(a) }
        return _fixpoint_run("tool/raw_all_promote.hexa", tail, "fixpoint promote not yet implemented")
    }
    if sub == "help" || sub == "-h" || sub == "--help" {
        _fixpoint_usage()
        return 0
    }

    eprintln("hx fixpoint: unknown subcommand '" + sub + "'")
    eprintln("")
    _fixpoint_usage()
    return 2
}

// ─── subcommand: chain <sub> ─────────────────────────────────────

fn _chain_usage() {
    eprintln("usage: ./hx chain <subcommand> [args...]")
    eprintln("")
    eprintln("  run    <chain_id> [<step_id>]        run (and cascade) from step")
    eprintln("  status <chain_id>                    per-step marker state")
    eprintln("  list                                 all chains + progress")
    eprintln("  reset  <chain_id> --reason \"...\"     clear markers (audited)")
}

fn _cmd_chain(args: array) -> int {
    if !_interp_ok() {
        eprintln("hx chain: " + _interp() + " not executable")
        return 1
    }
    if !_tool_exists("tool/chain_runner.hexa") {
        eprintln("hx chain: tool/chain_runner.hexa not found")
        return 1
    }
    if len(args) < 1 {
        _chain_usage()
        return 2
    }
    let sub = args[0]
    if sub == "help" || sub == "-h" || sub == "--help" {
        _chain_usage()
        return 0
    }
    if sub != "run" && sub != "status" && sub != "list" && sub != "reset" {
        eprintln("hx chain: unknown subcommand '" + sub + "'")
        eprintln("")
        _chain_usage()
        return 2
    }
    let mut cmd = _interp() + " tool/chain_runner.hexa"
    for a in args { cmd = cmd + " " + _shell_quote(a) }
    cmd = cmd + " 2>&1"
    let r = exec_with_status(cmd)
    print(to_string(r[0]))
    return r[1]
}

// ─── subcommand: pkg delegates (install/update/...) ──────────────
//
// Route package-manager operations through tool/pkg/hx (bash). This
// keeps a single SSOT entry point (`./hx`) while the pkg mgr implementation
// stays in one place. own#5 cli-via-hx-install forbids direct invocation
// of registry entries, so every external CLI must arrive via `./hx install`.

fn _pkg_script() -> string { return "tool/pkg/hx" }

fn _pkg_script_ok() -> bool {
    let r = exec_with_status("test -x " + _pkg_script())
    return r[1] == 0
}

fn _cmd_pkg_delegate(sub: string, args: array) -> int {
    if !_pkg_script_ok() {
        eprintln("hx " + sub + ": " + _pkg_script() + " not executable")
        return 1
    }
    let mut cmd = _pkg_script() + " " + sub
    for a in args { cmd = cmd + " " + _shell_quote(a) }
    cmd = cmd + " 2>&1"
    let r = exec_with_status(cmd)
    print(to_string(r[0]))
    return r[1]
}

// ─── usage ───────────────────────────────────────────────────────

fn _usage() {
    eprintln("usage: ./hx <subcommand> [args...]")
    eprintln("")
    eprintln("  commit    -m \"<msg>\"           run raw_all → git commit → audit")
    eprintln("  push      [branch]               run raw_all → git push → audit")
    eprintln("  edit      <file>                 hx_unlock → $EDITOR <file> → hx_lock")
    eprintln("  unlock    --reason \"...\"        delegate to tool/hx_unlock.hexa")
    eprintln("  lock                             delegate to tool/hx_lock.hexa")
    eprintln("  status                           chflags + last audit + raw_all --fast")
    eprintln("  verify                           raw_all --fast")
    eprintln("")
    eprintln("  init                             first-time install (tool/hx_init.hexa)")
    eprintln("  harden    [--force]              Level 1 → Level 2 promote")
    eprintln("  downgrade                        Level 2 → Level 1 demote")
    eprintln("  fixpoint  <sub> [args...]        fixpoint verify/archive/bisect/check/promote")
    eprintln("  chain     <sub> [args...]        forward-chain run/status/list/reset (OS-level)")
    eprintln("")
    eprintln("  install   <target>               install external CLI as shim (own#5)")
    eprintln("  update    [<name>]               refresh shim(s) (git pull cloned pkgs)")
    eprintln("  search                           list available packages")
    eprintln("  list                             list installed packages")
    eprintln("  info      <name>                 package detail")
    eprintln("  remove    <name>                 uninstall")
    eprintln("  where     <name>                 resolve name → repo url (no install)")
    eprintln("  orgs                             probe orgs (HX_ORGS env)")
    eprintln("  help                             this text")
    eprintln("")
    eprintln("  commit/push refuse unless raw_all exit 0. Every commit carries a")
    eprintln("  `raw-all-attest: raw-all-attest:v1:<sha>:<ts>:<hmac>` trailer")
    eprintln("  (HMAC-signed; verified server-side by raw-verify.yml). Every")
    eprintln("  state transition is appended to .raw-audit.")
    eprintln("")
    eprintln("EXAMPLE (fixpoint workflow)")
    eprintln("  ./hx fixpoint check                       # scaffold drift report")
    eprintln("  ./hx fixpoint verify                      # 3x compile fixpoint gate")
    eprintln("  ./hx fixpoint archive                     # snapshot current hexa_v2")
    eprintln("  ./hx fixpoint bisect <good> <bad>         # locate first drift commit")
    eprintln("  ./hx fixpoint promote <rule> <status>     # apply raw_all promotion")
}

// ─── main dispatcher ─────────────────────────────────────────────

fn _subargs() -> array {
    let av = argv()
    let mut rest = []
    let mut i = 3   // argv[0]=hexa, argv[1]=tool/hx.hexa, argv[2]=subcmd
    while i < len(av) {
        rest.push(av[i])
        i = i + 1
    }
    return rest
}

fn _cmd_selftest() -> int {
    // Pure-fn assertions — no git / no raw_all / no state mutation.
    println("[hx selftest]")
    let q = _shell_quote("a'b")
    if q != "'a'\\''b'" { eprintln("hx: selftest FAIL (shell_quote)"); return 1 }
    if _interp() != "./build/hexa_interp" { eprintln("hx: selftest FAIL (interp path)"); return 1 }
    println("[hx selftest] OK")
    return 0
}

fn main() -> int {
    let av = argv()
    if len(av) < 3 {
        _usage()
        return 2
    }
    let sub = av[2]
    let args = _subargs()

    if sub == "--selftest" || sub == "selftest" { return _cmd_selftest() }
    if sub == "commit"      { return _cmd_commit(args) }
    if sub == "push"        { return _cmd_push(args) }
    if sub == "edit"        { return _cmd_edit(args) }
    if sub == "unlock"      { return _cmd_unlock(args) }
    if sub == "lock"        { return _cmd_lock(args) }
    if sub == "status"      { return _cmd_status() }
    if sub == "verify"      { return _cmd_verify() }
    if sub == "init"        { return _cmd_init(args) }
    if sub == "harden"      { return _cmd_harden(args) }
    if sub == "downgrade"   { return _cmd_downgrade(args) }
    if sub == "fixpoint"    { return _cmd_fixpoint(args) }
    if sub == "chain"       { return _cmd_chain(args) }
    if sub == "install"     { return _cmd_pkg_delegate("install", args) }
    if sub == "update"      { return _cmd_pkg_delegate("update", args) }
    if sub == "search"      { return _cmd_pkg_delegate("search", args) }
    if sub == "list"        { return _cmd_pkg_delegate("list", args) }
    if sub == "info"        { return _cmd_pkg_delegate("info", args) }
    if sub == "remove"      { return _cmd_pkg_delegate("remove", args) }
    if sub == "where"       { return _cmd_pkg_delegate("where", args) }
    if sub == "orgs"        { return _cmd_pkg_delegate("orgs", args) }
    if sub == "help"        { _usage(); return 0 }
    if sub == "-h"          { _usage(); return 0 }
    if sub == "--help"      { _usage(); return 0 }

    eprintln("hx: unknown subcommand '" + sub + "'")
    eprintln("")
    _usage()
    return 2
}

exit(main())
