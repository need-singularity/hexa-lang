// tool/hx_api_drift.hexa — Phase 3.5 lang spec vs impl drift (real-v1).
//
// SPEC: docs/hexa_lang_meta_evolution_proposal_20260422.md §3.5.
// STATUS: v1 real — one-directional. Extract builtin names from
//         doc/hexa-lang-spec.json, verify each appears as a string
//         literal in self/ (where the compiler dispatches builtins).
//         Reverse direction (impl_only_undocumented) deferred to v2.
//
// CLI
//   hexa tool/hx_api_drift.hexa --selftest
//   hexa tool/hx_api_drift.hexa [--out <path>]
//
// OUTPUT
//   $HEXA_LANG/state/hx_api_drift.json  (schema hexa-lang/hx_api_drift/1)

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _iso_now() -> string {
    return to_string(exec("date -u +'%Y-%m-%dT%H:%M:%SZ'")).trim()
}

fn _arg_value(args: array, key: string, default: string) -> string {
    let mut i = 0
    while i < len(args) {
        if args[i] == key {
            let j = i + 1
            if j < len(args) { return args[j] }
        }
        i = i + 1
    }
    return default
}

fn _json_esc(s: string) -> string {
    let mut r = s.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", "\\n")
    r = r.replace("\r", "")
    r = r.replace("\t", " ")
    return r
}

fn _split_lines(s: string) -> array {
    let mut out = []
    let mut cur = ""
    let mut i = 0
    while i < len(s) {
        let c = s.substring(i, i + 1)
        if c == "\n" {
            if len(cur) > 0 { out.push(cur) }
            cur = ""
        } else {
            cur = cur + c
        }
        i = i + 1
    }
    if len(cur) > 0 { out.push(cur) }
    return out
}

fn _root() -> string {
    return _home() + "/core/hexa-lang"
}

fn _index_of_str(arr: array, s: string) -> int {
    let mut i = 0
    while i < len(arr) {
        if arr[i] == s { return i }
        i = i + 1
    }
    return -1
}

fn _push_unique(arr: array, s: string) -> array {
    if _index_of_str(arr, s) >= 0 { return arr }
    arr.push(s)
    return arr
}

fn _selftest() -> int {
    if len(_iso_now()) < 10 { eprintln("hx_api_drift: selftest FAIL (iso)"); return 1 }
    let mut a = []
    a = _push_unique(a, "x")
    a = _push_unique(a, "x")
    if len(a) != 1 { eprintln("hx_api_drift: selftest FAIL (uniq)"); return 1 }
    println("hx_api_drift: selftest PASS")
    return 0
}

fn _impl_has_literal(self_dir: string, name: string) -> bool {
    let needle = "\"" + name + "\""
    let cmd = "grep -rqF '" + needle + "' '" + self_dir + "' 2>/dev/null && echo y || echo n"
    return to_string(exec(cmd)).trim() == "y"
}

fn main() {
    let av = argv()
    let mut args = []
    let mut i = 2
    while i < len(av) { args.push(av[i]); i = i + 1 }

    if len(args) >= 1 && args[0] == "--selftest" { exit(_selftest()) }

    let default_out = _root() + "/state/hx_api_drift.json"
    let out_path = _arg_value(args, "--out", default_out)
    let ts = _iso_now()

    let spec_path = _root() + "/doc/hexa-lang-spec.json"
    let self_dir = _root() + "/self"

    let raw = to_string(exec(
        "grep -hoE '\"name\": *\"[a-zA-Z_][a-zA-Z_0-9]*\"' '" + spec_path + "' 2>/dev/null"
    ))
    let lines = _split_lines(raw)
    let mut declared = []
    for ln in lines {
        let q_start = ln.index_of(":")
        if q_start < 0 { continue }
        let tail = ln.substring(q_start + 1, len(ln))
        let sq = tail.index_of("\"")
        if sq < 0 { continue }
        let after = tail.substring(sq + 1, len(tail))
        let eq = after.index_of("\"")
        if eq < 0 { continue }
        let name = after.substring(0, eq)
        if len(name) == 0 { continue }
        declared = _push_unique(declared, name)
    }

    let mut covered = []
    let mut missing = []
    for n in declared {
        if _impl_has_literal(self_dir, n) {
            covered.push(n)
        } else {
            missing.push(n)
        }
    }

    let denom = if len(declared) > 0 { len(declared) } else { 1 }
    let pct_k = (len(covered) * 1000) / denom
    let pct_int = pct_k / 10
    let pct_frac = pct_k % 10

    let mut body = "{\n  \"schema\": \"hexa-lang/hx_api_drift/1\",\n"
    body = body + "  \"ts\": \"" + ts + "\",\n"
    body = body + "  \"status\": \"real-v1\",\n"
    body = body + "  \"spec_path\": \"doc/hexa-lang-spec.json\",\n"
    body = body + "  \"spec_builtin_count\": " + to_string(len(declared)) + ",\n"
    body = body + "  \"impl_covered\": " + to_string(len(covered)) + ",\n"
    body = body + "  \"spec_only_missing_count\": " + to_string(len(missing)) + ",\n"
    body = body + "  \"coverage_pct\": \"" + to_string(pct_int) + "." + to_string(pct_frac) + "\",\n"
    body = body + "  \"spec_only_missing\": [\n"
    let mut first = true
    for m in missing {
        if !first { body = body + ",\n" }
        body = body + "    \"" + _json_esc(m) + "\""
        first = false
    }
    body = body + "\n  ],\n"
    body = body + "  \"summary\": {\"covered\": " + to_string(len(covered))
    body = body + ", \"missing\": " + to_string(len(missing)) + "}\n}\n"

    try { write_file(out_path, body) } catch e {
        eprintln("hx_api_drift: write FAIL " + out_path)
        exit(1)
    }

    println("hx_api_drift: spec=" + to_string(len(declared))
          + " impl_covered=" + to_string(len(covered))
          + " spec_only_missing=" + to_string(len(missing))
          + " (coverage=" + to_string(pct_int) + "." + to_string(pct_frac) + "%)")
    println("hx_api_drift: wrote " + out_path)
    exit(0)
}
