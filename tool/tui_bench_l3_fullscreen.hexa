// tool/tui_bench_l3_fullscreen.hexa — L3 full-screen paint bench
//
// PURPOSE
//   Measures render_flush() worst-case (every cell changes). Companion
//   to tool/tui_bench_l3_flush.hexa (single-cell rapid case).
//
//   This is the upper bound for screen refresh — N=rows*cols cells
//   diff'd + emitted as ANSI per iteration. Validates that the diff
//   path scales linearly (O(dirty_cells)) and that AOT-compiled hexa
//   can fill 24x80=1920 cells under the human-perceptible 16ms threshold.
//
// METHOD
//   Per iter: rotate a single glyph offset, write across the full grid,
//   render_flush, measure ns. The single-glyph rotation forces every
//   cell to differ from the previous frame.
//
// EXPECTED
//   24x80 = 1920 cells × ~25 bytes ANSI/cell = ~48 KB per flush. macOS
//   pipe buffer is 64 KB so write() should not block. Diff scan cost
//   is 1920 cell-eq comparisons. Output string concat is ~50 KB.

use "self/stdlib/law_io"
use "self/tui/render"

let mut _N = 200

fn _ns_to_ms_str(ns: int) -> string {
    let ms_int = ns / 1000000
    let frac_ns = ns - ms_int * 1000000
    let frac_us = frac_ns / 1000
    return to_string(ms_int) + "." + _pad3(to_string(frac_us)) + "ms"
}

fn _pad3(s: string) -> string {
    let n = len(s)
    if n >= 3 { return s }
    if n == 2 { return "0" + s }
    if n == 1 { return "00" + s }
    return "000"
}

fn _sort_int_array(arr: array) -> array {
    let n = len(arr)
    let mut i = 1
    while i < n {
        let key = arr[i]
        let mut j = i - 1
        while j >= 0 && arr[j] > key {
            arr[j + 1] = arr[j]
            j = j - 1
        }
        arr[j + 1] = key
        i = i + 1
    }
    return arr
}

fn _percentile(sorted: array, pct: int) -> int {
    let n = len(sorted)
    if n == 0 { return 0 }
    let idx = (n * pct) / 100
    let i = if idx >= n { n - 1 } else { idx }
    return sorted[i]
}

fn _mean(arr: array) -> int {
    let n = len(arr)
    if n == 0 { return 0 }
    let mut sum = 0
    let mut i = 0
    while i < n {
        sum = sum + arr[i]
        i = i + 1
    }
    return sum / n
}

fn _bench_iter(iter: int, rows: int, cols: int) -> int {
    // Fill the full grid with a rotating glyph offset.
    let base = 33 + (iter % 94)
    let mut y = 0
    while y < rows {
        let mut x = 0
        while x < cols {
            let cp = 33 + ((base + x + y) % 94)
            let _r = render_put(x, y, chr(cp), -1, -1, 0)
            x = x + 1
        }
        y = y + 1
    }
    let t0 = mono_ns()
    let _f = render_flush()
    let t1 = mono_ns()
    return t1 - t0
}

fn run_bench() -> int {
    println("=== TUI-PRIM L3 render_flush() FULL-SCREEN paint bench ===")
    println("scenario: every cell differs each frame (worst-case diff)")
    println("")

    let r = render_init()
    if r != 0 {
        eprintln("render_init failed")
        return 1
    }
    let dims = render_dims()
    let rows = dims[0]
    let cols = dims[1]
    println("dims: " + to_string(rows) + "x" + to_string(cols) + " = " + to_string(rows * cols) + " cells")

    // Warm
    let mut w = 0
    while w < 10 {
        let _ = _bench_iter(w, rows, cols)
        w = w + 1
    }

    let mut samples = []
    let mut i = 0
    while i < _N {
        let dt = _bench_iter(i, rows, cols)
        samples = samples + [dt]
        i = i + 1
    }

    let _c = render_close()

    let sorted = _sort_int_array(samples)
    let p50 = _percentile(sorted, 50)
    let p95 = _percentile(sorted, 95)
    let p99 = _percentile(sorted, 99)
    let mu = _mean(samples)
    let mn = sorted[0]
    let mx = sorted[len(sorted) - 1]

    let cells = rows * cols
    let p50_per_cell_ns = if cells > 0 { p50 / cells } else { 0 }

    eprintln("")
    eprintln("samples:        " + to_string(_N))
    eprintln("cells/frame:    " + to_string(cells))
    eprintln("mean:           " + _ns_to_ms_str(mu))
    eprintln("min:            " + _ns_to_ms_str(mn))
    eprintln("p50:            " + _ns_to_ms_str(p50))
    eprintln("p95:            " + _ns_to_ms_str(p95))
    eprintln("p99:            " + _ns_to_ms_str(p99))
    eprintln("max:            " + _ns_to_ms_str(mx))
    eprintln("p50 per-cell:   " + to_string(p50_per_cell_ns) + "ns")
    eprintln("")
    eprintln("16.6ms (60fps) budget: " + (if p50 < 16600000 { "MET" } else { "MISS" }))
    eprintln("8.3ms (120fps) budget: " + (if p50 < 8300000 { "MET" } else { "MISS" }))

    let stamp = utc_iso_now()
    let row = "{\"ts\":\"" + stamp + "\",\"bench\":\"l3_flush_fullscreen\",\"samples\":" + to_string(_N) +
              ",\"cells\":" + to_string(cells) +
              ",\"p50_ns\":" + to_string(p50) +
              ",\"p95_ns\":" + to_string(p95) +
              ",\"p99_ns\":" + to_string(p99) +
              ",\"mean_ns\":" + to_string(mu) +
              ",\"min_ns\":" + to_string(mn) +
              ",\"max_ns\":" + to_string(mx) +
              ",\"p50_per_cell_ns\":" + to_string(p50_per_cell_ns) +
              ",\"60fps_met\":" + (if p50 < 16600000 { "true" } else { "false" }) +
              ",\"120fps_met\":" + (if p50 < 8300000 { "true" } else { "false" }) + "}"
    println(row)
    return 0
}

let _entry_rc = run_bench()
exit(_entry_rc)
