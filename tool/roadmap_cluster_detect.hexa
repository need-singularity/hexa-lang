// tool/roadmap_cluster_detect.hexa — Phase 3.10 cluster auto-grouping (stub).
//
// SPEC: docs/roadmap_engine_continuous_meta_proposal_20260422.md §Phase 3.10.
// STATUS: stub — skeleton + --selftest only.
//
// PURPOSE
//   Group .roadmap entries by shared name tokens / track / phase / deps.
//   When ≥5 related entries lack an explicit cluster label, propose a
//   new cluster. Read-only / propose-only.
//
// CLI
//   hexa tool/roadmap_cluster_detect.hexa --selftest
//   hexa tool/roadmap_cluster_detect.hexa --repo <name> [--out <path>]
//
// OUTPUT
//   $HEXA_LANG/state/roadmap_clusters_<repo>.json
//   schema = "hexa-lang/roadmap_clusters/1"

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _iso_now() -> string {
    return to_string(exec("date -u +'%Y-%m-%dT%H:%M:%SZ'")).trim()
}

fn _arg_value(args: array, key: string, default: string) -> string {
    let mut i = 0
    while i < len(args) {
        if args[i] == key {
            let j = i + 1
            if j < len(args) { return args[j] }
        }
        i = i + 1
    }
    return default
}

fn _selftest() -> int {
    if len(_iso_now()) < 10 {
        eprintln("roadmap_cluster_detect: selftest FAIL (iso_now empty)")
        return 1
    }
    println("roadmap_cluster_detect: selftest PASS (stub)")
    return 0
}

fn _emit(repo: string, out_path: string) -> int {
    let ts = _iso_now()
    let body = "{\n  \"schema\": \"hexa-lang/roadmap_clusters/1\",\n  \"ts\": \"" + ts + "\",\n  \"repo\": \"" + repo + "\",\n  \"status\": \"stub\",\n  \"clusters\": [],\n  \"cluster_proposals\": []\n}\n"
    try {
        write_file(out_path, body)
    } catch e {
        eprintln("roadmap_cluster_detect: write FAIL " + out_path)
        return 1
    }
    println("roadmap_cluster_detect: wrote " + out_path + " (stub)")
    return 0
}

fn main() {
    let av = argv()
    let mut args = []
    let mut i = 2
    while i < len(av) { args.push(av[i]); i = i + 1 }

    if len(args) >= 1 && args[0] == "--selftest" {
        exit(_selftest())
    }

    let repo = _arg_value(args, "--repo", "anima")
    let default_out = _home() + "/core/hexa-lang/state/roadmap_clusters_" + repo + ".json"
    let out_path = _arg_value(args, "--out", default_out)
    exit(_emit(repo, out_path))
}
