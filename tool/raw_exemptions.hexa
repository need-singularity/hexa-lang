#!hexa strict
// tool/raw_exemptions.hexa — raw#0 P1b exemption system
//
// PURPOSE
//   Per-rule grandfather registry with MANDATORY expiry dates.
//   Individual file:line violations can be exempted temporarily —
//   never indefinitely. Every entry MUST carry a YYYY-MM-DD expiry.
//
//   Storage:
//     .raw-exemptions/raw_<id>.list   — one file per rule id
//     .raw-exemptions/own_<id>.list   — (.own kind reuses same scheme)
//
// FILE FORMAT
//   # comments allowed at column 0
//   <file_path> | <line_range> | <reason> | <expiry YYYY-MM-DD>
//
//   line_range: integer (42), range (10-20), or "*" for whole file
//   expiry     : REQUIRED — indefinite grandfather forbidden (raw#0 law).
//
// LIBRARY API
//   load_exemptions(rule_id)           -> [[file, range, reason, expiry]]
//   is_exempt(rule_id, file, line)     -> bool   (non-expired + range match)
//   expiry_check_all()                 -> [[rule_id, file, expiry, days_until]]
//     — negative days_until = expired; 0..7 = expiring-soon.
//
// CLI
//   ./hexa tool/raw_exemptions.hexa list
//   ./hexa tool/raw_exemptions.hexa list <rule_id>
//   ./hexa tool/raw_exemptions.hexa add <rule_id> <file> <range> <reason> <expiry>
//   ./hexa tool/raw_exemptions.hexa check   (exit 1 on expired)

use "self/core/law_io"
fn _dir_path() -> string { return ".raw-exemptions" }

fn _rule_file(rule_id: string) -> string {
    // rule_id "7" → ".raw-exemptions/raw_7.list"
    // rule_id "own:3" → ".raw-exemptions/own_3.list"
    let colon = rule_id.index_of(":")
    if colon >= 0 {
        let kind = rule_id.substring(0, colon)
        let id = rule_id.substring(colon + 1, len(rule_id))
        return _dir_path() + "/" + kind + "_" + id + ".list"
    }
    return _dir_path() + "/raw_" + rule_id + ".list"
}

fn _file_exists(p: string) -> bool {
    let r = exec_with_status("test -f '" + p + "'")
    return r[1] == 0
}

fn _dir_exists(p: string) -> bool {
    let r = exec_with_status("test -d '" + p + "'")
    return r[1] == 0
}

fn _today_utc() -> string {
    return to_string(exec("date -u +\"%Y-%m-%d\"")).trim()
}

// ─── date arithmetic ─────────────────────────────────────────────
// YYYY-MM-DD → days since epoch (rough, via GNU date; fall back to
// `date -j -f` on BSD). Both host + linux sandbox return integer days.
fn _days_since_epoch(ymd: string) -> int {
    // try GNU form first
    let r = exec_with_status("date -d '" + ymd + "' +%s 2>/dev/null")
    let s = to_string(r[0]).trim()
    if r[1] == 0 && s != "" {
        // seconds → days
        let secs = to_int(s)
        return secs / 86400
    }
    // BSD fallback (macOS)
    let r2 = exec_with_status("date -j -f '%Y-%m-%d' '" + ymd + "' +%s 2>/dev/null")
    let s2 = to_string(r2[0]).trim()
    if r2[1] == 0 && s2 != "" {
        let secs2 = to_int(s2)
        return secs2 / 86400
    }
    return -1  // sentinel — caller treats as unparseable
}

pub fn days_until(expiry: string) -> int {
    let today = _today_utc()
    let d_exp = _days_since_epoch(expiry)
    let d_now = _days_since_epoch(today)
    if d_exp < 0 || d_now < 0 { return -99999 }  // parse failure
    return d_exp - d_now
}

// ─── line-range parsing ──────────────────────────────────────────

fn _range_contains(range_str: string, line: int) -> bool {
    let r = range_str.trim()
    if r == "*" || r == "" { return true }
    let dash = r.index_of("-")
    if dash < 0 {
        // single integer
        let n = to_int(r)
        return n == line
    }
    let lo = to_int(r.substring(0, dash))
    let hi = to_int(r.substring(dash + 1, len(r)))
    if line < lo { return false }
    if line > hi { return false }
    return true
}

// ─── file parsing ────────────────────────────────────────────────

fn _parse_line(line: string) -> array {
    // returns [file, range, reason, expiry] or []
    let t = line.trim()
    if len(t) == 0 { return [] }
    if t.substring(0, 1) == "#" { return [] }
    // split on '|' — 4 fields expected
    let parts = split(t, "|")
    if len(parts) < 4 { return [] }
    let file = parts[0].trim()
    let range = parts[1].trim()
    let reason = parts[2].trim()
    let expiry = parts[3].trim()
    if file == "" { return [] }
    if expiry == "" { return [] }  // indefinite → reject
    return [file, range, reason, expiry]
}

pub fn load_exemptions(rule_id: string) -> array {
    let path = _rule_file(rule_id)
    let mut out = []
    if !_file_exists(path) { return out }
    let src = to_string(read_file(path))
    let lines = split(src, "\n")
    for ln in lines {
        let parsed = _parse_line(ln)
        if len(parsed) == 4 { out = out.push(parsed) }
    }
    return out
}

pub fn is_exempt(rule_id: string, file: string, line: int) -> bool {
    let entries = load_exemptions(rule_id)
    for e in entries {
        if e[0] != file { continue }
        if !_range_contains(e[1], line) { continue }
        let du = days_until(e[3])
        if du < 0 { continue }  // expired → not exempt
        return true
    }
    return false
}

// ─── enumeration across ALL list files ───────────────────────────

fn _list_rule_files() -> array {
    let mut out = []
    if !_dir_exists(_dir_path()) { return out }
    let raw = to_string(exec("ls -1 '" + _dir_path() + "' 2>/dev/null")).trim()
    if raw == "" { return out }
    for p in split(raw, "\n") {
        let t = p.trim()
        if t == "" { continue }
        // only *.list files
        if !t.ends_with(".list") { continue }
        out = out.push(_dir_path() + "/" + t)
    }
    return out
}

fn _rule_id_from_path(path: string) -> string {
    // ".raw-exemptions/raw_7.list" → "7"
    // ".raw-exemptions/own_3.list" → "own:3"
    // manual backward scan for last '/' (no .last_index_of in hexa_v2)
    let mut slash = len(path) - 1
    while slash >= 0 {
        if path.substring(slash, slash + 1) == "/" { break }
        slash = slash - 1
    }
    let mut base = path
    if slash >= 0 { base = path.substring(slash + 1, len(path)) }
    // strip ".list"
    let noext = base.substring(0, len(base) - 5)
    let us = noext.index_of("_")
    if us < 0 { return noext }
    let kind = noext.substring(0, us)
    let id = noext.substring(us + 1, len(noext))
    if kind == "raw" { return id }
    return kind + ":" + id
}

pub fn expiry_check_all() -> array {
    // returns [[rule_id, file, expiry, days_until]]
    let mut rows = []
    for path in _list_rule_files() {
        let rid = _rule_id_from_path(path)
        let src = to_string(read_file(path))
        for ln in split(src, "\n") {
            let parsed = _parse_line(ln)
            if len(parsed) != 4 { continue }
            let du = days_until(parsed[3])
            rows = rows.push([rid, parsed[0], parsed[3], to_string(du)])
        }
    }
    return rows
}

// ─── CLI commands ────────────────────────────────────────────────

fn cmd_list(filter_rule: string) -> int {
    let files = _list_rule_files()
    if len(files) == 0 {
        println("(no exemption files in " + _dir_path() + "/)")
        return 0
    }
    let mut total = 0
    for path in files {
        let rid = _rule_id_from_path(path)
        if filter_rule != "" && filter_rule != rid { continue }
        let src = to_string(read_file(path))
        for ln in split(src, "\n") {
            let parsed = _parse_line(ln)
            if len(parsed) != 4 { continue }
            let du = days_until(parsed[3])
            let mut tag = ""
            if du < 0 { tag = " EXPIRED" }
            else if du <= 7 { tag = " (≤7d)" }
            println("[" + rid + "] " + parsed[0] + " | " + parsed[1]
                    + " | " + parsed[2] + " | " + parsed[3]
                    + " (" + to_string(du) + "d)" + tag)
            total = total + 1
        }
    }
    println("-- total entries: " + to_string(total))
    return 0
}

fn _validate_expiry(expiry: string) -> bool {
    // format check: YYYY-MM-DD (len 10 + dashes at 4/7)
    if len(expiry) != 10 { return false }
    if expiry.substring(4, 5) != "-" { return false }
    if expiry.substring(7, 8) != "-" { return false }
    return _days_since_epoch(expiry) > 0
}

fn cmd_add(rule_id: string, file: string, range: string, reason: string, expiry: string) -> int {
    if rule_id == "" || file == "" || range == "" || reason == "" || expiry == "" {
        eprintln("usage: add <rule_id> <file> <range> <reason> <expiry YYYY-MM-DD>")
        return 2
    }
    if !_validate_expiry(expiry) {
        eprintln("exemptions: expiry must be YYYY-MM-DD (indefinite grandfather forbidden)")
        return 2
    }
    // ensure dir
    exec("mkdir -p '" + _dir_path() + "' 2>/dev/null")
    let path = _rule_file(rule_id)
    // warn if same file already listed
    let existing = load_exemptions(rule_id)
    for e in existing {
        if e[0] == file {
            eprintln("warn: " + file + " already has an exemption entry for [" + rule_id + "] (" + e[3] + ")")
        }
    }
    let line = file + " | " + range + " | " + reason + " | " + expiry + "\n"
    let q = "'" + line.replace("'", "'\\''") + "'"
    let r = exec_with_status("printf '%s' " + q + " >> " + path)
    if r[1] != 0 {
        eprintln("exemptions: append failed (exit " + to_string(r[1]) + ")")
        return 1
    }
    println("added: [" + rule_id + "] " + file + " → " + expiry)
    return 0
}

fn cmd_check() -> int {
    let rows = expiry_check_all()
    if len(rows) == 0 {
        println("exemptions: CLEAN (no entries)")
        return 0
    }
    let mut expired = 0
    let mut soon = 0
    for r in rows {
        let du = to_int(r[3])
        if du < 0 {
            eprintln("ERR  [" + r[0] + "] " + r[1] + " expired " + r[2] + " (" + to_string(du) + "d)")
            expired = expired + 1
        } else if du <= 7 {
            eprintln("WARN [" + r[0] + "] " + r[1] + " expires " + r[2] + " (" + to_string(du) + "d left)")
            soon = soon + 1
        }
    }
    println("exemptions: " + to_string(len(rows)) + " entries, "
            + to_string(expired) + " expired, "
            + to_string(soon) + " expiring-soon")
    if expired > 0 { return 1 }
    return 0
}

// ─── CLI dispatch ────────────────────────────────────────────────

fn _usage() {
    eprintln("usage: hexa tool/raw_exemptions.hexa <cmd>")
    eprintln("  list [rule_id]                            — show all / filter")
    eprintln("  add <rule_id> <file> <range> <reason> <expiry>")
    eprintln("  check                                     — exit 1 if any expired")
}

fn main() -> int {
    let av = argv()
    if len(av) < 3 {
        _usage()
        return 2
    }
    let cmd = av[2]
    if cmd == "list" {
        let mut filter = ""
        if len(av) >= 4 { filter = av[3] }
        return cmd_list(filter)
    }
    if cmd == "add" {
        if len(av) < 8 {
            _usage()
            return 2
        }
        return cmd_add(av[3], av[4], av[5], av[6], av[7])
    }
    if cmd == "check" {
        return cmd_check()
    }
    _usage()
    return 2
}

exit(main())
