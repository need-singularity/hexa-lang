// tool/roadmap_t_star.hexa — Tier6#56 (roadmap 51): T* multi-path optimizer
//
// PURPOSE
//   T*(S₀→G) = inf_π Σ_k max_{i∈Ω} c_i(S_k^π). Given multiple candidate
//   subsets of the DAG (paths π), compute T*(π) for each and emit the
//   optimal. Supports named scopes + free-form id ranges.
//
// DEFAULT CANDIDATES (Path A vs Path B)
//   "Path-A" = all anima entries (full serial assumption, historical 11d)
//   "Path-B" = anima#22..30 with DAG parallelism (Brent/Graham span)
//   "All"    = whole 3-repo portfolio
//
// CLI
//   hexa tool/roadmap_t_star.hexa --compare A,B,All
//   hexa tool/roadmap_t_star.hexa --selftest

fn _rstrip(s: string) -> string {
    let mut end = len(s)
    while end > 0 {
        let c = s.substring(end - 1, end)
        if c == " " || c == "\t" || c == "\r" { end = end - 1 } else { break }
    }
    return s.substring(0, end)
}

fn _hdr(line: string) -> array {
    let sp1 = line.index_of(" ")
    if sp1 < 0 { return [] }
    if line.substring(0, sp1) != "roadmap" { return [] }
    let r1 = line.substring(sp1 + 1, len(line))
    let sp2 = r1.index_of(" ")
    if sp2 < 0 { return [] }
    let id = r1.substring(0, sp2)
    let r2 = r1.substring(sp2 + 1, len(r1))
    let sp3 = r2.index_of(" ")
    if sp3 < 0 { return [] }
    let st = r2.substring(0, sp3)
    let mut nm = r2.substring(sp3 + 1, len(r2)).trim()
    if len(nm) >= 2 && nm.substring(0, 1) == "\"" { nm = nm.substring(1, len(nm) - 1) }
    return [id, st, nm]
}

fn parse_roadmap(src: string) -> array {
    let lines = split(src, "\n")
    let mut rules = []
    let mut kind = ""
    let mut cid = ""; let mut cst = ""; let mut cnm = ""; let mut ck = []
    for raw_line in lines {
        let line = _rstrip(raw_line)
        if len(line) == 0 {
            if kind == "r" { rules.push([cid, cst, cnm, ck]) }
            kind = ""; ck = []
            continue
        }
        let f = line.substring(0, 1)
        if f == "#" { continue }
        if f == " " || f == "\t" {
            if kind == "" { continue }
            let s = line.trim_start()
            let sp = s.index_of(" ")
            if sp < 0 { continue }
            ck.push([s.substring(0, sp), s.substring(sp + 1, len(s)).trim()])
        } else {
            if kind == "r" { rules.push([cid, cst, cnm, ck]) }
            ck = []; kind = ""
            let fs = line.index_of(" ")
            if fs < 0 { continue }
            if line.substring(0, fs) == "roadmap" {
                let h = _hdr(line)
                if len(h) == 0 { continue }
                cid = h[0]; cst = h[1]; cnm = h[2]; kind = "r"
            }
        }
    }
    if kind == "r" { rules.push([cid, cst, cnm, ck]) }
    return rules
}

fn _load(path: string) -> array {
    let r = exec_with_status("test -f '" + path + "'")
    if r[1] != 0 { return [] }
    return parse_roadmap(to_string(read_file(path)))
}

fn _kv(keys: array, k: string) -> string {
    for kv in keys { if kv[0] == k { return kv[1] } }
    return ""
}

fn _is_int(s: string) -> bool {
    if len(s) == 0 { return false }
    let d = "0123456789"
    let mut i = 0
    while i < len(s) { if !d.contains(s.substring(i, i + 1)) { return false } i = i + 1 }
    return true
}

fn _parse_int(s: string) -> int {
    let mut n = 0
    let d = "0123456789"
    let mut i = 0
    while i < len(s) {
        let c = s.substring(i, i + 1)
        if !d.contains(c) { return n }
        n = n * 10 + d.index_of(c)
        i = i + 1
    }
    return n
}

fn parse_deps(val: string, default_repo: string) -> array {
    let mut out = []
    if len(val) == 0 || val == "—" { return out }
    let cleaned = val.replace(",", " ").replace("+", " ")
    let toks = split(cleaned, " ")
    let mut current = default_repo
    for raw in toks {
        let t = raw.trim()
        if len(t) == 0 { continue }
        let at = t.index_of("@")
        if at > 0 && at < len(t) - 1 {
            let repo = t.substring(0, at)
            let id = t.substring(at + 1, len(t))
            if _is_int(id) { out.push([repo, id]); current = repo; continue }
        }
        if _is_int(t) { out.push([current, t]) }
    }
    return out
}

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _load_repos() -> array {
    let home = _home()
    let mut out = []
    for r in ["anima", "airgenome", "hexa-lang"] {
        out.push([r, _load(home + "/core/" + r + "/.roadmap")])
    }
    return out
}

// Scope selectors.
fn _filter_anima_all(repos: array) -> array {
    let mut out = []
    for rr in repos { if rr[0] == "anima" { out.push(rr) } }
    return out
}
fn _filter_pathB(repos: array) -> array {
    let mut out = []
    for rr in repos {
        if rr[0] != "anima" { continue }
        let mut kept = []
        for rule in rr[1] {
            if !_is_int(rule[0]) { continue }
            let n = _parse_int(rule[0])
            if n >= 22 && n <= 30 { kept.push(rule) }
        }
        out.push(["anima", kept])
    }
    return out
}

// Compute span (parallel DAG) + work (serial sum).
fn span_and_work(repos: array) -> array {
    let mut keys = []
    let mut weights = []
    for rr in repos {
        for rule in rr[1] {
            keys.push(rr[0] + "#" + rule[0])
            let dv = _kv(rule[3], "days")
            if _is_int(dv) && _parse_int(dv) > 0 { weights.push(_parse_int(dv)) } else { weights.push(1) }
        }
    }
    let n = len(keys)
    let mut pred = []
    let mut succ = []
    let mut i = 0
    while i < n { pred.push([]); succ.push([]); i = i + 1 }
    for rr in repos {
        for rule in rr[1] {
            let sk = rr[0] + "#" + rule[0]
            let dep = _kv(rule[3], "depends-on")
            for pair in parse_deps(dep, rr[0]) {
                let tk = pair[0] + "#" + pair[1]
                let mut fi = -1; let mut ti = -1
                let mut k = 0
                while k < n {
                    if keys[k] == sk { fi = k }
                    if keys[k] == tk { ti = k }
                    k = k + 1
                }
                if fi < 0 || ti < 0 { continue }
                let p = pred[fi]; p.push(ti); pred[fi] = p
                let s = succ[ti]; s.push(fi); succ[ti] = s
            }
        }
    }
    let mut indeg = []
    let mut j = 0
    while j < n { indeg.push(len(pred[j])); j = j + 1 }
    let mut q = []
    let mut topo = []
    let mut jj = 0
    while jj < n { if indeg[jj] == 0 { q.push(jj) } jj = jj + 1 }
    let mut qi = 0
    while qi < len(q) {
        let u = q[qi]
        topo.push(u)
        for v in succ[u] {
            indeg[v] = indeg[v] - 1
            if indeg[v] == 0 { q.push(v) }
        }
        qi = qi + 1
    }
    if len(topo) != n { return [0, 0, n, true] }
    let mut earliest = []
    let mut k2 = 0
    while k2 < n { earliest.push(weights[k2]); k2 = k2 + 1 }
    for u in topo {
        let mut best = 0
        for p in pred[u] { if earliest[p] > best { best = earliest[p] } }
        earliest[u] = best + weights[u]
    }
    let mut span = 0
    for v in earliest { if v > span { span = v } }
    let mut work = 0
    for w in weights { work = work + w }
    return [work, span, n, false]
}

// T*(π) = span(π)  (infinite-workers lower bound)
// serial T(π) = work(π) for reference
// recommended T_p with p=2 workers: graham_upper = (work + span*(p-1))/p
fn graham_upper(work: int, sp: int, p: int) -> int {
    if p <= 0 { return 0 }
    return (work + sp * (p - 1) + p - 1) / p
}

fn _path_metrics(name: string, repos: array) -> array {
    let r = span_and_work(repos)
    if r[3] != false { return [name, -1, -1, -1, -1] }
    let work = r[0]; let sp = r[1]; let nn = r[2]
    return [name, work, sp, nn, graham_upper(work, sp, 2)]
}

fn _compare(names: array) -> array {
    let all = _load_repos()
    let mut rows = []
    for nm in names {
        if nm == "A" {
            // Path A = full serial anima path — no parallelism assumed
            // We simulate by making a linear chain: work == serial sum (from
            // the subset of entries with exit_criteria). Use all anima.
            let an = _filter_anima_all(all)
            rows.push(_path_metrics("Path-A-full-anima", an))
        }
        if nm == "B" {
            let pb = _filter_pathB(all)
            rows.push(_path_metrics("Path-B-pathB", pb))
        }
        if nm == "All" {
            rows.push(_path_metrics("All-3repo", all))
        }
    }
    return rows
}

fn _selftest() -> int {
    let rows = _compare(["A", "B", "All"])
    println("T* candidate comparison (T* ≈ span, serial = work):")
    println("  path                 work  span  nodes T_p2(graham)")
    for r in rows {
        let pad = r[0] + "                                "
        let name = pad.substring(0, 20)
        println("  " + name + " " + to_string(r[1]) + "    " + to_string(r[2]) + "     " + to_string(r[3]) + "    " + to_string(r[4]))
    }
    // Find best T*
    let mut best_i = -1
    let mut best_sp = 1000000
    let mut i = 0
    while i < len(rows) {
        let sp = rows[i][2]
        if sp > 0 && sp < best_sp { best_sp = sp; best_i = i }
        i = i + 1
    }
    if best_i < 0 { eprintln("selftest FAIL: no valid rows"); return 1 }
    let best = rows[best_i]
    println("OPTIMAL: " + best[0] + " T* = " + to_string(best[2]))
    // Path B should beat Path A (full anima) span
    let mut a_sp = 0
    let mut b_sp = 0
    for r in rows {
        if r[0].starts_with("Path-A") { a_sp = r[2] }
        if r[0].starts_with("Path-B") { b_sp = r[2] }
    }
    if b_sp > a_sp {
        eprintln("selftest FAIL: Path-B span (" + to_string(b_sp) + ") should be ≤ Path-A span (" + to_string(a_sp) + ")")
        return 1
    }
    println("selftest PASS — Path-B T* = " + to_string(b_sp) + " ≤ Path-A T* = " + to_string(a_sp))
    return 0
}

fn main() {
    let av = argv()
    let mut args = []
    let mut i = 2
    while i < len(av) { args.push(av[i]); i = i + 1 }
    if len(args) >= 1 && args[0] == "--selftest" { exit(_selftest()) }

    let mut paths_csv = "A,B,All"
    let mut j = 0
    while j < len(args) {
        if args[j] == "--compare" && j + 1 < len(args) { paths_csv = args[j + 1]; j = j + 1 }
        j = j + 1
    }
    let ns = split(paths_csv, ",")
    let mut names = []
    for n in ns { let t = n.trim(); if len(t) > 0 { names.push(t) } }
    let rows = _compare(names)

    let mut p = []
    p.push("{\"candidates\":[")
    let mut first = true
    for r in rows {
        if !first { p.push(",") }
        p.push("{\"name\":\""); p.push(r[0]); p.push("\",\"work\":"); p.push(to_string(r[1])); p.push(",\"span\":"); p.push(to_string(r[2])); p.push(",\"nodes\":"); p.push(to_string(r[3])); p.push(",\"t_p2_graham\":"); p.push(to_string(r[4])); p.push("}")
        first = false
    }
    // pick best
    let mut best_i = -1
    let mut best_sp = 1000000
    let mut k = 0
    while k < len(rows) {
        let s = rows[k][2]
        if s > 0 && s < best_sp { best_sp = s; best_i = k }
        k = k + 1
    }
    p.push("],\"optimal\":")
    if best_i >= 0 { p.push("\""); p.push(rows[best_i][0]); p.push("\"") } else { p.push("null") }
    p.push(",\"t_star\":"); p.push(to_string(best_sp))
    p.push("}")
    println(p.join(""))
}
