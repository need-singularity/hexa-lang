// tool/hx_fixedpoint_scan.hexa — 자호스팅 부동점 witness (nexus 메타 FP 개념).
//
// 배경: nexus atlas C3 convergence witness 의 hexa-lang 판.
//   - α: self_compile — stage0 / hexa_v2 / hexa(driver) SHA-256 스냅샷.
//   - β: interp_aot_isom — regression.hexa 를 interp 경로 (HEXA_CACHE=0) 와
//        AOT 경로로 각각 돌려서 PASS/FAIL 라인 정렬-비교. 동일하면 동형.
// 결과를 state/hx_fixedpoint.json 에 기록. 이후 build 마다 호출하면 drift
// 감지 가능 — nexus C3 "2 독립 도메인에서 같은 FP 관측" 과 동일 구조.
//
// 사용: $HEXA_LANG/hexa tool/hx_fixedpoint_scan.hexa

fn _sh(cmd) {
    return to_string(exec(cmd)).trim()
}

fn _hash_file(path) {
    let out = _sh("shasum -a 256 '" + path + "' 2>/dev/null | awk '{print $1}'")
    return out
}

fn _regression_signature(mode) {
    // mode: "interp" → HEXA_CACHE=0 / "aot" → default
    let root = env_var("HEXA_LANG")
    let env = if mode == "interp" { "HEXA_CACHE=0 " } else { "" }
    // PASS/FAIL/SKIP 라인만 수집 → 안정적 서명
    let cmd = env + "timeout 120 '" + root + "/hexa' run '" + root + "/test/regression.hexa' 2>&1 | grep -E '^(PASS|FAIL|SKIP)' | sort"
    return _sh(cmd)
}

fn main() {
    let root = env_var("HEXA_LANG")
    let stage0_h = _hash_file(root + "/build/hexa_stage0")
    let hexa_v2_h = _hash_file(root + "/self/native/hexa_v2")
    let driver_h = _hash_file(root + "/hexa")
    let now = _sh("date -u +'%Y-%m-%dT%H:%M:%SZ'")

    println("[fp-scan] hashing…")
    println("  stage0: " + stage0_h)
    println("  hexa_v2: " + hexa_v2_h)
    println("  driver: " + driver_h)

    println("[fp-scan] interp vs AOT regression…")
    let interp_sig = _regression_signature("interp")
    let aot_sig = _regression_signature("aot")
    let isom = interp_sig == aot_sig
    let interp_lines = to_string(len(interp_sig.split("\n")))
    let aot_lines = to_string(len(aot_sig.split("\n")))

    // 서명 자체는 다른 곳에 dump (사이즈 이유) — 현 json 은 해시/요약만
    let interp_hash_cmd = "printf '%s' '" + interp_sig + "' | shasum -a 256 | awk '{print $1}'"
    let aot_hash_cmd = "printf '%s' '" + aot_sig + "' | shasum -a 256 | awk '{print $1}'"
    let interp_hash = _sh(interp_hash_cmd)
    let aot_hash = _sh(aot_hash_cmd)

    let convergence = if isom { "true" } else { "false" }

    let json = "{\n"
        + "  \"schema\": \"hexa-lang.fixedpoint.v1\",\n"
        + "  \"updated_ts\": \"" + now + "\",\n"
        + "  \"note\": \"nexus 메타 부동점 Level B — self_compile + interp_aot_isom 관측\",\n"
        + "  \"axes\": {\n"
        + "    \"self_compile\": {\n"
        + "      \"stage0_sha256\": \"" + stage0_h + "\",\n"
        + "      \"hexa_v2_sha256\": \"" + hexa_v2_h + "\",\n"
        + "      \"driver_sha256\": \"" + driver_h + "\"\n"
        + "    },\n"
        + "    \"interp_aot_isom\": {\n"
        + "      \"isomorphic\": " + convergence + ",\n"
        + "      \"interp_lines\": " + interp_lines + ",\n"
        + "      \"aot_lines\": " + aot_lines + ",\n"
        + "      \"interp_sig_sha256\": \"" + interp_hash + "\",\n"
        + "      \"aot_sig_sha256\": \"" + aot_hash + "\"\n"
        + "    }\n"
        + "  },\n"
        + "  \"convergence_reached\": " + convergence + "\n"
        + "}\n"

    let path = root + "/state/hx_fixedpoint.json"
    write_file(path, json)
    println("")
    println("[fp-scan] wrote: " + path)
    println("[fp-scan] isomorphic=" + convergence + " (interp_lines=" + interp_lines + " aot_lines=" + aot_lines + ")")
}
