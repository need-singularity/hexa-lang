// tool/viz_pages_render.hexa — Tier 4 #30 : GitHub Pages HTML renderer
//
// PURPOSE
//   Static HTML renderer for the 3-repo .roadmap SSOT. Emits a single
//   self-contained index.html with:
//     - overview cards per repo (total / done / active / planned)
//     - CSS progress bars per phase
//     - expandable entry list per repo with depends-on links
//     - click-to-scroll entry details (anchor hrefs)
//
// raw#9 STRICT: hexa-only, deterministic, no Python, no LLM, no JS runtime.
//
// CLI
//   hexa tool/viz_pages_render.hexa                      — emit docs/_site/index.html
//   hexa tool/viz_pages_render.hexa --out <path>         — override output
//   hexa tool/viz_pages_render.hexa --selftest           — verify
//
// OUTPUT
//   <out>/_site/index.html (default: docs/_site/index.html in hexa-lang)

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _rstrip(s: string) -> string {
    let mut end = len(s)
    while end > 0 {
        let c = s.substring(end - 1, end)
        if c == " " || c == "\t" || c == "\r" { end = end - 1 } else { break }
    }
    return s.substring(0, end)
}

fn _hdr(line: string) -> array {
    let sp1 = line.index_of(" ")
    if sp1 < 0 { return [] }
    if line.substring(0, sp1) != "roadmap" { return [] }
    let r1 = line.substring(sp1 + 1, len(line))
    let sp2 = r1.index_of(" ")
    if sp2 < 0 { return [] }
    let id = r1.substring(0, sp2)
    let r2 = r1.substring(sp2 + 1, len(r1))
    let sp3 = r2.index_of(" ")
    if sp3 < 0 { return [] }
    let st = r2.substring(0, sp3)
    let mut nm = r2.substring(sp3 + 1, len(r2)).trim()
    if len(nm) >= 2 && nm.substring(0, 1) == "\"" { nm = nm.substring(1, len(nm) - 1) }
    return [id, st, nm]
}

fn parse_roadmap(src: string) -> array {
    let lines = split(src, "\n")
    let mut rules = []
    let mut kind = ""
    let mut cid = ""; let mut cst = ""; let mut cnm = ""; let mut ck = []
    for raw_line in lines {
        let line = _rstrip(raw_line)
        if len(line) == 0 {
            if kind == "r" { rules.push([cid, cst, cnm, ck]) }
            kind = ""; ck = []
            continue
        }
        let f = line.substring(0, 1)
        if f == "#" { continue }
        if f == " " || f == "\t" {
            if kind == "" { continue }
            let s = line.trim_start()
            let sp = s.index_of(" ")
            if sp < 0 { continue }
            ck.push([s.substring(0, sp), s.substring(sp + 1, len(s)).trim()])
        } else {
            if kind == "r" { rules.push([cid, cst, cnm, ck]) }
            ck = []; kind = ""
            let fs = line.index_of(" ")
            if fs < 0 { continue }
            if line.substring(0, fs) == "roadmap" {
                let h = _hdr(line)
                if len(h) == 0 { continue }
                cid = h[0]; cst = h[1]; cnm = h[2]; kind = "r"
            }
        }
    }
    if kind == "r" { rules.push([cid, cst, cnm, ck]) }
    return rules
}

fn _load(path: string) -> array {
    let r = exec_with_status("test -f '" + path + "'")
    if r[1] != 0 { return [] }
    return parse_roadmap(to_string(read_file(path)))
}

fn _kv(keys: array, k: string) -> string {
    for kv in keys { if kv[0] == k { return kv[1] } }
    return ""
}

fn _load_repos() -> array {
    let home = _home()
    let repos = ["anima", "airgenome", "hexa-lang"]
    let mut out = []
    for r in repos {
        out.push([r, _load(home + "/core/" + r + "/.roadmap")])
    }
    return out
}

fn _he(s: string) -> string {
    let mut o = s.replace("&", "&amp;")
    o = o.replace("<", "&lt;")
    o = o.replace(">", "&gt;")
    o = o.replace("\"", "&quot;")
    return o
}

fn _status_class(st: string) -> string {
    if st == "done" { return "st-done" }
    if st == "active" { return "st-active" }
    if st == "blocked" { return "st-blocked" }
    if st == "deferred" { return "st-deferred" }
    return "st-planned"
}

// phase pct: [total, done, active, planned, pct]
fn _phase_pct(rules: array, phase: string) -> array {
    let mut total = 0; let mut done = 0; let mut active = 0; let mut planned = 0
    for r in rules {
        let ph = _kv(r[3], "phase")
        if phase != "" && ph != phase { continue }
        total = total + 1
        let st = r[1]
        if st == "done" { done = done + 1 }
        if st == "active" { active = active + 1 }
        if st == "planned" || st == "blocked" || st == "deferred" || st == "todo" { planned = planned + 1 }
    }
    let mut pct = 0
    if total > 0 { pct = (done * 100) / total }
    return [total, done, active, planned, pct]
}

fn _all_phases(rules: array) -> array {
    let mut seen = []
    for r in rules {
        let ph = _kv(r[3], "phase")
        if len(ph) == 0 { continue }
        let mut found = false
        for s in seen { if s == ph { found = true } }
        if !found { seen.push(ph) }
    }
    return seen
}

fn _css() -> string {
    let mut p = []
    p.push("<style>\n")
    p.push("* { box-sizing: border-box; }\n")
    p.push("body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background: #0d1117; color: #c9d1d9; margin: 0; padding: 24px; }\n")
    p.push("h1 { color: #58a6ff; border-bottom: 2px solid #30363d; padding-bottom: 8px; }\n")
    p.push("h2 { color: #79c0ff; margin-top: 32px; }\n")
    p.push("h3 { color: #a5d6ff; }\n")
    p.push(".cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 16px; margin: 16px 0; }\n")
    p.push(".card { background: #161b22; border: 1px solid #30363d; border-radius: 6px; padding: 16px; }\n")
    p.push(".bar-wrap { background: #21262d; border-radius: 4px; height: 10px; margin: 6px 0; overflow: hidden; }\n")
    p.push(".bar-fill { background: linear-gradient(90deg, #238636, #2ea043); height: 100%; transition: width .3s; }\n")
    p.push(".bar-fill.low  { background: linear-gradient(90deg, #9e6a03, #e3b341); }\n")
    p.push(".bar-fill.crit { background: linear-gradient(90deg, #da3633, #f85149); }\n")
    p.push(".meta { font-size: 12px; color: #8b949e; }\n")
    p.push(".entries { list-style: none; padding: 0; }\n")
    p.push(".entry { background: #161b22; border: 1px solid #30363d; border-radius: 4px; margin: 6px 0; padding: 10px 14px; }\n")
    p.push(".entry .title { font-weight: 600; }\n")
    p.push(".entry .badge { display: inline-block; padding: 2px 8px; border-radius: 10px; font-size: 11px; font-weight: 600; margin-right: 8px; }\n")
    p.push(".st-done     { background: #2ea04333; color: #7ee787; }\n")
    p.push(".st-active   { background: #1f6feb33; color: #79c0ff; }\n")
    p.push(".st-planned  { background: #8b949e33; color: #c9d1d9; }\n")
    p.push(".st-blocked  { background: #da363333; color: #ff7b72; }\n")
    p.push(".st-deferred { background: #bf811d33; color: #e3b341; }\n")
    p.push(".entry .kv { font-size: 12px; color: #8b949e; margin-top: 6px; }\n")
    p.push(".entry .kv b { color: #c9d1d9; }\n")
    p.push(".entry details summary { cursor: pointer; color: #58a6ff; font-size: 12px; }\n")
    p.push(".phase-grid { display: grid; grid-template-columns: 120px 1fr 80px; gap: 8px; align-items: center; margin: 4px 0; }\n")
    p.push(".phase-grid .label { color: #8b949e; font-size: 13px; }\n")
    p.push(".phase-grid .pct { text-align: right; font-size: 12px; color: #7ee787; }\n")
    p.push(".footer { margin-top: 48px; padding-top: 16px; border-top: 1px solid #30363d; color: #6e7681; font-size: 12px; }\n")
    p.push(".nav a { color: #58a6ff; margin-right: 16px; text-decoration: none; }\n")
    p.push(".nav a:hover { text-decoration: underline; }\n")
    p.push("a { color: #58a6ff; }\n")
    p.push("</style>\n")
    return p.join("")
}

fn _bar_class(pct: int) -> string {
    if pct >= 70 { return "" }
    if pct >= 30 { return "low" }
    return "crit"
}

fn _render_card(rr: array) -> string {
    let repo = rr[0]; let rules = rr[1]
    let agg = _phase_pct(rules, "")
    let mut p = []
    p.push("<div class='card'>")
    p.push("<h3><a href='#repo-" + _he(repo) + "'>" + _he(repo) + "</a></h3>")
    p.push("<div class='bar-wrap'><div class='bar-fill " + _bar_class(agg[4]) + "' style='width:" + to_string(agg[4]) + "%'></div></div>")
    p.push("<div class='meta'>")
    p.push("total <b>" + to_string(agg[0]) + "</b> · done <b>" + to_string(agg[1]) + "</b> · active <b>" + to_string(agg[2]) + "</b> · planned <b>" + to_string(agg[3]) + "</b>")
    p.push(" &middot; <b>" + to_string(agg[4]) + "%</b>")
    p.push("</div>")
    // per phase
    p.push("<div style='margin-top:12px'>")
    let phases = _all_phases(rules)
    for ph in phases {
        let a = _phase_pct(rules, ph)
        p.push("<div class='phase-grid'>")
        p.push("<span class='label'>" + _he(ph) + "</span>")
        p.push("<div class='bar-wrap'><div class='bar-fill " + _bar_class(a[4]) + "' style='width:" + to_string(a[4]) + "%'></div></div>")
        p.push("<span class='pct'>" + to_string(a[4]) + "% (" + to_string(a[1]) + "/" + to_string(a[0]) + ")</span>")
        p.push("</div>")
    }
    p.push("</div>")
    p.push("</div>")
    return p.join("")
}

fn _render_entry(repo: string, rule: array) -> string {
    let id = rule[0]; let st = rule[1]; let name = rule[2]; let keys = rule[3]
    let mut p = []
    p.push("<li class='entry' id='e-" + _he(repo) + "-" + _he(id) + "'>")
    p.push("<span class='badge " + _status_class(st) + "'>" + _he(st) + "</span>")
    p.push("<span class='title'>#" + _he(id) + " " + _he(name) + "</span>")
    // Key-value meta
    let track = _kv(keys, "track")
    let phase = _kv(keys, "phase")
    let eta = _kv(keys, "eta")
    let dep = _kv(keys, "depends-on")
    p.push("<div class='kv'>")
    if len(track) > 0 { p.push("<b>track</b> " + _he(track) + " &middot; ") }
    if len(phase) > 0 { p.push("<b>phase</b> " + _he(phase) + " &middot; ") }
    if len(eta) > 0 { p.push("<b>eta</b> " + _he(eta) + " &middot; ") }
    if len(dep) > 0 { p.push("<b>depends-on</b> " + _he(dep)) }
    p.push("</div>")
    // Full details
    p.push("<details><summary>details</summary><div class='kv' style='margin-top:8px'>")
    for kv in keys {
        if kv[0] == "track" || kv[0] == "phase" || kv[0] == "eta" || kv[0] == "depends-on" { continue }
        let mut v = kv[1]
        if len(v) > 300 { v = v.substring(0, 297) + "..." }
        p.push("<b>" + _he(kv[0]) + "</b> " + _he(v) + "<br/>")
    }
    p.push("</div></details>")
    p.push("</li>")
    return p.join("")
}

fn render_html(repos: array) -> string {
    let mut p = []
    p.push("<!doctype html>\n<html lang='en'>\n<head>\n")
    p.push("<meta charset='utf-8'/>\n")
    p.push("<title>Roadmap Live — hexa-native SSOT</title>\n")
    p.push(_css())
    p.push("</head>\n<body>\n")
    p.push("<h1>Roadmap Live — 3-repo SSOT</h1>\n")
    p.push("<div class='nav'>")
    for rr in repos {
        p.push("<a href='#repo-" + _he(rr[0]) + "'>" + _he(rr[0]) + "</a>")
    }
    p.push("<a href='#all'>all entries</a>")
    p.push("</div>\n")
    p.push("<p class='meta'>Generated by tool/viz_pages_render.hexa (raw#9 strict, hexa-only).</p>\n")

    // Summary cards
    p.push("<div class='cards'>")
    for rr in repos { p.push(_render_card(rr)) }
    p.push("</div>\n")

    // Entries per repo
    for rr in repos {
        let repo = rr[0]; let rules = rr[1]
        p.push("<h2 id='repo-" + _he(repo) + "'>" + _he(repo) + " <span class='meta'>(" + to_string(len(rules)) + " entries)</span></h2>\n")
        p.push("<ul class='entries'>")
        for rule in rules { p.push(_render_entry(repo, rule)) }
        p.push("</ul>\n")
    }

    p.push("<div class='footer'>raw#9 hexa-only · deterministic · no LLM · no Python<br/>tool/viz_pages_render.hexa — Tier4 #30</div>\n")
    p.push("</body></html>\n")
    return p.join("")
}

fn _ensure_dir(path: string) -> void {
    exec("mkdir -p '" + path + "'")
}

fn _selftest() -> int {
    println("[viz_pages_render selftest] loading 3 repos...")
    let repos = _load_repos()
    if len(repos) != 3 {
        eprintln("FAIL: expected 3 repos, got " + to_string(len(repos)))
        return 1
    }
    let mut total = 0
    for rr in repos { total = total + len(rr[1]) }
    println("  total entries: " + to_string(total))

    let html = render_html(repos)
    if len(html) < 5000 {
        eprintln("FAIL: html too short: " + to_string(len(html)))
        return 1
    }
    // Validate: every entry ID should appear
    let mut missing = 0
    for rr in repos {
        let repo = rr[0]
        for rule in rr[1] {
            let anchor = "id='e-" + repo + "-" + rule[0] + "'"
            if !html.contains(anchor) {
                eprintln("FAIL: missing anchor for " + repo + "#" + rule[0])
                missing = missing + 1
            }
        }
    }
    if missing > 0 {
        eprintln("FAIL: " + to_string(missing) + " entries missing from HTML")
        return 1
    }
    println("  all " + to_string(total) + " entries present in HTML")

    // Basic HTML structure
    if !html.contains("<!doctype html>") {
        eprintln("FAIL: missing doctype")
        return 1
    }
    if !html.contains("</html>") {
        eprintln("FAIL: missing closing html")
        return 1
    }
    println("  HTML structure OK: " + to_string(len(html)) + " chars")

    // Write to tmp + verify file
    let home = _home()
    let outdir = home + "/core/hexa-lang/docs/_site"
    _ensure_dir(outdir)
    let outfile = outdir + "/index.html"
    write_file(outfile, html)
    let r = exec_with_status("test -f '" + outfile + "'")
    if r[1] != 0 {
        eprintln("FAIL: file not written")
        return 1
    }
    println("  wrote " + outfile)

    println("selftest PASS — #30 LIVE")
    return 0
}

fn main() {
    let av = argv()
    // Robust: find this script's name in argv, user args follow.
    let mut start = 2
    let mut j = 0
    while j < len(av) {
        let s = av[j]
        if len(s) >= 22 && s.contains("viz_pages_render.hexa") { start = j + 1 }
        j = j + 1
    }
    let mut args = []
    let mut i = start
    while i < len(av) { args.push(av[i]); i = i + 1 }

    if len(args) > 0 && args[0] == "--selftest" { exit(_selftest()) }

    let home = _home()
    let mut outpath = home + "/core/hexa-lang/docs/_site/index.html"
    let mut k = 0
    while k < len(args) {
        if args[k] == "--out" && k + 1 < len(args) { outpath = args[k + 1]; k = k + 1 }
        k = k + 1
    }
    let repos = _load_repos()
    let html = render_html(repos)
    // mkdir parent
    let last_slash = 0
    let mut ls = -1
    let mut ii = 0
    while ii < len(outpath) {
        if outpath.substring(ii, ii + 1) == "/" { ls = ii }
        ii = ii + 1
    }
    if ls > 0 {
        let parent = outpath.substring(0, ls)
        _ensure_dir(parent)
    }
    write_file(outpath, html)
    println("wrote " + outpath + " (" + to_string(len(html)) + " bytes)")
    exit(0)
}
