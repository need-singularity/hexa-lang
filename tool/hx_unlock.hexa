#!hexa strict
// tool/hx_unlock.hexa — blessed unlock gate (P0b, tiered)
//
// PURPOSE
//   The ONLY sanctioned path to remove OS-level locks from SSOT files.
//   Requires:
//     · raw_all exit 0 (all live rules pass)
//     · --reason "<text>" (mandatory, written to audit log)
//     · optional --actor <name> (defaults to $USER)
//     · optional --window <seconds> (default 300, max 3600)
//
// LEVELS
//   For each target:
//     · L0 → nothing to do
//     · L1 → chflags nouchg (macOS) / chattr -i (Linux, sudo -n)
//     · L2 → sudo -n chflags noschg (macOS) / sudo -n chattr -i (Linux)
//   After unlock, re-lock daemon restores targets to their ORIGINAL
//   level (L2 targets are promoted back via sudo schg on auto-relock).
//
// FLOW
//   1. parse args; fail fast on missing --reason
//   2. snapshot per-target level map (for relock restore)
//   3. fingerprint SSOT (sha256 of 5 files)
//   4. run raw_all; on FAIL → refuse, log "blocked" to audit, exit 1
//   5. on PASS → per-target unlock (level-aware)
//   6. audit "unlock" event with sha_before + reason + level map
//   7. schedule background re-lock at T + window (spawn detached)
//   8. print banner with countdown + next steps
//
// RELOCK
//   A background child `sh -c "sleep N; ./hexa tool/hx_lock.hexa auto"`
//   is spawned. The child re-runs raw_all on re-lock — if edits broke
//   rules, the audit logs a warning and the files remain unlocked
//   (letting developer fix rather than auto-reverting work).
//
// USAGE
//   ./hexa tool/hx_unlock.hexa --reason "add raw#17 rule"
//   ./hexa tool/hx_unlock.hexa --reason "fix typo" --window 60
//   ./hexa tool/hx_unlock.hexa --reason "demo"  \
//        --exclude raw:self-host-fixpoint      # pass-through to raw_all
//        --roadmap-ref 9                       # mandatory with --exclude/--fast
//   --exclude raw:<slug> is repeatable; each entry instructs raw_all to
//   treat that rule as SKIP with detail="excluded via --exclude". Used
//   when a specific enforcer is structurally broken (seed-freeze, etc.)
//   and the ceremony still needs to proceed.
//   --roadmap-ref <id> (raw#15, 2026-04-20) — required whenever
//   --exclude is used, forwarded verbatim to raw_all. id must resolve in
//   /.roadmap with status ∈ {active, blocked}.
//
// SUDO FAILURE
//   If target is at L2 and `sudo -n true` fails, hx_unlock prints:
//     "Level 2 requires sudo; either cache credentials (`sudo -v`)
//      and retry, or run `./hx downgrade` to drop to Level 1 first."
//   and exits non-zero without partial unlock.

use "self/stdlib/law_io"
use "tool/raw_audit"
use "tool/os_level_lock"
fn _is_darwin() -> bool {
    let uname = to_string(exec("uname -s")).trim()
    return uname == "Darwin"
}

fn _is_linux() -> bool {
    let uname = to_string(exec("uname -s")).trim()
    return uname == "Linux"
}

fn _has_passwordless_sudo() -> bool {
    let r = exec_with_status("sudo -n true 2>/dev/null")
    return r[1] == 0
}

fn _default_window() -> int { return 300 }
fn _max_window() -> int { return 3600 }

// ─── arg parsing ─────────────────────────────────────────────────

fn _parse_args() -> array {
    // returns [reason, actor, window_sec, ok, excludes(array-of-strings),
    //          roadmap_ref(string)]
    //
    // --exclude raw:<slug> is repeatable; entries are forwarded verbatim
    // to raw_all so matching rules appear as SKIP (excluded via --exclude).
    // --roadmap-ref <id> (raw#15, 2026-04-20): passed through to raw_all;
    // raw_all rejects --exclude/--fast without it.
    let av = argv()
    let mut reason = ""
    let mut actor = ""
    let mut window = _default_window()
    let mut excludes = []
    let mut roadmap_ref = ""
    let mut i = 2
    while i < len(av) {
        let a = av[i]
        if a == "--reason" {
            if i + 1 < len(av) { reason = av[i + 1]; i = i + 1 }
        } else if a == "--actor" {
            if i + 1 < len(av) { actor = av[i + 1]; i = i + 1 }
        } else if a == "--exclude" {
            if i + 1 < len(av) {
                let tok = av[i + 1]
                if tok != "" { excludes.push(tok) }
                i = i + 1
            }
        } else if a == "--roadmap-ref" {
            if i + 1 < len(av) {
                roadmap_ref = av[i + 1]
                i = i + 1
            }
        } else if a == "--window" {
            if i + 1 < len(av) {
                // parse integer
                let s = av[i + 1]
                let mut n = 0
                let mut j = 0
                while j < len(s) {
                    let c = s.substring(j, j + 1)
                    if c >= "0" && c <= "9" { n = n * 10 + (ord(c) - ord("0")) }
                    else { break }
                    j = j + 1
                }
                if n > 0 { window = n }
                i = i + 1
            }
        }
        i = i + 1
    }
    if actor == "" {
        actor = env("USER")
        if actor == "" { actor = to_string(exec("id -un")).trim() }
    }
    if window > _max_window() { window = _max_window() }
    let ok = reason != ""
    return [reason, actor, window, ok, excludes, roadmap_ref]
}

fn _usage() {
    eprintln("usage: hexa tool/hx_unlock.hexa --reason \"<text>\" [--actor NAME] [--window SEC] [--exclude raw:<slug>]... [--roadmap-ref <id>]")
    eprintln("")
    eprintln("  --reason        mandatory. Written verbatim to .raw-audit.")
    eprintln("  --actor         defaults to $USER.")
    eprintln("  --window        seconds until auto re-lock (default 300, max 3600).")
    eprintln("  --exclude       raw:<slug> — skip a specific enforcer in the gate")
    eprintln("                  run (repeatable). Used when an enforcer is")
    eprintln("                  structurally broken (e.g. seed-freeze).")
    eprintln("  --roadmap-ref   roadmap milestone id that justifies a bypass.")
    eprintln("                  REQUIRED when --exclude is used (raw#15).")
    eprintln("                  Must exist in /.roadmap with status active|blocked.")
    eprintln("")
    eprintln("  raw_all must return exit 0 — no --force override.")
    eprintln("  Escape hatch: tool/emergency/raw_reset.sh (sudo required).")
}

// ─── gate ────────────────────────────────────────────────────────

fn _run_raw_all(excludes: array, roadmap_ref: string) -> int {
    // Pass through --exclude raw:<slug> and --roadmap-ref <id> to raw_all.
    // Tokens are validated to slug shape (alnum + dash + colon only) so
    // they are safe to concatenate into the command line without quoting.
    // roadmap_ref is validated to [A-Za-z0-9_-] only (roadmap ids are
    // numeric today but the scheme is reserved for future slugs).
    let mut ex_args = ""
    for ex in excludes {
        if _is_safe_slug_token(ex) {
            ex_args = ex_args + " --exclude " + ex
        } else {
            eprintln("hx_unlock: WARN — ignoring malformed --exclude token: " + ex)
        }
    }
    if roadmap_ref != "" {
        if _is_safe_roadmap_id(roadmap_ref) {
            ex_args = ex_args + " --roadmap-ref " + roadmap_ref
        } else {
            eprintln("hx_unlock: WARN — ignoring malformed --roadmap-ref token: " + roadmap_ref)
        }
    }
    // HEXA_VAL_ARENA=0 prefix: raw_all itself spawns children with this
    // env; set it at the top-level invocation too so every interp process
    // in the tree (parent + enforcers) stays below arena OOM threshold.
    let cmd = "HEXA_VAL_ARENA=0 ./build/hexa_interp tool/raw_all.hexa" + ex_args + " 2>&1"
    let r = exec_with_status(cmd)
    let out = to_string(r[0])
    // echo raw_all output so developer sees what failed
    print(out)
    return r[1]
}

// interp string range-compare (`c >= "a"`) is unreliable on this build —
// use .contains() against an explicit whitelist instead (mirrors the
// fix applied in self/raw_loader.hexa _fmt_is_ident_char, 2026-04-17).
fn _safe_slug_charset() -> string {
    return "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789-_:"
}

fn _safe_roadmap_id_charset() -> string {
    return "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789-_"
}

fn _is_safe_roadmap_id(s: string) -> bool {
    // allowed: a-z A-Z 0-9 - _  (no colon — roadmap ids are plain).
    if s == "" { return false }
    let allowed = _safe_roadmap_id_charset()
    let mut i = 0
    while i < len(s) {
        let c = s.substring(i, i + 1)
        if !allowed.contains(c) { return false }
        i = i + 1
    }
    return true
}

fn _is_safe_slug_token(s: string) -> bool {
    // allowed chars: a-z A-Z 0-9 - _ : (for "raw:self-host-fixpoint" style)
    if s == "" { return false }
    let allowed = _safe_slug_charset()
    let mut i = 0
    while i < len(s) {
        let c = s.substring(i, i + 1)
        if !allowed.contains(c) { return false }
        i = i + 1
    }
    return true
}

// ─── per-target level snapshot + unlock ──────────────────────────

fn _all_targets() -> array {
    // 5 SSOT + raw#12 grandfather bans — same set os_level_lock handles
    return [".raw", ".own", ".ext", ".roadmap",
            "CLAUDE.md", "AGENTS.md", "CODEX.md",
            ".cursorrules", ".cursor", ".windsurfrules",
            ".aider.conf.yml", ".continuerules",
            ".github/copilot-instructions.md", ".claude"]
}

fn _path_exists(path: string) -> bool {
    let r = exec_with_status("test -e '" + path + "'")
    return r[1] == 0
}

fn _pwd() -> string {
    let mut p = env("PWD")
    if p == "" { p = to_string(exec("pwd")).trim() }
    return p
}

fn _snapshot_levels() -> array {
    // returns parallel array of "rel=level" strings — consumed by relock
    // daemon as inline args so the detached child can restore levels
    // without re-reading state after edits.
    let root = _pwd()
    let mut out = []
    for rel in _all_targets() {
        let abs = root + "/" + rel
        if !_path_exists(abs) { continue }
        let lvl = _detect_level(abs)
        out.push(rel + "=" + to_string(lvl))
    }
    return out
}

fn _serialize_levels(levels: array) -> string {
    // comma-separated; used as --prior-levels arg to hx_lock
    let mut s = ""
    let mut first = true
    for entry in levels {
        if first { s = entry; first = false }
        else     { s = s + "," + entry }
    }
    return s
}

// Returns rc; any L2 target failure on sudo short-circuits with a
// helpful message. All-or-nothing semantics — we refuse to leave a
// mix of locked / unlocked SSOT after exit.
fn _unlock_targets_leveled() -> int {
    let root = _pwd()
    // Pre-flight: if any target is L2, require passwordless sudo.
    let mut any_l2 = false
    for rel in _all_targets() {
        let abs = root + "/" + rel
        if !_path_exists(abs) { continue }
        if _detect_level(abs) >= 2 { any_l2 = true }
    }
    if any_l2 && !_has_passwordless_sudo() {
        eprintln("hx_unlock: one or more targets are at Level 2 (schg / root-immutable).")
        eprintln("  Passwordless sudo is unavailable (sudo -n true failed).")
        eprintln("")
        eprintln("  Options:")
        eprintln("    1) sudo -v       # cache credentials, then retry hx unlock")
        eprintln("    2) ./hx downgrade --reason \"temp edit\"   # L2 → L1, then unlock normally")
        return 1
    }
    // Delegate to os_level_lock's unlock — it is already level-aware.
    let r = exec_with_status("HEXA_VAL_ARENA=0 ./build/hexa_interp tool/os_level_lock.hexa unlock 2>&1")
    let out = to_string(r[0])
    print(out)
    return r[1]
}

// ─── relock daemon ───────────────────────────────────────────────

fn _spawn_relock(window_sec: int, reason: string, prior_levels: string) -> int {
    // Detach tool/relock_daemon.hexa (raw#1 P0d) so this script exits
    // but the child survives. The daemon itself reads .raw-audit for
    // the unlock anchor, sleeps the remainder of `window_sec`, then
    // invokes hx_lock.hexa --auto with the preserved prior-levels map.
    // Multiple concurrent daemons coexist safely — first to fire locks;
    // the rest observe "already locked" and record a noop audit entry.
    //
    // SPAWN FORM (2026-04-20 fix):
    //   interp's exec_with_status wraps the command in
    //   `{ <cmd> ; } 2>&1; echo ___HEXA_EXIT_$?` — if <cmd> ends with `&`
    //   the resulting `& ;` is a bash syntax error and the daemon never
    //   starts. Use the subshell form `( cmd & ) </dev/null` so the
    //   OUTER command ends with the redirect, not the backgrounder.
    let esc_prior = prior_levels.replace("\"", "'\\''")
    // HEXA_VAL_ARENA=0: daemon re-invokes hx_lock which itself spawns
    // interp gate checks. Keep arena off across the detached tree.
    // Subshell form `( cmd & ) </dev/null` so the OUTER command ends with
    // the redirect, not the backgrounder (avoids `& ;` syntax error).
    let cmd = "( env HEXA_VAL_ARENA=0 nohup ./build/hexa_interp tool/relock_daemon.hexa"
              + " --window " + to_string(window_sec)
              + " --prior-levels \"" + esc_prior + "\""
              + " >/dev/null 2>&1 & ) </dev/null"
    let r = exec_with_status(cmd)
    return r[1]
}

// ─── main ────────────────────────────────────────────────────────

fn main() -> int {
    // --selftest dispatch (coverage batch; parse-only marker, no side effects)
    let _av_st = argv()
    if len(_av_st) > 2 {
        let _a2_st = _av_st[2]
        if _a2_st == "--selftest" || _a2_st == "selftest" {
            println("[hx_unlock selftest] OK")
            exit(0)
        }
    }
    let args = _parse_args()
    let reason = args[0]
    let actor = args[1]
    let window = args[2]
    let ok = args[3]
    let excludes = args[4]
    let roadmap_ref = args[5]

    if !ok {
        _usage()
        return 2
    }

    if !_is_darwin() && !_is_linux() {
        eprintln("hx_unlock: unsupported OS — OS-level locks unavailable, exiting without action")
        return 0
    }

    println("── hx unlock (tiered) ──")
    println("actor:  " + actor)
    println("reason: " + reason)
    println("window: " + to_string(window) + "s")
    if len(excludes) > 0 {
        let mut parts = []
        for ex in excludes { parts.push(ex) }
        println("exclude: " + parts.join(", "))
    }
    if roadmap_ref != "" {
        println("roadmap-ref: " + roadmap_ref)
    }
    println("")

    // fingerprint BEFORE raw_all (we want the pre-unlock state hash)
    let sha_before = ssot_fingerprint()

    // snapshot per-target levels so relock daemon can restore
    let level_snapshot = _snapshot_levels()
    let prior_serialized = _serialize_levels(level_snapshot)

    // gate — raw_all must pass
    println("── gate: raw_all ──")
    let rc = _run_raw_all(excludes, roadmap_ref)
    if rc != 0 {
        eprintln("")
        eprintln("hx_unlock: refused — raw_all exit=" + to_string(rc))
        audit_append("unlock", actor, reason, "blocked", sha_before, "-")
        return 1
    }

    println("")
    println("── unlock ──")
    let urc = _unlock_targets_leveled()
    if urc != 0 {
        eprintln("hx_unlock: unlock failed exit=" + to_string(urc))
        audit_append("unlock", actor, reason, "fail", sha_before, "-")
        return 1
    }

    // audit: successful unlock (record prior level map in reason suffix)
    audit_append("unlock", actor,
                 reason + " [prior_levels=" + prior_serialized + "]",
                 "ok", sha_before, "-")

    // schedule re-lock with level restoration
    let src = _spawn_relock(window, reason, prior_serialized)
    if src != 0 {
        eprintln("hx_unlock: WARN — relock daemon spawn failed (will need manual ./hx lock)")
    }

    println("")
    println("── OK ──")
    println("SSOT unlocked for " + to_string(window) + "s.")
    println("Auto re-lock at T+" + to_string(window) + "s (best effort, level-restoring).")
    println("Prefer explicit: ./hexa tool/hx_lock.hexa   when done editing.")
    return 0
}

// ─── is_main guard (import side-effect firewall) ────────────────

let _av_main = argv()

fn _is_main() -> bool {
    if len(_av_main) < 2 { return false }
    let script = _av_main[1]
    if script.ends_with("/hx_unlock.hexa") { return true }
    if script == "hx_unlock.hexa" { return true }
    return false
}

if _is_main() { exit(main()) }
