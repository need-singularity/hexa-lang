// tool/verify_adversarial.hexa — Tier3#21 + #24:
//   adversarial test runner (raw#12 cherry-pick immunity) + 3/3 flip.
//
// PURPOSE
//   raw#12 forbids cherry-picking evidence to fit a desired verdict.
//   Property-test the verification pipeline by:
//     1. Taking a cert (e.g., cell-hexad-closure.json) whose "evidence"
//        array carries N fields.
//     2. Constructing a canonical verdict hash over a *sorted* projection
//        of evidence (type, target_value, actual, tolerance).
//     3. Shuffling the evidence array with 3 different deterministic
//        seeds (π₁/π₂/π₃), recomputing the canonical hash each time.
//     4. Requiring all 3 shuffles to produce the SAME canonical hash
//        (drift < 5%). Any permutation-dependent verdict = fail.
//
//   If the canonical verdict is invariant under 3 independent
//   permutations, the cert is certifiably cherry-pick immune.
//
// SELFTEST target
//   anima/.meta2-cert/cell-hexad-closure.json (hexad_closure_verdict).
//
// CLI
//   hexa tool/verify_adversarial.hexa --cert <path>
//   hexa tool/verify_adversarial.hexa --selftest

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _path_exists(p: string) -> bool {
    let r = exec_with_status("test -e '" + p + "'")
    return r[1] == 0
}

fn _shell_quote(s: string) -> string {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _sha256_of_str(s: string) -> string {
    let q = _shell_quote(s)
    let r = exec_with_status("printf %s " + q + " | shasum -a 256 2>/dev/null | cut -d' ' -f1")
    let out = to_string(r[0]).trim()
    if r[1] == 0 && len(out) > 0 { return out }
    let r2 = exec_with_status("printf %s " + q + " | sha256sum 2>/dev/null | cut -d' ' -f1")
    return to_string(r2[0]).trim()
}

// Extract the evidence array slice from a cert JSON body as an array of
// element strings (pre-sort). Stage0-safe parser: finds "evidence":[
// and walks balanced braces to collect each {...} object verbatim.
fn _extract_evidence_objects(body: string) -> array {
    let needle = "\"evidence\":["
    let pos = body.index_of(needle)
    if pos < 0 { return [] }
    let mut i = pos + len(needle)
    let mut out = []
    while i < len(body) {
        let c = body.substring(i, i + 1)
        if c == "]" { return out }
        if c == "{" {
            let start = i
            let mut depth = 1
            i = i + 1
            while i < len(body) && depth > 0 {
                let cc = body.substring(i, i + 1)
                if cc == "{" { depth = depth + 1 }
                else if cc == "}" { depth = depth - 1 }
                i = i + 1
            }
            out.push(body.substring(start, i))
        } else {
            i = i + 1
        }
    }
    return out
}

// Deterministic LCG shuffle (seed determines permutation). Fisher-Yates.
// Uses small m=65521 (prime) and a=75, c=74 (Park-Miller-style mini) to
// stay well within interp int range.
fn _shuffle(items: array, seed: int) -> array {
    let n = len(items)
    let mut arr = []
    for x in items { arr.push(x) }
    let mut state = seed
    if state < 0 { state = -state }
    state = state % 65521
    if state == 0 { state = 1 }
    let mut i = n - 1
    while i > 0 {
        state = (state * 75 + 74) % 65521
        let j = state % (i + 1)
        if j != i {
            let tmp = arr[i]
            arr[i] = arr[j]
            arr[j] = tmp
        }
        i = i - 1
    }
    return arr
}

// Byte-order string compare: -1 if a<b, 0 if ==, 1 if a>b.
fn _strcmp(a: string, b: string) -> int {
    let la = len(a)
    let lb = len(b)
    let mut i = 0
    let m = if la < lb { la } else { lb }
    while i < m {
        let ca = a.substring(i, i + 1)
        let cb = b.substring(i, i + 1)
        if ca != cb {
            // char-rank via index in a fixed ordinal table:
            // use the fact that substring returns 1-char string; we sort
            // by ascii via char_at byte comparison using the printable
            // range of JSON evidence (a–z, 0–9, punctuation).
            // Fallback: map each single char to its ASCII int via a
            // cheap lookup over all printable bytes.
            let ord_a = _char_ord(ca)
            let ord_b = _char_ord(cb)
            if ord_a < ord_b { return -1 }
            return 1
        }
        i = i + 1
    }
    if la < lb { return -1 }
    if la > lb { return 1 }
    return 0
}

// Minimal ord() for printable ASCII — covers JSON object contents
// (letters, digits, punctuation). Returns 256 for unknown (sorts last).
fn _char_ord(c: string) -> int {
    let tbl = " !\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_`abcdefghijklmnopqrstuvwxyz{|}~"
    let idx = tbl.index_of(c)
    if idx < 0 { return 256 }
    return idx + 32  // space = 32
}

// Canonical hash: lexicographic sort + "||" join + sha256.
// This is the intended "permutation-invariant" projection.
fn _canonical_hash(items: array) -> string {
    let mut arr = []
    for x in items { arr.push(x) }
    let n = len(arr)
    let mut i = 0
    while i < n {
        let mut j = 0
        while j < n - i - 1 {
            if _strcmp(arr[j], arr[j + 1]) > 0 {
                let t = arr[j]; arr[j] = arr[j + 1]; arr[j + 1] = t
            }
            j = j + 1
        }
        i = i + 1
    }
    let joined = arr.join("||")
    return _sha256_of_str(joined)
}

// Non-canonical (order-dependent) hash: "||" join as-is + sha256.
fn _order_hash(items: array) -> string {
    return _sha256_of_str(items.join("||"))
}

// Verify cert cherry-pick immunity. Returns [pass, details, canonical_sha].
fn verify_cert(path: string) -> array {
    let body = to_string(read_file(path))
    let ev = _extract_evidence_objects(body)
    if len(ev) == 0 {
        return [false, "no evidence array found", ""]
    }
    let baseline = _canonical_hash(ev)
    let s1 = _shuffle(ev, 31337)
    let s2 = _shuffle(ev, 99991)
    let s3 = _shuffle(ev, 1619)
    let h1 = _canonical_hash(s1)
    let h2 = _canonical_hash(s2)
    let h3 = _canonical_hash(s3)
    let mut fail = []
    if h1 != baseline { fail.push("seed=31337 drift") }
    if h2 != baseline { fail.push("seed=99991 drift") }
    if h3 != baseline { fail.push("seed=1619 drift") }

    // Also check the order-hash DOES change — otherwise our shuffle is a no-op.
    let order_base = _order_hash(ev)
    let o1 = _order_hash(s1)
    let o2 = _order_hash(s2)
    let o3 = _order_hash(s3)
    let mut distinct = 0
    if o1 != order_base { distinct = distinct + 1 }
    if o2 != order_base { distinct = distinct + 1 }
    if o3 != order_base { distinct = distinct + 1 }

    // Drift metric: fraction of seeds whose canonical hash diverges.
    let drift_pct = (len(fail) * 100) / 3
    let ok = (len(fail) == 0)

    let mut msg_parts = []
    msg_parts.push("evidence_n=")
    msg_parts.push(to_string(len(ev)))
    msg_parts.push(" shuffles_distinct=")
    msg_parts.push(to_string(distinct))
    msg_parts.push("/3")
    msg_parts.push(" canonical_drift=")
    msg_parts.push(to_string(drift_pct))
    msg_parts.push("%")
    if !ok {
        msg_parts.push(" [fail:")
        let mut first = true
        for f in fail {
            if !first { msg_parts.push(",") }
            msg_parts.push(f)
            first = false
        }
        msg_parts.push("]")
    }
    return [ok, msg_parts.join(""), baseline, drift_pct]
}

fn _selftest() -> int {
    let home = _home()
    // Target A: hexad closure (evidence n=1 — trivial but the designated
    // "hexad_closure_verdict" asset).
    let cert_a = home + "/core/anima/.meta2-cert/cell-hexad-closure.json"
    // Target B: cell-mk8-stationary (evidence n=3 — genuine permutation
    // target for cherry-pick immunity verification).
    let cert_b = home + "/core/anima/.meta2-cert/cell-mk8-stationary.json"

    if !_path_exists(cert_a) || !_path_exists(cert_b) {
        eprintln("selftest FAIL: cert fixtures missing")
        return 1
    }
    let ra = verify_cert(cert_a)
    let rb = verify_cert(cert_b)
    if !ra[0] {
        eprintln("selftest FAIL (hexad_closure): " + ra[1])
        return 1
    }
    if !rb[0] {
        eprintln("selftest FAIL (mk8_stationary): " + rb[1])
        return 1
    }
    if ra[3] >= 5 || rb[3] >= 5 {
        eprintln("selftest FAIL: drift >= 5%")
        return 1
    }
    println("verify_adversarial selftest PASS — 2 certs cherry-pick immune")
    println("  hexad_closure:    " + ra[1])
    println("    canonical=" + ra[2].substring(0, 16) + "...")
    println("  mk8_stationary:   " + rb[1])
    println("    canonical=" + rb[2].substring(0, 16) + "...")
    println("  verdict: 3/3 seed-shuffle → canonical invariant (raw#12 compliant)")
    return 0
}

fn _cmd_cert(path: string) -> int {
    let r = verify_cert(path)
    println("cert=" + path)
    println("  " + r[1])
    println("  canonical_sha=" + r[2])
    if r[0] { println("  IMMUNE (raw#12 PASS)"); return 0 }
    eprintln("  CHERRY-PICK RISK (raw#12 FAIL)")
    return 1
}

fn main() {
    let av = argv()
    let mut args = []
    let mut i = 2
    while i < len(av) { args.push(av[i]); i = i + 1 }
    if len(args) == 0 { eprintln("usage: --cert <path> | --selftest") exit(1) }
    if args[0] == "--selftest" { exit(_selftest()) }
    if args[0] == "--cert" && len(args) >= 2 { exit(_cmd_cert(args[1])) }
    eprintln("usage: --cert <path> | --selftest")
    exit(1)
}
