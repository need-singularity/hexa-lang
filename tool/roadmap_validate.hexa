// tool/roadmap_validate.hexa — Tier1#2 (roadmap 34): field validator
//
// PURPOSE
//   Validates required/standard fields on each roadmap entry. Enforces
//   raw#15 field contract (track, phase, eta, why) + raw#10 proof-carrying
//   symmetry (done → proof must exist; exit_criteria highly recommended).
//
// RULES
//   R1  header status ∈ {planned, active, done, blocked, deferred}
//   R2  required keys present: track, phase, eta, why
//   R3  eta matches one of: YYYY-MM-DD | YYYY-Qn | YYYY-Hn | YYYY | TBD
//   R4  status=done ⇒ `proof` key present
//   R5  exit_criteria is a RECOMMENDED key (warn-level) — not required
//   R6  depends-on if present, must tokenize (numeric ids or repo@N refs)
//   R7  reaches if present, must reference a declared checkpoint or track/phase
//
// CLI
//   hexa tool/roadmap_validate.hexa <path> [--strict]
//   hexa tool/roadmap_validate.hexa --selftest
//
// EXIT
//   0 → all entries pass strict rules
//   1 → ≥1 error-level violation

fn _rstrip(s: string) -> string {
    let mut end = len(s)
    while end > 0 {
        let c = s.substring(end - 1, end)
        if c == " " || c == "\t" || c == "\r" { end = end - 1 } else { break }
    }
    return s.substring(0, end)
}

// pull in parser via exec hop (keep module boundary clean): re-declare the
// minimal parser here. Duplication is accepted (raw#9 hexa-only, no hexa
// module system resolution from arbitrary CWD).
fn _parse_hdr_roadmap(line: string) -> array {
    let sp1 = line.index_of(" ")
    if sp1 < 0 { return [] }
    if line.substring(0, sp1) != "roadmap" { return [] }
    let rest1 = line.substring(sp1 + 1, len(line))
    let sp2 = rest1.index_of(" ")
    if sp2 < 0 { return [] }
    let id = rest1.substring(0, sp2)
    let rest2 = rest1.substring(sp2 + 1, len(rest1))
    let sp3 = rest2.index_of(" ")
    if sp3 < 0 { return [] }
    let status = rest2.substring(0, sp3)
    let mut name = rest2.substring(sp3 + 1, len(rest2)).trim()
    if len(name) >= 2 && name.substring(0, 1) == "\"" {
        name = name.substring(1, len(name) - 1)
    }
    return [id, status, name]
}

fn _parse_hdr_cp(line: string) -> array {
    let sp1 = line.index_of(" ")
    if sp1 < 0 { return [] }
    if line.substring(0, sp1) != "checkpoint" { return [] }
    let rest1 = line.substring(sp1 + 1, len(line))
    let sp2 = rest1.index_of(" ")
    if sp2 < 0 { return [] }
    let id = rest1.substring(0, sp2)
    let mut name = rest1.substring(sp2 + 1, len(rest1)).trim()
    if len(name) >= 2 && name.substring(0, 1) == "\"" {
        name = name.substring(1, len(name) - 1)
    }
    return [id, name]
}

fn parse_roadmap_text(src: string) -> array {
    let lines = split(src, "\n")
    let mut rules = []
    let mut cps = []
    let mut kind = ""
    let mut cid = ""
    let mut cst = ""
    let mut cnm = ""
    let mut ck = []
    for raw_line in lines {
        let line = _rstrip(raw_line)
        if len(line) == 0 {
            if kind == "r" { rules.push([cid, cst, cnm, ck]) }
            if kind == "c" { cps.push([cid, cnm, ck]) }
            kind = ""
            ck = []
            continue
        }
        let first = line.substring(0, 1)
        if first == "#" { continue }
        if first == " " || first == "\t" {
            if kind == "" { continue }
            let st = line.trim_start()
            let sp = st.index_of(" ")
            if sp < 0 { continue }
            let k = st.substring(0, sp)
            let v = st.substring(sp + 1, len(st)).trim()
            ck.push([k, v])
        } else {
            if kind == "r" { rules.push([cid, cst, cnm, ck]) }
            if kind == "c" { cps.push([cid, cnm, ck]) }
            ck = []
            kind = ""
            let fs = line.index_of(" ")
            if fs < 0 { continue }
            let tok = line.substring(0, fs)
            if tok == "roadmap" {
                let h = _parse_hdr_roadmap(line)
                if len(h) == 0 { continue }
                cid = h[0]; cst = h[1]; cnm = h[2]; kind = "r"
            }
            if tok == "checkpoint" {
                let h = _parse_hdr_cp(line)
                if len(h) == 0 { continue }
                cid = h[0]; cnm = h[1]; kind = "c"
            }
        }
    }
    if kind == "r" { rules.push([cid, cst, cnm, ck]) }
    if kind == "c" { cps.push([cid, cnm, ck]) }
    return [rules, cps]
}

fn _load(path: string) -> array {
    let r = exec_with_status("test -f '" + path + "'")
    if r[1] != 0 { return [[], []] }
    return parse_roadmap_text(to_string(read_file(path)))
}

fn _kv_find(keys: array, k: string) -> string {
    for kv in keys { if kv[0] == k { return kv[1] } }
    return ""
}

fn _valid_status(s: string) -> bool {
    if s == "planned" || s == "active" || s == "done" || s == "blocked" || s == "deferred" { return true }
    return false
}

fn _is_digit(c: string) -> bool {
    let digits = "0123456789"
    return digits.contains(c)
}

fn _all_digits(s: string) -> bool {
    if len(s) == 0 { return false }
    let mut i = 0
    while i < len(s) { if !_is_digit(s.substring(i, i + 1)) { return false } i = i + 1 }
    return true
}

fn _valid_eta(s: string) -> bool {
    if s == "TBD" { return true }
    let n = len(s)
    if n == 4 { return _all_digits(s) }
    if n == 7 {
        if !_all_digits(s.substring(0, 4)) { return false }
        if s.substring(4, 5) != "-" { return false }
        let m = s.substring(5, 6)
        let d = s.substring(6, 7)
        if m == "Q" {
            if d == "1" || d == "2" || d == "3" || d == "4" { return true }
            return false
        }
        if m == "H" {
            if d == "1" || d == "2" { return true }
            return false
        }
        return false
    }
    if n == 10 {
        let mut i = 0
        while i < 10 {
            let c = s.substring(i, i + 1)
            if i == 4 || i == 7 { if c != "-" { return false } }
            else { if !_is_digit(c) { return false } }
            i = i + 1
        }
        return true
    }
    return false
}

// depends-on value tokenizer — returns first token is ok (numeric or repo@N)
fn _valid_depends_token(tok: string) -> bool {
    if _all_digits(tok) { return true }
    // repo@N pattern: repo has letters/dashes, @ separator, digits after
    let at = tok.index_of("@")
    if at > 0 && at < len(tok) - 1 {
        let after = tok.substring(at + 1, len(tok))
        return _all_digits(after)
    }
    return false
}

// Returns [errors: array, warnings: array].
fn validate(rules: array, cps: array) -> array {
    let mut errs = []
    let mut warns = []
    for r in rules {
        let id = r[0]
        let st = r[1]
        let keys = r[3]
        let prefix = "#" + id + " "
        if !_valid_status(st) {
            errs.push(prefix + "R1: invalid header status '" + st + "'")
        }
        for req in ["track", "phase", "eta", "why"] {
            let v = _kv_find(keys, req)
            if len(v) == 0 { errs.push(prefix + "R2: missing required key '" + req + "'") }
        }
        let eta = _kv_find(keys, "eta")
        if len(eta) > 0 && !_valid_eta(eta) {
            errs.push(prefix + "R3: eta format invalid: '" + eta + "'")
        }
        if st == "done" {
            let pf = _kv_find(keys, "proof")
            let nt = _kv_find(keys, "note")
            if len(pf) == 0 && len(nt) == 0 {
                errs.push(prefix + "R4: status=done requires 'proof' or 'note'")
            }
        }
        let ec = _kv_find(keys, "exit_criteria")
        if len(ec) == 0 && st != "done" && st != "deferred" {
            warns.push(prefix + "R5: no exit_criteria (recommended)")
        }
        let dep = _kv_find(keys, "depends-on")
        if len(dep) > 0 && dep != "—" {
            // split on comma + whitespace
            let parts = split(dep.replace(",", " "), " ")
            for p in parts {
                let t = p.trim()
                if len(t) == 0 { continue }
                if !_valid_depends_token(t) {
                    warns.push(prefix + "R6: depends-on token unrecognized: '" + t + "'")
                }
            }
        }
    }
    return [errs, warns]
}

// ─── selftest ───────────────────────────────────────────────────────
fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _run_path(path: string, strict: bool) -> int {
    let out = _load(path)
    let v = validate(out[0], out[1])
    let errs = v[0]
    let warns = v[1]
    println("validate: " + path + " errors=" + to_string(len(errs)) + " warnings=" + to_string(len(warns)))
    for e in errs { eprintln("  ERROR " + e) }
    if strict { for w in warns { eprintln("  WARN  " + w) } }
    if len(errs) > 0 { return 1 }
    return 0
}

fn _selftest() -> int {
    let home = _home()
    // Run on 3 real repos in report-only mode (discovers real data issues).
    for repo in ["anima", "airgenome", "hexa-lang"] {
        let p = home + "/core/" + repo + "/.roadmap"
        let _ = _run_path(p, false)
    }
    // synthesized failing sample — must produce errors
    let bad = "roadmap 999 frobnicate \"x\"\n  track foo\n"
    let parsed = parse_roadmap_text(bad)
    let v = validate(parsed[0], parsed[1])
    if len(v[0]) < 2 {
        eprintln("selftest FAIL: bad sample did not produce ≥2 errors (got " + to_string(len(v[0])) + ")")
        return 1
    }
    // synthesized passing sample — must produce 0 errors
    let good = "roadmap 1 done \"ok\"\n  track ssot\n  phase P0\n  eta 2026-04-20\n  why x\n  proof x.hexa\n"
    let pg = parse_roadmap_text(good)
    let vg = validate(pg[0], pg[1])
    if len(vg[0]) != 0 {
        eprintln("selftest FAIL: good sample produced errors")
        for e in vg[0] { eprintln("  " + e) }
        return 1
    }
    println("selftest PASS (invariants + real-repo survey ok)")
    return 0
}

fn main() {
    let av = argv()
    let mut args = []
    let mut i = 2
    while i < len(av) { args.push(av[i]); i = i + 1 }

    if len(args) == 0 {
        eprintln("usage: hexa tool/roadmap_validate.hexa <path|--selftest> [--strict]")
        exit(1)
    }
    if args[0] == "--selftest" { exit(_selftest()) }

    let path = args[0]
    let mut strict = false
    let mut j = 1
    while j < len(args) { if args[j] == "--strict" { strict = true } j = j + 1 }
    exit(_run_path(path, strict))
}
