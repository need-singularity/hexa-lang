// tool/status_transition_proposer.hexa — Phase 3.1 status auto-transition proposer (stub).
//
// SPEC: docs/roadmap_engine_continuous_meta_proposal_20260422.md §Phase 3.1.
// STATUS: stub — skeleton + --selftest only.
//
// PURPOSE
//   For each entry, propose status transitions:
//     - probe 100% PASS → "should_be_done"
//     - active 30d+ no-change → "stale_active"
//     - planned + all deps done → "ready_to_activate"
//   Read-only / propose-only (never mutates .roadmap).
//
// CLI
//   hexa tool/status_transition_proposer.hexa --selftest
//   hexa tool/status_transition_proposer.hexa --repo <name> [--out <path>]
//
// OUTPUT
//   $HEXA_LANG/state/status_transition_proposals_<repo>.json
//   $HEXA_LANG/docs/proposed_status_transitions_<repo>.md (human review)
//   schema = "hexa-lang/status_transition_proposals/1"

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _iso_now() -> string {
    return to_string(exec("date -u +'%Y-%m-%dT%H:%M:%SZ'")).trim()
}

fn _arg_value(args: array, key: string, default: string) -> string {
    let mut i = 0
    while i < len(args) {
        if args[i] == key {
            let j = i + 1
            if j < len(args) { return args[j] }
        }
        i = i + 1
    }
    return default
}

fn _selftest() -> int {
    if len(_iso_now()) < 10 {
        eprintln("status_transition_proposer: selftest FAIL (iso_now empty)")
        return 1
    }
    println("status_transition_proposer: selftest PASS (stub)")
    return 0
}

fn _emit(repo: string, out_path: string) -> int {
    let ts = _iso_now()
    let body = "{\n  \"schema\": \"hexa-lang/status_transition_proposals/1\",\n  \"ts\": \"" + ts + "\",\n  \"repo\": \"" + repo + "\",\n  \"status\": \"stub\",\n  \"proposals\": [],\n  \"summary\": {\"should_be_done\": 0, \"stale_active\": 0, \"ready_to_activate\": 0}\n}\n"
    try {
        write_file(out_path, body)
    } catch e {
        eprintln("status_transition_proposer: write FAIL " + out_path)
        return 1
    }
    println("status_transition_proposer: wrote " + out_path + " (stub)")
    return 0
}

fn main() {
    let av = argv()
    let mut args = []
    let mut i = 2
    while i < len(av) { args.push(av[i]); i = i + 1 }

    if len(args) >= 1 && args[0] == "--selftest" {
        exit(_selftest())
    }

    let repo = _arg_value(args, "--repo", "anima")
    let default_out = _home() + "/core/hexa-lang/state/status_transition_proposals_" + repo + ".json"
    let out_path = _arg_value(args, "--out", default_out)
    exit(_emit(repo, out_path))
}
