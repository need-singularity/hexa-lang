// tool/roadmap_logic.hexa — 로드맵 3대 안정 로직 카탈로그 (ai-native)
//
// HX11 self-format — @catalog + `let _<suffix> = #{...}` 맵 리터럴.
// 소비자: hexa parse 통과, project_parser 텍스트 스캔으로 entries 추출 가능.
// 소유자: hexa-lang (tool/). 7-project 공용 참조는 use "tool/roadmap_logic".

@catalog(
    name    = "roadmap_stability_logic",
    version = "1.0",
    owner   = "hexa-lang",
    scope   = "cross-project"
)
let _catalog_meta = #{
    "name": "roadmap_stability_logic",
    "version": "1.0",
    "owner": "hexa-lang",
    "scope": "cross-project",
    "updated": "2026-04-22"
}

// ─── 로직 ① — 안정착지 (fixpoint bisection) ───────────────────────
@logic(id="fixpoint", shape="monotonic_good_to_bad")
let _logic_fixpoint = #{
    "id": "fixpoint",
    "ko": "안정착지",
    "shape": "good → bad 단조 전이, 경계 탐색",
    "math_name": "Banach fixpoint + bisection",
    "operational_name": "ossification (L1 → L0 승급)",
    "invariant": "SHA256(hexa_2) == SHA256(hexa_3)  // v3==v4 byte-identical",
    "checkpoint": "CP1 — hexa tool/bench.hexa --verify 18/18",
    "tools": [
        "tool/fixpoint_bisect.hexa",
        "tool/fixpoint_archive.hexa",
        "tool/fixpoint_v3_v4.hexa",
        "tool/verify_fixpoint.hexa",
        "tool/p7_7_fixpoint_check.hexa"
    ],
    "verdict_map": #{
        "exit_0": "good (fixpoint reached)",
        "exit_2": "bad (drift)",
        "other": "skip (compile fail)"
    },
    "use_cases": [
        "self-host interp fixpoint (raw#0 P7)",
        "cross-platform v3==v4 (arm64 ↔ x86_64)",
        "drift commit bisection (last-30d)"
    ]
}

// ─── 로직 ② — 천장·바닥 bad, 중간 good (unimodal bracketing) ──────
@logic(id="bracket", shape="unimodal_interior_optimum")
let _logic_bracket = #{
    "id": "bracket",
    "ko": "천장·바닥 bad, 중간 good",
    "shape": "양끝 bad, 내부 유일 극값 (계곡 포위)",
    "math_name": "ternary search / golden section search",
    "operational_name": "corridor / operating envelope / Goldilocks band",
    "invariant": "eval(lo) > eval(x*) < eval(hi)  // unimodal",
    "tools": [
        "tool/bracket.hexa"
    ],
    "api": #{
        "bracket_ternary": "(lo, hi, eval_fn, eps) -> x*   // 3-분 탐색",
        "bracket_golden":  "(lo, hi, eval_fn, eps) -> x*   // φ-비율 재사용",
        "bracket_discrete": "(lo, hi, eval_fn) -> i*       // 정수 인덱스"
    },
    "use_cases": [
        "shard_cv ∈ [0.05, 3.0] — 양끝 bad 구간 내부 최적",
        "|ΔΦ|/Φ < 0.05 corridor — ε-strict Phase Gate",
        "η_k 작동 창 (너무 낮으면 정체, 너무 높으면 overshoot)",
        "batch/lr/rank 등 하이퍼파라미터 단봉 탐색"
    ]
}

// ─── 로직 ③ — 잘게 쪼개기 (Bellman + DAG atomization) ────────────
@logic(id="atomize", shape="recursive_subproblem_decomposition")
let _logic_atomize = #{
    "id": "atomize",
    "ko": "잘게 쪼개기",
    "shape": "목표 → atom(node) 분해 → 부분문제 재귀",
    "math_name": "Bellman principle of optimality + DAG topological partition",
    "operational_name": "atomization / WBS / divide-and-conquer",
    "formula": "V*(S) = min_a [ b_a(S) + V*(f(S,a)) ],  V*(G)=0,  π*(S) = argmin",
    "t_star": "T*(S0→G) = inf_π Σ_k max_{i∈Ω} c_i(S_k^π)   s.t. Σ ΔI_k ≥ K(G|S0), η_k > 0",
    "omega_axes": ["build", "exp", "learn", "boot", "verify"],
    "tools": [
        "tool/roadmap_engine.hexa",
        "tool/roadmap_dag.hexa",
        "tool/raw_dag.hexa",
        "tool/roadmap_span_dag.hexa"
    ],
    "primitives": #{
        "kahn_ready_set": "|R(t)| >= 1",
        "b_star": "지배병목 — 다른 경로 현상유지, b* 만 attack",
        "eta_test": "η_k = 1 - b(S_{k+1}) / b(S_k);  η>0 ⟹ T*<∞;  η=0 ⟹ replan",
        "soft_deps_drop": "η=0 감지 시 edge 제거 후보 제안"
    },
    "use_cases": [
        "로드맵 전체 → node(atom) 단위 분해 + critical path 추출",
        "Mk.X T10-13 atoms ossified (≥10 atoms, novelty yield ≥3/10)",
        "raw-rule DAG / spanDAG (span=Brent T∞)",
        "bottleneck shift 실시간 감지 (JSONL event stream)"
    ]
}

// ─── 상호 관계 ─────────────────────────────────────────────────
@logic_triad
let _logic_triad = #{
    "pipeline": [
        "atomize → fixpoint → bracket",
        "① 목표를 atom 으로 쪼갠다 (③)",
        "② 각 atom 을 bracket 으로 튜닝한다 (②)",
        "③ 전체 결과를 fixpoint 로 안정착지 확인한다 (①)"
    ],
    "topology_contrast": #{
        "fixpoint":  "monotonic — good → bad 경계 찾기 (bisection)",
        "bracket":   "unimodal  — 내부 최적 찾기 (ternary/golden)",
        "atomize":   "recursive — 부분문제 분해 (Bellman + DAG)"
    },
    "closure_check": #{
        "fixpoint_reached": "SHA256 v3==v4",
        "bracket_converged": "(hi - lo) < eps",
        "atomize_complete":  "V*(G) == 0 && |R(t)| >= 1 유지"
    }
}

// ─── 엔트리 포인트 ─────────────────────────────────────────────
// `hexa tool/roadmap_logic.hexa` 로 실행 시 카탈로그를 print.
// `use "tool/roadmap_logic"` 로 다른 hexa 에서 map 참조.

fn _print_logic(label, m) {
    print("  ["); print(label); print("] ")
    println(m["ko"])
    print("      shape: "); println(m["shape"])
    print("      math : "); println(m["math_name"])
    print("      ops  : "); println(m["operational_name"])
}

fn cmd_selftest() -> i64 {
    println("[roadmap_logic selftest]")
    // 1) catalog meta matches declared scope
    if _catalog_meta["name"] != "roadmap_stability_logic" {
        eprintln("FAIL: catalog name drift"); return 1
    }
    if _catalog_meta["version"] != "1.0" {
        eprintln("FAIL: catalog version drift"); return 1
    }
    // 2) each of the 3 logic entries carries id + ko + shape
    if _logic_fixpoint["id"] != "fixpoint" { eprintln("FAIL: fixpoint id"); return 1 }
    if _logic_bracket["id"] != "bracket"   { eprintln("FAIL: bracket id"); return 1 }
    if _logic_atomize["id"] != "atomize"   { eprintln("FAIL: atomize id"); return 1 }
    // 3) triad pipeline label invariant
    let pipe = _logic_triad["pipeline"]
    if len(pipe) < 1 { eprintln("FAIL: triad pipeline empty"); return 1 }
    println("[roadmap_logic selftest] OK")
    return 0
}

fn main() {
    // --selftest dispatch: scan argv for --selftest / selftest (post-normalization
    // irrelevant — catalog file, no args consumed; accept either form).
    let av = args()
    let mut i = 0
    while i < len(av) {
        let a = av[i]
        if a == "--selftest" || (i >= 2 && a == "selftest") {
            exit(cmd_selftest())
        }
        i = i + 1
    }
    println("roadmap_stability_logic v1.0 — hexa-lang/tool/")
    println("")
    _print_logic("①", _logic_fixpoint)
    _print_logic("②", _logic_bracket)
    _print_logic("③", _logic_atomize)
    println("")
    println("pipeline: atomize → bracket → fixpoint")
    println("  ③ 쪼개고  →  ② 튜닝하고  →  ① 안정착지 확인")
}
