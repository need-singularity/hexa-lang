// tool/hexa_only_lint.hexa — raw#9 entry (HEXA-ONLY file extension ban)
//
// usage:
//   hexa tool/hexa_only_lint.hexa                — staged 파일 scan (git diff --cached), exit 1 on violation
//   hexa tool/hexa_only_lint.hexa --list         — ban list 출력 (debug 용)
//   hexa tool/hexa_only_lint.hexa --selftest     — synthetic-fixture self-test (returns 0/1)
//   hexa tool/hexa_only_lint.hexa --root <path>  — filesystem walk under <path>; only
//                                                  git-untracked banned-ext files are
//                                                  flagged (tracked = grandfathered, same
//                                                  contract as foreign_ext_sweep.hexa).
//
// exit code:
//   0 — violation 0 (pass)
//   1 — violation 1+ (block)
//
// rule: .raw#9 — HEXA-ONLY. .rs / .toml / .py / .sh 확장자의 신규 파일 커밋 차단.
// (audit-2026-04-26: file was historically labelled raw#8 pre-renumber; the
// canonical hive raw#9 identifier is current.)
// semantics: 기존 파일 grandfather — staged add/modify (git diff --cached --diff-filter=ACMR) 만 검사.
// --root 모드 추가 (2026-04-26): foreign_ext_sweep.hexa 의 워킹 트리 스캔 컨트랙트와
// 동일하게 git-untracked 만 violation 으로 처리. hive 의 packages/ 등 임의 경로 검사 가능.
// history: 2026-04-19 git-hook 전면 폐기 후 기존 pre-commit 인라인 grep 로직 (HX4) 을 hexa 로 포팅.

let _raw_args = args()
let mut cli = []
let mut ai = 2
while ai < len(_raw_args) {
    cli.push(_raw_args[ai])
    ai = ai + 1
}

// ban suffix list (확장자)
let banned_exts = [".rs", ".toml", ".py", ".sh"]

fn has_banned_ext(path) {
    let mut i = 0
    while i < len(banned_exts) {
        if path.ends_with(banned_exts[i]) { return true }
        i = i + 1
    }
    return false
}

fn list_bans() {
    println("HEXA-ONLY (raw#9) — banned file extensions:")
    let mut i = 0
    while i < len(banned_exts) {
        println("  " + banned_exts[i])
        i = i + 1
    }
    println("")
    println("rule: staged add/modify (git diff --cached --diff-filter=ACMR) 에서 이들 확장자 신규 파일 = block")
    println("grandfather: 이미 tracked 된 파일은 본 lint 가 삭제하지 않음")
}

if len(cli) > 0 && cli[0] == "--list" {
    list_bans()
    exit(0)
}

fn cmd_selftest() {
    println("[hexa_only_lint selftest]")
    // has_banned_ext: every banned ext must register, .hexa must not.
    let mut i = 0
    while i < len(banned_exts) {
        let probe = "foo" + banned_exts[i]
        if !has_banned_ext(probe) {
            eprintln("[hexa_only_lint selftest] FAIL has_banned_ext positive " + probe)
            exit(1)
        }
        i = i + 1
    }
    if has_banned_ext("foo.hexa") {
        eprintln("[hexa_only_lint selftest] FAIL has_banned_ext negative .hexa")
        exit(1)
    }

    // --root walk: build a temp dir with one tracked .py (grandfathered)
    // and one untracked .sh (violation). Walk should report exactly 1 hit.
    let setup = "d=$(mktemp -d /tmp/hexa_only_lint_st_XXXXXX); cd \"$d\"; git init -q; touch tracked.py; git add tracked.py; git -c user.email=t@t -c user.name=t commit -q -m s; touch untracked.sh; echo \"$d\""
    let tmp = to_string(exec(setup)).trim()
    if len(tmp) == 0 {
        eprintln("[hexa_only_lint selftest] FAIL tmp setup empty")
        exit(1)
    }
    let hits = scan_root(tmp)
    exec("rm -rf '" + tmp + "' 2>/dev/null")
    if len(hits) != 1 {
        eprintln("[hexa_only_lint selftest] FAIL --root walk: want 1 hit, got " + to_string(len(hits)))
        exit(1)
    }
    if !hits[0].ends_with(".sh") {
        eprintln("[hexa_only_lint selftest] FAIL --root walk: hit not the .sh — " + hits[0])
        exit(1)
    }
    println("[hexa_only_lint selftest] OK")
    exit(0)
}

// scan_root — walk <root> for banned-ext files; filter to "real untracked"
// (= git-untracked AND NOT gitignored). Tracked + gitignored both = grandfathered.
//
// Implementation prefers `git ls-files --others --exclude-standard` (canonical
// .gitignore-honoring untracked enumeration); falls back to find-walk for
// non-git roots.
//
// 2026-04-26: previous impl walked filesystem with `find` + per-file
// `git ls-files --error-unmatch` probe, which flagged .gitignore'd files as
// untracked violations. anima/.raw raw 100 (and the broader hive convention
// that .gitignore = explicit author intent) requires .gitignore'd files to be
// exempt. This rewrite delegates to git's own ignore logic. Falsifier: anima
// --root scan after this change reports 0 violations (was 2).
fn scan_root(root) {
    // Detect git repo at or above root.
    let in_git = to_string(exec("git -C '" + root + "' rev-parse --show-toplevel 2>/dev/null")).trim()
    if len(in_git) > 0 {
        // git ls-files --others --exclude-standard is run from <root>; output is
        // relative to cwd; we prefix with absolute root for output consistency.
        let abs_root = to_string(exec("cd '" + root + "' && pwd")).trim()
        let cmd = "cd '" + root + "' && git ls-files --others --exclude-standard 2>/dev/null | grep -E '\\.(rs|toml|py|sh)$' || true"
        let raw = to_string(exec(cmd))
        let lines = split(raw, "\n")
        let mut hits = []
        for line in lines {
            let p = line.trim()
            if len(p) == 0 { continue }
            hits.push(abs_root + "/" + p)
        }
        return hits
    }
    // Non-git fallback: find-walk + per-file untracked probe (original behavior).
    let exts_clause = "\\( -name '*.rs' -o -name '*.toml' -o -name '*.py' -o -name '*.sh' \\)"
    let prune_clause = "\\( -path '*/.git' -o -path '*/.claude' -o -path '*/.claude-*' -o -path '*/node_modules' -o -path '*/target' -o -path '*/dist' -o -path '*/build' -o -path '*/.hexa-cache' -o -path '*/archive' \\) -prune"
    let cmd = "find '" + root + "' " + prune_clause + " -o -type f " + exts_clause + " -print 2>/dev/null"
    let raw = to_string(exec(cmd))
    let lines = split(raw, "\n")
    let mut hits = []
    for line in lines {
        let p = line.trim()
        if len(p) == 0 { continue }
        hits.push(p)
    }
    return hits
}

// --selftest dispatch
if len(cli) > 0 && (cli[0] == "--selftest" || cli[0] == "selftest") {
    cmd_selftest()
}

// --root <path> dispatch — filesystem walk with git-untracked filter.
let mut root_arg = ""
let mut ci = 0
while ci < len(cli) {
    if cli[ci] == "--root" && ci + 1 < len(cli) {
        root_arg = cli[ci + 1]
        ci = ci + 2
        continue
    }
    ci = ci + 1
}

if len(root_arg) > 0 {
    let test_dir = to_string(exec("test -d '" + root_arg + "' && echo D || echo F")).trim()
    if test_dir != "D" {
        eprintln("hexa_only_lint: --root path does not exist or is not a directory: " + root_arg)
        exit(1)
    }
    let hits = scan_root(root_arg)
    if len(hits) == 0 {
        println("raw#9 (--root " + root_arg + "): untracked 위반 없음 — pass")
        exit(0)
    }
    eprintln("HEXA-ONLY 위반 (--root " + root_arg + "): .rs/.toml/.py/.sh untracked 파일 (raw#9)")
    for v in hits {
        eprintln("  violation  " + v)
    }
    eprintln(".hexa 로 작성하세요. Rust/Cargo/Python/Shell 의존 제거 원칙.")
    eprintln("note: tracked (git ls-files) 파일은 grandfather — untracked 만 위반으로 보고.")
    exit(1)
}

// staged 파일 수집 — ACMR 필터 (Added / Copied / Modified / Renamed)
let staged_raw = to_string(exec("git diff --cached --diff-filter=ACMR --name-only"))
let lines = split(staged_raw, "\n")

let mut violations = []
for line in lines {
    let path = line.trim()
    if len(path) == 0 { continue }
    if has_banned_ext(path) {
        violations.push(path)
    }
}

if len(violations) == 0 {
    println("raw#9: staged 위반 없음 — pass")
    exit(0)
}

eprintln("HEXA-ONLY 위반: .rs/.toml/.py/.sh 파일 커밋 금지 (raw#9)")
for v in violations {
    eprintln("  violation  " + v)
}
eprintln(".hexa 로 작성하세요. Rust/Cargo/Python/Shell 의존 제거 원칙.")
exit(1)
