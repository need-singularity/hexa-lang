// tool/hx_blocker_scan.hexa — Phase 1 blocker inventory (real logic v1).
//
// SPEC: docs/hexa_lang_meta_evolution_proposal_20260422.md §Phase 1.
// STATUS: v1 real — tool/*.hexa --selftest sweep + AOT freshness.
//         Future inputs (state/stage*_build_audit, state/raw_all_last,
//         state/codegen_error_log, .meta2-cert chain) deferred to v2.
//
// CLI
//   hexa tool/hx_blocker_scan.hexa --selftest       # synthetic test only
//   hexa tool/hx_blocker_scan.hexa                  # full repo scan
//   hexa tool/hx_blocker_scan.hexa --skip-selftest  # skip --selftest sweep
//   hexa tool/hx_blocker_scan.hexa --out <path>
//
// OUTPUT
//   $HEXA_LANG/state/hx_blockers.json (schema hexa-lang/hx_blockers/1)
//   selftest_fail → high · aot_stale → low

fn _home() -> string {
    let h = env("HOME")
    if len(h) > 0 { return h }
    return to_string(exec("echo $HOME")).trim()
}

fn _iso_now() -> string {
    return to_string(exec("date -u +'%Y-%m-%dT%H:%M:%SZ'")).trim()
}

fn _arg_value(args: array, key: string, default: string) -> string {
    let mut i = 0
    while i < len(args) {
        if args[i] == key {
            let j = i + 1
            if j < len(args) { return args[j] }
        }
        i = i + 1
    }
    return default
}

fn _has_flag(args: array, key: string) -> bool {
    let mut i = 0
    while i < len(args) {
        if args[i] == key { return true }
        i = i + 1
    }
    return false
}

fn _json_esc(s: string) -> string {
    let mut r = s.replace("\\", "\\\\")
    r = r.replace("\"", "\\\"")
    r = r.replace("\n", "\\n")
    r = r.replace("\r", "")
    r = r.replace("\t", " ")
    return r
}

fn _split_lines(s: string) -> array {
    let mut out = []
    let mut cur = ""
    let mut i = 0
    while i < len(s) {
        let c = s.substring(i, i + 1)
        if c == "\n" {
            if len(cur) > 0 { out.push(cur) }
            cur = ""
        } else {
            cur = cur + c
        }
        i = i + 1
    }
    if len(cur) > 0 { out.push(cur) }
    return out
}

fn _itoa(n: i64) -> string {
    if n == 0 { return "0" }
    let neg = n < 0
    let mut x = n
    if neg { x = 0 - x }
    let mut s = ""
    while x > 0 {
        let d = x % 10
        s = "0123456789".substring(d, d + 1) + s
        x = x / 10
    }
    if neg { s = "-" + s }
    return s
}

fn _tool_dir() -> string {
    return _home() + "/core/hexa-lang/tool"
}

fn _list_tools() -> array {
    let cmd = "ls " + _tool_dir() + " 2>/dev/null | grep '\\.hexa$'"
    return _split_lines(to_string(exec(cmd)))
}

fn _file_has_selftest_branch(path: string) -> bool {
    // regex '[-][-]selftest' avoids "--" being misread as option prefix by grep
    let cmd = "grep -q '[-][-]selftest' '" + path + "' 2>/dev/null && echo y || echo n"
    return to_string(exec(cmd)).trim() == "y"
}

fn _hexa_bin() -> string {
    return _home() + "/core/hexa-lang/hexa"
}

fn _run_selftest(path: string) -> i64 {
    let cmd = "'" + _hexa_bin() + "' '" + path + "' --selftest >/dev/null 2>&1"
    let r = exec_with_status(cmd)
    return r[1]
}

fn _bin_exists(stem: string) -> bool {
    let bin = _home() + "/core/hexa-lang/bin/" + stem
    let cmd = "test -x '" + bin + "' && echo y || echo n"
    return to_string(exec(cmd)).trim() == "y"
}

fn _bin_is_aot(stem: string) -> bool {
    // A shim script (e.g. bin/roadmap_engine, bin/hx_meta) is text starting
    // with #!/usr/bin/env bash. Treat as non-AOT — we don't compare mtime.
    let bin = _home() + "/core/hexa-lang/bin/" + stem
    let cmd = "head -c 2 '" + bin + "' 2>/dev/null"
    let head = to_string(exec(cmd))
    if head == "#!" { return false }
    return true
}

fn _bin_older_than_src(stem: string) -> bool {
    let bin = _home() + "/core/hexa-lang/bin/" + stem
    let src = _tool_dir() + "/" + stem + ".hexa"
    let r = exec_with_status("test '" + bin + "' -ot '" + src + "'")
    return r[1] == 0
}

fn _src_exists(stem: string) -> bool {
    let src = _tool_dir() + "/" + stem + ".hexa"
    let cmd = "test -f '" + src + "' && echo y || echo n"
    return to_string(exec(cmd)).trim() == "y"
}

fn _blocker_json(id: string, kind: string, source: string, desc: string, severity: string, evidence: string) -> string {
    return "{\"id\":\"" + _json_esc(id) + "\",\"kind\":\"" + _json_esc(kind) + "\",\"source\":\"" + _json_esc(source) + "\",\"description\":\"" + _json_esc(desc) + "\",\"severity\":\"" + _json_esc(severity) + "\",\"evidence\":\"" + _json_esc(evidence) + "\"}"
}

fn _selftest() -> int {
    let esc = _json_esc("a\"b\\c")
    if esc != "a\\\"b\\\\c" {
        eprintln("hx_blocker_scan: selftest FAIL (json_esc)")
        return 1
    }
    let lines = _split_lines("a\nb\n\nc\n")
    if len(lines) != 3 {
        eprintln("hx_blocker_scan: selftest FAIL (split_lines len)")
        return 1
    }
    if lines[0] != "a" { eprintln("hx_blocker_scan: selftest FAIL (line[0])"); return 1 }
    if lines[2] != "c" { eprintln("hx_blocker_scan: selftest FAIL (line[2])"); return 1 }
    if _itoa(0) != "0" { eprintln("hx_blocker_scan: selftest FAIL (itoa 0)"); return 1 }
    if _itoa(-42) != "-42" { eprintln("hx_blocker_scan: selftest FAIL (itoa -42)"); return 1 }
    if _itoa(12345) != "12345" { eprintln("hx_blocker_scan: selftest FAIL (itoa 12345)"); return 1 }
    println("hx_blocker_scan: selftest PASS")
    return 0
}

fn main() {
    let av = argv()
    let mut args = []
    let mut i = 2
    while i < len(av) { args.push(av[i]); i = i + 1 }

    if len(args) >= 1 && args[0] == "--selftest" { exit(_selftest()) }

    let default_out = _home() + "/core/hexa-lang/state/hx_blockers.json"
    let out_path = _arg_value(args, "--out", default_out)
    let skip_selftest = _has_flag(args, "--skip-selftest")

    let ts = _iso_now()
    let tools = _list_tools()
    let tool_count = len(tools)

    let mut blockers_json = []
    let mut critical = 0
    let mut high = 0
    let mut med = 0
    let mut low = 0
    let mut bid = 0

    // 1. --selftest sweep
    let mut selftest_scanned = 0
    if !skip_selftest {
        for t in tools {
            let path = _tool_dir() + "/" + t
            if _file_has_selftest_branch(path) {
                selftest_scanned = selftest_scanned + 1
                let rc = _run_selftest(path)
                if rc != 0 {
                    bid = bid + 1
                    let id = "blk-st-" + _itoa(bid)
                    let desc = "--selftest returned rc=" + _itoa(rc)
                    let evid = "hexa tool/" + t + " --selftest"
                    blockers_json.push(_blocker_json(id, "selftest_fail",
                        "tool/" + t, desc, "high", evid))
                    high = high + 1
                }
            }
        }
    }

    // 2. AOT freshness sweep
    let aot_dir = _home() + "/core/hexa-lang/bin"
    let aot_list = _split_lines(to_string(exec("ls '" + aot_dir + "' 2>/dev/null")))
    let mut aot_scanned = 0
    for name in aot_list {
        if !_src_exists(name) { continue }
        if !_bin_is_aot(name) { continue }
        aot_scanned = aot_scanned + 1
        if _bin_older_than_src(name) {
            bid = bid + 1
            let id = "blk-aot-" + _itoa(bid)
            let desc = "AOT binary older than source — rebuild recommended"
            let evid = "ls -la bin/" + name + " tool/" + name + ".hexa"
            blockers_json.push(_blocker_json(id, "aot_stale",
                "bin/" + name, desc, "low", evid))
            low = low + 1
        }
    }

    // 3. Emit JSON
    let mut body = "{\n  \"schema\": \"hexa-lang/hx_blockers/1\",\n"
    body = body + "  \"ts\": \"" + ts + "\",\n"
    body = body + "  \"status\": \"real-v1\",\n"
    body = body + "  \"tool_count\": " + _itoa(tool_count) + ",\n"
    body = body + "  \"selftest_scanned\": " + _itoa(selftest_scanned) + ",\n"
    body = body + "  \"aot_scanned\": " + _itoa(aot_scanned) + ",\n"
    body = body + "  \"blockers\": [\n"
    let mut first = true
    for j in blockers_json {
        if !first { body = body + ",\n" }
        body = body + "    " + j
        first = false
    }
    body = body + "\n  ],\n"
    let tot = len(blockers_json)
    body = body + "  \"summary\": {\"total\": " + _itoa(tot)
    body = body + ", \"critical\": " + _itoa(critical)
    body = body + ", \"high\": " + _itoa(high)
    body = body + ", \"med\": " + _itoa(med)
    body = body + ", \"low\": " + _itoa(low) + "}\n}\n"

    try { write_file(out_path, body) } catch e {
        eprintln("hx_blocker_scan: write FAIL " + out_path)
        exit(1)
    }

    println("hx_blocker_scan: scanned " + _itoa(tool_count) + " tools ("
          + _itoa(selftest_scanned) + " with --selftest), "
          + _itoa(aot_scanned) + " AOT bins; "
          + _itoa(tot) + " blockers (critical=" + _itoa(critical)
          + " high=" + _itoa(high) + " med=" + _itoa(med) + " low=" + _itoa(low) + ")")
    println("hx_blocker_scan: wrote " + out_path)
    exit(0)
}
