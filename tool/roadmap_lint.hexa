// tool/roadmap_lint.hexa — raw#15 enforcer (.roadmap SSOT)
//
// usage:
//   hexa tool/roadmap_lint.hexa          — validate /.roadmap + exit 1 on violation
//   hexa tool/roadmap_lint.hexa --list   — dump entries
//
// rule: raw#15 — phase/track/milestone registry. required: track, phase, eta, why.
//   status=done requires proof (raw#9 proof-carrying symmetry).

fn _rstrip(s: string) -> string {
    let mut end = len(s)
    while end > 0 {
        let c = s.substring(end - 1, end)
        if c == " " || c == "\t" || c == "\r" { end = end - 1 } else { break }
    }
    return s.substring(0, end)
}

// header: `roadmap <id> <status> "<name>"`
fn _parse_roadmap_header(line: string) -> array {
    let sp1 = line.index_of(" ")
    if sp1 < 0 { return [] }
    if line.substring(0, sp1) != "roadmap" { return [] }

    let rest1 = line.substring(sp1 + 1, len(line))
    let sp2 = rest1.index_of(" ")
    if sp2 < 0 { return [] }
    let id = rest1.substring(0, sp2)

    let rest2 = rest1.substring(sp2 + 1, len(rest1))
    let sp3 = rest2.index_of(" ")
    if sp3 < 0 { return [] }
    let status = rest2.substring(0, sp3)

    let mut name = rest2.substring(sp3 + 1, len(rest2)).trim()
    if len(name) >= 2 && name.substring(0, 1) == "\"" {
        name = name.substring(1, len(name) - 1)
    }
    return [id, status, name]
}

// header: `checkpoint <ID> "<name>"` — raw#15 checkpoint DSL
//
// Returns [id, name] on match, [] on non-match. ID is a short label
// (`CP1`, `CP2`, `FINAL`, ...) — no status field. Name may carry the
// 🧠 symbol to mark FINAL checkpoint (V4).
fn _parse_checkpoint_header(line: string) -> array {
    let sp1 = line.index_of(" ")
    if sp1 < 0 { return [] }
    if line.substring(0, sp1) != "checkpoint" { return [] }

    let rest1 = line.substring(sp1 + 1, len(line))
    let sp2 = rest1.index_of(" ")
    if sp2 < 0 { return [] }
    let id = rest1.substring(0, sp2)

    let mut name = rest1.substring(sp2 + 1, len(rest1)).trim()
    if len(name) >= 2 && name.substring(0, 1) == "\"" {
        name = name.substring(1, len(name) - 1)
    }
    return [id, name]
}

// Parse roadmap SSOT text (lines) into rules + checkpoints.
// Factored out so both `_load_roadmap(path)` and the git-HEAD transition
// check can share a single parser implementation.
//
// Returns [rules, checkpoints] where:
//   rules        = array of [id, status, name, keys]
//   checkpoints  = array of [id, name, keys]
//
// Header dispatch by first whitespace-delimited token:
//   `roadmap`    → rules entry (existing)
//   `checkpoint` → checkpoint block (raw#15 DSL)
//   (anything else at column 0) → unrecognized header → drop current block
fn _parse_roadmap_text(src: string) -> array {
    let lines = split(src, "\n")

    let mut rules = []
    let mut checkpoints = []

    // current block state — one of:
    //   kind = ""  (none)
    //   kind = "r" (roadmap rule)
    //   kind = "c" (checkpoint)
    let mut kind = ""
    let mut cur_id = ""
    let mut cur_status = ""
    let mut cur_name = ""
    let mut cur_keys = []

    for raw_line in lines {
        let line = _rstrip(raw_line)
        if len(line) == 0 {
            if kind == "r" {
                rules.push([cur_id, cur_status, cur_name, cur_keys])
            }
            if kind == "c" {
                checkpoints.push([cur_id, cur_name, cur_keys])
            }
            kind = ""
            cur_keys = []
            continue
        }
        let first = line.substring(0, 1)
        if first == "#" { continue }

        if first == " " || first == "\t" {
            if kind == "" { continue }
            let stripped = line.trim_start()
            let sp = stripped.index_of(" ")
            if sp < 0 { continue }
            let key = stripped.substring(0, sp)
            let val = stripped.substring(sp + 1, len(stripped)).trim()
            cur_keys.push([key, val])
        } else {
            // flush previous block
            if kind == "r" {
                rules.push([cur_id, cur_status, cur_name, cur_keys])
            }
            if kind == "c" {
                checkpoints.push([cur_id, cur_name, cur_keys])
            }
            cur_keys = []
            kind = ""

            // dispatch on first token
            let first_sp = line.index_of(" ")
            if first_sp < 0 { continue }
            let tok = line.substring(0, first_sp)
            if tok == "roadmap" {
                let hdr = _parse_roadmap_header(line)
                if len(hdr) == 0 { continue }
                cur_id = hdr[0]
                cur_status = hdr[1]
                cur_name = hdr[2]
                kind = "r"
            }
            if tok == "checkpoint" {
                let chdr = _parse_checkpoint_header(line)
                if len(chdr) == 0 { continue }
                cur_id = chdr[0]
                cur_name = chdr[1]
                kind = "c"
            }
        }
    }
    if kind == "r" {
        rules.push([cur_id, cur_status, cur_name, cur_keys])
    }
    if kind == "c" {
        checkpoints.push([cur_id, cur_name, cur_keys])
    }
    return [rules, checkpoints]
}

// Load .roadmap from a filesystem path. Returns [[], []] if the file does
// not exist — shape mirrors _parse_roadmap_text: [rules, checkpoints].
fn _load_roadmap(path: string) -> array {
    let exists = to_string(exec("test -f '" + path + "' && echo y || echo n")).trim()
    if exists != "y" { return [[], []] }
    let src = to_string(read_file(path))
    return _parse_roadmap_text(src)
}

fn _keys_first(keys: array, k: string) -> string {
    for kv in keys {
        if kv[0] == k { return kv[1] }
    }
    return ""
}

// phase status whitelist for inner `status` key (same as header for roadmap kind)
fn _valid_phase_status(s: string) -> bool {
    if s == "planned" || s == "active" || s == "done" || s == "blocked" || s == "deferred" { return true }
    return false
}

// roadmap header status whitelist — phase-lifecycle (kind-specific)
fn _valid_header_status(s: string) -> bool {
    if s == "planned" || s == "active" || s == "done" || s == "blocked" || s == "deferred" { return true }
    return false
}

// eta: accepted formats —
//   YYYY-MM-DD   (precise)           e.g. 2026-04-19
//   YYYY-Qn      (quarterly, n=1..4) e.g. 2026-Q2
//   YYYY-Hn      (half,      n=1..2) e.g. 2027-H1
//   YYYY         (yearly)            e.g. 2028
//   TBD          (explicit unknown)
// Rationale: long-horizon roadmap items 는 day-level 정확도가 없다. 강제하면
// .roadmap 작성자가 fake 날짜를 박거나 TBD 로 회피 → signal 손실. 이 형식은
// raw_attestation/raw-verify.yml bash port 와 정렬된다.
fn _valid_eta(s: string) -> bool {
    if s == "TBD" { return true }
    let n = len(s)
    let digits = "0123456789"
    // YYYY — 4 digits
    if n == 4 {
        let mut i = 0
        while i < 4 {
            if !digits.contains(s.substring(i, i + 1)) { return false }
            i = i + 1
        }
        return true
    }
    // YYYY-Qn or YYYY-Hn — 7 chars
    if n == 7 {
        let mut i = 0
        while i < 4 {
            if !digits.contains(s.substring(i, i + 1)) { return false }
            i = i + 1
        }
        if s.substring(4, 5) != "-" { return false }
        let marker = s.substring(5, 6)
        let digit  = s.substring(6, 7)
        if marker == "Q" {
            if digit == "1" || digit == "2" || digit == "3" || digit == "4" { return true }
            return false
        }
        if marker == "H" {
            if digit == "1" || digit == "2" { return true }
            return false
        }
        return false
    }
    // YYYY-MM-DD — 10 chars
    if n == 10 {
        let mut i = 0
        while i < 10 {
            let c = s.substring(i, i + 1)
            if i == 4 || i == 7 {
                if c != "-" { return false }
            } else {
                if !digits.contains(c) { return false }
            }
            i = i + 1
        }
        return true
    }
    return false
}

fn _pwd() -> string {
    let mut p = env("PWD")
    if p == "" { p = to_string(exec("pwd")).trim() }
    return p
}

// depends-on parsing helpers — raw#15 cross-validation
//
// Accepted depends-on shapes (loose — same field holds mixed refs):
//   "11"                         → numeric ID ref          → VERIFY existence + status
//   "11, ROI #153"               → numeric "11" extracted  → VERIFY id 11 (ROI ref skipped)
//   "12 + 30-day stability"      → numeric "12" extracted  → VERIFY id 12 (note skipped)
//   "ROI #152 (...)"             → no leading numeric      → SKIP (string ref)
//   "seed-freeze 해제 후 ..."     → no leading numeric      → SKIP (string ref)
//
// Rule: the first whitespace/comma-delimited token is examined. If it is a
// pure integer string, treat as roadmap-id cross-ref. Otherwise skip — the
// field is a free-form note.
fn _is_int_str(s: string) -> bool {
    if len(s) == 0 { return false }
    let digits = "0123456789"
    let mut i = 0
    while i < len(s) {
        if !digits.contains(s.substring(i, i + 1)) { return false }
        i = i + 1
    }
    return true
}

// Extract first numeric id token from depends-on value. Returns "" if the
// first token is not purely numeric (e.g. "ROI", "seed-freeze", "hexa").
fn _first_numeric_ref(val: string) -> string {
    let v = val.trim()
    if len(v) == 0 { return "" }
    // first token boundary = first space OR comma OR '+'
    let mut end = 0
    while end < len(v) {
        let c = v.substring(end, end + 1)
        if c == " " || c == "\t" || c == "," || c == "+" { break }
        end = end + 1
    }
    let tok = v.substring(0, end)
    if _is_int_str(tok) { return tok }
    return ""
}

// Lookup rule by id (linear — rule count is small, ≤100s).
fn _find_rule(rules: array, id: string) -> array {
    for r in rules {
        if r[0] == id { return r }
    }
    return []
}

// proof path existence — raw#9 proof-carrying symmetry
//
// proof field shapes (loose — accept real-world patterns in .roadmap):
//   "tool/foo.hexa"                       → single path       → test -e required
//   ".raw"                                → single file       → test -e required
//   "tool/a.hexa tool/b.hexa"             → space-separated   → each path tested
//   "tool/a.hexa, tool/b.hexa"            → comma-separated   → each path tested
//   "assert:<shell-expr>"                 → runtime assertion → SKIP (cannot verify)
//   ""                                    → missing           → handled by done-gate
//
// Paths are repo-relative (resolved against _pwd()). file_exists() accepts
// both files and directories (raw_attestation uses test -e — same semantics).
fn _proof_path_exists(rel: string) -> bool {
    let p = rel.trim()
    if len(p) == 0 { return false }
    // absolute path — test directly
    if p.substring(0, 1) == "/" { return file_exists(p) }
    // repo-relative — resolve against pwd
    return file_exists(_pwd() + "/" + p)
}

// Split proof value on whitespace + comma into path tokens.
fn _split_proof_tokens(val: string) -> array {
    let mut out = []
    let mut cur = ""
    let mut i = 0
    let n = len(val)
    while i < n {
        let c = val.substring(i, i + 1)
        if c == " " || c == "\t" || c == "," {
            if len(cur) > 0 { out.push(cur); cur = "" }
        } else {
            cur = cur + c
        }
        i = i + 1
    }
    if len(cur) > 0 { out.push(cur) }
    return out
}

// ─── cycle detection helpers (Kahn topological sort) ─────────────────
//
// Graph model:
//   node = roadmap id (string, numeric)
//   edge = (parent_id → child_id) where child has `depends-on` referencing parent
//
// Rationale: self-referential or mutually-referential roadmap entries indicate
// an inconsistent plan (cannot satisfy parent-done-before-child ordering).
// We reuse _first_numeric_ref — only the first numeric token per depends-on is
// currently used as an edge. TODO: extend to multi-parent (comma-split all
// numeric tokens) once raw#15 grammar formalizes multi-dep syntax.

// Find index of id in slug array, -1 if absent.
fn _idx_of(ids: array, id: string) -> int {
    let mut i = 0
    while i < len(ids) {
        if ids[i] == id { return i }
        i = i + 1
    }
    return -1
}

// Immutable-style array element set (interp-friendly — no in-place mutation
// on shared references).
fn _arr_set_int(arr: array, idx: int, val: int) -> array {
    let mut out = []
    let mut i = 0
    while i < len(arr) {
        if i == idx { out.push(val) } else { out.push(arr[i]) }
        i = i + 1
    }
    return out
}

// Reconstruct a cycle path via DFS walk within the residual graph.
// Start from `start_id`, follow the first outgoing edge at each step, stop
// when we revisit a node already on the walk stack → slice from first
// occurrence forms the cycle.
//
// residual_ids = nodes with in-degree > 0 (participants)
// edges        = [[parent, child], ...] from original graph
// start_id     = seed node (must be in residual_ids)
fn _cycle_walk(start_id: string, residual_ids: array, edges: array) -> array {
    let mut path = []
    let mut cur = start_id
    let max_steps = len(residual_ids) + 1
    let mut step = 0
    while step <= max_steps {
        // revisit check — find cur in path
        let hit = _idx_of(path, cur)
        if hit >= 0 {
            // slice cycle from first occurrence, append cur to close loop
            let mut cycle = []
            let mut j = hit
            while j < len(path) {
                cycle.push(path[j])
                j = j + 1
            }
            cycle.push(cur)
            return cycle
        }
        path.push(cur)
        // find first outgoing edge whose child is also residual
        let mut next_id = ""
        for e in edges {
            if e[0] != cur { continue }
            if _idx_of(residual_ids, e[1]) < 0 { continue }
            next_id = e[1]
            break
        }
        if next_id == "" {
            // dead end — shouldn't happen in a true cycle residual but guard
            return []
        }
        cur = next_id
        step = step + 1
    }
    return []
}

// ─── checkpoint DSL helpers (raw#15) ─────────────────────────────────
//
// Per-entry CP references:
//   reaches   → comma-separated CP IDs this entry contributes to when done
//   requires  → comma-separated CP IDs that must be satisfied before active
//   verify    → single CP ID evaluated for done transition
// CP refs are parsed via _split_cp_refs (comma-split + trim). Empty input
// returns [] — callers treat empty as "no CP involvement".

// Split a comma-separated CP ID list. Trims each token, drops empties.
fn _split_cp_refs(val: string) -> array {
    let mut out = []
    let v = val.trim()
    if len(v) == 0 { return out }
    let parts = split(v, ",")
    for p in parts {
        let t = p.trim()
        if len(t) > 0 { out.push(t) }
    }
    return out
}

// Lookup checkpoint by ID. Returns [] if absent.
fn _find_checkpoint(checkpoints: array, id: string) -> array {
    for c in checkpoints {
        if c[0] == id { return c }
    }
    return []
}

// Detect FINAL checkpoint via 🧠 symbol in the name.
fn _is_final_cp(name: string) -> bool {
    return name.contains("🧠")
}

// A CP is "satisfied" when ≥1 OTHER entry (excluding self) with
// `reaches <CP>` has status=done. self_id excludes the current rule from
// satisfying its own requires — enforces strictly external progress.
fn _cp_satisfied(rules: array, cp_id: string, self_id: string) -> bool {
    for r in rules {
        if r[0] == self_id { continue }
        if r[1] != "done" { continue }
        let reaches_val = _keys_first(r[3], "reaches")
        if reaches_val == "" { continue }
        let refs = _split_cp_refs(reaches_val)
        for ref in refs {
            if ref == cp_id { return true }
        }
    }
    return false
}

fn _roadmap_path() -> string { return _pwd() + "/.roadmap" }

let _raw_args = args()
let mut cli = []
let mut _ai = 2
while _ai < len(_raw_args) {
    cli.push(_raw_args[_ai])
    _ai = _ai + 1
}

let mut list_mode = false
for a in cli {
    if a == "--list" { list_mode = true }
}

let path = _roadmap_path()
let parsed = _load_roadmap(path)
let rules = parsed[0]
let checkpoints = parsed[1]

if list_mode {
    println("── .roadmap entries (" + to_string(len(rules)) + ") ──")
    for r in rules {
        let phase = _keys_first(r[3], "phase")
        let track = _keys_first(r[3], "track")
        println("  #" + r[0] + " [" + r[1] + "] track=" + track + " phase=" + phase + " — " + r[2])
    }
    if len(checkpoints) > 0 {
        println("── checkpoints (" + to_string(len(checkpoints)) + ") ──")
        for c in checkpoints {
            println("  " + c[0] + " — " + c[1])
        }
    }
    exit(0)
}

if len(rules) == 0 && len(checkpoints) == 0 {
    println("raw#15 roadmap_lint: .roadmap empty or missing — pass")
    exit(0)
}

let mut errs = []
for r in rules {
    let id = r[0]
    let hdr_status = r[1]
    let keys = r[3]
    let tag = "[roadmap #" + id + "] "

    if !_valid_header_status(hdr_status) {
        errs.push(tag + "invalid header status '" + hdr_status + "' — whitelist: planned active done blocked deferred")
    }

    if _keys_first(keys, "track") == "" {
        errs.push(tag + "missing required key: track")
    }
    if _keys_first(keys, "phase") == "" {
        errs.push(tag + "missing required key: phase")
    }
    if _keys_first(keys, "why") == "" {
        errs.push(tag + "missing required key: why")
    }

    let eta = _keys_first(keys, "eta")
    if eta == "" {
        errs.push(tag + "missing required key: eta")
    } else if !_valid_eta(eta) {
        errs.push(tag + "invalid eta '" + eta + "' — expected YYYY-MM-DD or TBD")
    }

    // inner `status` key (per-phase progress) — optional but whitelisted if present
    let phase_status = _keys_first(keys, "status")
    if phase_status != "" {
        if !_valid_phase_status(phase_status) {
            errs.push(tag + "invalid phase status '" + phase_status + "' — whitelist: planned active done blocked deferred")
        }
    }

    // proof-carrying gate — raw#9 symmetry
    //
    // Trigger: either header status==done OR inner status==done (union).
    //   - present-day .roadmap uses header status exclusively, but the inner
    //     `status` key is still parsed for future schema evolution.
    //
    // proof field handling:
    //   - missing/empty       → FAIL (existing "missing proof" behavior)
    //   - "assert:<expr>"     → SKIP (runtime assertion — not a path)
    //   - whitespace/comma-split → each token verified via file_exists
    //   - non-existent path   → FAIL "roadmap #<id> proof path missing: <path>"
    let is_done = (hdr_status == "done") || (phase_status == "done")
    if is_done {
        // V2 DONE_PROOF_GATE — accept `proof` OR `verify` (raw#15 DSL tighten).
        // Existing entries use proof only; new entries may use verify <CPID>
        // instead. Error only when BOTH are absent.
        let proof_val  = _keys_first(keys, "proof").trim()
        let verify_val = _keys_first(keys, "verify").trim()
        if len(proof_val) == 0 && len(verify_val) == 0 {
            errs.push(tag + "done requires proof or verify")
        }
        if len(proof_val) > 0 {
            if len(proof_val) >= 7 && proof_val.substring(0, 7) == "assert:" {
                // runtime shell assertion — no static path check
            } else {
                let tokens = _split_proof_tokens(proof_val)
                for tok in tokens {
                    if !_proof_path_exists(tok) {
                        errs.push(tag + "proof path missing: " + tok)
                    }
                }
            }
        }
    }

    // V1 REF_EXISTS — every CP ID referenced by reaches/requires/verify
    // must match a declared `checkpoint` block.
    let reaches_refs  = _split_cp_refs(_keys_first(keys, "reaches"))
    let requires_refs = _split_cp_refs(_keys_first(keys, "requires"))
    let verify_val2   = _keys_first(keys, "verify").trim()
    for rref in reaches_refs {
        if len(_find_checkpoint(checkpoints, rref)) == 0 {
            errs.push(tag + "unknown checkpoint: " + rref)
        }
    }
    for qref in requires_refs {
        if len(_find_checkpoint(checkpoints, qref)) == 0 {
            errs.push(tag + "unknown checkpoint: " + qref)
        }
    }
    if len(verify_val2) > 0 {
        if len(_find_checkpoint(checkpoints, verify_val2)) == 0 {
            errs.push(tag + "unknown checkpoint: " + verify_val2)
        }
    }

    // V3 ACTIVE_REQUIRES — entry with status=active AND non-empty
    // requires: every CP must be satisfied (≥1 OTHER rule reaches→done).
    // Runs on current-disk state only — not in _transition_allowed path.
    if hdr_status == "active" && len(requires_refs) > 0 {
        let mut unmet = []
        for qref in requires_refs {
            // skip CPs that failed V1 — avoid double error
            if len(_find_checkpoint(checkpoints, qref)) == 0 { continue }
            if !_cp_satisfied(rules, qref, id) {
                unmet.push(qref)
            }
        }
        if len(unmet) > 0 {
            let mut ulist = ""
            let mut ui = 0
            while ui < len(unmet) {
                if ui == 0 { ulist = unmet[ui] }
                else { ulist = ulist + ", " + unmet[ui] }
                ui = ui + 1
            }
            errs.push(tag + "active blocked by unmet requires: " + ulist)
        }
    }

    // exit_criteria gate — raw#15 "proof vs criteria" split
    //
    // Semantics:
    //   - proof          = where the evidence lives (path)
    //   - exit_criteria  = what must be true to call it done (prose)
    //
    // Enforcement:
    //   - status=active|done → exit_criteria REQUIRED (hard FAIL if missing/empty)
    //   - status=planned|blocked|deferred → OPTIONAL (no message)
    //   - len(exit_criteria) < 10 → WARN (placeholder smell)
    //
    // Messages:
    //   FAIL: "[roadmap #<id>] exit_criteria required for status=<s>"
    //   WARN: "[roadmap #<id>] exit_criteria too short (<10 chars)"
    let exit_criteria = _keys_first(keys, "exit_criteria").trim()
    if hdr_status == "active" || hdr_status == "done" {
        if len(exit_criteria) == 0 {
            errs.push(tag + "exit_criteria required for status=" + hdr_status)
        } else if len(exit_criteria) < 10 {
            eprintln("  WARN " + tag + "exit_criteria too short (<10 chars)")
        }
    } else {
        if len(exit_criteria) > 0 && len(exit_criteria) < 10 {
            eprintln("  WARN " + tag + "exit_criteria too short (<10 chars)")
        }
    }

    // depends-on cross-validation (raw#15 — orphan detection + status gate)
    //
    // Rules:
    //   a) if depends-on value starts with a numeric token, that token MUST
    //      resolve to an existing roadmap id (orphan detection).
    //   b) sealing (child=done) requires parent=done — no done-over-unfinished.
    //   b2) working (child=active) requires parent ∈ {active, done} — parallel
    //      work on the same track is allowed (umbrella-active parent +
    //      sibling-active children), but a planned/deferred/blocked parent
    //      still gates its children.
    //   c) non-numeric first tokens (ROI #nnn, "seed-freeze...", free-form)
    //      bypass id validation — they are external refs, out of .roadmap scope.
    let dep_val = _keys_first(keys, "depends-on")
    if dep_val != "" {
        let dep_id = _first_numeric_ref(dep_val)
        if dep_id == "" {
            // free-form reference — no id validation possible
        } else {
            let parent = _find_rule(rules, dep_id)
            if len(parent) == 0 {
                errs.push(tag + "depends-on #" + dep_id + " missing (orphan cross-ref)")
            } else {
                let parent_status = parent[1]
                if hdr_status == "done" {
                    if parent_status != "done" {
                        errs.push(tag + "depends-on #" + dep_id + " is " + parent_status + ", child cannot be done")
                    }
                } else if hdr_status == "active" {
                    if parent_status != "active" && parent_status != "done" {
                        errs.push(tag + "depends-on #" + dep_id + " is " + parent_status + ", child cannot be active")
                    }
                }
            }
        }
    }
}

// ─── status transition invariants (git HEAD diff) ───────────────────
//
// Compares the current .roadmap against its tracked HEAD version and
// validates per-id status transitions. Purpose: prevent "phantom work"
// rewrites — once an entry is sealed (done) or promoted, it cannot be
// silently regressed to an earlier status.
//
// Transition matrix:
//   allowed:
//     any → same           (no change)
//     planned  → active|blocked|deferred
//     active   → done|blocked|deferred
//     blocked  → active|done|deferred
//     deferred → planned|active
//   forbidden (FAIL):
//     done → any           (done is sealed)
//     active  → planned    (regression)
//     blocked → planned    (regression)
//
//   new entry (id absent in HEAD): allowed to start in any status
//   deleted entry (id present in HEAD, absent now): FAIL
//
// Failure modes for git show:
//   - initial commit (no HEAD yet)
//   - .roadmap not tracked in HEAD
//   - not a git checkout
// All three → SKIP silently (no WARN, no FAIL) — first landing of
// .roadmap must not self-trip.
fn _transition_allowed(prev: string, cur: string) -> bool {
    if prev == cur { return true }
    if prev == "done" { return false }
    if prev == "planned" {
        if cur == "active" || cur == "blocked" || cur == "deferred" { return true }
        return false
    }
    if prev == "active" {
        if cur == "done" || cur == "blocked" || cur == "deferred" { return true }
        return false
    }
    if prev == "blocked" {
        if cur == "active" || cur == "done" || cur == "deferred" { return true }
        return false
    }
    if prev == "deferred" {
        if cur == "planned" || cur == "active" { return true }
        return false
    }
    return false
}

if len(rules) >= 1 {
    let tmp_pid = exec("echo $$").trim()
    let prev_path = "/tmp/.roadmap.prev." + tmp_pid
    let show = exec_with_status("git show HEAD:.roadmap > " + prev_path + " 2>/dev/null")
    if show[1] == 0 {
        let exists_prev = to_string(exec("test -s '" + prev_path + "' && echo y || echo n")).trim()
        if exists_prev == "y" {
            let prev_src = to_string(read_file(prev_path))
            let prev_parsed = _parse_roadmap_text(prev_src)
            let prev_rules = prev_parsed[0]

            // forward check: each previous entry must survive (no deletion)
            // and its transition to the current status must be allowed.
            for pr in prev_rules {
                let pid_str = pr[0]
                let prev_status = pr[1]
                let ptag = "[roadmap #" + pid_str + "] "
                let cur_rule = _find_rule(rules, pid_str)
                if len(cur_rule) == 0 {
                    errs.push(ptag + "삭제 금지 — 이전에 존재 (status=" + prev_status + ")")
                    continue
                }
                let cur_status = cur_rule[1]
                if prev_status == cur_status { continue }
                if prev_status == "done" {
                    errs.push(ptag + "done 선언은 sealed (" + prev_status + "=done → " + cur_status + "=?)")
                    continue
                }
                if !_transition_allowed(prev_status, cur_status) {
                    errs.push(ptag + "status 역행 금지: " + prev_status + " → " + cur_status)
                }
            }
            // cleanup — best-effort, never fail.
            exec("rm -f '" + prev_path + "' 2>/dev/null")
        }
    } else {
        // git show failed — .roadmap untracked or no HEAD. silent skip.
        exec("rm -f '" + prev_path + "' 2>/dev/null")
    }
}

// ─── depends-on cycle detection (Kahn topological sort) ──────────────
//
// Builds a DAG over numeric roadmap ids and runs Kahn's algorithm. Any
// node with residual in-degree > 0 after the sweep sits on a cycle.
// Cycle path is reconstructed via DFS and emitted as:
//   [roadmap cycle] #a -> #b -> #c -> #a
//
// Edges are taken from _first_numeric_ref(depends-on) — only the first
// numeric parent per child. Multi-parent depends-on (e.g. "12, 15") is
// a future extension; see _first_numeric_ref TODO above.
if len(rules) >= 1 {
    let mut ids = []
    for r in rules { ids.push(r[0]) }

    // Build edges [parent_id, child_id] + per-node in-degree.
    let mut edges = []
    let mut indeg = []
    let mut gi = 0
    while gi < len(ids) { indeg.push(0); gi = gi + 1 }

    for r in rules {
        let child_id = r[0]
        let dep_val = _keys_first(r[3], "depends-on")
        if dep_val == "" { continue }
        let parent_id = _first_numeric_ref(dep_val)
        if parent_id == "" { continue }
        // orphan already reported above — skip here to avoid double-error;
        // also skip self-edge from building unless parent_id matches an id
        // (self-loop is a valid cycle and MUST be caught, so allow it).
        let pidx = _idx_of(ids, parent_id)
        if pidx < 0 { continue }
        edges.push([parent_id, child_id])
        let cidx = _idx_of(ids, child_id)
        if cidx >= 0 {
            indeg = _arr_set_int(indeg, cidx, indeg[cidx] + 1)
        }
    }

    // Kahn: seed queue with indeg==0, process FIFO, decrement children.
    let mut queue = []
    let mut seen_cnt = 0
    let mut qi = 0
    while qi < len(ids) {
        if indeg[qi] == 0 { queue.push(ids[qi]) }
        qi = qi + 1
    }
    let mut head = 0
    while head < len(queue) {
        let cur = queue[head]
        head = head + 1
        seen_cnt = seen_cnt + 1
        for e in edges {
            if e[0] != cur { continue }
            let cidx2 = _idx_of(ids, e[1])
            if cidx2 < 0 { continue }
            let nv = indeg[cidx2] - 1
            indeg = _arr_set_int(indeg, cidx2, nv)
            if nv == 0 { queue.push(e[1]) }
        }
    }

    if seen_cnt < len(ids) {
        // Collect residual ids (in-degree > 0 = on a cycle).
        let mut residual = []
        let mut ri = 0
        while ri < len(ids) {
            if indeg[ri] > 0 { residual.push(ids[ri]) }
            ri = ri + 1
        }
        // Report one cycle per residual seed, but dedupe — DFS from the
        // first residual node usually surfaces the full cycle; we emit a
        // single "[roadmap cycle]" line plus the residual list for clarity.
        if len(residual) > 0 {
            let cyc = _cycle_walk(residual[0], residual, edges)
            if len(cyc) >= 2 {
                let mut path_str = ""
                let mut pi = 0
                while pi < len(cyc) {
                    if pi == 0 { path_str = "#" + cyc[pi] }
                    else { path_str = path_str + " -> #" + cyc[pi] }
                    pi = pi + 1
                }
                errs.push("[roadmap cycle] " + path_str)
            } else {
                // fallback: just list participants
                let mut list_str = ""
                let mut li = 0
                while li < len(residual) {
                    if li == 0 { list_str = "#" + residual[li] }
                    else { list_str = list_str + ", #" + residual[li] }
                    li = li + 1
                }
                errs.push("[roadmap cycle] participants: " + list_str)
            }
        }
    }
}

// ─── V4 FINAL_UNIQUE (checkpoint DSL) ────────────────────────────────
//
// If ≥1 checkpoint declared, exactly one must carry the 🧠 symbol in its
// name. Zero checkpoints → skip (soft rollout — current .roadmap has none).
if len(checkpoints) >= 1 {
    let mut finals = []
    for c in checkpoints {
        if _is_final_cp(c[1]) { finals.push(c[0]) }
    }
    if len(finals) == 0 {
        errs.push("[roadmap] no FINAL (🧠) checkpoint declared")
    } else if len(finals) >= 2 {
        let mut flist = ""
        let mut fi = 0
        while fi < len(finals) {
            if fi == 0 { flist = finals[fi] }
            else { flist = flist + ", " + finals[fi] }
            fi = fi + 1
        }
        errs.push("[roadmap] multiple FINAL checkpoints: " + flist)
    }
}

// ─── V5 BIPARTITE_DAG (entry ↔ checkpoint cycle detection) ───────────
//
// Graph model (bipartite over entries + checkpoints):
//   node  = "R:<rule_id>" | "C:<cp_id>"
//   edges:
//     R:<id> -reaches→ C:<cp>      (entry contributes to CP)
//     C:<cp> -satisfied-by→ R:<id> (inverse of reaches — a CP's satisfaction
//                                   depends on the entries reaching it)
//     R:<id> -requires→ C:<cp>     (entry depends on CP being satisfied)
//
// A cycle across these nodes means: CP's satisfaction depends on an
// entry's activation, which depends on another CP that (transitively)
// loops back. Reuses Kahn logic with string nodes.
if len(checkpoints) >= 1 {
    let mut nodes = []
    for r in rules { nodes.push("R:" + r[0]) }
    for c in checkpoints { nodes.push("C:" + c[0]) }

    let mut bedges = []
    let mut bindeg = []
    let mut bi = 0
    while bi < len(nodes) { bindeg.push(0); bi = bi + 1 }

    // Build DEPENDENCY edges (not declaration edges). Semantic model:
    //   requires: R depends on C being satisfied → edge  R → C
    //   reaches:  C's satisfaction depends on R being done → edge C → R
    // Under this model, a pure `reaches` (no corresponding requires) does
    // NOT create a cycle — it only injects a C→R edge. A cycle requires
    // the closing leg: C → R → C' → R' → ... → C.
    // Edges are de-duplicated to keep Kahn sweeps stable (duplicate edges
    // inflate in-degree and can mask a real DAG as a false cycle).
    for r in rules {
        let rn = "R:" + r[0]
        let rreach = _split_cp_refs(_keys_first(r[3], "reaches"))
        for cp in rreach {
            if len(_find_checkpoint(checkpoints, cp)) == 0 { continue }
            let cn = "C:" + cp
            // C -depends-on-> R (C is satisfied only when R done)
            let mut dup = false
            for e in bedges {
                if e[0] == cn && e[1] == rn { dup = true }
            }
            if !dup {
                bedges.push([cn, rn])
                let ridx = _idx_of(nodes, rn)
                if ridx >= 0 { bindeg = _arr_set_int(bindeg, ridx, bindeg[ridx] + 1) }
            }
        }
        let rreq = _split_cp_refs(_keys_first(r[3], "requires"))
        for cp in rreq {
            if len(_find_checkpoint(checkpoints, cp)) == 0 { continue }
            let cn = "C:" + cp
            // R -depends-on-> C (R can only activate once C satisfied)
            let mut dup2 = false
            for e in bedges {
                if e[0] == rn && e[1] == cn { dup2 = true }
            }
            if !dup2 {
                bedges.push([rn, cn])
                let cidx2 = _idx_of(nodes, cn)
                if cidx2 >= 0 { bindeg = _arr_set_int(bindeg, cidx2, bindeg[cidx2] + 1) }
            }
        }
    }

    // Kahn sweep
    let mut bqueue = []
    let mut bqi = 0
    while bqi < len(nodes) {
        if bindeg[bqi] == 0 { bqueue.push(nodes[bqi]) }
        bqi = bqi + 1
    }
    let mut bseen = 0
    let mut bhead = 0
    while bhead < len(bqueue) {
        let cur = bqueue[bhead]
        bhead = bhead + 1
        bseen = bseen + 1
        for e in bedges {
            if e[0] != cur { continue }
            let tidx = _idx_of(nodes, e[1])
            if tidx < 0 { continue }
            let nv = bindeg[tidx] - 1
            bindeg = _arr_set_int(bindeg, tidx, nv)
            if nv == 0 { bqueue.push(e[1]) }
        }
    }

    if bseen < len(nodes) {
        let mut bresid = []
        let mut bri = 0
        while bri < len(nodes) {
            if bindeg[bri] > 0 { bresid.push(nodes[bri]) }
            bri = bri + 1
        }
        if len(bresid) > 0 {
            let cyc = _cycle_walk(bresid[0], bresid, bedges)
            if len(cyc) >= 2 {
                let mut path_str = ""
                let mut pi = 0
                while pi < len(cyc) {
                    if pi == 0 { path_str = cyc[pi] }
                    else { path_str = path_str + " -> " + cyc[pi] }
                    pi = pi + 1
                }
                errs.push("[roadmap cycle] " + path_str)
            } else {
                let mut list_str = ""
                let mut li = 0
                while li < len(bresid) {
                    if li == 0 { list_str = bresid[li] }
                    else { list_str = list_str + ", " + bresid[li] }
                    li = li + 1
                }
                errs.push("[roadmap cycle] participants: " + list_str)
            }
        }
    }
}

println("── raw#15 roadmap_lint ──")
println("entries : " + to_string(len(rules)))
if len(checkpoints) > 0 {
    println("checkpoints : " + to_string(len(checkpoints)))
}

if len(errs) == 0 {
    println("✅ PASS")
    exit(0)
}

println("🚫 FAIL — " + to_string(len(errs)) + " violations")
for e in errs {
    eprintln("  " + e)
}
exit(1)
