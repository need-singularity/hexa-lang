#!hexa strict
// tool/commands_loader_test.hexa — smoke test for commands_loader.hexa

use "tool/commands_loader"

fn main() {
    let cmds = load_commands("shared/config/.commands")
    let n = len(cmds)
    println("loaded " + to_string(n) + " commands")

    let mut i = 0
    while i < n {
        let c = cmds[i]
        let kwn = len(c.keywords)
        let mut kw = ""
        let mut j = 0
        while j < kwn {
            if j > 0 { kw = kw + "," }
            kw = kw + c.keywords[j]
            j = j + 1
        }
        let shim_s = if c.shim { "y" } else { "n" }
        println("  [" + to_string(i) + "] " + c.name +
                " cat=" + c.category +
                " shim=" + shim_s +
                " kw=[" + kw + "]" +
                " handler=" + c.handler +
                " desc=\"" + c.description + "\"")
        i = i + 1
    }

    // lookup checks
    let hit_go = find_command(cmds, "가자")
    println("find(가자) -> " + hit_go.name)
    let hit_ls = find_command(cmds, "ls")
    println("find(ls) -> " + hit_ls.name)
    let miss = find_command(cmds, "nonexistent")
    println("find(nonexistent) -> '" + miss.name + "' (empty = miss)")

    let shims = shim_names(cmds)
    println("shim count = " + to_string(len(shims)))
    let mut k = 0
    let sm = len(shims)
    let mut sline = ""
    while k < sm {
        if k > 0 { sline = sline + "," }
        sline = sline + shims[k]
        k = k + 1
    }
    println("shims = [" + sline + "]")

    if n == 12 {
        println("OK: 12 commands")
    } else {
        println("FAIL: expected 12, got " + to_string(n))
    }
}
