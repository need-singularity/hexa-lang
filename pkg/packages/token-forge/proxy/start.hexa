// start.hexa — ported from pkg/packages/token-forge/proxy/start.sh
// token-forge compression proxy — one-liner launcher
// Usage:  hexa start.hexa          (foreground)
//         hexa start.hexa --bg     (background, logs to ~/.token-forge/proxy.log)

let script_dir = exec("dirname " + __file__)
let python = env("TF_PYTHON") ?? "/opt/homebrew/bin/python3.12"
let tf_port = env("TF_PORT") ?? "8080"

let mode = args(1) ?? "fg"

if mode == "--bg" {
    let result = exec("nohup " + python + " " + script_dir + "/server.py >> ~/.token-forge/proxy.log 2>&1 & echo $!")
    let pid = result.trim()
    print("[token-forge] proxy started in background (PID " + pid + ")")
    print("[token-forge] ANTHROPIC_BASE_URL=http://localhost:" + tf_port + "/v1 claude")
    shell("echo " + pid + " > ~/.token-forge/proxy.pid")
} else {
    shell(python + " " + script_dir + "/server.py")
}
