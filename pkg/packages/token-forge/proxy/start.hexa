// start.hexa — token-forge compression proxy launcher (self-host)
// 2026-04-11: server.py → server.hexa, python3 의존 제거.
// Usage:  hexa start.hexa          (foreground)
//         hexa start.hexa --bg     (background, logs to ~/.token-forge/proxy.log)

let argv1 = args()
// args() = [hexa_bin_path, script_path, ...user_args]
// 자기 스크립트 경로에서 dir 추출
let script_path = if len(argv1) > 1 { argv1[1] } else { "." }
let script_dir = exec("dirname " + script_path).trim()
let env_bin = env("HEXA_BIN")
let hexa_bin = if env_bin == "" { "/Users/ghost/Dev/hexa-lang/hexa" } else { env_bin }
let env_port = env("TF_PORT")
let tf_port = if env_port == "" { "8080" } else { env_port }

let mode = if len(argv1) > 2 { argv1[2] } else { "fg" }

if mode == "--bg" {
    let result = exec("nohup " + hexa_bin + " " + script_dir + "/server.hexa >> ~/.token-forge/proxy.log 2>&1 & echo $!")
    let pid = result.trim()
    print("[token-forge] proxy started in background (PID " + pid + ")")
    print("[token-forge] ANTHROPIC_BASE_URL=http://localhost:" + tf_port + "/v1 claude")
    exec("echo " + pid + " > ~/.token-forge/proxy.pid")
} else {
    exec(hexa_bin + " " + script_dir + "/server.hexa")
}
