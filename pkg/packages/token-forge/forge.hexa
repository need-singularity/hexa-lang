// token-forge — LLM token compression engine (hexa-lang)
// Absorbed from token-forge repo: proxy + cache + forge + anvil + bench
//
// 2026-04-11 cleanup:
//   - server.py → server.hexa (proxy entry)
//   - analyze_cache/bench_dfs/compress_messages 3건 모두 pure-hexa 재작성 완료.
//     json_parse + json_stringify + 직접 경로 mutation 으로 python3 의존 0.
//     주의: hexa 객체는 복사 시맨틱이라 let-bind 우회 불가, msgs[i][...]["k"] = v
//     처럼 풀 경로 mutation 필수.

// ═══════════════════════════════════════════════════════════════════════
//  CONSTANTS
// ═══════════════════════════════════════════════════════════════════════

let VERSION = "0.2.0"
let MAX_CTX = comptime { 4000 }
let KEEP_RECENT = comptime { 5 }
let COMPRESS_THRESHOLD = comptime { 800 }
let PROXY_PORT = 8080
let UPSTREAM = "https://api.anthropic.com"

// ═══════════════════════════════════════════════════════════════════════
//  EFFECTS
// ═══════════════════════════════════════════════════════════════════════

effect LLMCall {
    fn call(prompt: str) -> str
    fn call_stream(prompt: str) -> str
}

effect FileSystem {
    fn read(path: str) -> str
    fn write(path: str, content: str) -> void
    fn glob(pattern: str) -> [str]
}

effect HttpProxy {
    fn listen(port: int) -> void
    fn forward(url: str, body: str, headers: str) -> str
}

// ═══════════════════════════════════════════════════════════════════════
//  COMPRESSION ENGINE (forge)
// ═══════════════════════════════════════════════════════════════════════

fn compress_safe(text: str) -> str {
    if len(text) < COMPRESS_THRESHOLD {
        return text
    }
    let prompt = "Compress for LLM. PRESERVE ALL: filenames, functions, decisions, code. Remove only filler.\n---\n" + text.substring(0, MAX_CTX) + "\n---\nCompressed:"
    return exec("claude -p '" + prompt.replace("'", "'\\''") + "' 2>/dev/null").trim()
}

fn compress_twostage(text: str) -> str {
    let prompt = "Two-stage: 1) Dense summary (200w max) 2) KEY=value pairs.\n---\n" + text.substring(0, MAX_CTX) + "\n---\nSUMMARY: "
    return exec("claude -p '" + prompt.replace("'", "'\\''") + "' 2>/dev/null").trim()
}

// ═══════════════════════════════════════════════════════════════════════
//  PROXY — message compression
// ═══════════════════════════════════════════════════════════════════════

fn compress_messages(messages: str, keep_recent: int, max_tool: int, max_asst: int) -> str {
    // 2026-04-11: pure-hexa rewrite — json_parse + 직접 경로 변형 + json_stringify.
    // python3 의존 0 (forge.hexa 3건 중 마지막). hexa 객체 mutation 의미는 복사
    // 시맨틱이라 `let m = msgs[i]` 우회 불가 → msgs[i][...] 풀 경로로 변형 필수.
    let msgs = json_parse(messages)
    let n = len(msgs)
    let limit = if n - keep_recent > 0 { n - keep_recent } else { 0 }
    let mut i = 0
    while i < limit {
        let content = msgs[i]["content"]
        let ctype = type_of(content)
        if ctype == "array" {
            let nc = len(content)
            let mut j = 0
            while j < nc {
                let block = msgs[i]["content"][j]
                if type_of(block) == "map" {
                    if block["type"] == "tool_result" {
                        let bc = to_string(block["content"])
                        if len(bc) > max_tool {
                            msgs[i]["content"][j]["content"] = bc.substring(0, max_tool) + "...[truncated]"
                        }
                    }
                }
                j = j + 1
            }
        } else if ctype == "string" && msgs[i]["role"] == "assistant" {
            let cstr = to_string(content)
            if len(cstr) > max_asst {
                msgs[i]["content"] = cstr.substring(0, max_asst) + "...[truncated]"
            }
        }
        i = i + 1
    }
    return json_stringify(msgs)
}

// ═══════════════════════════════════════════════════════════════════════
//  CACHE ANALYZER
// ═══════════════════════════════════════════════════════════════════════

fn analyze_cache(session_path: str) -> str {
    // 2026-04-11: pure-hexa rewrite — read_file + json_parse + 정수 누적.
    // python3 의존 0 (forge.hexa 3건 중 1건 해소).
    let content = read_file(session_path)
    let lines = content.split("\n")
    let mut turns = 0
    let mut total_in = 0
    let mut total_cache = 0
    let mut total_create = 0
    let mut total_out = 0
    for line in lines {
        if len(line) > 0 {
            let d = json_parse(line)
            if d["type"] == "assistant" {
                let msg = d["message"]
                let u = msg["usage"]
                if to_string(u) != "" {
                    turns = turns + 1
                    total_in = total_in + to_int(u["input_tokens"])
                    total_cache = total_cache + to_int(u["cache_read_input_tokens"])
                    total_create = total_create + to_int(u["cache_creation_input_tokens"])
                    total_out = total_out + to_int(u["output_tokens"])
                }
            }
        }
    }
    if turns == 0 { return "no data" }
    let denom = total_cache + total_create + total_in
    let hit_pct = if denom > 0 { (total_cache * 1000) / denom } else { 0 }
    // hit_pct = hit% × 10 (1자리 정수 분수)
    let hit_int = hit_pct / 10
    let hit_frac = hit_pct - (hit_int * 10)
    return "turns=" + to_string(turns) +
           " cache_hit=" + to_string(hit_int) + "." + to_string(hit_frac) + "%" +
           " in=" + to_string(total_in) +
           " cache_read=" + to_string(total_cache) +
           " create=" + to_string(total_create) +
           " out=" + to_string(total_out)
}

// ═══════════════════════════════════════════════════════════════════════
//  VERIFICATION (anvil)
// ═══════════════════════════════════════════════════════════════════════

fn verify_similarity(response_a: str, response_b: str) -> int {
    let prompt = "Rate semantic similarity 0-100.\nA: " + response_a.substring(0, 600) + "\nB: " + response_b.substring(0, 600) + "\nOutput ONLY number:"
    let result = exec("claude -p '" + prompt.replace("'", "'\\''") + "' 2>/dev/null").trim()
    // extract first number
    let parts = result.split(" ")
    let i = 0
    while i < len(parts) {
        let n = to_int(parts[i])
        if n >= 0 {
            return n
        }
        i = i + 1
    }
    return -1
}

// ═══════════════════════════════════════════════════════════════════════
//  BENCHMARK — DFS depth comparison
// ═══════════════════════════════════════════════════════════════════════

fn bench_dfs(session_path: str, max_depth: int) -> str {
    println("⬡ token-forge DFS benchmark (hexa)")
    println("  keep_recent=" + to_string(KEEP_RECENT) + " threshold=" + to_string(COMPRESS_THRESHOLD))
    println("")

    let cache_info = analyze_cache(session_path)
    println("  cache: " + cache_info)
    println("")

    // 2026-04-11: pure-hexa rewrite — read_file + json_parse 만으로 user/assistant
    // 메시지를 카운트. 결과 문자열은 사용처가 없어 카운트만 출력.
    let raw = read_file(session_path)
    let lines = raw.split("\n")
    let mut msg_count = 0
    let cap = 50
    for line in lines {
        if msg_count >= cap { } else if len(line) > 0 {
            let d = json_parse(line)
            let r = d["type"]
            if r == "user" || r == "assistant" {
                msg_count = msg_count + 1
            }
        }
    }
    println("  parsed messages: " + to_string(msg_count) + " (cap " + to_string(cap) + ")")

    return "benchmark complete — see bench reports"
}

// ═══════════════════════════════════════════════════════════════════════
//  CLI ROUTER
// ═══════════════════════════════════════════════════════════════════════

fn print_help() -> str {
    println("token-forge v" + VERSION + " — LLM token compression (hexa)")
    println("")
    println("Commands:")
    println("  proxy     — start compression proxy (port " + to_string(PROXY_PORT) + ")")
    println("  cache     — analyze session cache hit rate")
    println("  compress  — compress a text file")
    println("  bench     — run DFS benchmark")
    println("  verify    — verify compression quality")
    println("  help      — show this message")
    return "ok"
}

consciousness TokenForgeRouter {
    assert len(VERSION) > 0
    assert MAX_CTX == 4000
    assert KEEP_RECENT == 5
    assert PROXY_PORT == 8080

    let argv = args()
    let cmd = "help"
    if len(argv) > 3 {
        cmd = argv[3]
    }

    if cmd == "proxy" {
        println("⬡ starting compression proxy on :" + to_string(PROXY_PORT))
        println("  ANTHROPIC_BASE_URL=http://localhost:" + to_string(PROXY_PORT) + "/v1 claude")
        // 2026-04-11: server.py → server.hexa, python3 → ./hexa
        let env_bin = env("HEXA_BIN")
        let _hexa_root = if len(env("HEXA_LANG")) > 0 { env("HEXA_LANG") } else { "." }
        let hexa_bin = if env_bin == "" { _hexa_root + "/hexa" } else { env_bin }
        exec(hexa_bin + " " + argv[2].replace("forge.hexa", "proxy/server.hexa"))
    }
    if cmd == "cache" {
        if len(argv) > 4 {
            let info = analyze_cache(argv[4])
            println(info)
        }
        if len(argv) <= 4 {
            println("usage: token-forge cache <session.jsonl>")
        }
    }
    if cmd == "bench" {
        if len(argv) > 4 {
            bench_dfs(argv[4], 5)
        }
        if len(argv) <= 4 {
            println("usage: token-forge bench <session.jsonl>")
        }
    }
    if cmd == "help" { print_help() }
}
