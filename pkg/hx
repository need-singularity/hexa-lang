#!/bin/bash
# hx — hexa package manager
# Usage: hx install <pkg> | hx run <pkg> | hx list | hx remove <pkg>
set -e

HX_HOME="${HX_HOME:-$HOME/.hx}"
HX_BIN="$HX_HOME/bin"
HX_PKG="$HX_HOME/packages"
REGISTRY_REMOTE="https://raw.githubusercontent.com/dancinlife/hexa-lang/main/pkg/registry.json"
HX_SCRIPT="$(readlink "$0" 2>/dev/null || echo "$0")"
HX_DIR="$(cd "$(dirname "$HX_SCRIPT")" && pwd)"
REGISTRY_LOCAL="${HX_DIR}/registry.json"
[ ! -f "$REGISTRY_LOCAL" ] && REGISTRY_LOCAL="${HX_DIR}/../pkg/registry.json"

mkdir -p "$HX_BIN" "$HX_PKG"

red()   { printf '\033[31m%s\033[0m\n' "$*"; }
green() { printf '\033[32m%s\033[0m\n' "$*"; }
dim()   { printf '\033[2m%s\033[0m\n' "$*"; }

usage() {
  echo "hx — hexa package manager"
  echo ""
  echo "  hx install <pkg>   Install a package"
  echo "  hx run <pkg>       Run installed package"
  echo "  hx list            List installed packages"
  echo "  hx remove <pkg>    Remove a package"
  echo "  hx search          Show available packages"
  echo ""
}

fetch_registry() {
  # local first, remote fallback
  if [ -f "$REGISTRY_LOCAL" ]; then
    cat "$REGISTRY_LOCAL"
  elif command -v curl >/dev/null; then
    curl -sL "$REGISTRY_REMOTE"
  elif command -v wget >/dev/null; then
    wget -qO- "$REGISTRY_REMOTE"
  else
    red "error: curl or wget required"
    exit 1
  fi
}

pkg_field() {
  local pkg="$1" field="$2" json="$3"
  echo "$json" | python3 -c "
import sys,json
d=json.load(sys.stdin)
p=d.get('packages',{}).get('$pkg')
if p: print(p.get('$field',''))
else: sys.exit(1)
" 2>/dev/null
}

cmd_install() {
  local pkg="$1"
  [ -z "$pkg" ] && { red "usage: hx install <pkg>"; exit 1; }

  green "⬡ fetching registry..."
  local reg
  reg=$(fetch_registry)

  local repo entry desc
  repo=$(pkg_field "$pkg" "repo" "$reg") || { red "package '$pkg' not found"; exit 1; }
  entry=$(pkg_field "$pkg" "entry" "$reg")
  desc=$(pkg_field "$pkg" "desc" "$reg")

  dim "  $desc"
  # local path override: check ~/Dev/<pkg> first
  local local_path="$HOME/Dev/$pkg"
  local dest="$HX_PKG/$pkg"
  rm -rf "$dest"

  if [ -d "$local_path" ]; then
    green "⬡ linking $pkg (local: $local_path)..."
    ln -s "$local_path" "$dest"
  else
    green "⬡ cloning $pkg..."
    git clone --depth 1 --quiet "$repo" "$dest"
  fi

  # symlink entry to bin
  if [ -n "$entry" ] && [ -f "$dest/$entry" ]; then
    chmod +x "$dest/$entry"
    ln -sf "$dest/$entry" "$HX_BIN/$pkg"
    green "⬡ installed: $pkg"
    dim "  run with: hx run $pkg  (or: $pkg)"
  else
    red "warning: entry '$entry' not found in repo"
  fi
}

cmd_run() {
  local pkg="$1"; shift 2>/dev/null || true
  [ -z "$pkg" ] && { red "usage: hx run <pkg>"; exit 1; }

  local bin="$HX_BIN/$pkg"
  [ -x "$bin" ] || { red "'$pkg' not installed. Run: hx install $pkg"; exit 1; }
  exec "$bin" "$@"
}

cmd_list() {
  if [ -d "$HX_BIN" ] && [ "$(ls -A "$HX_BIN" 2>/dev/null)" ]; then
    green "⬡ installed packages:"
    for f in "$HX_BIN"/*; do
      echo "  $(basename "$f")"
    done
  else
    dim "  no packages installed"
  fi
}

cmd_remove() {
  local pkg="$1"
  [ -z "$pkg" ] && { red "usage: hx remove <pkg>"; exit 1; }

  rm -f "$HX_BIN/$pkg"
  rm -rf "$HX_PKG/$pkg"
  green "⬡ removed: $pkg"
}

cmd_search() {
  green "⬡ available packages:"
  local reg
  reg=$(fetch_registry)
  echo "$reg" | python3 -c "
import sys,json
d=json.load(sys.stdin)
for k,v in d.get('packages',{}).items():
    print(f\"  {k} ({v.get('version','?')}) — {v.get('desc','')}\")
"
}

case "${1:-}" in
  install) cmd_install "$2" ;;
  run)     shift; cmd_run "$@" ;;
  list)    cmd_list ;;
  remove)  cmd_remove "$2" ;;
  search)  cmd_search ;;
  *)       usage ;;
esac
