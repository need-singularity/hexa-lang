// install.hexa — ported from pkg/install.sh
// hx installer — one-liner: curl -sL <url> | bash

let hx_home = env("HX_HOME") ?? env("HOME") + "/.hx"
let hx_bin = hx_home + "/bin"
let hx_url = "https://raw.githubusercontent.com/dancinlife/hexa-lang/main/pkg/hx"

shell("mkdir -p " + hx_bin)

print("⬡ installing hx...")
shell("curl -sL " + hx_url + " -o " + hx_bin + "/hx")
shell("chmod +x " + hx_bin + "/hx")

// add to PATH if not already
let home = env("HOME")
let zshrc = home + "/.zshrc"
let bashrc = home + "/.bashrc"
let shell_rc = if file_exists(bashrc) && !file_exists(zshrc) { bashrc } else { zshrc }

let grep_result = exec("grep -q '.hx/bin' " + shell_rc + " 2>/dev/null && echo found || echo missing")
if grep_result.trim() == "missing" {
    shell("echo '' >> " + shell_rc)
    shell("echo '# hx — hexa package manager' >> " + shell_rc)
    shell("echo 'export PATH=\"$HOME/.hx/bin:$PATH\"' >> " + shell_rc)
    let rc_name = exec("basename " + shell_rc)
    print("⬡ added ~/.hx/bin to PATH in " + rc_name.trim())
}

print("⬡ done! restart terminal or run:")
print("  export PATH=\"$HOME/.hx/bin:$PATH\"")
print("")
print("then:")
print("  hx install airgenome")
