#!hexa strict
// @tool(slug="attr_ecosystem_source", desc="hexa-lang attr-ecosystem AI-native interface contract — 5 new attrs (B3 falsifier / B4 sister / B6 user-verbatim-record-exempt / B7 migration-quarantine / B9 env_required)")
// @sentinel(__ATTR_ECOSYSTEM_SOURCE__ <PASS|FAIL> mode=<selftest>)
// @usage(hexa hexa-lang/attr_ecosystem/core/source.hexa)
// @resolver-bypass(reason="local interface contract selftest, no network/heavy compute")
//
// hexa-lang/attr_ecosystem/core/source.hexa — attr-ecosystem interface
//
// Purpose
//   Single canonical contract that every attr-ecosystem module
//   (B3..B9) must satisfy. Sister to attr_format/core/source.hexa
//   (Level 3b WRAPPED v1..v5 evolution axis) — this is the
//   ECOSYSTEM axis, perpendicular to the format axis.
//
//   Where attr_format wraps the *form* of the @attr (comment / AST /
//   typed / composition / future), attr_ecosystem wraps the *catalog*
//   of cross-cutting attrs that hive-side rules want to formalize.
//
// raw#9 hexa-only strict. Additive-only — no migration.
//
// CONTRACT (every attr-ecosystem module must export):
//   fn attr_<name>_meta()                       -> AttrFormatMeta
//   fn attr_<name>_parse(src: str)              -> AttrParseResult
//   fn attr_<name>_validate(decls: [AttrDecl])  -> AttrValidateResult
//   fn attr_<name>_emit(pr: AttrParseResult)    -> str
//
// MODULES SHIPPED IN THIS LAND (5)
//   B3 attr_ecosystem/module/attr_falsifier.hexa
//      @falsifier(id, desc, observable, action_on_fail)
//   B4 attr_ecosystem/module/attr_sister.hexa
//      @sister(path[, relation])  + path-exist verify
//   B6 attr_ecosystem/module/attr_user_verbatim_record_exempt.hexa
//      @user-verbatim-record-exempt(reason)  + applies(hit_line, window)
//   B7 attr_ecosystem/module/attr_migration_quarantine.hexa
//      @migration-quarantine(reason, scope[, path])  + covers(line, total)
//   B9 attr_ecosystem/module/attr_env_required.hexa
//      @env_required(name[, fallback])  + resolve(decl)
//
// raw#10 caveats
//   (1) Each module is self-contained — no cross-module imports.
//       Aggregator (attr_ecosystem_main.hexa) drives selftests.
//   (2) The 5 modules use struct mirrors of AttrFormatMeta /
//       AttrDecl / etc. (same shapes as attr_format/core/source.hexa).
//       SSOT for the contract is THIS file; mirror drift = SSOT
//       violation.
//   (3) Validation only — runtime enforcement (action_on_fail dispatch,
//       lint suppression, build exclusion, env resolution) is owned by
//       sister tools that consume parse() output.

// ── AttrFormatMeta — version metadata ────────────────────────

struct AttrFormatMeta {
    name:                 str,
    version:              int,
    form:                 str,
    phase:                str,
    status:               str,
    supports_composition: int,
    supports_typing:      int,
    catalog_size:         int,
    spec_doc:             str,
    notes:                str
}

// ── AttrDecl — single attr declaration ───────────────────────

struct AttrDecl {
    name:         str,
    params:       [str],
    line:         int,
    col:          int,
    mode:         str,
    form_version: str
}

struct AttrParseResult {
    ok:       int,
    n_decls:  int,
    decls:    [AttrDecl],
    message:  str
}

struct AttrIssue {
    severity:  str,
    attr_name: str,
    line:      int,
    msg:       str
}

struct AttrValidateResult {
    ok:        int,
    n_issues:  int,
    issues:    [AttrIssue],
    message:   str
}

// ── Selftest ─────────────────────────────────────────────────

fn _selftest() -> int {
    // Constructor round-trip — just ensure the structs compose.
    let m = AttrFormatMeta {
        name: "test", version: 1, form: "comment", phase: "ecosystem_mk2",
        status: "WRAPPED", supports_composition: 0, supports_typing: 1,
        catalog_size: 5, spec_doc: "x", notes: "y"
    }
    if m.name != "test" { return 0 }
    if m.catalog_size != 5 { return 0 }

    let d = AttrDecl { name: "t", params: ["a=b"], line: 1, col: 1, mode: "decl", form_version: "ecosystem_b0" }
    if d.name != "t" { return 0 }
    if len(d.params) != 1 { return 0 }

    let pr = AttrParseResult { ok: 1, n_decls: 1, decls: [d], message: "ok" }
    if pr.ok != 1 { return 0 }
    if pr.n_decls != 1 { return 0 }

    let iss = AttrIssue { severity: "error", attr_name: "t", line: 1, msg: "x" }
    let vr = AttrValidateResult { ok: 0, n_issues: 1, issues: [iss], message: "x" }
    if vr.ok != 0 { return 0 }
    if vr.n_issues != 1 { return 0 }
    return 1
}

fn main() {
    println("[attr_ecosystem/source] interface contract — 5 module ecosystem")
    if _selftest() == 1 {
        println("[attr_ecosystem/source] SELFTEST PASS")
        println("__ATTR_ECOSYSTEM_SOURCE__ PASS mode=selftest")
    } else {
        println("[attr_ecosystem/source] SELFTEST FAIL")
        println("__ATTR_ECOSYSTEM_SOURCE__ FAIL mode=selftest")
    }
}
