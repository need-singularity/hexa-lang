/target/
hexa
hexa_test
hexa.prev*
playground/pkg/
hexa_old
.growth/
.DS_Store
build/
# baseline native interpreter source — must survive gitignore (SH-P3-1 소실 방지)
!build/artifacts/hexa_native_baseline.c
ready

.claude/*
!.claude/settings.json
!.claude/hooks/
!.claude/commands/

# Python bytecode noise
__pycache__/
*.pyc

# AOT build cache (hexa run)
.hexa-cache/

# Scratch space
tmp/

# hx install destinations for third-party packages (e.g. lib/yoga via `hx install yoga`)
# Use a sibling-level negate so first-party dirs (e.g. lib/hxnccl) stay tracked.
lib/*/
!lib/hxnccl/
# Build artefacts inside first-party libs are still ignored.
lib/hxnccl/build/

# Rust baseline benchmark build artifacts (cargo target/)
bench/rust_baseline/target/

# Large data files (exceeds GitHub 100MB limit)
shared/discovery_log.jsonl

# Removed legacy Rust build (commits 08caf07 / 94ffd0f)
src/
Cargo.toml
Cargo.lock
.cargo/

# Backup binaries / patched intermediates
hexa.backup_*
hexa.patched
hexa.pre_fix*
hexa.test
self/*.bin.o

# Scratch / debug / repro / probe files
self/dbg_*.hexa
self/mh_debug*.hexa
self/_*.hexa
self/arr_test*.hexa
self/att_fn_test.hexa
self/idx_test.hexa
self/debug_*.hexa
diag*.hexa
self/interpreter.hexa.c

# Claude Code memory (account-shared, local only)
.claude-memory/

# Backup snapshots of stage0/codegen (pre-regression checkpoints, local only)
*.bak_*
# Rust prebuilt shim at repo root (dev-only, built from hexa_v2 pipeline)
hexa.real
hexa.real.bak_*
# Staging artifact from hexa_v2 regen pipeline (canonical is hexa_cc.c)
self/native/hexa_cc.c.new

# Local smoke/session artifacts (not tracked)
shared/state/

# Attr hook regen artifacts (superseded by scripts/hooks/)
.attr-generated/

# Transient native/smoke artifacts at repo root
/err.log
/launch_*.o

# stage0 nightly rebuild backups (local-only safety copies)
self/native/hexa_v2.pre_nightly_rebuild_*
self/native/hexa_v2.pre_*

# raw#0 attestation HMAC key — repo-private, must mirror as CI secret
.raw-attest-key

# raw#0 P1d sha256 fast-path cache — per-user runtime state, invalidated
# on every SSOT edit (fingerprint shift). Safe to delete; regenerated.
.raw-cache/

# raw#15 roadmap progress snapshot — regenerated every raw_all run.
# Observational dashboard artifact, no commit noise.
.raw-status/

# raw#1 hash-chain migration backups — snapshot of pre-chain .raw-audit
# written once at migration time and on each rotate. Local-only archives.
.raw-audit.pre-chain
.raw-audit.pre-chain.*

# Compiled native shared libraries under self/native — built locally from
# the .c/.cu sources in the same directory. Do not ship binaries.
self/native/*.dylib
self/native/*.so

# BT-HEXA-28 Meta² fixpoint certificate chain — local-only (git history is
# the team-wide record; the chain here is a per-host tamper-evidence log).
.meta2-cert/
