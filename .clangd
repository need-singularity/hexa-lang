# clangd configuration — hexa-lang workspace
#
# The self/native/*.c files include "runtime.c" relative to self/, not
# relative to self/native/. Without this, clangd cannot resolve HexaVal
# and emits a wall of spurious "unknown type name" diagnostics even
# though the live build (clang -I self self/native/hexa_cc.c) succeeds.
#
# Ref: tool/build_hexa_v2_linux.hexa:54 (src = self/native/hexa_cc.c)
#      tool/build_stage0.hexa:105      (clang … -I self … hexa_cc.c)
CompileFlags:
  Add:
    - -I.
    - -Iself
    - -Iself/native
    - -D_GNU_SOURCE
    - -std=gnu11

# Legacy parity files — suppress diagnostics (dead; slated for hard-delete
# per doc/plans/runtime_c_purge.md Phase C).
---
If:
  PathMatch: self/native/(codegen_c2_v2|lexer_v2|parser_v2|type_checker_v2)\.c
Diagnostics:
  Suppress: ["*"]
