// ═══════════════════════════════════════════════════════════
//  test_closure_capture.hexa — C3 Phase 2 Closure Capture
//  Validates: free variable capture, nested lambdas, counter
//              closures, shadowing, capture-by-value semantics,
//              deep nesting, recursion through captured name.
//
//  Target surfaces:
//    - self/interpreter.hexa  (already handles closures via env snapshot)
//    - self/codegen_c2.hexa   (emits closure env struct + dispatch)
//
//  Reference semantics are validated through the main interpreter;
//  this file is the regression contract for the self-hosted path.
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  C3 Closure Capture — Free Variable Tests")
println("═══════════════════════════════════════════════════════")

// ── 1. Single int capture ────────────────────────────────
let a = 10
let f1 = |x| x + a
check("cap int", f1(5), 15)

// ── 2. Multiple int captures ──────────────────────────────
let p = 3
let q = 4
let f2 = |x| x * p + q
check("cap multi int", f2(10), 34)

// ── 3. String capture ────────────────────────────────────
let prefix = ">>> "
let f3 = |s| prefix + s
check("cap string", f3("hi"), ">>> hi")

// ── 4. Array capture (read) ──────────────────────────────
let arr = [10, 20, 30]
let f4 = |i| arr[i]
check("cap array[0]", f4(0), 10)
check("cap array[2]", f4(2), 30)

// ── 5. Capture-by-value (shadowing after creation) ───────
let v = 7
let f5 = |x| x + v
let v2 = 100
check("cap by value", f5(1), 8)

// ── 6. Counter closure (via rebinding pattern) ───────────
fn make_counter(start) {
    return |step| start + step
}
let c1 = make_counter(100)
check("counter 100+5", c1(5), 105)
check("counter 100+9", c1(9), 109)

// ── 7. Two counters independent ──────────────────────────
let c2 = make_counter(200)
check("counter2 200+1", c2(1), 201)
check("counter1 still 100+2", c1(2), 102)

// ── 8. Nested lambda capture outer param ─────────────────
fn outer_fn(a) {
    let inner = |b| {
        let inner2 = |c| a + b + c
        return inner2(1)
    }
    return inner(10)
}
check("nested 3-level", outer_fn(100), 111)

// ── 9. Closure returned from closure ─────────────────────
fn adder_factory() {
    let base = 1000
    return |x| {
        return |y| base + x + y
    }
}
let f9 = adder_factory()
let f9a = f9(20)
check("closure-returning-closure", f9a(3), 1023)

// ── 10. Capture in for loop ──────────────────────────────
fn make_adders() {
    let mut result = []
    let mut i = 0
    while i < 3 {
        let k = i
        result.push(|x| x + k)
        i = i + 1
    }
    return result
}
let adders = make_adders()
check("loop-cap adders[0](10)", adders[0](10), 10)
check("loop-cap adders[1](10)", adders[1](10), 11)
check("loop-cap adders[2](10)", adders[2](10), 12)

// ── 11. Compose with captured fns ────────────────────────
fn compose2(f, g) {
    return |x| f(g(x))
}
let inc2 = |x| x + 1
let dbl = |x| x * 2
let c11 = compose2(dbl, inc2)
check("compose dbl(inc(5))", c11(5), 12)

// ── 12. Capture into higher-order map ────────────────────
fn map_arr(arr, f) {
    let mut out = []
    for v in arr {
        out.push(f(v))
    }
    return out
}
let k12 = 3
let r12 = map_arr([1, 2, 3, 4], |x| x * k12)
check("map cap k*x len", len(r12), 4)
check("map cap k*x [0]", r12[0], 3)
check("map cap k*x [3]", r12[3], 12)

// ── 13. Filter with captured threshold ───────────────────
fn filter_arr(arr, pred) {
    let mut out = []
    for v in arr {
        if pred(v) { out.push(v) }
    }
    return out
}
let threshold = 5
let r13 = filter_arr([1, 10, 3, 20, 5, 30], |x| x > threshold)
check("filter cap len", len(r13), 3)
check("filter cap [0]", r13[0], 10)

// ── 14. Reduce with captured mul factor ──────────────────
fn reduce_arr(arr, init, f) {
    let mut acc = init
    for v in arr {
        acc = f(acc, v)
    }
    return acc
}
let mulf = 2
let r14 = reduce_arr([1, 2, 3, 4], 0, |a, b| a + b * mulf)
check("reduce cap", r14, 20)

// ── 15. Deep nesting (4 levels) ──────────────────────────
fn deep4() {
    let a1 = 1
    let f = |x| {
        let a2 = 10
        let g = |y| {
            let a3 = 100
            let h = |z| {
                return a1 + a2 + a3 + x + y + z
            }
            return h(1000)
        }
        return g(100)
    }
    return f(10)
}
check("deep4 nesting", deep4(), 1221)

// ── 16. Capture then call inside another lambda arg ──────
let m = 5
let apply = |f, v| f(v)
check("apply cap", apply(|x| x + m, 3), 8)

// ── 17. Higher order: fn param called with captured var ──
fn twice_fn(f, x) {
    return f(f(x))
}
let plus2 = 2
check("twice cap", twice_fn(|x| x + plus2, 10), 14)

// ═══════════════════════════════════════════════════════════
let total = pass_count + fail_count
println("")
println("═══════════════════════════════════════════════════════")
println("  Closure Capture: " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL / " + to_string(total) + " total")
if fail_count == 0 {
    println("  ALL CLOSURE CAPTURE TESTS PASSED!")
} else {
    println("  SOME TESTS FAILED")
}
println("═══════════════════════════════════════════════════════")
