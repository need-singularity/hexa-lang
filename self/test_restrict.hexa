// =====================================================================
//  test_restrict.hexa -- @restrict (noalias pointer marking) tests
//
//  @restrict marks pointer params as non-aliasing (C restrict),
//  enabling loop vectorization and reordering optimizations.
//  Validates: >=2 params required, pass recognition, semantics.
//
//  Run: ./hexa test self/test_restrict.hexa
// =====================================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_bool(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

println("=====================================================")
println("  HEXA @restrict (noalias) Test Suite")
println("=====================================================")
println("")

// -- 1. Basic @restrict: two-param fn (valid) --
println("--- 1. @restrict basic two-param ---")

@restrict fn vec_add(a, b) {
    let mut result = []
    let mut i = 0
    while i < len(a) {
        result.push(a[i] + b[i])
        i = i + 1
    }
    return result
}

let r1 = vec_add([1, 2, 3], [4, 5, 6])
check("restrict vec_add [0]", r1[0], 5)
check("restrict vec_add [1]", r1[1], 7)
check("restrict vec_add [2]", r1[2], 9)

// -- 2. @restrict with three params --
println("")
println("--- 2. @restrict three-param ---")

@restrict fn vec_fma(a, b, c) {
    let mut result = []
    let mut i = 0
    while i < len(a) {
        result.push(a[i] * b[i] + c[i])
        i = i + 1
    }
    return result
}

let r2 = vec_fma([1, 2, 3], [4, 5, 6], [10, 20, 30])
check("restrict vec_fma [0]", r2[0], 14)
check("restrict vec_fma [1]", r2[1], 30)
check("restrict vec_fma [2]", r2[2], 48)

// -- 3. @restrict with accumulation (dot product) --
println("")
println("--- 3. @restrict dot product ---")

@restrict fn dot_product(a, b) {
    let mut sum = 0
    let mut i = 0
    while i < len(a) {
        sum = sum + a[i] * b[i]
        i = i + 1
    }
    return sum
}

let dp = dot_product([1, 2, 3], [4, 5, 6])
check("restrict dot_product", dp, 32)

// -- 4. @restrict enables safe loop reordering --
println("")
println("--- 4. @restrict loop reordering safe ---")

@restrict fn scale_add(dst, src, factor) {
    let mut result = []
    let mut i = 0
    while i < len(dst) {
        result.push(dst[i] + src[i] * factor)
        i = i + 1
    }
    return result
}

let r4 = scale_add([10, 20, 30], [1, 2, 3], 5)
check("restrict scale_add [0]", r4[0], 15)
check("restrict scale_add [1]", r4[1], 30)
check("restrict scale_add [2]", r4[2], 45)

// -- 5. @restrict correctness: non-aliasing guarantee --
println("")
println("--- 5. @restrict non-aliasing correctness ---")

@restrict fn copy_add(dest, src) {
    let mut result = []
    let mut i = 0
    while i < len(src) {
        result.push(src[i] + 1)
        i = i + 1
    }
    return result
}

let r5 = copy_add([0, 0, 0], [10, 20, 30])
check("restrict copy_add [0]", r5[0], 11)
check("restrict copy_add [1]", r5[1], 21)
check("restrict copy_add [2]", r5[2], 31)

// -- 6. @restrict with @pure combination --
println("")
println("--- 6. @restrict + @pure ---")

@restrict @pure fn pure_dot(a, b) {
    let mut sum = 0
    let mut i = 0
    while i < len(a) {
        sum = sum + a[i] * b[i]
        i = i + 1
    }
    return sum
}

let pd1 = pure_dot([2, 3], [4, 5])
let pd2 = pure_dot([2, 3], [4, 5])
check("restrict+pure value", pd1, 23)
check("restrict+pure same args", pd1 == pd2, true)

// -- 7. @restrict with scalar output --
println("")
println("--- 7. @restrict max element ---")

@restrict fn max_elem(a, b) {
    let mut mx = a[0]
    let mut i = 0
    while i < len(a) {
        if a[i] > mx { mx = a[i] }
        i = i + 1
    }
    let mut j = 0
    while j < len(b) {
        if b[j] > mx { mx = b[j] }
        j = j + 1
    }
    return mx
}

check("restrict max_elem", max_elem([1, 5, 3], [2, 8, 4]), 8)

// -- Summary --
println("")
println("=====================================================")
println("  @restrict tests: " + to_string(pass_count) + " PASS, " + to_string(fail_count) + " FAIL")
println("=====================================================")
if fail_count > 0 {
    println("SOME TESTS FAILED")
}
