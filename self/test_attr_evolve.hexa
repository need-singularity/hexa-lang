// ═══════════════════════════════════════════════════════════
//  test_attr_evolve.hexa — C4 structural admissibility seal tests
//
//  Verifies evolve_attr_seal (self/stdlib/evolve.hexa) against
//  raw 68 idempotence-witness + raw 73 structural-admissibility
//  paradigm. Pure-fn input MUST produce deterministic attr set;
//  re-applying the seal MUST be byte-eq (no search, no oscillation).
//
//  Inlined per existing test_evolve.hexa convention (fn-param
//  shadowing bug workaround in interpreter).
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

// ── inlined C4 seal API (mirror of self/stdlib/evolve.hexa) ──

fn meta_get(meta, key) {
    let mut i = 0
    while i < len(meta) {
        if meta[i][0] == key { return meta[i][1] }
        i = i + 1
    }
    return false
}

fn attr_seal(meta) {
    let is_pure = meta_get(meta, "pure")
    let is_hot = meta_get(meta, "hot")
    let has_loop = meta_get(meta, "has_loop")
    let has_io = meta_get(meta, "has_io")
    let mut attrs = []
    if is_pure {
        attrs.push("@const")
        attrs.push("@memoize")
        attrs.push("@pure")
        if is_hot {
            attrs.push("@hot")
            attrs.push("@inline")
        }
        if has_loop {
            if !has_io {
                attrs.push("@simd")
                attrs.push("@vectorize")
            }
        }
    }
    return attrs
}

fn attr_eq(a, b) {
    if len(a) != len(b) { return false }
    let mut i = 0
    while i < len(a) {
        if a[i] != b[i] { return false }
        i = i + 1
    }
    return true
}

fn attr_seal_idempotent(meta) {
    let r1 = attr_seal(meta)
    let r2 = attr_seal(meta)
    return attr_eq(r1, r2)
}

// ── tests ──────────────────────────────────────────────────

println("═══════════════════════════════════════════════════════")
println("  HEXA C4 attr_seal — raw 73 structural admissibility")
println("═══════════════════════════════════════════════════════")
println("")

// T1: pure-only fn → 3 base attrs
let m1 = [["pure", true], ["hot", false], ["has_loop", false], ["has_io", false]]
let a1 = attr_seal(m1)
check("T1.pure-only.len=3", len(a1) == 3)
check("T1.pure-only.has-const", a1[0] == "@const")
check("T1.pure-only.has-memoize", a1[1] == "@memoize")
check("T1.pure-only.has-pure", a1[2] == "@pure")

// T2: pure+hot → 5 attrs
let m2 = [["pure", true], ["hot", true], ["has_loop", false], ["has_io", false]]
let a2 = attr_seal(m2)
check("T2.pure+hot.len=5", len(a2) == 5)
check("T2.pure+hot.has-hot", a2[3] == "@hot")
check("T2.pure+hot.has-inline", a2[4] == "@inline")

// T3: pure+loop (no io) → 5 attrs (3 base + 2 vec)
let m3 = [["pure", true], ["hot", false], ["has_loop", true], ["has_io", false]]
let a3 = attr_seal(m3)
check("T3.pure+loop.len=5", len(a3) == 5)
check("T3.pure+loop.has-simd", a3[3] == "@simd")
check("T3.pure+loop.has-vectorize", a3[4] == "@vectorize")

// T4: pure+loop+io → 3 base only (io blocks vec)
let m4 = [["pure", true], ["hot", false], ["has_loop", true], ["has_io", true]]
let a4 = attr_seal(m4)
check("T4.pure+loop+io.len=3", len(a4) == 3)

// T5: impure → empty (side-effect risk)
let m5 = [["pure", false], ["hot", true], ["has_loop", true], ["has_io", false]]
let a5 = attr_seal(m5)
check("T5.impure.len=0", len(a5) == 0)

// T6: pure+hot+loop → 7 attrs (full stack)
let m6 = [["pure", true], ["hot", true], ["has_loop", true], ["has_io", false]]
let a6 = attr_seal(m6)
check("T6.full-stack.len=7", len(a6) == 7)

// T7: raw 68 idempotence-witness — same meta produces byte-eq result
check("T7.idempotent.pure-only", attr_seal_idempotent(m1))
check("T7.idempotent.pure+hot", attr_seal_idempotent(m2))
check("T7.idempotent.full-stack", attr_seal_idempotent(m6))
check("T7.idempotent.impure-empty", attr_seal_idempotent(m5))

// T8: cross-meta determinism — seal(m1) twice via fresh calls = byte-eq
let a1a = attr_seal(m1)
let a1b = attr_seal(m1)
check("T8.cross-call byte-eq", attr_eq(a1a, a1b))

// T9: distinct meta → distinct output (sanity, not collapse)
check("T9.no-collapse.m1-vs-m2", !attr_eq(attr_seal(m1), attr_seal(m2)))

// ── verdict ────────────────────────────────────────────────

println("")
println("═══════════════════════════════════════════════════════")
println("  PASS=" + to_string(pass_count) + "  FAIL=" + to_string(fail_count))
println("═══════════════════════════════════════════════════════")

if fail_count == 0 {
    println("__C4_ATTR_SEAL_RESULT__ PASS pass=" + to_string(pass_count))
} else {
    println("__C4_ATTR_SEAL_RESULT__ FAIL pass=" + to_string(pass_count) + " fail=" + to_string(fail_count))
}
