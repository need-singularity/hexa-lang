// ═══════════════════════════════════════════════════════════════════
//  test_bloom_filter_pure.hexa — tests for bloom_filter_pure.hexa
//
//  Covers: bloom_create, bloom_hash, bloom_add, bloom_contains,
//          bloom_false_positive_rate, bloom_optimal_hashes,
//          bloom_count, bloom_clear, bloom_merge
// ═══════════════════════════════════════════════════════════════════

import "runtime/bloom_filter_pure.hexa"

let mut pass = 0
let mut fail = 0

fn check(name, cond) {
    if cond {
        pass = pass + 1
        println("[PASS] " + name)
    } else {
        fail = fail + 1
        println("[FAIL] " + name)
    }
}

fn eq(name, a, b) {
    if a == b {
        pass = pass + 1
        println("[PASS] " + name)
    } else {
        fail = fail + 1
        println("[FAIL] " + name + " got " + to_string(a) + " want " + to_string(b))
    }
}

fn approx(name, a, b, tol) {
    let mut diff = a - b
    if diff < 0.0 { diff = 0.0 - diff }
    if diff < tol {
        pass = pass + 1
        println("[PASS] " + name)
    } else {
        fail = fail + 1
        println("[FAIL] " + name + " got " + to_string(a) + " want ~" + to_string(b) + " tol=" + to_string(tol))
    }
}

println("═══════════════════════════════════════════════════════")
println("  bloom_filter_pure.hexa — test runner")
println("═══════════════════════════════════════════════════════")

// ────────────────────────────────────────────────────────────
// 1. bloom_create — construction
// ────────────────────────────────────────────────────────────
println("")
println("--- bloom_create ---")
let bf1 = bloom_create(256, 3)
eq("create size", bf1["size"], 256)
eq("create num_hashes", bf1["num_hashes"], 3)
eq("create bits len", len(bf1["bits"]), 256)

// ────────────────────────────────────────────────────────────
// 2. Empty filter -> contains always false
// ────────────────────────────────────────────────────────────
println("")
println("--- empty filter ---")
let empty = bloom_create(512, 5)
check("empty no hello", !bloom_contains(empty, "hello"))
check("empty no world", !bloom_contains(empty, "world"))
check("empty no 42", !bloom_contains(empty, "42"))
check("empty no empty-str", !bloom_contains(empty, ""))

// ────────────────────────────────────────────────────────────
// 3. Add item -> contains returns true
// ────────────────────────────────────────────────────────────
println("")
println("--- add + contains ---")
let mut bf2 = bloom_create(1024, 5)
bf2 = bloom_add(bf2, "apple")
bf2 = bloom_add(bf2, "banana")
bf2 = bloom_add(bf2, "cherry")
check("contains apple", bloom_contains(bf2, "apple"))
check("contains banana", bloom_contains(bf2, "banana"))
check("contains cherry", bloom_contains(bf2, "cherry"))

// ────────────────────────────────────────────────────────────
// 4. Never-added item may return false (known non-members)
// ────────────────────────────────────────────────────────────
println("")
println("--- non-members ---")
let mut fp_count = 0
let mut na_i = 0
let not_items = ["durian", "elderberry", "fig", "grape", "honeydew", "kiwi", "lemon", "mango", "nectarine", "orange"]
while na_i < len(not_items) {
    if bloom_contains(bf2, not_items[na_i]) {
        fp_count = fp_count + 1
    }
    na_i = na_i + 1
}
// with 1024 bits, k=5, 3 items: FP rate ~0, allow at most 2
check("low false positives (" + to_string(fp_count) + "/10)", fp_count < 3)

// ────────────────────────────────────────────────────────────
// 5. No false negatives — add 100 items, all must be found
// ────────────────────────────────────────────────────────────
println("")
println("--- no false negatives (100 items) ---")
let mut bf_big = bloom_create(8192, 7)
let mut ai = 0
while ai < 100 {
    bf_big = bloom_add(bf_big, "item_" + to_string(ai))
    ai = ai + 1
}
let mut all_found = true
let mut ci = 0
while ci < 100 {
    if !bloom_contains(bf_big, "item_" + to_string(ci)) {
        all_found = false
        println("  MISSING: item_" + to_string(ci))
    }
    ci = ci + 1
}
check("all 100 items found (zero false negatives)", all_found)

// ────────────────────────────────────────────────────────────
// 6. FPR formula correctness
// ────────────────────────────────────────────────────────────
println("")
println("--- FPR formula ---")
// (1 - e^(-kn/m))^k for m=1024, n=100, k=7
// expected ~ (1 - e^(-700/1024))^7 = (1 - e^(-0.68359))^7
//          ~ (1 - 0.5049)^7 ~ 0.4951^7 ~ 0.00757
let fpr1 = bloom_false_positive_rate(100, 1024, 7)
check("FPR 100/1024/7 in range", fpr1 > 0.001 && fpr1 < 0.05)
approx("FPR 100/1024/7 value", fpr1, 0.00757, 0.005)

// FPR with 0 items should be 0
let fpr_zero = bloom_false_positive_rate(0, 1024, 7)
approx("FPR 0 items = 0", fpr_zero, 0.0, 0.0001)

// FPR with moderate saturation should be high
// n=50, m=100, k=3 -> (1 - e^(-1.5))^3 ~ 0.469
let fpr_full = bloom_false_positive_rate(50, 100, 3)
check("FPR saturated > 0.3", fpr_full > 0.3)

// ────────────────────────────────────────────────────────────
// 7. bloom_optimal_hashes for known parameters
// ────────────────────────────────────────────────────────────
println("")
println("--- optimal hashes ---")
// optimal k = (m/n) * ln(2) = (1000/100) * 0.693 = 6.93 -> 7
let k1 = bloom_optimal_hashes(1000, 100)
eq("optimal k for 1000/100", k1, 7)

// (10000/1000) * ln(2) = 6.93 -> 7
let k2 = bloom_optimal_hashes(10000, 1000)
eq("optimal k for 10000/1000", k2, 7)

// (100/10) * ln(2) = 6.93 -> 7
let k3 = bloom_optimal_hashes(100, 10)
eq("optimal k for 100/10", k3, 7)

// (1000/500) * ln(2) = 1.386 -> 1
let k4 = bloom_optimal_hashes(1000, 500)
eq("optimal k for 1000/500", k4, 1)

// edge: 0 expected items -> 1
let k5 = bloom_optimal_hashes(1000, 0)
eq("optimal k for 0 items", k5, 1)

// ────────────────────────────────────────────────────────────
// 8. bloom_hash — deterministic and in range
// ────────────────────────────────────────────────────────────
println("")
println("--- bloom_hash ---")
let h1a = bloom_hash("test", 0, 1000)
let h1b = bloom_hash("test", 0, 1000)
eq("hash deterministic", h1a, h1b)
check("hash in range [0, 1000)", h1a >= 0 && h1a < 1000)

let h2a = bloom_hash("test", 0, 1000)
let h2b = bloom_hash("test", 1, 1000)
check("diff seeds -> range ok s0", h2a >= 0 && h2a < 1000)
check("diff seeds -> range ok s1", h2b >= 0 && h2b < 1000)

// ────────────────────────────────────────────────────────────
// 9. bloom_count — set bits tracking
// ────────────────────────────────────────────────────────────
println("")
println("--- bloom_count ---")
let bf_empty = bloom_create(100, 3)
eq("count empty = 0", bloom_count(bf_empty), 0)

let mut bf_c = bloom_create(100, 3)
bf_c = bloom_add(bf_c, "x")
let c1 = bloom_count(bf_c)
check("count after add > 0", c1 > 0)
check("count after add <= k", c1 <= 3)

// ────────────────────────────────────────────────────────────
// 10. bloom_clear — resets bits
// ────────────────────────────────────────────────────────────
println("")
println("--- bloom_clear ---")
let mut bf_clr = bloom_create(256, 3)
bf_clr = bloom_add(bf_clr, "hello")
check("before clear contains", bloom_contains(bf_clr, "hello"))
let cleared = bloom_clear(bf_clr)
eq("clear count 0", bloom_count(cleared), 0)
check("cleared not contains", !bloom_contains(cleared, "hello"))
eq("clear preserves size", cleared["size"], 256)

// ────────────────────────────────────────────────────────────
// 11. bloom_merge — union of two filters
// ────────────────────────────────────────────────────────────
println("")
println("--- bloom_merge ---")
let mut bfA = bloom_create(512, 4)
bfA = bloom_add(bfA, "alpha")
let mut bfB = bloom_create(512, 4)
bfB = bloom_add(bfB, "beta")
let merged = bloom_merge(bfA, bfB)
check("merge has alpha", bloom_contains(merged, "alpha"))
check("merge has beta", bloom_contains(merged, "beta"))
eq("merge preserves size", merged["size"], 512)

// ────────────────────────────────────────────────────────────
// 12. idempotent add
// ────────────────────────────────────────────────────────────
println("")
println("--- idempotent ---")
let mut bf_dup = bloom_create(256, 3)
bf_dup = bloom_add(bf_dup, "dup")
let c_before = bloom_count(bf_dup)
bf_dup = bloom_add(bf_dup, "dup")
let c_after = bloom_count(bf_dup)
eq("dup add same count", c_before, c_after)
check("dup still present", bloom_contains(bf_dup, "dup"))

// ────────────────────────────────────────────────────────────
// summary
// ────────────────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass) + " passed, " + to_string(fail) + " failed")
println("═══════════════════════════════════════════════════════")
if fail == 0 { println("ALL PASS") } else { println("SOME FAIL") }
