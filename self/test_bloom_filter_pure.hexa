// ── inlined from self/runtime/bloom_filter_pure.hexa ───────────────
// (import "runtime/bloom_filter_pure.hexa" removed — codegen doesn't resolve
//  runtime/ imports for standalone test files; contents inlined instead)

let MASK32 = 0xFFFFFFFF
let FNV_OFFSET = 0x811C9DC5
let FNV_PRIME  = 0x01000193

@pure
fn _mul32(a, b) {
    let a32 = a & MASK32
    let b32 = b & MASK32
    let aL = a32 & 0xFFFF
    let aH = (a32 / 65536) & 0xFFFF
    let bL = b32 & 0xFFFF
    let bH = (b32 / 65536) & 0xFFFF
    let low = aL * bL
    let mid = aL * bH + aH * bL
    return (low + mid * 65536) & MASK32
}

@pure
pub fn bloom_hash(item, seed, num_bits) {
    if num_bits <= 0 { return 0 }
    let s = to_string(item)
    let n = len(s)
    let mut hval = (FNV_OFFSET ^ (seed & MASK32)) & MASK32
    let mut i = 0
    while i < n {
        let byte = char_code(s, i)
        hval = (hval ^ (byte & 0xFF)) & MASK32
        hval = _mul32(hval, FNV_PRIME)
        i = i + 1
    }
    hval = (hval ^ _mul32(seed, 0x9E3779B9)) & MASK32
    hval = _mul32(hval, FNV_PRIME)
    return hval % num_bits
}

pub fn bloom_create(num_bits, num_hashes) {
    let mut bits = []
    let mut i = 0
    while i < num_bits {
        bits = bits.push(0)
        i = i + 1
    }
    return #{ "bits": bits, "num_hashes": num_hashes, "size": num_bits }
}

pub fn bloom_add(filter, item) {
    let k = filter["num_hashes"]
    let m = filter["size"]
    let old_bits = filter["bits"]
    // Collect positions to set
    let mut positions = []
    let mut pi = 0
    while pi < k {
        positions = positions.push(bloom_hash(item, pi, m))
        pi = pi + 1
    }
    // Rebuild bits array with positions set
    let mut new_bits = []
    let mut j = 0
    while j < m {
        let mut is_set = false
        if old_bits[j] != 0 { is_set = true }
        let mut qi = 0
        while qi < k {
            if positions[qi] == j { is_set = true }
            qi = qi + 1
        }
        if is_set {
            new_bits = new_bits.push(1)
        } else {
            new_bits = new_bits.push(0)
        }
        j = j + 1
    }
    let mut result = #{}
    result["bits"] = new_bits
    result["num_hashes"] = k
    result["size"] = m
    return result
}

@pure
pub fn bloom_contains(filter, item) {
    let bits = filter["bits"]
    let k = filter["num_hashes"]
    let m = filter["size"]
    let mut i = 0
    while i < k {
        let pos = bloom_hash(item, i, m)
        if bits[pos] != 1 { return false }
        i = i + 1
    }
    return true
}

@pure
fn _exp_approx(x) {
    let mut sum = 1.0
    let mut term = 1.0
    let mut i = 1
    while i <= 30 {
        term = term * x / i
        sum = sum + term
        i = i + 1
    }
    return sum
}

@pure
fn _ln_approx(x) {
    if x <= 0.0 { return 0.0 - 999999.0 }
    let mut val = x
    let mut p = 0
    while val > 2.0 {
        val = val / 2.0
        p = p + 1
    }
    while val < 1.0 {
        val = val * 2.0
        p = p - 1
    }
    let t = (val - 1.0) / (val + 1.0)
    let t2 = t * t
    let mut sum = t
    let mut power = t
    let mut i = 1
    while i <= 30 {
        power = power * t2
        sum = sum + power / (2 * i + 1)
        i = i + 1
    }
    return 2.0 * sum + p * 0.69314718055994530942
}

@pure
fn _floor_int(x) {
    if x >= 0.0 {
        let mut fl = 0
        let mut acc = 0.0
        while acc + 1.0 <= x {
            fl = fl + 1
            acc = acc + 1.0
        }
        return fl
    }
    let mut fl = 0
    let mut acc = 0.0
    while acc > x {
        fl = fl - 1
        acc = acc - 1.0
    }
    return fl
}

@pure
pub fn bloom_false_positive_rate(num_items, num_bits, num_hashes) {
    let k = num_hashes * 1.0
    let n = num_items * 1.0
    let m = num_bits * 1.0
    if m <= 0.0 { return 1.0 }
    if n <= 0.0 { return 0.0 }
    let exponent = (0.0 - k) * n / m
    if exponent < (0.0 - 20.0) { return 1.0 }
    let inner = 1.0 - _exp_approx(exponent)
    if inner <= 0.0 { return 0.0 }
    return _exp_approx(k * _ln_approx(inner))
}

@pure
pub fn bloom_optimal_hashes(num_bits, expected_items) {
    if expected_items <= 0 { return 1 }
    let ratio = (num_bits * 1.0) / (expected_items * 1.0)
    let raw = ratio * 0.69314718055994530942
    let result = _floor_int(raw + 0.5)
    if result < 1 { return 1 }
    return result
}

@pure
pub fn bloom_count(filter) {
    let bits = filter["bits"]
    let n = len(bits)
    let mut count = 0
    let mut i = 0
    while i < n {
        if bits[i] != 0 { count = count + 1 }
        i = i + 1
    }
    return count
}

@pure
pub fn bloom_clear(filter) {
    return bloom_create(filter["size"], filter["num_hashes"])
}

pub fn bloom_merge(f1, f2) {
    let m = f1["size"]
    let bits1 = f1["bits"]
    let bits2 = f2["bits"]
    let mut bits = []
    let mut i = 0
    while i < m {
        if bits1[i] == 1 || bits2[i] == 1 {
            bits = bits.push(1)
        } else {
            bits = bits.push(0)
        }
        i = i + 1
    }
    return #{ "bits": bits, "num_hashes": f1["num_hashes"], "size": m }
}

// ── end inlined bloom_filter_pure ──────────────────────────────────

let mut pass = 0
let mut fail = 0

fn check(name, cond) {
    if cond {
        pass = pass + 1
        println("[PASS] " + name)
    } else {
        fail = fail + 1
        println("[FAIL] " + name)
    }
}

fn eq(name, a, b) {
    if a == b {
        pass = pass + 1
        println("[PASS] " + name)
    } else {
        fail = fail + 1
        println("[FAIL] " + name + " got " + to_string(a) + " want " + to_string(b))
    }
}

fn approx(name, a, b, tol) {
    let mut diff = a - b
    if diff < 0.0 { diff = 0.0 - diff }
    if diff < tol {
        pass = pass + 1
        println("[PASS] " + name)
    } else {
        fail = fail + 1
        println("[FAIL] " + name + " got " + to_string(a) + " want ~" + to_string(b) + " tol=" + to_string(tol))
    }
}

println("═══════════════════════════════════════════════════════")
println("  bloom_filter_pure.hexa — test runner")
println("═══════════════════════════════════════════════════════")

// ────────────────────────────────────────────────────────────
// 1. bloom_create — construction
// ────────────────────────────────────────────────────────────
println("")
println("--- bloom_create ---")
let bf1 = bloom_create(256, 3)
eq("create size", bf1["size"], 256)
eq("create num_hashes", bf1["num_hashes"], 3)
eq("create bits len", len(bf1["bits"]), 256)

// ────────────────────────────────────────────────────────────
// 2. Empty filter -> contains always false
// ────────────────────────────────────────────────────────────
println("")
println("--- empty filter ---")
let empty = bloom_create(512, 5)
check("empty no hello", !bloom_contains(empty, "hello"))
check("empty no world", !bloom_contains(empty, "world"))
check("empty no 42", !bloom_contains(empty, "42"))
check("empty no empty-str", !bloom_contains(empty, ""))

// ────────────────────────────────────────────────────────────
// 3. Add item -> contains returns true
// ────────────────────────────────────────────────────────────
println("")
println("--- add + contains ---")
let mut bf2 = bloom_create(1024, 5)
bf2 = bloom_add(bf2, "apple")
bf2 = bloom_add(bf2, "banana")
bf2 = bloom_add(bf2, "cherry")
check("contains apple", bloom_contains(bf2, "apple"))
check("contains banana", bloom_contains(bf2, "banana"))
check("contains cherry", bloom_contains(bf2, "cherry"))

// ────────────────────────────────────────────────────────────
// 4. Never-added item may return false (known non-members)
// ────────────────────────────────────────────────────────────
println("")
println("--- non-members ---")
let mut fp_count = 0
let mut na_i = 0
let not_items = ["durian", "elderberry", "fig", "grape", "honeydew", "kiwi", "lemon", "mango", "nectarine", "orange"]
while na_i < len(not_items) {
    if bloom_contains(bf2, not_items[na_i]) {
        fp_count = fp_count + 1
    }
    na_i = na_i + 1
}
// with 1024 bits, k=5, 3 items: FP rate ~0, allow at most 2
check("low false positives (" + to_string(fp_count) + "/10)", fp_count < 3)

// ────────────────────────────────────────────────────────────
// 5. No false negatives — add 100 items, all must be found
// ────────────────────────────────────────────────────────────
println("")
println("--- no false negatives (100 items) ---")
let mut bf_big = bloom_create(8192, 7)
let mut ai = 0
while ai < 100 {
    bf_big = bloom_add(bf_big, "item_" + to_string(ai))
    ai = ai + 1
}
let mut all_found = true
let mut ci = 0
while ci < 100 {
    if !bloom_contains(bf_big, "item_" + to_string(ci)) {
        all_found = false
        println("  MISSING: item_" + to_string(ci))
    }
    ci = ci + 1
}
check("all 100 items found (zero false negatives)", all_found)

// ────────────────────────────────────────────────────────────
// 6. FPR formula correctness
// ────────────────────────────────────────────────────────────
println("")
println("--- FPR formula ---")
// (1 - e^(-kn/m))^k for m=1024, n=100, k=7
// expected ~ (1 - e^(-700/1024))^7 = (1 - e^(-0.68359))^7
//          ~ (1 - 0.5049)^7 ~ 0.4951^7 ~ 0.00757
let fpr1 = bloom_false_positive_rate(100, 1024, 7)
check("FPR 100/1024/7 in range", fpr1 > 0.001 && fpr1 < 0.05)
approx("FPR 100/1024/7 value", fpr1, 0.00757, 0.005)

// FPR with 0 items should be 0
let fpr_zero = bloom_false_positive_rate(0, 1024, 7)
approx("FPR 0 items = 0", fpr_zero, 0.0, 0.0001)

// FPR with moderate saturation should be high
// n=50, m=100, k=3 -> (1 - e^(-1.5))^3 ~ 0.469
let fpr_full = bloom_false_positive_rate(50, 100, 3)
check("FPR saturated > 0.3", fpr_full > 0.3)

// ────────────────────────────────────────────────────────────
// 7. bloom_optimal_hashes for known parameters
// ────────────────────────────────────────────────────────────
println("")
println("--- optimal hashes ---")
// optimal k = (m/n) * ln(2) = (1000/100) * 0.693 = 6.93 -> 7
let k1 = bloom_optimal_hashes(1000, 100)
eq("optimal k for 1000/100", k1, 7)

// (10000/1000) * ln(2) = 6.93 -> 7
let k2 = bloom_optimal_hashes(10000, 1000)
eq("optimal k for 10000/1000", k2, 7)

// (100/10) * ln(2) = 6.93 -> 7
let k3 = bloom_optimal_hashes(100, 10)
eq("optimal k for 100/10", k3, 7)

// (1000/500) * ln(2) = 1.386 -> 1
let k4 = bloom_optimal_hashes(1000, 500)
eq("optimal k for 1000/500", k4, 1)

// edge: 0 expected items -> 1
let k5 = bloom_optimal_hashes(1000, 0)
eq("optimal k for 0 items", k5, 1)

// ────────────────────────────────────────────────────────────
// 8. bloom_hash — deterministic and in range
// ────────────────────────────────────────────────────────────
println("")
println("--- bloom_hash ---")
let h1a = bloom_hash("test", 0, 1000)
let h1b = bloom_hash("test", 0, 1000)
eq("hash deterministic", h1a, h1b)
check("hash in range [0, 1000)", h1a >= 0 && h1a < 1000)

let h2a = bloom_hash("test", 0, 1000)
let h2b = bloom_hash("test", 1, 1000)
check("diff seeds -> range ok s0", h2a >= 0 && h2a < 1000)
check("diff seeds -> range ok s1", h2b >= 0 && h2b < 1000)

// ────────────────────────────────────────────────────────────
// 9. bloom_count — set bits tracking
// ────────────────────────────────────────────────────────────
println("")
println("--- bloom_count ---")
let bf_empty = bloom_create(100, 3)
eq("count empty = 0", bloom_count(bf_empty), 0)

let mut bf_c = bloom_create(100, 3)
bf_c = bloom_add(bf_c, "x")
let mut c1 = 0
c1 = bloom_count(bf_c)
check("count after add > 0", c1 > 0)
check("count after add <= k", c1 <= 3)

// ────────────────────────────────────────────────────────────
// 10. bloom_clear — resets bits
// ────────────────────────────────────────────────────────────
println("")
println("--- bloom_clear ---")
let mut bf_clr = bloom_create(256, 3)
bf_clr = bloom_add(bf_clr, "hello")
check("before clear contains", bloom_contains(bf_clr, "hello"))
let mut cleared = #{}
cleared = bloom_clear(bf_clr)
eq("clear count 0", bloom_count(cleared), 0)
check("cleared not contains", !bloom_contains(cleared, "hello"))
eq("clear preserves size", cleared["size"], 256)

// ────────────────────────────────────────────────────────────
// 11. bloom_merge — union of two filters
// ────────────────────────────────────────────────────────────
println("")
println("--- bloom_merge ---")
let mut bfA = bloom_create(512, 4)
bfA = bloom_add(bfA, "alpha")
let mut bfB = bloom_create(512, 4)
bfB = bloom_add(bfB, "beta")
let mut merged = #{}
merged = bloom_merge(bfA, bfB)
check("merge has alpha", bloom_contains(merged, "alpha"))
check("merge has beta", bloom_contains(merged, "beta"))
eq("merge preserves size", merged["size"], 512)

// ────────────────────────────────────────────────────────────
// 12. idempotent add
// ────────────────────────────────────────────────────────────
println("")
println("--- idempotent ---")
let mut bf_dup = bloom_create(256, 3)
bf_dup = bloom_add(bf_dup, "dup")
let mut c_before = 0
c_before = bloom_count(bf_dup)
bf_dup = bloom_add(bf_dup, "dup")
let mut c_after = 0
c_after = bloom_count(bf_dup)
eq("dup add same count", c_before, c_after)
check("dup still present", bloom_contains(bf_dup, "dup"))

// ────────────────────────────────────────────────────────────
// summary
// ────────────────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass) + " passed, " + to_string(fail) + " failed")
println("═══════════════════════════════════════════════════════")
if fail == 0 { println("ALL PASS") } else { println("SOME FAIL") }
