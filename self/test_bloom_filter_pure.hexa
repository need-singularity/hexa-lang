// test_bloom_filter_pure.hexa — tests for self/runtime/bloom_filter_pure.hexa

import "runtime/bloom_filter_pure.hexa"

let mut pass = 0
let mut fail = 0

fn check(name, cond) {
    if cond { pass = pass + 1 } else {
        fail = fail + 1
        println("[FAIL] " + name)
    }
}

fn eq(name, a, b) {
    if a == b { pass = pass + 1 } else {
        fail = fail + 1
        println("[FAIL] " + name + " got " + to_string(a) + " want " + to_string(b))
    }
}

println("=== bloom_filter_pure test suite ===")

// ────────────────────────────────────────────────────────────
// 1. bloom_new — construction
// ────────────────────────────────────────────────────────────
let bf1 = bloom_new(256, 3)
eq("new size", bf1["size"], 256)
eq("new k", bf1["k"], 3)
eq("new bits len", len(bf1["bits"]), 256)

// ────────────────────────────────────────────────────────────
// 2. empty filter returns false for everything
// ────────────────────────────────────────────────────────────
let empty = bloom_new(512, 5)
check("empty no hello", !bloom_contains(empty, "hello"))
check("empty no world", !bloom_contains(empty, "world"))
check("empty no 42", !bloom_contains(empty, "42"))

// ────────────────────────────────────────────────────────────
// 3. add + contains — no false negatives
// ────────────────────────────────────────────────────────────
let mut bf2 = bloom_new(1024, 5)
bf2 = bloom_add(bf2, "apple")
bf2 = bloom_add(bf2, "banana")
bf2 = bloom_add(bf2, "cherry")
check("contains apple", bloom_contains(bf2, "apple"))
check("contains banana", bloom_contains(bf2, "banana"))
check("contains cherry", bloom_contains(bf2, "cherry"))

// ────────────────────────────────────────────────────────────
// 4. items not added — should mostly be false
// ────────────────────────────────────────────────────────────
let mut fp_count = 0
let mut na_i = 0
let not_items = ["durian", "elderberry", "fig", "grape", "honeydew", "kiwi", "lemon", "mango", "nectarine", "orange"]
while na_i < len(not_items) {
    if bloom_contains(bf2, not_items[na_i]) {
        fp_count = fp_count + 1
    }
    na_i = na_i + 1
}
// with 1024 bits, k=5, 3 items: FP rate ~0, allow up to 2
check("low false positives", fp_count < 3)

// ────────────────────────────────────────────────────────────
// 5. bloom_count — set bits
// ────────────────────────────────────────────────────────────
let empty_bf = bloom_new(100, 3)
eq("count empty", bloom_count(empty_bf), 0)
let mut bf_c = bloom_new(100, 3)
bf_c = bloom_add(bf_c, "x")
let c1 = bloom_count(bf_c)
check("count after add > 0", c1 > 0)
check("count after add <= k", c1 <= 3)

// ────────────────────────────────────────────────────────────
// 6. bloom_clear — resets all bits
// ────────────────────────────────────────────────────────────
let mut bf_clr = bloom_new(256, 3)
bf_clr = bloom_add(bf_clr, "hello")
check("before clear contains", bloom_contains(bf_clr, "hello"))
let cleared = bloom_clear(bf_clr)
eq("clear count 0", bloom_count(cleared), 0)
check("cleared not contains", !bloom_contains(cleared, "hello"))
eq("clear preserves size", cleared["size"], 256)
eq("clear preserves k", cleared["k"], 3)

// ────────────────────────────────────────────────────────────
// 7. bloom_merge — union of two filters
// ────────────────────────────────────────────────────────────
let mut bfA = bloom_new(512, 4)
bfA = bloom_add(bfA, "alpha")
let mut bfB = bloom_new(512, 4)
bfB = bloom_add(bfB, "beta")
let merged = bloom_merge(bfA, bfB)
check("merge has alpha", bloom_contains(merged, "alpha"))
check("merge has beta", bloom_contains(merged, "beta"))
eq("merge size", merged["size"], 512)

// ────────────────────────────────────────────────────────────
// 8. bloom_hash — deterministic
// ────────────────────────────────────────────────────────────
let h1a = bloom_hash("test", 0, 1000)
let h1b = bloom_hash("test", 0, 1000)
eq("hash deterministic", h1a, h1b)
// different seeds produce different hashes (with high probability)
let h2a = bloom_hash("test", 0, 1000)
let h2b = bloom_hash("test", 1, 1000)
// not guaranteed different but extremely likely for these params
check("hash range 0", h1a >= 0)
check("hash range max", h1a < 1000)
check("hash range 1", h2b >= 0)
check("hash range max 1", h2b < 1000)

// ────────────────────────────────────────────────────────────
// 9. bloom_false_positive_rate — empty filter
// ────────────────────────────────────────────────────────────
let fpr_empty = bloom_false_positive_rate(empty_bf)
check("FPR empty == 0", fpr_empty == 0.0)

// ────────────────────────────────────────────────────────────
// 10. multiple adds — no false negatives for many items
// ────────────────────────────────────────────────────────────
let mut bf4 = bloom_new(2048, 7)
let items = ["a", "b", "c", "d", "e", "f", "g", "h", "i", "j"]
let mut add_i = 0
while add_i < len(items) {
    bf4 = bloom_add(bf4, items[add_i])
    add_i = add_i + 1
}
let mut all_found = true
let mut chk_i = 0
while chk_i < len(items) {
    if !bloom_contains(bf4, items[chk_i]) {
        all_found = false
    }
    chk_i = chk_i + 1
}
check("all 10 items found", all_found)

// ────────────────────────────────────────────────────────────
// 11. k=1 — single hash function
// ────────────────────────────────────────────────────────────
let mut bf_k1 = bloom_new(512, 1)
bf_k1 = bloom_add(bf_k1, "test_k1")
check("k=1 contains", bloom_contains(bf_k1, "test_k1"))

// ────────────────────────────────────────────────────────────
// 12. k=10 — many hash functions
// ────────────────────────────────────────────────────────────
let mut bf_k10 = bloom_new(512, 10)
bf_k10 = bloom_add(bf_k10, "test_k10")
check("k=10 contains", bloom_contains(bf_k10, "test_k10"))

// ────────────────────────────────────────────────────────────
// 13. empty string item
// ────────────────────────────────────────────────────────────
let mut bf_es = bloom_new(256, 3)
bf_es = bloom_add(bf_es, "")
check("empty string added", bloom_contains(bf_es, ""))

// ────────────────────────────────────────────────────────────
// 14. long string item
// ────────────────────────────────────────────────────────────
let long_str = "abcdefghijklmnopqrstuvwxyz0123456789abcdefghijklmnopqrstuvwxyz"
let mut bf_long = bloom_new(512, 5)
bf_long = bloom_add(bf_long, long_str)
check("long string present", bloom_contains(bf_long, long_str))

// ────────────────────────────────────────────────────────────
// 15. adding same item twice is idempotent
// ────────────────────────────────────────────────────────────
let mut bf_dup = bloom_new(256, 3)
bf_dup = bloom_add(bf_dup, "dup")
bf_dup = bloom_add(bf_dup, "dup")
check("dup still present", bloom_contains(bf_dup, "dup"))

// ────────────────────────────────────────────────────────────
// 16. stress — add 50 items, verify all present
// ────────────────────────────────────────────────────────────
let mut bf_stress = bloom_new(4096, 7)
let mut si = 0
while si < 50 {
    bf_stress = bloom_add(bf_stress, "item_" + to_string(si))
    si = si + 1
}
let mut stress_ok = true
let mut sj = 0
while sj < 50 {
    if !bloom_contains(bf_stress, "item_" + to_string(sj)) {
        stress_ok = false
    }
    sj = sj + 1
}
check("stress 50 items all present", stress_ok)

// ────────────────────────────────────────────────────────────
// 17. numeric string items
// ────────────────────────────────────────────────────────────
let mut bf_num = bloom_new(512, 4)
bf_num = bloom_add(bf_num, "12345")
bf_num = bloom_add(bf_num, "67890")
check("num 12345", bloom_contains(bf_num, "12345"))
check("num 67890", bloom_contains(bf_num, "67890"))

// ────────────────────────────────────────────────────────────
// summary
// ────────────────────────────────────────────────────────────
println("===========================================================")
println("  Results: " + to_string(pass) + " passed, " + to_string(fail) + " failed")
println("===========================================================")
if fail == 0 { println("ALL PASS") } else { println("SOME FAIL") }
