// test_xxhash_pure.hexa — tests for self/runtime/xxhash_pure.hexa

// ── inlined from self/runtime/xxhash_pure.hexa ──────────────────
// codegen_c2 import/use resolution for runtime/*_pure.hexa is not wired
// for test files; inline the module contents (same pattern as test_rle_pure).

let XXHP1 = 0x9E3779B1
let XXHP2 = 0x85EBCA77
let XXHP3 = 0xC2B2AE3D
let XXHP4 = 0x27D4EB2F
let XXHP5 = 0x165667B1
let XXH_MASK32 = 0xFFFFFFFF

fn xxh_pow2(n) {
    let mut r = 1
    let mut i = 0
    while i < n { r = r * 2; i = i + 1 }
    return r
        i = i + 1
}

fn xxh_shl(a, n) {
    if n <= 0 { return a }
    return a * xxh_pow2(n)
}

fn xxh_shr(a, n) {
    if n <= 0 { return a }
    return a / xxh_pow2(n)
}

fn xxh_or(a, b) {
    return (a + b) - (a & b)
}

fn xxh_rotl32(x, r) {
    let v = x & XXH_MASK32
    let sh = r % 32
    if sh == 0 { return v }
    let lo = (v * xxh_pow2(sh)) & XXH_MASK32
    let hi = v / xxh_pow2(32 - sh)
    return xxh_or(lo, hi) & XXH_MASK32
}

fn xxh_mul32(a, b) {
    let a32 = a & XXH_MASK32
    let b32 = b & XXH_MASK32
    let aL = a32 & 0xFFFF
    let aH = a32 / 0x10000
    let bL = b32 & 0xFFFF
    let bH = b32 / 0x10000
    let low = aL * bL
    let mid = (aL * bH + aH * bL) & 0xFFFF
    let result = low + mid * 0x10000
    return result & XXH_MASK32
}

fn xxh_add32(a, b) {
    return (a + b) & XXH_MASK32
}

fn xxh_read_u32(s, off) {
    let b0 = ord(s.substring(off, off + 1))
    let b1 = ord(s.substring(off + 1, off + 2))
    let b2 = ord(s.substring(off + 2, off + 3))
    let b3 = ord(s.substring(off + 3, off + 4))
    return xxh_or(xxh_or(b0, b1 * 0x100), xxh_or(b2 * 0x10000, b3 * 0x1000000))
}

fn xxh32_round(acc, input) {
    let v = xxh_add32(acc, xxh_mul32(input, XXHP2))
    let r = xxh_rotl32(v, 13)
    return xxh_mul32(r, XXHP1)
}

fn xxh32_avalanche(h_in) {
    let mut h = h_in
    h = h ^ xxh_shr(h, 15)
    h = xxh_mul32(h, XXHP2)
    h = h ^ xxh_shr(h, 13)
    h = xxh_mul32(h, XXHP3)
    h = h ^ xxh_shr(h, 16)
    return h
}

fn xxhash32_pure(data, seed) {
    let length = len(data)
    let mut h = 0
    let mut idx = 0

    if length >= 16 {
        let mut v1 = xxh_add32(xxh_add32(seed, XXHP1), XXHP2)
        let mut v2 = xxh_add32(seed, XXHP2)
        let mut v3 = seed & XXH_MASK32
        let mut v4 = (seed - XXHP1) & XXH_MASK32

        let limit = length - 16
        while idx <= limit {
            v1 = xxh32_round(v1, xxh_read_u32(data, idx))
            v2 = xxh32_round(v2, xxh_read_u32(data, idx + 4))
            v3 = xxh32_round(v3, xxh_read_u32(data, idx + 8))
            v4 = xxh32_round(v4, xxh_read_u32(data, idx + 12))
            idx = idx + 16
        }

        let r1 = xxh_rotl32(v1, 1)
        let r2 = xxh_rotl32(v2, 7)
        let r3 = xxh_rotl32(v3, 12)
        let r4 = xxh_rotl32(v4, 18)
        h = xxh_add32(xxh_add32(xxh_add32(r1, r2), r3), r4)
    } else {
        h = xxh_add32(seed, XXHP5)
    }

    h = xxh_add32(h, length)

    let limit4 = length - 4
    while idx <= limit4 {
        let k = xxh_read_u32(data, idx)
        h = xxh_add32(h, xxh_mul32(k, XXHP3))
        h = xxh_mul32(xxh_rotl32(h, 17), XXHP4)
        idx = idx + 4
    }

    while idx < length {
        let b = ord(data.substring(idx, idx + 1))
        h = xxh_add32(h, xxh_mul32(b, XXHP5))
        h = xxh_mul32(xxh_rotl32(h, 11), XXHP1)
        idx = idx + 1
    }

    return xxh32_avalanche(h)
}

fn xxhash32_simple(data) {
    return xxhash32_pure(data, 0)
}

// ── test harness ───────────────────────────────────────────────

let mut pass = 0
let mut fail = 0

fn eq(name, a, b) {
    if a == b { pass = pass + 1 } else {
        fail = fail + 1
        println("[FAIL] " + name + " got " + to_string(a) + " want " + to_string(b))
    }
}

fn check(name, cond) {
    if cond { pass = pass + 1 } else {
        fail = fail + 1
        println("[FAIL] " + name)
    }
}

println("=== xxhash_pure test suite ===")

// ────────────────────────────────────────────────────────────
// 1. Empty string, seed 0 — canonical vector
// ────────────────────────────────────────────────────────────
eq("empty seed=0", xxhash32_pure("", 0), 0x02CC5D05)

// ────────────────────────────────────────────────────────────
// 2. Short inputs (1-3 bytes) — byte-only tail path
// ────────────────────────────────────────────────────────────
// "a" seed=0 → known: 0x550D7456
eq("1-byte 'a' seed=0", xxhash32_pure("a", 0), 0x550D7456)

// "ab" seed=0
let h_ab = xxhash32_pure("ab", 0)
check("2-byte nonzero", h_ab != 0)
check("2-byte 32bit", h_ab >= 0 && h_ab <= 0xFFFFFFFF)

// "abc" seed=0
let h_abc = xxhash32_pure("abc", 0)
check("3-byte nonzero", h_abc != 0)
check("3-byte differs from 2-byte", h_abc != h_ab)

// ────────────────────────────────────────────────────────────
// 3. Medium inputs (4-15 bytes) — 4-byte chunk path
// ────────────────────────────────────────────────────────────
// "abcd" (4 bytes) seed=0
let h_4 = xxhash32_pure("abcd", 0)
check("4-byte nonzero", h_4 != 0)
check("4-byte 32bit", h_4 >= 0 && h_4 <= 0xFFFFFFFF)

// "Hello, World!" (13 bytes)
let h_hello = xxhash32_pure("Hello, World!", 0)
check("13-byte nonzero", h_hello != 0)
check("13-byte 32bit", h_hello >= 0 && h_hello <= 0xFFFFFFFF)

// "123456789012345" (15 bytes)
let h_15 = xxhash32_pure("123456789012345", 0)
check("15-byte nonzero", h_15 != 0)

// ────────────────────────────────────────────────────────────
// 4. Long inputs (16+ bytes) — stripe accumulator path
// ────────────────────────────────────────────────────────────
// "0123456789abcdef" (16 bytes exactly)
let h_16 = xxhash32_pure("0123456789abcdef", 0)
check("16-byte nonzero", h_16 != 0)
check("16-byte 32bit", h_16 >= 0 && h_16 <= 0xFFFFFFFF)

// "abcdefghijklmnopqrstuvwxyz" (26 bytes)
let h_26 = xxhash32_pure("abcdefghijklmnopqrstuvwxyz", 0)
check("26-byte nonzero", h_26 != 0)
check("26-byte 32bit", h_26 >= 0 && h_26 <= 0xFFFFFFFF)

// 32 bytes
let h_32 = xxhash32_pure("abcdefghijklmnopqrstuvwxyz012345", 0)
check("32-byte nonzero", h_32 != 0)
check("32-byte differs from 26", h_32 != h_26)

// ────────────────────────────────────────────────────────────
// 5. Seed variation — different seeds give different hashes
// ────────────────────────────────────────────────────────────
let s0 = xxhash32_pure("test", 0)
let s1 = xxhash32_pure("test", 1)
let s42 = xxhash32_pure("test", 42)
let s_big = xxhash32_pure("test", 0xDEADBEEF)
check("seed0 != seed1", s0 != s1)
check("seed0 != seed42", s0 != s42)
check("seed1 != seed42", s1 != s42)
check("seed0 != seed_big", s0 != s_big)

// ────────────────────────────────────────────────────────────
// 6. Determinism — same input always gives same output
// ────────────────────────────────────────────────────────────
eq("determinism 1", xxhash32_pure("hello", 0), xxhash32_pure("hello", 0))
eq("determinism 2", xxhash32_pure("hello", 99), xxhash32_pure("hello", 99))

// ────────────────────────────────────────────────────────────
// 7. xxhash32_simple convenience wrapper
// ────────────────────────────────────────────────────────────
eq("simple == seed0", xxhash32_simple("hello"), xxhash32_pure("hello", 0))
eq("simple empty", xxhash32_simple(""), xxhash32_pure("", 0))

// ────────────────────────────────────────────────────────────
// 8. Collision resistance spot check
// ────────────────────────────────────────────────────────────
check("aa != ab", xxhash32_pure("aa", 0) != xxhash32_pure("ab", 0))
check("abc != abd", xxhash32_pure("abc", 0) != xxhash32_pure("abd", 0))

// ────────────────────────────────────────────────────────────
// Summary
// ────────────────────────────────────────────────────────────
println("")
println("pass: " + to_string(pass) + "  fail: " + to_string(fail))
if fail == 0 {
    println("ALL PASS")
} else {
    println("SOME FAILED")
}
