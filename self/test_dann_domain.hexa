// ═══════════════════════════════════════════════════════════════════
//  test_dann_domain.hexa — Domain Adaptation DANN (#286)
// ═══════════════════════════════════════════════════════════════════

import "ml/dann_domain.hexa"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs_(inp) { if inp < 0.0 { return 0.0 - inp } return inp }
fn approx_(a, b, eps) { return fabs_(a - b) < eps }

println("=== Domain-Adversarial Network (#286) ===")

// ── Build simple 2-class dataset ───────────────────────────
// Source domain: x in [0,1]^2, class 0 if x1<0.5, class 1 if x1>0.5
// Target domain: shifted by (+1,+1), same labels
let Xs = [
    [0.1, 0.1], [0.2, 0.3], [0.1, 0.4],
    [0.8, 0.1], [0.9, 0.3], [0.7, 0.4]
]
let Ys = [0, 0, 0, 1, 1, 1]
let Xt = [
    [1.1, 1.1], [1.2, 1.3], [1.1, 1.4],
    [1.8, 1.1], [1.9, 1.3], [1.7, 1.4]
]
let Yt = [0, 0, 0, 1, 1, 1]

// ── T1 init model shapes ───────────────────────────────────
let model1 = dann_init(2, 8, 2, 42)
check("T1 W_f shape", len(model1["W_f"]) == 8 && len(model1["W_f"][0]) == 2)
check("T1 W_y shape", len(model1["W_y"]) == 2 && len(model1["W_y"][0]) == 8)
check("T1 w_d len", len(model1["w_d"]) == 8)

// ── T2 features have bounded activation ────────────────────
let feat2 = dann_features(model1, [0.5, 0.5])
check("T2 feat length", len(feat2) == 8)
let mut feat_bounded = true
let mut i = 0

while i < 8 {
    if fabs_(feat2[i]) > 1.0 { feat_bounded = false }
}
check("T2 |feat| < 1", feat_bounded)

// ── T3 label predict returns valid class ───────────────────
let pr3 = dann_predict_label(model1, [0.5, 0.5])
check("T3 label prediction valid", pr3 >= 0 && pr3 < 2)

// ── T4 domain prediction is probability ────────────────────
let pd4 = dann_predict_domain(model1, [0.5, 0.5])
check("T4 domain prob in [0,1]", pd4 >= 0.0 && pd4 <= 1.0)

// ── T5 softmax sums to 1 ───────────────────────────────────
let sm5 = dann_softmax([1.0, 2.0, 3.0])
let mut sum5 = 0.0
let mut i = 0

while i < 3 { sum5 = sum5 + sm5[i] }
check("T5 softmax sums", approx_(sum5, 1.0, 1.0e-6))

// ── T6 label loss non-negative ─────────────────────────────
let l6 = dann_label_loss(model1, [0.1, 0.2], 0)
check("T6 label loss ≥ 0", l6 >= 0.0)

// ── T7 domain loss non-negative ────────────────────────────
let l7 = dann_domain_loss(model1, [0.1, 0.2], 0)
check("T7 domain loss ≥ 0", l7 >= 0.0)

// ── T8 training reduces label loss (on source) ───────────
let mut total_loss_before = 0.0
let mut i = 0

while i < 6 { total_loss_before = total_loss_before + dann_label_loss(model1, Xs[i], Ys[i]) }
let mut model = model1
let mut _step = 0

while _step < 200 {
    model = dann_train_step(model, Xs, Ys, Xt, 0.5, 0.05)
}
let mut total_loss_after = 0.0
let mut i = 0

while i < 6 { total_loss_after = total_loss_after + dann_label_loss(model, Xs[i], Ys[i]) }
check("T8 label loss decreases", total_loss_after < total_loss_before)

// ── T9 source accuracy improves ────────────────────────────
let acc_src_before = dann_label_acc(model1, Xs, Ys)
let acc_src_after  = dann_label_acc(model, Xs, Ys)
check("T9 source acc improves", acc_src_after >= acc_src_before)

// ── T10 gradient reversal: domain classifier converges ────
// With higher lambda the adversarial loss pushes feature extractor
// to be domain invariant, so domain classifier accuracy should
// stay close to 50% (random).
let all_X = Xs + Xt
let mut all_D = []
let mut _i = 0

while _i < 6 { all_D = all_D + [0] }
let mut _i = 0

while _i < 6 { all_D = all_D + [1] }
let dacc_before = dann_domain_acc(model1, all_X, all_D)
let dacc_after  = dann_domain_acc(model, all_X, all_D)
check("T10 domain acc bounded [0,1]", dacc_after >= 0.0 && dacc_after <= 1.0)
check("T10 initial domain acc in [0,1]", dacc_before >= 0.0 && dacc_before <= 1.0)

// ── T11 label accuracy > 50% after training ───────────────
check("T11 source acc > 0.5", acc_src_after > 0.5)

// ── T12 model has K output classes ─────────────────────────
check("T12 K=2", model["K"] == 2)

// ── T13 determinism (same seed → same model) ───────────────
let model_a = dann_init(2, 4, 2, 7)
let model_b = dann_init(2, 4, 2, 7)
let fa = dann_features(model_a, [0.3, 0.7])
let fb = dann_features(model_b, [0.3, 0.7])
let mut same = true
let mut i = 0

while i < 4 {
    if fabs_(fa[i] - fb[i]) > 1.0e-9 { same = false }
}
check("T13 deterministic init", same)

println("")
println("=== DANN summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
