// ══════════════════════════════════════════════════════════════

proof parse_break_basic {
    let tokens = tokenize("loop {\n  break\n}")
    let stmts = parse(tokens)
    assert stmts[0].kind == "LoopStmt"
    assert stmts[0].body[0].kind == "BreakStmt"
}

proof parse_continue_basic {
    let tokens = tokenize("loop {\n  continue\n}")
    let stmts = parse(tokens)
    assert stmts[0].kind == "LoopStmt"
    assert stmts[0].body[0].kind == "ContinueStmt"
}

proof parse_yield_basic {
    let tokens = tokenize("yield 42")
    let stmts = parse(tokens)
    assert stmts[0].kind == "YieldStmt"
    assert stmts[0].left.kind == "IntLit"
    assert stmts[0].left.value == "42"
}

proof parse_comptime_block {
    let tokens = tokenize("comptime {\n  let x = 1\n}")
    let stmts = parse(tokens)
    assert stmts[0].kind == "ComptimeBlock"
    assert len(stmts[0].body) == 1
}

proof parse_comptime_const {
    let tokens = tokenize("comptime const PI = 3")
    let stmts = parse(tokens)
    assert stmts[0].kind == "ComptimeConst"
    assert stmts[0].name == "PI"
    assert stmts[0].left.kind == "IntLit"
}

proof parse_theorem_basic {
    let tokens = tokenize("theorem add_comm {\n  assert 1 + 2 == 2 + 1\n}")
    let stmts = parse(tokens)
    assert stmts[0].kind == "TheoremStmt"
    assert stmts[0].name == "add_comm"
    assert len(stmts[0].body) == 1
}

proof parse_type_alias_phase2 {
    let tokens = tokenize("type Num = int")
    let stmts = parse(tokens)
    assert stmts[0].kind == "TypeAlias"
    assert stmts[0].name == "Num"
    assert stmts[0].value == "int"
}

proof parse_pure_fn_basic {
    let tokens = tokenize("pure fn add(a, b) {\n  a + b\n}")
    let stmts = parse(tokens)
    assert stmts[0].kind == "PureFnDecl"
    assert stmts[0].name == "add"
    assert len(stmts[0].params) == 2
    assert len(stmts[0].body) == 1
}

proof parse_optimize_fn_basic {
    let tokens = tokenize("optimize fn fib(n) {\n  n + 1\n}")
    let stmts = parse(tokens)
    assert stmts[0].kind == "OptimizeFnStmt"
    assert stmts[0].name == "fib"
    assert len(stmts[0].params) == 1
}

proof parse_extern_fn_basic {
    let tokens = tokenize("extern fn getpid() -> Int")
    let stmts = parse(tokens)
    assert stmts[0].kind == "ExternFnDecl"
    assert stmts[0].name == "getpid"
    assert stmts[0].ret_type == "Int"
    assert stmts[0].value == ""
}

proof parse_extern_fn_symbol_alias {
    let tokens = tokenize("@symbol(\"objc_msgSend\")\nextern fn objc_send3(obj, sel, a1) -> Int")
    let stmts = parse(tokens)
    assert stmts[0].kind == "ExternFnDecl"
    assert stmts[0].name == "objc_send3"
    assert stmts[0].value == "objc_msgSend"
    assert len(stmts[0].params) == 3
    assert stmts[0].ret_type == "Int"
}

proof parse_extern_fn_link_and_symbol {
    let tokens = tokenize("@link(\"libm\")\n@symbol(\"cos\")\nextern fn my_cos(x) -> Float")
    let stmts = parse(tokens)
    assert stmts[0].kind == "ExternFnDecl"
    assert stmts[0].name == "my_cos"
    assert stmts[0].value == "cos"
    assert stmts[0].op == "libm"
}

proof parse_extern_fn_no_symbol_uses_name {
    let tokens = tokenize("extern fn strlen(s) -> Int")
    let stmts = parse(tokens)
    assert stmts[0].kind == "ExternFnDecl"
    assert stmts[0].name == "strlen"
    assert stmts[0].value == ""
}

proof parse_multiple_symbol_aliases {
    let tokens = tokenize("@symbol(\"objc_msgSend\")\nextern fn send2(a, b) -> Int\n@symbol(\"objc_msgSend\")\nextern fn send4(a, b, c, d) -> Int")
    let stmts = parse(tokens)
    assert len(stmts) == 2
    assert stmts[0].name == "send2"
    assert stmts[0].value == "objc_msgSend"
    assert stmts[1].name == "send4"
    assert stmts[1].value == "objc_msgSend"
}

proof parse_list_comp_basic {
    let tokens = tokenize("[x * 2 for x in items]")
    let stmts = parse(tokens)
    assert len(stmts) == 1
    let expr = stmts[0].left
    assert expr.kind == "ListComp"
    assert expr.name == "x"
    // body expr (x * 2) is in .left
    assert expr.left.kind == "BinOp"
    assert expr.left.op == "*"
    // iter_expr is in .iter_expr
    assert expr.iter_expr.kind == "Ident"
    assert expr.iter_expr.value == "items"
    // no filter
    assert type_of(expr.cond) == "string"
}

proof parse_list_comp_filtered {
    let tokens = tokenize("[x * 2 for x in items if x > 2]")
    let stmts = parse(tokens)
    assert len(stmts) == 1
    let expr = stmts[0].left
    assert expr.kind == "ListComp"
    assert expr.name == "x"
    assert expr.left.kind == "BinOp"
    assert expr.left.op == "*"
    assert expr.iter_expr.kind == "Ident"
    // has filter condition
    assert type_of(expr.cond) != "string"
    assert expr.cond.kind == "BinOp"
    assert expr.cond.op == ">"
}
