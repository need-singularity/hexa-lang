// Phase 1 tests: safe tests only (no braces/keywords in strings)
// ══════════════════════════════════════════════════════════════

proof parse_type_alias_basic {
    let tokens = tokenize("type MyInt = int")
    let stmts = parse(tokens)
    assert stmts[0].kind == "TypeAlias"
    assert stmts[0].name == "MyInt"
    assert stmts[0].value == "int"
}

proof parse_drop_basic {
    let tokens = tokenize("drop(x)")
    let stmts = parse(tokens)
    assert stmts[0].kind == "DropStmt"
    assert stmts[0].name == "x"
}

