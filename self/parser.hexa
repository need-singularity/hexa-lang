// self/parser.hexa — HEXA parser written in HEXA (Stage 2 of self-hosting)
// Recursive descent parser: tokens -> AST (represented as structs)
// Covers: let, const, static, fn, if/else, while, for, loop, return,
//   struct, enum, match, try/catch, throw, panic, drop, spawn, scope,
//   select, async fn, extern fn, type alias, atomic let, lambda,
//   type params <T>, where clauses, break, continue, yield,
//   comptime (fn/const/let/assert/block), intent, verify, generate,
//   optimize, effect, pure fn, macro!, derive, theorem, handle/with
//   — 47 parse functions, full self-hosting coverage.

// ══════════════════════════════════════════════════════════════
// AST Node types — represented as simple structs
// ══════════════════════════════════════════════════════════════
// We use a uniform AstNode struct with a "kind" discriminator.
// Fields that don't apply to a given kind are set to "" or [].
//
// Kinds:
//   Statements: LetStmt, ConstStmt, StaticStmt, FnDecl, StructDecl,
//               EnumDecl, ForStmt, WhileStmt, LoopStmt, ReturnStmt,
//               AssignStmt, ExprStmt, MatchStmt, ImplBlock, TraitDecl,
//               ProofStmt, AssertStmt, UseStmt, ModStmt,
//               TryCatch, ThrowStmt, PanicStmt, DropStmt,
//               SpawnStmt, ScopeStmt, SelectStmt,
//               AsyncFnDecl, ExternFnDecl, TypeAlias, AtomicLet,
//               BreakStmt, ContinueStmt, YieldStmt,
//               ComptimeFnDecl, ComptimeConst, ComptimeLet,
//               ComptimeBlock, ComptimeAssert,
//               IntentStmt, VerifyStmt, GenerateFnStmt, GenerateStmt,
//               OptimizeFnStmt, EffectDecl, PureFnDecl,
//               MacroDef, DeriveDecl, TheoremStmt, HandleWithStmt
//   Expressions: IntLit, FloatLit, BoolLit, StringLit, CharLit,
//                Ident, BinOp, UnaryOp, Call, Field, Index,
//                IfExpr, MatchExpr, Array, StructInit, Range,
//                EnumPath, Block, Lambda, Wildcard, Tuple

// ══════════════════════════════════════════════════════════════
// Token struct (same as lexer.hexa)
// ══════════════════════════════════════════════════════════════

struct Token {
    kind: string,
    value: string,
    line: int,
    col: int
}

// ══════════════════════════════════════════════════════════════
// AstNode — universal node type
// ══════════════════════════════════════════════════════════════
// Using separate fields for different data shapes.
// "kind" determines which fields are meaningful.

// AstNode is now a Map (#{...}) instead of struct — fixes deep copy issues

// ══════════════════════════════════════════════════════════════
// Node constructors — each returns an AstNode
// ══════════════════════════════════════════════════════════════

// Empty node for defaults
fn empty_node() {
    return #{
        "kind": "", "name": "", "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

fn node_int_lit(val) {
    let n = empty_node()
    // We can't mutate struct fields, so rebuild
    return #{
        "kind": "IntLit", "name": "", "value": val, "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

fn node_float_lit(val) {
    return #{
        "kind": "FloatLit", "name": "", "value": val, "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

fn node_bool_lit(val) {
    return #{
        "kind": "BoolLit", "name": "", "value": val, "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

fn node_string_lit(val) {
    return #{
        "kind": "StringLit", "name": "", "value": val, "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

fn node_char_lit(val) {
    return #{
        "kind": "CharLit", "name": "", "value": val, "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

fn node_ident(name) {
    return #{
        "kind": "Ident", "name": name, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

fn node_wildcard() {
    return #{
        "kind": "Wildcard", "name": "_", "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ══════════════════════════════════════════════════════════════
// Parser state — module-level mutable variables
// Since HEXA doesn't support struct field mutation,
// we use module-level variables that all parse_* functions share.
// ══════════════════════════════════════════════════════════════

// NOTE: These are declared `pub let mut` so that the self-interpreter's
// module loader (src/interpreter.rs exec_use) injects them into the
// importer's scope. Without `pub`, the module scope is popped after load
// and callers get "undefined variable: p_tokens" when invoking parse().
// See sprint commit: fix(self/parser): expose module state via pub let mut.
pub let mut p_tokens = []
pub let mut p_pos = 0
pub let mut p_pending_symbol = ""   // @symbol("name") — pending C symbol alias
pub let mut p_pending_link = ""     // @link("lib") — pending library name
// M0: AI-native @attr accumulator — parse_stmt fills this, parse_fn_decl consumes
pub let mut p_pending_attrs = ""
// @contract desugar: pending requires/ensures AST expressions
// Filled by parse_stmt's @attr loop when attr_name == "contract"
// Consumed by parse_fn_decl → injected as ContractAssert nodes
pub let mut p_pending_contract_requires = ""   // AST expr or ""
pub let mut p_pending_contract_ensures = ""    // AST expr or ""
pub let mut p_pending_contract_req_text = ""   // source text for error msg
pub let mut p_pending_contract_ens_text = ""   // source text for error msg
// Struct literal disambiguation: when set, `Name {` is NOT parsed as
// struct literal (used inside if/while/match conditions where `{` is body).
pub let mut p_suppress_struct_lit = false

// ── I1: Error Recovery ─────────────────────────────────────
// Collect all parse errors instead of halting on the first one.
// p_errors: list of #{line, col, message} maps
// p_max_errors: stop collecting after this many (avoid runaway)
pub let mut p_errors = []
pub let mut p_max_errors = 50

fn p_record_error(line, col, message) {
    if len(p_errors) < p_max_errors {
        p_errors = p_errors.push(#{"line": line, "col": col, "message": message})
    }
}

fn p_synchronize() {
    // Skip tokens until we reach a likely statement boundary.
    // Synchronization points: newlines followed by a keyword, or Eof.
    while !p_at_end() {
        let cur = p_peek()
        // If we hit a newline, check if next token starts a statement
        if cur.kind == "Newline" {
            p_advance()
            let next = p_peek()
            if next.kind == "Let" { return true }
            if next.kind == "Const" { return true }
            if next.kind == "Static" { return true }
            if next.kind == "Fn" { return true }
            if next.kind == "Struct" { return true }
            if next.kind == "Enum" { return true }
            if next.kind == "For" { return true }
            if next.kind == "While" { return true }
            if next.kind == "Loop" { return true }
            if next.kind == "Return" { return true }
            if next.kind == "If" { return true }
            if next.kind == "Match" { return true }
            if next.kind == "Impl" { return true }
            if next.kind == "Trait" { return true }
            if next.kind == "Use" { return true }
            if next.kind == "Mod" { return true }
            if next.kind == "Try" { return true }
            if next.kind == "Assert" { return true }
            if next.kind == "Proof" { return true }
            if next.kind == "At" { return true }
            if next.kind == "Eof" { return true }
            // keep skipping
        } else {
            p_advance()
        }
    }
    return false
}

fn p_get_errors() {
    return p_errors
}

fn p_has_errors() {
    return len(p_errors) > 0
}

fn p_error_count() {
    return len(p_errors)
}

fn p_format_errors() {
    let mut lines = []
    let mut i = 0
    while i < len(p_errors) {
        let e = p_errors[i]
        lines = lines.push("  error[" + to_string(i + 1) + "] " + to_string(e.line) + ":" + to_string(e.col) + " — " + e.message)
        i = i + 1
    }
    return lines.join("\n")
}

// ── Helpers ─────────────────────────────────────────────────

fn p_peek() {
    if p_pos >= len(p_tokens) {
        return Token { kind: "Eof", value: "", line: 0, col: 0 }
    }
    return p_tokens[p_pos]
}

fn p_peek_kind() {
    return p_peek().kind
}

fn p_peek_ahead(offset) {
    let idx = p_pos + offset
    if idx >= len(p_tokens) {
        return Token { kind: "Eof", value: "", line: 0, col: 0 }
    }
    return p_tokens[idx]
}

fn p_at_end() {
    return p_peek_kind() == "Eof"
}

fn p_advance() {
    let tok = p_peek()
    p_pos = p_pos + 1
    return tok
}

fn p_check(expected_kind) {
    return p_peek_kind() == expected_kind
}

fn p_expect(expected_kind) {
    if p_check(expected_kind) {
        return p_advance()
    }
    let tok = p_peek()
    let msg = "expected " + expected_kind + ", got " + tok.kind + " ('" + tok.value + "')"
    p_record_error(tok.line, tok.col, msg)
    println("Parse error at " + to_string(tok.line) + ":" + to_string(tok.col) + ": " + msg)
    return tok
}

fn p_expect_ident() {
    let tok = p_peek()
    if tok.kind == "Ident" {
        p_pos = p_pos + 1
        return tok.value
    }
    let msg2 = "expected identifier, got " + tok.kind + " ('" + tok.value + "')"
    p_record_error(tok.line, tok.col, msg2)
    println("Parse error at " + to_string(tok.line) + ":" + to_string(tok.col) + ": " + msg2)
    return ""
}

fn p_skip_newlines() {
    while p_peek_kind() == "Newline" || p_peek_kind() == "Semicolon" {
        p_pos = p_pos + 1
    }
}

// ══════════════════════════════════════════════════════════════
// Main parse entry point
// ══════════════════════════════════════════════════════════════

fn parse(tokens) {
    p_tokens = tokens
    p_pos = 0
    p_pending_symbol = ""
    p_pending_link = ""
    p_pending_contract_requires = ""
    p_pending_contract_ensures = ""
    p_pending_contract_req_text = ""
    p_pending_contract_ens_text = ""
    p_errors = []
    let mut stmts = []
    p_skip_newlines()
    while !p_at_end() {
        let prev_pos = p_pos
        let mut parse_ok = true
        try {
            stmts = stmts.push(parse_stmt())
        } catch parse_err {
            // parse_stmt threw — record & synchronize
            let err_tok = p_peek()
            p_record_error(err_tok.line, err_tok.col, to_string(parse_err))
            p_synchronize()
            parse_ok = false
        }
        if parse_ok {
            // Guard: if pos didn't advance, force-skip to avoid infinite loop
            if p_pos == prev_pos {
                p_advance()
            }
        }
        p_skip_newlines()
    }
    return stmts
}

// parse_strict — original behavior: halt on first error (for backward compat)
fn parse_strict(tokens) {
    p_tokens = tokens
    p_pos = 0
    p_pending_symbol = ""
    p_pending_link = ""
    p_errors = []
    let mut stmts = []
    p_skip_newlines()
    while !p_at_end() {
        stmts = stmts.push(parse_stmt())
        p_skip_newlines()
    }
    return stmts
}

// ══════════════════════════════════════════════════════════════
// Level 2: Statement
// ══════════════════════════════════════════════════════════════

fn parse_stmt() {
    p_skip_newlines()
    // M0: collect leading @attr markers (e.g. @optimize @memoize @pure @async)
    while p_peek_kind() == "At" {
        p_advance() // consume @
        // Attribute name may be a keyword (e.g. @pure where `pure` is a keyword)
        let next_tok = p_peek()
        let mut attr_name = ""
        if p_peek_kind() == "Ident" {
            attr_name = p_expect_ident()
        } else {
            // Accept any keyword token's value as the attribute name
            attr_name = next_tok.value
            p_advance()
        }
        // ── @contract — parse requires/ensures clauses ──────
        if attr_name == "contract" && p_peek_kind() == "LParen" {
            p_advance() // consume (
            p_pending_contract_requires = ""
            p_pending_contract_ensures = ""
            p_pending_contract_req_text = ""
            p_pending_contract_ens_text = ""
            while p_peek_kind() != "RParen" && p_peek_kind() != "Eof" {
                // Expect "requires" or "ensures" identifier
                let clause_tok = p_advance()
                let clause_name = clause_tok.value
                // Consume the colon after requires/ensures
                if p_peek_kind() == "Colon" {
                    p_advance()
                }
                // Capture token position for source text extraction
                let expr_start = p_pos
                // Parse the clause expression using the full expression parser
                let clause_expr = parse_expr()
                // Build source text from consumed tokens for error messages
                let mut src_text = ""
                let mut _si = expr_start
                while _si < p_pos {
                    if src_text != "" {
                        src_text = src_text + " "
                    }
                    src_text = src_text + p_tokens[_si].value
                    _si = _si + 1
                }
                if clause_name == "requires" {
                    p_pending_contract_requires = clause_expr
                    p_pending_contract_req_text = src_text
                } else if clause_name == "ensures" {
                    p_pending_contract_ensures = clause_expr
                    p_pending_contract_ens_text = src_text
                }
                // Skip comma separator between clauses
                if p_peek_kind() == "Comma" {
                    p_advance()
                }
            }
            p_expect("RParen")
            if p_pending_attrs == "" {
                p_pending_attrs = "contract"
            } else {
                p_pending_attrs = p_pending_attrs + ",contract"
            }
        } else if attr_name == "symbol" || attr_name == "link" {
            // @symbol("x") / @link("libm") — single string argument
            let mut attr_arg = ""
            if p_peek_kind() == "LParen" {
                p_advance()
                if p_peek_kind() != "RParen" {
                    let tok = p_advance()
                    attr_arg = tok.value
                    while p_peek_kind() != "RParen" && p_peek_kind() != "Eof" {
                        p_advance()
                    }
                }
                p_expect("RParen")
            }
            if attr_name == "symbol" {
                p_pending_symbol = attr_arg
            } else {
                p_pending_link = attr_arg
            }
        } else {
            // Generic attribute — skip optional parenthesized content
            if p_peek_kind() == "LParen" {
                p_advance()
                if p_peek_kind() != "RParen" {
                    let tok = p_advance()
                    while p_peek_kind() != "RParen" && p_peek_kind() != "Eof" {
                        p_advance()
                    }
                }
                p_expect("RParen")
            }
            if p_pending_attrs == "" {
                p_pending_attrs = attr_name
            } else {
                p_pending_attrs = p_pending_attrs + "," + attr_name
            }
        }
        p_skip_newlines()
    }
    let kind = p_peek_kind()

    if kind == "Let" { return parse_let() }
    if kind == "Const" { return parse_const() }
    if kind == "Static" { return parse_static() }
    if kind == "Fn" { return parse_fn_decl() }
    if kind == "Struct" { return parse_struct_decl() }
    if kind == "Enum" { return parse_enum_decl() }
    if kind == "For" { return parse_for_stmt() }
    if kind == "While" { return parse_while_stmt() }
    if kind == "Loop" { return parse_loop_stmt() }
    if kind == "Return" { return parse_return() }
    if kind == "Proof" { return parse_proof_stmt() }
    if kind == "Assert" { return parse_assert_stmt() }
    if kind == "Invariant" { return parse_invariant_stmt() }
    if kind == "Impl" { return parse_impl_block() }
    if kind == "Trait" { return parse_trait_decl() }
    if kind == "Use" { return parse_use_decl() }
    if kind == "Mod" { return parse_mod_decl() }
    // Phase2 C1 — `import "path.hexa"` 지시문.
    // module_loader.hexa 전처리기가 인라인 확장해야 정상이지만,
    // 파서 수준에서도 관대히 받아들여 NoOp 로 취급한다.
    if kind == "Ident" {
        let tok = p_peek()
        if tok.value == "import" {
            p_advance() // consume 'import'
            let mut path = ""
            if p_peek_kind() == "StringLit" {
                let str_tok = p_advance()
                path = str_tok.value
            }
            return #{
                "kind": "ImportStmt", "name": path, "value": "", "op": "",
                "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }
        }
    }
    if kind == "Try" { return parse_try_catch() }
    if kind == "Throw" { return parse_throw_stmt() }
    if kind == "Panic" { return parse_panic_stmt() }
    if kind == "Drop" { return parse_drop_stmt() }
    if kind == "Spawn" { return parse_spawn_stmt() }
    if kind == "Scope" { return parse_scope_stmt() }
    if kind == "Select" { return parse_select_stmt() }
    if kind == "Async" { return parse_async_fn() }
    if kind == "Extern" { return parse_extern_fn() }
    if kind == "Type" { return parse_type_alias() }
    if kind == "Atomic" { return parse_atomic_let() }
    if kind == "Break" { return parse_break_stmt() }
    if kind == "Continue" { return parse_continue_stmt() }
    if kind == "Yield" { return parse_yield_stmt() }
    if kind == "Comptime" { return parse_comptime_stmt() }
    if kind == "Intent" { return parse_intent_stmt() }
    if kind == "Verify" { return parse_verify_stmt() }
    if kind == "Generate" { return parse_generate_stmt() }
    if kind == "Optimize" { return parse_optimize_stmt() }
    if kind == "Effect" { return parse_effect_decl() }
    if kind == "Pure" { return parse_pure_fn() }
    if kind == "Macro" { return parse_macro_def() }
    if kind == "Derive" { return parse_derive_decl() }
    if kind == "Theorem" { return parse_theorem_stmt() }
    if kind == "Handle" { return parse_handle_stmt() }
    if kind == "Recover" { return parse_recover_stmt() }
    if kind == "Resume" { return parse_resume_stmt() }

    // @attribute(...) — consume and attach to next declaration
    if kind == "Attribute" {
        return parse_attribute_prefix()
    }

    // Expression statement or assignment (incl. compound: +=, -=, *=, /=, %=)
    let expr = parse_expr()
    let pk = p_peek_kind()
    if pk == "Eq" {
        p_advance() // consume =
        let rhs = parse_expr()
        return #{
            "kind": "AssignStmt", "name": "", "value": "", "op": "",
            "left": expr, "right": rhs, "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    if pk == "PlusEq" || pk == "MinusEq" || pk == "StarEq" || pk == "SlashEq" || pk == "PercentEq" {
        let op_tok = p_advance()
        let op_str = if pk == "PlusEq" { "+" } else { if pk == "MinusEq" { "-" } else { if pk == "StarEq" { "*" } else { if pk == "SlashEq" { "/" } else { "%" } } } }
        let rhs = parse_expr()
        return #{
            "kind": "CompoundAssign", "name": "", "value": "", "op": op_str,
            "left": expr, "right": rhs, "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    return #{
        "kind": "ExprStmt", "name": "", "value": "", "op": "",
        "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── let [mut] name [: type] = expr ──────────────────────────

fn parse_let() {
    p_advance() // consume 'let'
    let mut is_mut = false
    if p_peek_kind() == "Mut" {
        p_advance()
        is_mut = true
    }
    let name = p_expect_ident()
    // optional type annotation
    let mut typ = ""
    if p_peek_kind() == "Colon" {
        p_advance()
        typ = p_expect_ident()
    }
    p_expect("Eq")
    let expr = parse_expr()
    let mut kind_str = "LetStmt"
    if is_mut {
        kind_str = "LetMutStmt"
    }
    return #{
        "kind": kind_str, "name": name, "value": typ, "op": "",
        "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── const name [: type] = expr ──────────────────────────────

fn parse_const() {
    p_advance() // consume 'const'
    let name = p_expect_ident()
    let mut typ = ""
    if p_peek_kind() == "Colon" {
        p_advance()
        typ = p_expect_ident()
    }
    p_expect("Eq")
    let expr = parse_expr()
    return #{
        "kind": "ConstStmt", "name": name, "value": typ, "op": "",
        "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── static name [: type] = expr ─────────────────────────────

fn parse_static() {
    p_advance() // consume 'static'
    let name = p_expect_ident()
    let mut typ = ""
    if p_peek_kind() == "Colon" {
        p_advance()
        typ = p_expect_ident()
    }
    p_expect("Eq")
    let expr = parse_expr()
    return #{
        "kind": "StaticStmt", "name": name, "value": typ, "op": "",
        "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── return [expr] ───────────────────────────────────────────

fn parse_return() {
    p_advance() // consume 'return'
    let k = p_peek_kind()
    if k == "Newline" || k == "Eof" || k == "RBrace" {
        return #{
            "kind": "ReturnStmt", "name": "", "value": "", "op": "",
            "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    let expr = parse_expr()
    return #{
        "kind": "ReturnStmt", "name": "", "value": "", "op": "",
        "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── proof name { body } ─────────────────────────────────────

fn parse_proof_stmt() {
    p_advance() // consume 'proof'
    let name = p_expect_ident()
    let body = parse_block()
    return #{
        "kind": "ProofStmt", "name": name, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": body, "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── assert expr ─────────────────────────────────────────────

fn parse_assert_stmt() {
    p_advance() // consume 'assert'
    let expr = parse_expr()
    return #{
        "kind": "AssertStmt", "name": "", "value": "", "op": "",
        "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── resume expr (inside effect handler) ────────────────────
fn parse_resume_stmt() {
    p_advance() // consume 'resume'
    let expr = parse_expr()
    return #{
        "kind": "Resume", "name": "", "value": "", "op": "",
        "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── invariant expr (proof block hint) ───────────────────────
fn parse_invariant_stmt() {
    p_advance() // consume 'invariant'
    let expr = parse_expr()
    return #{
        "kind": "Invariant", "name": "", "value": "", "op": "",
        "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── use path::to::module ────────────────────────────────────

fn parse_use_decl() {
    p_advance() // consume 'use'
    let mut path = []
    path = path.push(p_expect_ident())
    while p_peek_kind() == "ColonColon" {
        p_advance()
        path = path.push(p_expect_ident())
    }
    return #{
        "kind": "UseStmt", "name": "", "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": path,
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── mod name { body } ───────────────────────────────────────

fn parse_mod_decl() {
    p_advance() // consume 'mod'
    let name = p_expect_ident()
    let body = parse_block()
    return #{
        "kind": "ModStmt", "name": name, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": body, "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ══════════════════════════════════════════════════════════════
// Level 3: Declarations
// ══════════════════════════════════════════════════════════════

// ── fn name(params) [-> ret] { body } ───────────────────────

fn parse_fn_decl() {
    p_advance() // consume 'fn'
    let name = p_expect_ident()
    // C4: Optional type parameters — fn foo<T, U>(params) { ... }
    let mut tparams = []
    if p_peek_kind() == "Lt" {
        tparams = parse_type_params()
    }
    p_expect("LParen")
    let params = parse_params()
    p_expect("RParen")
    let mut ret = ""
    if p_peek_kind() == "Arrow" {
        p_advance()
        ret = p_expect_ident()
    }
    let body = parse_block()
    // M0: consume any pending @attrs into FnDecl.value (comma-separated)
    let attrs = p_pending_attrs
    p_pending_attrs = ""

    // ── @contract desugar: inject ContractAssert nodes ──────
    let mut final_body = body
    let req_expr = p_pending_contract_requires
    let ens_expr = p_pending_contract_ensures
    let req_text = p_pending_contract_req_text
    let ens_text = p_pending_contract_ens_text
    p_pending_contract_requires = ""
    p_pending_contract_ensures = ""
    p_pending_contract_req_text = ""
    p_pending_contract_ens_text = ""

    if req_expr != "" {
        // Prepend requires check: if !(<requires_expr>) throw "contract ..."
        let req_node = #{
            "kind": "ContractAssert", "name": name, "value": "requires: " + req_text, "op": "requires",
            "left": req_expr, "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
        let mut new_body = [req_node]
        for stmt in final_body {
            new_body = new_body.push(stmt)
        }
        final_body = new_body
    }

    if ens_expr != "" {
        // Walk body and wrap every ReturnStmt with ensures check.
        // Replace: return <expr>
        // With:    let __contract_result = <expr>
        //          ContractAssert(ensures_expr)  // result bound to __contract_result
        //          return __contract_result
        final_body = contract_wrap_returns(final_body, ens_expr, name, ens_text)
    }

    return #{
        "kind": "FnDecl", "name": name, "value": attrs, "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": params, "body": final_body, "args": "", "fields": "", "items": tparams,
        "variants": "", "arms": "", "iter_expr": "", "ret_type": ret,
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── @contract ensures: wrap return statements ───────────────
// Walks a body array, replacing every ReturnStmt with a 3-node sequence:
//   1. let __contract_result = <return_expr>
//   2. ContractAssert(ensures_expr)   — interpreter binds `result`
//   3. return __contract_result
// Recurses into if/else blocks to catch early returns in branches.

fn contract_wrap_returns(body, ens_expr, fn_name, ens_text) {
    let mut out = []
    for stmt in body {
        if type_of(stmt) == "string" {
            out = out.push(stmt)
        } else if stmt.kind == "ReturnStmt" || stmt.kind == "Return" {
            // 1. let __contract_result = <original return expr>
            let let_node = #{
                "kind": "LetStmt", "name": "__contract_result", "value": "", "op": "",
                "left": stmt.left, "right": "", "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }
            // 2. ContractAssert — ensures check (result = __contract_result)
            let assert_node = #{
                "kind": "ContractAssert", "name": fn_name, "value": "ensures: " + ens_text, "op": "ensures",
                "left": ens_expr, "right": "", "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }
            // 3. return __contract_result
            let ret_node = #{
                "kind": "ReturnStmt", "name": "", "value": "", "op": "",
                "left": node_ident("__contract_result"),
                "right": "", "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }
            out = out.push(let_node)
            out = out.push(assert_node)
            out = out.push(ret_node)
        } else if stmt.kind == "IfStmt" {
            // Recurse into if/else branches to catch returns there
            let mut wrapped = stmt
            if type_of(stmt.then_body) == "array" {
                wrapped = #{
                    "kind": "IfStmt", "name": stmt.name, "value": stmt.value, "op": stmt.op,
                    "left": stmt.left, "right": stmt.right, "cond": stmt.cond,
                    "then_body": contract_wrap_returns(stmt.then_body, ens_expr, fn_name, ens_text),
                    "else_body": stmt.else_body,
                    "params": stmt.params, "body": stmt.body, "args": stmt.args,
                    "fields": stmt.fields, "items": stmt.items,
                    "variants": stmt.variants, "arms": stmt.arms,
                    "iter_expr": stmt.iter_expr, "ret_type": stmt.ret_type,
                    "target": stmt.target, "trait_name": stmt.trait_name, "methods": stmt.methods
                }
            }
            if type_of(wrapped.else_body) == "array" {
                wrapped = #{
                    "kind": "IfStmt", "name": wrapped.name, "value": wrapped.value, "op": wrapped.op,
                    "left": wrapped.left, "right": wrapped.right, "cond": wrapped.cond,
                    "then_body": wrapped.then_body,
                    "else_body": contract_wrap_returns(wrapped.else_body, ens_expr, fn_name, ens_text),
                    "params": wrapped.params, "body": wrapped.body, "args": wrapped.args,
                    "fields": wrapped.fields, "items": wrapped.items,
                    "variants": wrapped.variants, "arms": wrapped.arms,
                    "iter_expr": wrapped.iter_expr, "ret_type": wrapped.ret_type,
                    "target": wrapped.target, "trait_name": wrapped.trait_name, "methods": wrapped.methods
                }
            }
            out = out.push(wrapped)
        } else {
            out = out.push(stmt)
        }
    }
    return out
}

// Parse a type annotation after ':' — supports Ident and *Ident (pointer types)
fn parse_type_annotation() {
    if p_peek_kind() == "Star" {
        p_advance() // consume '*'
        return "*" + p_expect_ident()
    }
    if p_peek_kind() == "LBracket" {
        p_advance() // consume '['
        let inner = parse_type_annotation()
        p_expect("RBracket")
        return "[" + inner + "]"
    }
    return p_expect_ident()
}

fn parse_params() {
    let mut params = []
    if p_peek_kind() == "RParen" {
        return params
    }
    // Optional `mut` modifier on parameter
    if p_peek_kind() == "Mut" { p_advance() }
    let name = p_expect_ident()
    let mut typ = ""
    if p_peek_kind() == "Colon" {
        p_advance()
        typ = parse_type_annotation()
    }
    params = params.push(#{
        "kind": "Param", "name": name, "value": typ, "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    })
    while p_peek_kind() == "Comma" {
        p_advance()
        if p_peek_kind() == "Mut" { p_advance() }
        let pname = p_expect_ident()
        let mut ptyp = ""
        if p_peek_kind() == "Colon" {
            p_advance()
            ptyp = parse_type_annotation()
        }
        params = params.push(#{
            "kind": "Param", "name": pname, "value": ptyp, "op": "",
            "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        })
    }
    return params
}

// ── struct Name { field: type, ... } ────────────────────────

fn parse_struct_decl() {
    p_advance() // consume 'struct'
    let name = p_expect_ident()
    // C4: Optional type parameters — struct Foo<T, U> { ... }
    let mut tparams = []
    if p_peek_kind() == "Lt" {
        tparams = parse_type_params()
    }
    p_expect("LBrace")
    p_skip_newlines()
    let mut fields = []
    while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
        let fname = p_expect_ident()
        // Type annotation is optional: `value` and `value: int` both parse.
        let mut ftype = ""
        if p_peek_kind() == "Colon" {
            p_advance()
            ftype = p_expect_ident()
        }
        fields = fields.push(#{
            "kind": "StructField", "name": fname, "value": ftype, "op": "",
            "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        })
        if p_peek_kind() == "Comma" {
            p_advance()
        }
        p_skip_newlines()
    }
    p_expect("RBrace")
    return #{
        "kind": "StructDecl", "name": name, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": fields, "items": tparams,
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── enum Name { Variant1, Variant2(type), ... } ─────────────

fn parse_enum_decl() {
    p_advance() // consume 'enum'
    let name = p_expect_ident()
    p_expect("LBrace")
    p_skip_newlines()
    let mut variants = []
    while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
        let vname = p_expect_ident()
        let mut vtypes = []
        if p_peek_kind() == "LParen" {
            p_advance()
            while p_peek_kind() != "RParen" && p_peek_kind() != "Eof" {
                vtypes = vtypes.push(p_expect_ident())
                if p_peek_kind() == "Comma" {
                    p_advance()
                }
            }
            p_expect("RParen")
        }
        variants = variants.push(#{
            "kind": "EnumVariant", "name": vname, "value": "", "op": "",
            "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": vtypes,
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        })
        if p_peek_kind() == "Comma" {
            p_advance()
        }
        p_skip_newlines()
    }
    p_expect("RBrace")
    return #{
        "kind": "EnumDecl", "name": name, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": variants, "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── trait Name { fn method(params) -> ret { body } } ────────

fn parse_trait_decl() {
    p_advance() // consume 'trait'
    let name = p_expect_ident()
    p_expect("LBrace")
    p_skip_newlines()
    let mut methods = []
    while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
        p_skip_newlines()
        if p_peek_kind() == "RBrace" { }
        else {
            p_expect("Fn")
            let mname = p_expect_ident()
            p_expect("LParen")
            let mparams = parse_params()
            p_expect("RParen")
            let mut mret = ""
            if p_peek_kind() == "Arrow" {
                p_advance()
                mret = p_expect_ident()
            }
            let mut mbody = []
            if p_peek_kind() == "LBrace" {
                mbody = parse_block()
            }
            methods = methods.push(#{
                "kind": "FnDecl", "name": mname, "value": "", "op": "",
                "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
                "params": mparams, "body": mbody, "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": mret,
                "target": "", "trait_name": "", "methods": ""
            })
            p_skip_newlines()
        }
    }
    p_expect("RBrace")
    return #{
        "kind": "TraitDecl", "name": name, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": methods
    }
}

// ── impl [Trait for] Type { methods } ───────────────────────

fn parse_impl_block() {
    p_advance() // consume 'impl'
    let first_name = p_expect_ident()
    let mut trait_n = ""
    let mut target_n = first_name
    if p_peek_kind() == "For" {
        p_advance()
        trait_n = first_name
        target_n = p_expect_ident()
    }
    p_expect("LBrace")
    p_skip_newlines()
    let mut methods = []
    while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
        p_skip_newlines()
        if p_peek_kind() == "RBrace" { }
        else {
            p_expect("Fn")
            let mname = p_expect_ident()
            p_expect("LParen")
            let mparams = parse_params()
            p_expect("RParen")
            let mut mret = ""
            if p_peek_kind() == "Arrow" {
                p_advance()
                mret = p_expect_ident()
            }
            let mbody = parse_block()
            methods = methods.push(#{
                "kind": "FnDecl", "name": mname, "value": "", "op": "",
                "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
                "params": mparams, "body": mbody, "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": mret,
                "target": "", "trait_name": "", "methods": ""
            })
            p_skip_newlines()
        }
    }
    p_expect("RBrace")
    return #{
        "kind": "ImplBlock", "name": "", "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": target_n, "trait_name": trait_n, "methods": methods
    }
}

// ══════════════════════════════════════════════════════════════
// Level 4: Control Flow
// ══════════════════════════════════════════════════════════════

// ── for var in expr { body } ────────────────────────────────

fn parse_for_stmt() {
    p_advance() // consume 'for'
    let var = p_expect_ident()
    // expect 'in' keyword
    let in_tok = p_advance()
    if in_tok.value != "in" {
        let for_msg = format("expected 'in' after for variable, got '{}'", in_tok.value)
        p_record_error(in_tok.line, in_tok.col, for_msg)
        println("Parse error: " + for_msg)
    }
    let prev_supp = p_suppress_struct_lit
    p_suppress_struct_lit = true
    let iter = parse_expr()
    p_suppress_struct_lit = prev_supp
    let body = parse_block()
    return #{
        "kind": "ForStmt", "name": var, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": body, "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": iter, "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── while cond { body } ─────────────────────────────────────

fn parse_while_stmt() {
    p_advance() // consume 'while'
    // Suppress struct-literal parsing inside the condition (Name { ... } would
    // collide with while body brace).
    let prev_supp = p_suppress_struct_lit
    p_suppress_struct_lit = true
    let cond = parse_expr()
    p_suppress_struct_lit = prev_supp
    let body = parse_block()
    return #{
        "kind": "WhileStmt", "name": "", "value": "", "op": "",
        "left": "", "right": "", "cond": cond, "then_body": "", "else_body": "",
        "params": "", "body": body, "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── loop { body } ───────────────────────────────────────────

fn parse_loop_stmt() {
    p_advance() // consume 'loop'
    let body = parse_block()
    return #{
        "kind": "LoopStmt", "name": "", "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": body, "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── if cond { then } [else { else }] (expression) ──────────

fn parse_if_expr() {
    p_advance() // consume 'if'
    let prev_supp = p_suppress_struct_lit
    p_suppress_struct_lit = true
    let cond = parse_expr()
    p_suppress_struct_lit = prev_supp
    let then_b = parse_block()
    let saved = p_pos
    p_skip_newlines()
    let mut else_b = []
    if p_peek_kind() == "Else" {
        p_advance()
        if p_peek_kind() == "If" {
            // else if -> nested
            let nested = parse_if_expr()
            else_b = [#{
                "kind": "ExprStmt", "name": "", "value": "", "op": "",
                "left": nested, "right": "", "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }]
        } else {
            else_b = parse_block()
        }
    } else {
        // No else — backtrack past consumed newlines
        p_pos = saved
    }
    return #{
        "kind": "IfExpr", "name": "", "value": "", "op": "",
        "left": "", "right": "", "cond": cond, "then_body": then_b, "else_body": else_b,
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── match expr { pattern -> body, ... } ─────────────────────

fn parse_match_expr() {
    p_advance() // consume 'match'
    let prev_supp = p_suppress_struct_lit
    p_suppress_struct_lit = true
    let scrutinee = parse_expr()
    p_suppress_struct_lit = prev_supp
    p_expect("LBrace")
    p_skip_newlines()
    let mut arms = []
    while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
        let pattern = parse_match_pattern()
        // Optional guard clause: pattern if condition => body
        let mut guard = ""
        if p_peek_kind() == "If" {
            p_advance() // consume 'if'
            guard = parse_expr()
        }
        p_expect("Arrow")
        let mut arm_body = []
        if p_peek_kind() == "LBrace" {
            arm_body = parse_block()
        } else {
            let arm_expr = parse_expr()
            arm_body = [#{
                "kind": "ExprStmt", "name": "", "value": "", "op": "",
                "left": arm_expr, "right": "", "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }]
        }
        arms = arms.push(#{
            "kind": "MatchArm", "name": "", "value": "", "op": "",
            "left": pattern, "right": "", "cond": guard, "then_body": "", "else_body": "",
            "params": "", "body": arm_body, "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        })
        if p_peek_kind() == "Comma" {
            p_advance()
        }
        p_skip_newlines()
    }
    p_expect("RBrace")
    return #{
        "kind": "MatchExpr", "name": "", "value": "", "op": "",
        "left": scrutinee, "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": arms, "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

fn parse_match_pattern() {
    let tok = p_peek()
    // Wildcard _
    if tok.kind == "Ident" && tok.value == "_" {
        p_advance()
        return node_wildcard()
    }
    // Enum path: Name::Variant
    if tok.kind == "Ident" && p_peek_ahead(1).kind == "ColonColon" {
        let ename = tok.value
        p_advance() // enum name
        p_advance() // ::
        let vname = p_expect_ident()
        let mut data = ""
        let mut pat_items = ""
        if p_peek_kind() == "LParen" {
            p_advance()
            let mut plist = []
            while p_peek_kind() != "RParen" && p_peek_kind() != "Eof" {
                plist = plist.push(parse_match_pattern())
                if p_peek_kind() == "Comma" { p_advance() }
            }
            p_expect("RParen")
            if len(plist) == 1 {
                data = plist[0]
            } else {
                pat_items = plist
            }
        }
        return #{
            "kind": "EnumPath", "name": ename, "value": vname, "op": "",
            "left": data, "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": pat_items,
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    // Regular expression
    return parse_expr()
}

// ══════════════════════════════════════════════════════════════
// Block: { stmts }
// ══════════════════════════════════════════════════════════════

fn parse_block() {
    p_skip_newlines()
    p_expect("LBrace")
    p_skip_newlines()
    let mut stmts = []
    while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
        stmts = stmts.push(parse_stmt())
        p_skip_newlines()
    }
    p_expect("RBrace")
    return stmts
}

// ══════════════════════════════════════════════════════════════
// Level 5: Expression (precedence climbing)
// ══════════════════════════════════════════════════════════════

fn parse_expr() {
    return parse_pipe()
}

// Level 5.0a: |> (pipe operator, lowest binary precedence)
fn parse_pipe() {
    let mut left = parse_null_coal()
    while p_peek_kind() == "Pipe" {
        let op_tok = p_advance()
        p_skip_newlines()
        let right = parse_null_coal()
        left = #{
            "kind": "BinOp", "name": "", "value": "", "op": op_tok.value,
            "left": left, "right": right, "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    return left
}

// Level 5.0b: ?? (null coalescing — lower precedence than ||)
fn parse_null_coal() {
    let mut left = parse_or()
    while p_peek_kind() == "NullCoal" {
        let op_tok = p_advance()
        p_skip_newlines()
        let right = parse_or()
        left = #{
            "kind": "BinOp", "name": "", "value": "", "op": op_tok.value,
            "left": left, "right": right, "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    return left
}

// Level 5.1: || ^^
fn parse_or() {
    let mut left = parse_and()
    while p_peek_kind() == "Or" || p_peek_kind() == "Xor" {
        let op_tok = p_advance()
        p_skip_newlines()
        let right = parse_and()
        left = #{
            "kind": "BinOp", "name": "", "value": "", "op": op_tok.value,
            "left": left, "right": right, "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    return left
}

// Level 5.2: &&
fn parse_and() {
    let mut left = parse_comparison()
    while p_peek_kind() == "And" {
        let op_tok = p_advance()
        p_skip_newlines()
        let right = parse_comparison()
        left = #{
            "kind": "BinOp", "name": "", "value": "", "op": op_tok.value,
            "left": left, "right": right, "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    return left
}

// Level 5.3: == != < > <= >= in is
fn parse_comparison() {
    let mut left = parse_addition()
    while p_peek_kind() == "EqEq" || p_peek_kind() == "NotEq" || p_peek_kind() == "Lt" || p_peek_kind() == "Gt" || p_peek_kind() == "LtEq" || p_peek_kind() == "GtEq" || p_peek_kind() == "In" || (p_peek_kind() == "Ident" && p_peek().value == "is") {
        let op_tok = p_advance()
        p_skip_newlines()
        if op_tok.value == "is" {
            // 'is' — right side is a type name (identifier), not an expression
            let type_tok = p_advance()
            let right = #{
                "kind": "Ident", "name": type_tok.value, "value": type_tok.value, "op": "",
                "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }
            left = #{
                "kind": "BinOp", "name": "", "value": "", "op": "is",
                "left": left, "right": right, "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }
        } else {
            let right = parse_addition()
            left = #{
                "kind": "BinOp", "name": "", "value": "", "op": op_tok.value,
                "left": left, "right": right, "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }
        }
    }
    return left
}

// Level 5.4: + -
fn parse_addition() {
    let mut left = parse_multiplication()
    while p_peek_kind() == "Plus" || p_peek_kind() == "Minus" {
        let op_tok = p_advance()
        p_skip_newlines()
        let right = parse_multiplication()
        left = #{
            "kind": "BinOp", "name": "", "value": "", "op": op_tok.value,
            "left": left, "right": right, "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    return left
}

// Level 5.5: * / % **
fn parse_multiplication() {
    let mut left = parse_unary()
    while p_peek_kind() == "Star" || p_peek_kind() == "Slash" || p_peek_kind() == "Percent" || p_peek_kind() == "Power" {
        let op_tok = p_advance()
        p_skip_newlines()
        let right = parse_unary()
        left = #{
            "kind": "BinOp", "name": "", "value": "", "op": op_tok.value,
            "left": left, "right": right, "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    return left
}

// Level 5.6: Unary ! - ~
fn parse_unary() {
    let k = p_peek_kind()
    if k == "Not" || k == "Minus" || k == "BitNot" {
        let op_tok = p_advance()
        let operand = parse_unary()
        return #{
            "kind": "UnaryOp", "name": "", "value": "", "op": op_tok.value,
            "left": operand, "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    return parse_postfix()
}

// ── Postfix: call, field access, index ──────────────────────

fn parse_postfix() {
    let mut expr = parse_primary()
    let mut cont = true
    while cont {
        let k = p_peek_kind()
        if k == "LParen" {
            // Function call
            p_advance()
            let args = parse_args()
            p_expect("RParen")
            expr = #{
                "kind": "Call", "name": "", "value": "", "op": "",
                "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": args, "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }
        } else if k == "Dot" {
            // Field access or tuple index (.0, .1, ...)
            p_advance()
            let next_k = p_peek_kind()
            if next_k == "IntLit" {
                // Tuple field: expr.0 → Index(expr, IntLit)
                let idx_tok = p_advance()
                expr = #{
                    "kind": "Index", "name": "", "value": "", "op": "",
                    "left": expr, "right": #{"kind": "IntLit", "name": "", "value": idx_tok["value"], "op": "", "left": "", "right": "", "cond": "", "then_body": "", "else_body": "", "params": "", "body": "", "args": "", "fields": "", "items": "", "variants": "", "arms": "", "iter_expr": "", "ret_type": "", "target": "", "trait_name": "", "methods": ""}, "cond": "", "then_body": "", "else_body": "",
                    "params": "", "body": "", "args": "", "fields": "", "items": "",
                    "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                    "target": "", "trait_name": "", "methods": ""
                }
            } else {
                let field_name = p_expect_ident()
                expr = #{
                    "kind": "Field", "name": field_name, "value": "", "op": "",
                    "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
                    "params": "", "body": "", "args": "", "fields": "", "items": "",
                    "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                    "target": "", "trait_name": "", "methods": ""
                }
            }
        } else if k == "QuestionDot" {
            // Optional chaining: expr?.field — returns void if expr is void
            p_advance()
            let field_name = p_expect_ident()
            expr = #{
                "kind": "OptField", "name": field_name, "value": "", "op": "",
                "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }
        } else if k == "LBracket" {
            // Index access
            p_advance()
            let index = parse_expr()
            p_expect("RBracket")
            expr = #{
                "kind": "Index", "name": "", "value": "", "op": "",
                "left": expr, "right": index, "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }
        } else if k == "DotDot" {
            // Range
            p_advance()
            let end = parse_addition()
            expr = #{
                "kind": "Range", "name": "", "value": "exclusive", "op": "",
                "left": expr, "right": end, "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }
        } else if k == "DotDotEq" {
            // Inclusive range
            p_advance()
            let end = parse_addition()
            expr = #{
                "kind": "Range", "name": "", "value": "inclusive", "op": "",
                "left": expr, "right": end, "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }
        } else {
            cont = false
        }
    }
    return expr
}

fn parse_args() {
    let mut args = []
    // G12: allow newline-separated multiline call args — skip newlines before/after each arg and commas
    p_skip_newlines()
    if p_peek_kind() == "RParen" {
        return args
    }
    p_skip_newlines()
    args = args.push(parse_expr())
    p_skip_newlines()
    while p_peek_kind() == "Comma" {
        p_advance()
        p_skip_newlines()
        args = args.push(parse_expr())
        p_skip_newlines()
    }
    p_skip_newlines()
    return args
}

// ══════════════════════════════════════════════════════════════
// Level 6: Primary
// ══════════════════════════════════════════════════════════════

fn parse_primary() {
    let tok = p_peek()
    let k = tok.kind

    if k == "IntLit" {
        p_advance()
        return node_int_lit(tok.value)
    }
    if k == "FloatLit" {
        p_advance()
        return node_float_lit(tok.value)
    }
    if k == "BoolLit" {
        p_advance()
        return node_bool_lit(tok.value)
    }
    if k == "StringLit" {
        p_advance()
        return node_string_lit(tok.value)
    }
    if k == "CharLit" {
        p_advance()
        return node_char_lit(tok.value)
    }
    if k == "Ident" {
        p_advance()
        let name = tok.value
        // Check for enum path: Name::Variant
        if p_peek_kind() == "ColonColon" {
            p_advance() // consume ::
            let variant = p_expect_ident()
            return #{
                "kind": "EnumPath", "name": name, "value": variant, "op": "",
                "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }
        }
        // C4: Check for generic struct init: Name<Int, String> { ... }
        // or plain struct init: Name { field: val, ... }
        // Convention: name starts with uppercase
        let mut type_args = []
        if p_peek_kind() == "Lt" {
            let chars = name.chars()
            if len(chars) > 0 {
                let first_ch = chars[0]
                if is_alpha(first_ch) && to_string(first_ch) == to_string(first_ch).to_upper() {
                    type_args = parse_type_params()
                }
            }
        }
        if p_peek_kind() == "LBrace" && !p_suppress_struct_lit {
            let chars = name.chars()
            if len(chars) > 0 {
                let first_ch = chars[0]
                if is_alpha(first_ch) && to_string(first_ch) == to_string(first_ch).to_upper() {
                    p_advance() // consume {
                    p_skip_newlines()
                    let mut fields = []
                    while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
                        let fname = p_expect_ident()
                        p_expect("Colon")
                        let fval = parse_expr()
                        fields = fields.push(#{
                            "kind": "FieldInit", "name": fname, "value": "", "op": "",
                            "left": fval, "right": "", "cond": "", "then_body": "", "else_body": "",
                            "params": "", "body": "", "args": "", "fields": "", "items": "",
                            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                            "target": "", "trait_name": "", "methods": ""
                        })
                        if p_peek_kind() == "Comma" {
                            p_advance()
                        }
                        p_skip_newlines()
                    }
                    p_expect("RBrace")
                    return #{
                        "kind": "StructInit", "name": name, "value": "", "op": "",
                        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
                        "params": "", "body": "", "args": "", "fields": fields, "items": type_args,
                        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                        "target": "", "trait_name": "", "methods": ""
                    }
                }
            }
        }
        return node_ident(name)
    }
    if k == "LParen" {
        p_advance()
        let expr = parse_expr()
        // Check for tuple
        if p_peek_kind() == "Comma" {
            let mut items = [expr]
            while p_peek_kind() == "Comma" {
                p_advance()
                if p_peek_kind() == "RParen" { }
                else {
                    items = items.push(parse_expr())
                }
            }
            p_expect("RParen")
            return #{
                "kind": "Tuple", "name": "", "value": "", "op": "",
                "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": items,
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }
        }
        p_expect("RParen")
        return expr  // grouped expression
    }
    if k == "LBracket" {
        // Array literal or list comprehension
        p_advance()
        // Empty array: []
        if p_peek_kind() == "RBracket" {
            p_advance()
            return #{
                "kind": "Array", "name": "", "value": "", "op": "",
                "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": [],
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }
        }
        // Parse first expression
        let first = parse_expr()
        // Check for list comprehension: [expr for var in iterable]
        //                            or [expr for var in iterable if cond]
        if p_peek_kind() == "For" {
            p_advance() // consume 'for'
            let comp_var = p_expect_ident()
            let in_tok = p_advance()
            if in_tok.value != "in" {
                let comp_msg = format("expected 'in' after comprehension variable, got '{}'", in_tok.value)
                p_record_error(in_tok.line, in_tok.col, comp_msg)
                println("Parse error: " + comp_msg)
            }
            let comp_iter = parse_expr()
            // Optional filter: if condition
            let mut comp_cond = ""
            if p_peek_kind() == "If" {
                p_advance() // consume 'if'
                comp_cond = parse_expr()
            }
            p_expect("RBracket")
            return #{
                "kind": "ListComp", "name": comp_var, "value": "", "op": "",
                "left": first, "right": "", "cond": comp_cond, "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": comp_iter, "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }
        }
        // Normal array literal: continue parsing remaining items
        let mut items = [first]
        if p_peek_kind() == "Comma" {
            p_advance()
        }
        while p_peek_kind() != "RBracket" && p_peek_kind() != "Eof" {
            items = items.push(parse_expr())
            if p_peek_kind() == "Comma" {
                p_advance()
            }
        }
        p_expect("RBracket")
        return #{
            "kind": "Array", "name": "", "value": "", "op": "",
            "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": items,
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    if k == "HashLBrace" {
        // Map literal: #{ "key": value, ... }
        p_advance() // consume #{
        p_skip_newlines()
        let mut items = []
        while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
            let key_expr = parse_expr()
            p_expect("Colon")
            let val_expr = parse_expr()
            items = items.push(#{
                "kind": "MapEntry", "name": "", "value": "", "op": "",
                "left": key_expr, "right": val_expr, "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            })
            if p_peek_kind() == "Comma" {
                p_advance()
            }
            p_skip_newlines()
        }
        p_expect("RBrace")
        return #{
            "kind": "MapLit", "name": "", "value": "", "op": "",
            "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": items,
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    if k == "If" {
        return parse_if_expr()
    }
    if k == "Match" {
        return parse_match_expr()
    }
    if k == "BitOr" {
        // Lambda: |params| body
        p_advance() // consume first |
        let mut lparams = []
        if p_peek_kind() != "BitOr" {
            lparams = lparams.push(p_expect_ident())
            while p_peek_kind() == "Comma" {
                p_advance()
                lparams = lparams.push(p_expect_ident())
            }
        }
        p_expect("BitOr") // consume closing |
        let mut lbody = ""
        if p_peek_kind() == "LBrace" {
            lbody = parse_block()
        } else {
            lbody = parse_expr()
        }
        return #{
            "kind": "Lambda", "name": "", "value": "", "op": "",
            "left": lbody, "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": lparams, "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    if k == "Or" {
        // Zero-arg lambda: || body
        // Ambiguous with logical-or, but in primary-expression position
        // we're always at the START of an expression so || must be lambda.
        p_advance() // consume ||
        let mut lbody = ""
        if p_peek_kind() == "LBrace" {
            lbody = parse_block()
        } else {
            lbody = parse_expr()
        }
        return #{
            "kind": "Lambda", "name": "", "value": "", "op": "",
            "left": lbody, "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": [], "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    if k == "Fn" {
        // Anonymous fn: fn(params) -> ret? { body }
        p_advance() // consume 'fn'
        p_expect("LParen")
        let fparams = parse_params()
        p_expect("RParen")
        // Optional return type
        if p_peek_kind() == "Arrow" {
            p_advance()
            let _ret = p_expect_ident()
        }
        let fbody = parse_block()
        return #{
            "kind": "Lambda", "name": "", "value": "", "op": "",
            "left": fbody, "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": fparams, "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }

    // Unknown token
    let msg3 = "unexpected token " + tok.kind + " ('" + tok.value + "')"
    p_record_error(tok.line, tok.col, msg3)
    println("Parse error at " + to_string(tok.line) + ":" + to_string(tok.col) + ": " + msg3)
    p_advance() // skip to avoid infinite loop
    return empty_node()
}

// ══════════════════════════════════════════════════════════════
// Phase 1 additions: 14 missing parse functions for self-hosting
// ══════════════════════════════════════════════════════════════

// ── try { ... } catch(e) { ... } ────────────────────────────
fn parse_try_catch() {
    p_advance() // consume 'try'
    let try_body = parse_block()
    p_skip_newlines()
    p_expect("Catch")
    let mut catch_var = "_"
    if p_peek_kind() == "LParen" {
        // catch(e) syntax
        p_advance()
        catch_var = p_expect_ident()
        p_expect("RParen")
    } else {
        if p_peek_kind() == "Ident" {
            // catch e syntax (no parens)
            catch_var = p_expect_ident()
        }
    }
    let catch_body = parse_block()
    return #{
        "kind": "TryCatch", "name": catch_var, "value": "", "op": "",
        "left": try_body, "right": catch_body, "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

