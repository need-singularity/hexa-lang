    }
}

// ── recover { body } | recover |e| { body } ───────────────
fn parse_recover_stmt() {
    p_advance() // consume 'recover'
    let mut catch_var = "_"
    // Check for |e| error binding syntax
    if p_peek_kind() == "BitOr" {
        p_advance() // consume first |
        catch_var = p_expect_ident()
        p_expect("BitOr") // consume closing |
    }
    let body = parse_block()
    return #{
        "kind": "RecoverStmt", "name": catch_var, "value": "", "op": "",
        "left": body, "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

