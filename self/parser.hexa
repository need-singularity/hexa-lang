// self/parser.hexa — HEXA parser written in HEXA (Stage 2 of self-hosting)
// Recursive descent parser: tokens -> AST (represented as structs)
// Covers core subset: let, const, static, fn, if/else, while, for..in,
//   return, struct, enum, match, expressions with full precedence.

// ══════════════════════════════════════════════════════════════
// AST Node types — represented as simple structs
// ══════════════════════════════════════════════════════════════
// We use a uniform AstNode struct with a "kind" discriminator.
// Fields that don't apply to a given kind are set to "" or [].
//
// Kinds:
//   Statements: LetStmt, ConstStmt, StaticStmt, FnDecl, StructDecl,
//               EnumDecl, ForStmt, WhileStmt, LoopStmt, ReturnStmt,
//               AssignStmt, ExprStmt, MatchStmt, ImplBlock, TraitDecl,
//               ProofStmt, AssertStmt, UseStmt, ModStmt
//   Expressions: IntLit, FloatLit, BoolLit, StringLit, CharLit,
//                Ident, BinOp, UnaryOp, Call, Field, Index,
//                IfExpr, MatchExpr, Array, StructInit, Range,
//                EnumPath, Block, Lambda, Wildcard, Tuple

// ══════════════════════════════════════════════════════════════
// Token struct (same as lexer.hexa)
// ══════════════════════════════════════════════════════════════

struct Token {
    kind: string,
    value: string,
    line: int,
    col: int
}

// ══════════════════════════════════════════════════════════════
// AstNode — universal node type
// ══════════════════════════════════════════════════════════════
// Using separate fields for different data shapes.
// "kind" determines which fields are meaningful.

struct AstNode {
    kind: string,
    name: string,
    value: string,
    op: string,
    left: string,
    right: string,
    cond: string,
    then_body: string,
    else_body: string,
    params: string,
    body: string,
    args: string,
    fields: string,
    items: string,
    variants: string,
    arms: string,
    iter_expr: string,
    ret_type: string,
    target: string,
    trait_name: string,
    methods: string
}

// ══════════════════════════════════════════════════════════════
// Node constructors — each returns an AstNode
// ══════════════════════════════════════════════════════════════

// Empty node for defaults
fn empty_node() {
    return AstNode {
        kind: "", name: "", value: "", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn node_int_lit(val) {
    let n = empty_node()
    // We can't mutate struct fields, so rebuild
    return AstNode {
        kind: "IntLit", name: "", value: val, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn node_float_lit(val) {
    return AstNode {
        kind: "FloatLit", name: "", value: val, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn node_bool_lit(val) {
    return AstNode {
        kind: "BoolLit", name: "", value: val, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn node_string_lit(val) {
    return AstNode {
        kind: "StringLit", name: "", value: val, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn node_char_lit(val) {
    return AstNode {
        kind: "CharLit", name: "", value: val, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn node_ident(name) {
    return AstNode {
        kind: "Ident", name: name, value: "", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn node_wildcard() {
    return AstNode {
        kind: "Wildcard", name: "_", value: "", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

// ══════════════════════════════════════════════════════════════
// Parser state — module-level mutable variables
// Since HEXA doesn't support struct field mutation,
// we use module-level variables that all parse_* functions share.
// ══════════════════════════════════════════════════════════════

let mut p_tokens = []
let mut p_pos = 0

// ── Helpers ─────────────────────────────────────────────────

fn p_peek() {
    if p_pos >= len(p_tokens) {
        return Token { kind: "Eof", value: "", line: 0, col: 0 }
    }
    return p_tokens[p_pos]
}

fn p_peek_kind() {
    return p_peek().kind
}

fn p_peek_ahead(offset) {
    let idx = p_pos + offset
    if idx >= len(p_tokens) {
        return Token { kind: "Eof", value: "", line: 0, col: 0 }
    }
    return p_tokens[idx]
}

fn p_at_end() {
    return p_peek_kind() == "Eof"
}

fn p_advance() {
    let tok = p_peek()
    p_pos = p_pos + 1
    return tok
}

fn p_check(expected_kind) {
    return p_peek_kind() == expected_kind
}

fn p_expect(expected_kind) {
    if p_check(expected_kind) {
        return p_advance()
    }
    let tok = p_peek()
    let msg = "Parse error at " + to_string(tok.line) + ":" + to_string(tok.col) + ": expected " + expected_kind + ", got " + tok.kind + " ('" + tok.value + "')"
    println(msg)
    return tok
}

fn p_expect_ident() {
    let tok = p_peek()
    if tok.kind == "Ident" {
        p_pos = p_pos + 1
        return tok.value
    }
    let msg2 = "Parse error at " + to_string(tok.line) + ":" + to_string(tok.col) + ": expected identifier, got " + tok.kind + " ('" + tok.value + "')"
    println(msg2)
    return ""
}

fn p_skip_newlines() {
    while p_peek_kind() == "Newline" {
        p_pos = p_pos + 1
    }
}

// ══════════════════════════════════════════════════════════════
// Main parse entry point
// ══════════════════════════════════════════════════════════════

fn parse(tokens) {
    p_tokens = tokens
    p_pos = 0
    let mut stmts = []
    p_skip_newlines()
    while !p_at_end() {
        stmts = stmts.push(parse_stmt())
        p_skip_newlines()
    }
    return stmts
}

// ══════════════════════════════════════════════════════════════
// Level 2: Statement
// ══════════════════════════════════════════════════════════════

fn parse_stmt() {
    p_skip_newlines()
    let kind = p_peek_kind()

    if kind == "Let" { return parse_let() }
    if kind == "Const" { return parse_const() }
    if kind == "Static" { return parse_static() }
    if kind == "Fn" { return parse_fn_decl() }
    if kind == "Struct" { return parse_struct_decl() }
    if kind == "Enum" { return parse_enum_decl() }
    if kind == "For" { return parse_for_stmt() }
    if kind == "While" { return parse_while_stmt() }
    if kind == "Loop" { return parse_loop_stmt() }
    if kind == "Return" { return parse_return() }
    if kind == "Proof" { return parse_proof_stmt() }
    if kind == "Assert" { return parse_assert_stmt() }
    if kind == "Impl" { return parse_impl_block() }
    if kind == "Trait" { return parse_trait_decl() }
    if kind == "Use" { return parse_use_decl() }
    if kind == "Mod" { return parse_mod_decl() }

    // Expression statement or assignment
    let expr = parse_expr()
    if p_peek_kind() == "Eq" {
        p_advance() // consume =
        let rhs = parse_expr()
        return AstNode {
            kind: "AssignStmt", name: "", value: "", op: "",
            left: expr, right: rhs, cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    return AstNode {
        kind: "ExprStmt", name: "", value: "", op: "",
        left: expr, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

// ── let [mut] name [: type] = expr ──────────────────────────

fn parse_let() {
    p_advance() // consume 'let'
    let mut is_mut = false
    if p_peek_kind() == "Mut" {
        p_advance()
        is_mut = true
    }
    let name = p_expect_ident()
    // optional type annotation
    let mut typ = ""
    if p_peek_kind() == "Colon" {
        p_advance()
        typ = p_expect_ident()
    }
    p_expect("Eq")
    let expr = parse_expr()
    let mut kind_str = "LetStmt"
    if is_mut {
        kind_str = "LetMutStmt"
    }
    return AstNode {
        kind: kind_str, name: name, value: typ, op: "",
        left: expr, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

// ── const name [: type] = expr ──────────────────────────────

fn parse_const() {
    p_advance() // consume 'const'
    let name = p_expect_ident()
    let mut typ = ""
    if p_peek_kind() == "Colon" {
        p_advance()
        typ = p_expect_ident()
    }
    p_expect("Eq")
    let expr = parse_expr()
    return AstNode {
        kind: "ConstStmt", name: name, value: typ, op: "",
        left: expr, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

// ── static name [: type] = expr ─────────────────────────────

fn parse_static() {
    p_advance() // consume 'static'
    let name = p_expect_ident()
    let mut typ = ""
    if p_peek_kind() == "Colon" {
        p_advance()
        typ = p_expect_ident()
    }
    p_expect("Eq")
    let expr = parse_expr()
    return AstNode {
        kind: "StaticStmt", name: name, value: typ, op: "",
        left: expr, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

// ── return [expr] ───────────────────────────────────────────

fn parse_return() {
    p_advance() // consume 'return'
    let k = p_peek_kind()
    if k == "Newline" || k == "Eof" || k == "RBrace" {
        return AstNode {
            kind: "ReturnStmt", name: "", value: "", op: "",
            left: "", right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    let expr = parse_expr()
    return AstNode {
        kind: "ReturnStmt", name: "", value: "", op: "",
        left: expr, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

// ── proof name { body } ─────────────────────────────────────

fn parse_proof_stmt() {
    p_advance() // consume 'proof'
    let name = p_expect_ident()
    let body = parse_block()
    return AstNode {
        kind: "ProofStmt", name: name, value: "", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: body, args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

// ── assert expr ─────────────────────────────────────────────

fn parse_assert_stmt() {
    p_advance() // consume 'assert'
    let expr = parse_expr()
    return AstNode {
        kind: "AssertStmt", name: "", value: "", op: "",
        left: expr, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

// ── use path::to::module ────────────────────────────────────

fn parse_use_decl() {
    p_advance() // consume 'use'
    let mut path = []
    path = path.push(p_expect_ident())
    while p_peek_kind() == "ColonColon" {
        p_advance()
        path = path.push(p_expect_ident())
    }
    return AstNode {
        kind: "UseStmt", name: "", value: "", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: path,
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

// ── mod name { body } ───────────────────────────────────────

fn parse_mod_decl() {
    p_advance() // consume 'mod'
    let name = p_expect_ident()
    let body = parse_block()
    return AstNode {
        kind: "ModStmt", name: name, value: "", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: body, args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

// ══════════════════════════════════════════════════════════════
// Level 3: Declarations
// ══════════════════════════════════════════════════════════════

// ── fn name(params) [-> ret] { body } ───────────────────────

fn parse_fn_decl() {
    p_advance() // consume 'fn'
    let name = p_expect_ident()
    p_expect("LParen")
    let params = parse_params()
    p_expect("RParen")
    let mut ret = ""
    if p_peek_kind() == "Arrow" {
        p_advance()
        ret = p_expect_ident()
    }
    let body = parse_block()
    return AstNode {
        kind: "FnDecl", name: name, value: "", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: params, body: body, args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: ret,
        target: "", trait_name: "", methods: ""
    }
}

fn parse_params() {
    let mut params = []
    if p_peek_kind() == "RParen" {
        return params
    }
    let name = p_expect_ident()
    let mut typ = ""
    if p_peek_kind() == "Colon" {
        p_advance()
        typ = p_expect_ident()
    }
    params = params.push(AstNode {
        kind: "Param", name: name, value: typ, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    })
    while p_peek_kind() == "Comma" {
        p_advance()
        let pname = p_expect_ident()
        let mut ptyp = ""
        if p_peek_kind() == "Colon" {
            p_advance()
            ptyp = p_expect_ident()
        }
        params = params.push(AstNode {
            kind: "Param", name: pname, value: ptyp, op: "",
            left: "", right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        })
    }
    return params
}

// ── struct Name { field: type, ... } ────────────────────────

fn parse_struct_decl() {
    p_advance() // consume 'struct'
    let name = p_expect_ident()
    p_expect("LBrace")
    p_skip_newlines()
    let mut fields = []
    while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
        let fname = p_expect_ident()
        p_expect("Colon")
        let ftype = p_expect_ident()
        fields = fields.push(AstNode {
            kind: "StructField", name: fname, value: ftype, op: "",
            left: "", right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        })
        if p_peek_kind() == "Comma" {
            p_advance()
        }
        p_skip_newlines()
    }
    p_expect("RBrace")
    return AstNode {
        kind: "StructDecl", name: name, value: "", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: fields, items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

// ── enum Name { Variant1, Variant2(type), ... } ─────────────

fn parse_enum_decl() {
    p_advance() // consume 'enum'
    let name = p_expect_ident()
    p_expect("LBrace")
    p_skip_newlines()
    let mut variants = []
    while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
        let vname = p_expect_ident()
        let mut vtypes = []
        if p_peek_kind() == "LParen" {
            p_advance()
            while p_peek_kind() != "RParen" && p_peek_kind() != "Eof" {
                vtypes = vtypes.push(p_expect_ident())
                if p_peek_kind() == "Comma" {
                    p_advance()
                }
            }
            p_expect("RParen")
        }
        variants = variants.push(AstNode {
            kind: "EnumVariant", name: vname, value: "", op: "",
            left: "", right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: vtypes,
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        })
        if p_peek_kind() == "Comma" {
            p_advance()
        }
        p_skip_newlines()
    }
    p_expect("RBrace")
    return AstNode {
        kind: "EnumDecl", name: name, value: "", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: variants, arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

// ── trait Name { fn method(params) -> ret { body } } ────────

fn parse_trait_decl() {
    p_advance() // consume 'trait'
    let name = p_expect_ident()
    p_expect("LBrace")
    p_skip_newlines()
    let mut methods = []
    while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
        p_skip_newlines()
        if p_peek_kind() == "RBrace" { }
        else {
            p_expect("Fn")
            let mname = p_expect_ident()
            p_expect("LParen")
            let mparams = parse_params()
            p_expect("RParen")
            let mut mret = ""
            if p_peek_kind() == "Arrow" {
                p_advance()
                mret = p_expect_ident()
            }
            let mut mbody = []
            if p_peek_kind() == "LBrace" {
                mbody = parse_block()
            }
            methods = methods.push(AstNode {
                kind: "FnDecl", name: mname, value: "", op: "",
                left: "", right: "", cond: "", then_body: "", else_body: "",
                params: mparams, body: mbody, args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: mret,
                target: "", trait_name: "", methods: ""
            })
            p_skip_newlines()
        }
    }
    p_expect("RBrace")
    return AstNode {
        kind: "TraitDecl", name: name, value: "", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: methods
    }
}

// ── impl [Trait for] Type { methods } ───────────────────────

fn parse_impl_block() {
    p_advance() // consume 'impl'
    let first_name = p_expect_ident()
    let mut trait_n = ""
    let mut target_n = first_name
    if p_peek_kind() == "For" {
        p_advance()
        trait_n = first_name
        target_n = p_expect_ident()
    }
    p_expect("LBrace")
    p_skip_newlines()
    let mut methods = []
    while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
        p_skip_newlines()
        if p_peek_kind() == "RBrace" { }
        else {
            p_expect("Fn")
            let mname = p_expect_ident()
            p_expect("LParen")
            let mparams = parse_params()
            p_expect("RParen")
            let mut mret = ""
            if p_peek_kind() == "Arrow" {
                p_advance()
                mret = p_expect_ident()
            }
            let mbody = parse_block()
            methods = methods.push(AstNode {
                kind: "FnDecl", name: mname, value: "", op: "",
                left: "", right: "", cond: "", then_body: "", else_body: "",
                params: mparams, body: mbody, args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: mret,
                target: "", trait_name: "", methods: ""
            })
            p_skip_newlines()
        }
    }
    p_expect("RBrace")
    return AstNode {
        kind: "ImplBlock", name: "", value: "", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: target_n, trait_name: trait_n, methods: methods
    }
}

// ══════════════════════════════════════════════════════════════
// Level 4: Control Flow
// ══════════════════════════════════════════════════════════════

// ── for var in expr { body } ────────────────────────────────

fn parse_for_stmt() {
    p_advance() // consume 'for'
    let var = p_expect_ident()
    // expect 'in' — it's an identifier, not a keyword
    let in_tok = p_advance()
    if in_tok.value != "in" {
        println(format("Parse error: expected 'in' after for variable, got '{}'", in_tok.value))
    }
    let iter = parse_expr()
    let body = parse_block()
    return AstNode {
        kind: "ForStmt", name: var, value: "", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: body, args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: iter, ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

// ── while cond { body } ─────────────────────────────────────

fn parse_while_stmt() {
    p_advance() // consume 'while'
    let cond = parse_expr()
    let body = parse_block()
    return AstNode {
        kind: "WhileStmt", name: "", value: "", op: "",
        left: "", right: "", cond: cond, then_body: "", else_body: "",
        params: "", body: body, args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

// ── loop { body } ───────────────────────────────────────────

fn parse_loop_stmt() {
    p_advance() // consume 'loop'
    let body = parse_block()
    return AstNode {
        kind: "LoopStmt", name: "", value: "", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: body, args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

// ── if cond { then } [else { else }] (expression) ──────────

fn parse_if_expr() {
    p_advance() // consume 'if'
    let cond = parse_expr()
    let then_b = parse_block()
    let saved = p_pos
    p_skip_newlines()
    let mut else_b = []
    if p_peek_kind() == "Else" {
        p_advance()
        if p_peek_kind() == "If" {
            // else if -> nested
            let nested = parse_if_expr()
            else_b = [AstNode {
                kind: "ExprStmt", name: "", value: "", op: "",
                left: nested, right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            }]
        } else {
            else_b = parse_block()
        }
    } else {
        // No else — backtrack past consumed newlines
        p_pos = saved
    }
    return AstNode {
        kind: "IfExpr", name: "", value: "", op: "",
        left: "", right: "", cond: cond, then_body: then_b, else_body: else_b,
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

// ── match expr { pattern -> body, ... } ─────────────────────

fn parse_match_expr() {
    p_advance() // consume 'match'
    let scrutinee = parse_expr()
    p_expect("LBrace")
    p_skip_newlines()
    let mut arms = []
    while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
        let pattern = parse_match_pattern()
        p_expect("Arrow")
        let mut arm_body = []
        if p_peek_kind() == "LBrace" {
            arm_body = parse_block()
        } else {
            let arm_expr = parse_expr()
            arm_body = [AstNode {
                kind: "ExprStmt", name: "", value: "", op: "",
                left: arm_expr, right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            }]
        }
        arms = arms.push(AstNode {
            kind: "MatchArm", name: "", value: "", op: "",
            left: pattern, right: "", cond: "", then_body: "", else_body: "",
            params: "", body: arm_body, args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        })
        if p_peek_kind() == "Comma" {
            p_advance()
        }
        p_skip_newlines()
    }
    p_expect("RBrace")
    return AstNode {
        kind: "MatchExpr", name: "", value: "", op: "",
        left: scrutinee, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: arms, iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn parse_match_pattern() {
    let tok = p_peek()
    // Wildcard _
    if tok.kind == "Ident" && tok.value == "_" {
        p_advance()
        return node_wildcard()
    }
    // Enum path: Name::Variant
    if tok.kind == "Ident" && p_peek_ahead(1).kind == "ColonColon" {
        let ename = tok.value
        p_advance() // enum name
        p_advance() // ::
        let vname = p_expect_ident()
        let mut data = ""
        if p_peek_kind() == "LParen" {
            p_advance()
            data = parse_expr()
            p_expect("RParen")
        }
        return AstNode {
            kind: "EnumPath", name: ename, value: vname, op: "",
            left: data, right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    // Regular expression
    return parse_expr()
}

// ══════════════════════════════════════════════════════════════
// Block: { stmts }
// ══════════════════════════════════════════════════════════════

fn parse_block() {
    p_skip_newlines()
    p_expect("LBrace")
    p_skip_newlines()
    let mut stmts = []
    while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
        stmts = stmts.push(parse_stmt())
        p_skip_newlines()
    }
    p_expect("RBrace")
    return stmts
}

// ══════════════════════════════════════════════════════════════
// Level 5: Expression (precedence climbing)
// ══════════════════════════════════════════════════════════════

fn parse_expr() {
    return parse_or()
}

// Level 5.1: || ^^
fn parse_or() {
    let mut left = parse_and()
    while p_peek_kind() == "Or" || p_peek_kind() == "Xor" {
        let op_tok = p_advance()
        let right = parse_and()
        left = AstNode {
            kind: "BinOp", name: "", value: "", op: op_tok.value,
            left: left, right: right, cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    return left
}

// Level 5.2: &&
fn parse_and() {
    let mut left = parse_comparison()
    while p_peek_kind() == "And" {
        let op_tok = p_advance()
        let right = parse_comparison()
        left = AstNode {
            kind: "BinOp", name: "", value: "", op: op_tok.value,
            left: left, right: right, cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    return left
}

// Level 5.3: == != < > <= >=
fn parse_comparison() {
    let mut left = parse_addition()
    while p_peek_kind() == "EqEq" || p_peek_kind() == "NotEq" || p_peek_kind() == "Lt" || p_peek_kind() == "Gt" || p_peek_kind() == "LtEq" || p_peek_kind() == "GtEq" {
        let op_tok = p_advance()
        let right = parse_addition()
        left = AstNode {
            kind: "BinOp", name: "", value: "", op: op_tok.value,
            left: left, right: right, cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    return left
}

// Level 5.4: + -
fn parse_addition() {
    let mut left = parse_multiplication()
    while p_peek_kind() == "Plus" || p_peek_kind() == "Minus" {
        let op_tok = p_advance()
        let right = parse_multiplication()
        left = AstNode {
            kind: "BinOp", name: "", value: "", op: op_tok.value,
            left: left, right: right, cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    return left
}

// Level 5.5: * / % **
fn parse_multiplication() {
    let mut left = parse_unary()
    while p_peek_kind() == "Star" || p_peek_kind() == "Slash" || p_peek_kind() == "Percent" || p_peek_kind() == "Power" {
        let op_tok = p_advance()
        let right = parse_unary()
        left = AstNode {
            kind: "BinOp", name: "", value: "", op: op_tok.value,
            left: left, right: right, cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    return left
}

// Level 5.6: Unary ! - ~
fn parse_unary() {
    let k = p_peek_kind()
    if k == "Not" || k == "Minus" || k == "BitNot" {
        let op_tok = p_advance()
        let operand = parse_unary()
        return AstNode {
            kind: "UnaryOp", name: "", value: "", op: op_tok.value,
            left: operand, right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    return parse_postfix()
}

// ── Postfix: call, field access, index ──────────────────────

fn parse_postfix() {
    let mut expr = parse_primary()
    let mut cont = true
    while cont {
        let k = p_peek_kind()
        if k == "LParen" {
            // Function call
            p_advance()
            let args = parse_args()
            p_expect("RParen")
            expr = AstNode {
                kind: "Call", name: "", value: "", op: "",
                left: expr, right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: args, fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            }
        } else if k == "Dot" {
            // Field access
            p_advance()
            let field_name = p_expect_ident()
            expr = AstNode {
                kind: "Field", name: field_name, value: "", op: "",
                left: expr, right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            }
        } else if k == "LBracket" {
            // Index access
            p_advance()
            let index = parse_expr()
            p_expect("RBracket")
            expr = AstNode {
                kind: "Index", name: "", value: "", op: "",
                left: expr, right: index, cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            }
        } else if k == "DotDot" {
            // Range
            p_advance()
            let end = parse_addition()
            expr = AstNode {
                kind: "Range", name: "", value: "exclusive", op: "",
                left: expr, right: end, cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            }
        } else if k == "DotDotEq" {
            // Inclusive range
            p_advance()
            let end = parse_addition()
            expr = AstNode {
                kind: "Range", name: "", value: "inclusive", op: "",
                left: expr, right: end, cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            }
        } else {
            cont = false
        }
    }
    return expr
}

fn parse_args() {
    let mut args = []
    if p_peek_kind() == "RParen" {
        return args
    }
    args = args.push(parse_expr())
    while p_peek_kind() == "Comma" {
        p_advance()
        args = args.push(parse_expr())
    }
    return args
}

// ══════════════════════════════════════════════════════════════
// Level 6: Primary
// ══════════════════════════════════════════════════════════════

fn parse_primary() {
    let tok = p_peek()
    let k = tok.kind

    if k == "IntLit" {
        p_advance()
        return node_int_lit(tok.value)
    }
    if k == "FloatLit" {
        p_advance()
        return node_float_lit(tok.value)
    }
    if k == "BoolLit" {
        p_advance()
        return node_bool_lit(tok.value)
    }
    if k == "StringLit" {
        p_advance()
        return node_string_lit(tok.value)
    }
    if k == "CharLit" {
        p_advance()
        return node_char_lit(tok.value)
    }
    if k == "Ident" {
        p_advance()
        let name = tok.value
        // Check for enum path: Name::Variant
        if p_peek_kind() == "ColonColon" {
            p_advance() // consume ::
            let variant = p_expect_ident()
            return AstNode {
                kind: "EnumPath", name: name, value: variant, op: "",
                left: "", right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            }
        }
        // Check for struct init: Name { field: val, ... }
        // Convention: name starts with uppercase
        if p_peek_kind() == "LBrace" {
            let chars = name.chars()
            if len(chars) > 0 {
                let first_ch = chars[0]
                if is_alpha(first_ch) && to_string(first_ch) == to_string(first_ch).to_upper() {
                    p_advance() // consume {
                    p_skip_newlines()
                    let mut fields = []
                    while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
                        let fname = p_expect_ident()
                        p_expect("Colon")
                        let fval = parse_expr()
                        fields = fields.push(AstNode {
                            kind: "FieldInit", name: fname, value: "", op: "",
                            left: fval, right: "", cond: "", then_body: "", else_body: "",
                            params: "", body: "", args: "", fields: "", items: "",
                            variants: "", arms: "", iter_expr: "", ret_type: "",
                            target: "", trait_name: "", methods: ""
                        })
                        if p_peek_kind() == "Comma" {
                            p_advance()
                        }
                        p_skip_newlines()
                    }
                    p_expect("RBrace")
                    return AstNode {
                        kind: "StructInit", name: name, value: "", op: "",
                        left: "", right: "", cond: "", then_body: "", else_body: "",
                        params: "", body: "", args: "", fields: fields, items: "",
                        variants: "", arms: "", iter_expr: "", ret_type: "",
                        target: "", trait_name: "", methods: ""
                    }
                }
            }
        }
        return node_ident(name)
    }
    if k == "LParen" {
        p_advance()
        let expr = parse_expr()
        // Check for tuple
        if p_peek_kind() == "Comma" {
            let mut items = [expr]
            while p_peek_kind() == "Comma" {
                p_advance()
                if p_peek_kind() == "RParen" { }
                else {
                    items = items.push(parse_expr())
                }
            }
            p_expect("RParen")
            return AstNode {
                kind: "Tuple", name: "", value: "", op: "",
                left: "", right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: items,
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            }
        }
        p_expect("RParen")
        return expr  // grouped expression
    }
    if k == "LBracket" {
        // Array literal
        p_advance()
        let mut items = []
        while p_peek_kind() != "RBracket" && p_peek_kind() != "Eof" {
            items = items.push(parse_expr())
            if p_peek_kind() == "Comma" {
                p_advance()
            }
        }
        p_expect("RBracket")
        return AstNode {
            kind: "Array", name: "", value: "", op: "",
            left: "", right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: items,
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    if k == "If" {
        return parse_if_expr()
    }
    if k == "Match" {
        return parse_match_expr()
    }
    if k == "BitOr" {
        // Lambda: |params| body
        p_advance() // consume first |
        let mut lparams = []
        if p_peek_kind() != "BitOr" {
            lparams = lparams.push(p_expect_ident())
            while p_peek_kind() == "Comma" {
                p_advance()
                lparams = lparams.push(p_expect_ident())
            }
        }
        p_expect("BitOr") // consume closing |
        let mut lbody = ""
        if p_peek_kind() == "LBrace" {
            lbody = parse_block()
        } else {
            lbody = parse_expr()
        }
        return AstNode {
            kind: "Lambda", name: "", value: "", op: "",
            left: lbody, right: "", cond: "", then_body: "", else_body: "",
            params: lparams, body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }

    // Unknown token
    let msg3 = "Parse error at " + to_string(tok.line) + ":" + to_string(tok.col) + ": unexpected token " + tok.kind + " ('" + tok.value + "')"
    println(msg3)
    p_advance() // skip to avoid infinite loop
    return empty_node()
}

// ══════════════════════════════════════════════════════════════
// Utility: AST pretty-printer
// ══════════════════════════════════════════════════════════════

fn ast_to_string(node, indent) {
    let pad = ""
    let mut i = 0
    while i < indent {
        pad = pad + "  "
        i = i + 1
    }

    let k = node.kind

    if k == "IntLit" { return pad + "IntLit(" + node.value + ")" }
    if k == "FloatLit" { return pad + "FloatLit(" + node.value + ")" }
    if k == "BoolLit" { return pad + "BoolLit(" + node.value + ")" }
    if k == "StringLit" { return pad + "StringLit(\"" + node.value + "\")" }
    if k == "CharLit" { return pad + "CharLit('" + node.value + "')" }
    if k == "Ident" { return pad + "Ident(" + node.name + ")" }
    if k == "Wildcard" { return pad + "Wildcard" }

    if k == "BinOp" {
        let l = ast_to_string(node.left, 0)
        let r = ast_to_string(node.right, 0)
        return pad + "BinOp(" + node.op + ", " + l + ", " + r + ")"
    }
    if k == "UnaryOp" {
        let operand = ast_to_string(node.left, 0)
        return pad + "UnaryOp(" + node.op + ", " + operand + ")"
    }
    if k == "Call" {
        let callee = ast_to_string(node.left, 0)
        return pad + "Call(" + callee + ", [" + to_string(len(node.args)) + " args])"
    }
    if k == "Field" {
        let obj = ast_to_string(node.left, 0)
        return pad + "Field(" + obj + "." + node.name + ")"
    }
    if k == "Index" {
        let obj = ast_to_string(node.left, 0)
        let idx = ast_to_string(node.right, 0)
        return pad + "Index(" + obj + "[" + idx + "])"
    }
    if k == "IfExpr" {
        let c = ast_to_string(node.cond, 0)
        return pad + "IfExpr(" + c + ", then=[" + to_string(len(node.then_body)) + "], else=[" + to_string(len(node.else_body)) + "])"
    }
    if k == "MatchExpr" {
        return pad + "MatchExpr([" + to_string(len(node.arms)) + " arms])"
    }
    if k == "Array" {
        return pad + "Array([" + to_string(len(node.items)) + " items])"
    }
    if k == "StructInit" {
        return pad + "StructInit(" + node.name + ", [" + to_string(len(node.fields)) + " fields])"
    }
    if k == "Range" {
        let s = ast_to_string(node.left, 0)
        let e = ast_to_string(node.right, 0)
        return pad + "Range(" + s + ".." + e + ", " + node.value + ")"
    }
    if k == "EnumPath" {
        return pad + "EnumPath(" + node.name + "::" + node.value + ")"
    }
    if k == "Lambda" {
        return pad + "Lambda([" + to_string(len(node.params)) + " params])"
    }
    if k == "Tuple" {
        return pad + "Tuple([" + to_string(len(node.items)) + " items])"
    }

    // Statements
    if k == "LetStmt" || k == "LetMutStmt" {
        let v = ast_to_string(node.left, 0)
        return pad + k + "(" + node.name + " = " + v + ")"
    }
    if k == "ConstStmt" || k == "StaticStmt" {
        let v = ast_to_string(node.left, 0)
        return pad + k + "(" + node.name + " = " + v + ")"
    }
    if k == "ReturnStmt" {
        if node.left == "" {
            return pad + "ReturnStmt()"
        }
        let v = ast_to_string(node.left, 0)
        return pad + "ReturnStmt(" + v + ")"
    }
    if k == "FnDecl" {
        return pad + "FnDecl(" + node.name + ", [" + to_string(len(node.params)) + " params], [" + to_string(len(node.body)) + " stmts])"
    }
    if k == "StructDecl" {
        return pad + "StructDecl(" + node.name + ", [" + to_string(len(node.fields)) + " fields])"
    }
    if k == "EnumDecl" {
        return pad + "EnumDecl(" + node.name + ", [" + to_string(len(node.variants)) + " variants])"
    }
    if k == "ForStmt" {
        return pad + "ForStmt(" + node.name + " in ..., [" + to_string(len(node.body)) + " stmts])"
    }
    if k == "WhileStmt" {
        return pad + "WhileStmt(..., [" + to_string(len(node.body)) + " stmts])"
    }
    if k == "LoopStmt" {
        return pad + "LoopStmt([" + to_string(len(node.body)) + " stmts])"
    }
    if k == "ExprStmt" {
        let v = ast_to_string(node.left, 0)
        return pad + "ExprStmt(" + v + ")"
    }
    if k == "AssignStmt" {
        let l = ast_to_string(node.left, 0)
        let r = ast_to_string(node.right, 0)
        return pad + "AssignStmt(" + l + " = " + r + ")"
    }
    if k == "AssertStmt" {
        let v = ast_to_string(node.left, 0)
        return pad + "AssertStmt(" + v + ")"
    }
    if k == "ProofStmt" {
        return pad + "ProofStmt(" + node.name + ", [" + to_string(len(node.body)) + " stmts])"
    }
    if k == "ImplBlock" {
        return pad + "ImplBlock(" + node.target + ", [" + to_string(len(node.methods)) + " methods])"
    }
    if k == "TraitDecl" {
        return pad + "TraitDecl(" + node.name + ", [" + to_string(len(node.methods)) + " methods])"
    }
    if k == "UseStmt" {
        return pad + "UseStmt([" + to_string(len(node.items)) + " segments])"
    }
    if k == "ModStmt" {
        return pad + "ModStmt(" + node.name + ")"
    }

    return pad + "Unknown(" + k + ")"
}

fn print_ast(stmts) {
    for s in stmts {
        println(ast_to_string(s, 0))
    }
}

// ══════════════════════════════════════════════════════════════
// Inline lexer (since we don't have module imports yet)
// ══════════════════════════════════════════════════════════════

fn is_keyword(word) {
    if word == "if" { return true }
    if word == "else" { return true }
    if word == "match" { return true }
    if word == "for" { return true }
    if word == "while" { return true }
    if word == "loop" { return true }
    if word == "type" { return true }
    if word == "struct" { return true }
    if word == "enum" { return true }
    if word == "trait" { return true }
    if word == "impl" { return true }
    if word == "fn" { return true }
    if word == "return" { return true }
    if word == "yield" { return true }
    if word == "async" { return true }
    if word == "await" { return true }
    if word == "let" { return true }
    if word == "mut" { return true }
    if word == "const" { return true }
    if word == "static" { return true }
    if word == "mod" { return true }
    if word == "use" { return true }
    if word == "pub" { return true }
    if word == "crate" { return true }
    if word == "own" { return true }
    if word == "borrow" { return true }
    if word == "move" { return true }
    if word == "drop" { return true }
    if word == "spawn" { return true }
    if word == "channel" { return true }
    if word == "select" { return true }
    if word == "atomic" { return true }
    if word == "effect" { return true }
    if word == "handle" { return true }
    if word == "resume" { return true }
    if word == "pure" { return true }
    if word == "proof" { return true }
    if word == "assert" { return true }
    if word == "invariant" { return true }
    if word == "theorem" { return true }
    if word == "macro" { return true }
    if word == "derive" { return true }
    if word == "where" { return true }
    if word == "comptime" { return true }
    if word == "try" { return true }
    if word == "catch" { return true }
    if word == "throw" { return true }
    if word == "panic" { return true }
    if word == "recover" { return true }
    if word == "intent" { return true }
    if word == "generate" { return true }
    if word == "verify" { return true }
    if word == "optimize" { return true }
    return false
}

fn keyword_kind(word) {
    if word == "true" { return "BoolLit" }
    if word == "false" { return "BoolLit" }
    if is_keyword(word) {
        let first = to_string(word.chars()[0]).to_upper()
        let rest = ""
        let chars = word.chars()
        let i = 1
        while i < len(chars) {
            rest = rest + to_string(chars[i])
            i = i + 1
        }
        return first + rest
    }
    return "Ident"
}

fn is_ident_start(ch) {
    if is_alpha(ch) { return true }
    if ch == '_' { return true }
    return false
}

fn is_ident_char(ch) {
    if is_alphanumeric(ch) { return true }
    if ch == '_' { return true }
    return false
}

fn tokenize(source) {
    let mut tokens = []
    let chars = source.chars()
    let mut pos = 0
    let mut line = 1
    let mut col = 1
    let total = len(chars)

    while pos < total {
        let ch = chars[pos]
        if ch == ' ' || ch == '\t' || ch == '\r' {
            pos = pos + 1
            col = col + 1
        } else if ch == '\n' {
            tokens = tokens.push(Token { kind: "Newline", value: "\n", line: line, col: col })
            pos = pos + 1
            line = line + 1
            col = 1
        } else if ch == '/' && pos + 1 < total && chars[pos + 1] == '/' {
            pos = pos + 2
            col = col + 2
            while pos < total && chars[pos] != '\n' {
                pos = pos + 1
                col = col + 1
            }
        } else if is_ident_start(ch) {
            let start_col = col
            let mut word = ""
            while pos < total && is_ident_char(chars[pos]) {
                word = word + to_string(chars[pos])
                pos = pos + 1
                col = col + 1
            }
            let kind = keyword_kind(word)
            tokens = tokens.push(Token { kind: kind, value: word, line: line, col: start_col })
        } else if is_digit(ch) {
            let start_col = col
            let mut num_str = ""
            let mut is_float = false
            while pos < total && (is_digit(chars[pos]) || chars[pos] == '_') {
                if chars[pos] == '_' {
                    pos = pos + 1
                    col = col + 1
                } else {
                    num_str = num_str + to_string(chars[pos])
                    pos = pos + 1
                    col = col + 1
                }
            }
            if pos < total && chars[pos] == '.' {
                if pos + 1 < total && is_digit(chars[pos + 1]) {
                    is_float = true
                    num_str = num_str + "."
                    pos = pos + 1
                    col = col + 1
                    while pos < total && (is_digit(chars[pos]) || chars[pos] == '_') {
                        if chars[pos] == '_' {
                            pos = pos + 1
                            col = col + 1
                        } else {
                            num_str = num_str + to_string(chars[pos])
                            pos = pos + 1
                            col = col + 1
                        }
                    }
                }
            }
            if is_float {
                tokens = tokens.push(Token { kind: "FloatLit", value: num_str, line: line, col: start_col })
            } else {
                tokens = tokens.push(Token { kind: "IntLit", value: num_str, line: line, col: start_col })
            }
        } else if ch == '"' {
            let start_col = col
            pos = pos + 1
            col = col + 1
            let mut s = ""
            let mut done = false
            while pos < total && !done {
                let c = chars[pos]
                if c == '"' {
                    done = true
                    pos = pos + 1
                    col = col + 1
                } else if c == '\\' {
                    pos = pos + 1
                    col = col + 1
                    if pos < total {
                        let esc = chars[pos]
                        if esc == 'n' { s = s + "\n" }
                        else if esc == 't' { s = s + "\t" }
                        else if esc == 'r' { s = s + "\r" }
                        else if esc == '\\' { s = s + "\\" }
                        else if esc == '"' { s = s + "\"" }
                        else if esc == '0' { s = s + "\0" }
                        else { s = s + to_string(esc) }
                        pos = pos + 1
                        col = col + 1
                    }
                } else {
                    s = s + to_string(c)
                    pos = pos + 1
                    if c == '\n' {
                        line = line + 1
                        col = 1
                    } else {
                        col = col + 1
                    }
                }
            }
            tokens = tokens.push(Token { kind: "StringLit", value: s, line: line, col: start_col })
        } else if ch == '\'' {
            let start_col = col
            pos = pos + 1
            col = col + 1
            let mut ch_val = ""
            if pos < total && chars[pos] == '\\' {
                pos = pos + 1
                col = col + 1
                if pos < total {
                    let esc = chars[pos]
                    if esc == 'n' { ch_val = "\n" }
                    else if esc == 't' { ch_val = "\t" }
                    else if esc == 'r' { ch_val = "\r" }
                    else if esc == '\\' { ch_val = "\\" }
                    else if esc == '\'' { ch_val = "'" }
                    else if esc == '0' { ch_val = "\0" }
                    else { ch_val = to_string(esc) }
                    pos = pos + 1
                    col = col + 1
                }
            } else if pos < total {
                ch_val = to_string(chars[pos])
                pos = pos + 1
                col = col + 1
            }
            if pos < total && chars[pos] == '\'' {
                pos = pos + 1
                col = col + 1
            }
            tokens = tokens.push(Token { kind: "CharLit", value: ch_val, line: line, col: start_col })
        } else {
            let start_col = col
            if ch == '+' {
                tokens = tokens.push(Token { kind: "Plus", value: "+", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == '-' {
                if pos + 1 < total && chars[pos + 1] == '>' {
                    tokens = tokens.push(Token { kind: "Arrow", value: "->", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens = tokens.push(Token { kind: "Minus", value: "-", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '*' {
                if pos + 1 < total && chars[pos + 1] == '*' {
                    tokens = tokens.push(Token { kind: "Power", value: "**", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens = tokens.push(Token { kind: "Star", value: "*", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '/' {
                tokens = tokens.push(Token { kind: "Slash", value: "/", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == '%' {
                tokens = tokens.push(Token { kind: "Percent", value: "%", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == '=' {
                if pos + 1 < total && chars[pos + 1] == '=' {
                    tokens = tokens.push(Token { kind: "EqEq", value: "==", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens = tokens.push(Token { kind: "Eq", value: "=", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '!' {
                if pos + 1 < total && chars[pos + 1] == '=' {
                    tokens = tokens.push(Token { kind: "NotEq", value: "!=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens = tokens.push(Token { kind: "Not", value: "!", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '<' {
                if pos + 1 < total && chars[pos + 1] == '=' {
                    tokens = tokens.push(Token { kind: "LtEq", value: "<=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens = tokens.push(Token { kind: "Lt", value: "<", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '>' {
                if pos + 1 < total && chars[pos + 1] == '=' {
                    tokens = tokens.push(Token { kind: "GtEq", value: ">=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens = tokens.push(Token { kind: "Gt", value: ">", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '&' {
                if pos + 1 < total && chars[pos + 1] == '&' {
                    tokens = tokens.push(Token { kind: "And", value: "&&", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens = tokens.push(Token { kind: "BitAnd", value: "&", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '|' {
                if pos + 1 < total && chars[pos + 1] == '|' {
                    tokens = tokens.push(Token { kind: "Or", value: "||", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens = tokens.push(Token { kind: "BitOr", value: "|", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '^' {
                if pos + 1 < total && chars[pos + 1] == '^' {
                    tokens = tokens.push(Token { kind: "Xor", value: "^^", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens = tokens.push(Token { kind: "BitXor", value: "^", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '~' {
                tokens = tokens.push(Token { kind: "BitNot", value: "~", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == ':' {
                if pos + 1 < total && chars[pos + 1] == '=' {
                    tokens = tokens.push(Token { kind: "ColonEq", value: ":=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else if pos + 1 < total && chars[pos + 1] == ':' {
                    tokens = tokens.push(Token { kind: "ColonColon", value: "::", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens = tokens.push(Token { kind: "Colon", value: ":", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '.' {
                if pos + 1 < total && chars[pos + 1] == '.' {
                    if pos + 2 < total && chars[pos + 2] == '=' {
                        tokens = tokens.push(Token { kind: "DotDotEq", value: "..=", line: line, col: start_col })
                        pos = pos + 3
                        col = col + 3
                    } else {
                        tokens = tokens.push(Token { kind: "DotDot", value: "..", line: line, col: start_col })
                        pos = pos + 2
                        col = col + 2
                    }
                } else {
                    tokens = tokens.push(Token { kind: "Dot", value: ".", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '(' {
                tokens = tokens.push(Token { kind: "LParen", value: "(", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == ')' {
                tokens = tokens.push(Token { kind: "RParen", value: ")", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == '{' {
                tokens = tokens.push(Token { kind: "LBrace", value: "{", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == '}' {
                tokens = tokens.push(Token { kind: "RBrace", value: "}", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == '[' {
                tokens = tokens.push(Token { kind: "LBracket", value: "[", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == ']' {
                tokens = tokens.push(Token { kind: "RBracket", value: "]", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == ',' {
                tokens = tokens.push(Token { kind: "Comma", value: ",", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == ';' {
                tokens = tokens.push(Token { kind: "Semicolon", value: ";", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else {
                pos = pos + 1
                col = col + 1
            }
        }
    }
    tokens = tokens.push(Token { kind: "Eof", value: "", line: line, col: col })
    return tokens
}

// ══════════════════════════════════════════════════════════════
// Direct-run tests (runs when file is executed normally)
// ══════════════════════════════════════════════════════════════

println("=== HEXA Self-Hosting Parser ===")
println("")

// Test 1: Parse let binding
let t1 = tokenize("let x = 42")
let ast1 = parse(t1)
println("Test 1: let x = 42")
print_ast(ast1)
assert len(ast1) == 1
assert ast1[0].kind == "LetStmt"
assert ast1[0].name == "x"
assert ast1[0].left.kind == "IntLit"
assert ast1[0].left.value == "42"
println("  PASS")
println("")

// Test 2: Parse fn declaration
let t2 = tokenize("fn add(a, b) {\n  a + b\n}")
let ast2 = parse(t2)
println("Test 2: fn add(a, b) { a + b }")
print_ast(ast2)
assert len(ast2) == 1
assert ast2[0].kind == "FnDecl"
assert ast2[0].name == "add"
assert len(ast2[0].params) == 2
assert ast2[0].params[0].name == "a"
assert ast2[0].params[1].name == "b"
assert len(ast2[0].body) == 1
println("  PASS")
println("")

// Test 3: Parse if/else expression
let t3 = tokenize("if x > 0 { x } else { -x }")
let ast3 = parse(t3)
println("Test 3: if x > 0 { x } else { -x }")
print_ast(ast3)
assert len(ast3) == 1
assert ast3[0].kind == "ExprStmt"
assert ast3[0].left.kind == "IfExpr"
assert ast3[0].left.cond.kind == "BinOp"
assert ast3[0].left.cond.op == ">"
assert len(ast3[0].left.then_body) == 1
assert len(ast3[0].left.else_body) == 1
println("  PASS")
println("")

// Test 4: Operator precedence — 1 + 2 * 3 should be Add(1, Mul(2, 3))
let t4 = tokenize("1 + 2 * 3")
let ast4 = parse(t4)
println("Test 4: 1 + 2 * 3 (precedence)")
print_ast(ast4)
assert len(ast4) == 1
assert ast4[0].kind == "ExprStmt"
let expr4 = ast4[0].left
assert expr4.kind == "BinOp"
assert expr4.op == "+"
assert expr4.left.kind == "IntLit"
assert expr4.left.value == "1"
assert expr4.right.kind == "BinOp"
assert expr4.right.op == "*"
assert expr4.right.left.value == "2"
assert expr4.right.right.value == "3"
println("  PASS")
println("")

// Test 5: Struct declaration
let t5 = tokenize("struct Point {\n  x: float,\n  y: float\n}")
let ast5 = parse(t5)
println("Test 5: struct Point { x: float, y: float }")
print_ast(ast5)
assert len(ast5) == 1
assert ast5[0].kind == "StructDecl"
assert ast5[0].name == "Point"
assert len(ast5[0].fields) == 2
assert ast5[0].fields[0].name == "x"
assert ast5[0].fields[0].value == "float"
assert ast5[0].fields[1].name == "y"
assert ast5[0].fields[1].value == "float"
println("  PASS")
println("")

// Test 6: For loop
let t6 = tokenize("for i in 0..10 {\n  print(i)\n}")
let ast6 = parse(t6)
println("Test 6: for i in 0..10 { print(i) }")
print_ast(ast6)
assert len(ast6) == 1
assert ast6[0].kind == "ForStmt"
assert ast6[0].name == "i"
assert ast6[0].iter_expr.kind == "Range"
assert len(ast6[0].body) == 1
println("  PASS")
println("")

// Test 7: Const and return
let t7 = tokenize("const PI = 3.14\nfn get_pi() {\n  return PI\n}")
let ast7 = parse(t7)
println("Test 7: const + fn with return")
print_ast(ast7)
assert len(ast7) == 2
assert ast7[0].kind == "ConstStmt"
assert ast7[0].name == "PI"
assert ast7[0].left.kind == "FloatLit"
assert ast7[1].kind == "FnDecl"
assert ast7[1].name == "get_pi"
println("  PASS")
println("")

// Test 8: Enum declaration
let t8 = tokenize("enum Color {\n  Red,\n  Green,\n  Blue\n}")
let ast8 = parse(t8)
println("Test 8: enum Color { Red, Green, Blue }")
print_ast(ast8)
assert len(ast8) == 1
assert ast8[0].kind == "EnumDecl"
assert ast8[0].name == "Color"
assert len(ast8[0].variants) == 3
println("  PASS")
println("")

// Test 9: Round-trip — lex some real HEXA code, parse it, verify structure
let code9 = "fn factorial(n) {\n  if n <= 1 {\n    return 1\n  }\n  return n * factorial(n - 1)\n}"
let t9 = tokenize(code9)
let ast9 = parse(t9)
println("Test 9: round-trip factorial function")
print_ast(ast9)
assert len(ast9) == 1
assert ast9[0].kind == "FnDecl"
assert ast9[0].name == "factorial"
assert len(ast9[0].params) == 1
assert len(ast9[0].body) == 2  // if + return
println("  PASS")
println("")

// Test 10: Complex expression with method calls and chaining
let t10 = tokenize("arr.push(x).len()")
let ast10 = parse(t10)
println("Test 10: arr.push(x).len()")
print_ast(ast10)
assert len(ast10) == 1
assert ast10[0].kind == "ExprStmt"
// arr.push(x).len() = Call(Field(Call(Field(Ident(arr), push), [x]), len), [])
let e10 = ast10[0].left
assert e10.kind == "Call"
assert e10.left.kind == "Field"
assert e10.left.name == "len"
println("  PASS")
println("")

// Test 11: Match expression
let t11 = tokenize("match x {\n  0 -> \"zero\",\n  _ -> \"other\"\n}")
let ast11 = parse(t11)
println("Test 11: match expression")
print_ast(ast11)
assert len(ast11) == 1
assert ast11[0].kind == "ExprStmt"
assert ast11[0].left.kind == "MatchExpr"
assert len(ast11[0].left.arms) == 2
println("  PASS")
println("")

// Test 12: While loop + assignment
let t12 = tokenize("let mut i = 0\nwhile i < 10 {\n  i = i + 1\n}")
let ast12 = parse(t12)
println("Test 12: let mut + while + assignment")
print_ast(ast12)
assert len(ast12) == 2
assert ast12[0].kind == "LetMutStmt"
assert ast12[0].name == "i"
assert ast12[1].kind == "WhileStmt"
assert len(ast12[1].body) == 1
assert ast12[1].body[0].kind == "AssignStmt"
println("  PASS")
println("")

// Test 13: Unary operators
let t13 = tokenize("!true")
let ast13 = parse(t13)
println("Test 13: !true (unary)")
print_ast(ast13)
assert ast13[0].left.kind == "UnaryOp"
assert ast13[0].left.op == "!"
assert ast13[0].left.left.kind == "BoolLit"
println("  PASS")
println("")

// Test 14: Array literal + index
let t14 = tokenize("[1, 2, 3][0]")
let ast14 = parse(t14)
println("Test 14: [1,2,3][0] (array + index)")
print_ast(ast14)
assert ast14[0].left.kind == "Index"
assert ast14[0].left.left.kind == "Array"
assert len(ast14[0].left.left.items) == 3
println("  PASS")
println("")

println("=== Self-Hosting Parser: ALL 14 TESTS PASSED ===")

// ══════════════════════════════════════════════════════════════
// Proof blocks (for --test mode)
// ══════════════════════════════════════════════════════════════

proof parse_let_binding {
    let tokens = tokenize("let x = 42")
    let stmts = parse(tokens)
    assert len(stmts) == 1
    assert stmts[0].kind == "LetStmt"
    assert stmts[0].name == "x"
    assert stmts[0].left.kind == "IntLit"
    assert stmts[0].left.value == "42"
}

proof parse_fn_decl {
    let tokens = tokenize("fn add(a, b) {\n  a + b\n}")
    let stmts = parse(tokens)
    assert len(stmts) == 1
    assert stmts[0].kind == "FnDecl"
    assert stmts[0].name == "add"
    assert len(stmts[0].params) == 2
}

proof parse_if_else {
    let tokens = tokenize("if x > 0 { x } else { -x }")
    let stmts = parse(tokens)
    assert len(stmts) == 1
    assert stmts[0].left.kind == "IfExpr"
    assert len(stmts[0].left.then_body) == 1
    assert len(stmts[0].left.else_body) == 1
}

proof parse_precedence {
    let tokens = tokenize("1 + 2 * 3")
    let stmts = parse(tokens)
    let expr = stmts[0].left
    assert expr.kind == "BinOp"
    assert expr.op == "+"
    assert expr.left.value == "1"
    assert expr.right.kind == "BinOp"
    assert expr.right.op == "*"
    assert expr.right.left.value == "2"
    assert expr.right.right.value == "3"
}

proof parse_struct_decl {
    let tokens = tokenize("struct Pt {\n  x: int,\n  y: int\n}")
    let stmts = parse(tokens)
    assert stmts[0].kind == "StructDecl"
    assert stmts[0].name == "Pt"
    assert len(stmts[0].fields) == 2
}

proof parse_enum_decl {
    let tokens = tokenize("enum Dir {\n  Up,\n  Down\n}")
    let stmts = parse(tokens)
    assert stmts[0].kind == "EnumDecl"
    assert stmts[0].name == "Dir"
    assert len(stmts[0].variants) == 2
}

proof parse_for_loop {
    let tokens = tokenize("for i in 0..10 {\n  print(i)\n}")
    let stmts = parse(tokens)
    assert stmts[0].kind == "ForStmt"
    assert stmts[0].name == "i"
    assert stmts[0].iter_expr.kind == "Range"
}

proof parse_while_loop {
    let tokens = tokenize("while x > 0 {\n  x = x - 1\n}")
    let stmts = parse(tokens)
    assert stmts[0].kind == "WhileStmt"
    assert stmts[0].cond.kind == "BinOp"
    assert len(stmts[0].body) == 1
}

proof parse_match_expr {
    let tokens = tokenize("match n {\n  0 -> \"zero\",\n  _ -> \"other\"\n}")
    let stmts = parse(tokens)
    assert stmts[0].left.kind == "MatchExpr"
    assert len(stmts[0].left.arms) == 2
}

proof parse_const_static {
    let tokens = tokenize("const X = 1\nstatic Y = 2")
    let stmts = parse(tokens)
    assert stmts[0].kind == "ConstStmt"
    assert stmts[0].name == "X"
    assert stmts[1].kind == "StaticStmt"
    assert stmts[1].name == "Y"
}

proof parse_method_chain {
    let tokens = tokenize("a.b().c")
    let stmts = parse(tokens)
    let e = stmts[0].left
    // a.b().c = Field(Call(Field(Ident(a), b), []), c)
    assert e.kind == "Field"
    assert e.name == "c"
    assert e.left.kind == "Call"
}

proof parse_nested_calls {
    let tokens = tokenize("f(g(1), h(2, 3))")
    let stmts = parse(tokens)
    let e = stmts[0].left
    assert e.kind == "Call"
    assert len(e.args) == 2
    assert e.args[0].kind == "Call"
    assert e.args[1].kind == "Call"
}

proof parse_complex_precedence {
    // 2 + 3 * 4 - 1 should be Sub(Add(2, Mul(3, 4)), 1)
    let tokens = tokenize("2 + 3 * 4 - 1")
    let stmts = parse(tokens)
    let e = stmts[0].left
    assert e.kind == "BinOp"
    assert e.op == "-"
    assert e.left.kind == "BinOp"
    assert e.left.op == "+"
    assert e.right.value == "1"
}

proof parse_return_empty {
    let tokens = tokenize("fn f() {\n  return\n}")
    let stmts = parse(tokens)
    assert stmts[0].kind == "FnDecl"
    let body = stmts[0].body
    assert body[0].kind == "ReturnStmt"
    assert body[0].left == ""
}

proof round_trip_factorial {
    let code = "fn factorial(n) {\n  if n <= 1 {\n    return 1\n  }\n  return n * factorial(n - 1)\n}"
    let tokens = tokenize(code)
    let stmts = parse(tokens)
    assert stmts[0].kind == "FnDecl"
    assert stmts[0].name == "factorial"
    assert len(stmts[0].params) == 1
    assert len(stmts[0].body) == 2
}
