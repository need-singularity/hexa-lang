// ── select { arm1, arm2, ... } ──────────────────────────────
fn parse_select_stmt() {
    p_advance() // consume 'select'
    p_expect("LBrace")
    p_skip_newlines()
    let mut arms = []
    while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
        let expr = parse_expr()
        p_expect("Arrow")
        let body = parse_block()
        arms = arms.push(#{
            "kind": "SelectArm", "name": "", "value": "", "op": "",
            "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": body, "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        })
        p_skip_newlines()
    }
    p_expect("RBrace")
    return #{
        "kind": "SelectStmt", "name": "", "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": arms, "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── async fn name(params) { body } ──────────────────────────
fn parse_async_fn() {
    p_advance() // consume 'async'
    p_expect("Fn")
    let name = p_expect_ident()
    p_expect("LParen")
    let params = parse_params()
    p_expect("RParen")
    let mut ret = ""
    if p_peek_kind() == "Arrow" {
        p_advance()
        ret = p_expect_ident()
    }
    let body = parse_block()
    return #{
        "kind": "AsyncFnDecl", "name": name, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": params, "body": body, "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": ret,
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── @attribute(...) prefix ───────────────────────────────────
// Handles @symbol("name"), @link("lib"), and other attributes.
// Stores the value in pending state, then re-dispatches parse_stmt.
fn parse_attribute_prefix() {
    let attr = p_advance() // consume Attribute token
    let attr_name = attr.value

    if attr_name == "symbol" || attr_name == "link" {
        p_expect("LParen")
        let tok = p_advance()
        let val = tok.value
        p_expect("RParen")
        if attr_name == "symbol" {
            p_pending_symbol = val
        } else {
            p_pending_link = val
        }
        p_skip_newlines()
        return parse_stmt()
    }

    // Unknown attribute — skip and continue
    if p_peek_kind() == "LParen" {
        p_advance() // consume (
        let mut depth = 1
        while depth > 0 && p_peek_kind() != "Eof" {
            if p_peek_kind() == "LParen" { depth = depth + 1 }
            if p_peek_kind() == "RParen" { depth = depth - 1 }
            p_advance()
        }
    }
    p_skip_newlines()
    return parse_stmt()
}

// ── extern fn name(params) -> ret ───────────────────────────
// Supports @symbol("c_name") and @link("lib") attributes.
// @symbol("c_name") maps hexa name to a different C symbol for dlsym.
// The symbol_name field holds the C symbol; if empty, name is used.
fn parse_extern_fn() {
    p_advance() // consume 'extern'
    p_expect("Fn")
    let name = p_expect_ident()
    p_expect("LParen")
    let params = parse_params()
    p_expect("RParen")
    let mut ret = ""
    if p_peek_kind() == "Arrow" {
        p_advance()
        ret = parse_type_annotation()
    }
    // extern fn may have no body (declaration only)
    let mut body = []
    if p_peek_kind() == "LBrace" {
        body = parse_block()
    }
    // Consume pending @symbol / @link attributes
    let sym = p_pending_symbol
    let link = p_pending_link
    p_pending_symbol = ""
    p_pending_link = ""
    return #{
        "kind": "ExternFnDecl", "name": name, "value": sym, "op": link,
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": params, "body": body, "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": ret,
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── type Name = existing_type ───────────────────────────────
fn parse_type_alias() {
    p_advance() // consume 'type'
    let name = p_expect_ident()
    p_expect("Eq")
    let typ = p_expect_ident()
    return #{
        "kind": "TypeAlias", "name": name, "value": typ, "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── atomic let name = expr ──────────────────────────────────
fn parse_atomic_let() {
    p_advance() // consume 'atomic'
    p_expect("Let")
    let name = p_expect_ident()
    // Optional type annotation: atomic let x: int = 0
    let mut typ = ""
    if p_peek_kind() == "Colon" {
        p_advance()
        typ = parse_type_annotation()
    }
    p_expect("Eq")
    let expr = parse_expr()
    return #{
        "kind": "AtomicLet", "name": name, "value": typ, "op": "",
        "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

