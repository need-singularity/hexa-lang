// ── yield expr ──────────────────────────────────────────────
fn parse_yield_stmt() {
    p_advance() // consume 'yield'
    let mut expr = ""
    if p_peek_kind() != "Newline" && p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
        expr = parse_expr()
    }
    return #{
        "kind": "YieldStmt", "name": "", "value": "", "op": "",
        "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── comptime { block } | comptime fn | comptime const | comptime let ──
fn parse_comptime_stmt() {
    p_advance() // consume 'comptime'
    let next = p_peek_kind()
    if next == "Fn" {
        // comptime fn name(params) { body }
        p_advance() // consume 'fn'
        let name = p_expect_ident()
        p_expect("LParen")
        let params = parse_params()
        p_expect("RParen")
        let mut ret = ""
        if p_peek_kind() == "Arrow" {
            p_advance()
            ret = p_expect_ident()
        }
        let body = parse_block()
        return #{
            "kind": "ComptimeFnDecl", "name": name, "value": "", "op": "",
            "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": params, "body": body, "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": ret,
            "target": "", "trait_name": "", "methods": ""
        }
    }
    if next == "Const" {
        // comptime const name = expr
        p_advance() // consume 'const'
        let name = p_expect_ident()
        let mut typ = ""
        if p_peek_kind() == "Colon" {
            p_advance()
            typ = p_expect_ident()
        }
        p_expect("Eq")
        let expr = parse_expr()
        return #{
            "kind": "ComptimeConst", "name": name, "value": typ, "op": "",
            "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    if next == "Let" {
        // comptime let name = expr
        p_advance() // consume 'let'
        if p_peek_kind() == "Mut" {
            p_advance()
        }
        let name = p_expect_ident()
        let mut typ = ""
        if p_peek_kind() == "Colon" {
            p_advance()
            typ = p_expect_ident()
        }
        p_expect("Eq")
        let expr = parse_expr()
        return #{
            "kind": "ComptimeLet", "name": name, "value": typ, "op": "",
            "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    if next == "Assert" {
        // comptime assert expr
        p_advance() // consume 'assert'
        let expr = parse_expr()
        return #{
            "kind": "ComptimeAssert", "name": "", "value": "", "op": "",
            "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    // comptime { block } — compile-time block
    let body = parse_block()
    return #{
        "kind": "ComptimeBlock", "name": "", "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": body, "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── intent "description" { key: value, ... } ────────────────
fn parse_intent_stmt() {
    p_advance() // consume 'intent'
    // intent accepts a string literal or identifier as description
    let mut desc = ""
    if p_peek_kind() == "StringLit" {
        desc = p_advance().value
    } else {
        desc = p_expect_ident()
    }
    p_expect("LBrace")
    p_skip_newlines()
    let mut fields = []
    while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
        let key = p_expect_ident()
        p_expect("Colon")
        let val = parse_expr()
        fields = fields.push(#{
            "kind": "IntentField", "name": key, "value": "", "op": "",
            "left": val, "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        })
        if p_peek_kind() == "Comma" {
            p_advance()
        }
        p_skip_newlines()
    }
    p_expect("RBrace")
    return #{
        "kind": "IntentStmt", "name": desc, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": fields, "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── verify "name" { block } ────────────────────────────────
fn parse_verify_stmt() {
    p_advance() // consume 'verify'
    let mut name = ""
    if p_peek_kind() == "StringLit" {
        name = p_advance().value
    } else {
        name = p_expect_ident()
    }
    let body = parse_block()
    return #{
        "kind": "VerifyStmt", "name": name, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": body, "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── generate fn name(params) { "desc" } | generate { "desc" } ──
fn parse_generate_stmt() {
    p_advance() // consume 'generate'
    if p_peek_kind() == "Fn" {
        // generate fn name(params) -> ret { "description" }
        p_advance() // consume 'fn'
        let name = p_expect_ident()
        p_expect("LParen")
        let params = parse_params()
        p_expect("RParen")
        let mut ret = ""
        if p_peek_kind() == "Arrow" {
            p_advance()
            ret = p_expect_ident()
        }
        p_expect("LBrace")
        p_skip_newlines()
        let mut desc = ""
        if p_peek_kind() == "StringLit" {
            desc = p_advance().value
        }
        p_skip_newlines()
        p_expect("RBrace")
        return #{
            "kind": "GenerateFnStmt", "name": name, "value": desc, "op": "",
            "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": params, "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": ret,
            "target": "", "trait_name": "", "methods": ""
        }
    }
    // generate [type_hint] { "description" }
    let mut type_hint = ""
    if p_peek_kind() != "LBrace" {
        type_hint = p_expect_ident()
    }
    p_expect("LBrace")
    p_skip_newlines()
    let mut desc = ""
    if p_peek_kind() == "StringLit" {
        desc = p_advance().value
    }
    p_skip_newlines()
    p_expect("RBrace")
    return #{
        "kind": "GenerateStmt", "name": type_hint, "value": desc, "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── optimize fn name(params) { body } ──────────────────────
fn parse_optimize_stmt() {
    p_advance() // consume 'optimize'
    p_expect("Fn")
    let name = p_expect_ident()
    p_expect("LParen")
    let params = parse_params()
    p_expect("RParen")
    let mut ret = ""
    if p_peek_kind() == "Arrow" {
        p_advance()
        ret = p_expect_ident()
    }
    let body = parse_block()
    return #{
        "kind": "OptimizeFnStmt", "name": name, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": params, "body": body, "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": ret,
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── effect Name { fn op(params) -> ret, ... } ──────────────
fn parse_effect_decl() {
    p_advance() // consume 'effect'
    let name = p_expect_ident()
    // Optional type params: effect State<T> { ... }
    let mut tparams = []
    if p_peek_kind() == "Lt" {
        tparams = parse_type_params()
    }
    p_skip_newlines()
    p_expect("LBrace")
    p_skip_newlines()
    let mut ops = []
    while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
        p_expect("Fn")
        let op_name = p_expect_ident()
        p_expect("LParen")
        let op_params = parse_params()
        p_expect("RParen")
        let mut op_ret = ""
        if p_peek_kind() == "Arrow" {
            p_advance()
            op_ret = p_expect_ident()
        }
        ops = ops.push(#{
            "kind": "EffectOp", "name": op_name, "value": "", "op": "",
            "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": op_params, "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": op_ret,
            "target": "", "trait_name": "", "methods": ""
        })
        p_skip_newlines()
    }
    p_expect("RBrace")
    return #{
        "kind": "EffectDecl", "name": name, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": tparams, "body": "", "args": "", "fields": "", "items": ops,
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── pure fn name(params) { body } ──────────────────────────
fn parse_pure_fn() {
    p_advance() // consume 'pure'
    p_expect("Fn")
    let name = p_expect_ident()
    p_expect("LParen")
    let params = parse_params()
    p_expect("RParen")
    let mut ret = ""
    if p_peek_kind() == "Arrow" {
        p_advance()
        ret = p_expect_ident()
    }
    let body = parse_block()
    return #{
        "kind": "PureFnDecl", "name": name, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": params, "body": body, "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": ret,
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── macro! name { (pattern) => { body }, ... } ─────────────
fn parse_macro_def() {
    p_advance() // consume 'macro'
    // Expect '!' after macro
    if p_peek_kind() == "Not" {
        p_advance()
    }
    let name = p_expect_ident()
    p_expect("LBrace")
    p_skip_newlines()
    // Simplified: collect arms as (pattern_tokens, body_block) pairs
    let mut rules = []
    while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
        // Parse pattern: ( ... )
        p_expect("LParen")
        p_skip_newlines()
        let mut pat_tokens = []
        while p_peek_kind() != "RParen" && p_peek_kind() != "Eof" {
            let tok = p_advance()
            pat_tokens = pat_tokens.push(tok.value)
            p_skip_newlines()
        }
        p_expect("RParen")
        // Expect => (FatArrow)
        // Since we may not have FatArrow token, accept Eq + Gt combo or just skip
        if p_peek_kind() == "Eq" {
            p_advance()
            if p_peek_kind() == "Gt" {
                p_advance()
            }
        }
        let body = parse_block()
        rules = rules.push(#{
            "kind": "MacroRule", "name": "", "value": "", "op": "",
            "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": pat_tokens, "body": body, "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        })
        if p_peek_kind() == "Comma" || p_peek_kind() == "Semicolon" {
            p_advance()
        }
        p_skip_newlines()
    }
    p_expect("RBrace")
    return #{
        "kind": "MacroDef", "name": name, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": rules,
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── derive(Trait1, Trait2) for TypeName ─────────────────────
fn parse_derive_decl() {
    p_advance() // consume 'derive'
    p_expect("LParen")
    let mut traits = []
    traits = traits.push(p_expect_ident())
    while p_peek_kind() == "Comma" {
        p_advance()
        traits = traits.push(p_expect_ident())
    }
    p_expect("RParen")
    // Expect 'for' — it's a keyword or ident
    if p_peek_kind() == "For" {
        p_advance()
    } else {
        p_expect_ident() // "for" as ident
    }
    let type_name = p_expect_ident()
    return #{
        "kind": "DeriveDecl", "name": type_name, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": traits,
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── theorem name { proof_body } ─────────────────────────────
fn parse_theorem_stmt() {
    p_advance() // consume 'theorem'
    let name = p_expect_ident()
    p_expect("LBrace")
    p_skip_newlines()
    let mut stmts = []
    while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
        stmts = stmts.push(parse_stmt())
        p_skip_newlines()
    }
    p_expect("RBrace")
    return #{
        "kind": "TheoremStmt", "name": name, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": stmts, "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── handle { body } with { Effect.op(params) => { handler }, ... } ──
fn parse_handle_stmt() {
    p_advance() // consume 'handle'
    let body = parse_block()
    p_skip_newlines()
    // Expect 'with' (it's an ident, not a keyword)
    p_expect_ident() // consume "with"
    p_skip_newlines()
    p_expect("LBrace")
    p_skip_newlines()
    let mut handlers = []
    while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
        // Parse: Effect.op(params) => { body }
        let effect_name = p_expect_ident()
        p_expect("Dot")
        let op_name = p_expect_ident()
        let mut hparams = []
        if p_peek_kind() == "LParen" {
            p_advance()
            while p_peek_kind() != "RParen" && p_peek_kind() != "Eof" {
                hparams = hparams.push(p_expect_ident())
                if p_peek_kind() == "Comma" {
                    p_advance()
                }
            }
            p_expect("RParen")
        }
        // Expect => (Eq + Gt) or -> (Arrow) or FatArrow
        let pk = p_peek_kind()
        if pk == "Eq" {
            p_advance()
            if p_peek_kind() == "Gt" {
                p_advance()
            }
        } else {
            if pk == "Arrow" || pk == "FatArrow" {
                p_advance()
            }
        }
        let hbody = parse_block()
        handlers = handlers.push(#{
            "kind": "EffectHandler", "name": op_name, "value": "", "op": "",
            "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": hparams, "body": hbody, "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": effect_name, "trait_name": "", "methods": ""
        })
        p_skip_newlines()
    }
    p_expect("RBrace")
    return #{
        "kind": "HandleWithStmt", "name": "", "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": body, "args": "", "fields": "", "items": handlers,
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── pub/pub(crate) prefix — returns visibility string ───────
fn parse_visibility() {
    if p_peek_kind() == "Pub" {
        p_advance()
        if p_peek_kind() == "LParen" {
            p_advance()
            let vis_scope = p_expect_ident() // "crate" or "mod"
            p_expect("RParen")
            return vis_scope
        }
        return "pub"
    }
    return "private"
}

// ── <T, U: Trait> — type parameters ─────────────────────────
fn parse_type_params() {
    if p_peek_kind() != "Lt" { return [] }
    p_advance() // consume <
    let mut tparams = []
    let name = p_expect_ident()
    let mut bound = ""
    if p_peek_kind() == "Colon" {
        p_advance()
        bound = p_expect_ident()
    }
    tparams = tparams.push(#{
        "kind": "TypeParam", "name": name, "value": bound, "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    })
    while p_peek_kind() == "Comma" {
        p_advance()
        let pname = p_expect_ident()
        let mut pbound = ""
        if p_peek_kind() == "Colon" {
            p_advance()
            pbound = p_expect_ident()
        }
        tparams = tparams.push(#{
            "kind": "TypeParam", "name": pname, "value": pbound, "op": "",
            "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        })
    }
    p_expect("Gt")
    return tparams
}

// ── where T: Trait, U: Clone ────────────────────────────────
fn parse_where_clauses() {
    if p_peek_kind() != "Where" { return [] }
    p_advance() // consume 'where'
    let mut clauses = []
    let tname = p_expect_ident()
    p_expect("Colon")
    let tbound = p_expect_ident()
    clauses = clauses.push(#{
        "kind": "WhereClause", "name": tname, "value": tbound, "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    })
    while p_peek_kind() == "Comma" {
        p_advance()
        let wname = p_expect_ident()
        p_expect("Colon")
        let wbound = p_expect_ident()
        clauses = clauses.push(#{
            "kind": "WhereClause", "name": wname, "value": wbound, "op": "",
            "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        })
    }
    return clauses
}

// ══════════════════════════════════════════════════════════════
// Utility: AST pretty-printer
// ══════════════════════════════════════════════════════════════

fn ast_to_string(node, indent) {
    let pad = ""
    let mut i = 0
    while i < indent {
        pad = pad + "  "
        i = i + 1
    }

    let k = node.kind

    if k == "IntLit" { return pad + "IntLit(" + node.value + ")" }
    if k == "FloatLit" { return pad + "FloatLit(" + node.value + ")" }
    if k == "BoolLit" { return pad + "BoolLit(" + node.value + ")" }
    if k == "StringLit" { return pad + "StringLit(\"" + node.value + "\")" }
    if k == "CharLit" { return pad + "CharLit('" + node.value + "')" }
    if k == "Ident" { return pad + "Ident(" + node.name + ")" }
    if k == "Wildcard" { return pad + "Wildcard" }

    if k == "BinOp" {
        let l = ast_to_string(node.left, 0)
        let r = ast_to_string(node.right, 0)
        return pad + "BinOp(" + node.op + ", " + l + ", " + r + ")"
    }
    if k == "UnaryOp" {
        let operand = ast_to_string(node.left, 0)
        return pad + "UnaryOp(" + node.op + ", " + operand + ")"
    }
    if k == "Call" {
        let callee = ast_to_string(node.left, 0)
        return pad + "Call(" + callee + ", [" + to_string(len(node.args)) + " args])"
    }
    if k == "Field" {
        let obj = ast_to_string(node.left, 0)
        return pad + "Field(" + obj + "." + node.name + ")"
    }
    if k == "OptField" {
        let obj = ast_to_string(node.left, 0)
        return pad + "OptField(" + obj + "?." + node.name + ")"
    }
    if k == "Index" {
        let obj = ast_to_string(node.left, 0)
        let idx = ast_to_string(node.right, 0)
        return pad + "Index(" + obj + "[" + idx + "])"
    }
    if k == "IfExpr" {
        let c = ast_to_string(node.cond, 0)
        return pad + "IfExpr(" + c + ", then=[" + to_string(len(node.then_body)) + "], else=[" + to_string(len(node.else_body)) + "])"
    }
    if k == "MatchExpr" {
        return pad + "MatchExpr([" + to_string(len(node.arms)) + " arms])"
    }
    if k == "Array" {
        return pad + "Array([" + to_string(len(node.items)) + " items])"
    }
    if k == "ListComp" {
        let body_s = ast_to_string(node.left, 0)
        let iter_s = ast_to_string(node.iter_expr, 0)
        let filt = ""
        if type_of(node.cond) != "string" { filt = " if " + ast_to_string(node.cond, 0) }
        return pad + "ListComp(" + body_s + " for " + node.name + " in " + iter_s + filt + ")"
    }
    if k == "StructInit" {
        return pad + "StructInit(" + node.name + ", [" + to_string(len(node.fields)) + " fields])"
    }
    if k == "Range" {
        let s = ast_to_string(node.left, 0)
        let e = ast_to_string(node.right, 0)
        return pad + "Range(" + s + ".." + e + ", " + node.value + ")"
    }
    if k == "EnumPath" {
        return pad + "EnumPath(" + node.name + "::" + node.value + ")"
    }
    if k == "Lambda" {
        return pad + "Lambda([" + to_string(len(node.params)) + " params])"
    }
    if k == "Tuple" {
        return pad + "Tuple([" + to_string(len(node.items)) + " items])"
    }

    // Statements
    if k == "LetStmt" || k == "LetMutStmt" {
        let v = ast_to_string(node.left, 0)
        return pad + k + "(" + node.name + " = " + v + ")"
    }
    if k == "ConstStmt" || k == "StaticStmt" {
        let v = ast_to_string(node.left, 0)
        return pad + k + "(" + node.name + " = " + v + ")"
    }
    if k == "ReturnStmt" {
        if node.left == "" {
            return pad + "ReturnStmt()"
        }
        let v = ast_to_string(node.left, 0)
        return pad + "ReturnStmt(" + v + ")"
    }
    if k == "FnDecl" {
        return pad + "FnDecl(" + node.name + ", [" + to_string(len(node.params)) + " params], [" + to_string(len(node.body)) + " stmts])"
    }
    if k == "StructDecl" {
        return pad + "StructDecl(" + node.name + ", [" + to_string(len(node.fields)) + " fields])"
    }
    if k == "EnumDecl" {
        return pad + "EnumDecl(" + node.name + ", [" + to_string(len(node.variants)) + " variants])"
    }
    if k == "ForStmt" {
        return pad + "ForStmt(" + node.name + " in ..., [" + to_string(len(node.body)) + " stmts])"
    }
    if k == "WhileStmt" {
        return pad + "WhileStmt(..., [" + to_string(len(node.body)) + " stmts])"
    }
    if k == "LoopStmt" {
        return pad + "LoopStmt([" + to_string(len(node.body)) + " stmts])"
    }
    if k == "ExprStmt" {
        let v = ast_to_string(node.left, 0)
        return pad + "ExprStmt(" + v + ")"
    }
    if k == "AssignStmt" {
        let l = ast_to_string(node.left, 0)
        let r = ast_to_string(node.right, 0)
        return pad + "AssignStmt(" + l + " = " + r + ")"
    }
    if k == "AssertStmt" {
        let v = ast_to_string(node.left, 0)
        return pad + "AssertStmt(" + v + ")"
    }
    if k == "ProofStmt" {
        return pad + "ProofStmt(" + node.name + ", [" + to_string(len(node.body)) + " stmts])"
    }
    if k == "ImplBlock" {
        return pad + "ImplBlock(" + node.target + ", [" + to_string(len(node.methods)) + " methods])"
    }
    if k == "TraitDecl" {
        return pad + "TraitDecl(" + node.name + ", [" + to_string(len(node.methods)) + " methods])"
    }
    if k == "UseStmt" {
        return pad + "UseStmt([" + to_string(len(node.items)) + " segments])"
    }
    if k == "ModStmt" {
        return pad + "ModStmt(" + node.name + ")"
    }

    // Phase 2 node kinds
    if k == "BreakStmt" { return pad + "BreakStmt" }
    if k == "ContinueStmt" { return pad + "ContinueStmt" }
    if k == "YieldStmt" {
        if node.left == "" { return pad + "YieldStmt()" }
        return pad + "YieldStmt(" + ast_to_string(node.left, 0) + ")"
    }
    if k == "ComptimeFnDecl" {
        return pad + "ComptimeFnDecl(" + node.name + ", [" + to_string(len(node.params)) + " params])"
    }
    if k == "ComptimeConst" || k == "ComptimeLet" {
        let v = ast_to_string(node.left, 0)
        return pad + k + "(" + node.name + " = " + v + ")"
    }
    if k == "ComptimeBlock" {
        return pad + "ComptimeBlock([" + to_string(len(node.body)) + " stmts])"
    }
    if k == "ComptimeAssert" {
        return pad + "ComptimeAssert(" + ast_to_string(node.left, 0) + ")"
    }
    if k == "IntentStmt" {
        return pad + "IntentStmt(" + node.name + ", [" + to_string(len(node.fields)) + " fields])"
    }
    if k == "VerifyStmt" {
        return pad + "VerifyStmt(" + node.name + ", [" + to_string(len(node.body)) + " stmts])"
    }
    if k == "GenerateFnStmt" || k == "GenerateStmt" {
        return pad + k + "(" + node.name + ")"
    }
    if k == "OptimizeFnStmt" {
        return pad + "OptimizeFnStmt(" + node.name + ", [" + to_string(len(node.params)) + " params])"
    }
    if k == "EffectDecl" {
        return pad + "EffectDecl(" + node.name + ", [" + to_string(len(node.items)) + " ops])"
    }
    if k == "PureFnDecl" {
        return pad + "PureFnDecl(" + node.name + ", [" + to_string(len(node.params)) + " params])"
    }
    if k == "MacroDef" {
        return pad + "MacroDef(" + node.name + ", [" + to_string(len(node.items)) + " rules])"
    }
    if k == "DeriveDecl" {
        return pad + "DeriveDecl(" + node.name + ", [" + to_string(len(node.items)) + " traits])"
    }
    if k == "TheoremStmt" {
        return pad + "TheoremStmt(" + node.name + ", [" + to_string(len(node.body)) + " stmts])"
    }
    if k == "HandleWithStmt" {
        return pad + "HandleWithStmt([" + to_string(len(node.items)) + " handlers])"
    }
    // Phase 1 node kinds that may have been missing from printer
    if k == "TryCatch" {
        return pad + "TryCatch(" + node.name + ")"
    }
    if k == "ThrowStmt" {
        return pad + "ThrowStmt(" + ast_to_string(node.left, 0) + ")"
    }
    if k == "PanicStmt" {
        return pad + "PanicStmt(" + ast_to_string(node.left, 0) + ")"
    }
    if k == "DropStmt" {
        return pad + "DropStmt(" + node.name + ")"
    }
    if k == "SpawnStmt" {
        return pad + "SpawnStmt([" + to_string(len(node.body)) + " stmts])"
    }
    if k == "ScopeStmt" {
        return pad + "ScopeStmt([" + to_string(len(node.body)) + " stmts])"
    }
    if k == "SelectStmt" {
        return pad + "SelectStmt([" + to_string(len(node.arms)) + " arms])"
    }
    if k == "AsyncFnDecl" {
        return pad + "AsyncFnDecl(" + node.name + ", [" + to_string(len(node.params)) + " params])"
    }
    if k == "ExternFnDecl" {
        let sym_info = ""
        if node.value != "" {
            sym_info = ", @symbol(\"" + node.value + "\")"
        }
        return pad + "ExternFnDecl(" + node.name + ", [" + to_string(len(node.params)) + " params]" + sym_info + ")"
    }
    if k == "TypeAlias" {
        return pad + "TypeAlias(" + node.name + " = " + node.value + ")"
    }
    if k == "AtomicLet" {
        return pad + "AtomicLet(" + node.name + ")"
    }

    return pad + "Unknown(" + k + ")"
}

fn print_ast(stmts) {
    for s in stmts {
        println(ast_to_string(s, 0))
    }
}

// ══════════════════════════════════════════════════════════════
// Inline lexer (since we don't have module imports yet)
// ══════════════════════════════════════════════════════════════

fn is_keyword(word) {
    if word == "if" { return true }
    if word == "else" { return true }
    if word == "match" { return true }
    if word == "for" { return true }
    if word == "while" { return true }
    if word == "loop" { return true }
    if word == "type" { return true }
    if word == "struct" { return true }
    if word == "enum" { return true }
    if word == "trait" { return true }
    if word == "impl" { return true }
    if word == "fn" { return true }
    if word == "return" { return true }
    if word == "yield" { return true }
    if word == "async" { return true }
    if word == "await" { return true }
    if word == "let" { return true }
    if word == "mut" { return true }
    if word == "const" { return true }
    if word == "static" { return true }
    if word == "mod" { return true }
    if word == "use" { return true }
    if word == "pub" { return true }
    if word == "crate" { return true }
    if word == "own" { return true }
    if word == "borrow" { return true }
    if word == "move" { return true }
    if word == "drop" { return true }
    if word == "spawn" { return true }
    if word == "channel" { return true }
    if word == "select" { return true }
    if word == "atomic" { return true }
    if word == "effect" { return true }
    if word == "handle" { return true }
    if word == "resume" { return true }
    if word == "pure" { return true }
    if word == "proof" { return true }
    if word == "assert" { return true }
    if word == "invariant" { return true }
    if word == "theorem" { return true }
    if word == "macro" { return true }
    if word == "derive" { return true }
    if word == "where" { return true }
    if word == "comptime" { return true }
    if word == "try" { return true }
    if word == "catch" { return true }
    if word == "throw" { return true }
    if word == "panic" { return true }
    if word == "recover" { return true }
    if word == "intent" { return true }
    if word == "generate" { return true }
    if word == "verify" { return true }
    if word == "optimize" { return true }
    if word == "break" { return true }
    if word == "continue" { return true }
    if word == "extern" { return true }
    if word == "dyn" { return true }
    if word == "scope" { return true }
    return false
}

fn keyword_kind(word) {
    if word == "true" { return "BoolLit" }
    if word == "false" { return "BoolLit" }
    if is_keyword(word) {
        let first = to_string(word.chars()[0]).to_upper()
        let rest = ""
        let chars = word.chars()
        let i = 1
        while i < len(chars) {
            rest = rest + to_string(chars[i])
            i = i + 1
        }
        return first + rest
    }
    return "Ident"
}

fn is_ident_start(ch) {
    if is_alpha(ch) { return true }
    if ch == '_' { return true }
    return false
}

fn is_ident_char(ch) {
    if is_alphanumeric(ch) { return true }
    if ch == '_' { return true }
    return false
}

fn tokenize(source) {
    let mut tokens = []
    let chars = source.chars()
    let mut pos = 0
    let mut line = 1
    let mut col = 1
    let total = len(chars)

    while pos < total {
        let ch = chars[pos]
        if ch == ' ' || ch == '\t' || ch == '\r' {
            pos = pos + 1
            col = col + 1
        } else if ch == '\n' {
            tokens = tokens.push(Token { kind: "Newline", value: "\n", line: line, col: col })
            pos = pos + 1
            line = line + 1
            col = 1
        } else if ch == '/' && pos + 1 < total && chars[pos + 1] == '/' {
            pos = pos + 2
            col = col + 2
            while pos < total && chars[pos] != '\n' {
                pos = pos + 1
                col = col + 1
            }
        } else if is_ident_start(ch) {
            let start_col = col
            let mut word = ""
            while pos < total && is_ident_char(chars[pos]) {
                word = word + to_string(chars[pos])
                pos = pos + 1
                col = col + 1
            }
            let kind = keyword_kind(word)
            tokens = tokens.push(Token { kind: kind, value: word, line: line, col: start_col })
        } else if is_digit(ch) {
            let start_col = col
            let mut num_str = ""
            let mut is_float = false
            while pos < total && (is_digit(chars[pos]) || chars[pos] == '_') {
                if chars[pos] == '_' {
                    pos = pos + 1
                    col = col + 1
                } else {
                    num_str = num_str + to_string(chars[pos])
                    pos = pos + 1
                    col = col + 1
                }
            }
            if pos < total && chars[pos] == '.' {
                if pos + 1 < total && is_digit(chars[pos + 1]) {
                    is_float = true
                    num_str = num_str + "."
                    pos = pos + 1
                    col = col + 1
                    while pos < total && (is_digit(chars[pos]) || chars[pos] == '_') {
                        if chars[pos] == '_' {
                            pos = pos + 1
                            col = col + 1
                        } else {
                            num_str = num_str + to_string(chars[pos])
                            pos = pos + 1
                            col = col + 1
                        }
                    }
                }
            }
            if is_float {
                tokens = tokens.push(Token { kind: "FloatLit", value: num_str, line: line, col: start_col })
            } else {
                tokens = tokens.push(Token { kind: "IntLit", value: num_str, line: line, col: start_col })
            }
        } else if ch == '"' {
            let start_col = col
            pos = pos + 1
            col = col + 1
            let mut s = ""
            let mut done = false
            while pos < total && !done {
                let c = chars[pos]
                if c == '"' {
                    done = true
                    pos = pos + 1
                    col = col + 1
                } else if c == '\\' {
                    pos = pos + 1
                    col = col + 1
                    if pos < total {
                        let esc = chars[pos]
                        if esc == 'n' { s = s + "\n" }
                        else if esc == 't' { s = s + "\t" }
                        else if esc == 'r' { s = s + "\r" }
                        else if esc == '\\' { s = s + "\\" }
                        else if esc == '"' { s = s + "\"" }
                        else if esc == '0' { s = s + "\0" }
                        else { s = s + to_string(esc) }
                        pos = pos + 1
                        col = col + 1
                    }
                } else {
                    s = s + to_string(c)
                    pos = pos + 1
                    if c == '\n' {
                        line = line + 1
                        col = 1
                    } else {
                        col = col + 1
                    }
                }
            }
            tokens = tokens.push(Token { kind: "StringLit", value: s, line: line, col: start_col })
        } else if ch == '\'' {
            let start_col = col
            pos = pos + 1
            col = col + 1
            let mut ch_val = ""
            if pos < total && chars[pos] == '\\' {
                pos = pos + 1
                col = col + 1
                if pos < total {
                    let esc = chars[pos]
                    if esc == 'n' { ch_val = "\n" }
                    else if esc == 't' { ch_val = "\t" }
                    else if esc == 'r' { ch_val = "\r" }
                    else if esc == '\\' { ch_val = "\\" }
                    else if esc == '\'' { ch_val = "'" }
                    else if esc == '0' { ch_val = "\0" }
                    else { ch_val = to_string(esc) }
                    pos = pos + 1
                    col = col + 1
                }
            } else if pos < total {
                ch_val = to_string(chars[pos])
                pos = pos + 1
                col = col + 1
            }
            if pos < total && chars[pos] == '\'' {
                pos = pos + 1
                col = col + 1
            }
            tokens = tokens.push(Token { kind: "CharLit", value: ch_val, line: line, col: start_col })
        } else {
            let start_col = col
            if ch == '+' {
                if pos + 1 < total && chars[pos + 1] == '=' {
                    tokens = tokens.push(Token { kind: "PlusEq", value: "+=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens = tokens.push(Token { kind: "Plus", value: "+", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '-' {
                if pos + 1 < total && chars[pos + 1] == '>' {
                    tokens = tokens.push(Token { kind: "Arrow", value: "->", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else if pos + 1 < total && chars[pos + 1] == '=' {
                    tokens = tokens.push(Token { kind: "MinusEq", value: "-=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens = tokens.push(Token { kind: "Minus", value: "-", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '*' {
                if pos + 1 < total && chars[pos + 1] == '*' {
                    tokens = tokens.push(Token { kind: "Power", value: "**", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else if pos + 1 < total && chars[pos + 1] == '=' {
                    tokens = tokens.push(Token { kind: "StarEq", value: "*=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens = tokens.push(Token { kind: "Star", value: "*", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '/' {
                if pos + 1 < total && chars[pos + 1] == '=' {
                    tokens = tokens.push(Token { kind: "SlashEq", value: "/=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens = tokens.push(Token { kind: "Slash", value: "/", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '%' {
                if pos + 1 < total && chars[pos + 1] == '=' {
                    tokens = tokens.push(Token { kind: "PercentEq", value: "%=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens = tokens.push(Token { kind: "Percent", value: "%", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '=' {
                if pos + 1 < total && chars[pos + 1] == '=' {
                    tokens = tokens.push(Token { kind: "EqEq", value: "==", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens = tokens.push(Token { kind: "Eq", value: "=", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '!' {
                if pos + 1 < total && chars[pos + 1] == '=' {
                    tokens = tokens.push(Token { kind: "NotEq", value: "!=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens = tokens.push(Token { kind: "Not", value: "!", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '<' {
                if pos + 1 < total && chars[pos + 1] == '=' {
                    tokens = tokens.push(Token { kind: "LtEq", value: "<=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens = tokens.push(Token { kind: "Lt", value: "<", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '>' {
                if pos + 1 < total && chars[pos + 1] == '=' {
                    tokens = tokens.push(Token { kind: "GtEq", value: ">=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens = tokens.push(Token { kind: "Gt", value: ">", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '&' {
                if pos + 1 < total && chars[pos + 1] == '&' {
                    tokens = tokens.push(Token { kind: "And", value: "&&", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens = tokens.push(Token { kind: "BitAnd", value: "&", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '|' {
                if pos + 1 < total && chars[pos + 1] == '|' {
                    tokens = tokens.push(Token { kind: "Or", value: "||", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens = tokens.push(Token { kind: "BitOr", value: "|", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '^' {
                if pos + 1 < total && chars[pos + 1] == '^' {
                    tokens = tokens.push(Token { kind: "Xor", value: "^^", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens = tokens.push(Token { kind: "BitXor", value: "^", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '~' {
                tokens = tokens.push(Token { kind: "BitNot", value: "~", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == ':' {
                if pos + 1 < total && chars[pos + 1] == '=' {
                    tokens = tokens.push(Token { kind: "ColonEq", value: ":=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else if pos + 1 < total && chars[pos + 1] == ':' {
                    tokens = tokens.push(Token { kind: "ColonColon", value: "::", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens = tokens.push(Token { kind: "Colon", value: ":", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '.' {
                if pos + 1 < total && chars[pos + 1] == '.' {
                    if pos + 2 < total && chars[pos + 2] == '=' {
                        tokens = tokens.push(Token { kind: "DotDotEq", value: "..=", line: line, col: start_col })
                        pos = pos + 3
                        col = col + 3
                    } else {
                        tokens = tokens.push(Token { kind: "DotDot", value: "..", line: line, col: start_col })
                        pos = pos + 2
                        col = col + 2
                    }
                } else {
                    tokens = tokens.push(Token { kind: "Dot", value: ".", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '(' {
                tokens = tokens.push(Token { kind: "LParen", value: "(", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == ')' {
                tokens = tokens.push(Token { kind: "RParen", value: ")", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == '{' {
                tokens = tokens.push(Token { kind: "LBrace", value: "{", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == '}' {
                tokens = tokens.push(Token { kind: "RBrace", value: "}", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == '[' {
                tokens = tokens.push(Token { kind: "LBracket", value: "[", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == ']' {
                tokens = tokens.push(Token { kind: "RBracket", value: "]", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == ',' {
                tokens = tokens.push(Token { kind: "Comma", value: ",", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == ';' {
                tokens = tokens.push(Token { kind: "Semicolon", value: ";", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == '?' {
                // Optional chaining: ?.
                if pos + 1 < total && chars[pos + 1] == '.' {
                    tokens = tokens.push(Token { kind: "QuestionDot", value: "?.", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens = tokens.push(Token { kind: "Question", value: "?", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '@' {
                tokens = tokens.push(Token { kind: "At", value: "@", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == '#' {
                // Map literal: #{...}
                if pos + 1 < total && chars[pos + 1] == '{' {
                    tokens = tokens.push(Token { kind: "HashLBrace", value: "#{", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    pos = pos + 1
                    col = col + 1
                }
            } else {
                pos = pos + 1
                col = col + 1
            }
        }
    }
    tokens = tokens.push(Token { kind: "Eof", value: "", line: line, col: col })
    return tokens
}

// ══════════════════════════════════════════════════════════════
// Direct-run tests (runs when file is executed normally)
// ══════════════════════════════════════════════════════════════

println("=== HEXA Self-Hosting Parser ===")
println("")

// Test 1: Parse let binding
let t1 = tokenize("let x = 42")
let ast1 = parse(t1)
println("Test 1: let x = 42")
print_ast(ast1)
assert len(ast1) == 1
assert ast1[0].kind == "LetStmt"
assert ast1[0].name == "x"
assert ast1[0].left.kind == "IntLit"
assert ast1[0].left.value == "42"
println("  PASS")
println("")

// Test 2: Parse fn declaration
let t2 = tokenize("fn add(a, b) {\n  a + b\n}")
let ast2 = parse(t2)
println("Test 2: fn add(a, b) { a + b }")
print_ast(ast2)
assert len(ast2) == 1
assert ast2[0].kind == "FnDecl"
assert ast2[0].name == "add"
assert len(ast2[0].params) == 2
assert ast2[0].params[0].name == "a"
assert ast2[0].params[1].name == "b"
assert len(ast2[0].body) == 1
println("  PASS")
println("")

// Test 3: Parse if/else expression
let t3 = tokenize("if x > 0 { x } else { -x }")
let ast3 = parse(t3)
println("Test 3: if x > 0 { x } else { -x }")
print_ast(ast3)
assert len(ast3) == 1
assert ast3[0].kind == "ExprStmt"
assert ast3[0].left.kind == "IfExpr"
assert ast3[0].left.cond.kind == "BinOp"
assert ast3[0].left.cond.op == ">"
assert len(ast3[0].left.then_body) == 1
assert len(ast3[0].left.else_body) == 1
println("  PASS")
println("")

// Test 4: Operator precedence — 1 + 2 * 3 should be Add(1, Mul(2, 3))
let t4 = tokenize("1 + 2 * 3")
let ast4 = parse(t4)
println("Test 4: 1 + 2 * 3 (precedence)")
print_ast(ast4)
assert len(ast4) == 1
assert ast4[0].kind == "ExprStmt"
let expr4 = ast4[0].left
assert expr4.kind == "BinOp"
assert expr4.op == "+"
assert expr4.left.kind == "IntLit"
assert expr4.left.value == "1"
assert expr4.right.kind == "BinOp"
assert expr4.right.op == "*"
assert expr4.right.left.value == "2"
assert expr4.right.right.value == "3"
println("  PASS")
println("")

// Test 5: Struct declaration
let t5 = tokenize("struct Point {\n  x: float,\n  y: float\n}")
let ast5 = parse(t5)
println("Test 5: struct Point { x: float, y: float }")
print_ast(ast5)
assert len(ast5) == 1
assert ast5[0].kind == "StructDecl"
assert ast5[0].name == "Point"
assert len(ast5[0].fields) == 2
assert ast5[0].fields[0].name == "x"
assert ast5[0].fields[0].value == "float"
assert ast5[0].fields[1].name == "y"
assert ast5[0].fields[1].value == "float"
println("  PASS")
println("")

// Test 6: For loop
let t6 = tokenize("for i in 0..10 {\n  print(i)\n}")
let ast6 = parse(t6)
println("Test 6: for i in 0..10 { print(i) }")
print_ast(ast6)
assert len(ast6) == 1
assert ast6[0].kind == "ForStmt"
assert ast6[0].name == "i"
assert ast6[0].iter_expr.kind == "Range"
assert len(ast6[0].body) == 1
println("  PASS")
println("")

// Test 7: Const and return
let t7 = tokenize("const PI = 3.14\nfn get_pi() {\n  return PI\n}")
let ast7 = parse(t7)
println("Test 7: const + fn with return")
print_ast(ast7)
assert len(ast7) == 2
assert ast7[0].kind == "ConstStmt"
assert ast7[0].name == "PI"
assert ast7[0].left.kind == "FloatLit"
assert ast7[1].kind == "FnDecl"
assert ast7[1].name == "get_pi"
println("  PASS")
println("")

// Test 8: Enum declaration
let t8 = tokenize("enum Color {\n  Red,\n  Green,\n  Blue\n}")
let ast8 = parse(t8)
println("Test 8: enum Color { Red, Green, Blue }")
print_ast(ast8)
assert len(ast8) == 1
assert ast8[0].kind == "EnumDecl"
assert ast8[0].name == "Color"
assert len(ast8[0].variants) == 3
println("  PASS")
println("")

// Test 9: Round-trip — lex some real HEXA code, parse it, verify structure
let code9 = "fn factorial(n) {\n  if n <= 1 {\n    return 1\n  }\n  return n * factorial(n - 1)\n}"
let t9 = tokenize(code9)
let ast9 = parse(t9)
println("Test 9: round-trip factorial function")
print_ast(ast9)
assert len(ast9) == 1
assert ast9[0].kind == "FnDecl"
assert ast9[0].name == "factorial"
assert len(ast9[0].params) == 1
assert len(ast9[0].body) == 2  // if + return
println("  PASS")
println("")

// Test 10: Complex expression with method calls and chaining
let t10 = tokenize("arr.push(x).len()")
let ast10 = parse(t10)
println("Test 10: arr.push(x).len()")
print_ast(ast10)
assert len(ast10) == 1
assert ast10[0].kind == "ExprStmt"
// arr.push(x).len() = Call(Field(Call(Field(Ident(arr), push), [x]), len), [])
let e10 = ast10[0].left
assert e10.kind == "Call"
assert e10.left.kind == "Field"
assert e10.left.name == "len"
println("  PASS")
println("")

// Test 11: Match expression
let t11 = tokenize("match x {\n  0 -> \"zero\",\n  _ -> \"other\"\n}")
let ast11 = parse(t11)
println("Test 11: match expression")
print_ast(ast11)
assert len(ast11) == 1
assert ast11[0].kind == "ExprStmt"
assert ast11[0].left.kind == "MatchExpr"
assert len(ast11[0].left.arms) == 2
println("  PASS")
println("")

// Test 12: While loop + assignment
let t12 = tokenize("let mut i = 0\nwhile i < 10 {\n  i = i + 1\n}")
let ast12 = parse(t12)
println("Test 12: let mut + while + assignment")
print_ast(ast12)
assert len(ast12) == 2
assert ast12[0].kind == "LetMutStmt"
assert ast12[0].name == "i"
assert ast12[1].kind == "WhileStmt"
assert len(ast12[1].body) == 1
assert ast12[1].body[0].kind == "AssignStmt"
println("  PASS")
println("")

// Test 13: Unary operators
let t13 = tokenize("!true")
let ast13 = parse(t13)
println("Test 13: !true (unary)")
print_ast(ast13)
assert ast13[0].left.kind == "UnaryOp"
assert ast13[0].left.op == "!"
assert ast13[0].left.left.kind == "BoolLit"
println("  PASS")
println("")

// Test 14: Array literal + index
let t14 = tokenize("[1, 2, 3][0]")
let ast14 = parse(t14)
println("Test 14: [1,2,3][0] (array + index)")
print_ast(ast14)
assert ast14[0].left.kind == "Index"
assert ast14[0].left.left.kind == "Array"
assert len(ast14[0].left.left.items) == 3
println("  PASS")
println("")

// Test 15: break/continue in loop
