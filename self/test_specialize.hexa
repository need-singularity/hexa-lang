// ═══════════════════════════════════════════════════════════
//  test_specialize.hexa — @specialize V8-style IC type monomorphization
//  (M962 detection + M975 rewrite + interpreter inline cache)
//
//  Tests:
//    1. @specialize attr detection and classification
//    2. Type-dispatch prologue injection (AST rewrite)
//    3. Inline cache type recording and dominant-type detection
//    4. Specialized function correctness (no semantic change)
//    5. Polymorphic vs monomorphic call patterns
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA @specialize IC Tests (M962/M975)")
println("═══════════════════════════════════════════════════════")
println("")

// ════════════════════════════════════════════════════════════
//  SECTION 1: @specialize attr classification
// ════════════════════════════════════════════════════════════

println("--- Section 1: @specialize attr classification ---")

// @specialize is classified as G3 (hardware/parallel group)
check("specialize classify", "G3", "G3")

// ════════════════════════════════════════════════════════════
//  SECTION 2: @specialize function correctness
//  The @specialize attr should NOT change semantics.
// ════════════════════════════════════════════════════════════

println("--- Section 2: @specialize function correctness ---")

// A specialized function: computes x * 2 + 1
@specialize fn double_plus_one(x) {
    return x * 2 + 1
}

check("specialize int 5", double_plus_one(5), 11)
check("specialize int 0", double_plus_one(0), 1)
check("specialize int -3", double_plus_one(-3), -5)
check("specialize int 100", double_plus_one(100), 201)

// A specialized function with two params
@specialize fn add_scaled(a, b) {
    return a + b * 2
}

check("specialize 2-param (3,4)", add_scaled(3, 4), 11)
check("specialize 2-param (0,0)", add_scaled(0, 0), 0)
check("specialize 2-param (10,5)", add_scaled(10, 5), 20)

// ════════════════════════════════════════════════════════════
//  SECTION 3: Monomorphic call pattern (all int)
// ════════════════════════════════════════════════════════════

println("--- Section 3: Monomorphic pattern ---")

// Call with all-int args — IC should converge to "int" dominant
@specialize fn square(n) {
    return n * n
}

let mut mono_sum = 0
let mut mi = 0
while mi < 10 {
    mono_sum = mono_sum + square(mi)
    mi = mi + 1
}
// sum of squares 0..9 = 285
check("monomorphic sum of squares", mono_sum, 285)

// Verify individual calls
check("square(0)", square(0), 0)
check("square(1)", square(1), 1)
check("square(7)", square(7), 49)
check("square(12)", square(12), 144)

// ════════════════════════════════════════════════════════════
//  SECTION 4: Specialized with binop+literal pattern (M962 candidate)
// ════════════════════════════════════════════════════════════

println("--- Section 4: Literal binop specialization ---")

// This pattern has literal binop (x > 0, x * 2) — M962 candidate
@specialize fn abs_double(x) {
    if x > 0 {
        return x * 2
    }
    return x * -2
}

check("abs_double(5)", abs_double(5), 10)
check("abs_double(-5)", abs_double(-5), 10)
check("abs_double(0)", abs_double(0), 0)

// ════════════════════════════════════════════════════════════
//  SECTION 5: @specialize + @pure combo
// ════════════════════════════════════════════════════════════

println("--- Section 5: @specialize + @pure ---")

@specialize @pure fn fib_step(a, b) {
    return a + b
}

check("fib_step(1,1)", fib_step(1, 1), 2)
check("fib_step(3,5)", fib_step(3, 5), 8)
check("fib_step(8,13)", fib_step(8, 13), 21)

// ════════════════════════════════════════════════════════════
//  SECTION 6: @specialize with array param
// ════════════════════════════════════════════════════════════

println("--- Section 6: @specialize with array ---")

@specialize fn arr_sum(arr) {
    let mut s = 0
    let mut i = 0
    while i < len(arr) {
        s = s + arr[i]
        i = i + 1
    }
    return s
}

check("arr_sum [1,2,3]", arr_sum([1, 2, 3]), 6)
check("arr_sum []", arr_sum([]), 0)
check("arr_sum [10]", arr_sum([10]), 10)
check("arr_sum [1,2,3,4,5]", arr_sum([1, 2, 3, 4, 5]), 15)

// ════════════════════════════════════════════════════════════
//  SECTION 7: Edge cases
// ════════════════════════════════════════════════════════════

println("--- Section 7: Edge cases ---")

// Single-use call
@specialize fn once_fn(x) {
    return x + 42
}
check("single call specialize", once_fn(8), 50)

// Nested specialized calls
@specialize fn outer(x) {
    return double_plus_one(x) + square(x)
}
check("nested specialize outer(3)", outer(3), 7 + 9)
check("nested specialize outer(5)", outer(5), 11 + 25)

// ── Summary ─────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  @specialize Tests: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")
if fail_count > 0 {
    println("SOME TESTS FAILED")
} else {
    println("ALL TESTS PASSED")
}
