// ===================================================================
//  test_tokenizer_trainer.hexa — Tokenizer Trainer Tests
//
//  Verifies:
//    1. text_to_chars splits correctly
//    2. count_pairs finds bigram frequencies
//    3. merge_pair merges correctly
//    4. train_bpe produces vocab + merges
//    5. Special tokens present at correct positions
//    6. Encode-decode roundtrip
//    7. Single text training
//    8. Multiple text training
//    9. Edge cases (empty, single char)
//   10. is_special_token detection
//
//  Run: ./hexa self/test_tokenizer_trainer.hexa
//  Minimum 10 check() statements.
// ===================================================================

import "ml/tokenizer_trainer.hexa"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

println("===================================================================")
println("  Tokenizer Trainer Test Suite")
println("===================================================================")

// ===================================================================
//  T1: text_to_chars splits text into individual characters
// ===================================================================
let chars = text_to_chars("abc")
check("T1 text_to_chars length=3", len(chars) == 3)
check("T1b text_to_chars[0]='a'", chars[0] == "a")

// ===================================================================
//  T2: count_pairs finds bigram frequencies
// ===================================================================
let tokens2 = ["a", "b", "a", "b", "c"]
let pairs2 = count_pairs(tokens2)
// "a","b" appears twice, "b","a" once, "b","c" once
check("T2 count_pairs finds pairs", len(pairs2) > 0)
// First pair should be most frequent ("a","b" with count 2)
let top_pair = pairs2[0]
check("T2b most frequent pair count=2", top_pair[1] == 2)

// ===================================================================
//  T3: merge_pair merges occurrences
// ===================================================================
let tokens3 = ["a", "b", "c", "a", "b"]
let merged3 = merge_pair(tokens3, ["a", "b"])
// Should become ["ab", "c", "ab"]
check("T3 merge_pair length reduced", len(merged3) == 3)
check("T3b merged token = 'ab'", merged3[0] == "ab")

// ===================================================================
//  T4: merge_pair no match leaves unchanged
// ===================================================================
let merged4 = merge_pair(tokens3, ["x", "y"])
check("T4 no-match merge unchanged", len(merged4) == 5)

// ===================================================================
//  T5: train_bpe produces vocab with special tokens
// ===================================================================
let texts = ["aaab", "aaab", "aab"]
let result = train_bpe(texts, 15)
let vocab = result[0]
let merges = result[1]
check("T5 vocab starts with [PAD]", vocab[0] == "[PAD]")
check("T5b vocab[1] = [UNK]", vocab[1] == "[UNK]")
check("T5c vocab[2] = [BOS]", vocab[2] == "[BOS]")
check("T5d vocab[3] = [EOS]", vocab[3] == "[EOS]")

// ===================================================================
//  T6: train_bpe creates merges
// ===================================================================
check("T6 merges non-empty", len(merges) > 0)

// ===================================================================
//  T7: First merge should be most common pair
// ===================================================================
let first_merge = merges[0]
// "aa" or "ab" should be among first merges since "a" is very frequent
check("T7 first merge is a valid pair", len(first_merge) == 2)

// ===================================================================
//  T8: Encode-decode roundtrip
// ===================================================================
let test_text = "aab"
let ids = bpe_encode_trained(test_text, vocab, merges)
let decoded = bpe_decode_trained(ids, vocab)
check("T8 encode-decode roundtrip", decoded == test_text)

// ===================================================================
//  T9: is_special_token detection
// ===================================================================
check("T9 [PAD] is special", is_special_token("[PAD]") == true)
check("T9b 'hello' not special", is_special_token("hello") == false)

// ===================================================================
//  T10: trained_vocab_size correct
// ===================================================================
let vs = trained_vocab_size(vocab)
check("T10 vocab_size matches len(vocab)", vs == len(vocab))

// ===================================================================
//  T11: initial_special_tokens has 4 entries
// ===================================================================
let specials = initial_special_tokens()
check("T11 4 special tokens", len(specials) == 4)

// ===================================================================
//  T12: Single char text training
// ===================================================================
let result_single = train_bpe(["x"], 10)
let vocab_single = result_single[0]
let merges_single = result_single[1]
check("T12 single char: no merges needed", len(merges_single) == 0)

// ===================================================================
//  T13: collect_byte_vocab finds unique chars
// ===================================================================
let bv = collect_byte_vocab(["aabbc"])
check("T13 byte_vocab unique chars", len(bv) == 3)

// ===================================================================
//  T14: merge_pair handles consecutive pairs
// ===================================================================
let tokens14 = ["a", "a", "a"]
let merged14 = merge_pair(tokens14, ["a", "a"])
// "a","a","a" -> "aa","a" (greedy left-to-right merge)
check("T14 consecutive merge: 3->2", len(merged14) == 2)

// ===================================================================
//  Summary
// ===================================================================
println("")
println("pass=" + to_string(pass_count) + " fail=" + to_string(fail_count))
if fail_count == 0 {
    println("ALL PASS")
} else {
    println("FAILED")
}
println(to_string(pass_count) + " passed")
