// ═══════════════════════════════════════════════════════
//  AI-native @algebraic — 대수적 등가 변환
//  교환/결합법칙 활용 연산 순서 재배치
//  순수 .hexa 구현
//  NOTE: << / >> 연산자 미지원 → pow2 헬퍼 / / 2 로 대체
// ═══════════════════════════════════════════════════════

// sum_range: 1+2+...+n = n*(n+1)/2  O(1)
// 루프 대신 닫힌 해 직접 계산 (@reduce 통합)
fn sum_range(n) {
    return n * (n + 1) / 2
}

// sum_range_ab: a+(a+1)+...+b = (b-a+1)*(a+b)/2  O(1)
fn sum_range_ab(a, b) {
    return (b - a + 1) * (a + b) / 2
}

// sum_squares: 1^2+2^2+...+n^2 = n(n+1)(2n+1)/6  O(1)
fn sum_squares(n) {
    return n * (n + 1) * (2 * n + 1) / 6
}

// sum_cubes: 1^3+2^3+...+n^3 = [n(n+1)/2]^2  O(1)
fn sum_cubes(n) {
    let s = n * (n + 1) / 2
    return s * s
}

// arithmetic_series: a, a+d, a+2d, ..., a+(n-1)d의 합
fn arithmetic_sum(a, d, n) {
    return n * (2 * a + (n - 1) * d) / 2
}

// geometric_series: a + ar + ar^2 + ... + ar^(n-1)
// r != 1일 때 = a(r^n - 1)/(r - 1)
fn geometric_sum(a, r, n) {
    if r == 1 { return a * n }
    let rn = 1
    for i in 0..n { rn = rn * r }
    return a * (rn - 1) / (r - 1)
}

// matrix_mul_2x2: 2×2 행렬 곱셈 (inline)
// [a,b,c,d] × [e,f,g,h] = [ae+bg, af+bh, ce+dg, cf+dh]
fn mat2_mul(m1, m2) {
    return [
        m1[0]*m2[0] + m1[1]*m2[2],
        m1[0]*m2[1] + m1[1]*m2[3],
        m1[2]*m2[0] + m1[3]*m2[2],
        m1[2]*m2[1] + m1[3]*m2[3]
    ]
}

// matrix_pow: 2×2 행렬 거듭제곱 O(log n)
fn mat2_pow(m, n) {
    let result = [1, 0, 0, 1]  // identity
    let base = m
    let p = n
    while p > 0 {
        if (p & 1) == 1 {
            result = mat2_mul(result, base)
        }
        base = mat2_mul(base, base)
        p = p / 2
    }
    return result
}

// fibonacci via matrix power O(log n)
// 순수 .hexa 버전 — @optimize의 .hexa 구현체
fn fib_fast(n) {
    if n <= 1 { return n }
    let m = mat2_pow([1, 1, 1, 0], n - 1)
    return m[0]
}

// dot_product: 벡터 내적 (루프 언롤링 효과)
fn dot_product(a, b) {
    let sum = 0
    let len = a.len()
    if len != b.len() { return 0 }
    for i in 0..len {
        sum = sum + a[i] * b[i]
    }
    return sum
}

// prefix_sum: 누적합 배열 생성 O(n)
// 이후 구간합 O(1) 쿼리 가능: sum(i,j) = prefix[j+1] - prefix[i]
fn prefix_sum(arr) {
    let result = [0]
    let acc = 0
    for item in arr {
        acc = acc + item
        result = result.push(acc)
    }
    return result
}

// range_sum: prefix_sum 기반 O(1) 구간합
fn range_sum(prefix, i, j) {
    return prefix[j + 1] - prefix[i]
}
