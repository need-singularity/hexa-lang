// ═══════════════════════════════════════════════════════
//  AI-native @symbolic — 수학적 등가 변환 (강도 감소)
//  x*2 → x+x, x/4 → x>>2, x%8 → x&7 등
//  순수 .hexa 구현
//  NOTE: << / >> 연산자 미지원 → pow2 헬퍼로 대체
// ═══════════════════════════════════════════════════════

// pow2: 2^n 계산 (shift 연산 대체)
fn pow2(n) {
    let result = 1
    for i in 0..n { result = result * 2 }
    return result
}

// is_power_of_2: 2의 거듭제곱인지 확인
fn is_power_of_2(n) {
    if n <= 0 { return false }
    return (n & (n - 1)) == 0
}

// log2_int: 정수 log2 (2의 거듭제곱 전용)
fn log2_int(n) {
    let count = 0
    let v = n
    while v > 1 {
        v = v / 2
        count = count + 1
    }
    return count
}

// fast_mul: 곱셈을 shift+add로 변환
// x * 10 → (x << 3) + (x << 1) = x*8 + x*2
fn fast_mul(x, c) {
    if c == 0 { return 0 }
    if c == 1 { return x }
    if c == 2 { return x + x }
    if is_power_of_2(c) { return x * pow2(log2_int(c)) }
    // Decompose: find powers of 2 that sum to c
    let result = 0
    let remaining = c
    let shift = 0
    while remaining > 0 {
        if (remaining & 1) == 1 {
            result = result + (x * pow2(shift))
        }
        remaining = remaining / 2
        shift = shift + 1
    }
    return result
}

// fast_div: 2의 거듭제곱으로 나누기 → shift
fn fast_div(x, c) {
    if c == 1 { return x }
    if is_power_of_2(c) { return x / pow2(log2_int(c)) }
    return x / c
}

// fast_mod: 2의 거듭제곱으로 나머지 → bitwise and
fn fast_mod(x, c) {
    if is_power_of_2(c) { return x & (c - 1) }
    return x % c
}

// fast_pow: 정수 거듭제곱 (binary exponentiation)
// O(log n) — 기본 ** 연산자보다 빠른 구현
fn fast_pow(base, exp) {
    if exp == 0 { return 1 }
    if exp == 1 { return base }
    let result = 1
    let b = base
    let e = exp
    while e > 0 {
        if (e & 1) == 1 {
            result = result * b
        }
        b = b * b
        e = e / 2
    }
    return result
}

// horner: 다항식 평가 (Horner's method)
// coeffs = [a0, a1, a2, ...] → a0 + a1*x + a2*x^2 + ...
// O(n) 곱셈으로 다항식 계산 (naive는 O(n^2))
fn horner(coeffs, x) {
    let result = 0
    let i = coeffs.len() - 1
    while i >= 0 {
        result = result * x + coeffs[i]
        i = i - 1
    }
    return result
}

// fast_abs: 분기 없는 절대값
fn fast_abs(x) {
    if x < 0 { return -x }
    return x
}

// clamp: 범위 제한 (분기 최소화)
fn clamp(x, lo, hi) {
    if x < lo { return lo }
    if x > hi { return hi }
    return x
}

// gcd: 유클리드 호제법 (반복)
fn gcd(a, b) {
    let x = fast_abs(a)
    let y = fast_abs(b)
    while y != 0 {
        let t = y
        y = x % y
        x = t
    }
    return x
}

// lcm: 최소공배수
fn lcm(a, b) {
    if a == 0 { return 0 }
    if b == 0 { return 0 }
    return fast_abs(a * b) / gcd(a, b)
}
