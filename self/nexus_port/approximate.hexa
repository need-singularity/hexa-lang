// ═══════════════════════════════════════════════════════
//  AI-native @approximate — 빠른 근사 알고리즘
//  정밀도를 약간 희생하고 속도를 크게 향상
//  순수 .hexa 구현
//  NOTE: >> 연산자 미지원 → / 2 로 대체
// ═══════════════════════════════════════════════════════

// fast_sqrt: Newton's method 정수 제곱근
// O(log n) — 정확한 정수 결과
fn fast_isqrt(n) {
    if n <= 1 { return n }
    let x = n
    let y = (x + 1) / 2
    while y < x {
        x = y
        y = (x + n / x) / 2
    }
    return x
}

// fast_log2: 정수 log2 근사 (floor)
fn fast_log2(n) {
    if n <= 0 { return -1 }
    let result = 0
    let v = n
    while v > 1 {
        v = v / 2
        result = result + 1
    }
    return result
}

// fast_exp_approx: e^x 근사 (Taylor series, 정수 입력)
// 정밀도: 소수점 4자리 이내
fn fast_exp_int(x) {
    // e^x ≈ (1 + x/256)^256 — squaring method
    let n = 256
    let result = 1.0 + (x * 1.0) / (n * 1.0)
    // Square 8 times (256 = 2^8)
    result = result * result   // ^2
    result = result * result   // ^4
    result = result * result   // ^8
    result = result * result   // ^16
    result = result * result   // ^32
    result = result * result   // ^64
    result = result * result   // ^128
    result = result * result   // ^256
    return result
}

// is_prime_fast: Miller-Rabin 소수 판별 (확률적, 매우 빠름)
// 작은 수에 대해 결정론적 — 2^31까지 정확
fn is_prime_fast(n) {
    if n < 2 { return false }
    if n < 4 { return true }
    if n % 2 == 0 { return false }
    if n % 3 == 0 { return false }

    // Trial division for small factors
    let i = 5
    while i * i <= n {
        if n % i == 0 { return false }
        if n % (i + 2) == 0 { return false }
        i = i + 6
    }
    return true
}

// binary_search: O(log n) 탐색
fn binary_search(sorted_arr, target) {
    let lo = 0
    let hi = sorted_arr.len() - 1
    while lo <= hi {
        let mid = (lo + hi) / 2
        if sorted_arr[mid] == target { return mid }
        if sorted_arr[mid] < target {
            lo = mid + 1
        } else {
            hi = mid - 1
        }
    }
    return -1
}

// interpolation_search: 균등 분포 데이터에서 O(log log n)
fn interpolation_search(sorted_arr, target) {
    let lo = 0
    let hi = sorted_arr.len() - 1
    while lo <= hi {
        if sorted_arr[lo] == sorted_arr[hi] {
            if sorted_arr[lo] == target { return lo }
            return -1
        }
        let pos = lo + ((target - sorted_arr[lo]) * (hi - lo)) / (sorted_arr[hi] - sorted_arr[lo])
        if pos < lo { pos = lo }
        if pos > hi { pos = hi }
        if sorted_arr[pos] == target { return pos }
        if sorted_arr[pos] < target {
            lo = pos + 1
        } else {
            hi = pos - 1
        }
    }
    return -1
}

// counting_sort: O(n+k) 정렬 (정수, 범위 제한)
fn counting_sort(arr, max_val) {
    let count = []
    for i in 0..max_val+1 { count = count.push(0) }
    for item in arr { count[item] = count[item] + 1 }
    let result = []
    for i in 0..max_val+1 {
        for j in 0..count[i] {
            result = result.push(i)
        }
    }
    return result
}
