// ═══════════════════════════════════════════════════════
//  AI-native @parallel — 순수 .hexa 병렬 처리 라이브러리
//  Rust/Python 없이 hexa만으로 멀티코어 활용
//  spawn + channel 기반 데이터 병렬화
// ═══════════════════════════════════════════════════════

// par_map: 배열을 N 청크로 분할 → spawn → 결과 병합
// 사용: par_map(data, |x| x * x, 4)
fn par_map(data, f, n_workers) {
    let total = data.len()
    if total < 4 { return data.map(f) }
    if n_workers <= 0 { n_workers = 4 }
    let chunk_size = (total + n_workers - 1) / n_workers

    // Per-worker channel guarantees order
    let channels = []
    for w in 0..n_workers { channels.push(channel()) }

    let spawned = 0
    let start = 0
    while start < total {
        let end = start + chunk_size
        if end > total { end = total }
        let chunk_start = start
        let chunk_end = end
        let wtx = channels[spawned][0]
        spawn {
            let results = []
            let i = chunk_start
            while i < chunk_end {
                results.push(f(data[i]))
                i = i + 1
            }
            wtx.send(results)
        }
        spawned = spawned + 1
        start = end
    }

    let output = []
    for w in 0..spawned {
        let chunk = channels[w][1].recv()
        for item in chunk { output.push(item) }
    }
    return output
}

// par_filter: 병렬 필터
fn par_filter(data, pred, n_workers) {
    let total = data.len()
    if total < 4 { return data.filter(pred) }
    if n_workers <= 0 { n_workers = 4 }
    let chunk_size = (total + n_workers - 1) / n_workers

    let channels = []
    for w in 0..n_workers { channels.push(channel()) }

    let spawned = 0
    let start = 0
    while start < total {
        let end = start + chunk_size
        if end > total { end = total }
        let chunk_start = start
        let chunk_end = end
        let wtx = channels[spawned][0]
        spawn {
            let results = []
            let i = chunk_start
            while i < chunk_end {
                if pred(data[i]) {
                    results.push(data[i])
                }
                i = i + 1
            }
            wtx.send(results)
        }
        spawned = spawned + 1
        start = end
    }

    let output = []
    for w in 0..spawned {
        let chunk = channels[w][1].recv()
        for item in chunk { output.push(item) }
    }
    return output
}

// par_reduce: 병렬 리듀스 (각 청크 독립 축약 → 최종 합산)
fn par_reduce(data, f, init, n_workers) {
    let total = data.len()
    if total < 4 { return data.fold(init, f) }
    if n_workers <= 0 { n_workers = 4 }
    let chunk_size = (total + n_workers - 1) / n_workers

    let channels = []
    for w in 0..n_workers { channels.push(channel()) }

    let spawned = 0
    let start = 0
    while start < total {
        let end = start + chunk_size
        if end > total { end = total }
        let chunk_start = start
        let chunk_end = end
        let wtx = channels[spawned][0]
        spawn {
            let acc = init
            let i = chunk_start
            while i < chunk_end {
                acc = f(acc, data[i])
                i = i + 1
            }
            wtx.send(acc)
        }
        spawned = spawned + 1
        start = end
    }

    let result = init
    for w in 0..spawned {
        let partial = channels[w][1].recv()
        result = f(result, partial)
    }
    return result
}
