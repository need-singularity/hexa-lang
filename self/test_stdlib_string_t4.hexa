// T4 migration proof: HEXA str_trim matches runtime.c hexa_str_trim semantics.
// Inlined (no `use`) so stage0 interp path and `hexa build` AOT path both work.

pub fn str_trim(s) {
    let n = len(s)
    let mut i = 0
    let mut front_done = false
    while i < n && !front_done {
        let c = s.substring(i, i + 1)
        if c == " " || c == "\t" || c == "\n" || c == "\r" {
            i = i + 1
        } else {
            front_done = true
        }
    }
    let mut j = n
    let mut back_done = false
    while j > i && !back_done {
        let c = s.substring(j - 1, j)
        if c == " " || c == "\t" || c == "\n" || c == "\r" {
            j = j - 1
        } else {
            back_done = true
        }
    }
    return s.substring(i, j)
}

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if actual == expected {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected '" + expected + "' got '" + actual + "'")
        fail_count = fail_count + 1
    }
}

check("no whitespace",        str_trim("hello"),         "hello")
check("leading spaces",       str_trim("  hello"),       "hello")
check("trailing spaces",      str_trim("hello  "),       "hello")
check("both ends",            str_trim("  hello  "),     "hello")
check("tabs + newlines",      str_trim("\thello\n"),     "hello")
check("mixed whitespace",     str_trim(" \t\nhello\r "), "hello")
check("empty input",          str_trim(""),              "")
check("only whitespace",      str_trim("   \t\n"),       "")
check("interior spaces",      str_trim(" abc def "),     "abc def")
check("single char",          str_trim("x"),             "x")
check("single space",         str_trim(" "),             "")

println("")
println("═══════════════════════════════════════════════════════")
println("  HEXA str_trim — PASS " + to_string(pass_count) + " / FAIL " + to_string(fail_count))
println("═══════════════════════════════════════════════════════")
if fail_count > 0 { exit(1) }
