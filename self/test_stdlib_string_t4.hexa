// T4 migration proof: HEXA string helpers match runtime.c semantics.
// Inlined (no `use`) so interp interp path and `hexa build` AOT path both work.

pub fn str_trim(s) {
    let n = len(s)
    let mut i = 0
    let mut front_done = false
    while i < n && !front_done {
        let c = s.substring(i, i + 1)
        if c == " " || c == "\t" || c == "\n" || c == "\r" {
            i = i + 1
        } else {
            front_done = true
        }
    }
    let mut j = n
    let mut back_done = false
    while j > i && !back_done {
        let c = s.substring(j - 1, j)
        if c == " " || c == "\t" || c == "\n" || c == "\r" {
            j = j - 1
        } else {
            back_done = true
        }
    }
    return s.substring(i, j)
}

pub fn str_starts_with(s, prefix) {
    let n = len(s)
    let m = len(prefix)
    if m > n { return false }
    return s.substring(0, m) == prefix
}

pub fn str_ends_with(s, suffix) {
    let n = len(s)
    let m = len(suffix)
    if m > n { return false }
    return s.substring(n - m, n) == suffix
}

pub fn str_to_upper(s) {
    let n = len(s)
    let mut parts = []
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        let o = ord(c)
        if o >= 97 && o <= 122 {
            parts.push(chr(o - 32))
        } else {
            parts.push(c)
        }
        i = i + 1
    }
    return parts.join("")
}

pub fn str_to_lower(s) {
    let n = len(s)
    let mut parts = []
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        let o = ord(c)
        if o >= 65 && o <= 90 {
            parts.push(chr(o + 32))
        } else {
            parts.push(c)
        }
        i = i + 1
    }
    return parts.join("")
}

pub fn str_index_of(s, needle) {
    let n = len(s)
    let m = len(needle)
    if m == 0 { return 0 }
    if m > n { return -1 }
    let mut i = 0
    let limit = n - m + 1
    while i < limit {
        if s.substring(i, i + m) == needle {
            return i
        }
        i = i + 1
    }
    return -1
}

pub fn str_contains(s, needle) {
    return str_index_of(s, needle) >= 0
}

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if actual == expected {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected '" + expected + "' got '" + actual + "'")
        fail_count = fail_count + 1
    }
}

fn check_bool(name, actual, expected) {
    if actual == expected {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected " + to_string(expected) + " got " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_int(name, actual, expected) {
    if actual == expected {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected " + to_string(expected) + " got " + to_string(actual))
        fail_count = fail_count + 1
    }
}

// ── str_trim ────────────────────────────────────
check("trim/no ws",             str_trim("hello"),         "hello")
check("trim/leading",           str_trim("  hello"),       "hello")
check("trim/trailing",          str_trim("hello  "),       "hello")
check("trim/both",              str_trim("  hello  "),     "hello")
check("trim/tab+lf",            str_trim("\thello\n"),     "hello")
check("trim/mixed ws",          str_trim(" \t\nhello\r "), "hello")
check("trim/empty",             str_trim(""),              "")
check("trim/only ws",           str_trim("   \t\n"),       "")
check("trim/interior",          str_trim(" abc def "),     "abc def")
check("trim/single char",       str_trim("x"),             "x")
check("trim/single space",      str_trim(" "),             "")

// ── str_starts_with ─────────────────────────────
check_bool("starts_with/match",     str_starts_with("hello", "hel"),   true)
check_bool("starts_with/full",      str_starts_with("hello", "hello"), true)
check_bool("starts_with/empty",     str_starts_with("hello", ""),      true)
check_bool("starts_with/miss",      str_starts_with("hello", "ell"),   false)
check_bool("starts_with/longer",    str_starts_with("hi", "hello"),    false)
check_bool("starts_with/empty src", str_starts_with("", ""),           true)

// ── str_ends_with ───────────────────────────────
check_bool("ends_with/match",       str_ends_with("hello", "llo"),     true)
check_bool("ends_with/full",        str_ends_with("hello", "hello"),   true)
check_bool("ends_with/empty",       str_ends_with("hello", ""),        true)
check_bool("ends_with/miss",        str_ends_with("hello", "ell"),     false)
check_bool("ends_with/longer",      str_ends_with("hi", "hello"),      false)

// ── str_to_upper / str_to_lower ────────────────
check("to_upper/basic",         str_to_upper("hello world"),     "HELLO WORLD")
check("to_upper/mixed",         str_to_upper("Hello World"),     "HELLO WORLD")
check("to_upper/digits",        str_to_upper("abc123"),          "ABC123")
check("to_upper/already",       str_to_upper("HELLO"),           "HELLO")
check("to_upper/empty",         str_to_upper(""),                "")
check("to_lower/basic",         str_to_lower("HELLO WORLD"),     "hello world")
check("to_lower/mixed",         str_to_lower("Hello World"),     "hello world")
check("to_lower/already",       str_to_lower("hello"),           "hello")
check("to_lower/digits",        str_to_lower("ABC123"),          "abc123")

// ── str_index_of / str_contains ────────────────
check_int("index_of/start",         str_index_of("hello", "he"),      0)
check_int("index_of/middle",        str_index_of("hello", "ll"),      2)
check_int("index_of/end",           str_index_of("hello", "lo"),      3)
check_int("index_of/miss",          str_index_of("hello", "xyz"),     -1)
check_int("index_of/empty needle",  str_index_of("hello", ""),        0)
check_int("index_of/longer needle", str_index_of("hi", "hello"),      -1)
check_bool("contains/yes",          str_contains("hello", "ell"),     true)
check_bool("contains/no",           str_contains("hello", "xyz"),     false)
check_bool("contains/full",         str_contains("hello", "hello"),   true)

println("")
println("═══════════════════════════════════════════════════════")
println("  T4 HEXA stdlib/string — PASS " + to_string(pass_count) + " / FAIL " + to_string(fail_count))
println("═══════════════════════════════════════════════════════")
if fail_count > 0 { exit(1) }
