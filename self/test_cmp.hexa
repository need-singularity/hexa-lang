#!hexa lax
// self/test_cmp.hexa — ROI #162 P7-6a GAP-2 seed test (standalone).
//
// Verifies the expanded `lower_binop_mnemonic` recognizes comparison ops
// eq/ne/lt/le/gt/ge and routes them in lower_binop_from_vids. Runs under
// hexa_stage0 without flatten_imports by re-declaring the minimal fn.
//
// Before this patch every `a < b` in AST-lowering returned "" (unsupported).

// ── Inline replica of the patched mnemonic table ───────────────
// Kept in sync with self/ir/lowering.hexa. The self-hosted compiler
// will inline via flatten_imports once the stmt-driver lands (P7-6a.2).
fn _p7_6a_mnemonic(op_str) {
    if op_str == "add" { return "add" }
    if op_str == "sub" { return "sub" }
    if op_str == "mul" { return "mul" }
    if op_str == "div" { return "div" }
    if op_str == "rem" { return "mod" }
    if op_str == "mod" { return "mod" }
    if op_str == "eq" { return "eq" }
    if op_str == "ne" { return "ne" }
    if op_str == "lt" { return "lt" }
    if op_str == "le" { return "le" }
    if op_str == "gt" { return "gt" }
    if op_str == "ge" { return "ge" }
    if op_str == "bitand" { return "bitand" }
    if op_str == "bitor"  { return "bitor" }
    if op_str == "bitxor" { return "bitxor" }
    if op_str == "shl"    { return "shl" }
    if op_str == "shr"    { return "shr" }
    if op_str == "and" { return "and" }
    if op_str == "or"  { return "or" }
    if op_str == "xor" { return "xor" }
    return ""
}

fn _expect(label, got, want) {
    if got == want {
        println("  PASS " + label + " -> " + want)
        return 1
    }
    println("  FAIL " + label + " expected=" + want + " got=" + got)
    return 0
}

println("=== ROI #162 P7-6a GAP-2: BinOp comparison mnemonic coverage ===")
let mut pass = 0
pass = pass + _expect("eq", _p7_6a_mnemonic("eq"), "eq")
pass = pass + _expect("ne", _p7_6a_mnemonic("ne"), "ne")
pass = pass + _expect("lt", _p7_6a_mnemonic("lt"), "lt")
pass = pass + _expect("le", _p7_6a_mnemonic("le"), "le")
pass = pass + _expect("gt", _p7_6a_mnemonic("gt"), "gt")
pass = pass + _expect("ge", _p7_6a_mnemonic("ge"), "ge")
// Regression: arith table still works.
pass = pass + _expect("add", _p7_6a_mnemonic("add"), "add")
pass = pass + _expect("mod", _p7_6a_mnemonic("mod"), "mod")
pass = pass + _expect("rem-normalizes-to-mod", _p7_6a_mnemonic("rem"), "mod")
// Unsupported op still returns "".
pass = pass + _expect("unknown", _p7_6a_mnemonic("bogus"), "")

if pass == 10 {
    println("ALL PASS (10/10)")
} else {
    println("FAIL (" + pass + "/10)")
}
