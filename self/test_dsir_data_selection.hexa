// ═══════════════════════════════════════════════════════════════════
//  test_dsir_data_selection.hexa — DSIR Data Selection (#256)
//
//  Run: PATH=/Users/ghost/.cargo/bin:$PATH ./hexa self/test_dsir_data_selection.hexa
// ═══════════════════════════════════════════════════════════════════

import "ml/dsir_data_selection.hexa"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs_(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx_(a, b, eps) { return fabs_(a - b) < eps }

println("=== DSIR Data Selection (#256) Tests ===")

// ── T1 hash token is in range ───────────────────────────────────
let h1 = dsir_hash_token(42, 16)
check("T1 hash in range", h1 >= 0 && h1 < 16)

let h2 = dsir_hash_token(7, 16)
let h2b = dsir_hash_token(7, 16)
check("T1 determinism", h1 >= 0 && h2 == h2b)

// ── T2 ngrams length ────────────────────────────────────────────
let toks2 = [1, 2, 3, 4, 5]
let g2 = dsir_ngrams(toks2, 2)
check("T2 bigram count", len(g2) == 4)
check("T2 first bigram len", len(g2[0]) == 2)
check("T2 last bigram", g2[3][0] == 4 && g2[3][1] == 5)

// ── T3 bag sum equals n-gram count ──────────────────────────────
let b3 = dsir_bag(toks2, 2, 32)
let mut s3 = 0
for j in 0..32 { s3 = s3 + b3[j] }
check("T3 bag sum = ngram count", s3 == 4)

// ── T4 empty bag dist ───────────────────────────────────────────
let empty_bag = [0, 0, 0, 0]
let d_empty = dsir_bag_dist(empty_bag)
check("T4 empty dist sum = 0", approx_(d_empty[0] + d_empty[1] + d_empty[2] + d_empty[3], 0.0, 1.0e-9))

// ── T5 bag dist sums to 1 ───────────────────────────────────────
let b5 = [1, 2, 3, 4]
let d5 = dsir_bag_dist(b5)
let mut s5 = 0.0
for j in 0..4 { s5 = s5 + d5[j] }
check("T5 dist sum = 1", approx_(s5, 1.0, 1.0e-6))
check("T5 dist[3] largest", d5[3] > d5[0])

// ── T6 identical corpora -> 0 importance (log 1) ────────────────
let B6 = 32
let docs_a = [
    [1, 2, 3, 4],
    [1, 2, 3, 4]
]
let dist_a = dsir_merge_dist(docs_a, 2, B6)
let bag6 = dsir_bag(docs_a[0], 2, B6)
let w_same = dsir_importance(dist_a, dist_a, bag6)
check("T6 same dist weight = 0", approx_(w_same, 0.0, 1.0e-6))

// ── T7 in-domain doc has higher weight than out-of-domain doc ──
let B7 = 64
let src_docs = [
    [1, 2, 3, 4],   // in-domain tokens
    [5, 6, 7, 8],   // off-domain tokens
    [1, 2, 3, 4]    // in-domain again
]
let tgt_docs = [
    [1, 2, 3, 4],
    [1, 2, 3, 4]
]
let w7 = dsir_score_corpus(src_docs, tgt_docs, 2, B7)
check("T7 in-domain >= off-domain", w7[0] > w7[1])
check("T7 duplicate in-domain also high", w7[2] > w7[1])

// ── T8 select_topk picks in-domain docs first ───────────────────
let top2 = dsir_select_topk(src_docs, tgt_docs, 2, B7, 2)
check("T8 topk length = 2", len(top2) == 2)
let picked0 = top2[0]
let picked1 = top2[1]
check("T8 off-domain not in top2", picked0 != 1 && picked1 != 1)

// ── T9 select_topk with k > N returns all ───────────────────────
let top_all = dsir_select_topk(src_docs, tgt_docs, 2, B7, 100)
check("T9 clamp k to N", len(top_all) == 3)

// ── T10 weighted sampling respects determinism ──────────────────
let wts = [0.1, 0.2, 0.3, 0.4]
let samp1 = dsir_sample_weighted(wts, 10, 42)
let samp2 = dsir_sample_weighted(wts, 10, 42)
check("T10 sample length", len(samp1) == 10)
let mut match10 = true
for i in 0..10 {
    if samp1[i] != samp2[i] { match10 = false }
}
check("T10 seed determinism", match10)

// ── T11 weighted sampling favors large weights ──────────────────
let wts11 = [0.01, 0.99]
let samp11 = dsir_sample_weighted(wts11, 200, 7)
let mut ones = 0
for i in 0..200 {
    if samp11[i] == 1 { ones = ones + 1 }
}
check("T11 large weight dominates", ones > 150)

// ── T12 importance shift sign: higher target ratio -> higher w ──
// Build explicit dists where target highly favors index 5.
let src_dist12 = [0.25, 0.25, 0.25, 0.25, 0.0, 0.0, 0.0, 0.0]
let tgt_dist12 = [0.0, 0.0, 0.0, 0.0, 0.4, 0.3, 0.2, 0.1]
let bag_in   = [0, 0, 0, 0, 2, 0, 0, 0]
let bag_out  = [2, 0, 0, 0, 0, 0, 0, 0]
let w_in12  = dsir_importance(src_dist12, tgt_dist12, bag_in)
let w_out12 = dsir_importance(src_dist12, tgt_dist12, bag_out)
check("T12 in-domain weight > out-of-domain", w_in12 > w_out12)

println("")
println("=== DSIR Data Selection test summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
