// ═══════════════════════════════════════════════════════════════════
//  self/ml/dsir_data_selection.hexa — DSIR Data Selection (#256)
//
//  Data Selection with Importance Resampling (DSIR).
//    1. Build a hashed bag-of-n-grams feature (k-hot vector length B).
//    2. Estimate p_target(x) and p_source(x) as empirical bag dist.
//    3. Importance weight w_i = p_target(x_i) / p_source(x_i).
//    4. Top-k weighted sampling (highest weight = most in-domain).
//
//  Pure arithmetic — no RNG needed for the top-k path; the optional
//  probabilistic resampling uses a seeded LCG.
//
//  API:
//    dsir_hash_token(token, B)                   -> int in [0,B)
//    dsir_ngrams(tokens, n)                      -> [[int]]
//    dsir_bag(tokens, n, B)                      -> [int]  length B
//    dsir_bag_dist(bag)                          -> [float] length B
//    dsir_merge_dist(docs, n, B)                 -> [float]
//    dsir_importance(src_dist, tgt_dist, x_bag)  -> float
//    dsir_score_corpus(src_docs, tgt_docs, n, B) -> [float]
//    dsir_select_topk(src_docs, tgt_docs, n, B, k) -> [int]
//    dsir_sample_weighted(weights, k, seed)      -> [int]
//
//  AI-NATIVE attrs:
//    @pure  — no side effects
//    @hot   — corpus-scoring loop
// ═══════════════════════════════════════════════════════════════════

// ── helpers ──────────────────────────────────────────────────────

fn dsir_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn dsir_log(x) {
    if x <= 0.0 { return -30.0 }
    let mut v = x
    let mut count = 0
    while v > 2.0 {
        v = v / 2.718281828
        count = count + 1
    }
    while v < 0.5 {
        v = v * 2.718281828
        count = count - 1
    }
    let d = v - 1.0
    let ln_v = d - d * d / 2.0 + d * d * d / 3.0 - d * d * d * d / 4.0
    return to_float(count) + ln_v
}

fn dsir_zeros_i(n) {
    let mut v = []
    for _i in 0..n { v = v + [0] }
    return v
}

fn dsir_zeros_f(n) {
    let mut v = []
    for _i in 0..n { v = v + [0.0] }
    return v
}

fn dsir_sort_desc_idx(weights) {
    let n = len(weights)
    let mut idx = []
    for i in 0..n { idx = idx + [i] }
    // insertion sort descending by weights[idx[i]]
    for i in 0..n {
        for j in (i + 1)..n {
            if weights[idx[j]] > weights[idx[i]] {
                let tmp = idx[i]
                idx[i] = idx[j]
                idx[j] = tmp
            }
        }
    }
    return idx
}

// ═══════════════════════════════════════════════════════════════════
//  (1) Token hash  — deterministic integer hash into [0, B)
// ═══════════════════════════════════════════════════════════════════
@pure
fn dsir_hash_token(token, B) {
    // token is expected to be an int id.  Multiplicative Knuth hash.
    let h = (token * 2654435761 + 1) % B
    if h < 0 { return h + B }
    return h
}

// ═══════════════════════════════════════════════════════════════════
//  (2) N-grams — produce list of n-grams represented as int hashes
// ═══════════════════════════════════════════════════════════════════
@pure
fn dsir_ngrams(tokens, n) {
    let L = len(tokens)
    let mut out = []
    if L < n { return out }
    for i in 0..(L - n + 1) {
        let mut gram = []
        for k in 0..n { gram = gram + [tokens[i + k]] }
        out = out + [gram]
    }
    return out
}

// Combine an n-gram into a single int hash (Knuth-style chain).
fn dsir_gram_hash(gram, B) {
    let mut h = 2166136261
    for k in 0..len(gram) {
        h = (h * 16777619 + gram[k]) % B
        if h < 0 { h = h + B }
    }
    return h
}

// ═══════════════════════════════════════════════════════════════════
//  (3) Bag of hashed n-grams  -> count vector of length B
// ═══════════════════════════════════════════════════════════════════
@pure
fn dsir_bag(tokens, n, B) {
    let grams = dsir_ngrams(tokens, n)
    let mut bag = dsir_zeros_i(B)
    for i in 0..len(grams) {
        let h = dsir_gram_hash(grams[i], B)
        bag[h] = bag[h] + 1
    }
    return bag
}

// ═══════════════════════════════════════════════════════════════════
//  (4) Normalized probability distribution
// ═══════════════════════════════════════════════════════════════════
@pure
fn dsir_bag_dist(bag) {
    let B = len(bag)
    let mut total = 0
    for j in 0..B { total = total + bag[j] }
    let mut dist = dsir_zeros_f(B)
    if total == 0 { return dist }
    let tf = to_float(total)
    for j in 0..B {
        dist[j] = to_float(bag[j]) / tf
    }
    return dist
}

// ═══════════════════════════════════════════════════════════════════
//  (5) Merge many docs into one estimated distribution
// ═══════════════════════════════════════════════════════════════════
@pure
fn dsir_merge_dist(docs, n, B) {
    let mut total_bag = dsir_zeros_i(B)
    for d in 0..len(docs) {
        let b = dsir_bag(docs[d], n, B)
        for j in 0..B { total_bag[j] = total_bag[j] + b[j] }
    }
    return dsir_bag_dist(total_bag)
}

// ═══════════════════════════════════════════════════════════════════
//  (6) Importance weight of a single doc's bag
//
//      w = product_j (p_target[j] / p_source[j])^x_j
//
//  implemented in log-space and smoothed to avoid zero / infinity.
// ═══════════════════════════════════════════════════════════════════
@pure @hot
fn dsir_importance(src_dist, tgt_dist, x_bag) {
    let B = len(src_dist)
    let eps = 1.0e-8
    let mut log_w = 0.0
    for j in 0..B {
        if x_bag[j] > 0 {
            let ps = src_dist[j] + eps
            let pt = tgt_dist[j] + eps
            let ratio = pt / ps
            log_w = log_w + to_float(x_bag[j]) * dsir_log(ratio)
        }
    }
    return log_w
}

// ═══════════════════════════════════════════════════════════════════
//  (7) Score a whole source corpus vs a target corpus
// ═══════════════════════════════════════════════════════════════════
@hot
fn dsir_score_corpus(src_docs, tgt_docs, n, B) {
    let src_dist = dsir_merge_dist(src_docs, n, B)
    let tgt_dist = dsir_merge_dist(tgt_docs, n, B)
    let mut weights = []
    for d in 0..len(src_docs) {
        let bag = dsir_bag(src_docs[d], n, B)
        weights = weights + [dsir_importance(src_dist, tgt_dist, bag)]
    }
    return weights
}

// ═══════════════════════════════════════════════════════════════════
//  (8) Deterministic top-k selection
// ═══════════════════════════════════════════════════════════════════
fn dsir_select_topk(src_docs, tgt_docs, n, B, k) {
    let weights = dsir_score_corpus(src_docs, tgt_docs, n, B)
    let idx = dsir_sort_desc_idx(weights)
    let mut out = []
    let take = if k < len(idx) { k } else { len(idx) }
    for i in 0..take { out = out + [idx[i]] }
    return out
}

// ═══════════════════════════════════════════════════════════════════
//  (9) Weighted sampling (with replacement) using a seeded LCG
// ═══════════════════════════════════════════════════════════════════
fn dsir_lcg(state) {
    // 32-bit LCG (glibc parameters)
    let s = (state * 1103515245 + 12345) % 2147483648
    return s
}

fn dsir_sample_weighted(weights, k, seed) {
    // shift so all weights >= 0 and turn into a cumulative distribution
    let n = len(weights)
    if n == 0 { return [] }
    let mut min_w = weights[0]
    for i in 1..n {
        if weights[i] < min_w { min_w = weights[i] }
    }
    let shift = if min_w < 0.0 { 0.0 - min_w + 1.0e-6 } else { 0.0 }
    let mut cum = dsir_zeros_f(n)
    let mut total = 0.0
    for i in 0..n {
        let w = weights[i] + shift
        total = total + w
        cum[i] = total
    }
    let mut state = seed
    if state <= 0 { state = 1 }
    let mut out = []
    let mut c = 0
    while c < k {
        state = dsir_lcg(state)
        let u = (to_float(state) / 2147483648.0) * total
        let mut pick = n - 1
        let mut found = false
        let mut i = 0
        while i < n {
            if !found {
                if cum[i] >= u {
                    pick = i
                    found = true
                }
            }
            i = i + 1
        }
        out = out + [pick]
        c = c + 1
    }
    return out
}


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs_(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx_(a, b, eps) { return fabs_(a - b) < eps }

println("=== DSIR Data Selection (#256) Tests ===")

// ── T1 hash token is in range ───────────────────────────────────
let h1 = dsir_hash_token(42, 16)
check("T1 hash in range", h1 >= 0 && h1 < 16)

let h2 = dsir_hash_token(7, 16)
let h2b = dsir_hash_token(7, 16)
check("T1 determinism", h1 >= 0 && h2 == h2b)

// ── T2 ngrams length ────────────────────────────────────────────
let toks2 = [1, 2, 3, 4, 5]
let g2 = dsir_ngrams(toks2, 2)
check("T2 bigram count", len(g2) == 4)
check("T2 first bigram len", len(g2[0]) == 2)
check("T2 last bigram", g2[3][0] == 4 && g2[3][1] == 5)

// ── T3 bag sum equals n-gram count ──────────────────────────────
let b3 = dsir_bag(toks2, 2, 32)
let mut s3 = 0
for j in 0..32 { s3 = s3 + b3[j] }
check("T3 bag sum = ngram count", s3 == 4)

// ── T4 empty bag dist ───────────────────────────────────────────
let empty_bag = [0, 0, 0, 0]
let d_empty = dsir_bag_dist(empty_bag)
check("T4 empty dist sum = 0", approx_(d_empty[0] + d_empty[1] + d_empty[2] + d_empty[3], 0.0, 1.0e-9))

// ── T5 bag dist sums to 1 ───────────────────────────────────────
let b5 = [1, 2, 3, 4]
let d5 = dsir_bag_dist(b5)
let mut s5 = 0.0
for j in 0..4 { s5 = s5 + d5[j] }
check("T5 dist sum = 1", approx_(s5, 1.0, 1.0e-6))
check("T5 dist[3] largest", d5[3] > d5[0])

// ── T6 identical corpora -> 0 importance (log 1) ────────────────
let B6 = 32
let docs_a = [
    [1, 2, 3, 4],
    [1, 2, 3, 4]
]
let dist_a = dsir_merge_dist(docs_a, 2, B6)
let bag6 = dsir_bag(docs_a[0], 2, B6)
let w_same = dsir_importance(dist_a, dist_a, bag6)
check("T6 same dist weight = 0", approx_(w_same, 0.0, 1.0e-6))

// ── T7 in-domain doc has higher weight than out-of-domain doc ──
let B7 = 64
let src_docs = [
    [1, 2, 3, 4],   // in-domain tokens
    [5, 6, 7, 8],   // off-domain tokens
    [1, 2, 3, 4]    // in-domain again
]
let tgt_docs = [
    [1, 2, 3, 4],
    [1, 2, 3, 4]
]
let w7 = dsir_score_corpus(src_docs, tgt_docs, 2, B7)
check("T7 in-domain >= off-domain", w7[0] > w7[1])
check("T7 duplicate in-domain also high", w7[2] > w7[1])

// ── T8 select_topk picks in-domain docs first ───────────────────
let top2 = dsir_select_topk(src_docs, tgt_docs, 2, B7, 2)
check("T8 topk length = 2", len(top2) == 2)
let picked0 = top2[0]
let picked1 = top2[1]
check("T8 off-domain not in top2", picked0 != 1 && picked1 != 1)

// ── T9 select_topk with k > N returns all ───────────────────────
let top_all = dsir_select_topk(src_docs, tgt_docs, 2, B7, 100)
check("T9 clamp k to N", len(top_all) == 3)

// ── T10 weighted sampling respects determinism ──────────────────
let wts = [0.1, 0.2, 0.3, 0.4]
let samp1 = dsir_sample_weighted(wts, 10, 42)
let samp2 = dsir_sample_weighted(wts, 10, 42)
check("T10 sample length", len(samp1) == 10)
let mut match10 = true
for i in 0..10 {
    if samp1[i] != samp2[i] { match10 = false }
}
check("T10 seed determinism", match10)

// ── T11 weighted sampling favors large weights ──────────────────
let wts11 = [0.01, 0.99]
let samp11 = dsir_sample_weighted(wts11, 200, 7)
let mut ones = 0
for i in 0..200 {
    if samp11[i] == 1 { ones = ones + 1 }
}
check("T11 large weight dominates", ones > 150)

// ── T12 importance shift sign: higher target ratio -> higher w ──
// Build explicit dists where target highly favors index 5.
let src_dist12 = [0.25, 0.25, 0.25, 0.25, 0.0, 0.0, 0.0, 0.0]
let tgt_dist12 = [0.0, 0.0, 0.0, 0.0, 0.4, 0.3, 0.2, 0.1]
let bag_in   = [0, 0, 0, 0, 2, 0, 0, 0]
let bag_out  = [2, 0, 0, 0, 0, 0, 0, 0]
let w_in12  = dsir_importance(src_dist12, tgt_dist12, bag_in)
let w_out12 = dsir_importance(src_dist12, tgt_dist12, bag_out)
check("T12 in-domain weight > out-of-domain", w_in12 > w_out12)

println("")
println("=== DSIR Data Selection test summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
