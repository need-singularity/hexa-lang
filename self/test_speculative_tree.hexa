// test_speculative_tree.hexa — @speculative_tree_decode (EAGLE) tests
import "ml/speculative_tree.hexa"

let mut pass = 0
let mut fail = 0

fn check(name, cond) {
    if cond {
        pass = pass + 1
        println("PASS " + name)
    } else {
        fail = fail + 1
        println("FAIL " + name)
    }
}

// ── Test 1: hash_mix determinism ───────────────────────────────
let h1 = hash_mix(123456, 0)
let h2 = hash_mix(123456, 0)
let h3 = hash_mix(123456, 1)
check("hash_mix deterministic", h1 == h2)
check("hash_mix salt distinct", h1 != h3)

// ── Test 2: draft_top_k size & determinism ─────────────────────
let ctx1 = [7, 3, 1, 5]
let topk = draft_top_k(ctx1, 4)
check("draft_top_k size=4", len(topk) == 4)
let topk2 = draft_top_k(ctx1, 4)
let mut same = true
let mut i_eq = 0
while i_eq < len(topk) {
    if topk[i_eq] != topk2[i_eq] { same = false }
    i_eq = i_eq + 1
}
check("draft_top_k deterministic", same)

// ── Test 3: tree_draft_generate node count ─────────────────────
//  k=2, branch=3 → 1 (root) + 3 + 9 = 13 nodes
let tree_a = tree_draft_generate(ctx1, 2, 3)
check("tree_draft_generate node count = 13", tree_a[0] == 13)

// ── Test 4: tree depths correct ────────────────────────────────
let depths_a = tree_a[3]
check("root depth = 0", depths_a[0] == 0)
check("first child depth = 1", depths_a[1] == 1)
check("leaf depth = 2", depths_a[12] == 2)

// ── Test 5: parents form a valid tree ──────────────────────────
let parents_a = tree_a[2]
check("root parent = -1", parents_a[0] == -1)
let mut valid_parents = true
let mut vi = 1
while vi < tree_a[0] {
    if parents_a[vi] < 0 { valid_parents = false }
    if parents_a[vi] >= vi { valid_parents = false }
    vi = vi + 1
}
check("parents are strictly-lower indices", valid_parents)

// ── Test 6: path_of length matches depth ───────────────────────
let path_leaf = path_of(tree_a, 12)
check("path_of leaf length = depth", len(path_leaf) == depths_a[12])

// ── Test 7: tree_attention_mask shape & self-attention ─────────
let mask = tree_attention_mask(tree_a)
check("mask rows = n", len(mask) == tree_a[0])
check("mask cols = n", len(mask[0]) == tree_a[0])
let mut self_attn_ok = true
let mut mi = 0
while mi < tree_a[0] {
    if mask[mi][mi] != 1 { self_attn_ok = false }
    mi = mi + 1
}
check("mask diagonal = 1 (self attention)", self_attn_ok)

// ── Test 8: mask causality (root is visible to all) ────────────
let mut root_visible = true
let mut rvi = 0
while rvi < tree_a[0] {
    if mask[rvi][0] != 1 { root_visible = false }
    rvi = rvi + 1
}
check("root visible to every node", root_visible)

// ── Test 9: mask non-ancestors masked out ──────────────────────
//  node 1 (child 0 of root) and node 2 (child 1 of root) are
//  siblings — neither should be in the other's mask.
check("sibling not in mask row", mask[1][2] == 0)
check("sibling not in mask row (reverse)", mask[2][1] == 0)

// ── Test 10: tree_verify length = n ────────────────────────────
let verified = tree_verify(ctx1, tree_a)
check("tree_verify len = n", len(verified) == tree_a[0])

// ── Test 11: accept_longest_path returns valid chain ───────────
let chain = accept_longest_path(tree_a, verified)
let mut chain_valid = true
let mut ci = 0
while ci < len(chain) {
    let node = chain[ci]
    if node <= 0 { chain_valid = false }
    if node >= tree_a[0] { chain_valid = false }
    ci = ci + 1
}
check("accepted chain nodes in range", chain_valid)
// Each consecutive pair must be parent→child
let mut parent_child_ok = true
let mut pci = 1
while pci < len(chain) {
    if parents_a[chain[pci]] != chain[pci - 1] { parent_child_ok = false }
    pci = pci + 1
}
check("chain is parent→child sequence", parent_child_ok)

// ── Test 12: accepted_tokens matches chain length ──────────────
let acc_toks = accepted_tokens(tree_a, chain)
check("accepted_tokens len = chain len", len(acc_toks) == len(chain))

// ── Test 13: kv_merge appends in order ─────────────────────────
let merged = kv_merge(ctx1, [42, 43])
check("kv_merge len = base + added", len(merged) == len(ctx1) + 2)
check("kv_merge last-1 = 42", merged[len(ctx1)] == 42)
check("kv_merge last = 43", merged[len(ctx1) + 1] == 43)

// ── Test 14: count_nonroot_nodes = n - 1 ───────────────────────
check("count_nonroot_nodes = n - 1", count_nonroot_nodes(tree_a) == tree_a[0] - 1)

// ── Test 15: full speculative_tree_step produces max_tokens ────
let result = speculative_tree_step(ctx1, 2, 3, 16)
let out = result[0]
let td = result[1][0]
let ta = result[2][0]
let nr = result[3][0]
println("out_len=" + to_string(len(out)))
println("total_drafted=" + to_string(td))
println("total_accepted=" + to_string(ta))
println("rounds=" + to_string(nr))
let mut ratio_x100 = 0
if td > 0 {
    ratio_x100 = (ta * 100) / td
}
println("accept_ratio_pct=" + to_string(ratio_x100))
check("out reaches 16 tokens", len(out) == 16)
check("rounds >= 1", nr >= 1)
check("drafted >= accepted", td >= ta)

// ── Test 16: tree beats linear speculative for drafting budget ─
//  k=2, branch=3 → 12 non-root draft candidates per round. A linear
//  speculative_decode with k=2 would only draft 2 per round. We at
//  least verify the tree draft budget per round = branch^1 + branch^2 = 12.
let tree_budget_ok = count_nonroot_nodes(tree_a) == 12
check("tree drafts 12 per round (branch=3,k=2)", tree_budget_ok)

// ── Test 17: empty ctx edge case ───────────────────────────────
let empty_ctx = []
let tree_empty = tree_draft_generate(empty_ctx, 1, 2)
check("tree on empty ctx n = 3", tree_empty[0] == 3)

println("")
println("pass=" + to_string(pass) + " fail=" + to_string(fail))
if fail == 0 {
    println("ALL PASS")
} else {
    println("FAILED")
}
println(to_string(pass) + " passed")
