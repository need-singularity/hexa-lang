// ═══════════════════════════════════════════════════════════
//  test_functions_recursion.hexa — Function & Recursion Tests
//  Tests: basic fn, multiple params, default returns, recursion,
//         mutual recursion, tail patterns, fn as value, variadic patterns
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA Function & Recursion Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Basic functions ────────────────────────────────────

println("--- Basic Functions ---")

fn add(a, b) { return a + b }
fn sub(a, b) { return a - b }
fn mul(a, b) { return a * b }

check("add(3,4)", add(3, 4), 7)
check("sub(10,3)", sub(10, 3), 7)
check("mul(6,7)", mul(6, 7), 42)

fn greet(name) {
    return "hello " + name
}
check("greet", greet("world"), "hello world")

fn no_args() {
    return 42
}
check("no args", no_args(), 42)

// ── 2. Multiple return paths ──────────────────────────────

println("")
println("--- Multiple Return Paths ---")

fn abs_val(x) {
    if x < 0 {
        return 0 - x
    }
    return x
}
check("abs(5)", abs_val(5), 5)
check("abs(-3)", abs_val(-3), 3)
check("abs(0)", abs_val(0), 0)

fn sign(x) {
    if x > 0 { return 1 }
    if x < 0 { return -1 }
    return 0
}
check("sign(10)", sign(10), 1)
check("sign(-5)", sign(-5), -1)
check("sign(0)", sign(0), 0)

fn clamp(x, lo, hi) {
    if x < lo { return lo }
    if x > hi { return hi }
    return x
}
check("clamp(5,0,10)", clamp(5, 0, 10), 5)
check("clamp(-3,0,10)", clamp(-3, 0, 10), 0)
check("clamp(15,0,10)", clamp(15, 0, 10), 10)

// ── 3. Recursive functions ────────────────────────────────

println("")
println("--- Recursion ---")

fn factorial(n) {
    if n <= 1 { return 1 }
    return n * factorial(n - 1)
}
check("fact(0)", factorial(0), 1)
check("fact(1)", factorial(1), 1)
check("fact(5)", factorial(5), 120)
check("fact(6)", factorial(6), 720)
check("fact(10)", factorial(10), 3628800)

fn fib(n) {
    if n <= 0 { return 0 }
    if n == 1 { return 1 }
    return fib(n - 1) + fib(n - 2)
}
check("fib(0)", fib(0), 0)
check("fib(1)", fib(1), 1)
check("fib(5)", fib(5), 5)
check("fib(10)", fib(10), 55)

fn power(base, exp) {
    if exp == 0 { return 1 }
    return base * power(base, exp - 1)
}
check("power(2,0)", power(2, 0), 1)
check("power(2,10)", power(2, 10), 1024)
check("power(3,4)", power(3, 4), 81)

// ── 4. Iterative equivalents ──────────────────────────────

println("")
println("--- Iterative ---")

fn fact_iter(n) {
    let mut result = 1
    let mut i = 1
    while i <= n {
        result = result * i
        i = i + 1
    }
    return result
}
check("fact_iter(6)", fact_iter(6), 720)
check("fact_iter(10)", fact_iter(10), 3628800)

fn fib_iter(n) {
    if n <= 0 { return 0 }
    if n == 1 { return 1 }
    let mut a = 0
    let mut b = 1
    let mut i = 2
    while i <= n {
        let tmp = a + b
        a = b
        b = tmp
        i = i + 1
    }
    return b
}
check("fib_iter(0)", fib_iter(0), 0)
check("fib_iter(1)", fib_iter(1), 1)
check("fib_iter(10)", fib_iter(10), 55)
check("fib_iter(20)", fib_iter(20), 6765)

// ── 5. Mutual recursion ──────────────────────────────────

println("")
println("--- Mutual Recursion ---")

fn is_even(n) {
    if n == 0 { return true }
    return is_odd(n - 1)
}

fn is_odd(n) {
    if n == 0 { return false }
    return is_even(n - 1)
}

check("is_even(0)", is_even(0), true)
check("is_even(4)", is_even(4), true)
check("is_even(7)", is_even(7), false)
check("is_odd(0)", is_odd(0), false)
check("is_odd(3)", is_odd(3), true)
check("is_odd(6)", is_odd(6), false)

// ── 6. GCD / LCM ─────────────────────────────────────────

println("")
println("--- GCD / LCM ---")

fn gcd(a, b) {
    if b == 0 { return a }
    return gcd(b, a % b)
}

fn lcm(a, b) {
    return (a / gcd(a, b)) * b
}

check("gcd(12,8)", gcd(12, 8), 4)
check("gcd(100,75)", gcd(100, 75), 25)
check("gcd(7,13)", gcd(7, 13), 1)
check("lcm(4,6)", lcm(4, 6), 12)
check("lcm(3,5)", lcm(3, 5), 15)

// ── 7. Function composition ───────────────────────────────

println("")
println("--- Function Composition ---")

fn double(x) { return x * 2 }
fn inc(x) { return x + 1 }
fn square(x) { return x * x }

check("double(inc(5))", double(inc(5)), 12)
check("inc(double(5))", inc(double(5)), 11)
check("square(double(3))", square(double(3)), 36)
check("double(square(3))", double(square(3)), 18)

// Chain 3 functions
check("triple compose", inc(double(square(2))), 9)

// ── 8. Functions with complex logic ───────────────────────

println("")
println("--- Complex Functions ---")

fn collatz_steps(n) {
    let mut steps = 0
    let mut x = n
    while x != 1 {
        if x % 2 == 0 {
            x = x / 2
        } else {
            x = 3 * x + 1
        }
        steps = steps + 1
    }
    return steps
}
check("collatz(1)", collatz_steps(1), 0)
check("collatz(2)", collatz_steps(2), 1)
check("collatz(6)", collatz_steps(6), 8)
check("collatz(27)", collatz_steps(27), 111)

fn digit_sum(n) {
    let mut sum = 0
    let mut x = n
    if x < 0 { x = 0 - x }
    while x > 0 {
        sum = sum + (x % 10)
        x = x / 10
    }
    return sum
}
check("digit_sum(123)", digit_sum(123), 6)
check("digit_sum(999)", digit_sum(999), 27)
check("digit_sum(100)", digit_sum(100), 1)

fn is_prime(n) {
    if n < 2 { return false }
    if n == 2 { return true }
    if n % 2 == 0 { return false }
    let mut i = 3
    while i * i <= n {
        if n % i == 0 { return false }
        i = i + 2
    }
    return true
}
check("is_prime(2)", is_prime(2), true)
check("is_prime(7)", is_prime(7), true)
check("is_prime(13)", is_prime(13), true)
check("is_prime(4)", is_prime(4), false)
check("is_prime(9)", is_prime(9), false)
check("is_prime(1)", is_prime(1), false)

// ── 9. Sieve of Eratosthenes ─────────────────────────────

println("")
println("--- Sieve ---")

fn count_primes(limit) {
    let mut count = 0
    let mut n = 2
    while n <= limit {
        if is_prime(n) {
            count = count + 1
        }
        n = n + 1
    }
    return count
}
check("primes <= 10", count_primes(10), 4)
check("primes <= 30", count_primes(30), 10)
check("primes <= 100", count_primes(100), 25)

// ── 10. Recursive data processing ─────────────────────────

println("")
println("--- Recursive Processing ---")

fn sum_array(arr, idx) {
    if idx >= len(arr) { return 0 }
    return arr[idx] + sum_array(arr, idx + 1)
}
check("rec sum [1..5]", sum_array([1, 2, 3, 4, 5], 0), 15)
check("rec sum empty", sum_array([], 0), 0)

fn find_max(arr, idx, current_max) {
    if idx >= len(arr) { return current_max }
    let mut m = current_max
    if arr[idx] > m { m = arr[idx] }
    return find_max(arr, idx + 1, m)
}
check("rec max", find_max([3, 7, 2, 9, 1], 0, 0), 9)

fn binary_search(arr, target, lo, hi) {
    if lo > hi { return -1 }
    let mid = (lo + hi) / 2
    if arr[mid] == target { return mid }
    if arr[mid] < target {
        return binary_search(arr, target, mid + 1, hi)
    }
    return binary_search(arr, target, lo, mid - 1)
}
let sorted = [1, 3, 5, 7, 9, 11, 13, 15]
check("bsearch found", binary_search(sorted, 7, 0, len(sorted) - 1), 3)
check("bsearch found 1", binary_search(sorted, 1, 0, len(sorted) - 1), 0)
check("bsearch not found", binary_search(sorted, 6, 0, len(sorted) - 1), -1)

// ═══════════════════════════════════════════════════════════
