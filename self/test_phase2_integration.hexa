println("")
println("═══════════════════════════════════════════════════════")
let total = pass_count + fail_count
println("  Phase2 Integration: " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL / " + to_string(total) + " total")
if fail_count == 0 {
    println("  ALL PHASE2 INTEGRATION TESTS PASSED!")
} else {
    println("  SOME TESTS FAILED")
}
