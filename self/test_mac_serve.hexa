// ── 19. Parse request defaults ──────────────────────────────
let parsed2 = serve_parse_request("gpt4|Hi")
check("parse_default: max_tokens=16", parsed2.max_tokens == 16)
check("parse_default: stream=0", parsed2.stream == 0)

// ── 20. Streaming reconstructed content ─────────────────────
// Concatenating all deltas from chunks should equal blocking content
let msgs_recon = [#{"role": "user", "content": "reconstruct test"}]
let r_blk2 = make_chat_request("rc-1", "m", msgs_recon, 6, 0.7, 0)
let r_str2 = make_chat_request("rc-2", "m", msgs_recon, 6, 0.7, 1)
let s_rc = serve_create(80, "m", 1)
let blk_res = serve_process_request(s_rc, r_blk2)
let str_res = serve_process_stream(s_rc, r_str2)
let blk_content = blk_res[1].content
let str_chunks = str_res[1]
let mut recon = ""
let mut ri = 0
while ri < len(str_chunks) {
    recon = recon + str_chunks[ri].delta
    ri = ri + 1
}
check("recon: stream deltas == blocking content", recon == blk_content)

// ── 21. Queue overflow (more than max_batch) ────────────────
let s_of = serve_create(80, "m", 2)
let mut s_of2 = s_of
let mut oi = 0
while oi < 10 {
    let or1 = make_chat_request("of-" + str(oi), "m", msgs1, 2, 0.7, 0)
    s_of2 = serve_enqueue(s_of2, or1)
    oi = oi + 1
}
check("overflow: queue holds all 10", len(s_of2.request_queue) == 10)
let s_of3 = serve_schedule(s_of2)
check("overflow: only 2 active", len(s_of3.active_requests) == 2)
check("overflow: 8 remain in queue", len(s_of3.request_queue) == 8)

// ── 22. Stats with zero served ──────────────────────────────
let stats_zero = serve_stats(serve_create(80, "m", 1))
check("stats_zero: avg=0", stats_zero["avg_tokens_per_req"] == 0)

// ── 23. Prompt tokens counted ───────────────────────────────
check("prompt_tokens: counted", resp1.prompt_tokens > 0)

// ── 24. Stream chunk IDs match request ──────────────────────
let msgs_cid = [#{"role": "user", "content": "id check"}]
let r_cid = make_chat_request("cid-42", "m", msgs_cid, 3, 0.7, 1)
let res_cid = serve_process_stream(serve_create(80, "m", 1), r_cid)
let cid_chunks = res_cid[1]
check("chunk_id: matches request", cid_chunks[0].id == "cid-42")
check("chunk_id: last matches too", cid_chunks[3].id == "cid-42")

// ── 25. SSE format contains JSON ────────────────────────────
let mid_chunk = SSEChunk { id: "fmt-1", delta: "world", finish_reason: "" }
let mid_sse = serve_format_sse(mid_chunk)
check("sse_mid: contains delta", _str_contains(mid_sse, "world"))
check("sse_mid: contains choices", _str_contains(mid_sse, "choices"))

// ── 26. Multiple steps accumulate uptime ────────────────────
let s_up = serve_create(80, "m", 1)
let s_up2 = serve_step(serve_step(serve_step(s_up)))
check("uptime: 3 steps => 3", s_up2.uptime_ticks == 3)

// ── 27. Completed responses persist across steps ────────────
let s_per = serve_create(80, "m", 4)
let r_p1 = make_chat_request("per-1", "m", msgs1, 2, 0.7, 0)
let r_p2 = make_chat_request("per-2", "m", msgs1, 2, 0.7, 0)
let s_per2 = serve_step(serve_enqueue(serve_enqueue(s_per, r_p1), r_p2))
check("persist: completed=2", len(s_per2.completed) == 2)

// ── Helper: string contains ─────────────────────────────────
fn _str_contains(haystack, needle) {
    let h_len = len(haystack)
    let n_len = len(needle)
    if n_len > h_len { return false }
    let limit = h_len - n_len + 1
    let mut i = 0
    while i < limit {
        let mut match_found = true
        let mut j = 0
        while j < n_len {
            if haystack[i + j] != needle[j] {
                match_found = false
                j = n_len
            } else {
                j = j + 1
            }
        }
        if match_found { return true }
        i = i + 1
    }
    return false
}

