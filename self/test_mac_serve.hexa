// ===================================================================
//  self/ml/mac_serve.hexa — Mac Serve: HTTP+SSE Streaming Server (#182)
//
//  OpenAI-compatible serving endpoint for Mac Mini inference.
//  Pure HEXA simulation: HTTP layer modelled as request/response queue.
//
//  Integrates:
//    streaming_gen.hexa   — StreamChannel (backpressure token stream)
//    continuous_batching  — iteration-level scheduling
//    prefix_cache         — system-prompt KV reuse
//
//  Public API:
//    serve_create(port, model_name, max_batch)  -> ServeState
//    serve_enqueue(state, request)              -> ServeState
//    serve_schedule(state)                      -> ServeState
//    serve_process_request(state, request)      -> [ServeState, ChatResponse]
//    serve_process_stream(state, request)       -> [ServeState, [SSEChunk]]
//    serve_step(state)                          -> ServeState
//    serve_stats(state)                         -> #{} stats dict
//    serve_format_sse(chunk)                    -> string
//    serve_format_response(resp)                -> string (JSON)
//    serve_parse_request(json_str)              -> ChatRequest
//    mock_generate_token(seed, step)            -> string
//
//  Data:
//    ChatRequest   — incoming chat completion request
//    ChatResponse  — blocking response
//    SSEChunk      — one incremental streaming delta
//    ServeState    — server state with queues + counters
//
//  AI-NATIVE: @hot serve_step, @pure mock_generate_token
//  L0: src/*.rs untouched. Pure .hexa.
// ===================================================================

// ===================================================================
//  Structs
// ===================================================================

struct ChatRequest {
    id: string,
    model: string,
    messages: array,
    max_tokens: int,
    temperature: float,
    stream: int
}

struct ChatResponse {
    id: string,
    model: string,
    content: string,
    tokens_generated: int,
    prompt_tokens: int,
    finish_reason: string
}

struct SSEChunk {
    id: string,
    delta: string,
    finish_reason: string
}

struct ServeState {
    port: int,
    model_name: string,
    max_batch: int,
    request_queue: array,
    active_requests: array,
    completed: array,
    total_served: int,
    total_tokens: int,
    uptime_ticks: int
}

// ===================================================================
//  Server creation
// ===================================================================
fn serve_create(port, model_name, max_batch) {
    return ServeState {
        port: port,
        model_name: model_name,
        max_batch: max_batch,
        request_queue: [],
        active_requests: [],
        completed: [],
        total_served: 0,
        total_tokens: 0,
        uptime_ticks: 0
    }
}

// ===================================================================
//  Enqueue — add a ChatRequest to the queue
// ===================================================================
fn serve_enqueue(state, request) {
    return ServeState {
        port: state.port,
        model_name: state.model_name,
        max_batch: state.max_batch,
        request_queue: state.request_queue + [request],
        active_requests: state.active_requests,
        completed: state.completed,
        total_served: state.total_served,
        total_tokens: state.total_tokens,
        uptime_ticks: state.uptime_ticks
    }
}

// ===================================================================
//  Schedule — move requests from queue to active up to max_batch
// ===================================================================
fn serve_schedule(state) {
    let n_active = len(state.active_requests)
    let mut free_slots = state.max_batch - n_active
    if free_slots <= 0 {
        return state
    }
    let n_queue = len(state.request_queue)
    if n_queue == 0 {
        return state
    }

    let mut new_active = state.active_requests
    let mut new_queue = []
    let mut moved = 0
    let mut i = 0
    while i < n_queue {
        if moved < free_slots {
            new_active = new_active + [state.request_queue[i]]
            moved = moved + 1
        } else {
            new_queue = new_queue + [state.request_queue[i]]
        }
        i = i + 1
    }

    return ServeState {
        port: state.port,
        model_name: state.model_name,
        max_batch: state.max_batch,
        request_queue: new_queue,
        active_requests: new_active,
        completed: state.completed,
        total_served: state.total_served,
        total_tokens: state.total_tokens,
        uptime_ticks: state.uptime_ticks
    }
}

// ===================================================================
//  Mock token generation — deterministic, no actual model
//
//  Returns a word from a fixed vocabulary based on seed + step.
// ===================================================================
@pure
fn mock_generate_token(seed, step) {
    let words = ["the", "quick", "brown", "fox", "jumps",
                 "over", "lazy", "dog", "and", "cat",
                 "is", "a", "very", "good", "model",
                 "that", "can", "do", "many", "things"]
    let idx = (seed * 31 + step * 7) % len(words)
    return words[idx]
}

// ===================================================================
//  Compute a simple hash from the messages array for seeding
// ===================================================================
@pure
fn _msg_seed(messages) {
    let n = len(messages)
    let mut h = 17
    let mut i = 0
    while i < n {
        // Use index as proxy (struct field access not deep-hashed)
        h = h * 31 + (i + 1) * 13
        i = i + 1
    }
    if h < 0 { h = 0 - h }
    return h
}

// ===================================================================
//  Count prompt tokens (rough: sum of message content lengths)
// ===================================================================
@pure
fn _count_prompt_tokens(messages) {
    let n = len(messages)
    let mut total = 0
    let mut i = 0
    while i < n {
        let msg = messages[i]
        // Each message counts as ~4 tokens overhead + content length / 4
        let clen = len(msg["content"])
        total = total + 4 + (clen / 4)
        i = i + 1
    }
    if total < 1 { total = 1 }
    return total
}

// ===================================================================
//  Process blocking request — generate all tokens at once
//
//  Returns [updated_state, ChatResponse].
// ===================================================================
@hot
fn serve_process_request(state, request) {
    let seed = _msg_seed(request.messages)
    let mut content = ""
    let mut step = 0
    let max_t = request.max_tokens
    let mut finish = "length"

    while step < max_t {
        let tok = mock_generate_token(seed, step)
        if step > 0 {
            content = content + " " + tok
        } else {
            content = content + tok
        }
        step = step + 1
    }

    // If max_tokens was not reached (impossible in mock), mark "stop"
    // For mock: always generates exactly max_tokens, so finish = "length"
    // unless max_tokens <= 0
    if max_t <= 0 {
        finish = "stop"
    }

    let prompt_toks = _count_prompt_tokens(request.messages)
    let resp = ChatResponse {
        id: request.id,
        model: state.model_name,
        content: content,
        tokens_generated: step,
        prompt_tokens: prompt_toks,
        finish_reason: finish
    }

    let new_state = ServeState {
        port: state.port,
        model_name: state.model_name,
        max_batch: state.max_batch,
        request_queue: state.request_queue,
        active_requests: state.active_requests,
        completed: state.completed + [resp],
        total_served: state.total_served + 1,
        total_tokens: state.total_tokens + step,
        uptime_ticks: state.uptime_ticks
    }
    return [new_state, resp]
}

// ===================================================================
//  Process streaming request — return array of SSEChunks
//
//  One chunk per generated token, plus a final [DONE] sentinel.
//  Returns [updated_state, [SSEChunk]].
// ===================================================================
@hot
fn serve_process_stream(state, request) {
    let seed = _msg_seed(request.messages)
    let max_t = request.max_tokens
    let mut chunks = []
    let mut step = 0
    let mut total_content = ""

    while step < max_t {
        let tok = mock_generate_token(seed, step)
        let mut delta_text = tok
        if step > 0 {
            delta_text = " " + tok
        }
        total_content = total_content + delta_text

        let chunk = SSEChunk {
            id: request.id,
            delta: delta_text,
            finish_reason: ""
        }
        chunks = chunks + [chunk]
        step = step + 1
    }

    // Determine finish reason
    let mut finish = "length"
    if max_t <= 0 {
        finish = "stop"
    }

    // Final [DONE] chunk
    let done_chunk = SSEChunk {
        id: request.id,
        delta: "",
        finish_reason: finish
    }
    chunks = chunks + [done_chunk]

    let prompt_toks = _count_prompt_tokens(request.messages)
    let new_state = ServeState {
        port: state.port,
        model_name: state.model_name,
        max_batch: state.max_batch,
        request_queue: state.request_queue,
        active_requests: state.active_requests,
        completed: state.completed,
        total_served: state.total_served + 1,
        total_tokens: state.total_tokens + step,
        uptime_ticks: state.uptime_ticks
    }
    return [new_state, chunks]
}

// ===================================================================
//  serve_step — process one tick
//
//  1. Schedule pending -> active (up to max_batch)
//  2. Process all active requests (blocking mode for simplicity)
//  3. Remove processed from active
//  Returns updated state.
// ===================================================================
@hot
fn serve_step(state) {
    // Step 1: schedule
    let mut s = serve_schedule(state)

    // Step 2: process all active
    let n_active = len(s.active_requests)
    let mut i = 0
    while i < n_active {
        let req = s.active_requests[i]
        if req.stream == 1 {
            let result = serve_process_stream(s, req)
            s = result[0]
        } else {
            let result = serve_process_request(s, req)
            s = result[0]
        }
        i = i + 1
    }

    // Step 3: clear active (all processed this tick)
    return ServeState {
        port: s.port,
        model_name: s.model_name,
        max_batch: s.max_batch,
        request_queue: s.request_queue,
        active_requests: [],
        completed: s.completed,
        total_served: s.total_served,
        total_tokens: s.total_tokens,
        uptime_ticks: s.uptime_ticks + 1
    }
}

// ===================================================================
//  serve_stats — return stats as a dict
// ===================================================================
fn serve_stats(state) {
    let mut avg = 0
    if state.total_served > 0 {
        avg = state.total_tokens / state.total_served
    }
    let stats = #{
        "total_served": state.total_served,
        "total_tokens": state.total_tokens,
        "avg_tokens_per_req": avg,
        "queue_depth": len(state.request_queue),
        "active": len(state.active_requests),
        "uptime_ticks": state.uptime_ticks
    }
    return stats
}

// ===================================================================
//  serve_format_sse — format SSEChunk as SSE event line
//
//  Format: "data: {json}\n\n"
//  Final chunk (empty delta + finish_reason): "data: [DONE]\n\n"
// ===================================================================
fn serve_format_sse(chunk) {
    if chunk.finish_reason != "" {
        if chunk.delta == "" {
            return "data: [DONE]\n\n"
        }
    }
    let json = "{\"id\":\"" + chunk.id + "\","
    let json2 = json + "\"object\":\"chat.completion.chunk\","
    let json3 = json2 + "\"choices\":[{\"delta\":{\"content\":\"" + chunk.delta + "\"},"
    let json4 = json3 + "\"finish_reason\":null}]}"
    return "data: " + json4 + "\n\n"
}

// ===================================================================
//  serve_format_response — format ChatResponse as OpenAI JSON
// ===================================================================
fn serve_format_response(resp) {
    let json = "{\"id\":\"" + resp.id + "\","
    let json2 = json + "\"object\":\"chat.completion\","
    let json3 = json2 + "\"model\":\"" + resp.model + "\","
    let json4 = json3 + "\"choices\":[{\"message\":{\"role\":\"assistant\","
    let json5 = json4 + "\"content\":\"" + resp.content + "\"},"
    let json6 = json5 + "\"finish_reason\":\"" + resp.finish_reason + "\"}],"
    let json7 = json6 + "\"usage\":{\"prompt_tokens\":" + str(resp.prompt_tokens) + ","
    let json8 = json7 + "\"completion_tokens\":" + str(resp.tokens_generated) + "}}"
    return json8
}

// ===================================================================
//  serve_parse_request — parse simplified JSON string to ChatRequest
//
//  Expects format: "model|msg_content|max_tokens|temperature|stream"
//  Pipe-delimited for simplicity (no full JSON parser needed).
//  Example: "llama-3|Hello world|64|0.7|1"
// ===================================================================
fn serve_parse_request(input_str) {
    // Split by '|'
    let mut parts = []
    let mut cur = ""
    let n = len(input_str)
    let mut i = 0
    while i < n {
        let ch = str(input_str[i])
        if ch == "|" {
            parts = parts + [cur]
            cur = ""
        } else {
            cur = cur + ch
        }
        i = i + 1
    }
    parts = parts + [cur]

    // Default values
    let mut model = "default"
    let mut msg_content = ""
    let mut max_tok = 16
    let mut temp = 0.7
    let mut strm = 0

    if len(parts) >= 1 { model = parts[0] }
    if len(parts) >= 2 { msg_content = parts[1] }
    if len(parts) >= 3 { max_tok = int(parts[2]) }
    if len(parts) >= 4 { temp = to_float(parts[3]) }
    if len(parts) >= 5 {
        if parts[4] == "1" {
            strm = 1
        }
    }

    // Generate a unique-ish id from content
    let req_id = "chatcmpl-" + str(len(msg_content) * 7 + max_tok)

    let messages = [#{"role": "user", "content": msg_content}]

    return ChatRequest {
        id: req_id,
        model: model,
        messages: messages,
        max_tokens: max_tok,
        temperature: temp,
        stream: strm
    }
}

// ===================================================================
//  Helper: create a ChatRequest programmatically
// ===================================================================
fn make_chat_request(id, model, messages, max_tokens, temperature, stream) {
    return ChatRequest {
        id: id,
        model: model,
        messages: messages,
        max_tokens: max_tokens,
        temperature: temperature,
        stream: stream
    }
}

println("[mac_serve] loaded — OpenAI-compatible HTTP+SSE serving for Mac Mini")


// -- end inlined --

let mut pass = 0
let mut fail = 0

fn check(name, cond) {
    if cond {
        pass = pass + 1
        println("PASS " + name)
    } else {
        fail = fail + 1
        println("FAIL " + name)
    }
}

// ── 1. Server creation ────────────────────────────────────────
let s1 = serve_create(8080, "llama-3-8b", 4)
check("create: port", s1.port == 8080)
check("create: model_name", s1.model_name == "llama-3-8b")
check("create: max_batch", s1.max_batch == 4)
check("create: empty queues", len(s1.request_queue) == 0)
check("create: empty active", len(s1.active_requests) == 0)
check("create: total_served=0", s1.total_served == 0)
check("create: uptime=0", s1.uptime_ticks == 0)

// ── 2. ChatRequest creation ───────────────────────────────────
let msgs1 = [#{"role": "user", "content": "hello"}]
let r1 = make_chat_request("req-1", "llama-3-8b", msgs1, 8, 0.7, 0)
check("request: id", r1.id == "req-1")
check("request: max_tokens", r1.max_tokens == 8)
check("request: stream=0", r1.stream == 0)

// ── 3. Enqueue ────────────────────────────────────────────────
let s2 = serve_enqueue(s1, r1)
check("enqueue: queue grows", len(s2.request_queue) == 1)
check("enqueue: active stays empty", len(s2.active_requests) == 0)

// ── 4. Multiple enqueue ──────────────────────────────────────
let r2 = make_chat_request("req-2", "llama-3-8b", msgs1, 4, 0.5, 1)
let s3 = serve_enqueue(s2, r2)
check("multi-enqueue: queue=2", len(s3.request_queue) == 2)

// ── 5. Schedule moves to active ──────────────────────────────
let s4 = serve_schedule(s3)
check("schedule: queue drained", len(s4.request_queue) == 0)
check("schedule: active=2", len(s4.active_requests) == 2)

// ── 6. Schedule respects max_batch ───────────────────────────
let s_small = serve_create(8080, "m", 1)
let s_q = serve_enqueue(serve_enqueue(s_small, r1), r2)
let s_sched = serve_schedule(s_q)
check("schedule: max_batch=1 -> active=1", len(s_sched.active_requests) == 1)
check("schedule: max_batch=1 -> queue=1", len(s_sched.request_queue) == 1)

// ── 7. Process blocking request ─────────────────────────────
let s5 = serve_create(8080, "llama-3-8b", 4)
let msgs_block = [#{"role": "user", "content": "test prompt"}]
let r_block = make_chat_request("blk-1", "llama-3-8b", msgs_block, 5, 0.7, 0)
let result1 = serve_process_request(s5, r_block)
let s6 = result1[0]
let resp1 = result1[1]
check("blocking: tokens_generated=5", resp1.tokens_generated == 5)
check("blocking: finish_reason=length", resp1.finish_reason == "length")
check("blocking: model matches", resp1.model == "llama-3-8b")
check("blocking: id matches", resp1.id == "blk-1")
check("blocking: content non-empty", len(resp1.content) > 0)
check("blocking: state total_served=1", s6.total_served == 1)
check("blocking: state total_tokens=5", s6.total_tokens == 5)

// ── 8. Process streaming request ────────────────────────────
let r_stream = make_chat_request("str-1", "llama-3-8b", msgs_block, 4, 0.7, 1)
let result2 = serve_process_stream(s5, r_stream)
let s7 = result2[0]
let chunks = result2[1]
// 4 token chunks + 1 DONE chunk = 5 total
check("stream: chunk count=5", len(chunks) == 5)
check("stream: first chunk has delta", len(chunks[0].delta) > 0)
check("stream: last chunk is DONE", chunks[4].finish_reason == "length")
check("stream: last chunk delta empty", chunks[4].delta == "")
check("stream: middle chunks no finish", chunks[1].finish_reason == "")
check("stream: state total_served=1", s7.total_served == 1)

// ── 9. SSE format correctness ───────────────────────────────
let test_chunk = SSEChunk { id: "c-1", delta: "hello", finish_reason: "" }
let sse_out = serve_format_sse(test_chunk)
check("sse_format: starts with data:", len(sse_out) > 6)

// Check the DONE sentinel
let done_chunk = SSEChunk { id: "c-1", delta: "", finish_reason: "stop" }
let sse_done = serve_format_sse(done_chunk)
check("sse_format: DONE sentinel", sse_done == "data: [DONE]\n\n")

// ── 10. Response JSON format ────────────────────────────────
let test_resp = ChatResponse {
    id: "chatcmpl-1",
    model: "llama-3-8b",
    content: "hello world",
    tokens_generated: 2,
    prompt_tokens: 5,
    finish_reason: "stop"
}
let json_out = serve_format_response(test_resp)
// Verify key fields present
check("json: has chat.completion", _str_contains(json_out, "chat.completion"))
check("json: has model", _str_contains(json_out, "llama-3-8b"))
check("json: has content", _str_contains(json_out, "hello world"))
check("json: has finish_reason", _str_contains(json_out, "stop"))
check("json: has prompt_tokens", _str_contains(json_out, "prompt_tokens"))
check("json: has completion_tokens", _str_contains(json_out, "completion_tokens"))

// ── 11. Multiple concurrent requests (batch=4) ─────────────
let s_batch = serve_create(8080, "llama-3-8b", 4)
let b_msgs = [#{"role": "user", "content": "batch test"}]
let mut s_b = s_batch
let mut bi = 0
while bi < 6 {
    let br = make_chat_request("b-" + str(bi), "llama-3-8b", b_msgs, 3, 0.7, 0)
    s_b = serve_enqueue(s_b, br)
    bi = bi + 1
}
check("batch: queued 6", len(s_b.request_queue) == 6)

// One step processes up to max_batch=4
let s_b2 = serve_step(s_b)
check("batch: step1 served=4", s_b2.total_served == 4)
check("batch: step1 queue remaining=2", len(s_b2.request_queue) == 2)
check("batch: step1 active cleared", len(s_b2.active_requests) == 0)

// Second step picks up remaining 2
let s_b3 = serve_step(s_b2)
check("batch: step2 served=6", s_b3.total_served == 6)
check("batch: step2 queue empty", len(s_b3.request_queue) == 0)

// ── 12. Stats tracking ──────────────────────────────────────
let stats = serve_stats(s_b3)
check("stats: total_served=6", stats["total_served"] == 6)
check("stats: total_tokens=18", stats["total_tokens"] == 18)
check("stats: avg=3", stats["avg_tokens_per_req"] == 3)
check("stats: queue_depth=0", stats["queue_depth"] == 0)
check("stats: uptime=2", stats["uptime_ticks"] == 2)

// ── 13. Mock token determinism ──────────────────────────────
let tok_a = mock_generate_token(42, 3)
let tok_b = mock_generate_token(42, 3)
check("determinism: same seed+step => same", tok_a == tok_b)
let tok_c = mock_generate_token(42, 4)
check("determinism: different step => may differ", true)

// ── 14. Max tokens limit respected ──────────────────────────
let r_max = make_chat_request("mx-1", "m", [#{"role": "user", "content": "x"}], 10, 0.7, 0)
let res_max = serve_process_request(serve_create(80, "m", 1), r_max)
let resp_max = res_max[1]
check("max_tokens: generated=10", resp_max.tokens_generated == 10)

// ── 15. finish_reason "stop" vs "length" ────────────────────
let r_zero = make_chat_request("z-1", "m", [#{"role": "user", "content": "x"}], 0, 0.7, 0)
let res_zero = serve_process_request(serve_create(80, "m", 1), r_zero)
check("finish: zero tokens => stop", res_zero[1].finish_reason == "stop")

let r_pos = make_chat_request("p-1", "m", [#{"role": "user", "content": "x"}], 3, 0.7, 0)
let res_pos = serve_process_request(serve_create(80, "m", 1), r_pos)
check("finish: positive tokens => length", res_pos[1].finish_reason == "length")

// ── 16. Empty message handling ──────────────────────────────
let r_empty = make_chat_request("e-1", "m", [], 3, 0.7, 0)
let res_empty = serve_process_request(serve_create(80, "m", 1), r_empty)
check("empty msgs: no crash", res_empty[1].tokens_generated == 3)

// ── 17. Server step cycle (enqueue -> step -> completed) ────
let s_cycle = serve_create(8080, "m", 2)
let r_c1 = make_chat_request("c-1", "m", [#{"role": "user", "content": "cycle"}], 2, 0.7, 0)
let s_c2 = serve_enqueue(s_cycle, r_c1)
