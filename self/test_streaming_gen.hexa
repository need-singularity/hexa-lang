// ===================================================================
//  test_streaming_gen.hexa — Streaming Generation (#70) test suite
//
//  Verifies self/ml/streaming_gen.hexa:
//    1. create_channel invariants (capacity, watermarks)
//    2. push/pop FIFO ordering
//    3. high watermark backpressure (push rejected w/ blocked flag)
//    4. low watermark unblock on drain
//    5. try_push drops when capacity full
//    6. cancel aborts both push and pop paths
//    7. close prevents further pushes but allows pops
//    8. subscriber fan-out notify count
//    9. stats counters (produced/consumed/dropped/block_events)
//   10. partial decoder feed emits correct delta + accumulates emitted
//   11. decoder EOS marker
//   12. stream_generate happy path w/ subscribers
//   13. stream_generate backpressure + drain loop
//   14. stream_generate cancel short-circuit
//
//  Run: ./hexa self/test_streaming_gen.hexa
//  Expected: all [PASS], exit non-zero on any [FAIL].
// ===================================================================

// -- inlined from self/ml/streaming_gen.hexa --
// codegen import not wired for test files

// ===================================================================
//  self/ml/streaming_gen.hexa — Streaming Token Generation (#70)
//
//  Backpressure-aware token stream channel for interactive LLM UX.
//  Pure Hexa, self-contained. Complements self/ml/streaming.hexa (SSE).
//
//  Core primitives:
//    StreamChannel        — FIFO buffer + watermarks + flags + stats
//    create_channel       — build channel with capacity + watermarks
//    channel_push         — blocking producer side (respects backpressure)
//    channel_try_push     — non-blocking producer side (drops when full)
//    channel_pop          — consumer side (returns [ok, tok, ch])
//    channel_peek         — non-destructive read of oldest element
//    channel_len          — current buffered token count
//    channel_is_full      — buffered >= high watermark
//    channel_is_blocked   — producer currently blocked on full buffer
//    channel_is_drained   — buffered <= low watermark (unblock signal)
//    channel_cancel       — set abort flag (both sides must honor)
//    channel_is_cancelled — check abort flag
//    channel_subscribe    — register subscriber callback (pull model)
//    channel_notify       — fan-out notify subscribers with latest token
//    channel_stats        — produced / consumed / dropped / blocks
//
//  Partial decode (incremental detokenize):
//    create_decoder       — decoder state w/ pending bytes + output
//    decoder_feed         — push token id; emit string delta
//    decoder_flush        — drain any remaining partial bytes
//
//  High-level driver:
//    stream_generate      — producer loop; writes to channel with
//                           backpressure; respects cancel; notifies
//                           subscribers after each admitted token
//
//  Design notes:
//    - Immutable-style: every mutation returns a new StreamChannel
//      value (matching semantic_cache.hexa / continuous_batching.hexa).
//    - Single-threaded cooperative model: "blocking" means the
//      producer aborts this push and the caller retries later once
//      buffer has drained below the low watermark.
//    - Subscribers are closures (|tok_str| { ... }) stored in an
//      array; notify iterates and calls each.
//    - partial decode accumulates bytes in a string until a full
//      printable character arrives (byte-level detokenizer compatible
//      with streaming.hexa's token_to_str).
// ===================================================================

// ===================================================================
//  StreamChannel struct
//
//  NOTE on mutability: Hexa closures capture by value and arrays/maps
//  are not shared across lambdas. We therefore expose all mutation
//  through explicit [new_channel, ...] return tuples, matching
//  self/ml/semantic_cache.hexa and self/ml/continuous_batching.hexa.
//  Subscriber callbacks are stored as an array; channel_notify returns
//  (count, list_of_deltas) AND the channel records last_delta /
//  notify_count fields so tests can assert on the channel state.
// ===================================================================
struct StreamChannel {
    buffer: array,          // FIFO of token ids (ints)
    capacity: int,          // absolute upper bound
    high_watermark: int,    // producer blocks when len >= high
    low_watermark: int,     // producer resumes when len <= low
    blocked: bool,          // producer flagged blocked?
    cancelled: bool,        // abort flag
    closed: bool,           // producer finished (EOS/max reached)
    subscribers: array,     // array of callback closures
    produced: int,          // total successful pushes
    consumed: int,          // total pops
    dropped: int,           // try_push rejections
    block_events: int,      // number of times producer was blocked
    last_delta: string,     // most recent decoded string delta (for tests)
    notify_count: int,      // total channel_notify invocations
    history: array          // admitted token ids (append-only, for tests)
}

// ===================================================================
//  create_channel — build a channel with given capacity/watermarks
//
//  Watermark invariants:
//    0 < low < high <= capacity
//  Sensible default: high = 0.8*cap, low = 0.3*cap (min 1 each).
// ===================================================================
fn create_channel(capacity, high_watermark, low_watermark) {
    let mut hi = high_watermark
    let mut lo = low_watermark
    if hi <= 0 { hi = 1 }
    if hi > capacity { hi = capacity }
    if lo <= 0 { lo = 1 }
    if lo >= hi { lo = hi - 1 }
    if lo < 0 { lo = 0 }
    return StreamChannel {
        buffer: [],
        capacity: capacity,
        high_watermark: hi,
        low_watermark: lo,
        blocked: false,
        cancelled: false,
        closed: false,
        subscribers: [],
        produced: 0,
        consumed: 0,
        dropped: 0,
        block_events: 0,
        last_delta: "",
        notify_count: 0,
        history: []
    }
}

fn default_channel(capacity) {
    let mut hi = (capacity * 8) / 10
    let mut lo = (capacity * 3) / 10
    if hi < 1 { hi = 1 }
    if lo < 1 { lo = 1 }
    if lo >= hi { lo = hi - 1 }
    if lo < 1 { lo = 1 }
    return create_channel(capacity, hi, lo)
}

// ===================================================================
//  channel_len / introspection
// ===================================================================
fn channel_len(ch) {
    return len(ch.buffer)
}

fn channel_is_full(ch) {
    return len(ch.buffer) >= ch.high_watermark
}

fn channel_is_drained(ch) {
    return len(ch.buffer) <= ch.low_watermark
}

fn channel_is_blocked(ch) {
    return ch.blocked
}

fn channel_is_cancelled(ch) {
    return ch.cancelled
}

fn channel_is_closed(ch) {
    return ch.closed
}

// ===================================================================
//  channel_push — blocking producer push
//
//  Returns [ok, new_channel].
//  ok=false means either cancelled or buffer at high watermark.
//  When ok=false due to backpressure, new_channel.blocked is set and
//  block_events is incremented — caller should back off and retry.
// ===================================================================
fn channel_push(ch, tok) {
    if ch.cancelled {
        return [false, ch]
    }
    if ch.closed {
        return [false, ch]
    }
    let cur = len(ch.buffer)
    if cur >= ch.high_watermark {
        // Backpressure: flag blocked, do NOT enqueue.
        let blocked_ch = StreamChannel {
            buffer: ch.buffer,
            capacity: ch.capacity,
            high_watermark: ch.high_watermark,
            low_watermark: ch.low_watermark,
            blocked: true,
            cancelled: ch.cancelled,
            closed: ch.closed,
            subscribers: ch.subscribers,
            produced: ch.produced,
            consumed: ch.consumed,
            dropped: ch.dropped,
            block_events: ch.block_events + 1,
            last_delta: ch.last_delta,
            notify_count: ch.notify_count,
            history: ch.history
        }
        return [false, blocked_ch]
    }
    let new_buf = ch.buffer + [tok]
    let new_ch = StreamChannel {
        buffer: new_buf,
        capacity: ch.capacity,
        high_watermark: ch.high_watermark,
        low_watermark: ch.low_watermark,
        blocked: false,
        cancelled: ch.cancelled,
        closed: ch.closed,
        subscribers: ch.subscribers,
        produced: ch.produced + 1,
        consumed: ch.consumed,
        dropped: ch.dropped,
        block_events: ch.block_events,
        last_delta: ch.last_delta,
        notify_count: ch.notify_count,
        history: ch.history + [tok]
    }
    return [true, new_ch]
}

// ===================================================================
//  channel_try_push — non-blocking producer; drops on overflow
// ===================================================================
fn channel_try_push(ch, tok) {
    if ch.cancelled { return [false, ch] }
    if ch.closed { return [false, ch] }
    if len(ch.buffer) >= ch.capacity {
        let dropped_ch = StreamChannel {
            buffer: ch.buffer,
            capacity: ch.capacity,
            high_watermark: ch.high_watermark,
            low_watermark: ch.low_watermark,
            blocked: ch.blocked,
            cancelled: ch.cancelled,
            closed: ch.closed,
            subscribers: ch.subscribers,
            produced: ch.produced,
            consumed: ch.consumed,
            dropped: ch.dropped + 1,
            block_events: ch.block_events,
            last_delta: ch.last_delta,
            notify_count: ch.notify_count,
            history: ch.history
        }
        return [false, dropped_ch]
    }
    let new_buf = ch.buffer + [tok]
    let new_ch = StreamChannel {
        buffer: new_buf,
        capacity: ch.capacity,
        high_watermark: ch.high_watermark,
        low_watermark: ch.low_watermark,
        blocked: ch.blocked,
        cancelled: ch.cancelled,
        closed: ch.closed,
        subscribers: ch.subscribers,
        produced: ch.produced + 1,
        consumed: ch.consumed,
        dropped: ch.dropped,
        block_events: ch.block_events,
        last_delta: ch.last_delta,
        notify_count: ch.notify_count,
        history: ch.history + [tok]
    }
    return [true, new_ch]
}

// ===================================================================
//  channel_pop — consumer pops oldest element
//
//  Returns [ok, tok, new_channel]. ok=false iff buffer empty.
//  If popping crosses the low watermark, blocked flag is cleared
//  (producer may resume).
// ===================================================================
fn channel_pop(ch) {
    let n = len(ch.buffer)
    if n == 0 {
        return [false, 0, ch]
    }
    let tok = ch.buffer[0]
    let mut new_buf = []
    let mut i = 1
    while i < n {
        new_buf = new_buf + [ch.buffer[i]]
        i = i + 1
    }
    let mut was_blocked = ch.blocked
    if len(new_buf) <= ch.low_watermark {
        was_blocked = false
    }
    let new_ch = StreamChannel {
        buffer: new_buf,
        capacity: ch.capacity,
        high_watermark: ch.high_watermark,
        low_watermark: ch.low_watermark,
        blocked: was_blocked,
        cancelled: ch.cancelled,
        closed: ch.closed,
        subscribers: ch.subscribers,
        produced: ch.produced,
        consumed: ch.consumed + 1,
        dropped: ch.dropped,
        block_events: ch.block_events,
        last_delta: ch.last_delta,
        notify_count: ch.notify_count,
        history: ch.history
    }
    return [true, tok, new_ch]
}

// ===================================================================
//  channel_peek — non-destructive read of oldest element
// ===================================================================
fn channel_peek(ch) {
    if len(ch.buffer) == 0 { return [false, 0] }
    return [true, ch.buffer[0]]
}

// ===================================================================
//  channel_cancel — set abort flag
// ===================================================================
fn channel_cancel(ch) {
    return StreamChannel {
        buffer: ch.buffer,
        capacity: ch.capacity,
        high_watermark: ch.high_watermark,
        low_watermark: ch.low_watermark,
        blocked: ch.blocked,
        cancelled: true,
        closed: ch.closed,
        subscribers: ch.subscribers,
        produced: ch.produced,
        consumed: ch.consumed,
        dropped: ch.dropped,
        block_events: ch.block_events,
        last_delta: ch.last_delta,
        notify_count: ch.notify_count,
        history: ch.history
    }
}

fn channel_close(ch) {
    return StreamChannel {
        buffer: ch.buffer,
        capacity: ch.capacity,
        high_watermark: ch.high_watermark,
        low_watermark: ch.low_watermark,
        blocked: ch.blocked,
        cancelled: ch.cancelled,
        closed: true,
        subscribers: ch.subscribers,
        produced: ch.produced,
        consumed: ch.consumed,
        dropped: ch.dropped,
        block_events: ch.block_events,
        last_delta: ch.last_delta,
        notify_count: ch.notify_count,
        history: ch.history
    }
}

// ===================================================================
//  Subscriber callbacks (fan-out)
//
//  Subscribers are closures of shape |tok_str| { ... }. Because Hexa
//  closures are capture-by-value, callbacks cannot mutate caller
//  state through side effects — so in addition to invoking each
//  callback, channel_notify records the last delta and notify_count
//  on the returned channel. Callers that need real side effects
//  should inspect the returned channel.
//
//  Returns [count, new_channel].
// ===================================================================
fn channel_subscribe(ch, callback) {
    let new_subs = ch.subscribers + [callback]
    return StreamChannel {
        buffer: ch.buffer,
        capacity: ch.capacity,
        high_watermark: ch.high_watermark,
        low_watermark: ch.low_watermark,
        blocked: ch.blocked,
        cancelled: ch.cancelled,
        closed: ch.closed,
        subscribers: new_subs,
        produced: ch.produced,
        consumed: ch.consumed,
        dropped: ch.dropped,
        block_events: ch.block_events,
        last_delta: ch.last_delta,
        notify_count: ch.notify_count,
        history: ch.history
    }
}

fn channel_notify(ch, tok_str) {
    let n = len(ch.subscribers)
    let mut i = 0
    while i < n {
        let cb = ch.subscribers[i]
        cb(tok_str)
        i = i + 1
    }
    let new_ch = StreamChannel {
        buffer: ch.buffer,
        capacity: ch.capacity,
        high_watermark: ch.high_watermark,
        low_watermark: ch.low_watermark,
        blocked: ch.blocked,
        cancelled: ch.cancelled,
        closed: ch.closed,
        subscribers: ch.subscribers,
        produced: ch.produced,
        consumed: ch.consumed,
        dropped: ch.dropped,
        block_events: ch.block_events,
        last_delta: tok_str,
        notify_count: ch.notify_count + 1,
        history: ch.history
    }
    return [n, new_ch]
}

// ===================================================================
//  channel_stats — snapshot counters
// ===================================================================
fn channel_stats(ch) {
    return [ch.produced, ch.consumed, ch.dropped, ch.block_events]
}

// ===================================================================
//  Partial decode (incremental detokenize)
//
//  StreamDecoder: byte-level detokenizer that accumulates token ids
//  and emits the newly visible string slice as deltas. Works with the
//  byte_tokenize()/token_to_str() scheme used in self/ml/streaming.hexa
//  (token_id = byte_value + 3, EOS = 2, BOS = 1).
// ===================================================================
struct StreamDecoder {
    pending: string,    // accumulated raw bytes as string
    emitted: string,    // total text handed to the consumer so far
    token_count: int,   // token ids consumed
    eos_seen: bool
}

fn create_decoder() {
    return StreamDecoder {
        pending: "",
        emitted: "",
        token_count: 0,
        eos_seen: false
    }
}

fn sg_token_to_str(token_id) {
    if token_id <= 2 { return "" }
    let byte_val = token_id - 3
    if byte_val >= 32 {
        if byte_val < 127 {
            return chr(byte_val)
        }
    }
    return "?"
}

// decoder_feed — push a single token id. Returns [delta_string, new_decoder]
fn decoder_feed(dec, token_id) {
    if token_id == 2 {
        let eos_dec = StreamDecoder {
            pending: dec.pending,
            emitted: dec.emitted,
            token_count: dec.token_count + 1,
            eos_seen: true
        }
        return ["", eos_dec]
    }
    let piece = sg_token_to_str(token_id)
    let new_pending = dec.pending + piece
    let new_emitted = dec.emitted + piece
    let new_dec = StreamDecoder {
        pending: "",
        emitted: new_emitted,
        token_count: dec.token_count + 1,
        eos_seen: dec.eos_seen
    }
    return [piece, new_dec]
}

// decoder_flush — drain pending bytes (no-op for byte-level scheme)
fn decoder_flush(dec) {
    let flushed = dec.pending
    let new_dec = StreamDecoder {
        pending: "",
        emitted: dec.emitted + flushed,
        token_count: dec.token_count,
        eos_seen: dec.eos_seen
    }
    return [flushed, new_dec]
}

// ===================================================================
//  stream_generate — high-level producer loop
//
//  Because Hexa lambdas capture by value, we drive the producer with
//  an explicit token_ids array + starting src_pos instead of a
//  closure source. Drain is built-in: on backpressure we pop one
//  element from the channel ourselves (dropping its value) until
//  the push admits.
//
//  Inputs:
//    ch          initial StreamChannel
//    dec         initial StreamDecoder
//    token_ids   array of token ids; EOS (2) terminates, -1 aborts
//    max_tokens  hard cap on admitted tokens
//
//  Behavior:
//    - Walks token_ids from index 0 up to max_tokens or array end.
//    - Pushes each admitted token into channel.
//    - On backpressure (push returns false with blocked flag), pops
//      one element from the channel and retries. After buffer falls
//      to or below low_watermark the next push succeeds.
//    - Respects cancel: drops remaining work, returns summary.
//    - Notifies subscribers with the decoded delta for each admitted
//      token (via channel_notify which also updates last_delta).
//
//  Returns [final_channel, final_decoder, summary]
//    summary: [admitted, blocked, cancelled, eos]
//      admitted  : int — tokens successfully pushed
//      blocked   : int — total backpressure events observed
//      cancelled : bool
//      eos       : bool
// ===================================================================
fn stream_generate(ch, dec, token_ids, max_tokens) {
    let mut cur_ch = ch
    let mut cur_dec = dec
    let mut admitted = 0
    let mut blocked = 0
    let mut cancelled = false
    let mut eos = false
    let mut src_pos = 0
    let src_len = len(token_ids)
    let mut done = false

    // @partial — Stage 0: pre-witness acknowledgement
    while done == false {
        if cur_ch.cancelled {
            cancelled = true
            done = true
        } else {
            if admitted >= max_tokens {
                done = true
            } else {
                if src_pos >= src_len {
                    done = true
                } else {
                    let tok = token_ids[src_pos]
                    src_pos = src_pos + 1
                    if tok == 2 {
                        // EOS
                        eos = true
                        cur_ch = channel_close(cur_ch)
                        done = true
                    } else {
                        if tok < 0 {
                            // producer requested abort
                            cancelled = true
                            cur_ch = channel_cancel(cur_ch)
                            done = true
                        } else {
                            // Backpressure loop: pop until push admits
                            let mut push_ok = false
                            let mut retry = 0
                            // @partial — Stage 0: pre-witness acknowledgement
                            while push_ok == false {
                                let res = channel_push(cur_ch, tok)
                                push_ok = res[0]
                                cur_ch = res[1]
                                if push_ok == false {
                                    blocked = blocked + 1
                                    // Drain one element
                                    let pr = channel_pop(cur_ch)
                                    if pr[0] == true {
                                        cur_ch = pr[2]
                                    }
                                    retry = retry + 1
                                    if retry > cur_ch.capacity + 4 {
                                        cancelled = true
                                        cur_ch = channel_cancel(cur_ch)
                                        push_ok = true
                                    }
                                } else {
                                    admitted = admitted + 1
                                    let fed = decoder_feed(cur_dec, tok)
                                    let delta = fed[0]
                                    cur_dec = fed[1]
                                    let nres = channel_notify(cur_ch, delta)
                                    cur_ch = nres[1]
                                }
                            }
                        }
                    }
                }
            }
        }
    }

    return [cur_ch, cur_dec, [admitted, blocked, cancelled, eos]]
}

println("[streaming_gen] module loaded")


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

println("===================================================================")
println("  Streaming Generation (#70) Test Suite")
println("===================================================================")

// ===================================================================
//  T1: create_channel basic invariants
// ===================================================================
let ch0 = create_channel(10, 8, 3)
check("T1 capacity=10",      ch0.capacity == 10)
check("T1 high_watermark=8", ch0.high_watermark == 8)
check("T1 low_watermark=3",  ch0.low_watermark == 3)
check("T1 initial empty",    channel_len(ch0) == 0)
check("T1 not cancelled",    channel_is_cancelled(ch0) == false)

// ===================================================================
//  T2: push / pop FIFO ordering
// ===================================================================
let r1 = channel_push(ch0, 10)
let ch1 = r1[1]
let r2 = channel_push(ch1, 20)
let ch2 = r2[1]
let r3 = channel_push(ch2, 30)
let ch3 = r3[1]
check("T2 push1 ok",    r1[0] == true)
check("T2 push2 ok",    r2[0] == true)
check("T2 push3 ok",    r3[0] == true)
check("T2 len after 3 pushes", channel_len(ch3) == 3)

let p1 = channel_pop(ch3)
check("T2 pop1 ok",       p1[0] == true)
check("T2 pop1 FIFO=10",  p1[1] == 10)
let p2 = channel_pop(p1[2])
check("T2 pop2 FIFO=20",  p2[1] == 20)
let p3 = channel_pop(p2[2])
check("T2 pop3 FIFO=30",  p3[1] == 30)
let p_empty = channel_pop(p3[2])
check("T2 pop empty = !ok", p_empty[0] == false)

// ===================================================================
//  T3: high watermark backpressure
// ===================================================================
// capacity=5, high=3, low=1 — push 3 fills, 4th blocks
let chA = create_channel(5, 3, 1)
let a1 = channel_push(chA, 1)
let a2 = channel_push(a1[1], 2)
let a3 = channel_push(a2[1], 3)
check("T3 push up to high ok",  a3[0] == true)
check("T3 len=3 at high",       channel_len(a3[1]) == 3)
check("T3 is_full at high",     channel_is_full(a3[1]) == true)

let a4 = channel_push(a3[1], 4)
check("T3 4th push rejected",      a4[0] == false)
check("T3 blocked flag set",       channel_is_blocked(a4[1]) == true)
check("T3 block_events incremented", a4[1].block_events == 1)
check("T3 len unchanged on block",   channel_len(a4[1]) == 3)

// ===================================================================
//  T4: low watermark unblock on drain
// ===================================================================
// After draining from 3 down to 1 (low), blocked flag should clear.
let d1 = channel_pop(a4[1])
let d2 = channel_pop(d1[2])
check("T4 after 2 pops len=1 (low)",   channel_len(d2[2]) == 1)
check("T4 is_drained at low",          channel_is_drained(d2[2]) == true)
check("T4 blocked cleared after drain", channel_is_blocked(d2[2]) == false)

// ===================================================================
//  T5: try_push drops on capacity overflow
// ===================================================================
// capacity=2, high=2, low=1
let chB = create_channel(2, 2, 1)
let t1 = channel_try_push(chB, 100)
let t2 = channel_try_push(t1[1], 200)
let t3 = channel_try_push(t2[1], 300)
check("T5 try_push1 ok", t1[0] == true)
check("T5 try_push2 ok", t2[0] == true)
check("T5 try_push3 dropped", t3[0] == false)
check("T5 dropped counter = 1", t3[1].dropped == 1)

// ===================================================================
//  T6: cancel aborts push
// ===================================================================
let chC = create_channel(10, 8, 3)
let cc = channel_cancel(chC)
check("T6 cancelled flag set", channel_is_cancelled(cc) == true)
let cp = channel_push(cc, 42)
check("T6 push on cancelled = false", cp[0] == false)
let ct = channel_try_push(cc, 42)
check("T6 try_push on cancelled = false", ct[0] == false)

// ===================================================================
//  T7: close prevents push but not pop
// ===================================================================
let chD = create_channel(10, 8, 3)
let d_push = channel_push(chD, 7)
let d_closed = channel_close(d_push[1])
check("T7 closed flag", channel_is_closed(d_closed) == true)
let d_after_close = channel_push(d_closed, 8)
check("T7 push after close = false", d_after_close[0] == false)
let d_pop = channel_pop(d_closed)
check("T7 pop after close still ok", d_pop[0] == true)
check("T7 pop value = 7",             d_pop[1] == 7)

// ===================================================================
//  T8: subscriber fan-out
//
//  NOTE: Hexa closures capture by value → cannot mutate outer state.
//  We inspect the returned channel's last_delta / notify_count fields.
// ===================================================================
let cbA = |s| { return s }
let cbB = |s| { return s + "!" }
let chE = create_channel(10, 8, 3)
let chE1 = channel_subscribe(chE, cbA)
let chE2 = channel_subscribe(chE1, cbB)
check("T8 subscribe count=2",  len(chE2.subscribers) == 2)
let nres1 = channel_notify(chE2, "hello")
check("T8 fan-out count = 2",  nres1[0] == 2)
check("T8 last_delta=hello",   nres1[1].last_delta == "hello")
check("T8 notify_count=1",     nres1[1].notify_count == 1)
let nres2 = channel_notify(nres1[1], "world")
check("T8 second fan-out = 2", nres2[0] == 2)
check("T8 last_delta=world",   nres2[1].last_delta == "world")
check("T8 notify_count=2",     nres2[1].notify_count == 2)

// ===================================================================
//  T9: stats counters
// ===================================================================
let chF = create_channel(5, 3, 1)
let f1 = channel_push(chF, 1)
let f2 = channel_push(f1[1], 2)
let f3 = channel_push(f2[1], 3)
let f4 = channel_push(f3[1], 4)   // blocked (len=3 == high)
let fp = channel_pop(f3[1])        // consume 1
let stats = channel_stats(fp[2])
check("T9 produced = 3",  stats[0] == 3)
check("T9 consumed = 1",  stats[1] == 1)
check("T9 dropped  = 0",  stats[2] == 0)
// block_events on fp[2] is 0 because we used f3[1] for the pop path.
// Verify block_events on the rejected branch f4[1].
check("T9 block_events=1 on rejected branch", f4[1].block_events == 1)

// ===================================================================
//  T10: partial decoder feed deltas
// ===================================================================
let dec0 = create_decoder()
// 'H' = 72 → token_id = 75
// 'i' = 105 → token_id = 108
let fd_h = decoder_feed(dec0, 75)
let dec1 = fd_h[1]
check("T10 feed 'H' delta", fd_h[0] == "H")
check("T10 emitted='H'",    dec1.emitted == "H")

let fd_i = decoder_feed(dec1, 108)
let dec2 = fd_i[1]
check("T10 feed 'i' delta", fd_i[0] == "i")
check("T10 emitted='Hi'",   dec2.emitted == "Hi")
check("T10 token_count=2",  dec2.token_count == 2)

// ===================================================================
//  T11: decoder EOS marker
// ===================================================================
let fd_eos = decoder_feed(dec2, 2)
let dec_eos = fd_eos[1]
check("T11 EOS delta empty", fd_eos[0] == "")
check("T11 eos_seen=true",   dec_eos.eos_seen == true)
check("T11 emitted stable",  dec_eos.emitted == "Hi")

// ===================================================================
//  T12: stream_generate happy path
//
//  Token list: 'A'=65→68, 'B'=66→69, 'C'=67→70, then EOS=2
//  Expected: admitted=3, eos=true, decoder emitted="ABC".
// ===================================================================
let src_list = [68, 69, 70, 2]
let cb_pt = |s| { return s }
let ch_g = create_channel(10, 8, 3)
let ch_g1 = channel_subscribe(ch_g, cb_pt)
let dec_g = create_decoder()

let out = stream_generate(ch_g1, dec_g, src_list, 16)
let summary = out[2]
let ch_g_final = out[0]
let dec_g_final = out[1]
check("T12 admitted=3",         summary[0] == 3)
check("T12 blocked=0",          summary[1] == 0)
check("T12 cancelled=false",    summary[2] == false)
check("T12 eos=true",           summary[3] == true)
check("T12 decoder emitted=ABC", dec_g_final.emitted == "ABC")
check("T12 last_delta=C",       ch_g_final.last_delta == "C")
check("T12 history len=3",      len(ch_g_final.history) == 3)
check("T12 channel closed",     channel_is_closed(ch_g_final) == true)

// ===================================================================
//  T13: stream_generate backpressure + drain loop
//
//  Small channel (capacity=3, high=2, low=1) forces backpressure.
//  Built-in drain pops one element on each block.
// ===================================================================
let src_list2 = [68, 69, 70, 71, 72, 2]   // 'A'..'E' + EOS
let ch_bp = create_channel(3, 2, 1)
let ch_bp1 = channel_subscribe(ch_bp, cb_pt)
let dec_bp = create_decoder()

let out2 = stream_generate(ch_bp1, dec_bp, src_list2, 32)
let sum2 = out2[2]
let dec_bp_final = out2[1]
check("T13 all 5 admitted",         sum2[0] == 5)
check("T13 at least one blocked",   sum2[1] >= 1)
check("T13 eos reached",            sum2[3] == true)
check("T13 decoder emitted=ABCDE",  dec_bp_final.emitted == "ABCDE")

// ===================================================================
//  T14: stream_generate cancel short-circuit
//
//  token_ids contains -1 at index 1 → channel cancelled mid-stream.
// ===================================================================
let c_list = [68, -1, 70, 2]
let ch_c = create_channel(10, 8, 3)
let dec_c = create_decoder()
let out3 = stream_generate(ch_c, dec_c, c_list, 16)
let sum3 = out3[2]
let ch_c_final = out3[0]
check("T14 admitted=1 before cancel", sum3[0] == 1)
check("T14 cancelled=true",           sum3[2] == true)
check("T14 channel cancelled flag",   channel_is_cancelled(ch_c_final) == true)

// ===================================================================
//  Summary
// ===================================================================
println("===================================================================")
println("  Results: " + str(pass_count) + " passed / " + str(fail_count) + " failed")
println("===================================================================")

if fail_count > 0 {
    exit(1)
}
