// ═══════════════════════════════════════════════════════════════
//  test_simd_parallel_bench.hexa
//  Comprehensive @simd / @parallel codegen verification + benchmarks
//
//  Tests:
//    Section 1 — C codegen pragma verification (build_c.hexa)
//    Section 2 — Functional correctness (vector ops, matrix mul)
//    Section 3 — ai_native_pass attribute detection
//    Section 4 — Edge cases
//    Section 5 — Performance benchmarks
//
//  Usage: ./hexa self/test_simd_parallel_bench.hexa
// ═══════════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn check_eq(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " expected=" + to_string(expected) + " got=" + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn contains(haystack, needle) {
    let hlen = haystack.len()
    let nlen = needle.len()
    if nlen > hlen { return false }
    let mut i = 0
    while i <= hlen - nlen {
        if haystack.substring(i, i + nlen) == needle { return true }
        i = i + 1
    }
    return false
}

fn not_contains(haystack, needle) {
    return !contains(haystack, needle)
}

// count occurrences of needle in haystack
fn count_occurrences(haystack, needle) {
    let hlen = haystack.len()
    let nlen = needle.len()
    if nlen > hlen { return 0 }
    let mut count = 0
    let mut i = 0
    while i <= hlen - nlen {
        if haystack.substring(i, i + nlen) == needle {
            count = count + 1
            i = i + nlen
        } else {
            i = i + 1
        }
    }
    return count
}

println("═══════════════════════════════════════════════════════════════")
println("  @simd / @parallel — Codegen Verification & Benchmarks")
println("═══════════════════════════════════════════════════════════════")
println("")

