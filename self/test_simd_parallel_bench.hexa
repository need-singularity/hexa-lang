// Section 3: Attribute Classification & Conflict Detection
// (Mirrors ai_native_pass.hexa logic — tested in-process)
// ═══════════════════════════════════════════════════════════════

println("--- Section 3: Attribute Classification & Conflict Detection ---")
println("")

// 3a. Classify attrs (mirrors classify_attr_m0)
fn classify_attr(name) {
    if name == "optimize" { return "G1" }
    if name == "memoize" { return "G1" }
    if name == "pure" { return "G1" }
    if name == "inline" { return "G1" }
    if name == "hot" { return "G1" }
    if name == "cold" { return "G1" }
    if name == "parallel" { return "G3" }
    if name == "simd" { return "G3" }
    if name == "gpu" { return "G3" }
    if name == "test" { return "G4" }
    if name == "bench" { return "G4" }
    return "unknown"
}

check_eq("3a: @parallel is G3", classify_attr("parallel"), "G3")
check_eq("3a: @simd is G3", classify_attr("simd"), "G3")
check_eq("3a: @gpu is G3", classify_attr("gpu"), "G3")
check_eq("3a: @pure is G1", classify_attr("pure"), "G1")
check_eq("3a: @inline is G1", classify_attr("inline"), "G1")
check_eq("3a: @test is G4", classify_attr("test"), "G4")

// 3b. Attr conflict detection (mirrors find_attr_conflict)
fn attr_has_local(attrs, target) {
    let n = len(attrs)
    let mut i = 0
    while i < n {
        if attrs[i] == target { return true }
        i = i + 1
    }
    return false
}

fn find_conflict(attrs) {
    if attr_has_local(attrs, "hot") && attr_has_local(attrs, "cold") {
        return "hot+cold"
    }
    if attr_has_local(attrs, "inline") && attr_has_local(attrs, "cold") {
        return "inline+cold"
    }
    if attr_has_local(attrs, "pure") && attr_has_local(attrs, "evolve") {
        return "pure+evolve"
    }
    return ""
}

check_eq("3b: hot+cold conflict", find_conflict(["hot", "cold"]), "hot+cold")
check_eq("3b: inline+cold conflict", find_conflict(["inline", "cold"]), "inline+cold")
check_eq("3b: pure+evolve conflict", find_conflict(["pure", "evolve"]), "pure+evolve")
check_eq("3b: no conflict simd+parallel", find_conflict(["simd", "parallel"]), "")
check_eq("3b: no conflict pure+inline", find_conflict(["pure", "inline"]), "")
check_eq("3b: no conflict simd alone", find_conflict(["simd"]), "")

// 3c. fn_has_attr simulation (mirrors build_c.hexa fn_has_attr)
fn fn_has_attr_sim(op_str, name) {
    if op_str == "" { return false }
    if op_str == name { return true }
    let parts = op_str.split(",")
    let mut k = 0
    while k < len(parts) {
        if parts[k] == name { return true }
        k = k + 1
    }
    return false
}

check("3c: fn_has_attr 'parallel' in 'parallel'", fn_has_attr_sim("parallel", "parallel"))
check("3c: fn_has_attr 'simd' in 'simd'", fn_has_attr_sim("simd", "simd"))
check("3c: fn_has_attr 'simd' in 'parallel,simd'", fn_has_attr_sim("parallel,simd", "simd"))
check("3c: fn_has_attr 'parallel' in 'parallel,simd'", fn_has_attr_sim("parallel,simd", "parallel"))
check("3c: fn_has_attr no 'gpu' in 'parallel,simd'", !fn_has_attr_sim("parallel,simd", "gpu"))
check("3c: fn_has_attr empty op", !fn_has_attr_sim("", "simd"))

// 3d. Hardware attr validation: @simd/@parallel require loops
// (In ai_native_pass M8, body_has_loop checks for While/ForRange)
check("3d: @simd on loop body is valid (codegen emits pragma)", contains(c_simd_for, "#pragma omp simd"))
check("3d: @parallel on loop body is valid (codegen emits pragma)", contains(c_par_for, "#pragma omp parallel for"))

// 3e. @simd/@parallel stats counting simulation
fn count_hw_attrs(fn_attrs_list) {
    // fn_attrs_list: array of arrays, each being attrs for one fn
    let mut simd_count = 0
    let mut par_count = 0
    let mut i = 0
    while i < len(fn_attrs_list) {
        let attrs = fn_attrs_list[i]
        if attr_has_local(attrs, "simd") { simd_count = simd_count + 1 }
        if attr_has_local(attrs, "parallel") { par_count = par_count + 1 }
        i = i + 1
    }
    return [simd_count, par_count]
}

let stats = count_hw_attrs([["simd"], ["parallel"], ["simd", "parallel"], []])
check_eq("3e: simd count = 2", stats[0], 2)
check_eq("3e: parallel count = 2", stats[1], 2)

println("")

