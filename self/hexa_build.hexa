// ═══════════════════════════════════════════════════════════
//  hexa_build.hexa — Self-Host Build Tool (Phase 5)
//  Usage: hexa ready/self/run_build.hexa <source.hexa> [output]
//  Pipeline: .hexa → lex → parse → type_check → codegen_c2 → .c → clang → native
// ═══════════════════════════════════════════════════════════

let argv = args()
if len(argv) < 2 {
    println("Usage: hexa run_build.hexa <source.hexa> [output]")
    println("")
    println("Compiles a .hexa file to native binary via C transpilation.")
    println("Requires clang or gcc in PATH.")
}

let source_file = argv[1]
let mut output_file = "/tmp/hexa_compiled"
if len(argv) >= 3 {
    output_file = argv[2]
}

println("═══ HEXA Self-Host Compiler ═══")
println("  Source: " + source_file)
println("  Output: " + output_file)
println("")

// Stage 1: Read source
let source = read_file(source_file)
println("[1/5] Read: " + to_string(len(source)) + " chars")

// Stage 2: Tokenize
let tokens = tokenize(source)
println("[2/5] Tokenized: " + to_string(len(tokens)) + " tokens")

// Stage 3: Parse
let ast = parse(tokens)
println("[3/5] Parsed: " + to_string(len(ast)) + " top-level statements")

// Stage 4: Generate C code
let c_code = codegen_c2(ast)
let c_file = output_file + ".c"
write_file(c_file, c_code)
println("[4/5] C generated: " + to_string(len(c_code)) + " chars → " + c_file)

// Stage 5: Compile with clang (fallback gcc)
let compile_cmd = "clang -O2 -I ready/self -lm " + c_file + " -o " + output_file + " 2>&1"
println("[5/5] Compiling: clang -O2 " + c_file)
let result = exec(compile_cmd)
if result.contains("error") {
    println("  ⚠ clang failed, trying gcc...")
    let gcc_cmd = "gcc -O2 -I ready/self -lm " + c_file + " -o " + output_file + " 2>&1"
    let gcc_result = exec(gcc_cmd)
    if gcc_result.contains("error") {
        println("  ✗ Build FAILED")
        println("  " + gcc_result.split("\n")[0])
    } else {
        println("  ✓ Built with gcc: " + output_file)
    }
} else {
    println("  ✓ Built: " + output_file)
}

println("")
println("Run: " + output_file)
