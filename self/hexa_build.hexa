// ═══════════════════════════════════════════════════════════
//  hexa_build.hexa — Self-Host Build Tool
//  Usage: hexa hexa_build.hexa <source.hexa> [output]
//  Compiles .hexa → .c → native binary via gcc
//  This is the Phase 5 self-hosting compiler entry point
// ═══════════════════════════════════════════════════════════

// The lexer, parser, and codegen are loaded before this file (via cat)

// Read command line arguments
// For now, hardcode a test
let source_file = "examples/fibonacci.hexa"
let output_file = "/tmp/hexa_compiled"

println("═══ HEXA Self-Host Compiler ═══")
println("Source: " + source_file)

// Stage 1: Read source
let source = read_file(source_file)
println("[1/4] Read: " + to_string(len(source)) + " chars")

// Stage 2: Tokenize
let tokens = tokenize(source)
println("[2/4] Tokenized: " + to_string(len(tokens)) + " tokens")

// Stage 3: Parse
let ast = parse(tokens)
println("[3/4] Parsed: " + to_string(len(ast)) + " statements")

// Stage 4: Generate C code
let c_code = codegen_c2(ast)
let c_file = output_file + ".c"
write_file(c_file, c_code)
println("[4/4] C generated: " + to_string(len(c_code)) + " chars → " + c_file)

// Stage 5: Compile with gcc
let cmd = "gcc -O2 -I ready/self " + c_file + " -o " + output_file
println("[5/5] Compiling: " + cmd)
let result = exec(cmd)
println("Build complete: " + output_file)
println("")
println("Run with: " + output_file)
