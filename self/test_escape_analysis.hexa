// =============================================================
//  test_escape_analysis.hexa -- Escape Analysis heap-to-stack
//  Tests: stack promotion for non-escaping objects (ROI id=19)
// =============================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("=============================================================")
println("  HEXA Escape Analysis Tests (ROI id=19)")
println("=============================================================")
println("")

// -- 1. Non-escaping local: should be stack-promoted --

println("--- Non-escaping locals ---")

fn local_only() {
    let arr = [1, 2, 3]
    let mut sum = 0
    let mut i = 0
    while i < len(arr) {
        sum = sum + arr[i]
        i = i + 1
    }
    return sum
}

check("local_only returns sum not array", local_only(), 6)

fn local_struct() {
    let p = #{"x": 10, "y": 20}
    return p["x"] + p["y"]
}

check("local_struct field sum", local_struct(), 30)

// -- 2. Escaping via return: should NOT be stack-promoted --

println("")
println("--- Escaping via return ---")

fn escaping_return() {
    let arr = [10, 20, 30]
    return arr
}

let esc_arr = escaping_return()
check("escaping_return preserves array", len(esc_arr), 3)
check("escaping_return value[0]", esc_arr[0], 10)
check("escaping_return value[2]", esc_arr[2], 30)

fn escaping_struct_return() {
    let p = #{"a": 100, "b": 200}
    return p
}

let esc_s = escaping_struct_return()
check("escaping_struct a", esc_s["a"], 100)
check("escaping_struct b", esc_s["b"], 200)

// -- 3. Multiple locals, mixed escaping --

println("")
println("--- Mixed escape patterns ---")

fn mixed_escape() {
    let local_arr = [1, 2, 3]
    let escape_arr = [4, 5, 6]
    let mut sum = 0
    let mut i = 0
    while i < len(local_arr) {
        sum = sum + local_arr[i]
        i = i + 1
    }
    return escape_arr
}

let mix_r = mixed_escape()
check("mixed_escape returns escape_arr", len(mix_r), 3)
check("mixed_escape value[0]", mix_r[0], 4)

// -- 4. Nested scope: local in loop --

println("")
println("--- Nested scope ---")

fn nested_local() {
    let mut total = 0
    let mut i = 0
    while i < 3 {
        let temp = [i * 10]
        total = total + temp[0]
        i = i + 1
    }
    return total
}

check("nested_local sum", nested_local(), 30)

// -- 5. Large non-escaping array --

println("")
println("--- Large non-escaping ---")

fn large_local() {
    let mut arr = []
    let mut i = 0
    while i < 100 {
        arr.push(i)
        i = i + 1
    }
    let mut sum = 0
    i = 0
    while i < len(arr) {
        sum = sum + arr[i]
        i = i + 1
    }
    return sum
}

check("large_local sum 0..99", large_local(), 4950)

// -- Summary --
println("")
println("=============================================================")
println("  Escape Analysis: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("=============================================================")
