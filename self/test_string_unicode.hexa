// ═══════════════════════════════════════════════════════════
//  test_string_unicode.hexa — Unicode / Multibyte String Tests
//  Tests: Korean (한글), Japanese (かな), emoji, mixed ASCII,
//         concat, equality, contains, repeat patterns
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_true(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA Unicode String Tests")
println("═══════════════════════════════════════════════════════")

// ── 1. Korean literals ──────────────────────────────────
let kr = "한글"
check("kr equal self", kr, "한글")
check_true("kr len > 0", len(kr) > 0)
let kr2 = "안녕하세요"
check("kr2 equal self", kr2, "안녕하세요")
check_true("kr2 len > 0", len(kr2) > 0)

// ── 2. Korean concat ─────────────────────────────────────
let hello_kr = "안녕" + " " + "세계"
check("kr concat", hello_kr, "안녕 세계")
check("kr + ascii", "hello " + "한글", "hello 한글")
check("ascii + kr", "한글 " + "hello", "한글 hello")

// ── 3. Japanese literals ─────────────────────────────────
let jp = "こんにちは"
check("jp equal self", jp, "こんにちは")
check_true("jp len > 0", len(jp) > 0)
let jp_mix = "Hello " + "こんにちは"
check("jp mixed", jp_mix, "Hello こんにちは")

// ── 4. Chinese literals ─────────────────────────────────
let cn = "你好"
check("cn equal self", cn, "你好")
check_true("cn len > 0", len(cn) > 0)
check("cn + world", cn + " world", "你好 world")

// ── 5. Emoji ─────────────────────────────────────────────
let em = "🔥"
check_true("emoji len > 0", len(em) > 0)
check("emoji equal", em, "🔥")
let fire_rocket = "🔥🚀"
check("two emoji", fire_rocket, "🔥🚀")
check_true("two emoji len > single", len(fire_rocket) > len(em))

// ── 6. Mixed ascii+emoji+kr ──────────────────────────────
let mixed = "hi 한글 🔥"
check("mixed", mixed, "hi 한글 🔥")
check_true("mixed len > 0", len(mixed) > 5)

// ── 7. Equality ──────────────────────────────────────────
check_true("kr eq", "한글" == "한글")
check_true("kr neq", "한글" != "한국")
check_true("jp eq", "さくら" == "さくら")
check_true("emoji eq", "✨" == "✨")
check_true("emoji neq", "✨" != "⭐")

// ── 8. Empty vs unicode ─────────────────────────────────
check("empty+kr", "" + "한", "한")
check("kr+empty", "한" + "", "한")
check_true("empty len 0", len("") == 0)

// ── 9. Concat chain ──────────────────────────────────────
let chain = "a" + "한" + "b" + "글" + "c"
check("concat chain", chain, "a한b글c")

// ── 10. String in array ──────────────────────────────────
let arr = ["한", "글", "🔥"]
check("arr[0]", arr[0], "한")
check("arr[1]", arr[1], "글")
check("arr[2]", arr[2], "🔥")
check("arr len", len(arr), 3)

// ── 11. Nested unicode in loop ───────────────────────────
let mut joined = ""
for s in ["안", "녕", "!"] {
    joined = joined + s
}
check("loop join", joined, "안녕!")

// ── 12. Repeat via concat ────────────────────────────────
let mut r = ""
let mut i = 0
while i < 5 {
    r = r + "한"
    i = i + 1
}
check("repeat han 5x", r, "한한한한한")

// ── 13. Compare sorting order (lexical) ─────────────────
check_true("a < 한", "a" < "한")
check_true("한 > a", "한" > "a")

// ── 14. Unicode in map key-like contexts ────────────────
let keys = ["한글", "영어", "日本語"]
let mut found = false
for k in keys {
    if k == "영어" { found = true }
}
check("find korean key", found, true)

// ── 15. to_string preserves unicode ──────────────────────
check("to_string kr", to_string("한글"), "한글")
check("to_string emoji", to_string("🔥"), "🔥")
check("to_string mixed", to_string("a한b"), "a한b")

// ── 16. Long unicode string ──────────────────────────────
let long_kr = "가나다라마바사아자차카타파하"
check("long kr self", long_kr, "가나다라마바사아자차카타파하")
check_true("long kr len > 10", len(long_kr) > 10)

// ── 17. Special whitespace still ASCII ──────────────────
check("tab-ish", "a\tb", "a\tb")
check("newline-ish", "a\nb", "a\nb")

println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")
