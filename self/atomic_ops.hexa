// self/atomic_ops.hexa — HEXA atomic operations ported from src/atomic_ops.rs
// Provides atomic_new, atomic_load, atomic_store, atomic_cas, atomic_add, atomic_sub
// In pure Hexa: simulates atomics via mutable structs (no real hardware atomics).

// ── Atomic value container ──

struct AtomicValue {
    tag: string,       // "int" | "bool"
    int_val: int,
    bool_val: bool
}

fn atomic_value_new_int(val: int) -> AtomicValue {
    return AtomicValue { tag: "int", int_val: val, bool_val: false }
}

fn atomic_value_new_bool(val: bool) -> AtomicValue {
    return AtomicValue { tag: "bool", int_val: 0, bool_val: val }
}

fn atomic_value_load(self: AtomicValue) -> string {
    if self.tag == "int" {
        return str(self.int_val)
    }
    return str(self.bool_val)
}

fn atomic_value_load_int(self: AtomicValue) -> int {
    return self.int_val
}

fn atomic_value_load_bool(self: AtomicValue) -> bool {
    return self.bool_val
}

fn atomic_value_store(self: AtomicValue, tag: string, int_val: int, bool_val: bool) -> AtomicValue {
    if self.tag != tag {
        panic("atomic_store: type mismatch")
    }
    if tag == "int" {
        return AtomicValue { tag: "int", int_val: int_val, bool_val: false }
    }
    return AtomicValue { tag: "bool", int_val: 0, bool_val: bool_val }
}

fn atomic_value_compare_and_swap_int(self: AtomicValue, expected: int, desired: int) -> AtomicValue {
    // Returns new AtomicValue; caller checks old value
    if self.tag != "int" {
        panic("atomic_cas: type mismatch")
    }
    if self.int_val == expected {
        return AtomicValue { tag: "int", int_val: desired, bool_val: false }
    }
    return self
}

fn atomic_value_fetch_add(self: AtomicValue, val: int) -> AtomicValue {
    if self.tag != "int" {
        panic("atomic_add: only supported for integers")
    }
    return AtomicValue { tag: "int", int_val: self.int_val + val, bool_val: false }
}

fn atomic_value_fetch_sub(self: AtomicValue, val: int) -> AtomicValue {
    if self.tag != "int" {
        panic("atomic_sub: only supported for integers")
    }
    return AtomicValue { tag: "int", int_val: self.int_val - val, bool_val: false }
}

fn atomic_value_clone(self: AtomicValue) -> AtomicValue {
    return AtomicValue { tag: self.tag, int_val: self.int_val, bool_val: self.bool_val }
}

// ── Builtin function dispatch ──

fn exec_atomic_builtin(name: string, args: [string]) -> string {
    if name == "atomic_new" {
        if len(args) != 1 {
            panic("atomic_new: expected 1 argument")
        }
        return "atomic:" + args[0]
    }
    if name == "atomic_load" {
        if len(args) != 1 {
            panic("atomic_load: expected 1 argument")
        }
        return args[0]
    }
    if name == "atomic_store" {
        if len(args) != 2 {
            panic("atomic_store: expected 2 arguments (atomic, value)")
        }
        return "void"
    }
    if name == "atomic_cas" {
        if len(args) != 3 {
            panic("atomic_cas: expected 3 arguments")
        }
        return "[true," + args[0] + "]"
    }
    if name == "atomic_add" {
        if len(args) != 2 {
            panic("atomic_add: expected 2 arguments")
        }
        return args[0]
    }
    if name == "atomic_sub" {
        if len(args) != 2 {
            panic("atomic_sub: expected 2 arguments")
        }
        return args[0]
    }
    panic("unknown atomic operation: " + name)
    return ""
}

fn is_atomic_builtin(name: string) -> bool {
    if name == "atomic_new" { return true }
    if name == "atomic_load" { return true }
    if name == "atomic_store" { return true }
    if name == "atomic_cas" { return true }
    if name == "atomic_add" { return true }
    if name == "atomic_sub" { return true }
    return false
}
