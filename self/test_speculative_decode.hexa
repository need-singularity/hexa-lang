// test_speculative_decode.hexa — tests for pure Hexa speculative decoding
import "ml/speculative_decode.hexa"

let mut pass = 0
let mut fail = 0

fn check(name, cond) {
    if cond {
        pass = pass + 1
    } else {
        fail = fail + 1
        println("[FAIL] " + name)
    }
}

fn eq(name, a, b) {
    if a == b {
        pass = pass + 1
    } else {
        fail = fail + 1
        println("[FAIL] " + name + " got " + to_string(a) + " want " + to_string(b))
    }
}

fn approx(name, a, b, tol) {
    let diff = a - b
    let adiff = if diff < 0.0 { 0.0 - diff } else { diff }
    if adiff < tol {
        pass = pass + 1
    } else {
        fail = fail + 1
        println("[FAIL] " + name + " got " + to_string(a) + " want " + to_string(b) + " tol " + to_string(tol))
    }
}

println("=== speculative_decode test suite ===")

// ────────────────────────────────────────────────────────────
// 1. softmax
// ────────────────────────────────────────────────────────────
let sm1 = softmax([1.0, 2.0, 3.0])
eq("softmax len", len(sm1), 3)
let sm1_sum = sm1[0] + sm1[1] + sm1[2]
approx("softmax sum=1", sm1_sum, 1.0, 0.0001)
check("softmax order", sm1[2] > sm1[1] && sm1[1] > sm1[0])

let sm2 = softmax([0.0, 0.0, 0.0, 0.0])
approx("softmax uniform", sm2[0], 0.25, 0.0001)

let sm3 = softmax([])
eq("softmax empty", len(sm3), 0)

let sm4 = softmax([1000.0, 1001.0, 999.0])
let sm4_sum = sm4[0] + sm4[1] + sm4[2]
approx("softmax large stable", sm4_sum, 1.0, 0.0001)
check("softmax large peak", sm4[1] > sm4[0] && sm4[0] > sm4[2])

// ────────────────────────────────────────────────────────────
// 2. argmax
// ────────────────────────────────────────────────────────────
eq("argmax basic", argmax([0.1, 0.5, 0.3, 0.1]), 1)
eq("argmax first", argmax([9.0, 1.0, 2.0]), 0)
eq("argmax last", argmax([1.0, 2.0, 9.0]), 2)
eq("argmax single", argmax([42.0]), 0)

// ────────────────────────────────────────────────────────────
// 3. sample_categorical
// ────────────────────────────────────────────────────────────
eq("sample cat 0.0", sample_categorical([0.5, 0.3, 0.2], 0.0), 0)
eq("sample cat 0.49", sample_categorical([0.5, 0.3, 0.2], 0.49), 0)
eq("sample cat 0.51", sample_categorical([0.5, 0.3, 0.2], 0.51), 1)
eq("sample cat 0.79", sample_categorical([0.5, 0.3, 0.2], 0.79), 1)
eq("sample cat 0.81", sample_categorical([0.5, 0.3, 0.2], 0.81), 2)
eq("sample cat 0.99", sample_categorical([0.5, 0.3, 0.2], 0.99), 2)
eq("sample cat single", sample_categorical([1.0], 0.5), 0)

// ────────────────────────────────────────────────────────────
// 4. mock models
// ────────────────────────────────────────────────────────────
let draft = mock_draft_model(16)
let verify = mock_verify_model(16)
eq("draft type", draft["type"], "draft")
eq("verify type", verify["type"], "verify")
eq("draft vocab", draft["vocab_size"], 16)

let dl = model_logits(draft, [1, 2, 3])
eq("draft logits len", len(dl), 16)
let vl = model_logits(verify, [1, 2, 3])
eq("verify logits len", len(vl), 16)

// ────────────────────────────────────────────────────────────
// 5. spec_decode_step
// ────────────────────────────────────────────────────────────
let prefix = [1, 2, 3, 4, 5]
let step_result = spec_decode_step(draft, verify, prefix, 4)
check("step result len >= 1", len(step_result) >= 1)
check("step result len <= k+1", len(step_result) <= 5)

let mut all_valid = true
let mut si = 0
while si < len(step_result) {
    if step_result[si] < 0 || step_result[si] >= 16 {
        all_valid = false
    }
    si = si + 1
}
check("step tokens valid range", all_valid)

// ────────────────────────────────────────────────────────────
// 6. spec_decode_loop
// ────────────────────────────────────────────────────────────
let loop_result = spec_decode_loop(draft, verify, [1, 2, 3], 10, 4)
eq("loop produces max_tokens", len(loop_result), 10)

let mut all_loop_valid = true
let mut li = 0
while li < len(loop_result) {
    if loop_result[li] < 0 || loop_result[li] >= 16 {
        all_loop_valid = false
    }
    li = li + 1
}
check("loop tokens valid range", all_loop_valid)

// ────────────────────────────────────────────────────────────
// 7. acceptance rate > 0
// ────────────────────────────────────────────────────────────
let mut total_accepted = 0
let mut total_drafted = 0
let mut cur_prefix = [1, 2, 3]
let mut ri = 0
while ri < 10 {
    let tokens = spec_decode_step(draft, verify, cur_prefix, 4)
    total_accepted = total_accepted + len(tokens)
    total_drafted = total_drafted + 4
    let mut ti = 0
    while ti < len(tokens) {
        cur_prefix.push(tokens[ti])
        ti = ti + 1
    }
    ri = ri + 1
}
check("acceptance > 0", total_accepted > 0)
let rate = acceptance_rate(total_accepted, total_drafted)
println("  acceptance rate: " + to_string(rate) + "% (" + to_string(total_accepted) + "/" + to_string(total_drafted) + ")")
check("acceptance rate > 50%", rate > 50)

// ────────────────────────────────────────────────────────────
// 8. different prefix lengths
// ────────────────────────────────────────────────────────────
let short = spec_decode_step(draft, verify, [1], 2)
check("short prefix works", len(short) >= 1)
let empty_prefix = spec_decode_step(draft, verify, [], 2)
check("empty prefix works", len(empty_prefix) >= 1)

// ────────────────────────────────────────────────────────────
// 9. k=1 edge case
// ────────────────────────────────────────────────────────────
let k1_result = spec_decode_step(draft, verify, [1, 2, 3], 1)
check("k=1 produces 1-2 tokens", len(k1_result) >= 1 && len(k1_result) <= 2)

// ────────────────────────────────────────────────────────────
// 10. adaptive_k
// ────────────────────────────────────────────────────────────
eq("adaptive_k high rate", adaptive_k(4, 4, 4, 1, 10), 6)
eq("adaptive_k low rate", adaptive_k(4, 1, 4, 1, 10), 3)
eq("adaptive_k mid rate", adaptive_k(4, 3, 4, 1, 10), 4)
eq("adaptive_k clamp min", adaptive_k(1, 0, 4, 1, 10), 1)
eq("adaptive_k clamp max", adaptive_k(9, 9, 9, 1, 10), 10)

// ────────────────────────────────────────────────────────────
// 11. determinism — same input same output
// ────────────────────────────────────────────────────────────
let det1 = spec_decode_step(draft, verify, [7, 3, 1], 4)
let det2 = spec_decode_step(draft, verify, [7, 3, 1], 4)
eq("deterministic len match", len(det1), len(det2))
let mut det_match = true
let mut di = 0
while di < len(det1) && di < len(det2) {
    if det1[di] != det2[di] { det_match = false }
    di = di + 1
}
check("deterministic same tokens", det_match)

// ────────────────────────────────────────────────────────────
// 12. loop with larger token count
// ────────────────────────────────────────────────────────────
let big_loop = spec_decode_loop(draft, verify, [0], 50, 5)
eq("big loop len", len(big_loop), 50)

// ────────────────────────────────────────────────────────────
// 13. acceptance_rate calculation
// ────────────────────────────────────────────────────────────
eq("acceptance_rate 4/4=100", acceptance_rate(4, 4), 100)
eq("acceptance_rate 3/4=75", acceptance_rate(3, 4), 75)
eq("acceptance_rate 0/4=0", acceptance_rate(0, 4), 0)
eq("acceptance_rate 0/0=0", acceptance_rate(0, 0), 0)

println("")
println("=== speculative_decode: " + to_string(pass) + " passed, " + to_string(fail) + " failed ===")
if fail > 0 {
    exit(1)
}
