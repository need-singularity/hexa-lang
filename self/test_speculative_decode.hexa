// test_speculative_decode.hexa — @speculative_decode mock verification
import "ml/speculative_decode.hexa"

let mut pass = 0
let mut fail = 0

fn check(name, cond) {
    if cond {
        pass = pass + 1
        println("PASS " + name)
    } else {
        fail = fail + 1
        println("FAIL " + name)
    }
}

// ── Test 1: draft_generate length ──────────────────────────────
let ctx1 = [1, 2, 3, 4]
let d1 = draft_generate(ctx1, 4)
check("draft_generate len=4", len(d1) == 4)

// ── Test 2: target_verify length matches drafted ───────────────
let v1 = target_verify(ctx1, d1)
check("target_verify len matches", len(v1) == len(d1))

// ── Test 3: accept_prefix on identical arrays = full length ────
check("accept_prefix identical = k", accept_prefix(d1, d1) == 4)

// ── Test 4: accept_prefix on disjoint arrays ───────────────────
let a = [1, 2, 3, 4]
let b = [1, 2, 9, 4]
check("accept_prefix first mismatch at 2", accept_prefix(a, b) == 2)

// ── Test 5: full speculative_step — k=4, max=16 ────────────────
let ctx = [7, 3, 1, 5]
let result = speculative_step(ctx, 4, 16)
let out = result[0]
let td = result[1][0]
let ta = result[2][0]

println("out_len=" + to_string(len(out)))
println("total_drafted=" + to_string(td))
println("total_accepted=" + to_string(ta))

let mut ratio_x100 = 0
if td > 0 {
    ratio_x100 = (ta * 100) / td
}
println("accept_ratio_pct=" + to_string(ratio_x100))

check("produced >= 16 tokens", len(out) >= 16)
check("deterministic drafted=30", td == 30)
check("deterministic accepted=11", ta == 11)
check("accept_ratio ~36%", ratio_x100 == 36)

// ── Test 6: adaptive_k — high acceptance → k increases ─────────
let k_up = adaptive_k(4, 4, 4, 1, 16)
check("adaptive_k high acceptance → 6", k_up == 6)

// ── Test 7: adaptive_k — low acceptance → k decreases ──────────
let k_down = adaptive_k(4, 0, 4, 1, 16)
check("adaptive_k low acceptance → 3", k_down == 3)

// ── Test 8: adaptive_k — medium acceptance → k stays ───────────
let k_same = adaptive_k(4, 2, 4, 1, 16)
check("adaptive_k medium acceptance → 4", k_same == 4)

// ── Test 9: adaptive_k — clamp to max ──────────────────────────
let k_max_c = adaptive_k(15, 4, 4, 1, 16)
check("adaptive_k max clamp", k_max_c == 16)

// ── Test 10: adaptive_k — clamp to min ─────────────────────────
let k_min_c = adaptive_k(1, 0, 4, 1, 16)
check("adaptive_k min clamp", k_min_c == 1)

// ── Test 11: adaptive_k — zero drafted ─────────────────────────
let k_zero = adaptive_k(4, 0, 0, 1, 16)
check("adaptive_k zero drafted unchanged", k_zero == 4)

// ── Test 12: speculative_step_adaptive — produces output ───────
let ar = speculative_step_adaptive(ctx, 4, 16, 1, 16)
let ar_out = ar[0]
let ar_drafted = ar[1][0]
let ar_accepted = ar[2][0]
let ar_final_k = ar[3][0]
check("adaptive produced >= 16", len(ar_out) >= 16)
check("adaptive drafted > 0", ar_drafted > 0)
check("adaptive final_k in range", ar_final_k >= 1 && ar_final_k <= 16)
println("adaptive: tokens=" + to_string(len(ar_out)) + " drafted=" + to_string(ar_drafted) + " accepted=" + to_string(ar_accepted) + " final_k=" + to_string(ar_final_k))

// ── Test 13: acceptance_rate calculation ────────────────────────
check("acceptance_rate 4/4 = 100", acceptance_rate(4, 4) == 100)
check("acceptance_rate 3/4 = 75", acceptance_rate(3, 4) == 75)
check("acceptance_rate 0/4 = 0", acceptance_rate(0, 4) == 0)
check("acceptance_rate 0/0 = 0", acceptance_rate(0, 0) == 0)

// ── Test 14: speculative_batch — 3 contexts ────────────────────
let ctxs = [[1, 2, 3], [10, 20, 30], [5, 5, 5, 5]]
let batch_r = speculative_batch(ctxs, 4, 4)
check("batch len = 3", len(batch_r) == 3)
check("batch[0] output >= 4", len(batch_r[0][0]) >= 4)
check("batch[1] output >= 4", len(batch_r[1][0]) >= 4)
check("batch[2] output >= 4", len(batch_r[2][0]) >= 4)

// ── Test 15: determinism — same input → same output ────────────
let det1 = speculative_step([1, 2, 3], 4, 8)
let det2 = speculative_step([1, 2, 3], 4, 8)
check("deterministic output len", len(det1[0]) == len(det2[0]))
let mut det_match = true
let mut di = 0
while di < len(det1[0]) && di < len(det2[0]) {
    if det1[0][di] != det2[0][di] { det_match = false }
    di = di + 1
}
check("deterministic same tokens", det_match)

println("")
println("pass=" + to_string(pass) + " fail=" + to_string(fail))
if fail == 0 {
    println("ALL PASS")
} else {
    println("FAILED")
}
println(to_string(pass) + " passed")
