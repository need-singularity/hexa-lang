// test_speculative_decode.hexa — tests for pure Hexa speculative decoding
// Inlined from ml/speculative_decode.hexa (interpreter does not resolve imports at runtime)

// ═══════════════════════════════════════════════════════════════════
//  Inlined: speculative_decode.hexa core functions
// ═══════════════════════════════════════════════════════════════════

@pure
fn softmax(logits) {
    let n = len(logits)
    if n == 0 { return [] }
    let mut mx = logits[0]
    let mut i = 1
    while i < n {
        if logits[i] > mx { mx = logits[i] }
        i = i + 1
    }
    let mut probs = []
    let mut sum_e = 0.0
    i = 0
    while i < n {
        let e = exp(logits[i] - mx)
        probs.push(e)
        sum_e = sum_e + e
        i = i + 1
    }
    if sum_e > 0.0 {
        let inv = 1.0 / sum_e
        i = 0
        while i < n {
            probs[i] = probs[i] * inv
            i = i + 1
        }
    }
    return probs
}

@pure
fn argmax(arr) {
    let n = len(arr)
    if n == 0 { return 0 }
    let mut best_i = 0
    let mut best_v = arr[0]
    let mut i = 1
    while i < n {
        if arr[i] > best_v {
            best_v = arr[i]
            best_i = i
        }
        i = i + 1
    }
    return best_i
}

@pure
fn sample_categorical(probs, rand_val) {
    let n = len(probs)
    if n == 0 { return 0 }
    let mut cumsum = 0.0
    let mut i = 0
    while i < n {
        cumsum = cumsum + probs[i]
        if rand_val < cumsum {
            return i
        }
        i = i + 1
    }
    return n - 1
}

@pure
fn _ctx_hash_spec(ctx) {
    let n = len(ctx)
    let start = if n < 4 { 0 } else { n - 4 }
    let mut h = 2654435761
    let mut i = start
    while i < n {
        h = h ^ ((ctx[i] + 1) * (i + 7) * 1315423911)
        i = i + 1
    }
    return h
}

@pure
fn _pseudo_rand(seed) {
    let v = ((seed * 1103515245 + 12345) % 2147483647)
    let pos = if v < 0 { v + 2147483647 } else { v }
    return to_float(pos) / 2147483647.0
}

fn mock_draft_model(vocab_size) {
    let mut m = #{}
    m["type"] = "draft"
    m["vocab_size"] = vocab_size
    return m
}

fn mock_target_model(vocab_size) {
    let mut m = #{}
    m["type"] = "target"
    m["vocab_size"] = vocab_size
    return m
}

fn model_logits(model, prefix) {
    let vs = model["vocab_size"]
    let h = _ctx_hash_spec(prefix)
    let peak_token = h % vs
    let peak_pos = if peak_token < 0 { peak_token + vs } else { peak_token }
    let mut logits = []
    let mut i = 0
    while i < vs {
        if i == peak_pos {
            if model["type"] == "draft" {
                logits.push(5.0)
            } else {
                if (h % 5) == 0 {
                    logits.push(1.0)
                } else {
                    logits.push(5.0)
                }
            }
        } else if i == ((peak_pos + 1) % vs) {
            if model["type"] == "target" && (h % 5) == 0 {
                logits.push(5.0)
            } else {
                logits.push(0.5)
            }
        } else {
            logits.push(0.1)
        }
        i = i + 1
    }
    return logits
}

fn draft_logits_fn(model, prefix) {
    return model_logits(model, prefix)
}

fn target_logits_all(model, prefix, draft_tokens) {
    let k = len(draft_tokens)
    let mut results = []
    let mut cur = []
    let mut i = 0
    while i < len(prefix) {
        cur.push(prefix[i])
        i = i + 1
    }
    results.push(model_logits(model, cur))
    let mut j = 0
    while j < k {
        cur.push(draft_tokens[j])
        results.push(model_logits(model, cur))
        j = j + 1
    }
    return results
}

@speculative_decode
fn spec_decode_step(draft_model, target_model, prefix, k) {
    let vs = draft_model["vocab_size"]
    let mut draft_tokens = []
    let mut draft_logits_list = []
    let mut cur = []
    let mut i = 0
    while i < len(prefix) {
        cur.push(prefix[i])
        i = i + 1
    }
    let mut di = 0
    while di < k {
        let logits = draft_logits_fn(draft_model, cur)
        draft_logits_list.push(logits)
        let probs = softmax(logits)
        let token = argmax(probs)
        draft_tokens.push(token)
        cur.push(token)
        di = di + 1
    }
    let tgt_logits = target_logits_all(target_model, prefix, draft_tokens)
    let mut accepted = []
    let mut j = 0
    let mut rejected = false
    while j < k && !rejected {
        let draft_probs = softmax(draft_logits_list[j])
        let target_probs = softmax(tgt_logits[j])
        let t = draft_tokens[j]
        let p_draft = draft_probs[t]
        let p_big = target_probs[t]
        if p_big >= p_draft {
            accepted.push(t)
        } else {
            let accept_prob = if p_draft > 0.0 { p_big / p_draft } else { 0.0 }
            let r = _pseudo_rand(_ctx_hash_spec(prefix) + j * 7919 + t * 131)
            if r < accept_prob {
                accepted.push(t)
            } else {
                let mut adjusted = []
                let mut sum_adj = 0.0
                let mut ai = 0
                while ai < vs {
                    let diff = target_probs[ai] - draft_probs[ai]
                    let val = if diff > 0.0 { diff } else { 0.0 }
                    adjusted.push(val)
                    sum_adj = sum_adj + val
                    ai = ai + 1
                }
                if sum_adj > 0.0 {
                    let inv_adj = 1.0 / sum_adj
                    ai = 0
                    while ai < vs {
                        adjusted[ai] = adjusted[ai] * inv_adj
                        ai = ai + 1
                    }
                }
                let r2 = _pseudo_rand(_ctx_hash_spec(prefix) + j * 3571 + 997)
                let sampled = sample_categorical(adjusted, r2)
                accepted.push(sampled)
                rejected = true
            }
        }
        j = j + 1
    }
    if !rejected && len(accepted) == k {
        let bonus_probs = softmax(tgt_logits[k])
        let bonus_token = argmax(bonus_probs)
        accepted.push(bonus_token)
    }
    return accepted
}

fn spec_decode_loop(draft_model, target_model, prefix, max_tokens, k) {
    let mut cur = []
    let mut i = 0
    while i < len(prefix) {
        cur.push(prefix[i])
        i = i + 1
    }
    let mut generated = []
    while len(generated) < max_tokens {
        let remain = max_tokens - len(generated)
        let kk = if k < remain { k } else { remain }
        let tokens = spec_decode_step(draft_model, target_model, cur, kk)
        let mut ti = 0
        while ti < len(tokens) && len(generated) < max_tokens {
            cur.push(tokens[ti])
            generated.push(tokens[ti])
            ti = ti + 1
        }
        if len(tokens) == 0 { break }
    }
    return generated
}

fn adaptive_k(current_k, n_accepted, n_drafted, k_min, k_max) {
    if n_drafted == 0 { return current_k }
    let rate_pct = (n_accepted * 100) / n_drafted
    let mut new_k = current_k
    if rate_pct >= 80 {
        new_k = current_k + 2
    } else if rate_pct < 50 {
        new_k = current_k - 1
    }
    if new_k < k_min { new_k = k_min }
    if new_k > k_max { new_k = k_max }
    return new_k
}

fn acceptance_rate(n_accepted, n_drafted) {
    if n_drafted == 0 { return 0 }
    return (n_accepted * 100) / n_drafted
}

// ═══════════════════════════════════════════════════════════════════
//  Tests
// ═══════════════════════════════════════════════════════════════════

let mut pass = 0
let mut fail = 0

fn check(name, cond) {
    if cond {
        pass = pass + 1
    } else {
        fail = fail + 1
        println("[FAIL] " + name)
    }
}

fn eq_check(name, a, b) {
    if a == b {
        pass = pass + 1
    } else {
        fail = fail + 1
        println("[FAIL] " + name + " got " + to_string(a) + " want " + to_string(b))
    }
}

fn approx_check(name, a, b, tol) {
    let diff = a - b
    let adiff = if diff < 0.0 { 0.0 - diff } else { diff }
    if adiff < tol {
        pass = pass + 1
    } else {
        fail = fail + 1
        println("[FAIL] " + name + " got " + to_string(a) + " want " + to_string(b))
    }
}

println("=== speculative_decode test suite ===")

// 1. softmax
let sm1 = softmax([1.0, 2.0, 3.0])
eq_check("softmax len", len(sm1), 3)
let sm1_sum = sm1[0] + sm1[1] + sm1[2]
approx_check("softmax sum=1", sm1_sum, 1.0, 0.0001)
check("softmax order", sm1[2] > sm1[1] && sm1[1] > sm1[0])

let sm2 = softmax([0.0, 0.0, 0.0, 0.0])
approx_check("softmax uniform", sm2[0], 0.25, 0.0001)

let sm3 = softmax([])
eq_check("softmax empty", len(sm3), 0)

let sm4 = softmax([1000.0, 1001.0, 999.0])
let sm4_sum = sm4[0] + sm4[1] + sm4[2]
approx_check("softmax large stable", sm4_sum, 1.0, 0.0001)
check("softmax large peak", sm4[1] > sm4[0] && sm4[0] > sm4[2])

// 2. argmax
eq_check("argmax basic", argmax([0.1, 0.5, 0.3, 0.1]), 1)
eq_check("argmax first", argmax([9.0, 1.0, 2.0]), 0)
eq_check("argmax last", argmax([1.0, 2.0, 9.0]), 2)
eq_check("argmax single", argmax([42.0]), 0)

// 3. sample_categorical
eq_check("sample cat 0.0", sample_categorical([0.5, 0.3, 0.2], 0.0), 0)
eq_check("sample cat 0.49", sample_categorical([0.5, 0.3, 0.2], 0.49), 0)
eq_check("sample cat 0.51", sample_categorical([0.5, 0.3, 0.2], 0.51), 1)
eq_check("sample cat 0.79", sample_categorical([0.5, 0.3, 0.2], 0.79), 1)
eq_check("sample cat 0.81", sample_categorical([0.5, 0.3, 0.2], 0.81), 2)
eq_check("sample cat 0.99", sample_categorical([0.5, 0.3, 0.2], 0.99), 2)
eq_check("sample cat single", sample_categorical([1.0], 0.5), 0)

// 4. mock models
let draft = mock_draft_model(16)
let tgt = mock_target_model(16)
eq_check("draft type", draft["type"], "draft")
eq_check("target type", tgt["type"], "target")
eq_check("draft vocab", draft["vocab_size"], 16)

let dl = model_logits(draft, [1, 2, 3])
eq_check("draft logits len", len(dl), 16)
let vl = model_logits(tgt, [1, 2, 3])
eq_check("target logits len", len(vl), 16)

// 5. spec_decode_step
let prefix = [1, 2, 3, 4, 5]
let step_result = spec_decode_step(draft, tgt, prefix, 4)
check("step result len >= 1", len(step_result) >= 1)
check("step result len <= k+1", len(step_result) <= 5)

let mut all_valid = true
let mut si = 0
while si < len(step_result) {
    if step_result[si] < 0 || step_result[si] >= 16 {
        all_valid = false
    }
    si = si + 1
}
check("step tokens valid range", all_valid)

// 6. spec_decode_loop
let loop_result = spec_decode_loop(draft, tgt, [1, 2, 3], 10, 4)
eq_check("loop produces max_tokens", len(loop_result), 10)

let mut all_loop_valid = true
let mut li = 0
while li < len(loop_result) {
    if loop_result[li] < 0 || loop_result[li] >= 16 {
        all_loop_valid = false
    }
    li = li + 1
}
check("loop tokens valid range", all_loop_valid)

// 7. acceptance rate > 0
let mut total_acc = 0
let mut total_dft = 0
let mut cur_pfx = [1, 2, 3]
let mut ri = 0
while ri < 10 {
    let tokens = spec_decode_step(draft, tgt, cur_pfx, 4)
    total_acc = total_acc + len(tokens)
    total_dft = total_dft + 4
    let mut ti = 0
    while ti < len(tokens) {
        cur_pfx.push(tokens[ti])
        ti = ti + 1
    }
    ri = ri + 1
}
check("acceptance > 0", total_acc > 0)
let rate = acceptance_rate(total_acc, total_dft)
println("  acceptance rate: " + to_string(rate) + "% (" + to_string(total_acc) + "/" + to_string(total_dft) + ")")
check("acceptance rate > 50%", rate > 50)

// 8. different prefix lengths
let short_r = spec_decode_step(draft, tgt, [1], 2)
check("short prefix works", len(short_r) >= 1)
let empty_r = spec_decode_step(draft, tgt, [], 2)
check("empty prefix works", len(empty_r) >= 1)

// 9. k=1 edge case
let k1_result = spec_decode_step(draft, tgt, [1, 2, 3], 1)
check("k=1 produces 1-2 tokens", len(k1_result) >= 1 && len(k1_result) <= 2)

// 10. adaptive_k
eq_check("adaptive_k high rate", adaptive_k(4, 4, 4, 1, 10), 6)
eq_check("adaptive_k low rate", adaptive_k(4, 1, 4, 1, 10), 3)
eq_check("adaptive_k mid rate", adaptive_k(4, 3, 4, 1, 10), 4)
eq_check("adaptive_k clamp min", adaptive_k(1, 0, 4, 1, 10), 1)
eq_check("adaptive_k clamp max", adaptive_k(9, 9, 9, 1, 10), 10)

// 11. determinism
let det1 = spec_decode_step(draft, tgt, [7, 3, 1], 4)
let det2 = spec_decode_step(draft, tgt, [7, 3, 1], 4)
eq_check("deterministic len match", len(det1), len(det2))
let mut det_match = true
let mut dti = 0
while dti < len(det1) && dti < len(det2) {
    if det1[dti] != det2[dti] { det_match = false }
    dti = dti + 1
}
check("deterministic same tokens", det_match)

// 12. loop with larger token count
let big_loop = spec_decode_loop(draft, tgt, [0], 50, 5)
eq_check("big loop len", len(big_loop), 50)

// 13. acceptance_rate calculation
eq_check("acceptance_rate 4/4=100", acceptance_rate(4, 4), 100)
eq_check("acceptance_rate 3/4=75", acceptance_rate(3, 4), 75)
eq_check("acceptance_rate 0/4=0", acceptance_rate(0, 4), 0)
eq_check("acceptance_rate 0/0=0", acceptance_rate(0, 0), 0)

println("")
println("=== speculative_decode: " + to_string(pass) + " passed, " + to_string(fail) + " failed ===")
if fail > 0 {
    exit(1)
}
