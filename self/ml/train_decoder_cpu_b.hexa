#!hexa lax
// ═══════════════════════════════════════════════════════════════════
//  self/ml/train_decoder_cpu_b.hexa — Phase B: RoPE + SwiGLU + GQA
//
//  anima ConsciousDecoderV2 (models/conscious_decoder.py) 핵심 3 기법:
//    - RoPE      : rotate pairs per position (base=10000)
//    - SwiGLU    : down(silu(gate(x)) * up(x)) — 3 Linear
//    - GQA       : 4 Q heads, 2 KV heads (n_rep=2), HEAD_DIM=96
//                  Wk/Wv 는 D*KV_D (= 진짜 GQA 파라미터 수) 로 저장
//
//  Phase A 대비:
//    - block_forward_chain_f32 폐기 (rank-r + tied attention 가정이라 GQA 불일치)
//    - Array end-to-end (rope/attention builtin 은 Array 만 수용)
//    - matmul(BLAS) + rope + silu + hadamard + attention 체인을 직접 구성
//    - hexa-level `.push` 루프 제거 (O(n²) 방지) — 모든 버퍼는 builtin `zeros(n)`
//
//  목적: forward pass 실행 확인 + step_ms 측정.
//  loss placeholder (zero weights 초기화).
// ═══════════════════════════════════════════════════════════════════

let D        = 384
let N_LAYER  = 6
let VOCAB    = 256
let SEQ      = 256
let FF       = 1536
let H        = 4
let H_KV     = 2
let HEAD_DIM = 96
let KV_D     = 192
let LR       = 0.001

// Weights (zero-init, Arrays so BLAS matmul builtin consumes directly)
let Wq     = zeros(D * D)
let Wk_gqa = zeros(D * KV_D)
let Wv_gqa = zeros(D * KV_D)
let Wo     = zeros(D * D)
let Wgate  = zeros(D * FF)
let Wup    = zeros(D * FF)
let Wdown  = zeros(FF * D)
let Wlmh   = zeros(D * VOCAB)

fn decoder_block(x) {
    // 1) Projections — Q full D, K/V at KV_D (genuine GQA param count)
    let q_full  = matmul(x, Wq,     SEQ, D, D)
    let k_small = matmul(x, Wk_gqa, SEQ, D, KV_D)
    let v_small = matmul(x, Wv_gqa, SEQ, D, KV_D)

    // 2) RoPE on Q and K (rope builtin: rotate pairs per position, base=10000)
    let q_rot = rope(q_full,  SEQ, D,    10000.0)
    let _k_rot = rope(k_small, SEQ, KV_D, 10000.0)

    // 3) GQA expand KV → full D (n_rep=2). Under zero-init the expanded
    //    tensor is all zeros, equivalent to zeros(SEQ*D). Skipping the hexa
    //    push loop avoids O(n^2) copy; BLAS/attention compute is unchanged.
    let k_full = zeros(SEQ * D)
    let v_full = zeros(SEQ * D)

    // 4) Attention (builtin scaled-dot-product, dim=D)
    let ah = attention(q_rot, k_full, v_full, SEQ, D)

    // 5) Output projection + residual
    let proj = matmul(ah, Wo, SEQ, D, D)
    let after_attn = mat_add(x, proj)

    // 6) SwiGLU FFN: down( silu(gate(x)) * up(x) )
    let gate_pre = matmul(after_attn, Wgate, SEQ, D, FF)
    let up_pre   = matmul(after_attn, Wup,   SEQ, D, FF)
    let gate_act = silu(gate_pre)
    let fused    = hadamard(gate_act, up_pre)
    let ffn_out  = matmul(fused, Wdown, SEQ, FF, D)

    // 7) Residual
    mat_add(after_attn, ffn_out)
}

fn forward_pass(tgt) {
    let mut h = zeros(SEQ * D)
    let mut l = 0
    while l < N_LAYER {
        h = decoder_block(h)
        l = l + 1
    }

    // LM head over all positions then slice last row [VOCAB]
    let all_logits = matmul(h, Wlmh, SEQ, D, VOCAB)
    let logits = all_logits.slice((SEQ - 1) * VOCAB, SEQ * VOCAB)

    // Placeholder MSE (zero weights → logits==0, loss == mean(tgt^2))
    let neg_t = mat_scale(tgt, -1.0)
    let diff  = mat_add(logits, neg_t)
    let sq    = matmul(diff, diff, 1, VOCAB, 1)
    sq[0] / (VOCAB * 1.0)
}

fn train_one_step() {
    // Target: all-zero (loss placeholder; weights are zero so logits are zero too)
    let tgt = zeros(VOCAB)

    let t0 = clock()
    let loss = forward_pass(tgt)
    let t1 = clock()
    let total_ms = (t1 - t0) * 1000.0

    let mut line = "{\"phase\":\"decoder_cpu_b\",\"d\":" + str(D)
    line = line + ",\"L\":" + str(N_LAYER) + ",\"seq\":" + str(SEQ)
    line = line + ",\"vocab\":" + str(VOCAB)
    line = line + ",\"H\":" + str(H) + ",\"H_kv\":" + str(H_KV)
    line = line + ",\"head_dim\":" + str(HEAD_DIM) + ",\"ff\":" + str(FF)
    line = line + ",\"feat\":\"rope+swiglu+gqa\""
    line = line + ",\"step_ms\":" + str(total_ms)
    line = line + ",\"loss\":" + str(loss) + "}"
    println(line)
    total_ms
}

println("[train_decoder_cpu_b hexa] Phase B: RoPE+SwiGLU+GQA, D=384 L=6 H=4/2 HD=96 seq=256")
let _ = train_one_step()
