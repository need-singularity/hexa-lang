// ===================================================================
//  self/ml/dataloader.hexa — Dataset loading, batching, and splitting
//
//  Pure Hexa data loading pipeline for ML training:
//    load_text_dataset(path)  → array of text lines
//    load_jsonl(path)         → array of parsed JSON records
//    create_batches(ids, B, S)→ array of [batch_input, batch_target] pairs
//    fisher_yates(arr, seed)  → deterministically shuffled copy
//    train_val_test_split(data, ratios) → [train, val, test]
//
//  Builtins used: read_file, split, trim, json_parse, slice, shuffle,
//                 len, floor, random
// ===================================================================

// ── Special token IDs (match tokenizer convention) ──────────────
let PAD_TOKEN = 2
let BOS_TOKEN = 0
let EOS_TOKEN = 1

// ===================================================================
//  load_text_dataset — read file, split into non-empty trimmed lines
// ===================================================================
fn load_text_dataset(path) {
    let raw = read_file(path)
    let lines = split(raw, "\n")
    let mut result = []
    let mut i = 0
    while i < len(lines) {
        let line = trim(lines[i])
        if len(line) > 0 {
            result = result + [line]
        }
        i = i + 1
    }
    return result
}

// ===================================================================
//  load_jsonl — read JSONL file, parse each line as JSON object
// ===================================================================
fn load_jsonl(path) {
    let raw = read_file(path)
    let lines = split(raw, "\n")
    let mut result = []
    let mut i = 0
    while i < len(lines) {
        let line = trim(lines[i])
        if len(line) > 0 {
            let parsed = json_parse(line)
            result = result + [parsed]
        }
        i = i + 1
    }
    return result
}

// ===================================================================
//  fisher_yates — deterministic shuffle using seed
//  Uses builtin shuffle(array, seed) which implements FY internally
// ===================================================================
fn fisher_yates(arr, seed) {
    return shuffle(arr, seed)
}

// ===================================================================
//  train_val_test_split — split data by configurable ratios
//  ratios = [train_ratio, val_ratio]  (test = 1 - train - val)
//  Returns [train, val, test]
// ===================================================================
fn train_val_test_split(data, train_ratio, val_ratio) {
    let n = len(data)
    let train_end = floor(n * train_ratio)
    let val_end = floor(n * (train_ratio + val_ratio))
    let train = slice(data, 0, train_end)
    let val = slice(data, train_end, val_end)
    let test = slice(data, val_end, n)
    return [train, val, test]
}

// ===================================================================
//  train_test_split — simple 2-way split (convenience wrapper)
// ===================================================================
fn train_test_split(data, train_ratio) {
    let n = len(data)
    let split_idx = floor(n * train_ratio)
    let train = slice(data, 0, split_idx)
    let test = slice(data, split_idx, n)
    return [train, test]
}

// ===================================================================
//  create_batches — create input/target batch pairs from flat token IDs
//
//  Given a flat array of token IDs, creates batches of shape:
//    input  = [batch_size × seq_len]  (flattened)
//    target = [batch_size × seq_len]  (shifted by 1)
//
//  Returns array of [input_batch, target_batch] pairs
// ===================================================================
fn create_batches(token_ids, batch_size, seq_len) {
    let total = len(token_ids)
    let tokens_per_batch = batch_size * (seq_len + 1)
    let n_batches = floor(total / tokens_per_batch)
    let mut batches = []
    let mut b = 0
    while b < n_batches {
        let offset = b * tokens_per_batch
        let mut inputs = []
        let mut targets = []
        let mut s = 0
        while s < batch_size {
            let seq_start = offset + s * (seq_len + 1)
            let mut j = 0
            while j < seq_len {
                inputs = inputs + [token_ids[seq_start + j]]
                targets = targets + [token_ids[seq_start + j + 1]]
                j = j + 1
            }
            s = s + 1
        }
        batches = batches + [[inputs, targets]]
        b = b + 1
    }
    return batches
}

// ===================================================================
//  create_batches_padded — create batches with padding support
//  Pads shorter sequences to seq_len with PAD_TOKEN
// ===================================================================
fn create_batches_padded(sequences, batch_size, seq_len) {
    let n_seqs = len(sequences)
    let n_batches = floor(n_seqs / batch_size)
    let mut batches = []
    let mut b = 0
    while b < n_batches {
        let mut inputs = []
        let mut targets = []
        let mut s = 0
        while s < batch_size {
            let seq_idx = b * batch_size + s
            let seq = sequences[seq_idx]
            let slen = len(seq)
            let mut j = 0
            while j < seq_len {
                if j < slen - 1 {
                    inputs = inputs + [seq[j]]
                    targets = targets + [seq[j + 1]]
                } else {
                    inputs = inputs + [PAD_TOKEN]
                    targets = targets + [PAD_TOKEN]
                }
                j = j + 1
            }
            s = s + 1
        }
        batches = batches + [[inputs, targets]]
        b = b + 1
    }
    return batches
}

// ===================================================================
//  epoch_iterator — shuffle and re-batch for a new epoch
//  Returns fresh batches with different ordering
// ===================================================================
fn epoch_iterator(token_ids, batch_size, seq_len, epoch) {
    let shuffled = fisher_yates(token_ids, epoch * 7919)
    return create_batches(shuffled, batch_size, seq_len)
}
