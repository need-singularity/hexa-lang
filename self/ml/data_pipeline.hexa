// ===================================================================
//  self/ml/data_pipeline.hexa — Text preprocessing pipeline for ML
//
//  Pure Hexa data preprocessing:
//    clean_text(s)          → lowercase, trimmed, normalized whitespace
//    chunk_text(tokens, S)  → split token array into seq_len segments
//    pad_sequence(seq, L)   → pad or truncate to fixed length
//    pad_sequences(seqs, L) → batch pad/truncate
//    random_mask(ids, rate, mask_id, seed) → MLM random masking
//    build_vocab_from_lines(lines) → char-level vocab map
//    texts_to_ids(lines, vocab) → tokenize lines to ID arrays
//    full_pipeline(path, seq_len, batch_size, seed) → ready batches
//
//  Builtins used: to_lower, trim, replace, split, len, slice,
//                 floor, random, shuffle
// ===================================================================

// ── Special tokens ──────────────────────────────────────────────
let PIPE_PAD_ID   = 2
let PIPE_MASK_ID  = 4
let PIPE_BOS_ID   = 0
let PIPE_EOS_ID   = 1
let PIPE_UNK_ID   = 3

// ===================================================================
//  clean_text — normalize a raw text string
//  Lowercases, trims, collapses multiple spaces/tabs into single space
// ===================================================================
fn clean_text(s) {
    let lower = to_lower(s)
    let trimmed = trim(lower)
    let no_tab = replace(trimmed, "\t", " ")
    let mut result = replace(no_tab, "  ", " ")
    // Iterate to collapse all multi-spaces (up to 5 passes)
    let mut pass = 0
    while pass < 5 {
        let next = replace(result, "  ", " ")
        if next == result {
            return result
        }
        result = next
        pass = pass + 1
    }
    return result
}

// ===================================================================
//  clean_lines — clean an array of text strings
// ===================================================================
fn clean_lines(lines) {
    let mut result = []
    let mut i = 0
    while i < len(lines) {
        let cleaned = clean_text(lines[i])
        if len(cleaned) > 0 {
            result = result + [cleaned]
        }
        i = i + 1
    }
    return result
}

// ===================================================================
//  chunk_text — split a flat token ID array into fixed-length chunks
//  Drops the last chunk if shorter than seq_len
// ===================================================================
fn chunk_text(token_ids, seq_len) {
    let total = len(token_ids)
    let n_chunks = floor(total / seq_len)
    let mut chunks = []
    let mut c = 0
    while c < n_chunks {
        let start = c * seq_len
        let chunk = slice(token_ids, start, start + seq_len)
        chunks = chunks + [chunk]
        c = c + 1
    }
    return chunks
}

// ===================================================================
//  chunk_with_overlap — sliding window chunking with stride
//  Useful for training data augmentation
// ===================================================================
fn chunk_with_overlap(token_ids, seq_len, stride) {
    let total = len(token_ids)
    let mut chunks = []
    let mut start = 0
    while start + seq_len <= total {
        let chunk = slice(token_ids, start, start + seq_len)
        chunks = chunks + [chunk]
        start = start + stride
    }
    return chunks
}

// ===================================================================
//  pad_sequence — pad or truncate a single sequence to target length
// ===================================================================
fn pad_sequence(seq, target_len, pad_id) {
    let slen = len(seq)
    if slen >= target_len {
        return slice(seq, 0, target_len)
    }
    let mut result = seq
    let mut i = slen
    while i < target_len {
        result = result + [pad_id]
        i = i + 1
    }
    return result
}

// ===================================================================
//  pad_sequences — pad/truncate all sequences in a batch
// ===================================================================
fn pad_sequences(sequences, target_len, pad_id) {
    let mut result = []
    let mut i = 0
    while i < len(sequences) {
        result = result + [pad_sequence(sequences[i], target_len, pad_id)]
        i = i + 1
    }
    return result
}

// ===================================================================
//  random_mask — MLM-style random masking
//  Replaces ~mask_rate fraction of tokens with mask_id
//  Uses deterministic seed for reproducibility
//  Returns [masked_ids, mask_positions]
// ===================================================================
fn random_mask(token_ids, mask_rate, mask_id, seed) {
    let n = len(token_ids)
    let n_mask = floor(n * mask_rate)
    // Build index array and shuffle to pick random positions
    let mut indices = []
    let mut i = 0
    while i < n {
        indices = indices + [i]
        i = i + 1
    }
    let shuffled_idx = shuffle(indices, seed)
    // Mark first n_mask positions for masking
    let mut mask_set = []
    i = 0
    while i < n_mask {
        mask_set = mask_set + [shuffled_idx[i]]
        i = i + 1
    }
    // Apply masks
    let mut masked = []
    let mut positions = []
    i = 0
    while i < n {
        let mut is_masked = false
        let mut j = 0
        while j < len(mask_set) {
            if mask_set[j] == i {
                is_masked = true
            }
            j = j + 1
        }
        if is_masked {
            masked = masked + [mask_id]
            positions = positions + [i]
        } else {
            masked = masked + [token_ids[i]]
        }
        i = i + 1
    }
    return [masked, positions]
}

// ===================================================================
//  build_vocab_from_lines — build a simple char-level vocabulary
//  Returns array of [char, id] pairs for lookup
//  Reserves 0-4 for special tokens: BOS, EOS, PAD, UNK, MASK
// ===================================================================
fn build_vocab_from_lines(lines) {
    let mut chars = []
    let mut i = 0
    while i < len(lines) {
        let line = lines[i]
        let line_chars = split(line, "")
        let mut j = 0
        while j < len(line_chars) {
            let c = line_chars[j]
            if len(c) > 0 {
                // Check if already in vocab
                let mut found = false
                let mut k = 0
                while k < len(chars) {
                    if chars[k] == c {
                        found = true
                    }
                    k = k + 1
                }
                if found == false {
                    chars = chars + [c]
                }
            }
            j = j + 1
        }
        i = i + 1
    }
    // Build vocab: special tokens + unique chars
    let mut vocab = []
    let mut id = 5
    let mut vi = 0
    while vi < len(chars) {
        vocab = vocab + [[chars[vi], id]]
        id = id + 1
        vi = vi + 1
    }
    return vocab
}

// ===================================================================
//  char_to_id — look up character in vocab, return UNK if not found
// ===================================================================
fn char_to_id(c, vocab) {
    let mut i = 0
    while i < len(vocab) {
        if vocab[i][0] == c {
            return vocab[i][1]
        }
        i = i + 1
    }
    return PIPE_UNK_ID
}

// ===================================================================
//  text_to_ids — convert a string to array of token IDs
// ===================================================================
fn text_to_ids(text, vocab) {
    let chars = split(text, "")
    let mut ids = [PIPE_BOS_ID]
    let mut i = 0
    while i < len(chars) {
        if len(chars[i]) > 0 {
            ids = ids + [char_to_id(chars[i], vocab)]
        }
        i = i + 1
    }
    ids = ids + [PIPE_EOS_ID]
    return ids
}

// ===================================================================
//  texts_to_ids — convert array of strings to array of ID arrays
// ===================================================================
fn texts_to_ids(lines, vocab) {
    let mut result = []
    let mut i = 0
    while i < len(lines) {
        result = result + [text_to_ids(lines[i], vocab)]
        i = i + 1
    }
    return result
}

// ===================================================================
//  flatten_ids — concatenate array of ID arrays into single flat array
// ===================================================================
fn flatten_ids(id_arrays) {
    let mut result = []
    let mut i = 0
    while i < len(id_arrays) {
        let arr = id_arrays[i]
        let mut j = 0
        while j < len(arr) {
            result = result + [arr[j]]
            j = j + 1
        }
        i = i + 1
    }
    return result
}

// ===================================================================
//  full_pipeline — end-to-end: file → cleaned → tokenized → batched
//
//  Steps:
//    1. Load text lines from file
//    2. Clean each line (lowercase, normalize whitespace)
//    3. Build char-level vocab
//    4. Convert to token IDs (with BOS/EOS)
//    5. Flatten all IDs
//    6. Shuffle
//    7. Create batches
//
//  Returns #{batches: [...], vocab: [...], n_tokens: int}
// ===================================================================
fn full_pipeline(path, seq_len, batch_size, seed) {
    // 1. Load
    let raw = read_file(path)
    let lines = split(raw, "\n")
    let mut clean = []
    let mut i = 0
    while i < len(lines) {
        let line = clean_text(lines[i])
        if len(line) > 0 {
            clean = clean + [line]
        }
        i = i + 1
    }
    // 2. Build vocab
    let vocab = build_vocab_from_lines(clean)
    // 3. Tokenize
    let id_arrays = texts_to_ids(clean, vocab)
    // 4. Flatten
    let flat = flatten_ids(id_arrays)
    let n_tokens = len(flat)
    // 5. Shuffle
    let shuffled = shuffle(flat, seed)
    // 6. Batch
    let batches = create_batches(shuffled, batch_size, seq_len)
    return [batches, vocab, n_tokens]
}

// ===================================================================
//  Helper: create_batches (local copy to avoid cross-file dep)
// ===================================================================
fn create_batches(token_ids, batch_size, seq_len) {
    let total = len(token_ids)
    let tokens_per_batch = batch_size * (seq_len + 1)
    let n_batches = floor(total / tokens_per_batch)
    let mut batches = []
    let mut b = 0
    while b < n_batches {
        let offset = b * tokens_per_batch
        let mut inputs = []
        let mut targets = []
        let mut s = 0
        while s < batch_size {
            let seq_start = offset + s * (seq_len + 1)
            let mut j = 0
            while j < seq_len {
                inputs = inputs + [token_ids[seq_start + j]]
                targets = targets + [token_ids[seq_start + j + 1]]
                j = j + 1
            }
            s = s + 1
        }
        batches = batches + [[inputs, targets]]
        b = b + 1
    }
    return batches
}
