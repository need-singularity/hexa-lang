// ===================================================================
//  self/ml/embedding.hexa — Text Embedding Engine (pure Hexa)
//
//  Produces dense float vectors from text using model token embeddings.
//  Mean pooling over token embedding vectors.
//
//  Public API:
//    embed(model, text)               → float array (dim)
//    embed_batch(model, texts)        → array of float arrays
//    cosine_similarity(a, b)          → float [-1, 1]
//    dot_product(a, b)                → float
//    normalize(vec)                   → unit vector
//    euclidean_distance(a, b)         → float >= 0
// ===================================================================

// ===================================================================
//  Embedding model struct (for synthetic / test models)
// ===================================================================
struct EmbeddingModel {
    dim: int,
    vocab_size: int,
    embeddings: array
}

// ===================================================================
//  Vector math utilities
// ===================================================================

// Dot product of two float arrays of equal length
fn dot_product(a, b) {
    let n = len(a)
    let mut sum = 0.0
    let mut i = 0
    while i < n {
        sum = sum + a[i] * b[i]
        i = i + 1
    }
    return sum
}

// L2 norm (magnitude) of a vector
fn vec_norm(v) {
    let mut sum = 0.0
    let n = len(v)
    let mut i = 0
    while i < n {
        sum = sum + v[i] * v[i]
        i = i + 1
    }
    return sqrt(sum)
}

// Normalize a vector to unit length
fn normalize(v) {
    let n = len(v)
    let norm = vec_norm(v)
    if norm < 0.000001 { return v }
    let inv = 1.0 / norm
    let mut out = []
    let mut i = 0
    while i < n {
        out = out + [v[i] * inv]
        i = i + 1
    }
    return out
}

// Cosine similarity: dot(a,b) / (|a| * |b|)
fn cosine_similarity(a, b) {
    let d = dot_product(a, b)
    let na = vec_norm(a)
    let nb = vec_norm(b)
    let denom = na * nb
    if denom < 0.000001 { return 0.0 }
    return d / denom
}

// Euclidean distance between two vectors
fn euclidean_distance(a, b) {
    let n = len(a)
    let mut sum = 0.0
    let mut i = 0
    while i < n {
        let d = a[i] - b[i]
        sum = sum + d * d
        i = i + 1
    }
    return sqrt(sum)
}

// ===================================================================
//  Vector arithmetic helpers
// ===================================================================

// Element-wise add: a + b
fn vec_add(a, b) {
    let n = len(a)
    let mut out = []
    let mut i = 0
    while i < n {
        out = out + [a[i] + b[i]]
        i = i + 1
    }
    return out
}

// Scalar multiply: v * s
fn vec_scale(v, s) {
    let n = len(v)
    let mut out = []
    let mut i = 0
    while i < n {
        out = out + [v[i] * s]
        i = i + 1
    }
    return out
}

// Create zero vector of given dimension
fn vec_zeros(dim) {
    let mut out = []
    let mut i = 0
    while i < dim {
        out = out + [0.0]
        i = i + 1
    }
    return out
}

// ===================================================================
//  Simple byte-level tokenizer (matches generate.hexa byte_tokenize)
//  For real use, swap in BPE from tokenizer.hexa
// ===================================================================
fn embed_byte_tokenize(text) {
    let mut tokens = []
    let n = len(text)
    let mut i = 0
    while i < n {
        let ch = char_code(text, i)
        tokens = tokens + [ch + 3]
        i = i + 1
    }
    return tokens
}

// ===================================================================
//  Load a single token embedding vector from model
//  Returns float array of length dim.
//  Works with both GGUF models (load_embedding) and synthetic models.
// ===================================================================
fn get_token_embedding(model, token_id, dim) {
    // For EmbeddingModel (synthetic): embeddings is array of arrays
    let vocab_size = len(model.embeddings)
    if token_id >= 0 {
        if token_id < vocab_size {
            return model.embeddings[token_id]
        }
    }
    return vec_zeros(dim)
}

// ===================================================================
//  Embed a single text: tokenize → lookup embeddings → mean pool
//
//  Mean pooling: average all token embedding vectors to get a single
//  fixed-size representation vector.
// ===================================================================
fn embed(model, text) {
    let dim = model.dim
    let tokens = embed_byte_tokenize(text)
    let n_tokens = len(tokens)
    if n_tokens == 0 { return vec_zeros(dim) }

    let mut sum = vec_zeros(dim)
    let mut i = 0
    while i < n_tokens {
        let emb = get_token_embedding(model, tokens[i], dim)
        sum = vec_add(sum, emb)
        i = i + 1
    }

    let scale = 1.0 / to_float(n_tokens)
    return vec_scale(sum, scale)
}

// ===================================================================
//  Batch embed: embed multiple texts at once
//  Returns array of embedding vectors.
// ===================================================================
fn embed_batch(model, texts) {
    let n = len(texts)
    let mut results = []
    let mut i = 0
    while i < n {
        let v = embed(model, texts[i])
        results = results + [v]
        i = i + 1
    }
    return results
}

// ===================================================================
//  Create a simple synthetic embedding model for testing
//  Each token gets a deterministic pseudo-random vector.
//  vocab_size: number of token slots, dim: embedding dimension
// ===================================================================
fn create_synthetic_model(vocab_size, dim) {
    let mut embeddings = []
    let mut t = 0
    while t < vocab_size {
        let mut v = []
        let mut d = 0
        while d < dim {
            // deterministic pseudo-random: sin(t*137+d*31)
            let val = sin(to_float(t * 137 + d * 31 + 7))
            v = v + [val * 0.1]
            d = d + 1
        }
        embeddings = embeddings + [v]
        t = t + 1
    }
    return EmbeddingModel {
        dim: dim,
        vocab_size: vocab_size,
        embeddings: embeddings
    }
}
