// ═══════════════════════════════════════════════════════════════════
//  self/ml/latent_consistency.hexa — Latent Consistency Model (#307)
//
//  Luo et al., 2023 — distill a diffusion model into a consistency
//  model operating in latent space, enabling 1~4 step generation.
//  Uses classifier-free guidance as teacher.
//
//  Key idea: the student f_theta predicts x_0 from any (z_t, t) in
//  latent space.  Consistency distillation enforces:
//      f_theta(z_{t_n}, t_n) ≈ f_theta^-(z_{t_{n+1}}, t_{n+1})
//  where theta^- is the EMA target network.
//
//  Skip-connection parameterisation (ensures boundary condition):
//      f(z, t) = c_skip(t) * z  +  c_out(t) * F_theta(z, t)
//
//  Coefficients:
//      c_skip(t) = sigma_data^2 / (t^2 + sigma_data^2)
//      c_out(t)  = t * sigma_data / sqrt(t^2 + sigma_data^2)
//
//  Teacher step: DDIM deterministic solver
//      z_{t_next} = (t_next/t) * z_t + (t_next - t) * eps_pred
//
//  Guidance: w baked during distillation (not at inference).
//
//  Architecture in this module:
//      MLP:  z_concat_t -> hidden -> hidden -> D_latent
//      Two hidden layers with tanh activation.
//
//  API:
//    lcm_init(D_latent, D_hidden, seed)                 -> model
//    lcm_skip_coeff(t, sigma_data)                      -> float
//    lcm_out_coeff(t, sigma_data)                       -> float
//    lcm_predict_x0(model, z_t, t)                      -> [float]
//    lcm_teacher_step(model, z_t, t, t_next)            -> [float]
//    lcm_loss(model, ema_model, z_t, t_n, t_n1)         -> float
//    lcm_train_step(model, ema_model, batch, lr, ema_rate) -> [model, ema_model]
//    lcm_sample(model, noise, steps)                    -> [float]
//
//  AI-NATIVE attrs:
//    @pure  (forward / coefficients / loss)
//    @hot   (training step)
// ═══════════════════════════════════════════════════════════════════

// ── Math helpers ──────────────────────────────────────────────────

fn lcm_abs(x) { if x < 0.0 { return 0.0 - x } return x }

fn lcm_exp(x) {
    let mut v = x
    if v > 20.0 { v = 20.0 }
    if v < -20.0 { v = -20.0 }
    let mut result = 1.0
    let mut term = 1.0
    for i in 1..30 {
        term = term * v / to_float(i)
        result = result + term
    }
    if result < 0.0 { return 0.0 }
    return result
}

fn lcm_log(x) {
    if x <= 0.0 { return -30.0 }
    let mut v = x
    let mut count = 0
    while v > 2.0 {
        v = v / 2.718281828
        count = count + 1
    }
    while v < 0.5 {
        v = v * 2.718281828
        count = count - 1
    }
    let d = v - 1.0
    let ln_v = d - d * d / 2.0 + d * d * d / 3.0 - d * d * d * d / 4.0
    return to_float(count) + ln_v
}

fn lcm_sqrt(x) {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    for _i in 0..30 {
        g = (g + x / g) / 2.0
    }
    return g
}

fn lcm_tanh(x) {
    let ep = lcm_exp(x)
    let en = lcm_exp(0.0 - x)
    return (ep - en) / (ep + en)
}

fn lcm_zeros(n) {
    let mut v = []
    for _i in 0..n { v = v + [0.0] }
    return v
}

fn lcm_zeros_2d(rows, cols) {
    let mut m = []
    for _r in 0..rows {
        let mut row = []
        for _c in 0..cols { row = row + [0.0] }
        m = m + [row]
    }
    return m
}

fn lcm_lcg(state) {
    return (state * 1103515245 + 12345) % 2147483648
}

fn lcm_uniform(state) {
    let s = lcm_lcg(state)
    return [to_float(s) / 2147483648.0, to_float(s)]
}

fn lcm_randn(state) {
    // Box-Muller approximation: sum of 12 uniforms - 6
    let mut s = state
    let mut sum = 0.0
    for _i in 0..12 {
        let u = lcm_uniform(s)
        sum = sum + u[0]
        s = int(u[1])
        if s <= 0 { s = 1 }
    }
    return [sum - 6.0, s]
}

// ── Vector helpers ──────────────────────────────────────────────

fn lcm_add(a, b) {
    let n = len(a)
    let mut out = lcm_zeros(n)
    for i in 0..n { out[i] = a[i] + b[i] }
    return out
}

fn lcm_sub(a, b) {
    let n = len(a)
    let mut out = lcm_zeros(n)
    for i in 0..n { out[i] = a[i] - b[i] }
    return out
}

fn lcm_scale(v, s) {
    let n = len(v)
    let mut out = lcm_zeros(n)
    for i in 0..n { out[i] = v[i] * s }
    return out
}

fn lcm_dot(a, b) {
    let n = len(a)
    let mut s = 0.0
    for i in 0..n { s = s + a[i] * b[i] }
    return s
}

fn lcm_norm_sq(v) {
    return lcm_dot(v, v)
}

// ═══════════════════════════════════════════════════════════════════
//  Initialise LCM model
//
//  Architecture: 2-layer MLP
//    layer1: (D_latent + 1) -> D_hidden   (input = z concat t)
//    layer2: D_hidden -> D_hidden
//    layer3: D_hidden -> D_latent         (output head)
//
//  Also stores teacher network (same architecture) for DDIM step.
//    W_t1, b_t1, W_t2, b_t2, W_t3, b_t3  (teacher weights)
//
//  sigma_data: data scaling constant (default-like 0.5)
// ═══════════════════════════════════════════════════════════════════
fn lcm_init(D_latent, D_hidden, seed) {
    let mut state = seed
    if state <= 0 { state = 1 }

    let D_in = D_latent + 1

    // Student layer 1: D_in -> D_hidden
    let mut W1 = lcm_zeros_2d(D_hidden, D_in)
    for i in 0..D_hidden {
        for j in 0..D_in {
            let u = lcm_uniform(state)
            state = int(u[1])
            if state <= 0 { state = 1 }
            W1[i][j] = (u[0] - 0.5) * 0.5
        }
    }
    let b1 = lcm_zeros(D_hidden)

    // Student layer 2: D_hidden -> D_hidden
    let mut W2 = lcm_zeros_2d(D_hidden, D_hidden)
    for i in 0..D_hidden {
        for j in 0..D_hidden {
            let u = lcm_uniform(state)
            state = int(u[1])
            if state <= 0 { state = 1 }
            W2[i][j] = (u[0] - 0.5) * 0.5
        }
    }
    let b2 = lcm_zeros(D_hidden)

    // Student output: D_hidden -> D_latent
    let mut W3 = lcm_zeros_2d(D_latent, D_hidden)
    for i in 0..D_latent {
        for j in 0..D_hidden {
            let u = lcm_uniform(state)
            state = int(u[1])
            if state <= 0 { state = 1 }
            W3[i][j] = (u[0] - 0.5) * 0.5
        }
    }
    let b3 = lcm_zeros(D_latent)

    // Teacher layer 1
    let mut Wt1 = lcm_zeros_2d(D_hidden, D_in)
    for i in 0..D_hidden {
        for j in 0..D_in {
            let u = lcm_uniform(state)
            state = int(u[1])
            if state <= 0 { state = 1 }
            Wt1[i][j] = (u[0] - 0.5) * 0.5
        }
    }
    let bt1 = lcm_zeros(D_hidden)

    // Teacher layer 2
    let mut Wt2 = lcm_zeros_2d(D_hidden, D_hidden)
    for i in 0..D_hidden {
        for j in 0..D_hidden {
            let u = lcm_uniform(state)
            state = int(u[1])
            if state <= 0 { state = 1 }
            Wt2[i][j] = (u[0] - 0.5) * 0.5
        }
    }
    let bt2 = lcm_zeros(D_hidden)

    // Teacher output
    let mut Wt3 = lcm_zeros_2d(D_latent, D_hidden)
    for i in 0..D_latent {
        for j in 0..D_hidden {
            let u = lcm_uniform(state)
            state = int(u[1])
            if state <= 0 { state = 1 }
            Wt3[i][j] = (u[0] - 0.5) * 0.5
        }
    }
    let bt3 = lcm_zeros(D_latent)

    return #{
        "D_latent": D_latent,
        "D_hidden": D_hidden,
        "sigma_data": 0.5,
        "W1": W1, "b1": b1,
        "W2": W2, "b2": b2,
        "W3": W3, "b3": b3,
        "Wt1": Wt1, "bt1": bt1,
        "Wt2": Wt2, "bt2": bt2,
        "Wt3": Wt3, "bt3": bt3
    }
}

// ═══════════════════════════════════════════════════════════════════
//  Skip and output coefficients
//
//  c_skip(t) = sigma_data^2 / (t^2 + sigma_data^2)
//  c_out(t)  = t * sigma_data / sqrt(t^2 + sigma_data^2)
//
//  At t=0 (boundary): c_skip=1, c_out=0 => f(z,0) = z  (identity)
// ═══════════════════════════════════════════════════════════════════
@pure
fn lcm_skip_coeff(t, sigma_data) {
    let sd2 = sigma_data * sigma_data
    let t2 = t * t
    return sd2 / (t2 + sd2)
}

@pure
fn lcm_out_coeff(t, sigma_data) {
    let sd2 = sigma_data * sigma_data
    let t2 = t * t
    return t * sigma_data / lcm_sqrt(t2 + sd2)
}

// ═══════════════════════════════════════════════════════════════════
//  Raw network forward pass F_theta(z, t)
//  Input: concatenate z (D_latent) with [t] => D_latent+1
//  Two hidden layers with tanh, linear output head.
// ═══════════════════════════════════════════════════════════════════
@pure
fn lcm_network_fwd(W1, b1, W2, b2, W3, b3, z, t, D_latent, D_hidden) {
    let D_in = D_latent + 1

    // Build input: z concat [t]
    let mut inp = lcm_zeros(D_in)
    for i in 0..D_latent { inp[i] = z[i] }
    inp[D_latent] = t

    // Layer 1
    let mut h1 = lcm_zeros(D_hidden)
    for i in 0..D_hidden {
        let mut s = b1[i]
        for j in 0..D_in { s = s + W1[i][j] * inp[j] }
        h1[i] = lcm_tanh(s)
    }

    // Layer 2
    let mut h2 = lcm_zeros(D_hidden)
    for i in 0..D_hidden {
        let mut s = b2[i]
        for j in 0..D_hidden { s = s + W2[i][j] * h1[j] }
        h2[i] = lcm_tanh(s)
    }

    // Output
    let mut out = lcm_zeros(D_latent)
    for i in 0..D_latent {
        let mut s = b3[i]
        for j in 0..D_hidden { s = s + W3[i][j] * h2[j] }
        out[i] = s
    }
    return out
}

// ═══════════════════════════════════════════════════════════════════
//  Predict x_0:  consistency function with skip connection
//
//    f(z_t, t) = c_skip(t) * z_t  +  c_out(t) * F_theta(z_t, t)
//
//  Uses student weights (W1..W3).
// ═══════════════════════════════════════════════════════════════════
@pure
fn lcm_predict_x0(model, z_t, t) {
    let D_latent = model["D_latent"]
    let D_hidden = model["D_hidden"]
    let sigma_data = model["sigma_data"]

    let c_skip = lcm_skip_coeff(t, sigma_data)
    let c_out = lcm_out_coeff(t, sigma_data)

    let raw = lcm_network_fwd(
        model["W1"], model["b1"],
        model["W2"], model["b2"],
        model["W3"], model["b3"],
        z_t, t, D_latent, D_hidden
    )

    let mut pred = lcm_zeros(D_latent)
    for i in 0..D_latent {
        pred[i] = c_skip * z_t[i] + c_out * raw[i]
    }
    return pred
}

// ═══════════════════════════════════════════════════════════════════
//  Predict x_0 using EMA target network
//  Same architecture, uses EMA weights from ema_model.
// ═══════════════════════════════════════════════════════════════════
@pure
fn lcm_predict_x0_ema(ema_model, z_t, t) {
    let D_latent = ema_model["D_latent"]
    let D_hidden = ema_model["D_hidden"]
    let sigma_data = ema_model["sigma_data"]

    let c_skip = lcm_skip_coeff(t, sigma_data)
    let c_out = lcm_out_coeff(t, sigma_data)

    let raw = lcm_network_fwd(
        ema_model["W1"], ema_model["b1"],
        ema_model["W2"], ema_model["b2"],
        ema_model["W3"], ema_model["b3"],
        z_t, t, D_latent, D_hidden
    )

    let mut pred = lcm_zeros(D_latent)
    for i in 0..D_latent {
        pred[i] = c_skip * z_t[i] + c_out * raw[i]
    }
    return pred
}

// ═══════════════════════════════════════════════════════════════════
//  Teacher step: DDIM deterministic solver
//
//  Given z_t at timestep t, produce z_{t_next} using teacher network.
//  DDIM update:
//    eps_pred = (z_t - c_skip(t)*z_t_pred) / c_out(t)
//              ~ teacher's noise estimate
//    z_{t_next} = z_t + (t_next - t) * eps_pred
//               = z_t * (t_next / t) + (1 - t_next/t) * pred_x0 * ...
//
//  Simplified DDIM: use teacher to predict x_0, then interpolate
//    z_{t_next} = (t_next/t) * z_t + (1 - t_next/t) * x0_pred
//  This is the standard DDIM interpolation in signal space.
// ═══════════════════════════════════════════════════════════════════
@pure
fn lcm_teacher_step(model, z_t, t, t_next) {
    let D_latent = model["D_latent"]
    let D_hidden = model["D_hidden"]
    let sigma_data = model["sigma_data"]

    // Teacher predicts x_0 from z_t
    let c_skip = lcm_skip_coeff(t, sigma_data)
    let c_out = lcm_out_coeff(t, sigma_data)

    let raw = lcm_network_fwd(
        model["Wt1"], model["bt1"],
        model["Wt2"], model["bt2"],
        model["Wt3"], model["bt3"],
        z_t, t, D_latent, D_hidden
    )

    let mut x0_pred = lcm_zeros(D_latent)
    for i in 0..D_latent {
        x0_pred[i] = c_skip * z_t[i] + c_out * raw[i]
    }

    // DDIM interpolation to t_next
    // ratio = t_next / t  (both > 0 in practice)
    let mut ratio = 0.0
    if lcm_abs(t) > 1.0e-12 {
        ratio = t_next / t
    }

    let mut z_next = lcm_zeros(D_latent)
    for i in 0..D_latent {
        z_next[i] = ratio * z_t[i] + (1.0 - ratio) * x0_pred[i]
    }
    return z_next
}

// ═══════════════════════════════════════════════════════════════════
//  Consistency distillation loss
//
//  L = || f_theta(z_{t_n}, t_n) - f_{theta^-}(z_{t_{n+1}}, t_{n+1}) ||^2
//
//  where z_{t_{n+1}} is obtained by one teacher DDIM step from z_{t_n}.
//  theta^- is the EMA target (ema_model).
// ═══════════════════════════════════════════════════════════════════
@pure
fn lcm_loss(model, ema_model, z_t, t_n, t_n1) {
    let D_latent = model["D_latent"]

    // Student prediction at (z_{t_n}, t_n)
    let pred_student = lcm_predict_x0(model, z_t, t_n)

    // Teacher DDIM step: z_{t_n} -> z_{t_{n+1}}
    let z_next = lcm_teacher_step(model, z_t, t_n, t_n1)

    // EMA target prediction at (z_{t_{n+1}}, t_{n+1})
    let pred_ema = lcm_predict_x0_ema(ema_model, z_next, t_n1)

    // MSE loss
    let mut loss = 0.0
    for i in 0..D_latent {
        let diff = pred_student[i] - pred_ema[i]
        loss = loss + diff * diff
    }
    return loss / to_float(D_latent)
}

// ═══════════════════════════════════════════════════════════════════
//  EMA update: theta^- = ema_rate * theta^- + (1 - ema_rate) * theta
//  Applied per-weight to all student -> ema layers.
// ═══════════════════════════════════════════════════════════════════
fn lcm_ema_update_2d(W_ema, W_student, ema_rate, rows, cols) {
    let mut out = lcm_zeros_2d(rows, cols)
    for i in 0..rows {
        for j in 0..cols {
            out[i][j] = ema_rate * W_ema[i][j] + (1.0 - ema_rate) * W_student[i][j]
        }
    }
    return out
}

fn lcm_ema_update_1d(b_ema, b_student, ema_rate, n) {
    let mut out = lcm_zeros(n)
    for i in 0..n {
        out[i] = ema_rate * b_ema[i] + (1.0 - ema_rate) * b_student[i]
    }
    return out
}

// ═══════════════════════════════════════════════════════════════════
//  Training step
//
//  For each sample in batch:
//    1. Pick random t_n, t_{n+1} (adjacent timesteps)
//    2. Add noise to get z_t at t_n
//    3. Compute consistency distillation loss
//    4. Numerical gradient update on student weights
//    5. EMA update on target weights
//
//  Gradient: finite difference (delta = 1e-4) on student W1..W3, b1..b3
//  Returns [model, ema_model]
// ═══════════════════════════════════════════════════════════════════
@hot
fn lcm_train_step(model, ema_model, batch, lr, ema_rate) {
    let D_latent = model["D_latent"]
    let D_hidden = model["D_hidden"]
    let D_in = D_latent + 1
    let N = len(batch)
    if N == 0 { return [model, ema_model] }

    let delta = 1.0e-4
    let inv_2d = 1.0 / (2.0 * delta)
    let inv_N = 1.0 / to_float(N)

    // Timestep pairs: evenly spaced in [0.1, 1.0]
    // t_n = 0.8 (high noise), t_n1 = 0.4 (less noise)
    let t_n = 0.8
    let t_n1 = 0.4

    // Compute average loss over batch for base model
    let mut base_loss = 0.0
    for i in 0..N {
        base_loss = base_loss + lcm_loss(model, ema_model, batch[i], t_n, t_n1)
    }
    base_loss = base_loss * inv_N

    // ── Gradient for W1 ──────────────────────────────────────
    let mut gW1 = lcm_zeros_2d(D_hidden, D_in)
    for r in 0..D_hidden {
        for c in 0..D_in {
            let orig = model["W1"][r][c]

            model["W1"][r][c] = orig + delta
            let mut lp = 0.0
            for i in 0..N { lp = lp + lcm_loss(model, ema_model, batch[i], t_n, t_n1) }
            lp = lp * inv_N

            model["W1"][r][c] = orig - delta
            let mut lm = 0.0
            for i in 0..N { lm = lm + lcm_loss(model, ema_model, batch[i], t_n, t_n1) }
            lm = lm * inv_N

            gW1[r][c] = (lp - lm) * inv_2d
            model["W1"][r][c] = orig
        }
    }

    // ── Gradient for b1 ──────────────────────────────────────
    let mut gb1 = lcm_zeros(D_hidden)
    for r in 0..D_hidden {
        let orig = model["b1"][r]

        model["b1"][r] = orig + delta
        let mut lp = 0.0
        for i in 0..N { lp = lp + lcm_loss(model, ema_model, batch[i], t_n, t_n1) }
        lp = lp * inv_N

        model["b1"][r] = orig - delta
        let mut lm = 0.0
        for i in 0..N { lm = lm + lcm_loss(model, ema_model, batch[i], t_n, t_n1) }
        lm = lm * inv_N

        gb1[r] = (lp - lm) * inv_2d
        model["b1"][r] = orig
    }

    // ── Gradient for W2 ──────────────────────────────────────
    let mut gW2 = lcm_zeros_2d(D_hidden, D_hidden)
    for r in 0..D_hidden {
        for c in 0..D_hidden {
            let orig = model["W2"][r][c]

            model["W2"][r][c] = orig + delta
            let mut lp = 0.0
            for i in 0..N { lp = lp + lcm_loss(model, ema_model, batch[i], t_n, t_n1) }
            lp = lp * inv_N

            model["W2"][r][c] = orig - delta
            let mut lm = 0.0
            for i in 0..N { lm = lm + lcm_loss(model, ema_model, batch[i], t_n, t_n1) }
            lm = lm * inv_N

            gW2[r][c] = (lp - lm) * inv_2d
            model["W2"][r][c] = orig
        }
    }

    // ── Gradient for b2 ──────────────────────────────────────
    let mut gb2 = lcm_zeros(D_hidden)
    for r in 0..D_hidden {
        let orig = model["b2"][r]

        model["b2"][r] = orig + delta
        let mut lp = 0.0
        for i in 0..N { lp = lp + lcm_loss(model, ema_model, batch[i], t_n, t_n1) }
        lp = lp * inv_N

        model["b2"][r] = orig - delta
        let mut lm = 0.0
        for i in 0..N { lm = lm + lcm_loss(model, ema_model, batch[i], t_n, t_n1) }
        lm = lm * inv_N

        gb2[r] = (lp - lm) * inv_2d
        model["b2"][r] = orig
    }

    // ── Gradient for W3 ──────────────────────────────────────
    let mut gW3 = lcm_zeros_2d(D_latent, D_hidden)
    for r in 0..D_latent {
        for c in 0..D_hidden {
            let orig = model["W3"][r][c]

            model["W3"][r][c] = orig + delta
            let mut lp = 0.0
            for i in 0..N { lp = lp + lcm_loss(model, ema_model, batch[i], t_n, t_n1) }
            lp = lp * inv_N

            model["W3"][r][c] = orig - delta
            let mut lm = 0.0
            for i in 0..N { lm = lm + lcm_loss(model, ema_model, batch[i], t_n, t_n1) }
            lm = lm * inv_N

            gW3[r][c] = (lp - lm) * inv_2d
            model["W3"][r][c] = orig
        }
    }

    // ── Gradient for b3 ──────────────────────────────────────
    let mut gb3 = lcm_zeros(D_latent)
    for r in 0..D_latent {
        let orig = model["b3"][r]

        model["b3"][r] = orig + delta
        let mut lp = 0.0
        for i in 0..N { lp = lp + lcm_loss(model, ema_model, batch[i], t_n, t_n1) }
        lp = lp * inv_N

        model["b3"][r] = orig - delta
        let mut lm = 0.0
        for i in 0..N { lm = lm + lcm_loss(model, ema_model, batch[i], t_n, t_n1) }
        lm = lm * inv_N

        gb3[r] = (lp - lm) * inv_2d
        model["b3"][r] = orig
    }

    // ── Apply gradients to student ────────────────────────────
    let mut nW1 = lcm_zeros_2d(D_hidden, D_in)
    for r in 0..D_hidden {
        for c in 0..D_in {
            nW1[r][c] = model["W1"][r][c] - lr * gW1[r][c]
        }
    }
    let mut nb1 = lcm_zeros(D_hidden)
    for r in 0..D_hidden { nb1[r] = model["b1"][r] - lr * gb1[r] }

    let mut nW2 = lcm_zeros_2d(D_hidden, D_hidden)
    for r in 0..D_hidden {
        for c in 0..D_hidden {
            nW2[r][c] = model["W2"][r][c] - lr * gW2[r][c]
        }
    }
    let mut nb2 = lcm_zeros(D_hidden)
    for r in 0..D_hidden { nb2[r] = model["b2"][r] - lr * gb2[r] }

    let mut nW3 = lcm_zeros_2d(D_latent, D_hidden)
    for r in 0..D_latent {
        for c in 0..D_hidden {
            nW3[r][c] = model["W3"][r][c] - lr * gW3[r][c]
        }
    }
    let mut nb3 = lcm_zeros(D_latent)
    for r in 0..D_latent { nb3[r] = model["b3"][r] - lr * gb3[r] }

    // ── Build new student model ──────────────────────────────
    let new_model = #{
        "D_latent": D_latent,
        "D_hidden": D_hidden,
        "sigma_data": model["sigma_data"],
        "W1": nW1, "b1": nb1,
        "W2": nW2, "b2": nb2,
        "W3": nW3, "b3": nb3,
        "Wt1": model["Wt1"], "bt1": model["bt1"],
        "Wt2": model["Wt2"], "bt2": model["bt2"],
        "Wt3": model["Wt3"], "bt3": model["bt3"]
    }

    // ── EMA update on target weights ─────────────────────────
    let new_ema = #{
        "D_latent": D_latent,
        "D_hidden": D_hidden,
        "sigma_data": ema_model["sigma_data"],
        "W1": lcm_ema_update_2d(ema_model["W1"], nW1, ema_rate, D_hidden, D_in),
        "b1": lcm_ema_update_1d(ema_model["b1"], nb1, ema_rate, D_hidden),
        "W2": lcm_ema_update_2d(ema_model["W2"], nW2, ema_rate, D_hidden, D_hidden),
        "b2": lcm_ema_update_1d(ema_model["b2"], nb2, ema_rate, D_hidden),
        "W3": lcm_ema_update_2d(ema_model["W3"], nW3, ema_rate, D_latent, D_hidden),
        "b3": lcm_ema_update_1d(ema_model["b3"], nb3, ema_rate, D_latent),
        "Wt1": ema_model["Wt1"], "bt1": ema_model["bt1"],
        "Wt2": ema_model["Wt2"], "bt2": ema_model["bt2"],
        "Wt3": ema_model["Wt3"], "bt3": ema_model["bt3"]
    }

    return [new_model, new_ema]
}

// ═══════════════════════════════════════════════════════════════════
//  Multi-step sampling
//
//  Given initial noise z ~ N(0, I) at t=T_max:
//    for each step s in 0..steps:
//      t = T_max * (1 - s / steps)   (linearly decreasing)
//      z = f_theta(z, t)              (consistency prediction)
//
//  At 1 step: just predict x_0 from noise directly.
//  At 4 steps: iteratively refine through decreasing timesteps.
// ═══════════════════════════════════════════════════════════════════
@pure
fn lcm_sample(model, noise, steps) {
    let D_latent = model["D_latent"]
    if steps < 1 { return noise }

    let t_max = 1.0
    let mut z = lcm_zeros(D_latent)
    for i in 0..D_latent { z[i] = noise[i] }

    for s in 0..steps {
        // Current timestep: decreasing from t_max toward 0
        let frac = to_float(s) / to_float(steps)
        let t = t_max * (1.0 - frac)
        if t < 0.01 { return z }
        z = lcm_predict_x0(model, z, t)
    }
    return z
}

// ═══════════════════════════════════════════════════════════════════
//  Timestep schedule helper
//  Returns N+1 evenly spaced timesteps from t_max down to t_min
// ═══════════════════════════════════════════════════════════════════
@pure
fn lcm_timestep_schedule(t_max, t_min, N) {
    let mut ts = []
    for i in 0..N {
        let frac = to_float(i) / to_float(N)
        ts = ts + [t_max - frac * (t_max - t_min)]
    }
    ts = ts + [t_min]
    return ts
}

// ═══════════════════════════════════════════════════════════════════
//  Guidance-augmented teacher step
//  Uses classifier-free guidance with scale w:
//    eps_guided = (1 + w) * eps_cond - w * eps_uncond
//  For simplicity, unconditional = zero condition, so eps_uncond
//  is predicted with a zeroed-out input.
// ═══════════════════════════════════════════════════════════════════
@pure
fn lcm_guided_teacher_step(model, z_t, t, t_next, w) {
    let D_latent = model["D_latent"]
    let D_hidden = model["D_hidden"]
    let sigma_data = model["sigma_data"]

    // Conditional teacher prediction
    let c_skip = lcm_skip_coeff(t, sigma_data)
    let c_out = lcm_out_coeff(t, sigma_data)

    let raw_cond = lcm_network_fwd(
        model["Wt1"], model["bt1"],
        model["Wt2"], model["bt2"],
        model["Wt3"], model["bt3"],
        z_t, t, D_latent, D_hidden
    )

    // Unconditional: use zero input
    let z_zero = lcm_zeros(D_latent)
    let raw_uncond = lcm_network_fwd(
        model["Wt1"], model["bt1"],
        model["Wt2"], model["bt2"],
        model["Wt3"], model["bt3"],
        z_zero, t, D_latent, D_hidden
    )

    // Guided prediction: (1+w)*cond - w*uncond
    let mut x0_pred = lcm_zeros(D_latent)
    for i in 0..D_latent {
        let cond_x0 = c_skip * z_t[i] + c_out * raw_cond[i]
        let uncond_x0 = c_skip * z_zero[i] + c_out * raw_uncond[i]
        x0_pred[i] = (1.0 + w) * cond_x0 - w * uncond_x0
    }

    // DDIM interpolation
    let mut ratio = 0.0
    if lcm_abs(t) > 1.0e-12 { ratio = t_next / t }

    let mut z_next = lcm_zeros(D_latent)
    for i in 0..D_latent {
        z_next[i] = ratio * z_t[i] + (1.0 - ratio) * x0_pred[i]
    }
    return z_next
}
