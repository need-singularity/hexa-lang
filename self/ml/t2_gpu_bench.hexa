// ═══════════════════════════════════════════════════════════════
//  t2_gpu_bench.hexa — GPU training benchmark
//
//  Measures:
//    1. CUDA init time
//    2. Weight init time (100M params on GPU)
//    3. Forward pass time
//    4. Full step time (fwd + bwd + optimizer)
//    5. cuBLAS SGEMM throughput at various sizes
//    6. Memory bandwidth (H2D / D2H)
//    7. Comparison against theoretical H100 ceiling
//
//  Physical ceiling (H100 SXM):
//    FP32: 67 TFLOPS peak
//    FP16: 990 TFLOPS peak (with tensor cores)
//    Memory BW: 3.35 TB/s HBM3
//    100M model, ~600M FLOPs/step (FP32)
//    Theoretical minimum: ~0.009 ms/step
//    Realistic (memory-bound): <1 ms/step target
// ═══════════════════════════════════════════════════════════════

use "cuda_ffi"
use "gpu_tensor"

// ── cuBLAS SGEMM throughput benchmark ────────────────────────
fn bench_sgemm(M, N, K, iters) {
    let A = gpu_tensor_zeros(M, K)
    let B = gpu_tensor_zeros(K, N)
    let C = gpu_tensor_zeros(M, N)

    // Warmup
    let _ = gpu_sgemm(gt_ptr(A), gt_ptr(B), gt_ptr(C), M, N, K)
    let _ = cuda_sync()

    let t0 = clock()
    let mut i = 0
    while i < iters {
        let _ = gpu_sgemm(gt_ptr(A), gt_ptr(B), gt_ptr(C), M, N, K)
        i = i + 1
    }
    let _ = cuda_sync()
    let t1 = clock()

    let total_ms = (t1 - t0) * 1000.0
    let per_ms = total_ms / (iters * 1.0)
    let flops = 2.0 * M * 1.0 * N * 1.0 * K * 1.0
    let tflops = flops * iters / (total_ms / 1000.0) / 1.0e12

    println("  SGEMM " + str(M) + "x" + str(N) + "x" + str(K) + ": " + str(per_ms) + " ms/call, " + str(tflops) + " TFLOPS")

    gpu_tensor_free(A)
    gpu_tensor_free(B)
    gpu_tensor_free(C)

    let result = [per_ms, tflops]
    return result
}

// ── Memory bandwidth benchmark ───────────────────────────────
fn bench_memcpy(nbytes, iters) {
    let host_buf = alloc_raw(nbytes)
    let dev_ptr = cuda_malloc(nbytes)

    // H2D
    let _ = cuda_sync()
    let t0 = clock()
    let mut i = 0
    while i < iters {
        let _ = cuda_memcpy_h2d(dev_ptr, host_buf, nbytes)
        i = i + 1
    }
    let _ = cuda_sync()
    let t1 = clock()
    let h2d_ms = (t1 - t0) * 1000.0 / (iters * 1.0)
    let h2d_gbps = (nbytes * 1.0) / (h2d_ms / 1000.0) / 1.0e9

    // D2H
    let _ = cuda_sync()
    let t2 = clock()
    i = 0
    while i < iters {
        let _ = cuda_memcpy_d2h(host_buf, dev_ptr, nbytes)
        i = i + 1
    }
    let _ = cuda_sync()
    let t3 = clock()
    let d2h_ms = (t3 - t2) * 1000.0 / (iters * 1.0)
    let d2h_gbps = (nbytes * 1.0) / (d2h_ms / 1000.0) / 1.0e9

    println("  Memcpy " + str(nbytes / (1024 * 1024)) + " MB: H2D=" + str(h2d_gbps) + " GB/s, D2H=" + str(d2h_gbps) + " GB/s")

    cuda_free(dev_ptr)
    free_raw(host_buf, nbytes)

    let result = [h2d_gbps, d2h_gbps]
    return result
}

// ── Full training step benchmark ─────────────────────────────
fn bench_training_step() {
    use "gpu_grad_engine"
    use "gpu_optimizer"
    use "model_100m_gpu"

    println("")
    println("─── Full Training Step Benchmark ───")

    // Init weights
    let t0 = clock()
    let weights = init_model_weights()
    let _ = cuda_sync()
    let t1 = clock()
    println("  Weight init: " + str((t1 - t0) * 1000.0) + " ms")

    // Create optimizer
    let all_params = model_params(weights)
    let n_params = len(all_params)
    let mut opt_states = []
    let mut i = 0
    while i < n_params {
        opt_states = opt_states.push(adam_state_create(all_params[i]))
        i = i + 1
    }

    let seq = GPU_SEQ
    let vocab = GPU_VOCAB

    // Generate batch
    let mut tokens = []
    let mut targets = []
    i = 0
    while i < seq {
        tokens = tokens.push(int(random() * vocab) % vocab)
        targets = targets.push(int(random() * vocab) % vocab)
        i = i + 1
    }

    // Warmup step
    tape_clear()
    grad_table_clear()
    let logits_w = model_forward(weights, tokens, seq)
    let _ = gpu_cross_entropy_loss(logits_w, targets)
    let _ = backward(logits_w)
    let _ = cuda_sync()

    // Benchmark steps
    let N_BENCH = 5
    let mut times = []
    let mut step = 0
    while step < N_BENCH {
        tape_clear()
        grad_table_clear()

        let ts0 = clock()
        let logits = model_forward(weights, tokens, seq)
        let ce = gpu_cross_entropy_loss(logits, targets)
        let loss = ce[0]
        let _ = backward(ce[1])
        let _ = cuda_sync()

        let grads = model_grads(weights)
        let _ = gpu_clip_grad_norm(grads, 1.0)

        i = 0
        while i < n_params {
            let _ = adam_step(opt_states[i], grads[i], 3.0e-4, step + 1)
            i = i + 1
        }
        let _ = cuda_sync()
        let ts1 = clock()

        let ms = (ts1 - ts0) * 1000.0
        times = times.push(ms)
        println("  Step " + str(step) + ": " + str(ms) + " ms, loss=" + str(loss))
        step = step + 1
    }

    // Stats
    let mut sum_t = 0.0
    let mut min_t = times[0]
    i = 0
    while i < N_BENCH {
        sum_t = sum_t + times[i]
        if times[i] < min_t { min_t = times[i] }
        i = i + 1
    }
    let avg_t = sum_t / (N_BENCH * 1.0)

    // Theoretical FLOPs per step
    let total_params = model_param_count()
    let flops_per_step = 6.0 * total_params * seq * 1.0
    let achieved_tflops = flops_per_step / (avg_t / 1000.0) / 1.0e12

    // H100 ceiling comparison
    let h100_fp32_tflops = 67.0
    let utilization = achieved_tflops / h100_fp32_tflops * 100.0

    println("")
    println("─── Results ───")
    println("  Parameters:      " + str(total_params))
    println("  Sequence length:  " + str(seq))
    println("  Avg ms/step:      " + str(avg_t))
    println("  Min ms/step:      " + str(min_t))
    println("  FLOPs/step:       " + str(flops_per_step))
    println("  Achieved TFLOPS:  " + str(achieved_tflops))
    println("  H100 FP32 util:   " + str(utilization) + "%")
    println("  H100 theoretical: " + str(flops_per_step / 67.0e12 * 1000.0) + " ms/step")

    0
}

// ── Main benchmark ───────────────────────────────────────────
fn run_bench() {
    println("═══════════════════════════════════════════")
    println("  GPU Benchmark: hexa CUDA FFI")
    println("═══════════════════════════════════════════")

    // Init CUDA
    let err = cuda_init()
    if err != 0 {
        println("[FATAL] CUDA init failed: " + str(err))
        return -1
    }
    let _ = cuda_mem_info()

    // SGEMM benchmarks
    println("")
    println("─── cuBLAS SGEMM Throughput ───")
    let _ = bench_sgemm(512, 512, 512, 100)
    let _ = bench_sgemm(1024, 1024, 1024, 50)
    let _ = bench_sgemm(2048, 2048, 2048, 20)
    let _ = bench_sgemm(4096, 4096, 4096, 10)
    let _ = bench_sgemm(128, 32000, 512, 50)

    // Memory bandwidth
    println("")
    println("─── Memory Bandwidth ───")
    let _ = bench_memcpy(1024 * 1024, 100)
    let _ = bench_memcpy(64 * 1024 * 1024, 20)
    let _ = bench_memcpy(256 * 1024 * 1024, 10)

    // Full training step
    let _ = bench_training_step()

    let _ = cuda_shutdown()
    println("")
    println("═══════════════════════════════════════════")
    println("  Benchmark complete")
    println("═══════════════════════════════════════════")
    0
}

let _ = run_bench()
