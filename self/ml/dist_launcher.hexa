// ═══════════════════════════════════════════════════════════════
//  self/ml/dist_launcher.hexa — Multi-rank process launcher
//
//  Pure-hexa replacement for torchrun / mpirun. Spawns N worker
//  processes (one per GPU), sets env vars (RANK, WORLD_SIZE,
//  MASTER_ADDR, MASTER_PORT, LOCAL_RANK), and waits for all to
//  complete.
//
//  Usage:
//    use "dist_launcher"
//    let rc = dist_launch("self/ml/distributed_train.hexa", 4)
//    // Spawns 4 processes, each with RANK=0..3
//
//  Env override:
//    MASTER_ADDR  (default "127.0.0.1")
//    MASTER_PORT  (default "29500")
//    HEXA_BIN     (default "hexa")
//
//  Each child process is launched via:
//    RANK=k WORLD_SIZE=N LOCAL_RANK=k MASTER_ADDR=... MASTER_PORT=...
//      hexa <script>
// ═══════════════════════════════════════════════════════════════

// ── Default configuration ────────────────────────────────────
let DEFAULT_MASTER_ADDR = "127.0.0.1"
let DEFAULT_MASTER_PORT = "29500"

// ── Read env with fallback ───────────────────────────────────
fn dist_env_or(name, fallback) {
    let val = env(name)
    if val == "" { return fallback }
    return val
}

// ── Build the command string for a single rank ───────────────
fn dist_rank_cmd(script, rank, world_size, master_addr, master_port, hexa_bin) {
    let cmd = "RANK=" + str(rank) +
              " WORLD_SIZE=" + str(world_size) +
              " LOCAL_RANK=" + str(rank) +
              " MASTER_ADDR=" + master_addr +
              " MASTER_PORT=" + master_port +
              " " + hexa_bin + " " + script
    return cmd
}

// ═══════════════════════════════════════════════════════════════
//  dist_launch — spawn N workers and wait for all
//
//  Returns 0 on success, non-zero if any child failed.
// ═══════════════════════════════════════════════════════════════

pub fn dist_launch(script, num_ranks) {
    let master_addr = dist_env_or("MASTER_ADDR", DEFAULT_MASTER_ADDR)
    let master_port = dist_env_or("MASTER_PORT", DEFAULT_MASTER_PORT)
    let hexa_bin = dist_env_or("HEXA_BIN", "hexa")

    println("[dist_launcher] launching " + str(num_ranks) + " ranks")
    println("[dist_launcher]   script:      " + script)
    println("[dist_launcher]   master_addr: " + master_addr)
    println("[dist_launcher]   master_port: " + master_port)
    println("[dist_launcher]   hexa_bin:    " + hexa_bin)

    // Spawn all workers
    let mut pids = []
    for rank in 0..num_ranks {
        let cmd = dist_rank_cmd(script, rank, num_ranks, master_addr, master_port, hexa_bin)
        println("[dist_launcher] rank " + str(rank) + " → " + cmd)
        let pid = spawn(cmd)
        if pid <= 0 {
            println("[dist_launcher] ERROR: failed to spawn rank " + str(rank))
            // Kill already-spawned children
            for j in 0..len(pids) {
                let _ = kill(pids[j])
            }
            return 1
        }
        pids.push(pid)
    }

    println("[dist_launcher] all " + str(num_ranks) + " ranks spawned, waiting...")

    // Wait for all children to complete
    let mut any_fail = 0
    for rank in 0..num_ranks {
        let rc = wait(pids[rank])
        if rc != 0 {
            println("[dist_launcher] rank " + str(rank) + " exited with code " + str(rc))
            any_fail = any_fail + 1
        } else {
            println("[dist_launcher] rank " + str(rank) + " done")
        }
    }

    if any_fail > 0 {
        println("[dist_launcher] WARNING: " + str(any_fail) + " of " + str(num_ranks) + " ranks failed")
        return 1
    }

    println("[dist_launcher] all " + str(num_ranks) + " ranks completed successfully")
    return 0
}

// ═══════════════════════════════════════════════════════════════
//  dist_launch_with_env — launch with custom env overrides
//
//  extra_env: dict of key→value strings appended to each command
// ═══════════════════════════════════════════════════════════════

pub fn dist_launch_with_env(script, num_ranks, extra_env) {
    let master_addr = dist_env_or("MASTER_ADDR", DEFAULT_MASTER_ADDR)
    let master_port = dist_env_or("MASTER_PORT", DEFAULT_MASTER_PORT)
    let hexa_bin = dist_env_or("HEXA_BIN", "hexa")

    println("[dist_launcher] launching " + str(num_ranks) + " ranks (custom env)")

    let mut pids = []
    for rank in 0..num_ranks {
        // Build env prefix from extra_env dict
        let mut env_prefix = ""
        let keys = dict_keys(extra_env)
        for ki in 0..len(keys) {
            let k = keys[ki]
            env_prefix = env_prefix + k + "=" + extra_env[k] + " "
        }

        let base_cmd = dist_rank_cmd(script, rank, num_ranks, master_addr, master_port, hexa_bin)
        let cmd = env_prefix + base_cmd
        println("[dist_launcher] rank " + str(rank) + " → " + cmd)
        let pid = spawn(cmd)
        if pid <= 0 {
            println("[dist_launcher] ERROR: failed to spawn rank " + str(rank))
            for j in 0..len(pids) {
                let _ = kill(pids[j])
            }
            return 1
        }
        pids.push(pid)
    }

    // Wait for all
    let mut any_fail = 0
    for rank in 0..num_ranks {
        let rc = wait(pids[rank])
        if rc != 0 {
            any_fail = any_fail + 1
        }
    }

    if any_fail > 0 {
        println("[dist_launcher] " + str(any_fail) + " ranks failed")
        return 1
    }

    println("[dist_launcher] all ranks completed")
    return 0
}

// ═══════════════════════════════════════════════════════════════
//  Convenience: get this process's rank/world from env
//  (called by the child process after launcher sets env vars)
// ═══════════════════════════════════════════════════════════════

pub fn dist_my_rank() {
    let r = env("RANK")
    if r == "" { return 0 }
    return to_int(r)
}

pub fn dist_my_world_size() {
    let w = env("WORLD_SIZE")
    if w == "" { return 1 }
    return to_int(w)
}

pub fn dist_my_local_rank() {
    let r = env("LOCAL_RANK")
    if r == "" { return 0 }
    return to_int(r)
}

pub fn dist_master_addr() {
    return dist_env_or("MASTER_ADDR", DEFAULT_MASTER_ADDR)
}

pub fn dist_master_port() {
    return dist_env_or("MASTER_PORT", DEFAULT_MASTER_PORT)
}

println("[dist_launcher] loaded — multi-rank process launcher (torchrun-style)")
