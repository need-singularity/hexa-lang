// ===================================================================
//  self/ml/bnns_kernels.hexa — Accelerate BNNS-style Activation &
//                               Normalization Kernels (pure hexa)
//
//  Apple BNNS (Basic Neural Network Subroutines) provides C-callable
//  APIs for activations, normalization, and element-wise ops with
//  automatic Metal GPU dispatch. The C API is struct-heavy (filter
//  creation via BNNSFilterCreateLayerActivation etc.).
//
//  This module implements pure-hexa optimized kernels that match BNNS
//  semantics exactly. Each function operates on flat float arrays and
//  is designed as a drop-in replacement: when Accelerate BNNS extern
//  linking is enabled, the dispatch layer can swap to native calls.
//
//  Sections:
//    1. Activation functions (relu, gelu, gelu_fast, silu, sigmoid,
//       tanh_approx, softmax, log_softmax)
//    2. Normalization (layer_norm, rms_norm, batch_norm)
//    3. Element-wise ops (add, mul, scale, fma, clamp)
//    4. Reduction ops (sum, mean, variance, max, argmax)
//    5. BNNS extern stubs (commented, ready for future activation)
//    6. Dispatch layer (bnns_has_native)
//
//  AI-NATIVE attrs:
//    @hot      — activation/norm called every forward pass
//    @pure     — no side effects in math kernels
//    @fuse     — inner loops fusable by compiler
// ===================================================================

// ── Constants ────────────────────────────────────────────────────
let BK_PI = 3.141592653589793
let BK_SQRT_2_OVER_PI = 0.7978845608028654   // sqrt(2/pi)
let BK_GELU_COEFF = 0.044715
let BK_GELU_FAST_COEFF = 1.702

// ── Local math helpers (prefixed bk_ to avoid collision) ─────────

fn bk_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn bk_max_f(a, b) {
    if a >= b { return a }
    return b
}

fn bk_min_f(a, b) {
    if a <= b { return a }
    return b
}

fn bk_zeros(n) {
    let mut v = []
    for _i in 0..n {
        v = v + [0.0]
    }
    return v
}

// fast tanh via rational Pade approximant
// accurate to ~1e-4 for |x| < 4, clamps to +/-1 outside
fn bk_tanh_rational(x) {
    if x > 4.5 { return 1.0 }
    if x < -4.5 { return 0.0 - 1.0 }
    let x2 = x * x
    // Pade(3,3): tanh(x) ~ x(135 + 17x^2) / (135 + 62x^2 + 3x^4)
    // Simplified Pade(1,1)-ish: x*(28+x^2)/(28+11*x^2)  -- decent
    let num = x * (28.0 + x2)
    let den = 28.0 + 11.0 * x2
    return num / den
}

// ===================================================================
//  1. ACTIVATION FUNCTIONS
//  All operate on flat arrays: input[n] -> output[n]
// ===================================================================

// ── ReLU: max(0, x) ──────────────────────────────────────────────
@hot @pure @fuse
fn bnns_relu(input, output, n) {
    for i in 0..n {
        if input[i] > 0.0 {
            output[i] = input[i]
        } else {
            output[i] = 0.0
        }
    }
    return output
}

// ── GELU (exact): x * 0.5 * (1 + tanh(sqrt(2/pi)*(x + 0.044715*x^3)))
@hot @pure @fuse
fn bnns_gelu(input, output, n) {
    for i in 0..n {
        let x = input[i]
        let x3 = x * x * x
        let inner = BK_SQRT_2_OVER_PI * (x + BK_GELU_COEFF * x3)
        // tanh via (exp(2z)-1)/(exp(2z)+1), clamped for large |inner|
        let mut t = 0.0
        if inner > 10.0 {
            t = 1.0
        } else {
            if inner < -10.0 {
                t = 0.0 - 1.0
            } else {
                let z2 = 2.0 * inner
                let e = exp(z2)
                t = (e - 1.0) / (e + 1.0)
            }
        }
        output[i] = x * 0.5 * (1.0 + t)
    }
    return output
}

// ── GELU fast: x * sigmoid(1.702 * x) ───────────────────────────
@hot @pure @fuse
fn bnns_gelu_fast(input, output, n) {
    for i in 0..n {
        let x = input[i]
        let s = 1.0 / (1.0 + exp(0.0 - BK_GELU_FAST_COEFF * x))
        output[i] = x * s
    }
    return output
}

// ── SiLU (Swish): x * sigmoid(x) = x / (1 + exp(-x)) ───────────
@hot @pure @fuse
fn bnns_silu(input, output, n) {
    for i in 0..n {
        let x = input[i]
        output[i] = x / (1.0 + exp(0.0 - x))
    }
    return output
}

// ── Sigmoid: 1 / (1 + exp(-x)) ──────────────────────────────────
@hot @pure @fuse
fn bnns_sigmoid(input, output, n) {
    for i in 0..n {
        output[i] = 1.0 / (1.0 + exp(0.0 - input[i]))
    }
    return output
}

// ── Tanh approximation (fast Pade rational) ─────────────────────
@hot @pure @fuse
fn bnns_tanh_approx(input, output, n) {
    for i in 0..n {
        output[i] = bk_tanh_rational(input[i])
    }
    return output
}

// ── Softmax (numerically stable, max subtraction) ───────────────
@hot @pure
fn bnns_softmax(input, output, n) {
    // find max for numerical stability
    let mut m = input[0]
    for i in 1..n {
        if input[i] > m {
            m = input[i]
        }
    }
    // exp(x - max) and accumulate sum
    let mut sum_exp = 0.0
    for i in 0..n {
        let e = exp(input[i] - m)
        output[i] = e
        sum_exp = sum_exp + e
    }
    // normalize
    for i in 0..n {
        output[i] = output[i] / sum_exp
    }
    return output
}

// ── Log-Softmax: log(softmax(x)) = x - max - log(sum(exp(x-max)))
@hot @pure
fn bnns_log_softmax(input, output, n) {
    // find max
    let mut m = input[0]
    for i in 1..n {
        if input[i] > m {
            m = input[i]
        }
    }
    // sum of exp(x - max)
    let mut sum_exp = 0.0
    for i in 0..n {
        sum_exp = sum_exp + exp(input[i] - m)
    }
    let log_sum = log(sum_exp)
    // log_softmax_i = (x_i - max) - log(sum_exp)
    for i in 0..n {
        output[i] = (input[i] - m) - log_sum
    }
    return output
}

// ===================================================================
//  2. NORMALIZATION
// ===================================================================

// ── LayerNorm: (x - mean) / sqrt(var + eps) * gamma + beta ──────
@hot @pure
fn bnns_layer_norm(input, output, gamma, beta, n, eps) {
    // compute mean
    let mut sum = 0.0
    for i in 0..n {
        sum = sum + input[i]
    }
    let mean = sum / (n * 1.0)

    // compute variance
    let mut var_sum = 0.0
    for i in 0..n {
        let d = input[i] - mean
        var_sum = var_sum + d * d
    }
    let variance = var_sum / (n * 1.0)
    let inv_std = 1.0 / sqrt(variance + eps)

    // normalize, scale, shift
    for i in 0..n {
        let x_hat = (input[i] - mean) * inv_std
        output[i] = x_hat * gamma[i] + beta[i]
    }
    return output
}

// ── RMSNorm (Llama-style): x / sqrt(mean(x^2) + eps) * gamma ───
@hot @pure
fn bnns_rms_norm(input, output, gamma, n, eps) {
    // compute mean of squares
    let mut sq_sum = 0.0
    for i in 0..n {
        sq_sum = sq_sum + input[i] * input[i]
    }
    let rms = sqrt(sq_sum / (n * 1.0) + eps)
    let inv_rms = 1.0 / rms

    // normalize and scale
    for i in 0..n {
        output[i] = input[i] * inv_rms * gamma[i]
    }
    return output
}

// ── BatchNorm (inference, given running stats): ──────────────────
//    output = (x - mean) / sqrt(var + eps) * gamma + beta
@hot @pure @fuse
fn bnns_batch_norm(input, output, gamma, beta, mean, var, n, eps) {
    for i in 0..n {
        let inv_std = 1.0 / sqrt(var[i] + eps)
        let x_hat = (input[i] - mean[i]) * inv_std
        output[i] = x_hat * gamma[i] + beta[i]
    }
    return output
}

// ===================================================================
//  3. ELEMENT-WISE OPS
// ===================================================================

// ── Add: out[i] = a[i] + b[i] ───────────────────────────────────
@hot @pure @fuse
fn bnns_add(a, b, out, n) {
    for i in 0..n {
        out[i] = a[i] + b[i]
    }
    return out
}

// ── Mul: out[i] = a[i] * b[i] ───────────────────────────────────
@hot @pure @fuse
fn bnns_mul(a, b, out, n) {
    for i in 0..n {
        out[i] = a[i] * b[i]
    }
    return out
}

// ── Scale: output[i] = input[i] * scalar ────────────────────────
@hot @pure @fuse
fn bnns_scale(input, output, scalar, n) {
    for i in 0..n {
        output[i] = input[i] * scalar
    }
    return output
}

// ── FMA: out[i] = a[i] * b[i] + c[i] ───────────────────────────
@hot @pure @fuse
fn bnns_fma(a, b, c, out, n) {
    for i in 0..n {
        out[i] = a[i] * b[i] + c[i]
    }
    return out
}

// ── Clamp: output[i] = clamp(input[i], lo, hi) ─────────────────
@hot @pure @fuse
fn bnns_clamp(input, output, lo, hi, n) {
    for i in 0..n {
        let mut v = input[i]
        if v < lo { v = lo }
        if v > hi { v = hi }
        output[i] = v
    }
    return output
}

// ===================================================================
//  4. REDUCTION OPS
// ===================================================================

// ── Sum: sum of all elements ─────────────────────────────────────
@hot @pure
fn bnns_sum(input, n) {
    let mut s = 0.0
    for i in 0..n {
        s = s + input[i]
    }
    return s
}

// ── Mean: average of all elements ────────────────────────────────
@hot @pure
fn bnns_mean(input, n) {
    let mut s = 0.0
    for i in 0..n {
        s = s + input[i]
    }
    return s / (n * 1.0)
}

// ── Variance: sum((x - mean)^2) / n ─────────────────────────────
@hot @pure
fn bnns_variance(input, mean_val, n) {
    let mut s = 0.0
    for i in 0..n {
        let d = input[i] - mean_val
        s = s + d * d
    }
    return s / (n * 1.0)
}

// ── Max: maximum element ─────────────────────────────────────────
@hot @pure
fn bnns_max(input, n) {
    let mut m = input[0]
    for i in 1..n {
        if input[i] > m {
            m = input[i]
        }
    }
    return m
}

// ── Argmax: index of maximum element ─────────────────────────────
@hot @pure
fn bnns_argmax(input, n) {
    let mut m = input[0]
    let mut idx = 0
    for i in 1..n {
        if input[i] > m {
            m = input[i]
            idx = i
        }
    }
    return idx
}

// ===================================================================
//  5. BNNS EXTERN STUBS (ready for future Accelerate BNNS linking)
//
//  When Apple Accelerate BNNS is available via extern FFI, uncomment
//  these declarations and update the dispatch layer to route through
//  native BNNS filters for hardware-accelerated execution (Metal GPU).
//
//  @link("Accelerate")
//  @symbol("BNNSFilterCreateLayerActivation")
//  extern fn bnns_create_activation(params: *Void) -> *Void
//
//  @link("Accelerate")
//  @symbol("BNNSFilterApply")
//  extern fn bnns_filter_apply(filter: *Void, input: *Void, output: *Void) -> i32
//
//  @link("Accelerate")
//  @symbol("BNNSFilterDestroy")
//  extern fn bnns_filter_destroy(filter: *Void) -> Void
//
//  @link("Accelerate")
//  @symbol("BNNSNormalizationFilterParameters")
//  extern fn bnns_create_norm(params: *Void) -> *Void
// ===================================================================

// ===================================================================
//  6. DISPATCH LAYER
// ===================================================================

// Returns 1 if native BNNS is available (Accelerate linked), 0 otherwise.
// Currently always 0 — pure hexa fallback. When extern stubs above are
// activated, this should check platform and return 1 on macOS/iOS.
fn bnns_has_native() {
    return 0
}

// Backend label for diagnostics
fn bnns_backend_name() {
    if bnns_has_native() == 1 {
        return "BNNS/Accelerate (native)"
    }
    return "pure-hexa (fallback)"
}
