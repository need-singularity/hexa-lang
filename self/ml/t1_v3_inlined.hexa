// ═══════════════════════════════════════════════════════════════════
//  self/ml/t1_v3_inlined.hexa — 7B T1 v3 (fully inlined forward)
//
//  v2 was 22.2s/token (0.045 tok/s). Root cause: hexa function-call
//  overhead on interpreter, not BLAS. v3 inlines every matmul inside
//  a single while-loop. No lr_proj/ffn_lowrank helpers.
//
//  Config: D=4096, FFN=16384, SEQ=128, VOCAB=32000, LORA_R=16,
//          n_layer=32 (change to 16 for linearity check)
//  BLAS-only: tensor_zeros, matmul, mat_add.
// ═══════════════════════════════════════════════════════════════════

let D       = 4096
let N_LAYER = 32
let FF      = 16384
let SEQ     = 128
let VOCAB   = 32000
let LORA_R  = 16
let VOCAB_R = 16

// ── Shared lowrank weights (reused across all layers) ─────────────
let Uq = tensor_zeros(D * LORA_R)
let Vq = tensor_zeros(LORA_R * D)
let Uk = tensor_zeros(D * LORA_R)
let Vk = tensor_zeros(LORA_R * D)
let Uv = tensor_zeros(D * LORA_R)
let Vv = tensor_zeros(LORA_R * D)
let Uo = tensor_zeros(D * LORA_R)
let Vo = tensor_zeros(LORA_R * D)

let U_up = tensor_zeros(D  * LORA_R)
let V_up = tensor_zeros(LORA_R * FF)
let U_dn = tensor_zeros(FF * LORA_R)
let V_dn = tensor_zeros(LORA_R * D)

let U_lmh = tensor_zeros(D * VOCAB_R)
let V_lmh = tensor_zeros(VOCAB_R * VOCAB)

// per-layer matmul count (attn 8 + ffn 4 + 2 residual adds count 0 blas mm):
//   Qs, Ks, Vs, scores, ctx_r, ctx, o_t, o,           = 8
//   ffn_up1, ffn_up2, ffn_dn1, ffn_dn2                = 4
// total BLAS matmul per layer = 12
let MM_PER_LAYER = 12

let H0 = tensor_zeros(SEQ * D)

let t0 = clock()

let mut X = H0
let mut layer_i = 0
while layer_i < N_LAYER {
    // ---- attention (lowrank Q/K/V/O) — inlined ----
    let Qs     = matmul(X,     Uq, SEQ, D,      LORA_R)
    let Ks     = matmul(X,     Uk, SEQ, D,      LORA_R)
    let Vs     = matmul(X,     Uv, SEQ, D,      LORA_R)
    let scores = matmul(Qs,    Ks, SEQ, LORA_R, SEQ)
    let ctx_r  = matmul(scores, Vs, SEQ, SEQ,    LORA_R)
    let ctx    = matmul(ctx_r, Vv, SEQ, LORA_R, D)
    let o_t    = matmul(ctx,   Uo, SEQ, D,      LORA_R)
    let o      = matmul(o_t,   Vo, SEQ, LORA_R, D)
    let h1     = mat_add(X, o)

    // ---- ffn (lowrank up + lowrank down) — inlined ----
    let fup1 = matmul(h1,   U_up, SEQ, D,      LORA_R)
    let fup2 = matmul(fup1, V_up, SEQ, LORA_R, FF)
    let fdn1 = matmul(fup2, U_dn, SEQ, FF,     LORA_R)
    let fdn2 = matmul(fdn1, V_dn, SEQ, LORA_R, D)
    let h2   = mat_add(h1, fdn2)

    X = h2
    layer_i = layer_i + 1
}

// lm_head inlined on full SEQ (skip last-token slice — keep it BLAS only)
let lmh_t   = matmul(X,     U_lmh, SEQ, D,       VOCAB_R)
let _logits = matmul(lmh_t, V_lmh, SEQ, VOCAB_R, VOCAB)

let t1 = clock()

let fwd_ms         = (t1 - t0) * 1000.0
let tok_s          = 1000.0 / fwd_ms
let v2_22s_ms      = 22200.0
let vs_v2_22s      = v2_22s_ms / fwd_ms
let target_128_pct = tok_s / 128.0
let matmul_count   = N_LAYER * MM_PER_LAYER + 2

let mut line = "{"
line = line + "\"phase\":\"t1_v3\""
line = line + ",\"D\":" + str(D)
line = line + ",\"n_layer\":" + str(N_LAYER)
line = line + ",\"seq\":" + str(SEQ)
line = line + ",\"lora_r\":" + str(LORA_R)
line = line + ",\"fwd_ms\":" + str(fwd_ms)
line = line + ",\"tok_s\":" + str(tok_s)
line = line + ",\"matmul_count\":" + str(matmul_count)
line = line + ",\"vs_v2_22s\":" + str(vs_v2_22s)
line = line + ",\"target_128_pct\":" + str(target_128_pct)
line = line + "}"
println(line)
println("[t1_v3] OK")
