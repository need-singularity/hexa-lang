// ===================================================================
//  gradient_accumulation.hexa — Gradient Accumulation for Training
//
//  Accumulate gradients over multiple micro-batches before
//  performing an optimizer step. Enables large effective batch sizes
//  on memory-constrained hardware.
//
//  API:
//    create_accumulator(steps)         -> GradAccumulator
//    accumulate(acc, grad)             -> GradAccumulator (updated)
//    should_step(acc)                  -> bool
//    get_accumulated(acc)              -> array (averaged gradients)
//    reset(acc)                        -> GradAccumulator (zeroed)
//
//  Uses no external imports -- pure hexa.
// ===================================================================

// ── Structs ─────────────────────────────────────────────────────

struct GradAccumulator {
    accumulation_steps: int,
    current_step: int,
    accumulated_grads: array,
    total_steps_done: int,
    num_optimizer_steps: int,
    is_initialized: bool
}

// ── Create Accumulator ──────────────────────────────────────────

fn create_accumulator(steps) {
    if steps < 1 {
        println("[grad_accum] WARNING: steps must be >= 1, defaulting to 1")
        return GradAccumulator {
            accumulation_steps: 1,
            current_step: 0,
            accumulated_grads: [],
            total_steps_done: 0,
            num_optimizer_steps: 0,
            is_initialized: false
        }
    }
    return GradAccumulator {
        accumulation_steps: steps,
        current_step: 0,
        accumulated_grads: [],
        total_steps_done: 0,
        num_optimizer_steps: 0,
        is_initialized: false
    }
}

// ── Accumulate ──────────────────────────────────────────────────
// Add gradient to the accumulation buffer.
// On first call, initializes buffer from gradient shape.

fn accumulate(acc, grad) {
    let n = len(grad)

    if !acc.is_initialized {
        // First accumulation: initialize buffer with this gradient
        let mut init_grads = []
        let mut i = 0
        while i < n {
            init_grads = init_grads + [grad[i]]
            i = i + 1
        }
        return GradAccumulator {
            accumulation_steps: acc.accumulation_steps,
            current_step: 1,
            accumulated_grads: init_grads,
            total_steps_done: acc.total_steps_done + 1,
            num_optimizer_steps: acc.num_optimizer_steps,
            is_initialized: true
        }
    }

    // Add gradient element-wise to accumulated buffer
    let an = len(acc.accumulated_grads)
    let mut new_grads = []
    let mut i = 0
    while i < an {
        let gi = i % n
        new_grads = new_grads + [acc.accumulated_grads[i] + grad[gi]]
        i = i + 1
    }

    return GradAccumulator {
        accumulation_steps: acc.accumulation_steps,
        current_step: acc.current_step + 1,
        accumulated_grads: new_grads,
        total_steps_done: acc.total_steps_done + 1,
        num_optimizer_steps: acc.num_optimizer_steps,
        is_initialized: true
    }
}

// ── Should Step ─────────────────────────────────────────────────
// Returns true when accumulation_steps micro-batches have been accumulated.

fn should_step(acc) {
    return acc.current_step >= acc.accumulation_steps
}

// ── Get Accumulated ─────────────────────────────────────────────
// Return the averaged accumulated gradients (divide by accumulation_steps).

fn get_accumulated(acc) {
    let n = len(acc.accumulated_grads)
    let divisor = to_float(acc.accumulation_steps)
    let mut out = []
    let mut i = 0
    while i < n {
        out = out + [acc.accumulated_grads[i] / divisor]
        i = i + 1
    }
    return out
}

// ── Reset ───────────────────────────────────────────────────────
// Zero the accumulation buffer and reset step counter.
// Keeps track of total optimizer steps done.

fn reset(acc) {
    let n = len(acc.accumulated_grads)
    let mut zeros = []
    let mut i = 0
    while i < n {
        zeros = zeros + [0.0]
        i = i + 1
    }
    return GradAccumulator {
        accumulation_steps: acc.accumulation_steps,
        current_step: 0,
        accumulated_grads: zeros,
        total_steps_done: acc.total_steps_done,
        num_optimizer_steps: acc.num_optimizer_steps + 1,
        is_initialized: true
    }
}

// ── Effective Batch Size ────────────────────────────────────────

fn effective_batch_size(micro_batch, accumulation_steps) {
    return micro_batch * accumulation_steps
}

// ── Gradient Sync Check ─────────────────────────────────────────
// In distributed training, gradient sync should only happen when
// accumulation is complete (should_step returns true).

fn should_sync(acc) {
    return should_step(acc)
}

// ── Summary ─────────────────────────────────────────────────────

fn grad_accum_summary(acc) {
    println("[grad_accum] steps=" + str(acc.accumulation_steps) + " current=" + str(acc.current_step) + " total=" + str(acc.total_steps_done) + " optimizer_steps=" + str(acc.num_optimizer_steps))
}

println("[gradient_accumulation] loaded — accumulate + step check + reset + effective batch size")
