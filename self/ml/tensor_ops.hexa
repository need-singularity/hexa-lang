// ═══════════════════════════════════════════════════════════════════
//  tensor_ops.hexa — user-level tensor operations extension
//  Built on top of tensor_zeros/tensor_fill/tensor/dot primitives.
//  Pure hexa; no interpreter modifications required.
//  Last verified: 2026-04-11
// ═══════════════════════════════════════════════════════════════════

// ── Construction ─────────────────────────────────────────────

fn tensor_ones(n) {
    return tensor_fill(n, 1.0)
}

fn tensor_range(start, end) {
    let mut arr = []
    let mut i = start
    while i < end {
        arr.push(to_float(i))
        i = i + 1
    }
    return tensor(arr)
}

fn tensor_linspace(start, stop, n) {
    // n points from start to stop inclusive
    if n <= 1 { return tensor([start]) }
    let step = (stop - start) / to_float(n - 1)
    let mut arr = []
    let mut i = 0
    while i < n {
        arr.push(start + to_float(i) * step)
        i = i + 1
    }
    return tensor(arr)
}

// ── Elementwise binary ops ───────────────────────────────────

fn tensor_add(a, b) {
    let n = len(a)
    let m = len(b)
    let k = if n < m { n } else { m }
    let mut arr = []
    let mut i = 0
    while i < k {
        arr.push(a[i] + b[i])
        i = i + 1
    }
    return tensor(arr)
}

fn tensor_sub(a, b) {
    let n = len(a)
    let m = len(b)
    let k = if n < m { n } else { m }
    let mut arr = []
    let mut i = 0
    while i < k {
        arr.push(a[i] - b[i])
        i = i + 1
    }
    return tensor(arr)
}

fn tensor_mul(a, b) {
    // Elementwise (Hadamard) product
    let n = len(a)
    let m = len(b)
    let k = if n < m { n } else { m }
    let mut arr = []
    let mut i = 0
    while i < k {
        arr.push(a[i] * b[i])
        i = i + 1
    }
    return tensor(arr)
}

// ── Scalar ops ───────────────────────────────────────────────

fn tensor_scale(t, s) {
    let n = len(t)
    let mut arr = []
    let mut i = 0
    while i < n {
        arr.push(t[i] * s)
        i = i + 1
    }
    return tensor(arr)
}

fn tensor_add_scalar(t, s) {
    let n = len(t)
    let mut arr = []
    let mut i = 0
    while i < n {
        arr.push(t[i] + s)
        i = i + 1
    }
    return tensor(arr)
}

// ── Unary element ops ────────────────────────────────────────

fn tensor_neg(t) {
    return tensor_scale(t, -1.0)
}

fn tensor_abs(t) {
    let n = len(t)
    let mut arr = []
    let mut i = 0
    while i < n {
        let v = t[i]
        if v < 0.0 { arr.push(0.0 - v) } else { arr.push(v) }
        i = i + 1
    }
    return tensor(arr)
}

// ── Reductions (return scalars) ──────────────────────────────

fn tensor_sum(t) {
    let n = len(t)
    let mut s = 0.0
    let mut i = 0
    while i < n { s = s + t[i]; i = i + 1 }
    return s
}

fn tensor_mean(t) {
    let n = len(t)
    if n == 0 { return 0.0 }
    return tensor_sum(t) / to_float(n)
}

fn tensor_max(t) {
    let n = len(t)
    if n == 0 { return 0.0 }
    let mut m = t[0]
    let mut i = 1
    while i < n {
        if t[i] > m { m = t[i] }
        i = i + 1
    }
    return m
}

fn tensor_min(t) {
    let n = len(t)
    if n == 0 { return 0.0 }
    let mut m = t[0]
    let mut i = 1
    while i < n {
        if t[i] < m { m = t[i] }
        i = i + 1
    }
    return m
}

fn tensor_norm_l2(t) {
    // sqrt(dot(t, t)) — Euclidean norm
    return sqrt(dot(t, t))
}

// ── Self-test (runs when file is executed directly) ──────────

proof tensor_ops_suite {
    let a = tensor_ones(5)
    assert tensor_sum(a) == 5.0
    assert tensor_mean(a) == 1.0
    assert tensor_max(a) == 1.0
    assert tensor_min(a) == 1.0

    let b = tensor_range(0, 5)
    assert tensor_sum(b) == 10.0    // 0+1+2+3+4
    assert tensor_mean(b) == 2.0
    assert tensor_max(b) == 4.0
    assert tensor_min(b) == 0.0

    let c = tensor_add(a, b)
    assert tensor_sum(c) == 15.0    // 1+2+3+4+5

    let d = tensor_sub(b, a)
    assert tensor_sum(d) == 5.0     // -1+0+1+2+3

    let e = tensor_mul(b, b)
    assert tensor_sum(e) == 30.0    // 0+1+4+9+16

    let f = tensor_scale(a, 3.0)
    assert tensor_sum(f) == 15.0

    let g = tensor_neg(b)
    assert tensor_sum(g) == 0.0 - 10.0

    let h = tensor_abs(tensor_neg(b))
    assert tensor_sum(h) == 10.0

    let lin = tensor_linspace(0.0, 4.0, 5)
    assert tensor_sum(lin) == 10.0  // 0+1+2+3+4

    let norm = tensor_norm_l2(tensor_range(0, 5))
    // sqrt(0+1+4+9+16) = sqrt(30)
    assert norm > 5.47 && norm < 5.48

    println("tensor_ops: all 15 assertions pass")
}
