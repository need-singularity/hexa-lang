// ═══════════════════════════════════════════════════════════════════
//  self/ml/deduplication.hexa — MinHash+LSH Deduplication (#127)
//
//  Comprehensive deduplication for large-scale data cleaning.
//
//  Implements:
//    1. N-gram shingling (char & word)
//    2. MinHash signature (k hash functions)
//    3. LSH banding (b bands x r rows)
//    4. Union-Find (disjoint set) for cluster merging
//    5. Exact dedup (hash-based identical detection)
//    6. Fuzzy dedup (Jaccard similarity via LSH)
//    7. SimHash document fingerprinting
//    8. Streaming/online deduplication mode
//    9. Configurable thresholds and parameters
//
//  API:
//    dd_char_shingle(text, k)                    -> [string]
//    dd_word_shingle(text, k)                     -> [string]
//    dd_hash(s)                                   -> int
//    dd_hash_family(val, seed)                    -> int
//    dd_minhash_sig(shingles, num_hashes)         -> [int]
//    dd_lsh_band_key(sig, band, rows)             -> int
//    dd_lsh_buckets(sig, bands, rows)             -> [int]
//    dd_lsh_candidate_pairs(sigs, bands, rows)    -> [[i,j]]
//    dd_jaccard_exact(set_a, set_b)               -> float
//    dd_jaccard_minhash(sig_a, sig_b)             -> float
//    dd_uf_make(n)                                -> [int]
//    dd_uf_find(parent, x)                        -> int
//    dd_uf_union(parent, rank, a, b)              -> [parent, rank]
//    dd_exact_dedup(texts)                        -> [int] (keep flags)
//    dd_fuzzy_dedup(texts, cfg)                   -> [int] (cluster ids)
//    dd_simhash(text, k)                          -> int
//    dd_simhash_distance(a, b)                    -> int
//    dd_stream_new(cfg)                            -> state
//    dd_stream_add(state, text)                   -> [state, is_dup]
//    dd_dedup_pipeline(texts, cfg)                -> [unique_texts]
//    dd_config(num_hashes, bands, rows, threshold, shingle_k)
//
//  AI-NATIVE attrs:
//    @pure  — no side effects
//    @hot   — performance critical path
// ═══════════════════════════════════════════════════════════════════

// ── helpers ──────────────────────────────────────────────────────

fn dd_abs(x) {
    if x < 0 { return 0 - x }
    return x
}

fn dd_abs_f(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn dd_min(a, b) {
    if a < b { return a }
    return b
}

fn dd_max(a, b) {
    if a > b { return a }
    return b
}

// ═══════════════════════════════════════════════════════════════════
//  Configuration — default parameters for dedup pipeline
// ═══════════════════════════════════════════════════════════════════

fn dd_config(num_hashes, bands, rows, threshold, shingle_k) {
    return [num_hashes, bands, rows, threshold, shingle_k]
}

fn dd_config_default() {
    // 64 hashes, 16 bands, 4 rows, 0.5 threshold, 3-char shingles
    return dd_config(64, 16, 4, 0.5, 3)
}

fn dd_cfg_num_hashes(cfg) { return cfg[0] }
fn dd_cfg_bands(cfg) { return cfg[1] }
fn dd_cfg_rows(cfg) { return cfg[2] }
fn dd_cfg_threshold(cfg) { return cfg[3] }
fn dd_cfg_shingle_k(cfg) { return cfg[4] }

// ═══════════════════════════════════════════════════════════════════
//  Hash Functions — DJB2 variant + multiplicative family
// ═══════════════════════════════════════════════════════════════════

@pure @hot
fn dd_hash(s) {
    let n = len(s)
    let mut h = 5381
    for i in 0..n {
        let c = char_code(s, i)
        h = h * 33 + c
        if h > 1000000000 { h = h % 1000000007 }
        if h < -1000000000 { h = (0 - h) % 1000000007 }
    }
    if h < 0 { h = 0 - h }
    return h
}

// FNV-1a variant for second independent hash
@pure @hot
fn dd_hash_fnv(s) {
    let n = len(s)
    let mut h = 2166136261
    for i in 0..n {
        let c = char_code(s, i)
        h = h ^ c
        h = h * 16777619
        if h > 1000000000 { h = h % 1000000007 }
        if h < -1000000000 { h = (0 - h) % 1000000007 }
    }
    if h < 0 { h = 0 - h }
    return h
}

// Hash family: (a * val + b) mod p with seed-derived a, b
@pure @hot
fn dd_hash_family(val, seed) {
    let a = seed * 1103515245 + 12345
    let b = seed * 214013 + 2531011
    let p = 1000000007
    let mut h = a * val + b
    if h < 0 { h = 0 - h }
    h = h % p
    return h
}

// ═══════════════════════════════════════════════════════════════════
//  Character N-gram Shingling
//
//  Extracts all unique k-character substrings from text.
//  Returns: array of unique shingle strings
// ═══════════════════════════════════════════════════════════════════
@pure
fn dd_char_shingle(text, k) {
    let n = len(text)
    let mut shingles = []
    if n < k { return [text] }
    for i in 0..(n - k + 1) {
        let mut s = ""
        for j in 0..k {
            s = s + text[i + j]
        }
        // dedup: check if already present
        let mut found = false
        for si in 0..len(shingles) {
            if shingles[si] == s { found = true }
        }
        if !found {
            shingles = shingles + [s]
        }
    }
    return shingles
}

// ═══════════════════════════════════════════════════════════════════
//  Word N-gram Shingling
//
//  Splits text on spaces, then extracts all unique k-word windows.
//  Returns: array of unique word-shingle strings
// ═══════════════════════════════════════════════════════════════════
@pure
fn dd_word_shingle(text, k) {
    let words = text.split(" ")
    let nw = len(words)
    let mut shingles = []
    if nw < k {
        return [text]
    }
    for i in 0..(nw - k + 1) {
        let mut s = ""
        for j in 0..k {
            if j > 0 { s = s + " " }
            s = s + words[i + j]
        }
        let mut found = false
        for si in 0..len(shingles) {
            if shingles[si] == s { found = true }
        }
        if !found {
            shingles = shingles + [s]
        }
    }
    return shingles
}

// ═══════════════════════════════════════════════════════════════════
//  MinHash Signature
//
//  For each of num_hashes hash functions, compute min hash over
//  the shingle set. Produces a compact signature for Jaccard
//  estimation.
//
//  sig[i] = min { hash_family(hash(shingle), i+1) : shingle in set }
// ═══════════════════════════════════════════════════════════════════
@pure @hot
fn dd_minhash_sig(shingles, num_hashes) {
    let n_sh = len(shingles)
    let mut sig = []
    for hi in 0..num_hashes {
        let mut min_val = 2000000000
        for si in 0..n_sh {
            let sh = dd_hash(shingles[si])
            let hv = dd_hash_family(sh, hi + 1)
            if hv < min_val { min_val = hv }
        }
        sig = sig + [min_val]
    }
    return sig
}

// ═══════════════════════════════════════════════════════════════════
//  LSH Banding — hash each band of the signature
//
//  Divides the signature into `bands` segments of `rows` each.
//  Each band is hashed to a bucket key. Two signatures that
//  share a bucket in ANY band are candidate near-duplicates.
//
//  Probability of becoming candidate = 1 - (1 - s^r)^b
//  where s = Jaccard similarity, r = rows, b = bands
// ═══════════════════════════════════════════════════════════════════
@pure @hot
fn dd_lsh_band_key(sig, band, rows) {
    let start = band * rows
    let mut h = 0
    for i in 0..rows {
        let idx = start + i
        if idx < len(sig) {
            h = h * 31 + sig[idx]
            if h > 1000000000 { h = h % 1000000007 }
            if h < -1000000000 { h = (0 - h) % 1000000007 }
        }
    }
    if h < 0 { h = 0 - h }
    return h
}

@pure
fn dd_lsh_buckets(sig, bands, rows) {
    let mut keys = []
    for b in 0..bands {
        keys = keys + [dd_lsh_band_key(sig, b, rows)]
    }
    return keys
}

// Find all candidate pairs that share at least one band bucket
@pure
fn dd_lsh_candidate_pairs(sigs, bands, rows) {
    let n = len(sigs)
    // Precompute all bucket keys
    let mut all_keys = []
    for i in 0..n {
        all_keys = all_keys + [dd_lsh_buckets(sigs[i], bands, rows)]
    }
    // Find matching pairs
    let mut pairs = []
    for i in 0..n {
        for j in (i + 1)..n {
            let mut matched = false
            for b in 0..bands {
                if all_keys[i][b] == all_keys[j][b] {
                    matched = true
                }
            }
            if matched {
                pairs = pairs + [[i, j]]
            }
        }
    }
    return pairs
}

// ═══════════════════════════════════════════════════════════════════
//  Jaccard Similarity — exact (set comparison)
// ═══════════════════════════════════════════════════════════════════
@pure
fn dd_jaccard_exact(set_a, set_b) {
    let na = len(set_a)
    let nb = len(set_b)
    let mut inter = 0
    for i in 0..na {
        for j in 0..nb {
            if set_a[i] == set_b[j] { inter = inter + 1 }
        }
    }
    let union_size = na + nb - inter
    if union_size == 0 { return 1.0 }
    return to_float(inter) / to_float(union_size)
}

// ═══════════════════════════════════════════════════════════════════
//  Jaccard Similarity — MinHash approximation
//
//  Fraction of signature positions where sig_a[i] == sig_b[i]
//  approximates the true Jaccard similarity.
// ═══════════════════════════════════════════════════════════════════
@pure @hot
fn dd_jaccard_minhash(sig_a, sig_b) {
    let n = len(sig_a)
    if n == 0 { return 0.0 }
    let mut agree = 0
    for i in 0..n {
        if sig_a[i] == sig_b[i] { agree = agree + 1 }
    }
    return to_float(agree) / to_float(n)
}

// ═══════════════════════════════════════════════════════════════════
//  Union-Find (Disjoint Set) with rank
//
//  dd_uf_make(n) -> parent array (each element is own parent)
//  dd_uf_find(parent, x) -> root with path compression
//  dd_uf_union(parent, rank, a, b) -> updated [parent, rank]
// ═══════════════════════════════════════════════════════════════════

fn dd_uf_make(n) {
    let mut parent = []
    let mut rank = []
    for i in 0..n {
        parent = parent + [i]
        rank = rank + [0]
    }
    return [parent, rank]
}

fn dd_uf_find(parent, x) {
    let mut cur = x
    while parent[cur] != cur {
        // path compression: point to grandparent
        let gp = parent[parent[cur]]
        parent[cur] = gp
        cur = gp
    }
    return cur
}

fn dd_uf_union(parent, rank, a, b) {
    let ra = dd_uf_find(parent, a)
    let rb = dd_uf_find(parent, b)
    if ra == rb { return [parent, rank] }
    // union by rank
    if rank[ra] < rank[rb] {
        parent[ra] = rb
    } else {
        if rank[ra] > rank[rb] {
            parent[rb] = ra
        } else {
            parent[rb] = ra
            rank[ra] = rank[ra] + 1
        }
    }
    return [parent, rank]
}

// ═══════════════════════════════════════════════════════════════════
//  Exact Dedup — hash-based identical document detection
//
//  Returns array of 0/1 flags: 1 = keep (first occurrence),
//  0 = duplicate (later occurrence with same hash)
// ═══════════════════════════════════════════════════════════════════
@pure
fn dd_exact_dedup(texts) {
    let n = len(texts)
    let mut seen_hashes = []
    let mut flags = []
    for i in 0..n {
        let h = dd_hash(texts[i])
        let mut is_dup = false
        for j in 0..len(seen_hashes) {
            if seen_hashes[j] == h { is_dup = true }
        }
        if is_dup {
            flags = flags + [0]
        } else {
            seen_hashes = seen_hashes + [h]
            flags = flags + [1]
        }
    }
    return flags
}

// Exact dedup returning only unique texts
@pure
fn dd_exact_dedup_texts(texts) {
    let flags = dd_exact_dedup(texts)
    let n = len(texts)
    let mut result = []
    for i in 0..n {
        if flags[i] == 1 {
            result = result + [texts[i]]
        }
    }
    return result
}

// ═══════════════════════════════════════════════════════════════════
//  Fuzzy Dedup — MinHash+LSH pipeline with configurable params
//
//  Returns cluster IDs: documents in the same cluster are
//  near-duplicates (Jaccard >= threshold).
// ═══════════════════════════════════════════════════════════════════
@pure
fn dd_fuzzy_dedup(texts, cfg) {
    let num_hashes = dd_cfg_num_hashes(cfg)
    let bands = dd_cfg_bands(cfg)
    let rows = dd_cfg_rows(cfg)
    let threshold = dd_cfg_threshold(cfg)
    let k = dd_cfg_shingle_k(cfg)
    let n = len(texts)

    // Step 1: shingle
    let mut shingle_sets = []
    for i in 0..n {
        shingle_sets = shingle_sets + [dd_char_shingle(texts[i], k)]
    }

    // Step 2: MinHash signatures
    let mut sigs = []
    for i in 0..n {
        sigs = sigs + [dd_minhash_sig(shingle_sets[i], num_hashes)]
    }

    // Step 3: LSH candidate pairs
    let candidates = dd_lsh_candidate_pairs(sigs, bands, rows)

    // Step 4: Union-Find with threshold verification
    let uf = dd_uf_make(n)
    let mut parent = uf[0]
    let mut rank = uf[1]
    for ci in 0..len(candidates) {
        let a = candidates[ci][0]
        let b = candidates[ci][1]
        let sim = dd_jaccard_minhash(sigs[a], sigs[b])
        if sim >= threshold {
            let result = dd_uf_union(parent, rank, a, b)
            parent = result[0]
            rank = result[1]
        }
    }

    // Flatten to cluster IDs
    let mut clusters = []
    for i in 0..n {
        clusters = clusters + [dd_uf_find(parent, i)]
    }
    return clusters
}

// Return unique texts (first from each cluster)
@pure
fn dd_fuzzy_dedup_texts(texts, cfg) {
    let clusters = dd_fuzzy_dedup(texts, cfg)
    let n = len(texts)
    let mut seen = []
    let mut result = []
    for i in 0..n {
        let cid = clusters[i]
        let mut found = false
        for j in 0..len(seen) {
            if seen[j] == cid { found = true }
        }
        if !found {
            seen = seen + [cid]
            result = result + [texts[i]]
        }
    }
    return result
}

// ═══════════════════════════════════════════════════════════════════
//  SimHash — Document Fingerprinting
//
//  Produces a single integer fingerprint per document.
//  Similar documents have fingerprints with small Hamming distance.
//
//  Algorithm:
//    1. Extract shingles
//    2. For each bit position, accumulate +1/-1 votes from shingles
//    3. Final fingerprint: bit i = 1 if sum >= 0, else 0
//
//  Using 32-bit fingerprint (hexa int is 64-bit, using lower 32)
// ═══════════════════════════════════════════════════════════════════
@pure
fn dd_simhash(text, k) {
    let shingles = dd_char_shingle(text, k)
    let n_sh = len(shingles)
    let num_bits = 32
    // Accumulate weighted votes per bit
    let mut votes = []
    for _b in 0..num_bits {
        votes = votes + [0]
    }
    for si in 0..n_sh {
        let h = dd_hash(shingles[si])
        let mut bit_val = h
        for b in 0..num_bits {
            if bit_val % 2 == 1 {
                votes[b] = votes[b] + 1
            } else {
                votes[b] = votes[b] - 1
            }
            bit_val = bit_val / 2
        }
    }
    // Construct fingerprint
    let mut fp = 0
    let mut power = 1
    for b in 0..num_bits {
        if votes[b] >= 0 {
            fp = fp + power
        }
        power = power * 2
    }
    return fp
}

// Hamming distance between two SimHash fingerprints
@pure
fn dd_simhash_distance(a, b) {
    let mut xor_val = a ^ b
    if xor_val < 0 { xor_val = 0 - xor_val }
    let mut dist = 0
    let mut v = xor_val
    while v > 0 {
        dist = dist + (v % 2)
        v = v / 2
    }
    return dist
}

// SimHash similarity: 1 - (hamming_distance / num_bits)
@pure
fn dd_simhash_similarity(a, b) {
    let dist = dd_simhash_distance(a, b)
    return 1.0 - to_float(dist) / 32.0
}

// ═══════════════════════════════════════════════════════════════════
//  Streaming / Online Deduplication
//
//  Maintains a state of seen fingerprints and MinHash signatures.
//  Each new document is checked against existing entries before
//  being added.
//
//  State: [seen_hashes, seen_sigs, cfg, count]
//    seen_hashes: array of exact hashes for O(1) exact dedup
//    seen_sigs:   array of MinHash signatures for fuzzy dedup
//    cfg:         dedup config
//    count:       number of unique docs seen
// ═══════════════════════════════════════════════════════════════════

// Streaming dedup uses module-level mutable state to avoid
// mixed-type arrays. Call dd_stream_new() to reset.
let mut _dd_stream_hashes = []
let mut _dd_stream_sigs = []
let mut _dd_stream_cfg = dd_config_default()
let mut _dd_stream_count = 0

fn dd_stream_new(cfg) {
    _dd_stream_hashes = []
    _dd_stream_sigs = []
    _dd_stream_cfg = cfg
    _dd_stream_count = 0
}

fn dd_stream_add(text) {
    let threshold = dd_cfg_threshold(_dd_stream_cfg)
    let num_hashes = dd_cfg_num_hashes(_dd_stream_cfg)
    let bands = dd_cfg_bands(_dd_stream_cfg)
    let rows = dd_cfg_rows(_dd_stream_cfg)
    let k = dd_cfg_shingle_k(_dd_stream_cfg)

    // Step 1: Exact dedup check
    let h = dd_hash(text)
    for i in 0..len(_dd_stream_hashes) {
        if _dd_stream_hashes[i] == h {
            return 1
        }
    }

    // Step 2: Fuzzy dedup check via MinHash + LSH
    let shingles = dd_char_shingle(text, k)
    let sig = dd_minhash_sig(shingles, num_hashes)
    let buckets = dd_lsh_buckets(sig, bands, rows)

    for i in 0..len(_dd_stream_sigs) {
        let existing_sig = _dd_stream_sigs[i]
        let existing_buckets = dd_lsh_buckets(existing_sig, bands, rows)
        let mut band_match = false
        for b in 0..bands {
            if buckets[b] == existing_buckets[b] {
                band_match = true
            }
        }
        if band_match {
            let sim = dd_jaccard_minhash(sig, existing_sig)
            if sim >= threshold {
                return 1
            }
        }
    }

    // Not a duplicate, add to state
    _dd_stream_hashes = _dd_stream_hashes + [h]
    _dd_stream_sigs = _dd_stream_sigs + [sig]
    _dd_stream_count = _dd_stream_count + 1
    return 0
}

// Get count of unique documents in stream
fn dd_stream_count() {
    return _dd_stream_count
}

// ═══════════════════════════════════════════════════════════════════
//  LSH Probability Curve
//
//  P(candidate | Jaccard = s) = 1 - (1 - s^r)^b
//  Useful for parameter tuning.
// ═══════════════════════════════════════════════════════════════════
@pure
fn dd_lsh_probability(similarity, bands, rows) {
    // s^r
    let mut sr = 1.0
    for _i in 0..rows {
        sr = sr * similarity
    }
    // (1 - s^r)^b
    let one_minus_sr = 1.0 - sr
    let mut result = 1.0
    for _i in 0..bands {
        result = result * one_minus_sr
    }
    return 1.0 - result
}

// ═══════════════════════════════════════════════════════════════════
//  Full Dedup Pipeline — exact + fuzzy combined
//
//  1. Exact dedup (remove identical documents)
//  2. Fuzzy dedup (cluster near-duplicates via MinHash+LSH)
//  Returns: array of unique texts
// ═══════════════════════════════════════════════════════════════════
@pure
fn dd_dedup_pipeline(texts, cfg) {
    // Phase 1: exact dedup
    let exact_unique = dd_exact_dedup_texts(texts)
    // Phase 2: fuzzy dedup on remaining
    let fuzzy_unique = dd_fuzzy_dedup_texts(exact_unique, cfg)
    return fuzzy_unique
}

// ═══════════════════════════════════════════════════════════════════
//  Utility: Count unique clusters
// ═══════════════════════════════════════════════════════════════════
fn dd_count_clusters(clusters) {
    let n = len(clusters)
    let mut unique = []
    for i in 0..n {
        let mut found = false
        for j in 0..len(unique) {
            if unique[j] == clusters[i] { found = true }
        }
        if !found {
            unique = unique + [clusters[i]]
        }
    }
    return len(unique)
}

// ═══════════════════════════════════════════════════════════════════
//  Utility: Document statistics
//
//  Returns [n_total, n_exact_dup, n_fuzzy_clusters, n_unique]
// ═══════════════════════════════════════════════════════════════════
fn dd_stats(texts, cfg) {
    let n_total = len(texts)
    // exact dedup
    let exact_flags = dd_exact_dedup(texts)
    let mut n_exact_dup = 0
    for i in 0..n_total {
        if exact_flags[i] == 0 { n_exact_dup = n_exact_dup + 1 }
    }
    // fuzzy dedup on exact-unique
    let exact_unique = dd_exact_dedup_texts(texts)
    let clusters = dd_fuzzy_dedup(exact_unique, cfg)
    let n_clusters = dd_count_clusters(clusters)
    return [n_total, n_exact_dup, n_clusters, len(dd_dedup_pipeline(texts, cfg))]
}

// ═══════════════════════════════════════════════════════════════════
//  Weighted MinHash — for documents with TF weights
//
//  Instead of binary shingle presence, uses integer counts
//  (term frequency) to weight the signature.
//  shingle_weights: array of [shingle_str, weight] pairs
// ═══════════════════════════════════════════════════════════════════
// Weighted MinHash: takes parallel arrays of shingles and weights
@pure
fn dd_weighted_minhash(shingles, weights, num_hashes) {
    let n_sw = len(shingles)
    let mut sig = []
    for hi in 0..num_hashes {
        let mut min_val = 2000000000
        for si in 0..n_sw {
            let sh = dd_hash(shingles[si])
            let hv = dd_hash_family(sh, hi + 1)
            let mut effective = hv
            if weights[si] > 1 {
                effective = hv / weights[si]
            }
            if effective < min_val { min_val = effective }
        }
        sig = sig + [min_val]
    }
    return sig
}

// ═══════════════════════════════════════════════════════════════════
//  Containment Similarity
//
//  J_containment(A, B) = |A ∩ B| / |A|
//  Useful when document sizes differ greatly.
// ═══════════════════════════════════════════════════════════════════
@pure
fn dd_containment(set_a, set_b) {
    let na = len(set_a)
    if na == 0 { return 0.0 }
    let mut inter = 0
    for i in 0..na {
        for j in 0..len(set_b) {
            if set_a[i] == set_b[j] { inter = inter + 1 }
        }
    }
    return to_float(inter) / to_float(na)
}

println("[deduplication] loaded — MinHash+LSH + SimHash + streaming + exact/fuzzy dedup")
