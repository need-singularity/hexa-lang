// ═══════════════════════════════════════════════════════════════
//  distributed_train.hexa — Multi-GPU data-parallel training loop
//
//  Each GPU gets batch_size/num_gpus samples.
//  Forward + backward independently per GPU.
//  AllReduce gradients across GPUs.
//  Synchronized AdamW optimizer step.
//  Gradient accumulation for effective larger batch sizes.
//
//  Usage:
//    use "distributed_train"
//    let _ = dist_train(4)   // train on 4 GPUs
// ═══════════════════════════════════════════════════════════════

use "cuda_ffi"
use "gpu_tensor"
use "gpu_grad_engine"
use "gpu_optimizer"
use "model_100m_gpu"
use "distributed"

// ── Training config ──────────────────────────────────────────
let DIST_STEPS       = 100
let DIST_WARMUP      = 10
let DIST_PEAK_LR     = 3.0e-4
let DIST_MIN_LR      = 3.0e-5
let DIST_MAX_GNORM   = 1.0
let DIST_LOG_INTERVAL = 1
let DIST_ACCUM_STEPS  = 1    // gradient accumulation steps

// ── Per-GPU worker state ─────────────────────────────────────
// Holds the model replica + optimizer for one GPU
struct GpuWorker {
    gpu_id: int,
    weights: array,
    opt_states: array,
    seq_len: int
}

// Initialize a worker on a given GPU
fn init_worker(gpu_id, seq_len) {
    let _ = cudaSetDevice(gpu_id)
    let _ = cuda_init()

    println("[dist_train] GPU " + str(gpu_id) + " — initializing model replica")
    let weights = init_model_weights()

    let all_params = model_params(weights)
    let n_params = len(all_params)
    let mut opt_states = []
    let mut i = 0
    while i < n_params {
        opt_states = opt_states.push(adam_state_create(all_params[i]))
        i = i + 1
    }

    let w = GpuWorker {
        gpu_id: gpu_id,
        weights: weights,
        opt_states: opt_states,
        seq_len: seq_len
    }
    w
}

// ── Synthetic batch generator ────────────────────────────────
fn make_dist_batch(seq_len, vocab_size) {
    let mut tokens = []
    let mut targets = []
    let mut i = 0
    while i < seq_len {
        let tok = int(random() * vocab_size) % vocab_size
        tokens = tokens.push(tok)
        i = i + 1
    }
    i = 0
    while i < seq_len {
        if i < seq_len - 1 {
            targets = targets.push(tokens[i + 1])
        } else {
            targets = targets.push(int(random() * vocab_size) % vocab_size)
        }
        i = i + 1
    }
    [tokens, targets]
}

// ── Cosine LR schedule ──────────────────────────────────────
fn dist_lr_cosine(step, warmup, total, peak, minimum) {
    if step <= warmup {
        return minimum + (peak - minimum) * (step * 1.0) / (warmup * 1.0)
    }
    let progress = ((step - warmup) * 1.0) / ((total - warmup) * 1.0)
    let cosval = cos(progress * 3.14159265)
    minimum + (peak - minimum) * 0.5 * (1.0 + cosval)
}

// ── Single GPU forward+backward step ─────────────────────────
// Returns [loss, grads_array]
fn worker_forward_backward(worker: GpuWorker, tokens, targets) {
    let _ = cudaSetDevice(worker.gpu_id)

    tape_clear()
    grad_table_clear()

    let logits = model_forward(worker.weights, tokens, worker.seq_len)
    let ce_result = gpu_cross_entropy_loss(logits, targets)
    let loss = ce_result[0]

    let _ = backward(ce_result[1])
    let _ = cuda_sync()

    let grads = model_grads(worker.weights)
    [loss, grads]
}

// ── AllReduce gradient synchronization ───────────────────────
// Collects same-index gradient tensors from all workers,
// performs allreduce_mean, then each worker has the averaged grad
fn sync_gradients(ctx: DistContext, all_grads, num_gpus) {
    // all_grads[g] = array of GpuTensors (one per param) for GPU g
    let n_params = len(all_grads[0])

    let mut p = 0
    while p < n_params {
        // Collect the p-th gradient from each GPU
        let mut grad_set = []
        let mut g = 0
        while g < num_gpus {
            grad_set = grad_set.push(all_grads[g][p])
            g = g + 1
        }
        // In-place mean across GPUs
        let _ = allreduce_mean(ctx, grad_set)
        p = p + 1
    }
    0
}

// ── Synchronized optimizer step ──────────────────────────────
fn sync_optimizer_step(workers, all_grads, lr, step, num_gpus) {
    let mut g = 0
    while g < num_gpus {
        let _ = cudaSetDevice(workers[g].gpu_id)
        let grads = all_grads[g]
        let n_params = len(grads)

        // Gradient clipping
        let _ = gpu_clip_grad_norm(grads, DIST_MAX_GNORM)

        // AdamW update
        let mut p = 0
        while p < n_params {
            let _ = adam_step(workers[g].opt_states[p], grads[p], lr, step)
            p = p + 1
        }
        let _ = cuda_sync()
        g = g + 1
    }
    0
}

// ── Gradient accumulation step ───────────────────────────────
// Accumulates gradients over multiple micro-batches before sync
fn accumulate_grads(existing_grads, new_grads, n_params) {
    if len(existing_grads) == 0 {
        return new_grads
    }
    // Add new_grads into existing_grads (element-wise on GPU)
    let mut p = 0
    while p < n_params {
        let n = gt_numel(existing_grads[p])
        let _ = gpu_saxpy(gt_ptr(new_grads[p]), gt_ptr(existing_grads[p]), n, 1.0)
        p = p + 1
    }
    existing_grads
}

// Scale accumulated gradients by 1/accum_steps
fn scale_grads(grads, accum_steps) {
    let scale = 1.0 / (accum_steps * 1.0)
    let n_params = len(grads)
    let mut p = 0
    while p < n_params {
        let n = gt_numel(grads[p])
        let _ = gpu_sscal(gt_ptr(grads[p]), n, scale)
        p = p + 1
    }
    0
}

// ═══════════════════════════════════════════════════════════════
//  Main distributed training entry point
// ═══════════════════════════════════════════════════════════════

fn dist_train(num_gpus) {
    println("=" * 60)
    println("  Distributed GPU Training: " + str(num_gpus) + "-GPU Data Parallel")
    println("  100M Transformer — Pure hexa + CUDA FFI")
    println("  Gradient accumulation steps: " + str(DIST_ACCUM_STEPS))
    println("=" * 60)

    // Initialize distributed context
    let ctx = init_distributed(num_gpus)

    // Initialize workers (one model replica per GPU)
    let seq = GPU_SEQ
    let per_gpu_seq = seq / num_gpus
    let mut workers = []
    let mut g = 0
    while g < num_gpus {
        let w = init_worker(g, per_gpu_seq)
        workers = workers.push(w)
        g = g + 1
    }
    println("[dist_train] all " + str(num_gpus) + " GPU workers initialized")

    // Training loop
    println("")
    println("[dist_train] starting training for " + str(DIST_STEPS) + " steps")
    println("-" * 60)

    let _ = cudaSetDevice(0)

    let mut total_time = 0.0
    let mut total_loss = 0.0

    let mut step = 1
    while step <= DIST_STEPS {
        let t0 = clock()

        // Generate full batch and scatter across GPUs
        let full_batch = make_dist_batch(seq, GPU_VOCAB)
        let scattered = scatter_batch_tokens(full_batch[0], full_batch[1], num_gpus)

        // Gradient accumulation loop
        let mut accum_grads_per_gpu = []
        let mut ag = 0
        while ag < num_gpus {
            accum_grads_per_gpu = accum_grads_per_gpu.push([])
            ag = ag + 1
        }

        let mut accum = 0
        while accum < DIST_ACCUM_STEPS {
            // Forward + backward on each GPU (independent)
            let mut all_grads = []
            let mut all_losses = []
            g = 0
            while g < num_gpus {
                let sub_tokens = scattered[g][0]
                let sub_targets = scattered[g][1]
                let fb = worker_forward_backward(workers[g], sub_tokens, sub_targets)
                all_losses = all_losses.push(fb[0])
                all_grads = all_grads.push(fb[1])
                g = g + 1
            }

            // Accumulate gradients
            let n_params = len(all_grads[0])
            g = 0
            while g < num_gpus {
                accum_grads_per_gpu[g] = accumulate_grads(
                    accum_grads_per_gpu[g], all_grads[g], n_params
                )
                g = g + 1
            }

            accum = accum + 1
        }

        // Scale accumulated gradients
        if DIST_ACCUM_STEPS > 1 {
            g = 0
            while g < num_gpus {
                let _ = scale_grads(accum_grads_per_gpu[g], DIST_ACCUM_STEPS)
                g = g + 1
            }
        }

        // AllReduce gradient sync across GPUs
        let _ = sync_gradients(ctx, accum_grads_per_gpu, num_gpus)

        // Compute LR
        let lr = dist_lr_cosine(step, DIST_WARMUP, DIST_STEPS, DIST_PEAK_LR, DIST_MIN_LR)

        // Synchronized optimizer step on all GPUs
        let _ = sync_optimizer_step(workers, accum_grads_per_gpu, lr, step, num_gpus)

        let t1 = clock()
        let ms = (t1 - t0) * 1000.0

        // Compute average loss across GPUs (from last micro-batch)
        let full_batch2 = make_dist_batch(seq, GPU_VOCAB)
        let scattered2 = scatter_batch_tokens(full_batch2[0], full_batch2[1], num_gpus)
        let mut losses = []
        g = 0
        while g < num_gpus {
            let sub_tokens = scattered2[g][0]
            let sub_targets = scattered2[g][1]
            let fb = worker_forward_backward(workers[g], sub_tokens, sub_targets)
            losses = losses.push(fb[0])
            g = g + 1
        }
        let avg_loss = gather_losses(losses)

        total_time = total_time + ms
        total_loss = total_loss + avg_loss

        if step % DIST_LOG_INTERVAL == 0 {
            let running_avg = total_loss / (step * 1.0)
            println(
                "step=" + str(step) +
                " loss=" + str(avg_loss) +
                " lr=" + str(lr) +
                " ms=" + str(ms) +
                " avg=" + str(running_avg) +
                " gpus=" + str(num_gpus)
            )
        }

        step = step + 1
    }

    // Summary
    println("")
    println("=" * 60)
    println("  Distributed training complete!")
    println("  GPUs:       " + str(num_gpus))
    println("  Steps:      " + str(DIST_STEPS))
    println("  Avg loss:   " + str(total_loss / (DIST_STEPS * 1.0)))
    println("  Total time: " + str(total_time) + " ms")
    println("  Avg ms/step:" + str(total_time / (DIST_STEPS * 1.0)))
    println("  Throughput: " + str((DIST_STEPS * 1000.0) / total_time) + " steps/s")
    println("=" * 60)

    // Cleanup
    let _ = dist_shutdown(ctx)
    g = 0
    while g < num_gpus {
        let _ = cudaSetDevice(workers[g].gpu_id)
        let _ = cuda_shutdown()
        g = g + 1
    }
    let _ = cudaSetDevice(0)
    0
}

println("[distributed_train] module loaded — multi-GPU training loop ready")
