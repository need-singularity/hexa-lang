// ═══════════════════════════════════════════════════════════════
//  distributed_train.hexa — Multi-GPU data-parallel training loop
//
//  Each GPU gets batch_size/num_gpus samples.
//  Forward + backward independently per GPU.
//  AllReduce gradients across GPUs.
//  Synchronized AdamW optimizer step.
//  Gradient accumulation for effective larger batch sizes.
//
//  Usage:
//    use "distributed_train"
//    let _ = dist_train(4)   // train on 4 GPUs
// ═══════════════════════════════════════════════════════════════

use "cuda_ffi"
use "gpu_tensor"
use "gpu_grad_engine"
use "gpu_optimizer"
use "model_100m_gpu"
use "distributed"
use "hxccl"
use "fsdp"
use "dist_launcher"
use "data_loader"

// ── hxccl handle-based (Family B) toggle ─────────────────────
// When true, gradient sync uses hxccl_allreduce_float via handle
// instead of raw NCCL ncclAllReduce calls.
let USE_HXCCL = true

// ── FSDP toggle ─────────────────────────────────────────────
// When true, parameter sharding via FSDP is enabled:
//   fsdp_all_gather before forward, fsdp_reduce_scatter after backward.
let USE_FSDP = true

// ── Rank awareness ──────────────────────────────────────────
// Read RANK and WORLD_SIZE from env (set by dist_launcher).
// Defaults to rank=0, world=1 for single-process runs.
let MY_RANK = dist_my_rank()
let MY_WORLD = dist_my_world_size()

// Rank-aware logging: only rank 0 prints to avoid interleaved output
fn rank_println(msg) {
    if MY_RANK == 0 {
        println(msg)
    }
}

// ── Training config ──────────────────────────────────────────
let DIST_STEPS       = 100
let DIST_WARMUP      = 10
let DIST_PEAK_LR     = 3.0e-4
let DIST_MIN_LR      = 3.0e-5
let DIST_MAX_GNORM   = 1.0
let DIST_LOG_INTERVAL = 1
let DIST_ACCUM_STEPS  = 1    // gradient accumulation steps

// ── Per-GPU worker state ─────────────────────────────────────
// Holds the model replica + optimizer for one GPU
struct GpuWorker {
    gpu_id: int,
    weights: array,
    opt_states: array,
    seq_len: int
}

// Initialize a worker on a given GPU
fn init_worker(gpu_id, seq_len) {
    let _ = cuda_set_device(gpu_id)
    let _ = cuda_init()

    rank_println("[dist_train] GPU " + str(gpu_id) + " — initializing model replica")
    let weights = init_model_weights()

    let all_params = model_params(weights)
    let n_params = len(all_params)
    let mut opt_states = []
    let mut i = 0
    while i < n_params {
        opt_states = opt_states.push(adam_state_create(all_params[i]))
        i = i + 1
    }

    let w = GpuWorker {
        gpu_id: gpu_id,
        weights: weights,
        opt_states: opt_states,
        seq_len: seq_len
    }
    w
}

// ── Data loader integration ─────────────────────────────────
// When DIST_DATA_PATH is set to a valid HXTD binary file path,
// the training loop reads real data via data_loader.hexa instead
// of generating synthetic batches. Set to "" for synthetic mode.
let DIST_DATA_PATH = ""
let DIST_PREFETCH_N = 4   // prefetch buffer depth

// Module-level data loader handle (initialized in dist_train)
let mut g_data_loader = nil
let mut g_use_real_data = false

// Synthetic batch generator (fallback when no data file)
fn make_dist_batch(seq_len, vocab_size) {
    let mut tokens = []
    let mut targets = []
    let mut i = 0
    while i < seq_len {
        let tok = int(random() * vocab_size) % vocab_size
        tokens = tokens.push(tok)
        i = i + 1
    }
    i = 0
    while i < seq_len {
        if i < seq_len - 1 {
            targets = targets.push(tokens[i + 1])
        } else {
            targets = targets.push(int(random() * vocab_size) % vocab_size)
        }
        i = i + 1
    }
    let batch = [tokens, targets]
    return batch
}

// Get next batch: real data or synthetic
fn get_next_batch(seq_len, vocab_size, num_gpus) {
    if g_use_real_data {
        // Prefetch ahead
        let _ = dl_prefetch(g_data_loader, DIST_PREFETCH_N)
        let batch = dl_next_batch(g_data_loader)
        if batch == nil {
            // Epoch exhausted — reset and get first batch of new epoch
            let _ = dl_reset_epoch(g_data_loader)
            let _ = dl_prefetch(g_data_loader, DIST_PREFETCH_N)
            return dl_next_batch(g_data_loader)
        }
        return batch
    }
    // Synthetic fallback
    let full_batch = make_dist_batch(seq_len, vocab_size)
    return full_batch
}

// Scatter a batch for multi-GPU: returns array of [sub_tokens, sub_targets]
fn scatter_from_batch(batch, num_gpus) {
    if g_use_real_data {
        let seq = g_data_loader.seq_len
        return scatter_batch_for_dist(batch, num_gpus, seq)
    }
    // Legacy path: use distributed.hexa scatter
    return scatter_batch_tokens(batch[0], batch[1], num_gpus)
}

// ── Cosine LR schedule ──────────────────────────────────────
fn dist_lr_cosine(step, warmup, total, peak, minimum) {
    if step <= warmup {
        return minimum + (peak - minimum) * (step * 1.0) / (warmup * 1.0)
    }
    let progress = ((step - warmup) * 1.0) / ((total - warmup) * 1.0)
    let cosval = cos(progress * 3.14159265)
    minimum + (peak - minimum) * 0.5 * (1.0 + cosval)
}

// ── Single GPU forward+backward step ─────────────────────────
// Returns [loss, grads_array]
fn worker_forward_backward(worker: GpuWorker, tokens, targets) {
    let _ = cuda_set_device(worker.gpu_id)

    tape_clear()
    grad_table_clear()

    let logits = model_forward(worker.weights, tokens, worker.seq_len)
    let ce_result = gpu_cross_entropy_loss(logits, targets)
    let loss = ce_result[0]

    let _ = backward(ce_result[1])
    let _ = cuda_sync()

    let grads = model_grads(worker.weights)
    let result = [loss, grads]
    return result
}

// ── AllReduce gradient synchronization ───────────────────────
// Collects same-index gradient tensors from all workers,
// performs allreduce_mean, then each worker has the averaged grad.
//
// Two paths:
//   USE_HXCCL=true  → hxccl Family B handle-based allreduce (AVG)
//   USE_HXCCL=false → legacy raw NCCL via distributed.hexa
fn sync_gradients(ctx, all_grads, num_gpus) {
    let n_params = len(all_grads[0])

    if USE_HXCCL {
        // hxccl path: allreduce each param's gradient buffer in-place
        // ctx here is the hxccl handle (int) when USE_HXCCL=true
        let mut p = 0
        while p < n_params {
            let mut g = 0
            while g < num_gpus {
                let grad_t = all_grads[g][p]
                let count = gt_numel(grad_t)
                let buf = gt_ptr(grad_t)
                let _ = hxccl_allreduce_float(ctx, buf, count, HXCCL_OP_AVG)
                g = g + 1
            }
            p = p + 1
        }
        return 0
    }

    // Legacy path: raw NCCL allreduce via distributed.hexa
    let mut p = 0
    while p < n_params {
        let mut grad_set = []
        let mut g = 0
        while g < num_gpus {
            grad_set = grad_set.push(all_grads[g][p])
            g = g + 1
        }
        let _ = allreduce_mean(ctx, grad_set)
        p = p + 1
    }
    0
}

// ── Synchronized optimizer step ──────────────────────────────
fn sync_optimizer_step(workers, all_grads, lr, step, num_gpus) {
    let mut g = 0
    while g < num_gpus {
        let _ = cuda_set_device(workers[g].gpu_id)
        let grads = all_grads[g]
        let n_params = len(grads)

        // Gradient clipping
        let _ = gpu_clip_grad_norm(grads, DIST_MAX_GNORM)

        // AdamW update
        let mut p = 0
        while p < n_params {
            let _ = adam_step(workers[g].opt_states[p], grads[p], lr, step)
            p = p + 1
        }
        let _ = cuda_sync()
        g = g + 1
    }
    0
}

// ── Gradient accumulation step ───────────────────────────────
// Accumulates gradients over multiple micro-batches before sync
fn accumulate_grads(existing_grads, new_grads, n_params) {
    if len(existing_grads) == 0 {
        return new_grads
    }
    // Add new_grads into existing_grads (element-wise on GPU)
    let mut p = 0
    while p < n_params {
        let n = gt_numel(existing_grads[p])
        let _ = gpu_saxpy(gt_ptr(new_grads[p]), gt_ptr(existing_grads[p]), n, 1.0)
        p = p + 1
    }
    existing_grads
}

// Scale accumulated gradients by 1/accum_steps
fn scale_grads(grads, accum_steps) {
    let scale = 1.0 / (accum_steps * 1.0)
    let n_params = len(grads)
    let mut p = 0
    while p < n_params {
        let n = gt_numel(grads[p])
        let _ = gpu_sscal(gt_ptr(grads[p]), n, scale)
        p = p + 1
    }
    0
}

// ═══════════════════════════════════════════════════════════════
//  Main distributed training entry point
// ═══════════════════════════════════════════════════════════════

// dist_train with data_path override: loads real data from HXTD file
fn dist_train_with_data(num_gpus, data_path) {
    g_use_real_data = true
    let batch_size = num_gpus  // 1 sequence per GPU per micro-batch
    g_data_loader = dl_open(data_path, batch_size, GPU_SEQ, 42)
    if g_data_loader.total_tokens == 0 {
        rank_println("[dist_train] ERROR: no tokens loaded, falling back to synthetic")
        g_use_real_data = false
    } else {
        rank_println("[dist_train] real data: " + str(g_data_loader.total_tokens) + " tokens, " + str(g_data_loader.batches_per_epoch) + " batches/epoch")
        // Pre-fill prefetch buffer
        let _ = dl_prefetch(g_data_loader, DIST_PREFETCH_N)
    }
    return dist_train(num_gpus)
}

fn dist_train(num_gpus) {
    // Auto-detect data path from DIST_DATA_PATH or env
    if g_use_real_data == false && len(DIST_DATA_PATH) > 0 {
        return dist_train_with_data(num_gpus, DIST_DATA_PATH)
    }

    let data_mode = if g_use_real_data { "real-data" } else { "synthetic" }
    rank_println("=" * 60)
    rank_println("  Distributed GPU Training: " + str(num_gpus) + "-GPU Data Parallel")
    rank_println("  100M Transformer — Pure hexa + CUDA FFI")
    rank_println("  Gradient accumulation steps: " + str(DIST_ACCUM_STEPS))
    rank_println("  Data mode: " + data_mode)
    rank_println("  FSDP=" + str(USE_FSDP) + " RANK=" + str(MY_RANK) + "/" + str(MY_WORLD))
    rank_println("=" * 60)

    // Initialize distributed context
    // When USE_HXCCL, ctx is an hxccl handle (Family B); otherwise
    // it's a DistContext from distributed.hexa.
    let mut ctx = 0
    if USE_HXCCL {
        ctx = hxccl_init_handle(MY_RANK, num_gpus)
        if ctx <= 0 {
            rank_println("[dist_train] ERROR: hxccl_init_handle failed, falling back to legacy")
            ctx = init_distributed(num_gpus)
        } else {
            rank_println("[dist_train] hxccl handle initialized: " + str(ctx))
        }
    } else {
        ctx = init_distributed(num_gpus)
    }

    // Initialize FSDP state if enabled
    let mut fsdp_state = 0
    if USE_FSDP {
        // Dummy full weights vector for FSDP init — real weights come from workers
        // In production, this would flatten the model params into a single vector
        let mut dummy_weights = []
        let dummy_d = 1024   // placeholder dimension for FSDP shard math
        for di in 0..dummy_d {
            dummy_weights.push(random() * 0.01)
        }
        fsdp_state = fsdp_init(dummy_weights, num_gpus, false, false)
        rank_println("[dist_train] FSDP initialized: " + str(num_gpus) + " shards, total_d=" + str(dummy_d))
    }

    // Initialize workers (one model replica per GPU)
    let seq = GPU_SEQ
    let per_gpu_seq = seq / num_gpus
    let mut workers = []
    let mut g = 0
    while g < num_gpus {
        let w = init_worker(g, per_gpu_seq)
        workers = workers.push(w)
        g = g + 1
    }
    rank_println("[dist_train] all " + str(num_gpus) + " GPU workers initialized")

    // Training loop
    rank_println("")
    rank_println("[dist_train] starting training for " + str(DIST_STEPS) + " steps")
    rank_println("-" * 60)

    let _ = cuda_set_device(0)

    let mut total_time = 0.0
    let mut total_loss = 0.0

    let mut step = 1
    while step <= DIST_STEPS {
        let t0 = clock()

        // Get batch (real data or synthetic) and scatter across GPUs
        let full_batch = get_next_batch(seq, GPU_VOCAB, num_gpus)
        let scattered = scatter_from_batch(full_batch, num_gpus)

        // Gradient accumulation loop
        let mut accum_grads_per_gpu = []
        let mut ag = 0
        while ag < num_gpus {
            accum_grads_per_gpu = accum_grads_per_gpu.push([])
            ag = ag + 1
        }

        let mut accum = 0
        while accum < DIST_ACCUM_STEPS {
            // ── FSDP pre-forward: all-gather sharded params ─────
            if USE_FSDP {
                let _ = fsdp_all_gather(fsdp_state)
                // Barrier ensures all ranks have full params before forward
                let _ = fsdp_barrier_sync()
            }

            // Forward + backward on each GPU (independent)
            let mut all_grads = []
            let mut all_losses = []
            g = 0
            while g < num_gpus {
                let sub_tokens = scattered[g][0]
                let sub_targets = scattered[g][1]
                let fb = worker_forward_backward(workers[g], sub_tokens, sub_targets)
                all_losses = all_losses.push(fb[0])
                all_grads = all_grads.push(fb[1])
                g = g + 1
            }

            // ── FSDP post-backward: reduce-scatter gradients ────
            if USE_FSDP {
                // Build per-rank full gradient vectors for reduce-scatter
                // Each rank's gradient is flattened to match fsdp total_d
                let _ = fsdp_reduce_scatter(all_grads, num_gpus, fsdp_state.total_d)
                // Barrier after reduce-scatter before accumulation
                let _ = fsdp_barrier_sync()
            }

            // Accumulate gradients
            let n_params = len(all_grads[0])
            g = 0
            while g < num_gpus {
                accum_grads_per_gpu[g] = accumulate_grads(
                    accum_grads_per_gpu[g], all_grads[g], n_params
                )
                g = g + 1
            }

            accum = accum + 1
        }

        // Scale accumulated gradients
        if DIST_ACCUM_STEPS > 1 {
            g = 0
            while g < num_gpus {
                let _ = scale_grads(accum_grads_per_gpu[g], DIST_ACCUM_STEPS)
                g = g + 1
            }
        }

        // AllReduce gradient sync across GPUs
        let _ = sync_gradients(ctx, accum_grads_per_gpu, num_gpus)

        // Compute LR
        let lr = dist_lr_cosine(step, DIST_WARMUP, DIST_STEPS, DIST_PEAK_LR, DIST_MIN_LR)

        // Synchronized optimizer step on all GPUs
        let _ = sync_optimizer_step(workers, accum_grads_per_gpu, lr, step, num_gpus)

        let t1 = clock()
        let ms = (t1 - t0) * 1000.0

        // Compute average loss across GPUs (from next batch or synthetic eval batch)
        let full_batch2 = get_next_batch(seq, GPU_VOCAB, num_gpus)
        let scattered2 = scatter_from_batch(full_batch2, num_gpus)
        let mut losses = []
        g = 0
        while g < num_gpus {
            let sub_tokens = scattered2[g][0]
            let sub_targets = scattered2[g][1]
            let fb = worker_forward_backward(workers[g], sub_tokens, sub_targets)
            losses = losses.push(fb[0])
            g = g + 1
        }
        let avg_loss = gather_losses(losses)

        total_time = total_time + ms
        total_loss = total_loss + avg_loss

        if step % DIST_LOG_INTERVAL == 0 {
            let running_avg = total_loss / (step * 1.0)
            rank_println(
                "step=" + str(step) +
                " loss=" + str(avg_loss) +
                " lr=" + str(lr) +
                " ms=" + str(ms) +
                " avg=" + str(running_avg) +
                " gpus=" + str(num_gpus) +
                " rank=" + str(MY_RANK)
            )
        }

        step = step + 1
    }

    // Summary
    rank_println("")
    rank_println("=" * 60)
    rank_println("  Distributed training complete!")
    rank_println("  GPUs:       " + str(num_gpus))
    rank_println("  Steps:      " + str(DIST_STEPS))
    rank_println("  Avg loss:   " + str(total_loss / (DIST_STEPS * 1.0)))
    rank_println("  Total time: " + str(total_time) + " ms")
    rank_println("  Avg ms/step:" + str(total_time / (DIST_STEPS * 1.0)))
    rank_println("  Throughput: " + str((DIST_STEPS * 1000.0) / total_time) + " steps/s")
    rank_println("  FSDP:       " + str(USE_FSDP))
    if g_use_real_data {
        rank_println("  Data:       real (" + str(g_data_loader.total_tokens) + " tokens, epoch " + str(dl_epoch(g_data_loader)) + ")")
        rank_println("  Data path:  " + g_data_loader.path)
    } else {
        rank_println("  Data:       synthetic")
    }
    rank_println("=" * 60)

    // Cleanup
    if USE_HXCCL {
        let _ = hxccl_finalize(ctx)
        rank_println("[dist_train] hxccl handle finalized")
    } else {
        let _ = dist_shutdown(ctx)
    }
    g = 0
    while g < num_gpus {
        let _ = cuda_set_device(workers[g].gpu_id)
        let _ = cuda_shutdown()
        g = g + 1
    }
    let _ = cuda_set_device(0)
    0
}

rank_println("[distributed_train] module loaded — multi-GPU training loop ready (hxccl=" + str(USE_HXCCL) + " fsdp=" + str(USE_FSDP) + " data_loader=true rank=" + str(MY_RANK) + "/" + str(MY_WORLD) + ")")
