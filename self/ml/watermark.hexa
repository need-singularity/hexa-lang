// ═══════════════════════════════════════════════════════════════════
//  self/ml/watermark.hexa — Output Watermark (Kirchenbauer et al.)
//
//  Implements:
//    1. Green/red token list   — hash-based partition of vocabulary
//    2. Logit bias             — add delta to green token logits
//    3. Detection z-test       — statistical test for watermark
//    4. Watermarked generation — greedy/sampling with green bias
//
//  The watermark works by:
//    - For each token position, hash the previous token to split
//      the vocabulary into "green" and "red" sets (50/50 default)
//    - During generation, add a constant delta to green logits
//    - During detection, count green tokens and apply a z-test
//    - Under null hypothesis (no watermark), ~50% are green
//    - With watermark, significantly more are green (z > threshold)
//
//  API:
//    wm_hash_token(prev_token, vocab_size, seed)  -> [green_mask]
//    wm_apply_bias(logits, green_mask, delta)      -> [float]
//    wm_count_green(tokens, vocab_size, seed)       -> [n_green, n_total]
//    wm_z_score(n_green, n_total, gamma)            -> float
//    wm_detect(tokens, vocab_size, seed, threshold) -> [detected, z]
//    wm_generate(logits_fn, prev, n_tokens, vocab_size, seed, delta)
//
//  AI-NATIVE attrs:
//    @pure  — no side effects
//    @hot   — called during generation
// ═══════════════════════════════════════════════════════════════════

// ── helpers ──────────────────────────────────────────────────────

fn wm_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn wm_sqrt(x) {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    for _i in 0..30 {
        g = (g + x / g) / 2.0
    }
    return g
}

fn wm_exp(x) {
    let mut v = x
    if v > 20.0 { v = 20.0 }
    if v < -20.0 { v = -20.0 }
    let mut result = 1.0
    let mut term = 1.0
    for i in 1..30 {
        term = term * v / to_float(i)
        result = result + term
    }
    if result < 0.0 { return 0.0 }
    return result
}

fn wm_zeros(n) {
    let mut v = []
    for _i in 0..n { v = v + [0.0] }
    return v
}

fn wm_zeros_int(n) {
    let mut v = []
    for _i in 0..n { v = v + [0] }
    return v
}

// ═══════════════════════════════════════════════════════════════════
//  Hash Function — deterministic pseudo-random from prev_token
//
//  Maps (prev_token, token_id) -> 0 or 1 (green or red)
//  Uses multiplicative hashing for good distribution.
// ═══════════════════════════════════════════════════════════════════
fn wm_hash_single(prev_token, token_id, seed) {
    let mut h = (prev_token + 1) * 2654435761 + token_id * 1315423911 + seed * 7919
    h = h % 1000003
    if h < 0 { h = 0 - h }
    return h
}

// ═══════════════════════════════════════════════════════════════════
//  Green/Red Partition — hash-based vocabulary split
//
//  Given prev_token, split vocab into green (1) and red (0).
//  gamma: fraction of vocab that is green (default 0.5)
//
//  Returns: array of 0/1 (length = vocab_size)
// ═══════════════════════════════════════════════════════════════════
@pure
fn wm_green_mask(prev_token, vocab_size, seed, gamma) {
    let mut mask = wm_zeros_int(vocab_size)
    let threshold = to_int(gamma * to_float(vocab_size))
    for t in 0..vocab_size {
        let h = wm_hash_single(prev_token, t, seed)
        let bucket = h % vocab_size
        if bucket < threshold {
            mask[t] = 1
        }
    }
    return mask
}

// Default gamma=0.5
@pure
fn wm_green_mask_default(prev_token, vocab_size, seed) {
    return wm_green_mask(prev_token, vocab_size, seed, 0.5)
}

// ═══════════════════════════════════════════════════════════════════
//  Apply Logit Bias — add delta to green token logits
//
//  logits: [vocab_size] pre-softmax scores
//  green_mask: [vocab_size] 0/1 from wm_green_mask
//  delta: bias strength (typical: 1.0 ~ 2.5)
//
//  Returns: biased logits
// ═══════════════════════════════════════════════════════════════════
@pure @hot
fn wm_apply_bias(logits, green_mask, delta) {
    let n = len(logits)
    let mut out = wm_zeros(n)
    for i in 0..n {
        out[i] = logits[i]
        if green_mask[i] == 1 {
            out[i] = out[i] + delta
        }
    }
    return out
}

// ═══════════════════════════════════════════════════════════════════
//  Softmax — for sampling from biased logits
// ═══════════════════════════════════════════════════════════════════
@pure
fn wm_softmax(logits) {
    let n = len(logits)
    let mut mx = logits[0]
    for i in 1..n {
        if logits[i] > mx { mx = logits[i] }
    }
    let mut exps = wm_zeros(n)
    let mut z = 0.0
    for i in 0..n {
        exps[i] = wm_exp(logits[i] - mx)
        z = z + exps[i]
    }
    let mut out = wm_zeros(n)
    for i in 0..n {
        out[i] = exps[i] / z
    }
    return out
}

// ═══════════════════════════════════════════════════════════════════
//  Argmax — greedy selection from logits
// ═══════════════════════════════════════════════════════════════════
@pure
fn wm_argmax(logits) {
    let n = len(logits)
    let mut best = 0
    let mut best_v = logits[0]
    for i in 1..n {
        if logits[i] > best_v {
            best_v = logits[i]
            best = i
        }
    }
    return best
}

// ═══════════════════════════════════════════════════════════════════
//  Count Green Tokens — for detection
//
//  Given a sequence of tokens, count how many fall in the green set.
//  We start from index 1 (token[0] has no prev_token context).
//
//  Returns: [n_green, n_total]
// ═══════════════════════════════════════════════════════════════════
@pure
fn wm_count_green(tokens, vocab_size, seed) {
    let n = len(tokens)
    if n < 2 { return [0, 0] }
    let mut n_green = 0
    let mut n_total = 0
    for i in 1..n {
        let prev = tokens[i - 1]
        let cur = tokens[i]
        let mask = wm_green_mask_default(prev, vocab_size, seed)
        if mask[cur] == 1 {
            n_green = n_green + 1
        }
        n_total = n_total + 1
    }
    return [n_green, n_total]
}

// ═══════════════════════════════════════════════════════════════════
//  Z-Score — one-proportion z-test
//
//  H0: proportion of green = gamma (default 0.5)
//  z = (p_hat - gamma) / sqrt(gamma * (1-gamma) / n)
//
//  High z → likely watermarked (reject H0)
// ═══════════════════════════════════════════════════════════════════
@pure
fn wm_z_score(n_green, n_total, gamma) {
    if n_total <= 0 { return 0.0 }
    let p_hat = to_float(n_green) / to_float(n_total)
    let denom = wm_sqrt(gamma * (1.0 - gamma) / to_float(n_total))
    if denom < 1.0e-10 { return 0.0 }
    return (p_hat - gamma) / denom
}

// Default gamma=0.5
@pure
fn wm_z_score_default(n_green, n_total) {
    return wm_z_score(n_green, n_total, 0.5)
}

// ═══════════════════════════════════════════════════════════════════
//  Detect Watermark — full pipeline
//
//  1. Count green tokens
//  2. Compute z-score
//  3. Compare against threshold (typical: 4.0 for p < 0.00003)
//
//  Returns: [detected (0/1), z_score, n_green, n_total]
// ═══════════════════════════════════════════════════════════════════
@pure
fn wm_detect(tokens, vocab_size, seed, threshold) {
    let counts = wm_count_green(tokens, vocab_size, seed)
    let n_green = counts[0]
    let n_total = counts[1]
    let z = wm_z_score_default(n_green, n_total)
    let mut detected = 0
    if z >= threshold { detected = 1 }
    return [detected, z, n_green, n_total]
}

// ═══════════════════════════════════════════════════════════════════
//  Watermarked Generation — greedy with green bias
//
//  logits_fn(prev_token) -> [vocab_size] raw logits
//  Generates n_tokens with watermark delta applied.
//
//  Returns: array of generated token IDs
// ═══════════════════════════════════════════════════════════════════
@hot
fn wm_generate(logits_fn, start_token, n_tokens, vocab_size, seed, delta) {
    let mut tokens = [start_token]
    let mut prev = start_token
    for _t in 0..n_tokens {
        let raw_logits = logits_fn(prev)
        let mask = wm_green_mask_default(prev, vocab_size, seed)
        let biased = wm_apply_bias(raw_logits, mask, delta)
        let next = wm_argmax(biased)
        tokens = tokens + [next]
        prev = next
    }
    return tokens
}

// ═══════════════════════════════════════════════════════════════════
//  Unwatermarked Generation — baseline for comparison
// ═══════════════════════════════════════════════════════════════════
fn wm_generate_clean(logits_fn, start_token, n_tokens) {
    let mut tokens = [start_token]
    let mut prev = start_token
    for _t in 0..n_tokens {
        let raw_logits = logits_fn(prev)
        let next = wm_argmax(raw_logits)
        tokens = tokens + [next]
        prev = next
    }
    return tokens
}

// ═══════════════════════════════════════════════════════════════════
//  P-Value Approximation — from z-score (standard normal CDF)
//
//  Uses Abramowitz & Stegun approximation for upper tail.
//  Returns: probability of seeing this z under null hypothesis
// ═══════════════════════════════════════════════════════════════════
@pure
fn wm_p_value(z) {
    if z < 0.0 { return 1.0 }
    // Approximation: P(Z > z) ≈ (1/sqrt(2*pi)) * exp(-z^2/2) / z
    let pi = 3.141592653589793
    let inv_sqrt2pi = 1.0 / wm_sqrt(2.0 * pi)
    let pdf = inv_sqrt2pi * wm_exp(-0.5 * z * z)
    if z < 0.01 { return 0.5 }
    let p = pdf / z
    if p > 0.5 { return 0.5 }
    return p
}

// ═══════════════════════════════════════════════════════════════════
//  Sliding Window Detection — robust to token edits/insertions
//
//  Scans all windows of size `window_size` within the token sequence,
//  returning the window with the highest z-score. This handles cases
//  where parts of the text have been edited or tokens inserted/removed.
//
//  Returns: [best_z, best_start, best_end, best_n_green, best_n_total]
// ═══════════════════════════════════════════════════════════════════
@pure
fn wm_detect_sliding(tokens, vocab_size, seed, window_size) {
    let n = len(tokens)
    if n < 3 { return [0.0, 0, 0, 0, 0] }
    let mut ws = window_size
    if ws > n { ws = n }
    if ws < 3 { ws = 3 }
    let mut best_z = -999.0
    let mut best_start = 0
    let mut best_end = 0
    let mut best_ng = 0
    let mut best_nt = 0
    let num_windows = n - ws + 1
    for s in 0..num_windows {
        let e = s + ws
        // count green tokens in this window
        let mut ng = 0
        let mut nt = 0
        for i in (s + 1)..e {
            let prev = tokens[i - 1]
            let cur = tokens[i]
            let mask = wm_green_mask_default(prev, vocab_size, seed)
            if mask[cur] == 1 { ng = ng + 1 }
            nt = nt + 1
        }
        let z = wm_z_score_default(ng, nt)
        if z > best_z {
            best_z = z
            best_start = s
            best_end = e
            best_ng = ng
            best_nt = nt
        }
    }
    return [best_z, best_start, best_end, best_ng, best_nt]
}

// ═══════════════════════════════════════════════════════════════════
//  Detect with P-value threshold
//
//  Instead of a raw z threshold, use a p-value cutoff.
//  Typical: p_threshold = 0.01 for 99% confidence
//  Mapped to z via common thresholds:
//    p=0.05 -> z~1.645, p=0.01 -> z~2.326, p=0.001 -> z~3.09
//    p=0.0001 -> z~3.72, p=0.00001 -> z~4.26
//
//  Returns: [detected (0/1), z_score, p_value, n_green, n_total]
// ═══════════════════════════════════════════════════════════════════
@pure
fn wm_p_to_z_threshold(p_threshold) {
    // Lookup table for common p-values
    if p_threshold >= 0.05 { return 1.645 }
    if p_threshold >= 0.01 { return 2.326 }
    if p_threshold >= 0.001 { return 3.09 }
    if p_threshold >= 0.0001 { return 3.72 }
    if p_threshold >= 0.00001 { return 4.26 }
    return 4.75
}

@pure
fn wm_detect_pvalue(tokens, vocab_size, seed, p_threshold) {
    let z_thresh = wm_p_to_z_threshold(p_threshold)
    let counts = wm_count_green(tokens, vocab_size, seed)
    let ng = counts[0]
    let nt = counts[1]
    let z = wm_z_score_default(ng, nt)
    let p = wm_p_value(z)
    let mut detected = 0
    if z >= z_thresh { detected = 1 }
    return [detected, z, p, ng, nt]
}

// ═══════════════════════════════════════════════════════════════════
//  Key Management — multi-key watermarking
//
//  wm_keygen: generate a deterministic key from a passphrase
//  wm_key_fingerprint: short hash for key identity
//  wm_rotate_key: derive a new key from old key + epoch
//  wm_multi_key_detect: try multiple keys, return best match
// ═══════════════════════════════════════════════════════════════════

// Derive a numeric seed from a passphrase string
@pure
fn wm_keygen(passphrase) {
    let chars = passphrase.chars()
    let n = len(chars)
    let mut h = 5381
    for i in 0..n {
        let c = to_int(chars[i])
        h = h * 33 + c
        h = h % 2147483647
    }
    if h < 0 { h = 0 - h }
    return h
}

// Short fingerprint (last 6 digits) for key identity
@pure
fn wm_key_fingerprint(seed) {
    let mut fp = seed % 1000000
    if fp < 0 { fp = 0 - fp }
    return fp
}

// Rotate key: derive next epoch's key
@pure
fn wm_rotate_key(seed, epoch) {
    let mut h = seed * 2654435761 + epoch * 1315423911 + 7919
    h = h % 2147483647
    if h < 0 { h = 0 - h }
    return h
}

// Try multiple keys and return the one with highest z-score
// keys: array of integer seeds
// Returns: [best_key_idx, best_z, detected (0/1), n_green, n_total]
@pure
fn wm_multi_key_detect(tokens, vocab_size, keys, threshold) {
    let nk = len(keys)
    let mut best_idx = -1
    let mut best_z = -999.0
    let mut best_ng = 0
    let mut best_nt = 0
    for k in 0..nk {
        let counts = wm_count_green(tokens, vocab_size, keys[k])
        let ng = counts[0]
        let nt = counts[1]
        let z = wm_z_score_default(ng, nt)
        if z > best_z {
            best_z = z
            best_idx = k
            best_ng = ng
            best_nt = nt
        }
    }
    let mut detected = 0
    if best_z >= threshold { detected = 1 }
    return [best_idx, best_z, detected, best_ng, best_nt]
}

// ═══════════════════════════════════════════════════════════════════
//  Watermark Strength Estimator
//
//  Given a token sequence, estimate the effective watermark strength
//  (green fraction - expected fraction) normalized by sequence length.
//  Returns: [strength, green_fraction, expected_fraction]
// ═══════════════════════════════════════════════════════════════════
@pure
fn wm_strength(tokens, vocab_size, seed, gamma) {
    let n = len(tokens)
    if n < 2 { return [0.0, 0.0, gamma] }
    let mut ng = 0
    let mut nt = 0
    for i in 1..n {
        let prev = tokens[i - 1]
        let cur = tokens[i]
        let mask = wm_green_mask(prev, vocab_size, seed, gamma)
        if mask[cur] == 1 { ng = ng + 1 }
        nt = nt + 1
    }
    let gf = to_float(ng) / to_float(nt)
    return [gf - gamma, gf, gamma]
}

// ═══════════════════════════════════════════════════════════════════
//  Configurable Gamma Detection
//
//  Detect with a custom green list fraction (not just 0.5).
//  Useful for asymmetric watermarks or steganographic variants.
//
//  Returns: [detected (0/1), z_score, n_green, n_total]
// ═══════════════════════════════════════════════════════════════════
@pure
fn wm_count_green_gamma(tokens, vocab_size, seed, gamma) {
    let n = len(tokens)
    if n < 2 { return [0, 0] }
    let mut ng = 0
    let mut nt = 0
    for i in 1..n {
        let prev = tokens[i - 1]
        let cur = tokens[i]
        let mask = wm_green_mask(prev, vocab_size, seed, gamma)
        if mask[cur] == 1 { ng = ng + 1 }
        nt = nt + 1
    }
    return [ng, nt]
}

@pure
fn wm_detect_gamma(tokens, vocab_size, seed, gamma, threshold) {
    let counts = wm_count_green_gamma(tokens, vocab_size, seed, gamma)
    let ng = counts[0]
    let nt = counts[1]
    let z = wm_z_score(ng, nt, gamma)
    let mut detected = 0
    if z >= threshold { detected = 1 }
    return [detected, z, ng, nt]
}

// ═══════════════════════════════════════════════════════════════════
//  Robust Sliding Window + P-value Detection (combined)
//
//  Scans windows and uses p-value threshold for detection.
//  Best for texts that have been partially edited.
//
//  Returns: [detected (0/1), best_z, best_p, best_start, best_end]
// ═══════════════════════════════════════════════════════════════════
@pure
fn wm_detect_robust(tokens, vocab_size, seed, window_size, p_threshold) {
    let sw = wm_detect_sliding(tokens, vocab_size, seed, window_size)
    let best_z = sw[0]
    let best_p = wm_p_value(best_z)
    let z_thresh = wm_p_to_z_threshold(p_threshold)
    let mut detected = 0
    if best_z >= z_thresh { detected = 1 }
    return [detected, best_z, best_p, sw[1], sw[2]]
}

println("[watermark] loaded — green/red hash + logit bias + z-test + sliding window + key management")
