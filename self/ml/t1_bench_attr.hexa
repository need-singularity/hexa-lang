// ═══════════════════════════════════════════════════════════════
//  self/ml/t1_bench_attr.hexa — AI-native attr 가속 비교 벤치
//
//  Compares 1-token forward proxy latency across 4 modes:
//    baseline      — plain dense matmul
//    with_sparse   — 50% zero mask + auto_mm (sparse_mm.hexa)
//    with_lowrank  — rank-r factorization (lowrank_mm.hexa)
//    with_fused    — SKIPPED (matmul_fused.hexa 미존재)
//
//  Each mode: 2 warmup + 10 timed iters → JSON one-liner per mode.
//  SHRINK=32, flat-tensor simplified (not the nested-list t1_bench).
// ═══════════════════════════════════════════════════════════════

// sparse/lowrank 모듈 존재 확인 기준 작성 — fused 는 스킵
// NOTE: hexa 의 import 가 런타임 컨캣 방식이므로 인라인으로 필요한
// 함수만 로컬 복제하여 단독 실행 가능하게 만든다.

// ── config ─────────────────────────────────────────────────
let D_MODEL = 4096
let SHRINK  = 32
let SEQ     = 8            // small seq for per-iter bounded interp time
let N_LAYERS = 4           // reduced from 32 to keep each timed iter short
let LOWRANK_R = 4
let SPARSE_RATIO = 0.5     // 50% zeros in A
let BYTES_PER_STEP_INT8 = 3500000000

// ── tiny rand (LCG) ────────────────────────────────────────
let mut RNG = 2463534242
fn a_rand() {
    RNG = (RNG * 1664525 + 1013904223)
    let m = RNG % 10000
    let f = m / 10000.0 - 0.5
    return f * 0.1
}

// flat [rows*cols]
fn a_rand_flat(rows, cols) {
    let mut v = []
    let n = rows * cols
    let mut i = 0
    while i < n { v = v.push(a_rand()); i = i + 1 }
    return v
}

fn a_zeros_flat(rows, cols) {
    let mut v = []
    let n = rows * cols
    let mut i = 0
    while i < n { v = v.push(0.0); i = i + 1 }
    return v
}

// flat matmul: A[M,K] @ B[K,N] = C[M,N]
fn a_matmul(A, B, M, K, N) {
    let mut C = a_zeros_flat(M, N)
    let mut i = 0
    while i < M {
        let mut j = 0
        while j < N {
            let mut acc = 0.0
            let mut k = 0
            while k < K {
                acc = acc + A[i * K + k] * B[k * N + j]
                k = k + 1
            }
            C[i * N + j] = acc
            j = j + 1
        }
        i = i + 1
    }
    return C
}

// apply 50% zero mask (alternating) to produce sparse input
fn a_mask_sparse(A) {
    let n = len(A)
    let mut out = []
    let mut i = 0
    while i < n {
        if (i % 2) == 0 { out = out.push(0.0) }
        else            { out = out.push(A[i]) }
        i = i + 1
    }
    return out
}

// naive lowrank: W ≈ U[M,r] @ V[r,N], compute (U @ V) @ X as U @ (V @ X_slice).
// Here we simplify: U[M,r], V[r,N], input X[N,K]  →  U @ (V @ X)
fn a_lowrank_mm(U, V, X, M, r, N, K) {
    let T = a_matmul(V, X, r, N, K)
    let O = a_matmul(U, T, M, r, K)
    return O
}

// ── per-mode 1 "layer": simulate QKV+O+FFN as 6 matmuls of [S,Di]@[Di,Di*] ──
// Baseline
fn fwd_baseline(x, Wq, W1, W2, S, Di) {
    let q  = a_matmul(x,  Wq, S, Di, Di)
    let k  = a_matmul(x,  Wq, S, Di, Di)
    let v  = a_matmul(x,  Wq, S, Di, Di)
    let o  = a_matmul(q,  Wq, S, Di, Di)
    let h  = a_matmul(o,  W1, S, Di, Di * 4)
    let y  = a_matmul(h,  W2, S, Di * 4, Di)
    return y
}

// Sparse: zero-mask input before each matmul (call via plain a_matmul — the
// zeros propagate and measure the baseline cost WITHOUT sparse optimization;
// to show gain we'd route to auto_mm, but sparse_mm's API is tensor-shaped.
// Here we simulate gain by skipping zero rows manually in the first matmul.)
fn a_matmul_skipzero(A, B, M, K, N) {
    let mut C = a_zeros_flat(M, N)
    let mut i = 0
    while i < M {
        // skip row if all zero in A[i,*]
        let mut all_zero = true
        let mut kk = 0
        while kk < K {
            let v = A[i * K + kk]
            let av = if v < 0.0 { -1.0 * v } else { v }
            if av > 0.000000000001 { all_zero = false }
            kk = kk + 1
        }
        if all_zero == false {
            let mut j = 0
            while j < N {
                let mut acc = 0.0
                let mut k = 0
                while k < K {
                    acc = acc + A[i * K + k] * B[k * N + j]
                    k = k + 1
                }
                C[i * N + j] = acc
                j = j + 1
            }
        }
        i = i + 1
    }
    return C
}

fn fwd_sparse(x, Wq, W1, W2, S, Di) {
    let xs = a_mask_sparse(x)
    let q  = a_matmul_skipzero(xs, Wq, S, Di, Di)
    let k  = a_matmul_skipzero(xs, Wq, S, Di, Di)
    let v  = a_matmul_skipzero(xs, Wq, S, Di, Di)
    let o  = a_matmul_skipzero(q,  Wq, S, Di, Di)
    let h  = a_matmul(o,  W1, S, Di, Di * 4)
    let y  = a_matmul(h,  W2, S, Di * 4, Di)
    return y
}

// Lowrank: replace the 4 Di×Di projections with rank-r factorization
fn fwd_lowrank(x, U, V, W1, W2, S, Di, r) {
    // U:[Di,r], V:[r,Di], x:[S,Di]  — treat x as [N=Di, K=S]? Our layout is
    // x:[S,Di] so we do y = x @ (U@V) = (x@U)@V.
    let xu = a_matmul(x,  U, S, Di, r)
    let q  = a_matmul(xu, V, S, r,  Di)
    let xu2= a_matmul(x,  U, S, Di, r)
    let k  = a_matmul(xu2,V, S, r,  Di)
    let xu3= a_matmul(x,  U, S, Di, r)
    let v  = a_matmul(xu3,V, S, r,  Di)
    let xu4= a_matmul(q,  U, S, Di, r)
    let o  = a_matmul(xu4,V, S, r,  Di)
    let h  = a_matmul(o,  W1, S, Di, Di * 4)
    let y  = a_matmul(h,  W2, S, Di * 4, Di)
    return y
}

// ── sort / percentile ──────────────────────────────────────
fn a_sort(arr) {
    let mut a = []
    let mut i = 0
    while i < len(arr) { a = a.push(arr[i]); i = i + 1 }
    let n = len(a)
    let mut ii = 0
    while ii < n {
        let mut jj = ii + 1
        while jj < n {
            if a[jj] < a[ii] {
                let t = a[ii]; a[ii] = a[jj]; a[jj] = t
            }
            jj = jj + 1
        }
        ii = ii + 1
    }
    return a
}
fn a_pct(sorted, p) {
    let n = len(sorted)
    if n == 0 { return 0 }
    let mut idx = 0
    let tgt = p * n
    while (idx + 1) <= tgt { idx = idx + 1 }
    if idx >= n { idx = n - 1 }
    if idx < 0  { idx = 0 }
    return sorted[idx]
}

// ── run one mode: return [p50_ms, tok_s] ───────────────────
fn run_mode_baseline(Di) {
    let x  = a_rand_flat(SEQ, Di)
    let Wq = a_rand_flat(Di, Di)
    let W1 = a_rand_flat(Di, Di * 4)
    let W2 = a_rand_flat(Di * 4, Di)
    // warmup
    let mut w = 0
    while w < 2 {
        let mut xx = x
        let mut l = 0
        while l < N_LAYERS { xx = fwd_baseline(xx, Wq, W1, W2, SEQ, Di); l = l + 1 }
        w = w + 1
    }
    let mut lats = []
    let mut it = 0
    while it < 10 {
        let s0 = clock()
        let mut xx = x
        let mut l = 0
        while l < N_LAYERS { xx = fwd_baseline(xx, Wq, W1, W2, SEQ, Di); l = l + 1 }
        let s1 = clock()
        lats = lats.push((s1 - s0) * 1000.0)
        it = it + 1
    }
    return lats
}

fn run_mode_sparse(Di) {
    let x  = a_rand_flat(SEQ, Di)
    let Wq = a_rand_flat(Di, Di)
    let W1 = a_rand_flat(Di, Di * 4)
    let W2 = a_rand_flat(Di * 4, Di)
    let mut w = 0
    while w < 2 {
        let mut xx = x
        let mut l = 0
        while l < N_LAYERS { xx = fwd_sparse(xx, Wq, W1, W2, SEQ, Di); l = l + 1 }
        w = w + 1
    }
    let mut lats = []
    let mut it = 0
    while it < 10 {
        let s0 = clock()
        let mut xx = x
        let mut l = 0
        while l < N_LAYERS { xx = fwd_sparse(xx, Wq, W1, W2, SEQ, Di); l = l + 1 }
        let s1 = clock()
        lats = lats.push((s1 - s0) * 1000.0)
        it = it + 1
    }
    return lats
}

fn run_mode_lowrank(Di) {
    let x  = a_rand_flat(SEQ, Di)
    let U  = a_rand_flat(Di, LOWRANK_R)
    let V  = a_rand_flat(LOWRANK_R, Di)
    let W1 = a_rand_flat(Di, Di * 4)
    let W2 = a_rand_flat(Di * 4, Di)
    let mut w = 0
    while w < 2 {
        let mut xx = x
        let mut l = 0
        while l < N_LAYERS { xx = fwd_lowrank(xx, U, V, W1, W2, SEQ, Di, LOWRANK_R); l = l + 1 }
        w = w + 1
    }
    let mut lats = []
    let mut it = 0
    while it < 10 {
        let s0 = clock()
        let mut xx = x
        let mut l = 0
        while l < N_LAYERS { xx = fwd_lowrank(xx, U, V, W1, W2, SEQ, Di, LOWRANK_R); l = l + 1 }
        let s1 = clock()
        lats = lats.push((s1 - s0) * 1000.0)
        it = it + 1
    }
    return lats
}

// ── emit one JSON line for a mode ──────────────────────────
fn emit_mode(mode, lats) {
    let sorted = a_sort(lats)
    let p50 = a_pct(sorted, 0.50)
    let p95 = a_pct(sorted, 0.95)
    let mut sum = 0.0
    let mut i = 0
    while i < len(sorted) { sum = sum + sorted[i]; i = i + 1 }
    let mean_ms = sum / len(sorted)
    let mut tok_s = 0.0
    if p50 > 0 { tok_s = 1000.0 / p50 }
    let ts = clock()
    let line = "{"
        + "\"mode\":\"" + mode + "\""
        + ",\"p50_ms\":" + str(p50)
        + ",\"p95_ms\":" + str(p95)
        + ",\"mean_ms\":" + str(mean_ms)
        + ",\"tok_s\":" + str(tok_s)
        + ",\"iters\":" + str(len(sorted))
        + ",\"seq\":" + str(SEQ)
        + ",\"layers\":" + str(N_LAYERS)
        + ",\"d_model\":" + str(D_MODEL)
        + ",\"shrink\":" + str(SHRINK)
        + ",\"ts\":" + str(ts)
        + "}"
    println(line)
}

// ── main ───────────────────────────────────────────────────
let Di = D_MODEL / SHRINK   // 128
println("[t1_bench_attr] comparing baseline / sparse / lowrank (fused skipped)…")

let lats_b = run_mode_baseline(Di)
emit_mode("baseline", lats_b)

let lats_s = run_mode_sparse(Di)
emit_mode("with_sparse", lats_s)

let lats_l = run_mode_lowrank(Di)
emit_mode("with_lowrank", lats_l)

