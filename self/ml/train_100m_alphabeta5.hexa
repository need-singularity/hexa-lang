// alphabeta5 — alphabeta4 + tensor_last_row builtin + warmup + 10 iter avg
// alphabeta4 still had push-loop slice (2-3 ms/step overhead); v10_decode
// removed that for T1. alphabeta5 does the same for T2.
let D       = 768
let N_LAYER = 8
let VOCAB   = 8192
let SEQ     = 64
let FF      = 3072
let LORA_R  = 8
let LR      = 0.001

let Uqkv = tensor_zeros(D * 3 * LORA_R)
let Vv = tensor_zeros(LORA_R * D)
let Uo = tensor_zeros(D * LORA_R)
let Vo = tensor_zeros(LORA_R * D)
let U_up = tensor_zeros(D * LORA_R)
let V_up = tensor_zeros(LORA_R * FF)
let U_dn = tensor_zeros(FF * LORA_R)
let V_dn = tensor_zeros(LORA_R * D)
let U_lmh = tensor_zeros(D * LORA_R)
let V_lmh = tensor_zeros(LORA_R * VOCAB)

let scratch_lmh_t = tensor_zeros(1 * LORA_R)
let scratch_lmh_out = tensor_zeros(1 * VOCAB)
let scratch_bwd_z = tensor_zeros(1 * LORA_R)
let scratch_bwd_gvlmh = tensor_zeros(LORA_R * VOCAB)

let tgt_t = tensor_zeros(VOCAB)
let last_h_bwd = tensor_zeros(D)
let logits_f_bwd = tensor_zeros(VOCAB)
let h0 = tensor_zeros(SEQ * D)

fn forward_pass() {
    let h = block_forward_chain_f32(h0, Uqkv, Vv, Uo, Vo, U_up, V_up, U_dn, V_dn, SEQ, D, LORA_R, FF, N_LAYER)
    let last_t = tensor_last_row(h, SEQ, D)
    let t = matmul_into(last_t, U_lmh, 1, D, LORA_R, scratch_lmh_t)
    let logits = matmul_into(t, V_lmh, 1, LORA_R, VOCAB, scratch_lmh_out)
    let neg_t = mat_scale(tgt_t, -1.0)
    let diff  = mat_add(logits, neg_t)
    let sq = matmul(diff, diff, 1, VOCAB, 1)
    sq[0] / (VOCAB * 1.0)
}

fn backward_vlmh() {
    let z = matmul_into(last_h_bwd, U_lmh, 1, D, LORA_R, scratch_bwd_z)
    let neg_t = mat_scale(tgt_t, -1.0)
    let diff  = mat_add(logits_f_bwd, neg_t)
    matmul_into(z, diff, LORA_R, 1, VOCAB, scratch_bwd_gvlmh)
}

println("[alphabeta5] 100M spec + chain builtin + tensor_last_row")

// warmup
let _w_loss = forward_pass()
let _w_g = backward_vlmh()

let iters = 10
let mut k = 0
let mut sum_total = 0.0
let mut sum_fwd = 0.0
let mut sum_bwd = 0.0
let mut sum_opt = 0.0
let mut last_loss = 0.0
while k < iters {
    let t0 = clock()
    let loss = forward_pass()
    let t1 = clock()
    let g_vlmh = backward_vlmh()
    let t2 = clock()
    let _V = axpy(V_lmh, g_vlmh, -1.0 * LR)
    let t3 = clock()
    sum_fwd = sum_fwd + (t1 - t0) * 1000.0
    sum_bwd = sum_bwd + (t2 - t1) * 1000.0
    sum_opt = sum_opt + (t3 - t2) * 1000.0
    sum_total = sum_total + (t3 - t0) * 1000.0
    last_loss = loss
    k = k + 1
}
let avg_total = sum_total / (iters * 1.0)
let avg_fwd = sum_fwd / (iters * 1.0)
let avg_bwd = sum_bwd / (iters * 1.0)
let avg_opt = sum_opt / (iters * 1.0)
let steps_for_1b = 15600000.0
let hrs_1b = (avg_total * steps_for_1b) / (1000.0 * 3600.0)

let mut line = "{\"phase\":\"alphabeta5\",\"iters\":" + str(iters)
line = line + ",\"step_ms\":" + str(avg_total)
line = line + ",\"fwd\":" + str(avg_fwd)
line = line + ",\"bwd\":" + str(avg_bwd)
line = line + ",\"opt\":" + str(avg_opt)
line = line + ",\"hrs_1b\":" + str(hrs_1b)
line = line + ",\"loss\":" + str(last_loss) + "}"
println(line)
