// ═══════════════════════════════════════════════════════════════
//  accelerate_ffi.hexa — macOS Accelerate framework FFI bindings
//
//  ML roadmap #180 — Accelerate FFI
//
//  Pure hexa FFI bindings to Apple's Accelerate framework:
//    - CBLAS   (sgemm, dgemm, saxpy, sdot, snrm2, sscal, ...)
//    - vDSP    (vadd, vmul, sve, maxv, minv, vclr, mmul)
//    - BNNS    (stub declarations for future Neural Network primitives)
//
//  Pointers are hexa Pointer type (u64).
//  Float scalars for CBLAS passed by value (unlike cuBLAS which needs
//  device pointers). vDSP uses pointer+stride convention.
//
//  NOTE: extern fn names match C symbol names directly (no @symbol alias)
//  to work with both Rust pre-built and self-hosted interpreters.
//
//  On macOS, @link("Accelerate") causes runtime.c to try:
//    dlopen("/System/Library/Frameworks/Accelerate.framework/Accelerate")
//
//  Usage:
//    use "self/ml/accelerate_ffi"
//    let ok = acc_init()
//    if ok == 0 {
//        let C = alloc_raw(M * N * 4)
//        acc_matmul(A, B, C, M, N, K)
//        ...
//    }
// ═══════════════════════════════════════════════════════════════

// ── CBLAS constants ─────────────────────────────────────────
let CblasRowMajor  = 101
let CblasColMajor  = 102
let CblasNoTrans   = 111
let CblasTrans     = 112
let CblasConjTrans = 113

// ── CBLAS BLAS functions (single precision) ─────────────────

// C = alpha*A*B + beta*C  (f32)
@link("Accelerate")
extern fn cblas_sgemm(order: int, transA: int, transB: int, M: int, N: int, K: int, alpha: float, A: *Void, lda: int, B: *Void, ldb: int, beta: float, C: *Void, ldc: int)

// y = alpha*x + y  (f32)
@link("Accelerate")
extern fn cblas_saxpy(N: int, alpha: float, x: *Void, incx: int, y: *Void, incy: int)

// dot = x . y  (f32)
@link("Accelerate")
extern fn cblas_sdot(N: int, x: *Void, incx: int, y: *Void, incy: int) -> float

// ||x||_2  (f32)
@link("Accelerate")
extern fn cblas_snrm2(N: int, x: *Void, incx: int) -> float

// x = alpha*x  (f32)
@link("Accelerate")
extern fn cblas_sscal(N: int, alpha: float, x: *Void, incx: int)

// ── CBLAS BLAS functions (double precision) ─────────────────

// C = alpha*A*B + beta*C  (f64)
@link("Accelerate")
extern fn cblas_dgemm(order: int, transA: int, transB: int, M: int, N: int, K: int, alpha: float, A: *Void, lda: int, B: *Void, ldb: int, beta: float, C: *Void, ldc: int)

// y = alpha*x + y  (f64)
@link("Accelerate")
extern fn cblas_daxpy(N: int, alpha: float, x: *Void, incx: int, y: *Void, incy: int)

// dot = x . y  (f64)
@link("Accelerate")
extern fn cblas_ddot(N: int, x: *Void, incx: int, y: *Void, incy: int) -> float

// ||x||_2  (f64)
@link("Accelerate")
extern fn cblas_dnrm2(N: int, x: *Void, incx: int) -> float

// ── vDSP functions (single precision, stride=1) ────────────

// out[i] = A[i] + B[i]
@link("Accelerate")
extern fn vDSP_vadd(A: *Void, strideA: int, B: *Void, strideB: int, C: *Void, strideC: int, N: int)

// out[i] = A[i] * B[i]
@link("Accelerate")
extern fn vDSP_vmul(A: *Void, strideA: int, B: *Void, strideB: int, C: *Void, strideC: int, N: int)

// sum of elements
@link("Accelerate")
extern fn vDSP_sve(A: *Void, stride: int, result: *Void, N: int)

// maximum value
@link("Accelerate")
extern fn vDSP_maxv(A: *Void, stride: int, result: *Void, N: int)

// minimum value
@link("Accelerate")
extern fn vDSP_minv(A: *Void, stride: int, result: *Void, N: int)

// zero fill
@link("Accelerate")
extern fn vDSP_vclr(C: *Void, stride: int, N: int)

// matrix multiply C[M x N] = A[M x K] * B[K x N]
@link("Accelerate")
extern fn vDSP_mmul(A: *Void, strideA: int, B: *Void, strideB: int, C: *Void, strideC: int, M: int, N: int, K: int)

// ── BNNS (Apple Neural Network Subroutines) ─────────────────
// BNNS uses opaque struct handles; full binding requires more
// complex enum/struct FFI. Stubs for future expansion.
//
// TODO: BNNSFilterCreateLayerFullyConnected
// TODO: BNNSFilterCreateLayerConvolution
// TODO: BNNSFilterApply / BNNSFilterDestroy
// TODO: BNNSNDArrayDescriptor setup helpers

// ── Global state ────────────────────────────────────────────
let mut G_ACC_INITIALIZED = 0

// ── Platform detection ──────────────────────────────────────

fn has_accelerate() {
    let marker = env_var("HEXA_PLATFORM")
    if marker == "darwin" {
        return 1
    }
    let probe = env_var("HOME")
    if probe != "" {
        return 1
    }
    return 0
}

// ── Initialization ──────────────────────────────────────────

fn acc_init() {
    if G_ACC_INITIALIZED == 1 {
        return 0
    }
    let avail = has_accelerate()
    if avail == 0 {
        println("[accelerate_ffi] Accelerate framework not available (not macOS)")
        return -1
    }
    G_ACC_INITIALIZED = 1
    println("[accelerate_ffi] initialized — Accelerate framework ready")
    return 0
}

fn acc_shutdown() {
    G_ACC_INITIALIZED = 0
    return 0
}

// ── High-level wrappers (row-major f32) ─────────────────────
//
// All wrappers assume:
//   - f32 data stored in alloc_raw buffers
//   - Row-major layout
//   - Stride = 1 for vDSP operations
//   - write_f32 / deref_f32 for element access

// acc_matmul: C[M x N] = A[M x K] * B[K x N]
// Uses vDSP_mmul (all-integer params, ARM64 register safe)
// vDSP_mmul(A, 1, B, 1, C, 1, M, N, K) where C[MxN] = A[MxK] * B[KxN]
fn acc_matmul(A, B, C, M, N, K) {
    vDSP_mmul(A, 1, B, 1, C, 1, M, N, K)
}

// acc_matmul_t: C[M x N] = A[M x K] * B^T  (manual transpose then vDSP_mmul)
fn acc_matmul_t(A, Bt, C, M, N, K) {
    // Bt is [N x K] stored row-major, need B [K x N]
    // Transpose in-place to temp buffer
    let tmp = alloc_raw(K * N * 4)
    let mut r = 0
    while r < N {
        let mut c = 0
        while c < K {
            write_f32(tmp, c * N + r, deref_f32(Bt, r * K + c))
            c = c + 1
        }
        r = r + 1
    }
    vDSP_mmul(A, 1, tmp, 1, C, 1, M, N, K)
    free_raw(tmp, K * N * 4)
}

// acc_matmul_acc: C[M x N] += A[M x K] * B[K x N]
fn acc_matmul_acc(A, B, C, M, N, K) {
    let tmp = alloc_raw(M * N * 4)
    vDSP_mmul(A, 1, B, 1, tmp, 1, M, N, K)
    vDSP_vadd(tmp, 1, C, 1, C, 1, M * N)
    free_raw(tmp, M * N * 4)
}

// acc_matmul_tn: C[M x N] = A^T[M x K] * B[K x N]
fn acc_matmul_tn(At, B, C, M, N, K) {
    let tmp = alloc_raw(M * K * 4)
    let mut r = 0
    while r < K {
        let mut c = 0
        while c < M {
            write_f32(tmp, c * K + r, deref_f32(At, r * M + c))
            c = c + 1
        }
        r = r + 1
    }
    vDSP_mmul(tmp, 1, B, 1, C, 1, M, N, K)
    free_raw(tmp, M * K * 4)
}

// acc_vec_add: out[i] = x[i] + y[i]
fn acc_vec_add(x, y, out, n) {
    vDSP_vadd(x, 1, y, 1, out, 1, n)
}

// acc_vec_mul: out[i] = x[i] * y[i]
fn acc_vec_mul(x, y, out, n) {
    vDSP_vmul(x, 1, y, 1, out, 1, n)
}

// acc_vec_sum: sum of x[0..n]
fn acc_vec_sum(x, n) {
    let result_buf = alloc_raw(4)
    write_f32(result_buf, 0, 0.0)
    vDSP_sve(x, 1, result_buf, n)
    let val = deref_f32(result_buf, 0)
    free_raw(result_buf, 4)
    return val
}

// acc_vec_max: max of x[0..n]
fn acc_vec_max(x, n) {
    let result_buf = alloc_raw(4)
    write_f32(result_buf, 0, 0.0)
    vDSP_maxv(x, 1, result_buf, n)
    let val = deref_f32(result_buf, 0)
    free_raw(result_buf, 4)
    return val
}

// acc_vec_min: min of x[0..n]
fn acc_vec_min(x, n) {
    let result_buf = alloc_raw(4)
    write_f32(result_buf, 0, 0.0)
    vDSP_minv(x, 1, result_buf, n)
    let val = deref_f32(result_buf, 0)
    free_raw(result_buf, 4)
    return val
}

// acc_vec_zero: zero fill buffer
fn acc_vec_zero(out, n) {
    vDSP_vclr(out, 1, n)
}

// acc_vec_scale: x[i] = alpha * x[i] (pure hexa — cblas_sscal has float-by-value issue)
fn acc_vec_scale(x, n, alpha) {
    let mut i = 0
    while i < n {
        write_f32(x, i, deref_f32(x, i) * alpha)
        i = i + 1
    }
}

// acc_vec_axpy: y[i] = alpha * x[i] + y[i] (pure hexa)
fn acc_vec_axpy(x, y, n, alpha) {
    let mut i = 0
    while i < n {
        write_f32(y, i, alpha * deref_f32(x, i) + deref_f32(y, i))
        i = i + 1
    }
}

// acc_vec_dot: dot product (pure hexa — cblas_sdot returns float, ABI issue)
fn acc_vec_dot(x, y, n) {
    let mut sum = 0.0
    let mut i = 0
    while i < n {
        sum = sum + deref_f32(x, i) * deref_f32(y, i)
        i = i + 1
    }
    return sum
}

// acc_vec_norm2: L2 norm (pure hexa)
fn acc_vec_norm2(x, n) {
    let mut sum = 0.0
    let mut i = 0
    while i < n {
        let v = deref_f32(x, i)
        sum = sum + v * v
        i = i + 1
    }
    return sqrt(sum)
}

// ── Buffer helpers (f32 array <-> raw pointer) ──────────────

fn acc_f32_from_array(arr) {
    let n = len(arr)
    let buf = alloc_raw(n * 4)
    let mut i = 0
    while i < n {
        write_f32(buf, i, arr[i])
        i = i + 1
    }
    return buf
}

fn acc_f32_to_array(buf, n) {
    let mut arr = []
    let mut i = 0
    while i < n {
        arr = arr + [deref_f32(buf, i)]
        i = i + 1
    }
    return arr
}

fn acc_f32_zeros(n) {
    let buf = alloc_raw(n * 4)
    let mut i = 0
    while i < n {
        write_f32(buf, i, 0.0)
        i = i + 1
    }
    return buf
}

fn acc_f32_free(buf, n) {
    free_raw(buf, n * 4)
}

println("[accelerate_ffi] module loaded — macOS Accelerate extern FFI bindings ready")
