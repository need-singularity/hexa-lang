// ═══════════════════════════════════════════════════════════════
//  accelerate_ffi.hexa — macOS Accelerate framework FFI bindings
//
//  ML roadmap #180 — Accelerate FFI
//
//  Pure hexa FFI bindings to Apple's Accelerate framework:
//    - CBLAS   (sgemm, dgemm, saxpy, sdot, snrm2, sscal, ...)
//    - vDSP    (vadd, vmul, sve, maxv, minv, vclr, mmul)
//    - BNNS    (stub declarations for future Neural Network primitives)
//
//  Pointers are hexa Pointer type (u64).
//  Float scalars for CBLAS passed by value (unlike cuBLAS which needs
//  device pointers). vDSP uses pointer+stride convention.
//
//  NOTE: extern fn names match C symbol names directly (no @symbol alias)
//  to work with both Rust pre-built and self-hosted interpreters.
//
//  On macOS, @link("Accelerate") causes runtime.c to try:
//    dlopen("/System/Library/Frameworks/Accelerate.framework/Accelerate")
//
//  Usage:
//    use "self/ml/accelerate_ffi"
//    let ok = acc_init()
//    if ok == 0 {
//        let C = alloc_raw(M * N * 4)
//        acc_matmul(A, B, C, M, N, K)
//        ...
//    }
// ═══════════════════════════════════════════════════════════════

// ── CBLAS constants ─────────────────────────────────────────
let CblasRowMajor  = 101
let CblasColMajor  = 102
let CblasNoTrans   = 111
let CblasTrans     = 112
let CblasConjTrans = 113

// ── CBLAS BLAS functions (single precision) ─────────────────

// C = alpha*A*B + beta*C  (f32)
@link("Accelerate")
extern fn cblas_sgemm(order: int, transA: int, transB: int, M: int, N: int, K: int, alpha: float, A: *Void, lda: int, B: *Void, ldb: int, beta: float, C: *Void, ldc: int)

// y = alpha*x + y  (f32)
@link("Accelerate")
extern fn cblas_saxpy(N: int, alpha: float, x: *Void, incx: int, y: *Void, incy: int)

// dot = x . y  (f32)
@link("Accelerate")
extern fn cblas_sdot(N: int, x: *Void, incx: int, y: *Void, incy: int) -> float

// ||x||_2  (f32)
@link("Accelerate")
extern fn cblas_snrm2(N: int, x: *Void, incx: int) -> float

// x = alpha*x  (f32)
@link("Accelerate")
extern fn cblas_sscal(N: int, alpha: float, x: *Void, incx: int)

// ── CBLAS BLAS functions (double precision) ─────────────────

// C = alpha*A*B + beta*C  (f64)
@link("Accelerate")
extern fn cblas_dgemm(order: int, transA: int, transB: int, M: int, N: int, K: int, alpha: float, A: *Void, lda: int, B: *Void, ldb: int, beta: float, C: *Void, ldc: int)

// y = alpha*x + y  (f64)
@link("Accelerate")
extern fn cblas_daxpy(N: int, alpha: float, x: *Void, incx: int, y: *Void, incy: int)

// dot = x . y  (f64)
@link("Accelerate")
extern fn cblas_ddot(N: int, x: *Void, incx: int, y: *Void, incy: int) -> float

// ||x||_2  (f64)
@link("Accelerate")
extern fn cblas_dnrm2(N: int, x: *Void, incx: int) -> float

// ── vDSP functions (single precision, stride=1) ────────────

// out[i] = A[i] + B[i]
@link("Accelerate")
extern fn vDSP_vadd(A: *Void, strideA: int, B: *Void, strideB: int, C: *Void, strideC: int, N: int)

// out[i] = A[i] * B[i]
@link("Accelerate")
extern fn vDSP_vmul(A: *Void, strideA: int, B: *Void, strideB: int, C: *Void, strideC: int, N: int)

// sum of elements
@link("Accelerate")
extern fn vDSP_sve(A: *Void, stride: int, result: *Void, N: int)

// maximum value
@link("Accelerate")
extern fn vDSP_maxv(A: *Void, stride: int, result: *Void, N: int)

// minimum value
@link("Accelerate")
extern fn vDSP_minv(A: *Void, stride: int, result: *Void, N: int)

// zero fill
@link("Accelerate")
extern fn vDSP_vclr(C: *Void, stride: int, N: int)

// matrix multiply C[M x N] = A[M x K] * B[K x N]
@link("Accelerate")
extern fn vDSP_mmul(A: *Void, strideA: int, B: *Void, strideB: int, C: *Void, strideC: int, M: int, N: int, K: int)

// ── BNNS (Apple Neural Network Subroutines) ─────────────────
//
// BNNS provides hardware-accelerated neural network primitives on
// Apple Silicon (AMX/ANE). Filters are opaque handles created from
// layer parameter structs and applied to NDArray descriptors.
//
// BNNSNDArrayDescriptor layout (packed into raw memory):
//   offset  0: flags       (u32)  — BNNSNDArrayFlags (0 = default)
//   offset  4: layout      (u32)  — BNNSDataLayout enum
//   offset  8: size[8]     (8 x usize) — dimensions [w, h, ch, batch, ...]
//   offset 72: stride[8]   (8 x usize) — strides per dimension
//  offset 136: data        (ptr)  — pointer to float buffer
//  offset 144: data_type   (u32)  — BNNSDataType enum
//  offset 148: table_data  (ptr)  — NULL for dense
//  offset 156: table_data_type (u32) — 0
//  offset 160: data_scale  (f32)  — 1.0 for f32
//  offset 164: data_bias   (f32)  — 0.0
//  Total ~168 bytes; we allocate 176 for alignment.
//
// BNNSDataType constants
let BNNSDataTypeFloat32 = 65568    // 0x10020
let BNNSDataTypeFloat16 = 65552    // 0x10010
let BNNSDataTypeInt8     = 8       // 0x00008
let BNNSDataTypeInt32    = 32      // 0x00020

// BNNSDataLayout constants (common ones)
let BNNSDataLayoutVector                  = 65536   // 0x10000
let BNNSDataLayoutColumnMajorMatrix       = 131072  // 0x20000
let BNNSDataLayoutRowMajorMatrix          = 131073  // 0x20001
let BNNSDataLayoutImageCHW                = 196608  // 0x30000

// BNNSActivation function constants
let BNNSActivationFunctionIdentity = 0
let BNNSActivationFunctionReLU     = 1
let BNNSActivationFunctionSigmoid  = 3
let BNNSActivationFunctionTanh     = 4
let BNNSActivationFunctionGELU     = 11

// Descriptor size in bytes (176 for 8-byte alignment)
let BNNS_DESC_SIZE = 176

// Activation struct size: fn(u32) + params(2 x f32) + iscale/ioffset/ishift = 48 bytes
let BNNS_ACT_SIZE = 48

// ── BNNS low-level extern FFI ───────────────────────────────

// BNNSFilterCreateLayerFullyConnected:
//   Creates a dense (linear) layer filter.
//   in_desc, out_desc, weights_desc, bias_desc: pointers to BNNSNDArrayDescriptor
//   activation: pointer to BNNSActivation struct
//   filter_params: pointer to BNNSFilterParameters (NULL for defaults)
//   Returns opaque filter handle (*Void), NULL on failure.
@link("Accelerate")
extern fn BNNSFilterCreateLayerFullyConnected(in_desc: *Void, out_desc: *Void, weights_desc: *Void, bias_desc: *Void, activation: *Void, filter_params: *Void) -> *Void

// BNNSFilterCreateLayerConvolution:
//   Creates a convolution layer filter.
//   layer_params: pointer to BNNSLayerParametersConvolution struct
//   filter_params: pointer to BNNSFilterParameters (NULL for defaults)
//   Returns opaque filter handle (*Void), NULL on failure.
@link("Accelerate")
extern fn BNNSFilterCreateLayerConvolution(layer_params: *Void, filter_params: *Void) -> *Void

// BNNSFilterApply:
//   Run forward pass through filter.
//   filter: opaque handle from Create
//   in: pointer to input data
//   out: pointer to output data
//   Returns 0 on success, -1 on failure.
@link("Accelerate")
extern fn BNNSFilterApply(filter: *Void, input: *Void, output: *Void) -> int

// BNNSFilterApplyBatch:
//   Batched forward pass.
//   batch_size: number of samples
//   in_stride / out_stride: byte stride between batch elements
@link("Accelerate")
extern fn BNNSFilterApplyBatch(filter: *Void, batch_size: int, input: *Void, in_stride: int, output: *Void, out_stride: int) -> int

// BNNSFilterDestroy:
//   Free a filter and its internal resources.
@link("Accelerate")
extern fn BNNSFilterDestroy(filter: *Void)

// ── NDArrayDescriptor helpers ───────────────────────────────

// Allocate and zero a BNNSNDArrayDescriptor
fn bnns_alloc_desc() {
    let desc = alloc_raw(BNNS_DESC_SIZE)
    let mut i = 0
    while i < BNNS_DESC_SIZE {
        ptr_write(desc, i, 0)
        i = i + 1
    }
    return desc
}

// Set descriptor for 1D vector (e.g. bias)
fn bnns_desc_vector(data, n, dtype) {
    let desc = bnns_alloc_desc()
    // layout = BNNSDataLayoutVector
    write_i32(desc, 1, BNNSDataLayoutVector)
    // size[0] = n
    write_i64(desc, 1, n)   // offset 8 = size[0]
    // data pointer at offset 136
    ptr_write(desc, 136, data)
    // data_type at offset 144
    write_i32(desc, 36, dtype)
    // data_scale at offset 160
    write_f32(desc, 40, 1.0)
    // data_bias at offset 164
    write_f32(desc, 41, 0.0)
    return desc
}

// Set descriptor for 2D matrix (row-major) — e.g. weight [out_size x in_size]
fn bnns_desc_matrix(data, rows, cols, dtype) {
    let desc = bnns_alloc_desc()
    // layout = RowMajorMatrix
    write_i32(desc, 1, BNNSDataLayoutRowMajorMatrix)
    // size[0] = cols (width), size[1] = rows (height)
    write_i64(desc, 1, cols)   // offset 8
    write_i64(desc, 2, rows)   // offset 16
    // data pointer at offset 136
    ptr_write(desc, 136, data)
    // data_type at offset 144
    write_i32(desc, 36, dtype)
    // data_scale at offset 160
    write_f32(desc, 40, 1.0)
    write_f32(desc, 41, 0.0)
    return desc
}

// Set descriptor for 3D image tensor [C, H, W] (CHW layout)
fn bnns_desc_image_chw(data, channels, height, width, dtype) {
    let desc = bnns_alloc_desc()
    write_i32(desc, 1, BNNSDataLayoutImageCHW)
    // size[0]=W, size[1]=H, size[2]=C
    write_i64(desc, 1, width)
    write_i64(desc, 2, height)
    write_i64(desc, 3, channels)
    ptr_write(desc, 136, data)
    write_i32(desc, 36, dtype)
    write_f32(desc, 40, 1.0)
    write_f32(desc, 41, 0.0)
    return desc
}

// Free a descriptor (does NOT free the data buffer)
fn bnns_free_desc(desc) {
    free_raw(desc, BNNS_DESC_SIZE)
}

// ── Activation struct helper ────────────────────────────────

// Build a BNNSActivation struct in raw memory
// Returns pointer to 48-byte activation struct
fn bnns_activation(act_fn) {
    let act = alloc_raw(BNNS_ACT_SIZE)
    let mut i = 0
    while i < BNNS_ACT_SIZE {
        ptr_write(act, i, 0)
        i = i + 1
    }
    // function enum at offset 0
    write_i32(act, 0, act_fn)
    return act
}

fn bnns_free_activation(act) {
    free_raw(act, BNNS_ACT_SIZE)
}

// ── High-level BNNS wrappers ────────────────────────────────

// bnns_linear: create fully-connected layer filter
//   in_size:  input dimension
//   out_size: output dimension
//   weights:  f32 buffer [out_size x in_size], row-major
//   bias:     f32 buffer [out_size] or 0 (no bias)
//   act_fn:   BNNSActivationFunction* constant (0 = identity)
//   Returns opaque filter handle (pass to bnns_apply / bnns_destroy)
fn bnns_linear(in_size, out_size, weights, bias, act_fn) {
    let in_desc = bnns_desc_vector(0, in_size, BNNSDataTypeFloat32)
    let out_desc = bnns_desc_vector(0, out_size, BNNSDataTypeFloat32)
    let w_desc = bnns_desc_matrix(weights, out_size, in_size, BNNSDataTypeFloat32)

    let mut bias_desc = 0
    if bias != 0 {
        bias_desc = bnns_desc_vector(bias, out_size, BNNSDataTypeFloat32)
    }

    let act = bnns_activation(act_fn)

    // NULL filter_params = use defaults
    let filter = BNNSFilterCreateLayerFullyConnected(in_desc, out_desc, w_desc, bias_desc, act, 0)

    bnns_free_desc(in_desc)
    bnns_free_desc(out_desc)
    bnns_free_desc(w_desc)
    if bias_desc != 0 {
        bnns_free_desc(bias_desc)
    }
    bnns_free_activation(act)
    return filter
}

// bnns_apply: run forward pass through a BNNS filter
//   filter:  opaque handle from bnns_linear / bnns_conv
//   input:   f32 buffer
//   output:  f32 buffer (must be pre-allocated)
//   Returns 0 on success
fn bnns_apply(filter, input, output) {
    return BNNSFilterApply(filter, input, output)
}

// bnns_apply_batch: batched forward pass
fn bnns_apply_batch(filter, batch_size, input, in_stride, output, out_stride) {
    return BNNSFilterApplyBatch(filter, batch_size, input, in_stride, output, out_stride)
}

// bnns_destroy: free a BNNS filter
fn bnns_destroy(filter) {
    if filter != 0 {
        BNNSFilterDestroy(filter)
    }
}

// ── Global state ────────────────────────────────────────────
let mut G_ACC_INITIALIZED = 0

// ── Platform detection ──────────────────────────────────────

fn has_accelerate() {
    let marker = env_var("HEXA_PLATFORM")
    if marker == "darwin" {
        return 1
    }
    let probe = env_var("HOME")
    if probe != "" {
        return 1
    }
    return 0
}

// ── Initialization ──────────────────────────────────────────

fn acc_init() {
    if G_ACC_INITIALIZED == 1 {
        return 0
    }
    let avail = has_accelerate()
    if avail == 0 {
        println("[accelerate_ffi] Accelerate framework not available (not macOS)")
        return -1
    }
    G_ACC_INITIALIZED = 1
    println("[accelerate_ffi] initialized — Accelerate framework ready")
    return 0
}

fn acc_shutdown() {
    G_ACC_INITIALIZED = 0
    return 0
}

// ── High-level wrappers (row-major f32) ─────────────────────
//
// All wrappers assume:
//   - f32 data stored in alloc_raw buffers
//   - Row-major layout
//   - Stride = 1 for vDSP operations
//   - write_f32 / deref_f32 for element access

// acc_matmul: C[M x N] = A[M x K] * B[K x N]
// Uses vDSP_mmul (all-integer params, ARM64 register safe)
// vDSP_mmul(A, 1, B, 1, C, 1, M, N, K) where C[MxN] = A[MxK] * B[KxN]
fn acc_matmul(A, B, C, M, N, K) {
    vDSP_mmul(A, 1, B, 1, C, 1, M, N, K)
}

// acc_matmul_t: C[M x N] = A[M x K] * B^T  (manual transpose then vDSP_mmul)
fn acc_matmul_t(A, Bt, C, M, N, K) {
    // Bt is [N x K] stored row-major, need B [K x N]
    // Transpose in-place to temp buffer
    let tmp = alloc_raw(K * N * 4)
    let mut r = 0
    while r < N {
        let mut c = 0
        while c < K {
            write_f32(tmp, c * N + r, deref_f32(Bt, r * K + c))
            c = c + 1
        }
        r = r + 1
    }
    vDSP_mmul(A, 1, tmp, 1, C, 1, M, N, K)
    free_raw(tmp, K * N * 4)
}

// acc_matmul_acc: C[M x N] += A[M x K] * B[K x N]
fn acc_matmul_acc(A, B, C, M, N, K) {
    let tmp = alloc_raw(M * N * 4)
    vDSP_mmul(A, 1, B, 1, tmp, 1, M, N, K)
    vDSP_vadd(tmp, 1, C, 1, C, 1, M * N)
    free_raw(tmp, M * N * 4)
}

// acc_matmul_tn: C[M x N] = A^T[M x K] * B[K x N]
fn acc_matmul_tn(At, B, C, M, N, K) {
    let tmp = alloc_raw(M * K * 4)
    let mut r = 0
    while r < K {
        let mut c = 0
        while c < M {
            write_f32(tmp, c * K + r, deref_f32(At, r * M + c))
            c = c + 1
        }
        r = r + 1
    }
    vDSP_mmul(tmp, 1, B, 1, C, 1, M, N, K)
    free_raw(tmp, M * K * 4)
}

// acc_vec_add: out[i] = x[i] + y[i]
fn acc_vec_add(x, y, out, n) {
    vDSP_vadd(x, 1, y, 1, out, 1, n)
}

// acc_vec_mul: out[i] = x[i] * y[i]
fn acc_vec_mul(x, y, out, n) {
    vDSP_vmul(x, 1, y, 1, out, 1, n)
}

// acc_vec_sum: sum of x[0..n]
fn acc_vec_sum(x, n) {
    let result_buf = alloc_raw(4)
    write_f32(result_buf, 0, 0.0)
    vDSP_sve(x, 1, result_buf, n)
    let val = deref_f32(result_buf, 0)
    free_raw(result_buf, 4)
    return val
}

// acc_vec_max: max of x[0..n]
fn acc_vec_max(x, n) {
    let result_buf = alloc_raw(4)
    write_f32(result_buf, 0, 0.0)
    vDSP_maxv(x, 1, result_buf, n)
    let val = deref_f32(result_buf, 0)
    free_raw(result_buf, 4)
    return val
}

// acc_vec_min: min of x[0..n]
fn acc_vec_min(x, n) {
    let result_buf = alloc_raw(4)
    write_f32(result_buf, 0, 0.0)
    vDSP_minv(x, 1, result_buf, n)
    let val = deref_f32(result_buf, 0)
    free_raw(result_buf, 4)
    return val
}

// acc_vec_zero: zero fill buffer
fn acc_vec_zero(out, n) {
    vDSP_vclr(out, 1, n)
}

// acc_vec_scale: x[i] = alpha * x[i] (pure hexa — cblas_sscal has float-by-value issue)
fn acc_vec_scale(x, n, alpha) {
    let mut i = 0
    while i < n {
        write_f32(x, i, deref_f32(x, i) * alpha)
        i = i + 1
    }
}

// acc_vec_axpy: y[i] = alpha * x[i] + y[i] (pure hexa)
fn acc_vec_axpy(x, y, n, alpha) {
    let mut i = 0
    while i < n {
        write_f32(y, i, alpha * deref_f32(x, i) + deref_f32(y, i))
        i = i + 1
    }
}

// acc_vec_dot: dot product (pure hexa — cblas_sdot returns float, ABI issue)
fn acc_vec_dot(x, y, n) {
    let mut sum = 0.0
    let mut i = 0
    while i < n {
        sum = sum + deref_f32(x, i) * deref_f32(y, i)
        i = i + 1
    }
    return sum
}

// acc_vec_norm2: L2 norm (pure hexa)
fn acc_vec_norm2(x, n) {
    let mut sum = 0.0
    let mut i = 0
    while i < n {
        let v = deref_f32(x, i)
        sum = sum + v * v
        i = i + 1
    }
    return sqrt(sum)
}

// ── Buffer helpers (f32 array <-> raw pointer) ──────────────

fn acc_f32_from_array(arr) {
    let n = len(arr)
    let buf = alloc_raw(n * 4)
    let mut i = 0
    while i < n {
        write_f32(buf, i, arr[i])
        i = i + 1
    }
    return buf
}

fn acc_f32_to_array(buf, n) {
    let mut arr = []
    let mut i = 0
    while i < n {
        arr = arr + [deref_f32(buf, i)]
        i = i + 1
    }
    return arr
}

fn acc_f32_zeros(n) {
    let buf = alloc_raw(n * 4)
    let mut i = 0
    while i < n {
        write_f32(buf, i, 0.0)
        i = i + 1
    }
    return buf
}

fn acc_f32_free(buf, n) {
    free_raw(buf, n * 4)
}

println("[accelerate_ffi] module loaded — macOS Accelerate extern FFI bindings ready")
