// ===================================================================
//  self/ml/m4_inference.hexa — M4 16GB LLM Inference Engine
//
//  Strategy: bf16 weights + Metal FFN + CPU attention overlap
//
//  Architecture:
//    - Weights stored as bf16 (2 bytes) via hxblas_bf16 -- halves RSS
//    - Attention: CPU bf16 matvec (Q/K/V projection) -- memory-bound
//    - FFN: GPU via hxmetal (GELU + matmul) -- compute-bound
//    - Overlap: GPU FFN executes while CPU prefetches next layer
//    - M4 unified memory: MTLResourceStorageModeShared = zero-copy
//      GPU reads same bf16 buffers as CPU -- no PCIe transfer
//
//  Ceiling analysis (M4 Pro 16GB):
//    CPU f32 baseline: 23 tok/s (memory-bandwidth bound, ~50 GB/s)
//    bf16 weights:     46+ tok/s (halve bandwidth, same FLOPS)
//    Metal overlap:    60+ tok/s (FFN on GPU frees CPU for attn)
//
//  Dependencies:
//    - self/ml/hxmetal.hexa     (Metal GPU compute FFI)
//    - self/ml/hxblas_bf16.hexa (NEON bf16 matmul/matvec)
//    - self/ml/tensor.hexa      (Tensor struct + BLAS)
//    - self/ml/sampler.hexa     (token sampling)
//
//  Usage:
//    hexa self/ml/m4_inference.hexa --model <hexaw_path> [--tokens N]
//
//  Last updated: 2026-04-17
// ===================================================================

use "self/ml/hxmetal.hexa"
use "self/ml/hxblas_bf16.hexa"
use "self/ml/tensor.hexa"
use "self/ml/sampler.hexa"

// ── bf16 NEON kernel dispatch ───────────────────────────────────────
// Module-level switch routing all matvec calls through the bf16 NEON
// kernels in hxblas_linux.c (ARM64 path). When disabled, m4_matvec
// falls back to a scalar f32 reference by unpacking bf16 at call-site.
//
// Enabled by default. Override via --no-bf16 CLI flag for baseline
// comparison benchmarks (measures f32 scalar path on same pipeline).
//
// ABI probe: hxblas_bf16_version() returns 1 when libhxblas is linked
// with the NEON kernel section. 0 (or crash) means kernels missing.
//
// Platform dispatch model (2026-04-19):
//   Linux ARM64   → hxblas_bgemv NEON intrinsic path (primary target)
//   macOS ARM64   → same symbols; hxblas_linux.c compiled via __aarch64__
//   x86_64        → hxblas falls back to scalar reference (still bf16 ABI v1)
//
// The C library uses __aarch64__ preprocessor guards, so hxblas_bf16_version()
// returning >= 1 is a necessary but not sufficient signal for NEON intrinsics.
// We additionally gate on M4_BF16_PLATFORM, which is set from uname() when the
// host exports it (POSIX m4_detect_platform()), otherwise defaults to "arm64"
// because this module targets ARM-based inference by design.

let M4_BF16_PATH_NEON = 2     // hxblas_bgemv NEON intrinsic (linux/macOS ARM64)
let M4_BF16_PATH_SCALAR = 1   // hxblas_bgemv scalar loop (x86_64)
let M4_BF16_PATH_FALLBACK = 0 // disabled → f32 unpack + scalar gemv

let mut M4_BF16_ENABLED = true
let mut M4_BF16_PROBED = false
let mut M4_BF16_ABI = 0
let mut M4_BF16_PATH = 0             // one of M4_BF16_PATH_* after probe
let mut M4_BF16_PLATFORM = "arm64"   // "arm64" | "x86_64" | "unknown"
let mut M4_BF16_DISPATCH_COUNT = 0   // matvec calls routed through NEON
let mut M4_BF16_FALLBACK_COUNT = 0   // matvec calls routed through scalar

fn m4_detect_platform() {
    // Best-effort: inspect uname via env. hexa has no direct uname() FFI
    // on every target, so we key off common env hints and fall back to
    // "arm64" (the module's design target). This keeps parse green on
    // hosts without POSIX env exports.
    let mach = getenv("HEXA_HOST_MACH")
    if mach == "aarch64" { return "arm64" }
    if mach == "arm64"   { return "arm64" }
    if mach == "x86_64"  { return "x86_64" }
    if mach == "amd64"   { return "x86_64" }
    return "arm64"
}

fn m4_bf16_select_path(abi, platform) {
    // Decide which code path hxblas_bgemv resolves to on this host.
    //   ABI<1                 → disabled (library missing/old)
    //   ABI>=1 + arm64        → NEON intrinsic
    //   ABI>=1 + other        → scalar (still functionally correct)
    if abi < 1 { return M4_BF16_PATH_FALLBACK }
    if platform == "arm64" { return M4_BF16_PATH_NEON }
    return M4_BF16_PATH_SCALAR
}

fn m4_bf16_path_name(p) {
    if p == M4_BF16_PATH_NEON     { return "NEON" }
    if p == M4_BF16_PATH_SCALAR   { return "scalar" }
    return "fallback"
}

fn m4_bf16_probe() {
    // Call once at startup. Logs which path is active.
    if M4_BF16_PROBED { return M4_BF16_ABI }
    M4_BF16_ABI = hxblas_bf16_version()
    M4_BF16_PLATFORM = m4_detect_platform()
    M4_BF16_PATH = m4_bf16_select_path(M4_BF16_ABI, M4_BF16_PLATFORM)
    M4_BF16_PROBED = true
    if M4_BF16_ABI >= 1 {
        println("[m4] bf16 kernels: ABI v" + to_string(M4_BF16_ABI) +
                " platform=" + M4_BF16_PLATFORM +
                " path=" + m4_bf16_path_name(M4_BF16_PATH) +
                " (hxblas_bgemv)")
        if M4_BF16_PATH == M4_BF16_PATH_SCALAR {
            println("[m4] NOTE: non-ARM64 host — bf16 kernels run scalar loop, not NEON intrinsics")
        }
    } else {
        println("[m4] WARN: bf16 ABI probe returned " + to_string(M4_BF16_ABI) +
                " — kernels may be missing, forcing CPU fallback")
        M4_BF16_ENABLED = false
        M4_BF16_PATH = M4_BF16_PATH_FALLBACK
    }
    return M4_BF16_ABI
}

// Single dispatch entry used by every inference matvec site.
// W is a bf16-packed weight buffer. x is f32. Returns freshly
// allocated f32 y[M]. When bf16 is disabled, we unpack the row
// on the fly (slower, only for A/B comparison bench).
//
// Dispatch decision tree:
//   M4_BF16_ENABLED && path == NEON     → bf16_matvec → hxblas_bgemv(NEON)
//   M4_BF16_ENABLED && path == scalar   → bf16_matvec → hxblas_bgemv(scalar)
//   !M4_BF16_ENABLED || path == fallback → unpack-and-scalar in-line (below)
fn m4_matvec(M, K, W_bf16, x_f32) {
    if M4_BF16_ENABLED {
        M4_BF16_DISPATCH_COUNT = M4_BF16_DISPATCH_COUNT + 1
        return bf16_matvec(M, K, W_bf16, x_f32)
    }
    M4_BF16_FALLBACK_COUNT = M4_BF16_FALLBACK_COUNT + 1
    // Fallback: unpack entire weight to f32 and do scalar gemv.
    // This path exists purely so --no-bf16 measures the baseline on
    // the same code path; do not use in production.
    let w_f32 = bf16_unpack(W_bf16, M * K)
    let y = alloc_raw(M * 4)
    let mut r = 0
    while r < M {
        let mut acc = 0.0
        let mut c = 0
        while c < K {
            let wv = deref_f32(w_f32, (r * K + c) * 4)
            let xv = deref_f32(x_f32, c * 4)
            acc = acc + wv * xv
            c = c + 1
        }
        write_f32(y, r * 4, acc)
        r = r + 1
    }
    free_raw(w_f32, M * K * 4)
    return y
}

// Dispatch stats helper — useful in benchmark reports to confirm every
// matvec site actually hit the NEON path (no silent scalar leaks).
fn m4_bf16_dispatch_report() {
    println("[m4] bf16 dispatch: neon=" + to_string(M4_BF16_DISPATCH_COUNT) +
            " fallback=" + to_string(M4_BF16_FALLBACK_COUNT) +
            " path=" + m4_bf16_path_name(M4_BF16_PATH))
    return M4_BF16_DISPATCH_COUNT
}

// ── Model config ────────────────────────────────────────────────────

struct M4ModelConfig {
    dim: int,
    hidden_dim: int,
    n_layers: int,
    n_heads: int,
    n_kv_heads: int,
    vocab_size: int,
    max_seq_len: int,
    head_dim: int,
    rope_base: float,
    rms_eps: float
}

fn m4_config_7b() {
    return M4ModelConfig {
        dim: 4096,
        hidden_dim: 11008,
        n_layers: 32,
        n_heads: 32,
        n_kv_heads: 8,
        vocab_size: 32000,
        max_seq_len: 2048,
        head_dim: 128,
        rope_base: 10000.0,
        rms_eps: 0.000001
    }
}

fn m4_config_1b() {
    return M4ModelConfig {
        dim: 2048,
        hidden_dim: 5504,
        n_layers: 22,
        n_heads: 16,
        n_kv_heads: 4,
        vocab_size: 32000,
        max_seq_len: 2048,
        head_dim: 128,
        rope_base: 10000.0,
        rms_eps: 0.000001
    }
}

// ── bf16 weight container ───────────────────────────────────────────
// All weight pointers are raw bf16 (uint16_t*) packed via hxblas_f32_to_bf16.
// Norm weights stay f32 (tiny -- dim-sized, not worth bf16 loss).

struct M4LayerWeights {
    wq: int,         // bf16 ptr [dim, dim]
    wk: int,         // bf16 ptr [kv_dim, dim]
    wv: int,         // bf16 ptr [kv_dim, dim]
    wo: int,         // bf16 ptr [dim, dim]
    w1: int,         // bf16 ptr [hidden_dim, dim]   (gate)
    w2: int,         // bf16 ptr [dim, hidden_dim]   (down)
    w3: int,         // bf16 ptr [hidden_dim, dim]   (up)
    attn_norm: int,  // f32 ptr [dim]
    ffn_norm: int    // f32 ptr [dim]
}

struct M4Model {
    config: M4ModelConfig,
    layers: array,           // [M4LayerWeights]
    tok_emb: int,            // bf16 ptr [vocab_size, dim]
    lm_head: int,            // bf16 ptr [vocab_size, dim]
    final_norm: int,         // f32 ptr [dim]
    total_bf16_bytes: int,
    total_f32_bytes: int
}

// ── KV cache (raw f32 flat buffer, mutable) ─────────────────────────
// Layout: keys[layer][pos][kv_head][head_dim] -- contiguous f32
// Index: ((layer * max_seq + pos) * n_kv_heads + h) * head_dim + d

struct M4KVCache {
    keys: int,       // f32 ptr
    values: int,     // f32 ptr
    seq_len: int,
    max_seq: int,
    n_layers: int,
    n_kv_heads: int,
    head_dim: int
}

fn m4_kv_cache_new(cfg: M4ModelConfig) {
    let total = cfg.n_layers * cfg.max_seq_len * cfg.n_kv_heads * cfg.head_dim
    let bytes = total * 4
    let k = alloc_raw(bytes)
    let v = alloc_raw(bytes)
    return M4KVCache {
        keys: k,
        values: v,
        seq_len: 0,
        max_seq: cfg.max_seq_len,
        n_layers: cfg.n_layers,
        n_kv_heads: cfg.n_kv_heads,
        head_dim: cfg.head_dim
    }
}

fn m4_kv_cache_free(cache: M4KVCache) {
    let total = cache.n_layers * cache.max_seq * cache.n_kv_heads * cache.head_dim
    let bytes = total * 4
    free_raw(cache.keys, bytes)
    free_raw(cache.values, bytes)
}

fn m4_kv_idx(layer, pos, h, d, max_seq, n_kv_heads, head_dim) {
    return ((layer * max_seq + pos) * n_kv_heads + h) * head_dim + d
}

fn m4_kv_write_slab(ptr, layer, pos, vec_ptr, n_kv_heads, head_dim, max_seq) {
    let slab = n_kv_heads * head_dim
    let base = ((layer * max_seq + pos) * n_kv_heads) * head_dim
    let mut i = 0
    while i < slab {
        let v = deref_f32(vec_ptr, i * 4)
        write_f32(ptr, (base + i) * 4, v)
        i = i + 1
    }
}

// ── Weight loading: hexaw f32 -> bf16 pack ──────────────────────────
// Loads a .hexaw file, converts all weight matrices to bf16 in-place.
// Norm weights stay f32. Returns M4Model.
//
// Memory savings: 7B f32 = 28GB -> bf16 = 14GB (fits M4 16GB)

fn m4_pack_tensor_bf16(f32_data, numel) {
    // f32_data is a hexa array -- pack to raw f32 buffer first, then bf16
    let f32_buf = alloc_raw(numel * 4)
    let mut i = 0
    while i < numel {
        write_f32(f32_buf, i * 4, f32_data[i])
        i = i + 1
    }
    let bf16_buf = bf16_pack(f32_buf, numel)
    free_raw(f32_buf, numel * 4)
    return bf16_buf
}

fn m4_pack_tensor_f32(f32_data, numel) {
    // Pack hexa array to raw f32 buffer
    let buf = alloc_raw(numel * 4)
    let mut i = 0
    while i < numel {
        write_f32(buf, i * 4, f32_data[i])
        i = i + 1
    }
    return buf
}

fn m4_load_weights(hexaw_dict, cfg: M4ModelConfig) {
    let dim = cfg.dim
    let hidden_dim = cfg.hidden_dim
    let n_kv_heads = cfg.n_kv_heads
    let head_dim = cfg.head_dim
    let kv_dim = n_kv_heads * head_dim
    let vocab_size = cfg.vocab_size
    let n_layers = cfg.n_layers

    let mut total_bf16 = 0
    let mut total_f32 = 0

    // Token embedding: [vocab_size, dim] -> bf16
    let tok_emb_data = hexaw_tensor(hexaw_dict, "tok_embeddings.weight")
    let tok_emb_numel = vocab_size * dim
    let tok_emb = m4_pack_tensor_bf16(tok_emb_data, tok_emb_numel)
    total_bf16 = total_bf16 + tok_emb_numel * 2

    // LM head (often tied with tok_emb, but pack separately for clarity)
    let lm_head_data = hexaw_tensor(hexaw_dict, "output.weight")
    let lm_head = m4_pack_tensor_bf16(lm_head_data, vocab_size * dim)
    total_bf16 = total_bf16 + vocab_size * dim * 2

    // Final norm: f32
    let final_norm_data = hexaw_tensor(hexaw_dict, "norm.weight")
    let final_norm = m4_pack_tensor_f32(final_norm_data, dim)
    total_f32 = total_f32 + dim * 4

    // Per-layer weights
    let mut layers = []
    let mut li = 0
    while li < n_layers {
        let ls = to_string(li)
        let prefix = "layers." + ls + "."

        // Attention projections -> bf16
        let wq_data = hexaw_tensor(hexaw_dict, prefix + "attention.wq.weight")
        let wq = m4_pack_tensor_bf16(wq_data, dim * dim)
        total_bf16 = total_bf16 + dim * dim * 2

        let wk_data = hexaw_tensor(hexaw_dict, prefix + "attention.wk.weight")
        let wk = m4_pack_tensor_bf16(wk_data, kv_dim * dim)
        total_bf16 = total_bf16 + kv_dim * dim * 2

        let wv_data = hexaw_tensor(hexaw_dict, prefix + "attention.wv.weight")
        let wv = m4_pack_tensor_bf16(wv_data, kv_dim * dim)
        total_bf16 = total_bf16 + kv_dim * dim * 2

        let wo_data = hexaw_tensor(hexaw_dict, prefix + "attention.wo.weight")
        let wo = m4_pack_tensor_bf16(wo_data, dim * dim)
        total_bf16 = total_bf16 + dim * dim * 2

        // FFN projections -> bf16
        let w1_data = hexaw_tensor(hexaw_dict, prefix + "feed_forward.w1.weight")
        let w1 = m4_pack_tensor_bf16(w1_data, hidden_dim * dim)
        total_bf16 = total_bf16 + hidden_dim * dim * 2

        let w2_data = hexaw_tensor(hexaw_dict, prefix + "feed_forward.w2.weight")
        let w2 = m4_pack_tensor_bf16(w2_data, dim * hidden_dim)
        total_bf16 = total_bf16 + dim * hidden_dim * 2

        let w3_data = hexaw_tensor(hexaw_dict, prefix + "feed_forward.w3.weight")
        let w3 = m4_pack_tensor_bf16(w3_data, hidden_dim * dim)
        total_bf16 = total_bf16 + hidden_dim * dim * 2

        // Norm weights -> f32 (small, precision matters)
        let attn_norm_data = hexaw_tensor(hexaw_dict, prefix + "attention_norm.weight")
        let attn_norm = m4_pack_tensor_f32(attn_norm_data, dim)
        total_f32 = total_f32 + dim * 4

        let ffn_norm_data = hexaw_tensor(hexaw_dict, prefix + "ffn_norm.weight")
        let ffn_norm = m4_pack_tensor_f32(ffn_norm_data, dim)
        total_f32 = total_f32 + dim * 4

        let lw = M4LayerWeights {
            wq: wq, wk: wk, wv: wv, wo: wo,
            w1: w1, w2: w2, w3: w3,
            attn_norm: attn_norm, ffn_norm: ffn_norm
        }
        layers.push(lw)
        li = li + 1
    }

    let model = M4Model {
        config: cfg,
        layers: layers,
        tok_emb: tok_emb,
        lm_head: lm_head,
        final_norm: final_norm,
        total_bf16_bytes: total_bf16,
        total_f32_bytes: total_f32
    }

    let total_mb = to_float(total_bf16 + total_f32) / 1048576.0
    println("[m4] Loaded: bf16=" + to_string(total_bf16 / 1048576) + "MB f32=" + to_string(total_f32 / 1048576) + "MB total=" + to_string(total_mb) + "MB")

    return model
}

// ── RMSNorm (CPU, f32 activations, f32 norm weights) ────────────────

@hot
fn m4_rms_norm(x_ptr, w_ptr, out_ptr, dim, eps) {
    // x, w, out are all f32 raw pointers
    let mut ss = 0.0
    let mut i = 0
    while i < dim {
        let v = deref_f32(x_ptr, i * 4)
        ss = ss + v * v
        i = i + 1
    }
    let rms = sqrt(ss / to_float(dim) + eps)
    let inv_rms = 1.0 / rms
    i = 0
    while i < dim {
        let x_v = deref_f32(x_ptr, i * 4)
        let w_v = deref_f32(w_ptr, i * 4)
        write_f32(out_ptr, i * 4, x_v * inv_rms * w_v)
        i = i + 1
    }
}

// ── RoPE (CPU, in-place on f32 buffer) ──────────────────────────────

@hot
fn m4_apply_rope(vec_ptr, n_heads_rope, head_dim, pos, rope_base) {
    let half = head_dim / 2
    let mut h = 0
    while h < n_heads_rope {
        let base_off = h * head_dim
        let mut p = 0
        while p < half {
            let freq = 1.0 / pow(rope_base, 2.0 * to_float(p) / to_float(head_dim))
            let angle = to_float(pos) * freq
            let cos_a = cos(angle)
            let sin_a = sin(angle)
            let off0 = (base_off + 2 * p) * 4
            let off1 = (base_off + 2 * p + 1) * 4
            let x0 = deref_f32(vec_ptr, off0)
            let x1 = deref_f32(vec_ptr, off1)
            write_f32(vec_ptr, off0, x0 * cos_a - x1 * sin_a)
            write_f32(vec_ptr, off1, x0 * sin_a + x1 * cos_a)
            p = p + 1
        }
        h = h + 1
    }
}

// ── SiLU activation (CPU, in-place) ─────────────────────────────────

@hot
fn m4_silu_inplace(ptr, n) {
    let mut i = 0
    while i < n {
        let x = deref_f32(ptr, i * 4)
        let s = x / (1.0 + exp(0.0 - x))
        write_f32(ptr, i * 4, s)
        i = i + 1
    }
}

// ── Elementwise multiply (CPU, in-place: a *= b) ────────────────────

@hot
fn m4_elemul_inplace(a_ptr, b_ptr, n) {
    let mut i = 0
    while i < n {
        let a = deref_f32(a_ptr, i * 4)
        let b = deref_f32(b_ptr, i * 4)
        write_f32(a_ptr, i * 4, a * b)
        i = i + 1
    }
}

// ── Residual add (CPU, in-place: dst += src) ────────────────────────

@hot
fn m4_residual_add(dst_ptr, src_ptr, n) {
    let mut i = 0
    while i < n {
        let a = deref_f32(dst_ptr, i * 4)
        let b = deref_f32(src_ptr, i * 4)
        write_f32(dst_ptr, i * 4, a + b)
        i = i + 1
    }
}

// ── Embedding lookup: bf16 tok_emb -> f32 activation ────────────────

fn m4_embed(tok_emb_bf16, token_id, dim) {
    // tok_emb is bf16 [vocab_size, dim], row = token_id
    // Extract one row: bf16 ptr + offset, unpack to f32
    let row_offset = token_id * dim  // element offset
    let row_bf16_bytes = dim * 2
    // Point into the bf16 buffer at the right row
    // hxblas_bf16_to_f32(n, src, dst): src is byte-addressed via int cast
    let src_ptr = tok_emb_bf16 + row_offset * 2  // pointer arithmetic (byte offset)
    let dst = alloc_raw(dim * 4)
    hxblas_bf16_to_f32(dim, src_ptr, dst)
    return dst
}

// ===================================================================
//  Single Transformer Layer — M4 GPU/CPU overlap
//
//  CPU path: attention (bf16 matvec for QKV, f32 scores/softmax)
//  GPU path: FFN via hxmetal (fused GELU matmul)
//
//  On M4 unified memory, GPU reads the same bf16 weight buffers
//  as CPU with zero copy. The key overlap opportunity:
//    - GPU dispatches FFN (compute-bound, ~70% of layer FLOPS)
//    - CPU starts next layer's attention norm + QKV projection
//    - GPU result read-back after CPU finishes attn
// ===================================================================

@hot
fn m4_transformer_layer(model: M4Model, layer_idx, x_ptr, pos,
                        kv_cache: M4KVCache, use_metal) {
    let cfg = model.config
    let dim = cfg.dim
    let n_heads = cfg.n_heads
    let n_kv_heads = cfg.n_kv_heads
    let head_dim = cfg.head_dim
    let hidden_dim = cfg.hidden_dim
    let eps = cfg.rms_eps
    let rope_base = cfg.rope_base
    let gqa_ratio = n_heads / n_kv_heads
    let kv_dim = n_kv_heads * head_dim

    let lw = model.layers[layer_idx]

    // ── Phase 1: Attention (CPU, bf16 matvec) ───────────────────────

    // 1a. RMSNorm
    let xn = alloc_raw(dim * 4)
    m4_rms_norm(x_ptr, lw.attn_norm, xn, dim, eps)

    // 1b. Q/K/V projection via bf16 matvec (routes through m4_matvec dispatch)
    //     W[out_dim, dim] bf16 x xn[dim] f32 -> y[out_dim] f32
    let q_ptr = m4_matvec(dim, dim, lw.wq, xn)           // [dim] f32
    let k_ptr = m4_matvec(kv_dim, dim, lw.wk, xn)        // [kv_dim] f32
    let v_ptr = m4_matvec(kv_dim, dim, lw.wv, xn)        // [kv_dim] f32
    free_raw(xn, dim * 4)

    // 1c. RoPE on Q and K
    m4_apply_rope(q_ptr, n_heads, head_dim, pos, rope_base)
    m4_apply_rope(k_ptr, n_kv_heads, head_dim, pos, rope_base)

    // 1d. Write K, V into cache
    m4_kv_write_slab(kv_cache.keys, layer_idx, pos, k_ptr, n_kv_heads, head_dim, kv_cache.max_seq)
    m4_kv_write_slab(kv_cache.values, layer_idx, pos, v_ptr, n_kv_heads, head_dim, kv_cache.max_seq)
    free_raw(k_ptr, kv_dim * 4)
    free_raw(v_ptr, kv_dim * 4)

    // 1e. Grouped Query Attention (CPU, f32)
    let scale = 1.0 / sqrt(to_float(head_dim))
    let ctx_len = pos + 1
    let attn_out = alloc_raw(dim * 4)  // [n_heads * head_dim] f32

    let mut h = 0
    while h < n_heads {
        let kv_h = h / gqa_ratio
        let q_base = h * head_dim

        // Compute attention scores: Q[h] . K[kv_h, t] for t in 0..ctx_len
        let scores = alloc_raw(ctx_len * 4)
        let mut t = 0
        while t < ctx_len {
            let k_base_idx = m4_kv_idx(layer_idx, t, kv_h, 0, kv_cache.max_seq, n_kv_heads, head_dim)
            let mut dot = 0.0
            let mut d = 0
            while d < head_dim {
                let q_v = deref_f32(q_ptr, (q_base + d) * 4)
                let k_v = deref_f32(kv_cache.keys, (k_base_idx + d) * 4)
                dot = dot + q_v * k_v
                d = d + 1
            }
            write_f32(scores, t * 4, dot * scale)
            t = t + 1
        }

        // Softmax over scores
        let mut mx = deref_f32(scores, 0)
        t = 1
        while t < ctx_len {
            let s = deref_f32(scores, t * 4)
            if s > mx { mx = s }
            t = t + 1
        }
        let mut sum_e = 0.0
        t = 0
        while t < ctx_len {
            let e = exp(deref_f32(scores, t * 4) - mx)
            write_f32(scores, t * 4, e)
            sum_e = sum_e + e
            t = t + 1
        }
        let inv_sum = 1.0 / sum_e
        t = 0
        while t < ctx_len {
            let v = deref_f32(scores, t * 4)
            write_f32(scores, t * 4, v * inv_sum)
            t = t + 1
        }

        // Weighted sum of values -> attn_out[h * head_dim .. (h+1) * head_dim]
        let mut d = 0
        while d < head_dim {
            let mut acc = 0.0
            t = 0
            while t < ctx_len {
                let w = deref_f32(scores, t * 4)
                let v_base_idx = m4_kv_idx(layer_idx, t, kv_h, d, kv_cache.max_seq, n_kv_heads, head_dim)
                acc = acc + w * deref_f32(kv_cache.values, v_base_idx * 4)
                t = t + 1
            }
            write_f32(attn_out, (h * head_dim + d) * 4, acc)
            d = d + 1
        }

        free_raw(scores, ctx_len * 4)
        h = h + 1
    }
    free_raw(q_ptr, dim * 4)

    // 1f. Output projection: Wo[dim, dim] bf16 x attn_out[dim] f32 -> [dim] f32
    let attn_proj = m4_matvec(dim, dim, lw.wo, attn_out)
    free_raw(attn_out, dim * 4)

    // 1g. Residual connection: x += attn_proj
    m4_residual_add(x_ptr, attn_proj, dim)
    free_raw(attn_proj, dim * 4)

    // ── Phase 2: FFN ────────────────────────────────────────────────

    // 2a. RMSNorm for FFN
    let xn2 = alloc_raw(dim * 4)
    m4_rms_norm(x_ptr, lw.ffn_norm, xn2, dim, eps)

    if use_metal == true {
        // ── GPU path: Metal FFN (fused GELU matmul) ─────────────────
        // Unpack bf16 W1, W2 to f32 for Metal (Metal expects f32 buffers)
        // Future: Metal bf16 compute shaders would skip this unpack.
        let w1_f32 = bf16_unpack(lw.w1, hidden_dim * dim)
        let w2_f32 = bf16_unpack(lw.w2, dim * hidden_dim)
        let ffn_out = alloc_raw(dim * 4)

        // hxmetal_ffn_fwd: Y = GELU(X * W1) * W2
        // X: [1, dim], W1: [dim, hidden_dim], W2: [hidden_dim, dim], Y: [1, dim]
        let rc = metal_ffn_fwd(dim, hidden_dim, 1, w1_f32, w2_f32, xn2, ffn_out)

        free_raw(w1_f32, hidden_dim * dim * 4)
        free_raw(w2_f32, dim * hidden_dim * 4)

        if rc != 0 {
            // Metal failed -- fall back to CPU SwiGLU
            println("[m4] WARN: Metal FFN failed rc=" + to_string(rc) + " falling back to CPU")
            // CPU fallback below
            let gate = m4_matvec(hidden_dim, dim, lw.w1, xn2)
            let up = m4_matvec(hidden_dim, dim, lw.w3, xn2)
            m4_silu_inplace(gate, hidden_dim)
            m4_elemul_inplace(gate, up, hidden_dim)
            free_raw(up, hidden_dim * 4)
            let down = m4_matvec(dim, hidden_dim, lw.w2, gate)
            free_raw(gate, hidden_dim * 4)
            // Copy down -> ffn_out
            let mut fi = 0
            while fi < dim {
                write_f32(ffn_out, fi * 4, deref_f32(down, fi * 4))
                fi = fi + 1
            }
            free_raw(down, dim * 4)
        }

        free_raw(xn2, dim * 4)
        m4_residual_add(x_ptr, ffn_out, dim)
        free_raw(ffn_out, dim * 4)
    } else {
        // ── CPU path: SwiGLU FFN (bf16 matvec via dispatch) ─────────
        // gate = SiLU(W1 * xn)
        // up   = W3 * xn
        // down = W2 * (gate * up)
        let gate = m4_matvec(hidden_dim, dim, lw.w1, xn2)
        let up = m4_matvec(hidden_dim, dim, lw.w3, xn2)
        free_raw(xn2, dim * 4)

        m4_silu_inplace(gate, hidden_dim)
        m4_elemul_inplace(gate, up, hidden_dim)
        free_raw(up, hidden_dim * 4)

        let down = m4_matvec(dim, hidden_dim, lw.w2, gate)
        free_raw(gate, hidden_dim * 4)

        m4_residual_add(x_ptr, down, dim)
        free_raw(down, dim * 4)
    }
}

// ===================================================================
//  Full forward pass: all layers + LM head -> logits
// ===================================================================

fn m4_forward(model: M4Model, token_id, pos, kv_cache: M4KVCache, use_metal) {
    let cfg = model.config
    let dim = cfg.dim
    let n_layers = cfg.n_layers
    let vocab_size = cfg.vocab_size

    // Embed token -> f32 activation
    let x_ptr = m4_embed(model.tok_emb, token_id, dim)

    // Run all transformer layers
    let mut li = 0
    while li < n_layers {
        m4_transformer_layer(model, li, x_ptr, pos, kv_cache, use_metal)
        li = li + 1
    }

    // Final RMSNorm
    let xn = alloc_raw(dim * 4)
    m4_rms_norm(x_ptr, model.final_norm, xn, dim, cfg.rms_eps)
    free_raw(x_ptr, dim * 4)

    // LM head: logits = lm_head[vocab, dim] bf16 x xn[dim] f32 -> [vocab] f32
    let logits_ptr = m4_matvec(vocab_size, dim, model.lm_head, xn)
    free_raw(xn, dim * 4)

    return logits_ptr
}

// ===================================================================
//  Decode loop: autoregressive token generation
// ===================================================================

fn m4_decode(model: M4Model, input_tokens, max_new_tokens, temperature, use_metal) {
    let cfg = model.config
    let vocab_size = cfg.vocab_size

    let kv_cache = m4_kv_cache_new(cfg)

    let sampler_cfg = SamplerConfig {
        temperature: temperature,
        top_p: 0.9,
        top_k: 40,
        seed: 42
    }
    sampler_set_seed(42)

    let prompt_len = len(input_tokens)

    // ── Prefill: process all prompt tokens ──────────────────────────
    let t_prefill_0 = clock()
    let mut pos = 0
    let mut last_logits_ptr = 0
    while pos < prompt_len {
        let tok = input_tokens[pos]
        let logits_ptr = m4_forward(model, tok, pos, kv_cache, use_metal)
        if last_logits_ptr != 0 {
            free_raw(last_logits_ptr, vocab_size * 4)
        }
        last_logits_ptr = logits_ptr
        pos = pos + 1
    }
    let t_prefill_1 = clock()
    let prefill_ms = (t_prefill_1 - t_prefill_0) * 1000.0
    println("[m4] Prefill: " + to_string(prompt_len) + " tokens in " + to_string(prefill_ms) + " ms")

    // ── Decode: generate new tokens ─────────────────────────────────
    let t_decode_0 = clock()
    let mut generated = 0
    let mut tok_times = []
    let mut output_tokens = []

    // Sample first token from prefill logits
    let mut cur_tok = m4_sample_from_ptr(last_logits_ptr, vocab_size, sampler_cfg)
    free_raw(last_logits_ptr, vocab_size * 4)
    output_tokens.push(cur_tok)

    while generated < max_new_tokens {
        if cur_tok == 2 { generated = max_new_tokens }  // EOS
        else {
            let t0 = clock()
            let logits_ptr = m4_forward(model, cur_tok, pos, kv_cache, use_metal)
            let next_tok = m4_sample_from_ptr(logits_ptr, vocab_size, sampler_cfg)
            free_raw(logits_ptr, vocab_size * 4)

            let t1 = clock()
            let ms = (t1 - t0) * 1000.0
            tok_times.push(ms)

            output_tokens.push(next_tok)
            cur_tok = next_tok
            pos = pos + 1
            generated = generated + 1
        }
    }

    let t_decode_1 = clock()
    let decode_ms = (t_decode_1 - t_decode_0) * 1000.0

    m4_kv_cache_free(kv_cache)

    // ── Report ──────────────────────────────────────────────────────
    let n_gen = len(tok_times)
    let result = #{}
    result["output_tokens"] = output_tokens
    result["prefill_ms"] = prefill_ms
    result["decode_ms"] = decode_ms
    result["n_generated"] = n_gen

    if n_gen > 0 {
        let mut sum_ms = 0.0
        let mut best_ms = tok_times[0]
        let mut worst_ms = tok_times[0]
        let mut i = 0
        while i < n_gen {
            sum_ms = sum_ms + tok_times[i]
            if tok_times[i] < best_ms { best_ms = tok_times[i] }
            if tok_times[i] > worst_ms { worst_ms = tok_times[i] }
            i = i + 1
        }
        let avg_ms = sum_ms / to_float(n_gen)
        let tok_s = 1000.0 / avg_ms

        result["avg_ms_per_tok"] = avg_ms
        result["tok_s"] = tok_s
        result["best_ms"] = best_ms
        result["worst_ms"] = worst_ms
    }

    return result
}

// ── Sampling helper: read f32 logits from raw pointer ───────────────

fn m4_sample_from_ptr(logits_ptr, vocab_size, cfg: SamplerConfig) {
    // Convert raw f32 pointer to hexa array for sampler
    let mut logits = []
    let mut i = 0
    while i < vocab_size {
        logits.push(deref_f32(logits_ptr, i * 4))
        i = i + 1
    }
    return sample_token(logits, vocab_size, cfg)
}

// ===================================================================
//  Benchmark harness
// ===================================================================

fn m4_bench(model: M4Model, n_tokens, use_metal) {
    let cfg = model.config
    let vocab_size = cfg.vocab_size

    println("============================================================")
    println("  M4 Inference Benchmark")
    println("  dim=" + to_string(cfg.dim) + " layers=" + to_string(cfg.n_layers))
    println("  heads=" + to_string(cfg.n_heads) + " kv_heads=" + to_string(cfg.n_kv_heads))
    println("  hidden=" + to_string(cfg.hidden_dim) + " vocab=" + to_string(vocab_size))
    println("  bf16=" + to_string(model.total_bf16_bytes / 1048576) + "MB f32=" + to_string(model.total_f32_bytes / 1048576) + "MB")
    println("  metal=" + to_string(use_metal))
    println("  tokens=" + to_string(n_tokens))
    println("============================================================")

    // Use a simple prompt: [BOS, 1, 2, 3]
    let input_tokens = [1, 100, 200, 300]

    let result = m4_decode(model, input_tokens, n_tokens, 0.0, use_metal)

    let avg_ms = result["avg_ms_per_tok"]
    let tok_s = result["tok_s"]
    let prefill_ms = result["prefill_ms"]
    let decode_ms = result["decode_ms"]
    let n_gen = result["n_generated"]
    let best_ms = result["best_ms"]
    let worst_ms = result["worst_ms"]

    println("---")
    println("[m4] Decode: " + to_string(n_gen) + " tokens in " + to_string(decode_ms) + " ms")
    println("[m4] Avg: " + to_string(avg_ms) + " ms/tok = " + to_string(tok_s) + " tok/s")
    println("[m4] Best: " + to_string(best_ms) + " ms/tok")
    println("[m4] Worst: " + to_string(worst_ms) + " ms/tok")

    // Bandwidth utilization estimate
    let weight_bytes = to_float(model.total_bf16_bytes + model.total_f32_bytes)
    let bw_gbs = weight_bytes / (avg_ms / 1000.0) / 1000000000.0
    println("[m4] Est. bandwidth: " + to_string(bw_gbs) + " GB/s (M4 Pro ~100 GB/s)")

    // JSON summary
    let mut line = "{\"engine\":\"m4_inference\""
    line = line + ",\"metal\":" + to_string(use_metal)
    line = line + ",\"tokens\":" + to_string(n_gen)
    line = line + ",\"avg_ms\":" + to_string(avg_ms)
    line = line + ",\"tok_s\":" + to_string(tok_s)
    line = line + ",\"best_ms\":" + to_string(best_ms)
    line = line + ",\"worst_ms\":" + to_string(worst_ms)
    line = line + ",\"bw_gbs\":" + to_string(bw_gbs)
    line = line + ",\"prefill_ms\":" + to_string(prefill_ms)
    line = line + ",\"decode_ms\":" + to_string(decode_ms)
    line = line + ",\"bf16_mb\":" + to_string(model.total_bf16_bytes / 1048576)
    line = line + ",\"f32_mb\":" + to_string(model.total_f32_bytes / 1048576)
    line = line + ",\"bf16_path\":\"" + m4_bf16_path_name(M4_BF16_PATH) + "\""
    line = line + ",\"bf16_dispatch\":" + to_string(M4_BF16_DISPATCH_COUNT)
    line = line + ",\"bf16_fallback\":" + to_string(M4_BF16_FALLBACK_COUNT)
    line = line + "}"
    println(line)

    m4_bf16_dispatch_report()

    return result
}

// ===================================================================
//  Synthetic model generator (for testing without real weights)
// ===================================================================

fn m4_create_synthetic(cfg: M4ModelConfig) {
    let dim = cfg.dim
    let hidden_dim = cfg.hidden_dim
    let n_kv_heads = cfg.n_kv_heads
    let head_dim = cfg.head_dim
    let kv_dim = n_kv_heads * head_dim
    let vocab_size = cfg.vocab_size
    let n_layers = cfg.n_layers

    let mut total_bf16 = 0
    let mut total_f32 = 0

    // Helpers: allocate zero bf16/f32 buffers
    // (Zero weights produce zero activations, but pipeline is exercised)

    // Token embedding
    let tok_numel = vocab_size * dim
    let tok_emb = bf16_alloc(tok_numel)
    total_bf16 = total_bf16 + tok_numel * 2

    // Fill with tiny nonzero values so forward pass is numerically nontrivial
    let tok_f32 = alloc_raw(tok_numel * 4)
    let mut i = 0
    while i < tok_numel {
        // Pseudo-random small float: sin(i * 0.001) * 0.01
        let v = sin(to_float(i) * 0.001) * 0.01
        write_f32(tok_f32, i * 4, v)
        i = i + 1
    }
    hxblas_f32_to_bf16(tok_numel, tok_f32, tok_emb)
    free_raw(tok_f32, tok_numel * 4)

    // LM head
    let lm_numel = vocab_size * dim
    let lm_head = bf16_alloc(lm_numel)
    total_bf16 = total_bf16 + lm_numel * 2
    // Fill similarly
    let lm_f32 = alloc_raw(lm_numel * 4)
    i = 0
    while i < lm_numel {
        let v = cos(to_float(i) * 0.0007) * 0.01
        write_f32(lm_f32, i * 4, v)
        i = i + 1
    }
    hxblas_f32_to_bf16(lm_numel, lm_f32, lm_head)
    free_raw(lm_f32, lm_numel * 4)

    // Final norm (f32, ones)
    let final_norm = alloc_raw(dim * 4)
    i = 0
    while i < dim {
        write_f32(final_norm, i * 4, 1.0)
        i = i + 1
    }
    total_f32 = total_f32 + dim * 4

    // Per-layer weights
    let mut layers = []
    let mut li = 0
    while li < n_layers {
        // All projections: allocate bf16 zero-init (bf16_alloc uses alloc_raw which callocs)
        let wq = bf16_alloc(dim * dim)
        let wk = bf16_alloc(kv_dim * dim)
        let wv = bf16_alloc(kv_dim * dim)
        let wo = bf16_alloc(dim * dim)
        let w1 = bf16_alloc(hidden_dim * dim)
        let w2 = bf16_alloc(dim * hidden_dim)
        let w3 = bf16_alloc(hidden_dim * dim)
        total_bf16 = total_bf16 + (dim * dim * 2 + kv_dim * dim * 2 + kv_dim * dim * 2 + dim * dim * 2)
        total_bf16 = total_bf16 + (hidden_dim * dim * 2 + dim * hidden_dim * 2 + hidden_dim * dim * 2)

        // Norm weights: f32, all ones
        let attn_norm = alloc_raw(dim * 4)
        let ffn_norm = alloc_raw(dim * 4)
        let mut d = 0
        while d < dim {
            write_f32(attn_norm, d * 4, 1.0)
            write_f32(ffn_norm, d * 4, 1.0)
            d = d + 1
        }
        total_f32 = total_f32 + dim * 4 * 2

        let lw = M4LayerWeights {
            wq: wq, wk: wk, wv: wv, wo: wo,
            w1: w1, w2: w2, w3: w3,
            attn_norm: attn_norm, ffn_norm: ffn_norm
        }
        layers.push(lw)
        li = li + 1
    }

    return M4Model {
        config: cfg,
        layers: layers,
        tok_emb: tok_emb,
        lm_head: lm_head,
        final_norm: final_norm,
        total_bf16_bytes: total_bf16,
        total_f32_bytes: total_f32
    }
}

// ===================================================================
//  CLI entry point
// ===================================================================

fn _m4_cli_flag(av, n, key, default_v) {
    let mut i = 0
    while i < n {
        if av[i] == key {
            if (i + 1) < n { return av[i + 1] }
        }
        i = i + 1
    }
    return default_v
}

fn _m4_cli_has(av, n, key) {
    let mut i = 0
    while i < n {
        if av[i] == key { return true }
        i = i + 1
    }
    return false
}

let av = argv()
let n_av = len(av)

if _m4_cli_has(av, n_av, "--help") {
    println("M4 16GB LLM Inference Engine")
    println("")
    println("Usage:")
    println("  hexa self/ml/m4_inference.hexa --model <hexaw_path> [options]")
    println("  hexa self/ml/m4_inference.hexa --synthetic [options]")
    println("")
    println("Options:")
    println("  --model <path>    Path to .hexaw weight file")
    println("  --synthetic       Use synthetic weights (no model file needed)")
    println("  --tokens <N>      Tokens to generate (default: 32)")
    println("  --metal           Enable Metal GPU for FFN")
    println("  --no-bf16         Disable bf16 NEON kernels (baseline f32 fallback)")
    println("  --config <name>   Model config: 7b, 1b (default: 7b)")
    println("  --help            Show this help")
} else {
    let model_path = _m4_cli_flag(av, n_av, "--model", "")
    let n_tokens = to_int(_m4_cli_flag(av, n_av, "--tokens", "32"))
    let use_metal = _m4_cli_has(av, n_av, "--metal")
    let no_bf16 = _m4_cli_has(av, n_av, "--no-bf16")
    let config_name = _m4_cli_flag(av, n_av, "--config", "7b")
    let synthetic = _m4_cli_has(av, n_av, "--synthetic")

    let cfg = if config_name == "1b" { m4_config_1b() } else { m4_config_7b() }

    // Route bf16 dispatch — probe kernel ABI first so fallback is only
    // used when --no-bf16 or the library is missing.
    if no_bf16 {
        M4_BF16_ENABLED = false
        println("[m4] bf16 NEON kernels DISABLED via --no-bf16 (baseline f32)")
    } else {
        m4_bf16_probe()
    }

    if use_metal {
        let rc = metal_init()
        if rc != 0 {
            println("[m4] FATAL: Metal init failed, rc=" + to_string(rc))
        } else {
            println("[m4] Metal initialized")
        }
    }

    if synthetic {
        println("[m4] Creating synthetic model (config=" + config_name + ")...")
        let model = m4_create_synthetic(cfg)
        m4_bench(model, n_tokens, use_metal)
    } else {
        if model_path == "" {
            println("[m4] ERROR: --model <path> or --synthetic required")
        } else {
            println("[m4] Loading model from " + model_path + "...")
            let hexaw_dict = hexaw_load(model_path)
            let model = m4_load_weights(hexaw_dict, cfg)
            m4_bench(model, n_tokens, use_metal)
        }
    }
}
