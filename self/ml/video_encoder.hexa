// ===================================================================
//  self/ml/video_encoder.hexa — Video Encoder with Spatiotemporal
//  Patch Embedding for Multimodal LLM
//
//  HEXA-LANG ML #147 — Extends ViT to video: splits a video
//  [T, H, W, C] into non-overlapping 3D tubelets of size (t, h, w),
//  linearly projects to d_model, adds temporal + spatial positional
//  embeddings, and runs L layers of either joint spacetime attention
//  or divided space-time attention (TimeSformer-style).
//  Finally projects via a projection head to LLM embedding space.
//
//  Architecture:
//    1. 3D Patch (Tubelet) Embedding:
//       video [T,H,W,C] -> [Nt*Ns, t*h*w*C] -> linear -> [Nt*Ns, d_model]
//    2. CLS Token: prepend learnable [1, d_model]
//    3. Temporal Positional Embedding: sinusoidal for frame dimension
//    4. Spatial Positional Embedding: learnable 2D per frame
//    5. Spacetime Attention: joint attention over all spatiotemporal tokens
//    6. Divided Space-Time Attention (TimeSformer):
//       spatial-only then temporal-only per layer
//    7. Tubelet Embedding: non-overlapping 3D tube extraction
//    8. Video Preprocessing: frame sampling (uniform/random), resize, normalize
//    9. Projection Head: encoder output -> LLM embedding space
//   10. Configurable: num_frames, frame_size, patch_size, d_model, num_layers
//
//  Pure .hexa, self/ only, zero Rust. Deterministic via LCG seed.
//
//  API:
//    vid_make_config(...)             -> VidConfig
//    vid_make_model(cfg, seed)        -> VidModel
//    vid_extract_tubelets(video, cfg) -> [[float]]
//    vid_tubelet_embed(model, tubelets) -> [[float]]
//    vid_sinusoidal_pos(length, d_model) -> [[float]]
//    vid_add_pos_embed(model, embedded) -> [[float]]
//    vid_layer_norm(x, gamma, beta, eps) -> [float]
//    vid_softmax(scores, n)           -> [float]
//    vid_spacetime_attention(model, layer_idx, seq) -> [[float]]
//    vid_spatial_attention(model, layer_idx, seq) -> [[float]]
//    vid_temporal_attention(model, layer_idx, seq) -> [[float]]
//    vid_divided_st_attention(model, layer_idx, seq) -> [[float]]
//    vid_ffn(model, layer_idx, x)     -> [float]
//    vid_encoder_block(model, layer_idx, seq) -> [[float]]
//    vid_encode(model, video)         -> [float]
//    vid_project_to_llm(model, cls_out) -> [float]
//    vid_forward(model, video)        -> [float]
//    vid_sample_frames_uniform(video, total_frames, sample_count, h, w, c) -> [float]
//    vid_sample_frames_random(video, total_frames, sample_count, h, w, c, seed) -> [float]
//    vid_preprocess_frame(frame, target_h, target_w, c, mean, std_dev) -> [float]
//    vid_preprocess_video(video, cfg, mean, std_dev) -> [float]
//    vid_vec_norm(v) -> float
//    vid_cosine_sim(a, b) -> float
//
//  Rules: HX4 SELF-HOST FIRST, HX5 AI-native, P1 no semicolons,
//         P4 native collections.
// ===================================================================

// ── Structs ────────────────────────────────────────────────────

struct VidConfig {
    num_frames: int,
    frame_h: int,
    frame_w: int,
    channels: int,
    tube_t: int,
    tube_h: int,
    tube_w: int,
    d_model: int,
    n_heads: int,
    n_layers: int,
    ffn_dim: int,
    llm_dim: int,
    num_temporal: int,
    num_spatial: int,
    num_tubes: int,
    tube_dim: int,
    seq_len: int,
    head_dim: int,
    attn_mode: string
}

struct VidModel {
    cfg: VidConfig,
    tube_proj_w: array,
    tube_proj_b: array,
    cls_token: array,
    temporal_pos: array,
    spatial_pos: array,
    layers: array,
    proj_w: array,
    proj_b: array,
    ln_final_gamma: array,
    ln_final_beta: array,
    rng: int
}

struct VidLayer {
    ln1_gamma: array,
    ln1_beta: array,
    wq: array,
    wk: array,
    wv: array,
    wo: array,
    ln2_gamma: array,
    ln2_beta: array,
    ffn_w1: array,
    ffn_b1: array,
    ffn_w2: array,
    ffn_b2: array,
    ln_t_gamma: array,
    ln_t_beta: array,
    wq_t: array,
    wk_t: array,
    wv_t: array,
    wo_t: array
}

// ── Deterministic LCG ─────────────────────────────────────────

fn _vid_lcg_next(state) {
    let a = 1103515245
    let c = 12345
    let m = 2147483648
    let mut s = (state * a + c) % m
    if s < 0 { s = s + m }
    s
}

fn _vid_lcg_float(state) {
    let ns = _vid_lcg_next(state)
    let fv = (to_float(ns % 10000) / 10000.0) - 0.5
    let pair = [fv, ns]
    pair
}

// ── Math helpers ──────────────────────────────────────────────

fn _vid_abs(x) {
    if x < 0.0 { return 0.0 - x }
    x
}

fn _vid_sqrt(x) {
    if x <= 0.0 { return 0.0 }
    sqrt(x)
}

fn _vid_gelu(x) {
    let s = 1.0 / (1.0 + exp(0.0 - 1.702 * x))
    x * s
}

fn _vid_floor_int(x) {
    to_int(floor(x))
}

// ── Config builder ────────────────────────────────────────────

fn vid_make_config(num_frames, frame_h, frame_w, channels, tube_t, tube_h, tube_w, d_model, n_heads, n_layers, ffn_mult, llm_dim, attn_mode) {
    let num_temporal = num_frames / tube_t
    let num_spatial_h = frame_h / tube_h
    let num_spatial_w = frame_w / tube_w
    let num_spatial = num_spatial_h * num_spatial_w
    let num_tubes = num_temporal * num_spatial
    let tube_dim = tube_t * tube_h * tube_w * channels
    let seq_len = num_tubes + 1
    let head_dim = d_model / n_heads
    let ffn_dim = d_model * ffn_mult
    VidConfig {
        num_frames: num_frames,
        frame_h: frame_h,
        frame_w: frame_w,
        channels: channels,
        tube_t: tube_t,
        tube_h: tube_h,
        tube_w: tube_w,
        d_model: d_model,
        n_heads: n_heads,
        n_layers: n_layers,
        ffn_dim: ffn_dim,
        llm_dim: llm_dim,
        num_temporal: num_temporal,
        num_spatial: num_spatial,
        num_tubes: num_tubes,
        tube_dim: tube_dim,
        seq_len: seq_len,
        head_dim: head_dim,
        attn_mode: attn_mode
    }
}

// ── Weight matrix builder ─────────────────────────────────────

fn _vid_build_mat(rows, cols, scale, rng) {
    let mut mat = []
    let mut cur = rng
    let mut i = 0
    while i < rows {
        let mut row = []
        let mut j = 0
        while j < cols {
            let pair = _vid_lcg_float(cur)
            row = row + [pair[0] * scale]
            cur = pair[1]
            j = j + 1
        }
        mat = mat + [row]
        i = i + 1
    }
    let out = [mat, cur]
    out
}

fn _vid_build_vec(n, scale, rng) {
    let mut vec = []
    let mut cur = rng
    let mut i = 0
    while i < n {
        let pair = _vid_lcg_float(cur)
        vec = vec + [pair[0] * scale]
        cur = pair[1]
        i = i + 1
    }
    let out = [vec, cur]
    out
}

fn _vid_zeros(n) {
    let mut arr = []
    let mut i = 0
    while i < n {
        arr = arr + [0.0]
        i = i + 1
    }
    arr
}

fn _vid_ones(n) {
    let mut arr = []
    let mut i = 0
    while i < n {
        arr = arr + [1.0]
        i = i + 1
    }
    arr
}

// ── Sinusoidal positional embedding ───────────────────────────
// Generates [length, d_model] sinusoidal position encodings
// Even dims use sin, odd dims use cos

fn vid_sinusoidal_pos(length, d_model) {
    let mut table = []
    let mut pos = 0
    while pos < length {
        let mut row = []
        let mut d = 0
        while d < d_model {
            let half = d / 2
            let denom = pow(10000.0, to_float(half * 2) / to_float(d_model))
            let angle = to_float(pos) / denom
            if d % 2 == 0 {
                row = row + [sin(angle)]
            } else {
                row = row + [cos(angle)]
            }
            d = d + 1
        }
        table = table + [row]
        pos = pos + 1
    }
    table
}

// ── Model builder ─────────────────────────────────────────────

fn vid_make_model(cfg, seed) {
    let mut rng = seed
    let d = cfg.d_model
    let td = cfg.tube_dim
    let nt = cfg.num_temporal
    let ns = cfg.num_spatial
    let sl = cfg.seq_len
    let hd = cfg.head_dim
    let nh = cfg.n_heads
    let fd = cfg.ffn_dim
    let ld = cfg.llm_dim

    // Tubelet projection: tube_dim -> d_model
    let scale_tp = 1.0 / _vid_sqrt(to_float(td))
    let tp_pair = _vid_build_mat(d, td, scale_tp, rng)
    let tube_proj_w = tp_pair[0]
    rng = tp_pair[1]
    let tpb_pair = _vid_build_vec(d, 0.01, rng)
    let tube_proj_b = tpb_pair[0]
    rng = tpb_pair[1]

    // CLS token
    let cls_pair = _vid_build_vec(d, 0.02, rng)
    let cls_token = cls_pair[0]
    rng = cls_pair[1]

    // Temporal positional embedding: sinusoidal [num_temporal, d_model]
    let temporal_pos = vid_sinusoidal_pos(nt, d)

    // Spatial positional embedding: learnable [num_spatial + 1, d_model]
    // +1 for CLS token position
    let sp_pair = _vid_build_mat(ns + 1, d, 0.02, rng)
    let spatial_pos = sp_pair[0]
    rng = sp_pair[1]

    // Build encoder layers
    let scale_attn = 1.0 / _vid_sqrt(to_float(d))
    let scale_ffn = 1.0 / _vid_sqrt(to_float(fd))
    let mut layers = []
    let mut l = 0
    while l < cfg.n_layers {
        let ln1_gamma = _vid_ones(d)
        let ln1_beta = _vid_zeros(d)

        // Spatial attention QKV
        let wq_pair = _vid_build_mat(d, d, scale_attn, rng)
        rng = wq_pair[1]
        let wk_pair = _vid_build_mat(d, d, scale_attn, rng)
        rng = wk_pair[1]
        let wv_pair = _vid_build_mat(d, d, scale_attn, rng)
        rng = wv_pair[1]
        let wo_pair = _vid_build_mat(d, d, scale_attn, rng)
        rng = wo_pair[1]

        let ln2_gamma = _vid_ones(d)
        let ln2_beta = _vid_zeros(d)

        // FFN
        let fw1_pair = _vid_build_mat(fd, d, scale_ffn, rng)
        rng = fw1_pair[1]
        let fb1_pair = _vid_build_vec(fd, 0.01, rng)
        rng = fb1_pair[1]
        let fw2_pair = _vid_build_mat(d, fd, scale_ffn, rng)
        rng = fw2_pair[1]
        let fb2_pair = _vid_build_vec(d, 0.01, rng)
        rng = fb2_pair[1]

        // Temporal attention QKV (for divided space-time)
        let ln_t_gamma = _vid_ones(d)
        let ln_t_beta = _vid_zeros(d)
        let wq_t_pair = _vid_build_mat(d, d, scale_attn, rng)
        rng = wq_t_pair[1]
        let wk_t_pair = _vid_build_mat(d, d, scale_attn, rng)
        rng = wk_t_pair[1]
        let wv_t_pair = _vid_build_mat(d, d, scale_attn, rng)
        rng = wv_t_pair[1]
        let wo_t_pair = _vid_build_mat(d, d, scale_attn, rng)
        rng = wo_t_pair[1]

        let layer = VidLayer {
            ln1_gamma: ln1_gamma,
            ln1_beta: ln1_beta,
            wq: wq_pair[0],
            wk: wk_pair[0],
            wv: wv_pair[0],
            wo: wo_pair[0],
            ln2_gamma: ln2_gamma,
            ln2_beta: ln2_beta,
            ffn_w1: fw1_pair[0],
            ffn_b1: fb1_pair[0],
            ffn_w2: fw2_pair[0],
            ffn_b2: fb2_pair[0],
            ln_t_gamma: ln_t_gamma,
            ln_t_beta: ln_t_beta,
            wq_t: wq_t_pair[0],
            wk_t: wk_t_pair[0],
            wv_t: wv_t_pair[0],
            wo_t: wo_t_pair[0]
        }
        layers = layers + [layer]
        l = l + 1
    }

    // Final layer norm
    let ln_final_gamma = _vid_ones(d)
    let ln_final_beta = _vid_zeros(d)

    // Projection head: d_model -> llm_dim
    let scale_proj = 1.0 / _vid_sqrt(to_float(d))
    let pj_pair = _vid_build_mat(ld, d, scale_proj, rng)
    rng = pj_pair[1]
    let pjb_pair = _vid_build_vec(ld, 0.01, rng)
    rng = pjb_pair[1]

    VidModel {
        cfg: cfg,
        tube_proj_w: tube_proj_w,
        tube_proj_b: tube_proj_b,
        cls_token: cls_token,
        temporal_pos: temporal_pos,
        spatial_pos: spatial_pos,
        layers: layers,
        proj_w: pj_pair[0],
        proj_b: pjb_pair[0],
        ln_final_gamma: ln_final_gamma,
        ln_final_beta: ln_final_beta,
        rng: rng
    }
}

// ===================================================================
//  Tubelet extraction: video [T*H*W*C flat] -> [[tube_dim]] tubelets
//  Video layout: [T, H, W, C] flattened. Tubelets are non-overlapping
//  3D blocks of (tube_t, tube_h, tube_w) extracted in order:
//  temporal first, then spatial raster.
// ===================================================================

fn vid_extract_tubelets(video, cfg) {
    let tt = cfg.tube_t
    let th = cfg.tube_h
    let tw = cfg.tube_w
    let c = cfg.channels
    let h = cfg.frame_h
    let w = cfg.frame_w
    let nt = cfg.num_temporal
    let nsh = h / th
    let nsw = w / tw

    let frame_size = h * w * c
    let mut tubelets = []

    let mut ti = 0
    while ti < nt {
        let mut si_h = 0
        while si_h < nsh {
            let mut si_w = 0
            while si_w < nsw {
                let mut tube = []
                // Extract 3D block
                let mut ft = 0
                while ft < tt {
                    let frame_idx = ti * tt + ft
                    let mut ph = 0
                    while ph < th {
                        let mut pw = 0
                        while pw < tw {
                            let row = si_h * th + ph
                            let col = si_w * tw + pw
                            let base = frame_idx * frame_size + (row * w + col) * c
                            let mut ci = 0
                            while ci < c {
                                tube = tube + [video[base + ci]]
                                ci = ci + 1
                            }
                            pw = pw + 1
                        }
                        ph = ph + 1
                    }
                    ft = ft + 1
                }
                tubelets = tubelets + [tube]
                si_w = si_w + 1
            }
            si_h = si_h + 1
        }
        ti = ti + 1
    }
    tubelets
}

// ===================================================================
//  Tubelet embedding: linear projection tube_dim -> d_model
// ===================================================================

@pure
fn vid_tubelet_embed(model, tubelets) {
    let cfg = model.cfg
    let d = cfg.d_model
    let td = cfg.tube_dim
    let n = len(tubelets)
    let mut embedded = []
    let mut i = 0
    while i < n {
        let tube = tubelets[i]
        let mut vec = []
        let mut j = 0
        while j < d {
            let mut s = model.tube_proj_b[j]
            let mut k = 0
            while k < td {
                s = s + model.tube_proj_w[j][k] * tube[k]
                k = k + 1
            }
            vec = vec + [s]
            j = j + 1
        }
        embedded = embedded + [vec]
        i = i + 1
    }
    embedded
}

// ===================================================================
//  Add positional embeddings: temporal (sinusoidal) + spatial (learnable)
//  For token at (temporal_idx t, spatial_idx s):
//    pos_embed = temporal_pos[t] + spatial_pos[s+1]
//  CLS token gets spatial_pos[0]
// ===================================================================

fn vid_add_pos_embed(model, embedded) {
    let cfg = model.cfg
    let d = cfg.d_model
    let nt = cfg.num_temporal
    let ns = cfg.num_spatial
    let n = len(embedded)
    let mut seq = []

    // CLS token + spatial_pos[0]
    let mut cls = []
    let mut j = 0
    while j < d {
        cls = cls + [model.cls_token[j] + model.spatial_pos[0][j]]
        j = j + 1
    }
    seq = seq + [cls]

    // Patch tokens: for each tubelet (t, s) add temporal_pos[t] + spatial_pos[s+1]
    let mut i = 0
    while i < n {
        let t_idx = i / ns
        let s_idx = i % ns
        let mut tok = []
        let mut j2 = 0
        while j2 < d {
            let t_pe = model.temporal_pos[t_idx][j2]
            let s_pe = model.spatial_pos[s_idx + 1][j2]
            tok = tok + [embedded[i][j2] + t_pe + s_pe]
            j2 = j2 + 1
        }
        seq = seq + [tok]
        i = i + 1
    }
    seq
}

// ===================================================================
//  Layer Normalization
// ===================================================================

@pure
fn vid_layer_norm(x, gamma, beta, eps) {
    let n = len(x)
    let nf = to_float(n)
    let mut sum_x = 0.0
    let mut i = 0
    while i < n {
        sum_x = sum_x + x[i]
        i = i + 1
    }
    let mean = sum_x / nf
    let mut sum_var = 0.0
    i = 0
    while i < n {
        let d = x[i] - mean
        sum_var = sum_var + d * d
        i = i + 1
    }
    let vr = sum_var / nf
    let inv_std = 1.0 / _vid_sqrt(vr + eps)
    let mut out = []
    i = 0
    while i < n {
        out = out + [(x[i] - mean) * inv_std * gamma[i] + beta[i]]
        i = i + 1
    }
    out
}

// ===================================================================
//  Softmax
// ===================================================================

@pure
fn vid_softmax(scores, n) {
    let mut mx = scores[0]
    let mut i = 1
    while i < n {
        if scores[i] > mx { mx = scores[i] }
        i = i + 1
    }
    let mut exps = []
    let mut sum_e = 0.0
    i = 0
    while i < n {
        let e = exp(scores[i] - mx)
        exps = exps + [e]
        sum_e = sum_e + e
        i = i + 1
    }
    let inv = 1.0 / sum_e
    let mut out = []
    i = 0
    while i < n {
        out = out + [exps[i] * inv]
        i = i + 1
    }
    out
}

// ===================================================================
//  _vid_mhsa: Multi-Head Self-Attention over a subsequence
//  Takes normed token list, QKV weight matrices, output projection,
//  and original tokens for residual.
//  Returns updated tokens with residual connection.
// ===================================================================

fn _vid_mhsa(cfg, normed_seq, orig_seq, wq, wk, wv, wo) {
    let d = cfg.d_model
    let nh = cfg.n_heads
    let hd = cfg.head_dim
    let sl = len(normed_seq)
    let scale = 1.0 / _vid_sqrt(to_float(hd))

    // Compute Q, K, V
    let mut Q = []
    let mut K = []
    let mut V = []
    let mut ti = 0
    while ti < sl {
        let x = normed_seq[ti]
        let mut q = []
        let mut k = []
        let mut v = []
        let mut j = 0
        while j < d {
            let mut sq = 0.0
            let mut sk = 0.0
            let mut sv = 0.0
            let mut m = 0
            while m < d {
                sq = sq + wq[j][m] * x[m]
                sk = sk + wk[j][m] * x[m]
                sv = sv + wv[j][m] * x[m]
                m = m + 1
            }
            q = q + [sq]
            k = k + [sk]
            v = v + [sv]
            j = j + 1
        }
        Q = Q + [q]
        K = K + [k]
        V = V + [v]
        ti = ti + 1
    }

    // Multi-head attention
    let mut attn_out = []
    let mut tok = 0
    while tok < sl {
        let mut tok_out = _vid_zeros(d)
        let mut h = 0
        while h < nh {
            let h_off = h * hd
            let mut scores = []
            let mut j = 0
            while j < sl {
                let mut dot = 0.0
                let mut dd = 0
                while dd < hd {
                    dot = dot + Q[tok][h_off + dd] * K[j][h_off + dd]
                    dd = dd + 1
                }
                scores = scores + [dot * scale]
                j = j + 1
            }
            let weights = vid_softmax(scores, sl)
            let mut dd2 = 0
            while dd2 < hd {
                let mut acc = 0.0
                let mut j2 = 0
                while j2 < sl {
                    acc = acc + weights[j2] * V[j2][h_off + dd2]
                    j2 = j2 + 1
                }
                tok_out[h_off + dd2] = tok_out[h_off + dd2] + acc
                dd2 = dd2 + 1
            }
            h = h + 1
        }
        // Output projection
        let mut proj = []
        let mut pi = 0
        while pi < d {
            let mut s = 0.0
            let mut pj = 0
            while pj < d {
                s = s + wo[pi][pj] * tok_out[pj]
                pj = pj + 1
            }
            proj = proj + [s]
            pi = pi + 1
        }
        // Residual
        let mut res = []
        let mut ri = 0
        while ri < d {
            res = res + [orig_seq[tok][ri] + proj[ri]]
            ri = ri + 1
        }
        attn_out = attn_out + [res]
        tok = tok + 1
    }
    attn_out
}

// ===================================================================
//  Joint Spacetime Attention: all tokens attend to all tokens
// ===================================================================

@hot
fn vid_spacetime_attention(model, layer_idx, seq) {
    let cfg = model.cfg
    let d = cfg.d_model
    let sl = len(seq)
    let layer = model.layers[layer_idx]
    let eps = 0.00001

    // LayerNorm each token
    let mut normed = []
    let mut si = 0
    while si < sl {
        normed = normed + [vid_layer_norm(seq[si], layer.ln1_gamma, layer.ln1_beta, eps)]
        si = si + 1
    }

    _vid_mhsa(cfg, normed, seq, layer.wq, layer.wk, layer.wv, layer.wo)
}

// ===================================================================
//  Spatial Attention: for each temporal group, attend only spatially
//  CLS attends to all spatial tokens within each temporal group
// ===================================================================

fn vid_spatial_attention(model, layer_idx, seq) {
    let cfg = model.cfg
    let d = cfg.d_model
    let nt = cfg.num_temporal
    let ns = cfg.num_spatial
    let layer = model.layers[layer_idx]
    let eps = 0.00001
    let sl = len(seq)

    // Norm all tokens first
    let mut normed = []
    let mut si = 0
    while si < sl {
        normed = normed + [vid_layer_norm(seq[si], layer.ln1_gamma, layer.ln1_beta, eps)]
        si = si + 1
    }

    // CLS token (index 0) attends globally -- collect all normed for CLS
    // For simplicity: CLS attends to all tokens
    let mut result = []

    // Process CLS: attends to itself + all patch tokens
    let mut cls_normed = [normed[0]]
    let mut cls_orig = [seq[0]]
    let mut ci = 1
    while ci < sl {
        cls_normed = cls_normed + [normed[ci]]
        cls_orig = cls_orig + [seq[ci]]
        ci = ci + 1
    }
    let cls_result = _vid_mhsa(cfg, cls_normed, cls_orig, layer.wq, layer.wk, layer.wv, layer.wo)
    result = result + [cls_result[0]]

    // Process each temporal group spatially
    let mut t = 0
    while t < nt {
        let start = 1 + t * ns
        let mut group_normed = []
        let mut group_orig = []
        let mut s = 0
        while s < ns {
            group_normed = group_normed + [normed[start + s]]
            group_orig = group_orig + [seq[start + s]]
            s = s + 1
        }
        let group_result = _vid_mhsa(cfg, group_normed, group_orig, layer.wq, layer.wk, layer.wv, layer.wo)
        let mut s2 = 0
        while s2 < ns {
            result = result + [group_result[s2]]
            s2 = s2 + 1
        }
        t = t + 1
    }
    result
}

// ===================================================================
//  Temporal Attention: for each spatial position, attend over time
// ===================================================================

fn vid_temporal_attention(model, layer_idx, seq) {
    let cfg = model.cfg
    let d = cfg.d_model
    let nt = cfg.num_temporal
    let ns = cfg.num_spatial
    let layer = model.layers[layer_idx]
    let eps = 0.00001
    let sl = len(seq)

    // Norm all tokens
    let mut normed = []
    let mut si = 0
    while si < sl {
        normed = normed + [vid_layer_norm(seq[si], layer.ln_t_gamma, layer.ln_t_beta, eps)]
        si = si + 1
    }

    // CLS stays as-is (residual only)
    let mut result = [seq[0]]

    // For each spatial position, gather tokens across time
    let mut s = 0
    while s < ns {
        let mut group_normed = []
        let mut group_orig = []
        let mut t = 0
        while t < nt {
            let idx = 1 + t * ns + s
            group_normed = group_normed + [normed[idx]]
            group_orig = group_orig + [seq[idx]]
            t = t + 1
        }
        let group_result = _vid_mhsa(cfg, group_normed, group_orig, layer.wq_t, layer.wk_t, layer.wv_t, layer.wo_t)

        // Place results back in order -- store temporarily
        let mut t2 = 0
        while t2 < nt {
            // We'll collect all spatial results then reorder
            group_result[t2]
            t2 = t2 + 1
        }
        s = s + 1
    }

    // Re-gather: need to re-collect from temporal groups
    // Build a flat output where index (1 + t*ns + s) gets its temporal result
    // Since we can't do complex index assignment, build an intermediate map
    let mut flat_out = []
    let mut idx = 0
    while idx < sl {
        flat_out = flat_out + [seq[idx]]
        idx = idx + 1
    }

    // Process each spatial position and store results
    let mut s2 = 0
    while s2 < ns {
        let mut grp_n = []
        let mut grp_o = []
        let mut t3 = 0
        while t3 < nt {
            let i3 = 1 + t3 * ns + s2
            grp_n = grp_n + [normed[i3]]
            grp_o = grp_o + [seq[i3]]
            t3 = t3 + 1
        }
        let grp_res = _vid_mhsa(cfg, grp_n, grp_o, layer.wq_t, layer.wk_t, layer.wv_t, layer.wo_t)
        let mut t4 = 0
        while t4 < nt {
            let out_idx = 1 + t4 * ns + s2
            flat_out[out_idx] = grp_res[t4]
            t4 = t4 + 1
        }
        s2 = s2 + 1
    }

    flat_out
}

// ===================================================================
//  Divided Space-Time Attention (TimeSformer-style):
//  First spatial attention, then temporal attention per layer
// ===================================================================

fn vid_divided_st_attention(model, layer_idx, seq) {
    // Step 1: Spatial attention
    let after_spatial = vid_spatial_attention(model, layer_idx, seq)
    // Step 2: Temporal attention
    let after_temporal = vid_temporal_attention(model, layer_idx, after_spatial)
    after_temporal
}

// ===================================================================
//  FFN: GELU(x @ W1 + b1) @ W2 + b2
// ===================================================================

@pure
fn vid_ffn(model, layer_idx, x) {
    let cfg = model.cfg
    let d = cfg.d_model
    let fd = cfg.ffn_dim
    let layer = model.layers[layer_idx]
    let mut hidden = []
    let mut i = 0
    while i < fd {
        let mut s = layer.ffn_b1[i]
        let mut j = 0
        while j < d {
            s = s + layer.ffn_w1[i][j] * x[j]
            j = j + 1
        }
        hidden = hidden + [_vid_gelu(s)]
        i = i + 1
    }
    let mut out = []
    i = 0
    while i < d {
        let mut s = layer.ffn_b2[i]
        let mut j = 0
        while j < fd {
            s = s + layer.ffn_w2[i][j] * hidden[j]
            j = j + 1
        }
        out = out + [s]
        i = i + 1
    }
    out
}

// ===================================================================
//  Single encoder block: attention + FFN with residual
//  Uses cfg.attn_mode to select attention type:
//    "joint"   -> full spacetime attention
//    "divided" -> divided space-time attention (TimeSformer)
// ===================================================================

fn vid_encoder_block(model, layer_idx, seq) {
    let cfg = model.cfg
    let d = cfg.d_model
    let sl = len(seq)
    let layer = model.layers[layer_idx]
    let eps = 0.00001

    // Attention sub-block (pre-norm + residual done inside)
    let mut after_attn = []
    if cfg.attn_mode == "divided" {
        after_attn = vid_divided_st_attention(model, layer_idx, seq)
    } else {
        after_attn = vid_spacetime_attention(model, layer_idx, seq)
    }

    // FFN sub-block with pre-norm and residual
    let mut after_ffn = []
    let mut i = 0
    while i < sl {
        let normed = vid_layer_norm(after_attn[i], layer.ln2_gamma, layer.ln2_beta, eps)
        let ffn_out = vid_ffn(model, layer_idx, normed)
        let mut res = []
        let mut j = 0
        while j < d {
            res = res + [after_attn[i][j] + ffn_out[j]]
            j = j + 1
        }
        after_ffn = after_ffn + [res]
        i = i + 1
    }
    after_ffn
}

// ===================================================================
//  Full video encode: tubelets -> CLS output [d_model]
// ===================================================================

fn vid_encode(model, video) {
    let cfg = model.cfg
    let eps = 0.00001

    // 1. Extract tubelets
    let tubelets = vid_extract_tubelets(video, cfg)

    // 2. Tubelet embedding
    let embedded = vid_tubelet_embed(model, tubelets)

    // 3. Prepend CLS + positional embeddings
    let mut seq = vid_add_pos_embed(model, embedded)

    // 4. L encoder blocks
    let mut l = 0
    while l < cfg.n_layers {
        seq = vid_encoder_block(model, l, seq)
        l = l + 1
    }

    // 5. Final LayerNorm on CLS token (index 0)
    let cls_out = vid_layer_norm(seq[0], model.ln_final_gamma, model.ln_final_beta, eps)
    cls_out
}

// ===================================================================
//  Projection head: CLS [d_model] -> [llm_dim]
// ===================================================================

@pure
fn vid_project_to_llm(model, cls_out) {
    let cfg = model.cfg
    let d = cfg.d_model
    let ld = cfg.llm_dim
    let mut out = []
    let mut i = 0
    while i < ld {
        let mut s = model.proj_b[i]
        let mut j = 0
        while j < d {
            s = s + model.proj_w[i][j] * cls_out[j]
            j = j + 1
        }
        out = out + [s]
        i = i + 1
    }
    out
}

// ===================================================================
//  Full forward: video -> LLM embedding
// ===================================================================

fn vid_forward(model, video) {
    let cls_out = vid_encode(model, video)
    let llm_embed = vid_project_to_llm(model, cls_out)
    llm_embed
}

// ===================================================================
//  Frame Sampling: uniform
//  Selects sample_count frames uniformly from total_frames.
//  Returns flat array of sampled frames [sample_count * h * w * c].
// ===================================================================

fn vid_sample_frames_uniform(video, total_frames, sample_count, h, w, c) {
    let frame_size = h * w * c
    let mut sampled = []
    let mut i = 0
    while i < sample_count {
        let frame_idx = (i * total_frames) / sample_count
        let start = frame_idx * frame_size
        let mut j = 0
        while j < frame_size {
            sampled = sampled + [video[start + j]]
            j = j + 1
        }
        i = i + 1
    }
    sampled
}

// ===================================================================
//  Frame Sampling: pseudo-random (deterministic via LCG)
// ===================================================================

fn vid_sample_frames_random(video, total_frames, sample_count, h, w, c, seed) {
    let frame_size = h * w * c
    let mut rng = seed
    // Generate sample_count unique frame indices (with replacement for simplicity)
    let mut indices = []
    let mut i = 0
    while i < sample_count {
        rng = _vid_lcg_next(rng)
        let mut idx = rng % total_frames
        if idx < 0 { idx = idx + total_frames }
        indices = indices + [idx]
        i = i + 1
    }
    // Sort indices for sequential access
    // Simple insertion sort (small sample_count)
    let mut si = 1
    while si < sample_count {
        let key = indices[si]
        let mut sj = si - 1
        let mut done = false
        while sj >= 0 && done == false {
            if indices[sj] > key {
                indices[sj + 1] = indices[sj]
                sj = sj - 1
            } else {
                done = true
            }
        }
        indices[sj + 1] = key
        si = si + 1
    }

    let mut sampled = []
    let mut k = 0
    while k < sample_count {
        let frame_idx = indices[k]
        let start = frame_idx * frame_size
        let mut j = 0
        while j < frame_size {
            sampled = sampled + [video[start + j]]
            j = j + 1
        }
        k = k + 1
    }
    sampled
}

// ===================================================================
//  Preprocess a single frame: normalize per-channel, resize if needed
// ===================================================================

fn vid_preprocess_frame(frame, target_h, target_w, channels, mean, std_dev) {
    let raw_len = len(frame)
    let target_len = target_h * target_w * channels
    let raw_pixels = raw_len / channels
    let mut src_h = target_h
    let mut src_w = target_w
    if raw_len != target_len {
        let side = to_int(_vid_sqrt(to_float(raw_pixels)))
        src_h = side
        src_w = side
    }

    let mut out = []
    let mut y = 0
    while y < target_h {
        let src_y = (y * src_h) / target_h
        let mut x = 0
        while x < target_w {
            let src_x = (x * src_w) / target_w
            let src_idx = (src_y * src_w + src_x) * channels
            let mut c = 0
            while c < channels {
                let pixel = frame[src_idx + c]
                let normalized = (pixel - mean[c]) / std_dev[c]
                out = out + [normalized]
                c = c + 1
            }
            x = x + 1
        }
        y = y + 1
    }
    out
}

// ===================================================================
//  Preprocess full video: normalize each frame
//  video: flat [T*H*W*C] float array
//  Returns: flat [T*target_h*target_w*C] normalized float array
// ===================================================================

fn vid_preprocess_video(video, cfg, mean, std_dev) {
    let t = cfg.num_frames
    let h = cfg.frame_h
    let w = cfg.frame_w
    let c = cfg.channels
    let frame_size = h * w * c
    let mut out = []
    let mut fi = 0
    while fi < t {
        let start = fi * frame_size
        let mut frame = []
        let mut j = 0
        while j < frame_size {
            frame = frame + [video[start + j]]
            j = j + 1
        }
        let processed = vid_preprocess_frame(frame, h, w, c, mean, std_dev)
        let mut k = 0
        while k < len(processed) {
            out = out + [processed[k]]
            k = k + 1
        }
        fi = fi + 1
    }
    out
}

// ===================================================================
//  Utility: L2 norm
// ===================================================================

fn vid_vec_norm(v) {
    let mut s = 0.0
    let mut i = 0
    while i < len(v) {
        s = s + v[i] * v[i]
        i = i + 1
    }
    _vid_sqrt(s)
}

// ===================================================================
//  Utility: cosine similarity
// ===================================================================

fn vid_cosine_sim(a, b) {
    let na = vid_vec_norm(a)
    let nb = vid_vec_norm(b)
    if na < 0.0000001 { return 0.0 }
    if nb < 0.0000001 { return 0.0 }
    let mut dot = 0.0
    let mut i = 0
    while i < len(a) {
        dot = dot + a[i] * b[i]
        i = i + 1
    }
    dot / (na * nb)
}
