// t1_v15_kvcache_512 — 512 context decode.
let D = 4096
let R = 4
let FF = 16384
let N_LAYER = 32
let SEQ_LEN = 512

println("[t1_v15_kv512] 7B r=" + str(R) + " L=" + str(N_LAYER) + " SEQ_LEN=" + str(SEQ_LEN))

let mut k = 0
let mut sum_ms = 0.0
let mut best_ms = 1.0e9
let runs = 5
while k < runs {
    let ms_per_tok = kv_cache_decode_bench(D, R, FF, N_LAYER, SEQ_LEN)
    sum_ms = sum_ms + ms_per_tok
    if ms_per_tok < best_ms { best_ms = ms_per_tok }
    k = k + 1
}
let avg_ms = sum_ms / (runs * 1.0)

let mut line = "{\"phase\":\"t1_v15_kv512\",\"runs\":" + str(runs)
line = line + ",\"seq_len\":" + str(SEQ_LEN)
line = line + ",\"ms_per_tok_avg\":" + str(avg_ms)
line = line + ",\"ms_per_tok_best\":" + str(best_ms)
line = line + ",\"tok_s_avg\":" + str(1000.0 / avg_ms)
line = line + ",\"tok_s_best\":" + str(1000.0 / best_ms) + "}"
println(line)
