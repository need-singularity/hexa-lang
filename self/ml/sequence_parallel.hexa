// ===================================================================
//  sequence_parallel.hexa — Megatron-LM Sequence Parallelism (pure hexa)
//
//  Sequence Parallelism extends Tensor Parallelism by splitting the
//  LayerNorm / Dropout / residual regions along the SEQUENCE dimension,
//  so each TP rank only stores/holds a slice of the sequence in those
//  "non-TP" regions. This dramatically cuts activation memory at the
//  same communication cost as pure TP (all-gather + reduce-scatter
//  replace the single all-reduce).
//
//  Pipeline per transformer block (Megatron-SP):
//     X_sp (seq/P, hidden)
//       -> LayerNorm over hidden dim (local, no comm)
//       -> all-gather(seq) -> X_full (seq, hidden)    [enter TP region]
//       -> TP attention / MLP (column+row parallel)
//       -> reduce-scatter(seq) -> Y_sp (seq/P, hidden) [exit TP region]
//       -> residual add + Dropout (local per-rank on seq slice)
//
//  Memory saving: the LN input / output, residual stream, and Dropout
//  mask are sharded across P ranks => ~1/P activation memory in the
//  "non-attention, non-MLP" portion of each block.
//
//  This file is a pure-hexa CPU simulator: it emulates P ranks in-process
//  using plain arrays, so tests can run on any host. It mirrors the
//  numerics a real GPU NCCL implementation would produce.
//
//  Public API:
//    sp_context_init(world_size, seq_len, hidden)
//    sp_split_sequence(X, ctx)             -> [X_r0, X_r1, ...]
//    sp_concat_sequence(shards)            -> X_full
//    sp_all_gather_seq(shards)             -> X_full (comm stub)
//    sp_reduce_scatter_seq(full_by_rank)   -> [shard_r0, ...]
//    sp_layernorm_shard(shard, gamma, beta, eps)   -> LN(shard)
//    sp_dropout_shard(shard, rank, seed, keep_prob)-> masked shard
//    sp_attention_tp(X_full, heads, W_q, W_k, W_v, W_o, tp_world)
//    sp_mlp_tp(X_full, W1, W2, tp_world)
//    sp_block_forward(X_sharded, block, ctx)        -> Y_sharded
//    sp_activation_bytes(seq, hidden, P)            -> int
//    sp_memory_saved_ratio(P)                       -> float
//
//  Pure .hexa — no external FFI, no Rust.
// ===================================================================

// ── Data-parallel-free pseudo-context ───────────────────────────

struct SPContext {
    world_size: int,
    seq_len: int,
    hidden: int,
    seq_per_rank: int
}

struct SPBlockWeights {
    gamma1: array,
    beta1: array,
    gamma2: array,
    beta2: array,
    w_q: array,
    w_k: array,
    w_v: array,
    w_o: array,
    w_mlp1: array,
    w_mlp2: array,
    eps: float,
    keep_prob: float,
    seed: int
}

// ── Context ─────────────────────────────────────────────────────

fn sp_context_init(world_size, seq_len, hidden) {
    // Require clean divisibility; in real Megatron, seq_len is padded.
    let per = seq_len / world_size
    return SPContext {
        world_size: world_size,
        seq_len: seq_len,
        hidden: hidden,
        seq_per_rank: per
    }
}

// ── Tensor helpers (sequence is outer dim; layout: [seq * hidden]) ──

fn sp_zeros(n) {
    let mut a = []
    let mut i = 0
    while i < n {
        a = a + [0.0]
        i = i + 1
    }
    return a
}

fn sp_flat_index(s, h, hidden) {
    return s * hidden + h
}

// ── Sequence splitting / gathering ───────────────────────────────

fn sp_split_sequence(X, ctx) {
    let mut shards = []
    let per = ctx.seq_per_rank
    let hidden = ctx.hidden
    let chunk = per * hidden
    let mut r = 0
    while r < ctx.world_size {
        let mut shard = []
        let base = r * chunk
        let mut i = 0
        while i < chunk {
            shard = shard + [X[base + i]]
            i = i + 1
        }
        shards = shards + [shard]
        r = r + 1
    }
    return shards
}

fn sp_concat_sequence(shards) {
    let mut out = []
    let n = len(shards)
    let mut r = 0
    while r < n {
        let s = shards[r]
        let sl = len(s)
        let mut i = 0
        while i < sl {
            out = out + [s[i]]
            i = i + 1
        }
        r = r + 1
    }
    return out
}

// ── Collective stubs (CPU simulator for NCCL-equivalent ops) ─────
//
// In a real multi-GPU run these map to:
//   sp_all_gather_seq     <-> ncclAllGather along seq dim
//   sp_reduce_scatter_seq <-> ncclReduceScatter along seq dim

fn sp_all_gather_seq(shards) {
    return sp_concat_sequence(shards)
}

// Each rank contributes a FULL tensor (seq, hidden) after TP inner op;
// we need the elementwise SUM across ranks, then scatter along seq.
fn sp_reduce_scatter_seq(full_by_rank, ctx) {
    let P = ctx.world_size
    let hidden = ctx.hidden
    let seq = ctx.seq_len
    let total = seq * hidden

    // 1) element-wise sum across ranks
    let mut summed = sp_zeros(total)
    let mut r = 0
    while r < P {
        let full = full_by_rank[r]
        let mut i = 0
        while i < total {
            summed[i] = summed[i] + full[i]
            i = i + 1
        }
        r = r + 1
    }

    // 2) scatter back along sequence dimension
    return sp_split_sequence(summed, ctx)
}

// ── LayerNorm over hidden dim (sharded = LOCAL, no comm) ─────────
//
// LN normalizes over the hidden dim for each token; since each rank
// holds whole tokens (its sequence slice), there is NO cross-rank comm.

fn sp_layernorm_row(row, gamma, beta, eps, hidden) {
    let mut mean = 0.0
    let mut i = 0
    while i < hidden {
        mean = mean + row[i]
        i = i + 1
    }
    mean = mean / to_float(hidden)

    let mut var = 0.0
    i = 0
    while i < hidden {
        let d = row[i] - mean
        var = var + d * d
        i = i + 1
    }
    var = var / to_float(hidden)
    let inv = 1.0 / sqrt(var + eps)

    let mut out = []
    i = 0
    while i < hidden {
        let norm = (row[i] - mean) * inv
        out = out + [norm * gamma[i] + beta[i]]
        i = i + 1
    }
    return out
}

fn sp_layernorm_shard(shard, gamma, beta, eps, hidden) {
    let total = len(shard)
    let num_rows = total / hidden
    let mut out = sp_zeros(total)
    let mut s = 0
    while s < num_rows {
        // extract row
        let mut row = []
        let mut h = 0
        while h < hidden {
            row = row + [shard[s * hidden + h]]
            h = h + 1
        }
        let rn = sp_layernorm_row(row, gamma, beta, eps, hidden)
        h = 0
        while h < hidden {
            out[s * hidden + h] = rn[h]
            h = h + 1
        }
        s = s + 1
    }
    return out
}

// ── Deterministic Dropout (shard-local, seed+rank decorrelated) ──
//
// A pure hexa LCG keeps the test reproducible across platforms.

fn sp_lcg_next(state) {
    // Numerical Recipes constants
    let a = 1664525
    let c = 1013904223
    let m = 2147483647
    return (state * a + c) % m
}

fn sp_dropout_mask(n, seed, rank, keep_prob) {
    // Per-rank seed: combine base seed with rank so different ranks
    // get statistically independent masks (matches Megatron's SP dropout).
    let mut state = (seed * 131 + rank * 977 + 1) % 2147483647
    let thresh_int = to_int(keep_prob * 1000000.0)
    let mut mask = []
    let mut i = 0
    while i < n {
        state = sp_lcg_next(state)
        let r01 = state % 1000000
        if r01 < thresh_int {
            mask = mask + [1.0]
        } else {
            mask = mask + [0.0]
        }
        i = i + 1
    }
    return mask
}

fn sp_dropout_shard(shard, rank, seed, keep_prob) {
    let n = len(shard)
    // At keep_prob == 1.0 dropout is identity (useful for eval/tests)
    if keep_prob >= 0.999999 {
        return shard
    }
    let mask = sp_dropout_mask(n, seed, rank, keep_prob)
    let scale = 1.0 / keep_prob
    let mut out = []
    let mut i = 0
    while i < n {
        out = out + [shard[i] * mask[i] * scale]
        i = i + 1
    }
    return out
}

// ── Tiny attention / MLP stubs for block test ────────────────────
//
// These are intentionally simple (linear-in hidden dim only) so they
// can be used as a smoke test for the full SP pipeline. A "real" SP
// block would plug into flash_attention / transformer.hexa.

fn sp_matmul_rowmajor(X, W, rows, inner, out_cols) {
    // X: [rows * inner], W: [inner * out_cols] (row major)
    let mut out = sp_zeros(rows * out_cols)
    let mut r = 0
    while r < rows {
        let mut c = 0
        while c < out_cols {
            let mut acc = 0.0
            let mut k = 0
            while k < inner {
                acc = acc + X[r * inner + k] * W[k * out_cols + c]
                k = k + 1
            }
            out[r * out_cols + c] = acc
            c = c + 1
        }
        r = r + 1
    }
    return out
}

fn sp_add(a, b) {
    let n = len(a)
    let mut out = []
    let mut i = 0
    while i < n {
        out = out + [a[i] + b[i]]
        i = i + 1
    }
    return out
}

// Toy "attention": linear(W_q) projection. Good enough to prove
// that the SP pipeline assembles correctly and matches single-rank.
fn sp_attention_tp(X_full, W_q, seq_len, hidden) {
    return sp_matmul_rowmajor(X_full, W_q, seq_len, hidden, hidden)
}

// Toy "MLP": linear(W1) -> linear(W2)
fn sp_mlp_tp(X_full, W1, W2, seq_len, hidden, inter) {
    let h1 = sp_matmul_rowmajor(X_full, W1, seq_len, hidden, inter)
    // activation omitted — linearity keeps numerical equivalence test tight
    return sp_matmul_rowmajor(h1, W2, seq_len, inter, hidden)
}

// ── Full SP transformer block ────────────────────────────────────
//
//   in:  shards[rank] = (seq/P, hidden)
//   out: shards[rank] = (seq/P, hidden)

fn sp_block_forward(X_sharded, block, ctx) {
    let P = ctx.world_size
    let hidden = ctx.hidden
    let seq = ctx.seq_len

    // ---- LayerNorm 1 (local, per-shard) ----
    let mut ln1_shards = []
    let mut r = 0
    while r < P {
        let ln = sp_layernorm_shard(X_sharded[r], block.gamma1, block.beta1, block.eps, hidden)
        ln1_shards = ln1_shards + [ln]
        r = r + 1
    }

    // ---- All-gather -> full (seq, hidden) for TP attention ----
    let X_full = sp_all_gather_seq(ln1_shards)

    // ---- TP attention (toy linear) ----
    // In real TP, each rank has 1/P of the attention heads and produces
    // a partial (seq, hidden) that reduces with the other ranks. For the
    // simulator we compute the same full output on every rank so that
    // reduce-scatter can average (divide by P) to recover the single-GPU
    // answer.
    let attn = sp_attention_tp(X_full, block.w_q, seq, hidden)
    let mut attn_by_rank = []
    r = 0
    while r < P {
        attn_by_rank = attn_by_rank + [attn]
        r = r + 1
    }

    // ---- Reduce-scatter -> back to (seq/P, hidden) ----
    // SUM across ranks then split along seq; divide by P so simulator
    // matches single-GPU output.
    let attn_sum_shards = sp_reduce_scatter_seq(attn_by_rank, ctx)
    let mut attn_shards = []
    let Pf = to_float(P)
    r = 0
    while r < P {
        let s = attn_sum_shards[r]
        let sl = len(s)
        let mut scaled = []
        let mut i = 0
        while i < sl {
            scaled = scaled + [s[i] / Pf]
            i = i + 1
        }
        attn_shards = attn_shards + [scaled]
        r = r + 1
    }

    // ---- Residual add + Dropout (local) ----
    let mut post_attn = []
    r = 0
    while r < P {
        let sum_sh = sp_add(X_sharded[r], attn_shards[r])
        let drop_sh = sp_dropout_shard(sum_sh, r, block.seed, block.keep_prob)
        post_attn = post_attn + [drop_sh]
        r = r + 1
    }

    // ---- LayerNorm 2 (local) ----
    let mut ln2_shards = []
    r = 0
    while r < P {
        let ln = sp_layernorm_shard(post_attn[r], block.gamma2, block.beta2, block.eps, hidden)
        ln2_shards = ln2_shards + [ln]
        r = r + 1
    }

    // ---- All-gather -> TP MLP ----
    let X_full2 = sp_all_gather_seq(ln2_shards)
    let inter = hidden
    let mlp = sp_mlp_tp(X_full2, block.w_mlp1, block.w_mlp2, seq, hidden, inter)
    let mut mlp_by_rank = []
    r = 0
    while r < P {
        mlp_by_rank = mlp_by_rank + [mlp]
        r = r + 1
    }

    let mlp_sum_shards = sp_reduce_scatter_seq(mlp_by_rank, ctx)
    let mut mlp_shards = []
    r = 0
    while r < P {
        let s = mlp_sum_shards[r]
        let sl = len(s)
        let mut scaled = []
        let mut i = 0
        while i < sl {
            scaled = scaled + [s[i] / Pf]
            i = i + 1
        }
        mlp_shards = mlp_shards + [scaled]
        r = r + 1
    }

    // ---- Residual add + Dropout (local) ----
    let mut out_shards = []
    r = 0
    while r < P {
        let sum_sh = sp_add(post_attn[r], mlp_shards[r])
        let drop_sh = sp_dropout_shard(sum_sh, r, block.seed + 1, block.keep_prob)
        out_shards = out_shards + [drop_sh]
        r = r + 1
    }

    return out_shards
}

// ── Single-rank baseline (for equivalence tests) ─────────────────

fn sp_block_forward_single(X_full, block, seq_len, hidden) {
    // LN1
    let ln1 = sp_layernorm_shard(X_full, block.gamma1, block.beta1, block.eps, hidden)
    // Attention (same toy op as TP path)
    let attn = sp_attention_tp(ln1, block.w_q, seq_len, hidden)
    // Residual
    let post_attn = sp_add(X_full, attn)
    // LN2
    let ln2 = sp_layernorm_shard(post_attn, block.gamma2, block.beta2, block.eps, hidden)
    // MLP
    let mlp = sp_mlp_tp(ln2, block.w_mlp1, block.w_mlp2, seq_len, hidden, hidden)
    // Residual
    return sp_add(post_attn, mlp)
}

// ── Activation memory accounting ─────────────────────────────────
//
// Without SP: each rank stores the FULL activation stream across all
//   "LN/residual/dropout" regions -> 2 * seq * hidden * bytes_per_elem.
// With SP: each rank stores only seq/P of those regions.
// ratio = 1 - (1/P)

fn sp_activation_bytes(seq, hidden, P) {
    // 2 regions (pre-attn LN input + pre-mlp LN input), f32 = 4 bytes
    let regions = 2
    let per_rank = (seq / P) * hidden * regions * 4
    return per_rank
}

fn sp_activation_bytes_no_sp(seq, hidden) {
    let regions = 2
    return seq * hidden * regions * 4
}

fn sp_memory_saved_ratio(P) {
    if P <= 1 { return 0.0 }
    let pf = to_float(P)
    return 1.0 - 1.0 / pf
}

println("[sequence_parallel] loaded — Megatron-SP LN/Dropout shard + all-gather / reduce-scatter + TP block")
