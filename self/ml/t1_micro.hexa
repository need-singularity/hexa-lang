// ═══════════════════════════════════════════════════════════════
//  self/ml/t1_micro.hexa — T1 micro-benchmark: raw matmul GFLOPs/s
//
//  Why: full 7B forward는 hexa 인터프리터에서 분 단위 소요 → 불가.
//  대신 matmul(M,K,N) 자체가 forward의 ~95% 비중이므로 이것만 측정.
//
//  matmul은 src/interpreter.rs:4351에서 cblas_dgemm → BLAS 네이티브.
//  따라서 이 수치가 hexa 인터프리터 오버헤드와 무관한 **물리한계 근접치**.
//
//  Ryzen 9 7950X3D 이론 피크: ~2.5 TFLOPS FP64 (AVX-512).
//  BLAS 실효: ~60-80% = 1.5-2.0 TFLOPS.
//
//  Output: JSON one-liner { "op": "matmul", "M":..., "gflops":..., "ms":... }
// ═══════════════════════════════════════════════════════════════

let mut RNG = 2463534242

fn mr() {
    RNG = (RNG * 1664525 + 1013904223)
    let m = RNG % 10000
    return to_float(str(m)) / 10000.0 - 0.5
}

fn rand_flat(n) {
    let mut v = []
    let mut i = 0
    while i < n {
        v = v.push(mr())
        i = i + 1
    }
    return v
}

fn bench_one(M, K, N, iters) {
    let A = rand_flat(M * K)
    let B = rand_flat(K * N)
    // warmup
    let _ = matmul(A, B, M, K, N)

    let s0 = clock()
    let mut it = 0
    while it < iters {
        let _ = matmul(A, B, M, K, N)
        it = it + 1
    }
    let s1 = clock()

    let elapsed = s1 - s0
    // 2*M*K*N FLOPs per matmul
    let flops_per_call = 2.0 * to_float(str(M)) * to_float(str(K)) * to_float(str(N))
    let total_flops = flops_per_call * to_float(str(iters))
    let gflops = (total_flops / elapsed) / 1000000000.0
    let ms_each = (elapsed / to_float(str(iters))) * 1000.0

    let mut line = "{"
    line = line + "\"op\":\"matmul\""
    line = line + ",\"M\":" + str(M)
    line = line + ",\"K\":" + str(K)
    line = line + ",\"N\":" + str(N)
    line = line + ",\"iters\":" + str(iters)
    line = line + ",\"gflops\":" + str(gflops)
    line = line + ",\"ms_each\":" + str(ms_each)
    line = line + ",\"elapsed_s\":" + str(elapsed)
    line = line + "}"
    println(line)
    return gflops
}

println("[t1_micro] raw matmul physical limit probe")

// 작은 것부터 시작 → 큰 것까지
let _g1 = bench_one(256, 256, 256, 20)
let _g2 = bench_one(512, 512, 512, 10)
let _g3 = bench_one(1024, 1024, 1024, 5)
let _g4 = bench_one(2048, 2048, 2048, 3)

println("[t1_micro] done")
