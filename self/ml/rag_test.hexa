// ===================================================================
//  self/ml/rag_test.hexa — End-to-end RAG test with synthetic documents
//
//  Tests:
//    1. Embedding engine (embed, cosine_similarity, normalize)
//    2. Vector store (add, search, IVF index)
//    3. RAG pipeline (index_documents, retrieve, rag_generate)
//
//  All using a synthetic embedding model (no GGUF required).
// ===================================================================

use "embedding"
use "vector_store"
use "rag"

let mut PASS = 0
let mut FAIL = 0

fn check(name, cond) {
    if cond {
        println("  PASS: " + name)
        PASS = PASS + 1
    } else {
        println("  FAIL: " + name)
        FAIL = FAIL + 1
    }
}

fn approx_eq(a, b, tol) {
    let diff = a - b
    if diff < 0.0 { return (0.0 - diff) < tol }
    return diff < tol
}

// ===================================================================
//  Test 1: Vector math utilities
// ===================================================================
println("=== Test 1: Vector math ===")

let v1 = [1.0, 0.0, 0.0]
let v2 = [0.0, 1.0, 0.0]
let v3 = [1.0, 1.0, 0.0]

// Dot product
let d12 = dot_product(v1, v2)
check("dot orthogonal = 0", approx_eq(d12, 0.0, 0.001))

let d11 = dot_product(v1, v1)
check("dot self = 1", approx_eq(d11, 1.0, 0.001))

let d13 = dot_product(v1, v3)
check("dot [1,0,0].[1,1,0] = 1", approx_eq(d13, 1.0, 0.001))

// Cosine similarity
let c12 = cosine_similarity(v1, v2)
check("cosine orthogonal = 0", approx_eq(c12, 0.0, 0.001))

let c11 = cosine_similarity(v1, v1)
check("cosine self = 1", approx_eq(c11, 1.0, 0.001))

let c13 = cosine_similarity(v1, v3)
let expected_c13 = 1.0 / sqrt(2.0)
check("cosine [1,0,0].[1,1,0] = 1/sqrt(2)", approx_eq(c13, expected_c13, 0.001))

// Normalize
let n3 = normalize(v3)
let n3_norm = vec_norm(n3)
check("normalize yields unit vector", approx_eq(n3_norm, 1.0, 0.001))

// Euclidean distance
let ed12 = euclidean_distance(v1, v2)
let expected_ed = sqrt(2.0)
check("euclidean [1,0,0]-[0,1,0] = sqrt(2)", approx_eq(ed12, expected_ed, 0.001))

let ed11 = euclidean_distance(v1, v1)
check("euclidean self = 0", approx_eq(ed11, 0.0, 0.001))

// Vec arithmetic
let va = vec_add([1.0, 2.0], [3.0, 4.0])
check("vec_add", approx_eq(va[0], 4.0, 0.001))

let vs = vec_scale([2.0, 3.0], 0.5)
check("vec_scale", approx_eq(vs[0], 1.0, 0.001))

println("")

// ===================================================================
//  Test 2: Synthetic embedding model
// ===================================================================
println("=== Test 2: Embedding model ===")

let model = create_synthetic_model(256, 16)
check("model dim = 16", model.dim == 16)
check("model vocab = 256", model.vocab_size == 256)
check("embeddings count = 256", len(model.embeddings) == 256)

// Embed a single text
let e1 = embed(model, "hello")
check("embed returns dim-length vector", len(e1) == 16)

// Embed batch
let batch = embed_batch(model, ["hello", "world", "test"])
check("embed_batch returns 3 vectors", len(batch) == 3)
check("batch[0] dim = 16", len(batch[0]) == 16)

// Same text should produce same embedding
let e1b = embed(model, "hello")
let same_sim = cosine_similarity(e1, e1b)
check("same text -> same embedding", approx_eq(same_sim, 1.0, 0.001))

// Different text should produce different embedding
let e2 = embed(model, "goodbye")
let diff_sim = cosine_similarity(e1, e2)
check("different text -> different embedding", diff_sim < 0.99)

println("")

// ===================================================================
//  Test 3: Vector store (brute-force)
// ===================================================================
println("=== Test 3: Vector store ===")

let mut store = create_store(16)
check("empty store size = 0", store_size(store) == 0)

// Add some vectors
let doc1_vec = embed(model, "machine learning is great")
let doc2_vec = embed(model, "deep neural networks")
let doc3_vec = embed(model, "cooking recipes for dinner")
let doc4_vec = embed(model, "artificial intelligence research")

store = store_add(store, "doc1", doc1_vec, "topic=ml")
store = store_add(store, "doc2", doc2_vec, "topic=ml")
store = store_add(store, "doc3", doc3_vec, "topic=cooking")
store = store_add(store, "doc4", doc4_vec, "topic=ml")
check("store size = 4", store_size(store) == 4)

// Search for ML-related query
let query_vec = embed(model, "neural network training")
let results = store_search(store, query_vec, 2)
check("search returns 2 results", len(results) == 2)
check("result has id", len(results[0][0]) > 0)
check("result has score", results[0][1] > -2.0)

// Top result should have highest score
if len(results) >= 2 {
    check("results sorted by score desc", results[0][1] >= results[1][1])
}

// Get by id
let got = store_get(store, "doc1")
check("store_get finds doc1", len(got) == 2)

let missing = store_get(store, "nonexistent")
check("store_get returns [] for missing", len(missing) == 0)

println("")

// ===================================================================
//  Test 4: IVF vector store
// ===================================================================
println("=== Test 4: IVF vector store ===")

let mut ivf = create_ivf_store(16, 2)

// Add same documents
ivf = ivf_add(ivf, "d1", doc1_vec, "ml")
ivf = ivf_add(ivf, "d2", doc2_vec, "ml")
ivf = ivf_add(ivf, "d3", doc3_vec, "cooking")
ivf = ivf_add(ivf, "d4", doc4_vec, "ml")
check("ivf store has 4 docs", len(ivf.ids) == 4)

// Build index
let indexed = ivf_build_index(ivf)
check("ivf index built", indexed.built == true)
check("ivf has centroids", len(indexed.centroids) == 2)
check("ivf has assignments", len(indexed.assignments) == 4)

// Search
let ivf_results = ivf_search(indexed, query_vec, 2, 2)
check("ivf search returns 2 results", len(ivf_results) == 2)
check("ivf result has score", ivf_results[0][1] > -2.0)

println("")

// ===================================================================
//  Test 5: RAG pipeline
// ===================================================================
println("=== Test 5: RAG pipeline ===")

// Create document set
let documents = [
    ["doc1", "Machine learning uses algorithms to learn patterns from data", "topic=ml"],
    ["doc2", "Neural networks are inspired by biological neurons", "topic=ml"],
    ["doc3", "The best chocolate cake recipe uses cocoa butter", "topic=cooking"],
    ["doc4", "Gradient descent optimizes model parameters iteratively", "topic=ml"],
    ["doc5", "Pizza dough needs yeast and warm water to rise", "topic=cooking"]
]

// Index documents
let rag_store = index_documents(model, documents)
check("indexed 5 documents", store_size(rag_store) == 5)

// Retrieve relevant documents
let rag_results = retrieve(rag_store, model, "how do neural networks learn", 3)
check("retrieve returns 3 results", len(rag_results) == 3)

// Build prompt
let doc_texts = [
    ["doc1", "Machine learning uses algorithms to learn patterns from data"],
    ["doc2", "Neural networks are inspired by biological neurons"],
    ["doc3", "The best chocolate cake recipe uses cocoa butter"],
    ["doc4", "Gradient descent optimizes model parameters iteratively"],
    ["doc5", "Pizza dough needs yeast and warm water to rise"]
]

let config = default_rag_config()

let rag_output = rag_generate(model, "how do neural networks learn", rag_store, doc_texts, config)
let prompt = rag_output[0]
let ctx_docs = rag_output[1]
let scores = rag_output[2]

check("rag prompt is non-empty", len(prompt) > 0)
check("rag has context docs", len(ctx_docs) > 0)
check("rag has scores", len(scores) > 0)
check("prompt contains Question", prompt.index_of("Question") >= 0)
check("prompt contains Context", prompt.index_of("Context") >= 0)
check("prompt contains Answer", prompt.index_of("Answer") >= 0)

println("")
println("Generated RAG prompt:")
println("---")
println(prompt)
println("---")

println("")

// ===================================================================
//  Test 6: Prompt templates
// ===================================================================
println("=== Test 6: Prompt templates ===")

let test_docs = [["id1", "test context data"]]

let p_default = build_rag_prompt("test query?", test_docs, "default")
check("default template has Context:", p_default.index_of("Context:") >= 0)
check("default template has Question:", p_default.index_of("Question:") >= 0)

let p_concise = build_rag_prompt("test query?", test_docs, "concise")
check("concise template has Briefly", p_concise.index_of("Briefly") >= 0)

let p_detailed = build_rag_prompt("test query?", test_docs, "detailed")
check("detailed template has detailed", p_detailed.index_of("detailed") >= 0)

println("")

// ===================================================================
//  Test 7: Edge cases
// ===================================================================
println("=== Test 7: Edge cases ===")

// Empty text embedding
let empty_emb = embed(model, "")
check("empty text -> zero vector dim", len(empty_emb) == 16)

// Single char
let single_emb = embed(model, "a")
check("single char embedding dim", len(single_emb) == 16)

// Empty store search
let empty_store = create_store(16)
let empty_results = store_search(empty_store, doc1_vec, 5)
check("empty store search returns []", len(empty_results) == 0)

// Cosine of zero vector
let zero_v = vec_zeros(16)
let zero_cos = cosine_similarity(zero_v, doc1_vec)
check("cosine with zero vector = 0", approx_eq(zero_cos, 0.0, 0.001))

// Normalize zero vector (should not crash)
let zero_n = normalize(zero_v)
check("normalize zero vector ok", len(zero_n) == 16)

println("")

// ===================================================================
//  Summary
// ===================================================================
println("=== RAG Test Summary ===")
println("PASS: " + str(PASS))
println("FAIL: " + str(FAIL))
println("TOTAL: " + str(PASS + FAIL))

if FAIL == 0 {
    println("ALL RAG TESTS PASSED")
} else {
    println("SOME TESTS FAILED")
}
