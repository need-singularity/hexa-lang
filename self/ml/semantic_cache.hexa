// ===================================================================
//  self/ml/semantic_cache.hexa — Semantic Cache (pure Hexa)
//
//  Embedding-based similarity cache for LLM inference.
//  Cache hit when cosine similarity exceeds threshold.
//  LRU eviction on capacity overflow.
//
//  Public API:
//    create_cache(capacity, threshold)
//      Create a cache with max capacity entries and similarity threshold.
//
//    cache_lookup(cache, query_embedding)
//      Search cache for entry similar to query_embedding.
//      Returns [hit, response, similarity] or [false, "", 0.0].
//
//    cache_store(cache, embedding, response)
//      Store a new entry. Evicts LRU if at capacity.
//      Returns updated cache.
//
//    cache_stats(cache)
//      Return [hits, misses, hit_rate, size].
//
//    cache_clear(cache)
//      Clear all entries, reset stats.
//
//    cache_remove(cache, index)
//      Remove entry at index. Returns updated cache.
// ===================================================================

// ===================================================================
//  Vector math (self-contained to avoid circular imports)
// ===================================================================
fn sc_dot(a, b) {
    let n = len(a)
    let mut sum = 0.0
    let mut i = 0
    while i < n {
        sum = sum + a[i] * b[i]
        i = i + 1
    }
    return sum
}

fn sc_norm(v) {
    let mut sum = 0.0
    let n = len(v)
    let mut i = 0
    while i < n {
        sum = sum + v[i] * v[i]
        i = i + 1
    }
    return sqrt(sum)
}

fn sc_cosine(a, b) {
    let d = sc_dot(a, b)
    let na = sc_norm(a)
    let nb = sc_norm(b)
    let denom = na * nb
    if denom < 0.000001 { return 0.0 }
    return d / denom
}

// ===================================================================
//  Cache data structure
//
//  embeddings: array of float arrays (stored embeddings)
//  responses: array of strings (cached responses)
//  access_order: array of ints (access timestamps for LRU)
//  capacity: max entries
//  threshold: cosine similarity threshold for hit
//  hits: total cache hits
//  misses: total cache misses
//  tick: monotonic counter for LRU ordering
// ===================================================================
struct SemanticCache {
    embeddings: array,
    responses: array,
    access_order: array,
    capacity: int,
    threshold: float,
    hits: int,
    misses: int,
    tick: int
}

fn create_cache(capacity, threshold) {
    return SemanticCache {
        embeddings: [],
        responses: [],
        access_order: [],
        capacity: capacity,
        threshold: threshold,
        hits: 0,
        misses: 0,
        tick: 0
    }
}

// ===================================================================
//  cache_lookup: find most similar entry above threshold
//
//  Returns [hit_bool, response_string, similarity_float]
//  Updates access_order on hit, increments hit/miss counters.
// ===================================================================
fn cache_lookup(cache, query_embedding) {
    let n = len(cache.embeddings)
    if n == 0 {
        let new_cache = SemanticCache {
            embeddings: cache.embeddings,
            responses: cache.responses,
            access_order: cache.access_order,
            capacity: cache.capacity,
            threshold: cache.threshold,
            hits: cache.hits,
            misses: cache.misses + 1,
            tick: cache.tick
        }
        return [false, "", 0.0, new_cache]
    }

    // Find best match
    let mut best_idx = -1
    let mut best_sim = -1.0
    let mut i = 0
    while i < n {
        let sim = sc_cosine(query_embedding, cache.embeddings[i])
        if sim > best_sim {
            best_sim = sim
            best_idx = i
        }
        i = i + 1
    }

    if best_sim >= cache.threshold {
        // Cache hit - update access order
        let new_tick = cache.tick + 1
        let mut new_order = []
        i = 0
        while i < n {
            if i == best_idx {
                new_order = new_order + [new_tick]
            } else {
                new_order = new_order + [cache.access_order[i]]
            }
            i = i + 1
        }
        let new_cache = SemanticCache {
            embeddings: cache.embeddings,
            responses: cache.responses,
            access_order: new_order,
            capacity: cache.capacity,
            threshold: cache.threshold,
            hits: cache.hits + 1,
            misses: cache.misses,
            tick: new_tick
        }
        return [true, cache.responses[best_idx], best_sim, new_cache]
    }

    // Cache miss
    let miss_cache = SemanticCache {
        embeddings: cache.embeddings,
        responses: cache.responses,
        access_order: cache.access_order,
        capacity: cache.capacity,
        threshold: cache.threshold,
        hits: cache.hits,
        misses: cache.misses + 1,
        tick: cache.tick
    }
    return [false, "", best_sim, miss_cache]
}

// ===================================================================
//  cache_store: add entry, evict LRU if full
// ===================================================================
fn cache_store(cache, embedding, response) {
    let n = len(cache.embeddings)
    let new_tick = cache.tick + 1

    if n < cache.capacity {
        // Room available, just append
        return SemanticCache {
            embeddings: cache.embeddings + [embedding],
            responses: cache.responses + [response],
            access_order: cache.access_order + [new_tick],
            capacity: cache.capacity,
            threshold: cache.threshold,
            hits: cache.hits,
            misses: cache.misses,
            tick: new_tick
        }
    }

    // Evict LRU (lowest access_order)
    let mut lru_idx = 0
    let mut lru_tick = cache.access_order[0]
    let mut i = 1
    while i < n {
        if cache.access_order[i] < lru_tick {
            lru_tick = cache.access_order[i]
            lru_idx = i
        }
        i = i + 1
    }

    // Build new arrays without the evicted entry, then add new one
    let mut new_emb = []
    let mut new_resp = []
    let mut new_order = []
    i = 0
    while i < n {
        if i != lru_idx {
            new_emb = new_emb + [cache.embeddings[i]]
            new_resp = new_resp + [cache.responses[i]]
            new_order = new_order + [cache.access_order[i]]
        }
        i = i + 1
    }

    return SemanticCache {
        embeddings: new_emb + [embedding],
        responses: new_resp + [response],
        access_order: new_order + [new_tick],
        capacity: cache.capacity,
        threshold: cache.threshold,
        hits: cache.hits,
        misses: cache.misses,
        tick: new_tick
    }
}

// ===================================================================
//  cache_stats: return [hits, misses, hit_rate, size]
// ===================================================================
fn cache_stats(cache) {
    let total = cache.hits + cache.misses
    let mut hit_rate = 0.0
    if total > 0 {
        hit_rate = to_float(cache.hits) / to_float(total)
    }
    let size = len(cache.embeddings)
    return [cache.hits, cache.misses, hit_rate, size]
}

// ===================================================================
//  cache_clear: reset everything
// ===================================================================
fn cache_clear(cache) {
    return create_cache(cache.capacity, cache.threshold)
}

// ===================================================================
//  cache_remove: remove entry at index
// ===================================================================
fn cache_remove(cache, index) {
    let n = len(cache.embeddings)
    if index < 0 { return cache }
    if index >= n { return cache }

    let mut new_emb = []
    let mut new_resp = []
    let mut new_order = []
    let mut i = 0
    while i < n {
        if i != index {
            new_emb = new_emb + [cache.embeddings[i]]
            new_resp = new_resp + [cache.responses[i]]
            new_order = new_order + [cache.access_order[i]]
        }
        i = i + 1
    }

    return SemanticCache {
        embeddings: new_emb,
        responses: new_resp,
        access_order: new_order,
        capacity: cache.capacity,
        threshold: cache.threshold,
        hits: cache.hits,
        misses: cache.misses,
        tick: cache.tick
    }
}

println("[semantic_cache] loaded — embedding-based cache with LRU eviction")
