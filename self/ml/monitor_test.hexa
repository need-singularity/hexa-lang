// ═══════════════════════════════════════════════════════════════
//  monitor_test.hexa — Tests for monitor, visualize, profiler
// ═══════════════════════════════════════════════════════════════

use "monitor"
use "visualize"
use "profiler"

let mut PASS = 0
let mut FAIL = 0

fn check(label, condition) {
    if condition {
        PASS = PASS + 1
    } else {
        println("  FAIL: " + label)
        FAIL = FAIL + 1
    }
}

// ── Test 1: create_logger ────────────────────────────────────

fn test_create_logger() {
    println("[test] create_logger")
    let lg = create_logger("/tmp/hexa_test_monitor.jsonl")
    check("logger has path", lg[0] == "/tmp/hexa_test_monitor.jsonl")
    check("logger step_times empty", len(lg[1]) == 0)
    check("logger loss_hist empty", len(lg[2]) == 0)
    check("logger window is 20", lg[3] == 20)
}

let _ = test_create_logger()

// ── Test 2: log_step writes JSONL ────────────────────────────

fn test_log_step() {
    println("[test] log_step")
    write_file("/tmp/hexa_test_mon2.jsonl", "")
    let lg = create_logger("/tmp/hexa_test_mon2.jsonl")
    let keys = ["loss", "lr", "grad_norm", "step_ms", "tok_per_sec"]
    let vals = [2.5, 0.0003, 1.2, 50.0, 2560.0]
    let lg2 = log_step(lg, 1, keys, vals)
    let content = read_file("/tmp/hexa_test_mon2.jsonl")
    check("jsonl not empty", len(content) > 10)
    check("contains step", _str_contains(content, "\"step\":1"))
    check("contains loss", _str_contains(content, "\"loss\":2.5"))
    check("contains type", _str_contains(content, "\"type\":\"step\""))
    check("step_times has 1", len(lg2[1]) == 1)
    check("loss_hist has 1", len(lg2[2]) == 1)
}

let _ = test_log_step()

// ── Test 3: log_eval ─────────────────────────────────────────

fn test_log_eval() {
    println("[test] log_eval")
    write_file("/tmp/hexa_test_mon3.jsonl", "")
    let lg = create_logger("/tmp/hexa_test_mon3.jsonl")
    let ek = ["eval_loss", "perplexity"]
    let ev = [1.8, 6.05]
    let lg2 = log_eval(lg, 100, ek, ev)
    let content = read_file("/tmp/hexa_test_mon3.jsonl")
    check("eval jsonl not empty", len(content) > 10)
    check("eval contains type", _str_contains(content, "\"type\":\"eval\""))
    check("eval contains perplexity", _str_contains(content, "\"perplexity\":"))
}

let _ = test_log_eval()

// ── Test 4: smooth loss ──────────────────────────────────────

fn test_smooth_loss() {
    println("[test] smooth_loss")
    write_file("/tmp/hexa_test_mon4.jsonl", "")
    let mut lg = create_logger("/tmp/hexa_test_mon4.jsonl")
    let mut s = 1
    while s <= 5 {
        let loss = 6.0 - s * 1.0
        let k = ["loss", "lr", "step_ms"]
        let v = [loss, 0.001, 10.0]
        lg = log_step(lg, s, k, v)
        s = s + 1
    }
    let smooth = get_smooth_loss(lg)
    // losses: 5,4,3,2,1 -> mean = 3.0
    check("smooth loss is ~3.0", smooth > 2.9)
    check("smooth loss is ~3.0b", smooth < 3.1)
}

let _ = test_smooth_loss()

// ── Test 5: ETA calculation ──────────────────────────────────

fn test_eta() {
    println("[test] eta")
    write_file("/tmp/hexa_test_mon5.jsonl", "")
    let mut lg = create_logger("/tmp/hexa_test_mon5.jsonl")
    let mut s = 1
    while s <= 10 {
        let k = ["loss", "lr", "step_ms"]
        let v = [1.0, 0.001, 100.0]
        lg = log_step(lg, s, k, v)
        s = s + 1
    }
    let eta = get_eta(lg, 10, 100)
    // 90 remaining * 100ms = 9000ms = 9s
    check("ETA not N/A", eta != "N/A")
    println("  ETA = " + eta)
}

let _ = test_eta()

// ── Test 6: print_progress ───────────────────────────────────

fn test_progress() {
    println("[test] progress bar")
    write_file("/tmp/hexa_test_mon6.jsonl", "")
    let mut lg = create_logger("/tmp/hexa_test_mon6.jsonl")
    let k = ["loss", "lr", "step_ms", "tok_per_sec", "grad_norm"]
    let v = [2.1, 0.0003, 42.0, 3048.0, 0.8]
    lg = log_step(lg, 50, k, v)
    let _ = print_progress(lg, 50, 100, k, v)
    check("progress runs", true)
}

let _ = test_progress()

// ── Test 7: extract_field ────────────────────────────────────

fn test_extract_field() {
    println("[test] extract_field")
    let line = "{\"type\":\"step\",\"step\":42,\"loss\":2.718,\"lr\":0.0003}"
    let step_v = extract_field(line, "step")
    let loss_v = extract_field(line, "loss")
    let lr_v = extract_field(line, "lr")
    check("step == 42", step_v == 42.0)
    check("loss > 2.71", loss_v > 2.71)
    check("loss < 2.72", loss_v < 2.72)
    check("lr > 0.00029", lr_v > 0.00029)
    check("lr < 0.00031", lr_v < 0.00031)
}

let _ = test_extract_field()

// ── Test 8: profiler create_timer/mark/finish ────────────────

fn test_timer() {
    println("[test] profiler timer")
    let mut t = create_timer()
    let mut x = 0.0
    let mut i = 0
    while i < 1000 {
        x = x + 1.0
        i = i + 1
    }
    t = mark(t, "phase_a")
    i = 0
    while i < 1000 {
        x = x + 1.0
        i = i + 1
    }
    t = mark(t, "phase_b")
    let bd = finish_timer(t)
    check("breakdown has 3 entries", len(bd) == 3)
    check("first label is phase_a", bd[0][0] == "phase_a")
    check("second label is phase_b", bd[1][0] == "phase_b")
    check("third label is total", bd[2][0] == "total")
    check("phase_a ms >= 0", bd[0][1] >= 0.0)
    check("total ms >= 0", bd[2][1] >= 0.0)
    let _ = print_timer_breakdown(bd)
}

let _ = test_timer()

// ── Test 9: estimate_memory ──────────────────────────────────

fn test_memory() {
    println("[test] memory estimate")
    let mem = estimate_memory(81199104, 1, 128, 768)
    check("param_bytes > 0", mem[0] > 0)
    check("total > params", mem[4] > mem[0])
    let _ = print_memory(mem)
}

let _ = test_memory()

// ── Test 10: identify_bottleneck ─────────────────────────────

fn test_bottleneck() {
    println("[test] bottleneck")
    let bd = [20.0, 45.0, 10.0, 5.0, 80.0]
    let result = identify_bottleneck(bd)
    check("bottleneck is backward", _str_contains(result, "backward"))
    println("  bottleneck: " + result)
}

let _ = test_bottleneck()

// ── Test 11: visualize plot_series ───────────────────────────

fn test_plot() {
    println("[test] plot_series")
    let mut vals = []
    let mut i = 0
    while i < 50 {
        vals = vals.push(5.0 - i * 0.1)
        i = i + 1
    }
    let _ = plot_series(vals, "Test Loss (decreasing)", 40, 10)
    check("plot runs", true)
}

let _ = test_plot()

// ── Test 12: full pipeline — log + read + plot ───────────────

fn test_full_pipeline() {
    println("[test] full pipeline")
    write_file("/tmp/hexa_test_mon_full.jsonl", "")
    let mut lg = create_logger("/tmp/hexa_test_mon_full.jsonl")
    let mut s = 1
    while s <= 30 {
        let loss = 5.0 / (1.0 + s * 0.1)
        let lr = 0.0003 * (1.0 - s * 1.0 / 30.0)
        let tok_s = 2000.0 + s * 50.0
        let gn = 1.0 / (1.0 + s * 0.05)
        let k = ["loss", "lr", "step_ms", "tok_per_sec", "grad_norm"]
        let v = [loss, lr, 42.0, tok_s, gn]
        lg = log_step(lg, s, k, v)
        s = s + 1
    }
    let records = read_log("/tmp/hexa_test_mon_full.jsonl", "step")
    check("30 records written", len(records) == 30)
    let _ = plot_loss("/tmp/hexa_test_mon_full.jsonl")
    let _ = plot_lr("/tmp/hexa_test_mon_full.jsonl")
    let _ = plot_throughput("/tmp/hexa_test_mon_full.jsonl")
}

let _ = test_full_pipeline()

// ── Test 13: profile_step ────────────────────────────────────

fn test_profile_step() {
    println("[test] profile_step")
    fn dummy_work() {
        let mut x = 0.0
        let mut i = 0
        while i < 500 {
            x = x + 1.0
            i = i + 1
        }
        x
    }
    let bd = profile_step(dummy_work, dummy_work, dummy_work, dummy_work)
    check("profile has 5 fields", len(bd) == 5)
    check("fwd_ms >= 0", bd[0] >= 0.0)
    check("total_ms >= 0", bd[4] >= 0.0)
    check("total >= fwd+bwd", bd[4] >= bd[0] + bd[1])
    let _ = print_profile(bd)
}

let _ = test_profile_step()

// ── Test 14: _format_duration ────────────────────────────────

fn test_format_duration() {
    println("[test] format_duration")
    let s1 = _format_duration(5000.0)
    check("5s", s1 == "5s")
    let s2 = _format_duration(65000.0)
    check("1m 5s", s2 == "1m 5s")
    let s3 = _format_duration(3665000.0)
    check("1h 1m 5s", s3 == "1h 1m 5s")
}

let _ = test_format_duration()

// ── Test 15: window trimming ─────────────────────────────────

fn test_window_trim() {
    println("[test] window trimming")
    write_file("/tmp/hexa_test_mon_win.jsonl", "")
    let mut lg = create_logger("/tmp/hexa_test_mon_win.jsonl")
    // Set small window for testing
    lg = [lg[0], lg[1], lg[2], 5, lg[4]]
    let mut s = 1
    while s <= 10 {
        let k = ["loss", "lr", "step_ms"]
        let v = [s * 1.0, 0.001, 10.0]
        lg = log_step(lg, s, k, v)
        s = s + 1
    }
    // Window is 5, so only last 5 losses kept: 6,7,8,9,10
    check("loss_hist len is 5", len(lg[2]) == 5)
    let smooth = get_smooth_loss(lg)
    // mean(6,7,8,9,10) = 8.0
    check("smooth is ~8.0", smooth > 7.9)
    check("smooth is ~8.0b", smooth < 8.1)
}

let _ = test_window_trim()

// ── Summary ──────────────────────────────────────────────────

println("")
println("=" * 50)
println("  monitor_test: " + str(PASS) + " PASS, " + str(FAIL) + " FAIL")
println("=" * 50)
if FAIL > 0 { println("[FAIL] some tests failed") }
