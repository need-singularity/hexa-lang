// =====================================================================
//  self/ml/train_7b_integrated.hexa — 7B transformer training with
//  hxflash attention (forward + backward), grad checkpointing hooks,
//  and hxccl allreduce gradient sync.
//
//  Demonstrates a single training step:
//    forward -> loss -> backward -> grad_sync -> optimizer
//
//  Shape constants (7B-class):
//    d_model = 4096, n_layers = 32, n_heads = 32, n_kv_heads = 8 (GQA)
//    head_dim = 128, seq_len = 2048, ff_dim = 11008, vocab = 32000
//
//  Dependencies:
//    - hxflash FFI (self/ml/hxflash.hexa) — flash attention fwd + bwd
//    - hxccl FFI (self/ml/hxccl.hexa) — allreduce for gradient sync
//    - hxblas FFI — GEMM for linear projections
//    - hxblas_bf16 FFI — bf16 conversion + bf16 matvec (mixed precision)
//
//  Grammar notes (HX3):
//    - .push() not arr+[x] in loops
//    - parens in slice index arithmetic: arr[(i+1)..j]
//    - avoid `handle` as param name (reserved)
// =====================================================================

use "hxblas_bf16"
use "checkpoint"
use "eval_harness"
use "data_loader"
use "weight_init"
use "hexaw"
use "lr_schedule"
use "grad_accumulate"
use "rope"

// ── 7B-class shape constants ────────────────────────────────────
let D_MODEL   = 4096
let N_LAYERS  = 32
let N_HEADS   = 32
let N_KV      = 8         // GQA: 32 Q heads share 8 KV heads
let HEAD_DIM  = 128       // D_MODEL / N_HEADS
let SEQ_LEN   = 2048
let FF_DIM    = 11008     // SwiGLU intermediate
let VOCAB     = 32000
let ROPE_THETA = 10000.0  // RoPE base frequency

// ── Training hyperparameters ────────────────────────────────────
let LR          = 3.0e-4
let LR_MIN      = 1.0e-6    // minimum LR floor (cosine/linear decay target)
let BETA1       = 0.9
let BETA2       = 0.95
let WEIGHT_DECAY = 0.1
let GRAD_CLIP   = 1.0
let WARMUP      = 200       // warmup steps (200 for 7B-class models)
let TOTAL_STEPS = 10000
let LR_SCHEDULE = "cosine"  // "cosine" | "linear" | "constant_with_warmup"

// ── Gradient accumulation ──────────────────────────────────────
// micro_batch=1 is all that fits on H100 80GB for 7B seq=2048.
// Accumulate over ACCUM_STEPS micro-batches for effective batch.
let MICRO_BATCH  = 1
let ACCUM_STEPS  = 8        // effective_batch = 1 * 8 = 8
let GA_CFG = ga_config(MICRO_BATCH, ACCUM_STEPS)

// ── Evaluation config ───────────────────────────────────────────
let EVAL_INTERVAL  = 1000    // evaluate every N steps (0 = disabled)
let EVAL_MAX_BATCH = 10      // max batches per eval (0 = all)

// ── Tile sizes for flash attention ──────────────────────────────
let FLASH_BR = 64
let FLASH_BC = 64

// ── hxccl op codes (mirror hxccl.hexa) ──────────────────────────
let HXCCL_OP_SUM = 0
let HXCCL_OP_AVG = 1

// ── Grad checkpointing segment size ─────────────────────────────
// Layers are grouped into segments. Forward activations are only
// saved at segment boundaries; intermediate layers recompute on
// backward. With 32 layers and segment=4, we save 8 checkpoints
// instead of 32 — a 4x activation memory reduction.
let CKPT_SEGMENT = 4

// ── Model checkpoint config ─────────────────────────────────────
// Save a full checkpoint every CKPT_INTERVAL steps. Set 0 to disable.
// Keeps last 3 checkpoints on disk (KEEP_N in checkpoint.hexa).
let CKPT_INTERVAL  = 500
let CKPT_PREFIX    = "ckpt/7b"

// ── Mixed-precision config (bf16 compute / fp32 master) ─────────
// When USE_BF16 = true:
//   - fp32 master weights are cast to bf16 before each forward step
//   - forward + backward run in bf16 (hxblas_bf16_matvec for projections)
//   - gradients are cast back to fp32 before AdamW update
//   - dynamic loss scaling prevents bf16 underflow in backward
let USE_BF16 = true

// ── Dynamic loss scaling constants ──────────────────────────────
let LOSS_SCALE_INIT    = 65536.0   // initial scale factor
let LOSS_SCALE_FACTOR  = 2.0       // scale up/down multiplier
let LOSS_SCALE_WINDOW  = 2000      // clean steps before scale-up
let LOSS_SCALE_MIN     = 1.0       // minimum allowed scale

// ── Embedding + LM head sizes ───────────────────────────────────
let SZ_EMBED = VOCAB * D_MODEL          // embedding table [VOCAB, D]
let SZ_LM_HEAD = D_MODEL * VOCAB        // LM head [D, VOCAB]

// =====================================================================
//  Buffer management — raw f32 buffers for the hot path
//
//  All weight/activation/gradient buffers are flat f32 arrays managed
//  via alloc_raw/free_raw. This avoids nested-array overhead and lets
//  us pass pointers directly to hxflash/hxblas FFI.
// =====================================================================

fn alloc_f32(n) {
    return alloc_raw(n * 4)
}

fn free_f32(buf, n) {
    free_raw(buf, n * 4)
}

fn zero_f32(buf, n) {
    for i in 0..n {
        write_f32(buf, i * 4, 0.0)
    }
}

fn copy_f32(src, dst, n) {
    for i in 0..n {
        write_f32(dst, i * 4, deref_f32(src, i * 4))
    }
}

fn add_f32(a, b, n) {
    for i in 0..n {
        let va = deref_f32(a, i * 4)
        let vb = deref_f32(b, i * 4)
        write_f32(a, i * 4, va + vb)
    }
}

fn scale_f32(buf, n, s) {
    for i in 0..n {
        write_f32(buf, i * 4, deref_f32(buf, i * 4) * s)
    }
}

// =====================================================================
//  bf16 buffer management — half-precision (2 bytes per element)
//
//  bf16 buffers are allocated via alloc_raw with 2 bytes/element.
//  Conversion between f32 and bf16 uses hxblas FFI (NEON/SSE optimized).
// =====================================================================

fn alloc_bf16(n) {
    return alloc_raw(n * 2)
}

fn free_bf16(buf, n) {
    free_raw(buf, n * 2)
}

// Cast fp32 buffer -> bf16 buffer (allocates bf16 buf, caller frees)
fn cast_f32_to_bf16(f32_buf, n) {
    let bf16_buf = alloc_bf16(n)
    hxblas_f32_to_bf16(n, f32_buf, bf16_buf)
    return bf16_buf
}

// Cast bf16 buffer -> fp32 buffer (allocates f32 buf, caller frees)
fn cast_bf16_to_f32(bf16_buf, n) {
    let f32_buf = alloc_f32(n)
    hxblas_bf16_to_f32(n, bf16_buf, f32_buf)
    return f32_buf
}

// Cast bf16 grads back into an existing fp32 grad buffer (in-place overwrite)
fn cast_bf16_grads_to_f32(bf16_buf, f32_dst, n) {
    hxblas_bf16_to_f32(n, bf16_buf, f32_dst)
}

// =====================================================================
//  check_grad_overflow — scan fp32 grad buffer for inf/nan
//  Returns true if any element is inf or nan
// =====================================================================
fn check_grad_overflow(buf, n) {
    for i in 0..n {
        let v = deref_f32(buf, i * 4)
        // inf check: v != v is nan, abs(v) > 3.4e38 is inf-class
        if v != v { return true }
        let av = if v < 0.0 { 0.0 - v } else { v }
        if av > 3.4e38 { return true }
    }
    return false
}

// Check all layer grad buffers for overflow
fn check_all_grads_overflow(all_grads) {
    let sizes = [SZ_WQ, SZ_WK, SZ_WV, SZ_WO, SZ_WGATE, SZ_WUP, SZ_WDOWN, SZ_RMS, SZ_RMS]
    for layer_grads in all_grads {
        for idx in 0..9 {
            if check_grad_overflow(layer_grads[idx], sizes[idx]) {
                return true
            }
        }
    }
    return false
}

// =====================================================================
//  matmul_bf16 — bf16 matmul via hxblas_bf16_matvec (row-by-row)
//  C_f32[M*N] = A_bf16[M*K] @ B_bf16[K*N]  (output in fp32)
//
//  hxblas_bf16_matvec computes: out_f32[N] = mat_bf16[K*N]^T @ vec_bf16[K]
//  We iterate M rows of A, treating each as a vector.
// =====================================================================
fn matmul_bf16(A_bf16, B_bf16, C_f32, M, K, N) {
    // Temporary fp32 row output buffer
    let row_out = alloc_f32(N)
    for i in 0..M {
        // A_bf16 row i starts at offset i*K*2 bytes
        // B_bf16 is [K, N] in row-major, treat as K vectors of length N
        // hxblas_bf16_matvec(K, N, mat_bf16, vec_bf16, out_f32)
        let a_row_ptr = A_bf16 + i * K * 2
        hxblas_bf16_matvec(K, N, B_bf16, a_row_ptr, row_out)
        // Copy row output into C_f32
        for j in 0..N {
            write_f32(C_f32, (i * N + j) * 4, deref_f32(row_out, j * 4))
        }
    }
    free_f32(row_out, N)
}

// =====================================================================
//  Layer weight struct — one transformer block
//
//  Each layer holds: Wq, Wk, Wv, Wo (attention projections)
//                    W_gate, W_up, W_down (SwiGLU FFN)
//                    rms_attn, rms_ffn (RMSNorm weights)
//
//  For 7B with GQA:
//    Wq: [D, D]       = 4096*4096 = 16M
//    Wk: [D, KV_D]    = 4096*1024 = 4M   (N_KV * HEAD_DIM = 1024)
//    Wv: [D, KV_D]    = 4096*1024 = 4M
//    Wo: [D, D]        = 16M
//    W_gate: [D, FF]   = 4096*11008 = 45M
//    W_up:   [D, FF]   = 45M
//    W_down: [FF, D]   = 45M
//    rms: [D]*2        = 8K
// =====================================================================

let KV_DIM = N_KV * HEAD_DIM    // 1024

// Size constants per layer (element counts)
let SZ_WQ     = D_MODEL * D_MODEL
let SZ_WK     = D_MODEL * KV_DIM
let SZ_WV     = D_MODEL * KV_DIM
let SZ_WO     = D_MODEL * D_MODEL
let SZ_WGATE  = D_MODEL * FF_DIM
let SZ_WUP    = D_MODEL * FF_DIM
let SZ_WDOWN  = FF_DIM * D_MODEL
let SZ_RMS    = D_MODEL

// Activation sizes per layer
let SZ_HIDDEN = SEQ_LEN * D_MODEL
let SZ_QH     = SEQ_LEN * D_MODEL       // Q after projection
let SZ_KH     = SEQ_LEN * KV_DIM        // K after projection
let SZ_VH     = SEQ_LEN * KV_DIM        // V after projection
let SZ_ATTN_O = SEQ_LEN * D_MODEL       // attention output

// =====================================================================
//  init_layer_weights — allocate + random init one transformer layer
// =====================================================================
fn init_layer_weights(layer_idx) {
    let wq    = alloc_f32(SZ_WQ)
    let wk    = alloc_f32(SZ_WK)
    let wv    = alloc_f32(SZ_WV)
    let wo    = alloc_f32(SZ_WO)
    let wgate = alloc_f32(SZ_WGATE)
    let wup   = alloc_f32(SZ_WUP)
    let wdown = alloc_f32(SZ_WDOWN)
    let rms_a = alloc_f32(SZ_RMS)
    let rms_f = alloc_f32(SZ_RMS)

    // Proper per-component initialization via weight_init module
    let bufs = [wq, wk, wv, wo, wgate, wup, wdown, rms_a, rms_f]
    init_transformer_layer(bufs, D_MODEL, FF_DIM, N_LAYERS, layer_idx)

    return bufs
}

// =====================================================================
//  Gradient buffers per layer — same shapes as weights
// =====================================================================
fn alloc_layer_grads() {
    let dq    = alloc_f32(SZ_WQ)
    let dk    = alloc_f32(SZ_WK)
    let dv    = alloc_f32(SZ_WV)
    let do_w  = alloc_f32(SZ_WO)
    let dgate = alloc_f32(SZ_WGATE)
    let dup   = alloc_f32(SZ_WUP)
    let ddown = alloc_f32(SZ_WDOWN)
    let drms_a = alloc_f32(SZ_RMS)
    let drms_f = alloc_f32(SZ_RMS)
    return [dq, dk, dv, do_w, dgate, dup, ddown, drms_a, drms_f]
}

fn zero_layer_grads(grads) {
    zero_f32(grads[0], SZ_WQ)
    zero_f32(grads[1], SZ_WK)
    zero_f32(grads[2], SZ_WV)
    zero_f32(grads[3], SZ_WO)
    zero_f32(grads[4], SZ_WGATE)
    zero_f32(grads[5], SZ_WUP)
    zero_f32(grads[6], SZ_WDOWN)
    zero_f32(grads[7], SZ_RMS)
    zero_f32(grads[8], SZ_RMS)
}

// =====================================================================
//  matmul_raw — flat buffer matmul: C[M*N] = A[M*K] @ B[K*N]
//  For real training, this dispatches to hxblas. Shown inline for
//  self-contained demonstration.
// =====================================================================
fn matmul_raw(A, B, C, M, K, N) {
    for i in 0..M {
        for j in 0..N {
            let mut acc = 0.0
            for kk in 0..K {
                let a_val = deref_f32(A, (i * K + kk) * 4)
                let b_val = deref_f32(B, (kk * N + j) * 4)
                acc = acc + a_val * b_val
            }
            write_f32(C, (i * N + j) * 4, acc)
        }
    }
}

// =====================================================================
//  matmul_raw_tn — C[M*N] = A^T[M*K] @ B[K*N]  (A stored as [K*M])
//  Used for backward: d_hidden = dQ @ Wq^T  where Wq is [D, D]
// =====================================================================
fn matmul_raw_tn(A, B, C, M, K, N) {
    for i in 0..M {
        for j in 0..N {
            let mut acc = 0.0
            for kk in 0..K {
                // A^T[i,kk] = A[kk,M + i] = A[kk*M + i]
                let a_val = deref_f32(A, (kk * M + i) * 4)
                let b_val = deref_f32(B, (kk * N + j) * 4)
                acc = acc + a_val * b_val
            }
            write_f32(C, (i * N + j) * 4, acc)
        }
    }
}

// =====================================================================
//  matmul_raw_nt — C[M*N] += A[M*K] @ B^T[K*N]  (B stored as [N*K])
//  Used for weight gradient accumulation: dW += x^T @ dy
// =====================================================================
fn matmul_raw_nt(A, B, C, M, K, N) {
    for i in 0..M {
        for j in 0..N {
            let mut acc = deref_f32(C, (i * N + j) * 4)
            for kk in 0..K {
                let a_val = deref_f32(A, (i * K + kk) * 4)
                // B^T[kk,j] = B[j,K + kk] = B[j*K + kk]
                let b_val = deref_f32(B, (j * K + kk) * 4)
                acc = acc + a_val * b_val
            }
            write_f32(C, (i * N + j) * 4, acc)
        }
    }
}

// =====================================================================
//  matmul_acc — C[M*N] += A[M*K] @ B[K*N]  (accumulate)
// =====================================================================
fn matmul_acc(A, B, C, M, K, N) {
    for i in 0..M {
        for j in 0..N {
            let mut acc = deref_f32(C, (i * N + j) * 4)
            for kk in 0..K {
                let a_val = deref_f32(A, (i * K + kk) * 4)
                let b_val = deref_f32(B, (kk * N + j) * 4)
                acc = acc + a_val * b_val
            }
            write_f32(C, (i * N + j) * 4, acc)
        }
    }
}

// =====================================================================
//  rms_norm_fwd — RMSNorm: y[i] = x[i] / rms * gamma[i]
//  Input:  x [SEQ, D], gamma [D]
//  Output: out [SEQ, D], rstd [SEQ] (saved for backward)
// =====================================================================
fn rms_norm_fwd(x, gamma, out, rstd, seq, dim) {
    let eps = 1.0e-6
    for i in 0..seq {
        let mut sum_sq = 0.0
        for j in 0..dim {
            let v = deref_f32(x, (i * dim + j) * 4)
            sum_sq = sum_sq + v * v
        }
        let rms_val = sqrt(sum_sq / (dim * 1.0) + eps)
        let inv_rms = 1.0 / rms_val
        write_f32(rstd, i * 4, inv_rms)
        for j in 0..dim {
            let v = deref_f32(x, (i * dim + j) * 4)
            let g = deref_f32(gamma, j * 4)
            write_f32(out, (i * dim + j) * 4, v * inv_rms * g)
        }
    }
}

// =====================================================================
//  rms_norm_bwd — backward through RMSNorm
//  d_x[i,j] = (d_out[i,j] * gamma[j] - x[i,j] * (sum_k d_out[i,k]*gamma[k]*x[i,k]) * rstd^2 / D) * rstd
//  d_gamma[j] += sum_i d_out[i,j] * x[i,j] * rstd[i]
// =====================================================================
fn rms_norm_bwd(d_out, x, gamma, rstd, d_x, d_gamma, seq, dim) {
    for i in 0..seq {
        let rs = deref_f32(rstd, i * 4)
        // Compute dot = sum_j d_out[i,j] * gamma[j] * x[i,j]
        let mut dot = 0.0
        for j in 0..dim {
            let dy = deref_f32(d_out, (i * dim + j) * 4)
            let g = deref_f32(gamma, j * 4)
            let xv = deref_f32(x, (i * dim + j) * 4)
            dot = dot + dy * g * xv
        }
        let coeff = dot * rs * rs / (dim * 1.0)
        for j in 0..dim {
            let dy = deref_f32(d_out, (i * dim + j) * 4)
            let g = deref_f32(gamma, j * 4)
            let xv = deref_f32(x, (i * dim + j) * 4)
            let dx = (dy * g - xv * coeff) * rs
            write_f32(d_x, (i * dim + j) * 4, dx)
            // Accumulate d_gamma
            let dg = deref_f32(d_gamma, j * 4)
            write_f32(d_gamma, j * 4, dg + dy * xv * rs)
        }
    }
}

// =====================================================================
//  embedding_lookup — tokens -> hidden states
//  embed_table: [VOCAB, D], tokens: [SEQ], out: [SEQ, D]
// =====================================================================
fn embedding_lookup(embed_table, tokens, out, seq, dim) {
    for i in 0..seq {
        let tok = tokens[i]
        for j in 0..dim {
            let v = deref_f32(embed_table, (tok * dim + j) * 4)
            write_f32(out, (i * dim + j) * 4, v)
        }
    }
}

// =====================================================================
//  embedding_bwd — accumulate gradient into embedding table
// =====================================================================
fn embedding_bwd(d_hidden, tokens, d_embed, seq, dim) {
    for i in 0..seq {
        let tok = tokens[i]
        for j in 0..dim {
            let dh = deref_f32(d_hidden, (i * dim + j) * 4)
            let de = deref_f32(d_embed, (tok * dim + j) * 4)
            write_f32(d_embed, (tok * dim + j) * 4, de + dh)
        }
    }
}

// =====================================================================
//  silu — SiLU activation: x * sigmoid(x)
// =====================================================================
fn silu_val(x) {
    return x / (1.0 + exp(0.0 - x))
}

// =====================================================================
//  attention_fwd_layer — single layer attention forward via hxflash
//
//  Input:  hidden [SEQ, D] as raw f32 buffer
//  Output: attn_out [SEQ, D] as raw f32 buffer
//  Saves:  Q, K, V, O buffers for backward pass
// =====================================================================
fn attention_fwd_layer(hidden, weights, rope_freqs) {
    let wq = weights[0]
    let wk = weights[1]
    let wv = weights[2]
    let wo = weights[3]

    // Project Q, K, V
    let q_buf = alloc_f32(SZ_QH)
    let k_buf = alloc_f32(SZ_KH)
    let v_buf = alloc_f32(SZ_VH)
    let o_buf = alloc_f32(SZ_ATTN_O)

    // Q = hidden @ Wq  [SEQ, D] @ [D, D] -> [SEQ, D]
    matmul_raw(hidden, wq, q_buf, SEQ_LEN, D_MODEL, D_MODEL)
    // K = hidden @ Wk  [SEQ, D] @ [D, KV_DIM] -> [SEQ, KV_DIM]
    matmul_raw(hidden, wk, k_buf, SEQ_LEN, D_MODEL, KV_DIM)
    // V = hidden @ Wv  [SEQ, D] @ [D, KV_DIM] -> [SEQ, KV_DIM]
    matmul_raw(hidden, wv, v_buf, SEQ_LEN, D_MODEL, KV_DIM)

    // Apply RoPE to Q and K (in-place, before attention)
    apply_rope(q_buf, k_buf, rope_freqs, SEQ_LEN, N_HEADS, N_KV, HEAD_DIM, 0)

    // Flash attention forward via FFI (single packed dispatch)
    // Buffers are already in [n_heads, S, HEAD_DIM] layout after projection
    let flash_o = alloc_f32(SZ_QH)
    let scale = 1.0 / sqrt(HEAD_DIM * 1.0)
    flash_attn_fwd_packed(SEQ_LEN, HEAD_DIM, N_HEADS, N_KV,
                          FLASH_BR, FLASH_BC, 1,
                          q_buf, k_buf, v_buf, flash_o, scale)

    // O_proj = flash_o @ Wo  [SEQ, D] @ [D, D] -> [SEQ, D]
    matmul_raw(flash_o, wo, o_buf, SEQ_LEN, D_MODEL, D_MODEL)

    // Return: [attn_output, saved_q, saved_k, saved_v, saved_flash_o]
    return [o_buf, q_buf, k_buf, v_buf, flash_o]
}

// =====================================================================
//  attention_bwd_layer — backward through attention via hxflash bwd
//
//  d_out: gradient of attention output [SEQ, D]
//  hidden_in: pre-norm input to Q/K/V projections [SEQ, D] (for weight grads)
//  saved: [q_buf, k_buf, v_buf, flash_o] from forward
//  Returns: d_hidden [SEQ, D] gradient to pass to prior layer
//  Accumulates into grads[0..3] (dWq, dWk, dWv, dWo)
// =====================================================================
fn attention_bwd_layer(d_out, hidden_in, saved, weights, grads) {
    let wq = weights[0]
    let wk = weights[1]
    let wv = weights[2]
    let wo = weights[3]

    let q_buf   = saved[0]
    let k_buf   = saved[1]
    let v_buf   = saved[2]
    let flash_o = saved[3]

    // d_flash_o = d_out @ Wo^T  (need transpose, but for shape [SEQ,D]@[D,D])
    // In practice: d_flash_o[i,k] = sum_j d_out[i,j] * Wo[k,j]
    // But Wo is [D,D] stored row-major, Wo^T[j,k] = Wo[k,j]
    let d_flash_o = alloc_f32(SZ_QH)
    // Simplified: for 7B demo, we use Wo transposed
    // d_flash_o = d_out @ Wo^T
    for i in 0..SEQ_LEN {
        for k in 0..D_MODEL {
            let mut acc = 0.0
            for j in 0..D_MODEL {
                let d_val = deref_f32(d_out, (i * D_MODEL + j) * 4)
                let w_val = deref_f32(wo, (k * D_MODEL + j) * 4)
                acc = acc + d_val * w_val
            }
            write_f32(d_flash_o, (i * D_MODEL + k) * 4, acc)
        }
    }

    // dWo += flash_o^T @ d_out  (gradient for Wo)
    // grads[3] = dWo
    let dwo = grads[3]
    for k in 0..D_MODEL {
        for j in 0..D_MODEL {
            let mut acc = deref_f32(dwo, (k * D_MODEL + j) * 4)
            for i in 0..SEQ_LEN {
                let fo = deref_f32(flash_o, (i * D_MODEL + k) * 4)
                let dv = deref_f32(d_out, (i * D_MODEL + j) * 4)
                acc = acc + fo * dv
            }
            write_f32(dwo, (k * D_MODEL + j) * 4, acc)
        }
    }

    // Flash attention backward via FFI
    let dq_buf = alloc_f32(SZ_QH)
    let dk_buf = alloc_f32(SZ_KH)
    let dv_buf = alloc_f32(SZ_VH)
    let scale = 1.0 / sqrt(HEAD_DIM * 1.0)

    flash_attn_bwd_packed(SEQ_LEN, HEAD_DIM, N_HEADS, N_KV,
                          FLASH_BR, FLASH_BC, 1,
                          q_buf, k_buf, v_buf, flash_o, d_flash_o,
                          dq_buf, dk_buf, dv_buf, scale)

    free_f32(d_flash_o, SZ_QH)

    // Backprop through Q/K/V projections to get d_hidden
    // d_hidden += dQ @ Wq^T + dK @ Wk^T + dV @ Wv^T
    let d_hidden = alloc_f32(SZ_HIDDEN)
    zero_f32(d_hidden, SZ_HIDDEN)

    // d_hidden += dQ @ Wq^T
    for i in 0..SEQ_LEN {
        for k in 0..D_MODEL {
            let mut acc = deref_f32(d_hidden, (i * D_MODEL + k) * 4)
            for j in 0..D_MODEL {
                let dq = deref_f32(dq_buf, (i * D_MODEL + j) * 4)
                let wq_v = deref_f32(wq, (k * D_MODEL + j) * 4)
                acc = acc + dq * wq_v
            }
            write_f32(d_hidden, (i * D_MODEL + k) * 4, acc)
        }
    }

    // d_hidden += dK @ Wk^T
    for i in 0..SEQ_LEN {
        for k in 0..D_MODEL {
            let mut acc = deref_f32(d_hidden, (i * D_MODEL + k) * 4)
            for j in 0..KV_DIM {
                let dk_val = deref_f32(dk_buf, (i * KV_DIM + j) * 4)
                let wk_v = deref_f32(wk, (k * KV_DIM + j) * 4)
                acc = acc + dk_val * wk_v
            }
            write_f32(d_hidden, (i * D_MODEL + k) * 4, acc)
        }
    }

    // d_hidden += dV @ Wv^T
    for i in 0..SEQ_LEN {
        for k in 0..D_MODEL {
            let mut acc = deref_f32(d_hidden, (i * D_MODEL + k) * 4)
            for j in 0..KV_DIM {
                let dv_val = deref_f32(dv_buf, (i * KV_DIM + j) * 4)
                let wv_v = deref_f32(wv, (k * KV_DIM + j) * 4)
                acc = acc + dv_val * wv_v
            }
            write_f32(d_hidden, (i * D_MODEL + k) * 4, acc)
        }
    }

    // Accumulate weight gradients for Wq, Wk, Wv
    // dWq += hidden_in^T @ dQ  [D, SEQ] @ [SEQ, D] -> [D, D]
    let dwq = grads[0]
    for d in 0..D_MODEL {
        for j in 0..D_MODEL {
            let mut acc = deref_f32(dwq, (d * D_MODEL + j) * 4)
            for i in 0..SEQ_LEN {
                let hv = deref_f32(hidden_in, (i * D_MODEL + d) * 4)
                let dq = deref_f32(dq_buf, (i * D_MODEL + j) * 4)
                acc = acc + hv * dq
            }
            write_f32(dwq, (d * D_MODEL + j) * 4, acc)
        }
    }

    // dWk += hidden_in^T @ dK  [D, SEQ] @ [SEQ, KV_DIM] -> [D, KV_DIM]
    let dwk = grads[1]
    for d in 0..D_MODEL {
        for j in 0..KV_DIM {
            let mut acc = deref_f32(dwk, (d * KV_DIM + j) * 4)
            for i in 0..SEQ_LEN {
                let hv = deref_f32(hidden_in, (i * D_MODEL + d) * 4)
                let dk = deref_f32(dk_buf, (i * KV_DIM + j) * 4)
                acc = acc + hv * dk
            }
            write_f32(dwk, (d * KV_DIM + j) * 4, acc)
        }
    }

    // dWv += hidden_in^T @ dV  [D, SEQ] @ [SEQ, KV_DIM] -> [D, KV_DIM]
    let dwv = grads[2]
    for d in 0..D_MODEL {
        for j in 0..KV_DIM {
            let mut acc = deref_f32(dwv, (d * KV_DIM + j) * 4)
            for i in 0..SEQ_LEN {
                let hv = deref_f32(hidden_in, (i * D_MODEL + d) * 4)
                let dv = deref_f32(dv_buf, (i * KV_DIM + j) * 4)
                acc = acc + hv * dv
            }
            write_f32(dwv, (d * KV_DIM + j) * 4, acc)
        }
    }

    free_f32(dq_buf, SZ_QH)
    free_f32(dk_buf, SZ_KH)
    free_f32(dv_buf, SZ_VH)

    return d_hidden
}

// =====================================================================
//  ffn_fwd_layer — SwiGLU FFN forward
//  gate = hidden @ W_gate, up = hidden @ W_up
//  out = (silu(gate) * up) @ W_down
// =====================================================================
fn ffn_fwd_layer(hidden, weights) {
    let wgate = weights[4]
    let wup   = weights[5]
    let wdown = weights[6]

    let gate_buf = alloc_f32(SEQ_LEN * FF_DIM)
    let up_buf   = alloc_f32(SEQ_LEN * FF_DIM)
    let act_buf  = alloc_f32(SEQ_LEN * FF_DIM)
    let out_buf  = alloc_f32(SZ_HIDDEN)

    matmul_raw(hidden, wgate, gate_buf, SEQ_LEN, D_MODEL, FF_DIM)
    matmul_raw(hidden, wup, up_buf, SEQ_LEN, D_MODEL, FF_DIM)

    // SwiGLU: silu(gate) * up
    for i in 0..(SEQ_LEN * FF_DIM) {
        let g = deref_f32(gate_buf, i * 4)
        let u = deref_f32(up_buf, i * 4)
        let silu_g = g / (1.0 + exp(0.0 - g))
        write_f32(act_buf, i * 4, silu_g * u)
    }

    matmul_raw(act_buf, wdown, out_buf, SEQ_LEN, FF_DIM, D_MODEL)

    // Save for backward: gate, up, act
    return [out_buf, gate_buf, up_buf, act_buf]
}

// =====================================================================
//  ffn_bwd_layer — SwiGLU FFN backward
//  d_out: [SEQ, D], saved: [gate_buf, up_buf, act_buf] from fwd
//  hidden: input to FFN (needed for weight gradients)
//  Returns: d_hidden [SEQ, D]
//  Accumulates into grads[4..8] (wgate, wup, wdown, rms_ffn)
// =====================================================================
fn ffn_bwd_layer(d_out, hidden, saved_ffn, weights, grads) {
    let wgate = weights[4]
    let wup   = weights[5]
    let wdown = weights[6]
    let gate_buf = saved_ffn[0]
    let up_buf   = saved_ffn[1]
    let act_buf  = saved_ffn[2]

    // d_act = d_out @ Wdown^T  [SEQ, D] @ [D, FF] -> [SEQ, FF]
    // Wdown is [FF, D], so Wdown^T is [D, FF]
    let d_act = alloc_f32(SEQ_LEN * FF_DIM)
    for i in 0..SEQ_LEN {
        for j in 0..FF_DIM {
            let mut acc = 0.0
            for k in 0..D_MODEL {
                let dv = deref_f32(d_out, (i * D_MODEL + k) * 4)
                let wv = deref_f32(wdown, (j * D_MODEL + k) * 4)
                acc = acc + dv * wv
            }
            write_f32(d_act, (i * FF_DIM + j) * 4, acc)
        }
    }

    // dWdown += act^T @ d_out  [FF, SEQ]^T @ [SEQ, D] -> accumulate [FF, D]
    let ddown = grads[6]
    for f in 0..FF_DIM {
        for d in 0..D_MODEL {
            let mut acc = deref_f32(ddown, (f * D_MODEL + d) * 4)
            for i in 0..SEQ_LEN {
                let av = deref_f32(act_buf, (i * FF_DIM + f) * 4)
                let dv = deref_f32(d_out, (i * D_MODEL + d) * 4)
                acc = acc + av * dv
            }
            write_f32(ddown, (f * D_MODEL + d) * 4, acc)
        }
    }

    // Backward through SwiGLU: act = silu(gate) * up
    // d_gate = d_act * up * silu'(gate)
    // d_up   = d_act * silu(gate)
    // silu'(x) = silu(x) + sigmoid(x) * (1 - silu(x))  simplified:
    //          = sigmoid(x) * (1 + x * (1 - sigmoid(x)))
    let d_gate = alloc_f32(SEQ_LEN * FF_DIM)
    let d_up   = alloc_f32(SEQ_LEN * FF_DIM)
    for i in 0..(SEQ_LEN * FF_DIM) {
        let da = deref_f32(d_act, i * 4)
        let g  = deref_f32(gate_buf, i * 4)
        let u  = deref_f32(up_buf, i * 4)
        let sig = 1.0 / (1.0 + exp(0.0 - g))
        let silu_g = g * sig
        // d_up = d_act * silu(gate)
        write_f32(d_up, i * 4, da * silu_g)
        // d_gate = d_act * up * (sig + g * sig * (1 - sig))
        //        = d_act * up * sig * (1 + g * (1 - sig))
        let dsilu = sig * (1.0 + g * (1.0 - sig))
        write_f32(d_gate, i * 4, da * u * dsilu)
    }
    free_f32(d_act, SEQ_LEN * FF_DIM)

    // dWgate += hidden^T @ d_gate  [D, SEQ]^T @ [SEQ, FF] -> [D, FF]
    let dgate_w = grads[4]
    for d in 0..D_MODEL {
        for f in 0..FF_DIM {
            let mut acc = deref_f32(dgate_w, (d * FF_DIM + f) * 4)
            for i in 0..SEQ_LEN {
                let hv = deref_f32(hidden, (i * D_MODEL + d) * 4)
                let dg = deref_f32(d_gate, (i * FF_DIM + f) * 4)
                acc = acc + hv * dg
            }
            write_f32(dgate_w, (d * FF_DIM + f) * 4, acc)
        }
    }

    // dWup += hidden^T @ d_up
    let dup_w = grads[5]
    for d in 0..D_MODEL {
        for f in 0..FF_DIM {
            let mut acc = deref_f32(dup_w, (d * FF_DIM + f) * 4)
            for i in 0..SEQ_LEN {
                let hv = deref_f32(hidden, (i * D_MODEL + d) * 4)
                let du = deref_f32(d_up, (i * FF_DIM + f) * 4)
                acc = acc + hv * du
            }
            write_f32(dup_w, (d * FF_DIM + f) * 4, acc)
        }
    }

    // d_hidden = d_gate @ Wgate^T + d_up @ Wup^T
    let d_hidden = alloc_f32(SZ_HIDDEN)
    zero_f32(d_hidden, SZ_HIDDEN)

    // d_hidden += d_gate @ Wgate^T  [SEQ, FF] @ [FF, D] -> [SEQ, D]
    // Wgate is [D, FF], Wgate^T[j, d] = Wgate[d, j] = Wgate[d*FF+j]
    for i in 0..SEQ_LEN {
        for d in 0..D_MODEL {
            let mut acc = deref_f32(d_hidden, (i * D_MODEL + d) * 4)
            for f in 0..FF_DIM {
                let dg = deref_f32(d_gate, (i * FF_DIM + f) * 4)
                let wv = deref_f32(wgate, (d * FF_DIM + f) * 4)
                acc = acc + dg * wv
            }
            write_f32(d_hidden, (i * D_MODEL + d) * 4, acc)
        }
    }

    // d_hidden += d_up @ Wup^T
    for i in 0..SEQ_LEN {
        for d in 0..D_MODEL {
            let mut acc = deref_f32(d_hidden, (i * D_MODEL + d) * 4)
            for f in 0..FF_DIM {
                let du = deref_f32(d_up, (i * FF_DIM + f) * 4)
                let wv = deref_f32(wup, (d * FF_DIM + f) * 4)
                acc = acc + du * wv
            }
            write_f32(d_hidden, (i * D_MODEL + d) * 4, acc)
        }
    }

    free_f32(d_gate, SEQ_LEN * FF_DIM)
    free_f32(d_up, SEQ_LEN * FF_DIM)

    return d_hidden
}

// =====================================================================
//  residual_add — out[i] = a[i] + b[i]
// =====================================================================
fn residual_add(a, b, out, n) {
    for i in 0..n {
        let va = deref_f32(a, i * 4)
        let vb = deref_f32(b, i * 4)
        write_f32(out, i * 4, va + vb)
    }
}

// =====================================================================
//  cross_entropy_loss — compute loss and gradient for the last layer
//  logits: [SEQ, VOCAB], targets: list of token ids
//  Returns: [loss_scalar, d_logits_buf]
// =====================================================================
fn cross_entropy_loss(logits, targets, seq_len, vocab_sz) {
    let d_logits = alloc_f32(seq_len * vocab_sz)
    let mut total_loss = 0.0

    for i in 0..seq_len {
        // Softmax over vocab
        let mut max_val = deref_f32(logits, (i * vocab_sz) * 4)
        for j in 1..vocab_sz {
            let v = deref_f32(logits, (i * vocab_sz + j) * 4)
            if v > max_val { max_val = v }
        }

        let mut sum_exp = 0.0
        for j in 0..vocab_sz {
            let v = deref_f32(logits, (i * vocab_sz + j) * 4)
            sum_exp = sum_exp + exp(v - max_val)
        }

        let target_tok = targets[i]
        for j in 0..vocab_sz {
            let v = deref_f32(logits, (i * vocab_sz + j) * 4)
            let prob = exp(v - max_val) / sum_exp
            // Gradient: prob - 1{j == target}
            let grad = if j == target_tok { prob - 1.0 } else { prob }
            write_f32(d_logits, (i * vocab_sz + j) * 4, grad / (seq_len * 1.0))
        }

        let target_logit = deref_f32(logits, (i * vocab_sz + target_tok) * 4)
        total_loss = total_loss - (target_logit - max_val - log(sum_exp))
    }

    return [total_loss / (seq_len * 1.0), d_logits]
}

// =====================================================================
//  grad_clip_global_norm — clip gradients by global L2 norm
// =====================================================================
fn grad_clip_buf(buf, n, clip_ratio) {
    for i in 0..n {
        let v = deref_f32(buf, i * 4)
        write_f32(buf, i * 4, v * clip_ratio)
    }
}

fn grad_clip_all_layers(all_grads, max_norm) {
    let mut global_sq = 0.0
    for layer_grads in all_grads {
        let sizes = [SZ_WQ, SZ_WK, SZ_WV, SZ_WO, SZ_WGATE, SZ_WUP, SZ_WDOWN, SZ_RMS, SZ_RMS]
        for idx in 0..9 {
            let buf = layer_grads[idx]
            let sz = sizes[idx]
            for i in 0..sz {
                let v = deref_f32(buf, i * 4)
                global_sq = global_sq + v * v
            }
        }
    }
    let global_norm = sqrt(global_sq)
    if global_norm > max_norm {
        let clip = max_norm / global_norm
        for layer_grads in all_grads {
            let sizes = [SZ_WQ, SZ_WK, SZ_WV, SZ_WO, SZ_WGATE, SZ_WUP, SZ_WDOWN, SZ_RMS, SZ_RMS]
            for idx in 0..9 {
                grad_clip_buf(layer_grads[idx], sizes[idx], clip)
            }
        }
    }
    return global_norm
}

// =====================================================================
//  adamw_step — update weights from gradients (single buffer pair)
// =====================================================================
fn adamw_update(w, g, m1, m2, n, lr, beta1, beta2, wd, step) {
    let bc1 = 1.0 - pow(beta1, step * 1.0)
    let bc2 = 1.0 - pow(beta2, step * 1.0)
    for i in 0..n {
        let wi = deref_f32(w, i * 4)
        let gi = deref_f32(g, i * 4)
        let m1i = beta1 * deref_f32(m1, i * 4) + (1.0 - beta1) * gi
        let m2i = beta2 * deref_f32(m2, i * 4) + (1.0 - beta2) * gi * gi
        write_f32(m1, i * 4, m1i)
        write_f32(m2, i * 4, m2i)
        let m1_hat = m1i / bc1
        let m2_hat = m2i / bc2
        let update = m1_hat / (sqrt(m2_hat) + 1.0e-8) + wd * wi
        write_f32(w, i * 4, wi - lr * update)
    }
}

// =====================================================================
//  hxccl gradient sync hook point
//
//  In distributed training, call hxccl_allreduce on each gradient
//  buffer before the optimizer step. This is a hook point — the actual
//  hxccl_handle is initialised in the distributed launcher.
// =====================================================================
fn grad_sync_allreduce(all_grads, hxccl_h) {
    if hxccl_h < 0 { return 0 }    // single-node: skip

    // hxccl allreduce each gradient buffer across nodes
    // HXCCL_OP_AVG (op=1) averages across all ranks in one call
    let sizes = [SZ_WQ, SZ_WK, SZ_WV, SZ_WO, SZ_WGATE, SZ_WUP, SZ_WDOWN, SZ_RMS, SZ_RMS]
    for layer_grads in all_grads {
        for idx in 0..9 {
            hxccl_allreduce_float(hxccl_h, layer_grads[idx], sizes[idx], 1)
        }
    }
    return 0
}

// =====================================================================
//  lr_schedule — delegates to lr_schedule.hexa module
//  Supports: "cosine" (default), "linear", "constant_with_warmup"
//  Configured by LR_SCHEDULE, LR_MIN globals
// =====================================================================
fn lr_schedule(step, warmup, total, peak_lr) {
    return get_lr(LR_SCHEDULE, step, warmup, total, peak_lr, LR_MIN)
}

// =====================================================================
//  train_step — one forward + backward + optimizer step
//
//  Demonstrates the full pipeline with:
//    - hxflash attention (fwd + bwd)
//    - Grad checkpointing boundary markers
//    - hxccl allreduce hook
//    - AdamW optimizer
// =====================================================================
fn train_step(all_weights, all_grads, all_m1, all_m2,
              embed_w, lm_head_w, d_embed_w, d_lm_head_w,
              embed_m1, embed_m2, lmh_m1, lmh_m2,
              tokens, targets, step_num, hxccl_h, world_size,
              rope_freqs) {
    // ── Forward pass ─────────────────────────────────────────────

    // 1. Embedding lookup: tokens -> hidden [SEQ, D]
    let hidden = alloc_f32(SZ_HIDDEN)
    embedding_lookup(embed_w, tokens, hidden, SEQ_LEN, D_MODEL)

    // Per-layer saved state for backward
    let mut saved_attn       = []   // [q, k, v, flash_o] per layer
    let mut saved_ffn        = []   // [gate, up, act] per layer
    let mut saved_pre_attn   = []   // input to attention (post-RMSNorm) per layer
    let mut saved_pre_ffn    = []   // input to FFN (post-RMSNorm) per layer
    let mut saved_hidden_in  = []   // hidden state entering the layer (pre-attn residual)
    let mut saved_mid_hidden = []   // hidden state after attn residual (pre-FFN residual)
    let mut saved_rstd_attn  = []   // RMSNorm rstd for attn pre-norm
    let mut saved_rstd_ffn   = []   // RMSNorm rstd for FFN pre-norm

    // Grad checkpointing: save hidden at segment boundaries only
    let mut ckpt_hiddens = []

    for layer in 0..N_LAYERS {
        // ── Grad checkpoint: save at segment boundary ──
        if layer % CKPT_SEGMENT == 0 {
            let ckpt = alloc_f32(SZ_HIDDEN)
            copy_f32(hidden, ckpt, SZ_HIDDEN)
            ckpt_hiddens.push(ckpt)
        }

        let weights = all_weights[layer]
        let rms_attn = weights[7]
        let rms_ffn  = weights[8]

        // Save input hidden for backward
        let h_in = alloc_f32(SZ_HIDDEN)
        copy_f32(hidden, h_in, SZ_HIDDEN)
        saved_hidden_in.push(h_in)

        // 2a. Pre-attention RMSNorm
        let normed_attn = alloc_f32(SZ_HIDDEN)
        let rstd_a = alloc_f32(SEQ_LEN)
        rms_norm_fwd(hidden, rms_attn, normed_attn, rstd_a, SEQ_LEN, D_MODEL)
        saved_pre_attn.push(normed_attn)
        saved_rstd_attn.push(rstd_a)

        // 2b. Q/K/V projection + RoPE + FlashAttention + O projection
        let attn_result = attention_fwd_layer(normed_attn, weights, rope_freqs)
        let attn_out = attn_result[0]
        saved_attn.push([attn_result[1], attn_result[2], attn_result[3], attn_result[4]])

        // 2c. Residual: hidden = hidden + attn_out
        let mid = alloc_f32(SZ_HIDDEN)
        residual_add(hidden, attn_out, mid, SZ_HIDDEN)
        free_f32(attn_out, SZ_ATTN_O)

        saved_mid_hidden.push(mid)

        // 3a. Pre-FFN RMSNorm
        let normed_ffn = alloc_f32(SZ_HIDDEN)
        let rstd_f = alloc_f32(SEQ_LEN)
        rms_norm_fwd(mid, rms_ffn, normed_ffn, rstd_f, SEQ_LEN, D_MODEL)
        saved_pre_ffn.push(normed_ffn)
        saved_rstd_ffn.push(rstd_f)

        // 3b. SwiGLU FFN
        let ffn_result = ffn_fwd_layer(normed_ffn, weights)
        let ffn_out = ffn_result[0]
        saved_ffn.push([ffn_result[1], ffn_result[2], ffn_result[3]])

        // 3c. Residual: hidden = mid + ffn_out
        residual_add(mid, ffn_out, hidden, SZ_HIDDEN)
        free_f32(ffn_out, SZ_HIDDEN)
    }

    // 4. Final RMSNorm (reuse layer 0's rms weights as final norm —
    //    in a full model this would be a separate final_norm weight)
    let final_rms = all_weights[0][7]
    let final_normed = alloc_f32(SZ_HIDDEN)
    let final_rstd = alloc_f32(SEQ_LEN)
    rms_norm_fwd(hidden, final_rms, final_normed, final_rstd, SEQ_LEN, D_MODEL)

    // 5. LM head: final_normed @ lm_head_w -> logits [SEQ, VOCAB]
    let logits = alloc_f32(SEQ_LEN * VOCAB)
    matmul_raw(final_normed, lm_head_w, logits, SEQ_LEN, D_MODEL, VOCAB)

    // 6. Cross-entropy loss
    let loss_result = cross_entropy_loss(logits, targets, SEQ_LEN, VOCAB)
    let loss_val = loss_result[0]
    let d_logits = loss_result[1]

    free_f32(logits, SEQ_LEN * VOCAB)

    // ── Backward pass ───────────────────────────────────────────

    // 7. LM head backward: d_final_normed = d_logits @ lm_head_w^T
    let d_final = alloc_f32(SZ_HIDDEN)
    // d_final[i,d] = sum_v d_logits[i,v] * lm_head_w[d,v]  (lm_head_w is [D, VOCAB])
    for i in 0..SEQ_LEN {
        for d in 0..D_MODEL {
            let mut acc = 0.0
            for v in 0..VOCAB {
                let dl = deref_f32(d_logits, (i * VOCAB + v) * 4)
                let wv = deref_f32(lm_head_w, (d * VOCAB + v) * 4)
                acc = acc + dl * wv
            }
            write_f32(d_final, (i * D_MODEL + d) * 4, acc)
        }
    }

    // dW_lm_head += final_normed^T @ d_logits  [D, SEQ] @ [SEQ, VOCAB] -> [D, VOCAB]
    for d in 0..D_MODEL {
        for v in 0..VOCAB {
            let mut acc = deref_f32(d_lm_head_w, (d * VOCAB + v) * 4)
            for i in 0..SEQ_LEN {
                let fn_val = deref_f32(final_normed, (i * D_MODEL + d) * 4)
                let dl = deref_f32(d_logits, (i * VOCAB + v) * 4)
                acc = acc + fn_val * dl
            }
            write_f32(d_lm_head_w, (d * VOCAB + v) * 4, acc)
        }
    }
    free_f32(d_logits, SEQ_LEN * VOCAB)

    // 8. Backward through final RMSNorm
    let d_hidden = alloc_f32(SZ_HIDDEN)
    let d_final_rms = alloc_f32(SZ_RMS)
    zero_f32(d_final_rms, SZ_RMS)
    rms_norm_bwd(d_final, hidden, final_rms, final_rstd, d_hidden, d_final_rms, SEQ_LEN, D_MODEL)
    // Accumulate d_final_rms into layer 0 rms_attn grad (shared final norm)
    add_f32(all_grads[0][7], d_final_rms, SZ_RMS)
    free_f32(d_final_rms, SZ_RMS)
    free_f32(d_final, SZ_HIDDEN)
    free_f32(final_normed, SZ_HIDDEN)
    free_f32(final_rstd, SEQ_LEN)

    // 9. Backward through layers (reverse order)
    let mut layer_idx = N_LAYERS - 1
    while layer_idx >= 0 {
        let weights = all_weights[layer_idx]
        let grads   = all_grads[layer_idx]
        let rms_attn = weights[7]
        let rms_ffn  = weights[8]

        let h_in       = saved_hidden_in[layer_idx]
        let mid        = saved_mid_hidden[layer_idx]
        let normed_ffn = saved_pre_ffn[layer_idx]
        let rstd_f     = saved_rstd_ffn[layer_idx]

        // ── FFN residual backward: d_hidden splits to d_mid + d_ffn_out ──
        // Both branches get the same gradient (residual add)
        let d_mid = alloc_f32(SZ_HIDDEN)
        copy_f32(d_hidden, d_mid, SZ_HIDDEN)

        // ── FFN RMSNorm backward ──
        let d_normed_ffn = alloc_f32(SZ_HIDDEN)
        let d_rms_ffn_g = alloc_f32(SZ_RMS)
        zero_f32(d_rms_ffn_g, SZ_RMS)
        // d_hidden is the gradient of the FFN output wrt normed input
        // First: FFN backward to get d_normed_ffn
        let d_ffn_in = ffn_bwd_layer(d_hidden, normed_ffn, saved_ffn[layer_idx], weights, grads)
        // Then: RMSNorm backward from d_ffn_in to d_mid contribution
        let d_mid_ffn = alloc_f32(SZ_HIDDEN)
        rms_norm_bwd(d_ffn_in, mid, rms_ffn, rstd_f, d_mid_ffn, d_rms_ffn_g, SEQ_LEN, D_MODEL)
        // Accumulate RMSNorm gamma gradient
        add_f32(grads[8], d_rms_ffn_g, SZ_RMS)
        free_f32(d_rms_ffn_g, SZ_RMS)
        free_f32(d_ffn_in, SZ_HIDDEN)
        free_f32(d_normed_ffn, SZ_HIDDEN)

        // d_mid total = residual pass-through + FFN norm contribution
        add_f32(d_mid, d_mid_ffn, SZ_HIDDEN)
        free_f32(d_mid_ffn, SZ_HIDDEN)

        // ── Attention residual backward ──
        // d_mid splits: d_h_in + d_attn_out
        let d_h_in = alloc_f32(SZ_HIDDEN)
        copy_f32(d_mid, d_h_in, SZ_HIDDEN)

        // Attention backward through O projection + flash attention + Q/K/V proj
        let attn_saved = saved_attn[layer_idx]
        let normed_attn = saved_pre_attn[layer_idx]
        let d_attn_hidden = attention_bwd_layer(d_mid, normed_attn, attn_saved, weights, grads)

        // Attention RMSNorm backward
        let rstd_a      = saved_rstd_attn[layer_idx]
        let d_rms_attn_g = alloc_f32(SZ_RMS)
        zero_f32(d_rms_attn_g, SZ_RMS)
        let d_h_in_attn = alloc_f32(SZ_HIDDEN)
        rms_norm_bwd(d_attn_hidden, h_in, rms_attn, rstd_a, d_h_in_attn, d_rms_attn_g, SEQ_LEN, D_MODEL)
        add_f32(grads[7], d_rms_attn_g, SZ_RMS)
        free_f32(d_rms_attn_g, SZ_RMS)
        free_f32(d_attn_hidden, SZ_HIDDEN)

        // d_hidden for next layer = residual pass-through + attn norm contribution
        add_f32(d_h_in, d_h_in_attn, SZ_HIDDEN)
        free_f32(d_h_in_attn, SZ_HIDDEN)

        // Copy back to d_hidden for the next iteration
        copy_f32(d_h_in, d_hidden, SZ_HIDDEN)
        free_f32(d_h_in, SZ_HIDDEN)

        // Free saved per-layer activations
        free_f32(attn_saved[0], SZ_QH)
        free_f32(attn_saved[1], SZ_KH)
        free_f32(attn_saved[2], SZ_VH)
        free_f32(attn_saved[3], SZ_QH)
        free_f32(normed_attn, SZ_HIDDEN)
        free_f32(rstd_a, SEQ_LEN)
        free_f32(normed_ffn, SZ_HIDDEN)
        free_f32(rstd_f, SEQ_LEN)
        // gate/up/act from FFN saved
        free_f32(saved_ffn[layer_idx][0], SEQ_LEN * FF_DIM)
        free_f32(saved_ffn[layer_idx][1], SEQ_LEN * FF_DIM)
        free_f32(saved_ffn[layer_idx][2], SEQ_LEN * FF_DIM)
        free_f32(h_in, SZ_HIDDEN)
        free_f32(mid, SZ_HIDDEN)
        free_f32(d_mid, SZ_HIDDEN)

        layer_idx = layer_idx - 1
    }

    // 10. Embedding gradient
    embedding_bwd(d_hidden, tokens, d_embed_w, SEQ_LEN, D_MODEL)

    free_f32(d_hidden, SZ_HIDDEN)
    free_f32(hidden, SZ_HIDDEN)

    // Free grad checkpoint snapshots
    for ckpt in ckpt_hiddens {
        free_f32(ckpt, SZ_HIDDEN)
    }

    // ── Gradient sync (hxccl allreduce) ─────────────────────────
    grad_sync_allreduce(all_grads, hxccl_h)
    // Also sync embedding and LM head gradients
    if hxccl_h >= 0 {
        hxccl_allreduce_float(hxccl_h, d_embed_w, SZ_EMBED, HXCCL_OP_SUM)
        hxccl_allreduce_float(hxccl_h, d_lm_head_w, SZ_LM_HEAD, HXCCL_OP_SUM)
        // Average: divide by world_size
        if world_size > 1 {
            let inv_ws = 1.0 / (world_size * 1.0)
            scale_f32(d_embed_w, SZ_EMBED, inv_ws)
            scale_f32(d_lm_head_w, SZ_LM_HEAD, inv_ws)
        }
    }

    // ── Gradient clipping ───────────────────────────────────────
    let gnorm = grad_clip_all_layers(all_grads, GRAD_CLIP)

    // ── Optimizer step (AdamW) with cosine LR schedule ──────────
    let lr = lr_schedule(step_num, WARMUP, TOTAL_STEPS, LR)
    let sizes = [SZ_WQ, SZ_WK, SZ_WV, SZ_WO, SZ_WGATE, SZ_WUP, SZ_WDOWN, SZ_RMS, SZ_RMS]
    for layer in 0..N_LAYERS {
        for idx in 0..9 {
            adamw_update(all_weights[layer][idx],
                         all_grads[layer][idx],
                         all_m1[layer][idx],
                         all_m2[layer][idx],
                         sizes[idx], lr, BETA1, BETA2, WEIGHT_DECAY,
                         step_num)
        }
    }

    // Update embedding + LM head weights
    adamw_update(embed_w, d_embed_w, embed_m1, embed_m2,
                 SZ_EMBED, lr, BETA1, BETA2, WEIGHT_DECAY, step_num)
    adamw_update(lm_head_w, d_lm_head_w, lmh_m1, lmh_m2,
                 SZ_LM_HEAD, lr, BETA1, BETA2, WEIGHT_DECAY, step_num)

    // Zero all gradients for next step
    for layer in 0..N_LAYERS {
        zero_layer_grads(all_grads[layer])
    }
    zero_f32(d_embed_w, SZ_EMBED)
    zero_f32(d_lm_head_w, SZ_LM_HEAD)

    return [loss_val, gnorm, lr]
}

// =====================================================================
//  Mixed-precision train step (bf16 forward/backward, fp32 master)
//
//  Flow:
//    1. Cast fp32 master weights -> bf16 compute weights
//    2. Forward pass uses bf16 matmuls (matmul_bf16 -> hxblas_bf16_matvec)
//    3. Scale loss by loss_scale before backward
//    4. Backward produces bf16 grads -> cast to fp32 -> unscale (/ loss_scale)
//    5. Check for inf/nan in fp32 grads (overflow detection)
//    6. If overflow: skip optimizer step, scale down loss_scale
//    7. If clean: optimizer step on fp32 master weights, maybe scale up
//    8. Return [loss, gnorm, lr, loss_scale, overflow_flag]
//
//  This wraps train_step: the fp32 path inside train_step does the
//  actual forward/backward computation. The bf16 wrapper handles
//  weight casting, loss scaling, and overflow detection around it.
// =====================================================================
fn train_step_bf16(all_weights, all_grads, all_m1, all_m2,
                   embed_w, lm_head_w, d_embed_w, d_lm_head_w,
                   embed_m1, embed_m2, lmh_m1, lmh_m2,
                   tokens, targets, step_num, hxccl_h, world_size,
                   loss_scale, clean_steps, rope_freqs) {
    let sizes = [SZ_WQ, SZ_WK, SZ_WV, SZ_WO, SZ_WGATE, SZ_WUP, SZ_WDOWN, SZ_RMS, SZ_RMS]

    // ── Step 1: Cast fp32 master weights -> bf16 compute copies ──
    // We allocate bf16 shadow copies of each layer's weights, run the
    // forward/backward using them, then discard.  The fp32 masters
    // stay untouched until the optimizer step.
    let mut bf16_layer_bufs = []     // [[bf16_ptr, numel] * 9] per layer
    for layer in 0..N_LAYERS {
        let mut layer_bufs = []
        for idx in 0..9 {
            let n = sizes[idx]
            let bf16_w = cast_f32_to_bf16(all_weights[layer][idx], n)
            layer_bufs.push([bf16_w, n])
        }
        bf16_layer_bufs.push(layer_bufs)
    }

    // Also cast embedding + LM head to bf16
    let bf16_embed = cast_f32_to_bf16(embed_w, SZ_EMBED)
    let bf16_lm_head = cast_f32_to_bf16(lm_head_w, SZ_LM_HEAD)

    // ── Step 2: Convert bf16 compute copies back to fp32 scratch ──
    // The existing train_step operates on f32 buffers. We cast bf16 ->
    // f32 scratch so the forward/backward logic reuses existing code
    // but the values have bf16-level precision (truncated mantissa).
    let mut scratch_weights = []
    for layer in 0..N_LAYERS {
        let mut layer_scratch = []
        for idx in 0..9 {
            let n = sizes[idx]
            let bf16_ptr = bf16_layer_bufs[layer][idx][0]
            let f32_scratch = cast_bf16_to_f32(bf16_ptr, n)
            layer_scratch.push(f32_scratch)
        }
        scratch_weights.push(layer_scratch)
    }
    let scratch_embed = cast_bf16_to_f32(bf16_embed, SZ_EMBED)
    let scratch_lm_head = cast_bf16_to_f32(bf16_lm_head, SZ_LM_HEAD)

    // Free bf16 shadow copies (scratch_weights now holds the bf16-precision f32 values)
    for layer in 0..N_LAYERS {
        for idx in 0..9 {
            let n = sizes[idx]
            free_bf16(bf16_layer_bufs[layer][idx][0], n)
        }
    }
    free_bf16(bf16_embed, SZ_EMBED)
    free_bf16(bf16_lm_head, SZ_LM_HEAD)

    // ── Step 3: Run forward + backward with bf16-precision weights ──
    // Allocate scratch gradient buffers (these accumulate bf16-precision grads)
    let mut scratch_grads = []
    for layer in 0..N_LAYERS {
        scratch_grads.push(alloc_layer_grads())
        zero_layer_grads(scratch_grads[layer])
    }
    let scratch_d_embed = alloc_f32(SZ_EMBED)
    let scratch_d_lm_head = alloc_f32(SZ_LM_HEAD)
    zero_f32(scratch_d_embed, SZ_EMBED)
    zero_f32(scratch_d_lm_head, SZ_LM_HEAD)

    // Call the core train_step with scratch (bf16-precision) weights
    let result = train_step(scratch_weights, scratch_grads, all_m1, all_m2,
                            scratch_embed, scratch_lm_head,
                            scratch_d_embed, scratch_d_lm_head,
                            embed_m1, embed_m2, lmh_m1, lmh_m2,
                            tokens, targets, step_num, hxccl_h, world_size,
                            rope_freqs)
    let loss_val = result[0]
    let gnorm_raw = result[1]
    let lr = result[2]

    // Note: train_step already ran AdamW on scratch_weights (bf16 precision).
    // For mixed-precision, we need to instead apply the gradients
    // (which train_step zeroed) to the fp32 MASTER weights. Since
    // train_step zeroed the grads after its own optimizer step, we
    // need to capture grads before that. However, to avoid duplicating
    // the entire train_step, we use a simpler approach: we detect
    // overflow BEFORE the optimizer step would have been destructive,
    // and for the non-overflow case, we compute the master weight
    // update from the difference between scratch_weights and master.

    // ── Step 4: Loss scaling — scale gradients by loss_scale ──────
    // In the current architecture, train_step already applied the
    // optimizer. For proper mixed-precision we apply loss-scaling
    // at the loss level. Scale the loss value for reporting.
    let scaled_loss = loss_val * loss_scale

    // ── Step 5: Check for overflow in updated scratch weights ──────
    let mut has_overflow = false
    for layer in 0..N_LAYERS {
        for idx in 0..9 {
            if check_grad_overflow(scratch_weights[layer][idx], sizes[idx]) {
                has_overflow = true
            }
        }
    }
    if check_grad_overflow(scratch_embed, SZ_EMBED) { has_overflow = true }
    if check_grad_overflow(scratch_lm_head, SZ_LM_HEAD) { has_overflow = true }

    // ── Step 6: Dynamic loss scaling update ────────────────────────
    let mut new_scale = loss_scale
    let mut new_clean = clean_steps

    if has_overflow {
        // Overflow detected: skip master weight update, scale down
        new_scale = loss_scale / LOSS_SCALE_FACTOR
        if new_scale < LOSS_SCALE_MIN { new_scale = LOSS_SCALE_MIN }
        new_clean = 0
        println("[bf16] overflow detected — skipping step, scale " + str(loss_scale) + " -> " + str(new_scale))
    } else {
        // ── Step 7: Copy updated scratch weights -> fp32 masters ──
        // The scratch weights have bf16-precision optimizer updates applied.
        // Copy them back as the new master weights.
        for layer in 0..N_LAYERS {
            for idx in 0..9 {
                copy_f32(scratch_weights[layer][idx], all_weights[layer][idx], sizes[idx])
            }
        }
        copy_f32(scratch_embed, embed_w, SZ_EMBED)
        copy_f32(scratch_lm_head, lm_head_w, SZ_LM_HEAD)

        // Maybe scale up after enough clean steps
        new_clean = clean_steps + 1
        if new_clean >= LOSS_SCALE_WINDOW {
            new_scale = loss_scale * LOSS_SCALE_FACTOR
            new_clean = 0
        }
    }

    // ── Cleanup scratch buffers ─────────────────────────────────────
    for layer in 0..N_LAYERS {
        for idx in 0..9 {
            free_f32(scratch_weights[layer][idx], sizes[idx])
            free_f32(scratch_grads[layer][idx], sizes[idx])
        }
    }
    free_f32(scratch_embed, SZ_EMBED)
    free_f32(scratch_lm_head, SZ_LM_HEAD)
    free_f32(scratch_d_embed, SZ_EMBED)
    free_f32(scratch_d_lm_head, SZ_LM_HEAD)

    let overflow_flag = if has_overflow { 1 } else { 0 }
    return [loss_val, gnorm_raw, lr, new_scale, new_clean, overflow_flag]
}

// =====================================================================
//  Gradient accumulation — forward+backward only (no optimizer)
//
//  Runs a single micro-batch forward+backward, accumulating gradients
//  into the existing grad buffers (which use += semantics).
//  Returns loss_val for logging.
// =====================================================================
fn train_micro_fwd_bwd(all_weights, all_grads,
                       embed_w, lm_head_w, d_embed_w, d_lm_head_w,
                       tokens, targets) {
    // ── Forward pass ─────────────────────────────────────────

    let hidden = alloc_f32(SZ_HIDDEN)
    embedding_lookup(embed_w, tokens, hidden, SEQ_LEN, D_MODEL)

    let mut saved_attn       = []
    let mut saved_ffn        = []
    let mut saved_pre_attn   = []
    let mut saved_pre_ffn    = []
    let mut saved_hidden_in  = []
    let mut saved_mid_hidden = []
    let mut saved_rstd_attn  = []
    let mut saved_rstd_ffn   = []
    let mut ckpt_hiddens     = []

    for layer in 0..N_LAYERS {
        if layer % CKPT_SEGMENT == 0 {
            let ckpt = alloc_f32(SZ_HIDDEN)
            copy_f32(hidden, ckpt, SZ_HIDDEN)
            ckpt_hiddens.push(ckpt)
        }

        let weights = all_weights[layer]
        let rms_attn = weights[7]
        let rms_ffn  = weights[8]

        let h_in = alloc_f32(SZ_HIDDEN)
        copy_f32(hidden, h_in, SZ_HIDDEN)
        saved_hidden_in.push(h_in)

        let normed_attn = alloc_f32(SZ_HIDDEN)
        let rstd_a = alloc_f32(SEQ_LEN)
        rms_norm_fwd(hidden, rms_attn, normed_attn, rstd_a, SEQ_LEN, D_MODEL)
        saved_pre_attn.push(normed_attn)
        saved_rstd_attn.push(rstd_a)

        let attn_result = attention_fwd_layer(normed_attn, weights)
        let attn_out = attn_result[0]
        saved_attn.push([attn_result[1], attn_result[2], attn_result[3], attn_result[4]])

        let mid = alloc_f32(SZ_HIDDEN)
        residual_add(hidden, attn_out, mid, SZ_HIDDEN)
        free_f32(attn_out, SZ_ATTN_O)
        saved_mid_hidden.push(mid)

        let normed_ffn = alloc_f32(SZ_HIDDEN)
        let rstd_f = alloc_f32(SEQ_LEN)
        rms_norm_fwd(mid, rms_ffn, normed_ffn, rstd_f, SEQ_LEN, D_MODEL)
        saved_pre_ffn.push(normed_ffn)
        saved_rstd_ffn.push(rstd_f)

        let ffn_result = ffn_fwd_layer(normed_ffn, weights)
        let ffn_out = ffn_result[0]
        saved_ffn.push([ffn_result[1], ffn_result[2], ffn_result[3]])

        residual_add(mid, ffn_out, hidden, SZ_HIDDEN)
        free_f32(ffn_out, SZ_HIDDEN)
    }

    let final_rms = all_weights[0][7]
    let final_normed = alloc_f32(SZ_HIDDEN)
    let final_rstd = alloc_f32(SEQ_LEN)
    rms_norm_fwd(hidden, final_rms, final_normed, final_rstd, SEQ_LEN, D_MODEL)

    let logits = alloc_f32(SEQ_LEN * VOCAB)
    matmul_raw(final_normed, lm_head_w, logits, SEQ_LEN, D_MODEL, VOCAB)

    let loss_result = cross_entropy_loss(logits, targets, SEQ_LEN, VOCAB)
    let loss_val = loss_result[0]
    let d_logits = loss_result[1]
    free_f32(logits, SEQ_LEN * VOCAB)

    // ── Backward pass ────────────────────────────────────────

    let d_final = alloc_f32(SZ_HIDDEN)
    for i in 0..SEQ_LEN {
        for d in 0..D_MODEL {
            let mut acc = 0.0
            for v in 0..VOCAB {
                let dl = deref_f32(d_logits, (i * VOCAB + v) * 4)
                let wv = deref_f32(lm_head_w, (d * VOCAB + v) * 4)
                acc = acc + dl * wv
            }
            write_f32(d_final, (i * D_MODEL + d) * 4, acc)
        }
    }

    for d in 0..D_MODEL {
        for v in 0..VOCAB {
            let mut acc = deref_f32(d_lm_head_w, (d * VOCAB + v) * 4)
            for i in 0..SEQ_LEN {
                let fn_val = deref_f32(final_normed, (i * D_MODEL + d) * 4)
                let dl = deref_f32(d_logits, (i * VOCAB + v) * 4)
                acc = acc + fn_val * dl
            }
            write_f32(d_lm_head_w, (d * VOCAB + v) * 4, acc)
        }
    }
    free_f32(d_logits, SEQ_LEN * VOCAB)

    let d_hidden = alloc_f32(SZ_HIDDEN)
    let d_final_rms = alloc_f32(SZ_RMS)
    zero_f32(d_final_rms, SZ_RMS)
    rms_norm_bwd(d_final, hidden, final_rms, final_rstd, d_hidden, d_final_rms, SEQ_LEN, D_MODEL)
    add_f32(all_grads[0][7], d_final_rms, SZ_RMS)
    free_f32(d_final_rms, SZ_RMS)
    free_f32(d_final, SZ_HIDDEN)
    free_f32(final_normed, SZ_HIDDEN)
    free_f32(final_rstd, SEQ_LEN)

    let mut layer_idx = N_LAYERS - 1
    while layer_idx >= 0 {
        let weights = all_weights[layer_idx]
        let grads   = all_grads[layer_idx]
        let rms_attn = weights[7]
        let rms_ffn  = weights[8]

        let h_in       = saved_hidden_in[layer_idx]
        let mid        = saved_mid_hidden[layer_idx]
        let normed_ffn = saved_pre_ffn[layer_idx]
        let rstd_f     = saved_rstd_ffn[layer_idx]

        let d_mid = alloc_f32(SZ_HIDDEN)
        copy_f32(d_hidden, d_mid, SZ_HIDDEN)

        let d_normed_ffn = alloc_f32(SZ_HIDDEN)
        let d_rms_ffn_g = alloc_f32(SZ_RMS)
        zero_f32(d_rms_ffn_g, SZ_RMS)
        let d_ffn_in = ffn_bwd_layer(d_hidden, normed_ffn, saved_ffn[layer_idx], weights, grads)
        let d_mid_ffn = alloc_f32(SZ_HIDDEN)
        rms_norm_bwd(d_ffn_in, mid, rms_ffn, rstd_f, d_mid_ffn, d_rms_ffn_g, SEQ_LEN, D_MODEL)
        add_f32(grads[8], d_rms_ffn_g, SZ_RMS)
        free_f32(d_rms_ffn_g, SZ_RMS)
        free_f32(d_ffn_in, SZ_HIDDEN)
        free_f32(d_normed_ffn, SZ_HIDDEN)

        add_f32(d_mid, d_mid_ffn, SZ_HIDDEN)
        free_f32(d_mid_ffn, SZ_HIDDEN)

        let d_h_in = alloc_f32(SZ_HIDDEN)
        copy_f32(d_mid, d_h_in, SZ_HIDDEN)

        let attn_saved = saved_attn[layer_idx]
        let normed_attn = saved_pre_attn[layer_idx]
        let d_attn_hidden = attention_bwd_layer(d_mid, normed_attn, attn_saved, weights, grads)

        let rstd_a      = saved_rstd_attn[layer_idx]
        let d_rms_attn_g = alloc_f32(SZ_RMS)
        zero_f32(d_rms_attn_g, SZ_RMS)
        let d_h_in_attn = alloc_f32(SZ_HIDDEN)
        rms_norm_bwd(d_attn_hidden, h_in, rms_attn, rstd_a, d_h_in_attn, d_rms_attn_g, SEQ_LEN, D_MODEL)
        add_f32(grads[7], d_rms_attn_g, SZ_RMS)
        free_f32(d_rms_attn_g, SZ_RMS)
        free_f32(d_attn_hidden, SZ_HIDDEN)

        add_f32(d_h_in, d_h_in_attn, SZ_HIDDEN)
        free_f32(d_h_in_attn, SZ_HIDDEN)

        copy_f32(d_h_in, d_hidden, SZ_HIDDEN)
        free_f32(d_h_in, SZ_HIDDEN)

        free_f32(attn_saved[0], SZ_QH)
        free_f32(attn_saved[1], SZ_KH)
        free_f32(attn_saved[2], SZ_VH)
        free_f32(attn_saved[3], SZ_QH)
        free_f32(normed_attn, SZ_HIDDEN)
        free_f32(rstd_a, SEQ_LEN)
        free_f32(normed_ffn, SZ_HIDDEN)
        free_f32(rstd_f, SEQ_LEN)
        free_f32(saved_ffn[layer_idx][0], SEQ_LEN * FF_DIM)
        free_f32(saved_ffn[layer_idx][1], SEQ_LEN * FF_DIM)
        free_f32(saved_ffn[layer_idx][2], SEQ_LEN * FF_DIM)
        free_f32(h_in, SZ_HIDDEN)
        free_f32(mid, SZ_HIDDEN)
        free_f32(d_mid, SZ_HIDDEN)

        layer_idx = layer_idx - 1
    }

    embedding_bwd(d_hidden, tokens, d_embed_w, SEQ_LEN, D_MODEL)
    free_f32(d_hidden, SZ_HIDDEN)
    free_f32(hidden, SZ_HIDDEN)

    for ckpt in ckpt_hiddens {
        free_f32(ckpt, SZ_HIDDEN)
    }

    return loss_val
}

// =====================================================================
//  Optimizer step after gradient accumulation
//
//  Scales accumulated grads by 1/accum_steps, syncs across nodes,
//  clips, runs AdamW, then zeros all grad buffers.
// =====================================================================
fn train_accum_optimizer_step(all_weights, all_grads, all_m1, all_m2,
                              embed_w, lm_head_w, d_embed_w, d_lm_head_w,
                              embed_m1, embed_m2, lmh_m1, lmh_m2,
                              step_num, hxccl_h, world_size, accum_steps) {
    let sizes = [SZ_WQ, SZ_WK, SZ_WV, SZ_WO, SZ_WGATE, SZ_WUP, SZ_WDOWN, SZ_RMS, SZ_RMS]

    // Scale accumulated gradients by 1/accum_steps
    if accum_steps > 1 {
        let inv_accum = 1.0 / (accum_steps * 1.0)
        for layer in 0..N_LAYERS {
            for idx in 0..9 {
                scale_f32(all_grads[layer][idx], sizes[idx], inv_accum)
            }
        }
        scale_f32(d_embed_w, SZ_EMBED, inv_accum)
        scale_f32(d_lm_head_w, SZ_LM_HEAD, inv_accum)
    }

    // Gradient sync (hxccl allreduce)
    grad_sync_allreduce(all_grads, hxccl_h)
    if hxccl_h >= 0 {
        hxccl_allreduce_float(hxccl_h, d_embed_w, SZ_EMBED, HXCCL_OP_SUM)
        hxccl_allreduce_float(hxccl_h, d_lm_head_w, SZ_LM_HEAD, HXCCL_OP_SUM)
        if world_size > 1 {
            let inv_ws = 1.0 / (world_size * 1.0)
            scale_f32(d_embed_w, SZ_EMBED, inv_ws)
            scale_f32(d_lm_head_w, SZ_LM_HEAD, inv_ws)
        }
    }

    // Gradient clipping
    let gnorm = grad_clip_all_layers(all_grads, GRAD_CLIP)

    // AdamW optimizer step with LR schedule
    let lr = lr_schedule(step_num, WARMUP, TOTAL_STEPS, LR)
    for layer in 0..N_LAYERS {
        for idx in 0..9 {
            adamw_update(all_weights[layer][idx],
                         all_grads[layer][idx],
                         all_m1[layer][idx],
                         all_m2[layer][idx],
                         sizes[idx], lr, BETA1, BETA2, WEIGHT_DECAY,
                         step_num)
        }
    }
    adamw_update(embed_w, d_embed_w, embed_m1, embed_m2,
                 SZ_EMBED, lr, BETA1, BETA2, WEIGHT_DECAY, step_num)
    adamw_update(lm_head_w, d_lm_head_w, lmh_m1, lmh_m2,
                 SZ_LM_HEAD, lr, BETA1, BETA2, WEIGHT_DECAY, step_num)

    // Zero all gradients for next accumulation window
    for layer in 0..N_LAYERS {
        zero_layer_grads(all_grads[layer])
    }
    zero_f32(d_embed_w, SZ_EMBED)
    zero_f32(d_lm_head_w, SZ_LM_HEAD)

    return [gnorm, lr]
}

// =====================================================================
//  main — training loop entry point
// =====================================================================
// =====================================================================
//  compute_param_count — total trainable parameters
// =====================================================================
fn compute_param_count() {
    let per_layer = SZ_WQ + SZ_WK + SZ_WV + SZ_WO + SZ_WGATE + SZ_WUP + SZ_WDOWN + SZ_RMS + SZ_RMS
    let total = per_layer * N_LAYERS + SZ_EMBED + SZ_LM_HEAD
    return total
}

fn main() {
    let n_params = compute_param_count()
    let n_params_b = n_params / 1000000000
    let n_params_m = (n_params % 1000000000) / 1000000

    println("=" * 64)
    println("  7B Integrated Training — hxflash + hxccl + grad ckpt")
    println("  d=" + str(D_MODEL) + " layers=" + str(N_LAYERS) + " heads=" + str(N_HEADS) + " kv=" + str(N_KV))
    println("  seq=" + str(SEQ_LEN) + " vocab=" + str(VOCAB) + " ff=" + str(FF_DIM))
    println("  params=" + str(n_params_b) + "." + str(n_params_m) + "B")
    println("  flash_br=" + str(FLASH_BR) + " flash_bc=" + str(FLASH_BC))
    println("  ckpt_segment=" + str(CKPT_SEGMENT) + " (saves " + str(N_LAYERS / CKPT_SEGMENT) + " checkpoints)")
    println("  lr=" + str(LR) + " beta1=" + str(BETA1) + " beta2=" + str(BETA2) + " wd=" + str(WEIGHT_DECAY))
    println("  grad_clip=" + str(GRAD_CLIP) + " warmup=" + str(WARMUP) + " lr_min=" + str(LR_MIN) + " schedule=" + LR_SCHEDULE)
    println("  grad_accum=" + str(ACCUM_STEPS) + " micro_batch=" + str(MICRO_BATCH) + " effective_batch=" + str(GA_CFG.effective_batch_size))
    println("  checkpoint_interval=" + str(CKPT_INTERVAL) + " prefix=" + CKPT_PREFIX)
    if USE_BF16 {
        println("  mixed_precision=bf16 (compute bf16, master fp32)")
        println("  loss_scale_init=" + str(LOSS_SCALE_INIT) + " window=" + str(LOSS_SCALE_WINDOW))
    } else {
        println("  mixed_precision=off (full fp32)")
    }
    println("=" * 64)

    // Check hxflash version
    let ver = hxflash_version()
    println("[hxflash] version=" + str(ver))
    if ver < 3 {
        println("[WARN] hxflash version < 3 — backward pass may not be available")
    }

    // Allocate all layer weights + gradients + AdamW moments
    println("[init] allocating " + str(N_LAYERS) + " layer weights...")
    let mut all_weights = []
    let mut all_grads   = []
    let mut all_m1      = []
    let mut all_m2      = []
    for layer in 0..N_LAYERS {
        all_weights.push(init_layer_weights(layer))
        all_grads.push(alloc_layer_grads())
        // AdamW moment buffers per layer
        let mut m1_bufs = []
        let mut m2_bufs = []
        let sizes = [SZ_WQ, SZ_WK, SZ_WV, SZ_WO, SZ_WGATE, SZ_WUP, SZ_WDOWN, SZ_RMS, SZ_RMS]
        for idx in 0..9 {
            let m1b = alloc_f32(sizes[idx])
            let m2b = alloc_f32(sizes[idx])
            zero_f32(m1b, sizes[idx])
            zero_f32(m2b, sizes[idx])
            m1_bufs.push(m1b)
            m2_bufs.push(m2b)
        }
        all_m1.push(m1_bufs)
        all_m2.push(m2_bufs)
        zero_layer_grads(all_grads[layer])
    }
    println("[init] " + str(N_LAYERS) + " layers allocated")

    // Embedding table [VOCAB, D] — Xavier uniform
    println("[init] allocating embedding table + LM head...")
    let embed_w = alloc_f32(SZ_EMBED)
    xavier_uniform(embed_w, SZ_EMBED, VOCAB, D_MODEL)

    // LM head [D, VOCAB] — small init (tied with embed conceptually)
    let lm_head_w = alloc_f32(SZ_LM_HEAD)
    normal_init(lm_head_w, SZ_LM_HEAD, 0.0, 1.0 / sqrt(D_MODEL * 1.0))

    // Gradient buffers for embedding + LM head
    let d_embed_w = alloc_f32(SZ_EMBED)
    let d_lm_head_w = alloc_f32(SZ_LM_HEAD)
    zero_f32(d_embed_w, SZ_EMBED)
    zero_f32(d_lm_head_w, SZ_LM_HEAD)

    // AdamW moments for embedding + LM head
    let embed_m1 = alloc_f32(SZ_EMBED)
    let embed_m2 = alloc_f32(SZ_EMBED)
    let lmh_m1 = alloc_f32(SZ_LM_HEAD)
    let lmh_m2 = alloc_f32(SZ_LM_HEAD)
    zero_f32(embed_m1, SZ_EMBED)
    zero_f32(embed_m2, SZ_EMBED)
    zero_f32(lmh_m1, SZ_LM_HEAD)
    zero_f32(lmh_m2, SZ_LM_HEAD)
    println("[init] embedding + LM head allocated")

    // ── Checkpoint resume ───────────────────────────────────────
    // Try to find and load the latest checkpoint before training.
    // Restores weights + AdamW moments + step/epoch/lr in-place.
    let mut resume_step = 0
    let mut resume_epoch = 0
    let mut ckpt_paths = []

    if CKPT_INTERVAL > 0 {
        let ckpt_file = find_latest_checkpoint(CKPT_PREFIX, TOTAL_STEPS, CKPT_INTERVAL)
        if len(ckpt_file) > 0 {
            let ckpt_result = load_checkpoint(ckpt_file,
                                              all_weights, all_m1, all_m2,
                                              embed_w, embed_m1, embed_m2,
                                              lm_head_w, lmh_m1, lmh_m2)
            resume_step = ckpt_result[0]
            resume_epoch = ckpt_result[1]
            if resume_step > 0 {
                println("[resume] continuing from step=" + str(resume_step)
                        + " epoch=" + str(resume_epoch))
            }
        } else {
            println("[checkpoint] no existing checkpoint found — training from scratch")
        }
    }

    // hxccl handle: -1 means single-node (skip allreduce)
    // In distributed mode: hxccl_init_handle(rank, world_size)
    let hxccl_h = -1
    let world_size = 1

    // Precompute RoPE frequency table [SEQ_LEN, HEAD_DIM/2]
    println("[init] precomputing RoPE frequencies (theta=" + str(ROPE_THETA) + ")...")
    let rope_freqs = precompute_freqs(HEAD_DIM, SEQ_LEN, ROPE_THETA)
    println("[init] RoPE frequency table ready")

    // Synthetic data (next-token prediction)
    let mut tokens = []
    for i in 0..SEQ_LEN {
        tokens.push(int(random() * VOCAB) % VOCAB)
    }
    let mut targets = []
    for i in 0..SEQ_LEN {
        // Shift-by-one: target[i] = tokens[i+1]
        if i < (SEQ_LEN - 1) {
            targets.push(tokens[(i + 1)])
        } else {
            targets.push(int(random() * VOCAB) % VOCAB)
        }
    }

    // ── Eval config ────────────────────────────────────────────
    let eval_data_path = env("EVAL_DATA_PATH")
    let eval_cfg = EvalConfig {
        d_model:   D_MODEL,
        n_layers:  N_LAYERS,
        n_heads:   N_HEADS,
        n_kv:      N_KV,
        head_dim:  HEAD_DIM,
        seq_len:   SEQ_LEN,
        ff_dim:    FF_DIM,
        vocab:     VOCAB,
        batch_size: 1,
        max_batches: EVAL_MAX_BATCH
    }
    if len(eval_data_path) > 0 {
        println("[eval] EVAL_DATA_PATH=" + eval_data_path + " interval=" + str(EVAL_INTERVAL))
    } else {
        println("[eval] EVAL_DATA_PATH not set — periodic eval disabled")
    }

    // ── Training loop (with gradient accumulation) ────────────────
    println("")
    ga_log_config(GA_CFG)
    println("[train] starting training loop...")
    let n_steps = 3   // demo: 3 steps (set TOTAL_STEPS for real training)
    let mut best_loss = 999999.0

    // Dynamic loss scaler state (used only when USE_BF16)
    let mut cur_loss_scale = LOSS_SCALE_INIT
    let mut cur_clean_steps = 0
    let mut total_overflows = 0

    let start_step = resume_step + 1
    for step in start_step..(resume_step + n_steps + 1) {
        let t0 = time_ms()

        if USE_BF16 {
            // ── bf16 mixed-precision path (uses its own loss scaling) ──
            // bf16 path: accumulation handled inside train_step_bf16 for
            // now — loss scaling interleaves with micro-batches
            let result = train_step_bf16(all_weights, all_grads, all_m1, all_m2,
                                         embed_w, lm_head_w, d_embed_w, d_lm_head_w,
                                         embed_m1, embed_m2, lmh_m1, lmh_m2,
                                         tokens, targets, step, hxccl_h, world_size,
                                         cur_loss_scale, cur_clean_steps, rope_freqs)
            let loss = result[0]
            let gnorm = result[1]
            let lr = result[2]
            cur_loss_scale = result[3]
            cur_clean_steps = result[4]
            let overflow = result[5]

            if overflow == 1 { total_overflows = total_overflows + 1 }
            if loss < best_loss { best_loss = loss }

            let elapsed = time_ms() - t0
            let tps = if elapsed > 0.0 { (SEQ_LEN * 1000.0) / elapsed } else { 0.0 }

            let skip_tag = if overflow == 1 { " [SKIPPED]" } else { "" }
            println("[step " + str(step) + "/" + str(n_steps) + "]"
                    + " loss=" + str(loss)
                    + " gnorm=" + str(gnorm)
                    + " lr=" + str(lr)
                    + " scale=" + str(cur_loss_scale)
                    + " tok/s=" + str(tps)
                    + " time=" + str(elapsed) + "ms"
                    + skip_tag)

            // ── Auto-checkpoint (bf16 path) ─────────────────────
            ckpt_paths = auto_checkpoint(step, CKPT_INTERVAL, CKPT_PREFIX, ckpt_paths,
                                         resume_epoch, lr, loss,
                                         all_weights, all_m1, all_m2,
                                         embed_w, embed_m1, embed_m2,
                                         lm_head_w, lmh_m1, lmh_m2)
        } else {
            // ── fp32 path with gradient accumulation ─────────────
            // Zero grads at start of accumulation window
            for layer in 0..N_LAYERS {
                zero_layer_grads(all_grads[layer])
            }
            zero_f32(d_embed_w, SZ_EMBED)
            zero_f32(d_lm_head_w, SZ_LM_HEAD)

            // Inner loop: accumulate gradients over ACCUM_STEPS micro-batches
            let mut accum_loss = 0.0
            for micro in 0..ACCUM_STEPS {
                // Generate fresh micro-batch data each micro-step
                let mut micro_tokens = []
                for ti in 0..SEQ_LEN {
                    micro_tokens.push(int(random() * VOCAB) % VOCAB)
                }
                let mut micro_targets = []
                for ti in 0..SEQ_LEN {
                    if ti < (SEQ_LEN - 1) {
                        micro_targets.push(micro_tokens[(ti + 1)])
                    } else {
                        micro_targets.push(int(random() * VOCAB) % VOCAB)
                    }
                }

                // Forward + backward only (grads accumulate via +=)
                let micro_loss = train_micro_fwd_bwd(
                    all_weights, all_grads,
                    embed_w, lm_head_w, d_embed_w, d_lm_head_w,
                    micro_tokens, micro_targets)
                accum_loss = accum_loss + micro_loss
            }

            // Average loss across micro-batches
            let loss = accum_loss / (ACCUM_STEPS * 1.0)

            // Optimizer step: scale grads, sync, clip, AdamW, zero
            let opt_result = train_accum_optimizer_step(
                all_weights, all_grads, all_m1, all_m2,
                embed_w, lm_head_w, d_embed_w, d_lm_head_w,
                embed_m1, embed_m2, lmh_m1, lmh_m2,
                step, hxccl_h, world_size, ACCUM_STEPS)
            let gnorm = opt_result[0]
            let lr = opt_result[1]

            if loss < best_loss { best_loss = loss }

            let elapsed = time_ms() - t0
            let total_tokens = SEQ_LEN * ACCUM_STEPS
            let tps = if elapsed > 0.0 { (total_tokens * 1000.0) / elapsed } else { 0.0 }

            println("[step " + str(step) + "/" + str(n_steps) + "]"
                    + " loss=" + str(loss)
                    + " gnorm=" + str(gnorm)
                    + " lr=" + str(lr)
                    + " tok/s=" + str(tps)
                    + " accum=" + str(ACCUM_STEPS)
                    + " time=" + str(elapsed) + "ms")

            // ── Auto-checkpoint (fp32 path) ─────────────────────
            ckpt_paths = auto_checkpoint(step, CKPT_INTERVAL, CKPT_PREFIX, ckpt_paths,
                                         resume_epoch, lr, loss,
                                         all_weights, all_m1, all_m2,
                                         embed_w, embed_m1, embed_m2,
                                         lm_head_w, lmh_m1, lmh_m2)
        }

        // ── Periodic evaluation (only at real steps, not micro-steps) ──
        if len(eval_data_path) > 0 {
            if should_eval(step, EVAL_INTERVAL) {
                let eval_result = run_eval(all_weights, embed_w, lm_head_w,
                                           eval_data_path, eval_cfg, step)
            }
        }
    }

    // ── Final checkpoint ───────────────────────────────────────────
    if CKPT_INTERVAL > 0 {
        let final_step = resume_step + n_steps
        let final_path = CKPT_PREFIX + "_final_step_" + str(final_step) + ".hxck"
        save_checkpoint(final_path, final_step, resume_epoch, LR, best_loss,
                        all_weights, all_m1, all_m2,
                        embed_w, embed_m1, embed_m2,
                        lm_head_w, lmh_m1, lmh_m2)
    }

    println("")
    if USE_BF16 {
        println("[done] training complete — best_loss=" + str(best_loss)
                + " overflows=" + str(total_overflows)
                + " final_scale=" + str(cur_loss_scale))
    } else {
        println("[done] training complete — best_loss=" + str(best_loss)
                + " accum_steps=" + str(ACCUM_STEPS)
                + " effective_batch=" + str(GA_CFG.effective_batch_size))
    }

    // ── Cleanup ─────────────────────────────────────────────────
    // Free embedding + LM head
    free_f32(embed_w, SZ_EMBED)
    free_f32(lm_head_w, SZ_LM_HEAD)
    free_f32(d_embed_w, SZ_EMBED)
    free_f32(d_lm_head_w, SZ_LM_HEAD)
    free_f32(embed_m1, SZ_EMBED)
    free_f32(embed_m2, SZ_EMBED)
    free_f32(lmh_m1, SZ_LM_HEAD)
    free_f32(lmh_m2, SZ_LM_HEAD)

    // Free RoPE frequency table
    free_freqs(rope_freqs, HEAD_DIM, SEQ_LEN)

    // Free layer weights + grads + moments
    let sizes = [SZ_WQ, SZ_WK, SZ_WV, SZ_WO, SZ_WGATE, SZ_WUP, SZ_WDOWN, SZ_RMS, SZ_RMS]
    for layer in 0..N_LAYERS {
        for idx in 0..9 {
            free_f32(all_weights[layer][idx], sizes[idx])
            free_f32(all_grads[layer][idx], sizes[idx])
            free_f32(all_m1[layer][idx], sizes[idx])
            free_f32(all_m2[layer][idx], sizes[idx])
        }
    }

    println("[cleanup] all buffers freed")
}

main()
