// ═══════════════════════════════════════════════════════════════════
//  self/ml/local_sgd_fedavg.hexa — Local SGD / FedAvg (#276)
//
//  Local SGD: each node runs K local gradient steps then workers
//  all-reduce-average parameters every K steps.
//  FedAvg   : same schedule but the average is weighted by each
//             node's sample count (n_k / N).
//
//  We use a tiny linear regression objective  L = ½ Σ (wᵀxᵢ - yᵢ)²
//  so each node can perform local SGD analytically.
//
//  API:
//    ls_zeros(n)                                      -> [float]
//    ls_copy(w)                                       -> [float]
//    ls_dot(a, b)                                     -> float
//    ls_mse_loss(w, X, Y)                             -> float
//    ls_gradient(w, X, Y)                             -> [float]
//    ls_sgd_step(w, X, Y, lr)                         -> [float]
//    ls_local_train(w, X, Y, lr, K)                   -> [float]
//    ls_average_weights(node_weights)                 -> [float]
//    ls_weighted_average(node_weights, counts)        -> [float]
//    ls_local_sgd_round(global_w, nodes_X, nodes_Y, lr, K) -> [float]
//    ls_fedavg_round(global_w, nodes_X, nodes_Y, counts, lr, K) -> [float]
//    ls_train_local_sgd(w0, nodes_X, nodes_Y, lr, K, rounds) -> #{"w","loss_hist"}
//    ls_train_fedavg(w0, nodes_X, nodes_Y, counts, lr, K, rounds) -> #{"w","loss_hist"}
// ═══════════════════════════════════════════════════════════════════

fn ls_zeros(n) {
    let mut v = []
    for _i in 0..n { v = v + [0.0] }
    return v
}

@pure
fn ls_copy(w) {
    let n = len(w)
    let mut out = ls_zeros(n)
    for i in 0..n { out[i] = w[i] }
    return out
}

@pure
fn ls_dot(a, b) {
    let n = len(a)
    let mut s = 0.0
    for i in 0..n { s = s + a[i] * b[i] }
    return s
}

// ═══════════════════════════════════════════════════════════════════
//  1. Loss and gradient for least squares
// ═══════════════════════════════════════════════════════════════════

@pure
fn ls_mse_loss(w, X, Y) {
    let n = len(X)
    if n == 0 { return 0.0 }
    let mut s = 0.0
    for i in 0..n {
        let pred = ls_dot(w, X[i])
        let e = pred - Y[i]
        s = s + 0.5 * e * e
    }
    return s / to_float(n)
}

@pure
fn ls_gradient(w, X, Y) {
    let n = len(X)
    let D = len(w)
    let mut g = ls_zeros(D)
    if n == 0 { return g }
    for i in 0..n {
        let pred = ls_dot(w, X[i])
        let e = pred - Y[i]
        for j in 0..D {
            g[j] = g[j] + e * X[i][j]
        }
    }
    for j in 0..D { g[j] = g[j] / to_float(n) }
    return g
}

// ═══════════════════════════════════════════════════════════════════
//  2. One gradient descent step
// ═══════════════════════════════════════════════════════════════════

@pure
fn ls_sgd_step(w, X, Y, lr) {
    let D = len(w)
    let g = ls_gradient(w, X, Y)
    let mut new_w = ls_zeros(D)
    for j in 0..D {
        new_w[j] = w[j] - lr * g[j]
    }
    return new_w
}

// ═══════════════════════════════════════════════════════════════════
//  3. K local steps on a single node
// ═══════════════════════════════════════════════════════════════════

@pure
fn ls_local_train(w, X, Y, lr, K) {
    let mut cur = ls_copy(w)
    for _s in 0..K {
        cur = ls_sgd_step(cur, X, Y, lr)
    }
    return cur
}

// ═══════════════════════════════════════════════════════════════════
//  4. Uniform parameter average (Local SGD style)
// ═══════════════════════════════════════════════════════════════════

@pure
fn ls_average_weights(node_weights) {
    let M = len(node_weights)
    let D = len(node_weights[0])
    let mut avg = ls_zeros(D)
    for k in 0..M {
        for j in 0..D {
            avg[j] = avg[j] + node_weights[k][j]
        }
    }
    for j in 0..D { avg[j] = avg[j] / to_float(M) }
    return avg
}

// ═══════════════════════════════════════════════════════════════════
//  5. FedAvg weighted average by node sample count
// ═══════════════════════════════════════════════════════════════════

@pure
fn ls_weighted_average(node_weights, counts) {
    let M = len(node_weights)
    let D = len(node_weights[0])
    let mut total = 0
    for k in 0..M { total = total + counts[k] }
    if total <= 0 { total = 1 }
    let tot_f = to_float(total)
    let mut avg = ls_zeros(D)
    for k in 0..M {
        let w_k = to_float(counts[k]) / tot_f
        for j in 0..D {
            avg[j] = avg[j] + w_k * node_weights[k][j]
        }
    }
    return avg
}

// ═══════════════════════════════════════════════════════════════════
//  6. One communication round
//
//  All nodes start from global_w, each does K local steps, then
//  coordinator computes average and broadcasts.
// ═══════════════════════════════════════════════════════════════════

@pure
fn ls_local_sgd_round(global_w, nodes_X, nodes_Y, lr, K) {
    let M = len(nodes_X)
    let mut locals = []
    for k in 0..M {
        let w_k = ls_local_train(global_w, nodes_X[k], nodes_Y[k], lr, K)
        locals = locals + [w_k]
    }
    return ls_average_weights(locals)
}

@pure
fn ls_fedavg_round(global_w, nodes_X, nodes_Y, counts, lr, K) {
    let M = len(nodes_X)
    let mut locals = []
    for k in 0..M {
        let w_k = ls_local_train(global_w, nodes_X[k], nodes_Y[k], lr, K)
        locals = locals + [w_k]
    }
    return ls_weighted_average(locals, counts)
}

// ═══════════════════════════════════════════════════════════════════
//  7. Full training — multiple rounds + loss history on node 0
// ═══════════════════════════════════════════════════════════════════

fn ls_global_loss(w, nodes_X, nodes_Y) {
    let M = len(nodes_X)
    let mut total = 0.0
    let mut count = 0
    for k in 0..M {
        let n_k = len(nodes_X[k])
        if n_k > 0 {
            total = total + ls_mse_loss(w, nodes_X[k], nodes_Y[k]) * to_float(n_k)
            count = count + n_k
        }
    }
    if count == 0 { return 0.0 }
    return total / to_float(count)
}

fn ls_train_local_sgd(w0, nodes_X, nodes_Y, lr, K, rounds) {
    let mut w = ls_copy(w0)
    let mut hist = []
    for _r in 0..rounds {
        let loss = ls_global_loss(w, nodes_X, nodes_Y)
        hist = hist + [loss]
        w = ls_local_sgd_round(w, nodes_X, nodes_Y, lr, K)
    }
    let final_loss = ls_global_loss(w, nodes_X, nodes_Y)
    hist = hist + [final_loss]
    return #{
        "w": w,
        "loss_hist": hist
    }
}

fn ls_train_fedavg(w0, nodes_X, nodes_Y, counts, lr, K, rounds) {
    let mut w = ls_copy(w0)
    let mut hist = []
    for _r in 0..rounds {
        let loss = ls_global_loss(w, nodes_X, nodes_Y)
        hist = hist + [loss]
        w = ls_fedavg_round(w, nodes_X, nodes_Y, counts, lr, K)
    }
    let final_loss = ls_global_loss(w, nodes_X, nodes_Y)
    hist = hist + [final_loss]
    return #{
        "w": w,
        "loss_hist": hist
    }
}

println("[local_sgd_fedavg] loaded — K local steps + uniform/weighted average")
