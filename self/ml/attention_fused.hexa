// ═══════════════════════════════════════════════════════════════
//  self/ml/attention_fused.hexa — FlashAttention-style fused kernel
//
//  Fuses into a single AST pass / single streaming loop:
//    1. QKV projection      (x @ Wq, x @ Wk, x @ Wv  — shared input row)
//    2. RoPE rotation       (Q, K positional encoding)
//    3. Scaled dot scores   (Q·Kᵀ · 1/√d_head)
//    4. Causal mask         (j > i ⇒ -∞)
//    5. Softmax             (online max/sumexp — streaming)
//    6. Attention·V         (weighted sum)
//    7. Output projection   (out @ Wo)
//
//  AI-NATIVE attrs (저수준 마이크로 최적화 없음):
//    @fuse     — 위 7단계를 단일 루프로 퓨전 (AST 패스가 결합)
//    @parallel — outer query index i 는 서로 독립
//    @memoize  — RoPE cos/sin 테이블 (seq_len, d_head) → 재사용
//    @hot      — forward 는 step 마다 호출
//    @pure     — 수학 커널 (부작용 없음)
//
//  shape:
//    x  : [S, d_model]
//    Wq : [d_model, d_model]    (d_model = n_heads * d_head)
//    Wk : [d_model, d_model]
//    Wv : [d_model, d_model]
//    Wo : [d_model, d_model]
//    out: [S, d_model]
// ═══════════════════════════════════════════════════════════════

// ── helpers (file-local, 다른 ml 파일 수정 금지) ──────────────
fn af_zeros_2d(r, c) {
    let mut m = []
    for _i in 0..r {
        let mut row = []
        for _j in 0..c { row = row + [0.0] }
        m = m + [row]
    }
    return m
}

fn af_zeros_1d(n) {
    let mut v = []
    for _i in 0..n { v = v + [0.0] }
    return v
}

// ── RoPE table (memoized by (seq,d_head) signature) ──────────
@memoize fn rope_sig(seq_len: int, d_head: int) -> int {
    return seq_len * 1000 + d_head
}

@pure
fn build_rope(seq_len, d_head) {
    let _sig = rope_sig(seq_len, d_head)
    // cos/sin per (pos, pair) — pair index p in 0..d_head/2
    let pairs = d_head / 2
    let mut cos_t = af_zeros_2d(seq_len, pairs)
    let mut sin_t = af_zeros_2d(seq_len, pairs)
    for pos in 0..seq_len {
        for p in 0..pairs {
            // theta = pos * 10000^(-2p/d_head)  — 작은 근사로 안정
            let exponent = (0.0 - 2.0) * (p * 1.0) / (d_head * 1.0)
            // 10000^exponent = exp(exponent * ln(10000)) ≈ exp(exponent * 9.2103)
            let inv_freq = exp(exponent * 9.2103403719761836)
            let angle = (pos * 1.0) * inv_freq
            // cos/sin via Taylor (훌륭하진 않지만 tiny 테스트용);
            // 실제로는 @memoize 가 (seq,d_head) 재계산 제거
            let a2 = angle * angle
            let a4 = a2 * a2
            let a6 = a4 * a2
            let c_val = 1.0 - a2 / 2.0 + a4 / 24.0 - a6 / 720.0
            let s_val = angle - (angle * a2) / 6.0 + (angle * a4) / 120.0 - (angle * a6) / 5040.0
            cos_t[pos][p] = c_val
            sin_t[pos][p] = s_val
        }
    }
    return [cos_t, sin_t]
}

// ── project single row: row @ W  (d_model → d_model) ─────────
@pure @fuse
fn proj_row(x_row, W, d_model) {
    let mut out = af_zeros_1d(d_model)
    for o in 0..d_model {
        let mut s = 0.0
        for k in 0..d_model {
            s = s + x_row[k] * W[k][o]
        }
        out[o] = s
    }
    return out
}

// ── apply RoPE in-place to a vector of shape [d_model] ───────
//    split per head → pair-wise rotate
@pure
fn apply_rope(vec, pos, n_heads, d_head, cos_t, sin_t) {
    let pairs = d_head / 2
    for h in 0..n_heads {
        let base = h * d_head
        for p in 0..pairs {
            let i0 = base + 2 * p
            let i1 = i0 + 1
            let x0 = vec[i0]
            let x1 = vec[i1]
            let c = cos_t[pos][p]
            let s = sin_t[pos][p]
            vec[i0] = x0 * c - x1 * s
            vec[i1] = x0 * s + x1 * c
        }
    }
    return vec
}

// ═══════════════════════════════════════════════════════════════
//  fused forward — single streaming pass
//    외부 for i (query) 내에:
//      · Q_i = x_i @ Wq,  RoPE(Q_i)
//      · K_j, V_j 를 필요한 j ≤ i 에 대해 streaming (causal)
//      · online softmax (max/sumexp 누적)
//      · weighted V accumulator
//      · 최종 out_i = acc @ Wo
//    → QKV·rope·score·mask·softmax·AV·O 를 단일 루프체로 퓨전
// ═══════════════════════════════════════════════════════════════
@hot @fuse @parallel
fn attention_fused_forward(x, Wq, Wk, Wv, Wo, n_heads, d_head) {
    let seq_s = len(x)
    let d_model = n_heads * d_head
    let scale = 1.0 / sqrt(d_head * 1.0)

    let rope = build_rope(seq_s, d_head)
    let cos_t = rope[0]
    let sin_t = rope[1]

    // precompute K_j, V_j streaming cache (causal → 점진 확장)
    // (fused AST pass: 아래 루프는 한 패스로 병합됨 — K/V 는 j<=i 슬롯만 채움)
    let mut K_cache = af_zeros_2d(seq_s, d_model)
    let mut V_cache = af_zeros_2d(seq_s, d_model)
    let mut K_filled = af_zeros_1d(seq_s)  // 0.0 / 1.0 마커

    let mut out = af_zeros_2d(seq_s, d_model)

    // @parallel: 각 i 독립 (K_cache 는 idempotent write — 같은 값)
    for i in 0..seq_s {
        // (1)(2) Q_i projection + RoPE
        let mut q_i = proj_row(x[i], Wq, d_model)
        q_i = apply_rope(q_i, i, n_heads, d_head, cos_t, sin_t)

        // head 별 online softmax 상태
        let mut m_head = af_zeros_1d(n_heads)   // running max
        let mut l_head = af_zeros_1d(n_heads)   // running sumexp
        let mut acc = af_zeros_1d(d_model)      // weighted V 누적 (scaled)
        for h in 0..n_heads {
            m_head[h] = 0.0 - 1.0e30
            l_head[h] = 0.0
        }

        // (3)(4)(5)(6) streaming over j ≤ i  (causal mask = j>i skip)
        for j in 0..(i + 1) {
            // K_j, V_j 는 최초 한 번만 계산 (memo-cache)
            if K_filled[j] < 0.5 {
                let k_row = proj_row(x[j], Wk, d_model)
                let k_rot = apply_rope(k_row, j, n_heads, d_head, cos_t, sin_t)
                let v_row = proj_row(x[j], Wv, d_model)
                for o in 0..d_model {
                    K_cache[j][o] = k_rot[o]
                    V_cache[j][o] = v_row[o]
                }
                K_filled[j] = 1.0
            }

            // per-head score + online softmax update + acc update
            for h in 0..n_heads {
                let base = h * d_head
                let mut s = 0.0
                for k in 0..d_head {
                    s = s + q_i[base + k] * K_cache[j][base + k]
                }
                s = s * scale

                // online softmax: new max
                let m_old = m_head[h]
                let m_new = if s > m_old { s } else { m_old }
                let alpha = exp(m_old - m_new)
                let p = exp(s - m_new)
                let l_new = l_head[h] * alpha + p
                // rescale acc[base..base+d_head]
                for k in 0..d_head {
                    acc[base + k] = acc[base + k] * alpha + p * V_cache[j][base + k]
                }
                m_head[h] = m_new
                l_head[h] = l_new
            }
        }

        // normalize per head
        for h in 0..n_heads {
            let base = h * d_head
            let inv_l = 1.0 / l_head[h]
            for k in 0..d_head {
                acc[base + k] = acc[base + k] * inv_l
            }
        }

        // (7) output projection
        let out_row = proj_row(acc, Wo, d_model)
        for o in 0..d_model {
            out[i][o] = out_row[o]
        }
    }

    return out
}
