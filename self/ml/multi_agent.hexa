// ===================================================================
//  self/ml/multi_agent.hexa — Multi-Agent Orchestration Framework
//
//  Pure Hexa implementation of multi-agent collaboration.
//
//  Components:
//    1. Agent Registry   — register agents with name, description, tools, model
//    2. Task Router      — keyword-based task-to-agent matching
//    3. Message Bus      — pub/sub inter-agent messaging
//    4. Consensus Engine — majority vote or weighted vote for final result
//
//  Public API:
//    create_orchestrator()
//    register_agent(orch, name, desc, tools, model)
//    unregister_agent(orch, name)
//    get_agent(orch, name)
//    list_agents(orch)
//    route_task(orch, task)
//    route_task_top_n(orch, task, n)
//    send_message(orch, from, to, msg)
//    broadcast_message(orch, from, msg)
//    get_messages(orch, agent_name)
//    subscribe(orch, agent_name, topic)
//    publish(orch, topic, msg)
//    get_topic_messages(orch, agent_name)
//    consensus(orch, responses)
//    weighted_consensus(orch, responses, weights)
//    run_task(orch, task, executor)
//
//  Conventions:
//    - Uses #{} map literals (no {k:v} inside if blocks)
//    - Agent = map with keys: name, description, tools, model
// ===================================================================

// ===================================================================
//  Create a new orchestrator
//  Returns a map containing agent registry, message queues, and topics
// ===================================================================
fn create_orchestrator() {
    let orch = #{}
    orch["agents"] = #{}
    orch["messages"] = #{}
    orch["topics"] = #{}
    orch["subscriptions"] = #{}
    orch["agent_names"] = []
    return orch
}

// ===================================================================
//  Register an agent into the orchestrator
// ===================================================================
fn register_agent(orch, name, description, tools, model) {
    let agent = #{}
    agent["name"] = name
    agent["description"] = description
    agent["tools"] = tools
    agent["model"] = model

    let agents = orch["agents"]
    agents[name] = agent
    orch["agents"] = agents

    // initialize message queue for this agent
    let msgs = orch["messages"]
    msgs[name] = []
    orch["messages"] = msgs

    // initialize topic message queue
    let tmsg = orch["subscriptions"]
    tmsg[name] = []
    orch["subscriptions"] = tmsg

    // track agent names
    orch["agent_names"] = orch["agent_names"] + [name]

    return orch
}

// ===================================================================
//  Unregister an agent
// ===================================================================
fn unregister_agent(orch, name) {
    let agents = orch["agents"]
    let empty = #{}
    agents[name] = empty
    orch["agents"] = agents

    // remove from names list
    let names = orch["agent_names"]
    let mut new_names = []
    let n = len(names)
    let mut i = 0
    while i < n {
        if names[i] != name {
            new_names = new_names + [names[i]]
        }
        i = i + 1
    }
    orch["agent_names"] = new_names
    return orch
}

// ===================================================================
//  Get agent by name
// ===================================================================
fn get_agent(orch, name) {
    let agents = orch["agents"]
    return agents[name]
}

// ===================================================================
//  List all registered agent names
// ===================================================================
fn list_agents(orch) {
    return orch["agent_names"]
}

// ===================================================================
//  String helpers (self-contained)
// ===================================================================
fn _ma_to_lower(s) {
    // Hexa char doesn't support arithmetic, so we do manual replacement
    let n = len(s)
    let mut result = ""
    let mut i = 0
    while i < n {
        let ch = s[i]
        let mut low = str(ch)
        if ch == 'A' { low = "a" }
        if ch == 'B' { low = "b" }
        if ch == 'C' { low = "c" }
        if ch == 'D' { low = "d" }
        if ch == 'E' { low = "e" }
        if ch == 'F' { low = "f" }
        if ch == 'G' { low = "g" }
        if ch == 'H' { low = "h" }
        if ch == 'I' { low = "i" }
        if ch == 'J' { low = "j" }
        if ch == 'K' { low = "k" }
        if ch == 'L' { low = "l" }
        if ch == 'M' { low = "m" }
        if ch == 'N' { low = "n" }
        if ch == 'O' { low = "o" }
        if ch == 'P' { low = "p" }
        if ch == 'Q' { low = "q" }
        if ch == 'R' { low = "r" }
        if ch == 'S' { low = "s" }
        if ch == 'T' { low = "t" }
        if ch == 'U' { low = "u" }
        if ch == 'V' { low = "v" }
        if ch == 'W' { low = "w" }
        if ch == 'X' { low = "x" }
        if ch == 'Y' { low = "y" }
        if ch == 'Z' { low = "z" }
        result = result + low
        i = i + 1
    }
    return result
}

fn _ma_contains(haystack, needle) {
    let hn = len(haystack)
    let nn = len(needle)
    if nn == 0 { return true }
    if nn > hn { return false }
    let limit = hn - nn
    let mut i = 0
    while i <= limit {
        let mut j = 0
        let mut ok = true
        while j < nn {
            if haystack[i + j] != needle[j] {
                ok = false
                j = nn
            }
            j = j + 1
        }
        if ok { return true }
        i = i + 1
    }
    return false
}

// Split a string by spaces into words
fn _ma_split_words(s) {
    let n = len(s)
    let mut words = []
    let mut current = ""
    let mut i = 0
    while i < n {
        if s[i] == ' ' {
            if len(current) > 0 {
                words = words + [current]
                current = ""
            }
        } else {
            current = current + str(s[i])
        }
        i = i + 1
    }
    if len(current) > 0 {
        words = words + [current]
    }
    return words
}

// ===================================================================
//  Route a task to the best matching agent (keyword matching)
//  Scores each agent by counting how many words from the task
//  appear in the agent's description or tools list.
// ===================================================================
fn _score_agent(agent, task_words) {
    let desc = _ma_to_lower(agent["description"])
    let agent_tools = agent["tools"]
    let n_words = len(task_words)
    let mut score = 0
    let mut wi = 0
    while wi < n_words {
        let word = _ma_to_lower(task_words[wi])
        if _ma_contains(desc, word) {
            score = score + 1
        }
        // check tools
        let n_tools = len(agent_tools)
        let mut ti = 0
        while ti < n_tools {
            if _ma_contains(_ma_to_lower(agent_tools[ti]), word) {
                score = score + 1
            }
            ti = ti + 1
        }
        wi = wi + 1
    }
    return score
}

fn route_task(orch, task) {
    let task_words = _ma_split_words(task)
    let names = orch["agent_names"]
    let n = len(names)
    let mut best_name = ""
    let mut best_score = 0 - 1
    let mut i = 0
    while i < n {
        let agent = get_agent(orch, names[i])
        let score = _score_agent(agent, task_words)
        if score > best_score {
            best_score = score
            best_name = names[i]
        }
        i = i + 1
    }
    return best_name
}

// Route to top-N agents by score
fn route_task_top_n(orch, task, n) {
    let task_words = _ma_split_words(task)
    let names = orch["agent_names"]
    let total = len(names)

    // compute all scores
    let mut scores = []
    let mut scored_names = []
    let mut i = 0
    while i < total {
        let agent = get_agent(orch, names[i])
        let score = _score_agent(agent, task_words)
        scores = scores + [score]
        scored_names = scored_names + [names[i]]
        i = i + 1
    }

    // selection sort top-n (descending by score)
    let pick = if n < total { n } else { total }
    let mut result = []
    let mut picked = 0
    while picked < pick {
        let mut best_idx = 0 - 1
        let mut best_s = 0 - 1
        let mut si = 0
        while si < total {
            if scores[si] > best_s {
                best_s = scores[si]
                best_idx = si
            }
            si = si + 1
        }
        if best_idx >= 0 {
            result = result + [scored_names[best_idx]]
            scores[best_idx] = 0 - 999
        }
        picked = picked + 1
    }
    return result
}

// ===================================================================
//  Message Bus — direct messaging
// ===================================================================
fn send_message(orch, from, to, msg) {
    let envelope = #{}
    envelope["from"] = from
    envelope["to"] = to
    envelope["content"] = msg

    let msgs = orch["messages"]
    let queue = msgs[to]
    msgs[to] = queue + [envelope]
    orch["messages"] = msgs
    return orch
}

fn broadcast_message(orch, from, msg) {
    let names = orch["agent_names"]
    let n = len(names)
    let mut i = 0
    while i < n {
        if names[i] != from {
            orch = send_message(orch, from, names[i], msg)
        }
        i = i + 1
    }
    return orch
}

fn get_messages(orch, agent_name) {
    let msgs = orch["messages"]
    return msgs[agent_name]
}

fn clear_messages(orch, agent_name) {
    let msgs = orch["messages"]
    msgs[agent_name] = []
    orch["messages"] = msgs
    return orch
}

// ===================================================================
//  Pub/Sub topic messaging
// ===================================================================
fn subscribe(orch, agent_name, topic) {
    let topics = orch["topics"]
    if topics.contains_key(topic) {
        topics[topic] = topics[topic] + [agent_name]
    } else {
        topics[topic] = [agent_name]
    }
    orch["topics"] = topics
    return orch
}

fn publish(orch, topic, msg) {
    let topics = orch["topics"]
    if topics.contains_key(topic) == false {
        return orch
    }
    let subscribers = topics[topic]
    let n = len(subscribers)
    let mut i = 0
    while i < n {
        let agent_name = subscribers[i]
        let subs = orch["subscriptions"]
        let queue = subs[agent_name]
        let envelope = #{}
        envelope["topic"] = topic
        envelope["content"] = msg
        subs[agent_name] = queue + [envelope]
        orch["subscriptions"] = subs
        i = i + 1
    }
    return orch
}

fn get_topic_messages(orch, agent_name) {
    let subs = orch["subscriptions"]
    return subs[agent_name]
}

// ===================================================================
//  Consensus — majority vote
//  responses: array of strings (each agent's answer)
//  Returns the most common response
// ===================================================================
fn consensus(orch, responses) {
    let n = len(responses)
    if n == 0 { return "" }

    // count occurrences
    let mut unique = []
    let mut counts = []

    let mut i = 0
    while i < n {
        let r = responses[i]
        // find in unique
        let nu = len(unique)
        let mut found = false
        let mut fi = 0
        while fi < nu {
            if unique[fi] == r {
                counts[fi] = counts[fi] + 1
                found = true
                fi = nu
            }
            fi = fi + 1
        }
        if found == false {
            unique = unique + [r]
            counts = counts + [1]
        }
        i = i + 1
    }

    // find max count
    let nu = len(unique)
    let mut best = ""
    let mut best_count = 0
    let mut bi = 0
    while bi < nu {
        if counts[bi] > best_count {
            best_count = counts[bi]
            best = unique[bi]
        }
        bi = bi + 1
    }
    return best
}

// ===================================================================
//  Weighted consensus
//  responses: array of strings, weights: array of floats
//  Sums weights for each unique response, returns highest
// ===================================================================
fn weighted_consensus(orch, responses, weights) {
    let n = len(responses)
    if n == 0 { return "" }

    let mut unique = []
    let mut w_sums = []

    let mut i = 0
    while i < n {
        let r = responses[i]
        let w = weights[i]
        let nu = len(unique)
        let mut found = false
        let mut fi = 0
        while fi < nu {
            if unique[fi] == r {
                w_sums[fi] = w_sums[fi] + w
                found = true
                fi = nu
            }
            fi = fi + 1
        }
        if found == false {
            unique = unique + [r]
            w_sums = w_sums + [w]
        }
        i = i + 1
    }

    let nu = len(unique)
    let mut best = ""
    let mut best_w = 0.0 - 1.0
    let mut bi = 0
    while bi < nu {
        if w_sums[bi] > best_w {
            best_w = w_sums[bi]
            best = unique[bi]
        }
        bi = bi + 1
    }
    return best
}

// ===================================================================
//  Run task end-to-end
//  executor: fn(agent_name, task) -> str
//  Routes task, calls executor, returns result
// ===================================================================
fn run_task(orch, task, executor) {
    let agent_name = route_task(orch, task)
    if agent_name == "" { return "" }
    return executor(agent_name, task)
}

// ===================================================================
//  Run task with multi-agent consensus
//  Sends task to top-N agents, collects results, returns consensus
// ===================================================================
fn run_task_consensus(orch, task, executor, n) {
    let agents = route_task_top_n(orch, task, n)
    let na = len(agents)
    let mut responses = []
    let mut i = 0
    while i < na {
        let result = executor(agents[i], task)
        responses = responses + [result]
        i = i + 1
    }
    return consensus(orch, responses)
}

println("[multi_agent] module loaded")
