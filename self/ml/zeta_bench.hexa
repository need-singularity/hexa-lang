// ═══════════════════════════════════════════════════════════
//  zeta_bench.hexa — Zeta-vs-HEXA 4축 벤치 하네스
//  Axes: throughput(tok/s), latency(p50/p99 ms), quality(ppl proxy),
//        phi(consciousness metric)
//  Usage (as library):
//    let cfg = zb_config("hexa-mock", "zeta-ref", 64, 128)
//    let res = zb_run(cfg, model_fn, ref_logprob_fn, state_fn)
//    zb_append_jsonl("/path/to/zeta_compare.jsonl", res)
// ═══════════════════════════════════════════════════════════

// ── helpers ──────────────────────────────────────────────

fn zb_abs(x) {
    if x < 0 { return 0 - x }
    return x
}

fn zb_max(a, b) {
    if a > b { return a }
    return b
}

fn zb_floor_int(x) {
    // assume x >= 0
    let mut i = 0
    while (i + 1) <= x { i = i + 1 }
    return i
}

// Insertion sort (small N friendly; p50/p99 on latency arr)
fn zb_sort_asc(arr) {
    let mut a = []
    let mut i = 0
    while i < len(arr) { a = a.push(arr[i]); i = i + 1 }
    let n = len(a)
    let mut k = 1
    while k < n {
        let mut j = k
        while j > 0 {
            if a[j - 1] > a[j] {
                let t = a[j - 1]
                a[j - 1] = a[j]
                a[j] = t
                j = j - 1
            } else {
                j = 0 - 1
                j = 0  // break
                // emulate break
                while false {}
                j = 0
                // force exit
                j = 0 - 9999
            }
        }
    }
    return a
}

// simpler/safer sort
fn zb_sort(arr) {
    let mut a = []
    let mut i = 0
    while i < len(arr) { a = a.push(arr[i]); i = i + 1 }
    let n = len(a)
    let mut ii = 0
    while ii < n {
        let mut jj = ii + 1
        while jj < n {
            if a[jj] < a[ii] {
                let t = a[ii]
                a[ii] = a[jj]
                a[jj] = t
            }
            jj = jj + 1
        }
        ii = ii + 1
    }
    return a
}

fn zb_percentile(sorted_arr, p) {
    let n = len(sorted_arr)
    if n == 0 { return 0 }
    // rank = ceil(p * n) - 1, clamp
    let mut idx = zb_floor_int(p * n)
    if idx >= n { idx = n - 1 }
    if idx < 0 { idx = 0 }
    return sorted_arr[idx]
}

fn zb_mean(arr) {
    let n = len(arr)
    if n == 0 { return 0 }
    let mut s = 0
    let mut i = 0
    while i < n { s = s + arr[i]; i = i + 1 }
    return s / n
}

// Simple natural-log approximation via series (for ppl proxy).
// ln(x) for x>0 using ln(x) = 2*atanh((x-1)/(x+1)) series, 8 terms.
fn zb_ln(x) {
    if x <= 0 { return 0 - 1000000 }
    let y = (x - 1) / (x + 1)
    let y2 = y * y
    let mut term = y
    let mut sum = 0
    let mut k = 0
    while k < 8 {
        let denom = 2 * k + 1
        sum = sum + term / denom
        term = term * y2
        k = k + 1
    }
    return 2 * sum
}

fn zb_exp_small(x) {
    // e^x via 12 term Taylor (good for |x|<=4)
    let mut sum = 1
    let mut term = 1
    let mut k = 1
    while k < 14 {
        term = term * x / k
        sum = sum + term
        k = k + 1
    }
    return sum
}

// ── config / result constructors (tuples as arrays) ──────

fn zb_config(name_hexa, name_ref, warmup, iters) {
    // [0]=hexa_name, [1]=ref_name, [2]=warmup, [3]=iters
    let mut c = []
    c = c.push(name_hexa)
    c = c.push(name_ref)
    c = c.push(warmup)
    c = c.push(iters)
    return c
}

// ── core runner ──────────────────────────────────────────
// model_fn(step) -> [token_logprob, token_id, hidden_state_vec]
//   token_logprob: natural log probability of chosen token (<= 0)
//   hidden_state_vec: array of floats (for phi metric)
// ref_logprob_fn(step) -> reference baseline logprob (zeta)
// state_fn() unused placeholder (kept for future)

fn zb_phi_metric(state_series) {
    // Integrated information proxy:
    //   phi ~ mean( |x_t - x_{t-1}| ) * log(1 + variance)
    // We use a lightweight variance computed from the state vector
    // sequence to signal integration across timesteps.
    let n = len(state_series)
    if n < 2 { return 0 }
    // flatten means per step
    let mut means = []
    let mut i = 0
    while i < n {
        let v = state_series[i]
        let m = zb_mean(v)
        means = means.push(m)
        i = i + 1
    }
    // temporal delta
    let mut deltas = []
    i = 1
    while i < n {
        deltas = deltas.push(zb_abs(means[i] - means[i - 1]))
        i = i + 1
    }
    let d_mean = zb_mean(deltas)
    // variance of means
    let mu = zb_mean(means)
    let mut vs = 0
    i = 0
    while i < n {
        let dv = means[i] - mu
        vs = vs + dv * dv
        i = i + 1
    }
    let varv = vs / n
    // phi ~ d_mean * ln(1 + var)
    return d_mean * zb_ln(1 + varv)
}

fn zb_run(cfg, model_fn, ref_logprob_fn) {
    let warmup = cfg[2]
    let iters = cfg[3]

    // warmup
    let mut w = 0
    while w < warmup {
        let _ = model_fn(w)
        w = w + 1
    }

    let mut latencies_ms = []
    let mut logp_sum = 0
    let mut ref_logp_sum = 0
    let mut tokens = 0
    let mut states = []

    let t0 = clock()
    let mut step = 0
    while step < iters {
        let s0 = clock()
        let out = model_fn(step)
        let s1 = clock()
        let lat_ms = (s1 - s0) * 1000
        latencies_ms = latencies_ms.push(lat_ms)

        let lp = out[0]
        let state_vec = out[2]
        logp_sum = logp_sum + lp
        states = states.push(state_vec)

        let rlp = ref_logprob_fn(step)
        ref_logp_sum = ref_logp_sum + rlp

        tokens = tokens + 1
        step = step + 1
    }
    let t1 = clock()
    let wall_s = t1 - t0
    let mut throughput = 0
    if wall_s > 0 { throughput = tokens / wall_s }

    let sorted_lat = zb_sort(latencies_ms)
    let p50 = zb_percentile(sorted_lat, 0.50)
    let p99 = zb_percentile(sorted_lat, 0.99)

    // Perplexity proxy = exp(-mean_logprob)
    let mean_lp = logp_sum / tokens
    let ppl = zb_exp_small(0 - mean_lp)
    let mean_ref = ref_logp_sum / tokens
    let ppl_ref = zb_exp_small(0 - mean_ref)

    let phi = zb_phi_metric(states)

    // result record (array of [key, value] pairs for easy JSON emit)
    let mut r = []
    r = r.push(["hexa_name", cfg[0]])
    r = r.push(["ref_name", cfg[1]])
    r = r.push(["warmup", warmup])
    r = r.push(["iters", iters])
    r = r.push(["tokens", tokens])
    r = r.push(["wall_s", wall_s])
    r = r.push(["throughput_tok_s", throughput])
    r = r.push(["latency_p50_ms", p50])
    r = r.push(["latency_p99_ms", p99])
    r = r.push(["mean_logprob", mean_lp])
    r = r.push(["perplexity", ppl])
    r = r.push(["ref_mean_logprob", mean_ref])
    r = r.push(["ref_perplexity", ppl_ref])
    r = r.push(["phi", phi])
    return r
}

// ── JSONL emitter ────────────────────────────────────────

fn zb_char_is_digit(c) {
    if c == '0' { return true }
    if c == '1' { return true }
    if c == '2' { return true }
    if c == '3' { return true }
    if c == '4' { return true }
    if c == '5' { return true }
    if c == '6' { return true }
    if c == '7' { return true }
    if c == '8' { return true }
    if c == '9' { return true }
    return false
}

fn zb_char_is_numish(c) {
    if zb_char_is_digit(c) { return true }
    if c == '-' { return true }
    if c == '+' { return true }
    if c == '.' { return true }
    if c == 'e' { return true }
    if c == 'E' { return true }
    return false
}

fn zb_is_num(x) {
    let s = str(x)
    let n = len(s)
    if n == 0 { return false }
    let c0 = s[0]
    if !(c0 == '-' || c0 == '+' || zb_char_is_digit(c0)) { return false }
    let mut i = 0
    let mut saw_digit = false
    while i < n {
        let ch = s[i]
        if zb_char_is_digit(ch) { saw_digit = true }
        if !zb_char_is_numish(ch) { return false }
        i = i + 1
    }
    return saw_digit
}

fn zb_json_val(v) {
    if zb_is_num(v) { return str(v) }
    return "\"" + str(v) + "\""
}

fn zb_to_jsonl(record) {
    let mut s = "{"
    let mut i = 0
    let n = len(record)
    while i < n {
        let kv = record[i]
        s = s + "\"" + str(kv[0]) + "\":" + zb_json_val(kv[1])
        if i < n - 1 { s = s + "," }
        i = i + 1
    }
    s = s + "}"
    return s
}

fn zb_ensure_dir(path) {
    exec("mkdir -p " + path)
}

fn zb_append_jsonl(file_path, record) {
    let line = zb_to_jsonl(record) + "\n"
    // append = read existing + concat + write (no native append builtin)
    let mut prev = ""
    // best-effort read; if file missing, treat as empty
    // runtime read_file returns "" on missing in most builds
    prev = read_file(file_path)
    if len(prev) < 0 { prev = "" }
    write_file(file_path, prev + line)
    return line
}
