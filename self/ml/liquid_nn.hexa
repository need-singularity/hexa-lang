// ═══════════════════════════════════════════════════════════════
//  self/ml/liquid_nn.hexa — Liquid NN / CfC (#253)
//
//  Closed-form Continuous-time RNN (CfC) — Hasani et al. 2022.
//
//  For each neuron i the hidden state follows a closed-form solution of
//  a linear ODE with a learnable time-constant and input-gated decay:
//
//    x_i(t+1) = (x_i(t) - A_i) * exp( -(w_i * u(t) + softplus(b_i)) * tau )
//              + A_i
//
//  where
//    - A_i  : steady-state value (learnable)
//    - w_i  : input-dependent decay rate (learnable)
//    - b_i  : decay bias, gated through softplus(b_i) = ln(1+exp(b_i))
//    - tau  : integration step (1.0 default)
//    - u(t) : input stimulus (can be a scalar drive)
//
//  This is the "closed-form" in CfC: no numerical ODE integrator needed.
//
//  Extension: multi-neuron with per-neuron A, b, w and a readout matrix.
//
//  AI-NATIVE attrs:
//    @pure  — closed-form step is stateless
// ═══════════════════════════════════════════════════════════════

// ── helpers ───────────────────────────────────────────────────
fn cfc_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn cfc_zeros(n) {
    let mut v = []
    for _i in 0..n { v = v + [0.0] }
    return v
}

fn cfc_zeros2d(m, n) {
    let mut w = []
    for _i in 0..m { w = w + [cfc_zeros(n)] }
    return w
}

fn cfc_hash(seed, i, j) {
    let h = (seed * 2654435761 + i * 1315423911 + j * 731) % 10007
    return to_float(h) / 10007.0 - 0.5
}

// softplus(b) = ln(1 + exp(b))
// For numerical stability: if b > 20, softplus ≈ b; if b < -20, softplus ≈ exp(b)
@pure
fn cfc_softplus(b) {
    if b > 20.0 { return b }
    if b < (0.0 - 20.0) { return exp(b) }
    return log(1.0 + exp(b))
}

// safe_exp with clamp
@pure
fn cfc_safe_exp(x) {
    if x > 50.0 { return exp(50.0) }
    if x < (0.0 - 50.0) { return 0.0 }
    return exp(x)
}

// ═══════════════════════════════════════════════════════════════
//  (1) Single-neuron closed-form update
//
//  x_new = (x - A) * exp(-(w*u + softplus(b)) * tau) + A
// ═══════════════════════════════════════════════════════════════
@pure
fn cfc_cell_step(x, u, A, w, b, tau) {
    let sp = cfc_softplus(b)
    let rate = w * u + sp
    let neg_rate_tau = 0.0 - rate * tau
    let decay = cfc_safe_exp(neg_rate_tau)
    let x_minus_A = x - A
    return x_minus_A * decay + A
}

// ═══════════════════════════════════════════════════════════════
//  (2) Multi-neuron layer
//
//  params: dict with
//    A   : [n] steady states
//    w   : [n] input decay weights
//    b   : [n] decay biases
//    W_in: [n x d] input projection (u_i = W_in[i] . input + b_in[i])
//    b_in: [n]
//  State:  x : [n]
// ═══════════════════════════════════════════════════════════════
fn cfc_init_layer(n_neurons, input_dim, seed) {
    let mut A = cfc_zeros(n_neurons)
    let mut w = cfc_zeros(n_neurons)
    let mut b = cfc_zeros(n_neurons)
    let mut W_in = cfc_zeros2d(n_neurons, input_dim)
    let mut b_in = cfc_zeros(n_neurons)

    for i in 0..n_neurons {
        A[i] = 0.5 * cfc_hash(seed + 1, i, 0)
        w[i] = 0.3 + 0.2 * cfc_hash(seed + 2, i, 1)
        b[i] = 0.1 * cfc_hash(seed + 3, i, 2)
        for j in 0..input_dim {
            W_in[i][j] = 0.5 * cfc_hash(seed + 4, i, j)
        }
        b_in[i] = 0.1 * cfc_hash(seed + 5, i, 0)
    }

    let layer = #{
        "A": A,
        "w": w,
        "b": b,
        "W_in": W_in,
        "b_in": b_in,
        "n": n_neurons,
        "d": input_dim
    }
    return layer
}

// Forward 1 step given input vector and state x
fn cfc_layer_step(layer, x, input, tau) {
    let n = layer["n"]
    let d = layer["d"]
    let A_arr = layer["A"]
    let w_arr = layer["w"]
    let b_arr = layer["b"]
    let W_in = layer["W_in"]
    let b_in = layer["b_in"]

    let mut x_new = cfc_zeros(n)
    for i in 0..n {
        // compute input drive u_i = W_in[i] . input + b_in[i]
        let mut u_i = b_in[i]
        for j in 0..d {
            u_i = u_i + W_in[i][j] * input[j]
        }
        x_new[i] = cfc_cell_step(x[i], u_i, A_arr[i], w_arr[i], b_arr[i], tau)
    }
    return x_new
}

// ═══════════════════════════════════════════════════════════════
//  (3) Multi-step unrolled forward over a sequence of inputs
//  inputs: [T x d]  → returns final state or all states
// ═══════════════════════════════════════════════════════════════
fn cfc_forward_sequence(layer, x0, inputs, tau) {
    let T = len(inputs)
    let n = layer["n"]
    let mut x = cfc_zeros(n)
    for i in 0..n { x[i] = x0[i] }
    for t in 0..T {
        x = cfc_layer_step(layer, x, inputs[t], tau)
    }
    return x
}

// Returns all hidden states along the trajectory
fn cfc_trajectory(layer, x0, inputs, tau) {
    let T = len(inputs)
    let n = layer["n"]
    let mut x = cfc_zeros(n)
    for i in 0..n { x[i] = x0[i] }
    let mut traj = [x]
    for t in 0..T {
        x = cfc_layer_step(layer, x, inputs[t], tau)
        traj = traj + [x]
    }
    return traj
}
