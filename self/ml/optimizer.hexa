// ═══════════════════════════════════════════════════════════════
//  optimizer.hexa — SGD with momentum + weight decay for 100M training
//
//  Uses only BLAS builtins (no tensor element writes):
//    mat_scale_inplace(m, beta)  → momentum decay
//    mat_add_inplace(m, G)       → accumulate gradient
//    axpy(W, m, -lr)             → weight update
//    mat_scale_inplace(W, decay) → weight decay
//
//  Hyperparameters (tuned for 100M scale):
//    momentum beta=0.9, weight decay=0.1
//    Cosine LR: warmup 200, peak 3e-4, min 3e-5
// ═══════════════════════════════════════════════════════════════

let SGD_BETA = 0.9
let SGD_WD   = 0.1

// ── Cosine LR schedule with linear warmup ────────────────────
fn lr_schedule(step, warmup, total, peak, minimum) {
    if step < warmup {
        return peak * (step * 1.0) / (warmup * 1.0)
    }
    if step >= total {
        return minimum
    }
    let prog = (step - warmup) * 1.0 / ((total - warmup) * 1.0)
    let x = prog * 3.14159265358979
    let x2 = x * x
    let x4 = x2 * x2
    let x6 = x4 * x2
    let cos_v = 1.0 - x2 / 2.0 + x4 / 24.0 - x6 / 720.0
    minimum + (peak - minimum) * 0.5 * (1.0 + cos_v)
}

// ── Single parameter SGD step with momentum ──────────────────
// All operations via BLAS builtins (zero tensor element writes)
fn sgd_step(param, grad, momentum_buf, lr, beta, wd) {
    // Weight decay: param *= (1 - lr * wd)
    if wd > 0.0 {
        mat_scale_inplace(param, 1.0 - lr * wd)
    }
    // Momentum: m = beta * m + grad
    mat_scale_inplace(momentum_buf, beta)
    mat_add_inplace(momentum_buf, grad)
    // Update: param -= lr * m
    let _ = axpy(param, momentum_buf, -1.0 * lr)
    0
}

// ── Batch update for all parameters ──────────────────────────
// Takes arrays of [param, grad, momentum] triplets
fn sgd_step_all(params, grads, momenta, n_params, sizes, lr, beta, wd) {
    let mut i = 0
    while i < n_params {
        sgd_step(params[i], grads[i], momenta[i], lr, beta, wd)
        i = i + 1
    }
    0
}

println("[optimizer] loaded — SGD+momentum via BLAS (axpy/mat_scale_inplace)")
