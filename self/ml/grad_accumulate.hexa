// ═══════════════════════════════════════════════════════════════
//  self/ml/grad_accumulate.hexa — Gradient Accumulation for 7B
//
//  Enables effective batch sizes larger than GPU memory allows
//  by accumulating gradients over N micro-batches before a
//  single optimizer step.
//
//  For 7B on single H100 80GB: micro_batch=1 seq=2048 is tight.
//  With accum_steps=8, effective_batch=8 without extra memory.
//
//  API:
//    ga_config(micro_batch, accum_steps)  -> GradAccumConfig
//    ga_should_step(micro_step, cfg)      -> bool
//    ga_accumulate_layer(grads, micro_grads, n_bufs, sizes, accum_steps)
//    ga_accumulate_buf(grad_buf, micro_buf, sz, accum_steps)
//    ga_zero_all_grads(all_grads, d_embed_w, d_lm_head_w, n_layers,
//                      layer_sizes, sz_embed, sz_lm_head)
//
//  Grammar (HX3): no semicolons, .push() not arr+[x], parens in slice
// ═══════════════════════════════════════════════════════════════

// ── Config ──────────────────────────────────────────────────────

struct GradAccumConfig {
    micro_batch_size: int,
    accumulation_steps: int,
    effective_batch_size: int
}

fn ga_config(micro_batch, accum_steps) {
    let eff = micro_batch * accum_steps
    return GradAccumConfig {
        micro_batch_size: micro_batch,
        accumulation_steps: accum_steps,
        effective_batch_size: eff
    }
}

// ── Step control ────────────────────────────────────────────────

// Returns true when micro_step is the last micro-batch in an
// accumulation window (i.e. time to do optimizer step).
// micro_step is 1-based within the accumulation window.
fn ga_should_step(micro_step, cfg) {
    return micro_step == cfg.accumulation_steps
}

// ── Gradient accumulation (raw f32 buffers) ─────────────────────

// Accumulate a single buffer: grad_buf += micro_buf * (1/accum_steps)
// This scales each micro-gradient by 1/accum_steps on the fly so the
// final accumulated gradient is correctly averaged.
fn ga_accumulate_buf(grad_buf, micro_buf, sz, accum_steps) {
    let scale = 1.0 / (accum_steps * 1.0)
    for i in 0..sz {
        let off = i * 4
        let existing = deref_f32(grad_buf, off)
        let micro_val = deref_f32(micro_buf, off)
        write_f32(grad_buf, off, existing + micro_val * scale)
    }
}

// Accumulate all 9 per-layer gradient buffers
// grads[0..8] are the accumulation targets
// micro_grads[0..8] are the fresh micro-batch gradients
fn ga_accumulate_layer(grads, micro_grads, n_bufs, sizes, accum_steps) {
    for idx in 0..n_bufs {
        ga_accumulate_buf(grads[idx], micro_grads[idx], sizes[idx], accum_steps)
    }
}

// ── Zero all gradients ──────────────────────────────────────────

// Zero a single f32 buffer
fn ga_zero_buf(buf, sz) {
    for i in 0..sz {
        write_f32(buf, i * 4, 0.0)
    }
}

// Zero all gradient buffers (all layers + embed + lm_head)
fn ga_zero_all_grads(all_grads, d_embed_w, d_lm_head_w,
                     n_layers, layer_sizes, sz_embed, sz_lm_head) {
    for layer in 0..n_layers {
        let grads = all_grads[layer]
        for idx in 0..9 {
            ga_zero_buf(grads[idx], layer_sizes[idx])
        }
    }
    ga_zero_buf(d_embed_w, sz_embed)
    ga_zero_buf(d_lm_head_w, sz_lm_head)
}

// ── Logging helpers ─────────────────────────────────────────────

fn ga_log_config(cfg) {
    println("[grad_accum] micro_batch=" + str(cfg.micro_batch_size)
            + " accum_steps=" + str(cfg.accumulation_steps)
            + " effective_batch=" + str(cfg.effective_batch_size))
}

println("[grad_accumulate] module loaded")
