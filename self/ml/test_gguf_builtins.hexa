// Test read_file_bytes, file_size, q4_0_matvec, q4_0_dequantize builtins

// Test 1: file_size and read_file_bytes
let sz = file_size("Cargo.toml")
println("file_size: " + str(sz))
assert(sz > 0)

let bytes = read_file_bytes("Cargo.toml", 0, 4)
println("first 4 bytes: " + str(bytes[0]) + " " + str(bytes[1]) + " " + str(bytes[2]) + " " + str(bytes[3]))

// Test 2: q4_0_dequantize
// Create a synthetic Q4_0 block: 18 bytes -> 32 weights
// f16 scale = 1.0 -> binary: 0x3C00 -> LE: [0x00, 0x3C]
// 16 nibble bytes, each nibble = 8 -> weight = scale * (8 - 8) = 0.0
let mut q4_block = [0.0, 60.0]
let mut i = 0
while i < 16 {
    q4_block = q4_block + [136.0]
    i = i + 1
}

let decoded = q4_0_dequantize(q4_block, 32)
println("q4_0_dequantize: " + str(len(decoded)) + " values")
println("first value: " + str(decoded[0]))

// Test 3: q4_0_matvec with 1 row, 32 cols
let mut x_vec = []
i = 0
while i < 32 {
    if i == 0 { x_vec = x_vec + [1.0] }
    else { x_vec = x_vec + [0.0] }
    i = i + 1
}
let result = q4_0_matvec(q4_block, x_vec, 1, 32)
println("q4_0_matvec result (expect 0): " + str(result[0]))

// Test 4: non-trivial Q4_0 block
// f16 scale = 0.5 -> 0x3800 -> LE: [0x00, 0x38]
// nibble 0,0 -> weight = 0.5 * (0 - 8) = -4.0
let mut q4_block2 = [0.0, 56.0]
i = 0
while i < 16 {
    q4_block2 = q4_block2 + [0.0]
    i = i + 1
}

let decoded2 = q4_0_dequantize(q4_block2, 32)
println("q4_0 scale=0.5 nibble=0 (expect -4): " + str(decoded2[0]))

let result2 = q4_0_matvec(q4_block2, x_vec, 1, 32)
println("q4_0_matvec scale=0.5 (expect -4): " + str(result2[0]))

// Test 5: char_code and chr
let code = char_code("ABC", 0)
println("char_code A (expect 65): " + str(code))
assert(code == 65)

let ch = chr(65)
println("chr(65) (expect A): " + ch)
assert(ch == "A")

println("ALL BUILTIN TESTS PASSED")
