// t1_v16_kvcache_sweep — kv-cache continuous decode across rank 16/8/4/2/1.
// Produces honest serving tok/s matrix.
let D = 4096
let FF = 16384
let N_LAYER = 32
let SEQ_LEN = 128

println("[t1_v16_kvcache_sweep] 7B L=" + str(N_LAYER) + " SEQ_LEN=" + str(SEQ_LEN) + " rank sweep")

// rank 16
let mut best16 = 1.0e9
let mut k = 0
while k < 3 {
    let ms = kv_cache_decode_bench(D, 16, FF, N_LAYER, SEQ_LEN)
    if ms < best16 { best16 = ms }
    k = k + 1
}
println("{\"rank\":16,\"ms\":" + str(best16) + ",\"tok_s\":" + str(1000.0/best16) + "}")

