// ═══════════════════════════════════════════════════════════════════
//  self/ml/matmul_fused.hexa — @matmul_fused prototype (pure .hexa)
//
//  AI-native CPU optimization P2: matmul + activation kernel fusion.
//  Single-pass loop computes dot-product then applies activation
//  inline, eliminating the intermediate [M x N] tensor allocation
//  that a separate `matmul -> activation` pipeline would create.
//
//  API:
//    matmul_relu(A, B, M, K, N)          -> Tensor [M x N]
//    matmul_silu(A, B, M, K, N)          -> Tensor [M x N]   (x * sigmoid(x))
//    matmul_gelu(A, B, M, K, N)          -> Tensor [M x N]   (tanh approx)
//    fused_mm_act(A, B, kind, M, K, N)   -> Tensor [M x N]
//        kind: 0=relu, 1=silu, 2=gelu
//
//  The @matmul_fused attribute is parser-accepted for forward
//  compatibility; fusion here is provided explicitly in .hexa.
// ═══════════════════════════════════════════════════════════════════

// ── scalar activation helpers (inlined by interpreter) ─────────
fn _act_relu(x) {
    if x > 0.0 { x } else { 0.0 }
}

fn _act_silu(x) {
    let s = 1.0 / (1.0 + exp(-1.0 * x))
    x * s
}

// GELU (tanh approximation):
//   0.5 * x * (1 + tanh( sqrt(2/pi) * (x + 0.044715 * x^3) ))
fn _act_gelu(x) {
    let c = 0.7978845608028654   // sqrt(2/pi)
    let x3 = x * x * x
    let u = c * (x + 0.044715 * x3)
    let e_pos = exp(u)
    let e_neg = exp(-1.0 * u)
    let th = (e_pos - e_neg) / (e_pos + e_neg)
    0.5 * x * (1.0 + th)
}

// ── matmul + ReLU fused ────────────────────────────────────────
fn matmul_relu(A, B, M, K, N) {
    let mut out = []
    let mut i = 0
    while i < M {
        let mut j = 0
        while j < N {
            let mut acc = 0.0
            let mut k = 0
            while k < K {
                acc = acc + A[i * K + k] * B[k * N + j]
                k = k + 1
            }
            out = out.push(_act_relu(acc))
            j = j + 1
        }
        i = i + 1
    }
    tensor(out, [M, N])
}

// ── matmul + SiLU fused ────────────────────────────────────────
fn matmul_silu(A, B, M, K, N) {
    let mut out = []
    let mut i = 0
    while i < M {
        let mut j = 0
        while j < N {
            let mut acc = 0.0
            let mut k = 0
            while k < K {
                acc = acc + A[i * K + k] * B[k * N + j]
                k = k + 1
            }
            out = out.push(_act_silu(acc))
            j = j + 1
        }
        i = i + 1
    }
    tensor(out, [M, N])
}

// ── matmul + GELU fused ────────────────────────────────────────
fn matmul_gelu(A, B, M, K, N) {
    let mut out = []
    let mut i = 0
    while i < M {
        let mut j = 0
        while j < N {
            let mut acc = 0.0
            let mut k = 0
            while k < K {
                acc = acc + A[i * K + k] * B[k * N + j]
                k = k + 1
            }
            out = out.push(_act_gelu(acc))
            j = j + 1
        }
        i = i + 1
    }
    tensor(out, [M, N])
}

// ── Dispatch: fused matmul+activation ──────────────────────────
// act_kind: 0=relu, 1=silu, 2=gelu
@matmul_fused
fn fused_mm_act(A, B, act_kind, M, K, N) {
    if act_kind == 0 { return matmul_relu(A, B, M, K, N) }
    if act_kind == 1 { return matmul_silu(A, B, M, K, N) }
    if act_kind == 2 { return matmul_gelu(A, B, M, K, N) }
    // default: plain matmul wrapped as tensor
    let result_arr = matmul(A, B, M, K, N)
    tensor(result_arr, [M, N])
}
