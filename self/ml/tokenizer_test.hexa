// ===================================================================
//  self/ml/tokenizer_test.hexa — BPE Tokenizer Tests
// ===================================================================

use "tokenizer"

// -- Test helpers --
let mut PASS = 0
let mut FAIL = 0

fn check(label, condition) {
    if condition {
        PASS = PASS + 1
    } else {
        println("  FAIL: " + label)
        FAIL = FAIL + 1
    }
}

// ===================================================================
//  Setup: build test vocab and merges
// ===================================================================
let vocab = make_test_vocab()
let merges = make_test_merges()

println("[tokenizer_test] vocab size: " + str(len(vocab)))
println("[tokenizer_test] merges count: " + str(len(merges)))

// ===================================================================
//  Test 1: Special token constants
// ===================================================================
println("--- Test 1: Special tokens ---")
check("BOS_ID() == 0", BOS_ID() == 0)
check("EOS_ID() == 1", EOS_ID() == 1)
check("PAD_ID() == 2", PAD_ID() == 2)
check("UNK_ID() == 3", UNK_ID() == 3)

// ===================================================================
//  Test 2: Vocab lookup
// ===================================================================
println("--- Test 2: Vocab lookup ---")
check("vocab[0] == <bos>", vocab[0] == "<bos>")
check("vocab[1] == <eos>", vocab[1] == "<eos>")
check("vocab[2] == <pad>", vocab[2] == "<pad>")
check("vocab[3] == <unk>", vocab[3] == "<unk>")

// ASCII 'a' = 97, offset from 32 starts at id 4, so 'a' = 4 + (97-32) = 69
let a_id = 4 + 97 - 32
check("vocab[a_id] == a", vocab[a_id] == "a")

let space_id = 4 + 32 - 32
check("vocab[space_id] == space", vocab[space_id] == " ")

// ===================================================================
//  Test 3: Pre-tokenization
// ===================================================================
println("--- Test 3: Pre-tokenization ---")

let words1 = pre_tokenize("hello world")
check("pre_tokenize splits 2 words", len(words1) == 2)
check("first word is hello", words1[0] == "hello")
check("second word has space prefix", words1[1] == " world")

let words2 = pre_tokenize("a b c")
check("pre_tokenize 3 words", len(words2) == 3)
check("a", words2[0] == "a")
check("_b", words2[1] == " b")
check("_c", words2[2] == " c")

let words3 = pre_tokenize("hello, world!")
check("punctuation splits", len(words3) == 4)
check("hello", words3[0] == "hello")
check("comma", words3[1] == ",")
check("_world", words3[2] == " world")
check("excl", words3[3] == "!")

let words4 = pre_tokenize("")
check("empty string", len(words4) == 0)

let words5 = pre_tokenize("x")
check("single char", len(words5) == 1)
check("single char value", words5[0] == "x")

// ===================================================================
//  Test 4: BPE encoding "hello world"
// ===================================================================
println("--- Test 4: BPE encode hello world ---")

let ids1 = bpe_encode("hello world", vocab, merges)
println("  encoded ids: " + str(ids1))

// With our merges: hello → "hello" (id 107), " world" → " world" (id 111)
check("hello world encodes to 2 tokens", len(ids1) == 2)
check("first token is hello (107)", ids1[0] == 107)
check("second token is _world (111)", ids1[1] == 111)

// ===================================================================
//  Test 5: BPE encoding with special tokens
// ===================================================================
println("--- Test 5: Encode with special tokens ---")

let ids2 = bpe_encode_special("hello world", vocab, merges)
check("special has 4 tokens", len(ids2) == 4)
check("starts with BOS", ids2[0] == BOS_ID())
check("ends with EOS", ids2[3] == EOS_ID())
check("middle is hello", ids2[1] == 107)
check("middle is _world", ids2[2] == 111)

// ===================================================================
//  Test 6: Decode
// ===================================================================
println("--- Test 6: Decode ---")

let decoded1 = bpe_decode(ids1, vocab)
check("decode hello world", decoded1 == "hello world")

let decoded2 = bpe_decode(ids2, vocab)
check("decode with special tokens", decoded2 == "hello world")

// ===================================================================
//  Test 7: Round-trip encode → decode
// ===================================================================
println("--- Test 7: Round-trip ---")

let text_rt = "hello world"
let rt_ids = bpe_encode(text_rt, vocab, merges)
let rt_text = bpe_decode(rt_ids, vocab)
check("round-trip hello world", rt_text == text_rt)

// ===================================================================
//  Test 8: Single character encoding
// ===================================================================
println("--- Test 8: Single char ---")

let ids_a = bpe_encode("a", vocab, merges)
check("single char a encodes to 1 token", len(ids_a) == 1)
check("a maps to correct id", ids_a[0] == a_id)

let dec_a = bpe_decode(ids_a, vocab)
check("round-trip single char", dec_a == "a")

// ===================================================================
//  Test 9: Empty string
// ===================================================================
println("--- Test 9: Empty string ---")

let ids_empty = bpe_encode("", vocab, merges)
check("empty encodes to 0 tokens", len(ids_empty) == 0)

let dec_empty = bpe_decode([], vocab)
check("empty decode", dec_empty == "")

// ===================================================================
//  Test 10: Punctuation handling
// ===================================================================
println("--- Test 10: Punctuation ---")

let ids_punct = bpe_encode("a,b", vocab, merges)
check("a,b encodes to 3 tokens", len(ids_punct) == 3)

let dec_punct = bpe_decode(ids_punct, vocab)
check("round-trip punctuation", dec_punct == "a,b")

// ===================================================================
//  Test 11: PAD and UNK in decode
// ===================================================================
println("--- Test 11: Special token decode ---")

let dec_pad = bpe_decode([PAD_ID(), PAD_ID()], vocab)
check("PAD tokens produce empty", dec_pad == "")

let dec_bos = bpe_decode([BOS_ID()], vocab)
check("BOS produces empty", dec_bos == "")

let dec_eos = bpe_decode([BOS_ID(), 107, EOS_ID(), 111], vocab)
check("EOS stops decode", dec_eos == "hello")

// ===================================================================
//  Test 12: Vocab utility functions
// ===================================================================
println("--- Test 12: Utility functions ---")

check("vocab_size", vocab_size(vocab) == len(vocab))
check("id_to_token hello", id_to_token(107, vocab) == "hello")
check("id_to_token unk", id_to_token(99999, vocab) == "<unk>")
check("token_to_id hello", token_to_id("hello", vocab) == 107)
check("token_to_id unknown", token_to_id("zzzzz", vocab) == UNK_ID())

// ===================================================================
//  Test 13: Multiple spaces
// ===================================================================
println("--- Test 13: Multiple spaces ---")

let ids_sp = bpe_encode("a  b", vocab, merges)
// "a" + " " (empty after space) + " b"
// Actually: first space makes current=" ", second space flushes " " and starts new " "
// Then b is appended to current " " → " b"
let dec_sp = bpe_decode(ids_sp, vocab)
check("round-trip double space", dec_sp == "a  b")

// ===================================================================
//  Test 14: Digits
// ===================================================================
println("--- Test 14: Digits ---")

let ids_num = bpe_encode("123", vocab, merges)
check("digits encode to 3 tokens", len(ids_num) == 3)
let dec_num = bpe_decode(ids_num, vocab)
check("round-trip digits", dec_num == "123")

// ===================================================================
//  Summary
// ===================================================================
println("")
println("===========================")
println("  PASS: " + str(PASS))
println("  FAIL: " + str(FAIL))
println("  TOTAL: " + str(PASS + FAIL))
println("===========================")

if FAIL > 0 {
    println("[tokenizer_test] SOME TESTS FAILED")
} else {
    println("[tokenizer_test] ALL TESTS PASSED")
}
