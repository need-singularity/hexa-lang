// ===================================================================
//  self/ml/benchmark_suite.hexa — ML Benchmark Suite in pure Hexa
//
//  MMLU / HumanEval / MT-Bench evaluators + unified report.
//
//  API:
//    run_mmlu(model, data_path, num_shot)        -> MMLUResult
//    run_humaneval(model, data_path, k)           -> HumanEvalResult
//    run_mt_bench(model, data_path)               -> MTBenchResult
//    run_all_benchmarks(model, config)             -> BenchmarkReport
//    print_report(report)                          -> console ASCII table
//
//  Data formats (JSONL):
//    MMLU:      {"question":"...","choices":["A","B","C","D"],"answer":"B","subject":"math"}
//    HumanEval: {"prompt":"def add(a,b):","test":"assert add(1,2)==3","entry_point":"add"}
//    MT-Bench:  {"turns":["prompt1","prompt2"],"references":["ref1","ref2"],"category":"reasoning"}
//
//  All pure Hexa — no FFI, no libc, no Rust src changes.
// ===================================================================

// ── math helpers ────────────────────────────────────────────────

@pure fn bench_abs(x: float) -> float {
    if x < 0.0 { return 0.0 - x }
    return x
}

@pure fn bench_ln(x: float) -> float {
    if x <= 0.0 { return 0.0 - 1000000.0 }
    let mut m = x
    let mut k = 0
    while m >= 2.0 {
        m = m / 2.0
        k = k + 1
    }
    while m < 1.0 {
        m = m * 2.0
        k = k - 1
    }
    let y = (m - 1.0) / (m + 1.0)
    let y2 = y * y
    let mut term = y
    let mut sum = 0.0
    let mut i = 0
    while i < 20 {
        sum = sum + term / (2.0 * to_float(i) * 2.0 + 1.0)
        term = term * y2
        i = i + 1
    }
    let ln2 = 0.6931471805599453
    return 2.0 * sum + to_float(k) * ln2
}

@pure fn bench_max_float(a: float, b: float) -> float {
    if a > b { return a }
    return b
}

@pure fn bench_min_float(a: float, b: float) -> float {
    if a < b { return a }
    return b
}

@pure fn bench_min_int(a: int, b: int) -> int {
    if a < b { return a }
    return b
}

// ── factorial for pass@k (returns float to avoid overflow) ─────

@pure fn factorial_f(n: int) -> float {
    let mut r = 1.0
    let mut i = 2
    while i <= n {
        r = r * to_float(i)
        i = i + 1
    }
    return r
}

// C(n, k) = n! / (k! * (n-k)!)
@pure fn comb(n: int, k: int) -> float {
    if k > n { return 0.0 }
    if k == 0 { return 1.0 }
    if k == n { return 1.0 }
    // use smaller k for efficiency
    let mut kk = k
    if kk > n - kk { kk = n - kk }
    let mut result = 1.0
    let mut i = 0
    while i < kk {
        result = result * to_float(n - i) / to_float(i + 1)
        i = i + 1
    }
    return result
}

// ── string similarity (word overlap F1) ─────────────────────────

fn tokenize_words(text) {
    let parts = text.split(" ")
    let mut tokens = []
    let mut i = 0
    while i < len(parts) {
        let w = parts[i].trim()
        if len(w) > 0 {
            tokens = tokens + [w.to_lower()]
        }
        i = i + 1
    }
    return tokens
}

fn word_overlap_f1(hyp_text, ref_text) -> float {
    let hyp_words = tokenize_words(hyp_text)
    let ref_words = tokenize_words(ref_text)
    let h_len = len(hyp_words)
    let r_len = len(ref_words)
    if h_len == 0 { return 0.0 }
    if r_len == 0 { return 0.0 }

    // count overlapping words (allow each ref word to match once)
    let mut used = []
    let mut ri = 0
    while ri < r_len {
        used = used + [false]
        ri = ri + 1
    }

    let mut matches = 0
    let mut hi = 0
    while hi < h_len {
        let mut rj = 0
        while rj < r_len {
            if used[rj] == false {
                if hyp_words[hi] == ref_words[rj] {
                    matches = matches + 1
                    used[rj] = true
                    rj = r_len  // break
                }
            }
            rj = rj + 1
        }
        hi = hi + 1
    }

    if matches == 0 { return 0.0 }
    let precision = to_float(matches) / to_float(h_len)
    let recall = to_float(matches) / to_float(r_len)
    return 2.0 * precision * recall / (precision + recall)
}

// ===================================================================
//  Result structs
// ===================================================================

struct SubjectScore {
    subject: string,
    correct: int,
    total: int,
    accuracy: float
}

struct MMLUResult {
    total_correct: int,
    total_questions: int,
    overall_accuracy: float,
    subject_scores: string,
    num_subjects: int
}

struct HumanEvalResult {
    total_problems: int,
    pass_at_1: float,
    pass_at_5: float,
    pass_at_10: float,
    num_correct: int
}

struct MTBenchResult {
    total_conversations: int,
    avg_score: float,
    category_scores: string,
    num_categories: int
}

struct BenchmarkReport {
    mmlu: string,
    humaneval: string,
    mt_bench: string,
    timestamp: string
}

// ===================================================================
//  MMLU Evaluator
//
//  Input JSONL: {"question":"...","choices":["A","B","C","D"],"answer":"B","subject":"math"}
//
//  model(prompt) -> string (the model's answer letter: "A","B","C","D")
// ===================================================================

fn format_mmlu_choices(choices) -> string {
    let labels = ["A", "B", "C", "D"]
    let mut s = ""
    let mut i = 0
    let n = len(choices)
    while i < n {
        if i < len(labels) {
            s = s + labels[i] + ". " + to_string(choices[i]) + "\n"
        }
        i = i + 1
    }
    return s
}

fn build_mmlu_prompt(question, choices, few_shot_examples) -> string {
    let mut prompt = ""

    // few-shot examples
    let num_shots = len(few_shot_examples)
    let mut si = 0
    while si < num_shots {
        let ex = few_shot_examples[si]
        let ex_q = ex["question"]
        let ex_choices = ex["choices"]
        let ex_answer = ex["answer"]
        prompt = prompt + "Question: " + to_string(ex_q) + "\n"
        prompt = prompt + format_mmlu_choices(ex_choices)
        prompt = prompt + "Answer: " + to_string(ex_answer) + "\n\n"
        si = si + 1
    }

    // actual question
    prompt = prompt + "Question: " + to_string(question) + "\n"
    prompt = prompt + format_mmlu_choices(choices)
    prompt = prompt + "Answer:"
    return prompt
}

fn parse_mmlu_data(data_path) {
    let raw = read_file(data_path)
    let lines = raw.split("\n")
    let mut records = []
    let mut i = 0
    while i < len(lines) {
        let line = lines[i].trim()
        if len(line) > 0 {
            let parsed = json_parse(line)
            records = records + [parsed]
        }
        i = i + 1
    }
    return records
}

fn collect_subjects(records) {
    let mut subjects = []
    let mut i = 0
    while i < len(records) {
        let subj = to_string(records[i]["subject"])
        // check if already in list
        let mut found = false
        let mut j = 0
        while j < len(subjects) {
            if subjects[j] == subj {
                found = true
                j = len(subjects)  // break
            }
            j = j + 1
        }
        if found == false {
            subjects = subjects + [subj]
        }
        i = i + 1
    }
    return subjects
}

fn get_few_shot_examples(records, subject, num_shot: int, exclude_idx: int) {
    let mut examples = []
    let mut i = 0
    while i < len(records) {
        if len(examples) >= num_shot {
            i = len(records)  // break
        } else {
            if i != exclude_idx {
                if to_string(records[i]["subject"]) == subject {
                    examples = examples + [records[i]]
                }
            }
            i = i + 1
        }
    }
    return examples
}

fn run_mmlu(model, data_path, num_shot: int) -> MMLUResult {
    let records = parse_mmlu_data(data_path)
    let total = len(records)

    if total == 0 {
        return MMLUResult {
            total_correct: 0,
            total_questions: 0,
            overall_accuracy: 0.0,
            subject_scores: "[]",
            num_subjects: 0
        }
    }

    let subjects = collect_subjects(records)
    let num_subj = len(subjects)

    // per-subject correct / total arrays
    let mut subj_correct = []
    let mut subj_total = []
    let mut si = 0
    while si < num_subj {
        subj_correct = subj_correct + [0]
        subj_total = subj_total + [0]
        si = si + 1
    }

    let mut all_correct = 0

    let mut i = 0
    while i < total {
        let rec = records[i]
        let question = rec["question"]
        let choices = rec["choices"]
        let answer = to_string(rec["answer"])
        let subject = to_string(rec["subject"])

        // find subject index
        let mut subj_idx = 0
        let mut sj = 0
        while sj < num_subj {
            if subjects[sj] == subject {
                subj_idx = sj
                sj = num_subj  // break
            }
            sj = sj + 1
        }

        // build few-shot prompt
        let few_shots = get_few_shot_examples(records, subject, num_shot, i)
        let prompt = build_mmlu_prompt(question, choices, few_shots)

        // get model answer
        let response = model(prompt)
        let model_answer = response.trim()

        // check correctness — compare first character
        let mut correct = false
        if len(model_answer) > 0 {
            let first_char = model_answer.substring(0, 1)
            if first_char == answer {
                correct = true
            }
        }

        if correct {
            all_correct = all_correct + 1
            subj_correct[subj_idx] = subj_correct[subj_idx] + 1
        }
        subj_total[subj_idx] = subj_total[subj_idx] + 1

        i = i + 1
    }

    // build subject scores summary string (JSONL-like)
    let mut scores_str = ""
    let mut sk = 0
    while sk < num_subj {
        let mut acc = 0.0
        if subj_total[sk] > 0 {
            acc = to_float(subj_correct[sk]) / to_float(subj_total[sk])
        }
        if sk > 0 { scores_str = scores_str + "\n" }
        scores_str = scores_str + subjects[sk] + ": " + to_string(subj_correct[sk]) + "/" + to_string(subj_total[sk]) + " (" + to_string(acc) + ")"
        sk = sk + 1
    }

    let overall_acc = to_float(all_correct) / to_float(total)

    return MMLUResult {
        total_correct: all_correct,
        total_questions: total,
        overall_accuracy: overall_acc,
        subject_scores: scores_str,
        num_subjects: num_subj
    }
}

// ===================================================================
//  MMLU from pre-parsed records (for testing without file I/O)
// ===================================================================

fn run_mmlu_from_records(model, records, num_shot: int) -> MMLUResult {
    let total = len(records)

    if total == 0 {
        return MMLUResult {
            total_correct: 0,
            total_questions: 0,
            overall_accuracy: 0.0,
            subject_scores: "[]",
            num_subjects: 0
        }
    }

    let subjects = collect_subjects(records)
    let num_subj = len(subjects)

    let mut subj_correct = []
    let mut subj_total = []
    let mut si = 0
    while si < num_subj {
        subj_correct = subj_correct + [0]
        subj_total = subj_total + [0]
        si = si + 1
    }

    let mut all_correct = 0

    let mut i = 0
    while i < total {
        let rec = records[i]
        let question = rec["question"]
        let choices = rec["choices"]
        let answer = to_string(rec["answer"])
        let subject = to_string(rec["subject"])

        let mut subj_idx = 0
        let mut sj = 0
        while sj < num_subj {
            if subjects[sj] == subject {
                subj_idx = sj
                sj = num_subj
            }
            sj = sj + 1
        }

        let few_shots = get_few_shot_examples(records, subject, num_shot, i)
        let prompt = build_mmlu_prompt(question, choices, few_shots)

        let response = model(prompt)
        let model_answer = response.trim()

        let mut correct = false
        if len(model_answer) > 0 {
            let first_char = model_answer.substring(0, 1)
            if first_char == answer {
                correct = true
            }
        }

        if correct {
            all_correct = all_correct + 1
            subj_correct[subj_idx] = subj_correct[subj_idx] + 1
        }
        subj_total[subj_idx] = subj_total[subj_idx] + 1

        i = i + 1
    }

    let mut scores_str = ""
    let mut sk = 0
    while sk < num_subj {
        let mut acc = 0.0
        if subj_total[sk] > 0 {
            acc = to_float(subj_correct[sk]) / to_float(subj_total[sk])
        }
        if sk > 0 { scores_str = scores_str + "\n" }
        scores_str = scores_str + subjects[sk] + ": " + to_string(subj_correct[sk]) + "/" + to_string(subj_total[sk]) + " (" + to_string(acc) + ")"
        sk = sk + 1
    }

    let overall_acc = to_float(all_correct) / to_float(total)

    return MMLUResult {
        total_correct: all_correct,
        total_questions: total,
        overall_accuracy: overall_acc,
        subject_scores: scores_str,
        num_subjects: num_subj
    }
}

// ===================================================================
//  HumanEval Evaluator
//
//  Input JSONL: {"prompt":"def add(a,b):","test":"assert add(1,2)==3","entry_point":"add"}
//
//  model(prompt) -> string (generated code completion)
//
//  pass@k = 1 - C(n-c, k) / C(n, k)
//    n = total samples per problem
//    c = number of correct samples
//    k = number of draws
// ===================================================================

fn compute_pass_at_k(n: int, c: int, k: int) -> float {
    if n < k { return 0.0 }
    if c == 0 { return 0.0 }
    if c >= n { return 1.0 }

    // pass@k = 1 - C(n-c, k) / C(n, k)
    let numerator = comb(n - c, k)
    let denominator = comb(n, k)
    if denominator == 0.0 { return 0.0 }
    let ratio = numerator / denominator
    return 1.0 - ratio
}

fn parse_humaneval_data(data_path) {
    let raw = read_file(data_path)
    let lines = raw.split("\n")
    let mut records = []
    let mut i = 0
    while i < len(lines) {
        let line = lines[i].trim()
        if len(line) > 0 {
            let parsed = json_parse(line)
            records = records + [parsed]
        }
        i = i + 1
    }
    return records
}

fn run_humaneval(model, data_path, k: int) -> HumanEvalResult {
    let records = parse_humaneval_data(data_path)
    return run_humaneval_from_records(model, records, k)
}

fn run_humaneval_from_records(model, records, k: int) -> HumanEvalResult {
    let total = len(records)

    if total == 0 {
        return HumanEvalResult {
            total_problems: 0,
            pass_at_1: 0.0,
            pass_at_5: 0.0,
            pass_at_10: 0.0,
            num_correct: 0
        }
    }

    // For each problem, generate k samples and check correctness
    // We use k as num_samples (n), and count correct (c)
    let num_samples = k
    let mut total_correct = 0
    let mut sum_pass1 = 0.0
    let mut sum_pass5 = 0.0
    let mut sum_pass10 = 0.0

    let mut i = 0
    while i < total {
        let rec = records[i]
        let prompt_text = to_string(rec["prompt"])
        let test_code = to_string(rec["test"])
        let entry_point = to_string(rec["entry_point"])

        // generate num_samples completions and check each
        let mut correct_count = 0
        let mut si = 0
        while si < num_samples {
            let completion = model(prompt_text)

            // simple check: does the completion + test produce "pass"?
            // In real usage this would execute the code.
            // Here we check if the model output contains the entry_point
            // and the test string contains "assert" (basic sanity).
            let full_code = prompt_text + completion
            let mut passed = false
            if full_code.contains(entry_point) {
                // model generated something referencing the function
                // simulate: model returns "pass" or "fail" as part of output
                if completion.contains("pass") {
                    passed = true
                } else {
                    if completion.contains("return") {
                        passed = true
                    }
                }
            }

            if passed {
                correct_count = correct_count + 1
            }
            si = si + 1
        }

        if correct_count > 0 {
            total_correct = total_correct + 1
        }

        // compute pass@k for this problem
        sum_pass1 = sum_pass1 + compute_pass_at_k(num_samples, correct_count, 1)
        let k5 = bench_min_int(5, num_samples)
        sum_pass5 = sum_pass5 + compute_pass_at_k(num_samples, correct_count, k5)
        let k10 = bench_min_int(10, num_samples)
        sum_pass10 = sum_pass10 + compute_pass_at_k(num_samples, correct_count, k10)

        i = i + 1
    }

    let p1 = sum_pass1 / to_float(total)
    let p5 = sum_pass5 / to_float(total)
    let p10 = sum_pass10 / to_float(total)

    return HumanEvalResult {
        total_problems: total,
        pass_at_1: p1,
        pass_at_5: p5,
        pass_at_10: p10,
        num_correct: total_correct
    }
}

// ===================================================================
//  MT-Bench Evaluator
//
//  Input JSONL: {"turns":["p1","p2"],"references":["r1","r2"],"category":"reasoning"}
//
//  model(prompt) -> string (model response)
//  Score: word-overlap F1 against reference, scaled 1-10
// ===================================================================

fn parse_mt_bench_data(data_path) {
    let raw = read_file(data_path)
    let lines = raw.split("\n")
    let mut records = []
    let mut i = 0
    while i < len(lines) {
        let line = lines[i].trim()
        if len(line) > 0 {
            let parsed = json_parse(line)
            records = records + [parsed]
        }
        i = i + 1
    }
    return records
}

fn collect_categories(records) {
    let mut cats = []
    let mut i = 0
    while i < len(records) {
        let cat = to_string(records[i]["category"])
        let mut found = false
        let mut j = 0
        while j < len(cats) {
            if cats[j] == cat {
                found = true
                j = len(cats)
            }
            j = j + 1
        }
        if found == false {
            cats = cats + [cat]
        }
        i = i + 1
    }
    return cats
}

fn run_mt_bench(model, data_path) -> MTBenchResult {
    let records = parse_mt_bench_data(data_path)
    return run_mt_bench_from_records(model, records)
}

fn run_mt_bench_from_records(model, records) -> MTBenchResult {
    let total = len(records)

    if total == 0 {
        return MTBenchResult {
            total_conversations: 0,
            avg_score: 0.0,
            category_scores: "[]",
            num_categories: 0
        }
    }

    let categories = collect_categories(records)
    let num_cats = len(categories)

    let mut cat_sum = []
    let mut cat_count = []
    let mut ci = 0
    while ci < num_cats {
        cat_sum = cat_sum + [0.0]
        cat_count = cat_count + [0]
        ci = ci + 1
    }

    let mut total_score = 0.0

    let mut i = 0
    while i < total {
        let rec = records[i]
        let turns = rec["turns"]
        let references = rec["references"]
        let category = to_string(rec["category"])

        // find category index
        let mut cat_idx = 0
        let mut cj = 0
        while cj < num_cats {
            if categories[cj] == category {
                cat_idx = cj
                cj = num_cats
            }
            cj = cj + 1
        }

        let num_turns = len(turns)
        let mut turn_score_sum = 0.0
        let mut context = ""

        let mut ti = 0
        while ti < num_turns {
            let turn_prompt = to_string(turns[ti])

            // build multi-turn context
            if len(context) > 0 {
                context = context + "\n"
            }
            context = context + turn_prompt

            // get model response
            let response = model(context)

            // score against reference (if available)
            let mut score = 5.0  // default mid score
            if ti < len(references) {
                let ref_text = to_string(references[ti])
                let f1 = word_overlap_f1(response, ref_text)
                // scale F1 (0..1) to score (1..10)
                score = 1.0 + f1 * 9.0
            }

            turn_score_sum = turn_score_sum + score

            // add response to context for next turn
            context = context + "\n" + response

            ti = ti + 1
        }

        let mut conv_score = 5.0
        if num_turns > 0 {
            conv_score = turn_score_sum / to_float(num_turns)
        }

        total_score = total_score + conv_score
        cat_sum[cat_idx] = cat_sum[cat_idx] + conv_score
        cat_count[cat_idx] = cat_count[cat_idx] + 1

        i = i + 1
    }

    // build category scores string
    let mut cat_str = ""
    let mut ck = 0
    while ck < num_cats {
        let mut avg = 0.0
        if cat_count[ck] > 0 {
            avg = cat_sum[ck] / to_float(cat_count[ck])
        }
        if ck > 0 { cat_str = cat_str + "\n" }
        cat_str = cat_str + categories[ck] + ": " + to_string(avg)
        ck = ck + 1
    }

    let avg_all = total_score / to_float(total)

    return MTBenchResult {
        total_conversations: total,
        avg_score: avg_all,
        category_scores: cat_str,
        num_categories: num_cats
    }
}

// ===================================================================
//  Unified Benchmark Runner
//
//  config: map with optional keys:
//    "mmlu_path", "humaneval_path", "mt_bench_path",
//    "num_shot" (default 5), "k" (default 10)
// ===================================================================

fn run_all_benchmarks(model, config) -> BenchmarkReport {
    let mut mmlu_str = "skipped"
    let mut he_str = "skipped"
    let mut mt_str = "skipped"

    if has_key(config, "mmlu_path") {
        let num_shot = 5
        let r = run_mmlu(model, config["mmlu_path"], num_shot)
        mmlu_str = "acc=" + to_string(r.overall_accuracy) + " correct=" + to_string(r.total_correct) + "/" + to_string(r.total_questions) + " subjects=" + to_string(r.num_subjects)
    }

    if has_key(config, "humaneval_path") {
        let k_val = 10
        let r = run_humaneval(model, config["humaneval_path"], k_val)
        he_str = "pass@1=" + to_string(r.pass_at_1) + " pass@5=" + to_string(r.pass_at_5) + " pass@10=" + to_string(r.pass_at_10) + " problems=" + to_string(r.total_problems)
    }

    if has_key(config, "mt_bench_path") {
        let r = run_mt_bench(model, config["mt_bench_path"])
        mt_str = "avg=" + to_string(r.avg_score) + " conversations=" + to_string(r.total_conversations) + " categories=" + to_string(r.num_categories)
    }

    let ts = now()

    return BenchmarkReport {
        mmlu: mmlu_str,
        humaneval: he_str,
        mt_bench: mt_str,
        timestamp: ts
    }
}

// ===================================================================
//  Report: JSONL output + ASCII table
// ===================================================================

fn report_to_jsonl(report: BenchmarkReport) -> string {
    let mut s = ""
    s = s + "{\"benchmark\":\"mmlu\",\"result\":\"" + report.mmlu + "\",\"timestamp\":\"" + report.timestamp + "\"}\n"
    s = s + "{\"benchmark\":\"humaneval\",\"result\":\"" + report.humaneval + "\",\"timestamp\":\"" + report.timestamp + "\"}\n"
    s = s + "{\"benchmark\":\"mt_bench\",\"result\":\"" + report.mt_bench + "\",\"timestamp\":\"" + report.timestamp + "\"}"
    return s
}

fn pad_right(s, width: int) -> string {
    let mut result = s
    while len(result) < width {
        result = result + " "
    }
    return result
}

fn print_report(report: BenchmarkReport) {
    println("===================================================================")
    println("  HEXA ML Benchmark Report")
    println("  Timestamp: " + report.timestamp)
    println("===================================================================")
    println("")
    println("+-------------+----------------------------------------------------+")
    println("| Benchmark   | Result                                             |")
    println("+-------------+----------------------------------------------------+")
    println("| MMLU        | " + pad_right(report.mmlu, 51) + "|")
    println("| HumanEval   | " + pad_right(report.humaneval, 51) + "|")
    println("| MT-Bench    | " + pad_right(report.mt_bench, 51) + "|")
    println("+-------------+----------------------------------------------------+")
    println("")

    // JSONL output
    println("--- JSONL ---")
    println(report_to_jsonl(report))
    println("--- end ---")
}

// ===================================================================
//  Print individual results
// ===================================================================

fn print_mmlu_result(r: MMLUResult) {
    println("MMLU: " + to_string(r.total_correct) + "/" + to_string(r.total_questions) + " = " + to_string(r.overall_accuracy))
    if r.num_subjects > 0 {
        println("  Subjects (" + to_string(r.num_subjects) + "):")
        println("  " + r.subject_scores)
    }
}

fn print_humaneval_result(r: HumanEvalResult) {
    println("HumanEval: " + to_string(r.total_problems) + " problems, " + to_string(r.num_correct) + " solved")
    println("  pass@1  = " + to_string(r.pass_at_1))
    println("  pass@5  = " + to_string(r.pass_at_5))
    println("  pass@10 = " + to_string(r.pass_at_10))
}

fn print_mt_bench_result(r: MTBenchResult) {
    println("MT-Bench: " + to_string(r.total_conversations) + " conversations, avg=" + to_string(r.avg_score))
    if r.num_categories > 0 {
        println("  Categories (" + to_string(r.num_categories) + "):")
        println("  " + r.category_scores)
    }
}

println("[benchmark_suite] loaded — run_mmlu, run_humaneval, run_mt_bench, run_all_benchmarks, print_report")
