// ===================================================================
//  self/ml/streaming_test.hexa — Streaming Token Generation Tests
//
//  Tests SSE formatting, callback collection, and streaming pipeline.
//  Does NOT require a real model — tests the framing/protocol layer.
//
//  Run: hexa self/ml/streaming_test.hexa
// ===================================================================

// ===================================================================
//  Test 1: SSE token format
// ===================================================================
@test
fn test_sse_token_format() {
    let event = format_sse_token("world")
    // Must start with "data: "
    assert(event.starts_with("data: "))
    // Must end with double newline
    assert(event.ends_with("\n\n"))
    // Must contain token value
    assert(event.contains("\"token\":\"world\""))
    // Must have finished:false
    assert(event.contains("\"finished\":false"))
}

// ===================================================================
//  Test 2: SSE done format
// ===================================================================
@test
fn test_sse_done_format() {
    let event = format_sse_done(42, 14.5)
    assert(event.starts_with("data: "))
    assert(event.ends_with("\n\n"))
    assert(event.contains("\"finished\":true"))
    assert(event.contains("\"total_tokens\":42"))
    assert(event.contains("\"tok_per_sec\":"))
    // Token should be empty string
    assert(event.contains("\"token\":\"\""))
}

// ===================================================================
//  Test 3: JSON string escaping
// ===================================================================
@test
fn test_json_escape_quotes() {
    let escaped = escape_json_str("say \"hello\"")
    assert(escaped == "say \\\"hello\\\"")
}

@test
fn test_json_escape_backslash() {
    let escaped = escape_json_str("path\\to\\file")
    assert(escaped == "path\\\\to\\\\file")
}

@test
fn test_json_escape_newline() {
    let result = format_sse_token("line1\nline2")
    // The newline inside the token should be escaped
    assert(result.contains("\\n"))
    // But the SSE framing newlines should remain
    assert(result.ends_with("\n\n"))
}

@test
fn test_json_escape_plain() {
    let escaped = escape_json_str("hello world 123")
    assert(escaped == "hello world 123")
}

// ===================================================================
//  Test 4: SSE headers
// ===================================================================
@test
fn test_sse_headers_format() {
    let h = sse_headers()
    assert(h.contains("HTTP/1.1 200 OK"))
    assert(h.contains("Content-Type: text/event-stream"))
    assert(h.contains("Cache-Control: no-cache"))
    assert(h.contains("Connection: keep-alive"))
    assert(h.contains("Access-Control-Allow-Origin: *"))
    // Must end with \r\n\r\n (empty line after headers)
    assert(h.ends_with("\r\n\r\n"))
}

// ===================================================================
//  Test 5: StreamConfig defaults
// ===================================================================
@test
fn test_stream_config_defaults() {
    let cfg = default_stream_config()
    assert(cfg.max_tokens == 128)
    assert(cfg.temperature == 0.7)
    assert(cfg.top_p == 0.9)
    assert(cfg.top_k == 40)
    assert(cfg.seed == 42)
    assert(cfg.stop_on_eos == true)
}

@test
fn test_stream_config_greedy() {
    let cfg = greedy_stream_config(256)
    assert(cfg.max_tokens == 256)
    assert(cfg.temperature == 0.0)
    assert(cfg.top_k == 0)
}

// ===================================================================
//  Test 6: Callback collection (mock streaming)
// ===================================================================
@test
fn test_callback_collection() {
    // Simulate what collect_stream does without a model
    let mut collected = ""
    let mut token_list = []
    let mut count = 0

    let callback = |tok| {
        collected = collected + tok
        token_list = token_list + [tok]
        count = count + 1
    }

    // Simulate 5 tokens
    callback("H")
    callback("e")
    callback("l")
    callback("l")
    callback("o")

    assert(collected == "Hello")
    assert(len(token_list) == 5)
    assert(count == 5)
    assert(token_list[0] == "H")
    assert(token_list[4] == "o")
}

// ===================================================================
//  Test 7: Full SSE event sequence
// ===================================================================
@test
fn test_sse_event_sequence() {
    // Build a complete SSE stream as a client would see it
    let mut stream = ""
    let tokens = ["The", " ", "cat", " ", "sat"]
    let mut i = 0
    while i < len(tokens) {
        stream = stream + format_sse_token(tokens[i])
        i = i + 1
    }
    stream = stream + format_sse_done(5, 10.0)

    // Verify structure: each event separated by double newline
    let events = stream.split("\n\n")
    // 5 token events + 1 done event + trailing empty string from split
    let n_events = len(events)
    assert(n_events >= 6)

    // First event should contain "The"
    assert(events[0].contains("\"token\":\"The\""))
    // Last real event should contain finished:true
    assert(events[5].contains("\"finished\":true"))
}

// ===================================================================
//  Test 8: Empty token handling
// ===================================================================
@test
fn test_empty_token_sse() {
    let event = format_sse_token("")
    assert(event.contains("\"token\":\"\""))
    assert(event.contains("\"finished\":false"))
}

// ===================================================================
//  Test 9: Special characters in tokens
// ===================================================================
@test
fn test_special_chars_sse() {
    let event = format_sse_token("<|end|>")
    assert(event.contains("<|end|>"))
    assert(event.contains("\"finished\":false"))
}

// ===================================================================
//  Test 10: Byte tokenizer roundtrip
// ===================================================================
@test
fn test_byte_tokenizer_roundtrip() {
    let text = "Hello"
    let tokens = byte_tokenize(text)
    // BOS + 5 chars
    assert(len(tokens) == 6)
    assert(tokens[0] == 1)

    // Decode back
    let mut decoded = ""
    let mut i = 0
    while i < len(tokens) {
        decoded = decoded + token_to_str(tokens[i])
        i = i + 1
    }
    assert(decoded == "Hello")
}

// ===================================================================
//  Run all tests
// ===================================================================
let t1 = test_sse_token_format()
let t2 = test_sse_done_format()
let t3 = test_json_escape_quotes()
let t4 = test_json_escape_backslash()
let t5 = test_json_escape_newline()
let t6 = test_json_escape_plain()
let t7 = test_sse_headers_format()
let t8 = test_stream_config_defaults()
let t9 = test_stream_config_greedy()
let t10 = test_callback_collection()
let t11 = test_sse_event_sequence()
let t12 = test_empty_token_sse()
let t13 = test_special_chars_sse()
let t14 = test_byte_tokenizer_roundtrip()

let mut pass = 0
let mut fail = 0
let results = [t1, t2, t3, t4, t5, t6, t7, t8, t9, t10, t11, t12, t13, t14]
let names = [
    "sse_token_format", "sse_done_format",
    "json_escape_quotes", "json_escape_backslash",
    "json_escape_newline", "json_escape_plain",
    "sse_headers_format",
    "stream_config_defaults", "stream_config_greedy",
    "callback_collection", "sse_event_sequence",
    "empty_token_sse", "special_chars_sse",
    "byte_tokenizer_roundtrip"
]

let mut idx = 0
while idx < len(results) {
    if results[idx] == true {
        pass = pass + 1
    } else {
        fail = fail + 1
        println("[FAIL] " + names[idx])
    }
    idx = idx + 1
}

println("[streaming_test] " + str(pass) + "/" + str(len(results)) + " passed")
if fail > 0 {
    println("[streaming_test] " + str(fail) + " FAILED")
}
