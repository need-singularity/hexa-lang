// ═══════════════════════════════════════════════════════════════════
//  self/ml/sparse_mm.hexa — @sparse matmul prototype (pure .hexa)
//
//  AI-native CPU optimization P2-1: sparsity-aware matmul.
//  When input tensor has >= `ratio` zeros, switch to CSR sparse path
//  for O(nnz * N) instead of O(M*K*N) dense matmul.
//
//  API:
//    is_sparse(t, threshold)           -> bool
//    to_csr(t, rows, cols)             -> [values, col_idx, row_ptr]
//    sparse_mm_csr(csr, B, M, K, N)    -> Tensor (dense result [M x N])
//    auto_mm(A, B, M, K, N, ratio)     -> Tensor (auto sparse/dense)
//
//  @sparse(ratio) attribute is parser-accepted (verified) but has no
//  runtime hook yet — auto_mm() provides the behavior explicitly.
// ═══════════════════════════════════════════════════════════════════

// ── zero-ratio check ────────────────────────────────────────────
fn is_sparse(t, threshold) {
    let n = len(t)
    if n == 0 { return false }
    let mut zeros = 0
    let mut i = 0
    while i < n {
        let v = t[i]
        // treat |v| < 1e-12 as zero to be float-safe
        let av = if v < 0.0 { -1.0 * v } else { v }
        if av < 0.000000000001 { zeros = zeros + 1 }
        i = i + 1
    }
    let ratio = (zeros * 1.0) / (n * 1.0)
    ratio >= threshold
}

// ── CSR conversion ──────────────────────────────────────────────
// Returns a dict { values: [float], col_idx: [int], row_ptr: [int] }
// for an [rows x cols] row-major flat tensor.
fn to_csr(t, rows, cols) {
    let mut values = []
    let mut col_idx = []
    let mut row_ptr = [0]
    let mut r = 0
    let mut nnz = 0
    while r < rows {
        let mut c = 0
        while c < cols {
            let v = t[r * cols + c]
            let av = if v < 0.0 { -1.0 * v } else { v }
            if av >= 0.000000000001 {
                values = values.push(v)
                col_idx = col_idx.push(c)
                nnz = nnz + 1
            }
            c = c + 1
        }
        row_ptr = row_ptr.push(nnz)
        r = r + 1
    }
    [values, col_idx, row_ptr]
}

// ── Sparse × Dense matmul (CSR A × dense B) ─────────────────────
// A: CSR representation of [M x K]
// B: dense flat tensor [K x N] row-major
// Returns tensor [M x N]
fn sparse_mm_csr(csr, B, M, K, N) {
    let values = csr[0]
    let col_idx = csr[1]
    let row_ptr = csr[2]
    let mut out = []
    let total = M * N
    let mut z = 0
    while z < total {
        out = out.push(0.0)
        z = z + 1
    }
    let mut i = 0
    while i < M {
        let start = row_ptr[i]
        let end = row_ptr[i + 1]
        let mut p = start
        while p < end {
            let k = col_idx[p]
            let a_val = values[p]
            let mut j = 0
            while j < N {
                let idx = i * N + j
                out[idx] = out[idx] + a_val * B[k * N + j]
                j = j + 1
            }
            p = p + 1
        }
        i = i + 1
    }
    tensor(out, [M, N])
}

// ── Auto: dispatch to sparse/dense based on sparsity ────────────
@sparse(0.5)
fn auto_mm(A, B, M, K, N, ratio) {
    if is_sparse(A, ratio) {
        let csr = to_csr(A, M, K)
        return sparse_mm_csr(csr, B, M, K, N)
    }
    let result_arr = matmul(A, B, M, K, N)
    tensor(result_arr, [M, N])
}
