// t1_v14_kvcache — end-to-end continuous decode with growing kv-cache.
// Uses kv_cache_decode_bench builtin which does:
//   1. Init weights, 3-warmup, reset cache
//   2. Decode 64 tokens sequentially, each attending to growing context
//   3. Return ms_per_token
// This is the REAL serving number (not single-forward-pass).
let D = 4096
let R = 4
let FF = 16384
let N_LAYER = 32
let SEQ_LEN = 128

println("[t1_v14_kvcache] 7B r=" + str(R) + " L=" + str(N_LAYER) + " SEQ_LEN=" + str(SEQ_LEN) + " (continuous decode)")

let mut k = 0
let mut sum_ms = 0.0
let mut best_ms = 1.0e9
let mut worst_ms = 0.0
let runs = 5
while k < runs {
    let ms_per_tok = kv_cache_decode_bench(D, R, FF, N_LAYER, SEQ_LEN)
    sum_ms = sum_ms + ms_per_tok
    if ms_per_tok < best_ms { best_ms = ms_per_tok }
    if ms_per_tok > worst_ms { worst_ms = ms_per_tok }
    k = k + 1
}
let avg_ms = sum_ms / (runs * 1.0)
let tok_s_avg = 1000.0 / avg_ms
let tok_s_best = 1000.0 / best_ms
let tok_s_worst = 1000.0 / worst_ms

let mut line = "{\"phase\":\"t1_v14_kvcache\",\"runs\":" + str(runs)
line = line + ",\"rank\":" + str(R)
line = line + ",\"seq_len\":" + str(SEQ_LEN)
line = line + ",\"ms_per_tok_avg\":" + str(avg_ms)
line = line + ",\"ms_per_tok_best\":" + str(best_ms)
line = line + ",\"ms_per_tok_worst\":" + str(worst_ms)
line = line + ",\"tok_s_avg\":" + str(tok_s_avg)
line = line + ",\"tok_s_best\":" + str(tok_s_best)
line = line + ",\"tok_s_worst\":" + str(tok_s_worst) + "}"
println(line)
