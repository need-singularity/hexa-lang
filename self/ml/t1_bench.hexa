// ═══════════════════════════════════════════════════════════════
//  self/ml/t1_bench.hexa — T1 baseline: 7B-fake forward tok/s harness
//
//  Purpose: Measure *current* (pre-optimization) 1-token forward latency
//  for a 7B-class Transformer on CPU (htz: Ryzen 9 7950X3D 32T / 124GB).
//
//  Strategy (빠른 돌파용, 완벽 구현 불요):
//    - matmul 비중이 forward 시간의 ~95% 이므로 matmul 위주로 시뮬.
//    - 7B config: d=4096, n_layers=32, n_heads=32, vocab=32000, seq=128.
//    - 전체 7B 메모리(14GB fp32)를 할당하지 않고, **1 layer 만 실제 할당**
//      후 32× 반복 호출하여 memory-bandwidth 지배 상황을 재현.
//    - weights 는 random fill (정확성 무관, timing 만).
//    - int8-simulation 상정 bandwidth = 3.5 GB / step.
//
//  Output: stdout 마지막 줄에 JSON one-liner
//    {"ts": .., "host": "htz", "model": "7B_fake", "tok_s": ..,
//     "ms_per_tok": .., "bw_gbs": .., "p50_ms": .., "p95_ms": ..,
//     "iters": .., "layers": 32}
// ═══════════════════════════════════════════════════════════════

// ── 7B config ──────────────────────────────────────────────
let D_MODEL = 4096
let N_LAYERS = 32
let N_HEADS = 32
let SEQ = 8              // reduced from 128 for interpreter practicality
let FFN_MULT = 4         // 4096 * 4 = 16384
// Shrink factor: real 7B 1-layer matmul is seq*d*d*4 ≈ 128*4096*4096*4 FLOPs
// which is ~8.5G FLOPs per layer — too slow per step in an interpreter.
// We shrink the *effective* inner dim to keep each step bounded while
// preserving the memory-bandwidth signature (dominant cost).
let SHRINK = 128         // inner dim / SHRINK (aggressive for interpreter)
let BYTES_PER_STEP_INT8 = 3500000000   // ~3.5 GB (7B int8 weights fetched)

// ── tiny rand (LCG, deterministic) ─────────────────────────
let mut RNG = 2463534242

fn t1_rand() {
    // 32-bit LCG (Numerical Recipes)
    RNG = (RNG * 1664525 + 1013904223)
    // keep positive small float in [-0.05, 0.05]
    let m = RNG % 10000
    let f = to_float(str(m)) / 10000.0 - 0.5
    return f * 0.1
}

fn t1_rand_mat(rows, cols) {
    let mut m = []
    let mut i = 0
    while i < rows {
        let mut row = []
        let mut j = 0
        while j < cols {
            row.push(t1_rand())
            j = j + 1
        }
        m.push(row)
        i = i + 1
    }
    return m
}

fn t1_zeros_mat(rows, cols) {
    let mut m = []
    let mut i = 0
    while i < rows {
        let mut row = []
        let mut j = 0
        while j < cols { row.push(0.0); j = j + 1 }
        m.push(row)
        i = i + 1
    }
    return m
}

// ── shrunken matmul: x[s, d] @ W[d, d'] = y[s, d'] ─────────
fn t1_matmul(x, W, S, D_in, D_out) {
    let mut y = t1_zeros_mat(S, D_out)
    let mut i = 0
    while i < S {
        let xr = x[i]
        let mut j = 0
        while j < D_out {
            let mut acc = 0.0
            let mut k = 0
            while k < D_in {
                acc = acc + xr[k] * W[k][j]
                k = k + 1
            }
            y[i][j] = acc
            j = j + 1
        }
        i = i + 1
    }
    return y
}

// ── 1-layer forward (QKV + attn-proxy + FFN) ───────────────
// Uses shrunken inner dim to keep interpreter time reasonable.
// Weights are passed in (allocated once, reused × N_LAYERS).
fn t1_layer_forward(x, Wq, Wk, Wv, Wo, W1, W2, S, Di) {
    // QKV projection (3 matmuls) — input [S,Di] -> [S,Di]
    let q = t1_matmul(x, Wq, S, Di, Di)
    let k = t1_matmul(x, Wk, S, Di, Di)
    let v = t1_matmul(x, Wv, S, Di, Di)
    // attention proxy: just another matmul q @ Wo (skip softmax — timing only)
    let attn = t1_matmul(q, Wo, S, Di, Di)
    // FFN up [S,Di]->[S,Di*4] then down [S,Di*4]->[S,Di]
    let h = t1_matmul(attn, W1, S, Di, Di * 4)
    let o = t1_matmul(h,    W2, S, Di * 4, Di)
    return o
}

// ── build one-layer weights once (shared across 32 simulated layers) ──
fn t1_build_layer(Di) {
    let Wq = t1_rand_mat(Di, Di)
    let Wk = t1_rand_mat(Di, Di)
    let Wv = t1_rand_mat(Di, Di)
    let Wo = t1_rand_mat(Di, Di)
    let W1 = t1_rand_mat(Di, Di * 4)
    let W2 = t1_rand_mat(Di * 4, Di)
    let mut pack = []
    pack.push(Wq)
    pack.push(Wk)
    pack.push(Wv)
    pack.push(Wo)
    pack.push(W1)
    pack.push(W2)
    return pack
}

// ── sort helper for percentiles ────────────────────────────
fn t1_sort(arr) {
    let mut a = []
    let mut i = 0
    while i < len(arr) { a.push(arr[i]); i = i + 1 }
    let n = len(a)
    let mut ii = 0
    while ii < n {
        let mut jj = ii + 1
        while jj < n {
            if a[jj] < a[ii] {
                let t = a[ii]
                a[ii] = a[jj]
                a[jj] = t
            }
            jj = jj + 1
        }
        ii = ii + 1
    }
    return a
}

fn t1_pct(sorted, p) {
    let n = len(sorted)
    if n == 0 { return 0 }
    let mut idx = 0
    let tgt = p * n
    while (idx + 1) <= tgt { idx = idx + 1 }
    if idx >= n { idx = n - 1 }
    if idx < 0 { idx = 0 }
    return sorted[idx]
}

// ── one forward: build input + 32× reuse of the shrunken layer ──
fn t1_forward_once(pack, Di) {
    let Wq = pack[0]
    let Wk = pack[1]
    let Wv = pack[2]
    let Wo = pack[3]
    let W1 = pack[4]
    let W2 = pack[5]
    let mut x = t1_rand_mat(SEQ, Di)
    let mut l = 0
    while l < N_LAYERS {
        x = t1_layer_forward(x, Wq, Wk, Wv, Wo, W1, W2, SEQ, Di)
        l = l + 1
    }
    return x
}

// ── @bench fn (zero-arg) — 10 iters w/ 2 warmup ────────────
let mut T1_RESULTS = []

@bench fn bench_forward_1token() {
    let Di = D_MODEL / SHRINK    // shrunken inner dim
    let pack = t1_build_layer(Di)

    // warmup
    let mut w = 0
    while w < 1 {
        let _ = t1_forward_once(pack, Di)
        w = w + 1
    }

    let mut lats = []
    let mut it = 0
    while it < 3 {
        let s0 = clock()
        let _ = t1_forward_once(pack, Di)
        let s1 = clock()
        let ms = (s1 - s0) * 1000.0
        lats.push(ms)
        it = it + 1
    }
    T1_RESULTS = lats
    return len(lats)
}

// ── main: run bench + emit JSON line ───────────────────────
println("[t1_bench] starting 7B-fake forward timing…")
let _ = bench_forward_1token()

let sorted = t1_sort(T1_RESULTS)
let p50 = t1_pct(sorted, 0.50)
let p95 = t1_pct(sorted, 0.95)

// mean
let mut sum = 0.0
let mut i = 0
while i < len(sorted) { sum = sum + sorted[i]; i = i + 1 }
let mean_ms = sum / len(sorted)

// tok/s and bandwidth (using median as representative)
let ms_per_tok = p50
let mut tok_s = 0.0
if ms_per_tok > 0 { tok_s = 1000.0 / ms_per_tok }
// bandwidth: 3.5GB / sec_per_tok
let sec_per_tok = ms_per_tok / 1000.0
let mut bw_gbs = 0.0
if sec_per_tok > 0 { bw_gbs = (BYTES_PER_STEP_INT8 / sec_per_tok) / 1000000000.0 }

let ts = clock()

// JSON emit (single line, starts with '{')
let mut line = "{"
line = line + "\"ts\":" + str(ts)
line = line + ",\"host\":\"htz\""
line = line + ",\"model\":\"7B_fake\""
line = line + ",\"tok_s\":" + str(tok_s)
line = line + ",\"ms_per_tok\":" + str(ms_per_tok)
line = line + ",\"bw_gbs\":" + str(bw_gbs)
line = line + ",\"p50_ms\":" + str(p50)
line = line + ",\"p95_ms\":" + str(p95)
line = line + ",\"mean_ms\":" + str(mean_ms)
line = line + ",\"iters\":" + str(len(sorted))
line = line + ",\"layers\":" + str(N_LAYERS)
line = line + ",\"seq\":" + str(SEQ)
line = line + ",\"d_model\":" + str(D_MODEL)
line = line + ",\"shrink\":" + str(SHRINK)
line = line + "}"

println(line)
