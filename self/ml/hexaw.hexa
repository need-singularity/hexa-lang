// ═══════════════════════════════════════════════════════════
//  hexaw.hexa — .hexaw weight format (Phase 0 loader/saver)
//
//  Two on-disk formats:
//    HEXAW1  — legacy plaintext (float-as-decimal, whitespace-
//              delimited). Still written by hexaw_save() for
//              backward compatibility with smoke tests that rely
//              on a purely text-based dump.
//    HEXAW2  — binary f32 (little-endian). Raw IEEE-754 bytes,
//              ~3.5× smaller than HEXAW1 on Qwen2.5-14B (56GB
//              vs 118GB) so the converted file actually fits on
//              H100 NVMe. Written by hexaw_save_binary() and
//              streaming callers via self/tools/safetensors_to_hexaw.
//
//  HEXAW2 on-disk layout (newline-terminated header lines, raw
//  f32 payload; payload is *not* newline-terminated to stay
//  exactly count*4 bytes regardless of byte values):
//
//      "HEXAW2\n"
//      "<n_tensors>\n"
//      Per tensor:
//          "<name>\n"
//          "<ndim>\n"
//          "<d0>\n<d1>\n...\n<d(ndim-1)>\n"
//          "<count>\n"
//          <count * 4 raw LE f32 bytes>   (no trailing newline)
//
//  Public API:
//      hexaw_save(path, names, shapes, datas)          — HEXAW1 plaintext
//      hexaw_save_binary(path, names, shapes, datas)   — HEXAW2, buffered
//      hexaw_load(path) -> HexawRecord                 — autodetects magic
//      hexaw_tensor(hxw, name) -> flat float array     (@memoize cache)
//      hexaw_from_arrays(names, shapes, datas)         convenience
//
//  AI-NATIVE attrs:
//      @lazy       parse on first access (mmap-like)
//      @memoize    weight_dict cache — repeated tensor fetch O(1)
//      @pure       math helpers
// ═══════════════════════════════════════════════════════════

// ── tiny int-to-string / float-to-string helpers ─────────
@pure
fn hexaw_i2s(n) { return to_string(n) }

@pure
fn hexaw_f2s(x) { return to_string(x) }

// ── split one whitespace-delimited "word stream" into tokens ─
fn hexaw_tokenize(src) {
    // normalize newlines to spaces then split on spaces, drop empties
    let mut s = ""
    let chars = src.chars()
    let n = len(chars)
    let mut i = 0
    while i < n {
        let c = to_string(chars[i])
        if c == "\n" || c == "\t" || c == "\r" {
            s = s + " "
        } else {
            s = s + c
        }
        i = i + 1
    }
    let raw = s.split(" ")
    let mut toks = []
    let m = len(raw)
    let mut k = 0
    while k < m {
        if len(raw[k]) > 0 {
            toks = toks + [raw[k]]
        }
        k = k + 1
    }
    return toks
}

// ── product of a shape list ──────────────────────────────
@pure
fn hexaw_numel(shape) {
    let mut p = 1
    let n = len(shape)
    let mut i = 0
    while i < n { p = p * shape[i]; i = i + 1 }
    return p
}

// ── SAVE (HEXAW1, plaintext) ─────────────────────────────
//  names:  [string]            tensor names
//  shapes: [[int]]             per-tensor shape list
//  datas:  [[float]]           per-tensor flat data
fn hexaw_save(path, names, shapes, datas) {
    let n = len(names)
    let mut out = "HEXAW1\n" + hexaw_i2s(n) + "\n"
    let mut i = 0
    while i < n {
        let name = names[i]
        let shape = shapes[i]
        let data = datas[i]
        let ndim = len(shape)
        let count = len(data)
        let mut header = name + " " + hexaw_i2s(ndim)
        let mut d = 0
        while d < ndim {
            header = header + " " + hexaw_i2s(shape[d])
            d = d + 1
        }
        header = header + " " + hexaw_i2s(count) + "\n"
        out = out + header

        let mut row = ""
        let mut j = 0
        while j < count {
            if j > 0 { row = row + " " }
            row = row + hexaw_f2s(data[j])
            j = j + 1
        }
        out = out + row + "\n"
        i = i + 1
    }
    write_file(path, out)
    return true
}

// ── IEEE-754 f32 → 4 little-endian bytes ─────────────────
// Hand-rolled bit-level encoder: hexa has no bitcast intrinsic
// and runs the converter in interpreter mode during the test
// (so we cannot fall back to a C shim). Works for finite values,
// ±0, subnormals and Inf/NaN round-trip bit-exactly.
@pure
fn hexaw_f32_to_bytes(x) {
    // Sign
    let mut sign = 0
    let mut v = x
    if v < 0.0 { sign = 1; v = 0.0 - v }
    // NaN — emit a canonical quiet NaN (0x7fc00000)
    if x != x {
        return [0, 0, 192, 127]
    }
    // Zero
    if v == 0.0 {
        if sign == 1 { return [0, 0, 0, 128] }
        return [0, 0, 0, 0]
    }
    // Infinity detection: compare against a very large finite upper bound.
    // Fails for IEEE finite numbers above ~3.4e38 (out of f32 range anyway).
    if v > 3.4028235e38 {
        if sign == 1 { return [0, 0, 128, 255] }
        return [0, 0, 128, 127]
    }
    // Decompose into 2^e * m, 1.0 ≤ m < 2.0
    let mut e = 0
    let mut m = v
    while m >= 2.0 { m = m / 2.0; e = e + 1 }
    while m < 1.0 { m = m * 2.0; e = e - 1 }
    let biased = e + 127
    // Subnormal if biased ≤ 0: IEEE stores significand without the
    // implicit 1 and with exponent field 0.
    let mut exp_bits = 0
    let mut mant_bits = 0
    if biased <= 0 {
        // Shift mantissa right by (1 - biased) positions relative to
        // the normalized form, then truncate to 23 bits.
        let shift = 1 - biased
        let mut sub = m
        let mut s = 0
        while s < shift { sub = sub / 2.0; s = s + 1 }
        // sub is in [0, 1). Multiply by 2^23 to get the 23-bit mantissa.
        let scaled = sub * 8388608.0
        mant_bits = to_int(scaled)
        exp_bits = 0
    } else if biased >= 255 {
        // Already handled above, but keep a defensive branch.
        exp_bits = 255
        mant_bits = 0
    } else {
        // Normal: drop the implicit leading 1, encode 23 fractional bits.
        let frac = m - 1.0
        let scaled = frac * 8388608.0
        mant_bits = to_int(scaled)
        exp_bits = biased
    }
    // Pack into 32-bit word: sign(1) | exp(8) | mant(23)
    let b0 = mant_bits % 256
    let b1 = (mant_bits / 256) % 256
    let lo_exp = exp_bits % 2          // low bit of exponent goes into bit 7 of b2
    let hi_exp = exp_bits / 2          // upper 7 bits into b3
    let b2 = ((mant_bits / 65536) % 128) + lo_exp * 128
    let b3 = (sign * 128) + hi_exp
    return [b0, b1, b2, b3]
}

// ── 4 little-endian bytes → IEEE-754 f32 ────────────────
@pure
fn hexaw_bytes_to_f32(b0, b1, b2, b3) {
    let sign = b3 / 128
    let exp_bits = ((b3 % 128) * 2) + (b2 / 128)
    let mant_bits = (b2 % 128) * 65536 + b1 * 256 + b0
    // Special cases
    if exp_bits == 0 && mant_bits == 0 {
        if sign == 1 { return 0.0 - 0.0 }
        return 0.0
    }
    if exp_bits == 255 {
        // NaN or Inf — emit sentinel floats. NaN collapses to Inf in the
        // hexa runtime, which is acceptable for our weight payload.
        if sign == 1 { return 0.0 - 3.4028235e38 }
        return 3.4028235e38
    }
    let mut mant = 0.0
    if exp_bits == 0 {
        // Subnormal
        mant = to_float(mant_bits) / 8388608.0
    } else {
        // Normal: implicit leading 1
        mant = 1.0 + to_float(mant_bits) / 8388608.0
    }
    let mut e = exp_bits - 127
    let mut val = mant
    if exp_bits == 0 { e = -126 }
    if e >= 0 {
        let mut i = 0
        while i < e { val = val * 2.0; i = i + 1 }
    } else {
        let mut i = 0
        while i < (0 - e) { val = val / 2.0; i = i + 1 }
    }
    if sign == 1 { val = 0.0 - val }
    return val
}

// ── SAVE (HEXAW2, binary f32 little-endian) ──────────────
// Buffered single-shot write — safe for small tensors in the
// interpreter smoke test. The production converter uses
// write_bytes_append directly and streams per chunk so it can
// handle the full 56GB 14B dump without buffering in RAM.
fn hexaw_save_binary(path, names, shapes, datas) {
    let n = len(names)
    let mut buf = []
    // header: "HEXAW2\n" (7 bytes) + <n_tensors>\n
    let hdr_str = "HEXAW2\n" + hexaw_i2s(n) + "\n"
    let mut hi = 0
    while hi < len(hdr_str) {
        buf = buf + [char_code(hdr_str, hi)]
        hi = hi + 1
    }
    let mut i = 0
    while i < n {
        let name = names[i]
        let shape = shapes[i]
        let data = datas[i]
        let ndim = len(shape)
        let count = len(data)
        // Per-tensor header: name\nndim\nd0..d(ndim-1)\ncount\n
        let mut hstr = name + "\n" + hexaw_i2s(ndim) + "\n"
        let mut d = 0
        while d < ndim {
            hstr = hstr + hexaw_i2s(shape[d]) + "\n"
            d = d + 1
        }
        hstr = hstr + hexaw_i2s(count) + "\n"
        let mut hi2 = 0
        while hi2 < len(hstr) {
            buf = buf + [char_code(hstr, hi2)]
            hi2 = hi2 + 1
        }
        // Payload: count × f32 LE
        let mut j = 0
        while j < count {
            let bs = hexaw_f32_to_bytes(data[j])
            buf = buf + bs
            j = j + 1
        }
        i = i + 1
    }
    write_bytes(path, buf)
    return true
}

// ── HexaW record struct ─────────────────────────────────
struct HexawRecord {
    path: string,
    names: array,
    shapes: array,
    datas: array
}

// ── LOAD ─────────────────────────────────────────────────
//  Autodetects magic: HEXAW1 (plaintext) or HEXAW2 (binary f32).
//  Returns HexawRecord with names/shapes/datas arrays.
//
//  NOTE: the original @lazy attr was removed because the lazy-thunk
//  cache in self/hexa_full.hexa is keyed by function name only and
//  would return the same HexawRecord for every path. For big single-
//  shot loads callers can cache the record themselves.
fn hexaw_load(path) {
    // Peek first 7 bytes to disambiguate format. read_file_bytes
    // with no length still loads the whole file — fine for the
    // smoke test (KB-range) but the native converter path reads
    // HEXAW2 tensors on demand via hexaw_load_binary_streaming.
    let raw = read_file_bytes(path)
    let nb = len(raw)
    if nb < 7 {
        println("[hexaw] ERROR: empty/short file " + path)
        return HexawRecord { path: path, names: [], shapes: [], datas: [] }
    }
    // Magic byte 0-5 = "HEXAW", byte 6 = '1' or '2'
    if raw[0] == 72 && raw[1] == 69 && raw[2] == 88 && raw[3] == 65 && raw[4] == 87 && raw[5] == 50 {
        return hexaw_load_binary_from_bytes(path, raw)
    }
    // Legacy text path — reuse existing tokenizer
    let src = read_file(path)
    return hexaw_load_text(path, src)
}

// HEXAW1 text parser (extracted from the original hexaw_load).
fn hexaw_load_text(path, src) {
    let toks = hexaw_tokenize(src)
    let ntok = len(toks)
    if ntok < 2 {
        println("[hexaw] ERROR: empty/short file " + path)
        return HexawRecord { path: path, names: [], shapes: [], datas: [] }
    }
    if toks[0] != "HEXAW1" {
        println("[hexaw] ERROR: bad magic " + toks[0])
        return HexawRecord { path: path, names: [], shapes: [], datas: [] }
    }
    let n = to_int(toks[1])
    let mut names = []
    let mut shapes = []
    let mut datas = []
    let mut p = 2
    let mut t = 0
    while t < n {
        if p >= ntok {
            println("[hexaw] ERROR: truncated header")
            return HexawRecord { path: path, names: names, shapes: shapes, datas: datas }
        }
        let name = toks[p]; p = p + 1
        let ndim = to_int(toks[p]); p = p + 1
        let mut shape = []
        let mut d = 0
        while d < ndim {
            shape = shape + [to_int(toks[p])]
            p = p + 1
            d = d + 1
        }
        let count = to_int(toks[p]); p = p + 1
        let mut data = []
        let mut j = 0
        while j < count {
            data = data + [to_float(toks[p])]
            p = p + 1
            j = j + 1
        }
        names = names + [name]
        shapes = shapes + [shape]
        datas = datas + [data]
        t = t + 1
    }
    return HexawRecord { path: path, names: names, shapes: shapes, datas: datas }
}

// HEXAW2 binary parser — walks newline-delimited header fields
// then pulls count*4 raw bytes per tensor and decodes f32 LE.
// Accepts the full byte array (caller has already slurped the file).
fn hexaw_load_binary_from_bytes(path, raw) {
    let nb = len(raw)
    let mut pos = 0
    // Skip "HEXAW2\n"
    pos = 7
    // Read n_tensors (ASCII digits until \n)
    let mut nstr = ""
    while pos < nb && raw[pos] != 10 {
        nstr = nstr + to_string(from_char_code(raw[pos]))
        pos = pos + 1
    }
    pos = pos + 1
    let n = to_int(nstr)
    let mut names = []
    let mut shapes = []
    let mut datas = []
    let mut t = 0
    while t < n {
        // name line
        let mut name = ""
        while pos < nb && raw[pos] != 10 {
            name = name + to_string(from_char_code(raw[pos]))
            pos = pos + 1
        }
        pos = pos + 1
        // ndim
        let mut ndstr = ""
        while pos < nb && raw[pos] != 10 {
            ndstr = ndstr + to_string(from_char_code(raw[pos]))
            pos = pos + 1
        }
        pos = pos + 1
        let ndim = to_int(ndstr)
        // dims
        let mut shape = []
        let mut d = 0
        while d < ndim {
            let mut ds = ""
            while pos < nb && raw[pos] != 10 {
                ds = ds + to_string(from_char_code(raw[pos]))
                pos = pos + 1
            }
            pos = pos + 1
            shape = shape + [to_int(ds)]
            d = d + 1
        }
        // count
        let mut cs = ""
        while pos < nb && raw[pos] != 10 {
            cs = cs + to_string(from_char_code(raw[pos]))
            pos = pos + 1
        }
        pos = pos + 1
        let count = to_int(cs)
        // payload: count * 4 bytes LE f32
        let mut data = []
        let mut j = 0
        while j < count {
            let b0 = raw[pos]
            let b1 = raw[pos + 1]
            let b2 = raw[pos + 2]
            let b3 = raw[pos + 3]
            pos = pos + 4
            data = data + [hexaw_bytes_to_f32(b0, b1, b2, b3)]
            j = j + 1
        }
        names = names + [name]
        shapes = shapes + [shape]
        datas = datas + [data]
        t = t + 1
    }
    return HexawRecord { path: path, names: names, shapes: shapes, datas: datas }
}

// ── @memoize weight_dict cache — lookup flat data by name ─
@memoize
fn hexaw_tensor(hxw, name) {
    let names = hxw.names
    let n = len(names)
    let mut i = 0
    while i < n {
        if names[i] == name {
            return hxw.datas[i]
        }
        i = i + 1
    }
    return []
}

// ── shape lookup ─────────────────────────────────────────
fn hexaw_shape(hxw, name) {
    let names = hxw.names
    let n = len(names)
    let mut i = 0
    while i < n {
        if names[i] == name { return hxw.shapes[i] }
        i = i + 1
    }
    return []
}

// ── JSON-style weight dict → hexaw tuple (convenience) ──
//  Accepts parallel arrays (names, shapes, datas). A JSON
//  bridge can be added once json_parse returns a struct.
fn hexaw_from_arrays(names, shapes, datas) {
    return HexawRecord { path: "", names: names, shapes: shapes, datas: datas }
}
