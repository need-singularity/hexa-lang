// ===================================================================
//  self/ml/eval_runner.hexa — Evaluation loop runner
//
//  Iterates over an eval dataset in batches, accumulates metrics,
//  and prints a summary table.
//
//  Usage:
//    let result = run_eval(model_fn, dataset, batch_size, vocab_size, num_classes)
//    print_eval_summary(result)
//
//  model_fn: fn(input) -> logits array (vocab_size floats)
//  dataset:  array of [input, label] pairs
// ===================================================================

struct EvalResult {
    total_samples: int,
    top1_acc: float,
    top5_acc: float,
    avg_loss: float,
    ppl: float,
    micro_f1: float,
    macro_f1: float
}

// ===================================================================
//  Run evaluation over dataset in batches
//
//  model_fn:    fn(input) -> logits (array of vocab_size floats)
//  dataset:     array of [input, label] pairs
//  batch_size:  how many samples per batch
//  vocab_size:  logit dimension
//  num_classes: for F1 computation
// ===================================================================

fn run_eval(model_fn, dataset, batch_size: int, vocab_size: int, num_classes: int) -> EvalResult {
    let total = len(dataset)
    if total == 0 {
        return EvalResult {
            total_samples: 0,
            top1_acc: 0.0,
            top5_acc: 0.0,
            avg_loss: 0.0,
            ppl: 1.0,
            micro_f1: 0.0,
            macro_f1: 0.0
        }
    }

    // accumulate predictions, labels, logits for metrics
    let mut all_preds = []
    let mut all_labels = []
    let mut all_logits = []
    let mut total_loss = 0.0
    let mut processed = 0

    while processed < total {
        let mut batch_end = processed + batch_size
        if batch_end > total { batch_end = total }

        let mut bi = processed
        while bi < batch_end {
            let sample = dataset[bi]
            let input = sample[0]
            let label = sample[1]

            let logits = model_fn(input)
            let probs = eval_softmax(logits, vocab_size)

            // cross-entropy loss for this sample
            let p_target = probs[label]
            let loss_i = 0.0 - ln_eval(p_target)
            total_loss = total_loss + loss_i

            // top-1 prediction
            let pred = eval_argmax(logits, vocab_size)
            all_preds = all_preds + [pred]
            all_labels = all_labels + [label]
            all_logits = all_logits + [logits]

            bi = bi + 1
        }

        processed = batch_end

        // progress
        println("[eval_runner] " + str(processed) + "/" + str(total) + " samples")
    }

    // compute metrics
    let top1 = accuracy(all_preds, all_labels)

    let k5 = 5
    let mut effective_k = k5
    if effective_k > vocab_size { effective_k = vocab_size }
    let top5 = top_k_accuracy(all_logits, all_labels, effective_k, vocab_size)

    let avg_loss = total_loss / to_float(total)
    let ppl = exp(avg_loss)

    let f1_result = f1_score(all_preds, all_labels, num_classes)
    let micro = f1_result[0]
    let macro_val = f1_result[1]

    return EvalResult {
        total_samples: total,
        top1_acc: top1,
        top5_acc: top5,
        avg_loss: avg_loss,
        ppl: ppl,
        micro_f1: micro,
        macro_f1: macro_val
    }
}

// ===================================================================
//  Print summary table
// ===================================================================

fn print_eval_summary(r: EvalResult) {
    println("===================================================")
    println("  Evaluation Summary")
    println("===================================================")
    println("  Samples     : " + str(r.total_samples))
    println("  Top-1 Acc   : " + str(r.top1_acc))
    println("  Top-5 Acc   : " + str(r.top5_acc))
    println("  Avg Loss    : " + str(r.avg_loss))
    println("  Perplexity  : " + str(r.ppl))
    println("  Micro F1    : " + str(r.micro_f1))
    println("  Macro F1    : " + str(r.macro_f1))
    println("===================================================")
}

// ===================================================================
//  Batch-only perplexity runner (for language model eval)
//
//  model_fn:    fn(token_ids) -> array of logit arrays (one per position)
//  sequences:   array of token ID arrays
//  vocab_size:  vocabulary size
// ===================================================================

fn run_perplexity_eval(model_fn, sequences, vocab_size: int) -> float {
    let num_seq = len(sequences)
    if num_seq == 0 { return 1.0 }

    let mut total_nll = 0.0
    let mut total_tokens = 0

    let mut si = 0
    while si < num_seq {
        let tokens = sequences[si]
        let seq_len = len(tokens)
        if seq_len > 1 {
            let logits_seq = model_fn(tokens)
            // logits_seq[t] predicts tokens[t+1]
            let mut t = 0
            while t < seq_len - 1 {
                let logits = logits_seq[t]
                let probs = eval_softmax(logits, vocab_size)
                let target = tokens[t + 1]
                let p = probs[target]
                total_nll = total_nll - ln_eval(p)
                total_tokens = total_tokens + 1
                t = t + 1
            }
        }
        si = si + 1
        if si % 10 == 0 {
            println("[ppl_eval] " + str(si) + "/" + str(num_seq) + " sequences")
        }
    }

    if total_tokens == 0 { return 1.0 }
    let avg_nll = total_nll / to_float(total_tokens)
    let ppl = exp(avg_nll)
    println("[ppl_eval] tokens=" + str(total_tokens) + " avg_nll=" + str(avg_nll) + " ppl=" + str(ppl))
    return ppl
}

println("[eval_runner] loaded — run_eval, print_eval_summary, run_perplexity_eval")
