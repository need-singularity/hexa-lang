// ═══════════════════════════════════════════════════════════════════
//  self/ml/rectified_flow.hexa — Rectified Flow (#250)
//
//  Straight ODE 1-step generation + reflow procedure.
//
//  Theory (Liu et al. 2023):
//    Forward interpolation: x_t = (1-t) * x_0 + t * x_1
//    where x_0 ~ noise (N(0,I)), x_1 ~ data.
//    Target velocity: v*(x_t, t) = x_1 - x_0 (constant along the line)
//    Learn v_theta(x_t, t) ~ E[x_1 - x_0 | x_t, t]
//
//  1-step sampling:
//    x_1_pred = x_0 + v_theta(x_0, 0)
//
//  Multi-step (Euler ODE): x_{t+dt} = x_t + v_theta(x_t, t) * dt
//
//  Reflow:
//    Generate pairs (x_0, x_1_pred) from the trained model,
//    then re-train using these "straighter" coupling pairs
//    so that the transport path becomes straighter.
//
//  API (pure):
//    rf_zeros / rf_sqrt / rf_exp
//    rf_interpolate(x0, x1, t)                  -> [float]
//    rf_target_velocity(x0, x1)                 -> [float]
//    rf_velocity_mlp(xt, t, w1, b1, w2, b2)     -> [float]  (predicts v_theta)
//    rf_loss(v_pred, v_target)                  -> float
//    rf_batch_loss(x0_batch, x1_batch, ts, w1, b1, w2, b2) -> float
//    rf_sample_1step(x0, v)                     -> [float]
//    rf_sample_euler(x0, n_steps, w1, b1, w2, b2) -> [float]
//    rf_reflow_pairs(x0_batch, w1, b1, w2, b2)  -> [[[float]], [[float]]]  (new x0, x1)
//    rf_straightness(x0, x1, v_theta_w1, b1, w2, b2) -> float
//
//  AI-NATIVE:
//    @pure / @hot
// ═══════════════════════════════════════════════════════════════════

fn rf_abs(x) { if x < 0.0 { return 0.0 - x } return x }

fn rf_sqrt(x) {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    for _i in 0..25 { g = (g + x / g) / 2.0 }
    return g
}

fn rf_exp(x) {
    let mut v = x
    if v > 20.0 { v = 20.0 }
    if v < -20.0 { v = -20.0 }
    let mut result = 1.0
    let mut term = 1.0
    for i in 1..25 {
        term = term * v / to_float(i)
        result = result + term
    }
    if result < 0.0 { return 0.0 }
    return result
}

fn rf_zeros(n) {
    let mut v = []
    for _i in 0..n { v = v + [0.0] }
    return v
}

@pure
fn rf_add(a, b) {
    let n = len(a)
    let mut out = rf_zeros(n)
    for i in 0..n { out[i] = a[i] + b[i] }
    return out
}

@pure
fn rf_sub(a, b) {
    let n = len(a)
    let mut out = rf_zeros(n)
    for i in 0..n { out[i] = a[i] - b[i] }
    return out
}

@pure
fn rf_scale(v, s) {
    let n = len(v)
    let mut out = rf_zeros(n)
    for i in 0..n { out[i] = v[i] * s }
    return out
}

@pure
fn rf_dot(a, b) {
    let n = len(a)
    let mut s = 0.0
    for i in 0..n { s = s + a[i] * b[i] }
    return s
}

@pure
fn rf_norm(v) { return rf_sqrt(rf_dot(v, v)) }

// ═══════════════════════════════════════════════════════════════════
//  1. Interpolation x_t = (1-t)*x0 + t*x1
// ═══════════════════════════════════════════════════════════════════
@pure
fn rf_interpolate(x0, x1, t) {
    let n = len(x0)
    let mut xt = rf_zeros(n)
    for i in 0..n {
        xt[i] = (1.0 - t) * x0[i] + t * x1[i]
    }
    return xt
}

// ═══════════════════════════════════════════════════════════════════
//  2. Target velocity (constant along the line): v* = x1 - x0
// ═══════════════════════════════════════════════════════════════════
@pure
fn rf_target_velocity(x0, x1) {
    return rf_sub(x1, x0)
}

// ═══════════════════════════════════════════════════════════════════
//  3. Velocity MLP — predicts v_theta(x_t, t)
//
//  Input: [x_t; t] (dim = d + 1)
//  Output: velocity vector of dim d
//
//  w1: [hidden x (d+1)] flat, b1: [hidden]
//  w2: [d x hidden] flat, b2: [d]
// ═══════════════════════════════════════════════════════════════════
@pure
fn rf_gelu(x) {
    let e2x = rf_exp(2.0 * x)
    if e2x > 1.0e15 { return x }
    let t = (e2x - 1.0) / (e2x + 1.0)
    return 0.5 * x * (1.0 + t)
}

@pure
fn rf_velocity_mlp(xt, t_val, w1, b1, w2, b2) {
    let d = len(xt)
    let in_dim = d + 1
    let mut input = rf_zeros(in_dim)
    for i in 0..d { input[i] = xt[i] }
    input[d] = t_val

    let hidden_dim = len(b1)
    let out_dim = len(b2)

    let mut hid = rf_zeros(hidden_dim)
    for i in 0..hidden_dim {
        let mut s = b1[i]
        for j in 0..in_dim {
            s = s + w1[i * in_dim + j] * input[j]
        }
        hid[i] = rf_gelu(s)
    }

    let mut out = rf_zeros(out_dim)
    for i in 0..out_dim {
        let mut s = b2[i]
        for j in 0..hidden_dim {
            s = s + w2[i * hidden_dim + j] * hid[j]
        }
        out[i] = s
    }
    return out
}

// ═══════════════════════════════════════════════════════════════════
//  4. Loss: MSE between predicted and target velocity
// ═══════════════════════════════════════════════════════════════════
@pure
fn rf_loss(v_pred, v_target) {
    let diff = rf_sub(v_pred, v_target)
    return 0.5 * rf_dot(diff, diff)
}

// Batch loss over pairs (x0_i, x1_i, t_i)
@pure
fn rf_batch_loss(x0_batch, x1_batch, ts, w1, b1, w2, b2) {
    let n = len(x0_batch)
    if n == 0 { return 0.0 }
    let mut total = 0.0
    for i in 0..n {
        let x0 = x0_batch[i]
        let x1 = x1_batch[i]
        let t = ts[i]
        let xt = rf_interpolate(x0, x1, t)
        let v_pred = rf_velocity_mlp(xt, t, w1, b1, w2, b2)
        let v_target = rf_target_velocity(x0, x1)
        total = total + rf_loss(v_pred, v_target)
    }
    return total / to_float(n)
}

// ═══════════════════════════════════════════════════════════════════
//  5. 1-step sampling: x1_pred = x0 + v_theta(x0, 0)
// ═══════════════════════════════════════════════════════════════════
@pure
fn rf_sample_1step(x0, w1, b1, w2, b2) {
    let v = rf_velocity_mlp(x0, 0.0, w1, b1, w2, b2)
    return rf_add(x0, v)
}

// ═══════════════════════════════════════════════════════════════════
//  6. Euler multi-step sampling
//   x_{t+dt} = x_t + v_theta(x_t, t) * dt
// ═══════════════════════════════════════════════════════════════════
@pure
fn rf_sample_euler(x0, n_steps, w1, b1, w2, b2) {
    let d = len(x0)
    let mut x = rf_zeros(d)
    for i in 0..d { x[i] = x0[i] }
    let dt = 1.0 / to_float(n_steps)
    for step in 0..n_steps {
        let t = to_float(step) * dt
        let v = rf_velocity_mlp(x, t, w1, b1, w2, b2)
        for i in 0..d {
            x[i] = x[i] + v[i] * dt
        }
    }
    return x
}

// ═══════════════════════════════════════════════════════════════════
//  7. Reflow: regenerate (x0, x1_pred) pairs using the current v_theta
//
//  Returns [new_x0_batch, new_x1_batch] (straighter coupling)
// ═══════════════════════════════════════════════════════════════════
@pure
fn rf_reflow_pairs(x0_batch, w1, b1, w2, b2) {
    let n = len(x0_batch)
    let mut new_x0 = []
    let mut new_x1 = []
    for i in 0..n {
        let x0 = x0_batch[i]
        let x1_pred = rf_sample_1step(x0, w1, b1, w2, b2)
        new_x0 = new_x0 + [x0]
        new_x1 = new_x1 + [x1_pred]
    }
    return [new_x0, new_x1]
}

// ═══════════════════════════════════════════════════════════════════
//  8. Straightness measure: variance of v_theta along the line
//
//  A perfectly rectified flow has constant v along (x_t, t),
//  so variance → 0.
//
//  measure = (1/T) sum_t || v(x_t, t) - mean_v ||^2
// ═══════════════════════════════════════════════════════════════════
@pure
fn rf_straightness(x0, x1, w1, b1, w2, b2, n_t) {
    let d = len(x0)
    let mut sum_v = rf_zeros(d)
    let mut v_samples = []
    for i in 0..n_t {
        let t = to_float(i) / to_float(n_t - 1)
        let xt = rf_interpolate(x0, x1, t)
        let v = rf_velocity_mlp(xt, t, w1, b1, w2, b2)
        v_samples = v_samples + [v]
        for j in 0..d { sum_v[j] = sum_v[j] + v[j] }
    }
    let mut mean_v = rf_zeros(d)
    for j in 0..d { mean_v[j] = sum_v[j] / to_float(n_t) }
    let mut var = 0.0
    for i in 0..n_t {
        let diff = rf_sub(v_samples[i], mean_v)
        var = var + rf_dot(diff, diff)
    }
    return var / to_float(n_t)
}

// ═══════════════════════════════════════════════════════════════════
//  Pseudo-random noise (for sampling from Gaussian source)
// ═══════════════════════════════════════════════════════════════════
@pure
fn rf_pseudo_gauss(n, seed) {
    let mut out = rf_zeros(n)
    for i in 0..n {
        let mut h = (seed + 1) * 2654435761 + (i + 1) * 1315423911
        h = h % 1000003
        if h < 0 { h = 0 - h }
        let u = to_float(h % 10000) / 10000.0
        out[i] = (u - 0.5) * 3.46
    }
    return out
}

println("[rectified_flow] loaded — interpolation + velocity MLP + 1-step sample + reflow")
