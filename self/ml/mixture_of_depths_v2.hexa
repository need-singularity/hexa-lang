// ===================================================================
//  self/ml/mixture_of_depths_v2.hexa — Mixture of Depths v2 (pure Hexa)
//
//  ML roadmap #173 — Token-level dynamic computation allocation (v2)
//
//  Extends v1 with:
//    (1) Learned router per layer: trainable gate deciding skip/compute
//    (2) Skip decision: binary skip with straight-through estimator (STE)
//    (3) Capacity budget: limit fraction of tokens computed per layer
//    (4) Auxiliary loss: balance token routing (not all skip/compute)
//    (5) Early exit integration: exit model early for easy tokens
//    (6) Dynamic depth map: visualize per-token computation depth
//    (7) Stats: compute savings, skip rate per layer, effective FLOPs
//
//  Public API:
//    create_v2_router(hidden_dim, n_layers)
//    v2_router_forward(router, hiddens)
//    ste_binary_skip(scores, threshold)
//    apply_capacity_budget(skip_mask, capacity_fraction, scores)
//    v2_aux_balance_loss(skip_mask, target_fraction)
//    v2_aux_entropy_loss(scores)
//    create_v2_mod_layer(hidden_dim, ff_dim)
//    v2_mod_layer_forward(layer, router, hiddens, capacity_fraction)
//    v2_mod_forward_full(layers, routers, hiddens, cap_fractions)
//    early_exit_check(hiddens, threshold)
//    compute_depth_map(layers, routers, hiddens, cap_fractions)
//    v2_skip_rate_per_layer(depth_map, n_layers)
//    v2_compute_savings(depth_map, n_layers)
//    v2_effective_flops(depth_map, n_layers, flops_per_layer)
//    v2_capacity_schedule(n_layers, base_fraction, decay)
// ===================================================================

// ===================================================================
//  Vector utilities
// ===================================================================

fn v2_vec_zeros(dim) {
    let mut out = []
    let mut i = 0
    while i < dim {
        out = out + [0.0]
        i = i + 1
    }
    return out
}

fn v2_vec_add(a, b) {
    let n = len(a)
    let mut out = []
    let mut i = 0
    while i < n {
        out = out + [a[i] + b[i]]
        i = i + 1
    }
    return out
}

fn v2_vec_scale(v, s) {
    let n = len(v)
    let mut out = []
    let mut i = 0
    while i < n {
        out = out + [v[i] * s]
        i = i + 1
    }
    return out
}

fn v2_dot(a, b) {
    let n = len(a)
    let mut s = 0.0
    let mut i = 0
    while i < n {
        s = s + a[i] * b[i]
        i = i + 1
    }
    return s
}

fn v2_fabs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn v2_vec_norm(v) {
    let mut s = 0.0
    let n = len(v)
    let mut i = 0
    while i < n {
        s = s + v[i] * v[i]
        i = i + 1
    }
    return sqrt(s)
}

fn v2_vec_sub(a, b) {
    let n = len(a)
    let mut out = []
    let mut i = 0
    while i < n {
        out = out + [a[i] - b[i]]
        i = i + 1
    }
    return out
}

// ===================================================================
//  (1) Learned Router per Layer
//
//  Trainable gate: score = sigmoid(W . hidden + bias)
//  Each layer has its own router with independent weights.
//  W: array of floats (hidden_dim), bias: float, lr: learning rate
// ===================================================================

struct V2Router {
    dim: int,
    W: array,
    bias: float,
    layer_id: int
}

fn create_v2_router(dim, layer_id) {
    let scale = 1.0 / sqrt(to_float(dim))
    let mut W = []
    let mut i = 0
    while i < dim {
        // Different init per layer using layer_id for diversity
        let val = sin(to_float(i * 137 + layer_id * 53 + 7)) * scale
        W = W + [val]
        i = i + 1
    }
    return V2Router { dim: dim, W: W, bias: 0.01, layer_id: layer_id }
}

fn v2_sigmoid(x) {
    if x > 20.0 { return 1.0 }
    if x < -20.0 { return 0.0 }
    return 1.0 / (1.0 + exp(0.0 - x))
}

// Compute routing scores for all tokens at a given layer
// hiddens: array of arrays (n_tokens x hidden_dim)
// returns: array of floats (routing probability per token)
fn v2_router_forward(router, hiddens) {
    let n = len(hiddens)
    let mut scores = []
    let mut i = 0
    while i < n {
        let raw = v2_dot(router.W, hiddens[i]) + router.bias
        let prob = v2_sigmoid(raw)
        scores = scores + [prob]
        i = i + 1
    }
    return scores
}

// ===================================================================
//  (2) Skip Decision: Binary Skip with Straight-Through Estimator
//
//  Hard binary decision: skip_mask[i] = 1 if score >= threshold, 0 otherwise
//  STE forward: use hard decision for forward pass
//  STE backward: gradient flows through soft score (simulated)
//  Returns: [hard_mask, soft_scores] for combined usage
// ===================================================================

fn ste_binary_skip(scores, threshold) {
    let n = len(scores)
    let mut hard_mask = []
    let mut i = 0
    while i < n {
        if scores[i] >= threshold {
            hard_mask = hard_mask + [1.0]
        } else {
            hard_mask = hard_mask + [0.0]
        }
        i = i + 1
    }
    // STE: hard_mask for forward, scores for backward (simulated)
    // Return both so the caller can use soft scores for gradient
    return [hard_mask, scores]
}

// Combine STE result: hard_mask + (soft - hard).detach()
// In inference, this is just hard_mask. In training, gradient flows via soft.
fn ste_combine(hard_mask, soft_scores) {
    let n = len(hard_mask)
    let mut combined = []
    let mut i = 0
    while i < n {
        // STE forward: hard value, backward: soft gradient
        // combined = hard + (soft - hard).stop_gradient => hard in forward
        combined = combined + [hard_mask[i]]
        i = i + 1
    }
    return combined
}

// ===================================================================
//  (3) Capacity Budget: limit fraction of tokens computed per layer
//
//  Given a skip_mask (1=compute, 0=skip), enforce that at most
//  capacity_fraction * n_tokens are computed. If too many want to
//  compute, drop lowest-scoring ones.
// ===================================================================

fn apply_capacity_budget(skip_mask, capacity_fraction, scores) {
    let n = len(skip_mask)
    let max_compute_f = to_float(n) * capacity_fraction
    // Compute floor of max_compute
    let mut max_compute = 0
    let mut ci = 0
    while to_float(ci) < max_compute_f {
        max_compute = ci
        ci = ci + 1
    }
    if to_float(max_compute) < max_compute_f { max_compute = max_compute + 1 }
    if max_compute > n { max_compute = n }

    // Count how many want to compute
    let mut compute_count = 0
    let mut i = 0
    while i < n {
        if skip_mask[i] > 0.5 { compute_count = compute_count + 1 }
        i = i + 1
    }

    // If within budget, return as-is
    if compute_count <= max_compute {
        return skip_mask
    }

    // Need to drop (compute_count - max_compute) lowest-scoring compute tokens
    let n_drop = compute_count - max_compute

    // Collect indices of compute tokens with their scores
    let mut compute_indices = []
    let mut compute_scores = []
    i = 0
    while i < n {
        if skip_mask[i] > 0.5 {
            compute_indices = compute_indices + [i]
            compute_scores = compute_scores + [scores[i]]
        }
        i = i + 1
    }

    // Find n_drop lowest-scoring compute tokens
    let nc = len(compute_indices)
    let mut dropped = []
    i = 0
    while i < nc {
        dropped = dropped + [false]
        i = i + 1
    }

    let mut d = 0
    while d < n_drop {
        let mut worst_j = -1
        let mut worst_v = 1.0e30
        let mut j = 0
        while j < nc {
            if !dropped[j] {
                if compute_scores[j] < worst_v {
                    worst_v = compute_scores[j]
                    worst_j = j
                }
            }
            j = j + 1
        }
        if worst_j >= 0 {
            // Rebuild dropped array (no complex index assignment)
            let mut dropped2 = []
            let mut k = 0
            while k < nc {
                if k == worst_j { dropped2 = dropped2 + [true] } else { dropped2 = dropped2 + [dropped[k]] }
                k = k + 1
            }
            dropped = dropped2
        }
        d = d + 1
    }

    // Build new mask
    let mut new_mask = []
    i = 0
    while i < n {
        new_mask = new_mask + [skip_mask[i]]
        i = i + 1
    }

    // Zero out dropped tokens
    let mut di = 0
    while di < nc {
        if dropped[di] {
            let drop_idx = compute_indices[di]
            let mut new_mask2 = []
            let mut k = 0
            while k < n {
                if k == drop_idx { new_mask2 = new_mask2 + [0.0] } else { new_mask2 = new_mask2 + [new_mask[k]] }
                k = k + 1
            }
            new_mask = new_mask2
        }
        di = di + 1
    }

    return new_mask
}

// Count how many tokens are set to compute in a mask
fn count_compute(mask) {
    let n = len(mask)
    let mut c = 0
    let mut i = 0
    while i < n {
        if mask[i] > 0.5 { c = c + 1 }
        i = i + 1
    }
    return c
}

// ===================================================================
//  (4) Auxiliary Loss: balance token routing
//
//  Two components:
//    a) Balance loss: penalize deviation from target compute fraction
//    b) Entropy loss: encourage diverse routing (not all same decision)
// ===================================================================

fn v2_aux_balance_loss(skip_mask, target_fraction) {
    let n = len(skip_mask)
    if n == 0 { return 0.0 }
    let mut compute_sum = 0.0
    let mut i = 0
    while i < n {
        compute_sum = compute_sum + skip_mask[i]
        i = i + 1
    }
    let actual_fraction = compute_sum / to_float(n)
    let diff = actual_fraction - target_fraction
    return diff * diff * to_float(n)
}

fn v2_aux_entropy_loss(scores) {
    let n = len(scores)
    if n == 0 { return 0.0 }
    let eps = 1.0e-10
    // Binary entropy: H = -p*log(p) - (1-p)*log(1-p) per token
    let mut total_h = 0.0
    let mut i = 0
    while i < n {
        let p = scores[i]
        let p_clamped = if p < eps { eps } else { if p > 1.0 - eps { 1.0 - eps } else { p } }
        let h = 0.0 - p_clamped * log(p_clamped) - (1.0 - p_clamped) * log(1.0 - p_clamped)
        total_h = total_h + h
        i = i + 1
    }
    // Negate: we want to MAXIMIZE entropy, so loss = -mean_entropy
    return 0.0 - total_h / to_float(n)
}

fn v2_combined_aux_loss(skip_mask, scores, target_fraction, entropy_weight) {
    let balance = v2_aux_balance_loss(skip_mask, target_fraction)
    let entropy = v2_aux_entropy_loss(scores)
    return balance + entropy_weight * entropy
}

// ===================================================================
//  V2 MoD Layer: FFN with gated skip
// ===================================================================

struct V2ModLayer {
    dim: int,
    ff_dim: int,
    W_up: array,
    W_down: array,
    bias_up: array,
    bias_down: array
}

fn create_v2_mod_layer(dim, ff_dim) {
    let scale = 0.02
    let mut W_up = []
    let mut i = 0
    while i < ff_dim {
        let mut row = []
        let mut j = 0
        while j < dim {
            let val = sin(to_float(i * 137 + j * 31 + 7)) * scale
            row = row + [val]
            j = j + 1
        }
        W_up = W_up + [row]
        i = i + 1
    }
    let mut W_down = []
    i = 0
    while i < dim {
        let mut row = []
        let mut j = 0
        while j < ff_dim {
            let val = sin(to_float(i * 31 + j * 137 + 13)) * scale
            row = row + [val]
            j = j + 1
        }
        W_down = W_down + [row]
        i = i + 1
    }
    return V2ModLayer {
        dim: dim,
        ff_dim: ff_dim,
        W_up: W_up,
        W_down: W_down,
        bias_up: v2_vec_zeros(ff_dim),
        bias_down: v2_vec_zeros(dim)
    }
}

fn v2_ffn_forward(layer, x) {
    let dim = layer.dim
    let ff_dim = layer.ff_dim
    let mut h = []
    let mut i = 0
    while i < ff_dim {
        let mut s = layer.bias_up[i]
        let mut j = 0
        while j < dim {
            s = s + layer.W_up[i][j] * x[j]
            j = j + 1
        }
        if s < 0.0 { s = 0.0 }
        h = h + [s]
        i = i + 1
    }
    let mut out = []
    i = 0
    while i < dim {
        let mut s = layer.bias_down[i]
        let mut j = 0
        while j < ff_dim {
            s = s + layer.W_down[i][j] * h[j]
            j = j + 1
        }
        out = out + [s]
        i = i + 1
    }
    return out
}

// ===================================================================
//  V2 MoD Layer Forward
//
//  1. Router scores tokens
//  2. STE binary skip decision
//  3. Capacity budget enforcement
//  4. FFN applied only to compute tokens
//  5. Skip tokens pass through unchanged
//  Returns: [outputs, skip_mask, scores]
// ===================================================================

fn v2_mod_layer_forward(layer, router, hiddens, capacity_fraction) {
    let n = len(hiddens)
    let scores = v2_router_forward(router, hiddens)

    // STE binary decision at threshold 0.5
    let ste_result = ste_binary_skip(scores, 0.5)
    let hard_mask = ste_result[0]

    // Enforce capacity budget
    let final_mask = apply_capacity_budget(hard_mask, capacity_fraction, scores)

    // Apply FFN to compute tokens, skip for others
    let mut outputs = []
    let mut i = 0
    while i < n {
        if final_mask[i] > 0.5 {
            let ffn_out = v2_ffn_forward(layer, hiddens[i])
            let weighted = v2_vec_scale(ffn_out, scores[i])
            let result = v2_vec_add(hiddens[i], weighted)
            outputs = outputs + [result]
        } else {
            outputs = outputs + [hiddens[i]]
        }
        i = i + 1
    }
    return [outputs, final_mask, scores]
}

// ===================================================================
//  Multi-layer V2 MoD forward
//
//  Returns: [final_hiddens, total_aux_loss, all_masks]
// ===================================================================

fn v2_mod_forward_full(layers, routers, hiddens, cap_fractions) {
    let n_layers = len(layers)
    let mut h = hiddens
    let mut total_aux = 0.0
    let mut all_masks = []
    let mut i = 0
    while i < n_layers {
        let result = v2_mod_layer_forward(layers[i], routers[i], h, cap_fractions[i])
        h = result[0]
        let mask = result[1]
        let scores = result[2]
        all_masks = all_masks + [mask]
        total_aux = total_aux + v2_combined_aux_loss(mask, scores, cap_fractions[i], 0.1)
        i = i + 1
    }
    return [h, total_aux, all_masks]
}

// ===================================================================
//  (5) Early Exit Integration
//
//  Check if all tokens have low router scores (easy tokens).
//  If mean score across tokens < threshold, exit early.
//  Returns: [should_exit: bool, confidence: float]
// ===================================================================

fn early_exit_check(scores, threshold) {
    let n = len(scores)
    if n == 0 { return [false, 0.0] }
    let mut mean_score = 0.0
    let mut i = 0
    while i < n {
        mean_score = mean_score + scores[i]
        i = i + 1
    }
    mean_score = mean_score / to_float(n)
    // Low mean score = easy tokens = can exit early
    let confidence = 1.0 - mean_score
    let should_exit = mean_score < threshold
    return [should_exit, confidence]
}

// Full forward with early exit
// Returns: [hiddens, aux_loss, exit_layer, depth_map_masks]
fn v2_forward_with_early_exit(layers, routers, hiddens, cap_fractions, exit_threshold) {
    let n_layers = len(layers)
    let mut h = hiddens
    let mut total_aux = 0.0
    let mut all_masks = []
    let mut exit_layer = n_layers
    let mut i = 0
    while i < n_layers {
        let result = v2_mod_layer_forward(layers[i], routers[i], h, cap_fractions[i])
        h = result[0]
        let mask = result[1]
        let scores = result[2]
        all_masks = all_masks + [mask]
        total_aux = total_aux + v2_combined_aux_loss(mask, scores, cap_fractions[i], 0.1)

        // Early exit check
        let exit_result = early_exit_check(scores, exit_threshold)
        let should_exit = exit_result[0]
        if should_exit {
            exit_layer = i + 1
            return [h, total_aux, exit_layer, all_masks]
        }
        i = i + 1
    }
    return [h, total_aux, exit_layer, all_masks]
}

// ===================================================================
//  (6) Dynamic Depth Map
//
//  For each token, compute how many layers it was actually processed
//  (not skipped) through. This gives a per-token depth.
//  depth_map: array of int, one per token
// ===================================================================

fn compute_depth_map(layers, routers, hiddens, cap_fractions) {
    let n_layers = len(layers)
    let n_tokens = len(hiddens)

    // Initialize depth counters
    let mut depth = []
    let mut i = 0
    while i < n_tokens {
        depth = depth + [0]
        i = i + 1
    }

    let mut h = hiddens
    let mut layer_idx = 0
    while layer_idx < n_layers {
        let result = v2_mod_layer_forward(layers[layer_idx], routers[layer_idx], h, cap_fractions[layer_idx])
        h = result[0]
        let mask = result[1]

        // Update depth: add 1 for each computed token
        let mut new_depth = []
        i = 0
        while i < n_tokens {
            if mask[i] > 0.5 {
                new_depth = new_depth + [depth[i] + 1]
            } else {
                new_depth = new_depth + [depth[i]]
            }
            i = i + 1
        }
        depth = new_depth
        layer_idx = layer_idx + 1
    }
    return depth
}

// Max depth in a depth map
fn depth_map_max(depth_map) {
    let n = len(depth_map)
    let mut mx = 0
    let mut i = 0
    while i < n {
        if depth_map[i] > mx { mx = depth_map[i] }
        i = i + 1
    }
    return mx
}

// Mean depth in a depth map
fn depth_map_mean(depth_map) {
    let n = len(depth_map)
    if n == 0 { return 0.0 }
    let mut total = 0.0
    let mut i = 0
    while i < n {
        total = total + to_float(depth_map[i])
        i = i + 1
    }
    return total / to_float(n)
}

// Depth histogram: count tokens at each depth level
fn depth_histogram(depth_map, n_layers) {
    let mut hist = []
    let mut d = 0
    while d <= n_layers {
        let mut count = 0
        let mut i = 0
        while i < len(depth_map) {
            if depth_map[i] == d { count = count + 1 }
            i = i + 1
        }
        hist = hist + [count]
        d = d + 1
    }
    return hist
}

// ===================================================================
//  (7) Stats: compute savings, skip rate per layer, effective FLOPs
// ===================================================================

// Skip rate per layer from masks
fn v2_skip_rate_per_layer(all_masks, n_tokens) {
    let n_layers = len(all_masks)
    let mut rates = []
    let mut i = 0
    while i < n_layers {
        let mask = all_masks[i]
        let mut skip_count = 0
        let mut j = 0
        while j < n_tokens {
            if mask[j] < 0.5 { skip_count = skip_count + 1 }
            j = j + 1
        }
        let rate = to_float(skip_count) / to_float(n_tokens)
        rates = rates + [rate]
        i = i + 1
    }
    return rates
}

// Compute savings from masks
fn v2_compute_savings(all_masks, n_tokens) {
    let n_layers = len(all_masks)
    if n_layers == 0 { return 0.0 }
    let total_possible = to_float(n_tokens) * to_float(n_layers)
    let mut total_computed = 0.0
    let mut i = 0
    while i < n_layers {
        let mask = all_masks[i]
        let mut j = 0
        while j < n_tokens {
            if mask[j] > 0.5 { total_computed = total_computed + 1.0 }
            j = j + 1
        }
        i = i + 1
    }
    return 1.0 - total_computed / total_possible
}

// Effective FLOPs: computed tokens * flops_per_layer_per_token
fn v2_effective_flops(all_masks, n_tokens, flops_per_token) {
    let n_layers = len(all_masks)
    let mut total_flops = 0.0
    let mut i = 0
    while i < n_layers {
        let mask = all_masks[i]
        let mut j = 0
        while j < n_tokens {
            if mask[j] > 0.5 {
                total_flops = total_flops + flops_per_token
            }
            j = j + 1
        }
        i = i + 1
    }
    return total_flops
}

// Dense (no-skip) FLOPs for reference
fn v2_dense_flops(n_tokens, n_layers, flops_per_token) {
    return to_float(n_tokens) * to_float(n_layers) * flops_per_token
}

// ===================================================================
//  Capacity Schedule v2: exponential decay with floor
// ===================================================================

fn v2_capacity_schedule(n_layers, base_fraction, decay) {
    let mut schedule = []
    let mut i = 0
    while i < n_layers {
        let factor = base_fraction * pow(decay, to_float(i))
        // Floor at 0.1 to always compute at least 10%
        let clamped = if factor < 0.1 { 0.1 } else { factor }
        schedule = schedule + [clamped]
        i = i + 1
    }
    return schedule
}

// Linear capacity schedule (simpler)
fn v2_capacity_schedule_linear(n_layers, start_fraction, end_fraction) {
    let mut schedule = []
    let mut i = 0
    while i < n_layers {
        let ratio = if n_layers > 1 { to_float(i) / to_float(n_layers - 1) } else { 0.0 }
        let factor = start_fraction + (end_fraction - start_fraction) * ratio
        schedule = schedule + [factor]
        i = i + 1
    }
    return schedule
}

// ===================================================================
//  Router gradient simulation (for training)
//  Compute simple gradient signal for router weights
// ===================================================================

fn v2_router_gradient(router, hiddens, mask, target_fraction) {
    let n = len(hiddens)
    let scores = v2_router_forward(router, hiddens)

    // Compute fraction currently computed
    let mut compute_sum = 0.0
    let mut i = 0
    while i < n {
        compute_sum = compute_sum + mask[i]
        i = i + 1
    }
    let actual_frac = compute_sum / to_float(n)
    let error = actual_frac - target_fraction

    // Simple gradient: if too many compute, push scores down, and vice versa
    let mut grad_W = v2_vec_zeros(router.dim)
    i = 0
    while i < n {
        let scale = error * (scores[i] - 0.5) * 2.0
        let token_grad = v2_vec_scale(hiddens[i], scale / to_float(n))
        grad_W = v2_vec_add(grad_W, token_grad)
        i = i + 1
    }
    return grad_W
}

// ===================================================================
//  Dense reference forward (for comparison)
// ===================================================================

fn v2_dense_forward(layers, hiddens) {
    let n_layers = len(layers)
    let mut h = hiddens
    let mut i = 0
    while i < n_layers {
        let n = len(h)
        let mut h2 = []
        let mut t = 0
        while t < n {
            let ffn_out = v2_ffn_forward(layers[i], h[t])
            let result = v2_vec_add(h[t], ffn_out)
            h2 = h2 + [result]
            t = t + 1
        }
        h = h2
        i = i + 1
    }
    return h
}
