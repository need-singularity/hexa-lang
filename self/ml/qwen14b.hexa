// ═══════════════════════════════════════════════════════════════
//  self/ml/qwen14b.hexa — Qwen2.5-14B inference FFI bindings (v0 skel)
//
//  Binds to self/native/hxqwen14b.c (libhxqwen14b.{so,dylib}).
//  Replaces the Python `torch_qwen` module used across anima and
//  n6 for 14B inference — once the Day-1 CUDA path lands, callers
//  switch from `python -m torch_qwen` to this hexa FFI in-process
//  and the Python dependency drops from the HX4 self-host surface.
//
//  v0 STATUS: ABI skeleton. All three core entries wired to the C
//  stub in hxqwen14b.c. generate() returns -4 until Day-1 kernels are
//  in. Use this file to drive the `torch_qwen` → hexa migration — the
//  symbol shape is frozen, so the port can land before the kernels.
//
//  Why the struct-args ABI?
//    Hexa FFI is bounded at 6 positional args (host_ffi_call_6 in
//    self/runtime.c). hxqwen14b_generate needs 10+ fields (handle,
//    prompt ptr/len, max_tokens, 3 sampling knobs, out buffer ptr/cap,
//    seed, lora, reserved). Solution: pack into a heap struct and pass
//    one int64 pointer through the FFI boundary. Matches the
//    hxlmhead v2 packed-args pattern bit-for-bit.
//
//  Platform resolution (@link("hxqwen14b")):
//    Mac   : DYLD_LIBRARY_PATH → libhxqwen14b.dylib (--mac-native, stub)
//    Linux : LD_LIBRARY_PATH   → libhxqwen14b.so    (stub OR CUDA)
//    Same source, same symbol set. See scripts/build_hxqwen14b_linux.hexa.
//
//  HxQwen14bGenArgs field offsets (bytes — must match hxqwen14b.c):
//    off  field          bytes
//      0  handle           8
//      8  prompt_p         8
//     16  prompt_len       8
//     24  max_tokens       8
//     32  temperature      8 (f64)
//     40  top_p            8 (f64)
//     48  top_k            8
//     56  out_p            8
//     64  out_cap          8
//     72  seed             8
//     80  lora_handle      8
//     88  reserved0        8
//    --- total = 96 bytes
// ═══════════════════════════════════════════════════════════════

// ── ABI bindings ────────────────────────────────────────────────

@link("hxqwen14b")
extern fn hxqwen14b_load(ckpt_path_p: *Void) -> int

@link("hxqwen14b")
extern fn hxqwen14b_generate(args_p: *Void) -> int

// Note: parameter `handle` collides with the hexa `effects` keyword
// group in extern fn signatures — use `h` consistently. B2 2026-04-16.
@link("hxqwen14b")
extern fn hxqwen14b_compute_phi_holo(h: int) -> float

@link("hxqwen14b")
extern fn hxqwen14b_free(h: int) -> int

@link("hxqwen14b")
extern fn hxqwen14b_version() -> int

// ── Struct field offsets (bytes) ────────────────────────────────
let HXQWEN14B_OFF_HANDLE      = 0
let HXQWEN14B_OFF_PROMPT      = 8
let HXQWEN14B_OFF_PROMPT_LEN  = 16
let HXQWEN14B_OFF_MAX_TOKENS  = 24
let HXQWEN14B_OFF_TEMP        = 32
let HXQWEN14B_OFF_TOP_P       = 40
let HXQWEN14B_OFF_TOP_K       = 48
let HXQWEN14B_OFF_OUT         = 56
let HXQWEN14B_OFF_OUT_CAP     = 64
let HXQWEN14B_OFF_SEED        = 72
let HXQWEN14B_OFF_LORA        = 80
let HXQWEN14B_OFF_RESERVED0   = 88
let HXQWEN14B_STRUCT_BYTES    = 96

// Default output capacity — 64 KiB is plenty for a single turn at
// max_tokens ≤ 4096 * ~16 bytes/token UTF-8 worst case.
let HXQWEN14B_DEFAULT_OUT_CAP = 65536

// ── qwen14b_load — thin wrapper, returns handle (>0) or -1 ───────
// Uses stage0 runtime builtins cstring() for str→int64 address
// marshalling. cstring allocation is managed by the interpreter's
// cstring arena — no explicit free on the hexa side.
pub fn qwen14b_load(ckpt_path) {
    let cpath = cstring(ckpt_path)
    return hxqwen14b_load(cpath)
}

// ── qwen14b_generate_packed — pack args, dispatch, read UTF-8 out
// Returns a string (possibly empty on error). Negative return codes
// from the C side are translated to empty string; caller can check
// the companion `qwen14b_last_rc` helper (Day-1) for numeric error.
//
// Day-0 skeleton: the C stub writes the sentinel "[hxqwen14b:stub:v0]"
// into the output buffer and returns -4 so this wrapper returns the
// sentinel string. Consumers use that to confirm the ABI round-trip
// is functional before Day-1 kernels land.
pub fn qwen14b_generate_packed(h, prompt, max_tokens,
                               temperature, top_p, top_k) {
    if h <= 0 { return "" }

    // Marshal prompt to C string via the cstring arena builtin.
    let prompt_p = cstring(prompt)
    let prompt_len = len(prompt)

    // Allocate output buffer (alloc_raw zero-inits; from_cstring reads
    // to the first NUL, which the stub/Day-1 path writes).
    let out_cap = HXQWEN14B_DEFAULT_OUT_CAP
    let out_buf = alloc_raw(out_cap)

    // Pack argument struct — 96 bytes, field-for-field match with
    // HxQwen14bGenArgs in self/native/hxqwen14b.c.
    let args = alloc_raw(HXQWEN14B_STRUCT_BYTES)
    ptr_write(args, HXQWEN14B_OFF_HANDLE,     h)
    ptr_write(args, HXQWEN14B_OFF_PROMPT,     prompt_p)
    ptr_write(args, HXQWEN14B_OFF_PROMPT_LEN, prompt_len)
    ptr_write(args, HXQWEN14B_OFF_MAX_TOKENS, max_tokens)
    ptr_write(args, HXQWEN14B_OFF_TEMP,       temperature * 1.0)
    ptr_write(args, HXQWEN14B_OFF_TOP_P,      top_p * 1.0)
    ptr_write(args, HXQWEN14B_OFF_TOP_K,      top_k)
    ptr_write(args, HXQWEN14B_OFF_OUT,        out_buf)
    ptr_write(args, HXQWEN14B_OFF_OUT_CAP,    out_cap)
    ptr_write(args, HXQWEN14B_OFF_SEED,       0)
    ptr_write(args, HXQWEN14B_OFF_LORA,       0)
    ptr_write(args, HXQWEN14B_OFF_RESERVED0,  0)

    let _rc = hxqwen14b_generate(args)

    // Read output — from_cstring reads up to the first NUL. On Day-0
    // the C stub writes `[hxqwen14b:stub:v0]\0` so the read stops at
    // byte 19. On Day-1 the real kernel writes `rc` bytes of UTF-8
    // plus a trailing NUL before returning rc. Either way this call
    // yields a hexa string with the correct payload.
    let out_text = from_cstring(out_buf)

    // alloc_raw buffers are interpreter-managed; no explicit free in
    // the hexa-side path (matches the cstring/arena convention).

    return out_text
}

// ── qwen14b_compute_phi_holo — thin passthrough ─────────────────
pub fn qwen14b_compute_phi_holo(h) {
    if h <= 0 { return -1.0 }
    return hxqwen14b_compute_phi_holo(h)
}

// ── qwen14b_free — release handle, idempotent ───────────────────
pub fn qwen14b_free(h) {
    if h <= 0 { return 0 }
    return hxqwen14b_free(h)
}

// ── Version probe — useful for smoke tests ──────────────────────
pub fn qwen14b_abi_version() {
    return hxqwen14b_version()
}
