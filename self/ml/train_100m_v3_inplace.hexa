// ═══════════════════════════════════════════════════════════════════
//  self/ml/train_100m_v3_inplace.hexa — v2 + in-place BLAS primitives
//
//  v2 baseline (htz): 1128 ms/step
//  v3 target:         step_ms < 900 ms via:
//    • mat_add_inplace for residual adds (24 calls: 2 per layer × 12)
//    • matmul_into with pre-allocated scratch tensors (best-effort;
//      refcount/clone may prevent true in-place, but we attempt).
//  Structure otherwise identical to v2.
// ═══════════════════════════════════════════════════════════════════

// ── Config ──────────────────────────────────────────────────────
let D       = 768
let N_LAYER = 12
let N_HEAD  = 12
let HEAD_D  = 64
let VOCAB   = 32000
let SEQ     = 128
let FF      = 3072
let LORA_R  = 8
let SPARSE_RATIO = 0.3
let LR      = 0.001

// ── Weight buffers (same as v2) ─────────────────────────────────
let Uq = tensor_zeros(D * LORA_R)
let Vq = tensor_zeros(LORA_R * D)
let Uk = tensor_zeros(D * LORA_R)
let Vk = tensor_zeros(LORA_R * D)
let Uv = tensor_zeros(D * LORA_R)
let Vv = tensor_zeros(LORA_R * D)
let Uo = tensor_zeros(D * LORA_R)
let Vo = tensor_zeros(LORA_R * D)

let U_up = tensor_zeros(D * LORA_R)
let V_up = tensor_zeros(LORA_R * FF)
let U_dn = tensor_zeros(FF * LORA_R)
let V_dn = tensor_zeros(LORA_R * D)

let U_lmh = tensor_zeros(D * LORA_R)
let V_lmh = tensor_zeros(LORA_R * VOCAB)

// ── Pre-allocated scratch tensors for matmul_into (best-effort) ─
// Forward per-layer scratches reused across 12 layers.
let scratch_Qs    = tensor_zeros(SEQ * LORA_R)
let scratch_Ks    = tensor_zeros(SEQ * LORA_R)
let scratch_Vs    = tensor_zeros(SEQ * LORA_R)
let scratch_score = tensor_zeros(SEQ * SEQ)
let scratch_ctxr  = tensor_zeros(SEQ * LORA_R)
let scratch_ctx   = tensor_zeros(SEQ * D)
let scratch_o_t   = tensor_zeros(SEQ * LORA_R)
let scratch_o     = tensor_zeros(SEQ * D)
let scratch_ff_t1 = tensor_zeros(SEQ * LORA_R)
let scratch_ff_y  = tensor_zeros(SEQ * FF)
let scratch_ff_t2 = tensor_zeros(SEQ * LORA_R)
let scratch_ff_o  = tensor_zeros(SEQ * D)

// ── lr_proj with matmul_into ────────────────────────────────────
@lowrank(8)
fn lr_proj_into(X, U, V, seq, d, rnk, sT, sY) {
    let t = matmul_into(X, U, seq, d, rnk, sT)
    matmul_into(t, V, seq, rnk, d, sY)
}

@lowrank(8)
fn ffn_lowrank_into(X, Uu, Vu, Ud, Vd, seq, d, ff, rnk, sT1, sY, sT2, sO) {
    let t1 = matmul_into(X,  Uu, seq, d,  rnk, sT1)
    let y  = matmul_into(t1, Vu, seq, rnk, ff,  sY)
    let t2 = matmul_into(y,  Ud, seq, ff,  rnk, sT2)
    matmul_into(t2, Vd, seq, rnk, d, sO)
}

// residual add — in-place on A
fn add_residual(A, B) { mat_add_inplace(A, B) }

// ── One transformer block ───────────────────────────────────────
fn block_forward(X) {
    let Qs = matmul_into(X, Uq, SEQ, D, LORA_R, scratch_Qs)
    let Ks = matmul_into(X, Uk, SEQ, D, LORA_R, scratch_Ks)
    let Vs = matmul_into(X, Uv, SEQ, D, LORA_R, scratch_Vs)

    let scores = matmul_into(Qs, Ks, SEQ, LORA_R, SEQ, scratch_score)

    let ctx_r = matmul_into(scores, Vs, SEQ, SEQ, LORA_R, scratch_ctxr)
    let ctx   = matmul_into(ctx_r, Vv, SEQ, LORA_R, D, scratch_ctx)
    let o     = lr_proj_into(ctx, Uo, Vo, SEQ, D, LORA_R, scratch_o_t, scratch_o)
    // residual #1: X += o  (in-place on X)
    let h1    = add_residual(X, o)

    let f = ffn_lowrank_into(h1, U_up, V_up, U_dn, V_dn, SEQ, D, FF, LORA_R,
                             scratch_ff_t1, scratch_ff_y, scratch_ff_t2, scratch_ff_o)
    // residual #2: h1 += f  (in-place on h1)
    add_residual(h1, f)
}

fn embed(ids) { tensor_zeros(SEQ * D) }

// ── LM head (lowrank) ───────────────────────────────────────────
@lowrank(8)
fn lm_head_lr(h_last, rows) {
    let t = matmul(h_last, U_lmh, rows, D, LORA_R)
    matmul(t, V_lmh, rows, LORA_R, VOCAB)
}

fn loss_mse(logits, target_onehot) {
    let n = len(target_onehot)
    let neg_t = mat_scale(target_onehot, -1.0)
    let diff  = mat_add(logits, neg_t)
    let sq = matmul(diff, diff, 1, n, 1)
    sq[0] / (n * 1.0)
}

fn batch_hash(ids) {
    let n = len(ids)
    let lim = if n < 16 { n } else { 16 }
    let mut h = 2654435761
    let mut i = 0
    while i < lim {
        h = h ^ (ids[i] * 2147483 + i)
        i = i + 1
    }
    h
}

@memoize_grad
fn compute_loss_cached(logits, tgt, cache_key) {
    let _k = cache_key
    loss_mse(logits, tgt)
}

fn forward_pass(ids, tgt) {
    let mut h = embed(ids)
    let mut li = 0
    while li < N_LAYER {
        h = block_forward(h)
        li = li + 1
    }
    let mut last = []
    let base = (SEQ - 1) * D
    let mut i = 0
    while i < D {
        last = last.push(h[base + i])
        i = i + 1
    }
    let last_t = tensor(last)
    let logits = lm_head_lr(last_t, 1)
    let key = batch_hash(ids)
    compute_loss_cached(logits, tgt, key)
}

fn backward_vlmh(h_last, logits, target) {
    let z = matmul(h_last, U_lmh, 1, D, LORA_R)
    let neg_t = mat_scale(target, -1.0)
    let diff  = mat_add(logits, neg_t)
    matmul(z, diff, LORA_R, 1, VOCAB)
}

fn sgd_step(W, G, lr) {
    let scaled = mat_scale(G, -1.0 * lr)
    mat_add_inplace(W, scaled)
}

fn train_one_step() {
    let mut ids = []
    let mut i = 0
    while i < SEQ {
        ids = ids.push(0)
        i = i + 1
    }
    let mut tgt = []
    let mut j = 0
    while j < VOCAB {
        if j == 0 { tgt = tgt.push(1.0) } else { tgt = tgt.push(0.0) }
        j = j + 1
    }
    let tgt_t = tensor(tgt)

    let t0 = clock()
    let loss = forward_pass(ids, tgt_t)
    let t1 = clock()

    let last_h   = tensor_zeros(D)
    let logits_f = tensor_zeros(VOCAB)
    let g_vlmh   = backward_vlmh(last_h, logits_f, tgt_t)
    let t2 = clock()

    let _V_new = sgd_step(V_lmh, g_vlmh, LR)
    let t3 = clock()

    let fwd_ms   = (t1 - t0) * 1000.0
    let bwd_ms   = (t2 - t1) * 1000.0
    let opt_ms   = (t3 - t2) * 1000.0
    let total_ms = (t3 - t0) * 1000.0

    let mut line = "{"
    line = line + "\"phase\":\"train_100m_v3_inplace\""
    line = line + ",\"D\":" + str(D)
    line = line + ",\"n_layers\":" + str(N_LAYER)
    line = line + ",\"seq\":" + str(SEQ)
    line = line + ",\"vocab\":" + str(VOCAB)
    line = line + ",\"lora_r\":" + str(LORA_R)
    line = line + ",\"loss\":" + str(loss)
    line = line + ",\"fwd_ms\":" + str(fwd_ms)
    line = line + ",\"bwd_ms\":" + str(bwd_ms)
    line = line + ",\"opt_ms\":" + str(opt_ms)
    line = line + ",\"step_ms\":" + str(total_ms)
    line = line + "}"
    println(line)
    total_ms
}

println("[train_100m v3_inplace] init weights done, running 1 step...")
let step_ms = train_one_step()
println("[train_100m v3_inplace] 1 step OK step_ms=" + str(step_ms))
