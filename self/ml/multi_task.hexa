// ═══════════════════════════════════════════════════════════════════
//  self/ml/multi_task.hexa — Multi-Task Learning
//
//  Implements:
//    1. Shared encoder     — linear layers shared across tasks
//    2. Task-specific heads — per-task output layers
//    3. Loss balancing     — fixed ratio / uncertainty weighting
//    4. Task routing       — map input to correct head
//    5. Multi-task train step — joint gradient update
//
//  API:
//    mt_create_shared(in_dim, hidden_dim)       -> [[float]]
//    mt_create_head(hidden_dim, out_dim)         -> [[float]]
//    mt_encoder_forward(weights, input)           -> [float]
//    mt_head_forward(head, hidden)                -> [float]
//    mt_forward(shared, heads, input, task_id)    -> [float]
//    mt_loss_fixed(losses, ratios)                -> float
//    mt_loss_uncertainty(losses, log_vars)        -> float
//    mt_route_task(input, n_tasks, router_w)      -> int
//    mt_train_step(shared, heads, data, lr)       -> float
//
//  AI-NATIVE attrs:
//    @pure  — no side effects
//    @hot   — called every training step
// ═══════════════════════════════════════════════════════════════════

// ── helpers ──────────────────────────────────────────────────────

fn mt_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn mt_exp(x) {
    let mut v = x
    if v > 20.0 { v = 20.0 }
    if v < -20.0 { v = -20.0 }
    let mut result = 1.0
    let mut term = 1.0
    for i in 1..30 {
        term = term * v / to_float(i)
        result = result + term
    }
    if result < 0.0 { return 0.0 }
    return result
}

fn mt_log(x) {
    if x <= 0.0 { return -30.0 }
    let mut v = x
    let mut count = 0
    while v > 2.0 {
        v = v / 2.718281828
        count = count + 1
    }
    while v < 0.5 {
        v = v * 2.718281828
        count = count - 1
    }
    let d = v - 1.0
    let ln_v = d - d * d / 2.0 + d * d * d / 3.0 - d * d * d * d / 4.0
    return to_float(count) + ln_v
}

fn mt_zeros(n) {
    let mut v = []
    for _i in 0..n { v = v + [0.0] }
    return v
}

fn mt_hash(seed, i, j) {
    let h = ((seed * 2654435761 + i * 1315423911 + j * 731) % 10007)
    return to_float(h) / 10007.0 - 0.5
}

fn mt_relu(x) {
    if x > 0.0 { return x }
    return 0.0
}

// ═══════════════════════════════════════════════════════════════════
//  Shared Encoder — creates weight matrix [hidden_dim x in_dim]
// ═══════════════════════════════════════════════════════════════════
@pure
fn mt_create_shared(in_dim, hidden_dim) {
    let mut w = []
    for i in 0..hidden_dim {
        let mut row = mt_zeros(in_dim)
        for j in 0..in_dim {
            row[j] = mt_hash(42, i, j) * 0.1
        }
        w = w + [row]
    }
    return w
}

// ═══════════════════════════════════════════════════════════════════
//  Task-Specific Head — creates weight matrix [out_dim x hidden_dim]
// ═══════════════════════════════════════════════════════════════════
@pure
fn mt_create_head(hidden_dim, out_dim, seed) {
    let mut w = []
    for i in 0..out_dim {
        let mut row = mt_zeros(hidden_dim)
        for j in 0..hidden_dim {
            row[j] = mt_hash(seed, i, j) * 0.1
        }
        w = w + [row]
    }
    return w
}

// ═══════════════════════════════════════════════════════════════════
//  Encoder Forward — h = ReLU(W_enc @ input)
// ═══════════════════════════════════════════════════════════════════
@pure @hot
fn mt_encoder_forward(weights, input) {
    let hidden_dim = len(weights)
    let in_dim = len(input)
    let mut h = mt_zeros(hidden_dim)
    for i in 0..hidden_dim {
        let mut s = 0.0
        for j in 0..in_dim {
            s = s + weights[i][j] * input[j]
        }
        h[i] = mt_relu(s)
    }
    return h
}

// ═══════════════════════════════════════════════════════════════════
//  Head Forward — out = W_head @ hidden
// ═══════════════════════════════════════════════════════════════════
@pure @hot
fn mt_head_forward(head, hidden) {
    let out_dim = len(head)
    let hidden_dim = len(hidden)
    let mut out = mt_zeros(out_dim)
    for i in 0..out_dim {
        let mut s = 0.0
        for j in 0..hidden_dim {
            s = s + head[i][j] * hidden[j]
        }
        out[i] = s
    }
    return out
}

// ═══════════════════════════════════════════════════════════════════
//  Full Forward — encoder + task-specific head
//
//  shared: encoder weights
//  heads:  array of head weights (one per task)
//  input:  input vector
//  task_id: which head to use
// ═══════════════════════════════════════════════════════════════════
@pure @hot
fn mt_forward(shared, heads, input, task_id) {
    let hidden = mt_encoder_forward(shared, input)
    let head = heads[task_id]
    return mt_head_forward(head, hidden)
}

// ═══════════════════════════════════════════════════════════════════
//  MSE Loss — L = (1/n) * sum((pred[i] - target[i])^2)
// ═══════════════════════════════════════════════════════════════════
@pure
fn mt_mse_loss(pred, target) {
    let n = len(pred)
    let mut loss = 0.0
    for i in 0..n {
        let d = pred[i] - target[i]
        loss = loss + d * d
    }
    return loss / to_float(n)
}

// ═══════════════════════════════════════════════════════════════════
//  Loss Balancing — Fixed Ratio
//
//  total_loss = sum(ratios[i] * losses[i])
// ═══════════════════════════════════════════════════════════════════
@pure
fn mt_loss_fixed(losses, ratios) {
    let n = len(losses)
    let mut total = 0.0
    for i in 0..n {
        total = total + ratios[i] * losses[i]
    }
    return total
}

// ═══════════════════════════════════════════════════════════════════
//  Loss Balancing — Uncertainty Weighting (Kendall et al.)
//
//  L = sum( (1 / (2 * exp(log_var[i]))) * loss[i] + log_var[i] / 2 )
//
//  log_var: learnable log-variance per task (higher = less weight)
// ═══════════════════════════════════════════════════════════════════
@pure
fn mt_loss_uncertainty(losses, log_vars) {
    let n = len(losses)
    let mut total = 0.0
    for i in 0..n {
        let precision = 1.0 / (2.0 * mt_exp(log_vars[i]))
        total = total + precision * losses[i] + log_vars[i] / 2.0
    }
    return total
}

// ═══════════════════════════════════════════════════════════════════
//  Task Router — softmax over router weights to select task
//
//  router_w: [n_tasks x in_dim] scoring weights
//  Returns: task_id with highest score
// ═══════════════════════════════════════════════════════════════════
@pure
fn mt_route_task(input, n_tasks, router_w) {
    let in_dim = len(input)
    let mut best_id = 0
    let mut best_score = -1.0e30
    for t in 0..n_tasks {
        let mut s = 0.0
        for j in 0..in_dim {
            s = s + router_w[t][j] * input[j]
        }
        if s > best_score {
            best_score = s
            best_id = t
        }
    }
    return best_id
}

// ═══════════════════════════════════════════════════════════════════
//  Router Scores — return all task scores (for soft routing)
// ═══════════════════════════════════════════════════════════════════
@pure
fn mt_route_scores(input, n_tasks, router_w) {
    let in_dim = len(input)
    let mut scores = mt_zeros(n_tasks)
    for t in 0..n_tasks {
        let mut s = 0.0
        for j in 0..in_dim {
            s = s + router_w[t][j] * input[j]
        }
        scores[t] = s
    }
    return scores
}

// ═══════════════════════════════════════════════════════════════════
//  Create Router Weights
// ═══════════════════════════════════════════════════════════════════
@pure
fn mt_create_router(in_dim, n_tasks) {
    let mut w = []
    for t in 0..n_tasks {
        let mut row = mt_zeros(in_dim)
        for j in 0..in_dim {
            row[j] = mt_hash(7919 + t, t, j) * 0.05
        }
        w = w + [row]
    }
    return w
}

// ═══════════════════════════════════════════════════════════════════
//  Multi-Task Train Step (numerical gradient)
//
//  data: array of [input, target, task_id]
//  Returns: total loss after step
// ═══════════════════════════════════════════════════════════════════
@hot
fn mt_train_step(shared, heads, data, ratios, lr) {
    let n_samples = len(data)
    let n_tasks = len(heads)
    let hidden_dim = len(shared)
    let in_dim = len(shared[0])
    let eps = 1.0e-4

    // Compute per-task losses
    let mut task_losses = mt_zeros(n_tasks)
    let mut task_counts = mt_zeros(n_tasks)
    for s in 0..n_samples {
        let input = data[s][0]
        let target = data[s][1]
        let tid = data[s][2]
        let pred = mt_forward(shared, heads, input, tid)
        let loss = mt_mse_loss(pred, target)
        task_losses[tid] = task_losses[tid] + loss
        task_counts[tid] = task_counts[tid] + 1.0
    }
    // Average per-task loss
    for t in 0..n_tasks {
        if task_counts[t] > 0.0 {
            task_losses[t] = task_losses[t] / task_counts[t]
        }
    }
    let total_loss = mt_loss_fixed(task_losses, ratios)

    // Numerical gradient on shared encoder
    for i in 0..hidden_dim {
        for j in 0..in_dim {
            let orig = shared[i][j]
            shared[i][j] = orig + eps
            // Recompute
            let mut tl_plus = mt_zeros(n_tasks)
            let mut tc_plus = mt_zeros(n_tasks)
            for s in 0..n_samples {
                let pred_p = mt_forward(shared, heads, data[s][0], data[s][2])
                let loss_p = mt_mse_loss(pred_p, data[s][1])
                tl_plus[data[s][2]] = tl_plus[data[s][2]] + loss_p
                tc_plus[data[s][2]] = tc_plus[data[s][2]] + 1.0
            }
            for t in 0..n_tasks {
                if tc_plus[t] > 0.0 { tl_plus[t] = tl_plus[t] / tc_plus[t] }
            }
            let loss_plus = mt_loss_fixed(tl_plus, ratios)
            let grad = (loss_plus - total_loss) / eps
            shared[i][j] = orig - lr * grad
        }
    }

    return total_loss
}

// ═══════════════════════════════════════════════════════════════════
//  Softmax for router (temperature=1)
// ═══════════════════════════════════════════════════════════════════
@pure
fn mt_softmax(scores) {
    let n = len(scores)
    let mut mx = scores[0]
    for i in 1..n {
        if scores[i] > mx { mx = scores[i] }
    }
    let mut exps = mt_zeros(n)
    let mut z = 0.0
    for i in 0..n {
        exps[i] = mt_exp(scores[i] - mx)
        z = z + exps[i]
    }
    let mut out = mt_zeros(n)
    for i in 0..n {
        out[i] = exps[i] / z
    }
    return out
}

// ═══════════════════════════════════════════════════════════════════
//  Multi-Task Train Step v2 — separate arrays to avoid mixed types
//
//  inputs:  array of input vectors
//  targets: array of target vectors
//  tids:    array of task IDs (int)
// ═══════════════════════════════════════════════════════════════════
@hot
fn mt_train_step_v2(shared, heads, inputs, targets, tids, ratios, lr) {
    let n_samples = len(inputs)
    let n_tasks = len(heads)
    let hidden_dim = len(shared)
    let in_dim = len(shared[0])
    let eps = 1.0e-4

    let mut task_losses = mt_zeros(n_tasks)
    let mut task_counts = mt_zeros(n_tasks)
    for s in 0..n_samples {
        let tid = tids[s]
        let pred = mt_forward(shared, heads, inputs[s], tid)
        let loss = mt_mse_loss(pred, targets[s])
        task_losses[tid] = task_losses[tid] + loss
        task_counts[tid] = task_counts[tid] + 1.0
    }
    for t in 0..n_tasks {
        if task_counts[t] > 0.0 {
            task_losses[t] = task_losses[t] / task_counts[t]
        }
    }
    let total_loss = mt_loss_fixed(task_losses, ratios)

    for i in 0..hidden_dim {
        for j in 0..in_dim {
            let orig = shared[i][j]
            shared[i][j] = orig + eps
            let mut tl_plus = mt_zeros(n_tasks)
            let mut tc_plus = mt_zeros(n_tasks)
            for s in 0..n_samples {
                let tid_s = tids[s]
                let pred_p = mt_forward(shared, heads, inputs[s], tid_s)
                let loss_p = mt_mse_loss(pred_p, targets[s])
                tl_plus[tid_s] = tl_plus[tid_s] + loss_p
                tc_plus[tid_s] = tc_plus[tid_s] + 1.0
            }
            for t in 0..n_tasks {
                if tc_plus[t] > 0.0 { tl_plus[t] = tl_plus[t] / tc_plus[t] }
            }
            let loss_plus = mt_loss_fixed(tl_plus, ratios)
            let grad = (loss_plus - total_loss) / eps
            shared[i][j] = orig - lr * grad
        }
    }

    return total_loss
}

println("[multi_task] loaded — shared encoder + task heads + loss balancing + task routing")
