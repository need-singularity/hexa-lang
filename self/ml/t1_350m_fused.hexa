// t1_350m_fused — 7B inference with block_forward_fused
// hexa 인터프리터 overhead 최소화: layer당 1 Rust call
let D       = 1024
let N_LAYER = 24
let VOCAB   = 32000
let SEQ     = 128
let FF      = 4096
let LORA_R  = 16   // rect sweep sweet spot

let Uqkv = tensor_zeros(D * 3 * LORA_R)
let Vv = tensor_zeros(LORA_R * D)
let Uo = tensor_zeros(D * LORA_R)
let Vo = tensor_zeros(LORA_R * D)
let U_up = tensor_zeros(D * LORA_R)
let V_up = tensor_zeros(LORA_R * FF)
let U_dn = tensor_zeros(FF * LORA_R)
let V_dn = tensor_zeros(LORA_R * D)
let U_lmh = tensor_zeros(D * LORA_R)
let V_lmh = tensor_zeros(LORA_R * VOCAB)

let scratch_lmh_t   = tensor_zeros(1 * LORA_R)
let scratch_lmh_out = tensor_zeros(1 * VOCAB)

fn embed(ids) { tensor_zeros(SEQ * D) }

fn lm_head_lr_into(h_last) {
    let t = matmul_into(h_last, U_lmh, 1, D, LORA_R, scratch_lmh_t)
    matmul_into(t, V_lmh, 1, LORA_R, VOCAB, scratch_lmh_out)
}

fn forward_pass(ids) {
    let mut h = embed(ids)
    let mut li = 0
    while li < N_LAYER {
        h = block_forward_fused(h, Uqkv, Vv, Uo, Vo, U_up, V_up, U_dn, V_dn, SEQ, D, LORA_R, FF)
        li = li + 1
    }
    let mut last = []
    let base = (SEQ - 1) * D
    let mut i = 0
    while i < D {
        last = last.push(h[base + i])
        i = i + 1
    }
    let last_t = tensor(last)
    lm_head_lr_into(last_t)
}

println("[t1_350m] 7B inference via block_forward_fused — 1 forward")
let mut ids = []
let mut i = 0
while i < SEQ { ids = ids.push(0); i = i + 1 }

let t0 = clock()
let _logits = forward_pass(ids)
let t1 = clock()

let fwd_ms = (t1 - t0) * 1000.0
let tok_s = 1000.0 / fwd_ms
let bytes_per_step = 3500000000
let bw_gbs = (to_float(str(bytes_per_step)) / (fwd_ms / 1000.0)) / 1000000000.0

let mut line = "{\"phase\":\"t1_350m\",\"D\":" + str(D)
line = line + ",\"n_layer\":" + str(N_LAYER)
line = line + ",\"seq\":" + str(SEQ)
line = line + ",\"r\":" + str(LORA_R)
line = line + ",\"fwd_ms\":" + str(fwd_ms)
line = line + ",\"tok_s\":" + str(tok_s)
line = line + ",\"bw_gbs\":" + str(bw_gbs) + "}"
println(line)
