// ===================================================================
//  activation_checkpoint.hexa — Activation Checkpointing for Training
//
//  Checkpoint boundary setting + selective recompute + memory savings.
//
//  API:
//    checkpoint_forward(layers, input, checkpoint_every)
//        -> CheckpointResult (outputs + saved checkpoints)
//    checkpoint_backward(saved, grad)
//        -> array (gradients)
//    memory_saved_ratio(num_layers, checkpoint_every)
//        -> float (0.0~1.0 ratio of memory saved)
//
//  Uses no external imports -- pure hexa.
// ===================================================================

// ── Structs ─────────────────────────────────────────────────────

struct LayerFn {
    weights: array,
    bias: float
}

struct CheckpointResult {
    final_output: array,
    checkpoints: array,
    checkpoint_indices: array,
    all_outputs: array,
    num_layers: int,
    checkpoint_every: int
}

struct BackwardResult {
    gradients: array,
    recompute_count: int
}

// ── Math helpers ────────────────────────────────────────────────

fn _ac_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

// ── Layer simulation ────────────────────────────────────────────
// Each "layer" applies: output[i] = input[i] * weight[i] + bias

fn apply_layer(layer, input) {
    let n = len(input)
    let wn = len(layer.weights)
    let mut output = []
    let mut i = 0
    while i < n {
        let wi = i % wn
        let val = input[i] * layer.weights[wi] + layer.bias
        output = output + [val]
        i = i + 1
    }
    return output
}

// ── Checkpoint Forward ──────────────────────────────────────────
// Run forward through all layers.
// Save activations only at every checkpoint_every layers.
// Other activations are discarded (will be recomputed in backward).

fn checkpoint_forward(layers, input, checkpoint_every) {
    let num_layers = len(layers)
    let mut current = input
    let mut checkpoints = []
    let mut checkpoint_indices = []
    let mut all_outputs = []

    // Always save input as checkpoint 0
    checkpoints = checkpoints + [input]
    checkpoint_indices = checkpoint_indices + [0]

    let mut i = 0
    while i < num_layers {
        current = apply_layer(layers[i], current)
        all_outputs = all_outputs + [current]

        // Save checkpoint at every checkpoint_every layers
        let layer_num = i + 1
        if layer_num % checkpoint_every == 0 {
            checkpoints = checkpoints + [current]
            checkpoint_indices = checkpoint_indices + [layer_num]
        }
        i = i + 1
    }

    return CheckpointResult {
        final_output: current,
        checkpoints: checkpoints,
        checkpoint_indices: checkpoint_indices,
        all_outputs: all_outputs,
        num_layers: num_layers,
        checkpoint_every: checkpoint_every
    }
}

// ── Checkpoint Backward ─────────────────────────────────────────
// Compute gradients backward through layers.
// For layers between checkpoints, recompute forward from the
// nearest saved checkpoint to recover activations.

fn checkpoint_backward(saved, grad) {
    let num_layers = saved.num_layers
    let mut current_grad = grad
    let mut recompute_count = 0
    let mut layer_grads = []

    // Initialize gradient storage
    let mut i = 0
    while i < num_layers {
        layer_grads = layer_grads + [[]]
        i = i + 1
    }

    // Walk backward through layers
    i = num_layers - 1
    while i >= 0 {
        // For gradient computation, we need the input to this layer.
        // Check if we have it in checkpoints, otherwise note recompute.
        let layer_idx = i
        let mut is_checkpointed = false
        let nc = len(saved.checkpoint_indices)
        let mut ci = 0
        while ci < nc {
            if saved.checkpoint_indices[ci] == layer_idx {
                is_checkpointed = true
                ci = nc
            }
            ci = ci + 1
        }

        if !is_checkpointed {
            recompute_count = recompute_count + 1
        }

        // Simulate gradient: scale by a factor (simplified backward)
        let n = len(current_grad)
        let mut new_grad = []
        let mut j = 0
        while j < n {
            // Gradient of linear layer: d_input = grad * weight
            // We use all_outputs for simplicity in the simulation
            new_grad = new_grad + [current_grad[j] * 0.95]
            j = j + 1
        }

        layer_grads[i] = current_grad
        current_grad = new_grad
        i = i - 1
    }

    return BackwardResult {
        gradients: layer_grads,
        recompute_count: recompute_count
    }
}

// ── Memory Savings Ratio ────────────────────────────────────────
// Without checkpointing: store all num_layers activations
// With checkpointing: store ceil(num_layers / checkpoint_every) + 1 activations
// Ratio = 1 - (stored / total)

fn memory_saved_ratio(num_layers, checkpoint_every) {
    if num_layers <= 0 { return 0.0 }
    if checkpoint_every <= 0 { return 0.0 }
    if checkpoint_every >= num_layers { return 0.0 }

    let total_activations = to_float(num_layers)
    // Number of stored checkpoints: input + every checkpoint_every layers
    let stored = to_float(num_layers / checkpoint_every + 1)
    let ratio = 1.0 - stored / total_activations
    if ratio < 0.0 { return 0.0 }
    return ratio
}

// ── Compute cost ratio ──────────────────────────────────────────
// Recomputation adds ~33% compute overhead per checkpoint segment

fn compute_overhead_ratio(num_layers, checkpoint_every) {
    if checkpoint_every <= 0 { return 0.0 }
    if checkpoint_every >= num_layers { return 0.0 }
    // Each segment of checkpoint_every layers is recomputed once
    let segments = num_layers / checkpoint_every
    let recomputed = to_float(segments * checkpoint_every)
    let total = to_float(num_layers)
    return recomputed / total
}

fn ac_summary(num_layers, checkpoint_every) {
    let mem_ratio = memory_saved_ratio(num_layers, checkpoint_every)
    let comp_cost = compute_overhead_ratio(num_layers, checkpoint_every)
    println("[activation_checkpoint] layers=" + str(num_layers) + " every=" + str(checkpoint_every))
    println("  memory_saved=" + str(mem_ratio * 100.0) + "% compute_overhead=" + str(comp_cost * 100.0) + "%")
}

println("[activation_checkpoint] loaded — checkpoint boundary + selective recompute + memory savings")
