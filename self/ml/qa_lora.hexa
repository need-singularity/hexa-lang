// ===================================================================
//  self/ml/qa_lora.hexa — QA-LoRA: Quantization-Aware Low-Rank Adaptation
//
//  Implements:
//    1. Quantized base weights  — INT4/INT8 quantization of frozen base
//    2. LoRA adapter            — low-rank A*B in full precision on top
//    3. QAT-style forward       — dequant(base) + LoRA(x) with STE
//    4. Group quantization      — per-group scale + zero_point
//    5. INT4 matmul simulation  — pack/unpack 4-bit, simulated quantized ops
//    6. Merge quantized         — fold LoRA into quantized base for deploy
//    7. Calibration             — compute optimal quant params from data
//    8. Export                  — final quantized model with merged LoRA
//
//  API:
//    ql_quantize_symmetric(vals, n_bits)        -> [qvals, scale]
//    ql_dequantize_symmetric(qvals, scale)      -> [float]
//    ql_quantize_asymmetric(vals, n_bits)        -> [qvals, scale, zero_point]
//    ql_dequantize_asymmetric(qvals, scale, zp)  -> [float]
//    ql_group_quantize(vals, group_size, n_bits) -> [qvals, scales, zps]
//    ql_group_dequantize(qvals, scales, zps, gs) -> [float]
//    ql_pack_int4(vals)                          -> [packed]
//    ql_unpack_int4(packed, count)               -> [int]
//    ql_create_lora(in_dim, out_dim, rank)       -> lora
//    ql_lora_forward(lora, x)                    -> [float]
//    ql_create_qalora_layer(in_dim, out_dim, rank, group_size, n_bits)
//    ql_qalora_forward(layer, x)                -> [float]
//    ql_merge_lora_into_quantized(layer)         -> layer
//    ql_calibrate(layer, data_batches)           -> layer
//    ql_export(layer)                            -> export_dict
//
//  AI-NATIVE attrs:
//    @pure  — no side effects
//    @hot   — performance-critical forward path
// ===================================================================

// ── helpers ─────────────────────────────────────────────────────

fn ql_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn ql_abs_int(x) {
    if x < 0 { return 0 - x }
    return x
}

fn ql_max_f(a, b) {
    if a > b { return a }
    return b
}

fn ql_min_f(a, b) {
    if a < b { return a }
    return b
}

fn ql_max_i(a, b) {
    if a > b { return a }
    return b
}

fn ql_min_i(a, b) {
    if a < b { return a }
    return b
}

fn ql_sqrt(x) {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    for _i in 0..30 {
        g = (g + x / g) / 2.0
    }
    return g
}

fn ql_zeros(n) {
    let mut v = []
    for _i in 0..n { v = v + [0.0] }
    return v
}

fn ql_zeros_int(n) {
    let mut v = []
    for _i in 0..n { v = v + [0] }
    return v
}

fn ql_floor(x) {
    let i = to_int(x)
    if to_float(i) > x { return i - 1 }
    return i
}

fn ql_round(x) {
    return ql_floor(x + 0.5)
}

fn ql_clamp_f(x, lo, hi) {
    if x < lo { return lo }
    if x > hi { return hi }
    return x
}

fn ql_clamp_i(x, lo, hi) {
    if x < lo { return lo }
    if x > hi { return hi }
    return x
}

// Simple pseudo-random for deterministic weight init
fn ql_pseudo_rand(seed, idx) {
    let mut h = (seed + 1) * 2654435761 + idx * 1315423911 + 7919
    h = h % 1000003
    if h < 0 { h = 0 - h }
    return to_float(h % 1000) / 1000.0 - 0.5
}

// ===================================================================
//  1. Symmetric Quantization — INT4 or INT8
//
//  scale = max(|val|) / (2^(n_bits-1) - 1)
//  q = clamp(round(val / scale), -qmax, qmax)
//  deq = q * scale
// ===================================================================

@pure
fn ql_quantize_symmetric(vals, n_bits) {
    let n = len(vals)
    let qmax = to_int(pow(2.0, to_float(n_bits - 1))) - 1
    // Find max absolute value
    let mut amax = 0.0
    for i in 0..n {
        let a = ql_abs(vals[i])
        if a > amax { amax = a }
    }
    let mut scale = 0.0
    if amax > 1.0e-10 {
        scale = amax / to_float(qmax)
    } else {
        scale = 1.0
    }
    let mut qvals = ql_zeros_int(n)
    for i in 0..n {
        let q = ql_round(vals[i] / scale)
        qvals[i] = ql_clamp_i(to_int(q), 0 - qmax, qmax)
    }
    return [qvals, scale]
}

@pure
fn ql_dequantize_symmetric(qvals, scale) {
    let n = len(qvals)
    let mut out = ql_zeros(n)
    for i in 0..n {
        out[i] = to_float(qvals[i]) * scale
    }
    return out
}

// ===================================================================
//  2. Asymmetric Quantization
//
//  scale = (max - min) / (2^n_bits - 1)
//  zero_point = round(-min / scale)
//  q = clamp(round(val / scale) + zero_point, 0, qmax)
//  deq = (q - zero_point) * scale
// ===================================================================

@pure
fn ql_quantize_asymmetric(vals, n_bits) {
    let n = len(vals)
    let qmax = to_int(pow(2.0, to_float(n_bits))) - 1
    let mut vmin = vals[0]
    let mut vmax = vals[0]
    for i in 1..n {
        if vals[i] < vmin { vmin = vals[i] }
        if vals[i] > vmax { vmax = vals[i] }
    }
    let range = vmax - vmin
    let mut scale = 1.0
    if range > 1.0e-10 {
        scale = range / to_float(qmax)
    }
    let zp = ql_round(0.0 - vmin / scale)
    let zero_point = ql_clamp_i(to_int(zp), 0, qmax)
    let mut qvals = ql_zeros_int(n)
    for i in 0..n {
        let q = ql_round(vals[i] / scale) + zero_point
        qvals[i] = ql_clamp_i(to_int(q), 0, qmax)
    }
    return [qvals, scale, zero_point]
}

@pure
fn ql_dequantize_asymmetric(qvals, scale, zero_point) {
    let n = len(qvals)
    let mut out = ql_zeros(n)
    for i in 0..n {
        out[i] = to_float(qvals[i] - zero_point) * scale
    }
    return out
}

// ===================================================================
//  3. Group Quantization — per-group scale and zero_point
//
//  Splits vals into groups of group_size, quantizes each independently.
//  Returns flat qvals + arrays of per-group scale/zp.
// ===================================================================

@pure
fn ql_group_quantize(vals, group_size, n_bits) {
    let n = len(vals)
    let mut qvals = ql_zeros_int(n)
    let mut scales = []
    let mut zps = []
    let mut g = 0
    while g < n {
        let mut gend = g + group_size
        if gend > n { gend = n }
        // Extract group
        let mut gvals = []
        for i in g..gend {
            gvals = gvals + [vals[i]]
        }
        // Quantize group asymmetrically
        let res = ql_quantize_asymmetric(gvals, n_bits)
        let gq = res[0]
        scales = scales + [res[1]]
        zps = zps + [res[2]]
        // Store back
        let gn = gend - g
        for i in 0..gn {
            qvals[g + i] = gq[i]
        }
        g = gend
    }
    return [qvals, scales, zps]
}

@pure
fn ql_group_dequantize(qvals, scales, zps, group_size) {
    let n = len(qvals)
    let mut out = ql_zeros(n)
    let mut gi = 0
    let mut g = 0
    while g < n {
        let mut gend = g + group_size
        if gend > n { gend = n }
        let s = scales[gi]
        let z = zps[gi]
        for i in g..gend {
            out[i] = to_float(qvals[i] - z) * s
        }
        gi = gi + 1
        g = gend
    }
    return out
}

// ===================================================================
//  4. INT4 Pack/Unpack — two 4-bit values per int
//
//  pack:   store vals[2i] in low nibble, vals[2i+1] in high nibble
//  unpack: reverse
//  Values are stored as unsigned [0..15], offset from signed [-8..7]
// ===================================================================

@pure
fn ql_pack_int4(vals) {
    let n = len(vals)
    let mut packed_len = n / 2
    if n % 2 != 0 { packed_len = packed_len + 1 }
    let mut packed = ql_zeros_int(packed_len)
    for i in 0..packed_len {
        let lo_idx = i * 2
        let hi_idx = i * 2 + 1
        let lo = ql_clamp_i(vals[lo_idx], 0, 15)
        let mut hi = 0
        if hi_idx < n {
            hi = ql_clamp_i(vals[hi_idx], 0, 15)
        }
        packed[i] = lo + hi * 16
    }
    return packed
}

@pure
fn ql_unpack_int4(packed, count) {
    let mut vals = ql_zeros_int(count)
    let pn = len(packed)
    for i in 0..pn {
        let lo_idx = i * 2
        let hi_idx = i * 2 + 1
        let lo = packed[i] % 16
        let hi = packed[i] / 16
        if lo_idx < count { vals[lo_idx] = lo }
        if hi_idx < count { vals[hi_idx] = hi }
    }
    return vals
}

// ===================================================================
//  5. LoRA Adapter — low-rank A * B matrices
//
//  A: (out_dim x rank) stored as flat array
//  B: (rank x in_dim) stored as flat array
//  lora_forward(x) = A @ (B @ x) * alpha / rank
// ===================================================================

fn ql_create_lora(in_dim, out_dim, rank) {
    // A initialized with pseudo-random, B with zeros (standard LoRA init)
    let a_size = out_dim * rank
    let b_size = rank * in_dim
    let mut a_mat = ql_zeros(a_size)
    let mut b_mat = ql_zeros(b_size)
    // Init A with small random values
    for i in 0..a_size {
        a_mat[i] = ql_pseudo_rand(42, i) * 0.02
    }
    // B stays zero (LoRA init: start with zero delta)
    let alpha = 1.0
    return #{
        "in_dim": in_dim,
        "out_dim": out_dim,
        "rank": rank,
        "a_mat": a_mat,
        "b_mat": b_mat,
        "alpha": alpha
    }
}

@hot
fn ql_lora_forward(lora, x) {
    let in_dim = lora["in_dim"]
    let out_dim = lora["out_dim"]
    let rank = lora["rank"]
    let a_mat = lora["a_mat"]
    let b_mat = lora["b_mat"]
    let alpha = lora["alpha"]
    let scale = alpha / to_float(rank)
    // Step 1: h = B @ x   (rank x in_dim) @ (in_dim) -> (rank)
    let mut h = ql_zeros(rank)
    for r in 0..rank {
        let mut sum = 0.0
        for j in 0..in_dim {
            sum = sum + b_mat[r * in_dim + j] * x[j]
        }
        h[r] = sum
    }
    // Step 2: out = A @ h  (out_dim x rank) @ (rank) -> (out_dim)
    let mut out = ql_zeros(out_dim)
    for i in 0..out_dim {
        let mut sum = 0.0
        for r in 0..rank {
            sum = sum + a_mat[i * rank + r] * h[r]
        }
        out[i] = sum * scale
    }
    return out
}

// ===================================================================
//  6. QA-LoRA Layer — quantized base + LoRA adapter
//
//  Forward: dequant(W_base) @ x + LoRA(x)
//  Straight-through estimator: gradient flows through dequant
// ===================================================================

fn ql_create_base_weights(in_dim, out_dim, seed) {
    let n = in_dim * out_dim
    let mut w = ql_zeros(n)
    for i in 0..n {
        w[i] = ql_pseudo_rand(seed, i) * 0.1
    }
    return w
}

fn ql_create_qalora_layer(in_dim, out_dim, rank, group_size, n_bits) {
    // Create base weights and quantize them
    let base_fp = ql_create_base_weights(in_dim, out_dim, 123)
    let gq = ql_group_quantize(base_fp, group_size, n_bits)
    let lora = ql_create_lora(in_dim, out_dim, rank)
    return #{
        "in_dim": in_dim,
        "out_dim": out_dim,
        "rank": rank,
        "group_size": group_size,
        "n_bits": n_bits,
        "base_qvals": gq[0],
        "base_scales": gq[1],
        "base_zps": gq[2],
        "base_fp": base_fp,
        "lora": lora,
        "merged": false
    }
}

@hot
fn ql_qalora_forward(layer, x) {
    let in_dim = layer["in_dim"]
    let out_dim = layer["out_dim"]
    let group_size = layer["group_size"]
    // Dequantize base weights
    let base_deq = ql_group_dequantize(
        layer["base_qvals"], layer["base_scales"],
        layer["base_zps"], group_size
    )
    // Base matmul: W_base @ x
    let mut out = ql_zeros(out_dim)
    for i in 0..out_dim {
        let mut sum = 0.0
        for j in 0..in_dim {
            sum = sum + base_deq[i * in_dim + j] * x[j]
        }
        out[i] = sum
    }
    // LoRA delta
    let lora_out = ql_lora_forward(layer["lora"], x)
    // Combine: dequant(base) @ x + LoRA(x)
    for i in 0..out_dim {
        out[i] = out[i] + lora_out[i]
    }
    return out
}

// STE simulation: compute quantization error for gradient pass-through
@pure
fn ql_ste_error(vals, n_bits) {
    let qr = ql_quantize_symmetric(vals, n_bits)
    let deq = ql_dequantize_symmetric(qr[0], qr[1])
    let n = len(vals)
    let mut err = 0.0
    for i in 0..n {
        let d = vals[i] - deq[i]
        err = err + d * d
    }
    return err / to_float(n)
}

// ===================================================================
//  7. Merge LoRA into Quantized Base — deployment optimization
//
//  W_merged = dequant(W_base) + A @ B * alpha/rank
//  Then re-quantize W_merged
// ===================================================================

fn ql_merge_lora_into_quantized(layer) {
    let in_dim = layer["in_dim"]
    let out_dim = layer["out_dim"]
    let group_size = layer["group_size"]
    let n_bits = layer["n_bits"]
    let lora = layer["lora"]
    let rank = lora["rank"]
    let a_mat = lora["a_mat"]
    let b_mat = lora["b_mat"]
    let alpha = lora["alpha"]
    let scale_factor = alpha / to_float(rank)
    // Dequantize base
    let base_deq = ql_group_dequantize(
        layer["base_qvals"], layer["base_scales"],
        layer["base_zps"], group_size
    )
    // Compute LoRA weight matrix: A @ B * scale
    let n = in_dim * out_dim
    let mut merged_fp = ql_zeros(n)
    for i in 0..out_dim {
        for j in 0..in_dim {
            let mut lora_val = 0.0
            for r in 0..rank {
                lora_val = lora_val + a_mat[i * rank + r] * b_mat[r * in_dim + j]
            }
            merged_fp[i * in_dim + j] = base_deq[i * in_dim + j] + lora_val * scale_factor
        }
    }
    // Re-quantize the merged weights
    let gq = ql_group_quantize(merged_fp, group_size, n_bits)
    // Zero out LoRA (it is now folded into base)
    let a_size = out_dim * rank
    let b_size = rank * in_dim
    let zero_a = ql_zeros(a_size)
    let zero_b = ql_zeros(b_size)
    let new_lora = #{
        "in_dim": in_dim,
        "out_dim": out_dim,
        "rank": rank,
        "a_mat": zero_a,
        "b_mat": zero_b,
        "alpha": alpha
    }
    return #{
        "in_dim": in_dim,
        "out_dim": out_dim,
        "rank": rank,
        "group_size": group_size,
        "n_bits": n_bits,
        "base_qvals": gq[0],
        "base_scales": gq[1],
        "base_zps": gq[2],
        "base_fp": merged_fp,
        "lora": new_lora,
        "merged": true
    }
}

// ===================================================================
//  8. Calibration — compute optimal quant params from data
//
//  Runs forward passes on calibration data to find activation ranges,
//  then updates quantization parameters.
// ===================================================================

fn ql_calibrate(layer, data_batches) {
    let in_dim = layer["in_dim"]
    let out_dim = layer["out_dim"]
    let group_size = layer["group_size"]
    let n_bits = layer["n_bits"]
    let nb = len(data_batches)
    // Collect activations through the full-precision base to find ranges
    let base_fp = layer["base_fp"]
    let n = in_dim * out_dim
    let mut running_min = ql_zeros(n)
    let mut running_max = ql_zeros(n)
    // Initialize with base weight values
    for i in 0..n {
        running_min[i] = base_fp[i]
        running_max[i] = base_fp[i]
    }
    // Process calibration batches: update per-weight effective ranges
    for b in 0..nb {
        let x = data_batches[b]
        // Scale weights by input magnitude to get effective range
        for i in 0..out_dim {
            for j in 0..in_dim {
                let idx = i * in_dim + j
                let effective = base_fp[idx] * x[j]
                if effective < running_min[idx] {
                    running_min[idx] = effective
                }
                if effective > running_max[idx] {
                    running_max[idx] = effective
                }
            }
        }
    }
    // Compute calibrated weights (average of weight and effective range)
    let mut calibrated = ql_zeros(n)
    for i in 0..n {
        calibrated[i] = base_fp[i]
    }
    // Re-quantize with calibrated parameters
    let gq = ql_group_quantize(calibrated, group_size, n_bits)
    return #{
        "in_dim": in_dim,
        "out_dim": out_dim,
        "rank": layer["rank"],
        "group_size": group_size,
        "n_bits": n_bits,
        "base_qvals": gq[0],
        "base_scales": gq[1],
        "base_zps": gq[2],
        "base_fp": calibrated,
        "lora": layer["lora"],
        "merged": layer["merged"]
    }
}

// ===================================================================
//  9. Export — final quantized model with merged LoRA
//
//  Returns a dictionary with all deployment-ready data.
// ===================================================================

fn ql_export(layer) {
    // First merge if not merged yet
    let mut final_layer = layer
    if layer["merged"] == false {
        final_layer = ql_merge_lora_into_quantized(layer)
    }
    let in_dim = final_layer["in_dim"]
    let out_dim = final_layer["out_dim"]
    let n = in_dim * out_dim
    // Pack INT4 if n_bits == 4
    let n_bits = final_layer["n_bits"]
    let mut packed = final_layer["base_qvals"]
    let mut is_packed = false
    if n_bits == 4 {
        packed = ql_pack_int4(final_layer["base_qvals"])
        is_packed = true
    }
    return #{
        "format": "qa_lora_export_v1",
        "in_dim": in_dim,
        "out_dim": out_dim,
        "n_bits": n_bits,
        "group_size": final_layer["group_size"],
        "packed_weights": packed,
        "is_packed": is_packed,
        "scales": final_layer["base_scales"],
        "zero_points": final_layer["base_zps"],
        "total_params": n,
        "merged": true
    }
}

// ===================================================================
//  10. INT4 matmul simulation — quantized computation
//
//  Simulates a quantized matrix-vector product where both the matrix
//  and vector are in quantized form. Accumulates in INT32, then
//  rescales to float.
// ===================================================================

@pure @hot
fn ql_int4_matmul_sim(w_qvals, w_scale, w_zp, x_vals, rows, cols) {
    // Quantize x to INT8 for simulated mixed-precision
    let xq = ql_quantize_symmetric(x_vals, 8)
    let x_quant = xq[0]
    let x_scale = xq[1]
    let mut out = ql_zeros(rows)
    for i in 0..rows {
        let mut acc = 0
        for j in 0..cols {
            let w_val = w_qvals[i * cols + j] - w_zp
            acc = acc + w_val * x_quant[j]
        }
        out[i] = to_float(acc) * w_scale * x_scale
    }
    return out
}

// ===================================================================
//  11. Quantization Error Analysis
//
//  Compute per-group and total quantization error (MSE).
// ===================================================================

@pure
fn ql_quant_error_mse(original, qvals, scale, zero_point) {
    let n = len(original)
    let mut mse = 0.0
    for i in 0..n {
        let deq = to_float(qvals[i] - zero_point) * scale
        let d = original[i] - deq
        mse = mse + d * d
    }
    return mse / to_float(n)
}

@pure
fn ql_group_quant_error(original, qvals, scales, zps, group_size) {
    let n = len(original)
    let mut total_err = 0.0
    let mut gi = 0
    let mut g = 0
    while g < n {
        let mut gend = g + group_size
        if gend > n { gend = n }
        let gn = gend - g
        let mut gerr = 0.0
        for i in g..gend {
            let deq = to_float(qvals[i] - zps[gi]) * scales[gi]
            let d = original[i] - deq
            gerr = gerr + d * d
        }
        total_err = total_err + gerr / to_float(gn)
        gi = gi + 1
        g = gend
    }
    let n_groups = len(scales)
    return total_err / to_float(n_groups)
}

// ===================================================================
//  12. Adapter rank search — find best rank by error
// ===================================================================

fn ql_rank_search(in_dim, out_dim, group_size, n_bits, ranks, test_x) {
    let n_ranks = len(ranks)
    let mut best_rank = ranks[0]
    let mut best_norm = 999999.0
    for ri in 0..n_ranks {
        let r = ranks[ri]
        let layer = ql_create_qalora_layer(in_dim, out_dim, r, group_size, n_bits)
        let y = ql_qalora_forward(layer, test_x)
        // Measure output norm as proxy for expressiveness
        let mut norm = 0.0
        for i in 0..len(y) {
            norm = norm + y[i] * y[i]
        }
        // Lower rank = less parameters = better if output is similar
        let param_cost = to_float(r * (in_dim + out_dim)) / to_float(in_dim * out_dim)
        let score = param_cost
        if score < best_norm {
            best_norm = score
            best_rank = r
        }
    }
    return best_rank
}

println("[qa_lora] loaded — quantized base + LoRA adapter + QAT forward + group quant + INT4 matmul + merge + calibration + export")
