// ═══════════════════════════════════════════════════════════════
//  cuda_kernels.hexa — Custom CUDA C kernels for CLM training
//
//  Phase 2 of clm_hexa_gpu (zero-Rust, hexa-only path).
//
//  All twelve kernels live as hexa string constants. At startup,
//  gpu_init_kernels() concatenates them into a single translation
//  unit, hands it to NVRTC via cuda_rtc.hexa (rtc_compile_ptx),
//  loads the resulting module, and resolves each function handle
//  into a global. The 12 launcher wrappers build a host-side
//  argument array (alloc_raw(8) for pointers, alloc_raw(4) for
//  scalars) and forward to rtc_launch().
//
//  Numerical semantics MATCH training/train_byte_kr.hexa exactly:
//    - RMS: ms = mean(x^2); rstd = 1/sqrt(ms+eps); out = x*rstd*g
//    - Softmax: max-shift for numerical stability, causal mask via
//      additive -1e30 BEFORE the max so masked positions never
//      contribute to the normaliser.
//    - SwiGLU: out = up * sigmoid(gate)  (gate is the swish input)
//    - Cross-entropy: per-row logsumexp; dlogits = (softmax - onehot) / R
//      where R is rows (= SEQ) — matches scale = 1/SEQ in CPU ref.
//
//  Block/grid choices:
//    - 1D element-wise: block=256, grid=ceil(N/256)
//    - embed_lookup(_bwd): block=(16,16), grid=(ceil(N/16),ceil(D/16))
//    - rms_norm_(fwd|bwd) / softmax_rows_(fwd|bwd) / ce_loss_grad:
//      one block per row, block.x = D (or C), assumes D <= 1024.
//      Shared-memory reductions for sums/max.
//
//  Targets sm_90 (H100). Compile flags set in cuda_rtc.hexa.
// ═══════════════════════════════════════════════════════════════

use "cuda_ffi"
use "cuda_rtc"

// ── Kernel sources ───────────────────────────────────────────
//
// Each constant holds a single __global__ void definition with
// `extern "C"` so the symbol survives unmangled into the PTX.
// `restrict` and `__ldg` are intentionally avoided to keep the
// kernels portable; cuBLAS handles the heavy GEMMs anyway.

let K_EMBED_LOOKUP = "extern \"C\" __global__ void embed_lookup(const float* W, const int* toks, float* out, int V, int D, int N) {\n    int n = blockIdx.x * blockDim.x + threadIdx.x;\n    int d = blockIdx.y * blockDim.y + threadIdx.y;\n    if (n >= N || d >= D) return;\n    int t = toks[n];\n    out[n * D + d] = W[t * D + d];\n}\n"

let K_RMS_NORM_FWD = "extern \"C\" __global__ void rms_norm_fwd(const float* x, const float* g, float* out, float* rstd, int N, int D, float eps) {\n    int row = blockIdx.x;\n    int tid = threadIdx.x;\n    if (row >= N || tid >= D) return;\n    extern __shared__ float sdata[];\n    float v = x[row * D + tid];\n    sdata[tid] = v * v;\n    __syncthreads();\n    // tree reduction (D <= 1024, blockDim.x == D)\n    for (int s = blockDim.x >> 1; s > 0; s >>= 1) {\n        if (tid < s) sdata[tid] += sdata[tid + s];\n        __syncthreads();\n    }\n    float ms = sdata[0] / (float)D;\n    float r  = rsqrtf(ms + eps);\n    if (tid == 0) rstd[row] = r;\n    out[row * D + tid] = v * r * g[tid];\n}\n"

let K_SOFTMAX_ROWS_FWD = "extern \"C\" __global__ void softmax_rows_fwd(const float* x, float* out, int R, int C, int causal) {\n    int row = blockIdx.x;\n    int tid = threadIdx.x;\n    if (row >= R || tid >= C) return;\n    extern __shared__ float sdata[];\n    float v = x[row * C + tid];\n    if (causal != 0 && tid > row) v = -1e30f;\n    sdata[tid] = v;\n    __syncthreads();\n    // max reduction\n    for (int s = blockDim.x >> 1; s > 0; s >>= 1) {\n        if (tid < s) {\n            float a = sdata[tid];\n            float b = sdata[tid + s];\n            sdata[tid] = a > b ? a : b;\n        }\n        __syncthreads();\n    }\n    float mx = sdata[0];\n    __syncthreads();\n    float e = expf(v - mx);\n    sdata[tid] = e;\n    __syncthreads();\n    // sum reduction\n    for (int s = blockDim.x >> 1; s > 0; s >>= 1) {\n        if (tid < s) sdata[tid] += sdata[tid + s];\n        __syncthreads();\n    }\n    float sum = sdata[0];\n    out[row * C + tid] = e / sum;\n}\n"

let K_SWIGLU_FWD = "extern \"C\" __global__ void swiglu_fwd(const float* up, const float* gate, float* out, int N) {\n    int i = blockIdx.x * blockDim.x + threadIdx.x;\n    if (i >= N) return;\n    float g = gate[i];\n    float s = 1.0f / (1.0f + expf(-g));\n    out[i] = up[i] * s;\n}\n"

let K_ADD_INPLACE = "extern \"C\" __global__ void add_inplace(float* a, const float* b, int N) {\n    int i = blockIdx.x * blockDim.x + threadIdx.x;\n    if (i >= N) return;\n    a[i] = a[i] + b[i];\n}\n"

let K_MUL_SCALAR = "extern \"C\" __global__ void mul_scalar(const float* a, float s, float* out, int N) {\n    int i = blockIdx.x * blockDim.x + threadIdx.x;\n    if (i >= N) return;\n    out[i] = a[i] * s;\n}\n"

let K_RANDN_FILL = "extern \"C\" __global__ void randn_fill(float* a, int N, unsigned long long seed, float scale) {\n    int i = blockIdx.x * blockDim.x + threadIdx.x;\n    if (i >= N) return;\n    // splitmix64-style hash on (seed, i) for two uniforms\n    unsigned long long z1 = seed + (unsigned long long)i * 0x9E3779B97F4A7C15ULL + 0xD1B54A32D192ED03ULL;\n    z1 = (z1 ^ (z1 >> 30)) * 0xBF58476D1CE4E5B9ULL;\n    z1 = (z1 ^ (z1 >> 27)) * 0x94D049BB133111EBULL;\n    z1 = z1 ^ (z1 >> 31);\n    unsigned long long z2 = seed + (unsigned long long)i * 0xC2B2AE3D27D4EB4FULL + 0x165667B19E3779F9ULL;\n    z2 = (z2 ^ (z2 >> 30)) * 0xBF58476D1CE4E5B9ULL;\n    z2 = (z2 ^ (z2 >> 27)) * 0x94D049BB133111EBULL;\n    z2 = z2 ^ (z2 >> 31);\n    float u1 = ((float)((z1 >> 11) & 0xFFFFFFULL) + 1.0f) / 16777217.0f;\n    float u2 = ((float)((z2 >> 11) & 0xFFFFFFULL) + 1.0f) / 16777217.0f;\n    float r  = sqrtf(-2.0f * logf(u1));\n    float th = 6.2831853071795864769f * u2;\n    a[i] = r * cosf(th) * scale;\n}\n"

let K_EMBED_LOOKUP_BWD = "extern \"C\" __global__ void embed_lookup_bwd(const float* dy, const int* toks, float* dW, int V, int D, int N) {\n    int n = blockIdx.x * blockDim.x + threadIdx.x;\n    int d = blockIdx.y * blockDim.y + threadIdx.y;\n    if (n >= N || d >= D) return;\n    int t = toks[n];\n    atomicAdd(&dW[t * D + d], dy[n * D + d]);\n}\n"

let K_RMS_NORM_BWD = "extern \"C\" __global__ void rms_norm_bwd(const float* x, const float* g, const float* dy, const float* rstd, float* dx, float* dg, int N, int D, float eps) {\n    int row = blockIdx.x;\n    int tid = threadIdx.x;\n    if (row >= N || tid >= D) return;\n    extern __shared__ float sdata[];\n    float xv  = x[row * D + tid];\n    float gv  = g[tid];\n    float dyv = dy[row * D + tid];\n    float r   = rstd[row];\n    // coef = sum_d x[d] * g[d] * dy[d]\n    sdata[tid] = xv * gv * dyv;\n    __syncthreads();\n    for (int s = blockDim.x >> 1; s > 0; s >>= 1) {\n        if (tid < s) sdata[tid] += sdata[tid + s];\n        __syncthreads();\n    }\n    float coef = sdata[0];\n    float r3   = r * r * r;\n    dx[row * D + tid] = gv * dyv * r - xv * coef * r3 / (float)D;\n    // dg: atomicAdd across rows — caller passes gpu_zeros(D).\n    atomicAdd(&dg[tid], xv * dyv * r);\n}\n"

let K_SOFTMAX_ROWS_BWD = "extern \"C\" __global__ void softmax_rows_bwd(const float* probs, const float* dp, float* ds, int R, int C) {\n    int row = blockIdx.x;\n    int tid = threadIdx.x;\n    if (row >= R || tid >= C) return;\n    extern __shared__ float sdata[];\n    float p = probs[row * C + tid];\n    float d = dp[row * C + tid];\n    sdata[tid] = p * d;\n    __syncthreads();\n    for (int s = blockDim.x >> 1; s > 0; s >>= 1) {\n        if (tid < s) sdata[tid] += sdata[tid + s];\n        __syncthreads();\n    }\n    float sum = sdata[0];\n    ds[row * C + tid] = p * (d - sum);\n}\n"

let K_SWIGLU_BWD = "extern \"C\" __global__ void swiglu_bwd(const float* up, const float* gate, const float* dy, float* dup, float* dgate, int N) {\n    int i = blockIdx.x * blockDim.x + threadIdx.x;\n    if (i >= N) return;\n    float g  = gate[i];\n    float s  = 1.0f / (1.0f + expf(-g));\n    float dv = dy[i];\n    dup[i]   = dv * s;\n    dgate[i] = dv * up[i] * s * (1.0f - s);\n}\n"

let K_CE_LOSS_GRAD = "extern \"C\" __global__ void ce_loss_grad(const float* logits, const int* targets, float* loss_out, float* dlogits, int R, int C) {\n    int row = blockIdx.x;\n    int tid = threadIdx.x;\n    if (row >= R || tid >= C) return;\n    extern __shared__ float sdata[];\n    float v = logits[row * C + tid];\n    sdata[tid] = v;\n    __syncthreads();\n    // max reduction\n    for (int s = blockDim.x >> 1; s > 0; s >>= 1) {\n        if (tid < s) {\n            float a = sdata[tid];\n            float b = sdata[tid + s];\n            sdata[tid] = a > b ? a : b;\n        }\n        __syncthreads();\n    }\n    float mx = sdata[0];\n    __syncthreads();\n    float e = expf(v - mx);\n    sdata[tid] = e;\n    __syncthreads();\n    for (int s = blockDim.x >> 1; s > 0; s >>= 1) {\n        if (tid < s) sdata[tid] += sdata[tid + s];\n        __syncthreads();\n    }\n    float sum = sdata[0];\n    float lse = mx + logf(sum);\n    int t = targets[row];\n    if (tid == 0) {\n        float row_loss = lse - logits[row * C + t];\n        atomicAdd(loss_out, row_loss / (float)R);\n    }\n    float prob = e / sum;\n    float onehot = (tid == t) ? 1.0f : 0.0f;\n    dlogits[row * C + tid] = (prob - onehot) / (float)R;\n}\n"

// ── Module + function handles ────────────────────────────────

let mut G_K_MODULE = ptr_null()

let mut G_K_embed_lookup     = ptr_null()
let mut G_K_rms_norm_fwd     = ptr_null()
let mut G_K_softmax_rows_fwd = ptr_null()
let mut G_K_swiglu_fwd       = ptr_null()
let mut G_K_add_inplace      = ptr_null()
let mut G_K_mul_scalar       = ptr_null()
let mut G_K_randn_fill       = ptr_null()
let mut G_K_embed_lookup_bwd = ptr_null()
let mut G_K_rms_norm_bwd     = ptr_null()
let mut G_K_softmax_rows_bwd = ptr_null()
let mut G_K_swiglu_bwd       = ptr_null()
let mut G_K_ce_loss_grad     = ptr_null()

// ── Init ─────────────────────────────────────────────────────

fn gpu_init_kernels() {
    // Ensure driver API context is bound (required for cuLaunchKernel later).
    // cudart primary context is created by cuda_init but not auto-current
    // for driver API. rtc_init handles both the fresh case and the existing-ctx case.
    let ri = rtc_init()
    if ri != 0 {
        println("[cuda_kernels] rtc_init failed: " + str(ri))
        return -4
    }
    // Concatenate every kernel into one translation unit so NVRTC
    // sees them in a single compile (~1 PTX, 12 entry points).
    let mut src = ""
    src = src + K_EMBED_LOOKUP
    src = src + K_RMS_NORM_FWD
    src = src + K_SOFTMAX_ROWS_FWD
    src = src + K_SWIGLU_FWD
    src = src + K_ADD_INPLACE
    src = src + K_MUL_SCALAR
    src = src + K_RANDN_FILL
    src = src + K_EMBED_LOOKUP_BWD
    src = src + K_RMS_NORM_BWD
    src = src + K_SOFTMAX_ROWS_BWD
    src = src + K_SWIGLU_BWD
    src = src + K_CE_LOSS_GRAD

    let ptx = rtc_compile_ptx(src, "clm_kernels.cu")
    if ptr_addr(ptx) == 0 {
        println("[cuda_kernels] rtc_compile_ptx failed")
        return -1
    }
    G_K_MODULE = rtc_load_module(ptx)
    if ptr_addr(G_K_MODULE) == 0 {
        println("[cuda_kernels] rtc_load_module failed")
        return -2
    }

    G_K_embed_lookup     = rtc_get_function(G_K_MODULE, "embed_lookup")
    G_K_rms_norm_fwd     = rtc_get_function(G_K_MODULE, "rms_norm_fwd")
    G_K_softmax_rows_fwd = rtc_get_function(G_K_MODULE, "softmax_rows_fwd")
    G_K_swiglu_fwd       = rtc_get_function(G_K_MODULE, "swiglu_fwd")
    G_K_add_inplace      = rtc_get_function(G_K_MODULE, "add_inplace")
    G_K_mul_scalar       = rtc_get_function(G_K_MODULE, "mul_scalar")
    G_K_randn_fill       = rtc_get_function(G_K_MODULE, "randn_fill")
    G_K_embed_lookup_bwd = rtc_get_function(G_K_MODULE, "embed_lookup_bwd")
    G_K_rms_norm_bwd     = rtc_get_function(G_K_MODULE, "rms_norm_bwd")
    G_K_softmax_rows_bwd = rtc_get_function(G_K_MODULE, "softmax_rows_bwd")
    G_K_swiglu_bwd       = rtc_get_function(G_K_MODULE, "swiglu_bwd")
    G_K_ce_loss_grad     = rtc_get_function(G_K_MODULE, "ce_loss_grad")

    if ptr_addr(G_K_embed_lookup)     == 0 { println("[cuda_kernels] missing embed_lookup");     return -3 }
    if ptr_addr(G_K_rms_norm_fwd)     == 0 { println("[cuda_kernels] missing rms_norm_fwd");     return -3 }
    if ptr_addr(G_K_softmax_rows_fwd) == 0 { println("[cuda_kernels] missing softmax_rows_fwd"); return -3 }
    if ptr_addr(G_K_swiglu_fwd)       == 0 { println("[cuda_kernels] missing swiglu_fwd");       return -3 }
    if ptr_addr(G_K_add_inplace)      == 0 { println("[cuda_kernels] missing add_inplace");      return -3 }
    if ptr_addr(G_K_mul_scalar)       == 0 { println("[cuda_kernels] missing mul_scalar");       return -3 }
    if ptr_addr(G_K_randn_fill)       == 0 { println("[cuda_kernels] missing randn_fill");       return -3 }
    if ptr_addr(G_K_embed_lookup_bwd) == 0 { println("[cuda_kernels] missing embed_lookup_bwd"); return -3 }
    if ptr_addr(G_K_rms_norm_bwd)     == 0 { println("[cuda_kernels] missing rms_norm_bwd");     return -3 }
    if ptr_addr(G_K_softmax_rows_bwd) == 0 { println("[cuda_kernels] missing softmax_rows_bwd"); return -3 }
    if ptr_addr(G_K_swiglu_bwd)       == 0 { println("[cuda_kernels] missing swiglu_bwd");       return -3 }
    if ptr_addr(G_K_ce_loss_grad)     == 0 { println("[cuda_kernels] missing ce_loss_grad");     return -3 }

    println("[cuda_kernels] gpu_init_kernels OK — 12 entry points resolved")
    0
}

// ── Internal arg-buffer helpers ──────────────────────────────
//
// CUDA driver API expects an args array of `void**` where each
// slot is a pointer to the actual argument. For pointer args we
// store the dev_ptr int into a host i64 cell. For scalar args we
// store the f32/i32/i64 value. The hexa array we hand to
// rtc_launch holds those host pointers; rtc_launch is responsible
// for translating it into the cuLaunchKernel layout.

// Always alloc 8 bytes to avoid glibc small-chunk heap fragility.
// Extra 4 bytes for i32/f32 are harmless padding — cuLaunchKernel
// reads via *(T*)params[i] which only touches the first sizeof(T).
fn _arg_ptr(dev) {
    let buf = alloc_raw(8)
    write_i64(buf, 0, 0)
    write_i64(buf, 0, ptr_addr(dev))
    buf
}

fn _arg_i32(v) {
    let buf = alloc_raw(8)
    write_i64(buf, 0, 0)
    write_i32(buf, 0, v)
    buf
}

fn _arg_i64(v) {
    let buf = alloc_raw(8)
    write_i64(buf, 0, v)
    buf
}

fn _arg_f32(v) {
    let buf = alloc_raw(8)
    write_i64(buf, 0, 0)
    write_f32(buf, 0, v)
    buf
}

fn _free_args(args) {
    let n = len(args)
    let mut i = 0
    while i < n {
        // We allocated 8 for ptr/i64 and 4 for i32/f32. alloc_raw
        // tracks size internally for free_raw, so the second arg
        // is best-effort; pass 8 (max) to satisfy any size check.
        free_raw(args[i], 8)
        i = i + 1
    }
    0
}

fn _ceil_div(a, b) {
    (a + b - 1) / b
}

// ── Forward launchers ────────────────────────────────────────

// gpu_embed_lookup_fwd: out[N,D] = W[toks[i],:]
// Block (16,16,1), grid (ceil(N/16), ceil(D/16), 1)
fn gpu_embed_lookup_fwd(W_dev, toks_dev, out_dev, V, D, N) {
    let args = [
        _arg_ptr(W_dev),
        _arg_ptr(toks_dev),
        _arg_ptr(out_dev),
        _arg_i32(V),
        _arg_i32(D),
        _arg_i32(N)
    ]
    let gx = _ceil_div(N, 16)
    let gy = _ceil_div(D, 16)
    let st = rtc_launch(G_K_embed_lookup, gx, gy, 1, 16, 16, 1, args)
    let _ = _free_args(args)
    st
}

// gpu_rms_norm_fwd: per-row RMS norm. one block per row, blockDim.x = D.
// Shared mem = D * 4 bytes (handled inside rtc_launch via convention,
// or rtc_launch can be told via the 8th-arg signature; we keep the
// existing rtc_launch signature and rely on it allocating dynamic
// shared memory equal to blockDim.x * 4 when the function uses
// `extern __shared__`. If your rtc_launch needs an explicit shmem
// arg, extend it; this file follows the documented 7-dim signature.)
fn gpu_rms_norm_fwd(x_dev, g_dev, out_dev, rstd_dev, N, D, eps) {
    let args = [
        _arg_ptr(x_dev),
        _arg_ptr(g_dev),
        _arg_ptr(out_dev),
        _arg_ptr(rstd_dev),
        _arg_i32(N),
        _arg_i32(D),
        _arg_f32(eps)
    ]
    // shmem = D * 4 bytes for the extern __shared__ float sdata[] reduction
    let st = rtc_launch_shmem(G_K_rms_norm_fwd, N, 1, 1, D, 1, 1, D * 4, args)
    let _ = _free_args(args)
    st
}

// gpu_softmax_rows_fwd: per-row softmax with optional causal mask.
// One block per row, blockDim.x = C.
fn gpu_softmax_rows_fwd(x_dev, out_dev, R, C, causal_int) {
    let args = [
        _arg_ptr(x_dev),
        _arg_ptr(out_dev),
        _arg_i32(R),
        _arg_i32(C),
        _arg_i32(causal_int)
    ]
    // shmem = C * 4 bytes for max/sum reduction
    let st = rtc_launch_shmem(G_K_softmax_rows_fwd, R, 1, 1, C, 1, 1, C * 4, args)
    let _ = _free_args(args)
    st
}

// gpu_swiglu_fwd: out[i] = up[i] * sigmoid(gate[i])
fn gpu_swiglu_fwd(up_dev, gate_dev, out_dev, N) {
    let args = [
        _arg_ptr(up_dev),
        _arg_ptr(gate_dev),
        _arg_ptr(out_dev),
        _arg_i32(N)
    ]
    let bx = 256
    let gx = _ceil_div(N, bx)
    let st = rtc_launch(G_K_swiglu_fwd, gx, 1, 1, bx, 1, 1, args)
    let _ = _free_args(args)
    st
}

// gpu_add_inplace: a[i] += b[i]   (residual stream add)
fn gpu_add_inplace(a_dev, b_dev, N) {
    let args = [
        _arg_ptr(a_dev),
        _arg_ptr(b_dev),
        _arg_i32(N)
    ]
    let bx = 256
    let gx = _ceil_div(N, bx)
    let st = rtc_launch(G_K_add_inplace, gx, 1, 1, bx, 1, 1, args)
    let _ = _free_args(args)
    st
}

// gpu_mul_scalar: out[i] = a[i] * s
fn gpu_mul_scalar(a_dev, s, out_dev, N) {
    let args = [
        _arg_ptr(a_dev),
        _arg_f32(s),
        _arg_ptr(out_dev),
        _arg_i32(N)
    ]
    let bx = 256
    let gx = _ceil_div(N, bx)
    let st = rtc_launch(G_K_mul_scalar, gx, 1, 1, bx, 1, 1, args)
    let _ = _free_args(args)
    st
}

// gpu_randn_fill: Box-Muller normal(0, scale). Deterministic per (seed, i).
fn gpu_randn_fill(buf_dev, N, seed, scale) {
    let args = [
        _arg_ptr(buf_dev),
        _arg_i32(N),
        _arg_i64(seed),
        _arg_f32(scale)
    ]
    let bx = 256
    let gx = _ceil_div(N, bx)
    let st = rtc_launch(G_K_randn_fill, gx, 1, 1, bx, 1, 1, args)
    let _ = _free_args(args)
    st
}

// ── Backward launchers ───────────────────────────────────────

// gpu_embed_lookup_bwd: scatter dy into dW via atomicAdd.
fn gpu_embed_lookup_bwd(dy_dev, toks_dev, dW_dev, V, D, N) {
    let args = [
        _arg_ptr(dy_dev),
        _arg_ptr(toks_dev),
        _arg_ptr(dW_dev),
        _arg_i32(V),
        _arg_i32(D),
        _arg_i32(N)
    ]
    let gx = _ceil_div(N, 16)
    let gy = _ceil_div(D, 16)
    let st = rtc_launch(G_K_embed_lookup_bwd, gx, gy, 1, 16, 16, 1, args)
    let _ = _free_args(args)
    st
}

// gpu_rms_norm_bwd: per-row gradient. dg_partial is [N,D]; the
// caller is responsible for reducing rows -> [D] (e.g. sum-rows
// kernel or cuBLAS gemv against an all-ones vector). This avoids
// the need for atomics on dg in this kernel.
fn gpu_rms_norm_bwd(x_dev, g_dev, dy_dev, rstd_dev, dx_dev, dg_partial_dev, N, D, eps) {
    let args = [
        _arg_ptr(x_dev),
        _arg_ptr(g_dev),
        _arg_ptr(dy_dev),
        _arg_ptr(rstd_dev),
        _arg_ptr(dx_dev),
        _arg_ptr(dg_partial_dev),
        _arg_i32(N),
        _arg_i32(D),
        _arg_f32(eps)
    ]
    // shmem: D * 4 for reduction of sum(x*g*dy)
    let st = rtc_launch_shmem(G_K_rms_norm_bwd, N, 1, 1, D, 1, 1, D * 4, args)
    let _ = _free_args(args)
    st
}

// gpu_softmax_rows_bwd: ds[r,c] = probs[r,c] * (dp[r,c] - sum(probs*dp))
fn gpu_softmax_rows_bwd(probs_dev, dp_dev, ds_dev, R, C) {
    let args = [
        _arg_ptr(probs_dev),
        _arg_ptr(dp_dev),
        _arg_ptr(ds_dev),
        _arg_i32(R),
        _arg_i32(C)
    ]
    // shmem: C * 4 for sum(probs*dp) reduction
    let st = rtc_launch_shmem(G_K_softmax_rows_bwd, R, 1, 1, C, 1, 1, C * 4, args)
    let _ = _free_args(args)
    st
}

// gpu_swiglu_bwd: dup = dy*sigma; dgate = dy*up*sigma*(1-sigma)
fn gpu_swiglu_bwd(up_dev, gate_dev, dy_dev, dup_dev, dgate_dev, N) {
    let args = [
        _arg_ptr(up_dev),
        _arg_ptr(gate_dev),
        _arg_ptr(dy_dev),
        _arg_ptr(dup_dev),
        _arg_ptr(dgate_dev),
        _arg_i32(N)
    ]
    let bx = 256
    let gx = _ceil_div(N, bx)
    let st = rtc_launch(G_K_swiglu_bwd, gx, 1, 1, bx, 1, 1, args)
    let _ = _free_args(args)
    st
}

// gpu_ce_loss_grad: fused log_softmax + NLL + gradient.
//   loss is averaged over rows (matches train_byte_kr.hexa).
//   loss_out must be a device-side f32 zeroed by the caller before
//   the call (we atomicAdd into it).
//   Returns the scalar loss as a hexa float (D2H copy of loss_out).
fn gpu_ce_loss_grad(logits_dev, targets_dev, loss_out_dev, dlogits_dev, R, C) {
    // zero loss_out so the kernel atomicAdds start from 0
    let _ = cuda_memset_zero(loss_out_dev, 4)

    let args = [
        _arg_ptr(logits_dev),
        _arg_ptr(targets_dev),
        _arg_ptr(loss_out_dev),
        _arg_ptr(dlogits_dev),
        _arg_i32(R),
        _arg_i32(C)
    ]
    // shmem: C * 4 for logsumexp max/sum reduction
    let st = rtc_launch_shmem(G_K_ce_loss_grad, R, 1, 1, C, 1, 1, C * 4, args)
    let _ = _free_args(args)
    if st != 0 {
        println("[cuda_kernels] ce_loss_grad launch failed: " + str(st))
        return 0.0
    }

    // Sync and pull the scalar back
    let _ = cuda_sync()
    let host_buf = alloc_raw(4)
    write_f32(host_buf, 0, 0.0)
    let _ = cuda_memcpy_d2h(host_buf, loss_out_dev, 4)
    let loss = deref_f32(host_buf, 0)
    free_raw(host_buf, 4)
    loss
}

println("[cuda_kernels] module loaded — 12 kernels ready for NVRTC compile")
