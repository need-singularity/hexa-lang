// ═══════════════════════════════════════════════════════════════════
//  self/ml/speculative_decode.hexa — @speculative_decode prototype
//
//  AI-native inference: draft model generates k tokens ahead, target
//  model verifies in parallel; accept longest matching prefix.
//
//  Mock models are deterministic hash functions over the context tail
//  so tests are reproducible. The attr @speculative_decode is parser-
//  accepted; the verify+accept loop is implemented explicitly below.
//
//  API (pure):
//    ctx_hash(ctx)                      -> int
//    draft_model(ctx)                   -> int  (next token)
//    target_model(ctx)                  -> int  (next token)
//    draft_generate(ctx, k)             -> [int]
//    target_verify(ctx, drafted)        -> [int]
//    accept_prefix(drafted, verified)   -> int
//    @speculative_decode
//    speculative_step(ctx, k, max_tokens) -> [out, drafted, accepted]
// ═══════════════════════════════════════════════════════════════════

// 16 = 16 (inlined — module-level lets aren't visible across import)

// ── context hash (XOR of tail, window=4) ───────────────────────
fn ctx_hash(ctx) {
    let n = len(ctx)
    let start = if n < 4 { 0 } else { n - 4 }
    let mut h = 2654435761
    let mut i = start
    while i < n {
        h = h ^ ((ctx[i] + 1) * (i + 7) * 1315423911)
        i = i + 1
    }
    h
}

// ── mock draft model: fast, biased ─────────────────────────────
fn draft_model(ctx) {
    let h = ctx_hash(ctx)
    let v = h % 16
    if v < 0 { v + 16 } else { v }
}

// ── mock target model: agrees with draft most of the time ──────
// We make target = draft when hash%5 != 0, else a different token.
// This yields a deterministic ~80% per-position agreement ratio.
fn target_model(ctx) {
    let h = ctx_hash(ctx)
    let d = draft_model(ctx)
    if (h % 5) == 0 {
        (d + 1) % 16
    } else {
        d
    }
}

// ── draft generates k tokens autoregressively ──────────────────
fn draft_generate(ctx, k) {
    let mut local = []
    let mut i = 0
    while i < len(ctx) {
        local = local + [ctx[i]]
        i = i + 1
    }
    let mut out = []
    let mut j = 0
    while j < k {
        let t = draft_model(local)
        out = out + [t]
        local = local + [t]
        j = j + 1
    }
    out
}

// ── target verifies: at each position, what would target output
//    given the original ctx + drafted[0..i] ?
fn target_verify(ctx, drafted) {
    let mut local = []
    let mut i = 0
    while i < len(ctx) {
        local = local + [ctx[i]]
        i = i + 1
    }
    let mut out = []
    let mut j = 0
    while j < len(drafted) {
        let t = target_model(local)
        out = out + [t]
        local = local + [drafted[j]]
        j = j + 1
    }
    out
}

// ── accept longest matching prefix ─────────────────────────────
fn accept_prefix(drafted, verified) {
    let n = len(drafted)
    let mut i = 0
    while i < n {
        if drafted[i] != verified[i] {
            return i
        }
        i = i + 1
    }
    n
}

// ── @speculative_decode: draft → verify → commit loop ──────────
@speculative_decode
fn speculative_step(ctx, k, max_tokens) {
    let mut cur = []
    let mut i = 0
    while i < len(ctx) {
        cur = cur + [ctx[i]]
        i = i + 1
    }
    let mut produced = 0
    let mut total_drafted = 0
    let mut total_accepted = 0

    while produced < max_tokens {
        let remain = max_tokens - produced
        let kk = if k < remain { k } else { remain }
        let drafted = draft_generate(cur, kk)
        let verified = target_verify(cur, drafted)
        let n_acc = accept_prefix(drafted, verified)
        // Commit accepted prefix
        let mut j = 0
        while j < n_acc {
            cur = cur + [drafted[j]]
            j = j + 1
        }
        // If nothing accepted, force one token from target to progress
        if n_acc == 0 {
            cur = cur + [verified[0]]
            produced = produced + 1
        } else {
            produced = produced + n_acc
        }
        total_drafted = total_drafted + kk
        total_accepted = total_accepted + n_acc
    }

    // Extract the newly produced tail (exclude original ctx)
    let mut out = []
    let start = len(ctx)
    let mut m = start
    while m < len(cur) {
        out = out + [cur[m]]
        m = m + 1
    }
    [out, [total_drafted], [total_accepted]]
}

// ═══════════════════════════════════════════════════════════════════
//  Adaptive speculative decoding — acceptance-rate-based k adjustment
//
//  Core idea: if acceptance rate is high (>= 80%), increase draft
//  length k to amortize verify overhead. If low (< 50%), shrink k
//  to reduce wasted draft computation. This yields ~3x throughput
//  over fixed-k when agreement varies across the sequence.
//
//  API:
//    adaptive_k(current_k, accepted, drafted, k_min, k_max) -> int
//    speculative_step_adaptive(ctx, k_init, max_tokens, k_min, k_max) -> [out, drafted, accepted, final_k]
// ═══════════════════════════════════════════════════════════════════

// ── adaptive k adjustment ─────────────────────────────────────────
// Returns a new k based on acceptance rate of the last iteration.
//   rate >= 80% → k+2 (up to k_max)
//   rate >= 50% → k (stay)
//   rate <  50% → k-1 (down to k_min)
fn adaptive_k(current_k, accepted, drafted, k_min, k_max) {
    if drafted == 0 { return current_k }
    let rate_pct = (accepted * 100) / drafted
    let mut new_k = current_k
    if rate_pct >= 80 {
        new_k = current_k + 2
    } else if rate_pct < 50 {
        new_k = current_k - 1
    }
    // Clamp to [k_min, k_max]
    if new_k < k_min { new_k = k_min }
    if new_k > k_max { new_k = k_max }
    return new_k
}

// ── adaptive speculative decode loop ──────────────────────────────
// Same draft→verify→commit loop as speculative_step, but k is
// adjusted each iteration based on recent acceptance rate.
@speculative_decode
fn speculative_step_adaptive(ctx, k_init, max_tokens, k_min, k_max) {
    let mut cur = []
    let mut i = 0
    while i < len(ctx) {
        cur = cur + [ctx[i]]
        i = i + 1
    }
    let mut produced = 0
    let mut total_drafted = 0
    let mut total_accepted = 0
    let mut current_k = k_init

    while produced < max_tokens {
        let remain = max_tokens - produced
        let kk = if current_k < remain { current_k } else { remain }
        let drafted = draft_generate(cur, kk)
        let verified = target_verify(cur, drafted)
        let n_acc = accept_prefix(drafted, verified)
        // Commit accepted prefix
        let mut j = 0
        while j < n_acc {
            cur = cur + [drafted[j]]
            j = j + 1
        }
        // If nothing accepted, force one token from target
        if n_acc == 0 {
            cur = cur + [verified[0]]
            produced = produced + 1
        } else {
            produced = produced + n_acc
        }
        total_drafted = total_drafted + kk
        total_accepted = total_accepted + n_acc
        // Adjust k for next iteration
        current_k = adaptive_k(current_k, n_acc, kk, k_min, k_max)
    }

    // Extract the newly produced tail
    let mut out = []
    let start = len(ctx)
    let mut m = start
    while m < len(cur) {
        out = out + [cur[m]]
        m = m + 1
    }
    [out, [total_drafted], [total_accepted], [current_k]]
}

// ── acceptance rate calculator ────────────────────────────────────
fn acceptance_rate(accepted, drafted) {
    if drafted == 0 { return 0 }
    return (accepted * 100) / drafted
}

// ── batch speculative decode ──────────────────────────────────────
// Run speculative decoding on multiple independent sequences in parallel.
// Returns an array of results, one per input context.
fn speculative_batch(contexts, k, max_tokens) {
    let mut results = []
    let mut ci = 0
    while ci < len(contexts) {
        let r = speculative_step(contexts[ci], k, max_tokens)
        results = results + [r]
        ci = ci + 1
    }
    results
}
