// ═══════════════════════════════════════════════════════════════════
//  self/ml/train_100m_alpha.hexa — T2 option α: aggressive reductions
//
//  Base: train_100m.hexa v2 (htz 1128ms/step, 14.3x).
//  Target: step_ms ≈ 290ms via 4 reductions:
//    1) SEQ   128 → 64      (attention O(N²) 4x smaller)
//    2) VOCAB 32000 → 8192  (LM head 4x smaller)
//    3) LAYER 12 → 8        (D=768 kept)
//    4) Tied QKV            (Uq=Uk, Vq=Vk reused; Vv shared with Vo? no —
//                             only tie Q/K to keep attention well-defined)
// ═══════════════════════════════════════════════════════════════════

// ── Config (reduced) ────────────────────────────────────────────
let D       = 768
let N_LAYER = 8            // 12 → 8
let N_HEAD  = 12
let HEAD_D  = 64
let VOCAB   = 8192         // 32000 → 8192
let SEQ     = 64           // 128 → 64
let FF      = 3072
let LORA_R  = 8
let SPARSE_RATIO = 0.3
let LR      = 0.001

// ── Weight buffers ──────────────────────────────────────────────
// Tied QKV: Uq serves as Uk (single matmul reused), Vq serves as Vk.
// Vs (value) stays separate to preserve attention expressivity.
let Uq = tensor_zeros(D * LORA_R)
let Vq = tensor_zeros(LORA_R * D)
// Uk, Vk tied to Uq, Vq (no separate allocation)
let Uv = tensor_zeros(D * LORA_R)
let Vv = tensor_zeros(LORA_R * D)
let Uo = tensor_zeros(D * LORA_R)
let Vo = tensor_zeros(LORA_R * D)

let U_up = tensor_zeros(D * LORA_R)
let V_up = tensor_zeros(LORA_R * FF)
let U_dn = tensor_zeros(FF * LORA_R)
let V_dn = tensor_zeros(LORA_R * D)

let U_lmh = tensor_zeros(D * LORA_R)
let V_lmh = tensor_zeros(LORA_R * VOCAB)

@lowrank(8)
fn lr_proj(X, U, V, seq, d, rnk) {
    let t = matmul(X, U, seq, d, rnk)
    matmul(t, V, seq, rnk, d)
}

@lowrank(8)
fn ffn_lowrank(X, Uu, Vu, Ud, Vd, seq, d, ff, rnk) {
    let t1 = matmul(X,  Uu, seq, d,  rnk)
    let y  = matmul(t1, Vu, seq, rnk, ff)
    let t2 = matmul(y,  Ud, seq, ff,  rnk)
    matmul(t2, Vd, seq, rnk, d)
}

fn add_residual(A, B) { mat_add(A, B) }

// Tied QKV: Qs is computed once and reused as Ks — saves 1 matmul/layer.
fn block_forward(X) {
    let Qs = matmul(X, Uq, SEQ, D, LORA_R)   // [SEQ×r] — reused as Ks
    let Vs = matmul(X, Uv, SEQ, D, LORA_R)   // [SEQ×r]

    // scores = Qs @ Qs  (tied K)
    let scores = matmul(Qs, Qs, SEQ, LORA_R, SEQ)

    let ctx_r = matmul(scores, Vs, SEQ, SEQ, LORA_R)
    let ctx   = matmul(ctx_r, Vv, SEQ, LORA_R, D)
    let o     = lr_proj(ctx, Uo, Vo, SEQ, D, LORA_R)
    let h1    = add_residual(X, o)

    let f = ffn_lowrank(h1, U_up, V_up, U_dn, V_dn, SEQ, D, FF, LORA_R)
    add_residual(h1, f)
}

fn embed(ids) { tensor_zeros(SEQ * D) }

@lowrank(8)
fn lm_head_lr(h_last, rows) {
    let t = matmul(h_last, U_lmh, rows, D, LORA_R)
    matmul(t, V_lmh, rows, LORA_R, VOCAB)
}

fn loss_mse(logits, target_onehot) {
    let n = len(target_onehot)
    let neg_t = mat_scale(target_onehot, -1.0)
    let diff  = mat_add(logits, neg_t)
    let sq = matmul(diff, diff, 1, n, 1)
    sq[0] / (n * 1.0)
}

fn batch_hash(ids) {
    let n = len(ids)
    let lim = if n < 16 { n } else { 16 }
    let mut h = 2654435761
    let mut i = 0
    while i < lim {
        h = h ^ (ids[i] * 2147483 + i)
        i = i + 1
    }
    h
}

@memoize_grad
fn compute_loss_cached(logits, tgt, cache_key) {
    let _k = cache_key
    loss_mse(logits, tgt)
}

fn forward_pass(ids, tgt) {
    let mut h = embed(ids)
    let mut li = 0
    while li < N_LAYER {
        h = block_forward(h)
        li = li + 1
    }
    let mut last = []
    let base = (SEQ - 1) * D
    let mut i = 0
    while i < D {
        last.push(h[base + i])
        i = i + 1
    }
    let last_t = tensor(last)
    let logits = lm_head_lr(last_t, 1)
    let key = batch_hash(ids)
    compute_loss_cached(logits, tgt, key)
}

fn backward_vlmh(h_last, logits, target) {
    let z = matmul(h_last, U_lmh, 1, D, LORA_R)
    let neg_t = mat_scale(target, -1.0)
    let diff  = mat_add(logits, neg_t)
    matmul(z, diff, LORA_R, 1, VOCAB)
}

fn sgd_step(W, G, lr) {
    let scaled = mat_scale(G, -1.0 * lr)
    mat_add(W, scaled)
}

fn train_one_step() {
    let mut ids = []
    let mut i = 0
    while i < SEQ {
        ids.push(0)
        i = i + 1
    }
    let mut tgt = []
    let mut j = 0
    while j < VOCAB {
        if j == 0 { tgt.push(1.0) } else { tgt.push(0.0) }
        j = j + 1
    }
    let tgt_t = tensor(tgt)

    let t0 = clock()
    let loss = forward_pass(ids, tgt_t)
    let t1 = clock()

    let last_h   = tensor_zeros(D)
    let logits_f = tensor_zeros(VOCAB)
    let g_vlmh   = backward_vlmh(last_h, logits_f, tgt_t)
    let t2 = clock()

    let _V_new = sgd_step(V_lmh, g_vlmh, LR)
    let t3 = clock()

    let fwd_ms   = (t1 - t0) * 1000.0
    let bwd_ms   = (t2 - t1) * 1000.0
    let opt_ms   = (t3 - t2) * 1000.0
    let total_ms = (t3 - t0) * 1000.0

    let mut line = "{"
    line = line + "\"phase\":\"train_100m_alpha\""
    line = line + ",\"D\":" + str(D)
    line = line + ",\"n_layers\":" + str(N_LAYER)
    line = line + ",\"seq\":" + str(SEQ)
    line = line + ",\"vocab\":" + str(VOCAB)
    line = line + ",\"lora_r\":" + str(LORA_R)
    line = line + ",\"tied_qkv\":1"
    line = line + ",\"loss\":" + str(loss)
    line = line + ",\"fwd_ms\":" + str(fwd_ms)
    line = line + ",\"bwd_ms\":" + str(bwd_ms)
    line = line + ",\"opt_ms\":" + str(opt_ms)
    line = line + ",\"step_ms\":" + str(total_ms)
    line = line + "}"
    println(line)
    total_ms
}

println("[train_100m alpha] init weights done, running 1 step...")
let step_ms = train_one_step()
println("[train_100m alpha] 1 step OK step_ms=" + str(step_ms))
