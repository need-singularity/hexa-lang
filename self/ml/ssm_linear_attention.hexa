// ===================================================================
//  self/ml/ssm_linear_attention.hexa
//  Pure Hexa linear-time State Space Model attention (Mamba-style)
//
//  O(N) sequence processing via recurrent SSM scan:
//    h_new = A * h + B * x
//    y     = C * h_new + D * x
//
//  Components:
//    1. ssm_new          — create SSM with diagonal A, B, C, D
//    2. ssm_step         — single recurrent step
//    3. ssm_scan         — process full sequence O(N)
//    4. selective_scan   — Mamba-style input-dependent discretization
//    5. vec_mul / vec_add / vec_scale — elementwise helpers
//
//  AI-NATIVE attrs:
//    @pure     — deterministic
//    @hot      — called per forward step
// ===================================================================

// ===================================================================
//  Helpers
// ===================================================================

@pure @hot
fn vec_mul(a, b) {
    let n = len(a)
    let mut out = []
    for i in 0..n {
        out.push(a[i] * b[i])
    }
    return out
}

@pure @hot
fn vec_add(a, b) {
    let n = len(a)
    let mut out = []
    for i in 0..n {
        out.push(a[i] + b[i])
    }
    return out
}

@pure @hot
fn vec_scale(a, s) {
    let n = len(a)
    let mut out = []
    for i in 0..n {
        out.push(a[i] * s)
    }
    return out
}

// Approximate exp via Taylor series (pure, no FFI)
// Uses range reduction: exp(x) = exp(r) * 2^k where r = x - k*ln2
@pure
fn ssm_exp(x) {
    // clamp to avoid overflow / underflow
    let mut v = x
    if v > 80.0 { v = 80.0 }
    if v < -80.0 { return 0.0 }

    let ln2 = 0.6931471805599453
    // range reduce: x = k*ln2 + r, |r| <= ln2/2
    let k_f = v / ln2
    let mut k = 0
    if k_f >= 0.0 {
        k = to_int(k_f + 0.5)
    } else {
        k = to_int(k_f - 0.5)
    }
    let r = v - to_float(k) * ln2

    // Taylor series for exp(r), 13 terms for ~1e-15 precision
    let mut term = 1.0
    let mut sum = 1.0
    for i in 1..14 {
        term = term * r / to_float(i)
        sum = sum + term
    }

    // multiply by 2^k
    let mut pow2 = 1.0
    if k >= 0 {
        for _i in 0..k { pow2 = pow2 * 2.0 }
    } else {
        let neg_k = 0 - k
        for _i in 0..neg_k { pow2 = pow2 * 0.5 }
    }
    return sum * pow2
}

// ===================================================================
//  1. ssm_new — create SSM parameters
//
//  A: diagonal state transition (d_state), initialized to small negatives
//  B: input projection (d_state x d_model)
//  C: output projection (d_model x d_state)
//  D: skip connection (d_model), initialized to ones
// ===================================================================

@pure
fn ssm_new(d_model, d_state) {
    // A: diagonal, negative values for stability (HiPPO-inspired)
    let mut a_diag = []
    for i in 0..d_state {
        a_diag.push(0.0 - to_float(i + 1) * 0.1)
    }

    // B: (d_state x d_model) pseudo-random init
    let mut b_mat = []
    for i in 0..d_state {
        let mut row = []
        for j in 0..d_model {
            let h = (i * 137 + j * 311 + 42) % 10007
            let val = (to_float(h) / 10007.0 - 0.5) * 0.2
            row.push(val)
        }
        b_mat.push(row)
    }

    // C: (d_model x d_state) pseudo-random init
    let mut c_mat = []
    for i in 0..d_model {
        let mut row = []
        for j in 0..d_state {
            let h = (i * 251 + j * 173 + 77) % 10007
            let val = (to_float(h) / 10007.0 - 0.5) * 0.2
            row.push(val)
        }
        c_mat.push(row)
    }

    // D: skip, ones
    let mut d_vec = []
    for _i in 0..d_model {
        d_vec.push(1.0)
    }

    return #{
        "d_model": d_model,
        "d_state": d_state,
        "A": a_diag,
        "B": b_mat,
        "C": c_mat,
        "D": d_vec
    }
}

// ===================================================================
//  2. ssm_step — one recurrent step
//
//  h_new[n] = A[n] * h[n] + sum_j B[n][j] * x[j]
//  y[m]     = sum_n C[m][n] * h_new[n] + D[m] * x[m]
//
//  Returns: {"output": [float], "new_state": [float]}
// ===================================================================

@pure @hot
fn ssm_step(ssm, x, state) {
    let d_state = ssm["d_state"]
    let d_model = ssm["d_model"]
    let a_diag = ssm["A"]
    let b_mat = ssm["B"]
    let c_mat = ssm["C"]
    let d_vec = ssm["D"]

    // h_new = A * h + B * x
    let mut h_new = []
    for n in 0..d_state {
        let mut bx = 0.0
        for j in 0..d_model {
            bx = bx + b_mat[n][j] * x[j]
        }
        h_new.push(a_diag[n] * state[n] + bx)
    }

    // y = C * h_new + D * x
    let mut y = []
    for m in 0..d_model {
        let mut ch = 0.0
        for n in 0..d_state {
            ch = ch + c_mat[m][n] * h_new[n]
        }
        y.push(ch + d_vec[m] * x[m])
    }

    return #{
        "output": y,
        "new_state": h_new
    }
}

// ===================================================================
//  3. ssm_scan — process full sequence, O(N) time
//
//  Iterates ssm_step over the input sequence, carrying state forward.
// ===================================================================

@pure
fn ssm_scan(ssm, inputs) {
    let seq_len = len(inputs)
    let d_state = ssm["d_state"]

    // initial state = zeros
    let mut state = []
    for _i in 0..d_state {
        state.push(0.0)
    }

    let mut outputs = []
    for t in 0..seq_len {
        let result = ssm_step(ssm, inputs[t], state)
        state = result["new_state"]
        outputs.push(result["output"])
    }
    return outputs
}

// ===================================================================
//  4. selective_scan — Mamba-style input-dependent discretization
//
//  For each timestep t:
//    A_bar[n] = exp(A[n] * dt[t])
//    B_bar[n][j] = B[n][j] * dt[t]
//    h_new[n] = A_bar[n] * h[n] + sum_j B_bar[n][j] * x[j]
//    y[m] = sum_n C[m][n] * h_new[n] + D[m] * x[m]
//
//  dt: per-timestep discretization step [seq_len]
// ===================================================================

@pure
fn selective_scan(ssm, inputs, dt) {
    let seq_len = len(inputs)
    let d_state = ssm["d_state"]
    let d_model = ssm["d_model"]
    let a_diag = ssm["A"]
    let b_mat = ssm["B"]
    let c_mat = ssm["C"]
    let d_vec = ssm["D"]

    // initial state = zeros
    let mut state = []
    for _i in 0..d_state {
        state.push(0.0)
    }

    let mut outputs = []
    for t in 0..seq_len {
        let dt_t = dt[t]
        let x = inputs[t]

        // Discretize: A_bar = exp(A * dt), B_bar = B * dt
        let mut h_new = []
        for n in 0..d_state {
            let a_bar = ssm_exp(a_diag[n] * dt_t)
            let mut bx = 0.0
            for j in 0..d_model {
                bx = bx + b_mat[n][j] * dt_t * x[j]
            }
            h_new.push(a_bar * state[n] + bx)
        }

        // y = C * h_new + D * x
        let mut y = []
        for m in 0..d_model {
            let mut ch = 0.0
            for n in 0..d_state {
                ch = ch + c_mat[m][n] * h_new[n]
            }
            y.push(ch + d_vec[m] * x[m])
        }

        state = h_new
        outputs.push(y)
    }
    return outputs
}

println("[ssm_linear_attention] loaded — ssm_new / ssm_step / ssm_scan / selective_scan")
