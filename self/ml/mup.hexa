// ===================================================================
//  self/ml/mup.hexa — muP (Maximal Update Parametrization)
//
//  Implements hyperparameter transfer from small proxy models
//  to large target models (Yang et al., 2022).
//
//  Key insight: with standard parametrization (SP), optimal HPs
//  change with model width. muP fixes this so HPs transfer across
//  widths by adjusting init scale, learning rate, and output logits.
//
//  Public API:
//    mup_config(base_width, target_width)
//    mup_width_mult(cfg)
//    mup_init_std(fan_in, cfg, layer_type)
//    mup_lr_scale(base_lr, cfg, layer_type)
//    mup_output_scale(cfg)
//    mup_embed_scale(cfg)
//    mup_linear_create(in_dim, out_dim, cfg, layer_type)
//    mup_linear_forward(layer, x)
//    mup_coord_check(widths, forward_fn, input)
//    mup_proxy_to_target(proxy_hps, proxy_width, target_width)
//
//  Layer types: "embed", "hidden", "output"
//
//  AI-NATIVE attrs:
//    @pure  — no side effects
//    @hot   — performance-critical forward path
// ===================================================================

// ===================================================================
//  Math helpers (self-contained, no imports)
// ===================================================================

fn mup_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn mup_sqrt(x) {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    for _i in 0..40 {
        g = (g + x / g) / 2.0
    }
    return g
}

fn mup_log(x) {
    if x <= 0.0 { return -100.0 }
    // ln via series expansion around 1: ln(x) = 2 * sum((t^(2k+1))/(2k+1))
    // where t = (x-1)/(x+1)
    let mut v = x
    let mut shift = 0.0
    // normalize to [0.5, 2.0] range
    while v > 2.0 {
        v = v / 2.718281828
        shift = shift + 1.0
    }
    while v < 0.5 {
        v = v * 2.718281828
        shift = shift - 1.0
    }
    let t = (v - 1.0) / (v + 1.0)
    let t2 = t * t
    let mut term = t
    let mut result = t
    for k in 1..30 {
        term = term * t2
        result = result + term / to_float(2 * k + 1)
    }
    return 2.0 * result + shift
}

fn mup_zeros(n) {
    let mut v = []
    for _i in 0..n { v = v + [0.0] }
    return v
}

fn mup_ones(n) {
    let mut v = []
    for _i in 0..n { v = v + [1.0] }
    return v
}

fn mup_vec_scale(v, s) {
    let n = len(v)
    let mut out = []
    for i in 0..n { out = out + [v[i] * s] }
    return out
}

fn mup_vec_add(a, b) {
    let n = len(a)
    let mut out = []
    for i in 0..n { out = out + [a[i] + b[i]] }
    return out
}

fn mup_dot(a, b) {
    let n = len(a)
    let mut s = 0.0
    for i in 0..n { s = s + a[i] * b[i] }
    return s
}

fn mup_vec_max_abs(v) {
    let n = len(v)
    let mut mx = 0.0
    for i in 0..n {
        let a = mup_abs(v[i])
        if a > mx { mx = a }
    }
    return mx
}

fn mup_vec_mean(v) {
    let n = len(v)
    if n == 0 { return 0.0 }
    let mut s = 0.0
    for i in 0..n { s = s + v[i] }
    return s / to_float(n)
}

fn mup_vec_var(v) {
    let n = len(v)
    if n < 2 { return 0.0 }
    let m = mup_vec_mean(v)
    let mut s = 0.0
    for i in 0..n {
        let d = v[i] - m
        s = s + d * d
    }
    return s / to_float(n)
}

// Simple PRNG: linear congruential
fn mup_prng(seed) {
    let mut s = seed * 1103515245 + 12345
    s = s % 2147483647
    if s < 0 { s = 0 - s }
    return s
}

// Generate normal-ish sample via Box-Muller approximation
// Returns [sample, next_seed]
fn mup_randn(seed) {
    let s1 = mup_prng(seed)
    let s2 = mup_prng(s1)
    let u1 = to_float(s1 % 10000) / 10000.0 + 0.0001
    let u2 = to_float(s2 % 10000) / 10000.0
    let pi = 3.141592653589793
    let r = mup_sqrt(-2.0 * mup_log(u1))
    // cos approximation
    let angle = 2.0 * pi * u2
    let mut cos_val = 1.0 - angle * angle / 2.0 + angle * angle * angle * angle / 24.0
    if mup_abs(angle) > 1.5 {
        // Taylor around pi
        let d = angle - pi
        cos_val = -1.0 + d * d / 2.0
    }
    let sample = r * cos_val
    return [sample, s2]
}

// Generate n normal samples, return [samples_array, next_seed]
fn mup_randn_vec(n, seed) {
    let mut out = []
    let mut s = seed
    for _i in 0..n {
        let result = mup_randn(s)
        out = out + [result[0]]
        s = to_int(result[1])
    }
    return [out, s]
}

// ===================================================================
//  muP Configuration
//
//  base_width:   width of the proxy (small) model
//  target_width: width of the target (large) model
//  width_mult:   target_width / base_width
//
//  Returns a map: #{"base_width": ..., "target_width": ..., "width_mult": ...}
// ===================================================================
@pure
fn mup_config(base_width, target_width) {
    let mult = to_float(target_width) / to_float(base_width)
    return #{
        "base_width": base_width,
        "target_width": target_width,
        "width_mult": mult
    }
}

// ===================================================================
//  Width Multiplier — m = target_width / base_width
// ===================================================================
@pure
fn mup_width_mult(cfg) {
    return cfg["width_mult"]
}

// ===================================================================
//  muP Initialization Scaling
//
//  Standard init: N(0, 1/sqrt(fan_in))
//  muP adjustments by layer type:
//    embed:  1/sqrt(fan_in)           (same as SP)
//    hidden: 1/sqrt(fan_in)           (same as SP, but LR is adjusted)
//    output: 1/(sqrt(fan_in) * m)     (scaled down by 1/width_mult)
//
//  Returns: standard deviation for initialization
// ===================================================================
@pure
fn mup_init_std(fan_in, cfg, layer_type) {
    let base_std = 1.0 / mup_sqrt(to_float(fan_in))
    let m = cfg["width_mult"]
    if layer_type == "output" {
        return base_std / m
    }
    // embed and hidden: same as SP
    return base_std
}

// ===================================================================
//  muP Learning Rate Scaling
//
//  Standard: same LR for all layers
//  muP adjustments:
//    embed:  base_lr                (1x, no change)
//    hidden: base_lr / m            (scaled by 1/width_mult)
//    output: base_lr / m            (scaled by 1/width_mult)
//
//  This ensures updates in feature space are O(1) regardless of width.
// ===================================================================
@pure
fn mup_lr_scale(base_lr, cfg, layer_type) {
    let m = cfg["width_mult"]
    if layer_type == "embed" {
        return base_lr
    }
    // hidden and output: scale down by width multiplier
    return base_lr / m
}

// ===================================================================
//  Output Layer Scaling
//
//  Logits must be scaled by 1/m to keep output distribution stable.
//  output_scale = 1.0 / width_mult
// ===================================================================
@pure
fn mup_output_scale(cfg) {
    let m = cfg["width_mult"]
    return 1.0 / m
}

// ===================================================================
//  Embedding Scaling
//
//  Under muP, embedding vectors are scaled by 1.0 (no change from SP).
//  Some variants scale by sqrt(width_mult) for the embedding output,
//  but the canonical muP keeps embed at 1.0 scale.
//  We return alpha = 1.0 (standard) for embed layer.
// ===================================================================
@pure
fn mup_embed_scale(cfg) {
    return 1.0
}

// ===================================================================
//  muP-aware Linear Layer
//
//  Wraps weight matrix with muP init and forward scaling.
//
//  layer = #{
//    "in_dim": int, "out_dim": int,
//    "weights": [[float]], (out_dim x in_dim)
//    "bias": [float],      (out_dim)
//    "layer_type": string, ("embed" | "hidden" | "output")
//    "output_mult": float, (1.0 for embed/hidden, 1/m for output)
//    "lr_mult": float,     (per-layer LR multiplier)
//    "init_std": float
//  }
// ===================================================================

// Initialize weight matrix with scaled normal distribution
fn mup_init_weights(out_dim, in_dim, std_dev, seed) {
    let mut weights = []
    let mut s = seed
    for _r in 0..out_dim {
        let result = mup_randn_vec(in_dim, s)
        let row_raw = result[0]
        s = to_int(result[1])
        let row = mup_vec_scale(row_raw, std_dev)
        weights = weights + [row]
    }
    return [weights, s]
}

fn mup_linear_create(in_dim, out_dim, cfg, layer_type) {
    let init_std = mup_init_std(in_dim, cfg, layer_type)
    let lr_mult_val = mup_lr_scale(1.0, cfg, layer_type)
    let mut out_mult = 1.0
    if layer_type == "output" {
        out_mult = mup_output_scale(cfg)
    }
    let w_result = mup_init_weights(out_dim, in_dim, init_std, 42)
    let weights = w_result[0]
    let bias = mup_zeros(out_dim)
    return #{
        "in_dim": in_dim,
        "out_dim": out_dim,
        "weights": weights,
        "bias": bias,
        "layer_type": layer_type,
        "output_mult": out_mult,
        "lr_mult": lr_mult_val,
        "init_std": init_std
    }
}

// Forward: y = (W @ x + b) * output_mult
@hot
fn mup_linear_forward(layer, x) {
    let out_dim = layer["out_dim"]
    let weights = layer["weights"]
    let bias = layer["bias"]
    let out_mult = layer["output_mult"]
    let mut out = []
    for r in 0..out_dim {
        let val = mup_dot(weights[r], x) + bias[r]
        out = out + [val * out_mult]
    }
    return out
}

// ===================================================================
//  Coord Check — verify activations scale correctly across widths
//
//  Core muP invariant: for a properly parametrized model,
//  activation magnitudes should be O(1) regardless of width.
//
//  coord_check runs a forward pass at multiple widths and returns
//  per-width activation statistics.
//
//  widths: [int] list of widths to check
//  base_width: the reference width for muP config
//  input_dim: dimension of input
//  seed: random seed
//
//  Returns: array of #{"width": w, "act_mean": m, "act_var": v, "act_max": mx}
// ===================================================================
@pure
fn mup_coord_check(widths, base_width, input_dim, seed) {
    let mut results = []
    let mut s = seed
    for wi in 0..len(widths) {
        let w = widths[wi]
        let cfg = mup_config(base_width, w)
        // Create a simple 2-layer net: input -> hidden(w) -> output(1)
        let hidden_layer = mup_linear_create(input_dim, w, cfg, "hidden")
        let output_layer = mup_linear_create(w, 1, cfg, "output")
        // Generate random input
        let inp_result = mup_randn_vec(input_dim, s)
        let inp = inp_result[0]
        s = to_int(inp_result[1])
        // Forward through hidden layer
        let h = mup_linear_forward(hidden_layer, inp)
        // ReLU
        let mut h_relu = []
        for j in 0..len(h) {
            if h[j] > 0.0 {
                h_relu = h_relu + [h[j]]
            } else {
                h_relu = h_relu + [0.0]
            }
        }
        // Collect hidden activation stats
        let act_mean = mup_vec_mean(h_relu)
        let act_var = mup_vec_var(h_relu)
        let act_max = mup_vec_max_abs(h_relu)
        results = results + [#{
            "width": w,
            "act_mean": act_mean,
            "act_var": act_var,
            "act_max": act_max
        }]
    }
    return results
}

// ===================================================================
//  Coord Check Validation — check that activation stats are stable
//
//  Under muP, act_var should remain O(1) across widths.
//  Returns: true if max/min variance ratio < threshold
// ===================================================================
@pure
fn mup_coord_check_pass(results, ratio_threshold) {
    let n = len(results)
    if n < 2 { return true }
    let mut min_var = results[0]["act_var"]
    let mut max_var = results[0]["act_var"]
    for i in 1..n {
        let v = results[i]["act_var"]
        if v < min_var { min_var = v }
        if v > max_var { max_var = v }
    }
    if min_var < 0.0001 { return true }
    let ratio = max_var / min_var
    return ratio < ratio_threshold
}

// ===================================================================
//  Proxy-to-Target HP Transfer
//
//  Given HPs optimized on a small proxy model, transfer them to a
//  large target model using muP scaling rules.
//
//  proxy_hps: #{"lr": float, "init_std": float, ...}
//  proxy_width: int
//  target_width: int
//
//  Returns: #{"lr_embed": ..., "lr_hidden": ..., "lr_output": ...,
//             "init_std_hidden": ..., "init_std_output": ...,
//             "output_logit_scale": ..., "width_mult": ...}
// ===================================================================
@pure
fn mup_proxy_to_target(proxy_hps, proxy_width, target_width) {
    let m = to_float(target_width) / to_float(proxy_width)
    let base_lr = proxy_hps["lr"]
    let base_init = proxy_hps["init_std"]
    return #{
        "lr_embed": base_lr,
        "lr_hidden": base_lr / m,
        "lr_output": base_lr / m,
        "init_std_hidden": base_init,
        "init_std_output": base_init / m,
        "output_logit_scale": 1.0 / m,
        "width_mult": m
    }
}

// ===================================================================
//  muP Model — full model with embed, hidden layers, output
//
//  A simple feed-forward model with muP parametrization.
//  model = #{
//    "embed": linear,   (vocab_size -> width)
//    "hiddens": [linear], (width -> width)
//    "output": linear,  (width -> vocab_size)
//    "cfg": mup_config,
//    "embed_scale": float
//  }
// ===================================================================
fn mup_model_create(vocab_size, width, n_hidden, base_width, seed) {
    let cfg = mup_config(base_width, width)
    let embed = mup_linear_create(vocab_size, width, cfg, "embed")
    let mut hiddens = []
    let mut s = seed + 1000
    for _l in 0..n_hidden {
        let h = mup_linear_create(width, width, cfg, "hidden")
        hiddens = hiddens + [h]
        s = s + 100
    }
    let output = mup_linear_create(width, vocab_size, cfg, "output")
    return #{
        "embed": embed,
        "hiddens": hiddens,
        "output": output,
        "cfg": cfg,
        "embed_scale": mup_embed_scale(cfg)
    }
}

// Forward pass through muP model
// x: one-hot or embedding index (we use a dense vector here)
@hot
fn mup_model_forward(model, x) {
    let embed_scale = model["embed_scale"]
    // Embedding layer
    let mut h = mup_linear_forward(model["embed"], x)
    h = mup_vec_scale(h, embed_scale)
    // Hidden layers with ReLU
    let hiddens = model["hiddens"]
    for li in 0..len(hiddens) {
        let raw = mup_linear_forward(hiddens[li], h)
        let mut activated = []
        for j in 0..len(raw) {
            if raw[j] > 0.0 {
                activated = activated + [raw[j]]
            } else {
                activated = activated + [0.0]
            }
        }
        h = activated
    }
    // Output layer (already has output_mult = 1/m built in)
    let logits = mup_linear_forward(model["output"], h)
    return logits
}

// ===================================================================
//  Per-layer LR extraction
//
//  Given a model, return the LR multipliers for each layer group.
// ===================================================================
@pure
fn mup_get_lr_schedule(model) {
    let embed_lr = model["embed"]["lr_mult"]
    let output_lr = model["output"]["lr_mult"]
    let hiddens = model["hiddens"]
    let mut hidden_lrs = []
    for i in 0..len(hiddens) {
        hidden_lrs = hidden_lrs + [hiddens[i]["lr_mult"]]
    }
    return #{
        "embed_lr": embed_lr,
        "hidden_lrs": hidden_lrs,
        "output_lr": output_lr
    }
}

// ===================================================================
//  muP Scaling Verification
//
//  Verify a set of muP scaling factors are internally consistent.
//  Returns: true if all invariants hold
// ===================================================================
@pure
fn mup_verify_scaling(cfg) {
    let m = cfg["width_mult"]
    let bw = cfg["base_width"]
    let tw = cfg["target_width"]
    // Check: width_mult = target / base
    let expected_m = to_float(tw) / to_float(bw)
    if mup_abs(m - expected_m) > 0.001 { return false }
    // Check: m >= 1.0 (target >= base)
    if m < 0.999 { return false }
    return true
}

// ===================================================================
//  Batch LR Scaling
//
//  Given a list of param groups with layer_types,
//  compute per-group scaled LR.
//
//  param_groups: [#{"name": str, "layer_type": str}]
//  base_lr: float
//  cfg: mup_config
//
//  Returns: [#{"name": str, "lr": float}]
// ===================================================================
@pure
fn mup_batch_lr(param_groups, base_lr, cfg) {
    let n = len(param_groups)
    let mut out = []
    for i in 0..n {
        let pg = param_groups[i]
        let scaled = mup_lr_scale(base_lr, cfg, pg["layer_type"])
        out = out + [#{"name": pg["name"], "lr": scaled}]
    }
    return out
}

// ===================================================================
//  Batch Init Std
//
//  Given param groups with fan_in and layer_type, compute init stds.
// ===================================================================
@pure
fn mup_batch_init(param_groups, cfg) {
    let n = len(param_groups)
    let mut out = []
    for i in 0..n {
        let pg = param_groups[i]
        let std_val = mup_init_std(pg["fan_in"], cfg, pg["layer_type"])
        out = out + [#{"name": pg["name"], "init_std": std_val}]
    }
    return out
}

println("[mup] loaded — maximal update parametrization for HP transfer")
