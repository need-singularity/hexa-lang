// ═══════════════════════════════════════════════════════════════
//  pipeline_test.hexa — End-to-end CPU pipeline tests
//
//  Tests the device→pipeline→infer chain on CPU only.
//  GPU tests require actual CUDA hardware.
//
//  Run: hexa self/ml/pipeline_test.hexa
// ═══════════════════════════════════════════════════════════════

use "device"
use "pipeline"

// ── Test 1: Device detection ─────────────────────────────────
@test
fn test_device_cpu_select() {
    let dev = select_device("cpu")
    assert(is_cpu(dev))
    assert(dev.kind == 0)
    assert(dev.name == "cpu")
    println("[test] device CPU select: PASS")
}

@test
fn test_device_auto_select() {
    let dev = select_device("auto")
    // On machines without GPU, should fall back to CPU
    // On machines with GPU, should select GPU
    // Either way, kind must be DEV_CPU or DEV_GPU
    let valid = is_cpu(dev) || is_gpu(dev)
    assert(valid)
    println("[test] device auto select: PASS (" + device_str(dev) + ")")
}

@test
fn test_device_str() {
    let cpu = device_cpu()
    assert(device_str(cpu) == "CPU")
    println("[test] device_str: PASS")
}

// ── Test 2: Pipeline config creation ─────────────────────────
@test
fn test_pipeline_config_defaults() {
    let cfg = pipeline_config_small("cpu")
    assert(cfg.dim == 64)
    assert(cfg.layers == 2)
    assert(cfg.ff == 128)
    assert(cfg.vocab == 256)
    assert(cfg.seq == 16)
    assert(is_cpu(cfg.device))
    println("[test] pipeline config defaults: PASS")
}

@test
fn test_pipeline_config_custom() {
    let cfg = pipeline_config("cpu", "model.bin", "ckpt.bin", 1.0e-3, 5, 1, 16, 0.7)
    assert(cfg.lr == 1.0e-3)
    assert(cfg.epochs == 5)
    assert(cfg.max_tokens == 16)
    assert(cfg.temperature == 0.7)
    println("[test] pipeline config custom: PASS")
}

// ── Test 3: Model initialization ─────────────────────────────
@test
fn test_model_init_small() {
    let cfg = pipeline_config_small("cpu")
    let model = pipeline_init_model(cfg)
    // Expected params: vocab*dim + (dd*4 + df*2 + fd) * layers
    // = 256*64 + (4096*4 + 8192*2 + 8192) * 2
    // = 16384 + (16384 + 16384 + 8192) * 2
    // = 16384 + 40960*2 = 16384 + 81920 = 98304
    assert(model.n_params > 0)
    assert(is_cpu(model.device))
    println("[test] model init small: PASS (" + str(model.n_params) + " params)")
}

// ── Test 4: CPU forward pass ─────────────────────────────────
@test
fn test_cpu_forward_runs() {
    let cfg = pipeline_config_small("cpu")
    let model = pipeline_init_model(cfg)

    // Dummy tokens
    let tokens = [0, 1, 2, 3]
    let t0 = clock()
    let h = _cpu_forward(model, tokens)
    let t1 = clock()
    let ms = (t1 - t0) * 1000.0

    // Output should be seq*dim = 4*64 = 256 elements
    assert(len(h) == 4 * 64)
    println("[test] CPU forward: PASS (" + str(ms) + " ms)")
}

// ── Test 5: CPU loss computation ─────────────────────────────
@test
fn test_cpu_loss_finite() {
    let cfg = pipeline_config_small("cpu")
    let model = pipeline_init_model(cfg)
    let tokens = [0, 1, 2, 3]
    let h = _cpu_forward(model, tokens)
    let loss = _cpu_loss(h, model)
    // Loss should be a finite positive number
    assert(loss >= 0.0)
    assert(loss < 1.0e10)
    println("[test] CPU loss: PASS (loss=" + str(loss) + ")")
}

// ── Test 6: CPU training loop ────────────────────────────────
@test
fn test_cpu_train_small() {
    let dev = select_device("cpu")
    let cfg = PipelineConfig {
        device: dev, model_path: "", checkpoint_path: "",
        lr: 3.0e-4, epochs: 3, batch_size: 1, max_tokens: 32,
        temperature: 0.0, dim: 64, heads: 4, layers: 2,
        ff: 128, vocab: 256, seq: 16
    }
    let model = pipeline_init_model(cfg)
    let t0 = clock()
    pipeline_train(model, cfg)
    let t1 = clock()
    let ms = (t1 - t0) * 1000.0
    println("[test] CPU train 3 steps: PASS (" + str(ms) + " ms)")
}

// ── Test 7: Inference end-to-end ─────────────────────────────
@test
fn test_cpu_infer_e2e() {
    let dev = select_device("cpu")
    let cfg = PipelineConfig {
        device: dev, model_path: "", checkpoint_path: "",
        lr: 3.0e-4, epochs: 10, batch_size: 1, max_tokens: 2,
        temperature: 0.0, dim: 64, heads: 4, layers: 2,
        ff: 128, vocab: 256, seq: 16
    }
    let model = pipeline_init_model(cfg)
    let t0 = clock()
    let tokens = pipeline_infer(model, "Hi", cfg)
    let t1 = clock()
    let ms = (t1 - t0) * 1000.0
    assert(len(tokens) == 2)
    println("[test] CPU infer e2e: PASS (" + str(ms) + " ms, " + str(len(tokens)) + " tokens)")
}

// ── Test 8: Train then infer (full pipeline) ─────────────────
@test
fn test_train_then_infer() {
    let dev = select_device("cpu")
    let cfg = PipelineConfig {
        device: dev, model_path: "", checkpoint_path: "",
        lr: 3.0e-4, epochs: 2, batch_size: 1, max_tokens: 1,
        temperature: 0.0, dim: 64, heads: 4, layers: 2,
        ff: 128, vocab: 256, seq: 16
    }
    let model = pipeline_init_model(cfg)

    // Train
    pipeline_train(model, cfg)

    // Infer with trained model
    let tokens = pipeline_infer(model, "A", cfg)
    assert(len(tokens) == 1)

    // Token should be a valid vocab index
    assert(tokens[0] >= 0)
    assert(tokens[0] < 256)
    println("[test] train-then-infer: PASS")
}

// ── Test 9: Device fallback ──────────────────────────────────
@test
fn test_gpu_fallback_to_cpu() {
    // On machines without GPU, requesting "gpu" should fall back to CPU
    let dev = select_device("gpu")
    // Should not crash — either GPU or CPU
    let valid = is_cpu(dev) || is_gpu(dev)
    assert(valid)
    println("[test] GPU fallback: PASS (got " + device_str(dev) + ")")
}

// ── Run all tests ────────────────────────────────────────────
let _ = test_device_cpu_select()
let _ = test_device_auto_select()
let _ = test_device_str()
let _ = test_pipeline_config_defaults()
let _ = test_pipeline_config_custom()
let _ = test_model_init_small()
let _ = test_cpu_forward_runs()
let _ = test_cpu_loss_finite()
let _ = test_cpu_train_small()
let _ = test_cpu_infer_e2e()
let _ = test_train_then_infer()
let _ = test_gpu_fallback_to_cpu()

println("")
println("============================================================")
println("  pipeline_test.hexa — all 12 tests passed")
println("============================================================")
