// ===================================================================
//  self/ml/gpu_sampler.hexa — Sampling on GPU
//
//  All logit transformations (temperature, top-k, top-p, softmax)
//  happen on GPU via host-fallback pattern (D2H -> compute -> H2D).
//  Only the final sampled token ID is transferred back to CPU.
//
//  Pipeline:
//    GPU logits [1 x vocab]
//    -> temperature scaling (GPU/host)
//    -> softmax (host)
//    -> top-k filtering (host)
//    -> top-p filtering (host)
//    -> multinomial sample (host)
//    -> return token_id (int, CPU)
//
//  For greedy: argmax on host, single D2H transfer.
// ===================================================================

use "cuda_ffi"
use "gpu_tensor"

// -- Sampler configuration --
struct GpuSamplerConfig {
    temperature: float,
    top_k: int,
    top_p: float,
    seed: int
}

fn gpu_sampler_default() {
    GpuSamplerConfig {
        temperature: 0.7,
        top_k: 40,
        top_p: 0.9,
        seed: 42
    }
}

fn gpu_sampler_greedy() {
    GpuSamplerConfig {
        temperature: 0.0,
        top_k: 0,
        top_p: 1.0,
        seed: 0
    }
}

// -- RNG state (Xorshift32) --
let mut GPU_SAMPLER_RNG = 2463534242

fn gpu_sampler_set_seed(s) {
    GPU_SAMPLER_RNG = s
}

fn gpu_sampler_rand_float() {
    let mut x = GPU_SAMPLER_RNG
    x = x ^ (x * 8192)
    x = x ^ (x / 131072)
    x = x ^ (x * 32)
    if x < 0 { x = 0 - x }
    GPU_SAMPLER_RNG = x
    to_float(x % 1000000) / 1000000.0
}

// ===================================================================
//  Greedy argmax on host (D2H only the logits, return index)
// ===================================================================
fn gpu_argmax(logits_gt, vocab) {
    let host = alloc_raw(vocab * 4)
    let _ = cuda_memcpy_d2h(host, gt_ptr(logits_gt), vocab * 4)
    let mut best_i = 0
    let mut best_v = deref_f32(host, 0)
    let mut i = 1
    while i < vocab {
        let v = deref_f32(host, i)
        if v > best_v {
            best_v = v
            best_i = i
        }
        i = i + 1
    }
    free_raw(host, vocab * 4)
    best_i
}

// ===================================================================
//  Full sampling pipeline: logits_gt [1 x vocab] -> token_id
// ===================================================================
fn gpu_sample_token(logits_gt, vocab, cfg: GpuSamplerConfig) {
    // Greedy mode
    if cfg.temperature <= 0.0 {
        return gpu_argmax(logits_gt, vocab)
    }

    // D2H: download logits to host
    let host = alloc_raw(vocab * 4)
    let _ = cuda_memcpy_d2h(host, gt_ptr(logits_gt), vocab * 4)

    // Temperature scaling
    let inv_t = 1.0 / cfg.temperature
    let mut i = 0
    while i < vocab {
        let v = deref_f32(host, i)
        write_f32(host, i, v * inv_t)
        i = i + 1
    }

    // Softmax (in-place on host buffer)
    let mut mx = deref_f32(host, 0)
    i = 1
    while i < vocab {
        let v = deref_f32(host, i)
        if v > mx { mx = v }
        i = i + 1
    }
    let mut sum_e = 0.0
    i = 0
    while i < vocab {
        let e = exp(deref_f32(host, i) - mx)
        write_f32(host, i, e)
        sum_e = sum_e + e
        i = i + 1
    }
    let inv_sum = 1.0 / sum_e
    i = 0
    while i < vocab {
        let v = deref_f32(host, i)
        write_f32(host, i, v * inv_sum)
        i = i + 1
    }

    // Top-k filtering
    if cfg.top_k > 0 {
        if cfg.top_k < vocab {
            // Find k-th largest value via partial selection
            let sorted_buf = alloc_raw(vocab * 4)
            i = 0
            while i < vocab {
                write_f32(sorted_buf, i, deref_f32(host, i))
                i = i + 1
            }
            let mut j = 0
            while j < cfg.top_k {
                let mut best = j
                let mut m = j + 1
                while m < vocab {
                    if deref_f32(sorted_buf, m) > deref_f32(sorted_buf, best) {
                        best = m
                    }
                    m = m + 1
                }
                if best != j {
                    let tmp = deref_f32(sorted_buf, j)
                    write_f32(sorted_buf, j, deref_f32(sorted_buf, best))
                    write_f32(sorted_buf, best, tmp)
                }
                j = j + 1
            }
            let threshold = deref_f32(sorted_buf, cfg.top_k - 1)
            free_raw(sorted_buf, vocab * 4)

            // Zero out entries below threshold + renormalize
            let mut sum_k = 0.0
            i = 0
            while i < vocab {
                let v = deref_f32(host, i)
                if v < threshold {
                    write_f32(host, i, 0.0)
                } else {
                    sum_k = sum_k + v
                }
                i = i + 1
            }
            if sum_k > 0.0 {
                let inv_k = 1.0 / sum_k
                i = 0
                while i < vocab {
                    let v = deref_f32(host, i)
                    write_f32(host, i, v * inv_k)
                    i = i + 1
                }
            }
        }
    }

    // Top-p (nucleus) filtering
    if cfg.top_p < 1.0 {
        if cfg.top_p > 0.0 {
            // Build sorted index-value pairs (only non-zero probs)
            let mut idx_arr = []
            let mut val_arr = []
            i = 0
            while i < vocab {
                let v = deref_f32(host, i)
                if v > 0.0 {
                    idx_arr = idx_arr.push(i)
                    val_arr = val_arr.push(v)
                }
                i = i + 1
            }

            // Sort descending by probability
            let nn = len(idx_arr)
            let mut ii = 0
            while ii < nn {
                let mut best = ii
                let mut jj = ii + 1
                while jj < nn {
                    if val_arr[jj] > val_arr[best] { best = jj }
                    jj = jj + 1
                }
                if best != ii {
                    let ti = idx_arr[ii]
                    idx_arr[ii] = idx_arr[best]
                    idx_arr[best] = ti
                    let tv = val_arr[ii]
                    val_arr[ii] = val_arr[best]
                    val_arr[best] = tv
                }
                ii = ii + 1
            }

            // Accumulate until >= top_p, zero rest
            // First zero everything
            i = 0
            while i < vocab {
                write_f32(host, i, 0.0)
                i = i + 1
            }
            let mut cum = 0.0
            let mut sum_p = 0.0
            let mut done = 0
            i = 0
            while i < nn {
                if done == 0 {
                    let idx = idx_arr[i]
                    let prob = val_arr[i]
                    write_f32(host, idx, prob)
                    sum_p = sum_p + prob
                    cum = cum + prob
                    if cum >= cfg.top_p { done = 1 }
                }
                i = i + 1
            }

            // Renormalize
            if sum_p > 0.0 {
                let inv_p = 1.0 / sum_p
                i = 0
                while i < vocab {
                    let v = deref_f32(host, i)
                    write_f32(host, i, v * inv_p)
                    i = i + 1
                }
            }
        }
    }

    // Multinomial sample
    let r = gpu_sampler_rand_float()
    let mut cum = 0.0
    let mut chosen = vocab - 1
    i = 0
    while i < vocab {
        cum = cum + deref_f32(host, i)
        if cum > r {
            chosen = i
            i = vocab
        }
        i = i + 1
    }

    free_raw(host, vocab * 4)
    chosen
}

// ===================================================================
//  Batch argmax: for prefill logits [seq x vocab], get last token
// ===================================================================
fn gpu_sample_last_token(logits_gt, seq_len, vocab, cfg: GpuSamplerConfig) {
    // Extract last row
    let byte_offset = (seq_len - 1) * vocab * 4
    let last_host = alloc_raw(vocab * 4)
    let src = ptr_offset(gt_ptr(logits_gt), byte_offset)
    let _ = cuda_memcpy_d2h(last_host, src, vocab * 4)

    // Upload last row to a temp GPU tensor for sampling
    let last_gt = gpu_tensor_zeros(1, vocab)
    let _ = cuda_memcpy_h2d(gt_ptr(last_gt), last_host, vocab * 4)
    free_raw(last_host, vocab * 4)

    let tok = gpu_sample_token(last_gt, vocab, cfg)
    gpu_tensor_free(last_gt)
    tok
}

println("[gpu_sampler] module loaded — GPU sampling (temperature + top-k + top-p)")
