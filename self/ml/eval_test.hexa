// ===================================================================
//  self/ml/eval_test.hexa — Tests for eval metrics with known values
// ===================================================================

let mut PASS = 0
let mut FAIL = 0

fn check(label, condition) {
    if condition {
        PASS = PASS + 1
    } else {
        println("  FAIL: " + label)
        FAIL = FAIL + 1
    }
}

fn approx_eq(a: float, b: float, eps: float) -> bool {
    let diff = a - b
    if diff < 0.0 { return (0.0 - diff) < eps }
    return diff < eps
}

// ===================================================================
//  Test 1: Accuracy
// ===================================================================
println("--- Test 1: Accuracy ---")

let preds1 = [0, 1, 2, 0, 1]
let labels1 = [0, 1, 2, 0, 1]
check("perfect accuracy == 1.0", approx_eq(accuracy(preds1, labels1), 1.0, 0.001))

let preds2 = [0, 0, 0, 0, 0]
let labels2 = [0, 1, 2, 0, 1]
check("3/5 correct == 0.4", approx_eq(accuracy(preds2, labels2), 0.4, 0.001))

let preds3 = [1, 2, 0]
let labels3 = [0, 1, 2]
check("all wrong == 0.0", approx_eq(accuracy(preds3, labels3), 0.0, 0.001))

// ===================================================================
//  Test 2: Top-k Accuracy
// ===================================================================
println("--- Test 2: Top-k Accuracy ---")

// logits where true class has 2nd highest score
let logits_tk1 = [[5.0, 3.0, 1.0]]
let labels_tk1 = [0]
check("top1 correct (class 0 highest)", approx_eq(top_k_accuracy(logits_tk1, labels_tk1, 1, 3), 1.0, 0.001))

let logits_tk2 = [[1.0, 5.0, 3.0]]
let labels_tk2 = [2]
check("top1 miss, top2 hit", approx_eq(top_k_accuracy(logits_tk2, labels_tk2, 1, 3), 0.0, 0.001))
check("top2 finds class 2", approx_eq(top_k_accuracy(logits_tk2, labels_tk2, 2, 3), 1.0, 0.001))

// multiple samples
let logits_tk3 = [[5.0, 3.0, 1.0], [1.0, 5.0, 3.0]]
let labels_tk3 = [0, 2]
check("top1 = 0.5 (1/2 correct)", approx_eq(top_k_accuracy(logits_tk3, labels_tk3, 1, 3), 0.5, 0.001))
check("top2 = 1.0 (both in top2)", approx_eq(top_k_accuracy(logits_tk3, labels_tk3, 2, 3), 1.0, 0.001))

// ===================================================================
//  Test 3: Perplexity
// ===================================================================
println("--- Test 3: Perplexity ---")

// perfect prediction: logits strongly favor correct class -> PPL ~ 1.0
let logits_ppl1 = [[100.0, 0.0, 0.0], [0.0, 100.0, 0.0]]
let targets_ppl1 = [0, 1]
let ppl1 = perplexity(logits_ppl1, targets_ppl1, 3)
check("perfect logits -> ppl near 1.0", ppl1 < 1.01)

// uniform logits over 3 classes -> PPL = 3.0
let logits_ppl2 = [[0.0, 0.0, 0.0]]
let targets_ppl2 = [0]
let ppl2 = perplexity(logits_ppl2, targets_ppl2, 3)
check("uniform 3-class -> ppl near 3.0", approx_eq(ppl2, 3.0, 0.1))

// ===================================================================
//  Test 4: BLEU Score
// ===================================================================
println("--- Test 4: BLEU Score ---")

// identical sequences -> BLEU = 1.0
let bleu1 = bleu_score(["the", "cat", "sat", "on", "the", "mat"], ["the", "cat", "sat", "on", "the", "mat"])
check("identical -> bleu == 1.0", approx_eq(bleu1, 1.0, 0.001))

// completely different -> BLEU near 0
let bleu2 = bleu_score(["a", "b", "c", "d"], ["x", "y", "z", "w"])
check("no overlap -> bleu near 0", bleu2 < 0.01)

// partial overlap (1 token difference, BLEU-4 penalizes heavily due to 0 4-gram matches)
let bleu3 = bleu_score(["the", "cat", "is", "on", "the", "mat"], ["the", "cat", "sat", "on", "the", "mat"])
check("partial overlap -> bleu > 0", bleu3 > 0.0)
check("partial overlap -> bleu < 1", bleu3 < 1.0)

// high overlap test (longer, more n-gram matches)
let bleu5 = bleu_score(["the", "cat", "sat", "on", "the", "mat", "today"], ["the", "cat", "sat", "on", "the", "mat", "yesterday"])
check("high overlap -> bleu > 0.3", bleu5 > 0.3)

// empty hypothesis -> 0
let bleu4 = bleu_score([], ["a", "b", "c"])
check("empty hyp -> bleu == 0", approx_eq(bleu4, 0.0, 0.001))

// ===================================================================
//  Test 5: ROUGE-L Score
// ===================================================================
println("--- Test 5: ROUGE-L ---")

// identical
let rouge1 = rouge_l_score(["the", "cat", "sat"], ["the", "cat", "sat"])
check("identical -> rouge_l == 1.0", approx_eq(rouge1, 1.0, 0.001))

// no overlap
let rouge2 = rouge_l_score(["a", "b"], ["x", "y"])
check("no overlap -> rouge_l == 0", approx_eq(rouge2, 0.0, 0.001))

// partial: LCS = "the cat" (len 2)
let rouge3 = rouge_l_score(["the", "cat", "is"], ["the", "cat", "sat"])
// P = 2/3, R = 2/3, F1 = 2/3
check("LCS 2/3 -> rouge_l near 0.667", approx_eq(rouge3, 0.6667, 0.01))

// subsequence match
let rouge4 = rouge_l_score(["a", "x", "b", "y", "c"], ["a", "b", "c"])
// LCS = 3, P = 3/5, R = 3/3 = 1.0, F1 = 2*0.6*1/(0.6+1) = 0.75
check("subseq LCS=3 -> rouge_l near 0.75", approx_eq(rouge4, 0.75, 0.01))

// empty
let rouge5 = rouge_l_score([], ["a", "b"])
check("empty hyp -> rouge_l == 0", approx_eq(rouge5, 0.0, 0.001))

// ===================================================================
//  Test 6: F1 Score
// ===================================================================
println("--- Test 6: F1 Score ---")

// perfect classification
let f1_r1 = f1_score([0, 1, 2, 0, 1, 2], [0, 1, 2, 0, 1, 2], 3)
check("perfect -> micro_f1 == 1.0", approx_eq(f1_r1[0], 1.0, 0.001))
check("perfect -> macro_f1 == 1.0", approx_eq(f1_r1[1], 1.0, 0.001))

// all predicted as class 0: 2 correct out of 6
// class 0: TP=2 FP=4 FN=0 -> P=2/6 R=2/2=1 F1=2*(1/3*1)/(1/3+1)=0.5
// class 1: TP=0 FP=0 FN=2 -> F1=0
// class 2: TP=0 FP=0 FN=2 -> F1=0
// micro: TP=2 FP=4 FN=4, P=2/6 R=2/6 F1=2*(1/3)*(1/3)/(2/3)=1/3
let f1_r2 = f1_score([0, 0, 0, 0, 0, 0], [0, 1, 2, 0, 1, 2], 3)
check("all-0 pred -> micro_f1 near 0.333", approx_eq(f1_r2[0], 0.3333, 0.01))
check("all-0 pred -> macro_f1 near 0.167", approx_eq(f1_r2[1], 0.1667, 0.02))

// ===================================================================
//  Test 7: Confusion Matrix
// ===================================================================
println("--- Test 7: Confusion Matrix ---")

let cm1 = confusion_matrix([0, 1, 2, 0, 1, 2], [0, 1, 2, 0, 1, 2], 3)
// diagonal should be [2, 2, 2], off-diagonal 0
check("cm perfect: (0,0)=2", cm1[0 * 3 + 0] == 2)
check("cm perfect: (1,1)=2", cm1[1 * 3 + 1] == 2)
check("cm perfect: (2,2)=2", cm1[2 * 3 + 2] == 2)
check("cm perfect: (0,1)=0", cm1[0 * 3 + 1] == 0)
check("cm perfect: (1,0)=0", cm1[1 * 3 + 0] == 0)

let cm2 = confusion_matrix([0, 0, 0], [0, 1, 2], 3)
check("cm all-0: (0,0)=1", cm2[0 * 3 + 0] == 1)
check("cm all-0: (1,0)=1", cm2[1 * 3 + 0] == 1)
check("cm all-0: (2,0)=1", cm2[2 * 3 + 0] == 1)

// ===================================================================
//  Test 8: LCS helper
// ===================================================================
println("--- Test 8: LCS ---")

check("lcs identical", lcs_length(["a", "b", "c"], ["a", "b", "c"]) == 3)
check("lcs empty", lcs_length([], ["a", "b"]) == 0)
check("lcs subsequence", lcs_length(["a", "x", "b", "y", "c"], ["a", "b", "c"]) == 3)
check("lcs single match", lcs_length(["x", "a", "y"], ["b", "a", "c"]) == 1)
check("lcs no match", lcs_length(["a", "b"], ["x", "y"]) == 0)

// ===================================================================
//  Test 9: n-gram match helper
// ===================================================================
println("--- Test 9: N-gram matches ---")

let ng1 = count_ngram_matches(["a", "b", "c", "d"], ["a", "b", "c", "d"], 1)
check("unigram perfect match = 4", ng1 == 4)

let ng2 = count_ngram_matches(["a", "b", "c", "d"], ["a", "b", "c", "d"], 2)
check("bigram perfect match = 3", ng2 == 3)

let ng3 = count_ngram_matches(["a", "b", "c"], ["x", "y", "z"], 1)
check("unigram no match = 0", ng3 == 0)

// clipped count: hyp has "a a", ref has "a" -> only 1 match
let ng4 = count_ngram_matches(["a", "a"], ["a", "b"], 1)
check("clipped unigram = 1", ng4 == 1)

// ===================================================================
//  Summary
// ===================================================================
println("")
println("===================================================")
println("  eval_test: " + str(PASS) + " PASS, " + str(FAIL) + " FAIL")
println("===================================================")

if FAIL > 0 {
    println("SOME TESTS FAILED")
} else {
    println("ALL TESTS PASSED")
}
