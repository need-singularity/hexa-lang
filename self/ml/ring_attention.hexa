// ═══════════════════════════════════════════════════════════════════
//  self/ml/ring_attention.hexa — Ring Attention
//
//  Sequence partitioning + inter-device KV circulation (ring topology)
//  + blockwise attention computation + chunk result aggregation.
//
//  Enables arbitrarily long sequences by distributing chunks across
//  devices in a ring. Each device computes local attention, then
//  passes its KV to the next device in the ring.
//
//  API:
//    ra_zeros(n)                           -> [float]
//    ra_split_seq(seq, n_chunks)           -> [[float]]
//    ra_softmax(logits)                    -> [float]
//    ra_dot(a, b)                          -> float
//    ra_matmul(A, B, m, k, n)             -> [float]
//    ra_scale(v, s)                        -> [float]
//    ra_add(a, b)                          -> [float]
//    ra_causal_mask(q_start, q_len, k_start, k_len) -> [float]
//    ra_blockwise_attention(Q, K, V, d, q_start, k_start) -> [float]
//    ra_ring_step(kv_chunks, ring_size)    -> [[float]]
//    ra_ring_attention(seq, W_q, W_k, W_v, d, n_devices) -> [float]
//    ra_online_softmax_block(scores, values, d) -> [float, float, float]
//    ra_merge_blocks(blocks)               -> [float]
//
//  AI-NATIVE attrs:
//    @pure     — no side effects
//    @hot      — inner loop
// ═══════════════════════════════════════════════════════════════════

// ── helpers ──────────────────────────────────────────────────────

fn ra_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn ra_exp(x) {
    let mut v = x
    if v > 20.0 { v = 20.0 }
    if v < -20.0 { v = -20.0 }
    let mut result = 1.0
    let mut term = 1.0
    for i in 1..30 {
        term = term * v / to_float(i)
        result = result + term
    }
    if result < 0.0 { return 0.0 }
    return result
}

fn ra_sqrt(x) {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    for _i in 0..20 {
        g = (g + x / g) / 2.0
    }
    return g
}

fn ra_zeros(n) {
    let mut v = []
    for _i in 0..n { v = v + [0.0] }
    return v
}

fn ra_ones(n) {
    let mut v = []
    for _i in 0..n { v = v + [1.0] }
    return v
}

fn ra_hash(seed, i) {
    let h = ((seed * 2654435761 + i * 1315423911) % 10007)
    return to_float(h) / 10007.0 - 0.5
}

// ═══════════════════════════════════════════════════════════════════
//  Sequence splitting — divide flat sequence into n_chunks
// ═══════════════════════════════════════════════════════════════════
@pure
fn ra_split_seq(seq, n_chunks) {
    let total = len(seq)
    let chunk_size = total / n_chunks
    let mut chunks = []
    for c in 0..n_chunks {
        let start = c * chunk_size
        let mut end = start + chunk_size
        if c == n_chunks - 1 { end = total }
        let mut chunk = []
        for i in start..end {
            chunk = chunk + [seq[i]]
        }
        chunks = chunks + [chunk]
    }
    return chunks
}

// ═══════════════════════════════════════════════════════════════════
//  Vector operations
// ═══════════════════════════════════════════════════════════════════
@pure
fn ra_dot(a, b) {
    let n = len(a)
    let mut s = 0.0
    for i in 0..n { s = s + a[i] * b[i] }
    return s
}

@pure
fn ra_scale(v, s) {
    let n = len(v)
    let mut out = ra_zeros(n)
    for i in 0..n { out[i] = v[i] * s }
    return out
}

@pure
fn ra_add(a, b) {
    let n = len(a)
    let mut out = ra_zeros(n)
    for i in 0..n { out[i] = a[i] + b[i] }
    return out
}

// ═══════════════════════════════════════════════════════════════════
//  Matrix multiply: A[m,k] @ B[k,n] -> C[m,n]  (row-major flat)
// ═══════════════════════════════════════════════════════════════════
@pure
fn ra_matmul(A, B, m, k, n) {
    let mut C = ra_zeros(m * n)
    for i in 0..m {
        for j in 0..n {
            let mut s = 0.0
            for p in 0..k {
                s = s + A[i * k + p] * B[p * n + j]
            }
            C[i * n + j] = s
        }
    }
    return C
}

// ═══════════════════════════════════════════════════════════════════
//  Softmax (numerically stable)
// ═══════════════════════════════════════════════════════════════════
@pure
fn ra_softmax(logits) {
    let n = len(logits)
    let mut mx = logits[0]
    for i in 1..n {
        if logits[i] > mx { mx = logits[i] }
    }
    let mut exps = ra_zeros(n)
    let mut z = 0.0
    for i in 0..n {
        exps[i] = ra_exp(logits[i] - mx)
        z = z + exps[i]
    }
    let mut out = ra_zeros(n)
    for i in 0..n { out[i] = exps[i] / z }
    return out
}

// ═══════════════════════════════════════════════════════════════════
//  Causal mask — returns flat [q_len x k_len] mask
//  mask[i,j] = 1.0 if (q_start+i >= k_start+j) else -1e9
// ═══════════════════════════════════════════════════════════════════
@pure
fn ra_causal_mask(q_start, q_len, k_start, k_len) {
    let mut mask = ra_zeros(q_len * k_len)
    for i in 0..q_len {
        for j in 0..k_len {
            let q_pos = q_start + i
            let k_pos = k_start + j
            if q_pos >= k_pos {
                mask[i * k_len + j] = 0.0
            } else {
                mask[i * k_len + j] = -1000000000.0
            }
        }
    }
    return mask
}

// ═══════════════════════════════════════════════════════════════════
//  Blockwise attention: Q_block @ K_block^T -> scores -> softmax -> @ V_block
//
//  Q: [q_len x d], K: [k_len x d], V: [k_len x d]
//  Returns: [q_len x d] attention output
// ═══════════════════════════════════════════════════════════════════
@pure @hot
fn ra_blockwise_attention(Q, K, V, d, q_start, k_start) {
    let q_len = len(Q) / d
    let k_len = len(K) / d
    let scale = 1.0 / ra_sqrt(to_float(d))

    // scores = Q @ K^T  [q_len x k_len]
    let mut scores = ra_zeros(q_len * k_len)
    for i in 0..q_len {
        for j in 0..k_len {
            let mut s = 0.0
            for p in 0..d {
                s = s + Q[i * d + p] * K[j * d + p]
            }
            scores[i * k_len + j] = s * scale
        }
    }

    // Apply causal mask
    let mask = ra_causal_mask(q_start, q_len, k_start, k_len)
    for i in 0..(q_len * k_len) {
        scores[i] = scores[i] + mask[i]
    }

    // Row-wise softmax + weighted sum of V
    let mut out = ra_zeros(q_len * d)
    for i in 0..q_len {
        // extract row
        let mut row = ra_zeros(k_len)
        for j in 0..k_len { row[j] = scores[i * k_len + j] }
        let probs = ra_softmax(row)
        // weighted sum: out[i,:] = sum_j probs[j] * V[j,:]
        for p in 0..d {
            let mut s = 0.0
            for j in 0..k_len {
                s = s + probs[j] * V[j * d + p]
            }
            out[i * d + p] = s
        }
    }
    return out
}

// ═══════════════════════════════════════════════════════════════════
//  Ring step — rotate KV chunks around the ring
//  Each device i receives KV from device (i-1) mod ring_size
// ═══════════════════════════════════════════════════════════════════
@pure
fn ra_ring_step(kv_chunks, ring_size) {
    // Rotate: new[i] = old[(i-1+ring_size) % ring_size]
    let mut new_chunks = []
    for i in 0..ring_size {
        let src = (i - 1 + ring_size) % ring_size
        new_chunks = new_chunks + [kv_chunks[src]]
    }
    return new_chunks
}

// ═══════════════════════════════════════════════════════════════════
//  Linear projection: input[seq_len x d_in] @ W[d_in x d_out]
// ═══════════════════════════════════════════════════════════════════
@pure
fn ra_project(input, W, seq_len, d_in, d_out) {
    return ra_matmul(input, W, seq_len, d_in, d_out)
}

// ═══════════════════════════════════════════════════════════════════
//  Online softmax block statistics
//  Returns [sum_exp_values (d-dim), max_score, total_weight]
// ═══════════════════════════════════════════════════════════════════
@pure
fn ra_online_softmax_block(scores, values, d) {
    let k_len = len(scores)
    let mut mx = scores[0]
    for j in 1..k_len {
        if scores[j] > mx { mx = scores[j] }
    }
    let mut total_w = 0.0
    let mut weighted = ra_zeros(d)
    for j in 0..k_len {
        let w = ra_exp(scores[j] - mx)
        total_w = total_w + w
        for p in 0..d {
            weighted[p] = weighted[p] + w * values[j * d + p]
        }
    }
    return [weighted, [mx], [total_w]]
}

// ═══════════════════════════════════════════════════════════════════
//  Merge blocks — combine online softmax partial results
//  blocks: list of [weighted_sum, [max], [weight]]
// ═══════════════════════════════════════════════════════════════════
@pure
fn ra_merge_blocks(blocks, d) {
    let n = len(blocks)
    // Find global max
    let mut global_max = blocks[0][1][0]
    for i in 1..n {
        let bm = blocks[i][1][0]
        if bm > global_max { global_max = bm }
    }
    // Re-weight each block
    let mut merged = ra_zeros(d)
    let mut total = 0.0
    for i in 0..n {
        let bm = blocks[i][1][0]
        let bw = blocks[i][2][0]
        let correction = ra_exp(bm - global_max)
        let adj_w = bw * correction
        total = total + adj_w
        let weighted = blocks[i][0]
        for p in 0..d {
            merged[p] = merged[p] + weighted[p] * correction
        }
    }
    // Normalize
    if total > 0.0 {
        for p in 0..d { merged[p] = merged[p] / total }
    }
    return merged
}

// ═══════════════════════════════════════════════════════════════════
//  Ring Attention — full pipeline
//
//  1. Split sequence into n_devices chunks
//  2. Project Q, K, V for each chunk
//  3. Ring-rotate KV n_devices times
//  4. Each device accumulates blockwise attention over all KV blocks
//  5. Concatenate results
// ═══════════════════════════════════════════════════════════════════
@hot
fn ra_ring_attention(seq, W_q, W_k, W_v, d, n_devices) {
    let total_len = len(seq) / d
    let chunk_len = total_len / n_devices

    // Split sequence into per-device chunks
    let mut q_chunks = []
    let mut kv_chunks = []
    for dev in 0..n_devices {
        let offset = dev * chunk_len * d
        let mut q_flat = ra_zeros(chunk_len * d)
        let mut s_flat = ra_zeros(chunk_len * d)
        for i in 0..(chunk_len * d) {
            q_flat[i] = seq[offset + i]
            s_flat[i] = seq[offset + i]
        }
        // Project
        let Q_dev = ra_project(q_flat, W_q, chunk_len, d, d)
        let K_dev = ra_project(s_flat, W_k, chunk_len, d, d)
        let V_dev = ra_project(s_flat, W_v, chunk_len, d, d)
        q_chunks = q_chunks + [Q_dev]
        kv_chunks = kv_chunks + [[K_dev, V_dev, dev]]
    }

    // Ring communication: each device sees all KV blocks
    let mut results = []
    for dev in 0..n_devices {
        results = results + [ra_zeros(chunk_len * d)]
    }

    let mut current_kv = kv_chunks
    for ring_step in 0..n_devices {
        // Each device computes attention with current KV
        for dev in 0..n_devices {
            let Q_local = q_chunks[dev]
            let kv = current_kv[dev]
            let K_remote = kv[0]
            let V_remote = kv[1]
            let src_dev = kv[2]
            let q_start = dev * chunk_len
            let k_start = src_dev * chunk_len

            let block_out = ra_blockwise_attention(Q_local, K_remote, V_remote, d, q_start, k_start)

            // Accumulate (simplified: just add contributions)
            let prev = results[dev]
            for i in 0..(chunk_len * d) {
                prev[i] = prev[i] + block_out[i]
            }
            results[dev] = prev
        }

        // Rotate KV around the ring
        if ring_step < n_devices - 1 {
            current_kv = ra_ring_step(current_kv, n_devices)
        }
    }

    // Normalize by n_devices (each position saw all KV blocks)
    let mut final_out = ra_zeros(total_len * d)
    for dev in 0..n_devices {
        let offset = dev * chunk_len * d
        let r = results[dev]
        for i in 0..(chunk_len * d) {
            final_out[offset + i] = r[i] / to_float(n_devices)
        }
    }
    return final_out
}

// ═══════════════════════════════════════════════════════════════════
//  Utility: compute standard (non-ring) attention for comparison
// ═══════════════════════════════════════════════════════════════════
@pure
fn ra_standard_attention(Q, K, V, d) {
    let seq_len = len(Q) / d
    return ra_blockwise_attention(Q, K, V, d, 0, 0)
}

println("[ring_attention] loaded — sequence chunking + ring KV circulation + blockwise attention")
