// ═══════════════════════════════════════════════════════════════
//  visualize.hexa — ASCII chart visualization for training logs
//
//  Pure hexa. No external dependencies.
//  Reads JSONL logs produced by monitor.hexa.
//
//  API:
//    plot_loss(log_path)            — ASCII loss curve
//    plot_lr(log_path)              — ASCII learning rate schedule
//    plot_throughput(log_path)      — ASCII tok/s over time
//    plot_series(values, title, w, h) — generic ASCII line plot
// ═══════════════════════════════════════════════════════════════

use "monitor"

// ── Configuration defaults ───────────────────────────────────

let PLOT_WIDTH  = 70
let PLOT_HEIGHT = 20

// ── Generic ASCII line plot ──────────────────────────────────
// values: [float], title: string, w: int (width), h: int (height)

fn plot_series(values, title, w, h) {
    let n = len(values)
    if n == 0 {
        println("[visualize] no data for: " + title)
        return 0
    }

    // Find min/max
    let mut vmin = values[0]
    let mut vmax = values[0]
    let mut i = 1
    while i < n {
        if values[i] < vmin { vmin = values[i] }
        if values[i] > vmax { vmax = values[i] }
        i = i + 1
    }

    // Avoid zero range
    if vmax - vmin < 1.0e-12 {
        vmax = vmin + 1.0
    }

    let range = vmax - vmin

    // Build canvas: h rows x w cols, filled with ' '
    let mut canvas = []
    let mut r = 0
    while r < h {
        let mut row = []
        let mut c = 0
        while c < w {
            row = row.push(' ')
            c = c + 1
        }
        canvas = canvas.push(row)
        r = r + 1
    }

    // Downsample or map values to columns
    i = 0
    while i < n {
        let col = (i * (w - 1)) / (n - 1)
        let mut ci = col
        if n == 1 { ci = w / 2 }
        if ci >= w { ci = w - 1 }
        let normalized = (values[i] - vmin) / range
        let row_idx = h - 1 - to_int(normalized * (h - 1) * 1.0 + 0.5)
        let mut ri = row_idx
        if ri < 0 { ri = 0 }
        if ri >= h { ri = h - 1 }
        canvas[ri][ci] = '*'
        i = i + 1
    }

    // Print title
    println("")
    println("  " + title)
    println("  " + _repeat("─", w + 8))

    // Print with Y-axis labels
    r = 0
    while r < h {
        let y_val = vmax - (r * 1.0 / (h - 1) * 1.0) * range
        let label = _fmt_num(y_val, 6)
        let mut row_str = ""
        let mut c = 0
        while c < w {
            row_str = row_str + str(canvas[r][c])
            c = c + 1
        }
        println(label + " |" + row_str)
        r = r + 1
    }

    // X-axis
    println(_pad("", 7) + "+" + _repeat("─", w))
    let x_start = _pad("0", 4)
    let x_end = str(n - 1)
    let gap_len = w - len(x_start) - len(x_end)
    let mut gap = ""
    if gap_len > 0 { gap = _repeat(" ", gap_len) }
    println(_pad("", 8) + x_start + gap + x_end)
    println("")
    0
}

// ── plot_loss ────────────────────────────────────────────────

fn plot_loss(log_path) {
    let records = read_log(log_path, "step")
    let mut losses = []
    let mut i = 0
    while i < len(records) {
        let v = extract_field(records[i], "loss")
        losses = losses.push(v)
        i = i + 1
    }
    plot_series(losses, "Loss Curve (step)", PLOT_WIDTH, PLOT_HEIGHT)
}

// ── plot_lr ──────────────────────────────────────────────────

fn plot_lr(log_path) {
    let records = read_log(log_path, "step")
    let mut lrs = []
    let mut i = 0
    while i < len(records) {
        let v = extract_field(records[i], "lr")
        lrs = lrs.push(v)
        i = i + 1
    }
    plot_series(lrs, "Learning Rate Schedule (step)", PLOT_WIDTH, PLOT_HEIGHT)
}

// ── plot_throughput ──────────────────────────────────────────

fn plot_throughput(log_path) {
    let records = read_log(log_path, "step")
    let mut toks = []
    let mut i = 0
    while i < len(records) {
        let v = extract_field(records[i], "tok_per_sec")
        toks = toks.push(v)
        i = i + 1
    }
    plot_series(toks, "Throughput (tok/s)", PLOT_WIDTH, PLOT_HEIGHT)
}

// ── Custom size plots ────────────────────────────────────────

fn plot_loss_sized(log_path, w, h) {
    let records = read_log(log_path, "step")
    let mut losses = []
    let mut i = 0
    while i < len(records) {
        losses = losses.push(extract_field(records[i], "loss"))
        i = i + 1
    }
    plot_series(losses, "Loss Curve (step)", w, h)
}

fn plot_lr_sized(log_path, w, h) {
    let records = read_log(log_path, "step")
    let mut lrs = []
    let mut i = 0
    while i < len(records) {
        lrs = lrs.push(extract_field(records[i], "lr"))
        i = i + 1
    }
    plot_series(lrs, "Learning Rate Schedule (step)", w, h)
}

fn plot_throughput_sized(log_path, w, h) {
    let records = read_log(log_path, "step")
    let mut toks = []
    let mut i = 0
    while i < len(records) {
        toks = toks.push(extract_field(records[i], "tok_per_sec"))
        i = i + 1
    }
    plot_series(toks, "Throughput (tok/s)", w, h)
}

// ── Formatting helpers ───────────────────────────────────────

fn _repeat(ch, n) {
    let mut s = ""
    let mut i = 0
    while i < n {
        s = s + ch
        i = i + 1
    }
    s
}

fn _pad(s, width) {
    let n = len(s)
    if n >= width { return s }
    _repeat(" ", width - n) + s
}

fn _fmt_num(v, width) {
    // Format a number to fit in `width` chars
    let s = str(v)
    let n = len(s)
    if n >= width { return s }
    _repeat(" ", width - n) + s
}
