// ═══════════════════════════════════════════════════════════════
//  self/ml/model_registry.hexa — Model-shape registry
//
//  F-MULTIARCH-1: extends the single-shape Live execution path
//  (Qwen2.5-14B — see self/ml/qwen14b.hexa, self/native/hxqwen14b.c)
//  to a small registry of named shapes the multi-arch dispatcher can
//  bind against without a per-model FFI shim.
//
//  Each entry is a pure-data ModelShape struct. Construction is by
//  ID lookup (`shape_lookup("llama-7b")`) so callers don't depend on
//  a particular file layout. Adding a new shape = adding one entry
//  to `shape_all()`.
//
//  Field meaning:
//    layers     — number of decoder blocks
//    d_model    — hidden dim
//    n_heads    — query heads
//    n_kv_heads — KV heads (GQA: n_kv_heads < n_heads)
//    head_dim   — d_model / n_heads (stored to avoid divide-by-zero
//                 on degenerate tiny shapes)
//    d_ff       — MLP intermediate dim
//    vocab      — vocabulary size (post-tokeniser)
//    rope_base  — RoPE θ base (10000 default; Qwen2/Llama-3 use 1e6;
//                 Llama-2 uses 1e4; Mistral-v0.1 uses 1e6)
//    rope_scale — linear scaling factor for context extension (1.0 if
//                 native ctx; e.g. dynamic-NTK ratio for longer ctx)
//    seq_max    — native maximum context length
//    norm       — "rmsnorm" | "layernorm"
//    act        — "silu" | "gelu" | "swiglu"
//    note       — free-form provenance string
//
//  Why these four?
//    qwen14b   : current Live execution target (anchor for parity)
//    llama-7b  : reference open-weight 7B (Llama-2 era, RoPE 1e4)
//    mistral-7b: SWA + RoPE 1e6, the GQA reference (n_kv_heads=8)
//    tiny      : 2-layer × d=32 — runs on macOS CPU end-to-end in
//                cpu_forward_tiny.hexa for the local F-MULTIARCH-1
//                acceptance row.
// ═══════════════════════════════════════════════════════════════

struct ModelShape {
    id:         string,
    layers:     int,
    d_model:    int,
    n_heads:    int,
    n_kv_heads: int,
    head_dim:   int,
    d_ff:       int,
    vocab:      int,
    rope_base:  float,
    rope_scale: float,
    seq_max:    int,
    norm:       string,
    act:        string,
    note:       string
}

// ── Canonical entries ───────────────────────────────────────────

fn shape_qwen14b() {
    ModelShape {
        id:         "qwen14b",
        layers:     48,
        d_model:    5120,
        n_heads:    40,
        n_kv_heads: 8,
        head_dim:   128,
        d_ff:       13824,
        vocab:      152064,
        rope_base:  1000000.0,
        rope_scale: 1.0,
        seq_max:    32768,
        norm:       "rmsnorm",
        act:        "swiglu",
        note:       "Qwen2.5-14B (existing Live execution anchor; matches self/native/hxqwen14b.c manifest)"
    }
}

fn shape_llama7b() {
    ModelShape {
        id:         "llama-7b",
        layers:     32,
        d_model:    4096,
        n_heads:    32,
        n_kv_heads: 32,        // Llama-2-7B: no GQA
        head_dim:   128,
        d_ff:       11008,
        vocab:      32000,
        rope_base:  10000.0,   // Llama-2 era
        rope_scale: 1.0,
        seq_max:    4096,
        norm:       "rmsnorm",
        act:        "swiglu",
        note:       "Llama-2-7B reference (RoPE base 1e4, no GQA)"
    }
}

fn shape_mistral7b() {
    ModelShape {
        id:         "mistral-7b",
        layers:     32,
        d_model:    4096,
        n_heads:    32,
        n_kv_heads: 8,         // Mistral GQA 4:1
        head_dim:   128,
        d_ff:       14336,
        vocab:      32000,
        rope_base:  1000000.0, // Mistral-v0.1
        rope_scale: 1.0,
        seq_max:    32768,     // SWA window 4096 in original
        norm:       "rmsnorm",
        act:        "swiglu",
        note:       "Mistral-7B-v0.1 (GQA 4:1, RoPE base 1e6, SWA window 4096)"
    }
}

// Tiny shape — exists exclusively to make the CPU end-to-end forward
// runnable on a developer laptop in milliseconds. Every dim is the
// smallest value that exercises the same code paths as the full
// shapes (multi-head, GQA ratio, MLP gate, RMSNorm). Sized to fit
// inside the 4 GiB hexa-runner container without OOM — pure-hexa
// Float arrays-of-arrays are memory-heavy compared to a real f32
// buffer.
fn shape_tiny() {
    ModelShape {
        id:         "tiny",
        layers:     2,
        d_model:    16,
        n_heads:    2,
        n_kv_heads: 1,         // 2:1 GQA
        head_dim:   8,
        d_ff:       32,
        vocab:      32,
        rope_base:  10000.0,
        rope_scale: 1.0,
        seq_max:    8,
        norm:       "rmsnorm",
        act:        "swiglu",
        note:       "tiny dev shape — F-MULTIARCH-1 CPU acceptance row"
    }
}

// ── Lookup ──────────────────────────────────────────────────────

pub fn shape_lookup(id: string) {
    if id == "qwen14b"    { return shape_qwen14b()   }
    if id == "llama-7b"   { return shape_llama7b()   }
    if id == "mistral-7b" { return shape_mistral7b() }
    if id == "tiny"       { return shape_tiny()      }
    // Caller is responsible for handling missing IDs; we return a
    // sentinel zero-shape so a misspelled id surfaces as an obvious
    // forward-pass divergence rather than a runtime crash.
    ModelShape {
        id:         "unknown",
        layers:     0,
        d_model:    0,
        n_heads:    0,
        n_kv_heads: 0,
        head_dim:   0,
        d_ff:       0,
        vocab:      0,
        rope_base:  10000.0,
        rope_scale: 1.0,
        seq_max:    0,
        norm:       "rmsnorm",
        act:        "swiglu",
        note:       "UNKNOWN shape id — registry miss"
    }
}

pub fn shape_known_ids() {
    return ["qwen14b", "llama-7b", "mistral-7b", "tiny"]
}

// Param-count estimate (no tied embedding assumption; embeddings counted once).
// Mirrors the model_100m.hexa accounting style. Not exact for shared QK norms
// or per-Llama-3 quirks, but stable enough for shape-registry sanity checks.
pub fn shape_param_estimate(s: ModelShape) -> int {
    let dd       = s.d_model * s.d_model
    let dkv      = s.d_model * (s.n_kv_heads * s.head_dim)
    let attn     = dd + 2 * dkv + dd       // Wq, Wk, Wv (KV-shrunk), Wo
    let mlp      = 3 * (s.d_model * s.d_ff)  // gate, up, down (SwiGLU)
    let norm     = 2 * s.d_model              // pre-attn + pre-mlp RMSNorm
    let per_lyr  = attn + mlp + norm
    let embed    = s.vocab * s.d_model
    let lm_head  = s.vocab * s.d_model
    return embed + per_lyr * s.layers + lm_head
}

pub fn shape_describe(s: ModelShape) -> string {
    return s.id + "[L=" + str(s.layers) + ",d=" + str(s.d_model)
        + ",h=" + str(s.n_heads) + "/" + str(s.n_kv_heads)
        + ",ff=" + str(s.d_ff) + ",rope=" + str(s.rope_base) + "]"
}

println("[model_registry] module loaded — shapes: qwen14b, llama-7b, mistral-7b, tiny")
