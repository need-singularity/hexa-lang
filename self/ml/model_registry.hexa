// ═══════════════════════════════════════════════════════════════
//  self/ml/model_registry.hexa — Model-shape registry
//
//  F-MULTIARCH-1 component 2/4: a single source of truth for
//  Transformer shape parameters that the multi-arch forward pass
//  needs (RoPE base, head dim, GQA ratio, MLP intermediate width,
//  RMSNorm epsilon). Decouples shape from arch — the same shape
//  object feeds CPU / CUDA / MPS / ROCm dispatch downstream.
//
//  Shapes shipped:
//
//    "tiny"       — 4 layer / 64 dim / 4 head / 2 kv-head / vocab 256.
//                   Pure synthetic. CPU forward-pass round-trip target;
//                   used by test/t_multiarch_cpu_smoke.hexa to validate
//                   the dispatcher without loading any real checkpoint.
//
//    "qwen14b"    — Qwen2.5-14B numbers (existing Live execution
//                   reference path). Mirrors what hxqwen14b.c expects.
//
//    "llama-7b"   — Llama-2/3 7B reference. RoPE base 1e4, no GQA on
//                   Llama-2 (n_heads == n_kv_heads); we record the
//                   Llama-2 7B layout because Llama-3 8B has a
//                   different vocab (128k) and warrants its own row.
//
//    "mistral-7b" — Mistral-7B v0.1 reference. RoPE base 1e6, GQA 4:1
//                   (32 q-heads, 8 kv-heads), SwiGLU MLP 14336.
//
//  Shape lookup is by string id. Unknown ids yield the "tiny" shape
//  with a warning, never a crash — keeps the CLI escape hatch
//  (HEXA_SHAPE=foo) safe to type wrong.
//
//  This file is read-only metadata. Adding a new shape is a single
//  case in `shape_lookup()`. Do NOT add per-shape logic here — that
//  belongs in the forward kernel, gated on `cfg.id` if necessary.
// ═══════════════════════════════════════════════════════════════

// ── Shape descriptor ────────────────────────────────────────────
// Matches LlamaConfig in self/ml/transformer.hexa field-for-field
// where overlapping; adds `id`, `family`, `tie_embeddings` for the
// dispatcher's diagnostics path.
struct ShapeConfig {
    id: string,         // canonical lookup key
    family: string,     // "qwen" | "llama" | "mistral" | "synthetic"
    dim: int,           // model hidden dim (residual stream)
    hidden_dim: int,    // FFN intermediate width (a.k.a. mlp_dim)
    n_layers: int,      // number of transformer blocks
    n_heads: int,       // attention heads (q-heads)
    n_kv_heads: int,    // kv-heads (== n_heads on non-GQA models)
    head_dim: int,      // dim / n_heads
    vocab_size: int,
    max_seq_len: int,
    rope_base: float,   // RoPE theta
    rms_eps: float,     // RMSNorm epsilon
    tie_embeddings: bool,
    notes: string
}

// ── Shape constructors ──────────────────────────────────────────
fn shape_tiny() {
    return ShapeConfig {
        id: "tiny",
        family: "synthetic",
        dim: 64,
        hidden_dim: 128,
        n_layers: 4,
        n_heads: 4,
        n_kv_heads: 2,
        head_dim: 16,
        vocab_size: 256,
        max_seq_len: 32,
        rope_base: 10000.0,
        rms_eps: 0.00001,
        tie_embeddings: true,
        notes: "synthetic CPU forward-pass smoke shape; deterministic checksum"
    }
}

fn shape_qwen14b() {
    // Qwen2.5-14B layout (canonical):
    //   dim=5120, n_heads=40, n_kv_heads=8, head_dim=128
    //   n_layers=48, hidden_dim=13824, vocab=152064, rope_base=1e6
    return ShapeConfig {
        id: "qwen14b",
        family: "qwen",
        dim: 5120,
        hidden_dim: 13824,
        n_layers: 48,
        n_heads: 40,
        n_kv_heads: 8,
        head_dim: 128,
        vocab_size: 152064,
        max_seq_len: 32768,
        rope_base: 1000000.0,
        rms_eps: 0.000001,
        tie_embeddings: false,
        notes: "Qwen2.5-14B; existing Live execution reference (hxqwen14b.c)"
    }
}

fn shape_llama_7b() {
    // Llama-2-7B layout:
    //   dim=4096, n_heads=32, n_kv_heads=32 (no GQA), head_dim=128
    //   n_layers=32, hidden_dim=11008, vocab=32000, rope_base=1e4
    return ShapeConfig {
        id: "llama-7b",
        family: "llama",
        dim: 4096,
        hidden_dim: 11008,
        n_layers: 32,
        n_heads: 32,
        n_kv_heads: 32,
        head_dim: 128,
        vocab_size: 32000,
        max_seq_len: 4096,
        rope_base: 10000.0,
        rms_eps: 0.00001,
        tie_embeddings: false,
        notes: "Llama-2-7B; non-GQA reference (n_heads == n_kv_heads)"
    }
}

fn shape_mistral_7b() {
    // Mistral-7B-v0.1 layout:
    //   dim=4096, n_heads=32, n_kv_heads=8 (GQA 4:1), head_dim=128
    //   n_layers=32, hidden_dim=14336, vocab=32000, rope_base=1e6
    return ShapeConfig {
        id: "mistral-7b",
        family: "mistral",
        dim: 4096,
        hidden_dim: 14336,
        n_layers: 32,
        n_heads: 32,
        n_kv_heads: 8,
        head_dim: 128,
        vocab_size: 32000,
        max_seq_len: 32768,
        rope_base: 1000000.0,
        rms_eps: 0.00001,
        tie_embeddings: false,
        notes: "Mistral-7B-v0.1; GQA 4:1, sliding-window attention 4096"
    }
}

// ── Lookup ──────────────────────────────────────────────────────
pub fn shape_lookup(id: string) {
    if id == "tiny"        { return shape_tiny() }
    if id == "qwen14b"     { return shape_qwen14b() }
    if id == "llama-7b"    { return shape_llama_7b() }
    if id == "mistral-7b"  { return shape_mistral_7b() }
    println("[model_registry] unknown shape id '" + id + "' — defaulting to tiny")
    return shape_tiny()
}

// ── Operator-facing list (for help/diagnostics) ─────────────────
pub fn shape_known_ids() {
    return ["tiny", "qwen14b", "llama-7b", "mistral-7b"]
}

pub fn shape_describe(s: ShapeConfig) -> string {
    return s.id + "[family=" + s.family
         + ",dim=" + str(s.dim)
         + ",L=" + str(s.n_layers)
         + ",H=" + str(s.n_heads)
         + ",KV=" + str(s.n_kv_heads)
         + ",rope=" + str(s.rope_base)
         + ",mlp=" + str(s.hidden_dim) + "]"
}

// ── Honour HEXA_SHAPE env override (matches HEXA_ARCH idiom) ────
pub fn shape_from_env(default_id: string) {
    let raw = env_var("HEXA_SHAPE")
    if raw == "" { return shape_lookup(default_id) }
    return shape_lookup(raw)
}
