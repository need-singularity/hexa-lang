// ═══════════════════════════════════════════════════════════════
//  self/ml/matryoshka_embed.hexa — Matryoshka Representation Learning (#186)
//
//  Kusupati et al. 2022 "Matryoshka Representation Learning":
//    Train a single embedding model whose first D dimensions form a
//    useful D-dimensional embedding for ANY D in a nested set
//    {d1, d2, ..., dM} where d1 < d2 < ... < dM = full_dim.
//
//    Loss = sum_{d in dims} w_d * contrastive_loss(truncate(emb, d))
//
//    At inference time, simply slice emb[0..D] — no retraining.
//    Coarse-to-fine cascaded search: fast filter at small D, refine
//    at larger D. Single model replaces N separate dim-specific ones.
//
//  Model representation: array-tuple [W_flat, full_dim, input_dim]
//    W_flat is a flat array of full_dim * input_dim floats (row-major).
//    emb = normalize(W @ input)
//
//  Batch representation: [anchors, positives, negatives]
//    Each is a flat array of n_samples * input_dim floats.
//
//  API:
//    mrl_create_model(full_dim, input_dim)                  -> model
//    mrl_embed(model, input, full_dim)                      -> [full_dim]
//    mrl_truncate(embedding, target_dim)                    -> [target_dim]
//    mrl_normalize(vec, dim)                                -> [dim]
//    mrl_cosine_sim(a, b, dim)                              -> float
//    mrl_dot(a, b, dim)                                     -> float
//    mrl_loss_at_dim(model, anchors, positives, negatives, dim, n)  -> float
//    mrl_matryoshka_loss(model, anchors, positives, negatives, dims, n) -> float
//    mrl_train_step(model, batch, dims, lr, n)              -> model
//    mrl_search(query_emb, corpus_embs, query_dim, n_corpus, top_k) -> [indices]
//    mrl_adaptive_search(query, corpus, dims_cascade, n_corpus, top_k) -> [indices]
//    mrl_recall_at_k(results, ground_truth, k)              -> float
//    mrl_dim_efficiency(model, test_inputs, ground_truth, dims, n) -> [recall]
//
//  AI-NATIVE attrs:
//    @pure   — no hidden state mutation
//    @hot    — called per training step / search query
//    @fuse   — inner dot+normalize loops
//
//  L0: src/*.rs untouched. Pure .hexa.
//  HX3: no semicolons, arr = arr + [x], while loops, no continue.
// ═══════════════════════════════════════════════════════════════

// ── math helpers (prefixed to avoid collision) ──────────────

@pure
fn _mrl_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

@pure
fn _mrl_max_f(a, b) {
    if a > b { return a }
    return b
}

@pure
fn _mrl_min_i(a, b) {
    if a < b { return a }
    return b
}

fn _mrl_zeros(n) {
    let mut out = []
    let mut i = 0
    while i < n {
        out = out + [0.0]
        i = i + 1
    }
    return out
}

fn _mrl_zeros_int(n) {
    let mut out = []
    let mut i = 0
    while i < n {
        out = out + [0]
        i = i + 1
    }
    return out
}

// Deterministic LCG for weight init
fn _mrl_lcg(seed) {
    let mut s = seed
    if s <= 0 { s = 1 }
    s = (s * 1103515245 + 12345) % 2147483647
    return s
}

// ═══════════════════════════════════════════════════════════════
//  Model creation
//  Model = [W_flat, full_dim, input_dim]
//  W_flat: full_dim * input_dim floats, Xavier-ish init
// ═══════════════════════════════════════════════════════════════

fn mrl_create_model(full_dim, input_dim) {
    let total = full_dim * input_dim
    let mut W = []
    let mut s = 42
    let scale = 1.0 / sqrt(to_float(input_dim))
    let mut i = 0
    while i < total {
        s = _mrl_lcg(s)
        let v = (to_float(s % 2000) - 1000.0) / 1000.0 * scale
        W = W + [v]
        i = i + 1
    }
    return [W, full_dim, input_dim]
}

// ═══════════════════════════════════════════════════════════════
//  L2 normalization
// ═══════════════════════════════════════════════════════════════

@pure @fuse
fn mrl_normalize(vec, dim) {
    let mut norm_sq = 0.0
    let mut i = 0
    while i < dim {
        norm_sq = norm_sq + vec[i] * vec[i]
        i = i + 1
    }
    let norm = sqrt(norm_sq)
    if norm < 1.0e-12 {
        return _mrl_zeros(dim)
    }
    let inv = 1.0 / norm
    let mut out = []
    i = 0
    while i < dim {
        out = out + [vec[i] * inv]
        i = i + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
//  Embedding: linear projection + normalize
//  emb = normalize(W @ input)
//  W is [full_dim x input_dim] stored row-major in W_flat
// ═══════════════════════════════════════════════════════════════

@hot @fuse
fn mrl_embed(model, input, full_dim) {
    let W = model[0]
    let fd = model[1]
    let id = model[2]
    // W @ input -> [full_dim]
    let mut raw = []
    let mut r = 0
    while r < fd {
        let mut dot = 0.0
        let mut c = 0
        while c < id {
            dot = dot + W[r * id + c] * input[c]
            c = c + 1
        }
        raw = raw + [dot]
        r = r + 1
    }
    return mrl_normalize(raw, fd)
}

// ═══════════════════════════════════════════════════════════════
//  Truncation: take first target_dim dimensions
// ═══════════════════════════════════════════════════════════════

@pure
fn mrl_truncate(embedding, target_dim) {
    let mut out = []
    let mut i = 0
    while i < target_dim {
        out = out + [embedding[i]]
        i = i + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
//  Dot product and cosine similarity at given dimension
// ═══════════════════════════════════════════════════════════════

@pure @fuse
fn mrl_dot(a, b, dim) {
    let mut s = 0.0
    let mut i = 0
    while i < dim {
        s = s + a[i] * b[i]
        i = i + 1
    }
    return s
}

@pure
fn mrl_cosine_sim(a, b, dim) {
    let mut dot = 0.0
    let mut na = 0.0
    let mut nb = 0.0
    let mut i = 0
    while i < dim {
        dot = dot + a[i] * b[i]
        na = na + a[i] * a[i]
        nb = nb + b[i] * b[i]
        i = i + 1
    }
    let denom = sqrt(na) * sqrt(nb)
    if denom < 1.0e-12 { return 0.0 }
    return dot / denom
}

// ═══════════════════════════════════════════════════════════════
//  Contrastive loss at a specific dimension
//
//  Triplet margin loss at truncated dimension d:
//    loss_d = mean_i max(0, cos(a_i, neg_i) - cos(a_i, pos_i) + margin)
//
//  anchors/positives/negatives: flat arrays, n samples, input_dim each
// ═══════════════════════════════════════════════════════════════

@hot
fn mrl_loss_at_dim(model, anchors, positives, negatives, dim, n) {
    let id = model[2]
    let mut total_loss = 0.0
    let margin = 0.2
    let mut i = 0
    while i < n {
        // extract sample i from flat arrays
        let mut a_inp = []
        let mut p_inp = []
        let mut n_inp = []
        let mut j = 0
        while j < id {
            a_inp = a_inp + [anchors[i * id + j]]
            p_inp = p_inp + [positives[i * id + j]]
            n_inp = n_inp + [negatives[i * id + j]]
            j = j + 1
        }
        // embed all three
        let a_emb = mrl_embed(model, a_inp, model[1])
        let p_emb = mrl_embed(model, p_inp, model[1])
        let n_emb = mrl_embed(model, n_inp, model[1])
        // truncate to dim
        let a_t = mrl_truncate(a_emb, dim)
        let p_t = mrl_truncate(p_emb, dim)
        let n_t = mrl_truncate(n_emb, dim)
        // re-normalize after truncation (critical for MRL)
        let a_n = mrl_normalize(a_t, dim)
        let p_n = mrl_normalize(p_t, dim)
        let n_n = mrl_normalize(n_t, dim)
        // cosine sims
        let sim_pos = mrl_cosine_sim(a_n, p_n, dim)
        let sim_neg = mrl_cosine_sim(a_n, n_n, dim)
        // hinge loss
        let raw = sim_neg - sim_pos + margin
        if raw > 0.0 {
            total_loss = total_loss + raw
        }
        i = i + 1
    }
    if n > 0 {
        return total_loss / to_float(n)
    }
    return 0.0
}

// ═══════════════════════════════════════════════════════════════
//  Matryoshka loss: sum of losses across multiple dims
//  Equal weighting (1/|dims|) per dimension
// ═══════════════════════════════════════════════════════════════

@hot
fn mrl_matryoshka_loss(model, anchors, positives, negatives, dims, n) {
    let n_dims = len(dims)
    if n_dims == 0 { return 0.0 }
    let mut total = 0.0
    let mut d = 0
    while d < n_dims {
        let loss_d = mrl_loss_at_dim(model, anchors, positives, negatives, dims[d], n)
        total = total + loss_d
        d = d + 1
    }
    return total / to_float(n_dims)
}

// ═══════════════════════════════════════════════════════════════
//  Numerical gradient for one weight
//  Finite-difference: dL/dW_k = (L(W_k+eps) - L(W_k-eps)) / (2*eps)
// ═══════════════════════════════════════════════════════════════

fn _mrl_grad_single(model, anchors, positives, negatives, dims, n, k) {
    let W = model[0]
    let fd = model[1]
    let id = model[2]
    let eps = 1.0e-4

    // W+
    let mut Wp = []
    let mut i = 0
    while i < len(W) {
        if i == k {
            Wp = Wp + [W[i] + eps]
        } else {
            Wp = Wp + [W[i]]
        }
        i = i + 1
    }
    let model_p = [Wp, fd, id]
    let loss_p = mrl_matryoshka_loss(model_p, anchors, positives, negatives, dims, n)

    // W-
    let mut Wm = []
    i = 0
    while i < len(W) {
        if i == k {
            Wm = Wm + [W[i] - eps]
        } else {
            Wm = Wm + [W[i]]
        }
        i = i + 1
    }
    let model_m = [Wm, fd, id]
    let loss_m = mrl_matryoshka_loss(model_m, anchors, positives, negatives, dims, n)

    return (loss_p - loss_m) / (2.0 * eps)
}

// ═══════════════════════════════════════════════════════════════
//  Train step: SGD update with matryoshka loss
//  Computes numerical gradient for each weight and updates W.
//  batch = [anchors, positives, negatives]
// ═══════════════════════════════════════════════════════════════

@hot
fn mrl_train_step(model, batch, dims, lr, n) {
    let W = model[0]
    let fd = model[1]
    let id = model[2]
    let anchors = batch[0]
    let positives = batch[1]
    let negatives = batch[2]
    let n_weights = len(W)

    // compute gradient for each weight
    let mut new_W = []
    let mut k = 0
    while k < n_weights {
        let g = _mrl_grad_single(model, anchors, positives, negatives, dims, n, k)
        new_W = new_W + [W[k] - lr * g]
        k = k + 1
    }
    return [new_W, fd, id]
}

// ═══════════════════════════════════════════════════════════════
//  Search: top-k cosine at truncated dimension
//  query_emb: already embedded [full_dim]
//  corpus_embs: list of [full_dim] embeddings
// ═══════════════════════════════════════════════════════════════

@hot
fn mrl_search(query_emb, corpus_embs, query_dim, n_corpus, top_k) {
    // truncate and normalize query
    let q_t = mrl_truncate(query_emb, query_dim)
    let q_n = mrl_normalize(q_t, query_dim)

    // compute similarity for each corpus item
    let mut scores = _mrl_zeros(n_corpus)
    let mut i = 0
    while i < n_corpus {
        let c_t = mrl_truncate(corpus_embs[i], query_dim)
        let c_n = mrl_normalize(c_t, query_dim)
        scores[i] = mrl_cosine_sim(q_n, c_n, query_dim)
        i = i + 1
    }

    // top-k by descending score
    let mut used = _mrl_zeros_int(n_corpus)
    let mut results = []
    let mut kk = top_k
    if kk > n_corpus { kk = n_corpus }
    let mut r = 0
    while r < kk {
        let mut best_idx = 0 - 1
        let mut best_score = 0.0 - 1.0e30
        let mut j = 0
        while j < n_corpus {
            if used[j] == 0 {
                if scores[j] > best_score {
                    best_score = scores[j]
                    best_idx = j
                }
            }
            j = j + 1
        }
        if best_idx < 0 {
            r = kk  // break
        } else {
            used[best_idx] = 1
            results = results + [best_idx]
            r = r + 1
        }
    }
    return results
}

// ═══════════════════════════════════════════════════════════════
//  Adaptive (cascaded) search:
//    1. Coarse pass at smallest dim -> top_k * expansion candidates
//    2. Refine at each subsequent dim -> narrow down
//    3. Final pass at largest dim -> top_k results
//
//  dims_cascade must be sorted ascending, e.g. [32, 64, 128, 256]
//  query/corpus: raw input vectors (not yet embedded)
// ═══════════════════════════════════════════════════════════════

@hot
fn mrl_adaptive_search(query, corpus, dims_cascade, n_corpus, top_k) {
    // Build a model reference from the first corpus member's length
    // For adaptive search, we need pre-embedded data
    // query: already-embedded [full_dim]
    // corpus: list of already-embedded [full_dim] vectors

    let n_dims = len(dims_cascade)
    if n_dims == 0 { return [] }

    // start with all corpus indices as candidates
    let mut candidates = []
    let mut i = 0
    while i < n_corpus {
        candidates = candidates + [i]
        i = i + 1
    }

    // cascade: at each dim, re-rank candidates and keep top
    let mut d = 0
    while d < n_dims {
        let dim = dims_cascade[d]
        let q_t = mrl_truncate(query, dim)
        let q_n = mrl_normalize(q_t, dim)

        let n_cand = len(candidates)
        // how many to keep at this stage
        let mut keep = top_k
        if d < n_dims - 1 {
            // intermediate stages keep more (expansion factor)
            keep = top_k * 4
            if keep > n_cand { keep = n_cand }
        }
        if keep > n_cand { keep = n_cand }

        // score each candidate
        let mut scored = []
        let mut ci = 0
        while ci < n_cand {
            let idx = candidates[ci]
            let c_t = mrl_truncate(corpus[idx], dim)
            let c_n = mrl_normalize(c_t, dim)
            let sim = mrl_cosine_sim(q_n, c_n, dim)
            scored = scored + [[sim, idx]]
            ci = ci + 1
        }

        // top-keep by descending score (selection sort, small n_cand)
        let mut used = _mrl_zeros_int(n_cand)
        let mut new_cand = []
        let mut r = 0
        while r < keep {
            let mut best_j = 0 - 1
            let mut best_s = 0.0 - 1.0e30
            let mut j = 0
            while j < n_cand {
                if used[j] == 0 {
                    if scored[j][0] > best_s {
                        best_s = scored[j][0]
                        best_j = j
                    }
                }
                j = j + 1
            }
            if best_j < 0 {
                r = keep  // break
            } else {
                used[best_j] = 1
                // scored[best_j][1] is the original corpus index
                let orig = scored[best_j][1]
                // need int
                let mut orig_i = 0
                let mut oi = 0
                while oi < n_corpus {
                    if oi == orig { orig_i = oi }
                    oi = oi + 1
                }
                new_cand = new_cand + [orig_i]
                r = r + 1
            }
        }

        candidates = new_cand
        d = d + 1
    }

    // final: return top_k from candidates
    let mut final_results = []
    let mut fi = 0
    let final_k = _mrl_min_i(top_k, len(candidates))
    while fi < final_k {
        final_results = final_results + [candidates[fi]]
        fi = fi + 1
    }
    return final_results
}

// ═══════════════════════════════════════════════════════════════
//  Recall@K metric
//  results: array of returned indices
//  ground_truth: array of relevant indices
//  k: evaluate recall at top-k
// ═══════════════════════════════════════════════════════════════

@pure
fn mrl_recall_at_k(results, ground_truth, k) {
    let n_results = len(results)
    let n_gt = len(ground_truth)
    if n_gt == 0 { return 1.0 }
    let mut kk = k
    if kk > n_results { kk = n_results }
    let mut hits = 0
    let mut i = 0
    while i < kk {
        let mut j = 0
        while j < n_gt {
            if results[i] == ground_truth[j] {
                hits = hits + 1
                j = n_gt  // break inner
            } else {
                j = j + 1
            }
        }
        i = i + 1
    }
    return to_float(hits) / to_float(n_gt)
}

// ═══════════════════════════════════════════════════════════════
//  Dimension efficiency: recall vs dimension curve
//  For each dim in dims, embed test_inputs, search, measure recall.
//  test_inputs: list of raw input vectors
//  ground_truth: list of relevant corpus indices for the first test input
//  Returns array of recall values, one per dim.
// ═══════════════════════════════════════════════════════════════

fn mrl_dim_efficiency(model, test_inputs, ground_truth, dims, n) {
    let n_dims = len(dims)
    // embed all test inputs
    let fd = model[1]
    let mut corpus_embs = []
    let mut i = 0
    while i < n {
        let mut inp = []
        let mut j = 0
        while j < model[2] {
            inp = inp + [test_inputs[i * model[2] + j]]
            j = j + 1
        }
        corpus_embs = corpus_embs + [mrl_embed(model, inp, fd)]
        i = i + 1
    }

    // use first input as query
    let mut q_inp = []
    let mut qi = 0
    while qi < model[2] {
        q_inp = q_inp + [test_inputs[qi]]
        qi = qi + 1
    }
    let q_emb = mrl_embed(model, q_inp, fd)

    // measure recall at each dim
    let mut recalls = []
    let mut d = 0
    while d < n_dims {
        let dim = dims[d]
        let results = mrl_search(q_emb, corpus_embs, dim, n, _mrl_min_i(10, n))
        let recall = mrl_recall_at_k(results, ground_truth, _mrl_min_i(10, n))
        recalls = recalls + [recall]
        d = d + 1
    }
    return recalls
}

// ═══════════════════════════════════════════════════════════════
//  Embedding norm (for diagnostics)
// ═══════════════════════════════════════════════════════════════

@pure
fn mrl_norm(vec, dim) {
    let mut s = 0.0
    let mut i = 0
    while i < dim {
        s = s + vec[i] * vec[i]
        i = i + 1
    }
    return sqrt(s)
}

// ═══════════════════════════════════════════════════════════════
//  Weight count helper
// ═══════════════════════════════════════════════════════════════

@pure
fn mrl_param_count(model) {
    return model[1] * model[2]
}
