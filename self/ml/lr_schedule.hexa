// =====================================================================
//  self/ml/lr_schedule.hexa — Learning rate schedules + gradient clipping
//
//  Standalone module for configurable LR warmup/decay strategies:
//    - cosine warmup+decay (default for 7B training)
//    - linear warmup+decay
//    - constant with warmup
//
//  Also provides a generic clip_grad_norm that works on any list of
//  {buf, n} pairs (buffer pointer + element count).
//
//  Grammar notes (HX3):
//    - .push() not arr+[x] in loops
//    - parens in slice index arithmetic
// =====================================================================

let PI = 3.14159265358979

// =====================================================================
//  lr_cosine_warmup — linear warmup then cosine annealing to lr_min
//
//  step     : current training step (1-based)
//  warmup   : number of warmup steps
//  total    : total training steps
//  lr_max   : peak learning rate after warmup
//  lr_min   : minimum learning rate floor
// =====================================================================
fn lr_cosine_warmup(step, warmup, total, lr_max, lr_min) {
    if step <= 0 { return lr_min }
    if step <= warmup {
        // linear ramp from lr_min to lr_max
        return lr_min + (lr_max - lr_min) * (step * 1.0) / (warmup * 1.0)
    }
    if step >= total { return lr_min }
    let progress = ((step - warmup) * 1.0) / ((total - warmup) * 1.0)
    let cosval = cos(progress * PI)
    return lr_min + (lr_max - lr_min) * 0.5 * (1.0 + cosval)
}

// =====================================================================
//  lr_linear_warmup — linear warmup then linear decay to lr_min
//
//  After warmup, LR decays linearly from lr_max to lr_min over the
//  remaining (total - warmup) steps.
// =====================================================================
fn lr_linear_warmup(step, warmup, total, lr_max, lr_min) {
    if step <= 0 { return lr_min }
    if step <= warmup {
        return lr_min + (lr_max - lr_min) * (step * 1.0) / (warmup * 1.0)
    }
    if step >= total { return lr_min }
    let progress = ((step - warmup) * 1.0) / ((total - warmup) * 1.0)
    return lr_max - (lr_max - lr_min) * progress
}

// =====================================================================
//  lr_constant_warmup — linear warmup then constant lr_max
//
//  Useful for fine-tuning where you want a fixed LR after warmup.
// =====================================================================
fn lr_constant_warmup(step, warmup, lr_max) {
    if step <= 0 { return 0.0 }
    if step <= warmup {
        let lr_min = lr_max * 0.01
        return lr_min + (lr_max - lr_min) * (step * 1.0) / (warmup * 1.0)
    }
    return lr_max
}

// =====================================================================
//  get_lr — dispatch to the right schedule by name
//
//  schedule : "cosine" | "linear" | "constant_with_warmup"
//  Returns the learning rate for the given step.
// =====================================================================
fn get_lr(schedule, step, warmup, total, lr_max, lr_min) {
    if schedule == "linear" {
        return lr_linear_warmup(step, warmup, total, lr_max, lr_min)
    }
    if schedule == "constant_with_warmup" {
        return lr_constant_warmup(step, warmup, lr_max)
    }
    // default: cosine
    return lr_cosine_warmup(step, warmup, total, lr_max, lr_min)
}

// =====================================================================
//  clip_grad_norm — clip a list of gradient buffers by global L2 norm
//
//  grads_list : list of [buf, n] pairs (buffer pointer, element count)
//  max_norm   : maximum allowed L2 norm
//
//  Returns the actual (pre-clip) global norm. If actual_norm <= max_norm,
//  no scaling is performed.
// =====================================================================
fn clip_grad_norm(grads_list, max_norm) {
    // pass 1: compute global squared norm
    let mut global_sq = 0.0
    for pair in grads_list {
        let buf = pair[0]
        let n = pair[1]
        for i in 0..n {
            let v = deref_f32(buf, i * 4)
            global_sq = global_sq + v * v
        }
    }
    let actual_norm = sqrt(global_sq)

    // pass 2: scale if over max_norm
    if actual_norm > max_norm {
        let clip_ratio = max_norm / actual_norm
        for pair in grads_list {
            let buf = pair[0]
            let n = pair[1]
            for i in 0..n {
                let v = deref_f32(buf, i * 4)
                write_f32(buf, i * 4, v * clip_ratio)
            }
        }
    }
    return actual_norm
}
