// ===================================================================
//  self/ml/retnet.hexa — RetNet: Retentive Network
//
//  Implements the RetNet architecture (Sun et al., 2023), a sequence
//  model with dual parallel + recurrent modes. Training uses the
//  parallel form (full matrix multiply), inference uses the recurrent
//  form (O(1) per step). A chunkwise hybrid bridges the two.
//
//  Components:
//    1. Retention mechanism      — Q*K^T with exponential decay D
//    2. Parallel mode            — full-sequence retention via matrix
//    3. Recurrent mode           — O(1) per-step via state update
//    4. Chunkwise mode           — parallel within chunk, recurrent across
//    5. Multi-scale retention    — different gamma per head
//    6. Gated retention          — swish gate on retention output
//    7. RetNet block             — retention + FFN + LayerNorm + residual
//    8. Multi-layer stack        — configurable layers, d_model, heads
//    9. Generation               — autoregressive with recurrent state
//
//  AI-NATIVE attrs:
//    @pure  — no side effects
//    @hot   — inner-loop kernels
// ===================================================================

// ===================================================================
//  Math helpers
// ===================================================================

fn ret_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn ret_sqrt(x) {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    for _i in 0..30 { g = (g + x / g) / 2.0 }
    return g
}

fn ret_exp(x) {
    let mut v = x
    if v > 20.0 { v = 20.0 }
    if v < -20.0 { v = -20.0 }
    let mut result = 1.0
    let mut term = 1.0
    for i in 1..30 {
        term = term * v / to_float(i)
        result = result + term
    }
    if result < 0.0 { return 0.0 }
    return result
}

fn ret_log(x) {
    if x <= 0.0 { return -20.0 }
    let mut y = 0.0
    let mut t = (x - 1.0) / (x + 1.0)
    let t2 = t * t
    let mut term = t
    for i in 0..15 {
        y = y + term / to_float(2 * i + 1)
        term = term * t2
    }
    return 2.0 * y
}

fn ret_sigmoid(x) {
    if x > 20.0 { return 1.0 }
    if x < -20.0 { return 0.0 }
    return 1.0 / (1.0 + ret_exp(0.0 - x))
}

// swish(x) = x * sigmoid(x)
@pure
fn ret_swish(x) {
    return x * ret_sigmoid(x)
}

fn ret_pow(base, exp_val) {
    if base <= 0.0 { return 0.0 }
    return ret_exp(exp_val * ret_log(base))
}

fn ret_max(a, b) { if a > b { return a } return b }
fn ret_min(a, b) { if a < b { return a } return b }

// ===================================================================
//  Vector utilities
// ===================================================================

fn ret_zeros(n) {
    let mut v = []
    for _i in 0..n { v = v + [0.0] }
    return v
}

fn ret_ones(n) {
    let mut v = []
    for _i in 0..n { v = v + [1.0] }
    return v
}

fn ret_vec_add(a, b) {
    let n = len(a)
    let mut out = []
    for i in 0..n { out = out + [a[i] + b[i]] }
    return out
}

fn ret_vec_sub(a, b) {
    let n = len(a)
    let mut out = []
    for i in 0..n { out = out + [a[i] - b[i]] }
    return out
}

fn ret_vec_mul(a, b) {
    let n = len(a)
    let mut out = []
    for i in 0..n { out = out + [a[i] * b[i]] }
    return out
}

fn ret_vec_scale(v, s) {
    let n = len(v)
    let mut out = []
    for i in 0..n { out = out + [v[i] * s] }
    return out
}

fn ret_dot(a, b) {
    let n = len(a)
    let mut s = 0.0
    for i in 0..n { s = s + a[i] * b[i] }
    return s
}

fn ret_vec_swish(v) {
    let n = len(v)
    let mut out = []
    for i in 0..n { out = out + [ret_swish(v[i])] }
    return out
}

fn ret_vec_sigmoid(v) {
    let n = len(v)
    let mut out = []
    for i in 0..n { out = out + [ret_sigmoid(v[i])] }
    return out
}

// ===================================================================
//  Matrix utilities (row-major: array of row-vectors)
// ===================================================================

fn ret_mat_zeros(rows, cols) {
    let mut m = []
    for _r in 0..rows { m = m + [ret_zeros(cols)] }
    return m
}

fn ret_mat_vec(mat, v) {
    let rows = len(mat)
    let mut out = []
    for r in 0..rows { out = out + [ret_dot(mat[r], v)] }
    return out
}

// Outer product: a (col) * b (row) -> matrix [len(a) x len(b)]
fn ret_outer(a, b) {
    let ra = len(a)
    let cb = len(b)
    let mut m = []
    for i in 0..ra {
        let mut row = []
        for j in 0..cb {
            row = row + [a[i] * b[j]]
        }
        m = m + [row]
    }
    return m
}

// Matrix add: element-wise
fn ret_mat_add(a, b) {
    let rows = len(a)
    let mut m = []
    for r in 0..rows {
        m = m + [ret_vec_add(a[r], b[r])]
    }
    return m
}

// Matrix scale
fn ret_mat_scale(mat, s) {
    let rows = len(mat)
    let mut m = []
    for r in 0..rows {
        m = m + [ret_vec_scale(mat[r], s)]
    }
    return m
}

// Deterministic pseudo-random initialization
fn ret_init_weight(rows, cols, seed) {
    let scale = 1.0 / ret_sqrt(to_float(cols))
    let mut m = []
    for r in 0..rows {
        let mut row = []
        for c in 0..cols {
            let h = (r * 137 + c * 311 + seed * 7919) % 10007
            let val = (to_float(h) / 10007.0 - 0.5) * 2.0 * scale
            row = row + [val]
        }
        m = m + [row]
    }
    return m
}

fn ret_init_vec(dim, seed) {
    let scale = 1.0 / ret_sqrt(to_float(dim))
    let mut v = []
    for i in 0..dim {
        let h = (i * 251 + seed * 6173) % 10007
        let val = (to_float(h) / 10007.0 - 0.5) * 2.0 * scale
        v = v + [val]
    }
    return v
}

// ===================================================================
//  LayerNorm
// ===================================================================

struct RetLayerNorm {
    dim: int,
    gamma: array,
    beta: array,
    eps: float
}

fn create_ret_layer_norm(dim) {
    return RetLayerNorm {
        dim: dim,
        gamma: ret_ones(dim),
        beta: ret_zeros(dim),
        eps: 1.0e-5
    }
}

@pure
fn ret_layer_norm_forward(ln, x) {
    let n = ln.dim
    let mut mean = 0.0
    for i in 0..n { mean = mean + x[i] }
    mean = mean / to_float(n)
    let mut var = 0.0
    for i in 0..n {
        let d = x[i] - mean
        var = var + d * d
    }
    var = var / to_float(n)
    let inv_std = 1.0 / ret_sqrt(var + ln.eps)
    let mut out = []
    for i in 0..n {
        let normed = (x[i] - mean) * inv_std
        out = out + [ln.gamma[i] * normed + ln.beta[i]]
    }
    return out
}

// ===================================================================
//  Decay matrix D: D_{ij} = gamma^(i-j) for i >= j, 0 otherwise
//
//  This is the core of the retention mechanism. For a sequence of
//  length T, D is a TxT lower-triangular causal mask with exponential
//  decay based on distance.
// ===================================================================

@pure
fn build_decay_matrix(seq_len, gamma) {
    let mut d_mat = []
    for i in 0..seq_len {
        let mut row = []
        for j in 0..seq_len {
            if j > i {
                row = row + [0.0]
            } else {
                let dist = i - j
                row = row + [ret_pow(gamma, to_float(dist))]
            }
        }
        d_mat = d_mat + [row]
    }
    return d_mat
}

// ===================================================================
//  Multi-scale gamma: gamma_h = 1 - 2^(-5 - h) for head h
//  Each head uses a different decay rate, capturing different timescales.
// ===================================================================

@pure
fn compute_gamma(head_idx) {
    // gamma_h = 1 - 2^(-5-h)
    let exponent = 0.0 - to_float(5 + head_idx)
    let two_pow = ret_pow(2.0, exponent)
    return 1.0 - two_pow
}

fn compute_gammas(n_heads) {
    let mut gammas = []
    for h in 0..n_heads {
        gammas = gammas + [compute_gamma(h)]
    }
    return gammas
}

// ===================================================================
//  Single-head Retention
//
//  Given Q, K, V sequences (each: [seq_len x head_dim]):
//
//  Parallel mode:
//    Retention(X) = (Q * K^T .* D) * V
//    where D_{ij} = gamma^{i-j} for i>=j, 0 otherwise
//
//  Recurrent mode:
//    S_n = gamma * S_{n-1} + K_n^T * V_n   (state: head_dim x head_dim)
//    O_n = Q_n * S_n                         (output: head_dim)
// ===================================================================

struct RetentionHead {
    head_dim: int,
    gamma: float,
    W_q: array,
    W_k: array,
    W_v: array
}

fn create_retention_head(head_dim, gamma, seed) {
    return RetentionHead {
        head_dim: head_dim,
        gamma: gamma,
        W_q: ret_init_weight(head_dim, head_dim, seed + 1),
        W_k: ret_init_weight(head_dim, head_dim, seed + 2),
        W_v: ret_init_weight(head_dim, head_dim, seed + 3)
    }
}

// --- Parallel mode ---
// xs: [seq_len x head_dim] input embeddings for one head
// Returns: [seq_len x head_dim]
@hot
fn retention_parallel(head, xs) {
    let seq_len = len(xs)
    let d = head.head_dim
    // Compute Q, K, V for all positions
    let mut qs = []
    let mut ks = []
    let mut vs = []
    for t in 0..seq_len {
        qs = qs + [ret_mat_vec(head.W_q, xs[t])]
        ks = ks + [ret_mat_vec(head.W_k, xs[t])]
        vs = vs + [ret_mat_vec(head.W_v, xs[t])]
    }
    // Build decay matrix D
    let d_mat = build_decay_matrix(seq_len, head.gamma)
    // Compute output: for each position i:
    //   out_i = sum_j (D[i][j] * dot(Q_i, K_j)) * V_j
    let mut outputs = []
    for i in 0..seq_len {
        let mut out = ret_zeros(d)
        for j in 0..seq_len {
            let qk = ret_dot(qs[i], ks[j])
            let weight = d_mat[i][j] * qk
            out = ret_vec_add(out, ret_vec_scale(vs[j], weight))
        }
        outputs = outputs + [out]
    }
    return outputs
}

// --- Recurrent mode ---
// Single step: process one token, update state
// x: [head_dim] current input
// state: [head_dim x head_dim] recurrent state matrix
// Returns: [output, new_state]
//   output: [head_dim]
//   new_state: [head_dim x head_dim]
@pure @hot
fn retention_recurrent_step(head, x, state) {
    let d = head.head_dim
    let q = ret_mat_vec(head.W_q, x)
    let k = ret_mat_vec(head.W_k, x)
    let v = ret_mat_vec(head.W_v, x)
    // S_n = gamma * S_{n-1} + V_n * K_n^T  (outer product: V x K)
    // so that mat_vec(S, Q) = V * dot(K, Q) = dot(Q, K) * V
    let new_state = ret_mat_add(
        ret_mat_scale(state, head.gamma),
        ret_outer(v, k)
    )
    // O_n = S_n * Q_n
    let output = ret_mat_vec(new_state, q)
    return [output, new_state]
}

// Process full sequence in recurrent mode
// xs: [seq_len x head_dim]
// Returns: [seq_len x head_dim]
fn retention_recurrent(head, xs) {
    let seq_len = len(xs)
    let d = head.head_dim
    let mut state = ret_mat_zeros(d, d)
    let mut outputs = []
    for t in 0..seq_len {
        let res = retention_recurrent_step(head, xs[t], state)
        outputs = outputs + [res[0]]
        state = res[1]
    }
    return outputs
}

// ===================================================================
//  Chunkwise mode
//
//  Splits the sequence into chunks of size C. Within each chunk,
//  use parallel mode. Across chunks, pass a recurrent state.
//
//  For chunk m:
//    inner = (Q_m * K_m^T .* D_C) * V_m         (parallel within chunk)
//    cross = (Q_m * S_{m-1}) .* decay_offset     (recurrent across chunks)
//    O_m = inner + cross
//    S_m = gamma^C * S_{m-1} + sum_{j in chunk} gamma^(C-1-j) * K_j^T * V_j
// ===================================================================

fn retention_chunkwise(head, xs, chunk_size) {
    let seq_len = len(xs)
    let d = head.head_dim
    let gamma = head.gamma
    let mut state = ret_mat_zeros(d, d)
    let mut outputs = []

    let mut pos = 0
    for _chunk_idx in 0..((seq_len + chunk_size - 1) / chunk_size) {
        let c_end = ret_min(pos + chunk_size, seq_len)
        let c_len = c_end - pos

        // Extract chunk
        let mut chunk_xs = []
        for i in 0..c_len {
            chunk_xs = chunk_xs + [xs[pos + i]]
        }

        // Compute Q, K, V for chunk
        let mut qs = []
        let mut ks = []
        let mut vs = []
        for i in 0..c_len {
            qs = qs + [ret_mat_vec(head.W_q, chunk_xs[i])]
            ks = ks + [ret_mat_vec(head.W_k, chunk_xs[i])]
            vs = vs + [ret_mat_vec(head.W_v, chunk_xs[i])]
        }

        // Inner: parallel within chunk
        let d_inner = build_decay_matrix(c_len, gamma)
        let mut inner_outs = []
        for i in 0..c_len {
            let mut out = ret_zeros(d)
            for j in 0..c_len {
                let qk = ret_dot(qs[i], ks[j])
                let weight = d_inner[i][j] * qk
                out = ret_vec_add(out, ret_vec_scale(vs[j], weight))
            }
            inner_outs = inner_outs + [out]
        }

        // Cross: recurrent across chunks
        // cross_i = Q_i * state * gamma^(i+1)
        for i in 0..c_len {
            let decay_cross = ret_pow(gamma, to_float(i + 1))
            let cross_out = ret_vec_scale(ret_mat_vec(state, qs[i]), decay_cross)
            let combined = ret_vec_add(inner_outs[i], cross_out)
            outputs = outputs + [combined]
        }

        // Update state: S_m = gamma^C * S_{m-1} + sum_j gamma^(C-1-j) * outer(V_j, K_j)
        let gamma_c = ret_pow(gamma, to_float(c_len))
        state = ret_mat_scale(state, gamma_c)
        for j in 0..c_len {
            let decay_j = ret_pow(gamma, to_float(c_len - 1 - j))
            let vk_outer = ret_outer(vs[j], ks[j])
            state = ret_mat_add(state, ret_mat_scale(vk_outer, decay_j))
        }

        pos = pos + c_len
    }
    return outputs
}

// ===================================================================
//  Multi-Scale Retention (MSR)
//
//  Splits input into n_heads sub-spaces, each with its own gamma.
//  Concatenates head outputs and projects through W_o.
//  Applies a gated retention: output = swish(W_g * x) * (W_o * concat_heads)
// ===================================================================

struct MultiScaleRetention {
    d_model: int,
    n_heads: int,
    head_dim: int,
    heads: array,
    gammas: array,
    W_o: array,
    W_g: array
}

fn create_multi_scale_retention(d_model, n_heads, seed) {
    let head_dim = d_model / n_heads
    let gammas = compute_gammas(n_heads)
    let mut heads = []
    for h in 0..n_heads {
        heads = heads + [create_retention_head(head_dim, gammas[h], seed + h * 100)]
    }
    return MultiScaleRetention {
        d_model: d_model,
        n_heads: n_heads,
        head_dim: head_dim,
        heads: heads,
        gammas: gammas,
        W_o: ret_init_weight(d_model, d_model, seed + 900),
        W_g: ret_init_weight(d_model, d_model, seed + 950)
    }
}

// Split d_model vector into n_heads chunks of head_dim
fn split_heads(x, n_heads, head_dim) {
    let mut parts = []
    for h in 0..n_heads {
        let mut part = []
        for i in 0..head_dim {
            part = part + [x[h * head_dim + i]]
        }
        parts = parts + [part]
    }
    return parts
}

// Concatenate head outputs back into d_model vector
fn concat_heads(parts, n_heads, head_dim) {
    let mut out = []
    for h in 0..n_heads {
        for i in 0..head_dim {
            out = out + [parts[h][i]]
        }
    }
    return out
}

// MSR parallel forward (full sequence)
// xs: [seq_len x d_model]
// Returns: [seq_len x d_model]
fn msr_parallel(msr, xs) {
    let seq_len = len(xs)
    let nh = msr.n_heads
    let hd = msr.head_dim

    // Split input per head: [n_heads x seq_len x head_dim]
    let mut head_inputs = []
    for h in 0..nh {
        let mut h_seq = []
        for t in 0..seq_len {
            let parts = split_heads(xs[t], nh, hd)
            h_seq = h_seq + [parts[h]]
        }
        head_inputs = head_inputs + [h_seq]
    }

    // Run each head in parallel mode
    let mut head_outputs = []
    for h in 0..nh {
        head_outputs = head_outputs + [retention_parallel(msr.heads[h], head_inputs[h])]
    }

    // Concatenate + gate + project for each position
    let mut outputs = []
    for t in 0..seq_len {
        let mut parts = []
        for h in 0..nh {
            parts = parts + [head_outputs[h][t]]
        }
        let cat = concat_heads(parts, nh, hd)
        // Gated retention: swish(W_g * x) * (W_o * cat)
        let gate = ret_vec_swish(ret_mat_vec(msr.W_g, xs[t]))
        let proj = ret_mat_vec(msr.W_o, cat)
        outputs = outputs + [ret_vec_mul(gate, proj)]
    }
    return outputs
}

// MSR recurrent step (single token)
// x: [d_model]
// states: [n_heads x head_dim x head_dim] array of per-head state matrices
// Returns: [output, new_states]
fn msr_recurrent_step(msr, x, states) {
    let nh = msr.n_heads
    let hd = msr.head_dim
    let parts = split_heads(x, nh, hd)

    let mut head_outs = []
    let mut new_states = []
    for h in 0..nh {
        let res = retention_recurrent_step(msr.heads[h], parts[h], states[h])
        head_outs = head_outs + [res[0]]
        new_states = new_states + [res[1]]
    }

    let cat = concat_heads(head_outs, nh, hd)
    // Gated retention
    let gate = ret_vec_swish(ret_mat_vec(msr.W_g, x))
    let proj = ret_mat_vec(msr.W_o, cat)
    let output = ret_vec_mul(gate, proj)
    return [output, new_states]
}

// MSR recurrent forward (full sequence token by token)
fn msr_recurrent(msr, xs) {
    let seq_len = len(xs)
    let nh = msr.n_heads
    let hd = msr.head_dim
    let mut states = []
    for h in 0..nh {
        states = states + [ret_mat_zeros(hd, hd)]
    }
    let mut outputs = []
    for t in 0..seq_len {
        let res = msr_recurrent_step(msr, xs[t], states)
        outputs = outputs + [res[0]]
        states = res[1]
    }
    return outputs
}

// MSR chunkwise forward
fn msr_chunkwise(msr, xs, chunk_size) {
    let seq_len = len(xs)
    let nh = msr.n_heads
    let hd = msr.head_dim

    // Split input per head
    let mut head_inputs = []
    for h in 0..nh {
        let mut h_seq = []
        for t in 0..seq_len {
            let parts = split_heads(xs[t], nh, hd)
            h_seq = h_seq + [parts[h]]
        }
        head_inputs = head_inputs + [h_seq]
    }

    // Run each head in chunkwise mode
    let mut head_outputs = []
    for h in 0..nh {
        head_outputs = head_outputs + [retention_chunkwise(msr.heads[h], head_inputs[h], chunk_size)]
    }

    // Concatenate + gate + project
    let mut outputs = []
    for t in 0..seq_len {
        let mut parts = []
        for h in 0..nh {
            parts = parts + [head_outputs[h][t]]
        }
        let cat = concat_heads(parts, nh, hd)
        let gate = ret_vec_swish(ret_mat_vec(msr.W_g, xs[t]))
        let proj = ret_mat_vec(msr.W_o, cat)
        outputs = outputs + [ret_vec_mul(gate, proj)]
    }
    return outputs
}

// ===================================================================
//  RetNet Block: LayerNorm + MSR + residual + LayerNorm + FFN + residual
//
//  FFN: W2 * swish(W1 * x)
// ===================================================================

struct RetNetBlock {
    d_model: int,
    ff_dim: int,
    ln1: RetLayerNorm,
    ln2: RetLayerNorm,
    msr: MultiScaleRetention,
    W_ff1: array,
    W_ff2: array
}

fn create_retnet_block(d_model, n_heads, ff_dim, seed) {
    return RetNetBlock {
        d_model: d_model,
        ff_dim: ff_dim,
        ln1: create_ret_layer_norm(d_model),
        ln2: create_ret_layer_norm(d_model),
        msr: create_multi_scale_retention(d_model, n_heads, seed),
        W_ff1: ret_init_weight(ff_dim, d_model, seed + 2000),
        W_ff2: ret_init_weight(d_model, ff_dim, seed + 2100)
    }
}

// FFN: W2 * swish(W1 * x)
@pure
fn retnet_ffn(blk, x) {
    let hidden = ret_vec_swish(ret_mat_vec(blk.W_ff1, x))
    return ret_mat_vec(blk.W_ff2, hidden)
}

// Block parallel forward (full sequence)
fn retnet_block_parallel(blk, xs) {
    let seq_len = len(xs)
    // MSR branch with residual
    let mut normed1 = []
    for t in 0..seq_len {
        normed1 = normed1 + [ret_layer_norm_forward(blk.ln1, xs[t])]
    }
    let msr_out = msr_parallel(blk.msr, normed1)
    let mut x2 = []
    for t in 0..seq_len {
        x2 = x2 + [ret_vec_add(xs[t], msr_out[t])]
    }
    // FFN branch with residual
    let mut outputs = []
    for t in 0..seq_len {
        let normed2 = ret_layer_norm_forward(blk.ln2, x2[t])
        let ffn_out = retnet_ffn(blk, normed2)
        outputs = outputs + [ret_vec_add(x2[t], ffn_out)]
    }
    return outputs
}

// Block recurrent step (single token)
// x: [d_model]
// states: per-head state matrices [n_heads x head_dim x head_dim]
// Returns: [output, new_states]
fn retnet_block_recurrent_step(blk, x, states) {
    // MSR branch
    let normed1 = ret_layer_norm_forward(blk.ln1, x)
    let msr_res = msr_recurrent_step(blk.msr, normed1, states)
    let x2 = ret_vec_add(x, msr_res[0])
    let new_states = msr_res[1]
    // FFN branch
    let normed2 = ret_layer_norm_forward(blk.ln2, x2)
    let ffn_out = retnet_ffn(blk, normed2)
    let x3 = ret_vec_add(x2, ffn_out)
    return [x3, new_states]
}

// ===================================================================
//  RetNet State — container for multi-layer per-head states
// ===================================================================

struct RetNetState {
    n_layers: int,
    n_heads: int,
    head_dim: int,
    layer_states: array
}

fn create_retnet_state(n_layers, n_heads, head_dim) {
    let mut ls = []
    for _l in 0..n_layers {
        let mut hs = []
        for _h in 0..n_heads {
            hs = hs + [ret_mat_zeros(head_dim, head_dim)]
        }
        ls = ls + [hs]
    }
    return RetNetState {
        n_layers: n_layers,
        n_heads: n_heads,
        head_dim: head_dim,
        layer_states: ls
    }
}

// ===================================================================
//  Multi-layer RetNet stack
// ===================================================================

struct RetNetStack {
    n_layers: int,
    d_model: int,
    n_heads: int,
    ff_dim: int,
    blocks: array,
    ln_out: RetLayerNorm
}

fn create_retnet_stack(n_layers, d_model, n_heads, ff_dim, seed) {
    let mut blocks = []
    for l in 0..n_layers {
        blocks = blocks + [create_retnet_block(d_model, n_heads, ff_dim, seed + l * 5000)]
    }
    return RetNetStack {
        n_layers: n_layers,
        d_model: d_model,
        n_heads: n_heads,
        ff_dim: ff_dim,
        blocks: blocks,
        ln_out: create_ret_layer_norm(d_model)
    }
}

// Stack parallel forward (full sequence)
fn retnet_stack_parallel(stack, xs) {
    let mut h = xs
    for l in 0..stack.n_layers {
        h = retnet_block_parallel(stack.blocks[l], h)
    }
    let seq_len = len(h)
    let mut outputs = []
    for t in 0..seq_len {
        outputs = outputs + [ret_layer_norm_forward(stack.ln_out, h[t])]
    }
    return outputs
}

// Stack recurrent step (single token)
// Returns: [output, new_state]
fn retnet_stack_recurrent_step(stack, x, state) {
    let mut h = x
    let mut new_ls = []
    for l in 0..stack.n_layers {
        let res = retnet_block_recurrent_step(stack.blocks[l], h, state.layer_states[l])
        h = res[0]
        new_ls = new_ls + [res[1]]
    }
    let out = ret_layer_norm_forward(stack.ln_out, h)
    let new_state = RetNetState {
        n_layers: state.n_layers,
        n_heads: state.n_heads,
        head_dim: state.head_dim,
        layer_states: new_ls
    }
    return [out, new_state]
}

// Stack recurrent forward (full sequence, token by token)
fn retnet_stack_recurrent(stack, xs) {
    let seq_len = len(xs)
    let n_heads = stack.n_heads
    let head_dim = stack.d_model / n_heads
    let mut state = create_retnet_state(stack.n_layers, n_heads, head_dim)
    let mut outputs = []
    for t in 0..seq_len {
        let res = retnet_stack_recurrent_step(stack, xs[t], state)
        outputs = outputs + [res[0]]
        state = res[1]
    }
    return outputs
}

// ===================================================================
//  Embedding / un-embedding
// ===================================================================

fn ret_embed(token_id, d_model, seed) {
    let mut v = []
    for i in 0..d_model {
        let h = (token_id * 137 + i * 311 + seed) % 10007
        let val = (to_float(h) / 10007.0 - 0.5) * 0.1
        v = v + [val]
    }
    return v
}

fn ret_unembed(h, vocab_size, d_model, seed) {
    let mut logits = []
    for v in 0..vocab_size {
        let mut score = 0.0
        for i in 0..d_model {
            let w_h = (v * 137 + i * 311 + seed + 999) % 10007
            let w = (to_float(w_h) / 10007.0 - 0.5) * 0.1
            score = score + h[i] * w
        }
        logits = logits + [score]
    }
    return logits
}

fn ret_embed_seq(token_ids, d_model, seed) {
    let n = len(token_ids)
    let mut xs = []
    for t in 0..n {
        xs = xs + [ret_embed(token_ids[t], d_model, seed)]
    }
    return xs
}

// ===================================================================
//  Softmax / Argmax
// ===================================================================

@pure
fn ret_softmax(logits) {
    let n = len(logits)
    let mut mx = logits[0]
    for i in 1..n { if logits[i] > mx { mx = logits[i] } }
    let mut exps = ret_zeros(n)
    let mut z = 0.0
    for i in 0..n {
        exps[i] = ret_exp(logits[i] - mx)
        z = z + exps[i]
    }
    let mut out = ret_zeros(n)
    for i in 0..n { out[i] = exps[i] / z }
    return out
}

@pure
fn ret_argmax(logits) {
    let n = len(logits)
    let mut best = 0
    let mut best_v = logits[0]
    for i in 1..n {
        if logits[i] > best_v {
            best_v = logits[i]
            best = i
        }
    }
    return best
}

// ===================================================================
//  Generation — greedy, using recurrent mode (O(1) per step)
// ===================================================================

fn retnet_generate(stack, start_tokens, n_gen, vocab_size, emb_seed) {
    let d = stack.d_model
    let n_heads = stack.n_heads
    let head_dim = d / n_heads
    let mut state = create_retnet_state(stack.n_layers, n_heads, head_dim)
    // Prefill
    let n_prompt = len(start_tokens)
    let mut last_out = ret_zeros(d)
    for t in 0..n_prompt {
        let emb = ret_embed(start_tokens[t], d, emb_seed)
        let res = retnet_stack_recurrent_step(stack, emb, state)
        last_out = res[0]
        state = res[1]
    }
    // Generate
    let mut generated = []
    for _g in 0..n_gen {
        let logits = ret_unembed(last_out, vocab_size, d, emb_seed)
        let next_id = ret_argmax(logits)
        generated = generated + [next_id]
        let emb = ret_embed(next_id, d, emb_seed)
        let res = retnet_stack_recurrent_step(stack, emb, state)
        last_out = res[0]
        state = res[1]
    }
    return generated
}

// ===================================================================
//  Training mode — parallel over full sequence
// ===================================================================

fn retnet_train_forward(stack, token_ids, vocab_size, emb_seed) {
    let d = stack.d_model
    let seq_len = len(token_ids)
    let xs = ret_embed_seq(token_ids, d, emb_seed)
    let outs = retnet_stack_parallel(stack, xs)
    let mut all_logits = []
    for t in 0..seq_len {
        let logits = ret_unembed(outs[t], vocab_size, d, emb_seed)
        all_logits = all_logits + [logits]
    }
    return all_logits
}

// ===================================================================
//  Cross-entropy loss
// ===================================================================

@pure
fn ret_cross_entropy(logits, target) {
    let probs = ret_softmax(logits)
    let p = probs[target]
    let safe_p = if p < 1.0e-10 { 1.0e-10 } else { p }
    return 0.0 - ret_log(safe_p)
}

// ===================================================================
//  Param count
// ===================================================================

fn retnet_param_count(stack) {
    let d = stack.d_model
    let nh = stack.n_heads
    let hd = d / nh
    let ff = stack.ff_dim
    let n = stack.n_layers
    // Per head: 3 * hd*hd (W_q, W_k, W_v)
    let head_params = 3 * hd * hd
    // MSR: n_heads * head_params + 2 * d*d (W_o, W_g)
    let msr_params = nh * head_params + 2 * d * d
    // FFN: ff*d + d*ff
    let ffn_params = ff * d + d * ff
    // LN: 2 * (2*d)
    let ln_params = 4 * d
    let per_block = msr_params + ffn_params + ln_params
    let total = n * per_block + 2 * d
    return total
}

println("[retnet] loaded — retention + parallel/recurrent/chunkwise + multi-scale + gated + RetNet block + stack + generate")
