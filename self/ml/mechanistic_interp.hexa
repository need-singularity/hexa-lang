// ═══════════════════════════════════════════════════════════════════
//  self/ml/mechanistic_interp.hexa — pure Hexa mechanistic interpretability
//
//  Activation patching, logit lens, attention head importance,
//  linear probe training/eval, causal tracing.
//
//  AI-NATIVE: all pure Hexa, zero FFI/C dependency.
//  Designed for post-hoc analysis of transformer internals.
// ═══════════════════════════════════════════════════════════════════

// ── helpers ──────────────────────────────────────────────────────

@pure
fn _zeros1(n) {
    let mut v = []
    let mut i = 0
    while i < n {
        v.push(0.0)
        i = i + 1
    }
    return v
}

@pure
fn _dot(a, b, n) {
    let mut s = 0.0
    let mut i = 0
    while i < n {
        s = s + a[i] * b[i]
        i = i + 1
    }
    return s
}

@pure
fn _exp_approx(x) {
    // clamp to avoid overflow
    let mut v = x
    if v > 20.0 { v = 20.0 }
    if v < -20.0 { v = -20.0 }
    // Taylor series exp around 0, 12 terms
    let mut result = 1.0
    let mut term = 1.0
    let mut i = 1
    while i <= 12 {
        term = term * v / to_float(i)
        result = result + term
        i = i + 1
    }
    return result
}

@pure
fn _sigmoid(x) {
    return 1.0 / (1.0 + _exp_approx(0.0 - x))
}

@pure
fn _abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

// ═══════════════════════════════════════════════════════════════════
//  1. activation_patching
//     Replace activations at specified indices from corrupt into clean.
// ═══════════════════════════════════════════════════════════════════
@pure
pub fn activation_patching(clean_act, corrupt_act, patch_indices) {
    let n = len(clean_act)
    let mut result = []
    let mut i = 0
    while i < n {
        // check if i is in patch_indices
        let mut patched = false
        let mut j = 0
        let np = len(patch_indices)
        while j < np {
            if patch_indices[j] == i {
                patched = true
            }
            j = j + 1
        }
        if patched {
            result.push(corrupt_act[i])
        } else {
            result.push(clean_act[i])
        }
        i = i + 1
    }
    return result
}

// ═══════════════════════════════════════════════════════════════════
//  2. logit_lens
//     Project each layer's hidden states through unembedding matrix.
//     hidden_states: [num_layers][hidden_dim]
//     unembedding:   [vocab_size][hidden_dim]
//     returns:       [num_layers][vocab_size]
// ═══════════════════════════════════════════════════════════════════
@pure
pub fn logit_lens(hidden_states, unembedding) {
    let num_layers = len(hidden_states)
    let vocab_size = len(unembedding)
    let hidden_dim = len(hidden_states[0])
    let mut result = []
    let mut layer = 0
    while layer < num_layers {
        let h = hidden_states[layer]
        let mut logits = []
        let mut v = 0
        while v < vocab_size {
            logits.push(_dot(unembedding[v], h, hidden_dim))
            v = v + 1
        }
        result.push(logits)
        layer = layer + 1
    }
    return result
}

// ═══════════════════════════════════════════════════════════════════
//  3. attention_head_importance
//     Importance = sum(|attn_weight * grad|) per head.
//     attn_weights: [num_heads][seq_len] (flattened per head)
//     grad:         [num_heads][seq_len] (same shape)
//     returns:      [num_heads] importance scores
// ═══════════════════════════════════════════════════════════════════
@pure
pub fn attention_head_importance(attn_weights, grad) {
    let num_heads = len(attn_weights)
    let mut scores = []
    let mut h = 0
    while h < num_heads {
        let seq_len = len(attn_weights[h])
        let mut score = 0.0
        let mut s = 0
        while s < seq_len {
            score = score + _abs(attn_weights[h][s] * grad[h][s])
            s = s + 1
        }
        scores.push(score)
        h = h + 1
    }
    return scores
}

// ═══════════════════════════════════════════════════════════════════
//  4. probe_train
//     Train a linear probe (logistic regression) on activations.
//     activations: [num_samples][dim]
//     labels:      [num_samples] (0 or 1)
//     lr:          learning rate
//     steps:       number of SGD steps
//     returns:     [dim] weight vector
// ═══════════════════════════════════════════════════════════════════
@pure
pub fn probe_train(activations, labels, lr, steps) {
    let num_samples = len(activations)
    let dim = len(activations[0])
    let mut weights = _zeros1(dim)

    let mut step = 0
    while step < steps {
        // accumulate gradient over all samples
        let mut grad = _zeros1(dim)
        let mut si = 0
        while si < num_samples {
            let act = activations[si]
            let logit = _dot(weights, act, dim)
            let pred = _sigmoid(logit)
            let err = pred - to_float(labels[si])
            let mut d = 0
            while d < dim {
                grad[d] = grad[d] + err * act[d]
                d = d + 1
            }
            si = si + 1
        }
        // SGD update
        let inv_n = 1.0 / to_float(num_samples)
        let mut d = 0
        while d < dim {
            weights[d] = weights[d] - lr * grad[d] * inv_n
            d = d + 1
        }
        step = step + 1
    }
    return weights
}

// ═══════════════════════════════════════════════════════════════════
//  5. probe_accuracy
//     Evaluate probe: predict class from sign of dot(w, act).
//     weights:     [dim]
//     activations: [num_samples][dim]
//     labels:      [num_samples] (0 or 1)
//     returns:     accuracy in [0.0, 1.0]
// ═══════════════════════════════════════════════════════════════════
@pure
pub fn probe_accuracy(weights, activations, labels) {
    let num_samples = len(activations)
    let dim = len(weights)
    let mut correct = 0
    let mut i = 0
    while i < num_samples {
        let logit = _dot(weights, activations[i], dim)
        let mut pred = 0
        if logit >= 0.0 { pred = 1 }
        if pred == labels[i] {
            correct = correct + 1
        }
        i = i + 1
    }
    return to_float(correct) / to_float(num_samples)
}

// ═══════════════════════════════════════════════════════════════════
//  6. causal_trace
//     Measure logit difference when corrupting one position and
//     restoring at a specific layer.
//
//     model_fn:      fn(input, corrupt_pos, restore_layer) -> float
//                    Returns the logit difference for this configuration.
//     input:         [int] token ids
//     corrupt_pos:   int position to corrupt
//     restore_layer: int layer at which to restore clean activation
//     returns:       float logit difference
//
//     The actual corruption/restoration logic lives in model_fn,
//     since it requires model internals. This function provides
//     the tracing protocol: clean_logit - corrupted_logit + restored_logit.
// ═══════════════════════════════════════════════════════════════════
pub fn causal_trace(model_fn, input, corrupt_pos, restore_layer) {
    return model_fn(input, corrupt_pos, restore_layer)
}
