// ===================================================================
//  self/ml/rag.hexa — Retrieval Augmented Generation Pipeline (pure Hexa)
//
//  Combines embedding, vector store, and LLM generation into a
//  complete RAG pipeline.
//
//  Public API:
//    index_documents(model, documents)                    → vector store
//    retrieve(store, model, query, top_k)                 → relevant docs
//    rag_generate(model, query, context_docs, config)     → augmented response
//    build_rag_prompt(query, context_docs, template)      → prompt string
//
//  Documents format: array of #{id, text, metadata}
//  Config: #{max_tokens, temperature, top_k_retrieve}
// ===================================================================

// ===================================================================
//  Document struct
// ===================================================================
struct Document {
    id: string,
    text: string,
    metadata: string
}

// ===================================================================
//  RAG config
// ===================================================================
struct RAGConfig {
    max_tokens: int,
    temperature: float,
    top_k_retrieve: int,
    prompt_template: string
}

fn default_rag_config() {
    return RAGConfig {
        max_tokens: 128,
        temperature: 0.7,
        top_k_retrieve: 3,
        prompt_template: "default"
    }
}

// ===================================================================
//  Build prompt template for RAG
//
//  Default template:
//    Context: {context}
//
//    Question: {query}
//
//    Answer:
// ===================================================================
fn build_rag_prompt(query, context_docs, template) {
    // Build context string from retrieved documents
    let mut context = ""
    let n = len(context_docs)
    let mut i = 0
    while i < n {
        let doc = context_docs[i]
        if i > 0 { context = context + "\n\n" }
        context = context + "[" + str(i + 1) + "] " + doc[1]
        i = i + 1
    }

    if template == "default" {
        let mut prompt = "Context:\n"
        prompt = prompt + context
        prompt = prompt + "\n\nQuestion: " + query
        prompt = prompt + "\n\nAnswer:"
        return prompt
    }

    if template == "concise" {
        let mut prompt = "Given the following information:\n"
        prompt = prompt + context
        prompt = prompt + "\n\nBriefly answer: " + query
        return prompt
    }

    if template == "detailed" {
        let mut prompt = "You are a helpful assistant. Use the following context to answer the question.\n\n"
        prompt = prompt + "Context:\n" + context
        prompt = prompt + "\n\nQuestion: " + query
        prompt = prompt + "\n\nProvide a detailed answer based on the context above:"
        return prompt
    }

    // Custom template: replace {context} and {query}
    let mut result = template
    // Simple string replace for {context} and {query}
    result = str_replace(result, "{context}", context)
    result = str_replace(result, "{query}", query)
    return result
}

// ===================================================================
//  Simple string replace (needle → replacement)
// ===================================================================
fn str_replace(haystack, needle, replacement) {
    let hn = len(haystack)
    let nn = len(needle)
    if nn == 0 { return haystack }
    let mut result = ""
    let mut i = 0
    while i < hn {
        let remaining = hn - i
        if remaining >= nn {
            let sub = haystack.substring(i, i + nn)
            if sub == needle {
                result = result + replacement
                i = i + nn
            } else {
                result = result + haystack.substring(i, i + 1)
                i = i + 1
            }
        } else {
            result = result + haystack.substring(i, i + 1)
            i = i + 1
        }
    }
    return result
}

// ===================================================================
//  Index documents: embed each document text, store in vector store
//
//  documents: array of [id, text, metadata_string]
//  Returns: VectorStore with all documents indexed
// ===================================================================
fn index_documents(model, documents) {
    let dim = model.dim
    let mut store = create_store(dim)
    let n = len(documents)
    let mut i = 0
    while i < n {
        let doc = documents[i]
        let id = doc[0]
        let text = doc[1]
        let metadata = doc[2]
        let vector = embed(model, text)
        store = store_add(store, id, vector, metadata)
        i = i + 1
    }
    return store
}

// ===================================================================
//  Retrieve: embed query → search vector store → return top docs
//
//  Returns: array of [id, score, metadata] sorted by relevance
// ===================================================================
fn retrieve(store, model, query, top_k) {
    let query_vector = embed(model, query)
    return store_search(store, query_vector, top_k)
}

// ===================================================================
//  Retrieve with text: returns [id, score, text] by looking up
//  the original documents from a document map
// ===================================================================
fn retrieve_with_text(store, model, query, top_k, doc_texts) {
    let results = retrieve(store, model, query, top_k)
    let n = len(results)
    let mut enriched = []
    let mut i = 0
    while i < n {
        let id = results[i][0]
        let score = results[i][1]
        // Look up text from doc_texts map
        let mut text = ""
        let nd = len(doc_texts)
        let mut j = 0
        while j < nd {
            if doc_texts[j][0] == id {
                text = doc_texts[j][1]
            }
            j = j + 1
        }
        enriched = enriched + [[id, score, text]]
        i = i + 1
    }
    return enriched
}

// ===================================================================
//  RAG Generate: retrieve context docs → build prompt → generate
//
//  For real LLM generation, this would call transformer_forward.
//  For testing, returns the constructed prompt (demonstrating the
//  full pipeline) since we may not have a GGUF model loaded.
//
//  model: embedding model (for retrieval)
//  query: user question
//  store: indexed vector store
//  doc_texts: array of [id, text] for looking up full document text
//  config: RAGConfig
//
//  Returns: #{prompt, context_docs, scores}
// ===================================================================
fn rag_generate(model, query, store, doc_texts, config) {
    let top_k = config.top_k_retrieve

    // Step 1: Retrieve relevant documents
    let search_results = retrieve(store, model, query, top_k)

    // Step 2: Enrich with text
    let n = len(search_results)
    let mut context_docs = []
    let mut scores = []
    let mut i = 0
    while i < n {
        let id = search_results[i][0]
        let score = search_results[i][1]
        scores = scores + [score]
        // Find document text
        let mut text = ""
        let nd = len(doc_texts)
        let mut j = 0
        while j < nd {
            if doc_texts[j][0] == id {
                text = doc_texts[j][1]
            }
            j = j + 1
        }
        context_docs = context_docs + [[id, text]]
        i = i + 1
    }

    // Step 3: Build augmented prompt
    let prompt = build_rag_prompt(query, context_docs, config.prompt_template)

    return [prompt, context_docs, scores]
}
