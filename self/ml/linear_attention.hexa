// ═══════════════════════════════════════════════════════════════
//  self/ml/linear_attention.hexa — Linear Attention (Performer/Linformer)
//
//  Implements O(N) attention approximations for long-sequence efficiency:
//    1. Performer  — FAVOR+ random feature map φ(x) that satisfies
//                    E[φ(q)·φ(k)] ≈ exp(q·k), enabling the reformulation
//                    Attn(Q,K,V) = φ(Q)·(φ(K)^T·V) / (φ(Q)·φ(K)^T·1)
//                    which is O(N·d·r) instead of O(N²·d).
//    2. Linformer  — projects K,V along the sequence axis with learned
//                    low-rank matrices E,F ∈ R^{k×N} so softmax runs on
//                    O(N·k·d) instead of O(N²·d).
//
//  Two feature maps for Performer:
//    A) Trig (cosine/sine) map   — the original Performer-style positive
//       orthogonal random features:
//         φ(x) = exp(-‖x‖²/2) * √(1/m) * [cos(w_i·x); sin(w_i·x)]
//       Unbiased estimator of softmax kernel exp(q·k) when w_i ~ N(0,I).
//    B) Positive exponential map (FAVOR+):
//         φ(x) = exp(-‖x‖²/2) * √(1/m) * exp(w_i·x)
//       Non-negative, reduces variance on attention softmax.
//
//  O(N) algorithm (un-normalized numerator):
//     K̃V_sum[d'][d] = Σ_j φ(K_j)[d'] * V_j[d]      (r × d matrix)
//     K̃_sum[d']    = Σ_j φ(K_j)[d']                (r vector)
//     Out_i[d]     = (φ(Q_i)·K̃V_sum)[d] / (φ(Q_i)·K̃_sum)
//
//  AI-NATIVE attrs:
//    @pure     — deterministic given seed
//    @hot      — called per forward step
//    @parallel — outer query loop is embarrassingly parallel
// ═══════════════════════════════════════════════════════════════

// ── helpers ──────────────────────────────────────────────────

fn la_zeros_2d(r, c) {
    let mut m = []
    for _i in 0..r {
        let mut row = []
        for _j in 0..c {
            row = row + [0.0]
        }
        m = m + [row]
    }
    return m
}

fn la_zeros_1d(n) {
    let mut v = []
    for _i in 0..n {
        v = v + [0.0]
    }
    return v
}

fn la_fabs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn la_max_f(a, b) {
    if a > b { return a }
    return b
}

// ═══════════════════════════════════════════════════════════════
//  Deterministic PRNG (LCG) — seedable pseudo-random for
//  reproducible feature matrices.
// ═══════════════════════════════════════════════════════════════
fn la_lcg_next(state) {
    // Numerical Recipes LCG: xn+1 = (a*xn + c) mod 2^31
    let a = 1103515245
    let c = 12345
    let m = 2147483648
    let nxt = (a * state + c) % m
    return nxt
}

fn la_rand_uniform(state) {
    // Returns (new_state, uniform in [0,1))
    let nxt = la_lcg_next(state)
    let u = (nxt * 1.0) / 2147483648.0
    return [nxt, u]
}

// Box-Muller transform: two uniforms -> one standard normal.
// To avoid log(0), clamp u1.
fn la_box_muller(u1, u2) {
    let mut x = u1
    if x < 1.0e-9 { x = 1.0e-9 }
    let r = sqrt(0.0 - 2.0 * ln(x))
    let two_pi = 6.283185307179586
    let theta = two_pi * u2
    return r * cos(theta)
}

// Draw next standard-normal variate from LCG state.
fn la_rand_normal(state) {
    let r1 = la_rand_uniform(state)
    let s1 = r1[0]
    let u1 = r1[1]
    let r2 = la_rand_uniform(s1)
    let s2 = r2[0]
    let u2 = r2[1]
    let z = la_box_muller(u1, u2)
    return [s2, z]
}

// ═══════════════════════════════════════════════════════════════
//  Random feature matrix W ∈ R^{m × d} with entries ~ N(0,1).
//  Each row is a projection vector.
// ═══════════════════════════════════════════════════════════════
@pure
fn la_random_projection(m, d, seed) {
    let mut W = la_zeros_2d(m, d)
    let mut state = seed
    for i in 0..m {
        for j in 0..d {
            let r = la_rand_normal(state)
            state = r[0]
            W[i][j] = r[1]
        }
    }
    return W
}

// ═══════════════════════════════════════════════════════════════
//  Trig feature map (Performer original).
//  φ(x)[2i]   = exp(-‖x‖²/2) * √(1/m) * cos(w_i·x)
//  φ(x)[2i+1] = exp(-‖x‖²/2) * √(1/m) * sin(w_i·x)
//  Length of φ(x) = 2·m.
//  Satisfies E[φ(q)·φ(k)] = exp(q·k) under w ~ N(0,I).
// ═══════════════════════════════════════════════════════════════
@pure
fn la_feature_map_trig(x, W) {
    let m = len(W)
    let d = len(W[0])

    // ‖x‖²
    let mut norm_sq = 0.0
    for k in 0..d {
        norm_sq = norm_sq + x[k] * x[k]
    }
    let envelope = exp(0.0 - 0.5 * norm_sq)
    let scale = 1.0 / sqrt(m * 1.0)

    let mut phi = la_zeros_1d(2 * m)
    for i in 0..m {
        let mut dot = 0.0
        for k in 0..d {
            dot = dot + W[i][k] * x[k]
        }
        phi[2 * i]     = envelope * scale * cos(dot)
        phi[2 * i + 1] = envelope * scale * sin(dot)
    }
    return phi
}

// ═══════════════════════════════════════════════════════════════
//  Positive exponential feature map (FAVOR+).
//  φ(x)[i] = exp(-‖x‖²/2) * √(1/m) * exp(w_i·x)
//  Length of φ(x) = m. Non-negative by construction.
// ═══════════════════════════════════════════════════════════════
@pure
fn la_feature_map_pos(x, W) {
    let m = len(W)
    let d = len(W[0])

    let mut norm_sq = 0.0
    for k in 0..d {
        norm_sq = norm_sq + x[k] * x[k]
    }
    let envelope = exp(0.0 - 0.5 * norm_sq)
    let scale = 1.0 / sqrt(m * 1.0)

    let mut phi = la_zeros_1d(m)
    for i in 0..m {
        let mut dot = 0.0
        for k in 0..d {
            dot = dot + W[i][k] * x[k]
        }
        phi[i] = envelope * scale * exp(dot)
    }
    return phi
}

// ═══════════════════════════════════════════════════════════════
//  Apply feature map φ row-wise to a matrix X ∈ R^{S×d}.
//  use_trig: true  -> trig map (output [S, 2m])
//            false -> positive map (output [S, m])
// ═══════════════════════════════════════════════════════════════
fn la_apply_feature_map(X, W, use_trig) {
    let S = len(X)
    let mut out = []
    for i in 0..S {
        if use_trig {
            out = out + [la_feature_map_trig(X[i], W)]
        } else {
            out = out + [la_feature_map_pos(X[i], W)]
        }
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
//  Naive softmax attention — reference implementation for variance
//  testing.  Scales Q by 1/√d so that Performer's kernel
//  exp(q'·k') approximates softmax(q·k/√d).
// ═══════════════════════════════════════════════════════════════
fn la_naive_attention(Q, K, V) {
    let S = len(Q)
    let d = len(Q[0])
    let dv = len(V[0])
    let inv_sqrt_d = 1.0 / sqrt(d * 1.0)

    let mut out = la_zeros_2d(S, dv)
    for i in 0..S {
        let mut scores = la_zeros_1d(S)
        let mut mx = 0.0 - 1.0e30
        for j in 0..S {
            let mut dot = 0.0
            for k in 0..d {
                dot = dot + Q[i][k] * K[j][k]
            }
            let s = dot * inv_sqrt_d
            scores[j] = s
            if s > mx { mx = s }
        }
        let mut sum_exp = 0.0
        let mut exps = la_zeros_1d(S)
        for j in 0..S {
            let e = exp(scores[j] - mx)
            exps[j] = e
            sum_exp = sum_exp + e
        }
        for k in 0..dv {
            let mut acc = 0.0
            for j in 0..S {
                acc = acc + exps[j] * V[j][k]
            }
            out[i][k] = acc / sum_exp
        }
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
//  Performer / FAVOR+ linear attention.
//
//  Step 1:  Scale Q by (1/d)^{1/4}, K by (1/d)^{1/4}.
//           This places the softmax temperature 1/√d inside the
//           kernel: φ(Q')·φ(K') approximates exp((q·k)/√d).
//  Step 2:  Compute feature rows Q' = φ(Q), K' = φ(K).
//  Step 3:  Accumulate K̃V (r×d_v) = K'^T · V   — O(N·r·d_v)
//           Accumulate K̃  (r)     = Σ K'_j    — O(N·r)
//  Step 4:  For each i:
//              numer = Q'_i · K̃V   (d_v)
//              denom = Q'_i · K̃    (scalar, clamped)
//              out_i = numer / denom
//           Total O(N·(r·d_v + r)) = O(N).
// ═══════════════════════════════════════════════════════════════
@hot @parallel
fn linear_attention_performer(Q, K, V, W, use_trig) {
    let S  = len(Q)
    let d  = len(Q[0])
    let dv = len(V[0])
    let scale = pow(d * 1.0, 0.0 - 0.25)

    // Scale Q and K
    let mut Qs = la_zeros_2d(S, d)
    let mut Ks = la_zeros_2d(S, d)
    for i in 0..S {
        for k in 0..d {
            Qs[i][k] = Q[i][k] * scale
            Ks[i][k] = K[i][k] * scale
        }
    }

    // Feature-map the scaled Q, K
    let Qp = la_apply_feature_map(Qs, W, use_trig)
    let Kp = la_apply_feature_map(Ks, W, use_trig)
    let r  = len(Qp[0])   // 2m for trig, m for positive

    // KV_sum[r][dv]
    let mut KV_sum = la_zeros_2d(r, dv)
    // K_sum[r]
    let mut K_sum = la_zeros_1d(r)
    for j in 0..S {
        for a in 0..r {
            let ka = Kp[j][a]
            K_sum[a] = K_sum[a] + ka
            for b in 0..dv {
                KV_sum[a][b] = KV_sum[a][b] + ka * V[j][b]
            }
        }
    }

    let mut out = la_zeros_2d(S, dv)
    for i in 0..S {
        // numer = Qp_i · KV_sum   (dv)
        let mut numer = la_zeros_1d(dv)
        for a in 0..r {
            let qa = Qp[i][a]
            for b in 0..dv {
                numer[b] = numer[b] + qa * KV_sum[a][b]
            }
        }
        // denom = Qp_i · K_sum   (scalar)
        let mut denom = 0.0
        for a in 0..r {
            denom = denom + Qp[i][a] * K_sum[a]
        }
        // Stabilize: clamp absolute value away from 0.
        let sign_denom = denom
        let mut safe = denom
        if la_fabs(safe) < 1.0e-12 {
            if sign_denom < 0.0 {
                safe = 0.0 - 1.0e-12
            } else {
                safe = 1.0e-12
            }
        }
        for b in 0..dv {
            out[i][b] = numer[b] / safe
        }
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
//  Causal Performer linear attention.
//
//  For autoregressive decoding we cannot pre-accumulate over all j.
//  Instead we stream K,V: for each position i we fold K_i,V_i into
//  running KV_sum and K_sum *before* reading out_i.  This preserves
//  O(N·r·d_v) cost while respecting the causal mask j ≤ i.
// ═══════════════════════════════════════════════════════════════
@hot
fn linear_attention_performer_causal(Q, K, V, W, use_trig) {
    let S  = len(Q)
    let d  = len(Q[0])
    let dv = len(V[0])
    let scale = pow(d * 1.0, 0.0 - 0.25)

    let mut Qs = la_zeros_2d(S, d)
    let mut Ks = la_zeros_2d(S, d)
    for i in 0..S {
        for k in 0..d {
            Qs[i][k] = Q[i][k] * scale
            Ks[i][k] = K[i][k] * scale
        }
    }
    let Qp = la_apply_feature_map(Qs, W, use_trig)
    let Kp = la_apply_feature_map(Ks, W, use_trig)
    let r  = len(Qp[0])

    let mut KV_sum = la_zeros_2d(r, dv)
    let mut K_sum  = la_zeros_1d(r)
    let mut out    = la_zeros_2d(S, dv)

    for i in 0..S {
        // fold in position i (causal: j ≤ i)
        for a in 0..r {
            let ka = Kp[i][a]
            K_sum[a] = K_sum[a] + ka
            for b in 0..dv {
                KV_sum[a][b] = KV_sum[a][b] + ka * V[i][b]
            }
        }
        // read out_i
        let mut numer = la_zeros_1d(dv)
        for a in 0..r {
            let qa = Qp[i][a]
            for b in 0..dv {
                numer[b] = numer[b] + qa * KV_sum[a][b]
            }
        }
        let mut denom = 0.0
        for a in 0..r {
            denom = denom + Qp[i][a] * K_sum[a]
        }
        let sign_denom = denom
        let mut safe = denom
        if la_fabs(safe) < 1.0e-12 {
            if sign_denom < 0.0 {
                safe = 0.0 - 1.0e-12
            } else {
                safe = 1.0e-12
            }
        }
        for b in 0..dv {
            out[i][b] = numer[b] / safe
        }
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
//  Linformer — low-rank sequence projection.
//
//  Given projection matrices E ∈ R^{k×S}, F ∈ R^{k×S}:
//     K̂ = E · K    (k × d)
//     V̂ = F · V    (k × d_v)
//  Then softmax attention runs on Q (S×d) × K̂^T (d×k) which costs
//  O(N·k·d) instead of O(N²·d).
//
//  This implementation exposes:
//    la_linformer_random_projection(k, S, seed)   — build a random E
//    linear_attention_linformer(Q, K, V, E, F)    — forward
// ═══════════════════════════════════════════════════════════════

@pure
fn la_linformer_random_projection(k, S, seed) {
    // Gaussian projection with 1/√k scaling (Johnson-Lindenstrauss style).
    let mut P = la_zeros_2d(k, S)
    let mut state = seed
    let inv = 1.0 / sqrt(k * 1.0)
    for i in 0..k {
        for j in 0..S {
            let r = la_rand_normal(state)
            state = r[0]
            P[i][j] = r[1] * inv
        }
    }
    return P
}

@hot
fn linear_attention_linformer(Q, K, V, E, F) {
    let S  = len(Q)
    let d  = len(Q[0])
    let dv = len(V[0])
    let k  = len(E)      // E: [k, S], F: [k, S]
    let inv_sqrt_d = 1.0 / sqrt(d * 1.0)

    // K_hat = E · K     (k × d)
    let mut K_hat = la_zeros_2d(k, d)
    for a in 0..k {
        for j in 0..d {
            let mut acc = 0.0
            for s in 0..S {
                acc = acc + E[a][s] * K[s][j]
            }
            K_hat[a][j] = acc
        }
    }
    // V_hat = F · V     (k × dv)
    let mut V_hat = la_zeros_2d(k, dv)
    for a in 0..k {
        for j in 0..dv {
            let mut acc = 0.0
            for s in 0..S {
                acc = acc + F[a][s] * V[s][j]
            }
            V_hat[a][j] = acc
        }
    }

    // scores = Q · K_hat^T · (1/√d)      (S × k)
    let mut out = la_zeros_2d(S, dv)
    for i in 0..S {
        let mut scores = la_zeros_1d(k)
        let mut mx = 0.0 - 1.0e30
        for a in 0..k {
            let mut dot = 0.0
            for j in 0..d {
                dot = dot + Q[i][j] * K_hat[a][j]
            }
            let s = dot * inv_sqrt_d
            scores[a] = s
            if s > mx { mx = s }
        }
        let mut sum_exp = 0.0
        let mut exps = la_zeros_1d(k)
        for a in 0..k {
            let e = exp(scores[a] - mx)
            exps[a] = e
            sum_exp = sum_exp + e
        }
        // out_i = (softmax · V_hat)
        for j in 0..dv {
            let mut acc = 0.0
            for a in 0..k {
                acc = acc + exps[a] * V_hat[a][j]
            }
            out[i][j] = acc / sum_exp
        }
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
//  Utility: Frobenius-norm distance between two matrices — for
//  numerical approximation tests.
// ═══════════════════════════════════════════════════════════════
fn la_frob_diff(A, B) {
    let rows = len(A)
    let mut acc = 0.0
    for i in 0..rows {
        let cols = len(A[i])
        for j in 0..cols {
            let d = A[i][j] - B[i][j]
            acc = acc + d * d
        }
    }
    return sqrt(acc)
}
