// ---- map / filter / fold ------------------------------------------------
@pure
pub fn array_map_pure(arr, f) {
    let mut out = []
    let n = len(arr)
    let mut i = 0
    while i < n {
        out.push(f(arr[i]))
        i = i + 1
    }
    return out
}

@pure
pub fn array_map_indexed_pure(arr, f) {
    let mut out = []
    let n = len(arr)
    let mut i = 0
    while i < n {
        out.push(f(i, arr[i]))
        i = i + 1
    }
    return out
}

@pure
pub fn array_filter_pure(arr, pred) {
    let mut out = []
    let n = len(arr)
    let mut i = 0
    while i < n {
        let v = arr[i]
        if pred(v) { out.push(v) }
        i = i + 1
    }
    return out
}

@pure
pub fn array_fold_pure(arr, init, f) {
    let mut acc = init
    let n = len(arr)
    let mut i = 0
    while i < n {
        acc = f(acc, arr[i])
        i = i + 1
    }
    return acc
}

@pure
pub fn array_fold_right_pure(arr, init, f) {
    let mut acc = init
    let n = len(arr)
    let mut i = n - 1
    while i >= 0 {
        acc = f(arr[i], acc)
        i = i - 1
    }
    return acc
}

// ---- any / all / count -------------------------------------------------
@pure
pub fn array_any_pure(arr, pred) {
    let n = len(arr)
    let mut i = 0
    while i < n {
        if pred(arr[i]) { return true }
        i = i + 1
    }
    return false
}

@pure
pub fn array_all_pure(arr, pred) {
    let n = len(arr)
    let mut i = 0
    while i < n {
        if !pred(arr[i]) { return false }
        i = i + 1
    }
    return true
}

@pure
pub fn array_count_pure(arr, pred) {
    let mut c = 0
    let n = len(arr)
    let mut i = 0
    while i < n {
        if pred(arr[i]) { c = c + 1 }
        i = i + 1
    }
    return c
}

// ---- find / position ---------------------------------------------------
@pure
pub fn array_find_pure(arr, pred) {
    let n = len(arr)
    let mut i = 0
    while i < n {
        let v = arr[i]
        if pred(v) { return v }
        i = i + 1
    }
    return void
}

@pure
pub fn array_position_pure(arr, pred) {
    let n = len(arr)
    let mut i = 0
    while i < n {
        if pred(arr[i]) { return i }
        i = i + 1
    }
    return -1
}

// ---- pop / drop / take -------------------------------------------------
@pure
pub fn array_pop_pure(arr) {
    let n = len(arr)
    if n == 0 { return [void, []] }
    let mut rest = []
    let mut i = 0
    while i < n - 1 {
        rest.push(arr[i])
        i = i + 1
    }
    return [arr[n - 1], rest]
}

@pure
pub fn array_drop_pure(arr, k) {
    if k <= 0 { return arr }
    let n = len(arr)
    if k >= n { return [] }
    let mut out = []
    let mut i = k
    while i < n {
        out.push(arr[i])
        i = i + 1
    }
    return out
}

@pure
pub fn array_take_pure(arr, k) {
    let n = len(arr)
    let m = if k < n { k } else { n }
    let mut out = []
    let mut i = 0
    while i < m {
        out.push(arr[i])
        i = i + 1
    }
    return out
}

// ---- sum / product / min / max -----------------------------------------
@pure
pub fn array_sum_pure(arr) {
    let mut s = 0
    let n = len(arr)
    let mut i = 0
    while i < n {
        s = s + arr[i]
        i = i + 1
    }
    return s
}

@pure
pub fn array_product_pure(arr) {
    if len(arr) == 0 { return 1 }
    let mut p = 1
    let n = len(arr)
    let mut i = 0
    while i < n {
        p = p * arr[i]
        i = i + 1
    }
    return p
}

@pure
pub fn array_min_pure(arr) {
    if len(arr) == 0 { return void }
    let mut m = arr[0]
    let n = len(arr)
    let mut i = 1
    while i < n {
        if arr[i] < m { m = arr[i] }
        i = i + 1
    }
    return m
}

@pure
pub fn array_max_pure(arr) {
    if len(arr) == 0 { return void }
    let mut m = arr[0]
    let n = len(arr)
    let mut i = 1
    while i < n {
        if arr[i] > m { m = arr[i] }
        i = i + 1
    }
    return m
}

// ---- sort (stable insertion + comparator) ------------------------------
@pure
pub fn array_sort_by_pure(arr, cmp) {
    let n = len(arr)
    let mut out = []
    let mut i = 0
    while i < n {
        out.push(arr[i])
        i = i + 1
    }
    let mut k = 1
    while k < n {
        let cur = out[k]
        let mut j = k - 1
        while j >= 0 {
            if cmp(out[j], cur) <= 0 { j = -1 } else {
                let tmp = out[j]
                let mut next = []
                let mut t = 0
                while t < n {
                    if t == j + 1 { next.push(tmp) }
                    else if t == j { next.push(out[j + 1]) }
                    else { next.push(out[t]) }
                    t = t + 1
                }
                out = next
                j = j - 1
            }
        }
        k = k + 1
    }
    return out
}

@pure
fn default_cmp(a, b) {
    if a < b { return -1 }
    if a > b { return 1 }
    return 0
}

@pure
pub fn array_sort_pure(arr) {
    return array_sort_by_pure(arr, default_cmp)
}

// --- END INLINED from self/runtime/array_higher_pure.hexa ---

let mut pass = 0
let mut fail = 0

fn check(name, cond) {
    if cond { pass = pass + 1 } else {
        fail = fail + 1
        println("[FAIL] " + name)
    }
}

fn eq(name, a, b) {
    if a == b { pass = pass + 1 } else {
        fail = fail + 1
        println("[FAIL] " + name + " got " + to_string(a) + " want " + to_string(b))
    }
}

fn eq_arr(name, a, b) {
    let na = len(a)
    let nb = len(b)
    if na != nb {
        fail = fail + 1
        println("[FAIL] " + name + " len " + to_string(na) + " vs " + to_string(nb))
        return
    }
    let mut i = 0
    while i < na {
        if a[i] != b[i] {
            fail = fail + 1
            println("[FAIL] " + name + " at " + to_string(i) + ": " + to_string(a[i]) + " vs " + to_string(b[i]))
            return
        }
        i = i + 1
    }
    pass = pass + 1
}

fn dbl(x) { return x * 2 }
fn is_even(x) { return x % 2 == 0 }
fn is_pos(x) { return x > 0 }
fn add(a, b) { return a + b }
fn mul(a, b) { return a * b }
fn gt5(x) { return x > 5 }
fn asc(a, b) { if a < b { return -1 } if a > b { return 1 } return 0 }
fn desc(a, b) { if a < b { return 1 } if a > b { return -1 } return 0 }

println("=== array_higher_pure test suite ===")

// ---- map ----
eq_arr("map dbl", array_map_pure([1, 2, 3], dbl), [2, 4, 6])
eq_arr("map empty", array_map_pure([], dbl), [])

fn indexed_add(i, v) { return i + v }
eq_arr("map_indexed", array_map_indexed_pure([10, 20, 30], indexed_add), [10, 21, 32])

// ---- filter ----
eq_arr("filter even", array_filter_pure([1, 2, 3, 4, 5, 6], is_even), [2, 4, 6])
eq_arr("filter empty", array_filter_pure([], is_even), [])
eq_arr("filter pos", array_filter_pure([-1, 2, -3, 4], is_pos), [2, 4])

// ---- fold ----
eq("fold sum", array_fold_pure([1, 2, 3, 4], 0, add), 10)
eq("fold product", array_fold_pure([1, 2, 3, 4], 1, mul), 24)
eq("fold empty init", array_fold_pure([], 42, add), 42)
eq("fold_right", array_fold_right_pure([1, 2, 3], 0, add), 6)

// ---- any / all / count ----
check("any >5 in [1,3,6]", array_any_pure([1, 3, 6], gt5))
check("any >5 in [1,3] false", !array_any_pure([1, 3], gt5))
check("any empty false", !array_any_pure([], gt5))
check("all pos", array_all_pure([1, 2, 3], is_pos))
check("all pos mixed", !array_all_pure([1, -2, 3], is_pos))
check("all empty true", array_all_pure([], is_pos))
eq("count even [1..6]", array_count_pure([1, 2, 3, 4, 5, 6], is_even), 3)
eq("count pred none", array_count_pure([1, 3, 5], is_even), 0)

// ---- find / position ----
eq("find first even", array_find_pure([1, 3, 4, 5, 6], is_even), 4)
eq("position first even", array_position_pure([1, 3, 4, 5, 6], is_even), 2)
eq("position none", array_position_pure([1, 3, 5], is_even), -1)

// ---- pop / drop / take ----
let p = array_pop_pure([1, 2, 3])
eq("pop head", p[0], 3)
eq_arr("pop tail", p[1], [1, 2])

let pe = array_pop_pure([])
check("pop empty head void", type_of(pe[0]) == "void")
eq_arr("pop empty tail", pe[1], [])

eq_arr("drop 2", array_drop_pure([1, 2, 3, 4, 5], 2), [3, 4, 5])
eq_arr("drop all", array_drop_pure([1, 2], 5), [])
eq_arr("drop zero", array_drop_pure([1, 2], 0), [1, 2])
eq_arr("take 2", array_take_pure([1, 2, 3, 4, 5], 2), [1, 2])
eq_arr("take more than len", array_take_pure([1, 2], 5), [1, 2])

// ---- sum / product / min / max ----
eq("sum", array_sum_pure([1, 2, 3, 4]), 10)
eq("sum empty", array_sum_pure([]), 0)
eq("product", array_product_pure([2, 3, 4]), 24)
eq("product empty 1", array_product_pure([]), 1)
eq("min", array_min_pure([3, 1, 4, 1, 5]), 1)
eq("max", array_max_pure([3, 1, 4, 1, 5]), 5)
check("min empty void", type_of(array_min_pure([])) == "void")
check("max empty void", type_of(array_max_pure([])) == "void")

// ---- sort ----
eq_arr("sort empty", array_sort_pure([]), [])
eq_arr("sort single", array_sort_pure([42]), [42])
eq_arr("sort sorted", array_sort_pure([1, 2, 3]), [1, 2, 3])
eq_arr("sort reverse", array_sort_pure([3, 2, 1]), [1, 2, 3])
eq_arr("sort mixed", array_sort_pure([3, 1, 4, 1, 5, 9, 2, 6]), [1, 1, 2, 3, 4, 5, 6, 9])
eq_arr("sort_by desc", array_sort_by_pure([3, 1, 4, 1, 5], desc), [5, 4, 3, 1, 1])

println("===========================================================")
println("  Results: " + to_string(pass) + " passed, " + to_string(fail) + " failed")
println("===========================================================")
if fail == 0 { println("ALL PASS") } else { println("SOME FAIL") }
