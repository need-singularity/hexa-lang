// -- inlined from self/ml/once_for_all.hexa --
// codegen import not wired for test files

// ═══════════════════════════════════════════════════════════════════
//  self/ml/once_for_all.hexa — Once-For-All Network (#278)
//
//  Once-For-All (Cai et al. 2020) trains a single supernet that
//  supports many elastic settings:
//      elastic kernel  (3 / 5 / 7)
//      elastic depth   (2 / 3 / 4 layers)
//      elastic width   (0.25 / 0.5 / 0.75 / 1.0 channels)
//  The "sandwich rule" samples smallest + largest + 2 random subnets
//  per training step.
//
//  Our mini-supernet is fully numerical:
//      layer i  ≔  y = ReLU( y · w_i + b_i )   (scalar per channel)
//      kernel   : replicate input over k taps (averaged)
//      depth    : drop tail layers
//      width    : scale active channel count
//
//  API:
//    ofa_build_supernet(depth_max, width_max)                -> #{"W","B"}
//    ofa_kernels()                                           -> [int]
//    ofa_depths()                                            -> [int]
//    ofa_widths()                                            -> [float]
//    ofa_sample_subnet(seed)                                 -> #{"kernel","depth","width_mult"}
//    ofa_sandwich_batch(seed)                                -> [subnet]   // 4 subnets
//    ofa_forward_subnet(inp, net, subnet)                    -> [float]
//    ofa_loss_subnet(inp, target, net, subnet)               -> float
//    ofa_sandwich_loss(inp, target, net, seed)               -> float
//    ofa_train_step(inp, target, net, lr, seed)              -> #{"net","loss"}
//    ofa_count_params(net, subnet)                           -> int
// ═══════════════════════════════════════════════════════════════════

fn ofa_abs(inp) {
    if inp < 0.0 { return 0.0 - inp }
    return inp
}

fn ofa_zeros(n) {
    let mut v = []
    let mut _i = 0
    while _i < n {
    return v
        _i = _i + 1
}

fn ofa_zeros_mat(m, n) {
    let mut M = []
    let mut _i = 0
    while _i < m {
    return M
        _i = _i + 1
}

fn ofa_relu(inp) {
    if inp < 0.0 { return 0.0 }
    return inp
}

fn ofa_hash(seed, idx) {
    let mut h = (seed + 1) * 2654435761 + (idx + 1) * 1315423911
    h = h % 1000003
    if h < 0 { h = 0 - h }
    return h
}

fn ofa_rand01(seed, idx) {
    let h = ofa_hash(seed, idx)
    return to_float(h % 10000) / 10000.0
}

fn ofa_rand_int(seed, idx, modulo) {
    let h = ofa_hash(seed, idx)
    return h % modulo
}

// ═══════════════════════════════════════════════════════════════════
//  1. Supernet weights
//
//  W: [depth_max][width_max][width_max]   matrix per layer
//  B: [depth_max][width_max]
//
//  For simplicity we initialise deterministically.
// ═══════════════════════════════════════════════════════════════════

@pure
fn ofa_build_supernet(depth_max, width_max) {
    let mut W = []
    let mut B = []
    let mut d = 0
    while d < depth_max {
        let mut M = ofa_zeros_mat(width_max, width_max)
        for i in 0..width_max {
            for j in 0..width_max {
                // small deterministic init
                M[i][j] = 0.1 * to_float(((d + 1) * (i + 1) * (j + 1)) % 7) - 0.3
            }
        }
        W = W + [M]
        let mut b = ofa_zeros(width_max)
        for i in 0..width_max {
            b[i] = 0.01 * to_float(((d + 1) * (i + 2)) % 5)
        }
        B = B + [b]
        d = d + 1
    }
    return #{
        "W": W,
        "B": B,
        "depth_max": depth_max,
        "width_max": width_max
    }
}

// ═══════════════════════════════════════════════════════════════════
//  2. Elastic choice sets
// ═══════════════════════════════════════════════════════════════════

@pure
fn ofa_kernels() {
    return [3, 5, 7]
}

@pure
fn ofa_depths() {
    return [2, 3, 4]
}

@pure
fn ofa_widths() {
    return [0.25, 0.5, 0.75, 1.0]
}

// ═══════════════════════════════════════════════════════════════════
//  3. Subnet sampling
//
//  Returns #{"kernel", "depth", "width_mult"}
// ═══════════════════════════════════════════════════════════════════

@pure
fn ofa_sample_subnet(seed) {
    let ks = ofa_kernels()
    let ds = ofa_depths()
    let ws = ofa_widths()
    let ki = ofa_rand_int(seed, 0, len(ks))
    let di = ofa_rand_int(seed, 1, len(ds))
    let wi = ofa_rand_int(seed, 2, len(ws))
    return #{
        "kernel": ks[ki],
        "depth": ds[di],
        "width_mult": ws[wi]
    }
}

// ═══════════════════════════════════════════════════════════════════
//  4. Sandwich rule — smallest, largest, + 2 random
// ═══════════════════════════════════════════════════════════════════

@pure
fn ofa_sandwich_batch(seed) {
    let ks = ofa_kernels()
    let ds = ofa_depths()
    let ws = ofa_widths()
    let smallest = #{
        "kernel": ks[0],
        "depth": ds[0],
        "width_mult": ws[0]
    }
    let largest = #{
        "kernel": ks[len(ks) - 1],
        "depth": ds[len(ds) - 1],
        "width_mult": ws[len(ws) - 1]
    }
    let r1 = ofa_sample_subnet(seed + 100)
    let r2 = ofa_sample_subnet(seed + 200)
    return [smallest, largest, r1, r2]
}

// ═══════════════════════════════════════════════════════════════════
//  5. Forward through a chosen subnet
//
//  Width mult => active channels = ⌈width_max · wm⌉
//  Depth      => use first `depth` layers of W
//  Kernel k   => average inp over k duplicate taps (simulated)
// ═══════════════════════════════════════════════════════════════════

fn ofa_active_width(width_max, width_mult) {
    let mut n = int(to_float(width_max) * width_mult + 0.5)
    if n < 1 { n = 1 }
    if n > width_max { n = width_max }
    return n
}

@pure
fn ofa_forward_subnet(inp, net, subnet) {
    let width_max = net["width_max"]
    let depth = subnet["depth"]
    let kernel = subnet["kernel"]
    let active = ofa_active_width(width_max, subnet["width_mult"])
    // Pad/truncate input to `active` channels
    let mut h = ofa_zeros(active)
    let d_in = len(inp)
    let mut i = 0
    while i < active {
        if i < d_in { h[i] = inp[i] }
        i = i + 1
    }
    // Kernel taps: average with a cyclic shift of h k times
    let mut kernel_out = ofa_zeros(active)
    let mut i = 0
    while i < active {
        let mut s = 0.0
        for t in 0..kernel {
            let idx = (i + t) % active
            s = s + h[idx]
        }
        kernel_out[i] = s / to_float(kernel)
        i = i + 1
    }
    h = kernel_out
    // Forward through `depth` layers
    let W = net["W"]
    let B = net["B"]
    let mut d = 0
    while d < depth {
        let mut new_h = ofa_zeros(active)
        for i in 0..active {
            let mut s = B[d][i]
            for j in 0..active {
                s = s + W[d][i][j] * h[j]
            }
            new_h[i] = ofa_relu(s)
        }
        h = new_h
        d = d + 1
    }
    return h
}

// ═══════════════════════════════════════════════════════════════════
//  6. Subnet loss — MSE to target (truncated/padded)
// ═══════════════════════════════════════════════════════════════════

@pure
fn ofa_loss_subnet(inp, target, net, subnet) {
    let out = ofa_forward_subnet(inp, net, subnet)
    let n_out = len(out)
    let n_tgt = len(target)
    let mut s = 0.0
    let mut count = 0
    let mut i = 0
    while i < n_out {
        if i < n_tgt {
            let e = out[i] - target[i]
            s = s + e * e
            count = count + 1
        }
        i = i + 1
    }
    if count == 0 { return 0.0 }
    return s / to_float(count)
}

// ═══════════════════════════════════════════════════════════════════
//  7. Sandwich loss — average over the 4 sandwich subnets
// ═══════════════════════════════════════════════════════════════════

@pure
fn ofa_sandwich_loss(inp, target, net, seed) {
    let batch = ofa_sandwich_batch(seed)
    let n = len(batch)
    let mut total = 0.0
    let mut i = 0
    while i < n {
        total = total + ofa_loss_subnet(inp, target, net, batch[i])
        i = i + 1
    }
    return total / to_float(n)
}

// ═══════════════════════════════════════════════════════════════════
//  8. Parameter counting for a subnet (depth × active_width²)
// ═══════════════════════════════════════════════════════════════════

@pure
fn ofa_count_params(net, subnet) {
    let width_max = net["width_max"]
    let active = ofa_active_width(width_max, subnet["width_mult"])
    let depth = subnet["depth"]
    return depth * active * active + depth * active
}

// ═══════════════════════════════════════════════════════════════════
//  9. Training step — finite-difference gradient on sandwich loss
// ═══════════════════════════════════════════════════════════════════

fn ofa_copy_net(net) {
    let depth_max = net["depth_max"]
    let width_max = net["width_max"]
    let W_src = net["W"]
    let B_src = net["B"]
    let mut W_dst = []
    let mut B_dst = []
    let mut d = 0
    while d < depth_max {
        let mut M = ofa_zeros_mat(width_max, width_max)
        for i in 0..width_max {
            for j in 0..width_max {
                M[i][j] = W_src[d][i][j]
            }
        }
        W_dst = W_dst + [M]
        let mut b = ofa_zeros(width_max)
        for i in 0..width_max { b[i] = B_src[d][i] }
        B_dst = B_dst + [b]
        d = d + 1
    }
    return #{
        "W": W_dst,
        "B": B_dst,
        "depth_max": depth_max,
        "width_max": width_max
    }
}

@hot
fn ofa_train_step(inp, target, net, lr, seed) {
    let depth_max = net["depth_max"]
    let width_max = net["width_max"]
    let base = ofa_sandwich_loss(inp, target, net, seed)
    let eps = 0.001
    let mut new_net = ofa_copy_net(net)
    // Gradient on W only (B left alone to keep compute cheap)
    let mut d = 0
    while d < depth_max {
        for i in 0..width_max {
            for j in 0..width_max {
                let mut perturbed = ofa_copy_net(net)
                perturbed["W"][d][i][j] = perturbed["W"][d][i][j] + eps
                let lp = ofa_sandwich_loss(inp, target, perturbed, seed)
                let g = (lp - base) / eps
                new_net["W"][d][i][j] = new_net["W"][d][i][j] - lr * g
            }
        }
        d = d + 1
    }
    return #{
        "net": new_net,
        "loss": base
    }
}

println("[once_for_all] loaded — elastic kernel/depth/width supernet + sandwich rule")


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs_(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx_(a, b, eps) { return fabs_(a - b) < eps }

println("=== Once-For-All (#278) Tests ===")

// ── T1 build supernet ─────────────────────────────────────────────
let net = ofa_build_supernet(4, 4)
check("T1 depth_max 4", net["depth_max"] == 4)
check("T1 width_max 4", net["width_max"] == 4)
check("T1 W[0] rows=4", len(net["W"][0]) == 4)
check("T1 W[0] cols=4", len(net["W"][0][0]) == 4)
check("T1 B[0] len=4", len(net["B"][0]) == 4)

// ── T2 kernels/depths/widths discrete sets ───────────────────────
let ks = ofa_kernels()
let ds = ofa_depths()
let ws = ofa_widths()
check("T2 3 kernels", len(ks) == 3)
check("T2 3 depths", len(ds) == 3)
check("T2 4 widths", len(ws) == 4)
check("T2 first kernel 3", ks[0] == 3)
check("T2 last kernel 7", ks[2] == 7)

// ── T3 sample subnet returns valid spec ──────────────────────────
let sub3 = ofa_sample_subnet(42)
check("T3 kernel valid",
      sub3["kernel"] == 3 || sub3["kernel"] == 5 || sub3["kernel"] == 7)
check("T3 depth valid",
      sub3["depth"] == 2 || sub3["depth"] == 3 || sub3["depth"] == 4)

// ── T4 sandwich batch has 4 subnets with min+max first ──────────
let sw = ofa_sandwich_batch(11)
check("T4 sandwich 4", len(sw) == 4)
check("T4 smallest kernel=3", sw[0]["kernel"] == 3)
check("T4 smallest depth=2", sw[0]["depth"] == 2)
check("T4 largest kernel=7", sw[1]["kernel"] == 7)
check("T4 largest depth=4", sw[1]["depth"] == 4)

// ── T5 forward returns active width channels ─────────────────────
let inp5 = [0.5, 0.3, -0.2, 0.1]
let sub5 = #{
    "kernel": 3,
    "depth": 2,
    "width_mult": 1.0
}
let o5 = ofa_forward_subnet(inp5, net, sub5)
check("T5 out len=4", len(o5) == 4)

// ── T6 smaller width produces fewer output channels ─────────────
let sub6 = #{
    "kernel": 3,
    "depth": 2,
    "width_mult": 0.5
}
let o6 = ofa_forward_subnet(inp5, net, sub6)
check("T6 out len=2", len(o6) == 2)

// ── T7 ReLU ensures output non-negative ─────────────────────────
let mut all_non_neg = true
let mut i = 0

while i < len(o5) {
    if o5[i] < 0.0 { all_non_neg = false }
}
check("T7 ReLU non-neg", all_non_neg)

// ── T8 loss subnet returns finite >= 0 ──────────────────────────
let target8 = [0.1, 0.1, 0.1, 0.1]
let l8 = ofa_loss_subnet(inp5, target8, net, sub5)
check("T8 loss >= 0", l8 >= 0.0)

// ── T9 sandwich loss >= 0 ───────────────────────────────────────
let sl9 = ofa_sandwich_loss(inp5, target8, net, 77)
check("T9 sandwich loss >= 0", sl9 >= 0.0)

// ── T10 param count scales with depth and width ────────────────
let sub_small = #{
    "kernel": 3,
    "depth": 2,
    "width_mult": 0.5
}
let sub_large = #{
    "kernel": 3,
    "depth": 4,
    "width_mult": 1.0
}
let p_small = ofa_count_params(net, sub_small)
let p_large = ofa_count_params(net, sub_large)
check("T10 large > small", p_large > p_small)

// ── T11 kernel averaging doesn't change constant input ─────────
// Constant input, width=1 -> all channels equal, kernel averaging
// should not change values at layer 0.  Use a degenerate depth=0
// style: depth=2, just check output finite.
check("T11 k=5 run", len(ofa_forward_subnet(inp5, net, #{
    "kernel": 5,
    "depth": 3,
    "width_mult": 1.0
})) == 4)

// ── T12 training step reduces sandwich loss ────────────────────
let base_loss = ofa_sandwich_loss(inp5, target8, net, 5)
let step = ofa_train_step(inp5, target8, net, 0.02, 5)
let new_loss = ofa_sandwich_loss(inp5, target8, step["net"], 5)
check("T12 step reduces loss", new_loss <= base_loss + 1.0e-6)

// ── T13 training step preserves shape of net ───────────────────
let new_net = step["net"]
check("T13 still depth 4", new_net["depth_max"] == 4)
check("T13 still width 4", new_net["width_max"] == 4)
check("T13 W shape", len(new_net["W"][0]) == 4)

println("")
println("=== Once-For-All test summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
