// ═══════════════════════════════════════════════════════════════════
//  test_once_for_all.hexa — Once-For-All Network (#278)
//
//  Run: PATH=/Users/ghost/.cargo/bin:$PATH ./hexa self/test_once_for_all.hexa
// ═══════════════════════════════════════════════════════════════════

import "ml/once_for_all.hexa"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs_(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx_(a, b, eps) { return fabs_(a - b) < eps }

println("=== Once-For-All (#278) Tests ===")

// ── T1 build supernet ─────────────────────────────────────────────
let net = ofa_build_supernet(4, 4)
check("T1 depth_max 4", net["depth_max"] == 4)
check("T1 width_max 4", net["width_max"] == 4)
check("T1 W[0] rows=4", len(net["W"][0]) == 4)
check("T1 W[0] cols=4", len(net["W"][0][0]) == 4)
check("T1 B[0] len=4", len(net["B"][0]) == 4)

// ── T2 kernels/depths/widths discrete sets ───────────────────────
let ks = ofa_kernels()
let ds = ofa_depths()
let ws = ofa_widths()
check("T2 3 kernels", len(ks) == 3)
check("T2 3 depths", len(ds) == 3)
check("T2 4 widths", len(ws) == 4)
check("T2 first kernel 3", ks[0] == 3)
check("T2 last kernel 7", ks[2] == 7)

// ── T3 sample subnet returns valid spec ──────────────────────────
let sub3 = ofa_sample_subnet(42)
check("T3 kernel valid",
      sub3["kernel"] == 3 || sub3["kernel"] == 5 || sub3["kernel"] == 7)
check("T3 depth valid",
      sub3["depth"] == 2 || sub3["depth"] == 3 || sub3["depth"] == 4)

// ── T4 sandwich batch has 4 subnets with min+max first ──────────
let sw = ofa_sandwich_batch(11)
check("T4 sandwich 4", len(sw) == 4)
check("T4 smallest kernel=3", sw[0]["kernel"] == 3)
check("T4 smallest depth=2", sw[0]["depth"] == 2)
check("T4 largest kernel=7", sw[1]["kernel"] == 7)
check("T4 largest depth=4", sw[1]["depth"] == 4)

// ── T5 forward returns active width channels ─────────────────────
let inp5 = [0.5, 0.3, -0.2, 0.1]
let sub5 = #{
    "kernel": 3,
    "depth": 2,
    "width_mult": 1.0
}
let o5 = ofa_forward_subnet(inp5, net, sub5)
check("T5 out len=4", len(o5) == 4)

// ── T6 smaller width produces fewer output channels ─────────────
let sub6 = #{
    "kernel": 3,
    "depth": 2,
    "width_mult": 0.5
}
let o6 = ofa_forward_subnet(inp5, net, sub6)
check("T6 out len=2", len(o6) == 2)

// ── T7 ReLU ensures output non-negative ─────────────────────────
let mut all_non_neg = true
for i in 0..len(o5) {
    if o5[i] < 0.0 { all_non_neg = false }
}
check("T7 ReLU non-neg", all_non_neg)

// ── T8 loss subnet returns finite >= 0 ──────────────────────────
let target8 = [0.1, 0.1, 0.1, 0.1]
let l8 = ofa_loss_subnet(inp5, target8, net, sub5)
check("T8 loss >= 0", l8 >= 0.0)

// ── T9 sandwich loss >= 0 ───────────────────────────────────────
let sl9 = ofa_sandwich_loss(inp5, target8, net, 77)
check("T9 sandwich loss >= 0", sl9 >= 0.0)

// ── T10 param count scales with depth and width ────────────────
let sub_small = #{
    "kernel": 3,
    "depth": 2,
    "width_mult": 0.5
}
let sub_large = #{
    "kernel": 3,
    "depth": 4,
    "width_mult": 1.0
}
let p_small = ofa_count_params(net, sub_small)
let p_large = ofa_count_params(net, sub_large)
check("T10 large > small", p_large > p_small)

// ── T11 kernel averaging doesn't change constant input ─────────
// Constant input, width=1 -> all channels equal, kernel averaging
// should not change values at layer 0.  Use a degenerate depth=0
// style: depth=2, just check output finite.
check("T11 k=5 run", len(ofa_forward_subnet(inp5, net, #{
    "kernel": 5,
    "depth": 3,
    "width_mult": 1.0
})) == 4)

// ── T12 training step reduces sandwich loss ────────────────────
let base_loss = ofa_sandwich_loss(inp5, target8, net, 5)
let step = ofa_train_step(inp5, target8, net, 0.02, 5)
let new_loss = ofa_sandwich_loss(inp5, target8, step["net"], 5)
check("T12 step reduces loss", new_loss <= base_loss + 1.0e-6)

// ── T13 training step preserves shape of net ───────────────────
let new_net = step["net"]
check("T13 still depth 4", new_net["depth_max"] == 4)
check("T13 still width 4", new_net["width_max"] == 4)
check("T13 W shape", len(new_net["W"][0]) == 4)

println("")
println("=== Once-For-All test summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
