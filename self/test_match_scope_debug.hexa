enum Result {
    Ok(val),
    Err(msg)
}

fn map_result(r, f) {
    println("  map_result called, f type = " + type_of(f))
    let out = match r {
        Ok(val) -> {
            println("  matched Ok, val = " + to_string(val))
            println("  f = " + to_string(f))
            let applied = f(val)
            println("  f(val) = " + to_string(applied))
            Result::Ok(applied)
        },
        Err(e) -> Result::Err(e)
    }
    return out
}

fn double(x) { return x * 2 }
fn add_ten(x) { return x + 10 }

println("=== Call 1: map_result(Ok(4), double) ===")
let mapped1 = map_result(Result::Ok(4), double)
let mapped1_val = match mapped1 { Ok(v) -> v, Err(_) -> -1 }
println("mapped1_val = " + to_string(mapped1_val))

println("")
println("=== Call 2: map_result(Ok(6), add_ten) ===")
let mapped2 = map_result(Result::Ok(6), add_ten)
let mapped2_val = match mapped2 { Ok(v) -> v, Err(_) -> -1 }
println("mapped2_val = " + to_string(mapped2_val))
