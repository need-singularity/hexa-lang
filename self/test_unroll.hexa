// ===============================================================
//  test_unroll.hexa -- @unroll AI-native attribute tests
//
//  @unroll = loop unrolling for bounded iterations.
//  Requires @bounded(N) with N <= 16 to hint the unroll factor.
//  The AI-native pass detects while loops in body and replicates
//  them N times as sequential guarded blocks.
//
//  Static model: ai_native_pass.hexa validates:
//    - @unroll requires a loop in body
//    - @bounded(N<=16) required for unroll factor
//    - N > 16 triggers violation (too large)
// ===============================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("===============================================================")
println("  HEXA @unroll Loop Unrolling Tests")
println("===============================================================")
println("")

// ── 1. Basic loop sum (unroll candidate) ────────────────────

println("--- 1. Basic loop sum ---")

@unroll @bounded(4)
fn unroll_sum4() -> int {
    let mut s = 0
    let mut i = 0
    while i < 4 {
        s = s + i
        i = i + 1
    }
    return s
}

check("@unroll sum 0..4 = 6", unroll_sum4(), 6)
check("@unroll idempotent", unroll_sum4() == unroll_sum4(), true)
println("")

// ── 2. Loop product (small N) ───────────────────────────────

println("--- 2. Loop product ---")

@unroll @bounded(5)
fn unroll_fact5() -> int {
    let mut r = 1
    let mut i = 1
    while i <= 5 {
        r = r * i
        i = i + 1
    }
    return r
}

check("@unroll fact(5) = 120", unroll_fact5(), 120)
println("")

// ── 3. N=1 (degenerate unroll) ──────────────────────────────

println("--- 3. Degenerate N=1 ---")

@unroll @bounded(1)
fn unroll_one() -> int {
    let mut s = 0
    let mut i = 0
    while i < 1 {
        s = s + 100
        i = i + 1
    }
    return s
}

check("@unroll N=1 = 100", unroll_one(), 100)
println("")

// ── 4. N=16 (max allowed) ───────────────────────────────────

println("--- 4. Max N=16 ---")

@unroll @bounded(16)
fn unroll_max16() -> int {
    let mut s = 0
    let mut i = 0
    while i < 16 {
        s = s + 1
        i = i + 1
    }
    return s
}

check("@unroll N=16 count = 16", unroll_max16(), 16)
println("")

// ── 5. Without @bounded (should still compute correctly) ────

println("--- 5. Without @bounded ---")

@unroll
fn unroll_no_bound() -> int {
    let mut s = 0
    let mut i = 0
    while i < 3 {
        s = s + i * i
        i = i + 1
    }
    return s
}

check("@unroll no @bounded still computes", unroll_no_bound(), 5)
println("")

// ── 6. Nested computation ───────────────────────────────────

println("--- 6. Nested computation ---")

@unroll @bounded(3)
fn unroll_nested() -> int {
    let mut total = 0
    let mut i = 0
    while i < 3 {
        let val = (i + 1) * 10
        total = total + val
        i = i + 1
    }
    return total
}

check("@unroll nested = 60", unroll_nested(), 60)
println("")

// ── 7. Powers of 2 ─────────────────────────────────────────

println("--- 7. Powers of 2 ---")

@unroll @bounded(8)
fn unroll_pow2() -> int {
    let mut x = 1
    let mut i = 0
    while i < 8 {
        x = x * 2
        i = i + 1
    }
    return x
}

check("@unroll 2^8 = 256", unroll_pow2(), 256)
println("")

// ── 8. Sum of squares ───────────────────────────────────────

println("--- 8. Sum of squares ---")

@unroll @bounded(10)
fn unroll_sq_sum() -> int {
    let mut s = 0
    let mut i = 1
    while i <= 10 {
        s = s + i * i
        i = i + 1
    }
    return s
}

check("@unroll sum of squares 1..10 = 385", unroll_sq_sum(), 385)
println("")

// ── 9. Fibonacci-like accumulation ──────────────────────────

println("--- 9. Fibonacci ---")

@unroll @bounded(10)
fn unroll_fib10() -> int {
    let mut a = 0
    let mut b = 1
    let mut i = 0
    while i < 10 {
        let tmp = a + b
        a = b
        b = tmp
        i = i + 1
    }
    return a
}

check("@unroll fib(10) = 55", unroll_fib10(), 55)
println("")

// ── 10. Determinism ─────────────────────────────────────────

println("--- 10. Determinism ---")

let r10a = unroll_sum4()
let r10b = unroll_sum4()
let r10c = unroll_fact5()
let r10d = unroll_fact5()
check("@unroll deterministic sum4", r10a == r10b, true)
check("@unroll deterministic fact5", r10c == r10d, true)
println("")

// ── Summary ─────────────────────────────────────────────────

println("===============================================================")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("===============================================================")

if fail_count == 0 {
    println("")
    println("=== test_unroll.hexa: ALL TESTS PASSED ===")
} else {
    println("")
    println("!!! SOME TESTS FAILED !!!")
}
