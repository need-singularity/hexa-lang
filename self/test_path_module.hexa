// self/test_path_module.hexa — S-NEW-PATH acceptance smoke
//
// Self-contained: inline the helpers (no cross-file import — same pattern
// as stdlib/collections_test.hexa). The path module itself lives at
// stdlib/path.hexa; this test mirrors its API surface to validate behavior
// before I2-IMPORT-PATH wires up `import stdlib/path as path`.

let mut pass_count = 0
let mut total_count = 0
let mut failed_name = ""

fn check(name, cond) {
    total_count = total_count + 1
    if cond {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name)
    }
}

// ── inline mirror of stdlib/path.hexa surface ─────────────────────────

fn path_is_abs(p) { if len(p) == 0 { return false } if p[0] == '/' { return true } return false }

fn path_dirname(p) {
    let n = len(p)
    if n == 0 { return "." }
    let mut i = n - 1
    while i > 0 { if p[i] != '/' { break } i = i - 1 }
    while i >= 0 {
        if p[i] == '/' { if i == 0 { return "/" } return p.substring(0, i) }
        i = i - 1
    }
    return "."
}

fn path_basename(p) {
    let n = len(p)
    if n == 0 { return "" }
    let mut end = n
    while end > 0 { if p[end - 1] != '/' { break } end = end - 1 }
    if end == 0 { return "/" }
    let mut i = end - 1
    while i >= 0 {
        if p[i] == '/' { return p.substring(i + 1, end) }
        i = i - 1
    }
    return p.substring(0, end)
}

fn path_ext(p) {
    let base = path_basename(p)
    let n = len(base)
    let mut i = n - 1
    while i > 0 { if base[i] == '.' { return base.substring(i, n) } i = i - 1 }
    return ""
}

fn path_stem(p) {
    let base = path_basename(p)
    let ext = path_ext(p)
    let n = len(base)
    let m = len(ext)
    if m == 0 { return base }
    return base.substring(0, n - m)
}

fn path_join(a, b) {
    if len(a) == 0 { return b }
    if len(b) == 0 { return a }
    if path_is_abs(b) { return b }
    let mut parts = []
    parts.push(a)
    if a[len(a) - 1] != '/' { parts.push("/") }
    parts.push(b)
    return parts.join("")
}

// ── tests ──────────────────────────────────────────────────────────────

fn main() {
    // is_abs
    check("is_abs /a", path_is_abs("/a"))
    check("is_abs a/b", path_is_abs("a/b") == false)
    check("is_abs empty", path_is_abs("") == false)

    // dirname
    check("dirname /a/b/c", path_dirname("/a/b/c") == "/a/b")
    check("dirname a/b/c", path_dirname("a/b/c") == "a/b")
    check("dirname a", path_dirname("a") == ".")
    check("dirname /a", path_dirname("/a") == "/")
    check("dirname /", path_dirname("/") == "/")
    check("dirname empty", path_dirname("") == ".")
    check("dirname trailing /", path_dirname("a/b/") == "a")

    // basename
    check("basename /a/b/c", path_basename("/a/b/c") == "c")
    check("basename a/b/c", path_basename("a/b/c") == "c")
    check("basename foo", path_basename("foo") == "foo")
    check("basename /a/b/", path_basename("/a/b/") == "b")
    check("basename /", path_basename("/") == "/")

    // ext
    check("ext file.hexa", path_ext("file.hexa") == ".hexa")
    check("ext a.tar.gz", path_ext("a.tar.gz") == ".gz")
    check("ext noext", path_ext("noext") == "")
    check("ext .hidden", path_ext(".hidden") == "")
    check("ext /a/b/c.x", path_ext("/a/b/c.x") == ".x")

    // stem
    check("stem file.hexa", path_stem("file.hexa") == "file")
    check("stem a.tar.gz", path_stem("a.tar.gz") == "a.tar")
    check("stem noext", path_stem("noext") == "noext")

    // join
    check("join a b", path_join("a", "b") == "a/b")
    check("join a/ b", path_join("a/", "b") == "a/b")
    check("join /a /b", path_join("/a", "/b") == "/b")
    check("join '' b", path_join("", "b") == "b")
    check("join a ''", path_join("a", "") == "a")

    println("PASS " + to_string(pass_count) + "/" + to_string(total_count))
    if failed_name != "" {
        println("first fail: " + failed_name)
        exit(1)
    }
}
