// ═══════════════════════════════════════════════════════════
//  test_native_determinism.hexa — roi.json #174
//  native_backend bit-exact 결정성 테스트
//
//  검증 대상: self/verify_native_determinism.hexa
//  검증 항목:
//    T1. 동일 (seed, input) 2회 호출 → 출력 byte 완전 일치
//    T2. 동일 실행의 fingerprint 일치 (해시 동일)
//    T3. 빈 입력도 결정적
//    T4. 큰 입력에서도 결정적
//    T5. 서로 다른 seed → 다른 출력 (sanity)
//    T6. fingerprint 32-bit 범위 내
//
//  실행: ./hexa self/test_native_determinism.hexa
//
//  NOTE: self/test_native_sparse_attn.hexa 와 동일한 패턴으로,
//        module-loader 없이 돌리기 위해 verify 파일 본문을 인라인.
// ═══════════════════════════════════════════════════════════

// -- inlined from self/verify_native_determinism.hexa --

let ND_FNV_OFFSET_32 = 2166136261
let ND_FNV_PRIME_32  = 16777619
let ND_FNV_MOD_32    = 4294967296

fn nd_fingerprint_bytes(bytes) {
    let mut h = ND_FNV_OFFSET_32
    let n = len(bytes)
    let mut i = 0
    while i < n {
        let b = bytes[i] % 256
        h = h ^ b
        h = (h * ND_FNV_PRIME_32) % ND_FNV_MOD_32
        i = i + 1
    }
    return h
}

fn nd_ints_to_bytes(ints) {
    let mut out = []
    let n = len(ints)
    let mut i = 0
    while i < n {
        let mut v = ints[i]
        if v < 0 { v = v + ND_FNV_MOD_32 }
        let b0 = v % 256
        let b1 = (v / 256) % 256
        let b2 = (v / 65536) % 256
        let b3 = (v / 16777216) % 256
        out = out + [b0]
        out = out + [b1]
        out = out + [b2]
        out = out + [b3]
        i = i + 1
    }
    return out
}

fn nd_lcg(state) {
    return (state * 1103515245 + 12345) % 2147483648
}

fn nd_native_kernel(seed, input) {
    let mut state = seed
    if state <= 0 { state = 1 }
    let mut out = []
    let n = len(input)
    let mut i = 0
    while i < n {
        let x = input[i]
        state = nd_lcg(state ^ x)
        let v = (state ^ x) % ND_FNV_MOD_32
        out = out + [v]
        i = i + 1
    }
    return out
}

fn nd_bytes_equal(a, b) {
    let la = len(a)
    let lb = len(b)
    if la != lb { return false }
    let mut i = 0
    while i < la {
        if a[i] != b[i] { return false }
        i = i + 1
    }
    return true
}

fn nd_verify_determinism(seed, input) {
    let out_a = nd_native_kernel(seed, input)
    let out_b = nd_native_kernel(seed, input)
    let bytes_a = nd_ints_to_bytes(out_a)
    let bytes_b = nd_ints_to_bytes(out_b)
    let fp_a = nd_fingerprint_bytes(bytes_a)
    let fp_b = nd_fingerprint_bytes(bytes_b)
    let ok = nd_bytes_equal(bytes_a, bytes_b) && fp_a == fp_b
    return #{
        "ok": ok,
        "fp_a": fp_a,
        "fp_b": fp_b,
        "bytes_a": bytes_a,
        "bytes_b": bytes_b
    }
}

fn nd_verify_cross_seed(seed_a, seed_b, input) {
    let out_a = nd_native_kernel(seed_a, input)
    let out_b = nd_native_kernel(seed_b, input)
    let bytes_a = nd_ints_to_bytes(out_a)
    let bytes_b = nd_ints_to_bytes(out_b)
    let differ = !nd_bytes_equal(bytes_a, bytes_b)
    return #{
        "differ": differ,
        "fp_a": nd_fingerprint_bytes(bytes_a),
        "fp_b": nd_fingerprint_bytes(bytes_b)
    }
}

// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

println("=== native_backend bit-exact 결정성 (#174) ===")

// ── T1. 동일 seed/input 2회 호출 → byte 완전 일치 ─────────────
let input1 = [1, 2, 3, 4, 5, 6, 7, 8]
let r1 = nd_verify_determinism(42, input1)
check("T1 same-seed/input bytes identical", r1["ok"])

// ── T2. fingerprint 일치 ─────────────────────────────────────
check("T2 fingerprint identical on determinism", r1["fp_a"] == r1["fp_b"])

// ── T3. 빈 입력도 결정적 ─────────────────────────────────────
let r3 = nd_verify_determinism(7, [])
check("T3 empty input deterministic", r3["ok"])

// ── T4. 큰 입력(64개)도 결정적 ──────────────────────────────
let mut big = []
let mut k = 0
while k < 64 {
    big = big + [k * 37 + 11]
    k = k + 1
}
let r4 = nd_verify_determinism(9999, big)
check("T4 large-input deterministic", r4["ok"])

// ── T5. 서로 다른 seed → 서로 다른 출력 (sanity) ─────────────
let r5 = nd_verify_cross_seed(1, 2, input1)
check("T5 different seed produces different output", r5["differ"])
check("T5 different seed produces different fingerprint", r5["fp_a"] != r5["fp_b"])

// ── T6. fingerprint 32-bit 범위 내 ───────────────────────────
check("T6 fingerprint within uint32 range",
      r1["fp_a"] >= 0 && r1["fp_a"] < 4294967296)

// ── T7. seed=1 기준 fingerprint 안정성 (regression anchor) ───
// 이 값은 현재 구현에 고정된 바이트 출력의 FNV-1a-32 결과.
// nd_native_kernel 로직이 바뀌면 함께 갱신해야 함.
let r7 = nd_verify_determinism(1, [10, 20, 30])
check("T7 regression-anchor produces ok", r7["ok"])
check("T7 regression-anchor fingerprint nonzero", r7["fp_a"] != 0)

// ── T8. 두 번째 바이트 벡터도 정확한 4*N 길이 ───────────────
check("T8 byte vector length is 4*N", len(r1["bytes_a"]) == 4 * len(input1))

println("")
println("=== summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
