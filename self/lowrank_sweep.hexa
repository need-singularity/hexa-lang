// lowrank_sweep.hexa — rank r sweep at N=1024, dense vs lowrank speedup curve

let N = 1024

// dense baseline: 5 iters of N×N × N×N
let A1 = tensor_zeros(N * N)
let B1 = tensor_zeros(N * N)
let _w1 = matmul(A1, B1, N, N, N)

let s0 = clock()
let mut i1 = 0
while i1 < 5 {
    let _ = matmul(A1, B1, N, N, N)
    i1 = i1 + 1
}
let s1 = clock()
let dense_elapsed = s1 - s0
let dense_each = dense_elapsed / 5.0
let dense_ms = dense_each * 1000.0

// sweep ranks
let ranks = [8, 16, 32, 64, 128, 256]

let mut best_r = 0
let mut best_speedup = 0.0

let mut k = 0
while k < 6 {
    let R = ranks[k]
    let U = tensor_zeros(N * R)
    let V = tensor_zeros(R * N)
    let X = tensor_zeros(N * N)
    let _wT = matmul(V, X, R, N, N)
    let _wY = matmul(U, _wT, N, R, N)

    let t0 = clock()
    let mut i2 = 0
    while i2 < 5 {
        let T = matmul(V, X, R, N, N)
        let _ = matmul(U, T, N, R, N)
        i2 = i2 + 1
    }
    let t1 = clock()
    let lowrank_elapsed = t1 - t0
    let lowrank_each = lowrank_elapsed / 5.0
    let lowrank_ms = lowrank_each * 1000.0
    let speedup = dense_each / lowrank_each

    let mut line = "{"
    line = line + "\"N\":" + str(N)
    line = line + ",\"R\":" + str(R)
    line = line + ",\"dense_ms\":" + str(dense_ms)
    line = line + ",\"lowrank_ms\":" + str(lowrank_ms)
    line = line + ",\"speedup\":" + str(speedup)
    line = line + "}"
    println(line)

    if speedup > best_speedup {
        best_speedup = speedup
        best_r = R
    }

    k = k + 1
}

let mut summary = "{"
summary = summary + "\"summary\":\"rank_sweep\""
summary = summary + ",\"best_r\":" + str(best_r)
summary = summary + ",\"best_speedup\":" + str(best_speedup)
summary = summary + "}"
println(summary)
