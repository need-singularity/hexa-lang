// ===================================================================
//  self/ml/nas.hexa — Neural Architecture Search (NAS)
//
//  Pure Hexa implementation of automated architecture search.
//
//  Components:
//    1. Search Space   — define available layer types, sizes, connections
//    2. Controller     — random or evolutionary architecture generation
//    3. Evaluator      — build architecture, train briefly, measure metric
//    4. Pareto Front   — multi-objective optimization (accuracy vs FLOPs)
//
//  Public API:
//    create_search_space(options)
//    sample_architecture(space)
//    mutate_architecture(arch, space)
//    crossover_architectures(arch1, arch2)
//    evaluate_architecture(arch, data)
//    evaluate_flops(arch)
//    pareto_front(results)
//    best_architecture(results, metric)
//    run_evolution(space, data, pop_size, generations)
//    run_random_search(space, data, n_samples)
//
//  Conventions:
//    - Uses #{} map literals (no {k:v} inside if blocks)
//    - Architecture = array of layer specs (maps)
//    - Layer spec = { "type": str, "size": int, "activation": str }
// ===================================================================

// ===================================================================
//  Math helpers
// ===================================================================
fn _nas_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn _nas_sqrt(x) {
    if x <= 0.0 { return 0.0 }
    let mut guess = x / 2.0
    if guess < 0.001 { guess = 0.001 }
    let mut i = 0
    while i < 15 {
        guess = (guess + x / guess) / 2.0
        i = i + 1
    }
    return guess
}

// Simple pseudo-random (LCG)
let mut _nas_seed = 42
fn _nas_rand() {
    _nas_seed = (_nas_seed * 1103515245 + 12345) % 2147483647
    if _nas_seed < 0 { _nas_seed = 0 - _nas_seed }
    return _nas_seed
}

fn _nas_rand_int(low, high) {
    let r = _nas_rand()
    return low + r % (high - low + 1)
}

fn _nas_rand_choice(arr) {
    let n = len(arr)
    let idx = _nas_rand_int(0, n - 1)
    return arr[idx]
}

// ===================================================================
//  Search Space
// ===================================================================

// options map should contain:
//   layer_types: ["linear", "conv1d", "attention", ...]
//   sizes: [64, 128, 256, 512, ...]
//   activations: ["relu", "gelu", "swish", ...]
//   min_layers: int
//   max_layers: int
fn create_search_space(options) {
    let space = #{}
    space["layer_types"] = options["layer_types"]
    space["sizes"] = options["sizes"]
    space["activations"] = options["activations"]
    space["min_layers"] = options["min_layers"]
    space["max_layers"] = options["max_layers"]
    return space
}

// ===================================================================
//  Sample a random architecture from the search space
//  Returns array of layer specs
// ===================================================================
fn sample_architecture(space) {
    let min_l = space["min_layers"]
    let max_l = space["max_layers"]
    let n_layers = _nas_rand_int(min_l, max_l)

    let types = space["layer_types"]
    let sizes = space["sizes"]
    let acts = space["activations"]

    let mut arch = []
    let mut i = 0
    while i < n_layers {
        let layer = #{}
        layer["type"] = _nas_rand_choice(types)
        layer["size"] = _nas_rand_choice(sizes)
        layer["activation"] = _nas_rand_choice(acts)
        arch = arch + [layer]
        i = i + 1
    }
    return arch
}

// ===================================================================
//  Mutate an architecture (change one random layer)
// ===================================================================
fn mutate_architecture(arch, space) {
    let n = len(arch)
    if n == 0 { return arch }

    let idx = _nas_rand_int(0, n - 1)
    let types = space["layer_types"]
    let sizes = space["sizes"]
    let acts = space["activations"]

    // decide what to mutate
    let what = _nas_rand_int(0, 2)

    let mut new_arch = []
    let mut i = 0
    while i < n {
        if i == idx {
            let layer = #{}
            if what == 0 {
                layer["type"] = _nas_rand_choice(types)
                layer["size"] = arch[i]["size"]
                layer["activation"] = arch[i]["activation"]
            } else {
                layer["type"] = arch[i]["type"]
                if what == 1 {
                    layer["size"] = _nas_rand_choice(sizes)
                    layer["activation"] = arch[i]["activation"]
                } else {
                    layer["size"] = arch[i]["size"]
                    layer["activation"] = _nas_rand_choice(acts)
                }
            }
            new_arch = new_arch + [layer]
        } else {
            new_arch = new_arch + [arch[i]]
        }
        i = i + 1
    }
    return new_arch
}

// ===================================================================
//  Crossover two architectures (uniform crossover)
// ===================================================================
fn crossover_architectures(arch1, arch2) {
    let n1 = len(arch1)
    let n2 = len(arch2)
    let n = if n1 < n2 { n1 } else { n2 }

    let mut child = []
    let mut i = 0
    while i < n {
        let pick = _nas_rand_int(0, 1)
        if pick == 0 {
            child = child + [arch1[i]]
        } else {
            child = child + [arch2[i]]
        }
        i = i + 1
    }

    // if parent1 is longer, maybe add remaining layers
    while i < n1 {
        let pick = _nas_rand_int(0, 1)
        if pick == 0 {
            child = child + [arch1[i]]
        }
        i = i + 1
    }

    return child
}

// ===================================================================
//  Evaluate architecture (simplified metric estimation)
//  data: map with "input_size" and "output_size" (integers)
//  Returns map with "accuracy" (simulated) and "flops"
// ===================================================================
fn evaluate_architecture(arch, data) {
    let n_layers = len(arch)
    let input_size = data["input_size"]
    let output_size = data["output_size"]

    // estimate FLOPs: sum of layer_in * layer_out for linear layers
    let mut flops = 0
    let mut prev_size = input_size
    let mut i = 0
    while i < n_layers {
        let layer_size = arch[i]["size"]
        let layer_type = arch[i]["type"]
        if layer_type == "linear" {
            flops = flops + prev_size * layer_size * 2
        }
        if layer_type == "conv1d" {
            flops = flops + prev_size * layer_size * 3 * 2
        }
        if layer_type == "attention" {
            flops = flops + layer_size * layer_size * 4
        }
        prev_size = layer_size
        i = i + 1
    }
    // output projection
    flops = flops + prev_size * output_size * 2

    // simulate accuracy based on architecture capacity
    // deeper and wider = better, but diminishing returns
    let mut total_params = 0
    prev_size = input_size
    i = 0
    while i < n_layers {
        total_params = total_params + prev_size * arch[i]["size"]
        prev_size = arch[i]["size"]
        i = i + 1
    }
    total_params = total_params + prev_size * output_size

    // simulated accuracy: saturating function of params
    // accuracy ~ 1 - 1/(1 + params/1000)
    let param_score = (total_params * 1.0) / (total_params * 1.0 + 1000.0)
    // add small random noise
    let noise = (_nas_rand() % 100) * 1.0 / 10000.0
    let accuracy = param_score * 0.95 + noise

    let result = #{}
    result["accuracy"] = accuracy
    result["flops"] = flops
    result["params"] = total_params
    result["n_layers"] = n_layers
    return result
}

// Compute estimated FLOPs for an architecture
fn evaluate_flops(arch) {
    let n = len(arch)
    let mut flops = 0
    let mut prev = 64
    let mut i = 0
    while i < n {
        let s = arch[i]["size"]
        flops = flops + prev * s * 2
        prev = s
        i = i + 1
    }
    return flops
}

// ===================================================================
//  Pareto Front — find non-dominated solutions
//  results: array of maps, each with "accuracy" and "flops"
//  Returns indices of Pareto-optimal solutions
// ===================================================================
fn pareto_front(results) {
    let n = len(results)
    let mut front = []

    let mut i = 0
    while i < n {
        let mut dominated = false
        let acc_i = results[i]["accuracy"]
        let flops_i = results[i]["flops"]

        let mut j = 0
        while j < n {
            if i != j {
                let acc_j = results[j]["accuracy"]
                let flops_j = results[j]["flops"]
                // j dominates i if j has >= accuracy and <= flops (strictly better in at least one)
                if acc_j >= acc_i {
                    if flops_j <= flops_i {
                        if acc_j > acc_i {
                            dominated = true
                            j = n
                        }
                        if flops_j < flops_i {
                            dominated = true
                            j = n
                        }
                    }
                }
            }
            j = j + 1
        }

        if dominated == false {
            front = front + [i]
        }
        i = i + 1
    }
    return front
}

// ===================================================================
//  Best architecture by a single metric
//  results: array of maps with metric values
//  metric: string key (e.g. "accuracy")
//  Returns index of best result
// ===================================================================
fn best_architecture(results, metric) {
    let n = len(results)
    if n == 0 { return 0 - 1 }

    let mut best_idx = 0
    let mut best_val = results[0][metric]
    let mut i = 1
    while i < n {
        let val = results[i][metric]
        if val > best_val {
            best_val = val
            best_idx = i
        }
        i = i + 1
    }
    return best_idx
}

// ===================================================================
//  Evolutionary search
// ===================================================================
fn run_evolution(space, data, pop_size, generations) {
    // initialize population
    let mut population = []
    let mut pop_results = []
    let mut pi = 0
    while pi < pop_size {
        let arch = sample_architecture(space)
        let result = evaluate_architecture(arch, data)
        population = population + [arch]
        pop_results = pop_results + [result]
        pi = pi + 1
    }

    let mut gen = 0
    while gen < generations {
        // tournament selection + mutation
        let mut new_pop = []
        let mut new_results = []
        let mut ni = 0
        while ni < pop_size {
            // tournament: pick 2 random, keep better
            let idx1 = _nas_rand_int(0, pop_size - 1)
            let idx2 = _nas_rand_int(0, pop_size - 1)
            let parent_idx = if pop_results[idx1]["accuracy"] > pop_results[idx2]["accuracy"] { idx1 } else { idx2 }
            let parent = population[parent_idx]

            // mutate or crossover
            let action = _nas_rand_int(0, 2)
            let mut child = parent
            if action == 0 {
                child = mutate_architecture(parent, space)
            }
            if action == 1 {
                let idx3 = _nas_rand_int(0, pop_size - 1)
                child = crossover_architectures(parent, population[idx3])
            }
            // action==2: keep parent as-is (elitism)

            let result = evaluate_architecture(child, data)
            new_pop = new_pop + [child]
            new_results = new_results + [result]
            ni = ni + 1
        }
        population = new_pop
        pop_results = new_results
        gen = gen + 1
    }

    // return best results and architectures
    let output = #{}
    output["population"] = population
    output["results"] = pop_results
    output["best_idx"] = best_architecture(pop_results, "accuracy")
    return output
}

// ===================================================================
//  Random search
// ===================================================================
fn run_random_search(space, data, n_samples) {
    let mut architectures = []
    let mut results = []
    let mut i = 0
    while i < n_samples {
        let arch = sample_architecture(space)
        let result = evaluate_architecture(arch, data)
        architectures = architectures + [arch]
        results = results + [result]
        i = i + 1
    }

    let output = #{}
    output["architectures"] = architectures
    output["results"] = results
    output["best_idx"] = best_architecture(results, "accuracy")
    return output
}

println("[nas] module loaded")


// -- end inlined --

let mut pass = 0
let mut fail = 0

fn check(name, cond) {
    if cond {
        pass = pass + 1
        println("[PASS] " + name)
    } else {
        fail = fail + 1
        println("[FAIL] " + name)
    }
}

fn abs_f(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

// ── 1. create_search_space ──────────────────────────────────────
let opts = #{}
opts["layer_types"] = ["linear", "conv1d", "attention"]
opts["sizes"] = [64, 128, 256]
opts["activations"] = ["relu", "gelu"]
opts["min_layers"] = 2
opts["max_layers"] = 5

let space = create_search_space(opts)
check("search_space has layer_types", len(space["layer_types"]) == 3)
check("search_space has sizes", len(space["sizes"]) == 3)
check("search_space min_layers", space["min_layers"] == 2)
check("search_space max_layers", space["max_layers"] == 5)

// ── 2. sample_architecture structure ────────────────────────────
let arch1 = sample_architecture(space)
check("sample_arch is array", len(arch1) >= 2)
check("sample_arch layer has type", arch1[0]["type"] != "")
check("sample_arch layer has size", arch1[0]["size"] > 0)
check("sample_arch layer has activation", arch1[0]["activation"] != "")

// ── 3. sample_architecture layer count in range ─────────────────
let n1 = len(arch1)
check("sample_arch layers in range", n1 >= 2)
check("sample_arch layers max", n1 <= 5)

// ── 4. mutate_architecture ──────────────────────────────────────
let arch2 = mutate_architecture(arch1, space)
check("mutate returns same length", len(arch2) == len(arch1))
// at least the structure is valid
check("mutate layer 0 has type", arch2[0]["type"] != "")

// ── 5. crossover_architectures ──────────────────────────────────
let arch3 = sample_architecture(space)
let child = crossover_architectures(arch1, arch3)
check("crossover produces architecture", len(child) > 0)
check("crossover child has valid layers", child[0]["type"] != "")

// ── 6. evaluate_architecture metrics ────────────────────────────
let data = #{}
data["input_size"] = 64
data["output_size"] = 10

let eval1 = evaluate_architecture(arch1, data)
check("evaluate has accuracy", eval1["accuracy"] > 0.0)
check("evaluate accuracy <= 1", eval1["accuracy"] <= 1.0)
check("evaluate has flops", eval1["flops"] > 0)
check("evaluate has params", eval1["params"] > 0)

// ── 7. evaluate_flops ───────────────────────────────────────────
let flops1 = evaluate_flops(arch1)
check("evaluate_flops > 0", flops1 > 0)

// bigger architecture should have more flops
let big_layer = #{}
big_layer["type"] = "linear"
big_layer["size"] = 1024
big_layer["activation"] = "relu"
let big_arch = [big_layer, big_layer, big_layer]
let flops2 = evaluate_flops(big_arch)
check("bigger arch more flops", flops2 > flops1)

// ── 8. pareto_front ─────────────────────────────────────────────
let r1 = #{}
r1["accuracy"] = 0.9
r1["flops"] = 1000
let r2 = #{}
r2["accuracy"] = 0.8
r2["flops"] = 500
let r3 = #{}
r3["accuracy"] = 0.85
r3["flops"] = 800
let results = [r1, r2, r3]

let front = pareto_front(results)
check("pareto_front has results", len(front) > 0)
// r1 (best acc) and r2 (best flops) should be on front
check("pareto_front includes best acc", front[0] == 0)

// ── 9. best_architecture ────────────────────────────────────────
let best_acc = best_architecture(results, "accuracy")
check("best_architecture by accuracy", best_acc == 0)

// ── 10. run_random_search ───────────────────────────────────────
let random_out = run_random_search(space, data, 5)
check("random_search 5 architectures", len(random_out["architectures"]) == 5)
check("random_search 5 results", len(random_out["results"]) == 5)
check("random_search has best_idx", random_out["best_idx"] >= 0)

// ── 11. run_evolution ───────────────────────────────────────────
let evo_out = run_evolution(space, data, 4, 3)
check("evolution has population", len(evo_out["population"]) == 4)
check("evolution has results", len(evo_out["results"]) == 4)
check("evolution has best_idx", evo_out["best_idx"] >= 0)

// ── 12. pareto_front correctness ────────────────────────────────
// dominated point should not appear
let d1 = #{}
d1["accuracy"] = 0.9
d1["flops"] = 100
let d2 = #{}
d2["accuracy"] = 0.5
d2["flops"] = 200
let d_results = [d1, d2]
let d_front = pareto_front(d_results)
// d1 dominates d2 (higher acc, lower flops)
check("pareto dominated excluded", len(d_front) == 1)
check("pareto dominant included", d_front[0] == 0)

// ── Summary ─────────────────────────────────────────────────────
println("")
println("========================================")
println("  nas tests: " + str(pass) + " passed, " + str(fail) + " failed")
println("========================================")
