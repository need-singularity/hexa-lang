// -- inlined from self/core/map.hexa --
// codegen import not wired for test files

// ═══════════════════════════════════════════════════════════
//  self/core/map.hexa — HEXA-native map utilities (T4)
//
//  T4 trio (string + array + map) 완성의 마지막 모듈. stage0 의 `#{...}`
//  map primitives (.keys(), .values(), m[key], m.key) 위에서 순수 HEXA
//  로직으로 고수준 오퍼레이션 구현.
//
//  Note: stage0 의 `len(m)` 은 map 에 대해 0 을 반환 (array 전용).
//  엔트리 개수는 `len(m.keys())` 로 계산. map_size() 가 편의 래퍼.
//
//  Usage:
//      use "stdlib/map"
//      let n = map_size(m)
// ═══════════════════════════════════════════════════════════

// Number of entries in a map.
pub fn map_size(m) {
    return len(m.keys())
}

// True if m has the given key.
pub fn map_contains_key(m, key) {
    let ks = m.keys()
    let n = len(ks)
    let mut i = 0
    while i < n {
        if ks[i] == key { return true }
        i = i + 1
    }
    return false
}

// Get value or default if key missing.
pub fn map_get_or(m, key, default_value) {
    if map_contains_key(m, key) {
        return m[key]
    }
    return default_value
}

// All keys as array (same as m.keys() — convenience wrapper for consistency).
pub fn map_keys(m) {
    return m.keys()
}

// All values as array (order matches map_keys).
pub fn map_values(m) {
    return m.values()
}

// Collect key-value pairs as array of [key, value] tuples.
// Each element is a 2-array: [ks[i], vs[i]].
pub fn map_entries(m) {
    let ks = m.keys()
    let vs = m.values()
    let n = len(ks)
    let mut out = []
    let mut i = 0
    while i < n {
        out.push([ks[i], vs[i]])
        i = i + 1
    }
    return out
}

// True if map is empty (size == 0).
pub fn map_is_empty(m) {
    return map_size(m) == 0
}

// Sum of all values (assumes numeric).
pub fn map_sum_values(m) {
    let vs = m.values()
    let n = len(vs)
    let mut s = 0
    let mut i = 0
    while i < n {
        s = s + vs[i]
        i = i + 1
    }
    return s
}

// Count entries whose value equals v.
pub fn map_count_values(m, v) {
    let vs = m.values()
    let n = len(vs)
    let mut c = 0
    let mut i = 0
    while i < n {
        if vs[i] == v { c = c + 1 }
        i = i + 1
    }
    return c
}


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check_int(name, actual, expected) {
    if actual == expected {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected " + to_string(expected) + " got " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_bool(name, actual, expected) {
    if actual == expected {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected " + to_string(expected) + " got " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_str(name, actual, expected) {
    if actual == expected {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected '" + expected + "' got '" + actual + "'")
        fail_count = fail_count + 1
    }
}

fn main() {
    let m = #{"a": 1, "b": 2, "c": 3}
    let empty_map = #{}
    let str_map = #{"name": "alice", "role": "admin"}

    // ── map_size ────────────────────────────────
    check_int("size/3 entries",   map_size(m), 3)
    check_int("size/empty",       map_size(empty_map), 0)
    check_int("size/2 str",       map_size(str_map), 2)

    // ── map_contains_key ────────────────────────
    check_bool("contains/yes",    map_contains_key(m, "a"), true)
    check_bool("contains/yes-c",  map_contains_key(m, "c"), true)
    check_bool("contains/no",     map_contains_key(m, "z"), false)
    check_bool("contains/empty",  map_contains_key(empty_map, "a"), false)

    // ── map_get_or ──────────────────────────────
    check_int("get_or/hit",       map_get_or(m, "b", 999), 2)
    check_int("get_or/miss",      map_get_or(m, "z", 42), 42)
    check_int("get_or/empty",     map_get_or(empty_map, "k", 7), 7)
    check_str("get_or/str hit",   map_get_or(str_map, "name", "nobody"), "alice")
    check_str("get_or/str miss",  map_get_or(str_map, "x", "fallback"), "fallback")

    // ── map_keys / map_values ───────────────────
    check_int("keys len",         len(map_keys(m)), 3)
    check_int("values len",       len(map_values(m)), 3)
    check_int("keys empty",       len(map_keys(empty_map)), 0)

    // ── map_entries ─────────────────────────────
    let ents = map_entries(m)
    check_int("entries/count",    len(ents), 3)
    check_int("entries/pair size", len(ents[0]), 2)

    // ── map_is_empty ────────────────────────────
    check_bool("is_empty/no",     map_is_empty(m), false)
    check_bool("is_empty/yes",    map_is_empty(empty_map), true)

    // ── map_sum_values ──────────────────────────
    check_int("sum_values/basic", map_sum_values(m), 6)
    check_int("sum_values/empty", map_sum_values(empty_map), 0)

    // ── map_count_values ────────────────────────
    let m2 = #{"a": 1, "b": 2, "c": 1, "d": 3, "e": 1}
    check_int("count_values/1",   map_count_values(m2, 1), 3)
    check_int("count_values/2",   map_count_values(m2, 2), 1)
    check_int("count_values/99",  map_count_values(m2, 99), 0)

    println("")
    println("═══════════════════════════════════════════════════════")
    println("  T4 HEXA stdlib/map — PASS " + to_string(pass_count) + " / FAIL " + to_string(fail_count))
    println("═══════════════════════════════════════════════════════")
    if fail_count > 0 { exit(1) }
}

// `main()` is auto-called by stage0 — no explicit call needed.
