// T4 stdlib/map helpers test — via `use "stdlib/map"` resolver fallback.

use "stdlib/map"

let mut pass_count = 0
let mut fail_count = 0

fn check_int(name, actual, expected) {
    if actual == expected {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected " + to_string(expected) + " got " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_bool(name, actual, expected) {
    if actual == expected {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected " + to_string(expected) + " got " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_str(name, actual, expected) {
    if actual == expected {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected '" + expected + "' got '" + actual + "'")
        fail_count = fail_count + 1
    }
}

fn main() {
    let m = #{"a": 1, "b": 2, "c": 3}
    let empty_map = #{}
    let str_map = #{"name": "alice", "role": "admin"}

    // ── map_size ────────────────────────────────
    check_int("size/3 entries",   map_size(m), 3)
    check_int("size/empty",       map_size(empty_map), 0)
    check_int("size/2 str",       map_size(str_map), 2)

    // ── map_contains_key ────────────────────────
    check_bool("contains/yes",    map_contains_key(m, "a"), true)
    check_bool("contains/yes-c",  map_contains_key(m, "c"), true)
    check_bool("contains/no",     map_contains_key(m, "z"), false)
    check_bool("contains/empty",  map_contains_key(empty_map, "a"), false)

    // ── map_get_or ──────────────────────────────
    check_int("get_or/hit",       map_get_or(m, "b", 999), 2)
    check_int("get_or/miss",      map_get_or(m, "z", 42), 42)
    check_int("get_or/empty",     map_get_or(empty_map, "k", 7), 7)
    check_str("get_or/str hit",   map_get_or(str_map, "name", "nobody"), "alice")
    check_str("get_or/str miss",  map_get_or(str_map, "x", "fallback"), "fallback")

    // ── map_keys / map_values ───────────────────
    check_int("keys len",         len(map_keys(m)), 3)
    check_int("values len",       len(map_values(m)), 3)
    check_int("keys empty",       len(map_keys(empty_map)), 0)

    // ── map_entries ─────────────────────────────
    let ents = map_entries(m)
    check_int("entries/count",    len(ents), 3)
    check_int("entries/pair size", len(ents[0]), 2)

    // ── map_is_empty ────────────────────────────
    check_bool("is_empty/no",     map_is_empty(m), false)
    check_bool("is_empty/yes",    map_is_empty(empty_map), true)

    // ── map_sum_values ──────────────────────────
    check_int("sum_values/basic", map_sum_values(m), 6)
    check_int("sum_values/empty", map_sum_values(empty_map), 0)

    // ── map_count_values ────────────────────────
    let m2 = #{"a": 1, "b": 2, "c": 1, "d": 3, "e": 1}
    check_int("count_values/1",   map_count_values(m2, 1), 3)
    check_int("count_values/2",   map_count_values(m2, 2), 1)
    check_int("count_values/99",  map_count_values(m2, 99), 0)

    println("")
    println("═══════════════════════════════════════════════════════")
    println("  T4 HEXA stdlib/map — PASS " + to_string(pass_count) + " / FAIL " + to_string(fail_count))
    println("═══════════════════════════════════════════════════════")
    if fail_count > 0 { exit(1) }
}

// `main()` is auto-called by stage0 — no explicit call needed.
