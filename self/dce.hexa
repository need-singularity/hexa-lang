// self/dce.hexa — HEXA dead code elimination ported from src/dce.rs
// Walks the AST and marks/removes unreachable code:
// - Statements after an unconditional return in a block
// - if false { ... } branches (when condition is a literal)
// - if true { ... } else { ... } -- the else branch is dead
// - while false { ... } -- the entire loop is dead

// ── Result ─────────────────────────────────────────────────────

struct DceResult {
    stmts: [string],
    eliminated: int
}

// ── Context ────────────────────────────────────────────────────

struct DceCtx {
    eliminated: int
}

// ── Entry point ────────────────────────────────────────────────

fn eliminate_dead_code(stmts: [string]) -> DceResult {
    let ctx = DceCtx { eliminated: 0 }
    let optimized = dce_ctx_optimize_block(ctx, stmts)
    return DceResult { stmts: optimized, eliminated: ctx.eliminated }
}

// ── Optimize block ─────────────────────────────────────────────

fn dce_ctx_optimize_block(ctx: DceCtx, stmts: [string]) -> [string] {
    let mut result = []
    let reached_terminator = false

    for stmt in stmts {
        if reached_terminator {
            ctx.eliminated = ctx.eliminated + 1
            continue
        }

        let optimized = dce_ctx_optimize_stmt(ctx, stmt)

        if is_noop(optimized) {
            ctx.eliminated = ctx.eliminated + 1
            continue
        }

        if is_terminator(optimized) {
            reached_terminator = true
        }

        result = result.push(optimized)
    }

    return result
}

// ── Optimize a single statement ────────────────────────────────

fn dce_ctx_optimize_stmt(ctx: DceCtx, stmt: string) -> string {
    // In full AST impl, this matches on statement kinds:
    // - FnDecl: recurse into body
    // - For/While/Loop/Scope: recurse into body
    // - While(false, _): eliminate -> noop
    // - If(true, then, else): eliminate else branch
    // - If(false, then, else): eliminate then branch
    // - TryCatch: recurse into both blocks
    // Simplified: pass through
    return stmt
}

// ── If with literal condition optimization ─────────────────────

struct IfInfo {
    cond_is_true: bool,
    cond_is_false: bool,
    then_block: [string],
    else_block: [string]
}

fn optimize_if(ctx: DceCtx, info: IfInfo) -> [string] {
    if info.cond_is_true {
        // Eliminate else branch
        ctx.eliminated = ctx.eliminated + info.else_block.length()
        return dce_ctx_optimize_block(ctx, info.then_block)
    }
    if info.cond_is_false {
        // Eliminate then branch
        ctx.eliminated = ctx.eliminated + info.then_block.length()
        if info.else_block.length() > 0 {
            return dce_ctx_optimize_block(ctx, info.else_block)
        }
        ctx.eliminated = ctx.eliminated + 1
        return []
    }
    // Non-literal condition: recurse both branches
    let opt_then = dce_ctx_optimize_block(ctx, info.then_block)
    let opt_else = dce_ctx_optimize_block(ctx, info.else_block)
    // Return combined (in full impl, reconstruct If node)
    return opt_then
}

// ── Helper checks ──────────────────────────────────────────────

fn is_noop(stmt: string) -> bool {
    // Empty block expression is a noop
    if stmt == "EmptyBlock" { return true }
    return false
}

fn is_terminator(stmt: string) -> bool {
    if stmt == "Return" { return true }
    if stmt == "Throw" { return true }
    return false
}
