// ═══════════════════════════════════════════════════════════════════
//  test_motion_transfer.hexa — Motion Transfer (#324)
// ═══════════════════════════════════════════════════════════════════

// -- inlined from self/ml/motion_transfer.hexa --
// codegen import not wired for test files

// ===================================================================
//  self/ml/motion_transfer.hexa -- Motion Transfer (#324)
//
//  Decompose video into appearance and motion, then transfer motion
//  from one video to another's appearance.
//
//  Core idea:
//    - Motion estimation: compute optical flow (displacement field)
//      between consecutive frames via a learned network.
//    - Appearance encoding: encode a single frame into a compact
//      appearance code via a learned encoder.
//    - Motion application (warping): given an appearance code and a
//      flow field, produce an output frame.
//
//  Architecture:
//    Motion encoder: two frames -> hidden -> 2D flow field
//      h = tanh(W_me * [frame1 ++ frame2] + b_me)    2*D_spatial -> D_motion
//      flow = W_mf * h + b_mf                        D_motion -> D_spatial
//      (flow has 2 channels: dx, dy per spatial pixel)
//
//    Appearance encoder: single frame -> appearance code
//      h_a = tanh(W_ae * frame + b_ae)                D_spatial -> D_appear
//      code = tanh(W_ac * h_a + b_ac)                 D_appear -> D_appear
//
//    Decoder: appearance code + flow -> output frame
//      combined = [appearance ++ flow]
//      h_d = tanh(W_d * combined + b_d)               (D_appear + D_spatial) -> D_motion
//      out = sigmoid(W_do * h_d + b_do)               D_motion -> D_spatial
//
//  API:
//    mt_init(D_spatial, D_motion, D_appear, seed) -> model
//    mt_estimate_motion(model, frame1, frame2) -> flow_field
//    mt_encode_appearance(model, frame) -> appearance_code
//    mt_warp(frame, flow_field) -> warped_frame
//    mt_apply_motion(model, appearance, flow_field) -> output_frame
//    mt_transfer(model, source_frames, target_frame) -> output_frames
//    mt_loss(model, video_frames) -> float (reconstruction)
//    mt_train_step(model, videos, lr) -> model
//
//  AI-NATIVE attrs:
//    @pure  (forward / loss)
//    @hot   (training step)
// ===================================================================

// ── Math helpers ──────────────────────────────────────────────

fn mt_abs(x) { if x < 0.0 { return 0.0 - x } return x }

fn mt_exp(x) {
    let mut v = x
    if v > 20.0 { v = 20.0 }
    if v < -20.0 { v = -20.0 }
    let mut result = 1.0
    let mut term = 1.0
    let mut i = 1
    while i < 30 {
        term = term * v / to_float(i)
        result = result + term
        i = i + 1
    }
    if result < 0.0 { return 0.0 }
    return result
}

fn mt_log(x) {
    if x <= 0.0 { return -30.0 }
    let mut v = x
    let mut count = 0
    while v > 2.0 {
        v = v / 2.718281828
        count = count + 1
    }
    while v < 0.5 {
        v = v * 2.718281828
        count = count - 1
    }
    let d = v - 1.0
    let ln_v = d - d * d / 2.0 + d * d * d / 3.0 - d * d * d * d / 4.0
    return to_float(count) + ln_v
}

fn mt_tanh(x) {
    let ep = mt_exp(x)
    let en = mt_exp(0.0 - x)
    return (ep - en) / (ep + en)
}

fn mt_sigmoid(x) {
    return 1.0 / (1.0 + mt_exp(0.0 - x))
}

fn mt_sqrt(x) {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 0.001 { g = 0.001 }
    let mut _i = 0
    while _i < 20 {
        g = (g + x / g) / 2.0
        _i = _i + 1
    }
    return g
}

// ── Array helpers ─────────────────────────────────────────────

fn mt_zeros(n) {
    let mut v = []
    let mut _i = 0
    while _i < n {
    return v
        _i = _i + 1
}

fn mt_zeros_2d(rows, cols) {
    let mut m = []
    let mut _r = 0
    while _r < rows {
        let mut row = []
        for _c in 0..cols { row = row + [0.0] }
        m = m + [row]
        _r = _r + 1
    }
    return m
}

// ── RNG ───────────────────────────────────────────────────────

fn mt_lcg(state) {
    return (state * 1103515245 + 12345) % 2147483648
}

fn mt_uniform(state) {
    let s = mt_lcg(state)
    return [to_float(s) / 2147483648.0, to_float(s)]
}

// ── Xavier-ish init for a 2D weight matrix ────────────────────

fn mt_init_weight(rows, cols, state_in) {
    let mut state = state_in
    let scale = 1.0 / mt_sqrt(to_float(rows + cols))
    let mut W = mt_zeros_2d(rows, cols)
    let mut i = 0
    while i < rows {
        for j in 0..cols {
            let u = mt_uniform(state)
            state = int(u[1])
            if state <= 0 { state = 1 }
            W[i][j] = (u[0] - 0.5) * 2.0 * scale
        }
        i = i + 1
    }
    return #{"W": W, "state": state}
}

// ===================================================================
//  mt_init  --  Create motion transfer model
//
//  D_spatial : flattened frame size (e.g. H*W for grayscale)
//  D_motion  : hidden dimension for motion encoder/decoder
//  D_appear  : appearance code dimension
//  seed      : RNG seed for reproducibility
// ===================================================================
fn mt_init(D_spatial, D_motion, D_appear, seed) {
    let mut state = seed
    if state <= 0 { state = 1 }

    // Motion encoder: [frame1 ++ frame2] -> D_motion -> D_spatial (flow)
    let r1 = mt_init_weight(D_motion, D_spatial * 2, state)
    let W_me = r1["W"]
    state = r1["state"]
    let b_me = mt_zeros(D_motion)

    let r2 = mt_init_weight(D_spatial, D_motion, state)
    let W_mf = r2["W"]
    state = r2["state"]
    let b_mf = mt_zeros(D_spatial)

    // Appearance encoder: frame -> D_appear (two layers)
    let r3 = mt_init_weight(D_appear, D_spatial, state)
    let W_ae = r3["W"]
    state = r3["state"]
    let b_ae = mt_zeros(D_appear)

    let r4 = mt_init_weight(D_appear, D_appear, state)
    let W_ac = r4["W"]
    state = r4["state"]
    let b_ac = mt_zeros(D_appear)

    // Decoder: [appearance ++ flow] -> D_motion -> D_spatial
    let r5 = mt_init_weight(D_motion, D_appear + D_spatial, state)
    let W_d = r5["W"]
    state = r5["state"]
    let b_d = mt_zeros(D_motion)

    let r6 = mt_init_weight(D_spatial, D_motion, state)
    let W_do = r6["W"]
    state = r6["state"]
    let b_do = mt_zeros(D_spatial)

    return #{
        "D_spatial": D_spatial,
        "D_motion": D_motion,
        "D_appear": D_appear,
        "W_me": W_me, "b_me": b_me,
        "W_mf": W_mf, "b_mf": b_mf,
        "W_ae": W_ae, "b_ae": b_ae,
        "W_ac": W_ac, "b_ac": b_ac,
        "W_d": W_d, "b_d": b_d,
        "W_do": W_do, "b_do": b_do
    }
}

// ===================================================================
//  mt_estimate_motion  --  Compute flow field between two frames
//
//  Input: frame1, frame2 each [D_spatial]
//  Output: flow_field [D_spatial] (displacement per element)
// ===================================================================
@pure
fn mt_estimate_motion(model, frame1, frame2) {
    let D_spatial = model["D_spatial"]
    let D_motion = model["D_motion"]
    let W_me = model["W_me"]
    let b_me = model["b_me"]
    let W_mf = model["W_mf"]
    let b_mf = model["b_mf"]

    // Concatenate frames
    let inp = frame1 + frame2

    // Hidden layer
    let mut h = mt_zeros(D_motion)
    let mut i = 0
    while i < D_motion {
        let mut s = b_me[i]
        for j in 0..(D_spatial * 2) {
            s = s + W_me[i][j] * inp[j]
        }
        h[i] = mt_tanh(s)
        i = i + 1
    }

    // Flow output (no activation -- flow can be positive or negative)
    let mut flow = mt_zeros(D_spatial)
    let mut i = 0
    while i < D_spatial {
        let mut s = b_mf[i]
        for j in 0..D_motion {
            s = s + W_mf[i][j] * h[j]
        }
        flow[i] = s
        i = i + 1
    }
    return flow
}

// ===================================================================
//  mt_encode_appearance  --  Encode single frame to appearance code
//
//  Input: frame [D_spatial]
//  Output: appearance code [D_appear]
// ===================================================================
@pure
fn mt_encode_appearance(model, frame) {
    let D_spatial = model["D_spatial"]
    let D_appear = model["D_appear"]
    let W_ae = model["W_ae"]
    let b_ae = model["b_ae"]
    let W_ac = model["W_ac"]
    let b_ac = model["b_ac"]

    // First layer
    let mut h_a = mt_zeros(D_appear)
    let mut i = 0
    while i < D_appear {
        let mut s = b_ae[i]
        for j in 0..D_spatial {
            s = s + W_ae[i][j] * frame[j]
        }
        h_a[i] = mt_tanh(s)
        i = i + 1
    }

    // Second layer
    let mut code = mt_zeros(D_appear)
    let mut i = 0
    while i < D_appear {
        let mut s = b_ac[i]
        for j in 0..D_appear {
            s = s + W_ac[i][j] * h_a[j]
        }
        code[i] = mt_tanh(s)
        i = i + 1
    }
    return code
}

// ===================================================================
//  mt_warp  --  Simple warp: frame + flow_field -> warped frame
//
//  For a 1D "video" this adds the flow displacement to each pixel.
//  Clamp result to [0, 1].
// ===================================================================
@pure
fn mt_warp(frame, flow_field) {
    let n = len(frame)
    let mut out = mt_zeros(n)
    let mut i = 0
    while i < n {
        let mut v = frame[i] + flow_field[i]
        if v < 0.0 { v = 0.0 }
        if v > 1.0 { v = 1.0 }
        out[i] = v
        i = i + 1
    }
    return out
}

// ===================================================================
//  mt_apply_motion  --  Decode appearance + flow -> output frame
//
//  Concatenates appearance code and flow field, passes through
//  decoder network.
// ===================================================================
@pure
fn mt_apply_motion(model, appearance, flow_field) {
    let D_spatial = model["D_spatial"]
    let D_motion = model["D_motion"]
    let D_appear = model["D_appear"]
    let W_d = model["W_d"]
    let b_d = model["b_d"]
    let W_do = model["W_do"]
    let b_do = model["b_do"]

    // Concatenate appearance + flow
    let combined = appearance + flow_field

    // Hidden layer
    let mut h = mt_zeros(D_motion)
    let mut i = 0
    while i < D_motion {
        let mut s = b_d[i]
        for j in 0..(D_appear + D_spatial) {
            s = s + W_d[i][j] * combined[j]
        }
        h[i] = mt_tanh(s)
        i = i + 1
    }

    // Output (sigmoid to keep in [0,1])
    let mut out = mt_zeros(D_spatial)
    let mut i = 0
    while i < D_spatial {
        let mut s = b_do[i]
        for j in 0..D_motion {
            s = s + W_do[i][j] * h[j]
        }
        out[i] = mt_sigmoid(s)
        i = i + 1
    }
    return out
}

// ===================================================================
//  mt_transfer  --  Transfer motion from source video to target frame
//
//  source_frames: list of frames defining the motion sequence
//  target_frame:  single frame providing appearance
//  Returns: list of output frames with target appearance + source motion
// ===================================================================
@pure
fn mt_transfer(model, source_frames, target_frame) {
    let n = len(source_frames)
    if n < 2 { return [target_frame] }

    let appearance = mt_encode_appearance(model, target_frame)
    let mut outputs = [target_frame]

    let mut i = 1
    while i < n {
        let flow = mt_estimate_motion(model, source_frames[i - 1], source_frames[i])
        let out = mt_apply_motion(model, appearance, flow)
        outputs = outputs + [out]
        i = i + 1
    }
    return outputs
}

// ===================================================================
//  mt_loss  --  Reconstruction loss over a video sequence
//
//  For each consecutive pair (t, t+1):
//    1. Estimate motion from frame_t -> frame_{t+1}
//    2. Encode appearance from frame_t
//    3. Decode: apply_motion(appearance, flow) -> reconstructed frame_{t+1}
//    4. MSE between reconstruction and ground truth frame_{t+1}
//
//  Returns average MSE over all pairs.
// ===================================================================
@pure
fn mt_loss(model, video_frames) {
    let n = len(video_frames)
    if n < 2 { return 0.0 }
    let D_spatial = model["D_spatial"]
    let mut total = 0.0
    let pairs = n - 1

    let mut t = 0
    while t < pairs {
        let frame_t = video_frames[t]
        let frame_next = video_frames[t + 1]

        let flow = mt_estimate_motion(model, frame_t, frame_next)
        let appearance = mt_encode_appearance(model, frame_t)
        let recon = mt_apply_motion(model, appearance, flow)

        let mut mse = 0.0
        for i in 0..D_spatial {
            let diff = recon[i] - frame_next[i]
            mse = mse + diff * diff
        }
        total = total + mse / to_float(D_spatial)
        t = t + 1
    }
    return total / to_float(pairs)
}

// ===================================================================
//  Forward pass helpers for training (return intermediates)
// ===================================================================

fn mt_motion_forward(model, frame1, frame2) {
    let D_spatial = model["D_spatial"]
    let D_motion = model["D_motion"]
    let W_me = model["W_me"]
    let b_me = model["b_me"]
    let W_mf = model["W_mf"]
    let b_mf = model["b_mf"]

    let inp = frame1 + frame2

    let mut h = mt_zeros(D_motion)
    let mut i = 0
    while i < D_motion {
        let mut s = b_me[i]
        for j in 0..(D_spatial * 2) {
            s = s + W_me[i][j] * inp[j]
        }
        h[i] = mt_tanh(s)
        i = i + 1
    }

    let mut flow = mt_zeros(D_spatial)
    let mut i = 0
    while i < D_spatial {
        let mut s = b_mf[i]
        for j in 0..D_motion {
            s = s + W_mf[i][j] * h[j]
        }
        flow[i] = s
        i = i + 1
    }
    return #{"inp": inp, "h": h, "flow": flow}
}

fn mt_appear_forward(model, frame) {
    let D_spatial = model["D_spatial"]
    let D_appear = model["D_appear"]
    let W_ae = model["W_ae"]
    let b_ae = model["b_ae"]
    let W_ac = model["W_ac"]
    let b_ac = model["b_ac"]

    let mut h_a = mt_zeros(D_appear)
    let mut i = 0
    while i < D_appear {
        let mut s = b_ae[i]
        for j in 0..D_spatial {
            s = s + W_ae[i][j] * frame[j]
        }
        h_a[i] = mt_tanh(s)
        i = i + 1
    }

    let mut code = mt_zeros(D_appear)
    let mut i = 0
    while i < D_appear {
        let mut s = b_ac[i]
        for j in 0..D_appear {
            s = s + W_ac[i][j] * h_a[j]
        }
        code[i] = mt_tanh(s)
        i = i + 1
    }
    return #{"h_a": h_a, "code": code}
}

fn mt_decode_forward(model, appearance, flow_field) {
    let D_spatial = model["D_spatial"]
    let D_motion = model["D_motion"]
    let D_appear = model["D_appear"]
    let W_d = model["W_d"]
    let b_d = model["b_d"]
    let W_do = model["W_do"]
    let b_do = model["b_do"]

    let combined = appearance + flow_field

    let mut h = mt_zeros(D_motion)
    let mut i = 0
    while i < D_motion {
        let mut s = b_d[i]
        for j in 0..(D_appear + D_spatial) {
            s = s + W_d[i][j] * combined[j]
        }
        h[i] = mt_tanh(s)
        i = i + 1
    }

    let mut out = mt_zeros(D_spatial)
    let mut i = 0
    while i < D_spatial {
        let mut s = b_do[i]
        for j in 0..D_motion {
            s = s + W_do[i][j] * h[j]
        }
        out[i] = mt_sigmoid(s)
        i = i + 1
    }
    return #{"combined": combined, "h": h, "out": out}
}

// ===================================================================
//  mt_train_step  --  One gradient descent step
//
//  videos: list of video clips, each clip is a list of frames
//  lr: learning rate
//
//  Gradient flow (reconstruction loss = MSE):
//    d_loss/d_out = 2*(out - target) / D_spatial
//
//    Decoder:
//      out_i = sigmoid(z_do_i)  =>  d/dz = out*(1-out)
//      z_do_i = sum_j W_do[i][j]*h_d[j] + b_do[i]
//      h_d_j = tanh(z_d_j)     =>  d/dz = 1 - h_d^2
//      z_d_j = sum_k W_d[j][k]*combined[k] + b_d[j]
//
//    Gradients propagate back into both appearance encoder and
//    motion encoder via the combined = [appearance ++ flow] input.
//
//    Motion encoder:
//      flow_i = z_mf_i = sum_j W_mf[i][j]*h_me[j] + b_mf[i]
//      h_me_j = tanh(z_me_j)  =>  d/dz = 1 - h_me^2
//      z_me_j = sum_k W_me[j][k]*inp[k] + b_me[j]
//
//    Appearance encoder:
//      code_i = tanh(z_ac_i)  =>  d/dz = 1 - code^2
//      z_ac_i = sum_j W_ac[i][j]*h_a[j] + b_ac[j]
//      h_a_j = tanh(z_ae_j)   =>  d/dz = 1 - h_a^2
//      z_ae_j = sum_k W_ae[j][k]*frame[k] + b_ae[j]
// ===================================================================
@hot
fn mt_train_step(model, videos, lr) {
    let D_spatial = model["D_spatial"]
    let D_motion = model["D_motion"]
    let D_appear = model["D_appear"]

    // Accumulate gradients
    let mut gW_me = mt_zeros_2d(D_motion, D_spatial * 2)
    let mut gb_me = mt_zeros(D_motion)
    let mut gW_mf = mt_zeros_2d(D_spatial, D_motion)
    let mut gb_mf = mt_zeros(D_spatial)

    let mut gW_ae = mt_zeros_2d(D_appear, D_spatial)
    let mut gb_ae = mt_zeros(D_appear)
    let mut gW_ac = mt_zeros_2d(D_appear, D_appear)
    let mut gb_ac = mt_zeros(D_appear)

    let mut gW_d = mt_zeros_2d(D_motion, D_appear + D_spatial)
    let mut gb_d = mt_zeros(D_motion)
    let mut gW_do = mt_zeros_2d(D_spatial, D_motion)
    let mut gb_do = mt_zeros(D_spatial)

    let mut total_pairs = 0

    let mut v = 0
    while v < len(videos) {
        let clip = videos[v]
        let n_frames = len(clip)
        if n_frames < 2 { continue }

        for t in 0..(n_frames - 1) {
            let frame_t = clip[t]
            let frame_next = clip[t + 1]
            total_pairs = total_pairs + 1

            // Forward passes with intermediates
            let mf = mt_motion_forward(model, frame_t, frame_next)
            let h_me = mf["h"]
            let flow = mf["flow"]
            let me_inp = mf["inp"]

            let af = mt_appear_forward(model, frame_t)
            let h_a = af["h_a"]
            let code = af["code"]

            let df = mt_decode_forward(model, code, flow)
            let combined = df["combined"]
            let h_d = df["h"]
            let out = df["out"]

            // ── d_loss/d_out = 2*(out - target) / D_spatial ──
            let inv_d = 1.0 / to_float(D_spatial)
            let mut d_out = mt_zeros(D_spatial)
            for i in 0..D_spatial {
                d_out[i] = 2.0 * (out[i] - frame_next[i]) * inv_d
            }

            // ── Decoder backward ──
            // d_out -> d_z_do: d_z_do = d_out * out*(1-out)
            let mut d_z_do = mt_zeros(D_spatial)
            for i in 0..D_spatial {
                d_z_do[i] = d_out[i] * out[i] * (1.0 - out[i])
            }

            // gW_do, gb_do
            for i in 0..D_spatial {
                gb_do[i] = gb_do[i] + d_z_do[i]
                for j in 0..D_motion {
                    gW_do[i][j] = gW_do[i][j] + d_z_do[i] * h_d[j]
                }
            }

            // d_h_d
            let mut d_h_d = mt_zeros(D_motion)
            for j in 0..D_motion {
                let mut s = 0.0
                for i in 0..D_spatial {
                    s = s + d_z_do[i] * model["W_do"][i][j]
                }
                d_h_d[j] = s
            }

            // d_z_d = d_h_d * (1 - h_d^2)
            let mut d_z_d = mt_zeros(D_motion)
            for j in 0..D_motion {
                d_z_d[j] = d_h_d[j] * (1.0 - h_d[j] * h_d[j])
            }

            // gW_d, gb_d
            for j in 0..D_motion {
                gb_d[j] = gb_d[j] + d_z_d[j]
                for k in 0..(D_appear + D_spatial) {
                    gW_d[j][k] = gW_d[j][k] + d_z_d[j] * combined[k]
                }
            }

            // d_combined: gradient w.r.t. combined = [appearance ++ flow]
            let mut d_combined = mt_zeros(D_appear + D_spatial)
            for k in 0..(D_appear + D_spatial) {
                let mut s = 0.0
                for j in 0..D_motion {
                    s = s + d_z_d[j] * model["W_d"][j][k]
                }
                d_combined[k] = s
            }

            // Split d_combined into d_code [0..D_appear] and d_flow [D_appear..D_appear+D_spatial]
            let mut d_code = mt_zeros(D_appear)
            for i in 0..D_appear { d_code[i] = d_combined[i] }
            let mut d_flow = mt_zeros(D_spatial)
            for i in 0..D_spatial { d_flow[i] = d_combined[D_appear + i] }

            // ── Appearance encoder backward ──
            // code = tanh(z_ac) => d_z_ac = d_code * (1 - code^2)
            let mut d_z_ac = mt_zeros(D_appear)
            for i in 0..D_appear {
                d_z_ac[i] = d_code[i] * (1.0 - code[i] * code[i])
            }
            for i in 0..D_appear {
                gb_ac[i] = gb_ac[i] + d_z_ac[i]
                for j in 0..D_appear {
                    gW_ac[i][j] = gW_ac[i][j] + d_z_ac[i] * h_a[j]
                }
            }

            // d_h_a
            let mut d_h_a = mt_zeros(D_appear)
            for j in 0..D_appear {
                let mut s = 0.0
                for i in 0..D_appear {
                    s = s + d_z_ac[i] * model["W_ac"][i][j]
                }
                d_h_a[j] = s
            }

            // d_z_ae = d_h_a * (1 - h_a^2)
            let mut d_z_ae = mt_zeros(D_appear)
            for j in 0..D_appear {
                d_z_ae[j] = d_h_a[j] * (1.0 - h_a[j] * h_a[j])
            }
            for j in 0..D_appear {
                gb_ae[j] = gb_ae[j] + d_z_ae[j]
                for k in 0..D_spatial {
                    gW_ae[j][k] = gW_ae[j][k] + d_z_ae[j] * frame_t[k]
                }
            }

            // ── Motion encoder backward ──
            // flow = W_mf * h_me + b_mf (linear, no activation)
            // d_flow already computed above
            for i in 0..D_spatial {
                gb_mf[i] = gb_mf[i] + d_flow[i]
                for j in 0..D_motion {
                    gW_mf[i][j] = gW_mf[i][j] + d_flow[i] * h_me[j]
                }
            }

            // d_h_me
            let mut d_h_me = mt_zeros(D_motion)
            for j in 0..D_motion {
                let mut s = 0.0
                for i in 0..D_spatial {
                    s = s + d_flow[i] * model["W_mf"][i][j]
                }
                d_h_me[j] = s
            }

            // d_z_me = d_h_me * (1 - h_me^2)
            let mut d_z_me = mt_zeros(D_motion)
            for j in 0..D_motion {
                d_z_me[j] = d_h_me[j] * (1.0 - h_me[j] * h_me[j])
            }
            for j in 0..D_motion {
                gb_me[j] = gb_me[j] + d_z_me[j]
                for k in 0..(D_spatial * 2) {
                    gW_me[j][k] = gW_me[j][k] + d_z_me[j] * me_inp[k]
                }
            }
        }
        v = v + 1
    }

    if total_pairs == 0 { return model }

    // ── Apply gradients (averaged over pairs) ──
    let inv_n = lr / to_float(total_pairs)

    let mut W_me_new = mt_zeros_2d(D_motion, D_spatial * 2)
    let mut b_me_new = mt_zeros(D_motion)
    let mut i = 0
    while i < D_motion {
        b_me_new[i] = model["b_me"][i] - inv_n * gb_me[i]
        for j in 0..(D_spatial * 2) {
            W_me_new[i][j] = model["W_me"][i][j] - inv_n * gW_me[i][j]
        }
        i = i + 1
    }

    let mut W_mf_new = mt_zeros_2d(D_spatial, D_motion)
    let mut b_mf_new = mt_zeros(D_spatial)
    let mut i = 0
    while i < D_spatial {
        b_mf_new[i] = model["b_mf"][i] - inv_n * gb_mf[i]
        for j in 0..D_motion {
            W_mf_new[i][j] = model["W_mf"][i][j] - inv_n * gW_mf[i][j]
        }
        i = i + 1
    }

    let mut W_ae_new = mt_zeros_2d(D_appear, D_spatial)
    let mut b_ae_new = mt_zeros(D_appear)
    let mut i = 0
    while i < D_appear {
        b_ae_new[i] = model["b_ae"][i] - inv_n * gb_ae[i]
        for j in 0..D_spatial {
            W_ae_new[i][j] = model["W_ae"][i][j] - inv_n * gW_ae[i][j]
        }
        i = i + 1
    }

    let mut W_ac_new = mt_zeros_2d(D_appear, D_appear)
    let mut b_ac_new = mt_zeros(D_appear)
    let mut i = 0
    while i < D_appear {
        b_ac_new[i] = model["b_ac"][i] - inv_n * gb_ac[i]
        for j in 0..D_appear {
            W_ac_new[i][j] = model["W_ac"][i][j] - inv_n * gW_ac[i][j]
        }
        i = i + 1
    }

    let mut W_d_new = mt_zeros_2d(D_motion, D_appear + D_spatial)
    let mut b_d_new = mt_zeros(D_motion)
    let mut i = 0
    while i < D_motion {
        b_d_new[i] = model["b_d"][i] - inv_n * gb_d[i]
        for j in 0..(D_appear + D_spatial) {
            W_d_new[i][j] = model["W_d"][i][j] - inv_n * gW_d[i][j]
        }
        i = i + 1
    }

    let mut W_do_new = mt_zeros_2d(D_spatial, D_motion)
    let mut b_do_new = mt_zeros(D_spatial)
    let mut i = 0
    while i < D_spatial {
        b_do_new[i] = model["b_do"][i] - inv_n * gb_do[i]
        for j in 0..D_motion {
            W_do_new[i][j] = model["W_do"][i][j] - inv_n * gW_do[i][j]
        }
        i = i + 1
    }

    return #{
        "D_spatial": D_spatial,
        "D_motion": D_motion,
        "D_appear": D_appear,
        "W_me": W_me_new, "b_me": b_me_new,
        "W_mf": W_mf_new, "b_mf": b_mf_new,
        "W_ae": W_ae_new, "b_ae": b_ae_new,
        "W_ac": W_ac_new, "b_ac": b_ac_new,
        "W_d": W_d_new, "b_d": b_d_new,
        "W_do": W_do_new, "b_do": b_do_new
    }
}


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs_(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx_(a, b, eps) { return fabs_(a - b) < eps }

println("=== Motion Transfer (#324) ===")

// ── Dimensions for tests ──
let D_sp = 4
let D_mo = 6
let D_ap = 3

// ── T1: init model shapes ─────────────────────────────────────
let m = mt_init(D_sp, D_mo, D_ap, 42)
check("T1 D_spatial",  m["D_spatial"] == D_sp)
check("T1 D_motion",   m["D_motion"]  == D_mo)
check("T1 D_appear",   m["D_appear"]  == D_ap)
check("T1 W_me shape", len(m["W_me"]) == D_mo && len(m["W_me"][0]) == D_sp * 2)
check("T1 W_mf shape", len(m["W_mf"]) == D_sp && len(m["W_mf"][0]) == D_mo)
check("T1 W_ae shape", len(m["W_ae"]) == D_ap && len(m["W_ae"][0]) == D_sp)
check("T1 W_d shape",  len(m["W_d"])  == D_mo && len(m["W_d"][0]) == D_ap + D_sp)

// ── T2: deterministic init ────────────────────────────────────
let m2a = mt_init(D_sp, D_mo, D_ap, 99)
let m2b = mt_init(D_sp, D_mo, D_ap, 99)
let mut det_ok = true
let mut i = 0

while i < D_mo {
    let mut j = 0

    while j < (D_sp * 2) {
        if fabs_(m2a["W_me"][i][j] - m2b["W_me"][i][j]) > 1.0e-9 { det_ok = false }
    }
}
check("T2 deterministic init", det_ok)

// ── T3: motion estimation dimension and finiteness ────────────
let f1 = [0.1, 0.2, 0.3, 0.4]
let f2 = [0.4, 0.3, 0.2, 0.1]
let flow3 = mt_estimate_motion(m, f1, f2)
check("T3 flow dim", len(flow3) == D_sp)
let mut fin3 = true
let mut i = 0

while i < D_sp { if fabs_(flow3[i]) > 1000.0 { fin3 = false } }
check("T3 flow finite", fin3)

// ── T4: identical frames -> near-zero flow ────────────────────
let f_same = [0.5, 0.5, 0.5, 0.5]
let flow4 = mt_estimate_motion(m, f_same, f_same)
let mut flow4_sum = 0.0
let mut i = 0

while i < D_sp { flow4_sum = flow4_sum + fabs_(flow4[i]) }
// With biases the flow won't be exactly zero, but should be small-ish
// compared to flow between very different frames
let f_diff = [0.0, 0.0, 0.0, 0.0]
let flow4b = mt_estimate_motion(m, f_same, f_diff)
let mut flow4b_sum = 0.0
let mut i = 0

while i < D_sp { flow4b_sum = flow4b_sum + fabs_(flow4b[i]) }
check("T4 same-frame flow <= diff-frame flow", flow4_sum <= flow4b_sum + 0.5)

// ── T5: appearance encoding dimension and range ───────────────
let code5 = mt_encode_appearance(m, f1)
check("T5 code dim", len(code5) == D_ap)
let mut in_range = true
let mut i = 0

while i < D_ap {
    if code5[i] < -1.0 || code5[i] > 1.0 { in_range = false }
}
check("T5 code in [-1,1] (tanh)", in_range)

// ── T6: appearance encoding determinism ───────────────────────
let code6a = mt_encode_appearance(m, f1)
let code6b = mt_encode_appearance(m, f1)
let mut det6 = true
let mut i = 0

while i < D_ap {
    if fabs_(code6a[i] - code6b[i]) > 1.0e-9 { det6 = false }
}
check("T6 appearance deterministic", det6)

// ── T7: different frames yield different codes ────────────────
let code7a = mt_encode_appearance(m, f1)
let code7b = mt_encode_appearance(m, f2)
let mut diff7 = 0.0
let mut i = 0

while i < D_ap { diff7 = diff7 + fabs_(code7a[i] - code7b[i]) }
check("T7 different frames != codes", diff7 > 1.0e-6)

// ── T8: warp clamping [0,1] ──────────────────────────────────
let warp_frame = [0.9, 0.1, 0.5, 0.0]
let warp_flow  = [0.5, -0.5, 0.0, -0.1]
let warped = mt_warp(warp_frame, warp_flow)
check("T8 warp dim", len(warped) == D_sp)
let mut clamp_ok = true
let mut i = 0

while i < D_sp {
    if warped[i] < 0.0 || warped[i] > 1.0 { clamp_ok = false }
}
check("T8 warp clamp [0,1]", clamp_ok)

// ── T9: warp with zero flow = identity ────────────────────────
let zero_flow = [0.0, 0.0, 0.0, 0.0]
let warp9 = mt_warp([0.3, 0.5, 0.7, 0.2], zero_flow)
check("T9 zero-flow identity", approx_(warp9[0], 0.3, 1.0e-9) && approx_(warp9[2], 0.7, 1.0e-9))

// ── T10: apply_motion output in [0,1] (sigmoid) ──────────────
let code10 = mt_encode_appearance(m, f1)
let flow10 = mt_estimate_motion(m, f1, f2)
let out10 = mt_apply_motion(m, code10, flow10)
check("T10 apply_motion dim", len(out10) == D_sp)
let mut sig_ok = true
let mut i = 0

while i < D_sp {
    if out10[i] < 0.0 || out10[i] > 1.0 { sig_ok = false }
}
check("T10 apply_motion in [0,1]", sig_ok)

// ── T11: transfer with < 2 frames returns target ─────────────
let target11 = [0.2, 0.4, 0.6, 0.8]
let tr11 = mt_transfer(m, [f1], target11)
check("T11 single-frame transfer len", len(tr11) == 1)
let mut t11_ok = true
let mut i = 0

while i < D_sp {
    if fabs_(tr11[0][i] - target11[i]) > 1.0e-9 { t11_ok = false }
}
check("T11 single-frame = target", t11_ok)

// ── T12: transfer output length matches source ───────────────
let source12 = [f1, f2, [0.5, 0.5, 0.5, 0.5]]
let tr12 = mt_transfer(m, source12, target11)
check("T12 transfer len == source len", len(tr12) == 3)
// First output should be the target frame itself
let mut t12_first = true
let mut i = 0

while i < D_sp {
    if fabs_(tr12[0][i] - target11[i]) > 1.0e-9 { t12_first = false }
}
check("T12 transfer[0] = target", t12_first)

// ── T13: transfer output frames are valid [0,1] ─────────────
let mut t13_ok = true
let mut fi = 0

while fi < len(tr12) {
    let mut i = 0

    while i < D_sp {
        if tr12[fi][i] < 0.0 || tr12[fi][i] > 1.0 { t13_ok = false }
    }
}
check("T13 transfer outputs in [0,1]", t13_ok)

// ── T14: loss is non-negative ─────────────────────────────────
let video14 = [f1, f2, [0.5, 0.5, 0.5, 0.5]]
let loss14 = mt_loss(m, video14)
check("T14 loss >= 0", loss14 >= 0.0)
check("T14 loss finite", loss14 < 1.0e6)

// ── T15: loss with single frame = 0.0 ────────────────────────
let loss15 = mt_loss(m, [f1])
check("T15 single frame loss = 0", approx_(loss15, 0.0, 1.0e-9))

// ── T16: motion forward returns intermediates ─────────────────
let mf16 = mt_motion_forward(m, f1, f2)
check("T16 motion_forward has inp", len(mf16["inp"]) == D_sp * 2)
check("T16 motion_forward has h", len(mf16["h"]) == D_mo)
check("T16 motion_forward has flow", len(mf16["flow"]) == D_sp)

// ── T17: appear forward returns intermediates ─────────────────
let af17 = mt_appear_forward(m, f1)
check("T17 appear_forward h_a dim", len(af17["h_a"]) == D_ap)
check("T17 appear_forward code dim", len(af17["code"]) == D_ap)

// ── T18: decode forward returns intermediates ─────────────────
let df18 = mt_decode_forward(m, af17["code"], mf16["flow"])
check("T18 decode_forward combined dim", len(df18["combined"]) == D_ap + D_sp)
check("T18 decode_forward h dim", len(df18["h"]) == D_mo)
check("T18 decode_forward out dim", len(df18["out"]) == D_sp)

// ── T19: training reduces loss ────────────────────────────────
let vid_a = [[0.1, 0.2, 0.3, 0.4], [0.2, 0.3, 0.4, 0.5], [0.3, 0.4, 0.5, 0.6]]
let vid_b = [[0.8, 0.7, 0.6, 0.5], [0.7, 0.6, 0.5, 0.4]]
let videos19 = [vid_a, vid_b]

let m19 = mt_init(D_sp, D_mo, D_ap, 7)
let loss_before = mt_loss(m19, vid_a)

let mut cur = m19
let mut _step = 0

while _step < 15 {
    cur = mt_train_step(cur, videos19, 0.05)
}

let loss_after = mt_loss(cur, vid_a)
check("T19 training reduces loss", loss_after < loss_before)

// ── T20: training changes weights ─────────────────────────────
let mut w_changed = false
let mut i = 0

while i < D_mo {
    let mut j = 0

    while j < (D_sp * 2) {
        if fabs_(cur["W_me"][i][j] - m19["W_me"][i][j]) > 1.0e-12 { w_changed = true }
    }
}
check("T20 weights changed after training", w_changed)

// ── T21: different seed -> different model ────────────────────
let ms1 = mt_init(D_sp, D_mo, D_ap, 1)
let ms2 = mt_init(D_sp, D_mo, D_ap, 2)
let mut seed_diff = 0.0
let mut i = 0

while i < D_mo {
    seed_diff = seed_diff + fabs_(ms1["W_me"][i][0] - ms2["W_me"][i][0])
}
check("T21 different seed -> different weights", seed_diff > 1.0e-6)

// ── T22: warp overflow clamps to 1.0 ─────────────────────────
let warp22 = mt_warp([0.9, 0.9, 0.9, 0.9], [0.5, 0.5, 0.5, 0.5])
let mut clamp22 = true
let mut i = 0

while i < D_sp {
    if warp22[i] > 1.0 { clamp22 = false }
}
check("T22 warp overflow clamped to 1.0", clamp22)

// ── T23: warp underflow clamps to 0.0 ────────────────────────
let warp23 = mt_warp([0.1, 0.1, 0.1, 0.1], [-0.5, -0.5, -0.5, -0.5])
let mut clamp23 = true
let mut i = 0

while i < D_sp {
    if warp23[i] < 0.0 { clamp23 = false }
}
check("T23 warp underflow clamped to 0.0", clamp23)

// ── T24: empty videos training returns model unchanged ────────
let m24 = mt_init(D_sp, D_mo, D_ap, 55)
let m24b = mt_train_step(m24, [], 0.01)
let mut unchanged = true
let mut i = 0

while i < D_mo {
    let mut j = 0

    while j < (D_sp * 2) {
        if fabs_(m24b["W_me"][i][j] - m24["W_me"][i][j]) > 1.0e-12 { unchanged = false }
    }
}
check("T24 empty videos -> no weight change", unchanged)

// ── T25: motion estimation is asymmetric ──────────────────────
let flow25a = mt_estimate_motion(m, f1, f2)
let flow25b = mt_estimate_motion(m, f2, f1)
let mut asym_diff = 0.0
let mut i = 0

while i < D_sp { asym_diff = asym_diff + fabs_(flow25a[i] - flow25b[i]) }
check("T25 motion estimation asymmetric", asym_diff > 1.0e-6)

// ── T26: transfer preserves frame count ──────────────────────
let src26 = [f1, f2, [0.3, 0.3, 0.3, 0.3], [0.6, 0.6, 0.6, 0.6], [0.9, 0.1, 0.9, 0.1]]
let tr26 = mt_transfer(m, src26, target11)
check("T26 transfer 5 frames -> 5 outputs", len(tr26) == 5)

println("")
println("=== Motion Transfer summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
