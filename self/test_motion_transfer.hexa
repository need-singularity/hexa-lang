// ═══════════════════════════════════════════════════════════════════
//  test_motion_transfer.hexa — Motion Transfer (#324)
// ═══════════════════════════════════════════════════════════════════

import "ml/motion_transfer.hexa"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs_(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx_(a, b, eps) { return fabs_(a - b) < eps }

println("=== Motion Transfer (#324) ===")

// ── Dimensions for tests ──
let D_sp = 4
let D_mo = 6
let D_ap = 3

// ── T1: init model shapes ─────────────────────────────────────
let m = mt_init(D_sp, D_mo, D_ap, 42)
check("T1 D_spatial",  m["D_spatial"] == D_sp)
check("T1 D_motion",   m["D_motion"]  == D_mo)
check("T1 D_appear",   m["D_appear"]  == D_ap)
check("T1 W_me shape", len(m["W_me"]) == D_mo && len(m["W_me"][0]) == D_sp * 2)
check("T1 W_mf shape", len(m["W_mf"]) == D_sp && len(m["W_mf"][0]) == D_mo)
check("T1 W_ae shape", len(m["W_ae"]) == D_ap && len(m["W_ae"][0]) == D_sp)
check("T1 W_d shape",  len(m["W_d"])  == D_mo && len(m["W_d"][0]) == D_ap + D_sp)

// ── T2: deterministic init ────────────────────────────────────
let m2a = mt_init(D_sp, D_mo, D_ap, 99)
let m2b = mt_init(D_sp, D_mo, D_ap, 99)
let mut det_ok = true
for i in 0..D_mo {
    for j in 0..(D_sp * 2) {
        if fabs_(m2a["W_me"][i][j] - m2b["W_me"][i][j]) > 1.0e-9 { det_ok = false }
    }
}
check("T2 deterministic init", det_ok)

// ── T3: motion estimation dimension and finiteness ────────────
let f1 = [0.1, 0.2, 0.3, 0.4]
let f2 = [0.4, 0.3, 0.2, 0.1]
let flow3 = mt_estimate_motion(m, f1, f2)
check("T3 flow dim", len(flow3) == D_sp)
let mut fin3 = true
for i in 0..D_sp { if fabs_(flow3[i]) > 1000.0 { fin3 = false } }
check("T3 flow finite", fin3)

// ── T4: identical frames -> near-zero flow ────────────────────
let f_same = [0.5, 0.5, 0.5, 0.5]
let flow4 = mt_estimate_motion(m, f_same, f_same)
let mut flow4_sum = 0.0
for i in 0..D_sp { flow4_sum = flow4_sum + fabs_(flow4[i]) }
// With biases the flow won't be exactly zero, but should be small-ish
// compared to flow between very different frames
let f_diff = [0.0, 0.0, 0.0, 0.0]
let flow4b = mt_estimate_motion(m, f_same, f_diff)
let mut flow4b_sum = 0.0
for i in 0..D_sp { flow4b_sum = flow4b_sum + fabs_(flow4b[i]) }
check("T4 same-frame flow <= diff-frame flow", flow4_sum <= flow4b_sum + 0.5)

// ── T5: appearance encoding dimension and range ───────────────
let code5 = mt_encode_appearance(m, f1)
check("T5 code dim", len(code5) == D_ap)
let mut in_range = true
for i in 0..D_ap {
    if code5[i] < -1.0 || code5[i] > 1.0 { in_range = false }
}
check("T5 code in [-1,1] (tanh)", in_range)

// ── T6: appearance encoding determinism ───────────────────────
let code6a = mt_encode_appearance(m, f1)
let code6b = mt_encode_appearance(m, f1)
let mut det6 = true
for i in 0..D_ap {
    if fabs_(code6a[i] - code6b[i]) > 1.0e-9 { det6 = false }
}
check("T6 appearance deterministic", det6)

// ── T7: different frames yield different codes ────────────────
let code7a = mt_encode_appearance(m, f1)
let code7b = mt_encode_appearance(m, f2)
let mut diff7 = 0.0
for i in 0..D_ap { diff7 = diff7 + fabs_(code7a[i] - code7b[i]) }
check("T7 different frames != codes", diff7 > 1.0e-6)

// ── T8: warp clamping [0,1] ──────────────────────────────────
let warp_frame = [0.9, 0.1, 0.5, 0.0]
let warp_flow  = [0.5, -0.5, 0.0, -0.1]
let warped = mt_warp(warp_frame, warp_flow)
check("T8 warp dim", len(warped) == D_sp)
let mut clamp_ok = true
for i in 0..D_sp {
    if warped[i] < 0.0 || warped[i] > 1.0 { clamp_ok = false }
}
check("T8 warp clamp [0,1]", clamp_ok)

// ── T9: warp with zero flow = identity ────────────────────────
let zero_flow = [0.0, 0.0, 0.0, 0.0]
let warp9 = mt_warp([0.3, 0.5, 0.7, 0.2], zero_flow)
check("T9 zero-flow identity", approx_(warp9[0], 0.3, 1.0e-9) && approx_(warp9[2], 0.7, 1.0e-9))

// ── T10: apply_motion output in [0,1] (sigmoid) ──────────────
let code10 = mt_encode_appearance(m, f1)
let flow10 = mt_estimate_motion(m, f1, f2)
let out10 = mt_apply_motion(m, code10, flow10)
check("T10 apply_motion dim", len(out10) == D_sp)
let mut sig_ok = true
for i in 0..D_sp {
    if out10[i] < 0.0 || out10[i] > 1.0 { sig_ok = false }
}
check("T10 apply_motion in [0,1]", sig_ok)

// ── T11: transfer with < 2 frames returns target ─────────────
let target11 = [0.2, 0.4, 0.6, 0.8]
let tr11 = mt_transfer(m, [f1], target11)
check("T11 single-frame transfer len", len(tr11) == 1)
let mut t11_ok = true
for i in 0..D_sp {
    if fabs_(tr11[0][i] - target11[i]) > 1.0e-9 { t11_ok = false }
}
check("T11 single-frame = target", t11_ok)

// ── T12: transfer output length matches source ───────────────
let source12 = [f1, f2, [0.5, 0.5, 0.5, 0.5]]
let tr12 = mt_transfer(m, source12, target11)
check("T12 transfer len == source len", len(tr12) == 3)
// First output should be the target frame itself
let mut t12_first = true
for i in 0..D_sp {
    if fabs_(tr12[0][i] - target11[i]) > 1.0e-9 { t12_first = false }
}
check("T12 transfer[0] = target", t12_first)

// ── T13: transfer output frames are valid [0,1] ─────────────
let mut t13_ok = true
for fi in 0..len(tr12) {
    for i in 0..D_sp {
        if tr12[fi][i] < 0.0 || tr12[fi][i] > 1.0 { t13_ok = false }
    }
}
check("T13 transfer outputs in [0,1]", t13_ok)

// ── T14: loss is non-negative ─────────────────────────────────
let video14 = [f1, f2, [0.5, 0.5, 0.5, 0.5]]
let loss14 = mt_loss(m, video14)
check("T14 loss >= 0", loss14 >= 0.0)
check("T14 loss finite", loss14 < 1.0e6)

// ── T15: loss with single frame = 0.0 ────────────────────────
let loss15 = mt_loss(m, [f1])
check("T15 single frame loss = 0", approx_(loss15, 0.0, 1.0e-9))

// ── T16: motion forward returns intermediates ─────────────────
let mf16 = mt_motion_forward(m, f1, f2)
check("T16 motion_forward has inp", len(mf16["inp"]) == D_sp * 2)
check("T16 motion_forward has h", len(mf16["h"]) == D_mo)
check("T16 motion_forward has flow", len(mf16["flow"]) == D_sp)

// ── T17: appear forward returns intermediates ─────────────────
let af17 = mt_appear_forward(m, f1)
check("T17 appear_forward h_a dim", len(af17["h_a"]) == D_ap)
check("T17 appear_forward code dim", len(af17["code"]) == D_ap)

// ── T18: decode forward returns intermediates ─────────────────
let df18 = mt_decode_forward(m, af17["code"], mf16["flow"])
check("T18 decode_forward combined dim", len(df18["combined"]) == D_ap + D_sp)
check("T18 decode_forward h dim", len(df18["h"]) == D_mo)
check("T18 decode_forward out dim", len(df18["out"]) == D_sp)

// ── T19: training reduces loss ────────────────────────────────
let vid_a = [[0.1, 0.2, 0.3, 0.4], [0.2, 0.3, 0.4, 0.5], [0.3, 0.4, 0.5, 0.6]]
let vid_b = [[0.8, 0.7, 0.6, 0.5], [0.7, 0.6, 0.5, 0.4]]
let videos19 = [vid_a, vid_b]

let m19 = mt_init(D_sp, D_mo, D_ap, 7)
let loss_before = mt_loss(m19, vid_a)

let mut cur = m19
for _step in 0..15 {
    cur = mt_train_step(cur, videos19, 0.05)
}

let loss_after = mt_loss(cur, vid_a)
check("T19 training reduces loss", loss_after < loss_before)

// ── T20: training changes weights ─────────────────────────────
let mut w_changed = false
for i in 0..D_mo {
    for j in 0..(D_sp * 2) {
        if fabs_(cur["W_me"][i][j] - m19["W_me"][i][j]) > 1.0e-12 { w_changed = true }
    }
}
check("T20 weights changed after training", w_changed)

// ── T21: different seed -> different model ────────────────────
let ms1 = mt_init(D_sp, D_mo, D_ap, 1)
let ms2 = mt_init(D_sp, D_mo, D_ap, 2)
let mut seed_diff = 0.0
for i in 0..D_mo {
    seed_diff = seed_diff + fabs_(ms1["W_me"][i][0] - ms2["W_me"][i][0])
}
check("T21 different seed -> different weights", seed_diff > 1.0e-6)

// ── T22: warp overflow clamps to 1.0 ─────────────────────────
let warp22 = mt_warp([0.9, 0.9, 0.9, 0.9], [0.5, 0.5, 0.5, 0.5])
let mut clamp22 = true
for i in 0..D_sp {
    if warp22[i] > 1.0 { clamp22 = false }
}
check("T22 warp overflow clamped to 1.0", clamp22)

// ── T23: warp underflow clamps to 0.0 ────────────────────────
let warp23 = mt_warp([0.1, 0.1, 0.1, 0.1], [-0.5, -0.5, -0.5, -0.5])
let mut clamp23 = true
for i in 0..D_sp {
    if warp23[i] < 0.0 { clamp23 = false }
}
check("T23 warp underflow clamped to 0.0", clamp23)

// ── T24: empty videos training returns model unchanged ────────
let m24 = mt_init(D_sp, D_mo, D_ap, 55)
let m24b = mt_train_step(m24, [], 0.01)
let mut unchanged = true
for i in 0..D_mo {
    for j in 0..(D_sp * 2) {
        if fabs_(m24b["W_me"][i][j] - m24["W_me"][i][j]) > 1.0e-12 { unchanged = false }
    }
}
check("T24 empty videos -> no weight change", unchanged)

// ── T25: motion estimation is asymmetric ──────────────────────
let flow25a = mt_estimate_motion(m, f1, f2)
let flow25b = mt_estimate_motion(m, f2, f1)
let mut asym_diff = 0.0
for i in 0..D_sp { asym_diff = asym_diff + fabs_(flow25a[i] - flow25b[i]) }
check("T25 motion estimation asymmetric", asym_diff > 1.0e-6)

// ── T26: transfer preserves frame count ──────────────────────
let src26 = [f1, f2, [0.3, 0.3, 0.3, 0.3], [0.6, 0.6, 0.6, 0.6], [0.9, 0.1, 0.9, 0.1]]
let tr26 = mt_transfer(m, src26, target11)
check("T26 transfer 5 frames -> 5 outputs", len(tr26) == 5)

println("")
println("=== Motion Transfer summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
