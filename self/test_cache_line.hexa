// ═══════════════════════════════════════════════════════════
//  test_cache_line.hexa — @cache_line attribute: 64B alignment
//  ROI id=29, P3, effect 2x — hot field cache line alignment
//  Tests:
//    1. @cache_line fn with field accesses → detected
//    2. @cache_line fn without fields → violation
//    3. Struct field access patterns
//    4. codegen alignment helper verification
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA @cache_line Tests — 64B Alignment (ROI #29)")
println("═══════════════════════════════════════════════════════")
println("")

// ── Test 1: struct with hot field accesses ────────────────

struct Particle {
    x: float,
    y: float,
    z: float,
    mass: float,
    color: int
}

@cache_line fn update_particle(p) {
    let new_x = p.x + 1.0
    let new_y = p.y + 2.0
    let new_z = p.z + 3.0
    return Particle { x: new_x, y: new_y, z: new_z, mass: p.mass, color: p.color }
}

let p = Particle { x: 0.0, y: 0.0, z: 0.0, mass: 1.0, color: 255 }
let p2 = update_particle(p)
check("cache_line particle x", p2.x, 1.0)
check("cache_line particle y", p2.y, 2.0)
check("cache_line particle z", p2.z, 3.0)
check("cache_line particle mass preserved", p2.mass, 1.0)

// ── Test 2: @cache_line with no field accesses ───────────

@cache_line fn no_fields(a, b) {
    return a + b
}

check("cache_line no_fields result", no_fields(3, 4), 7)

// ── Test 3: @cache_line with loop field access ───────────

struct Point { x: int, y: int }

@cache_line fn sum_points(points) {
    let mut total_x = 0
    let mut total_y = 0
    let mut i = 0
    while i < len(points) {
        total_x = total_x + points[i].x
        total_y = total_y + points[i].y
        i = i + 1
    }
    return total_x + total_y
}

let points = [
    Point { x: 1, y: 2 },
    Point { x: 3, y: 4 },
    Point { x: 5, y: 6 }
]
check("cache_line sum_points", sum_points(points), 21)

// ── Test 4: @cache_line with single field ────────────────

struct Counter { count: int, label: string }

@cache_line fn increment_counter(c) {
    return Counter { count: c.count + 1, label: c.label }
}

let c1 = Counter { count: 0, label: "hits" }
let c2 = increment_counter(c1)
check("cache_line increment count", c2.count, 1)
check("cache_line increment label", c2.label, "hits")

// ── Test 5: @cache_line alignment constant ───────────────
// Verify the alignment value is 64 bytes (standard cache line)

let cache_line_size = 64
check("cache_line size", cache_line_size, 64)
check("cache_line power of 2", cache_line_size % 2, 0)

// ── Summary ──────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  @cache_line: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")
