// ═══════════════════════════════════════════════════════════
//  test_sort_topk_rewrite.hexa — ROI #141
//  Verifies:
//    (a) rt_nth_element / rt_top_k_sorted / rt_top_k_unordered
//        runtime correctness (uses the wrappers from
//        self/rt/array_ops.hexa indirectly — we inline the same
//        Hoare partition here so the test is runnable standalone
//        under interp without module resolution tweaks).
//    (b) detect_sort_topk_pattern precision contract — must fire
//        on `.sort().take(k)` / `.sort().first(k)` but NOT on
//        `.sort().first()` (arg-less = arr[0]).
//    (c) k >= n falls back to full sort (semantic-preserving).
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA ROI #141 — sort-topk rewrite tests")
println("═══════════════════════════════════════════════════════")

// ── Inline copies of the rt helpers so this test runs without
//    needing import machinery to line up. These MUST stay in sync
//    with self/rt/array_ops.hexa; any divergence is a red flag.

@pure fn t141_cmp(a, b) {
    if a < b { return -1 }
    if a > b { return 1 }
    return 0
}

@pure fn t141_swap(arr, i, j) {
    let n = len(arr)
    let mut out = []
    let mut k = 0
    while k < n {
        if k == i {
            out.push(arr[j])
        } else {
            if k == j {
                out.push(arr[i])
            } else {
                out.push(arr[k])
            }
        }
        k = k + 1
    }
    return out
}

@pure fn t141_med3(arr, lo, mid, hi, cmp) {
    let a = arr[lo]
    let b = arr[mid]
    let c = arr[hi]
    if cmp(a, b) <= 0 {
        if cmp(b, c) <= 0 { return b }
        if cmp(a, c) <= 0 { return c }
        return a
    }
    if cmp(a, c) <= 0 { return a }
    if cmp(b, c) <= 0 { return c }
    return b
}

@pure fn t141_sort_full(arr, cmp) {
    // Simple insertion sort — OK for small k-prefix and fallback.
    // Uses `done` flag instead of a break keyword (not supported in
    // interp while bodies).
    let n = len(arr)
    let mut out = []
    let mut i = 0
    while i < n { out.push(arr[i]); i = i + 1 }
    let mut ii = 1
    while ii < n {
        let mut jj = ii
        let mut done = false
        while !done && jj > 0 {
            if cmp(out[jj - 1], out[jj]) > 0 {
                out = t141_swap(out, jj - 1, jj)
                jj = jj - 1
            } else {
                done = true
            }
        }
        ii = ii + 1
    }
    return out
}

@pure fn t141_top_k_unordered(arr, k, cmp) {
    let n = len(arr)
    if n == 0 { return [] }
    if k <= 0 { return [] }
    if k >= n { return t141_sort_full(arr, cmp) }
    let mut buf = []
    let mut i = 0
    while i < n { buf.push(arr[i]); i = i + 1 }
    let mut lo = 0
    let mut hi = n - 1
    let target = k - 1
    while lo < hi {
        let mid = lo + (hi - lo) / 2
        let pivot = t141_med3(buf, lo, mid, hi, cmp)
        let mut li = lo - 1
        let mut hj = hi + 1
        let mut done = false
        while !done {
            li = li + 1
            while cmp(buf[li], pivot) < 0 { li = li + 1 }
            hj = hj - 1
            while cmp(buf[hj], pivot) > 0 { hj = hj - 1 }
            if li >= hj {
                done = true
            } else {
                buf = t141_swap(buf, li, hj)
            }
        }
        if target <= hj {
            hi = hj
        } else {
            lo = hj + 1
        }
    }
    let mut out = []
    let mut j = 0
    while j < k { out.push(buf[j]); j = j + 1 }
    return out
}

@pure fn t141_top_k_sorted(arr, k, cmp) {
    let pref = t141_top_k_unordered(arr, k, cmp)
    return t141_sort_full(pref, cmp)
}

// ── (A) Runtime correctness ────────────────────────────────────

println("--- (A) Runtime correctness ---")

let data = [7, 2, 9, 4, 1, 8, 3, 6, 5]

// Case 1: sorted top-k, k=3 — expected [1,2,3]
let t3 = t141_top_k_sorted(data, 3, t141_cmp)
check("sorted top-3 len", len(t3), 3)
check("sorted top-3[0]", t3[0], 1)
check("sorted top-3[1]", t3[1], 2)
check("sorted top-3[2]", t3[2], 3)

// Case 2: unordered top-k — must contain exactly {1,2,3} (any order)
let u3 = t141_top_k_unordered(data, 3, t141_cmp)
check("unordered top-3 len", len(u3), 3)
let mut u3_sum = 0
let mut ui = 0
while ui < len(u3) { u3_sum = u3_sum + u3[ui]; ui = ui + 1 }
check("unordered top-3 contains 1,2,3 (sum=6)", u3_sum, 6)
// Each must be <= 3 (strictly k smallest)
let mut u3_ok = true
let mut uj = 0
while uj < len(u3) {
    if u3[uj] > 3 { u3_ok = false }
    uj = uj + 1
}
check("unordered top-3 all <= 3", u3_ok, true)

// Case 3: k >= n fallback to full sort (k=20 for n=9)
let t20 = t141_top_k_sorted(data, 20, t141_cmp)
check("k>=n fallback len", len(t20), 9)
check("k>=n fallback sorted[0]", t20[0], 1)
check("k>=n fallback sorted[8]", t20[8], 9)

// Case 4: k == n exact (another boundary)
let t9 = t141_top_k_sorted(data, 9, t141_cmp)
check("k==n sorted len", len(t9), 9)
check("k==n sorted[0]", t9[0], 1)
check("k==n sorted[8]", t9[8], 9)

// Case 5: k == 0 edge
let t0 = t141_top_k_sorted(data, 0, t141_cmp)
check("k==0 → empty", len(t0), 0)

// Case 6: k == 1 — single min
let t1 = t141_top_k_sorted(data, 1, t141_cmp)
check("k==1 len", len(t1), 1)
check("k==1 value == min", t1[0], 1)

// ── (B) Detector precision ─────────────────────────────────────
// We can't invoke detect_sort_topk_pattern here without the ast module,
// but we can reason about the contract in documentation and assert it
// with mirror logic on a tiny synthetic shape.

println("--- (B) Detector precision (mirror) ---")

// Mirror of detector's decision matrix:
//   input → should_rewrite
//   .sort().take(k)    → true
//   .sort().first(k)   → true
//   .sort().first()    → false  (R1: 0 args = scalar access)
//   .sort_by(c).take(k) → true
//   .sort().take()     → false  (no k)
//   .take(k) alone     → false  (no inner sort)
//   .filter(p).take(k) → false  (inner not sort)
fn should_rewrite_mirror(outer_method, outer_arity, inner_method, inner_arity) {
    let is_take = outer_method == "take"
    let is_first = outer_method == "first"
    if !is_take && !is_first { return false }
    if outer_arity != 1 { return false }
    let is_sort = inner_method == "sort"
    let is_sort_by = inner_method == "sort_by"
    if !is_sort && !is_sort_by { return false }
    if is_sort && inner_arity != 0 { return false }
    if is_sort_by && inner_arity != 1 { return false }
    return true
}

check("detector: .sort().take(k)", should_rewrite_mirror("take", 1, "sort", 0), true)
check("detector: .sort().first(k)", should_rewrite_mirror("first", 1, "sort", 0), true)
check("detector: .sort().first() NO", should_rewrite_mirror("first", 0, "sort", 0), false)
check("detector: .sort_by(c).take(k)", should_rewrite_mirror("take", 1, "sort_by", 1), true)
check("detector: .sort().take() NO", should_rewrite_mirror("take", 0, "sort", 0), false)
check("detector: .filter(p).take(k) NO", should_rewrite_mirror("take", 1, "filter", 1), false)
check("detector: .take(k) alone NO (inner=\"\")", should_rewrite_mirror("take", 1, "", 0), false)

// ── Summary ────────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL")
println("═══════════════════════════════════════════════════════")
if fail_count > 0 { exit(1) }
