// ═══════════════════════════════════════════════════════════
//  test_string_edge.hexa — String Edge Cases & Interpolation Tests
//  Tests: concatenation chains, special characters, string building,
//         conversion round-trips, string as key, string comparison,
//         string accumulation, repeated operations, boundary conditions
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA String Edge Case Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Concatenation chains ──────────────────────────────

println("--- Concat Chains ---")

check("5-part concat", "a" + "b" + "c" + "d" + "e", "abcde")
check("10-part concat", "1" + "2" + "3" + "4" + "5" + "6" + "7" + "8" + "9" + "0", "1234567890")

let mut built = ""
let mut i = 0
while i < 10 {
    built = built + to_string(i)
    i = i + 1
}
check("loop concat", built, "0123456789")

// ── 2. String with numbers ───────────────────────────────

println("")
println("--- String + Number ---")

check("str + int", "val=" + to_string(42), "val=42")
check("str + neg", "x=" + to_string(-7), "x=-7")
check("str + float", "pi=" + to_string(3.14), "pi=3.14")
check("str + bool t", "ok=" + to_string(true), "ok=true")
check("str + bool f", "ok=" + to_string(false), "ok=false")

// ── 3. Conversion round-trips ────────────────────────────

println("")
println("--- Round Trips ---")

check("int roundtrip", to_int(to_string(42)), 42)
check("int roundtrip neg", to_int(to_string(-99)), -99)
check("float roundtrip", to_float(to_string(3.14)), 3.14)
check("string roundtrip", to_string(to_int("123")), "123")

// ── 4. String comparison edge cases ──────────────────────

println("")
println("--- Comparison Edge ---")

check("same str eq", "hello" == "hello", true)
check("diff len neq", "abc" == "abcd", false)
check("prefix neq", "abc" != "abcd", true)
check("case diff", "ABC" == "abc", false)
check("empty vs non", "" == "a", false)
check("space matters", " " == "", false)
check("space vs space", " " == " ", true)

// ── 5. String methods edge cases ─────────────────────────

println("")
println("--- Method Edge Cases ---")

check("contains self", "hello".contains("hello"), true)
check("contains empty", "hello".contains(""), true)
check("contains single", "hello".contains("h"), true)
check("contains end", "hello".contains("lo"), true)
check("contains not", "hello".contains("xyz"), false)

check("starts_with full", "hello".starts_with("hello"), true)
check("starts_with empty", "hello".starts_with(""), true)
check("starts_with h", "hello".starts_with("h"), true)
check("starts_with no", "hello".starts_with("x"), false)

check("ends_with full", "hello".ends_with("hello"), true)
check("ends_with empty", "hello".ends_with(""), true)
check("ends_with o", "hello".ends_with("o"), true)
check("ends_with no", "hello".ends_with("x"), false)

// ── 6. Split edge cases ──────────────────────────────────

println("")
println("--- Split Edge ---")

let s1 = "a,b,c".split(",")
check("split comma len", len(s1), 3)
check("split comma [0]", s1[0], "a")
check("split comma [2]", s1[2], "c")

let s2 = "hello".split(",")
check("split no match len", len(s2), 1)
check("split no match [0]", s2[0], "hello")

let s3 = "a::b::c".split("::")
check("split multi-char len", len(s3), 3)
check("split multi-char [1]", s3[1], "b")

// ── 7. String building patterns ──────────────────────────

println("")
println("--- Building Patterns ---")

fn repeat_str(s, n) {
    let mut result = ""
    let mut i = 0
    while i < n {
        result = result + s
        i = i + 1
    }
    return result
}
check("repeat x 5", repeat_str("x", 5), "xxxxx")
check("repeat ab 3", repeat_str("ab", 3), "ababab")
check("repeat empty", repeat_str("x", 0), "")

fn join_with(arr, sep) {
    let mut result = ""
    let mut i = 0
    while i < len(arr) {
        if i > 0 {
            result = result + sep
        }
        result = result + to_string(arr[i])
        i = i + 1
    }
    return result
}
check("join comma", join_with(["a", "b", "c"], ","), "a,b,c")
check("join space", join_with(["hello", "world"], " "), "hello world")
check("join empty", join_with([], ","), "")
check("join single", join_with(["x"], ","), "x")

// ── 8. Replace operations ────────────────────────────────

println("")
println("--- Replace ---")

check("replace basic", "hello world".replace("world", "hexa"), "hello hexa")
check("replace first", "aaa".replace("a", "b"), "bbb")
check("replace none", "hello".replace("xyz", "!"), "hello")

// ── 9. Trim operations ──────────────────────────────────

println("")
println("--- Trim ---")

check("trim spaces", "  hello  ".trim(), "hello")
check("trim left only", "  hello".trim(), "hello")
check("trim right only", "hello  ".trim(), "hello")
check("trim none needed", "hello".trim(), "hello")
check("trim all spaces", "   ".trim(), "")

// ── 10. Case operations ──────────────────────────────────

println("")
println("--- Case ---")

check("to_upper basic", "hello".to_upper(), "HELLO")
check("to_upper mixed", "Hello World".to_upper(), "HELLO WORLD")
check("to_lower basic", "HELLO".to_lower(), "hello")
check("to_lower mixed", "Hello World".to_lower(), "hello world")
check("to_upper empty", "".to_upper(), "")
check("to_lower empty", "".to_lower(), "")

// ── Summary ──────────────────────────────────────────────

println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    throw "TESTS FAILED: " + to_string(fail_count)
}
