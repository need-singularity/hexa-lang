// ===================================================================
//  test_activation_checkpoint.hexa — Activation Checkpointing Tests
//
//  Validates:
//    1. checkpoint_forward produces correct final output
//    2. Checkpoint indices are correct
//    3. Memory saved ratio computation
//    4. checkpoint_backward returns gradients
//    5. Selective recompute count
//    6. Edge case: checkpoint_every = 1 (save all)
//    7. Edge case: checkpoint_every >= num_layers
//    8. Large layer count memory savings
//    9. Compute overhead ratio
//   10. Backward gradient shape
//
//  Execution: ./hexa self/test_activation_checkpoint.hexa
//  Minimum 8 check() statements.
// ===================================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

// ===================================================================
//  Inline module (self-contained test)
// ===================================================================

struct LayerFn {
    weights: array,
    bias: float
}

struct CheckpointResult {
    final_output: array,
    checkpoints: array,
    checkpoint_indices: array,
    all_outputs: array,
    num_layers: int,
    checkpoint_every: int
}

struct BackwardResult {
    gradients: array,
    recompute_count: int
}

fn apply_layer(layer, input) {
    let n = len(input)
    let wn = len(layer.weights)
    let mut output = []
    let mut i = 0
    while i < n {
        let wi = i % wn
        let val = input[i] * layer.weights[wi] + layer.bias
        output = output + [val]
        i = i + 1
    }
    return output
}

fn checkpoint_forward(layers, input, checkpoint_every) {
    let num_layers = len(layers)
    let mut current = input
    let mut checkpoints = []
    let mut checkpoint_indices = []
    let mut all_outputs = []

    checkpoints = checkpoints + [input]
    checkpoint_indices = checkpoint_indices + [0]

    let mut i = 0
    while i < num_layers {
        current = apply_layer(layers[i], current)
        all_outputs = all_outputs + [current]
        let layer_num = i + 1
        if layer_num % checkpoint_every == 0 {
            checkpoints = checkpoints + [current]
            checkpoint_indices = checkpoint_indices + [layer_num]
        }
        i = i + 1
    }

    return CheckpointResult {
        final_output: current,
        checkpoints: checkpoints,
        checkpoint_indices: checkpoint_indices,
        all_outputs: all_outputs,
        num_layers: num_layers,
        checkpoint_every: checkpoint_every
    }
}

fn checkpoint_backward(saved, grad) {
    let num_layers = saved.num_layers
    let mut current_grad = grad
    let mut recompute_count = 0
    let mut layer_grads = []

    let mut i = 0
    while i < num_layers {
        layer_grads = layer_grads + [[]]
        i = i + 1
    }

    i = num_layers - 1
    while i >= 0 {
        let layer_idx = i
        let mut is_checkpointed = false
        let nc = len(saved.checkpoint_indices)
        let mut ci = 0
        while ci < nc {
            if saved.checkpoint_indices[ci] == layer_idx {
                is_checkpointed = true
                ci = nc
            }
            ci = ci + 1
        }
        if !is_checkpointed {
            recompute_count = recompute_count + 1
        }
        let n = len(current_grad)
        let mut new_grad = []
        let mut j = 0
        while j < n {
            new_grad = new_grad + [current_grad[j] * 0.95]
            j = j + 1
        }
        layer_grads[i] = current_grad
        current_grad = new_grad
        i = i - 1
    }

    return BackwardResult {
        gradients: layer_grads,
        recompute_count: recompute_count
    }
}

fn memory_saved_ratio(num_layers, checkpoint_every) {
    if num_layers <= 0 { return 0.0 }
    if checkpoint_every <= 0 { return 0.0 }
    if checkpoint_every >= num_layers { return 0.0 }
    let total_activations = to_float(num_layers)
    let stored = to_float(num_layers / checkpoint_every + 1)
    let ratio = 1.0 - stored / total_activations
    if ratio < 0.0 { return 0.0 }
    return ratio
}

fn compute_overhead_ratio(num_layers, checkpoint_every) {
    if checkpoint_every <= 0 { return 0.0 }
    if checkpoint_every >= num_layers { return 0.0 }
    let segments = num_layers / checkpoint_every
    let recomputed = to_float(segments * checkpoint_every)
    let total = to_float(num_layers)
    return recomputed / total
}

// ===================================================================
//  TESTS
// ===================================================================

println("===================================================")
println("  Activation Checkpointing Test Suite")
println("===================================================")

// -- Build test layers --
let layer1 = LayerFn { weights: [1.1, 0.9, 1.0], bias: 0.01 }
let layer2 = LayerFn { weights: [0.8, 1.2, 1.0], bias: 0.02 }
let layer3 = LayerFn { weights: [1.0, 1.0, 1.0], bias: 0.03 }
let layer4 = LayerFn { weights: [0.9, 1.1, 0.95], bias: 0.01 }
let layer5 = LayerFn { weights: [1.05, 0.95, 1.0], bias: 0.02 }
let layer6 = LayerFn { weights: [1.0, 1.0, 1.0], bias: 0.01 }

let layers = [layer1, layer2, layer3, layer4, layer5, layer6]
let input = [1.0, 2.0, 3.0]

// -- 1. Checkpoint forward: correct final output --
println("")
println("=== Forward Pass ===")
let result = checkpoint_forward(layers, input, 2)
check("forward: final output has correct length", len(result.final_output) == 3)
check("forward: num_layers recorded", result.num_layers == 6)

// Verify final output by computing without checkpointing
let mut expected = input
let mut li = 0
while li < 6 {
    expected = apply_layer(layers[li], expected)
    li = li + 1
}
let mut out_match = true
let mut k = 0
while k < 3 {
    if fabs(result.final_output[k] - expected[k]) > 0.0001 {
        out_match = false
    }
    k = k + 1
}
check("forward: output matches non-checkpointed", out_match)

// -- 2. Checkpoint indices --
println("")
println("=== Checkpoint Indices ===")
// checkpoint_every=2 => checkpoints at layers 0 (input), 2, 4, 6
check("indices: includes input (0)", result.checkpoint_indices[0] == 0)
check("indices: checkpoint at layer 2", result.checkpoint_indices[1] == 2)
check("indices: checkpoint at layer 4", result.checkpoint_indices[2] == 4)
check("indices: checkpoint at layer 6", result.checkpoint_indices[3] == 6)

// -- 3. Memory saved ratio --
println("")
println("=== Memory Savings ===")
let ratio_6_2 = memory_saved_ratio(6, 2)
check("memory_saved: 6 layers, every 2", ratio_6_2 > 0.3)

let ratio_24_4 = memory_saved_ratio(24, 4)
check("memory_saved: 24 layers, every 4", ratio_24_4 > 0.5)

// -- 4. Backward --
println("")
println("=== Backward Pass ===")
let grad = [1.0, 1.0, 1.0]
let bwd = checkpoint_backward(result, grad)
check("backward: gradients for each layer", len(bwd.gradients) == 6)
check("backward: recompute count > 0", bwd.recompute_count > 0)

// -- 5. Recompute count --
// With checkpoint_every=2, layers 0,2,4,6 are checkpointed (indices)
// Layers 1,3,5 are NOT checkpointed => 3 recomputes
// Plus layers 2,4 are at checkpoint_indices but layer indices 2,4 match
// Actually: checkpoint_indices = [0,2,4,6], layer indices checked = [0,1,2,3,4,5]
// layers 1,3,5 not in checkpoint_indices => recompute_count = 3
check("recompute: correct count for every=2", bwd.recompute_count == 3)

// -- 6. Edge case: checkpoint_every = 1 (save all) --
println("")
println("=== Edge Cases ===")
let r_all = checkpoint_forward(layers, input, 1)
// Every layer is checkpointed
check("every=1: all layers checkpointed", len(r_all.checkpoints) == 7)

let ratio_all = memory_saved_ratio(6, 1)
// Saving 7 checkpoints for 6 layers => ratio negative => 0
check("every=1: no memory saved", ratio_all <= 0.001)

// -- 7. Edge case: checkpoint_every >= num_layers --
let ratio_big = memory_saved_ratio(6, 10)
check("every>=N: no memory saved", ratio_big == 0.0)

// -- 8. Large layer count --
let ratio_100_10 = memory_saved_ratio(100, 10)
check("100 layers, every 10: significant savings", ratio_100_10 > 0.8)

// -- 9. Compute overhead ratio --
let overhead = compute_overhead_ratio(12, 3)
check("compute_overhead: 12 layers, every 3", overhead > 0.9)

// -- 10. Backward gradient shape --
let grad2 = [0.5, 0.5, 0.5]
let bwd2 = checkpoint_backward(result, grad2)
let g_last = bwd2.gradients[5]
check("backward: last layer gradient length", len(g_last) == 3)

// ===================================================================
//  Summary
// ===================================================================
println("")
println("=== Activation Checkpointing Tests Summary ===")
println("pass=" + str(pass_count) + " fail=" + str(fail_count))
if fail_count == 0 {
    println("ALL PASS")
} else {
    println("FAILED")
}
println(str(pass_count) + " passed")
