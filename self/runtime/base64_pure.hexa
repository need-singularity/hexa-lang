// self/runtime/base64_pure.hexa -- Phase 2.6 runtime port (base64)
//
// Pure-Hexa RFC 4648 base64 encoder/decoder. Mirrors hexa_base64_encode
// (runtime.c:4367) and hexa_base64_decode (runtime.c:4396).
//
// ASCII input/output only; the C reference treats input bytes as
// unsigned char so non-ASCII data round-trips correctly. In pure
// hexa we operate on `ord(substring(i, i+1))` which yields the raw
// byte value. Encoded output is always ASCII.
//
// Pitfalls:
//   P15 let mut
//   P29 .push() returns new array — unused here

let B64_ALPHABET = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"

// ── _b64_char_at (internal) — index into alphabet ─────────────────
fn _b64_char_at(idx) {
    B64_ALPHABET.substring(idx, idx + 1)
}

// ── _b64_decode_char (internal) — char → 0..63 or -1 ──────────────
fn _b64_decode_char(c) {
    let o = ord(c)
    if o >= 65 && o <= 90  { return o - 65 }       // A-Z
    if o >= 97 && o <= 122 { return o - 97 + 26 }  // a-z
    if o >= 48 && o <= 57  { return o - 48 + 52 }  // 0-9
    if o == 43 { return 62 }                       // +
    if o == 47 { return 63 }                       // /
    -1
}

// ── base64_encode_pure ────────────────────────────────────────────
// Mirrors hexa_base64_encode (runtime.c:4367).
pub fn base64_encode_pure(s) {
    if type_of(s) != "string" { return "" }
    let n = len(s)
    let mut out = ""
    let mut i = 0
    while i + 3 <= n {
        let b0 = ord(s.substring(i, i + 1))
        let b1 = ord(s.substring(i + 1, i + 2))
        let b2 = ord(s.substring(i + 2, i + 3))
        let t = (b0 * 65536) + (b1 * 256) + b2
        // Portable bit-extraction: shift via division, mask via modulo.
        out = out + _b64_char_at((t / 262144) % 64)   // (t >> 18) & 0x3F
        out = out + _b64_char_at((t / 4096) % 64)     // (t >> 12) & 0x3F
        out = out + _b64_char_at((t / 64) % 64)       // (t >> 6)  & 0x3F
        out = out + _b64_char_at(t % 64)              // t & 0x3F
        i = i + 3
    }
    if i < n {
        let rem = n - i
        let b0 = ord(s.substring(i, i + 1))
        let mut t = b0 * 65536
        if rem == 2 {
            t = t + ord(s.substring(i + 1, i + 2)) * 256
        }
        out = out + _b64_char_at((t / 262144) % 64)
        out = out + _b64_char_at((t / 4096) % 64)
        if rem == 2 {
            out = out + _b64_char_at((t / 64) % 64)
        } else {
            out = out + "="
        }
        out = out + "="
    }
    out
}

// ── base64_decode_pure ────────────────────────────────────────────
// Mirrors hexa_base64_decode (runtime.c:4396). Skips non-alphabet
// characters and stops at the first '='.
pub fn base64_decode_pure(s) {
    if type_of(s) != "string" { return "" }
    let n = len(s)
    let mut out_chars = []
    let mut bits = 0
    let mut vbits = 0
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "=" {
            i = n
        } else {
            let v = _b64_decode_char(c)
            if v >= 0 {
                bits = bits * 64 + v
                vbits = vbits + 6
                if vbits >= 8 {
                    vbits = vbits - 8
                    // emit high byte
                    let scale = 1
                    let mut sc = scale
                    let mut p = 0
                    while p < vbits {
                        sc = sc * 2
                        p = p + 1
                    }
                    let byte = (bits / sc) % 256
                    out_chars.push(from_char_code(byte))
                    // mask off emitted bits from `bits`
                    bits = bits % sc
                }
            }
            i = i + 1
        }
    }
    out_chars.join("")
}
