// ═══════════════════════════════════════════════════════════════════
//  self/runtime/bitops_pure.hexa — pure-Hexa arith-overflow / pow2 ops
//
//  Ported as net-new pure-Hexa semantics. runtime.c does NOT currently
//  expose checked/wrapping arithmetic or power-of-two helpers — the
//  closest cousin is hexa_float_to_int (self/runtime.c:4355). Integer
//  overflow in the stage0 interpreter silently wraps via two's
//  complement, so these helpers give callers an *explicit* protocol.
//
//  Public API:
//      checked_add_pure(a, b)        -> int | nil (nil on int64 overflow)
//      checked_mul_pure(a, b)        -> int | nil (nil on int64 overflow)
//      wrapping_add_pure(a, b, bits) -> int (unsigned wrap at 2^bits)
//      is_power_of_two_pure(n)       -> bool (n > 0 and n & (n-1) == 0)
//      next_power_of_two_pure(n)     -> int | nil (smallest 2^k >= n)
//      isqrt_pure(n)                 -> int | nil (floor(sqrt(n)), Newton)
//      log2_int_pure(n)              -> int | nil (floor(log2(n)))
//      ipow_pure(base, exp)          -> int | nil (base^exp, exp >= 0)
//      digit_sum_pure(n)             -> int (sum of base-10 digits of |n|)
//      bit_reverse32_pure(a)         -> int (reverse low 32 bits)
//
//  SEMANTIC DIVERGENCE from hypothetical runtime.c counterparts
//  ────────────────────────────────────────────────────────────
//  * All pure-Hexa ints are 64-bit signed (stage0 interpreter width).
//    A C runtime `add_checked` on a 32-bit int would wrap at 2^31;
//    our `checked_add_pure` checks against INT64 limits only. If the
//    caller wants 32-bit semantics they should combine `wrapping_add_pure`
//    with `bits=32`.
//  * `checked_*` return `nil` (void value) on overflow. runtime.c
//    patterns more commonly abort or silently wrap.
//  * `wrapping_add_pure` interprets `bits` as unsigned width. A 64-bit
//    wrapping add is already the native interpreter behaviour; the
//    `bits` parameter is only load-bearing for `bits < 64`.
//  * `next_power_of_two_pure(0)` returns 1 (matching Rust's
//    next_power_of_two convention — smallest pow2 >= n, with 2^0 = 1).
// ═══════════════════════════════════════════════════════════════════

// ── int64 boundary constants ────────────────────────────────────────
@pure
fn _i64_max() { return 9223372036854775807 }  // 2^63 - 1

@pure
fn _i64_min() { return 0 - 9223372036854775807 - 1 }  // -2^63

// ── pow2(n) — returns 2^n for n in [0, 62] ──────────────────────────
// Shared with bit_pure's pow2 in spirit; redefined here to keep
// bitops_pure standalone.
@pure
fn _pow2(n) {
    let mut r = 1
    let mut i = 0
    while i < n {
        r = r * 2
        i = i + 1
    }
    return r
}

// ═══════════════════════════════════════════════════════════════════
//  checked_add_pure — int64 checked addition
// ═══════════════════════════════════════════════════════════════════
// Returns nil when a + b would exceed [INT64_MIN, INT64_MAX].
// Uses pre-check: if b > 0 and a > MAX - b  -> overflow
//                 if b < 0 and a < MIN - b  -> underflow
@pure
pub fn checked_add_pure(a, b) {
    let hi = _i64_max()
    let lo = _i64_min()
    if b > 0 {
        if a > hi - b { return nil }
    }
    if b < 0 {
        if a < lo - b { return nil }
    }
    return a + b
}

// ═══════════════════════════════════════════════════════════════════
//  checked_mul_pure — int64 checked multiplication
// ═══════════════════════════════════════════════════════════════════
// Returns nil on int64 overflow. Handles sign edge cases (INT_MIN * -1
// overflows because +INT_MIN is not representable).
@pure
pub fn checked_mul_pure(a, b) {
    if a == 0 { return 0 }
    if b == 0 { return 0 }
    let hi = _i64_max()
    let lo = _i64_min()

    // INT_MIN * -1 is the classic overflow corner.
    if a == lo {
        if b == -1 { return nil }
    }
    if b == lo {
        if a == -1 { return nil }
    }

    // Generic path — use division-based check. Integer division in
    // the interpreter truncates toward zero, which is what we want for
    // magnitude comparison after handling the INT_MIN corners above.
    let prod = a * b
    // Recover: prod / b should equal a. If it doesn't, overflow happened.
    if b != 0 {
        if (prod / b) != a { return nil }
    }
    // Also clamp against the signed range explicitly (belt + suspenders;
    // interpreter already wrapped so prod may read as hi/lo exactly).
    if prod > hi { return nil }
    if prod < lo { return nil }
    return prod
}

// ═══════════════════════════════════════════════════════════════════
//  wrapping_add_pure — unsigned wrap at 2^bits
// ═══════════════════════════════════════════════════════════════════
// For `bits == 64` returns the native interpreter wrap (equivalent to
// plain `a + b`, since hexa ints are already int64). For `bits` in
// {8, 16, 32} masks the result to `bits` low bits so callers simulating
// narrower widths get a stable unsigned representation.
@pure
pub fn wrapping_add_pure(a, b, bits) {
    let sum = a + b
    if bits >= 64 { return sum }
    if bits <= 0 { return 0 }
    let modulus = _pow2(bits)
    // Hexa `%` is truncation-mod; use `sum - (sum / mod) * mod` to
    // get a true Euclidean remainder (always non-negative).
    let q = sum / modulus
    let mut r = sum - q * modulus
    if r < 0 { r = r + modulus }
    return r
}

// ═══════════════════════════════════════════════════════════════════
//  is_power_of_two_pure
// ═══════════════════════════════════════════════════════════════════
// True iff n > 0 and n is 2^k for some k >= 0.
// Uses the classic `n & (n - 1) == 0` trick — which IS in bit_pure via
// `&` directly, so this works in the stage0 interpreter.
@pure
pub fn is_power_of_two_pure(n) {
    if n <= 0 { return false }
    return (n & (n - 1)) == 0
}

// ═══════════════════════════════════════════════════════════════════
//  next_power_of_two_pure
// ═══════════════════════════════════════════════════════════════════
// Smallest 2^k such that 2^k >= n.
//   n <= 0  -> 1 (matches Rust convention next_power_of_two(0) = 1)
//   n == 1  -> 1
//   already pow2 -> n itself
//   > 2^62  -> nil (next pow2 would exceed INT64_MAX = 2^63 - 1)
@pure
pub fn next_power_of_two_pure(n) {
    if n <= 1 { return 1 }
    if is_power_of_two_pure(n) { return n }
    // 2^62 = 4611686018427387904 is the largest pow2 that fits in i64.
    // Any n strictly greater than that has no representable answer.
    let cap = _pow2(62)
    if n > cap { return nil }
    let mut p = 1
    while p < n {
        p = p * 2
    }
    return p
}

// ═══════════════════════════════════════════════════════════════════
//  isqrt_pure — integer square root (floor(sqrt(n)))
// ═══════════════════════════════════════════════════════════════════
// Returns floor(sqrt(n)) for n >= 0, nil for n < 0.
// Uses Newton's method with integer arithmetic — converges quadratically
// for int64 inputs. Unlike sqrt_pure (float), this has NO rounding error:
// result^2 <= n < (result + 1)^2 exactly.
//
// Note: private `_isqrt` already exists in prime_sieve_pure.hexa but is
// not publicly exported; this is the public pure-Hexa integer-sqrt API.
@pure
pub fn isqrt_pure(n) {
    if n < 0 { return nil }
    if n < 2 { return n }
    // Newton iteration: x_{k+1} = (x_k + n/x_k) / 2, converging to sqrt(n).
    // Seed with n/2 — safe upper bound for n >= 4.
    let mut x = n
    let mut y = (x + 1) / 2
    while y < x {
        x = y
        y = (x + n / x) / 2
    }
    return x
}

// ═══════════════════════════════════════════════════════════════════
//  log2_int_pure — floor(log2(n)) via bit-length
// ═══════════════════════════════════════════════════════════════════
// Returns k such that 2^k <= n < 2^(k+1), for n > 0.
// Returns nil for n <= 0 (log2 undefined on non-positive).
// Pure int operation — `log2_pure` exists for floats; this is the
// integer counterpart.
@pure
pub fn log2_int_pure(n) {
    if n <= 0 { return nil }
    let mut x = n
    let mut k = 0
    while x > 1 {
        x = x / 2
        k = k + 1
    }
    return k
}

// ═══════════════════════════════════════════════════════════════════
//  ipow_pure — integer power base^exp via exponentiation-by-squaring
// ═══════════════════════════════════════════════════════════════════
// Returns base^exp for integer base, exp >= 0. Returns nil for exp < 0
// (not representable as int). `pow_pure` exists for floats; this is the
// integer counterpart with no FP rounding.
// Overflow is NOT checked — caller should combine with checked_mul_pure
// or clamp the input range for safety on large inputs.
// Convention: ipow_pure(0, 0) = 1 (matches math.pow / Python).
@pure
pub fn ipow_pure(base, exp) {
    if exp < 0 { return nil }
    let mut result = 1
    let mut b = base
    let mut e = exp
    while e > 0 {
        if (e & 1) == 1 {
            result = result * b
        }
        e = e / 2
        if e > 0 {
            b = b * b
        }
    }
    return result
}

// ═══════════════════════════════════════════════════════════════════
//  digit_sum_pure — sum of base-10 digits of |n|
// ═══════════════════════════════════════════════════════════════════
// Returns the sum of the absolute value's base-10 digits.
// digit_sum_pure(0)   -> 0
// digit_sum_pure(123) -> 6
// digit_sum_pure(-42) -> 6 (operates on absolute value)
// Handy for casting-out-nines checks, Luhn preamble, divisibility-by-9 tests.
@pure
pub fn digit_sum_pure(n) {
    let mut x = n
    if x < 0 { x = 0 - x }
    let mut s = 0
    if x == 0 { return 0 }
    while x > 0 {
        s = s + (x - (x / 10) * 10)
        x = x / 10
    }
    return s
}

// ═══════════════════════════════════════════════════════════════════
//  bit_reverse32_pure — reverse the low 32 bits of an integer
// ═══════════════════════════════════════════════════════════════════
// Returns a 32-bit value whose bit i equals the input's bit (31 - i).
// Useful for FFT bit-reversal permutations, hash mixing, CRC reflection.
// Avoids surface-parser limitations on `<<`/`>>` by using *2 / /2 which
// are well-supported in stage0 interpreter. `|` of disjoint bits is
// emulated as addition (no carry possible since we never set the same
// bit twice).
@pure
pub fn bit_reverse32_pure(a) {
    // Normalise input to the low 32 bits only, so negative int64
    // inputs don't leak sign-extended bits into the result.
    let mask = _pow2(32) - 1
    let mut x = a & mask
    let mut r = 0
    let mut i = 0
    while i < 32 {
        let bit = x - (x / 2) * 2     // x & 1, without relying on `&` precedence here
        r = r * 2 + bit                // (r << 1) | bit; bit fits in low slot cleanly
        x = x / 2                      // x >> 1 (logical, x already non-negative)
        i = i + 1
    }
    return r
}
