// ═══════════════════════════════════════════════════════════════════
//  self/runtime/topo_sort_pure.hexa — Kahn's topological sort (ROI #125)
//
//  Pure-Hexa Kahn's algorithm for topological sorting of DAGs.
//  O(V + E) time and space. No C deps, no FFI, no syscalls.
//
//  Public API:
//      topo_sort_pure(n, edges)      — sorted array or [] if cycle
//      topo_has_cycle_pure(n, edges) — true if cycle exists
//
//  edges = [[from, to], ...] where from/to are 0-based node indices.
//
//  Pitfalls honored: P1 no semicolons, P15 let mut, P29 push rebind,
//  P39 no 0b literals, arr[(i+1)..j] needs parens
// ═══════════════════════════════════════════════════════════════════

// ── _set_at — pure helper: return new array with arr[idx] = val ──
fn _set_at(arr, idx, val) {
    let n = len(arr)
    let mut out = []
    let mut i = 0
    while i < n {
        if i == idx {
            out = out.push(val)
        } else {
            out = out.push(arr[i])
        }
        i = i + 1
    }
    return out
}

// ── topo_sort_pure ──────────────────────────────────────────────
// Kahn's algorithm: BFS-based topological sort.
// Returns a valid topological ordering, or empty array if a cycle
// exists. n = number of nodes, edges = [[from, to], ...].
@pure
pub fn topo_sort_pure(n, edges) {
    if n <= 0 { return [] }

    // Build in-degree array and adjacency list
    let mut in_deg = []
    let mut adj = []
    let mut i = 0
    while i < n {
        in_deg = in_deg.push(0)
        adj = adj.push([])
        i = i + 1
    }

    let num_edges = len(edges)
    let mut ei = 0
    while ei < num_edges {
        let edge = edges[ei]
        let from_node = edge[0]
        let to_node = edge[1]
        if from_node >= 0 && from_node < n && to_node >= 0 && to_node < n {
            let old_list = adj[from_node]
            adj = _set_at(adj, from_node, old_list.push(to_node))
            in_deg = _set_at(in_deg, to_node, in_deg[to_node] + 1)
        }
        ei = ei + 1
    }

    // Initialize queue with all nodes of in-degree 0
    let mut queue = []
    i = 0
    while i < n {
        if in_deg[i] == 0 {
            queue = queue.push(i)
        }
        i = i + 1
    }

    let mut result = []
    let mut head = 0

    while head < len(queue) {
        let node = queue[head]
        head = head + 1
        result = result.push(node)

        // For each neighbor of node, decrement in-degree
        let neighbors = adj[node]
        let nn = len(neighbors)
        let mut ni = 0
        while ni < nn {
            let nb = neighbors[ni]
            let new_val = in_deg[nb] - 1
            in_deg = _set_at(in_deg, nb, new_val)
            if new_val == 0 {
                queue = queue.push(nb)
            }
            ni = ni + 1
        }
    }

    // If not all nodes are in result, there is a cycle
    if len(result) != n { return [] }
    return result
}

// ── topo_has_cycle_pure ─────────────────────────────────────────
// Returns true if the directed graph contains a cycle.
@pure
pub fn topo_has_cycle_pure(n, edges) {
    if n <= 0 { return false }
    let sorted = topo_sort_pure(n, edges)
    return len(sorted) == 0
}
