// ═══════════════════════════════════════════════════════════════════
//  self/runtime/graph_algo_pure.hexa — extended graph algorithms
//
//  Five net-new adjacency-list graph algorithms, complementing
//  self/runtime/graph_pure.hexa (bfs/dfs/has_path/num_components)
//  and self/runtime/topo_sort_pure.hexa (edge-list Kahn).
//
//  Representation: adj = array of array of int.
//    adj[i] = list of neighbor node ids for node i.
//
//  Public API:
//    bfs_distance_pure(adj, start)          -> array of distances (-1 unreachable)
//    shortest_path_bfs_pure(adj, start, end) -> path array or [] if no path
//    connected_components_pure(adj)          -> array of components (undirected view)
//    topo_sort_adj_pure(adj)                 -> topo order or [] if cycle
//    has_cycle_directed_pure(adj)            -> bool
//
//  Constraints honored:
//    HX4 SELF-HOST FIRST / HX10 C-purge — pure hexa, no FFI
//    P1 no semicolons  P15 let mut  P29 push rebind
//    P50 no << >> — queue is array + head index pointer
//    P17 no short-circuit — nested ifs for bounds guards
// ═══════════════════════════════════════════════════════════════════

// ── _set_at — return new array with arr[idx] = val ────────────────
fn _set_at(arr, idx, val) {
    let n = len(arr)
    let mut out = []
    let mut i = 0
    while i < n {
        if i == idx {
            out = out.push(val)
        } else {
            out = out.push(arr[i])
        }
        i = i + 1
    }
    return out
}

// ── _contains — linear membership check ───────────────────────────
fn _contains(arr, val) {
    let mut i = 0
    while i < len(arr) {
        if arr[i] == val { return true }
        i = i + 1
    }
    return false
}

// ── bfs_distance_pure ─────────────────────────────────────────────
// BFS from start, returning the array of shortest-edge distances
// from start for every node in adj. Unreachable nodes get -1.
// Queue implemented as array + head pointer (not ring buffer — P50).
pub fn bfs_distance_pure(adj, start) {
    let n = len(adj)
    let mut dist = []
    let mut i = 0
    while i < n {
        dist = dist.push(-1)
        i = i + 1
    }
    if n == 0 { return dist }
    if start < 0 { return dist }
    if start >= n { return dist }

    dist = _set_at(dist, start, 0)
    let mut queue = []
    queue = queue.push(start)
    let mut head = 0

    while head < len(queue) {
        let cur = queue[head]
        head = head + 1
        let neighbors = adj[cur]
        let nn = len(neighbors)
        let mut j = 0
        while j < nn {
            let nb = neighbors[j]
            if nb >= 0 {
                if nb < n {
                    if dist[nb] == -1 {
                        dist = _set_at(dist, nb, dist[cur] + 1)
                        queue = queue.push(nb)
                    }
                }
            }
            j = j + 1
        }
    }
    return dist
}

// ── shortest_path_bfs_pure ────────────────────────────────────────
// Returns the shortest (fewest edges) path from start to end as an
// array of node ids, inclusive of both endpoints. Returns [] if
// there is no path. If start == end, returns [start].
pub fn shortest_path_bfs_pure(adj, start, end) {
    let n = len(adj)
    if n == 0 { return [] }
    if start < 0 { return [] }
    if start >= n { return [] }
    if end < 0 { return [] }
    if end >= n { return [] }
    if start == end { return [start] }

    // parent[i] = predecessor of i on a shortest path, or -1 if none
    let mut parent = []
    let mut i = 0
    while i < n {
        parent = parent.push(-1)
        i = i + 1
    }
    let mut visited = []
    let mut vi = 0
    while vi < n {
        visited = visited.push(false)
        vi = vi + 1
    }

    visited = _set_at(visited, start, true)
    let mut queue = []
    queue = queue.push(start)
    let mut head = 0
    let mut found = false

    while head < len(queue) {
        let cur = queue[head]
        head = head + 1
        if cur == end {
            found = true
            head = len(queue) // break outer
        } else {
            let neighbors = adj[cur]
            let nn = len(neighbors)
            let mut j = 0
            while j < nn {
                let nb = neighbors[j]
                if nb >= 0 {
                    if nb < n {
                        if visited[nb] == false {
                            visited = _set_at(visited, nb, true)
                            parent = _set_at(parent, nb, cur)
                            queue = queue.push(nb)
                        }
                    }
                }
                j = j + 1
            }
        }
    }

    if found == false { return [] }

    // Reconstruct path by walking parent[] end -> start, then reverse
    let mut rev = []
    let mut cur2 = end
    let mut hops = 0
    while cur2 != -1 {
        rev = rev.push(cur2)
        if cur2 == start {
            cur2 = -1
        } else {
            cur2 = parent[cur2]
        }
        hops = hops + 1
        if hops > n + 1 { cur2 = -1 }
    }

    // Reverse rev into path
    let mut path = []
    let mut k = len(rev) - 1
    while k >= 0 {
        path = path.push(rev[k])
        k = k - 1
    }
    return path
}

// ── _bfs_reach — internal, undirected reachability from v ─────────
// For undirected traversal, we also walk "reverse" edges by scanning
// every node u with v in adj[u]. Costs O(V+E) per call.
fn _bfs_reach_undirected(adj, start, already_visited) {
    let n = len(adj)
    let mut comp = []
    let mut visited_local = already_visited
    if visited_local[start] { return [comp, visited_local] }

    visited_local = _set_at(visited_local, start, true)
    let mut queue = []
    queue = queue.push(start)
    let mut head = 0

    while head < len(queue) {
        let cur = queue[head]
        head = head + 1
        comp = comp.push(cur)

        // Forward neighbors
        let neighbors = adj[cur]
        let nn = len(neighbors)
        let mut j = 0
        while j < nn {
            let nb = neighbors[j]
            if nb >= 0 {
                if nb < n {
                    if visited_local[nb] == false {
                        visited_local = _set_at(visited_local, nb, true)
                        queue = queue.push(nb)
                    }
                }
            }
            j = j + 1
        }

        // Reverse neighbors (treat directed edges as undirected)
        let mut u = 0
        while u < n {
            if visited_local[u] == false {
                if _contains(adj[u], cur) {
                    visited_local = _set_at(visited_local, u, true)
                    queue = queue.push(u)
                }
            }
            u = u + 1
        }
    }
    return [comp, visited_local]
}

// ── connected_components_pure ─────────────────────────────────────
// Treats adj as an undirected graph (edges considered both ways) and
// returns an array of components, each component being an array of
// node ids. Order within a component is BFS order.
pub fn connected_components_pure(adj) {
    let n = len(adj)
    let mut visited = []
    let mut i = 0
    while i < n {
        visited = visited.push(false)
        i = i + 1
    }

    let mut comps = []
    let mut k = 0
    while k < n {
        if visited[k] == false {
            let pair = _bfs_reach_undirected(adj, k, visited)
            let comp = pair[0]
            visited = pair[1]
            comps = comps.push(comp)
        }
        k = k + 1
    }
    return comps
}

// ── topo_sort_adj_pure ────────────────────────────────────────────
// Kahn's algorithm applied directly to an adjacency list.
// Returns a topological ordering, or [] if the graph has a cycle
// (distinguishable from an empty-graph sort via len(adj)==0).
pub fn topo_sort_adj_pure(adj) {
    let n = len(adj)
    if n == 0 { return [] }

    // Compute in-degree from adj
    let mut in_deg = []
    let mut i = 0
    while i < n {
        in_deg = in_deg.push(0)
        i = i + 1
    }
    let mut u = 0
    while u < n {
        let neighbors = adj[u]
        let nn = len(neighbors)
        let mut j = 0
        while j < nn {
            let v = neighbors[j]
            if v >= 0 {
                if v < n {
                    in_deg = _set_at(in_deg, v, in_deg[v] + 1)
                }
            }
            j = j + 1
        }
        u = u + 1
    }

    // Queue all in-degree-0 nodes
    let mut queue = []
    let mut k = 0
    while k < n {
        if in_deg[k] == 0 {
            queue = queue.push(k)
        }
        k = k + 1
    }

    let mut result = []
    let mut head = 0
    while head < len(queue) {
        let node = queue[head]
        head = head + 1
        result = result.push(node)
        let neighbors = adj[node]
        let nn = len(neighbors)
        let mut ni = 0
        while ni < nn {
            let nb = neighbors[ni]
            if nb >= 0 {
                if nb < n {
                    let new_val = in_deg[nb] - 1
                    in_deg = _set_at(in_deg, nb, new_val)
                    if new_val == 0 {
                        queue = queue.push(nb)
                    }
                }
            }
            ni = ni + 1
        }
    }

    if len(result) != n { return [] }
    return result
}

// ── has_cycle_directed_pure ───────────────────────────────────────
// True iff the directed graph described by adj contains a cycle.
// An empty graph has no cycle.
pub fn has_cycle_directed_pure(adj) {
    let n = len(adj)
    if n == 0 { return false }
    let order = topo_sort_adj_pure(adj)
    return len(order) != n
}
