// ═══════════════════════════════════════════════════════════════════
//  self/runtime/geometry2d_pure.hexa — pure-Hexa 2D integer geometry
//
//  Net-new. runtime.c has no hexa_geom_* / hexa_point_* /
//  hexa_polygon_* helpers today (verified 2026-04-17 via grep).
//  All operations are closed over Z (int64) — no floats — so the
//  stage0 interpreter's wrapping int semantics plus the pure-Hexa
//  arithmetic surface is sufficient. Per HX10 / P50 pitfall this
//  module explicitly avoids `<<` and `>>`; any power-of-two scaling
//  goes through plain `*` / `/`, and absolute value is routed through
//  `abs_pure` from math_pure.hexa.
//
//  Point repr   : [x, y]              (2-elem int array)
//  AABB  repr   : [min_x, min_y, max_x, max_y]
//  Polygon repr : [[x0,y0], [x1,y1], …]   (CW or CCW; see signed area)
//
//  Public API (5 net-new):
//      manhattan_distance_pure(p1, p2)           -> int
//      chebyshev_distance_pure(p1, p2)           -> int
//      cross_product_2d_pure(v1, v2)             -> int (scalar z)
//      bounding_box_pure(points)                 -> [minx,miny,maxx,maxy] | nil
//      polygon_signed_area_x2_pure(points)       -> int (shoelace × 2)
//
//  SEMANTIC NOTES
//  ──────────────
//  * manhattan_distance_pure and chebyshev_distance_pure both assume
//    int-typed coordinates. Float coords would silently work but the
//    return type would leak a float; callers should int-clamp first.
//  * cross_product_2d_pure returns the signed z-component of the 3D
//    cross product of (v1.x, v1.y, 0) × (v2.x, v2.y, 0). Positive =
//    counter-clockwise turn from v1 to v2; zero = collinear vectors.
//  * bounding_box_pure returns nil on an empty input array. This
//    mirrors the "no valid answer" protocol used by checked_*_pure.
//  * polygon_signed_area_x2_pure returns **twice** the signed area,
//    keeping the result in Z for polygons with integer vertices
//    (shoelace's /2 is the only place a rational would sneak in).
//    Sign convention matches math texts: positive = CCW vertex order,
//    negative = CW.  Caller divides by 2 (and abs's) for the area.
// ═══════════════════════════════════════════════════════════════════

// ── local int abs — avoid module-level coupling ────────────────────
@pure
fn _iabs(n) {
    if n < 0 { return 0 - n }
    return n
}

// ── local int max/min — keep module standalone ─────────────────────
@pure
fn _imax(a, b) {
    if a > b { return a }
    return b
}

@pure
fn _imin(a, b) {
    if a < b { return a }
    return b
}

// ═══════════════════════════════════════════════════════════════════
//  manhattan_distance_pure — L1 / taxicab metric
// ═══════════════════════════════════════════════════════════════════
// |x1 - x2| + |y1 - y2|.  Never uses multiplication, so overflow is
// impossible as long as coordinates fit in int63 (stage0's effective
// range).
@pure
pub fn manhattan_distance_pure(p1, p2) {
    let dx = p1[0] - p2[0]
    let dy = p1[1] - p2[1]
    return _iabs(dx) + _iabs(dy)
}

// ═══════════════════════════════════════════════════════════════════
//  chebyshev_distance_pure — L∞ / king-move metric
// ═══════════════════════════════════════════════════════════════════
// max(|x1 - x2|, |y1 - y2|). Matches number of moves a chess king
// needs between two squares.
@pure
pub fn chebyshev_distance_pure(p1, p2) {
    let dx = p1[0] - p2[0]
    let dy = p1[1] - p2[1]
    return _imax(_iabs(dx), _iabs(dy))
}

// ═══════════════════════════════════════════════════════════════════
//  cross_product_2d_pure — scalar z of (v1 × v2)
// ═══════════════════════════════════════════════════════════════════
// v1.x * v2.y - v1.y * v2.x.  Useful for orientation tests:
//   > 0  →  v1 -> v2 is a CCW turn
//   < 0  →  v1 -> v2 is a CW  turn
//   == 0 →  v1, v2 are collinear (possibly anti-parallel)
@pure
pub fn cross_product_2d_pure(v1, v2) {
    return v1[0] * v2[1] - v1[1] * v2[0]
}

// ═══════════════════════════════════════════════════════════════════
//  bounding_box_pure — axis-aligned bounding box of a point cloud
// ═══════════════════════════════════════════════════════════════════
// Returns [min_x, min_y, max_x, max_y]. Returns nil on empty input,
// consistent with checked_*_pure's "no answer" protocol.
@pure
pub fn bounding_box_pure(points) {
    let n = len(points)
    if n == 0 { return nil }
    let mut minx = points[0][0]
    let mut miny = points[0][1]
    let mut maxx = points[0][0]
    let mut maxy = points[0][1]
    let mut i = 1
    while i < n {
        let p = points[i]
        if p[0] < minx { minx = p[0] }
        if p[1] < miny { miny = p[1] }
        if p[0] > maxx { maxx = p[0] }
        if p[1] > maxy { maxy = p[1] }
        i = i + 1
    }
    return [minx, miny, maxx, maxy]
}

// ═══════════════════════════════════════════════════════════════════
//  polygon_signed_area_x2_pure — 2 × shoelace formula
// ═══════════════════════════════════════════════════════════════════
// Σ (x_i * y_{i+1} - x_{i+1} * y_i) over the closed polygon.
// Returns **twice** the signed area so the result stays in Z.
// Positive = CCW order, negative = CW. Degenerate (<3 vertices) → 0.
@pure
pub fn polygon_signed_area_x2_pure(points) {
    let n = len(points)
    if n < 3 { return 0 }
    let mut s = 0
    let mut i = 0
    while i < n {
        let j = (i + 1) % n
        let xi = points[i][0]
        let yi = points[i][1]
        let xj = points[j][0]
        let yj = points[j][1]
        s = s + (xi * yj - xj * yi)
        i = i + 1
    }
    return s
}
