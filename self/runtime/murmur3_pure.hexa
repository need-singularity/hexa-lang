// ═══════════════════════════════════════════════════════════════════
//  self/runtime/murmur3_pure.hexa — MurmurHash3 x86-32 (pure Hexa)
//
//  Non-cryptographic fast hash, complementing FNV-1a in hash_pure.hexa.
//  Reference: https://github.com/aappleby/smhasher/blob/master/src/MurmurHash3.cpp
//
//  All arithmetic is 32-bit unsigned, emulated via & 0xFFFFFFFF masks
//  because HEXA integers are 64-bit signed. Intermediate products
//  (max 2^32 * 2^32 = 2^64) may overflow int64, so we split large
//  multiplies into hi16/lo16 halves.
//
//  Bit helpers inlined (interp interpreter does not re-export
//  transitive imports reliably).
//
//  Pitfalls:
//    P15 let mut for reassigned locals
//    P30 no unsigned int type — emulate via & 0xFFFFFFFF
//    No 0b binary literals — use hex
// ═══════════════════════════════════════════════════════════════════

import "runtime/bit_pure.hexa"

let MASK32 = 0xFFFFFFFF

// ── inlined bit helpers (from bit_pure.hexa) ─────────────────────
@pure
fn _pow2(n) {
    let mut r = 1
    let mut i = 0
    while i < n {
        r = r * 2
        i = i + 1
    }
    return r
}

@pure
fn _shl(a, n) {
    if n <= 0 { return a }
    return a * _pow2(n)
}

@pure
fn _shr(a, n) {
    if n <= 0 { return a }
    return a / _pow2(n)
}

@pure
fn _or(a, b) {
    return (a + b) - (a & b)
}

@pure
fn _xor(a, b) {
    return a ^ b
}

@pure
fn _rotl32(x, r) {
    let v = x & MASK32
    let shift = r % 32
    if shift == 0 { return v }
    let lo = _shl(v, shift) & MASK32
    let hi = _shr(v, 32 - shift)
    return _or(lo, hi) & MASK32
}

// ── constants ────────────────────────────────────────────────────
let C1 = 0xCC9E2D51
let C2 = 0x1B873593

// ── mul32 — 32-bit unsigned multiply via 16-bit split ─────────────
@pure
fn mul32(a, b) {
    let a32 = a & MASK32
    let b32 = b & MASK32
    let aL = a32 & 0xFFFF
    let aH = _shr(a32, 16)
    let bL = b32 & 0xFFFF
    let bH = _shr(b32, 16)
    let low = aL * bL
    let mid = (aL * bH + aH * bL) & 0xFFFF
    let result = low + _shl(mid, 16)
    return result & MASK32
}

// ── fmix32 — finalization mix ────────────────────────────────────
@pure
fn fmix32(hh) {
    let mut h = hh & MASK32
    h = _xor(h, _shr(h, 16))
    h = mul32(h, 0x85EBCA6B)
    h = _xor(h, _shr(h, 13))
    h = mul32(h, 0xC2B2AE35)
    h = _xor(h, _shr(h, 16))
    return h & MASK32
}

// ── get_byte — extract byte at position i from string ────────────
@pure
fn get_byte(s, i) {
    return ord(s.substring(i, i + 1))
}

// ── get_block32 — read little-endian 32-bit word at block index ──
@pure
fn get_block32(s, block_start, i) {
    let base = block_start + i * 4
    let b0 = get_byte(s, base)
    let b1 = _shl(get_byte(s, base + 1), 8)
    let b2 = _shl(get_byte(s, base + 2), 16)
    let b3 = _shl(get_byte(s, base + 3), 24)
    return _or(_or(b0, b1), _or(b2, b3))
}

// ═══════════════════════════════════════════════════════════════════
//  murmur3_hash32 — MurmurHash3 x86-32
//
//  data : string input
//  seed : integer seed (default 0)
//  returns: 32-bit unsigned hash as integer
// ═══════════════════════════════════════════════════════════════════
@pure
pub fn murmur3_hash32(data, seed) {
    if type_of(data) != "string" { return seed & MASK32 }

    let length = len(data)
    let mut h1 = seed & MASK32
    let nblocks = length / 4

    // ── body: process 4-byte blocks ──────────────────────────────
    let mut i = 0
    while i < nblocks {
        let mut k1 = get_block32(data, 0, i)
        k1 = mul32(k1, C1)
        k1 = _rotl32(k1, 15)
        k1 = mul32(k1, C2)

        h1 = _xor(h1, k1)
        h1 = _rotl32(h1, 13)
        h1 = (mul32(h1, 5) + 0xE6546B64) & MASK32

        i = i + 1
    }

    // ── tail: remaining 1–3 bytes ────────────────────────────────
    let tail_start = nblocks * 4
    let rem = length & 3
    let mut k1 = 0

    if rem == 3 {
        k1 = _or(k1, _shl(get_byte(data, tail_start + 2), 16))
    }
    if rem >= 2 {
        k1 = _or(k1, _shl(get_byte(data, tail_start + 1), 8))
    }
    if rem >= 1 {
        k1 = _or(k1, get_byte(data, tail_start))
        k1 = mul32(k1, C1)
        k1 = _rotl32(k1, 15)
        k1 = mul32(k1, C2)
        h1 = _xor(h1, k1)
    }

    // ── finalization ─────────────────────────────────────────────
    h1 = _xor(h1, length)
    h1 = fmix32(h1)

    return h1
}

// ── murmur3_32 — alias matching the standard name ────────────────
@pure
pub fn murmur3_32(data, seed) {
    return murmur3_hash32(data, seed)
}

// ── murmur3_simple — convenience wrapper with seed=0 ─────────────
@pure
pub fn murmur3_simple(data) {
    return murmur3_hash32(data, 0)
}
