// ═══════════════════════════════════════════════════════════════════
//  self/runtime/map_ext_pure.hexa — extended map/hash helpers (pure hexa)
//
//  Phase 7 additive port. Complements self/runtime/map_pure.hexa with
//  5 higher-ROI MEDIUM-tier operations that the C runtime does not
//  provide directly. Callers previously hand-rolled these inline;
//  centralising here keeps hot paths (IR lowering, inline caches,
//  iteration stats) consistent.
//
//  C runtime reference points (no direct replacement — these are
//  compositions over the existing primitives):
//      self/runtime.c:1452 hexa_map_keys        — iteration base
//      self/runtime.c:1463 hexa_map_values      — iteration base
//      self/runtime.c:1474 hexa_map_contains_key
//      self/runtime.c:1480 hexa_map_remove      — used conceptually
//
//  Semantic divergence from C:
//    • C runtime stores entries in insertion order in parallel
//      key/value arrays and looks them up via linear scan
//      (hexa_map_lookup_linear-like). These pure variants preserve
//      whatever key order `keys(m)` returns; no extra ordering
//      guarantee beyond that of the host map implementation.
//    • map_invert_multi_pure handles value collisions by grouping
//      instead of last-write-wins (map_invert_pure in map_pure.hexa
//      keeps last-write-wins semantics — both kept for clarity).
//    • All functions return fresh maps/arrays — no in-place mutation,
//      matching the rest of the pure-hexa runtime.
//
//  Public API:
//      map_partition_pure(m, pred)         — [yes_map, no_map]
//      map_min_by_pure(m, f)               — key with min f(k, v) (void if empty)
//      map_max_by_pure(m, f)               — key with max f(k, v) (void if empty)
//      map_count_by_pure(arr, f)           — counter map key->count
//      map_invert_multi_pure(m)            — swap keys/values, collect collisions
// ═══════════════════════════════════════════════════════════════════

// ── partition: split map into two by predicate ─────────────────
// pred(k, v) -> bool. Returns [yes_map, no_map].
// Empty input -> [#{}, #{}]. Total entries preserved: |yes|+|no|==|m|.

@pure
pub fn map_partition_pure(m, pred) {
    let mut yes = #{}
    let mut no = #{}
    let ks = keys(m)
    let n = len(ks)
    let mut i = 0
    while i < n {
        let k = ks[i]
        let v = m[k]
        if pred(k, v) {
            yes[k] = v
        } else {
            no[k] = v
        }
        i = i + 1
    }
    return [yes, no]
}

// ── min_by: key whose f(k, v) is smallest ──────────────────────
// f(k, v) must return a comparable (int/float/string). Empty map
// returns void. Ties -> first key encountered in keys(m) order.

@pure
pub fn map_min_by_pure(m, f) {
    let ks = keys(m)
    let n = len(ks)
    if n == 0 { return void }
    let mut best_k = ks[0]
    let mut best_v = f(best_k, m[best_k])
    let mut i = 1
    while i < n {
        let k = ks[i]
        let v = f(k, m[k])
        if v < best_v {
            best_k = k
            best_v = v
        }
        i = i + 1
    }
    return best_k
}

// ── max_by: key whose f(k, v) is largest ───────────────────────
// Mirrors min_by. Empty map -> void. Ties -> first in keys(m) order.

@pure
pub fn map_max_by_pure(m, f) {
    let ks = keys(m)
    let n = len(ks)
    if n == 0 { return void }
    let mut best_k = ks[0]
    let mut best_v = f(best_k, m[best_k])
    let mut i = 1
    while i < n {
        let k = ks[i]
        let v = f(k, m[k])
        if v > best_v {
            best_k = k
            best_v = v
        }
        i = i + 1
    }
    return best_k
}

// ── count_by: build counter map from array via classifier ──────
// f(elem) -> key. Result: map key -> count of elements mapping there.
// Roughly equivalent to Python's collections.Counter after a keyfunc.
// Empty array -> #{}.

@pure
pub fn map_count_by_pure(arr, f) {
    let mut out = #{}
    let n = len(arr)
    let mut i = 0
    while i < n {
        let k = f(arr[i])
        if has_key(out, k) {
            out[k] = out[k] + 1
        } else {
            out[k] = 1
        }
        i = i + 1
    }
    return out
}

// ── invert_multi: swap keys/values, grouping collisions ────────
// Unlike map_invert_pure (last-write-wins), this preserves all
// source keys by collecting them into arrays. Useful for building
// reverse lookups when multiple keys share a value.
// Example: #{"a": 1, "b": 1, "c": 2} -> #{"1": ["a", "b"], "2": ["c"]}

@pure
pub fn map_invert_multi_pure(m) {
    let mut out = #{}
    let ks = keys(m)
    let n = len(ks)
    let mut i = 0
    while i < n {
        let k = ks[i]
        let vkey = to_string(m[k])
        if has_key(out, vkey) {
            out[vkey] = out[vkey].push(k)
        } else {
            let init = []
            out[vkey] = init.push(k)
        }
        i = i + 1
    }
    return out
}
