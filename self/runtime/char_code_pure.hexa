// self/runtime/char_code_pure.hexa — Wave 1 runtime port (char_code(s, i))
//
// Pure-Hexa mirror of `hexa_char_code` (runtime.c:4297). The C helper
// returns the byte value at position `i` of string `s`, or 0 for
// out-of-range / non-string input.
//
// Why this module exists despite conv_pure::char_to_int_pure:
//   - conv_pure's variant ALWAYS returns the first byte (mirrors
//     `hexa_char_code(s, 0)`). It intentionally hides the `idx`
//     parameter to dodge the interp codegen bug where
//     `char_code(param_string, i>0)` always returns position 0's
//     byte (memory: feedback_hexa_parser_quirks.md P38).
//   - This module provides the FULL two-arg signature the C runtime
//     exposes, using `s.substring(i, i+1) |> ord` to sidestep the bug
//     while still respecting `idx`. Callers that need proper indexing
//     from pure hexa should import this module.
//
// ADDITIVE — the C body stays as the codegen-emitted target.
//
// Pitfalls honoured:
//   P1  no semicolons
//   P15 let mut for reassigned locals
//   P38 char_code(s, i>0) broken — use substring+ord
//
// Behaviour table (matches runtime.c:4297):
//   char_code("abc", 0)     -> 97
//   char_code("abc", 2)     -> 99
//   char_code("abc", 3)     -> 0   (out of range)
//   char_code("abc", -1)    -> 0
//   char_code("", 0)        -> 0
//   char_code(non-string, 0)-> 0

@pure
pub fn char_code_pure(s, idx) {
    if type_of(s) != "string" { return 0 }
    if type_of(idx) != "int" { return 0 }
    let n = len(s)
    if idx < 0 { return 0 }
    if idx >= n { return 0 }
    ord(s.substring(idx, idx + 1))
}

// ── byte_at_pure ──────────────────────────────────────────────────
// Alias with the stricter "byte" wording used elsewhere in the
// runtime. Same semantics as char_code_pure.
@pure
pub fn byte_at_pure(s, idx) {
    char_code_pure(s, idx)
}

// ── string_bytes_range_pure ───────────────────────────────────────
// Returns [byte0, byte1, ...] for the half-open range [start, end).
// Out-of-range indices are clipped (matching hexa_str_slice).
// Complement to hexa_str_bytes (runtime.c:4115) which returns the
// full string; this variant supports an explicit range.
@pure
pub fn string_bytes_range_pure(s, start_idx, end_idx) {
    if type_of(s) != "string" { return [] }
    let n = len(s)
    let mut a = start_idx
    let mut b = end_idx
    if a < 0 { a = 0 }
    if b > n { b = n }
    if a >= b { return [] }
    let mut out = []
    let mut i = a
    while i < b {
        out.push(ord(s.substring(i, i + 1)))
        i = i + 1
    }
    out
}
