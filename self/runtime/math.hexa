// self/runtime/math.hexa — P7-7b chunk 3: int/float math runtime in pure Hexa
//
// Role
//   P7-7b chunk 3. runtime.c 의 math helper 10종을 pure-Hexa 로 재구현한다.
//   chunk 1 (strings) / chunk 2 (arrays) 와 동일한 additive 레퍼런스 구현.
//   runtime.c 는 건드리지 않고, 추후 codegen 이 해당 심볼을 pure-Hexa pub fn
//   으로 lowering 하게 되면 그대로 인라인 emit 한다.
//
//   **Additive** — runtime.c 에서 아직 아무것도 제거하지 않는다.
//
// C ↔ Hexa 의미 대응표 (byte-semantic equivalence)
//   hexa_abs         (runtime.c:3075)  → int_abs / float_abs      (tag 분기)
//   (신규, C 는 인라인) → int_neg / int_min / int_max
//   (신규, C 는 인라인) → int_mod (C hexa_mod:3319 int branch, b==0 → 0)
//   hexa_pow         (runtime.c:3057)  → int_pow                  (int fast-path)
//   (신규, float 유도)  → float_min / float_max / float_pow
//
// 선택 기준 (HX4 / HX7)
//   · self-contained      : builtin 만. FFI / cstring 금지.
//   · runtime.c 구현 <50 LOC — byte-identity 검증 쉬움.
//   · hexa_full.hexa / self/* 핫패스에서 자주 쓰는 사칙 math.
//
// 제약 (CLAUDE.md)
//   HX3  : grammar pitfalls — no ;  · let mut for reassign  · `.push()` + join
//   HX4  : SELF-HOST FIRST — no FFI, no cstring(), builtin-only
//   HX7  : self/ 경로 전용
//   feedback_seed_freeze — stage0 재빌드 금지. 검증은 build/hexa_stage0 test 러너만.
//
// Stage0 pitfall 회피
//   · `<<` / `>>` silent-reject (feedback_hexa_bitop_surface). int_pow 는 C 의
//     binary-exponentiation 대신 단순 선형 누적을 쓴다 (exp 가 크지 않음 가정).
//   · 정수 오버플로: 본 포팅은 C 와 동일하게 wrap-around 를 보장하지 않고
//     그대로 둔다 (int_pow(2, 63) 등은 정의되지 않은 동작).
//   · float_pow 은 builtin pow 가 없으므로 int 지수에 한해 반복 곱셈으로
//     근사. 비정수 지수는 호출 금지 — 현재 호출처는 int exp 만 사용.
//   · NaN/Inf 는 Stage0 float 모델이 IEEE-754 따르므로 비교 로직은 C 와 동일.


// ── int_abs ──────────────────────────────────────────────
// Mirrors hexa_abs (runtime.c:3075) TAG_INT branch.
// 의미: n<0 이면 -n, 아니면 n. 정수 전용.
pub fn int_abs(n) {
    if n < 0 { return -n }
    n
}

// ── int_neg ──────────────────────────────────────────────
// Mirrors unary `-` on TAG_INT (runtime.c hexa_neg 인라인).
// 의미: -n. 0 은 0. 음수는 양수로, 양수는 음수로.
pub fn int_neg(n) {
    -n
}

// ── int_min ──────────────────────────────────────────────
// Mirrors (a<b)?a:b on TAG_INT. C 는 hexa_cmp_lt + 삼항.
pub fn int_min(a, b) {
    if a < b { return a }
    b
}

// ── int_max ──────────────────────────────────────────────
// Mirrors (a>b)?a:b on TAG_INT. C 는 hexa_cmp_gt + 삼항.
pub fn int_max(a, b) {
    if a > b { return a }
    b
}

// ── int_mod ──────────────────────────────────────────────
// Mirrors hexa_mod (runtime.c:3319) TAG_INT branch.
// 의미: b == 0 → 0 (C truncated-mod 대신 divide-by-zero guard).
//       그 외엔 a % b. Hexa `%` 는 builtin.
pub fn int_mod(a, b) {
    if b == 0 { return 0 }
    a % b
}

// ── int_pow ──────────────────────────────────────────────
// Mirrors hexa_pow (runtime.c:3057) int fast-path — base^exp, exp >= 0 → int.
// C 는 binary exponentiation (`e & 1`, `e >>= 1`) — Stage0 bit-op 제약으로
// 선형 누적 사용. exp < 0 은 C 가 float 로 떨어뜨리지만, 본 포팅은 int
// 전용이므로 exp < 0 은 0 반환 (호출처 전부 exp >= 0).
pub fn int_pow(base, exp) {
    if exp < 0 { return 0 }
    let mut r = 1
    let mut i = 0
    while i < exp {
        r = r * base
        i = i + 1
    }
    r
}

// ── float_abs ────────────────────────────────────────────
// Mirrors hexa_abs (runtime.c:3075) TAG_FLOAT branch — fabs().
// 의미: x<0.0 이면 -x, 아니면 x. Stage0 float 비교는 IEEE-754 와 동일.
pub fn float_abs(x) {
    if x < 0.0 { return -x }
    x
}

// ── float_min ────────────────────────────────────────────
// Mirrors (a<b)?a:b on double. NaN 처리는 Stage0 float 모델에 위임.
pub fn float_min(a, b) {
    if a < b { return a }
    b
}

// ── float_max ────────────────────────────────────────────
// Mirrors (a>b)?a:b on double.
pub fn float_max(a, b) {
    if a > b { return a }
    b
}

// ── float_pow ────────────────────────────────────────────
// Mirrors hexa_pow (runtime.c:3057) non-int-fast-path — pow().
// 의미: float base, int exp(>=0) → float 누적 곱. 비정수 exp 은 builtin
// pow() 가 없어 Stage0 에서 지원하지 않는다 (exp < 0 도 0.0). 호출처는
// 모두 int exp 로 제한.
pub fn float_pow(base, exp) {
    if exp < 0 { return 0.0 }
    let mut r = 1.0
    let mut i = 0
    while i < exp {
        r = r * base
        i = i + 1
    }
    r
}
