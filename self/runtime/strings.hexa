// self/runtime/strings.hexa — P7-7b chunk 1: string runtime in pure Hexa
//
// Role
//   P7-7b 는 self/runtime.c (4,696 LOC) 를 pure-Hexa 모듈로 쪼개서
//   self-hosting fixpoint 를 닫는 트랙. 본 파일은 첫 번째 청크로,
//   runtime.c 의 문자열 헬퍼 8종을 pure-Hexa 로 재구현한다.
//
//   **Additive** — runtime.c 에서 아직 아무것도 제거하지 않는다.
//   codegen_c2 는 여전히 hexa_str_*() 심볼을 C 로 떨어뜨리므로, 본 파일은
//   (a) 참조 구현 (byte-for-byte 의미 검증용)
//   (b) codegen-interpose 단계에서 그대로 inline-emit 할 소스 베이스
//   역할만 한다.
//
// 선행 모듈
//   self/runtime/string_pure.hexa — 넓은 스펙 (40+ 함수). 본 파일은
//   그 중 P7-7b 가 우선 "교체 대상" 으로 찍은 8종만 추린 뒤, 이름을
//   runtime.c 의 hexa_str_* 와 1:1 대응으로 맞춘 버전이다. 이름 매칭을
//   맞춘 이유: codegen 이 나중에 `hexa_str_concat(a, b)` 를 찾을 때
//   FFI 심볼이 아닌 이 파일의 pub fn 으로 해석되도록 하기 위함.
//
// C ↔ Hexa 의미 대응표 (byte 단위 동일해야 함)
//   hexa_str_concat       (runtime.c:2356) → str_concat
//   hexa_str_substring    (runtime.c:2420) → str_substring
//   hexa_str_index_of     (runtime.c:2433) → str_index_of
//   hexa_str_starts_with  (runtime.c:2406) → str_starts_with
//   hexa_str_ends_with    (runtime.c:2412) → str_ends_with
//   hexa_str_to_upper     (runtime.c:3172) → str_to_upper
//   hexa_str_to_lower     (runtime.c:3179) → str_to_lower
//   hexa_str_trim         (runtime.c:3131) → str_trim
//
// 선택 기준 (태스크 조건)
//   · self-contained  : regex / unicode table 없이 ASCII 바이트만 필요
//   · used by hexa_full.hexa : 106 건 메서드 호출 중 상위 12가지의 부분집합
//   · runtime.c 의 C 구현이 50 LOC 이하 — byte-identity 검증 쉬움
//
// 제약 (CLAUDE.md)
//   HX3: grammar pitfalls — no ;  · let mut for reassign  · parts.push + join
//   HX4: SELF-HOST FIRST — no FFI, no cstring(), pure builtin only
//   HX7: self/ 경로 전용
//   feedback_seed_freeze — stage0 재빌드 금지, 인터프리터 경로만 검증
//
// Stage0 pitfall 회피
//   · `char_code(param_string, i)` 파라미터-문자열에서 잘못된 값을 돌려
//     주는 알려진 버그가 있다 (string_pure.hexa 주석 참조). 본 파일은
//     char_code 를 전혀 쓰지 않고, substring(i, i+1) + 문자 비교로
//     모든 변환을 처리한다 (알파벳 26자 룩업).


// ── str_concat ───────────────────────────────────────────
// Mirrors hexa_str_concat (runtime.c:2356).
// 의미: a, b 둘 다 string 일 때 "a+b". 비-string 은 "" 로 떨어뜨리고
// 한쪽이 빈 문자열이면 다른 쪽을 그대로 리턴 (C 쪽 empty-string elision).
pub fn str_concat(a, b) {
    let sa = if type_of(a) == "string" { a } else { "" }
    let sb = if type_of(b) == "string" { b } else { "" }
    if len(sa) == 0 { return sb }
    if len(sb) == 0 { return sa }
    sa + sb
}

// ── str_substring ────────────────────────────────────────
// Mirrors hexa_str_substring (runtime.c:2420).
// 의미: s[a..b) — a<0 → 0, b>len → len, a>=b → "".
// C 는 malloc + memcpy; Hexa 는 builtin substring 이 동일 의미.
pub fn str_substring(s, a, b) {
    if type_of(s) != "string" { return "" }
    let n = len(s)
    let mut lo = a
    let mut hi = b
    if lo < 0 { lo = 0 }
    if hi > n { hi = n }
    if lo >= hi { return "" }
    s.substring(lo, hi)
}

// ── str_index_of ─────────────────────────────────────────
// Mirrors hexa_str_index_of (runtime.c:2433).
// 의미: sub 의 첫 발견 byte 인덱스, 없으면 -1. C 는 strstr.
// sub == "" → C 의 strstr(s, "") 은 s 를 돌려줘서 결과 0 이다. 본 포팅
// 도 이에 맞춰 빈 서브스트링은 0 을 돌려준다.
pub fn str_index_of(s, sub) {
    if type_of(s) != "string" { return -1 }
    if type_of(sub) != "string" { return -1 }
    let sn = len(s)
    let mn = len(sub)
    if mn == 0 { return 0 }
    if mn > sn { return -1 }
    let limit = sn - mn + 1
    let mut i = 0
    while i < limit {
        if s.substring(i, i + mn) == sub {
            return i
        }
        i = i + 1
    }
    -1
}

// ── str_starts_with ──────────────────────────────────────
// Mirrors hexa_str_starts_with (runtime.c:2406).
// 의미: s 의 맨 앞이 prefix 와 같으면 true. C 는 strncmp(s, p, len(p)).
// prefix == "" → strncmp 는 0 → true. 본 포팅도 빈 prefix 는 true.
pub fn str_starts_with(s, prefix) {
    if type_of(s) != "string" { return false }
    if type_of(prefix) != "string" { return false }
    let sn = len(s)
    let pn = len(prefix)
    if pn > sn { return false }
    if pn == 0 { return true }
    s.substring(0, pn) == prefix
}

// ── str_ends_with ────────────────────────────────────────
// Mirrors hexa_str_ends_with (runtime.c:2412).
// 의미: s 의 꼬리가 suffix 와 같으면 true. C 는 strcmp(s + sn - sfn, sfx).
// suffix == "" → sn - 0 == sn, strcmp("", "") → 0 → true.
pub fn str_ends_with(s, suffix) {
    if type_of(s) != "string" { return false }
    if type_of(suffix) != "string" { return false }
    let sn = len(s)
    let sfn = len(suffix)
    if sfn > sn { return false }
    if sfn == 0 { return true }
    s.substring(sn - sfn, sn) == suffix
}

// ── str_to_upper ─────────────────────────────────────────
// Mirrors hexa_str_to_upper (runtime.c:3172).
// 의미: ASCII 소문자(a..z) 를 대문자(A..Z) 로. 나머지 바이트는 보존.
// C 는 r[i] >= 'a' && r[i] <= 'z' 일 때 r[i] -= 32. 본 포팅은 26-문자
// 룩업으로 동일한 결과를 얻는다 (stage0 char_code 버그 회피).
// UTF-8 continuation byte (0x80..0xFF) 는 lowers 에 없으므로 통과 → C 와 동일.
pub fn str_to_upper(s) {
    if type_of(s) != "string" { return s }
    let n = len(s)
    let mut parts = []
    let lowers = "abcdefghijklmnopqrstuvwxyz"
    let uppers = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
    let mut i = 0
    while i < n {
        let ch = s.substring(i, i + 1)
        let mut j = 0
        let mut found = false
        while j < 26 && found == false {
            if lowers.substring(j, j + 1) == ch {
                parts.push(uppers.substring(j, j + 1))
                found = true
            }
            j = j + 1
        }
        if found == false { parts.push(ch) }
        i = i + 1
    }
    parts.join("")
}

// ── str_to_lower ─────────────────────────────────────────
// Mirrors hexa_str_to_lower (runtime.c:3179). 대칭.
pub fn str_to_lower(s) {
    if type_of(s) != "string" { return s }
    let n = len(s)
    let mut parts = []
    let lowers = "abcdefghijklmnopqrstuvwxyz"
    let uppers = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
    let mut i = 0
    while i < n {
        let ch = s.substring(i, i + 1)
        let mut j = 0
        let mut found = false
        while j < 26 && found == false {
            if uppers.substring(j, j + 1) == ch {
                parts.push(lowers.substring(j, j + 1))
                found = true
            }
            j = j + 1
        }
        if found == false { parts.push(ch) }
        i = i + 1
    }
    parts.join("")
}

// ── str_trim ─────────────────────────────────────────────
// Mirrors hexa_str_trim (runtime.c:3131).
// 의미: 앞뒤 공백 ' ' / '\t' / '\n' / '\r' 를 제거. C 는 포인터 이동 + len 감소.
// 전부 공백이면 "" 반환.
pub fn str_trim(s) {
    if type_of(s) != "string" { return s }
    let n = len(s)
    if n == 0 { return s }
    let mut lo = 0
    let mut done_lo = false
    while lo < n && done_lo == false {
        let ch = s.substring(lo, lo + 1)
        if ch == " " || ch == "\t" || ch == "\n" || ch == "\r" {
            lo = lo + 1
        } else {
            done_lo = true
        }
    }
    if done_lo == false { return "" }
    let mut hi = n - 1
    let mut done_hi = false
    while hi >= lo && done_hi == false {
        let ch = s.substring(hi, hi + 1)
        if ch == " " || ch == "\t" || ch == "\n" || ch == "\r" {
            hi = hi - 1
        } else {
            done_hi = true
        }
    }
    if hi < lo { return "" }
    s.substring(lo, hi + 1)
}
