#!hexa lax
// ═══════════════════════════════════════════════════════════════════
//  self/runtime/reservoir_sample_pure.hexa — Reservoir sampling (pure Hexa)
//
//  Vitter's Algorithm R — uniform random sample of k items from a
//  stream of unknown length. Each item in the (unbounded) stream ends
//  up in the final reservoir with probability k/N, for any final N ≥ k.
//
//  Public API:
//      reservoir_create(k)                         -> map
//      reservoir_add(r, item, idx, rng_state)      -> map
//      reservoir_items(r)                          -> array
//      reservoir_size(r)                           -> int
//
//  Bonus helpers (pure convenience, not in spec):
//      reservoir_capacity(r)                       -> int
//      reservoir_count(r)                          -> int    (stream idx seen)
//      reservoir_merge(r1, r2, rng_state)          -> map    (weighted)
//
//  PRNG (inline, no imports):
//      _lcg_next(state)     -> [new_state, random_int]
//      standard 32-bit LCG: (state * 1103515245 + 12345) & 0x7FFFFFFF
//
//  Threading convention:
//      Caller owns rng_state. Each call to reservoir_add that needs
//      randomness returns an updated reservoir whose ["rng"] slot holds
//      the *next* rng_state; or — for strict purity — the caller can
//      read r["rng"] after each add. The rng_state argument to
//      reservoir_add seeds that specific call so the function is pure.
//
//  Properties:
//      - Pure Hexa, no C/FFI, no external imports
//      - O(1) amortized per stream item (after reservoir fills)
//      - Uniform: each of the first N items has probability k/N of
//        being in the final sample, regardless of N
//
//  HX3 pitfalls handled:
//      P1   no semicolons
//      P15  let mut for mutable variables
//      P30  no unsigned int — mask with & 0xFFFFFFFF
//      Array growth via .push() (O(n) not O(n^2))
// ═══════════════════════════════════════════════════════════════════

let MASK32 = 0xFFFFFFFF
let LCG_MASK = 0x7FFFFFFF
let LCG_MUL = 1103515245
let LCG_ADD = 12345

// ── _mul32 — 32-bit multiply without int64 overflow ─────────────
@pure
fn _mul32(a, b) {
    let a32 = a & MASK32
    let b32 = b & MASK32
    let aL = a32 & 0xFFFF
    let aH = (a32 / 65536) & 0xFFFF
    let bL = b32 & 0xFFFF
    let bH = (b32 / 65536) & 0xFFFF
    let low = aL * bL
    let mid = aL * bH + aH * bL
    return (low + mid * 65536) & MASK32
}

// ── _lcg_next — deterministic PRNG step ─────────────────────────
// Returns two-element array [new_state, random_int].
// random_int is in [0, 0x7FFFFFFF].
@pure
fn _lcg_next(s) {
    let s32 = s & MASK32
    let prod = _mul32(s32, LCG_MUL)
    let next = (prod + LCG_ADD) & LCG_MASK
    let mut out = []
    out.push(next)
    out.push(next)
    return out
}

// ── _rand_range — uniform int in [0, n) given rng_state ─────────
// Returns [new_state, value].
@pure
fn _rand_range(state, n) {
    let step = _lcg_next(state)
    let new_state = step[0]
    let r = step[1]
    let mut out = []
    out.push(new_state)
    if n <= 0 {
        out.push(0)
    } else {
        out.push(r % n)
    }
    return out
}

// ── reservoir_create ────────────────────────────────────────────
// Returns #{items: [], capacity: k, count: 0, rng: 0}
// count = number of stream elements considered so far (not len(items))
pub fn reservoir_create(k) {
    let mut cap = k
    if cap < 0 { cap = 0 }
    let mut r = #{}
    r["items"] = []
    r["capacity"] = cap
    r["count"] = 0
    r["rng"] = 0
    return r
}

// ── reservoir_add ───────────────────────────────────────────────
// Vitter's Algorithm R:
//   if idx < k:       append item
//   else:             pick j in [0, idx]; if j < k, replace slot j
// `idx` is the 0-based position of `item` in the stream. The caller
// is responsible for passing monotonically increasing idx values
// matching the number of items seen so far (not reservoir fill level).
// `rng_state` seeds the random choice; the returned map's ["rng"]
// slot carries the next state.
pub fn reservoir_add(r, item, idx, rng_state) {
    let cap = r["capacity"]
    let items = r["items"]
    let mut out = #{}
    out["capacity"] = cap

    if cap <= 0 {
        out["items"] = items
        out["count"] = idx + 1
        out["rng"] = rng_state & MASK32
        return out
    }

    if idx < cap {
        // still filling: append
        let mut new_items = items
        new_items.push(item)
        out["items"] = new_items
        out["count"] = idx + 1
        out["rng"] = rng_state & MASK32
        return out
    }

    // reservoir full: pick j in [0, idx]
    let pick = _rand_range(rng_state, idx + 1)
    let new_state = pick[0]
    let j = pick[1]

    if j < cap {
        // replace slot j with item
        let n = len(items)
        let mut new_items = []
        let mut i = 0
        while i < n {
            if i == j {
                new_items.push(item)
            } else {
                new_items.push(items[i])
            }
            i = i + 1
        }
        out["items"] = new_items
    } else {
        out["items"] = items
    }

    out["count"] = idx + 1
    out["rng"] = new_state
    return out
}

// ── reservoir_items ─────────────────────────────────────────────
@pure
pub fn reservoir_items(r) {
    return r["items"]
}

// ── reservoir_size ──────────────────────────────────────────────
// Current filled count (≤ capacity).
@pure
pub fn reservoir_size(r) {
    return len(r["items"])
}

// ── reservoir_capacity (bonus) ──────────────────────────────────
@pure
pub fn reservoir_capacity(r) {
    return r["capacity"]
}

// ── reservoir_count (bonus) ─────────────────────────────────────
// Number of stream elements processed so far (can exceed capacity).
@pure
pub fn reservoir_count(r) {
    return r["count"]
}

// ── reservoir_merge (bonus) ─────────────────────────────────────
// Weighted merge of two reservoirs with the same capacity.
// Each item in the output is drawn proportionally to how many stream
// elements its source reservoir represents. For r1 with count n1 and
// r2 with count n2, the merged reservoir samples each output slot
// from r1 with prob n1/(n1+n2), else from r2 — matching the marginal
// probability each stream element would have in a combined run.
//
// Notes:
//   - Capacities must match; if they differ, uses r1["capacity"].
//   - Source reservoirs that are still partially filled contribute
//     only the items they actually hold.
//   - Result count = n1 + n2.
pub fn reservoir_merge(r1, r2, rng_state) {
    let cap = r1["capacity"]
    let items1 = r1["items"]
    let items2 = r2["items"]
    let n1 = r1["count"]
    let n2 = r2["count"]
    let l1 = len(items1)
    let l2 = len(items2)
    let total = n1 + n2

    let mut out = #{}
    out["capacity"] = cap
    out["count"] = total

    if total <= 0 || cap <= 0 || (l1 == 0 && l2 == 0) {
        out["items"] = []
        out["rng"] = rng_state & MASK32
        return out
    }

    let mut state = rng_state & MASK32
    let mut merged = []
    let mut slot = 0
    let target = cap

    while slot < target {
        // pick a bucket in [0, total); if < n1 and r1 has items, pull
        // from r1, else pull from r2 (falling back if one side empty).
        let pick = _rand_range(state, total)
        state = pick[0]
        let bucket = pick[1]

        if bucket < n1 && l1 > 0 {
            let idx_pick = _rand_range(state, l1)
            state = idx_pick[0]
            merged.push(items1[idx_pick[1]])
        } else {
            if l2 > 0 {
                let idx_pick = _rand_range(state, l2)
                state = idx_pick[0]
                merged.push(items2[idx_pick[1]])
            } else {
                if l1 > 0 {
                    let idx_pick = _rand_range(state, l1)
                    state = idx_pick[0]
                    merged.push(items1[idx_pick[1]])
                }
            }
        }
        slot = slot + 1
    }

    out["items"] = merged
    out["rng"] = state
    return out
}
