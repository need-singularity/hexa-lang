#!hexa lax
// ═══════════════════════════════════════════════════════════════════
//  self/runtime/count_min_sketch_pure.hexa — Count-Min Sketch (pure Hexa)
//
//  Sublinear approximate frequency estimation for heavy-hitter queries.
//  Uses FNV-1a variant with per-row seed mixing for d independent hashes.
//
//  Public API:
//      cms_create(width, depth)              -> map
//      cms_hash(item, seed, width)           -> int
//      cms_add(sketch, item)                 -> map
//      cms_estimate(sketch, item)            -> int
//      cms_width(sketch)                     -> int
//      cms_depth(sketch)                     -> int
//
//  Bonus helper (pure convenience, not in spec):
//      cms_merge(s1, s2)                     -> map  (element-wise add, same shape)
//
//  Error bounds (parameter sizing guidance):
//      width w >= e / epsilon       (over-count additive error epsilon * N)
//      depth d >= ln(1 / delta)     (probability 1 - delta the bound holds)
//      where N = total additions. Estimate is always >= true count (no under-count).
//
//  Properties:
//      - No under-count (estimate is a non-strict upper bound on true count)
//      - Over-count possible (hash collisions add neighbor counts)
//      - Counters stored row-major in a single 1D array of length d*w
//      - Pure Hexa, no C/FFI, no external imports
//
//  HX3 pitfalls handled:
//      P1   no semicolons
//      P15  let mut for mutable variables
//      P30  no unsigned int — emulate via & 0xFFFFFFFF
//      Array concat in loops O(n^2) — use .push()
// ═══════════════════════════════════════════════════════════════════

let MASK32 = 0xFFFFFFFF

// ── FNV-1a 32-bit constants ─────────────────────────────────────
let FNV_OFFSET = 0x811C9DC5
let FNV_PRIME  = 0x01000193

// ── 32-bit multiply via 16-bit split (avoid int64 overflow) ─────
@pure
fn _mul32(a, b) {
    let a32 = a & MASK32
    let b32 = b & MASK32
    let aL = a32 & 0xFFFF
    let aH = (a32 / 65536) & 0xFFFF
    let bL = b32 & 0xFFFF
    let bH = (b32 / 65536) & 0xFFFF
    let low = aL * bL
    let mid = aL * bH + aH * bL
    return (low + mid * 65536) & MASK32
}

// ── cms_hash ────────────────────────────────────────────────────
// FNV-1a with seed mixing. Produces a column index in [0, width).
@pure
pub fn cms_hash(item, seed, width) {
    if width <= 0 { return 0 }
    let s = to_string(item)
    let n = len(s)
    // mix seed into FNV offset basis
    let mut hval = (FNV_OFFSET ^ (seed & MASK32)) & MASK32
    let mut i = 0
    while i < n {
        let byte = char_code(s, i)
        hval = (hval ^ (byte & 0xFF)) & MASK32
        hval = _mul32(hval, FNV_PRIME)
        i = i + 1
    }
    // second mix with seed for better decorrelation across rows
    hval = (hval ^ _mul32(seed, 0x9E3779B9)) & MASK32
    hval = _mul32(hval, FNV_PRIME)
    return hval % width
}

// ── cms_create ──────────────────────────────────────────────────
// Returns #{counters: [int], width: int, depth: int}
// counters is a row-major 1D array of length depth*width, zero-init.
pub fn cms_create(width, depth) {
    let mut counters = []
    let total = width * depth
    let mut i = 0
    while i < total {
        counters.push(0)
        i = i + 1
    }
    let mut result = #{}
    result["counters"] = counters
    result["width"] = width
    result["depth"] = depth
    return result
}

// ── cms_add ─────────────────────────────────────────────────────
// Increments one counter per row at column = cms_hash(item, row_seed, w).
// Row seed = row index (0..depth-1). Returns updated sketch map.
pub fn cms_add(sketch, item) {
    let counters = sketch["counters"]
    let w = sketch["width"]
    let d = sketch["depth"]
    let mut row = 0
    while row < d {
        let col = cms_hash(item, row, w)
        let idx = row * w + col
        counters[idx] = counters[idx] + 1
        row = row + 1
    }
    let mut r = #{}
    r["counters"] = counters
    r["width"] = w
    r["depth"] = d
    return r
}

// ── cms_estimate ────────────────────────────────────────────────
// Returns min over d row-counters (the Count-Min estimator).
@pure
pub fn cms_estimate(sketch, item) {
    let counters = sketch["counters"]
    let w = sketch["width"]
    let d = sketch["depth"]
    if d <= 0 { return 0 }
    let first_col = cms_hash(item, 0, w)
    let mut best = counters[first_col]
    let mut row = 1
    while row < d {
        let col = cms_hash(item, row, w)
        let idx = row * w + col
        let v = counters[idx]
        if v < best { best = v }
        row = row + 1
    }
    return best
}

// ── cms_width ───────────────────────────────────────────────────
@pure
pub fn cms_width(sketch) {
    return sketch["width"]
}

// ── cms_depth ───────────────────────────────────────────────────
@pure
pub fn cms_depth(sketch) {
    return sketch["depth"]
}

// ── cms_merge (bonus) ───────────────────────────────────────────
// Element-wise add of two same-shape sketches. Shapes must match.
pub fn cms_merge(s1, s2) {
    let w = s1["width"]
    let d = s1["depth"]
    let w2 = s2["width"]
    let d2 = s2["depth"]
    if w != w2 { return s1 }
    if d != d2 { return s1 }
    let c1 = s1["counters"]
    let c2 = s2["counters"]
    let total = w * d
    let mut merged = []
    let mut i = 0
    while i < total {
        merged.push(c1[i] + c2[i])
        i = i + 1
    }
    let mut r = #{}
    r["counters"] = merged
    r["width"] = w
    r["depth"] = d
    return r
}
