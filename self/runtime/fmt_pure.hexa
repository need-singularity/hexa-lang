// self/runtime/fmt_pure.hexa — String formatting utilities
//
// Pure-Hexa string formatting: pad, align, repeat, truncate.
//
// API:
//   pad_left(s, width, ch)   -> left-padded string
//   pad_right(s, width, ch)  -> right-padded string
//   repeat_str(s, n)         -> string repeated n times
//   truncate(s, max_len)     -> truncated string with "..." if over max
//   center(s, width, ch)     -> centered string
//
// Constraints honored (CLAUDE.md):
//   - No C dependencies, no FFI
//   - P1 no semicolons, P15 let mut everywhere
//   - .push() not arr + [x] in loops
//   - parts.join("") for string building

// ── repeat_str ──────────────────────────────────────────────────
// Repeats string s exactly n times.
@pure pub fn repeat_str(s, n) {
    if n <= 0 { return "" }
    let mut parts = []
    let mut i = 0
    while i < n {
        parts = parts.push(s)
        i = i + 1
    }
    parts.join("")
}

// ── pad_left ────────────────────────────────────────────────────
// Left-pads s to width with ch.
@pure pub fn pad_left(s, width, ch) {
    let slen = len(s)
    if slen >= width { return s }
    let pad = repeat_str(ch, width - slen)
    pad + s
}

// ── pad_right ───────────────────────────────────────────────────
// Right-pads s to width with ch.
@pure pub fn pad_right(s, width, ch) {
    let slen = len(s)
    if slen >= width { return s }
    let pad = repeat_str(ch, width - slen)
    s + pad
}

// ── center ──────────────────────────────────────────────────────
// Centers s in a field of given width, padded with ch.
@pure pub fn center(s, width, ch) {
    let slen = len(s)
    if slen >= width { return s }
    let total_pad = width - slen
    let left_pad = total_pad / 2
    let right_pad = total_pad - left_pad
    repeat_str(ch, left_pad) + s + repeat_str(ch, right_pad)
}

// ── truncate ────────────────────────────────────────────────────
// Truncates s to max_len, appending "..." if truncated.
@pure pub fn truncate(s, max_len) {
    let slen = len(s)
    if slen <= max_len { return s }
    if max_len <= 3 { return s.substring(0, max_len) }
    s.substring(0, max_len - 3) + "..."
}
