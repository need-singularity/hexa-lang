// ═══════════════════════════════════════════════════════════════════
//  self/runtime/array_ext_pure.hexa — extended list/array combinators
//
//  Net-new pure-Hexa array combinators that compose with existing
//  array_pure / array_higher_pure / range_pure primitives.  None of
//  these correspond to an existing `hexa_*` C builtin — this file
//  widens the pure-Hexa surface without touching runtime.c (HX10).
//
//  Public API:
//      unzip_pure(pairs)              // [[a,b],...] → [as, bs]
//      take_while_pure(arr, pred)     // prefix while pred true
//      drop_while_pure(arr, pred)     // suffix after pred false
//      window_pure(arr, n)            // sliding windows size n
//      chunks_pure(arr, n)            // non-overlapping chunks size n
//
//  Pitfalls (grammar.jsonl):
//      P1  no semicolons
//      P15 let mut everywhere
//      P29 .push() returns NEW array — rebind required
// ═══════════════════════════════════════════════════════════════════

// ── unzip_pure ───────────────────────────────────────────────────────
// Inverse of zip_pure. Given [[a0,b0],[a1,b1],...] returns [as, bs].
// Non-array elements or missing index-1 are treated as nil.
@pure
pub fn unzip_pure(pairs) {
    let mut xs = []
    let mut ys = []
    if type_of(pairs) != "array" { return [xs, ys] }
    let n = len(pairs)
    let mut i = 0
    while i < n {
        let p = pairs[i]
        if type_of(p) == "array" {
            let m = len(p)
            if m >= 1 { xs = xs.push(p[0]) } else { xs = xs.push(nil) }
            if m >= 2 { ys = ys.push(p[1]) } else { ys = ys.push(nil) }
        } else {
            xs = xs.push(nil)
            ys = ys.push(nil)
        }
        i = i + 1
    }
    return [xs, ys]
}

// ── take_while_pure ──────────────────────────────────────────────────
// Take the leading prefix while `pred(elem)` is true.  Stops at the
// first element where pred returns false.
@pure
pub fn take_while_pure(arr, pred) {
    let mut out = []
    if type_of(arr) != "array" { return out }
    let n = len(arr)
    let mut i = 0
    while i < n {
        let v = arr[i]
        if pred(v) {
            out = out.push(v)
            i = i + 1
        } else {
            return out
        }
    }
    return out
}

// ── drop_while_pure ──────────────────────────────────────────────────
// Drop the leading prefix while `pred(elem)` is true.  Returns the
// tail starting at the first element where pred returns false.
@pure
pub fn drop_while_pure(arr, pred) {
    let mut out = []
    if type_of(arr) != "array" { return out }
    let n = len(arr)
    let mut i = 0
    while i < n {
        if pred(arr[i]) {
            i = i + 1
        } else {
            while i < n {
                out = out.push(arr[i])
                i = i + 1
            }
            return out
        }
    }
    return out
}

// ── window_pure ──────────────────────────────────────────────────────
// Sliding windows of size `n` with step 1.  window_pure([1,2,3,4], 2)
// → [[1,2],[2,3],[3,4]].  Returns [] if n <= 0 or n > len(arr).
@pure
pub fn window_pure(arr, n) {
    let mut out = []
    if type_of(arr) != "array" { return out }
    if n <= 0 { return out }
    let total = len(arr)
    if n > total { return out }
    let last = total - n
    let mut i = 0
    while i <= last {
        let mut w = []
        let mut j = 0
        while j < n {
            w = w.push(arr[i + j])
            j = j + 1
        }
        out = out.push(w)
        i = i + 1
    }
    return out
}

// ── chunks_pure ──────────────────────────────────────────────────────
// Split `arr` into non-overlapping runs of size `n`.  The last run may
// be shorter if len(arr) is not divisible by n.  Returns [] on n <= 0.
@pure
pub fn chunks_pure(arr, n) {
    let mut out = []
    if type_of(arr) != "array" { return out }
    if n <= 0 { return out }
    let total = len(arr)
    let mut i = 0
    while i < total {
        let mut c = []
        let mut j = 0
        while j < n {
            let k = i + j
            if k >= total { j = n } else {
                c = c.push(arr[k])
                j = j + 1
            }
        }
        out = out.push(c)
        i = i + n
    }
    return out
}
