// self/runtime/lfu_cache_pure.hexa — Least Frequently Used cache
//
// Pure-Hexa LFU cache using parallel arrays.
//
// API:
//   lfu_new(capacity)       -> cache state [keys, vals, freqs, cap]
//   lfu_get(cache, key)     -> [cache, value_or_nil]
//   lfu_put(cache, key, val) -> cache
//   lfu_size(cache)         -> int
//
// Constraints honored (CLAUDE.md):
//   - No C dependencies, no FFI
//   - P1 no semicolons, P15 let mut everywhere
//   - .push() not arr + [x] in loops

// Cache layout: [keys_arr, vals_arr, freqs_arr, capacity]
//   keys_arr[i], vals_arr[i], freqs_arr[i] are parallel arrays

// ── lfu_new ─────────────────────────────────────────────────────
@pure pub fn lfu_new(capacity) {
    [[], [], [], capacity]
}

// ── _lfu_find ───────────────────────────────────────────────────
fn _lfu_find(keys, key) {
    let mut i = 0
    while i < len(keys) {
        if to_string(keys[i]) == to_string(key) { return i }
        i = i + 1
    }
    -1
}

// ── _lfu_set_at ─────────────────────────────────────────────────
// Returns new array with arr[idx] replaced by val.
fn _lfu_set_at(arr, idx, val) {
    let mut out = []
    let mut i = 0
    while i < len(arr) {
        if i == idx {
            out = out.push(val)
        } else {
            out = out.push(arr[i])
        }
        i = i + 1
    }
    out
}

// ── _lfu_remove_at ──────────────────────────────────────────────
fn _lfu_remove_at(arr, idx) {
    let mut out = []
    let mut i = 0
    while i < len(arr) {
        if i != idx {
            out = out.push(arr[i])
        }
        i = i + 1
    }
    out
}

// ── _lfu_min_freq_idx ───────────────────────────────────────────
// Returns index of element with minimum frequency.
fn _lfu_min_freq_idx(freqs) {
    let mut min_idx = 0
    let mut min_val = freqs[0]
    let mut i = 1
    while i < len(freqs) {
        if freqs[i] < min_val {
            min_val = freqs[i]
            min_idx = i
        }
        i = i + 1
    }
    min_idx
}

// ── lfu_get ─────────────────────────────────────────────────────
// Returns [new_cache, value]. value is nil on miss.
@pure pub fn lfu_get(cache, key) {
    let keys = cache[0]
    let vals = cache[1]
    let freqs = cache[2]
    let cap = cache[3]
    let idx = _lfu_find(keys, key)
    if idx == -1 {
        return [cache, nil]
    }
    let new_freqs = _lfu_set_at(freqs, idx, freqs[idx] + 1)
    [[keys, vals, new_freqs, cap], vals[idx]]
}

// ── lfu_put ─────────────────────────────────────────────────────
@pure pub fn lfu_put(cache, key, val) {
    let keys = cache[0]
    let vals = cache[1]
    let freqs = cache[2]
    let cap = cache[3]
    // update existing
    let idx = _lfu_find(keys, key)
    if idx != -1 {
        let new_vals = _lfu_set_at(vals, idx, val)
        let new_freqs = _lfu_set_at(freqs, idx, freqs[idx] + 1)
        return [keys, new_vals, new_freqs, cap]
    }
    // need to evict if at capacity
    let mut k = keys
    let mut v = vals
    let mut f = freqs
    if len(k) >= cap {
        let evict = _lfu_min_freq_idx(f)
        k = _lfu_remove_at(k, evict)
        v = _lfu_remove_at(v, evict)
        f = _lfu_remove_at(f, evict)
    }
    // insert new
    k = k.push(key)
    v = v.push(val)
    f = f.push(1)
    [k, v, f, cap]
}

// ── lfu_size ────────────────────────────────────────────────────
@pure pub fn lfu_size(cache) {
    len(cache[0])
}
