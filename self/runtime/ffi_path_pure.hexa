// self/runtime/ffi_path_pure.hexa — Wave 1 runtime port (FFI library path parsing)
//
// Pure-Hexa equivalent of `hexa_ffi_extract_libname` (runtime.c:3334).
// The C helper extracts a bare library name (without the conventional
// `lib` prefix and `.dylib` / `.so` / `.so.N` suffix) from a possibly
// absolute shared-library path. It is used by hexa_ffi_dlopen so that
// `@link("/abs/path/libhxblas.dylib")` can fall back to a Linux
// `libhxblas.so` (or vice-versa) without source changes — see the
// hxblas-linux port (2026-04-16, c6_hxblas_linux_port_20260416.json).
//
// Behaviour (mirrors C reference):
//   "/abs/path/libhxblas.dylib"   -> "hxblas"
//   "./libfoo.so"                 -> "foo"
//   "libhxml.so.2"                -> "hxml"
//   "libalone"                    -> ""   (no recognised suffix)
//   "not-a-lib.dylib"             -> ""   (no "lib" prefix in basename)
//   ""                            -> ""
//
// ADDITIVE — the C body remains live for codegen-emitted dlopen calls.
// This file is the reference impl for the upcoming codegen interpose
// pass and is what `import "self/runtime/ffi_path_pure"` resolves to.
//
// Pitfalls honoured (CLAUDE.md HX3 + grammar.jsonl):
//   P1  no semicolons
//   P15 let mut for reassigned locals
//   P29 .push() returns new array
//   + string_pure::str_index_of_pure / last_index_of style idioms

// ── _ffi_basename (internal) — drop any leading directory component ───
@pure
fn _ffi_basename(path) {
    let n = len(path)
    if n == 0 { return path }
    // Find the last '/' (ASCII) manually without str_last_index_of_pure
    // to keep this module stand-alone.
    let mut i = n - 1
    let mut cut = 0 - 1
    while i >= 0 {
        if path.substring(i, i + 1) == "/" {
            cut = i
            i = 0 - 1
        } else {
            i = i - 1
        }
    }
    if cut < 0 { return path }
    path.substring(cut + 1, n)
}

// ── _ffi_find_suffix (internal) — locate ".dylib" / ".so" / ".so.N"
// suffix in `base`. Returns the index of the '.' starting the suffix,
// or -1 if `base` does not end in a recognised suffix.
@pure
fn _ffi_find_suffix(base) {
    let n = len(base)
    if n >= 6 && base.substring(n - 6, n) == ".dylib" {
        return n - 6
    }
    if n >= 3 && base.substring(n - 3, n) == ".so" {
        return n - 3
    }
    // ".so.N" case — scan for ".so." from the left and pick the first
    // occurrence. The C reference uses strstr which finds the leftmost
    // ".so." substring.
    let mut i = 0
    let lim = n - 4
    while i <= lim {
        if base.substring(i, i + 4) == ".so." {
            return i
        }
        i = i + 1
    }
    0 - 1
}

// ── ffi_extract_libname_pure ──────────────────────────────────────
// Returns the bare library name, or "" on any unrecognised input.
@pure
pub fn ffi_extract_libname_pure(path) {
    if type_of(path) != "string" { return "" }
    let n = len(path)
    if n == 0 { return "" }

    let base = _ffi_basename(path)
    let bn = len(base)
    if bn < 3 { return "" }
    if base.substring(0, 3) != "lib" { return "" }

    let after_lib = base.substring(3, bn)
    let suffix_at = _ffi_find_suffix(after_lib)
    if suffix_at < 0 { return "" }
    if suffix_at == 0 { return "" }

    after_lib.substring(0, suffix_at)
}
