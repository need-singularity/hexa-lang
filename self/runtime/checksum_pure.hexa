// self/runtime/checksum_pure.hexa -- Phase 2.10 runtime port (checksums)
//
// Pure-Hexa port of five classical checksum / hash functions. These
// complement the existing hash_pure.hexa (FNV-1a 32) and crc32_pure.hexa
// (CRC-32) modules. None of these is present in self/runtime.c yet;
// this file is the canonical reference.
//
// Functions:
//   sdbm_pure(s)        — SDBM hash (h = c + h*65599). 32-bit masked.
//                          Widely used in gawk / gdbm / sendmail.
//   djb2_pure(s)        — Bernstein DJB2 (h = h*33 + c, init 5381,
//                          masked to 32-bit).
//   adler32_pure(s)     — Adler-32 (RFC 1950 zlib). a,b reduced mod
//                          65521 per byte, output b*2^16 + a.
//   sum_xor_pure(s)     — simple 8-bit XOR checksum.
//   luhn_pure(s)        — Luhn mod-10 checksum over digits. Returns
//                          the final mod-10 sum (0 == valid check).
//
// Pitfalls honored:
//   P15 let mut for reassigned locals
//   P29 .push() returns new array — unused here
//   P30 no unsigned type — mask at every step
//   P50 stage0 interpreter rejects `<<` / `>>` (parse error) — use
//        integer multiply/divide by 2 instead.
//
// Note on 64-bit FNV: not included here. HEXA int is 64-bit *signed*,
// so the FNV-1a-64 offset 0xCBF29CE484222325 and the multiply result
// both exceed 2^63, requiring a high/low split throughout. A dedicated
// fnv1a_64_pure belongs in a future module that embraces that cost.

let TWO_POW_32 = 4294967296     // 2^32

// ── SDBM constants ────────────────────────────────────────────────
// Found empirically to scramble bits well with a simple formula.
// Max intermediate: (2^32-1) * 65599 ≈ 2^48, fits in int63.
let SDBM_MULT = 65599

// ── sdbm_pure — SDBM hash, 32-bit masked ──────────────────────────
pub fn sdbm_pure(s) {
    if type_of(s) != "string" { return 0 }
    let mut h = 0
    let mut i = 0
    let n = len(s)
    while i < n {
        let c = ord(s.substring(i, i + 1))
        h = (c + h * SDBM_MULT) % TWO_POW_32
        i = i + 1
    }
    h
}

// ── DJB2 constants ────────────────────────────────────────────────
let DJB2_INIT = 5381

// ── djb2_pure — Bernstein DJB2, masked to 32-bit ──────────────────
// Max intermediate: (2^32-1) * 33 + 255 ≈ 2^37, fits comfortably.
pub fn djb2_pure(s) {
    if type_of(s) != "string" { return DJB2_INIT }
    let mut h = DJB2_INIT
    let mut i = 0
    let n = len(s)
    while i < n {
        let c = ord(s.substring(i, i + 1))
        h = (h * 33 + c) % TWO_POW_32
        i = i + 1
    }
    h
}

// ── Adler-32 constants ────────────────────────────────────────────
let ADLER_MOD = 65521

// ── adler32_pure — Adler-32 (RFC 1950) ────────────────────────────
// a, b are each < 65521, so b*65536 + a < 2^32, fits in int63.
pub fn adler32_pure(s) {
    if type_of(s) != "string" { return 1 }
    let mut a = 1
    let mut b = 0
    let mut i = 0
    let n = len(s)
    while i < n {
        let c = ord(s.substring(i, i + 1))
        a = (a + c) % ADLER_MOD
        b = (b + a) % ADLER_MOD
        i = i + 1
    }
    b * 65536 + a
}

// ── sum_xor_pure — 8-bit XOR checksum ─────────────────────────────
// Result always in [0, 255].
pub fn sum_xor_pure(s) {
    if type_of(s) != "string" { return 0 }
    let mut h = 0
    let mut i = 0
    let n = len(s)
    while i < n {
        let c = ord(s.substring(i, i + 1))
        h = h ^ c
        i = i + 1
    }
    h
}

// ── luhn_pure — mod-10 credit-card style checksum ────────────────
// Returns the mod-10 total. A valid sequence yields 0. Non-digit
// characters are skipped (permits dashes/spaces in card numbers).
// Doubling follows the canonical right-to-left rule: every second
// digit from the right is doubled (index 1, 3, 5, …).
pub fn luhn_pure(s) {
    if type_of(s) != "string" { return 0 }
    let n = len(s)
    // First pass: collect digit values in left-to-right order.
    let mut digits = []
    let mut i = 0
    while i < n {
        let c = ord(s.substring(i, i + 1))
        if c >= 48 {
            if c <= 57 {
                digits = digits + [c - 48]
            }
        }
        i = i + 1
    }
    // Second pass: walk right-to-left, doubling every second digit.
    let m = len(digits)
    let mut total = 0
    let mut k = 0
    while k < m {
        let mut d = digits[m - 1 - k]
        if (k % 2) == 1 {
            d = d * 2
            if d > 9 { d = d - 9 }
        }
        total = total + d
        k = k + 1
    }
    total % 10
}
