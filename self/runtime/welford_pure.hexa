// ═══════════════════════════════════════════════════════════════════
//  self/runtime/welford_pure.hexa — pure-Hexa one-pass online statistics
//
//  Welford's online algorithm for numerically stable running
//  mean, variance, and standard deviation in a single pass.
//  No C, no FFI, no libm — pure Hexa only.
//
//  Public API (_pure suffix — canonical names):
//      welford_new_pure()                  -> dict   — init empty state
//      welford_update_pure(state, x)       -> dict   — add one sample
//      welford_mean_pure(state)            -> float  — current mean
//      welford_variance_pure(state)        -> float  — population variance (m2/n)
//      welford_sample_variance_pure(state) -> float  — sample variance (m2/(n-1))
//      welford_stddev_pure(state)          -> float  — population std dev
//      welford_merge_pure(a, b)            -> dict   — merge two states (parallel)
//      welford_from_array(arr)             -> dict   — convenience fold
//
//  Legacy aliases (no _pure suffix) retained for backward compat.
// ═══════════════════════════════════════════════════════════════════

// ── sqrt helper (inline Newton-Raphson) ─────────────────────────
// Avoids import dependency on math_pure.hexa.
@pure
fn _wf_sqrt(x) {
    let s = x * 1.0
    if s <= 0.0 { return 0.0 }
    let mut guess = if s > 1.0 { s * 0.5 } else { 1.0 }
    let mut i = 0
    while i < 60 {
        let next = 0.5 * (guess + s / guess)
        let diff = next - guess
        let ad = if diff < 0.0 { 0.0 - diff } else { diff }
        if ad < 1.0e-15 * next {
            if ad < 1.0e-15 { return next }
        }
        guess = next
        i = i + 1
    }
    return guess
}

// ── welford_new_pure ─────────────────────────────────────────────
// Returns initial Welford state: {n: 0, mean: 0.0, m2: 0.0}
@pure
pub fn welford_new_pure() {
    return #{"n": 0, "mean": 0.0, "m2": 0.0}
}

// ── welford_update_pure ──────────────────────────────────────────
// Add one sample x to the running state. Returns updated state.
// Welford recurrence:
//   n      <- n + 1
//   delta  <- x - mean
//   mean   <- mean + delta / n
//   delta2 <- x - mean   (using new mean)
//   m2     <- m2 + delta * delta2
@pure
pub fn welford_update_pure(state, x) {
    let old_n = state["n"]
    let old_mean = state["mean"]
    let old_m2 = state["m2"]

    let new_n = old_n + 1
    let fx = x * 1.0
    let delta = fx - old_mean
    let new_mean = old_mean + delta / (new_n * 1.0)
    let delta2 = fx - new_mean
    let new_m2 = old_m2 + delta * delta2

    return #{"n": new_n, "mean": new_mean, "m2": new_m2}
}

// ── welford_mean_pure ────────────────────────────────────────────
@pure
pub fn welford_mean_pure(state) {
    return state["mean"]
}

// ── welford_variance_pure ────────────────────────────────────────
// Population variance = m2 / n.  Returns 0.0 for n == 0.
@pure
pub fn welford_variance_pure(state) {
    let n = state["n"]
    if n == 0 { return 0.0 }
    return state["m2"] / (n * 1.0)
}

// ── welford_sample_variance_pure ─────────────────────────────────
// Sample variance = m2 / (n - 1).  Returns 0.0 for n <= 1.
@pure
pub fn welford_sample_variance_pure(state) {
    let n = state["n"]
    if n <= 1 { return 0.0 }
    return state["m2"] / ((n - 1) * 1.0)
}

// ── welford_stddev_pure ──────────────────────────────────────────
// Population standard deviation = sqrt(variance).
@pure
pub fn welford_stddev_pure(state) {
    let v = welford_variance_pure(state)
    if v <= 0.0 { return 0.0 }
    return _wf_sqrt(v)
}

// ── welford_merge_pure ───────────────────────────────────────────
// Merge two independent Welford states (Chan et al. parallel algorithm).
//   n_ab   = n_a + n_b
//   delta  = mean_b - mean_a
//   mean   = (n_a * mean_a + n_b * mean_b) / n_ab
//   m2     = m2_a + m2_b + delta^2 * n_a * n_b / n_ab
@pure
pub fn welford_merge_pure(a, b) {
    let na = a["n"]
    let nb = b["n"]
    if na == 0 { return b }
    if nb == 0 { return a }

    let n_ab = na + nb
    let delta = b["mean"] - a["mean"]
    let new_mean = (na * 1.0 * a["mean"] + nb * 1.0 * b["mean"]) / (n_ab * 1.0)
    let new_m2 = a["m2"] + b["m2"] + delta * delta * (na * 1.0) * (nb * 1.0) / (n_ab * 1.0)

    return #{"n": n_ab, "mean": new_mean, "m2": new_m2}
}

// ── welford_from_array ───────────────────────────────────────────
// Convenience: fold all elements of arr through welford_update_pure.
@pure
pub fn welford_from_array(arr) {
    let mut st = welford_new_pure()
    let n = len(arr)
    let mut i = 0
    while i < n {
        st = welford_update_pure(st, arr[i])
        i = i + 1
    }
    return st
}

// ── welford_remove_pure ──────────────────────────────────────────
// Inverse of welford_update_pure: remove a previously-added sample x.
// Precondition: x was actually added to state (caller responsibility).
// Returns state with n-1 observations.  If n drops to 0, resets to init.
@pure
pub fn welford_remove_pure(state, x) {
    let old_n = state["n"]
    if old_n <= 1 { return welford_new_pure() }

    let new_n = old_n - 1
    let fx = x * 1.0
    let delta = fx - state["mean"]
    let new_mean = (state["mean"] * (old_n * 1.0) - fx) / (new_n * 1.0)
    let delta2 = fx - new_mean
    let new_m2 = state["m2"] - delta * delta2

    return #{"n": new_n, "mean": new_mean, "m2": new_m2}
}

// ═══════════════════════════════════════════════════════════════════
//  Legacy / convenience aliases (backward compat with existing callers)
// ═══════════════════════════════════════════════════════════════════
@pure
pub fn welford_init() { return welford_new_pure() }
@pure
pub fn welford_new() { return welford_new_pure() }
@pure
pub fn welford_update(state, x) { return welford_update_pure(state, x) }
@pure
pub fn welford_mean(state) { return welford_mean_pure(state) }
@pure
pub fn welford_variance(state) { return welford_variance_pure(state) }
@pure
pub fn welford_sample_variance(state) { return welford_sample_variance_pure(state) }
@pure
pub fn welford_stddev(state) { return welford_stddev_pure(state) }
@pure
pub fn welford_std(state) { return welford_stddev_pure(state) }
@pure
pub fn welford_batch(data) { return welford_from_array(data) }
@pure
pub fn welford_merge(a, b) { return welford_merge_pure(a, b) }
@pure
pub fn welford_remove(state, x) { return welford_remove_pure(state, x) }
