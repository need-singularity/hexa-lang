// self/runtime/dijkstra_pure.hexa -- Dijkstra shortest path (pure hexa)
//
// Binary-heap priority queue + Dijkstra single-source shortest path.
// No C deps, no FFI, no 0b literals.
//
// Public API:
//     dijkstra_pure(n, edges, src)           -> [int] dist array (999999999 = unreachable)
//     dijkstra_path_pure(n, edges, src, dst) -> [int] path node list ([] if unreachable)
//     heap_push_pure(heap, item)             -> new heap with item inserted
//     heap_pop_pure(heap)                    -> [popped_item, new_heap]
//
// Pitfalls honored: P1 no semicolons, P15 let mut, P29 push rebind,
// while loops only, no ++ or --, swap via tmp

// ── Min-heap helpers ─────────────────────────────────────────────
// Heap is an array of [dist, node] pairs.
// Parent: (i-1)/2   Left: 2*i+1   Right: 2*i+2

fn _heap_swap(heap, i, j) {
    let tmp = heap[i]
    heap[i] = heap[j]
    heap[j] = tmp
    return heap
}

fn _heap_sift_up(heap, idx) {
    let mut i = idx
    while i > 0 {
        let parent = (i - 1) / 2
        if heap[i][0] < heap[parent][0] {
            heap = _heap_swap(heap, i, parent)
            i = parent
        } else {
            i = 0
        }
    }
    return heap
}

fn _heap_sift_down(heap, idx) {
    let n = len(heap)
    let mut i = idx
    let mut cont = true
    while cont {
        let left = 2 * i + 1
        let right = 2 * i + 2
        let mut smallest = i
        if left < n {
            if heap[left][0] < heap[smallest][0] {
                smallest = left
            }
        }
        if right < n {
            if heap[right][0] < heap[smallest][0] {
                smallest = right
            }
        }
        if smallest != i {
            heap = _heap_swap(heap, i, smallest)
            i = smallest
        } else {
            cont = false
        }
    }
    return heap
}

// Push item onto min-heap. Sift up by comparing item[0] (distance).
@pure
pub fn heap_push_pure(heap, item) {
    let mut h = heap.push(item)
    h = _heap_sift_up(h, len(h) - 1)
    return h
}

// Pop minimum element from min-heap. Returns [popped_item, new_heap].
// If heap is empty, returns [nil, []].
@pure
pub fn heap_pop_pure(heap) {
    let n = len(heap)
    if n == 0 { return [nil, []] }
    if n == 1 { return [heap[0], []] }
    let top = heap[0]
    heap[0] = heap[n - 1]
    // Remove last element by rebuilding
    let mut new_heap = []
    let mut i = 0
    while i < n - 1 {
        new_heap = new_heap.push(heap[i])
        i = i + 1
    }
    new_heap = _heap_sift_down(new_heap, 0)
    return [top, new_heap]
}

// ── Build adjacency list from edge list ──────────────────────────
fn _build_adj(n, edges) {
    // adj[u] = [[v, w], [v2, w2], ...]
    let mut adj = []
    let mut i = 0
    while i < n {
        adj = adj.push([])
        i = i + 1
    }
    let ne = len(edges)
    let mut j = 0
    while j < ne {
        let e = edges[j]
        let u = e[0]
        let v = e[1]
        let w = e[2]
        adj[u] = adj[u].push([v, w])
        j = j + 1
    }
    return adj
}

// ── dijkstra_pure ────────────────────────────────────────────────
// Returns dist array of length n. dist[i] = shortest distance from
// src to i, or 999999999 if unreachable.
@pure
pub fn dijkstra_pure(n, edges, src) {
    let inf = 999999999
    let adj = _build_adj(n, edges)

    // Initialize dist array
    let mut dist = []
    let mut i = 0
    while i < n {
        if i == src {
            dist = dist.push(0)
        } else {
            dist = dist.push(inf)
        }
        i = i + 1
    }

    // visited array
    let mut visited = []
    i = 0
    while i < n {
        visited = visited.push(false)
        i = i + 1
    }

    // Min-heap: [dist, node]
    let mut heap = []
    heap = heap_push_pure(heap, [0, src])

    while len(heap) > 0 {
        let result = heap_pop_pure(heap)
        let top = result[0]
        heap = result[1]
        let d = top[0]
        let u = top[1]

        if visited[u] {
            // skip stale entries
        } else {
            visited[u] = true

            let neighbors = adj[u]
            let nn = len(neighbors)
            let mut k = 0
            while k < nn {
                let edge = neighbors[k]
                let v = edge[0]
                let w = edge[1]
                let new_dist = d + w
                if new_dist < dist[v] {
                    dist[v] = new_dist
                    heap = heap_push_pure(heap, [new_dist, v])
                }
                k = k + 1
            }
        }
    }

    return dist
}

// ── dijkstra_path_pure ───────────────────────────────────────────
// Returns the actual shortest path from src to dst as a list of nodes,
// or [] if dst is unreachable from src.
@pure
pub fn dijkstra_path_pure(n, edges, src, dst) {
    let inf = 999999999
    let adj = _build_adj(n, edges)

    let mut dist = []
    let mut prev = []
    let mut i = 0
    while i < n {
        if i == src {
            dist = dist.push(0)
        } else {
            dist = dist.push(inf)
        }
        prev = prev.push(-1)
        i = i + 1
    }

    let mut visited = []
    i = 0
    while i < n {
        visited = visited.push(false)
        i = i + 1
    }

    let mut heap = []
    heap = heap_push_pure(heap, [0, src])

    while len(heap) > 0 {
        let result = heap_pop_pure(heap)
        let top = result[0]
        heap = result[1]
        let d = top[0]
        let u = top[1]

        if visited[u] {
            // skip
        } else {
            visited[u] = true

            let neighbors = adj[u]
            let nn = len(neighbors)
            let mut k = 0
            while k < nn {
                let edge = neighbors[k]
                let v = edge[0]
                let w = edge[1]
                let new_dist = d + w
                if new_dist < dist[v] {
                    dist[v] = new_dist
                    prev[v] = u
                    heap = heap_push_pure(heap, [new_dist, v])
                }
                k = k + 1
            }
        }
    }

    // Unreachable
    if dist[dst] == inf {
        return []
    }

    // Reconstruct path by walking prev[] backwards
    let mut path = []
    let mut cur = dst
    while cur != -1 {
        path = path.push(cur)
        cur = prev[cur]
    }

    // Reverse the path
    let plen = len(path)
    let mut reversed = []
    let mut j = plen - 1
    while j >= 0 {
        reversed = reversed.push(path[j])
        j = j - 1
    }

    return reversed
}
