// self/runtime/file_pure.hexa -- Phase 2.1 runtime port (file I/O)
//
// Pure-Hexa wrappers for file I/O operations currently implemented in
// self/runtime.c (hexa_read_file, hexa_write_file, hexa_delete_file,
// hexa_append_file). These are TRANSITIONAL bridges: they delegate to
// the existing exec() builtin for read/stat/exists, and to write_file
// builtin for writes. Once native codegen can emit syscalls directly,
// these wrappers become the sole entry point and the C bodies drop.
//
// ADDITIVE -- does not remove any C function. See string_pure.hexa
// header for the full rationale on why removal requires a codegen
// interpose pass first.
//
// Shell injection note: paths are controlled by the self-hosting
// compiler itself (never user input at this stage). Production code
// must never pass untrusted strings to exec().
//
// Pitfalls observed:
//   P1  no semicolons
//   P15 let mut everywhere
//   P28 nil/true/false literals lower correctly

// ── read_file_pure ────────────────────────────────────────────────
// Mirrors hexa_read_file (runtime.c:2591). Reads entire file as string.
// Uses exec("cat ...") as the bridge. Returns "" on missing files,
// matching the C behavior (fopen fail -> "").
pub fn read_file_pure(path) {
    exec("cat '" + path + "'")
}

// ── write_file_pure ───────────────────────────────────────────────
// Mirrors hexa_write_file (runtime.c:2604). Writes content to file,
// creating or truncating. Delegates to the write_file builtin which
// is the thinnest FFI shim available.
pub fn write_file_pure(path, content) {
    write_file(path, content)
}

// ── append_file_pure ──────────────────────────────────────────────
// Mirrors hexa_append_file (runtime.c:4329). Appends content to file.
// Uses shell redirect as bridge since there is no append_file builtin
// in the interpreter.
pub fn append_file_pure(path, content) {
    // Write content to a temp file, then cat-append to target.
    // This avoids echo/printf which mangle escapes.
    let tmp = "/tmp/_hexa_append_" + to_string(timestamp())
    write_file(tmp, content)
    exec("cat '" + tmp + "' >> '" + path + "'")
    exec("rm -f '" + tmp + "'")
}

// ── delete_file_pure ──────────────────────────────────────────────
// Mirrors hexa_delete_file (runtime.c:4323). Removes a file.
// Uses exec("rm -f ..."). Silent on missing files, matching C unlink.
pub fn delete_file_pure(path) {
    exec("rm -f '" + path + "'")
}

// ── file_exists_pure ──────────────────────────────────────────────
// No direct C counterpart (C code uses fopen != NULL inline).
// Returns true if path exists as a regular file.
pub fn file_exists_pure(path) {
    let r = exec("test -f '" + path + "' && printf 1 || printf 0")
    r == "1"
}

// ── dir_exists_pure ───────────────────────────────────────────────
// Returns true if path exists as a directory.
pub fn dir_exists_pure(path) {
    let r = exec("test -d '" + path + "' && printf 1 || printf 0")
    r == "1"
}

// ── file_size_pure ────────────────────────────────────────────────
// Returns file size in bytes as an integer. Returns -1 on error.
// Uses wc -c which works on both macOS and Linux (stat flags differ).
pub fn file_size_pure(path) {
    let raw = exec("wc -c < '" + path + "' 2>/dev/null | tr -d ' \\n'")
    if len(raw) == 0 { return -1 }
    to_int(raw)
}

// ── mkdir_p_pure ──────────────────────────────────────────────────
// Creates directory and parents. Thin wrapper over exec.
pub fn mkdir_p_pure(path) {
    exec("mkdir -p '" + path + "'")
}

// ── list_dir_pure ─────────────────────────────────────────────────
// Lists entries in a directory, returns array of filenames.
// Returns empty array if directory doesn't exist.
pub fn list_dir_pure(path) {
    let raw = exec("ls -1 '" + path + "' 2>/dev/null")
    if len(raw) == 0 { return [] }
    // Split by newline, filter empties
    let entries = raw.split("\n")
    let mut result = []
    let mut i = 0
    while i < len(entries) {
        if len(entries[i]) > 0 {
            result = result.push(entries[i])
        }
        i = i + 1
    }
    result
}

// ── write_bytes_pure ──────────────────────────────────────────────
// Mirrors hexa_write_bytes (runtime.c:2617). Writes an array of byte
// ints to a file. NUL-safe; exec shell redirects can't carry NULs so
// we delegate to the write_bytes builtin which fwrites directly.
pub fn write_bytes_pure(path, arr) {
    if type_of(arr) != "array" { return false }
    write_bytes(path, arr)
    true
}

// ── read_file_bytes_pure ──────────────────────────────────────────
// Mirrors hexa_read_file_bytes (runtime.c:2638). Returns an array of
// byte ints ([] on missing or empty file). Delegates to the
// read_file_bytes builtin because shell cat truncates at NUL bytes.
pub fn read_file_bytes_pure(path) {
    read_file_bytes(path)
}
