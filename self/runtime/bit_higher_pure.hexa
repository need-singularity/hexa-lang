// ═══════════════════════════════════════════════════════════════════
//  self/runtime/bit_higher_pure.hexa — higher-level bit operations
//
//  Complements bit_pure.hexa (primitives) and bitops_pure.hexa
//  (arith/overflow) with classic "bit tricks" frequently needed in
//  codegen, perfect hashing, Z-order curves, and Gray-coded DACs.
//
//  Public API:
//      popcount32_pure(n)          — Kernighan's, masks to low 32 bits
//      gray_encode_pure(n)         — binary → reflected Gray code
//      gray_decode_pure(g)         — Gray → binary (iterative XOR)
//      swap_adjacent_bits_pure(n)  — swap every pair of adjacent bits
//      interleave_bits16_pure(a,b) — Morton / Z-order encode two u16
//
//  PARSER NOTE
//  -----------
//  Same constraint as bit_pure.hexa — no `<<`, `>>`, or `|` on the
//  stage0 surface. We reuse `* _pow2(k)` / `/ _pow2(k)` for shifts and
//  compose disjoint-bit unions via `+` (no-carry when bits don't
//  overlap). Masking is always explicit to avoid sign-extension bleed.
// ═══════════════════════════════════════════════════════════════════

@pure
fn _pow2(n) {
    let mut r = 1
    let mut i = 0
    while i < n {
        r = r * 2
        i = i + 1
    }
    return r
}

// ── popcount32_pure — Brian Kernighan's iterative bit clear ─────────
// Counts set bits in the low 32 bits of n. Each loop iteration clears
// the lowest set bit via  x & (x - 1) — so cost = O(popcount(n)),
// which beats the naive shift-and-test on sparsely populated words.
@pure
pub fn popcount32_pure(n) {
    let mask32 = 0xFFFFFFFF
    let mut x = n & mask32
    let mut c = 0
    while x != 0 {
        x = x & (x - 1)
        c = c + 1
    }
    return c
}

// ── gray_encode_pure — binary → reflected Gray code ─────────────────
// g = n XOR (n >> 1). Consecutive integers' Gray codes differ in
// exactly one bit — used by rotary encoders, K-maps, analog-to-digital
// quantisers, and Karnaugh-style minimisation.
@pure
pub fn gray_encode_pure(n) {
    let mask = 0xFFFFFFFFFFFFFFFF
    let nn = n & mask
    return nn ^ (nn / 2)
}

// ── gray_decode_pure — Gray code → binary ───────────────────────────
// Inverse of gray_encode. Bit i of binary = XOR of Gray bits ≥ i.
// Iterative formulation: start from the top, fold each bit down.
// Works for 64-bit values; inner shifts emulated via division.
@pure
pub fn gray_decode_pure(g) {
    let mask = 0xFFFFFFFFFFFFFFFF
    let mut n = g & mask
    let mut shift = 1
    while shift < 64 {
        n = n ^ (n / _pow2(shift))
        shift = shift * 2
    }
    return n & mask
}

// ── swap_adjacent_bits_pure — swap every pair of adjacent bits ──────
// ((n & 0xAA..) >> 1) | ((n & 0x55..) << 1) — classical SWAR trick
// used inside bit-reversal networks and SIMD lane permutations.
// Works on the low 32 bits; higher bits are preserved unchanged.
@pure
pub fn swap_adjacent_bits_pure(n) {
    let mask32 = 0xFFFFFFFF
    let odd_mask  = 0xAAAAAAAA          // ...1010 1010
    let even_mask = 0x55555555          // ...0101 0101
    let x = n & mask32
    let odd  = (x & odd_mask) / 2        // odd bits shifted down
    let even = (x & even_mask) * 2       // even bits shifted up
    // odd and even now occupy disjoint bit positions, so `+` == `|`.
    let swapped = (odd + even) & mask32
    // Preserve any bits above position 31 from the original input.
    let hi = n - x
    return hi + swapped
}

// ── interleave_bits16_pure — Morton (Z-order) encode two 16-bit ─────
// Takes two 16-bit inputs a, b and produces a 32-bit interleaved
// value: bit 2i = a_i, bit 2i+1 = b_i. Fundamental for Z-order
// curves, quadtree indexing, and cache-friendly 2-D layouts.
// Simple per-bit loop — clear, auditable, O(16).
@pure
pub fn interleave_bits16_pure(a, b) {
    let mask16 = 0xFFFF
    let aa = a & mask16
    let bb = b & mask16
    let mut r = 0
    let mut i = 0
    while i < 16 {
        let bit_i   = _pow2(i)
        let slot_a  = _pow2(i * 2)
        let slot_b  = _pow2(i * 2 + 1)
        if (aa & bit_i) != 0 {
            r = r + slot_a
        }
        if (bb & bit_i) != 0 {
            r = r + slot_b
        }
        i = i + 1
    }
    return r
}
