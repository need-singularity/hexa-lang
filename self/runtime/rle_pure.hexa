// self/runtime/rle_pure.hexa — Run-length encoding encode/decode
//
// Pure-Hexa RLE compression: repeated value/byte compression.
// ROI #117: Run-length encoding encode/decode — repeated byte compression.
//
// API:
//   rle_encode(data)   -> [[value, count], ...]   nested pairs
//   rle_decode(runs)   -> [int]                   flat array
//   rle_encode_str(s)  -> str   "aaabbc" -> "a3b2c1"
//   rle_decode_str(s)  -> str   "a3b2c1" -> "aaabbc"
//
// Constraints honored (CLAUDE.md):
//   - No C dependencies, no FFI
//   - P1 no semicolons, P15 let mut everywhere
//   - .push() not arr + [x] in loops
//   - parts.join("") for string building

// ── rle_encode ──────────────────────────────────────────────────
// Encodes an array of ints into [[value, count], ...] nested pairs.
// Consecutive equal elements are collapsed.
@pure pub fn rle_encode(data) {
    let n = len(data)
    if n == 0 { return [] }
    let mut out = []
    let mut i = 0
    while i < n {
        let cur = data[i]
        let mut count = 1
        while i + count < n && data[i + count] == cur {
            count = count + 1
        }
        out = out.push([cur, count])
        i = i + count
    }
    out
}

// ── rle_decode ──────────────────────────────────────────────────
// Decodes [[value, count], ...] back to the original flat array.
@pure pub fn rle_decode(runs) {
    let n = len(runs)
    if n == 0 { return [] }
    let mut out = []
    let mut i = 0
    while i < n {
        let pair = runs[i]
        let val = pair[0]
        let count = pair[1]
        let mut j = 0
        while j < count {
            out = out.push(val)
            j = j + 1
        }
        i = i + 1
    }
    out
}

// ── _digit_char helper ──────────────────────────────────────────
// Returns the digit character for 0..9. Uses substring on a lookup.
fn _digit_char(d) {
    let digits = "0123456789"
    digits.substring(d, d + 1)
}

// ── _int_to_str helper ──────────────────────────────────────────
// Converts a non-negative integer to its string representation.
fn _int_to_str(n) {
    if n == 0 { return "0" }
    let mut v = n
    let mut parts = []
    while v > 0 {
        parts = parts.push(_digit_char(v % 10))
        v = v / 10
    }
    // reverse
    let mut rev = []
    let mut i = len(parts) - 1
    while i >= 0 {
        rev = rev.push(parts[i])
        i = i - 1
    }
    rev.join("")
}

// ── _is_digit helper ────────────────────────────────────────────
fn _is_digit_ch(ch) {
    let digits = "0123456789"
    let mut k = 0
    while k < 10 {
        if digits.substring(k, k + 1) == ch { return true }
        k = k + 1
    }
    false
}

// ── _digit_val helper ───────────────────────────────────────────
fn _digit_val(ch) {
    let digits = "0123456789"
    let mut k = 0
    while k < 10 {
        if digits.substring(k, k + 1) == ch { return k }
        k = k + 1
    }
    0
}

// ── rle_encode_str ──────────────────────────────────────────────
// String RLE: "aaabbc" -> "a3b2c1"
@pure pub fn rle_encode_str(s) {
    if type_of(s) != "string" { return "" }
    let n = len(s)
    if n == 0 { return "" }
    let mut parts = []
    let mut i = 0
    while i < n {
        let cur = s.substring(i, i + 1)
        let mut count = 1
        while i + count < n && s.substring(i + count, i + count + 1) == cur {
            count = count + 1
        }
        parts = parts.push(cur)
        parts = parts.push(_int_to_str(count))
        i = i + count
    }
    parts.join("")
}

// ── rle_decode_str ──────────────────────────────────────────────
// Reverse string RLE: "a3b2c1" -> "aaabbc"
// Parses: one non-digit char, then one or more digit chars for count.
@pure pub fn rle_decode_str(s) {
    if type_of(s) != "string" { return "" }
    let n = len(s)
    if n == 0 { return "" }
    let mut parts = []
    let mut i = 0
    while i < n {
        let ch = s.substring(i, i + 1)
        i = i + 1
        // parse digits for count
        let mut count = 0
        while i < n && _is_digit_ch(s.substring(i, i + 1)) {
            count = count * 10 + _digit_val(s.substring(i, i + 1))
            i = i + 1
        }
        if count == 0 { count = 1 }
        let mut j = 0
        while j < count {
            parts = parts.push(ch)
            j = j + 1
        }
    }
    parts.join("")
}
