// ═══════════════════════════════════════════════════════════════════
//  self/runtime/union_find_pure.hexa — disjoint-set (union-find)
//
//  Pure Hexa implementation. No C, no FFI.
//  Uses dict with "parent" and "rank" arrays.
//  Union by rank + path compression for near-O(alpha(n)) amortized.
//
//  Pitfalls honored: P1 no semicolons, P15 let mut, P29 push rebind,
//  while loops only
//
//  Public API:
//      uf_new_pure(n)                — create UF for n elements {0..n-1}
//      uf_find_pure(uf, x)           — find root with path compression
//      uf_union_pure(uf, x, y)       — union by rank, returns true if merged
//      uf_connected_pure(uf, x, y)   — are x and y in the same set?
//      uf_count_pure(uf)             — number of distinct sets
// ═══════════════════════════════════════════════════════════════════

// ── uf_new_pure — create union-find for n elements ──────────────
// Returns dict with keys "parent", "rank", "n"
// Each element is its own parent, rank 0.
@pure
pub fn uf_new_pure(n) {
    let mut parent = []
    let mut rank = []
    let mut i = 0
    while i < n {
        parent = parent.push(i)
        rank = rank.push(0)
        i = i + 1
    }
    let mut uf = #{}
    uf["parent"] = parent
    uf["rank"] = rank
    uf["n"] = n
    return uf
}

// ── uf_find_pure — find root with path compression ─────────────
// Iterative path compression: walk to root, then flatten.
@pure
pub fn uf_find_pure(uf, x) {
    let parent = uf["parent"]
    // Walk to root
    let mut r = x
    while parent[r] != r {
        r = parent[r]
    }
    // Path compression: set all nodes on path to point to root
    let mut c = x
    while c != r {
        let next = parent[c]
        parent[c] = r
        c = next
    }
    return r
}

// ── uf_union_pure — union by rank, returns true if merged ───────
@pure
pub fn uf_union_pure(uf, x, y) {
    let rx = uf_find_pure(uf, x)
    let ry = uf_find_pure(uf, y)
    if rx == ry {
        return false
    }
    let parent = uf["parent"]
    let rank = uf["rank"]
    if rank[rx] < rank[ry] {
        parent[rx] = ry
    } else {
        if rank[rx] > rank[ry] {
            parent[ry] = rx
        } else {
            parent[ry] = rx
            rank[rx] = rank[rx] + 1
        }
    }
    return true
}

// ── uf_connected_pure — are x and y in the same set? ────────────
@pure
pub fn uf_connected_pure(uf, x, y) {
    return uf_find_pure(uf, x) == uf_find_pure(uf, y)
}

// ── uf_count_pure — number of distinct sets ─────────────────────
@pure
pub fn uf_count_pure(uf) {
    let parent = uf["parent"]
    let n = uf["n"]
    let mut count = 0
    let mut i = 0
    while i < n {
        if uf_find_pure(uf, i) == i {
            count = count + 1
        }
        i = i + 1
    }
    return count
}
