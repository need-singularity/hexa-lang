// self/runtime/crc32_pure.hexa -- Phase 2.9 runtime port (CRC-32)
//
// Pure-Hexa CRC-32 (IEEE 802.3 / PKZIP / gzip / PNG) checksum. The
// self/runtime.c side does not ship a CRC-32 yet; this module adds
// one so that any future binary-format consumer (PNG chunks, zlib
// framing, cache-key verification) can call a known-good reference
// without going through a C shim.
//
// Implementation:
//   - Polynomial: 0xEDB88320 (reflected form of 0x04C11DB7)
//   - Init value: 0xFFFFFFFF
//   - Final XOR : 0xFFFFFFFF
//   - Input/output reflected (standard "CRC-32" variant)
//
// 32-bit unsigned arithmetic is emulated with `& 0xFFFFFFFF` because
// HEXA ints are 64-bit signed.
//
// Pitfalls honored:
//   P15 let mut for reassigned locals
//   P29 .push() returns new array — unused here
//   P30 no unsigned type — mask at every step
//   G40/G41 stage0 interpreter rejects `<<` / `>>` (parse error) — use
//        integer divide by 2 / multiply by 2 instead. The compiled
//        hexa_v2 path supports the operators, but the interpreter
//        (`./hexa run`) does not, and the test runner uses run.

let CRC32_POLY     = 3988292384      // 0xEDB88320 reflected polynomial
let CRC32_INIT     = 4294967295      // 0xFFFFFFFF
let CRC32_MOD      = 4294967296      // 2^32
let CRC32_XOR_OUT  = 4294967295      // 0xFFFFFFFF

// ── _crc32_update_byte (internal) — roll in one byte ──────────────
// Standard reflected inner loop (no precomputed table, 8 iterations
// per byte is fine for a pure-hexa reference impl).
fn _crc32_update_byte(crc, byte) {
    let mut c = crc ^ byte
    let mut k = 0
    while k < 8 {
        let lsb = c & 1
        if lsb != 0 {
            c = (c / 2) ^ CRC32_POLY
        } else {
            c = c / 2
        }
        k = k + 1
    }
    c
}

// ── crc32_pure — byte-buffer CRC-32 ───────────────────────────────
// Hashes `n` bytes of `s`. n is clipped to len(s).
pub fn crc32_pure(s, n) {
    if type_of(s) != "string" { return 0 }
    let mut crc = CRC32_INIT
    let mut i = 0
    let lim = if n < len(s) { n } else { len(s) }
    while i < lim {
        let b = ord(s.substring(i, i + 1))
        crc = _crc32_update_byte(crc, b)
        i = i + 1
    }
    (crc ^ CRC32_XOR_OUT) & (CRC32_MOD - 1)
}

// ── crc32_str_pure — string CRC-32 ────────────────────────────────
// Entire string.
pub fn crc32_str_pure(s) {
    crc32_pure(s, len(s))
}

// ── crc32_combine_pure — concatenated-data helper ─────────────────
// crc32_combine_pure(crc32_str_pure(a), b) == crc32_str_pure(a + b)
// Useful when you have streaming chunks and don't want to hold the
// full buffer. Takes the *output* CRC of the previous chunk and the
// next chunk's bytes.
pub fn crc32_combine_pure(prev_crc, next) {
    if type_of(next) != "string" { return prev_crc }
    // Invert the final XOR to get the internal state back.
    let mut crc = (prev_crc ^ CRC32_XOR_OUT) & (CRC32_MOD - 1)
    let mut i = 0
    let n = len(next)
    while i < n {
        let b = ord(next.substring(i, i + 1))
        crc = _crc32_update_byte(crc, b)
        i = i + 1
    }
    (crc ^ CRC32_XOR_OUT) & (CRC32_MOD - 1)
}
