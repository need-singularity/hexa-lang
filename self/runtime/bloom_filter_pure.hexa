// ═══════════════════════════════════════════════════════════════════
//  self/runtime/bloom_filter_pure.hexa — pure-Hexa probabilistic bloom filter
//
//  Self-contained dict-based bloom filter using FNV-1a-style hashing
//  with modular arithmetic (no bitwise XOR needed) and double-hashing
//  for k independent hash functions.
//
//  Public API:
//      bloom_new(size, num_hashes)     — create bloom filter
//      bloom_add(bf, item)            — add string item to filter
//      bloom_contains(bf, item)       — probabilistic membership test
//      bloom_hash(item, seed, size)   — FNV-1a-style hash via modular arith
//      bloom_count(bf)                — number of set bits
//      bloom_clear(bf)                — reset all bits to 0
//      bloom_merge(bf1, bf2)          — union of two same-size filters
//      bloom_false_positive_rate(bf)  — estimated FP rate based on fill
//
//  Properties:
//      - No false negatives (if added, contains always returns true)
//      - False positives possible (probability depends on size and k)
//      - Pure Hexa, no C/FFI, no external imports
//
//  HX3 pitfalls handled:
//      P1   no semicolons
//      P15  let mut for mutable variables
//      P29  .push() returns new array — must reassign
//      P28  nil/true/false literals
// ═══════════════════════════════════════════════════════════════════

// ── bloom_hash ──────────────────────────────────────────────────
// FNV-1a-style hash using modular arithmetic.
// hash = (hash * 16777619 + char_code) % size
// The seed offsets the initial hash value for independent hashes.
@pure
pub fn bloom_hash(item, seed, size) {
    if size <= 0 { return 0 }
    let n = len(item)
    // FNV offset basis + seed perturbation, kept positive
    let mut hash_val = 2166136261 + seed * 16777619
    if hash_val < 0 { hash_val = 0 - hash_val }
    hash_val = hash_val % (size * 1000000)
    let mut i = 0
    while i < n {
        let ch = item.substring(i, i + 1)
        let code = ord(ch)
        hash_val = (hash_val * 16777619 + code) % (size * 1000000)
        if hash_val < 0 { hash_val = 0 - hash_val }
        i = i + 1
    }
    return hash_val % size
}

// ── _bloom_positions ────────────────────────────────────────────
// Compute k bit positions for item using double-hashing:
// h(i) = (h1 + i * h2) % size
@pure
fn _bloom_positions(bf, item) {
    let size = bf["size"]
    let k = bf["k"]
    let h1 = bloom_hash(item, 0, size)
    let h2 = bloom_hash(item, 1, size)
    // Ensure h2 is at least 1 so positions vary across k
    let mut h2_safe = h2
    if h2_safe == 0 { h2_safe = 1 }
    let mut positions = []
    let mut j = 0
    while j < k {
        let pos = (h1 + j * h2_safe) % size
        positions = positions.push(pos)
        j = j + 1
    }
    return positions
}

// ── bloom_new ───────────────────────────────────────────────────
// Create a bloom filter with a bit array of given size and k hash
// functions. Returns #{"bits": [...], "size": size, "k": num_hashes}.
@pure
pub fn bloom_new(size, num_hashes) {
    let mut bits = []
    let mut i = 0
    while i < size {
        bits = bits.push(0)
        i = i + 1
    }
    return #{"bits": bits, "size": size, "k": num_hashes}
}

// ── bloom_add ───────────────────────────────────────────────────
// Add item to filter. Sets k bit positions to 1.
// Returns updated bloom filter dict.
pub fn bloom_add(bf, item) {
    let positions = _bloom_positions(bf, item)
    let k = len(positions)
    let mut bits = bf["bits"]
    let mut j = 0
    while j < k {
        let pos = positions[j]
        bits[pos] = 1
        j = j + 1
    }
    return #{"bits": bits, "size": bf["size"], "k": bf["k"]}
}

// ── bloom_contains ──────────────────────────────────────────────
// Probabilistic membership test.
// Returns true if all k bit positions are set (may be false positive).
// Returns false if any bit is 0 (guaranteed true negative).
@pure
pub fn bloom_contains(bf, item) {
    let positions = _bloom_positions(bf, item)
    let k = len(positions)
    let bits = bf["bits"]
    let mut j = 0
    while j < k {
        let pos = positions[j]
        if bits[pos] != 1 { return false }
        j = j + 1
    }
    return true
}

// ── bloom_count ─────────────────────────────────────────────────
// Count number of set bits in the filter.
@pure
pub fn bloom_count(bf) {
    let bits = bf["bits"]
    let n = len(bits)
    let mut count = 0
    let mut i = 0
    while i < n {
        if bits[i] == 1 { count = count + 1 }
        i = i + 1
    }
    return count
}

// ── bloom_clear ─────────────────────────────────────────────────
// Reset all bits to 0, preserving size and k.
@pure
pub fn bloom_clear(bf) {
    return bloom_new(bf["size"], bf["k"])
}

// ── bloom_merge ─────────────────────────────────────────────────
// Union of two bloom filters with the same size and k.
// Result contains all items from both filters.
pub fn bloom_merge(bf1, bf2) {
    let size = bf1["size"]
    let bits1 = bf1["bits"]
    let bits2 = bf2["bits"]
    let mut bits = []
    let mut i = 0
    while i < size {
        if bits1[i] == 1 || bits2[i] == 1 {
            bits = bits.push(1)
        } else {
            bits = bits.push(0)
        }
        i = i + 1
    }
    return #{"bits": bits, "size": size, "k": bf1["k"]}
}

// ── bloom_false_positive_rate ───────────────────────────────────
// Estimated false positive rate based on current fill ratio.
// Approximation: (set_bits / total_bits) ^ k
@pure
pub fn bloom_false_positive_rate(bf) {
    let size = bf["size"]
    let k = bf["k"]
    if size == 0 { return 1.0 }
    let set_count = bloom_count(bf)
    let ratio = (set_count * 1.0) / (size * 1.0)
    // ratio^k
    let mut result = 1.0
    let mut i = 0
    while i < k {
        result = result * ratio
        i = i + 1
    }
    return result
}
