// ═══════════════════════════════════════════════════════════════════
//  self/runtime/hash_rng_pure.hexa — pure-Hexa hash-combine + RNG
//
//  5 net-new pure functions complementing hash_pure / bitops_pure:
//    hash_combine_pure(a, b)           -> int  (32-bit boost-style mix)
//    hash_int_pure(n)                  -> int  (32-bit integer scramble)
//    rng_xorshift32_pure(state)        -> [new_state, value]
//    rng_range_pure(state, lo, hi)     -> [new_state, value in [lo, hi]]
//    shuffle_pure(arr, state)          -> [shuffled, new_state]  Fisher-Yates
//
//  Constraints (P50):
//    * No `<<` / `>>` operators in expressions — emulated with
//      `* _pow2(n)` / `/ _pow2(n)` patterns, same style as
//      bit_reverse32_pure and bitops_pure's helpers.
//    * Overflow-safe 32-bit via & 0xFFFFFFFF at each step.
//
//  Pitfalls:
//    P15 let mut for reassigned locals
//    P29 .push() returns new array (slice return convention)
//    P30 no unsigned int type — mask via & 0xFFFFFFFF
// ═══════════════════════════════════════════════════════════════════

let _MASK32 = 0xFFFFFFFF

// ── _pow2(n) — returns 2^n for n in [0, 62] ──────────────────────────
// Inlined helper (stage0 does not reliably re-export transitive imports).
@pure
fn _pow2(n) {
    let mut r = 1
    let mut i = 0
    while i < n {
        r = r * 2
        i = i + 1
    }
    return r
}

// ── _shl32 / _shr32 — 32-bit shift emulation (no `<<` / `>>`) ────────
@pure
fn _shl32(a, n) {
    if n <= 0 { return a & _MASK32 }
    return (a * _pow2(n)) & _MASK32
}

@pure
fn _shr32(a, n) {
    if n <= 0 { return a & _MASK32 }
    let m = a & _MASK32
    return m / _pow2(n)
}

// ── _rotl32 — 32-bit left rotate via shl/shr ────────────────────────
@pure
fn _rotl32(x, r) {
    let v = x & _MASK32
    let shift = r % 32
    if shift == 0 { return v }
    let lo = _shl32(v, shift)
    let hi = _shr32(v, 32 - shift)
    return (lo | hi) & _MASK32
}

// ═══════════════════════════════════════════════════════════════════
//  hash_combine_pure — merge two hashes (boost-style)
// ═══════════════════════════════════════════════════════════════════
// Reference: boost::hash_combine seed ^= v + 0x9E3779B9 + (seed<<6) + (seed>>2)
// 32-bit variant for stable cross-architecture output.
// The 0x9E3779B9 magic is the golden-ratio fractional constant.
//
// Property: non-commutative — hash_combine(a, b) != hash_combine(b, a)
// for generic a, b (useful for ordered tuple hashing).
@pure
pub fn hash_combine_pure(a, b) {
    let a32 = a & _MASK32
    let b32 = b & _MASK32
    let golden = 0x9E3779B9
    // seed<<6 and seed>>2 using shl/shr helpers
    let seed_shl6 = _shl32(a32, 6)
    let seed_shr2 = _shr32(a32, 2)
    let mixed = (b32 + golden + seed_shl6 + seed_shr2) & _MASK32
    return (a32 ^ mixed) & _MASK32
}

// ═══════════════════════════════════════════════════════════════════
//  hash_int_pure — integer scramble (xorshift-style avalanche)
// ═══════════════════════════════════════════════════════════════════
// Produces a well-distributed 32-bit hash from any integer input.
// Same finalization sequence as MurmurHash3's fmix32 (multiplier +
// xor-shift) — avalanches every input bit.
//
// Property: hash_int_pure(0) is a fixed point only for the null input.
// Adjacent ints produce very different hashes (no linear correlation).
@pure
pub fn hash_int_pure(n) {
    let mut h = n & _MASK32
    // h ^= h >> 16
    h = (h ^ _shr32(h, 16)) & _MASK32
    // h *= 0x85EBCA6B
    h = (h * 0x85EBCA6B) & _MASK32
    // h ^= h >> 13
    h = (h ^ _shr32(h, 13)) & _MASK32
    // h *= 0xC2B2AE35
    h = (h * 0xC2B2AE35) & _MASK32
    // h ^= h >> 16
    h = (h ^ _shr32(h, 16)) & _MASK32
    return h
}

// ═══════════════════════════════════════════════════════════════════
//  rng_xorshift32_pure — 32-bit xorshift one-step
// ═══════════════════════════════════════════════════════════════════
// Marsaglia's classic xorshift32 (triple 13/17/5). State 0 is a
// fixed-point attractor — callers must seed with a non-zero state.
//
// Returns [new_state, value]. The value equals the new state (xorshift
// convention — the state IS the output).
//
// Property: period 2^32 - 1 (excluding state 0).
@pure
pub fn rng_xorshift32_pure(state) {
    let mut x = state & _MASK32
    if x == 0 {
        // Avoid fixed point — promote to a stable non-zero seed.
        x = 0x1 & _MASK32
    }
    // x ^= x << 13
    x = (x ^ _shl32(x, 13)) & _MASK32
    // x ^= x >> 17
    x = (x ^ _shr32(x, 17)) & _MASK32
    // x ^= x << 5
    x = (x ^ _shl32(x, 5)) & _MASK32
    return [x, x]
}

// ═══════════════════════════════════════════════════════════════════
//  rng_range_pure — uniform int in [lo, hi] via xorshift32
// ═══════════════════════════════════════════════════════════════════
// Returns [new_state, value] where value in [lo, hi] inclusive.
// Uses modulo mapping — slight bias for spans that don't divide 2^32
// evenly, but acceptable for hash-table / shuffle use cases.
//
// Edge cases:
//   * hi < lo  -> returns [new_state, lo] (clamp to lo)
//   * hi == lo -> returns [new_state, lo] (single-value range)
@pure
pub fn rng_range_pure(state, lo, hi) {
    let step = rng_xorshift32_pure(state)
    let new_state = step[0]
    let raw = step[1]
    if hi <= lo { return [new_state, lo] }
    let span = hi - lo + 1
    let v = lo + (raw % span)
    return [new_state, v]
}

// ── _swap_at — return new array with arr[i] and arr[j] swapped ──────
// Pure helper — stage0 arrays don't expose safe in-place index-set.
@pure
fn _swap_at(arr, i, j) {
    let n = len(arr)
    let mut out = []
    let mut k = 0
    while k < n {
        if k == i {
            out.push(arr[j])
        } else {
            if k == j {
                out.push(arr[i])
            } else {
                out.push(arr[k])
            }
        }
        k = k + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════════
//  shuffle_pure — Fisher-Yates shuffle using rng_xorshift32
// ═══════════════════════════════════════════════════════════════════
// Returns [shuffled_array, new_state]. Deterministic given seed.
// O(n^2) due to pure swap-by-copy (stage0 arrays are immutable from
// callee scope). For n < 1000 this is acceptable; larger shuffles
// should use a map-backed variant.
//
// Safety: works on arrays of any element type. Non-mutating — the
// returned array is a fresh sequence.
@pure
pub fn shuffle_pure(arr, state) {
    let n = len(arr)
    if n <= 1 { return [arr, state] }

    let mut out = arr
    let mut st = state
    let mut i = n - 1
    while i > 0 {
        let step = rng_range_pure(st, 0, i)
        st = step[0]
        let j = step[1]
        if j != i {
            out = _swap_at(out, i, j)
        }
        i = i - 1
    }
    return [out, st]
}
