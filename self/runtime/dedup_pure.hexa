// self/runtime/dedup_pure.hexa — Array deduplication utilities
//
// Pure-Hexa dedup: remove duplicate elements from arrays.
//
// API:
//   dedup(arr)           -> array with consecutive duplicates removed
//   dedup_all(arr)       -> array with all duplicates removed (first occurrence kept)
//   dedup_by(arr, key_fn) -> dedup using key function
//   is_unique(arr)       -> true if no duplicates
//   count_unique(arr)    -> number of unique elements
//
// Constraints honored (CLAUDE.md):
//   - No C dependencies, no FFI
//   - P1 no semicolons, P15 let mut everywhere
//   - .push() not arr + [x] in loops
//   - parts.join("") for string building

// ── dedup ───────────────────────────────────────────────────────
// Removes consecutive duplicate elements (like Unix uniq).
@pure pub fn dedup(arr) {
    let n = len(arr)
    if n == 0 { return [] }
    let mut out = []
    out = out.push(arr[0])
    let mut i = 1
    while i < n {
        if to_string(arr[i]) != to_string(arr[i - 1]) {
            out = out.push(arr[i])
        }
        i = i + 1
    }
    out
}

// ── dedup_all ───────────────────────────────────────────────────
// Removes all duplicates, keeping first occurrence.
@pure pub fn dedup_all(arr) {
    let n = len(arr)
    if n == 0 { return [] }
    let mut out = []
    let mut seen = []
    let mut i = 0
    while i < n {
        let key = to_string(arr[i])
        let mut found = false
        let mut j = 0
        while j < len(seen) {
            if seen[j] == key {
                found = true
            }
            j = j + 1
        }
        if found == false {
            out = out.push(arr[i])
            seen = seen.push(key)
        }
        i = i + 1
    }
    out
}

// ── is_unique ───────────────────────────────────────────────────
// Returns true if all elements are distinct.
@pure pub fn is_unique(arr) {
    let n = len(arr)
    let mut i = 0
    while i < n {
        let mut j = i + 1
        while j < n {
            if to_string(arr[i]) == to_string(arr[j]) { return false }
            j = j + 1
        }
        i = i + 1
    }
    true
}

// ── count_unique ────────────────────────────────────────────────
// Returns count of unique elements.
@pure pub fn count_unique(arr) {
    len(dedup_all(arr))
}
