// ═══════════════════════════════════════════════════════════════════
//  self/runtime/sort_variants_pure.hexa — extra pure-Hexa sort variants
//
//  Ported as net-new pure-Hexa semantics. runtime.c exposes only one
//  sort path (hexa_sort_cmp qsort over HexaVal — self/runtime.c:2454)
//  and array_higher_pure.hexa already carries the ascending insertion
//  sort (array_sort_pure) + user-comparator (array_sort_by_pure). This
//  module adds five orthogonal variants that callers frequently reach
//  for when the default ascending sort is the wrong shape.
//
//  Public API:
//      merge_sort_pure(arr)     -> array (O(n log n), stable)
//      heap_sort_pure(arr)      -> array (O(n log n), NOT stable)
//      sort_desc_pure(arr)      -> array (descending, stable by flip)
//      topk_pure(arr, k)        -> array (k smallest ints, partial sort)
//      median_pure(arr)         -> int  | nil (middle element, lower-mid)
//
//  SEMANTIC DIVERGENCE from runtime.c counterparts
//  ───────────────────────────────────────────────
//  * merge_sort_pure uses functional rebuild (push + concat via push)
//    rather than in-place index assignment — the interpreter forbids
//    complex index assignment on persistent arrays (grammar pitfall).
//  * heap_sort_pure computes parent = (i-1)/2, left = 2*i+1, right
//    = 2*i+2 explicitly. No `<<`/`>>` — P50 critical, and the interp
//    interpreter shift semantics are already covered by bit_pure.
//  * topk_pure stops after k insertions when n >= k; for n < k it
//    returns the full sorted array. Result is ascending.
//  * median_pure returns the lower middle (index n/2 - 1 for even n)
//    to stay integer-typed — callers wanting the average can pair
//    with the upper middle manually.
//  * sort_desc_pure is NOT simply `reverse(sort_asc)` — equal keys
//    keep original relative order (stable descent), achieved by
//    running insertion sort with a descending comparator.
// ═══════════════════════════════════════════════════════════════════

// ── internal ascending comparator (shared) ───────────────────────────
@pure
fn _sv_asc(a, b) {
    if a < b { return -1 }
    if a > b { return 1 }
    return 0
}

@pure
fn _sv_desc(a, b) {
    if a < b { return 1 }
    if a > b { return -1 }
    return 0
}

// ── merge_sort_pure ─────────────────────────────────────────────────
//   Classical top-down merge sort. Stable: when keys equal, left half
//   element is emitted first. For single-element or empty input the
//   array is returned verbatim.
@pure
fn _sv_slice(arr, lo, hi) {
    let mut out = []
    let mut i = lo
    while i < hi {
        out.push(arr[i])
        i = i + 1
    }
    return out
}

@pure
fn _sv_merge(a, b) {
    let na = len(a)
    let nb = len(b)
    let mut out = []
    let mut i = 0
    let mut j = 0
    while i < na {
        if j >= nb {
            out.push(a[i])
            i = i + 1
        } else {
            if a[i] <= b[j] {
                out.push(a[i])
                i = i + 1
            } else {
                out.push(b[j])
                j = j + 1
            }
        }
    }
    while j < nb {
        out.push(b[j])
        j = j + 1
    }
    return out
}

@pure
pub fn merge_sort_pure(arr) {
    let n = len(arr)
    if n <= 1 { return arr }
    let mid = n / 2
    let left = merge_sort_pure(_sv_slice(arr, 0, mid))
    let right = merge_sort_pure(_sv_slice(arr, mid, n))
    return _sv_merge(left, right)
}

// ── heap_sort_pure ──────────────────────────────────────────────────
//   Max-heap sort producing ascending output. Not stable. Uses explicit
//   (i-1)/2, 2*i+1, 2*i+2 — no shifts.
@pure
fn _sv_set_at(arr, idx, val) {
    let n = len(arr)
    let mut out = []
    let mut i = 0
    while i < n {
        if i == idx { out.push(val) } else { out.push(arr[i]) }
        i = i + 1
    }
    return out
}

@pure
fn _sv_sift_down(arr, start_idx, heap_end) {
    let mut cur = arr
    let mut root = start_idx
    let mut done = false
    while !done {
        let left = 2 * root + 1
        if left >= heap_end {
            done = true
        } else {
            let right = left + 1
            let mut swap_idx = root
            if cur[swap_idx] < cur[left] { swap_idx = left }
            if right < heap_end {
                if cur[swap_idx] < cur[right] { swap_idx = right }
            }
            if swap_idx == root {
                done = true
            } else {
                let tmp = cur[root]
                cur = _sv_set_at(cur, root, cur[swap_idx])
                cur = _sv_set_at(cur, swap_idx, tmp)
                root = swap_idx
            }
        }
    }
    return cur
}

@pure
pub fn heap_sort_pure(arr) {
    let n = len(arr)
    if n <= 1 { return arr }
    let mut work = []
    let mut ci = 0
    while ci < n {
        work.push(arr[ci])
        ci = ci + 1
    }
    // heapify: start at (n-2)/2 and walk down to 0
    let mut start_idx = (n - 2) / 2
    while start_idx >= 0 {
        work = _sv_sift_down(work, start_idx, n)
        start_idx = start_idx - 1
    }
    // repeatedly swap root→end, shrink heap
    let mut end_idx = n - 1
    while end_idx > 0 {
        let tmp = work[0]
        work = _sv_set_at(work, 0, work[end_idx])
        work = _sv_set_at(work, end_idx, tmp)
        work = _sv_sift_down(work, 0, end_idx)
        end_idx = end_idx - 1
    }
    return work
}

// ── sort_desc_pure ──────────────────────────────────────────────────
//   Stable descending insertion sort. Equal keys preserve input order.
@pure
pub fn sort_desc_pure(arr) {
    let n = len(arr)
    let mut out = []
    let mut i = 0
    while i < n {
        out.push(arr[i])
        i = i + 1
    }
    let mut k = 1
    while k < n {
        let cur = out[k]
        let mut j = k - 1
        while j >= 0 {
            if _sv_desc(out[j], cur) <= 0 { j = -1 } else {
                let tmp = out[j]
                let mut next = []
                let mut t = 0
                while t < n {
                    if t == j + 1 { next.push(tmp) }
                    else if t == j { next.push(out[j + 1]) }
                    else { next.push(out[t]) }
                    t = t + 1
                }
                out = next
                j = j - 1
            }
        }
        k = k + 1
    }
    return out
}

// ── topk_pure ───────────────────────────────────────────────────────
//   Returns the k smallest elements of arr, in ascending order. If k
//   >= len(arr) the whole sorted array is returned. If k <= 0 an empty
//   array is returned.
@pure
pub fn topk_pure(arr, k) {
    let n = len(arr)
    if k <= 0 { return [] }
    let sorted = merge_sort_pure(arr)
    let lim = if k < n { k } else { n }
    let mut out = []
    let mut i = 0
    while i < lim {
        out.push(sorted[i])
        i = i + 1
    }
    return out
}

// ── median_pure ─────────────────────────────────────────────────────
//   Returns the lower-middle element of the sorted array (index n/2
//   for odd n, index n/2 - 1 for even n — i.e. floor((n-1)/2)). Nil
//   on empty input.
@pure
pub fn median_pure(arr) {
    let n = len(arr)
    if n == 0 { return nil }
    let sorted = merge_sort_pure(arr)
    let idx = (n - 1) / 2
    return sorted[idx]
}
