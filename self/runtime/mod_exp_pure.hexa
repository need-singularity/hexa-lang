// ═══════════════════════════════════════════════════════════════════
//  self/runtime/mod_exp_pure.hexa — pure-Hexa modular arithmetic
//
//  No C, no FFI, no 0b literals. Integer-only ops with overflow
//  awareness — Hexa float64 is safe up to 2^53.
//
//  Public API:
//      mod_mul_pure(a, b, m)            overflow-safe (a*b) mod m
//      mod_exp_pure(base, exp, m)       binary exponentiation O(log exp)
//      gcd_ext_pure(a, b)               extended GCD → [gcd, x, y]
//      mod_inv_pure(a, m)               modular inverse, -1 if none
//      gcd(a, b)                        Euclidean GCD
//      lcm(a, b)                        via GCD
//      is_prime_miller(n, k)            Miller-Rabin primality, k rounds
// ═══════════════════════════════════════════════════════════════════

// ── gcd — greatest common divisor (Euclidean) ────────────────────
@pure
pub fn gcd(a, b) {
    let mut x = if a < 0 { 0 - a } else { a }
    let mut y = if b < 0 { 0 - b } else { b }
    while y != 0 {
        let tmp = y
        y = x - (x / y) * y
        x = tmp
    }
    return x
}

// ── lcm — least common multiple via GCD ─────────────────────────
@pure
pub fn lcm(a, b) {
    if a == 0 { return 0 }
    if b == 0 { return 0 }
    let aa = if a < 0 { 0 - a } else { a }
    let bb = if b < 0 { 0 - b } else { b }
    return (aa / gcd(aa, bb)) * bb
}

// ── _mod_positive — ensure positive modular result ───────────────
@pure
fn _mod_positive(val, m) {
    let r = val - (val / m) * m
    if r < 0 { return r + m }
    return r
}

// ── mod_mul_pure — overflow-safe (a * b) mod m ───────────────────
// Splits via Russian-peasant double-and-add so intermediates
// never exceed ~2*m. Safe for m up to ~2^52.
@pure
pub fn mod_mul_pure(a, b, m) {
    if m <= 0 { return 0 }
    if m == 1 { return 0 }
    let mut aa = _mod_positive(a, m)
    let mut bb = _mod_positive(b, m)
    // Direct multiply is safe if both < 2^26 (~67 million)
    if aa < 67108864 {
        if bb < 67108864 {
            return _mod_positive(aa * bb, m)
        }
    }
    // Russian-peasant double-and-add
    let mut result = 0
    while bb > 0 {
        let half = bb / 2
        if half * 2 != bb {
            // bb is odd
            result = result + aa
            if result >= m { result = result - m }
        }
        aa = aa + aa
        if aa >= m { aa = aa - m }
        bb = half
    }
    return result
}

// ── mod_exp_pure — modular exponentiation via binary method ──────
// Computes (base^exp) mod m in O(log exp) multiplications.
// Uses mod_mul_pure for each step to stay overflow-safe.
@pure
pub fn mod_exp_pure(base, exp, m) {
    if m <= 0 { return 0 }
    if m == 1 { return 0 }
    let mut result = 1
    let mut b = _mod_positive(base, m)
    let mut e = exp
    if e < 0 { e = 0 }
    while e > 0 {
        let half = e / 2
        if half * 2 != e {
            result = mod_mul_pure(result, b, m)
        }
        e = half
        b = mod_mul_pure(b, b, m)
    }
    return result
}

// ── gcd_ext_pure — extended Euclidean algorithm ──────────────────
// Returns [gcd, x, y] such that a*x + b*y == gcd.
// Iterative to avoid recursion depth issues.
@pure
pub fn gcd_ext_pure(a, b) {
    let a_neg = a < 0
    let b_neg = b < 0
    let mut old_r = if a_neg { 0 - a } else { a }
    let mut r = if b_neg { 0 - b } else { b }
    let mut old_s = 1
    let mut s = 0
    let mut old_t = 0
    let mut t = 1

    while r != 0 {
        let q = old_r / r

        let tmp_r = r
        r = old_r - q * r
        old_r = tmp_r

        let tmp_s = s
        s = old_s - q * s
        old_s = tmp_s

        let tmp_t = t
        t = old_t - q * t
        old_t = tmp_t
    }

    // Adjust signs for negative original inputs
    let rx = if a_neg { 0 - old_s } else { old_s }
    let ry = if b_neg { 0 - old_t } else { old_t }
    return [old_r, rx, ry]
}

// ── mod_inv_pure — modular multiplicative inverse ────────────────
// Returns x in [0, m) such that (a * x) mod m == 1.
// Returns -1 if gcd(a, m) != 1 (inverse does not exist).
@pure
pub fn mod_inv_pure(a, m) {
    if m <= 0 { return -1 }
    if m == 1 { return 0 }
    let ext = gcd_ext_pure(a, m)
    let g = ext[0]
    if g != 1 { return -1 }
    let x = ext[1]
    return _mod_positive(x, m)
}

// ── Legacy aliases (keep backward compat) ────────────────────────

@pure
pub fn mod_exp(base, exp, m) { return mod_exp_pure(base, exp, m) }

@pure
pub fn mod_inv(a, m) { return mod_inv_pure(a, m) }

// ── is_prime_miller — Miller-Rabin probabilistic primality test ──
// Returns true if n is probably prime after k rounds.
// Deterministic for n < 3,215,031,751 with these 7 witnesses.
@pure
pub fn is_prime_miller(n, k) {
    if n < 2 { return false }
    if n == 2 { return true }
    if n == 3 { return true }
    let rem2 = n - (n / 2) * 2
    if rem2 == 0 { return false }

    // Write n - 1 as d * 2^r
    let mut d = n - 1
    let mut r = 0
    let mut d_rem = d - (d / 2) * 2
    while d_rem == 0 {
        d = d / 2
        r = r + 1
        d_rem = d - (d / 2) * 2
    }

    // Fixed witnesses for deterministic results up to large ranges
    let witnesses = [2, 3, 5, 7, 11, 13, 17]
    let num_witnesses = len(witnesses)
    let mut rounds = k
    if rounds > num_witnesses { rounds = num_witnesses }

    let mut wi = 0
    while wi < rounds {
        let mut a = witnesses[wi]
        if a >= n { a = 2 }
        if a >= n - 1 { a = n - 2 }
        if a < 2 { a = 2 }

        // Compute a^d mod n
        let mut x = mod_exp_pure(a, d, n)

        if x == 1 {
            wi = wi + 1
            continue
        }
        if x == n - 1 {
            wi = wi + 1
            continue
        }

        // Repeat r - 1 times: x = x^2 mod n
        let mut found = false
        let mut j = 0
        while j < r - 1 {
            x = mod_exp_pure(x, 2, n)
            if x == n - 1 {
                found = true
                j = r
            } else {
                j = j + 1
            }
        }

        if found == false { return false }
        wi = wi + 1
    }
    return true
}
