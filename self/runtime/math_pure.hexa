// self/runtime/math_pure.hexa — Phase 2.2 runtime port (math starter pack)
//
// Pure-Hexa equivalents of libm-free math helpers from self/runtime.c
// (see docs/runtime_port_plan.md §P2.2). Additive port — the C runtime
// functions still exist in runtime.c; this file provides pure-Hexa
// reference implementations for the `use "runtime/math_pure"` path and
// for the upcoming codegen interpose pass.
//
// Scope (this file): only libm-free primitives.
//   - abs_pure              ← hexa_abs          (runtime.c:2712)
//   - null_coal_pure        ← hexa_null_coal    (runtime.c:609)
//   - sign_pure             (int/float -1/0/1; no C twin, pure logic)
//   - min_pure / max_pure   (integer/float; libm-free — fmin/fmax C
//                           twin at runtime.c:4189/4190 only handles
//                           the float path; these cover both)
//   - clamp_pure            (composition of min/max)
//   - neg_pure              (pure negation with type dispatch)
//
// Out of scope (defer until libm-free sqrt/log strategy lands):
//   - hexa_math_abs         (runtime.c:4183 — fabs libm dep)
//   - hexa_math_sin/cos/tan (runtime.c:4174-4176 — libm dep)
//   - hexa_math_sqrt/log/exp(runtime.c:4181-4184 — libm dep)
//   - hexa_floor/ceil       (runtime.c:2704-2709 — libm dep)
//
// Constraints honored (CLAUDE.md HX1-HX7 + port plan §5 Risks):
//   - No libm calls. No syscalls.
//   - No NaN-boxing / tag layout touched.
//   - Pitfalls (grammar.jsonl): P1 no semicolons, P15 let mut, P28
//     nil/true/false literals compile correctly.
//   - Type dispatch via type_of(v) → "int"|"float"|"string"|"void".

// ── abs_pure ──────────────────────────────────────────────────────
// Mirrors hexa_abs (runtime.c:2712):
//   if (HX_IS_INT(v)) return hexa_int(HX_INT(v) < 0 ? -HX_INT(v) : HX_INT(v));
//   return hexa_float(fabs(HX_FLOAT(v)));
//
// Pure-Hexa: dispatch on type_of. For float we avoid fabs by branching
// on sign (libm-free). For non-numeric types we return the input
// unchanged so higher-level pipelines don't stumble on a type error
// (matches the liberal "pass-through on mismatch" discipline used by
// string_pure.hexa — e.g. str_to_upper_ascii).
pub fn abs_pure(v) {
    let t = type_of(v)
    if t == "int" {
        if v < 0 { return 0 - v }
        return v
    }
    if t == "float" {
        if v < 0.0 { return 0.0 - v }
        return v
    }
    v
}

// ── null_coal_pure ────────────────────────────────────────────────
// Mirrors hexa_null_coal (runtime.c:609):
//   if (HX_IS_VOID(a)) return b;
//   if (HX_IS_STR(a) && (HX_STR(a) == NULL || HX_STR(a)[0] == '\0')) return b;
//   return a;
//
// Pure-Hexa: type_of(nil) returns "void" (verified against stage0
// 2026-04-16). Empty-string fallthrough matches the C behavior for the
// `a ?? b` operator as used by codegen_c2.
pub fn null_coal_pure(a, b) {
    if type_of(a) == "void" { return b }
    if type_of(a) == "string" {
        if len(a) == 0 { return b }
    }
    a
}

// ── sign_pure ─────────────────────────────────────────────────────
// No direct runtime.c twin — there is no hexa_sign in C today. Added
// here because sign() is a common companion to abs() and is trivially
// pure. Returns -1/0/1 as int for int inputs, -1.0/0.0/1.0 for float.
// Non-numeric inputs return 0 (no useful sign).
pub fn sign_pure(v) {
    let t = type_of(v)
    if t == "int" {
        if v > 0 { return 1 }
        if v < 0 { return -1 }
        return 0
    }
    if t == "float" {
        if v > 0.0 { return 1.0 }
        if v < 0.0 { return -1.0 }
        return 0.0
    }
    0
}

// ── min_pure ──────────────────────────────────────────────────────
// Libm-free min. runtime.c has hexa_math_min (4189) using fmin — this
// pure version covers both int and float without libm. Returns the
// smaller of a, b. If types differ we fall back to "<" which stage0
// lowers to a numeric compare (int↔float coerces through the stage0
// numeric path). If either is non-numeric we return a.
pub fn min_pure(a, b) {
    let ta = type_of(a)
    let tb = type_of(b)
    if ta != "int" {
        if ta != "float" { return a }
    }
    if tb != "int" {
        if tb != "float" { return a }
    }
    if a < b { return a }
    b
}

// ── max_pure ──────────────────────────────────────────────────────
// Libm-free max. Mirrors structure of min_pure; runtime.c twin at
// hexa_math_max (4190) uses fmax (libm). Returns the larger of a, b.
pub fn max_pure(a, b) {
    let ta = type_of(a)
    let tb = type_of(b)
    if ta != "int" {
        if ta != "float" { return a }
    }
    if tb != "int" {
        if tb != "float" { return a }
    }
    if a > b { return a }
    b
}

// ── clamp_pure ────────────────────────────────────────────────────
// Clamps v into [lo, hi]. No direct runtime.c twin; included because
// it composes min/max and is libm-free. Invariant: if lo > hi, returns
// lo (matches the std::clamp "well-defined only when lo <= hi" contract
// by preferring lo as the canonical boundary).
pub fn clamp_pure(v, lo, hi) {
    if lo > hi { return lo }
    if v < lo { return lo }
    if v > hi { return hi }
    v
}

// ── neg_pure ──────────────────────────────────────────────────────
// Pure negation with int/float type dispatch. Useful as a building
// block for abs and for user code doing `neg(x)` in pipelines. Non-
// numeric inputs pass through unchanged (same liberal policy as
// abs_pure above).
pub fn neg_pure(v) {
    let t = type_of(v)
    if t == "int" { return 0 - v }
    if t == "float" { return 0.0 - v }
    v
}
