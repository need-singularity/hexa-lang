// self/runtime/spawn_pure.hexa
// Cooperative spawn runtime — pure hexa, no FFI (HX7 compliant).
//
// Provides the rt_spawn / rt_join_all API contract that parallel_for.hexa
// and prefetch_batch.hexa consume. At this stage each "spawn" executes
// its closure immediately (run-to-completion, cooperative scheduling).
// The API is shaped so that a future pthread/OS-thread backend can be
// swapped in without changing any call site.
//
// Design:
//   rt_spawn(fn, arg)           -> task_handle (int)
//     Executes fn(arg) immediately, stores result, returns handle.
//
//   rt_spawn2(fn, a, b)         -> task_handle
//     Executes fn(a, b) immediately. 2-arg variant.
//
//   rt_spawn3(fn, a, b, c)      -> task_handle
//     Executes fn(a, b, c) immediately. 3-arg variant.
//
//   rt_spawn_thunk(fn)           -> task_handle
//     Executes fn() (zero args). Used by prefetch double-buffer.
//
//   rt_join(handle)              -> result
//     Returns the stored result for a completed task.
//
//   rt_join_all(handles)         -> [result, ...]
//     Joins all handles in order, returns array of results.
//
//   rt_reset()
//     Clears the task store. Call between independent dispatch rounds.
//
// Future threading note: when OS threads land, rt_spawn will push
// (fn, args) onto a work queue and return a handle immediately. The
// fn will execute on a worker thread. rt_join will block until the
// handle's future is resolved. The cooperative version here is
// semantically identical (the future is always resolved at return).

// ── task store ──────────────────────────────────────────────
// Parallel arrays: rt_results[i] holds the return value of task i.
let mut rt_task_results = []
let mut rt_task_count   = 0

// ── spawn variants ──────────────────────────────────────────

@pure
pub fn rt_spawn(f, arg) {
    let result = f(arg)
    let h = rt_task_count
    rt_task_results.push(result)
    rt_task_count = rt_task_count + 1
    return h
}

@pure
pub fn rt_spawn2(f, a, b) {
    let result = f(a, b)
    let h = rt_task_count
    rt_task_results.push(result)
    rt_task_count = rt_task_count + 1
    return h
}

@pure
pub fn rt_spawn3(f, a, b, c) {
    let result = f(a, b, c)
    let h = rt_task_count
    rt_task_results.push(result)
    rt_task_count = rt_task_count + 1
    return h
}

@pure
pub fn rt_spawn_thunk(f) {
    let result = f()
    let h = rt_task_count
    rt_task_results.push(result)
    rt_task_count = rt_task_count + 1
    return h
}

// ── join ────────────────────────────────────────────────────

@pure
pub fn rt_join(h) {
    if h < 0 { return 0 }
    if h >= rt_task_count { return 0 }
    return rt_task_results[h]
}

@pure
pub fn rt_join_all(handles) {
    let n = len(handles)
    let mut out = []
    let mut i = 0
    while i < n {
        out.push(rt_join(handles[i]))
        i = i + 1
    }
    return out
}

// ── reset ───────────────────────────────────────────────────
// Call between independent dispatch rounds to reclaim task slots.

pub fn rt_reset() {
    rt_task_results = []
    rt_task_count = 0
}

// ── partition helper for parallel_for ───────────────────────
// Wraps a (body, start, end, ctx) tuple into a thunk-like call
// that iterates body(i, ctx) for i in [start, end). Returns void.
// Used by parallel_for_logical to rt_spawn each partition.

@pure
pub fn rt_run_partition(body, start, endv, ctx) {
    let mut i = start
    while i < endv {
        body(i, ctx)
        i = i + 1
    }
}
