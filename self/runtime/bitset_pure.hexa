// ═══════════════════════════════════════════════════════════════════
//  self/runtime/bitset_pure.hexa — fixed-size bit array (pure hexa)
//
//  Backed by an array of int "words" (treated as 32-bit lanes).
//  Useful for sieve, set membership, simple bloom filter.
//
//  Public API:
//      bitset_new_pure(nbits) -> bitset
//      bitset_set_pure(bs, i)
//      bitset_clear_pure(bs, i)
//      bitset_get_pure(bs, i) -> bool
//      bitset_flip_pure(bs, i)
//      bitset_count_pure(bs) -> int        — total bits set
//      bitset_union_pure(a, b) -> bitset
//      bitset_intersect_pure(a, b) -> bitset
//      bitset_diff_pure(a, b) -> bitset    — a AND NOT b
//      bitset_eq_pure(a, b) -> bool
//
//  Layout: bitset = struct{ words: int[], nbits: int }
//  Word size: 32 bits.
//
//  HX3 pitfalls handled:
//      - hexa surface parser is unreliable on `<<`, `>>`, `|` (parse
//        ambiguity with closures / postfix). We use mul/div/and/+ to
//        emulate the missing ops. `&` and `~` work directly.
// ═══════════════════════════════════════════════════════════════════

let BS_WORD_BITS = 32
let BS_WORD_MASK = 0xFFFFFFFF

@pure
fn bs_words_for(nbits) {
    return (nbits + BS_WORD_BITS - 1) / BS_WORD_BITS
}

// shift-left as repeated *2; n is small (≤31).
@pure
fn bs_shl(x, n) {
    let mut r = x
    let mut i = 0
    while i < n {
        r = r * 2
        i = i + 1
    }
    return r
}

// shift-right as repeated /2; n is small (≤31). For non-negative x.
@pure
fn bs_shr(x, n) {
    let mut r = x
    let mut i = 0
    while i < n {
        r = r / 2
        i = i + 1
    }
    return r
}

// bitwise OR via   a | b = (a + b) - (a & b).  & is supported directly.
@pure
fn bs_or(a, b) {
    return (a + b) - (a & b)
}

pub fn bitset_new_pure(nbits) {
    let nwords = bs_words_for(nbits)
    let mut words = []
    let mut i = 0
    while i < nwords {
        words.push(0)
        i = i + 1
    }
    return #{ "words": words, "nbits": nbits }
}

@pure
fn bs_word_idx(i) {
    return i / BS_WORD_BITS
}

@pure
fn bs_bit_mask(i) {
    let off = i % BS_WORD_BITS
    return bs_shl(1, off)
}

@pure
fn bs_arr_with_at(arr, idx, val) {
    let n = len(arr)
    let mut out = []
    let mut k = 0
    while k < n {
        if k == idx {
            out.push(val)
        } else {
            out.push(arr[k])
        }
        k = k + 1
    }
    return out
}

pub fn bitset_set_pure(bs, i) {
    if i < 0 || i >= bs["nbits"] { return bs }
    let w = bs_word_idx(i)
    let m = bs_bit_mask(i)
    let words = bs["words"]
    let cur = words[w]
    let new_w = bs_or(cur, m)
    let new_words = bs_arr_with_at(words, w, new_w)
    return #{ "words": new_words, "nbits": bs["nbits"] }
}

pub fn bitset_clear_pure(bs, i) {
    if i < 0 || i >= bs["nbits"] { return bs }
    let w = bs_word_idx(i)
    let m = bs_bit_mask(i)
    let inv_m = (~m) & BS_WORD_MASK
    let words = bs["words"]
    let cur = words[w]
    let new_w = cur & inv_m
    let new_words = bs_arr_with_at(words, w, new_w)
    return #{ "words": new_words, "nbits": bs["nbits"] }
}

pub fn bitset_get_pure(bs, i) {
    if i < 0 || i >= bs["nbits"] { return false }
    let w = bs_word_idx(i)
    let m = bs_bit_mask(i)
    let cur = bs["words"][w]
    return (cur & m) != 0
}

pub fn bitset_flip_pure(bs, i) {
    if bitset_get_pure(bs, i) {
        return bitset_clear_pure(bs, i)
    }
    return bitset_set_pure(bs, i)
}

@pure
fn popcount32(n) {
    let mut x = n & BS_WORD_MASK
    let mut c = 0
    while x != 0 {
        c = c + (x & 1)
        x = bs_shr(x, 1)
    }
    return c
}

pub fn bitset_count_pure(bs) {
    let words = bs["words"]
    let n = len(words)
    let mut total = 0
    let mut i = 0
    while i < n {
        total = total + popcount32(words[i])
        i = i + 1
    }
    return total
}

pub fn bitset_union_pure(a, b) {
    if a["nbits"] != b["nbits"] { return a }
    let aw = a["words"]
    let bw = b["words"]
    let n = len(aw)
    let mut out = []
    let mut i = 0
    while i < n {
        out.push(bs_or(aw[i], bw[i]))
        i = i + 1
    }
    return #{ "words": out, "nbits": a["nbits"] }
}

pub fn bitset_intersect_pure(a, b) {
    if a["nbits"] != b["nbits"] { return a }
    let aw = a["words"]
    let bw = b["words"]
    let n = len(aw)
    let mut out = []
    let mut i = 0
    while i < n {
        out.push(aw[i] & bw[i])
        i = i + 1
    }
    return #{ "words": out, "nbits": a["nbits"] }
}

pub fn bitset_diff_pure(a, b) {
    if a["nbits"] != b["nbits"] { return a }
    let aw = a["words"]
    let bw = b["words"]
    let n = len(aw)
    let mut out = []
    let mut i = 0
    while i < n {
        let inv = (~bw[i]) & BS_WORD_MASK
        out.push(aw[i] & inv)
        i = i + 1
    }
    return #{ "words": out, "nbits": a["nbits"] }
}

pub fn bitset_eq_pure(a, b) {
    if a["nbits"] != b["nbits"] { return false }
    let aw = a["words"]
    let bw = b["words"]
    let n = len(aw)
    let mut i = 0
    while i < n {
        if (aw[i] & BS_WORD_MASK) != (bw[i] & BS_WORD_MASK) { return false }
        i = i + 1
    }
    return true
}
