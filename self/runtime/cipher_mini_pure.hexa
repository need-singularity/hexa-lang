// ═══════════════════════════════════════════════════════════════════
//  self/runtime/cipher_mini_pure.hexa — pure-Hexa educational ciphers
//
//  TOY / EDUCATIONAL ONLY — none of these provide cryptographic
//  confidentiality. They exist as stdlib-shaped building blocks for
//  intro-to-crypto demos, CTFs, and teaching material. DO NOT use for
//  real message protection.
//
//  Public API:
//      xor_cipher_pure(text, key)       -> string  (symmetric: enc==dec)
//      caesar_shift_pure(text, n)       -> string  (ASCII letter shift)
//      rot13_pure(text)                 -> string  (caesar n=13, self-inverse)
//      atbash_pure(text)                -> string  (a<->z, b<->y, …)
//      vigenere_encode_pure(text, key)  -> string  (polyalphabetic caesar)
//
//  Shared semantics:
//    * Only ASCII a..z and A..Z are transformed; everything else
//      (digits, punctuation, whitespace, non-ASCII bytes) is passed
//      through unchanged.
//    * Case is preserved.
//    * Modular arithmetic uses `%` (the stage0 grammar has no `<<`/`>>`
//      in runtime codegen here, and we want portable byte math).
//    * XOR uses the `^` operator (parity with checksum_pure::sum_xor_pure).
//
//  Stage0 / HX3 pitfalls avoided:
//    * `char_code(param_string, i)` is broken on stage0 — we always
//      read bytes via `ord(s.substring(i, i + 1))` (same idiom as
//      checksum_pure.hexa:82, adler32_pure.hexa, luhn_pure).
//    * `from_char_code(n)` is unreliable for ASCII on stage0 (returns
//      decimal string in some paths). We build characters from a
//      local printable-table lookup (parity with from_char_code_pure
//      in string_pure.hexa:637).
//    * Concat uses `parts.push(…)` + `parts.join("")` to avoid the
//      O(n²) string-concat pitfall documented in
//      feedback_hexa_on2_concat.md.
//
//  No FFI, no imports — all primitives (`ord`, `substring`, `len`,
//  `type_of`, `^`, `%`) are stage0 builtins.
// ═══════════════════════════════════════════════════════════════════

// ── _from_code — int codepoint → 1-char string (ASCII only) ───────
//
// Mirrors the printable-range logic of from_char_code_pure, inlined
// so this module stands alone (same pattern as _ch_normalize in
// char_pure.hexa). Non-ASCII or control codes round-trip through the
// printable table only; unknowns fall back to the empty string.
@pure
fn _from_code(code) {
    if type_of(code) != "int" { return "" }
    if code < 0 { return "" }
    if code > 126 { return "" }
    if code >= 32 {
        let printable = " !\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_`abcdefghijklmnopqrstuvwxyz{|}~"
        let idx = code - 32
        return printable.substring(idx, idx + 1)
    }
    if code == 9 { return "\t" }
    if code == 10 { return "\n" }
    if code == 13 { return "\r" }
    ""
}

// ── _shift_letter — apply an integer shift to a single ASCII byte ─
//
// Letters (A..Z, a..z) are shifted by `n` positions within their
// own case; non-letters are returned unchanged. `n` may be any
// integer — it is normalised to [0, 25] via two `%` + add rounds
// so that negative shifts (used by vigenere_decode) work cleanly.
@pure
fn _shift_byte(c, n) {
    // Upper-case A..Z = 65..90
    if c >= 65 {
        if c <= 90 {
            let k = ((n % 26) + 26) % 26
            return ((c - 65 + k) % 26) + 65
        }
    }
    // Lower-case a..z = 97..122
    if c >= 97 {
        if c <= 122 {
            let k = ((n % 26) + 26) % 26
            return ((c - 97 + k) % 26) + 97
        }
    }
    c
}

// ── xor_cipher_pure — byte-wise repeating-key XOR ─────────────────
//
// Produces the same byte-length output as the input. Key repeats
// modulo its length. Symmetric: xor_cipher_pure(xor_cipher_pure(t,k),k) == t
// whenever every output byte maps back to a printable ASCII glyph
// via _from_code (which is the case for the tests below, where both
// text and key are printable-ASCII).
//
// Empty key → returns text unchanged (defensive, avoids %0 trap).
pub fn xor_cipher_pure(text, key) {
    if type_of(text) != "string" { return text }
    if type_of(key) != "string" { return text }
    let n = len(text)
    let k = len(key)
    if k == 0 { return text }
    let mut parts = []
    let mut i = 0
    while i < n {
        let tb = ord(text.substring(i, i + 1))
        let kb = ord(key.substring(i % k, (i % k) + 1))
        let xb = tb ^ kb
        parts.push(_from_code(xb))
        i = i + 1
    }
    parts.join("")
}

// ── caesar_shift_pure — classical letter shift ────────────────────
//
// Shifts each ASCII letter by `n` (positive = forward in the
// alphabet, negative = backward). All non-letter bytes pass through.
// `caesar_shift_pure("abc", 3) == "def"`.
pub fn caesar_shift_pure(text, n) {
    if type_of(text) != "string" { return text }
    if type_of(n) != "int" { return text }
    let sz = len(text)
    let mut parts = []
    let mut i = 0
    while i < sz {
        let b = ord(text.substring(i, i + 1))
        let sb = _shift_byte(b, n)
        parts.push(_from_code(sb))
        i = i + 1
    }
    parts.join("")
}

// ── rot13_pure — caesar(13), self-inverse ─────────────────────────
//
// `rot13_pure(rot13_pure(s)) == s` for any ASCII-letter-only string.
// Non-letters are preserved, so the round-trip holds for any input
// that is a well-formed printable-ASCII string.
pub fn rot13_pure(text) {
    caesar_shift_pure(text, 13)
}

// ── atbash_pure — reverse-alphabet substitution ───────────────────
//
// Maps a↔z, b↔y, …, A↔Z. Because the transform is its own inverse,
// `atbash_pure(atbash_pure(s)) == s` for any ASCII input.
// Non-letters are passed through.
pub fn atbash_pure(text) {
    if type_of(text) != "string" { return text }
    let sz = len(text)
    let mut parts = []
    let mut i = 0
    while i < sz {
        let b = ord(text.substring(i, i + 1))
        let mut out = b
        if b >= 65 {
            if b <= 90 {
                // 'A' + ('Z' - b) = 65 + (90 - b) = 155 - b
                out = 155 - b
            }
        }
        if b >= 97 {
            if b <= 122 {
                // 'a' + ('z' - b) = 97 + (122 - b) = 219 - b
                out = 219 - b
            }
        }
        parts.push(_from_code(out))
        i = i + 1
    }
    parts.join("")
}

// ── vigenere_encode_pure — polyalphabetic caesar ──────────────────
//
// Each letter of `text` is shifted by the corresponding letter of
// `key` (A=0, B=1, …, Z=25; case of key is normalised, case of text
// is preserved). Non-letter bytes in `text` are passed through AND
// do not advance the key cursor (standard behaviour — matches the
// "wheel Vigenère" variant used in textbooks and CTFs).
//
// Empty or non-string key → returns text unchanged.
// Known test pair: encode("ATTACKATDAWN", "LEMON") == "LXFOPVEFRNHR".
pub fn vigenere_encode_pure(text, key) {
    if type_of(text) != "string" { return text }
    if type_of(key) != "string" { return text }
    let kn = len(key)
    if kn == 0 { return text }

    // Normalise key: collect only A..Z / a..z, uppercase to 0..25.
    let mut key_shifts = []
    let mut ki = 0
    while ki < kn {
        let kb = ord(key.substring(ki, ki + 1))
        if kb >= 65 {
            if kb <= 90 {
                key_shifts.push(kb - 65)
            }
        }
        if kb >= 97 {
            if kb <= 122 {
                key_shifts.push(kb - 97)
            }
        }
        ki = ki + 1
    }
    let ks = len(key_shifts)
    if ks == 0 { return text }

    let sz = len(text)
    let mut parts = []
    let mut i = 0
    let mut kcur = 0
    while i < sz {
        let b = ord(text.substring(i, i + 1))
        let is_upper = (b >= 65 && b <= 90)
        let is_lower = (b >= 97 && b <= 122)
        if is_upper || is_lower {
            let shift = key_shifts[kcur % ks]
            let sb = _shift_byte(b, shift)
            parts.push(_from_code(sb))
            kcur = kcur + 1
        } else {
            parts.push(_from_code(b))
        }
        i = i + 1
    }
    parts.join("")
}
