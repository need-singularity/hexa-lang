// ═══════════════════════════════════════════════════════════════════
//  self/runtime/trie_pure.hexa — Trie (prefix tree) as pure hexa
//
//  String dictionary / autocomplete Trie built on nested maps.
//  Each trie node is a map with:
//    "children" -> map of char_string -> child_node
//    "is_end"   -> bool (true if a complete word ends here)
//
//  No C dependencies. Uses surface builtins: keys(), len(), has_key().
//  Character iteration via s[i..(i+1)] slice syntax.
//
//  Pitfalls honored: P1 no semicolons, P15 let mut, P29 push rebind,
//  while loops only, string char via s[i..(i+1)]
//
//  Public API:
//      trie_new_pure()                     — empty trie node
//      trie_insert_pure(trie, word)        — insert word, returns updated trie
//      trie_lookup_pure(trie, word)        — true if exact word exists
//      trie_starts_with_pure(trie, prefix) — true if any word starts with prefix
//      trie_collect_pure(trie, prefix)     — array of all words with prefix
//      trie_count_pure(trie)               — total number of words stored
//      trie_remove_pure(trie, word)        — remove word, returns updated trie
//      trie_words_pure(trie)               — array of all words
// ═══════════════════════════════════════════════════════════════════

// ── trie_new_pure — create empty trie node ─────────────────────────

@pure
pub fn trie_new_pure() {
    let mut node = #{}
    node["children"] = #{}
    node["is_end"] = false
    return node
}

// ── trie_insert_pure — insert word into trie, return root ──────────

@pure
pub fn trie_insert_pure(root, word) {
    let mut cur = root
    let n = len(word)
    let mut i = 0
    while i < n {
        let ch = word[i..(i + 1)]
        let children = cur["children"]
        if !has_key(children, ch) {
            children[ch] = trie_new_pure()
        }
        cur = children[ch]
        i = i + 1
    }
    cur["is_end"] = true
    return root
}

// ── trie_lookup_pure — exact match lookup ──────────────────────────

@pure
pub fn trie_lookup_pure(root, word) {
    let mut cur = root
    let n = len(word)
    let mut i = 0
    while i < n {
        let ch = word[i..(i + 1)]
        let children = cur["children"]
        if !has_key(children, ch) {
            return false
        }
        cur = children[ch]
        i = i + 1
    }
    return cur["is_end"]
}

// ── trie_starts_with_pure — does any word start with prefix? ───────

@pure
pub fn trie_starts_with_pure(root, prefix) {
    let mut cur = root
    let n = len(prefix)
    let mut i = 0
    while i < n {
        let ch = prefix[i..(i + 1)]
        let children = cur["children"]
        if !has_key(children, ch) {
            return false
        }
        cur = children[ch]
        i = i + 1
    }
    return true
}

// ── _trie_collect_helper — DFS collect all words from node ─────────

fn _trie_collect_helper(node, prefix, results) {
    if node["is_end"] {
        results = results.push(prefix)
    }
    let children = node["children"]
    let ks = keys(children)
    let nk = len(ks)
    let mut i = 0
    while i < nk {
        let ch = ks[i]
        results = _trie_collect_helper(children[ch], prefix + ch, results)
        i = i + 1
    }
    return results
}

// ── trie_collect_pure — all words with given prefix (autocomplete) ──

@pure
pub fn trie_collect_pure(root, prefix) {
    let mut cur = root
    let n = len(prefix)
    let mut i = 0
    while i < n {
        let ch = prefix[i..(i + 1)]
        let children = cur["children"]
        if !has_key(children, ch) {
            return []
        }
        cur = children[ch]
        i = i + 1
    }
    return _trie_collect_helper(cur, prefix, [])
}

// ── _trie_count_helper — DFS count all is_end nodes ────────────────

fn _trie_count_helper(node) {
    let mut count = 0
    if node["is_end"] {
        count = 1
    }
    let children = node["children"]
    let ks = keys(children)
    let nk = len(ks)
    let mut i = 0
    while i < nk {
        count = count + _trie_count_helper(children[ks[i]])
        i = i + 1
    }
    return count
}

// ── trie_count_pure — total number of words stored ─────────────────

@pure
pub fn trie_count_pure(root) {
    return _trie_count_helper(root)
}

// ── trie_words_pure — array of all words in the trie ───────────────

@pure
pub fn trie_words_pure(root) {
    return _trie_collect_helper(root, "", [])
}

// ── trie_remove_pure — remove word (unmark is_end), return root ────
// Does not prune empty branches — idempotent on missing words.

@pure
pub fn trie_remove_pure(root, word) {
    let mut cur = root
    let n = len(word)
    let mut i = 0
    while i < n {
        let ch = word[i..(i + 1)]
        let children = cur["children"]
        if !has_key(children, ch) {
            return root
        }
        cur = children[ch]
        i = i + 1
    }
    cur["is_end"] = false
    return root
}
