// ═══════════════════════════════════════════════════════════════════
//  self/runtime/trie_pure.hexa — Trie (prefix tree) as pure hexa
//
//  String dictionary / autocomplete Trie built on nested maps.
//  Each trie node is a map with:
//    "children" -> map of char_string -> child_node
//    "is_end"   -> bool (true if a complete word ends here)
//
//  No C dependencies. Uses surface builtins: keys(), len(), has_key().
//  Character iteration via substring(i, i+1).
//
//  ROI #122: Trie (prefix tree) data structure as pure Hexa.
//
//  Pitfalls honored: P1 no semicolons, P15 let mut, P29 push rebind,
//  while loops only, substring for char access
//
//  Public API:
//      char_to_index(c)                        — 'a'=0 .. 'z'=25, -1 if out of range
//      trie_create() / trie_new_pure()         — empty trie node
//      trie_insert(t, w) / trie_insert_pure()  — insert word, returns updated trie
//      trie_search(t, w) / trie_lookup_pure()  — true if exact word exists
//      trie_starts_with(t, p) / trie_starts_with_pure() — prefix check
//      trie_count_words(t) / trie_count_pure() — total words stored
//      trie_all_with_prefix(t, p) / trie_collect_pure() — words with prefix
//      trie_remove_pure(t, w)                  — remove word, returns updated trie
//      trie_words_pure(t)                      — array of all words
// ═══════════════════════════════════════════════════════════════════

// ── char_to_index — map character to child index ───────────────────
// 'a'=0, 'b'=1, ... 'z'=25. Returns -1 for anything outside a-z.

@pure
pub fn char_to_index(c) {
    let alpha = "abcdefghijklmnopqrstuvwxyz"
    let mut i = 0
    while i < 26 {
        if alpha.substring(i, i + 1) == c { return i }
        i = i + 1
    }
    return -1
}

// ── _new_node — create empty trie node ─────────────────────────────

fn _new_node() {
    let mut node = #{}
    node["children"] = #{}
    node["is_end"] = false
    return node
}

// ── trie_create — create fresh empty trie ──────────────────────────
// Returns a map representing the trie root node.
// Internally each node is #{children: #{char -> node}, is_end: bool}.

@pure
pub fn trie_create() {
    return _new_node()
}

// ── trie_insert — insert word into trie, return root ───────────────

pub fn trie_insert(trie, word) {
    let mut cur = trie
    let n = len(word)
    let mut i = 0
    while i < n {
        let ch = word.substring(i, i + 1)
        let children = cur["children"]
        if !has_key(children, ch) {
            children[ch] = _new_node()
        }
        cur = children[ch]
        i = i + 1
    }
    cur["is_end"] = true
    return trie
}

// ── trie_search — exact match lookup ───────────────────────────────

@pure
pub fn trie_search(trie, word) {
    let mut cur = trie
    let n = len(word)
    let mut i = 0
    while i < n {
        let ch = word.substring(i, i + 1)
        let children = cur["children"]
        if !has_key(children, ch) {
            return false
        }
        cur = children[ch]
        i = i + 1
    }
    return cur["is_end"]
}

// ── trie_starts_with — does any word start with prefix? ────────────

@pure
pub fn trie_starts_with(trie, prefix) {
    let mut cur = trie
    let n = len(prefix)
    let mut i = 0
    while i < n {
        let ch = prefix.substring(i, i + 1)
        let children = cur["children"]
        if !has_key(children, ch) {
            return false
        }
        cur = children[ch]
        i = i + 1
    }
    return true
}

// ── _count_helper — DFS count all is_end nodes ─────────────────────

fn _count_helper(node) {
    let mut count = 0
    if node["is_end"] {
        count = 1
    }
    let children = node["children"]
    let ks = keys(children)
    let nk = len(ks)
    let mut i = 0
    while i < nk {
        count = count + _count_helper(children[ks[i]])
        i = i + 1
    }
    return count
}

// ── trie_count_words — total number of words stored ────────────────

@pure
pub fn trie_count_words(trie) {
    return _count_helper(trie)
}

// ── _collect_helper — DFS collect all words from node ──────────────

fn _collect_helper(node, prefix, results) {
    if node["is_end"] {
        results = results.push(prefix)
    }
    let children = node["children"]
    let ks = keys(children)
    let nk = len(ks)
    let mut i = 0
    while i < nk {
        let ch = ks[i]
        results = _collect_helper(children[ch], prefix + ch, results)
        i = i + 1
    }
    return results
}

// ── trie_all_with_prefix — all words with given prefix ─────────────

@pure
pub fn trie_all_with_prefix(trie, prefix) {
    let mut cur = trie
    let n = len(prefix)
    let mut i = 0
    while i < n {
        let ch = prefix.substring(i, i + 1)
        let children = cur["children"]
        if !has_key(children, ch) {
            return []
        }
        cur = children[ch]
        i = i + 1
    }
    return _collect_helper(cur, prefix, [])
}

// ═══════════════════════════════════════════════════════════════════
//  _pure suffix aliases — consistent naming with other runtime files
// ═══════════════════════════════════════════════════════════════════

@pure
pub fn trie_new_pure() {
    return trie_create()
}

@pure
pub fn trie_insert_pure(trie, word) {
    return trie_insert(trie, word)
}

@pure
pub fn trie_lookup_pure(trie, word) {
    return trie_search(trie, word)
}

@pure
pub fn trie_starts_with_pure(trie, prefix) {
    return trie_starts_with(trie, prefix)
}

@pure
pub fn trie_count_pure(trie) {
    return trie_count_words(trie)
}

@pure
pub fn trie_collect_pure(trie, prefix) {
    return trie_all_with_prefix(trie, prefix)
}

// ── trie_words_pure — array of all words in the trie ───────────────

@pure
pub fn trie_words_pure(trie) {
    return _collect_helper(trie, "", [])
}

// ── trie_remove_pure — remove word (unmark is_end), return root ────
// Does not prune empty branches — idempotent on missing words.

@pure
pub fn trie_remove_pure(trie, word) {
    let mut cur = trie
    let n = len(word)
    let mut i = 0
    while i < n {
        let ch = word.substring(i, i + 1)
        let children = cur["children"]
        if !has_key(children, ch) {
            return trie
        }
        cur = children[ch]
        i = i + 1
    }
    cur["is_end"] = false
    return trie
}
