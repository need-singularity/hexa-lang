// self/runtime/path_pure.hexa -- Phase 2.5 runtime port (paths)
//
// Pure-Hexa path manipulation helpers. Currently these live as ad-hoc
// local fns in tool/flatten_imports.hexa (fl_dirname/fl_basename/
// fl_file_base), tool/regression_harness.hexa (rh_basename),
// self/build_c.hexa (dirname_of), self/main.hexa (basename_stem),
// self/module_loader.hexa (ml_dirname) — at least 6 duplicates.
//
// This module is DRY — replacing those will remove ~50 lines of
// redundant code once referencing is wired up. For now it's a
// standalone module so new callers can prefer these.
//
// POSIX semantics only (no Windows drive letters or backslashes).

// ── _last_index_of (internal helper) ──────────────────────────────
// interp has no .last_index_of method. Simple linear scan from the
// end — adequate for path-length strings.
fn _last_idx_of(s, target) {
    let n = len(s)
    let m = len(target)
    if m == 0 { return n }
    let mut i = n - m
    while i >= 0 {
        if s.substring(i, i + m) == target { return i }
        i = i - 1
    }
    -1
}

// ── basename_pure ─────────────────────────────────────────────────
// Everything after the last '/'. Trailing slashes are stripped first.
//   "/a/b/c"     → "c"
//   "/a/b/c/"    → "c"
//   "foo.hexa"   → "foo.hexa"
//   "/"          → ""
//   ""           → ""
pub fn basename_pure(path) {
    if type_of(path) != "string" { return "" }
    let mut n = len(path)
    while n > 0 && path.substring(n - 1, n) == "/" {
        n = n - 1
    }
    let trimmed = path.substring(0, n)
    let idx = _last_idx_of(trimmed, "/")
    if idx < 0 { return trimmed }
    trimmed.substring(idx + 1, len(trimmed))
}

// ── dirname_pure ──────────────────────────────────────────────────
// Everything before the last '/'. Returns "" for bare names, "/"
// for absolute paths under root.
//   "/a/b/c"     → "/a/b"
//   "/a"         → "/"
//   "foo.hexa"   → ""
//   ""           → ""
pub fn dirname_pure(path) {
    if type_of(path) != "string" { return "" }
    let idx = _last_idx_of(path, "/")
    if idx < 0 { return "" }
    if idx == 0 { return "/" }
    path.substring(0, idx)
}

// ── ext_pure ──────────────────────────────────────────────────────
// Returns the final extension WITHOUT the leading dot, "" if none.
// A leading dot file (".env") has no extension.
//   "foo.hexa"       → "hexa"
//   "a/b/c.tar.gz"   → "gz"
//   ".env"           → ""
//   "no_ext"         → ""
pub fn ext_pure(path) {
    if type_of(path) != "string" { return "" }
    let base = basename_pure(path)
    let dot = _last_idx_of(base, ".")
    if dot <= 0 { return "" }
    base.substring(dot + 1, len(base))
}

// ── stem_pure ─────────────────────────────────────────────────────
// basename with the final extension removed.
//   "foo.hexa"       → "foo"
//   "a/b/c.tar.gz"   → "c.tar"
//   ".env"           → ".env"
//   "no_ext"         → "no_ext"
pub fn stem_pure(path) {
    if type_of(path) != "string" { return "" }
    let base = basename_pure(path)
    let dot = _last_idx_of(base, ".")
    if dot <= 0 { return base }
    base.substring(0, dot)
}

// ── join_path_pure ────────────────────────────────────────────────
// Joins two path segments with a single '/'. Handles trailing/leading
// slashes so you never get "a//b" or lose the separator.
//   "a", "b"     → "a/b"
//   "a/", "b"    → "a/b"
//   "a", "/b"    → "a/b"
//   "", "b"      → "b"
//   "a", ""      → "a"
pub fn join_path_pure(a, b) {
    if type_of(a) != "string" { return b }
    if type_of(b) != "string" { return a }
    if len(a) == 0 { return b }
    if len(b) == 0 { return a }
    // strip trailing / from a
    let mut alen = len(a)
    while alen > 0 && a.substring(alen - 1, alen) == "/" {
        alen = alen - 1
    }
    // strip leading / from b
    let mut bstart = 0
    while bstart < len(b) && b.substring(bstart, bstart + 1) == "/" {
        bstart = bstart + 1
    }
    // Root-only ('/') left side keeps its slash.
    if alen == 0 {
        return "/" + b.substring(bstart, len(b))
    }
    a.substring(0, alen) + "/" + b.substring(bstart, len(b))
}

// ── is_absolute_pure ──────────────────────────────────────────────
// True for paths starting with '/'.
pub fn is_absolute_pure(path) {
    if type_of(path) != "string" { return false }
    if len(path) == 0 { return false }
    path.substring(0, 1) == "/"
}
