// self/runtime/format_pure.hexa -- Phase 2.3 runtime port (format)
//
// Pure-Hexa covers for hexa_format (single-arg) and hexa_format_n
// (multi-arg with optional {:.N} precision). Mirrors self/runtime.c:
// 2720 (format) and 2736 (format_n).
//
// Placeholder grammar:
//   {}         — to_string(arg)
//   {:.N}      — float arg formatted with N-digit precision (snprintf %.Nf)
//   {...}      — any other spec falls back to to_string(arg)
//
// Pitfalls:
//   P1  no semicolons
//   P15 let mut everywhere
//   P29 .push() returns NEW array — rebind is mandatory

// ── format_float_prec — helper for {:.N} ──────────────────────────
// Formats a float to fixed N-digit precision. Implements:
//   1. sign extraction
//   2. integer part via repeated /10
//   3. rounded fractional part = round(x * 10^N) mod 10^N
// Matches %.Nf C snprintf for positive/negative/zero. Rounds ties
// to nearest (matches strtod-like conventions reliably enough for
// log/diagnostic output; not IEEE 754 bit-perfect).
fn format_float_prec(val, prec) {
    let mut x = val
    if type_of(x) == "int" { x = x + 0.0 }
    let mut neg = false
    if x < 0.0 {
        neg = true
        x = 0.0 - x
    }
    // scale = 10^prec
    let mut scale = 1
    let mut p = 0
    while p < prec {
        scale = scale * 10
        p = p + 1
    }
    // round-half-up via +0.5, then truncate to integer portion by
    // dropping "." and everything after in the string representation.
    let scaled = x * (scale + 0.0) + 0.5
    let trunc_str = to_string(scaled)
    let dot_idx = trunc_str.index_of(".")
    let mut int_part_str = trunc_str
    if dot_idx >= 0 {
        int_part_str = trunc_str.substring(0, dot_idx)
    }
    // Now int_part_str is the rounded integer representation.
    // Split into integer and fractional halves.
    let n = len(int_part_str)
    let mut intp = ""
    let mut fracp = ""
    if n <= prec {
        // Pad fractional with leading zeros
        intp = "0"
        let missing = prec - n
        let mut k = 0
        while k < missing {
            fracp = fracp + "0"
            k = k + 1
        }
        fracp = fracp + int_part_str
    } else {
        intp = int_part_str.substring(0, n - prec)
        fracp = int_part_str.substring(n - prec, n)
    }
    let mut out = intp
    if prec > 0 {
        out = out + "." + fracp
    }
    // Suppress "-0" and "-0.00..." — matches snprintf %.Nf.
    let mut is_zero = (intp == "0")
    if is_zero && prec > 0 {
        let mut zi = 0
        while zi < len(fracp) {
            if fracp.substring(zi, zi + 1) != "0" {
                is_zero = false
            }
            zi = zi + 1
        }
    }
    if neg && !is_zero {
        out = "-" + out
    }
    out
}

// ── format_pure ───────────────────────────────────────────────────
// Single-arg format: replace first {} with to_string(arg). Non-string
// format input returned as-is. No placeholder → input unchanged.
pub fn format_pure(fmt, arg) {
    if type_of(fmt) != "string" { return fmt }
    let pos = fmt.index_of("{}")
    if pos < 0 { return fmt }
    let sarg = to_string(arg)
    fmt.substring(0, pos) + sarg + fmt.substring(pos + 2, len(fmt))
}

// ── format_n_pure ─────────────────────────────────────────────────
// Multi-arg format with {} and {:.N} placeholders. Matches hexa_format_n
// (runtime.c:2736). Unmatched placeholders (args list shorter than
// placeholder count) are emitted verbatim.
pub fn format_n_pure(fmt, args) {
    if type_of(fmt) != "string" { return fmt }
    if type_of(args) != "array"  { return fmt }
    let n = len(fmt)
    let argc = len(args)
    let mut out = ""
    let mut i = 0
    let mut ai = 0
    while i < n {
        let c = fmt.substring(i, i + 1)
        if c == "{" && ai < argc {
            // find closing }
            let close_rel = fmt.substring(i, n).index_of("}")
            if close_rel < 0 {
                // No close → literal
                out = out + c
                i = i + 1
            } else {
                let close = i + close_rel
                let spec = fmt.substring(i + 1, close)
                let arg = args[ai]
                ai = ai + 1
                if len(spec) >= 2 && spec.substring(0, 2) == ":." {
                    let prec_str = spec.substring(2, len(spec))
                    // Minimal int parse for precision (single-digit common case)
                    let mut prec = 0
                    let mut pi = 0
                    while pi < len(prec_str) {
                        let ch = ord(prec_str.substring(pi, pi + 1))
                        if ch >= 48 && ch <= 57 {
                            prec = prec * 10 + (ch - 48)
                        }
                        pi = pi + 1
                    }
                    out = out + format_float_prec(arg, prec)
                } else {
                    out = out + to_string(arg)
                }
                i = close + 1
            }
        } else {
            out = out + c
            i = i + 1
        }
    }
    out
}
