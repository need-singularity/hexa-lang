// self/runtime/array_pure.hexa -- Phase 2.2 runtime port (array helpers)
//
// Pure-Hexa covers for selected hexa_array_* functions in self/runtime.c.
// These port the algorithmic wrappers (slice, index_of, contains, reverse,
// last, first, flatten, unique) — the low-level primitives (push, new, get,
// set, reserve, len) stay in C because they own the HeapDescriptor layout.
//
// ADDITIVE — does not remove any C function. See string_pure.hexa header
// for the full rationale on why removal requires a codegen interpose pass.
//
// Pitfalls observed (grammar.jsonl):
//   P1  no semicolons
//   P15 let mut everywhere
//   P29 .push() returns NEW array — rebind is mandatory

// ── array_slice_pure ──────────────────────────────────────────────
// Mirrors hexa_array_slice (runtime.c:4056). Byte-indexed clip with
// saturating bounds (a<0 → 0, b>len → len, a>b → empty).
pub fn array_slice_pure(arr, start_idx, end_idx) {
    if type_of(arr) != "array" { return [] }
    let n = len(arr)
    let mut a = start_idx
    let mut b = end_idx
    if a < 0 { a = 0 }
    if b > n { b = n }
    if a > b { a = b }
    let mut out = []
    let mut i = a
    while i < b {
        out = out.push(arr[i])
        i = i + 1
    }
    out
}

// ── array_index_of_pure ───────────────────────────────────────────
// Mirrors hexa_array_index_of (runtime.c:4107). Linear search for
// first index with `arr[i] == item`, else -1.
pub fn array_index_of_pure(arr, item) {
    if type_of(arr) != "array" { return -1 }
    let n = len(arr)
    let mut i = 0
    while i < n {
        if arr[i] == item { return i }
        i = i + 1
    }
    -1
}

// ── array_contains_pure ───────────────────────────────────────────
// Convenience: true if `item` appears anywhere in `arr`.
pub fn array_contains_pure(arr, item) {
    array_index_of_pure(arr, item) >= 0
}

// ── array_reverse_pure ────────────────────────────────────────────
// Returns a new array with elements in reverse order.
pub fn array_reverse_pure(arr) {
    if type_of(arr) != "array" { return [] }
    let n = len(arr)
    let mut out = []
    let mut i = n - 1
    while i >= 0 {
        out = out.push(arr[i])
        i = i - 1
    }
    out
}

// ── array_first_pure / array_last_pure ────────────────────────────
// Return first/last element, or nil on empty / non-array.
pub fn array_first_pure(arr) {
    if type_of(arr) != "array" { return nil }
    if len(arr) == 0 { return nil }
    arr[0]
}

pub fn array_last_pure(arr) {
    if type_of(arr) != "array" { return nil }
    let n = len(arr)
    if n == 0 { return nil }
    arr[n - 1]
}

// ── array_flatten_pure ────────────────────────────────────────────
// Flattens one level: [[1,2],[3,4]] → [1,2,3,4]. Non-array elements
// are pushed as-is.
pub fn array_flatten_pure(arr) {
    if type_of(arr) != "array" { return [] }
    let mut out = []
    let n = len(arr)
    let mut i = 0
    while i < n {
        let elem = arr[i]
        if type_of(elem) == "array" {
            let m = len(elem)
            let mut j = 0
            while j < m {
                out = out.push(elem[j])
                j = j + 1
            }
        } else {
            out = out.push(elem)
        }
        i = i + 1
    }
    out
}

// ── array_unique_pure ─────────────────────────────────────────────
// Returns a new array with duplicates removed, preserving first-
// occurrence order. O(n^2) linear scan — adequate for small arrays,
// fine for codegen/interpreter dedup lists.
pub fn array_unique_pure(arr) {
    if type_of(arr) != "array" { return [] }
    let mut out = []
    let n = len(arr)
    let mut i = 0
    while i < n {
        let elem = arr[i]
        if array_index_of_pure(out, elem) < 0 {
            out = out.push(elem)
        }
        i = i + 1
    }
    out
}

// ── array_concat_pure ─────────────────────────────────────────────
// Returns a + b. Non-array operands are skipped (treated as []).
pub fn array_concat_pure(a, b) {
    let mut out = []
    if type_of(a) == "array" {
        let mut i = 0
        while i < len(a) {
            out = out.push(a[i])
            i = i + 1
        }
    }
    if type_of(b) == "array" {
        let mut j = 0
        while j < len(b) {
            out = out.push(b[j])
            j = j + 1
        }
    }
    out
}
