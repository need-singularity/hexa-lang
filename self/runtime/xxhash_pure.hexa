// ═══════════════════════════════════════════════════════════════════
//  self/runtime/xxhash_pure.hexa — xxHash32 non-cryptographic hash
//
//  Pure-Hexa implementation of xxHash32 (Yann Collet).
//  Ultra-fast hash for large buffer checksums — ROI #116.
//
//  All bit ops inlined (stage0 interpreter does not re-export
//  transitive imports). All arithmetic masked to 32 bits.
//
//  Pitfalls:
//    P15 let mut for reassigned locals
//    P30 no unsigned int type — emulate via & 0xFFFFFFFF after each op
//    No 0b binary literals — use hex
// ═══════════════════════════════════════════════════════════════════

// xxHash32 primes
let XXHP1 = 0x9E3779B1   // 2654435761
let XXHP2 = 0x85EBCA77   // 2246822519
let XXHP3 = 0xC2B2AE3D   // 3266489917
let XXHP4 = 0x27D4EB2F   //  668265263
let XXHP5 = 0x165667B1   //  374761393

let XXH_MASK32 = 0xFFFFFFFF

// ── inlined bit helpers ──────────────────────────────────────────

@pure
fn xxh_pow2(n) {
    let mut r = 1
    let mut i = 0
    while i < n { r = r * 2; i = i + 1 }
    return r
}

@pure
fn xxh_shl(a, n) {
    if n <= 0 { return a }
    return a * xxh_pow2(n)
}

@pure
fn xxh_shr(a, n) {
    if n <= 0 { return a }
    return a / xxh_pow2(n)
}

@pure
fn xxh_or(a, b) {
    return (a + b) - (a & b)
}

@pure
fn xxh_rotl32(x, r) {
    let v = x & XXH_MASK32
    let sh = r % 32
    if sh == 0 { return v }
    let lo = (v * xxh_pow2(sh)) & XXH_MASK32
    let hi = v / xxh_pow2(32 - sh)
    return xxh_or(lo, hi) & XXH_MASK32
}

// 32-bit multiply via 16-bit split to avoid int64 overflow
@pure
fn xxh_mul32(a, b) {
    let a32 = a & XXH_MASK32
    let b32 = b & XXH_MASK32
    let aL = a32 & 0xFFFF
    let aH = a32 / 0x10000
    let bL = b32 & 0xFFFF
    let bH = b32 / 0x10000
    let low = aL * bL
    let mid = (aL * bH + aH * bL) & 0xFFFF
    let result = low + mid * 0x10000
    return result & XXH_MASK32
}

// 32-bit add with mask
@pure
fn xxh_add32(a, b) {
    return (a + b) & XXH_MASK32
}

// read little-endian uint32 from string at offset
@pure
fn xxh_read_u32(s, off) {
    let b0 = ord(s.substring(off, off + 1))
    let b1 = ord(s.substring(off + 1, off + 2))
    let b2 = ord(s.substring(off + 2, off + 3))
    let b3 = ord(s.substring(off + 3, off + 4))
    return xxh_or(xxh_or(b0, b1 * 0x100), xxh_or(b2 * 0x10000, b3 * 0x1000000))
}

// xxHash32 round
@pure
fn xxh32_round(acc, input) {
    let v = xxh_add32(acc, xxh_mul32(input, XXHP2))
    let r = xxh_rotl32(v, 13)
    return xxh_mul32(r, XXHP1)
}

// xxHash32 avalanche
@pure
fn xxh32_avalanche(h_in) {
    let mut h = h_in
    h = h ^ xxh_shr(h, 15)
    h = xxh_mul32(h, XXHP2)
    h = h ^ xxh_shr(h, 13)
    h = xxh_mul32(h, XXHP3)
    h = h ^ xxh_shr(h, 16)
    return h
}

// ── xxhash32_pure — main entry point ────────────────────────────

@pure
pub fn xxhash32_pure(data, seed) {
    let length = len(data)
    let mut h = 0
    let mut idx = 0

    if length >= 16 {
        // init accumulators
        let mut v1 = xxh_add32(xxh_add32(seed, XXHP1), XXHP2)
        let mut v2 = xxh_add32(seed, XXHP2)
        let mut v3 = seed & XXH_MASK32
        let mut v4 = (seed - XXHP1) & XXH_MASK32

        // process 16-byte stripes
        let limit = length - 16
        while idx <= limit {
            v1 = xxh32_round(v1, xxh_read_u32(data, idx))
            v2 = xxh32_round(v2, xxh_read_u32(data, idx + 4))
            v3 = xxh32_round(v3, xxh_read_u32(data, idx + 8))
            v4 = xxh32_round(v4, xxh_read_u32(data, idx + 12))
            idx = idx + 16
        }

        // merge accumulators
        let r1 = xxh_rotl32(v1, 1)
        let r2 = xxh_rotl32(v2, 7)
        let r3 = xxh_rotl32(v3, 12)
        let r4 = xxh_rotl32(v4, 18)
        h = xxh_add32(xxh_add32(xxh_add32(r1, r2), r3), r4)
    } else {
        h = xxh_add32(seed, XXHP5)
    }

    h = xxh_add32(h, length)

    // process remaining 4-byte chunks
    let limit4 = length - 4
    while idx <= limit4 {
        let k = xxh_read_u32(data, idx)
        h = xxh_add32(h, xxh_mul32(k, XXHP3))
        h = xxh_mul32(xxh_rotl32(h, 17), XXHP4)
        idx = idx + 4
    }

    // process remaining bytes
    while idx < length {
        let b = ord(data.substring(idx, idx + 1))
        h = xxh_add32(h, xxh_mul32(b, XXHP5))
        h = xxh_mul32(xxh_rotl32(h, 11), XXHP1)
        idx = idx + 1
    }

    return xxh32_avalanche(h)
}
