// self/runtime/levenshtein_pure.hexa — pure-Hexa edit distance DP
//
// Pure Hexa implementations of string distance metrics for fuzzy matching.
// No C, no FFI, no syscalls, no 0b literals.
//
// Public API:
//     levenshtein_pure(a, b)       — Wagner-Fischer DP, O(nm) time, O(min(n,m)) space
//     levenshtein_ratio_pure(a, b) — 1.0 - dist / max(len(a), len(b))
//     hamming_pure(a, b)           — Hamming distance (equal-length strings)
//
// Pitfalls observed:
//     P1   no semicolons
//     P15  let mut everywhere
//     P16  substring(i, i+1) for single-char access
//     slice precedence: arr[(i+1)..j] needs parens (avoided here)
//     let mut after let str contamination: avoided by init order

// ── levenshtein_pure ────────────────────────────────────────────────
// Wagner-Fischer DP with single-row optimization.
// Uses the shorter string as the "column" dimension so the row
// buffer is O(min(n,m)).
pub fn levenshtein_pure(a, b) {
    if type_of(a) != "string" { return -1 }
    if type_of(b) != "string" { return -1 }
    let a_len = len(a)
    let b_len = len(b)

    // Early exits
    if a == b { return 0 }
    if a_len == 0 { return b_len }
    if b_len == 0 { return a_len }

    // Ensure we iterate over the shorter string in the inner loop
    // to minimize memory: row has min(n,m)+1 entries.
    let mut s1 = a
    let mut s2 = b
    let mut n = a_len
    let mut m = b_len
    if a_len > b_len {
        s1 = b
        s2 = a
        n = b_len
        m = a_len
    }
    // Now n <= m.  s1 has length n (columns), s2 has length m (rows).

    // Initialize previous row: [0, 1, 2, ..., n]
    let mut prev = []
    let mut k = 0
    while k <= n {
        prev.push(k)
        k = k + 1
    }

    // Fill row by row
    let mut i = 0
    while i < m {
        let ch2 = s2.substring(i, i + 1)
        let mut curr = [i + 1]
        let mut j = 0
        while j < n {
            let ch1 = s1.substring(j, j + 1)
            let cost = if ch1 == ch2 { 0 } else { 1 }

            // deletion: curr[j] + 1
            let del = curr[j] + 1
            // insertion: prev[j+1] + 1
            let ins = prev[j + 1] + 1
            // substitution: prev[j] + cost
            let sub = prev[j] + cost

            // min of three
            let mut best = del
            if ins < best { best = ins }
            if sub < best { best = sub }

            curr.push(best)
            j = j + 1
        }
        prev = curr
        i = i + 1
    }

    prev[n]
}

// ── levenshtein_ratio_pure ──────────────────────────────────────────
// Returns similarity ratio: 1.0 for identical strings, 0.0 for
// completely different. Formula: 1.0 - dist / max(len(a), len(b)).
// Two empty strings => 1.0 (identical by convention).
pub fn levenshtein_ratio_pure(a, b) {
    if type_of(a) != "string" { return 0.0 }
    if type_of(b) != "string" { return 0.0 }
    let a_len = len(a)
    let b_len = len(b)
    if a_len == 0 && b_len == 0 { return 1.0 }
    let mx = if a_len > b_len { a_len } else { b_len }
    let dist = levenshtein_pure(a, b)
    1.0 - (dist * 1.0) / (mx * 1.0)
}

// ── hamming_pure ────────────────────────────────────────────────────
// Hamming distance: counts positions where characters differ.
// Requires equal-length strings; returns -1 if lengths differ.
pub fn hamming_pure(a, b) {
    if type_of(a) != "string" { return -1 }
    if type_of(b) != "string" { return -1 }
    let a_len = len(a)
    let b_len = len(b)
    if a_len != b_len { return -1 }
    let mut dist = 0
    let mut i = 0
    while i < a_len {
        if a.substring(i, i + 1) != b.substring(i, i + 1) {
            dist = dist + 1
        }
        i = i + 1
    }
    dist
}
