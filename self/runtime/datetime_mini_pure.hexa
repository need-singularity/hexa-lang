// ═══════════════════════════════════════════════════════════════════
//  self/runtime/datetime_mini_pure.hexa — Batch 23 calendar mini
//
//  Five net-new pure-Hexa calendar builtins returning int-encoded
//  results (1/0 for bool, day counts, weekday indices). Proleptic
//  Gregorian calendar — correct for any positive year ≥ 1.
//
//  Kept separate from self/runtime/datetime_pure.hexa (which exports
//  bool-returning is_leap_year_pure + Sun-indexed day_of_week_pure
//  and is already used by self/hexa_full.hexa) so the Batch 23 int
//  API can coexist without breaking upstream imports.
//
//  Public API:
//      is_leap_year_pure(y)              -> int   (1 if leap, else 0)
//      days_in_month_pure(y, m)          -> int   (28/29/30/31)
//      day_of_year_pure(y, m, d)         -> int   (1..366)
//      days_between_pure(y1,m1,d1,
//                        y2,m2,d2)       -> int   (signed, b - a)
//      weekday_zeller_pure(y, m, d)      -> int   (0=Sat..6=Fri)
//
//  Weekday convention:
//      Zeller's original — 0=Saturday, 1=Sunday, 2=Monday, 3=Tuesday,
//      4=Wednesday, 5=Thursday, 6=Friday.
//      (April 17, 2026 → 6 = Friday.)
//
//  Golden cases honored (from task spec):
//      is_leap_year_pure(2000) == 1      (4/100/400 rule)
//      is_leap_year_pure(1900) == 0      (century not divisible by 400)
//      days_in_month_pure(2024, 2) == 29 (2024 is leap)
//      weekday_zeller_pure(2026, 4, 17) == 6   (Friday)
//      days_between_pure(2026,1,1, 2026,4,17) == 106
//
//  P50/P51 constraints:
//      - string concat only via `+`, no `|` tricks
//      - no reserved idents as names (pure/with/move/...)
//      - private helpers prefixed `_dt_` to avoid clashes with
//        datetime_pure.hexa's is_leap_year_impl / days_in_month_impl
//      - integer arithmetic only (+, -, *, /, %), no bit ops
// ═══════════════════════════════════════════════════════════════════

// ── internal: leap predicate as int (1/0) ───────────────────────────
@pure
fn _dt_mini_is_leap(year) {
    if (year % 4) != 0 { return 0 }
    if (year % 100) != 0 { return 1 }
    if (year % 400) != 0 { return 0 }
    return 1
}

// ── internal: days in a given month (1..12) ─────────────────────────
@pure
fn _dt_mini_dim(year, month) {
    if month == 1  { return 31 }
    if month == 3  { return 31 }
    if month == 5  { return 31 }
    if month == 7  { return 31 }
    if month == 8  { return 31 }
    if month == 10 { return 31 }
    if month == 12 { return 31 }
    if month == 4  { return 30 }
    if month == 6  { return 30 }
    if month == 9  { return 30 }
    if month == 11 { return 30 }
    if month == 2 {
        if _dt_mini_is_leap(year) == 1 { return 29 }
        return 28
    }
    return 0
}

// ═══════════════════════════════════════════════════════════════════
//  1. is_leap_year_pure — Gregorian leap test, int (1/0) result
// ═══════════════════════════════════════════════════════════════════
//   Rule: divisible by 4, except centuries not divisible by 400.
//     1900 → 0, 2000 → 1, 2024 → 1, 2023 → 0.
@pure
pub fn is_leap_year_pure(y) {
    return _dt_mini_is_leap(y)
}

// ═══════════════════════════════════════════════════════════════════
//  2. days_in_month_pure — days in month m of year y (m: 1..12)
// ═══════════════════════════════════════════════════════════════════
//   Returns 28/29/30/31. Returns 0 for out-of-range month.
//   Feb flips to 29 on leap years.
@pure
pub fn days_in_month_pure(y, m) {
    return _dt_mini_dim(y, m)
}

// ═══════════════════════════════════════════════════════════════════
//  3. day_of_year_pure — ordinal day within the year (1..366)
// ═══════════════════════════════════════════════════════════════════
//   Sum full months preceding m, then add d. Jan 1 → 1, Dec 31 → 365
//   (or 366 on leap years). No validity check — caller's responsibility
//   to pass m ∈ [1,12] and d ∈ [1, days_in_month_pure(y,m)].
@pure
pub fn day_of_year_pure(y, m, d) {
    let mut total = 0
    let mut mm = 1
    while mm < m {
        total = total + _dt_mini_dim(y, mm)
        mm = mm + 1
    }
    return total + d
}

// ═══════════════════════════════════════════════════════════════════
//  4. days_between_pure — signed day count b - a
// ═══════════════════════════════════════════════════════════════════
//   Uses Howard Hinnant's civil_from_days / days_from_civil algorithm:
//     shifted March-based year so leap-day falls at the end:
//        y'   = y - (m <= 2)
//        era  = floor(y' / 400)       [negative-aware]
//        yoe  = y' - era*400          [0..399]
//        doy  = (153*mp + 2)/5 + d - 1 where mp = (m + 9) % 12
//        doe  = yoe*365 + yoe/4 - yoe/100 + doy
//        days = era*146097 + doe - 719468
//     (719468 anchors 1970-01-01 = 0.)
//
//   Exact, O(1), handles BC / AD transitions and 400-year cycle.
@pure
fn _dt_mini_days_from_civil(y, m, d) {
    let mut yy = y
    if m <= 2 { yy = yy - 1 }
    // integer floor division for negative values: y' / 400 but rounded toward -inf
    let mut era = 0
    if yy >= 0 {
        era = yy / 400
    } else {
        era = (yy - 399) / 400
    }
    let yoe = yy - era * 400
    let mp = (m + 9) % 12
    let doy = (153 * mp + 2) / 5 + d - 1
    let doe = yoe * 365 + yoe / 4 - yoe / 100 + doy
    return era * 146097 + doe - 719468
}

@pure
pub fn days_between_pure(y1, m1, d1, y2, m2, d2) {
    let a = _dt_mini_days_from_civil(y1, m1, d1)
    let b = _dt_mini_days_from_civil(y2, m2, d2)
    return b - a
}

// ═══════════════════════════════════════════════════════════════════
//  5. weekday_zeller_pure — Zeller's congruence, 0=Sat..6=Fri
// ═══════════════════════════════════════════════════════════════════
//   Formula (ISO / Zeller 1882):
//       if m < 3 then m += 12, y -= 1
//       K = y mod 100
//       J = y / 100
//       h = (q + floor(13(m+1)/5) + K + floor(K/4) + floor(J/4) + 5J) mod 7
//
//   Produces h with convention:
//       0 = Saturday, 1 = Sunday, 2 = Monday, 3 = Tuesday,
//       4 = Wednesday, 5 = Thursday, 6 = Friday.
//
//   Uses +5J form (mathematically equivalent to -2J but always
//   yields a non-negative h for non-negative inputs — avoids the
//   language-dependent sign-of-modulo trap on negative remainders).
@pure
pub fn weekday_zeller_pure(y, m, d) {
    let mut yy = y
    let mut mm = m
    if mm < 3 {
        mm = mm + 12
        yy = yy - 1
    }
    let k = yy % 100
    let j = yy / 100
    let h = (d + (13 * (mm + 1)) / 5 + k + k / 4 + j / 4 + 5 * j) % 7
    return h
}
