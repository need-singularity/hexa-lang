// ═══════════════════════════════════════════════════════════════════
//  self/runtime/conv_pure.hexa — type conversion helpers (pure hexa)
//
//  Unified type-coercion and base-conversion module. Replaces the
//  scattered C runtime helpers for type conversion:
//    hexa_str_parse_int   (runtime.c:4014) — see also parse_pure.hexa
//    hexa_str_parse_float (runtime.c:4026) — see also parse_pure.hexa
//    hexa_hex             (runtime.c:4350) — see also hex_pure.hexa
//    hexa_bin             (runtime.c:4339) — see also string_pure.hexa
//    hexa_truthy          (runtime.c:2505) — see also value_pure.hexa
//    hexa_to_string       (runtime.c:2474) — see also value_pure.hexa
//    hexa_from_char_code  (runtime.c:4262)
//    hexa_char_code       (runtime.c:3991)
//
//  This module adds the conversions NOT yet present in any pure file:
//    int_to_oct_pure   — integer to octal string (no C counterpart)
//    to_int_pure       — coerce any value to int
//    to_float_pure     — coerce any value to float
//    to_bool_pure      — coerce any value to bool (truthy)
//    char_to_int_pure  — single-char string to ASCII code
//    int_to_char_pure  — ASCII code to single-char string
//
//  And re-exports core converters that delegate to the canonical
//  implementations in sibling modules, providing a single-import
//  convenience API:
//    parse_int_pure    — from parse_pure.hexa (re-implemented inline)
//    parse_float_pure  — from parse_pure.hexa (re-implemented inline)
//    int_to_hex_pure   — from hex_pure.hexa   (re-implemented inline)
//    int_to_bin_pure   — from string_pure.hexa (re-implemented inline)
//
//  Pitfalls honored (CLAUDE.md HX3 + grammar.jsonl):
//    P1   no semicolons
//    P15  let mut everywhere (no bare let for mutated vars)
//    P29  .push() returns NEW array — must rebind
//    P12  `handle` is reserved keyword — avoid as param name
//    P38  char_code(s, i>0) broken — use s.bytes() or substring+ord
//    P39  no 0b binary literals
//    + while loops only, no for-in-range
// ═══════════════════════════════════════════════════════════════════

// ── parse_int_pure ───────────────────────────────────────────────
// String to int. Handles "0x"/"0X" hex prefix. Skips leading
// whitespace, accepts optional +/- sign. Non-parseable returns 0.
// Mirrors hexa_str_parse_int (runtime.c:4014).
@pure
pub fn parse_int_pure(s) {
    if type_of(s) != "string" { return 0 }
    let n = len(s)
    if n == 0 { return 0 }

    // Skip leading whitespace.
    let mut i = 0
    while i < n {
        let ch = s.substring(i, i + 1)
        if ch == " " || ch == "\t" || ch == "\n" || ch == "\r" {
            i = i + 1
        } else {
            break
        }
    }
    if i >= n { return 0 }

    // Optional sign.
    let mut sign = 1
    let ch0 = s.substring(i, i + 1)
    if ch0 == "+" {
        i = i + 1
    } else if ch0 == "-" {
        sign = 0 - 1
        i = i + 1
    }

    // Detect 0x / 0X prefix for hex.
    let mut base = 10
    if (i + 1) < n {
        let p0 = s.substring(i, i + 1)
        let p1 = s.substring(i + 1, i + 2)
        if p0 == "0" && (p1 == "x" || p1 == "X") {
            base = 16
            i = i + 2
        }
    }

    let ord0 = ord("0")
    let ord9 = ord("9")
    let orda = ord("a")
    let ordf = ord("f")
    let ordA = ord("A")
    let ordF = ord("F")

    let mut val = 0
    let mut consumed = false
    while i < n {
        let c = ord(s.substring(i, i + 1))
        let mut digit = 0 - 1
        if c >= ord0 && c <= ord9 {
            digit = c - ord0
        }
        if base == 16 && digit < 0 {
            if c >= orda && c <= ordf {
                digit = c - orda + 10
            } else if c >= ordA && c <= ordF {
                digit = c - ordA + 10
            }
        }
        if digit < 0 { break }
        if digit >= base { break }
        val = val * base + digit
        consumed = true
        i = i + 1
    }

    if consumed == false { return 0 }
    val * sign
}

// ── parse_float_pure ─────────────────────────────────────────────
// String to float. Handles sign, integer part, fractional part, and
// exponent (e/E with optional sign). Non-parseable returns 0.0.
// Mirrors hexa_str_parse_float (runtime.c:4026).
@pure
pub fn parse_float_pure(s) {
    if type_of(s) != "string" { return 0.0 }
    let n = len(s)
    if n == 0 { return 0.0 }

    // Skip leading whitespace.
    let mut i = 0
    while i < n {
        let ch = s.substring(i, i + 1)
        if ch == " " || ch == "\t" || ch == "\n" || ch == "\r" {
            i = i + 1
        } else {
            break
        }
    }
    if i >= n { return 0.0 }

    // Sign.
    let mut sign = 1.0
    let ch0 = s.substring(i, i + 1)
    if ch0 == "+" {
        i = i + 1
    } else if ch0 == "-" {
        sign = 0.0 - 1.0
        i = i + 1
    }

    let ord0 = ord("0")
    let ord9 = ord("9")

    let mut val = 0.0
    let mut consumed = false

    // Integer part.
    while i < n {
        let c = ord(s.substring(i, i + 1))
        if c < ord0 || c > ord9 { break }
        val = val * 10.0 + to_float(c - ord0)
        consumed = true
        i = i + 1
    }

    // Fractional part.
    if i < n {
        let dot = s.substring(i, i + 1)
        if dot == "." {
            i = i + 1
            let mut pw = 0.1
            while i < n {
                let cf = ord(s.substring(i, i + 1))
                if cf < ord0 || cf > ord9 { break }
                val = val + to_float(cf - ord0) * pw
                pw = pw / 10.0
                consumed = true
                i = i + 1
            }
        }
    }

    if consumed == false { return 0.0 }

    // Exponent.
    if i < n {
        let ce = s.substring(i, i + 1)
        if ce == "e" || ce == "E" {
            let mut j = i + 1
            let mut exp_sign = 1
            if j < n {
                let cs = s.substring(j, j + 1)
                if cs == "+" {
                    j = j + 1
                } else if cs == "-" {
                    exp_sign = 0 - 1
                    j = j + 1
                }
            }
            let mut exp_val = 0
            let mut exp_seen = false
            while j < n {
                let cd = ord(s.substring(j, j + 1))
                if cd < ord0 || cd > ord9 { break }
                exp_val = exp_val * 10 + (cd - ord0)
                exp_seen = true
                j = j + 1
            }
            if exp_seen {
                let mut k = 0
                if exp_sign > 0 {
                    while k < exp_val {
                        val = val * 10.0
                        k = k + 1
                    }
                } else {
                    while k < exp_val {
                        val = val / 10.0
                        k = k + 1
                    }
                }
            }
        }
    }

    val * sign
}

// ── int_to_hex_pure ──────────────────────────────────────────────
// Non-negative int to lowercase hex string. Mirrors hexa_hex
// (runtime.c:4350). Negative inputs prefix with "-".
@pure
pub fn int_to_hex_pure(n) {
    if type_of(n) != "int" { return "0" }
    if n == 0 { return "0" }
    let digits = "0123456789abcdef"
    let mut v = n
    let mut neg = false
    if v < 0 {
        neg = true
        v = 0 - v
    }
    let mut out = ""
    while v > 0 {
        let d = v % 16
        out = digits.substring(d, d + 1) + out
        v = v / 16
    }
    if neg { return "-" + out }
    out
}

// ── int_to_bin_pure ──────────────────────────────────────────────
// Non-negative int to binary string. Mirrors hexa_bin
// (runtime.c:4339). Negative inputs prefix with "-".
// NOTE: does NOT use 0b prefix (pitfall P39).
@pure
pub fn int_to_bin_pure(n) {
    if type_of(n) != "int" { return "0" }
    if n == 0 { return "0" }
    let mut v = n
    let mut neg = false
    if v < 0 {
        neg = true
        v = 0 - v
    }
    let mut out = ""
    while v > 0 {
        let bit = v % 2
        if bit == 0 { out = "0" + out } else { out = "1" + out }
        v = v / 2
    }
    if neg { return "-" + out }
    out
}

// ── int_to_oct_pure ──────────────────────────────────────────────
// Non-negative int to octal string. No direct C counterpart in
// runtime.c — this is a new pure-hexa-only addition.
@pure
pub fn int_to_oct_pure(n) {
    if type_of(n) != "int" { return "0" }
    if n == 0 { return "0" }
    let digits = "01234567"
    let mut v = n
    let mut neg = false
    if v < 0 {
        neg = true
        v = 0 - v
    }
    let mut out = ""
    while v > 0 {
        let d = v % 8
        out = digits.substring(d, d + 1) + out
        v = v / 8
    }
    if neg { return "-" + out }
    out
}

// ── to_int_pure ──────────────────────────────────────────────────
// Coerce any value to int. Mirrors the coercion rules used across
// the C runtime:
//   int      -> identity
//   float    -> truncate toward zero (floor for positive, ceil for neg)
//   string   -> parse_int_pure (with hex auto-detect)
//   bool     -> true=1, false=0
//   void     -> 0
//   other    -> 0
@pure
pub fn to_int_pure(v) {
    let t = type_of(v)
    if t == "int" { return v }
    if t == "float" {
        // Truncate toward zero: subtract fractional part.
        // For positive: floor. For negative: ceil.
        if v >= 0.0 {
            // integer part by subtracting fractional
            let mut result = 0
            let mut remaining = v
            let mut power = 1
            // Find the magnitude
            while to_float(power) * 10.0 <= remaining {
                power = power * 10
            }
            while power >= 1 {
                let d = 0
                let fp = to_float(power)
                let mut digit = 0
                while to_float(digit + 1) * fp <= remaining {
                    digit = digit + 1
                }
                result = result + digit * power
                remaining = remaining - to_float(digit) * fp
                power = power / 10
            }
            return result
        } else {
            // For negative: negate, truncate, then negate back.
            let pos = 0.0 - v
            let mut result = 0
            let mut remaining = pos
            let mut power = 1
            while to_float(power) * 10.0 <= remaining {
                power = power * 10
            }
            while power >= 1 {
                let mut digit = 0
                let fp = to_float(power)
                while to_float(digit + 1) * fp <= remaining {
                    digit = digit + 1
                }
                result = result + digit * power
                remaining = remaining - to_float(digit) * fp
                power = power / 10
            }
            return 0 - result
        }
    }
    if t == "bool" {
        if v { return 1 }
        return 0
    }
    if t == "string" { return parse_int_pure(v) }
    // void, array, map, function, etc.
    0
}

// ── to_float_pure ────────────────────────────────────────────────
// Coerce any value to float. Rules:
//   float    -> identity
//   int      -> int + 0.0
//   string   -> parse_float_pure
//   bool     -> true=1.0, false=0.0
//   void     -> 0.0
//   other    -> 0.0
@pure
pub fn to_float_pure(v) {
    let t = type_of(v)
    if t == "float" { return v }
    if t == "int" { return v + 0.0 }
    if t == "bool" {
        if v { return 1.0 }
        return 0.0
    }
    if t == "string" { return parse_float_pure(v) }
    // void, array, map, function, etc.
    0.0
}

// ── to_bool_pure ─────────────────────────────────────────────────
// Coerce any value to bool (truthy check). Mirrors hexa_truthy
// (runtime.c:2505) and value_truthy_pure (value_pure.hexa).
//   int      -> v != 0
//   float    -> v != 0.0
//   string   -> len > 0
//   bool     -> identity
//   array    -> len > 0
//   map      -> key count > 0
//   void     -> false
//   function -> true
@pure
pub fn to_bool_pure(v) {
    let t = type_of(v)
    if t == "void" { return false }
    if t == "bool" { return v }
    if t == "int" { return v != 0 }
    if t == "float" { return v != 0.0 }
    if t == "string" { return len(v) > 0 }
    if t == "array" { return len(v) > 0 }
    if t == "map" {
        let ks = keys(v)
        return len(ks) > 0
    }
    // function, struct, etc. -> true
    true
}

// ── char_to_int_pure ─────────────────────────────────────────────
// Single-character string to its ASCII/byte code. Mirrors
// hexa_char_code(s, 0) (runtime.c:3991).
// Uses s.bytes() to avoid the char_code(s, i>0) bug (P38).
// Returns 0 for empty strings or non-string inputs.
@pure
pub fn char_to_int_pure(c) {
    if type_of(c) != "string" { return 0 }
    if len(c) == 0 { return 0 }
    // Use ord on the first character via substring to be safe.
    ord(c.substring(0, 1))
}

// ── int_to_char_pure ─────────────────────────────────────────────
// ASCII/byte code to single-character string. Mirrors
// hexa_from_char_code (runtime.c:4262) for the ASCII range.
// Delegates to from_char_code builtin for the actual char creation.
// Returns "" for out-of-range inputs.
@pure
pub fn int_to_char_pure(n) {
    if type_of(n) != "int" { return "" }
    if n < 0 { return "" }
    if n > 127 { return "" }
    from_char_code(n)
}

// ── digit_to_char_pure ───────────────────────────────────────────
// Converts a digit value (0-35) to its character representation.
// 0-9 -> "0"-"9", 10-35 -> "a"-"z". Useful for arbitrary base
// conversion. Returns "" for out-of-range.
@pure
pub fn digit_to_char_pure(d) {
    if type_of(d) != "int" { return "" }
    if d < 0 { return "" }
    let digits = "0123456789abcdefghijklmnopqrstuvwxyz"
    if d >= 36 { return "" }
    digits.substring(d, d + 1)
}

// ── char_to_digit_pure ───────────────────────────────────────────
// Converts a character to its digit value. "0"-"9" -> 0-9,
// "a"-"f"/"A"-"F" -> 10-15. Returns -1 for non-digit characters.
@pure
pub fn char_to_digit_pure(c) {
    if type_of(c) != "string" { return -1 }
    if len(c) == 0 { return -1 }
    let o = ord(c.substring(0, 1))
    if o >= 48 && o <= 57 { return o - 48 }
    if o >= 97 && o <= 102 { return o - 97 + 10 }
    if o >= 65 && o <= 70 { return o - 65 + 10 }
    -1
}

// ── int_to_base_pure ─────────────────────────────────────────────
// General base conversion: int to string in any base 2-36.
// Builds on digit_to_char_pure.
@pure
pub fn int_to_base_pure(n, base) {
    if type_of(n) != "int" { return "0" }
    if base < 2 || base > 36 { return "0" }
    if n == 0 { return "0" }
    let mut v = n
    let mut neg = false
    if v < 0 {
        neg = true
        v = 0 - v
    }
    let mut out = ""
    while v > 0 {
        let d = v % base
        out = digit_to_char_pure(d) + out
        v = v / base
    }
    if neg { return "-" + out }
    out
}

// ── is_int_string_pure ───────────────────────────────────────────
// Returns true if the string can be parsed as an integer (decimal
// or hex). Does not consume the value.
@pure
pub fn is_int_string_pure(s) {
    if type_of(s) != "string" { return false }
    let n = len(s)
    if n == 0 { return false }

    let mut i = 0
    // Skip whitespace.
    while i < n {
        let ch = s.substring(i, i + 1)
        if ch == " " || ch == "\t" || ch == "\n" || ch == "\r" {
            i = i + 1
        } else {
            break
        }
    }
    if i >= n { return false }

    // Optional sign.
    let ch0 = s.substring(i, i + 1)
    if ch0 == "+" || ch0 == "-" { i = i + 1 }
    if i >= n { return false }

    // At least one digit must follow.
    let c = ord(s.substring(i, i + 1))
    c >= 48 && c <= 57
}

// ── is_float_string_pure ─────────────────────────────────────────
// Returns true if the string looks like a float (has a dot or
// exponent marker).
@pure
pub fn is_float_string_pure(s) {
    if type_of(s) != "string" { return false }
    let n = len(s)
    let mut i = 0
    let mut has_dot = false
    let mut has_e = false
    let mut has_digit = false
    while i < n {
        let ch = s.substring(i, i + 1)
        if ch == "." { has_dot = true }
        if ch == "e" || ch == "E" { has_e = true }
        let o = ord(ch)
        if o >= 48 && o <= 57 { has_digit = true }
        i = i + 1
    }
    has_digit && (has_dot || has_e)
}

// ── clamp_int_pure ───────────────────────────────────────────────
// Clamps an integer to [lo, hi] range. Convenience for bounds
// checking after type conversion.
@pure
pub fn clamp_int_pure(v, lo, hi) {
    if v < lo { return lo }
    if v > hi { return hi }
    v
}

// ── clamp_float_pure ─────────────────────────────────────────────
// Clamps a float to [lo, hi] range.
@pure
pub fn clamp_float_pure(v, lo, hi) {
    if v < lo { return lo }
    if v > hi { return hi }
    v
}
