// self/runtime/json_mini_pure.hexa -- Phase 2.x runtime port (JSON mini)
//
// Pure-Hexa JSON mini subset — pragmatic encoder + simple unescape.
//
// Scope (by design, to keep surface small and self-host-safe):
//   * ASCII / byte-oriented — no \uXXXX emission, no unicode escapes
//   * integers only (no scientific-notation floats)
//   * string, int, int-array, string-array, and {string: int} object
//
// Escape rules match the JSON RFC minimum set:
//   " -> \"
//   \ -> \\
//   / -> \/      (optional per spec, we emit for solidus safety)
//   \n -> \n
//   \r -> \r
//   \t -> \t
//   \b -> \b
//   \f -> \f
//   other control bytes (< 0x20) are passed through as-is
//     (caller should avoid binary input; this is a mini codec)
//
// Pitfalls observed:
//   P15 let mut
//   P50 no <<, >>
//   @pure only on private helpers — pub entrypoints stay un-annotated
//
// Sibling of: base64_pure, hex_pure, encoding_pure.

// ── _json_escape_char (internal) — one char → escaped form ────────
@pure fn _json_escape_char(c) {
    let o = ord(c)
    if o == 34 { return "\\\"" }     //  "
    if o == 92 { return "\\\\" }     //  \
    if o == 47 { return "\\/" }      //  /
    if o == 10 { return "\\n" }
    if o == 13 { return "\\r" }
    if o == 9  { return "\\t" }
    if o == 8  { return "\\b" }
    if o == 12 { return "\\f" }
    c
}

// ── _json_escape_body (internal) — escape chars, no surrounding quotes
@pure fn _json_escape_body(s) {
    let n = len(s)
    let mut parts = []
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        parts.push(_json_escape_char(c))
        i = i + 1
    }
    parts.join("")
}

// ── json_escape_string_pure — escape + wrap in double quotes ──────
// Mirrors the common JSON string serializer: returns the *quoted*
// JSON literal (e.g. `hi"there` -> `"hi\"there"`).
pub fn json_escape_string_pure(s) {
    if type_of(s) != "string" { return "\"\"" }
    "\"" + _json_escape_body(s) + "\""
}

// ── json_encode_int_pure — integer → decimal string ───────────────
// Accepts int only; returns "0" for non-ints so caller gets a valid
// JSON token instead of a parse error. Mirrors `to_string` behavior
// for ints but with a defensive type guard.
pub fn json_encode_int_pure(n) {
    if type_of(n) != "int" { return "0" }
    to_string(n)
}

// ── json_encode_string_array_pure — ["a","b","c"] ─────────────────
// Each element is JSON-escaped and wrapped. Non-string elements are
// coerced through `to_string` then escaped.
pub fn json_encode_string_array_pure(arr) {
    if type_of(arr) != "array" { return "[]" }
    let n = len(arr)
    let mut parts = []
    parts.push("[")
    let mut i = 0
    while i < n {
        let e = arr[i]
        let es = if type_of(e) == "string" { e } else { to_string(e) }
        parts.push("\"")
        parts.push(_json_escape_body(es))
        parts.push("\"")
        if i + 1 < n { parts.push(",") }
        i = i + 1
    }
    parts.push("]")
    parts.join("")
}

// ── json_format_object_int_pure — {"k":v,...} parallel arrays ─────
// `keys` are escaped strings; `values` are ints. If arrays differ in
// length, iterate to the shorter length.
pub fn json_format_object_int_pure(keys, values) {
    if type_of(keys) != "array" { return "{}" }
    if type_of(values) != "array" { return "{}" }
    let nk = len(keys)
    let nv = len(values)
    let n = if nk < nv { nk } else { nv }
    let mut parts = []
    parts.push("{")
    let mut i = 0
    while i < n {
        let k = keys[i]
        let v = values[i]
        let ks = if type_of(k) == "string" { k } else { to_string(k) }
        parts.push("\"")
        parts.push(_json_escape_body(ks))
        parts.push("\":")
        parts.push(json_encode_int_pure(v))
        if i + 1 < n { parts.push(",") }
        i = i + 1
    }
    parts.push("}")
    parts.join("")
}

// ── json_unescape_string_pure — inverse of json_escape_string_pure
// Accepts the *quoted* form (with surrounding `"…"`) and returns the
// raw string. If the input is not quoted or not a string, returns "".
// Unknown escape sequences are passed through as the literal char
// after the backslash (JSON would normally error; we are lenient).
// Does NOT handle \uXXXX (per module scope).
pub fn json_unescape_string_pure(s) {
    if type_of(s) != "string" { return "" }
    let n = len(s)
    if n < 2 { return "" }
    if s.substring(0, 1) != "\"" { return "" }
    if s.substring(n - 1, n) != "\"" { return "" }
    let mut parts = []
    let mut i = 1
    let end = n - 1
    while i < end {
        let c = s.substring(i, i + 1)
        if c == "\\" && (i + 1) < end {
            let esc = s.substring(i + 1, i + 2)
            if esc == "\"" { parts.push("\"") }
            else if esc == "\\" { parts.push("\\") }
            else if esc == "/" { parts.push("/") }
            else if esc == "n" { parts.push("\n") }
            else if esc == "r" { parts.push("\r") }
            else if esc == "t" { parts.push("\t") }
            else if esc == "b" { parts.push(from_char_code(8)) }
            else if esc == "f" { parts.push(from_char_code(12)) }
            else { parts.push(esc) }
            i = i + 2
        } else {
            parts.push(c)
            i = i + 1
        }
    }
    parts.join("")
}
