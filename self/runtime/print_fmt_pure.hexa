// ═══════════════════════════════════════════════════════════════════
//  self/runtime/print_fmt_pure.hexa — table/tree pretty-print mini
//
//  Five pure-Hexa pretty printers for human-readable CLI output.
//  All ASCII / UTF-8 box-drawing, no runtime.c dependency, no FFI.
//
//  Public API:
//      table_render_pure(rows, headers) -> str
//          Pipe-separated `| a | b |` table with `|---|---|` underline.
//      tree_render_pure(edges, root)    -> str
//          ASCII tree from parent→child edges using ├── └── │   .
//      box_render_pure(lines)           -> str
//          Unicode box ┌─┐│└─┘ around the provided text block.
//      align_cols_pure(rows)            -> [[str]]
//          Left-aligned column padding to max width (spaces).
//      truncate_ellipsis_pure(s, max)   -> str
//          "hello world" max=7 → "hell..." (keep max-3 chars + "...").
//
//  Constraints honored (CLAUDE.md P50/P51):
//      * no `|` tricks for concat — always `+`
//      * no reserved keywords as identifiers (with/handle/own/move/drop/
//        guard/scope/defer/typeof/pure/proof/theorem/effect)
//      * .push() returns new array — always rebind
//      * parts.join("") over repeated concat for loops
//      * substring(i, i+1) + ord() for byte-level char handling
// ═══════════════════════════════════════════════════════════════════

// ── internal: repeat string ──────────────────────────────────────────
@pure
fn _pf_repeat(s, n) {
    if n <= 0 { return "" }
    let mut parts = []
    let mut i = 0
    while i < n {
        parts = parts.push(s)
        i = i + 1
    }
    return parts.join("")
}

// ── internal: left-pad right (append spaces to reach width) ─────────
@pure
fn _pf_pad_right(s, width) {
    let slen = len(s)
    if slen >= width { return s }
    return s + _pf_repeat(" ", width - slen)
}

// ── internal: max-of-column over rows (treats missing cells as "") ──
@pure
fn _pf_col_width(rows, col) {
    let n = len(rows)
    let mut w = 0
    let mut i = 0
    while i < n {
        let row = rows[i]
        if col < len(row) {
            let cl = len(row[col])
            if cl > w { w = cl }
        }
        i = i + 1
    }
    return w
}

// ── internal: number of columns (= max row length) ──────────────────
@pure
fn _pf_max_cols(rows) {
    let n = len(rows)
    let mut mc = 0
    let mut i = 0
    while i < n {
        let rl = len(rows[i])
        if rl > mc { mc = rl }
        i = i + 1
    }
    return mc
}

// ═══════════════════════════════════════════════════════════════════
//  1. align_cols_pure — pad each column to max width (left-align)
// ═══════════════════════════════════════════════════════════════════
// Returns a new 2D array where every row has the same number of
// columns (= max row length) and every cell is padded with spaces on
// the right to the per-column max width. Missing cells become padded
// empty strings so downstream table/box renderers have rectangular
// input.
@pure
pub fn align_cols_pure(rows) {
    let n = len(rows)
    if n == 0 { return [] }
    let ncols = _pf_max_cols(rows)
    // Pre-compute column widths.
    let mut widths = []
    let mut c = 0
    while c < ncols {
        widths = widths.push(_pf_col_width(rows, c))
        c = c + 1
    }
    // Build padded output row-by-row.
    let mut out = []
    let mut i = 0
    while i < n {
        let row = rows[i]
        let rl = len(row)
        let mut new_row = []
        let mut j = 0
        while j < ncols {
            let cell = if j < rl { row[j] } else { "" }
            new_row = new_row.push(_pf_pad_right(cell, widths[j]))
            j = j + 1
        }
        out = out.push(new_row)
        i = i + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════════
//  2. truncate_ellipsis_pure — shorten with trailing "..."
// ═══════════════════════════════════════════════════════════════════
// Semantics (per task spec):
//   "hello world" max=7 → "hell..."  (keep max-3 chars, append "...")
//   len(s) <= max        → s unchanged
//   max <= 3             → plain prefix of length max (no ellipsis)
//   max <= 0             → ""
@pure
pub fn truncate_ellipsis_pure(s, max) {
    if max <= 0 { return "" }
    let slen = len(s)
    if slen <= max { return s }
    if max <= 3 { return s.substring(0, max) }
    return s.substring(0, max - 3) + "..."
}

// ═══════════════════════════════════════════════════════════════════
//  3. table_render_pure — markdown-style pipe table
// ═══════════════════════════════════════════════════════════════════
// Output shape (2 rows, 2 cols):
//   | a   | bb  |
//   |-----|-----|
//   | ccc | d   |
//
// Column width = max(header_w, data_col_w). Cells are left-aligned
// with a single leading/trailing space inside pipes (matches common
// markdown conventions). Underline uses `-` repeated to column width.
// Missing data cells render as empty padding.
@pure
fn _pf_render_row(cells, widths) {
    let n = len(widths)
    let mut parts = ["|"]
    let mut j = 0
    while j < n {
        let cell = if j < len(cells) { cells[j] } else { "" }
        parts = parts.push(" ")
        parts = parts.push(_pf_pad_right(cell, widths[j]))
        parts = parts.push(" |")
        j = j + 1
    }
    return parts.join("")
}

@pure
fn _pf_render_sep(widths) {
    let n = len(widths)
    let mut parts = ["|"]
    let mut j = 0
    while j < n {
        parts = parts.push(_pf_repeat("-", widths[j] + 2))
        parts = parts.push("|")
        j = j + 1
    }
    return parts.join("")
}

@pure
pub fn table_render_pure(rows, headers) {
    let nh = len(headers)
    let nr = len(rows)
    // Determine per-column width = max(header_len, data_col_max)
    let data_cols = _pf_max_cols(rows)
    let ncols = if nh > data_cols { nh } else { data_cols }
    let mut widths = []
    let mut c = 0
    while c < ncols {
        let hw = if c < nh { len(headers[c]) } else { 0 }
        let dw = _pf_col_width(rows, c)
        let w = if hw > dw { hw } else { dw }
        widths = widths.push(w)
        c = c + 1
    }
    let mut lines = []
    // Always render a header row — empty headers become "" padded.
    lines = lines.push(_pf_render_row(headers, widths))
    lines = lines.push(_pf_render_sep(widths))
    let mut i = 0
    while i < nr {
        lines = lines.push(_pf_render_row(rows[i], widths))
        i = i + 1
    }
    return lines.join("\n")
}

// ═══════════════════════════════════════════════════════════════════
//  4. box_render_pure — unicode-boxed text block
// ═══════════════════════════════════════════════════════════════════
// Draws ┌─┐ / │ │ / └─┘ around the widest line in `lines`. Each line
// is left-aligned and right-padded to the max width so the right │
// lines up.
//
// Empty input → four-char box "┌┐\n└┘" (degenerate but well-defined).
@pure
pub fn box_render_pure(lines) {
    let n = len(lines)
    let mut max_w = 0
    let mut i = 0
    while i < n {
        let lw = len(lines[i])
        if lw > max_w { max_w = lw }
        i = i + 1
    }
    let tl = "┌"
    let tr = "┐"
    let bl = "└"
    let br = "┘"
    let horiz = "─"
    let vert = "│"
    let top = tl + _pf_repeat(horiz, max_w) + tr
    let bottom = bl + _pf_repeat(horiz, max_w) + br
    let mut parts = [top]
    let mut k = 0
    while k < n {
        let padded = _pf_pad_right(lines[k], max_w)
        parts = parts.push(vert + padded + vert)
        k = k + 1
    }
    parts = parts.push(bottom)
    return parts.join("\n")
}

// ═══════════════════════════════════════════════════════════════════
//  5. tree_render_pure — ASCII tree from parent→child edges
// ═══════════════════════════════════════════════════════════════════
// Input: edges is an array of [parent_int, child_int] pairs.
// Renders a tree rooted at `root` using `├── `, `└── ` for branch
// heads and `│   ` / `    ` for continuation columns.
//
// Children of a node are visited in the order they appear in `edges`.
// Cycles and unknown roots yield a single root line (no recursion
// explosion — we only follow direct child edges from `edges`).

// ── internal: collect direct children of `node` (in edge order) ─────
@pure
fn _pf_children(edges, node) {
    let n = len(edges)
    let mut out = []
    let mut i = 0
    while i < n {
        let e = edges[i]
        if len(e) >= 2 {
            if e[0] == node {
                out = out.push(e[1])
            }
        }
        i = i + 1
    }
    return out
}

// ── internal: recursive builder, appends lines into `acc` ───────────
// prefix is the accumulated left column (made of "│   " / "    ").
// branch is the connector to the current node ("├── " or "└── " or
// "" for the root).
@pure
fn _pf_tree_build(edges, node, prefix, branch, acc) {
    let mut lines = acc
    lines = lines.push(prefix + branch + to_string(node))
    let kids = _pf_children(edges, node)
    let nk = len(kids)
    if nk == 0 { return lines }
    // Next-level prefix: replace the connector column with a
    // continuation "│   " if branch == "├── ", spaces otherwise.
    let mut next_prefix = prefix
    if branch == "├── " {
        next_prefix = prefix + "│   "
    } else {
        if branch == "└── " {
            next_prefix = prefix + "    "
        }
        // else: root (branch == "") → next_prefix stays "" (unused at root)
    }
    let mut i = 0
    while i < nk {
        let is_last = (i == nk - 1)
        let cb = if is_last { "└── " } else { "├── " }
        lines = _pf_tree_build(edges, kids[i], next_prefix, cb, lines)
        i = i + 1
    }
    return lines
}

@pure
pub fn tree_render_pure(edges, root) {
    let mut lines = _pf_tree_build(edges, root, "", "", [])
    return lines.join("\n")
}
