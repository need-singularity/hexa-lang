// self/runtime/lru_pure.hexa — Least Recently Used cache
//
// Pure-Hexa LRU cache using parallel arrays with recency ordering.
//
// API:
//   lru_new(capacity)       -> cache state [keys, vals, cap]
//   lru_get(cache, key)     -> [cache, value_or_nil]
//   lru_put(cache, key, val) -> cache
//   lru_size(cache)         -> int
//   lru_keys(cache)         -> array of keys (most recent last)
//
// Constraints honored (CLAUDE.md):
//   - No C dependencies, no FFI
//   - P1 no semicolons, P15 let mut everywhere
//   - .push() not arr + [x] in loops

// Cache layout: [keys_arr, vals_arr, capacity]
//   Most recently used is at the END of the arrays.

// ── lru_new ─────────────────────────────────────────────────────
@pure pub fn lru_new(capacity) {
    [[], [], capacity]
}

// ── _lru_find ───────────────────────────────────────────────────
fn _lru_find(keys, key) {
    let mut i = 0
    while i < len(keys) {
        if to_string(keys[i]) == to_string(key) { return i }
        i = i + 1
    }
    -1
}

// ── _lru_remove_at ──────────────────────────────────────────────
fn _lru_remove_at(arr, idx) {
    let mut out = []
    let mut i = 0
    while i < len(arr) {
        if i != idx {
            out = out.push(arr[i])
        }
        i = i + 1
    }
    out
}

// ── lru_get ─────────────────────────────────────────────────────
// Returns [new_cache, value]. Moves accessed key to end (most recent).
@pure pub fn lru_get(cache, key) {
    let keys = cache[0]
    let vals = cache[1]
    let cap = cache[2]
    let idx = _lru_find(keys, key)
    if idx == -1 {
        return [cache, nil]
    }
    let val = vals[idx]
    // move to end
    let new_keys = _lru_remove_at(keys, idx).push(keys[idx])
    let new_vals = _lru_remove_at(vals, idx).push(val)
    [[new_keys, new_vals, cap], val]
}

// ── lru_put ─────────────────────────────────────────────────────
@pure pub fn lru_put(cache, key, val) {
    let keys = cache[0]
    let vals = cache[1]
    let cap = cache[2]
    // update existing: remove and re-add at end
    let idx = _lru_find(keys, key)
    if idx != -1 {
        let k2 = _lru_remove_at(keys, idx).push(key)
        let v2 = _lru_remove_at(vals, idx).push(val)
        return [k2, v2, cap]
    }
    let mut k = keys
    let mut v = vals
    // evict LRU (index 0 = oldest)
    if len(k) >= cap {
        k = _lru_remove_at(k, 0)
        v = _lru_remove_at(v, 0)
    }
    k = k.push(key)
    v = v.push(val)
    [k, v, cap]
}

// ── lru_size ────────────────────────────────────────────────────
@pure pub fn lru_size(cache) {
    len(cache[0])
}

// ── lru_keys ────────────────────────────────────────────────────
@pure pub fn lru_keys(cache) {
    cache[0]
}
