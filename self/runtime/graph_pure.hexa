// self/runtime/graph_pure.hexa — Basic graph utilities
//
// Pure-Hexa adjacency-list graph: BFS, DFS, has_path, connected components.
//
// API:
//   graph_new(n)                -> adjacency list (array of arrays)
//   graph_add_edge(g, u, v)     -> adds undirected edge
//   graph_add_directed(g, u, v) -> adds directed edge
//   graph_bfs(g, start)         -> BFS visit order
//   graph_dfs(g, start)         -> DFS visit order
//   graph_has_path(g, src, dst) -> true if path exists
//   graph_num_components(g)     -> number of connected components
//
// Constraints honored (CLAUDE.md):
//   - No C dependencies, no FFI
//   - P1 no semicolons, P15 let mut everywhere
//   - .push() not arr + [x] in loops

// ── graph_new ───────────────────────────────────────────────────
@pure pub fn graph_new(n) {
    let mut g = []
    let mut i = 0
    while i < n {
        g = g.push([])
        i = i + 1
    }
    g
}

// ── graph_add_edge ──────────────────────────────────────────────
// Adds undirected edge. Returns new graph (pure).
@pure pub fn graph_add_edge(g, u, v) {
    let n = len(g)
    let mut out = []
    let mut i = 0
    while i < n {
        if i == u {
            out = out.push(g[i].push(v))
        } else {
            if i == v {
                out = out.push(g[i].push(u))
            } else {
                out = out.push(g[i])
            }
        }
        i = i + 1
    }
    out
}

// ── graph_add_directed ──────────────────────────────────────────
@pure pub fn graph_add_directed(g, u, v) {
    let n = len(g)
    let mut out = []
    let mut i = 0
    while i < n {
        if i == u {
            out = out.push(g[i].push(v))
        } else {
            out = out.push(g[i])
        }
        i = i + 1
    }
    out
}

// ── _contains helper ────────────────────────────────────────────
fn _contains(arr, val) {
    let mut i = 0
    while i < len(arr) {
        if arr[i] == val { return true }
        i = i + 1
    }
    false
}

// ── graph_bfs ───────────────────────────────────────────────────
@pure pub fn graph_bfs(g, start) {
    let mut visited = []
    let mut queue = []
    queue = queue.push(start)
    visited = visited.push(start)
    let mut head = 0
    while head < len(queue) {
        let cur = queue[head]
        head = head + 1
        let neighbors = g[cur]
        let mut j = 0
        while j < len(neighbors) {
            let nb = neighbors[j]
            if _contains(visited, nb) == false {
                visited = visited.push(nb)
                queue = queue.push(nb)
            }
            j = j + 1
        }
    }
    visited
}

// ── graph_dfs ───────────────────────────────────────────────────
@pure pub fn graph_dfs(g, start) {
    let mut visited = []
    let mut stack = []
    stack = stack.push(start)
    while len(stack) > 0 {
        let cur = stack[len(stack) - 1]
        // pop: rebuild without last element
        let mut new_stack = []
        let mut si = 0
        while si < len(stack) - 1 {
            new_stack = new_stack.push(stack[si])
            si = si + 1
        }
        stack = new_stack
        if _contains(visited, cur) == false {
            visited = visited.push(cur)
            let neighbors = g[cur]
            let mut j = len(neighbors) - 1
            while j >= 0 {
                if _contains(visited, neighbors[j]) == false {
                    stack = stack.push(neighbors[j])
                }
                j = j - 1
            }
        }
    }
    visited
}

// ── graph_has_path ──────────────────────────────────────────────
@pure pub fn graph_has_path(g, src, dst) {
    if src == dst { return true }
    let reachable = graph_bfs(g, src)
    _contains(reachable, dst)
}

// ── graph_num_components ────────────────────────────────────────
@pure pub fn graph_num_components(g) {
    let n = len(g)
    let mut all_visited = []
    let mut components = 0
    let mut i = 0
    while i < n {
        if _contains(all_visited, i) == false {
            components = components + 1
            let reached = graph_bfs(g, i)
            let mut j = 0
            while j < len(reached) {
                all_visited = all_visited.push(reached[j])
                j = j + 1
            }
        }
        i = i + 1
    }
    components
}
