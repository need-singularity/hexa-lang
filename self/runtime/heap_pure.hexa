// ═══════════════════════════════════════════════════════════════════
//  self/runtime/heap_pure.hexa — binary MIN-heap / priority queue (pure hexa)
//
//  A purely-functional binary min-heap represented as a flat int array
//  (array-embedded complete binary tree). heap[0] is the minimum.
//
//  Relation to sort_variants_pure::heap_sort_pure:
//      heap_sort_pure is a MAX-heap in-place sort producing an ascending
//      array. The operations here are the reusable priority-queue
//      primitives over a MIN-heap — different semantics, different
//      invariants. No duplication.
//
//  Public API:
//      heap_push_pure(heap, x)         -> heap         (O(log n), sift-up)
//      heap_pop_pure(heap)             -> [heap, min]  (O(log n), sift-down)
//                                                      — returns nil on empty
//      heap_peek_pure(heap)            -> int | nil    (O(1))
//      heap_from_array_pure(arr)       -> heap         (O(n), Floyd's build)
//      heap_replace_pure(heap, x)      -> [heap, min]  (O(log n) amortized)
//                                                      — pop + push in one step
//                                                      — returns [push([x]), nil] on empty
//
//  Invariant: for every index i with parent p = (i-1)/2, heap[p] <= heap[i].
//
//  Parent/child arithmetic — HX3 pitfall P50 (no `<<`/`>>` in stage0):
//      parent(i) = (i - 1) / 2
//      left(i)   = 2 * i + 1
//      right(i)  = 2 * i + 2
//  All divisions are safe (integer floor; i >= 1 when computing parent).
//
//  HX3 pitfalls handled:
//    * Array mutation builds a fresh array via push-copy (_h_set_at),
//      same pattern as sort_variants_pure::_sv_set_at. Stage0's
//      arr[i] = v surface-parser path is unreliable on nested sift
//      loops (feedback_module_box_struct_replace.md class).
//    * No bitops — pure arithmetic for parent/child.
//    * No string concat in hot paths.
// ═══════════════════════════════════════════════════════════════════

// ── _h_set_at — copy array with one element replaced ───────────────
@pure
fn _h_set_at(arr, idx, val) {
    let n = len(arr)
    let mut out = []
    let mut i = 0
    while i < n {
        if i == idx { out = out.push(val) } else { out = out.push(arr[i]) }
        i = i + 1
    }
    return out
}

// ── _h_sift_up — restore heap property from index up to root ───────
@pure
fn _h_sift_up(heap, start) {
    let mut cur = heap
    let mut i = start
    let mut done = false
    while !done {
        if i <= 0 {
            done = true
        } else {
            let p = (i - 1) / 2
            if cur[p] <= cur[i] {
                done = true
            } else {
                let tmp = cur[p]
                cur = _h_set_at(cur, p, cur[i])
                cur = _h_set_at(cur, i, tmp)
                i = p
            }
        }
    }
    return cur
}

// ── _h_sift_down — restore heap property from index down to leaf ──
@pure
fn _h_sift_down(heap, start, heap_end) {
    let mut cur = heap
    let mut root = start
    let mut done = false
    while !done {
        let left = 2 * root + 1
        if left >= heap_end {
            done = true
        } else {
            let right = left + 1
            let mut smallest = root
            if cur[left] < cur[smallest] { smallest = left }
            if right < heap_end {
                if cur[right] < cur[smallest] { smallest = right }
            }
            if smallest == root {
                done = true
            } else {
                let tmp = cur[root]
                cur = _h_set_at(cur, root, cur[smallest])
                cur = _h_set_at(cur, smallest, tmp)
                root = smallest
            }
        }
    }
    return cur
}

// ── heap_push_pure — insert x, return new heap ─────────────────────
@pure
pub fn heap_push_pure(heap, x) {
    let mut out = []
    let n = len(heap)
    let mut i = 0
    while i < n {
        out = out.push(heap[i])
        i = i + 1
    }
    out = out.push(x)
    return _h_sift_up(out, n)
}

// ── heap_pop_pure — remove min, return [new_heap, min] ─────────────
//   Returns nil if the heap is empty.
@pure
pub fn heap_pop_pure(heap) {
    let n = len(heap)
    if n == 0 { return nil }
    let top = heap[0]
    if n == 1 { return [[], top] }
    // Move last element to root, shrink, sift-down.
    let last = heap[n - 1]
    let mut work = _h_set_at(heap, 0, last)
    // Drop the final index by rebuilding 0..n-1
    let mut shrunk = []
    let mut i = 0
    while i < n - 1 {
        shrunk = shrunk.push(work[i])
        i = i + 1
    }
    let out = _h_sift_down(shrunk, 0, n - 1)
    return [out, top]
}

// ── heap_peek_pure — read min without removing (nil if empty) ──────
@pure
pub fn heap_peek_pure(heap) {
    if len(heap) == 0 { return nil }
    return heap[0]
}

// ── heap_from_array_pure — Floyd's O(n) bottom-up build ────────────
@pure
pub fn heap_from_array_pure(arr) {
    let n = len(arr)
    if n <= 1 { return arr }
    // Copy into a fresh array (preserves purity).
    let mut work = []
    let mut ci = 0
    while ci < n {
        work = work.push(arr[ci])
        ci = ci + 1
    }
    // Start sifting from the last non-leaf: (n-2)/2 down to 0.
    let mut start = (n - 2) / 2
    while start >= 0 {
        work = _h_sift_down(work, start, n)
        start = start - 1
    }
    return work
}

// ── heap_replace_pure — pop-min then push in one pass ──────────────
//   On empty heap: behaves as heap_push_pure([], x) and returns
//   [new_heap, nil] (nil standing in for "no old minimum").
@pure
pub fn heap_replace_pure(heap, x) {
    let n = len(heap)
    if n == 0 {
        return [[x], nil]
    }
    let top = heap[0]
    let replaced = _h_set_at(heap, 0, x)
    let out = _h_sift_down(replaced, 0, n)
    return [out, top]
}
