// ===================================================================
//  test_structured_output.hexa — Grammar-constrained structured output tests
//
//  Verifies:
//    1. Schema parsing (object, array, string, number, bool)
//    2. FSM state transitions for valid JSON
//    3. FSM rejects invalid JSON
//    4. Token mask blocks invalid chars
//    5. Constrained sampling produces valid tokens
//    6. validate_json_output on valid/invalid cases
//    7. Nested object/array structures
//
//  Run: ./hexa self/test_structured_output.hexa
// ===================================================================
// -- inlined from self/ml/structured_output.hexa --
// codegen import not wired for test files

// ===================================================================
//  self/ml/structured_output.hexa — Grammar-Constrained Structured Output
//
//  JSON Schema -> FSM -> Token Mask -> Constrained Decode
//
//  Pure HEXA implementation of grammar-constrained decoding.
//  Forces LLM output to be valid JSON conforming to a given schema.
//
//  API:
//    create_json_grammar(schema)                  -> Grammar
//    constrained_sample(logits, grammar, state)   -> [token_id, new_state]
//    validate_json_output(text, schema)           -> bool
//
//  Internal:
//    parse_schema(schema_str)          -> SchemaNode
//    fsm_advance(state, char)          -> new_state
//    compute_token_mask(grammar, state, vocab_size) -> mask
// ===================================================================

// ===================================================================
//  Constants: FSM states
// ===================================================================
let ST_START         = 0
let ST_OBJECT_OPEN   = 1
let ST_OBJECT_KEY    = 2
let ST_OBJECT_COLON  = 3
let ST_OBJECT_VALUE  = 4
let ST_OBJECT_NEXT   = 5
let ST_ARRAY_OPEN    = 6
let ST_ARRAY_VALUE   = 7
let ST_ARRAY_NEXT    = 8
let ST_STRING        = 9
let ST_STRING_ESCAPE = 10
let ST_NUMBER        = 11
let ST_TRUE_1        = 12
let ST_TRUE_2        = 13
let ST_TRUE_3        = 14
let ST_FALSE_1       = 15
let ST_FALSE_2       = 16
let ST_FALSE_3       = 17
let ST_FALSE_4       = 18
let ST_NULL_1        = 19
let ST_NULL_2        = 20
let ST_NULL_3        = 21
let ST_DONE          = 22
let ST_ERROR         = 23

// ===================================================================
//  Schema types
// ===================================================================
let SCHEMA_OBJECT  = 0
let SCHEMA_ARRAY   = 1
let SCHEMA_STRING  = 2
let SCHEMA_NUMBER  = 3
let SCHEMA_BOOL    = 4
let SCHEMA_NULL    = 5
let SCHEMA_ANY     = 6

// ===================================================================
//  FSM state is encoded as a flat list: [state, depth, stack...]
//  index 0 = state, index 1 = depth, index 2.. = stack entries
//  This avoids struct-literal-in-if-block parser ambiguity.
// ===================================================================

fn make_fsm(s, d, stack) {
    let mut out = [s, d]
    let mut i = 0
    while i < len(stack) {
        out = out + [stack[i]]
        i = i + 1
    }
    return out
}

fn fsm_state(f) { return f[0] }
fn fsm_depth(f) { return f[1] }
fn fsm_stack(f) {
    let mut out = []
    let mut i = 2
    while i < len(f) {
        out = out + [f[i]]
        i = i + 1
    }
    return out
}

fn initial_fsm_state() {
    return make_fsm(ST_START, 0, [])
}

// ===================================================================
//  Schema node: encoded as list [stype, items_type, n_fields, name0, type0, ...]
// ===================================================================
fn make_schema_node(stype, items_type, field_names, field_types) {
    let mut out = [stype, items_type, len(field_names)]
    let mut i = 0
    while i < len(field_names) {
        out = out + [field_names[i]]
        out = out + [field_types[i]]
        i = i + 1
    }
    return out
}

fn schema_stype(s) { return s[0] }
fn schema_items_type(s) { return s[1] }
fn schema_n_fields(s) { return s[2] }
fn schema_field_name(s, i) { return s[3 + i * 2] }
fn schema_field_type(s, i) { return s[3 + i * 2 + 1] }

fn make_schema(stype) {
    return make_schema_node(stype, SCHEMA_ANY, [], [])
}

fn make_object_schema(names, types) {
    return make_schema_node(SCHEMA_OBJECT, SCHEMA_ANY, names, types)
}

fn make_array_schema(items_type) {
    return make_schema_node(SCHEMA_ARRAY, items_type, [], [])
}

// ===================================================================
//  Grammar: encoded as [vocab_size, schema...]
// ===================================================================
fn make_grammar(schema, vocab_size) {
    let mut out = [vocab_size]
    let mut i = 0
    while i < len(schema) {
        out = out + [schema[i]]
        i = i + 1
    }
    return out
}

fn grammar_vocab(g) { return g[0] }
fn grammar_schema(g) {
    let mut out = []
    let mut i = 1
    while i < len(g) {
        out = out + [g[i]]
        i = i + 1
    }
    return out
}

// ===================================================================
//  String helpers
// ===================================================================
fn find_char(s, ch, start) {
    let n = len(s)
    let mut i = start
    while i < n {
        let c = char_code(s, i)
        if c == ch { return i }
        i = i + 1
    }
    return -1
}

fn substr(s, start, end_pos) {
    let mut result = ""
    let mut i = start
    while i < end_pos {
        result = result + chr(char_code(s, i))
        i = i + 1
    }
    return result
}

fn str_match_at(s, pattern, pos) {
    let sn = len(s)
    let pn = len(pattern)
    if pos + pn > sn { return false }
    let mut i = 0
    while i < pn {
        if char_code(s, pos + i) != char_code(pattern, i) { return false }
        i = i + 1
    }
    return true
}

fn find_str(s, pattern, start) {
    let sn = len(s)
    let pn = len(pattern)
    let mut i = start
    while i < sn - pn + 1 {
        if str_match_at(s, pattern, i) { return i }
        i = i + 1
    }
    return -1
}

fn is_ws(c) { return c == 32 || c == 9 || c == 10 || c == 13 }
fn is_digit(c) { return c >= 48 && c <= 57 }

// ===================================================================
//  Schema parser
// ===================================================================
fn parse_type_string(type_str) {
    if type_str == "object" { return SCHEMA_OBJECT }
    if type_str == "array" { return SCHEMA_ARRAY }
    if type_str == "string" { return SCHEMA_STRING }
    if type_str == "number" { return SCHEMA_NUMBER }
    if type_str == "integer" { return SCHEMA_NUMBER }
    if type_str == "boolean" { return SCHEMA_BOOL }
    if type_str == "null" { return SCHEMA_NULL }
    return SCHEMA_ANY
}

fn extract_type(schema_str) {
    let pos = find_str(schema_str, "\"type\"", 0)
    if pos < 0 { return "any" }
    let colon = find_char(schema_str, 58, pos + 6)
    if colon < 0 { return "any" }
    let q1 = find_char(schema_str, 34, colon + 1)
    if q1 < 0 { return "any" }
    let q2 = find_char(schema_str, 34, q1 + 1)
    if q2 < 0 { return "any" }
    return substr(schema_str, q1 + 1, q2)
}

fn parse_schema(schema_str) {
    let type_str = extract_type(schema_str)
    let stype = parse_type_string(type_str)

    if stype == SCHEMA_OBJECT {
        let props_pos = find_str(schema_str, "\"properties\"", 0)
        let mut names = []
        let mut types = []
        if props_pos >= 0 {
            let brace = find_char(schema_str, 123, props_pos + 12)
            if brace >= 0 {
                let mut pos = brace + 1
                let slen = len(schema_str)
                while pos < slen {
                    let kq1 = find_char(schema_str, 34, pos)
                    if kq1 < 0 { pos = slen }
                    else {
                        let kq2 = find_char(schema_str, 34, kq1 + 1)
                        if kq2 < 0 { pos = slen }
                        else {
                            let key = substr(schema_str, kq1 + 1, kq2)
                            if key == "type" {
                                pos = kq2 + 1
                            } else {
                                names = names + [key]
                                let inner_type_pos = find_str(schema_str, "\"type\"", kq2 + 1)
                                if inner_type_pos >= 0 {
                                    let ic = find_char(schema_str, 58, inner_type_pos + 6)
                                    if ic >= 0 {
                                        let iq1 = find_char(schema_str, 34, ic + 1)
                                        if iq1 >= 0 {
                                            let iq2 = find_char(schema_str, 34, iq1 + 1)
                                            if iq2 >= 0 {
                                                let ft = substr(schema_str, iq1 + 1, iq2)
                                                types = types + [parse_type_string(ft)]
                                                pos = iq2 + 1
                                            } else { pos = slen }
                                        } else { pos = slen }
                                    } else { pos = slen }
                                } else {
                                    types = types + [SCHEMA_ANY]
                                    pos = kq2 + 1
                                }
                            }
                        }
                    }
                }
            }
        }
        return make_object_schema(names, types)
    }

    if stype == SCHEMA_ARRAY {
        let items_pos = find_str(schema_str, "\"items\"", 0)
        let mut items_type = SCHEMA_ANY
        if items_pos >= 0 {
            let ibrace = find_char(schema_str, 123, items_pos + 7)
            if ibrace >= 0 {
                let end_brace = find_char(schema_str, 125, ibrace + 1)
                if end_brace >= 0 {
                    let items_str = substr(schema_str, ibrace, end_brace + 1)
                    let it_str = extract_type(items_str)
                    items_type = parse_type_string(it_str)
                }
            }
        }
        return make_array_schema(items_type)
    }

    return make_schema(stype)
}

// ===================================================================
//  create_json_grammar: public API
// ===================================================================
fn create_json_grammar(schema_str) {
    let schema = parse_schema(schema_str)
    return make_grammar(schema, 256)
}

// ===================================================================
//  pop_stack: remove last element from a list (used for FSM)
// ===================================================================
fn pop_stack(stack) {
    let n = len(stack)
    if n == 0 { return [] }
    let mut out = []
    let mut i = 0
    while i < (n - 1) {
        out = out + [stack[i]]
        i = i + 1
    }
    return out
}

// ===================================================================
//  resolve_parent: when a value completes, determine next state
//  based on parent container type in the stack
// ===================================================================
fn resolve_parent(d, stack) {
    if d == 0 { return ST_DONE }
    let slen = len(stack)
    if slen > 0 {
        let parent = stack[slen - 1]
        if parent == 1 { return ST_OBJECT_NEXT }
        return ST_ARRAY_NEXT
    }
    return ST_DONE
}

// ===================================================================
//  FSM value-start transition: shared by ST_START, ST_OBJECT_VALUE, ST_ARRAY_OPEN
// ===================================================================
fn fsm_value_start(ch) {
    if ch == 123 { return ST_OBJECT_OPEN }
    if ch == 91 { return ST_ARRAY_OPEN }
    if ch == 34 { return ST_STRING }
    if is_digit(ch) || ch == 45 { return ST_NUMBER }
    if ch == 116 { return ST_TRUE_1 }
    if ch == 102 { return ST_FALSE_1 }
    if ch == 110 { return ST_NULL_1 }
    return ST_ERROR
}

// ===================================================================
//  FSM transition
// ===================================================================
fn fsm_advance(st, ch) {
    let s = fsm_state(st)
    let d = fsm_depth(st)
    let stack = fsm_stack(st)
    let mut new_s = s
    let mut new_d = d
    let mut new_stack = stack

    // Whitespace skip (except inside strings)
    if s != ST_STRING {
        if s != ST_STRING_ESCAPE {
            if is_ws(ch) { return make_fsm(s, d, stack) }
        }
    }

    if s == ST_START {
        new_s = fsm_value_start(ch)
        if ch == 123 { new_d = d + 1; new_stack = stack + [1] }
        if ch == 91 { new_d = d + 1; new_stack = stack + [2] }
    }
    else { if s == ST_OBJECT_OPEN {
        if ch == 34 { new_s = ST_OBJECT_KEY }
        else { if ch == 125 {
            new_d = d - 1
            new_stack = pop_stack(stack)
            new_s = resolve_parent(new_d, new_stack)
        }
        else { new_s = ST_ERROR }}
    }
    else { if s == ST_OBJECT_KEY {
        if ch == 34 { new_s = ST_OBJECT_COLON }
        // else stay (consuming key chars)
    }
    else { if s == ST_OBJECT_COLON {
        if ch == 58 { new_s = ST_OBJECT_VALUE }
        else { new_s = ST_ERROR }
    }
    else { if s == ST_OBJECT_VALUE {
        new_s = fsm_value_start(ch)
        if ch == 123 { new_d = d + 1; new_stack = stack + [1] }
        if ch == 91 { new_d = d + 1; new_stack = stack + [2] }
    }
    else { if s == ST_OBJECT_NEXT {
        if ch == 44 { new_s = ST_OBJECT_OPEN }
        else { if ch == 125 {
            new_d = d - 1
            new_stack = pop_stack(stack)
            new_s = resolve_parent(new_d, new_stack)
        }
        else { new_s = ST_ERROR }}
    }
    else { if s == ST_ARRAY_OPEN {
        if ch == 93 {
            new_d = d - 1
            new_stack = pop_stack(stack)
            new_s = resolve_parent(new_d, new_stack)
        } else {
            new_s = fsm_value_start(ch)
            if ch == 123 { new_d = d + 1; new_stack = stack + [1] }
            if ch == 91 { new_d = d + 1; new_stack = stack + [2] }
        }
    }
    else { if s == ST_ARRAY_NEXT {
        if ch == 44 { new_s = ST_ARRAY_OPEN }
        else { if ch == 93 {
            new_d = d - 1
            new_stack = pop_stack(stack)
            new_s = resolve_parent(new_d, new_stack)
        }
        else { new_s = ST_ERROR }}
    }
    else { if s == ST_STRING {
        if ch == 92 { new_s = ST_STRING_ESCAPE }
        else { if ch == 34 { new_s = resolve_parent(d, stack) }
        }
        // else stay in ST_STRING
    }
    else { if s == ST_STRING_ESCAPE {
        new_s = ST_STRING
    }
    else { if s == ST_NUMBER {
        if is_digit(ch) || ch == 46 || ch == 101 || ch == 69 || ch == 43 || ch == 45 {
            // stay in number
            new_s = ST_NUMBER
        } else {
            // Number ended -- process terminator
            new_s = resolve_parent(d, stack)
            if ch == 44 {
                if new_s == ST_OBJECT_NEXT { new_s = ST_OBJECT_OPEN }
                if new_s == ST_ARRAY_NEXT { new_s = ST_ARRAY_OPEN }
            }
            if ch == 125 {
                new_d = d - 1
                new_stack = pop_stack(stack)
                new_s = resolve_parent(new_d, new_stack)
            }
            if ch == 93 {
                new_d = d - 1
                new_stack = pop_stack(stack)
                new_s = resolve_parent(new_d, new_stack)
            }
        }
    }
    // Boolean/null literal states
    else { if s == ST_TRUE_1 {
        if ch == 114 { new_s = ST_TRUE_2 } else { new_s = ST_ERROR }
    }
    else { if s == ST_TRUE_2 {
        if ch == 117 { new_s = ST_TRUE_3 } else { new_s = ST_ERROR }
    }
    else { if s == ST_TRUE_3 {
        if ch == 101 { new_s = resolve_parent(d, stack) } else { new_s = ST_ERROR }
    }
    else { if s == ST_FALSE_1 {
        if ch == 97 { new_s = ST_FALSE_2 } else { new_s = ST_ERROR }
    }
    else { if s == ST_FALSE_2 {
        if ch == 108 { new_s = ST_FALSE_3 } else { new_s = ST_ERROR }
    }
    else { if s == ST_FALSE_3 {
        if ch == 115 { new_s = ST_FALSE_4 } else { new_s = ST_ERROR }
    }
    else { if s == ST_FALSE_4 {
        if ch == 101 { new_s = resolve_parent(d, stack) } else { new_s = ST_ERROR }
    }
    else { if s == ST_NULL_1 {
        if ch == 117 { new_s = ST_NULL_2 } else { new_s = ST_ERROR }
    }
    else { if s == ST_NULL_2 {
        if ch == 108 { new_s = ST_NULL_3 } else { new_s = ST_ERROR }
    }
    else { if s == ST_NULL_3 {
        if ch == 108 { new_s = resolve_parent(d, stack) } else { new_s = ST_ERROR }
    }
    else { if s == ST_DONE { new_s = ST_DONE }
    else { new_s = ST_ERROR }
    }}}}}}}}}}}}}}}}}}}}}

    return make_fsm(new_s, new_d, new_stack)
}

// ===================================================================
//  Compute token mask
// ===================================================================
fn compute_token_mask(grammar, state, vocab_size) {
    let mut mask = []
    let mut i = 0
    while i < vocab_size {
        let next_st = fsm_advance(state, i)
        if fsm_state(next_st) != ST_ERROR {
            mask = mask + [1.0]
        } else {
            mask = mask + [0.0]
        }
        i = i + 1
    }
    return mask
}

// ===================================================================
//  Apply mask to logits
// ===================================================================
fn apply_mask_to_logits(logits, mask, n) {
    let mut out = []
    let mut i = 0
    while i < n {
        if i < len(mask) {
            if mask[i] > 0.5 {
                out = out + [logits[i]]
            } else {
                out = out + [-1.0e30]
            }
        } else {
            out = out + [-1.0e30]
        }
        i = i + 1
    }
    return out
}

// ===================================================================
//  constrained_sample: apply grammar mask then argmax
//  Returns [token_id, new_state]
// ===================================================================
fn constrained_sample(logits, grammar, state) {
    let vocab_size = grammar_vocab(grammar)
    let n = len(logits)
    let effective_n = if n < vocab_size { n } else { vocab_size }

    let mask = compute_token_mask(grammar, state, effective_n)
    let masked = apply_mask_to_logits(logits, mask, effective_n)

    // Argmax
    let mut best_i = 0
    let mut best_v = masked[0]
    let mut i = 1
    while i < effective_n {
        if masked[i] > best_v {
            best_v = masked[i]
            best_i = i
        }
        i = i + 1
    }

    let new_state = fsm_advance(state, best_i)
    return [best_i, new_state]
}

// ===================================================================
//  FSM run: feed entire text, return final FSM state
// ===================================================================
fn fsm_run(text) {
    let mut st = initial_fsm_state()
    let n = len(text)
    let mut i = 0
    while i < n {
        let ch = char_code(text, i)
        st = fsm_advance(st, ch)
        if fsm_state(st) == ST_ERROR { return st }
        i = i + 1
    }
    return st
}

// ===================================================================
//  is_valid_json: check well-formed JSON via FSM
// ===================================================================
fn is_valid_json(text) {
    let st = fsm_run(text)
    return fsm_state(st) == ST_DONE
}

// ===================================================================
//  check_type_match: top-level type vs schema
// ===================================================================
fn check_type_match(text, schema) {
    let n = len(text)
    if n == 0 { return false }
    let first = char_code(text, 0)

    let st = schema_stype(schema)
    if st == SCHEMA_ANY { return true }
    if st == SCHEMA_OBJECT { return first == 123 }
    if st == SCHEMA_ARRAY { return first == 91 }
    if st == SCHEMA_STRING { return first == 34 }
    if st == SCHEMA_NUMBER { return is_digit(first) || first == 45 }
    if st == SCHEMA_BOOL { return first == 116 || first == 102 }
    if st == SCHEMA_NULL { return first == 110 }
    return false
}

// ===================================================================
//  validate_json_output: public API
// ===================================================================
fn validate_json_output(text, schema_str) {
    if !is_valid_json(text) { return false }
    let schema = parse_schema(schema_str)
    return check_type_match(text, schema)
}

// ===================================================================
//  generate_constrained_json: constrained generation loop
// ===================================================================
fn generate_constrained_json(logit_fn, grammar, max_len) {
    let mut state = initial_fsm_state()
    let mut output = ""
    let mut i = 0
    while i < max_len {
        if fsm_state(state) == ST_DONE { i = max_len }
        else { if fsm_state(state) == ST_ERROR { i = max_len }
        else {
            let logits = logit_fn(i)
            let result = constrained_sample(logits, grammar, state)
            let token_id = result[0]
            let new_state = result[1]
            output = output + chr(token_id)
            state = new_state
            i = i + 1
        }}
    }
    return output
}


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

// ===================================================================
//  T1: Schema parsing -- object type
// ===================================================================
let s1 = parse_schema("{\"type\":\"object\",\"properties\":{\"name\":{\"type\":\"string\"}}}")
check("T1 schema object type", schema_stype(s1) == SCHEMA_OBJECT)

// ===================================================================
//  T2: Schema parsing -- array type
// ===================================================================
let s2 = parse_schema("{\"type\":\"array\",\"items\":{\"type\":\"number\"}}")
check("T2 schema array type", schema_stype(s2) == SCHEMA_ARRAY)
check("T2 array items_type number", schema_items_type(s2) == SCHEMA_NUMBER)

// ===================================================================
//  T3: Schema parsing -- primitive types
// ===================================================================
let s3 = parse_schema("{\"type\":\"string\"}")
check("T3 schema string type", schema_stype(s3) == SCHEMA_STRING)
let s4 = parse_schema("{\"type\":\"boolean\"}")
check("T4 schema boolean type", schema_stype(s4) == SCHEMA_BOOL)

// ===================================================================
//  T5: FSM -- valid simple object {"a":1}
// ===================================================================
let mut st = initial_fsm_state()
st = fsm_advance(st, 123)  // {
check("T5 fsm after { state", fsm_state(st) == ST_OBJECT_OPEN)
st = fsm_advance(st, 34)   // "
st = fsm_advance(st, 97)   // a
st = fsm_advance(st, 34)   // "
check("T5 fsm after key state", fsm_state(st) == ST_OBJECT_COLON)
st = fsm_advance(st, 58)   // :
check("T5 fsm after : state", fsm_state(st) == ST_OBJECT_VALUE)
st = fsm_advance(st, 49)   // 1 (digit)
st = fsm_advance(st, 125)  // }
check("T5 fsm complete object -> DONE", fsm_state(st) == ST_DONE)

// ===================================================================
//  T6: FSM -- valid array [1,2]
// ===================================================================
let mut st2 = initial_fsm_state()
st2 = fsm_advance(st2, 91)   // [
check("T6 fsm after [ state", fsm_state(st2) == ST_ARRAY_OPEN)
st2 = fsm_advance(st2, 49)   // 1
st2 = fsm_advance(st2, 44)   // ,
st2 = fsm_advance(st2, 50)   // 2
st2 = fsm_advance(st2, 93)   // ]
check("T6 fsm complete array -> DONE", fsm_state(st2) == ST_DONE)

// ===================================================================
//  T7: FSM -- string "hello"
// ===================================================================
let mut st3 = initial_fsm_state()
st3 = fsm_advance(st3, 34)   // "
st3 = fsm_advance(st3, 104)  // h
st3 = fsm_advance(st3, 101)  // e
st3 = fsm_advance(st3, 108)  // l
st3 = fsm_advance(st3, 108)  // l
st3 = fsm_advance(st3, 111)  // o
st3 = fsm_advance(st3, 34)   // "
check("T7 fsm string -> DONE", fsm_state(st3) == ST_DONE)

// ===================================================================
//  T8: FSM -- boolean true
// ===================================================================
let mut st4 = initial_fsm_state()
st4 = fsm_advance(st4, 116)  // t
st4 = fsm_advance(st4, 114)  // r
st4 = fsm_advance(st4, 117)  // u
st4 = fsm_advance(st4, 101)  // e
check("T8 fsm true -> DONE", fsm_state(st4) == ST_DONE)

// ===================================================================
//  T9: FSM -- invalid input (@ at start)
// ===================================================================
let mut st5 = initial_fsm_state()
st5 = fsm_advance(st5, 64)   // @
check("T9 fsm invalid start -> ERROR", fsm_state(st5) == ST_ERROR)

// ===================================================================
//  T10: Token mask blocks invalid tokens at start
// ===================================================================
let g1 = create_json_grammar("{\"type\":\"object\"}")
let init_st = initial_fsm_state()
let mask = compute_token_mask(g1, init_st, 128)
check("T10 mask allows { at start", mask[123] > 0.5)
check("T10 mask blocks @ at start", mask[64] < 0.5)
check("T10 mask allows [ at start", mask[91] > 0.5)

// ===================================================================
//  T11: Constrained sampling picks valid token
// ===================================================================
let g2 = create_json_grammar("{\"type\":\"object\"}")
let init_st2 = initial_fsm_state()
let mut logits = []
let mut i = 0

while i < 256 {
    if i == 123 { logits = logits + [10.0] }
    else { logits = logits + [0.1] }
}
let result = constrained_sample(logits, g2, init_st2)
let tok = result[0]
let next_s = result[1]
check("T11 constrained sample picks {", tok == 123)
check("T11 new state is OBJECT_OPEN", fsm_state(next_s) == ST_OBJECT_OPEN)

// ===================================================================
//  T12: validate_json_output -- valid cases
// ===================================================================
check("T12 valid object", validate_json_output("{\"a\":1}", "{\"type\":\"object\"}"))
check("T12 valid array", validate_json_output("[1,2,3]", "{\"type\":\"array\"}"))
check("T12 valid string", validate_json_output("\"hello\"", "{\"type\":\"string\"}"))
check("T12 valid bool", validate_json_output("true", "{\"type\":\"boolean\"}"))
check("T12 valid null", validate_json_output("null", "{\"type\":\"null\"}"))

// ===================================================================
//  T13: validate_json_output -- invalid / type mismatch
// ===================================================================
check("T13 reject type mismatch", !validate_json_output("[1]", "{\"type\":\"object\"}"))

// ===================================================================
//  T14: FSM -- nested object {"a":{"b":1}}
// ===================================================================
let st_nested = fsm_run("{\"a\":{\"b\":1}}")
check("T14 nested object valid", fsm_state(st_nested) == ST_DONE)

// ===================================================================
//  T15: FSM -- nested array [[1,2],[3]]
// ===================================================================
let st_narr = fsm_run("[[1,2],[3]]")
check("T15 nested array valid", fsm_state(st_narr) == ST_DONE)

// ===================================================================
//  T16: FSM -- object with string value {"key":"value"}
// ===================================================================
let st_os = fsm_run("{\"key\":\"value\"}")
check("T16 object with string value valid", fsm_state(st_os) == ST_DONE)

// ===================================================================
//  T17: FSM -- false literal
// ===================================================================
let st_f = fsm_run("false")
check("T17 false literal valid", fsm_state(st_f) == ST_DONE)

// ===================================================================
//  T18: FSM -- null literal
// ===================================================================
let st_n = fsm_run("null")
check("T18 null literal valid", fsm_state(st_n) == ST_DONE)

// ===================================================================
//  T19: Mask after { only allows " and } and whitespace
// ===================================================================
let mut st_obj = initial_fsm_state()
st_obj = fsm_advance(st_obj, 123)
let mask2 = compute_token_mask(g1, st_obj, 128)
check("T19 after { mask allows quote", mask2[34] > 0.5)
check("T19 after { mask allows }", mask2[125] > 0.5)
check("T19 after { mask blocks a", mask2[97] < 0.5)

// ===================================================================
//  T20: Complex object with multiple fields
// ===================================================================
let st_complex = fsm_run("{\"name\":\"test\",\"value\":42,\"active\":true}")
check("T20 multi-field object valid", fsm_state(st_complex) == ST_DONE)

// ===================================================================
//  T21: Escaped string {"a":"hello\"world"}
// ===================================================================
let st_esc = fsm_run("{\"a\":\"hello\\\"world\"}")
check("T21 escaped string valid", fsm_state(st_esc) == ST_DONE)

// ===================================================================
//  Summary
// ===================================================================
println("")
println("=== Structured Output test summary ===")
println("PASS: " + to_string(pass_count))
println("FAIL: " + to_string(fail_count))
if fail_count == 0 {
    println("ALL GREEN -- grammar FSM + token mask + constrained decode OK")
}
println(to_string(pass_count) + " passed")
