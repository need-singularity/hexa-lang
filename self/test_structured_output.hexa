// ===================================================================
//  test_structured_output.hexa — Grammar-constrained structured output tests
//
//  Verifies:
//    1. Schema parsing (object, array, string, number, bool)
//    2. FSM state transitions for valid JSON
//    3. FSM rejects invalid JSON
//    4. Token mask blocks invalid chars
//    5. Constrained sampling produces valid tokens
//    6. validate_json_output on valid/invalid cases
//    7. Nested object/array structures
//
//  Run: ./hexa self/test_structured_output.hexa
// ===================================================================
import "ml/structured_output.hexa"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

// ===================================================================
//  T1: Schema parsing — object type
// ===================================================================
let s1 = parse_schema("{\"type\":\"object\",\"properties\":{\"name\":{\"type\":\"string\"}}}")
check("T1 schema object type", s1.stype == SCHEMA_OBJECT)

// ===================================================================
//  T2: Schema parsing — array type
// ===================================================================
let s2 = parse_schema("{\"type\":\"array\",\"items\":{\"type\":\"number\"}}")
check("T2 schema array type", s2.stype == SCHEMA_ARRAY)
check("T2 array items_type number", s2.items_type == SCHEMA_NUMBER)

// ===================================================================
//  T3: Schema parsing — primitive types
// ===================================================================
let s3 = parse_schema("{\"type\":\"string\"}")
check("T3 schema string type", s3.stype == SCHEMA_STRING)
let s4 = parse_schema("{\"type\":\"boolean\"}")
check("T4 schema boolean type", s4.stype == SCHEMA_BOOL)

// ===================================================================
//  T5: FSM — valid simple object {"a":1}
// ===================================================================
let mut st = initial_fsm_state()
st = fsm_advance(st, 123)  // {
check("T5 fsm after { -> OBJECT_OPEN", st.state == ST_OBJECT_OPEN)
st = fsm_advance(st, 34)   // "
st = fsm_advance(st, 97)   // a
st = fsm_advance(st, 34)   // "
check("T5 fsm after key -> OBJECT_COLON", st.state == ST_OBJECT_COLON)
st = fsm_advance(st, 58)   // :
check("T5 fsm after : -> OBJECT_VALUE", st.state == ST_OBJECT_VALUE)
st = fsm_advance(st, 49)   // 1 (digit)
st = fsm_advance(st, 125)  // }
check("T5 fsm complete object -> DONE", st.state == ST_DONE)

// ===================================================================
//  T6: FSM — valid array [1,2]
// ===================================================================
let mut st2 = initial_fsm_state()
st2 = fsm_advance(st2, 91)   // [
check("T6 fsm after [ -> ARRAY_OPEN", st2.state == ST_ARRAY_OPEN)
st2 = fsm_advance(st2, 49)   // 1
st2 = fsm_advance(st2, 44)   // ,
st2 = fsm_advance(st2, 50)   // 2
st2 = fsm_advance(st2, 93)   // ]
check("T6 fsm complete array -> DONE", st2.state == ST_DONE)

// ===================================================================
//  T7: FSM — string "hello"
// ===================================================================
let mut st3 = initial_fsm_state()
st3 = fsm_advance(st3, 34)   // "
st3 = fsm_advance(st3, 104)  // h
st3 = fsm_advance(st3, 101)  // e
st3 = fsm_advance(st3, 108)  // l
st3 = fsm_advance(st3, 108)  // l
st3 = fsm_advance(st3, 111)  // o
st3 = fsm_advance(st3, 34)   // "
check("T7 fsm string -> DONE", st3.state == ST_DONE)

// ===================================================================
//  T8: FSM — boolean true
// ===================================================================
let mut st4 = initial_fsm_state()
st4 = fsm_advance(st4, 116)  // t
st4 = fsm_advance(st4, 114)  // r
st4 = fsm_advance(st4, 117)  // u
st4 = fsm_advance(st4, 101)  // e
check("T8 fsm true -> DONE", st4.state == ST_DONE)

// ===================================================================
//  T9: FSM — invalid input (random byte at start)
// ===================================================================
let mut st5 = initial_fsm_state()
st5 = fsm_advance(st5, 64)   // @ (invalid start)
check("T9 fsm invalid start -> ERROR", st5.state == ST_ERROR)

// ===================================================================
//  T10: Token mask blocks invalid tokens at start
// ===================================================================
let g1 = create_json_grammar("{\"type\":\"object\"}")
let init_st = initial_fsm_state()
let mask = compute_token_mask(g1, init_st, 128)
// At ST_START, { (123) should be allowed
check("T10 mask allows { at start", mask[123] > 0.5)
// @ (64) should be blocked
check("T10 mask blocks @ at start", mask[64] < 0.5)
// [ (91) should be allowed (valid JSON start)
check("T10 mask allows [ at start", mask[91] > 0.5)

// ===================================================================
//  T11: Constrained sampling picks valid token
// ===================================================================
let g2 = create_json_grammar("{\"type\":\"object\"}")
let init_st2 = initial_fsm_state()
// Create logits biased toward { (123) which is valid
let mut logits = []
for i in 0..256 {
    if i == 123 { logits = logits + [10.0] }
    else { logits = logits + [0.1] }
}
let result = constrained_sample(logits, g2, init_st2)
let tok = result[0]
let next_s = result[1]
check("T11 constrained sample picks {", tok == 123)
check("T11 new state is OBJECT_OPEN", next_s.state == ST_OBJECT_OPEN)

// ===================================================================
//  T12: validate_json_output — valid cases
// ===================================================================
check("T12 valid object", validate_json_output("{\"a\":1}", "{\"type\":\"object\"}"))
check("T12 valid array", validate_json_output("[1,2,3]", "{\"type\":\"array\"}"))
check("T12 valid string", validate_json_output("\"hello\"", "{\"type\":\"string\"}"))
check("T12 valid bool", validate_json_output("true", "{\"type\":\"boolean\"}"))
check("T12 valid null", validate_json_output("null", "{\"type\":\"null\"}"))

// ===================================================================
//  T13: validate_json_output — invalid cases
// ===================================================================
check("T13 reject broken json", !validate_json_output("{\"a\":}", "{\"type\":\"object\"}"))
check("T13 reject type mismatch", !validate_json_output("[1]", "{\"type\":\"object\"}"))

// ===================================================================
//  T14: FSM — nested object {"a":{"b":1}}
// ===================================================================
let nested = "{\"a\":{\"b\":1}}"
let st_nested = fsm_run(nested)
check("T14 nested object valid", st_nested.state == ST_DONE)

// ===================================================================
//  T15: FSM — nested array [[1,2],[3]]
// ===================================================================
let nested_arr = "[[1,2],[3]]"
let st_narr = fsm_run(nested_arr)
check("T15 nested array valid", st_narr.state == ST_DONE)

// ===================================================================
//  T16: FSM — object with string value {"k":"v"}
// ===================================================================
let obj_str = "{\"key\":\"value\"}"
let st_os = fsm_run(obj_str)
check("T16 object with string value valid", st_os.state == ST_DONE)

// ===================================================================
//  T17: FSM — false literal
// ===================================================================
let st_f = fsm_run("false")
check("T17 false literal valid", st_f.state == ST_DONE)

// ===================================================================
//  T18: FSM — null literal
// ===================================================================
let st_n = fsm_run("null")
check("T18 null literal valid", st_n.state == ST_DONE)

// ===================================================================
//  T19: Mask after { only allows " and }
// ===================================================================
let mut st_obj = initial_fsm_state()
st_obj = fsm_advance(st_obj, 123)  // {
let mask2 = compute_token_mask(g1, st_obj, 128)
check("T19 after { mask allows \" (34)", mask2[34] > 0.5)
check("T19 after { mask allows } (125)", mask2[125] > 0.5)
// a (97) is not valid directly after {
check("T19 after { mask blocks a (97)", mask2[97] < 0.5)

// ===================================================================
//  T20: Complex object with multiple fields
// ===================================================================
let complex_obj = "{\"name\":\"test\",\"value\":42,\"active\":true}"
let st_complex = fsm_run(complex_obj)
check("T20 multi-field object valid", st_complex.state == ST_DONE)

// ===================================================================
//  T21: Escaped string {"a":"he said \\\"hi\\\""}
// ===================================================================
let esc_obj = "{\"a\":\"hello\\\"world\"}"
let st_esc = fsm_run(esc_obj)
check("T21 escaped string valid", st_esc.state == ST_DONE)

// ===================================================================
//  Summary
// ===================================================================
println("")
println("=== Structured Output test summary ===")
println("PASS: " + to_string(pass_count))
println("FAIL: " + to_string(fail_count))
if fail_count == 0 {
    println("ALL GREEN -- grammar FSM + token mask + constrained decode OK")
}
println(to_string(pass_count) + " passed")
