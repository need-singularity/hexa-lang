// self/poc/builtin/push_method.hexa
// @method .push
//
// Called from expr/call.hexa for `arr.push(v)` (Call with Field target).

use "poc/common"
use "mini_native"

fn poc_bi_push_method(e) -> int {
    let base_vid = poc_lower_expr(e.left.left)
    if base_vid < 0 { return -1 }
    let sm = poc_next_vid
    let v_vid = poc_lower_expr(e.args[0])
    if v_vid < 0 { return -1 }
    // len = [base+0]
    let len_old = poc_fresh_vid()
    poc_emit(mn_load_off(len_old, base_vid, 0))
    // addr = base + 16 + len*8   (shift+add inline)
    let sh_vid = poc_fresh_vid()
    poc_emit(mn_load_imm(sh_vid, 3))
    let off_vid = poc_fresh_vid()
    poc_emit(mn_shl(off_vid, len_old, sh_vid))
    let addr_vid = poc_fresh_vid()
    poc_emit(mn_add(addr_vid, base_vid, off_vid))
    poc_emit(mn_add_imm(addr_vid, addr_vid, 16))
    // STR v, [addr]
    poc_emit(mn_store_off(addr_vid, 0, v_vid))
    // length++ ; STR length, [base+0]
    poc_emit(mn_add_imm(len_old, len_old, 1))
    poc_emit(mn_store_off(base_vid, 0, len_old))
    poc_next_vid = sm
    return base_vid
}
