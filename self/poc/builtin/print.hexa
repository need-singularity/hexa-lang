// self/poc/builtin/print.hexa
// @name print

use "poc/common"
use "mini_native"

fn poc_bi_print(e) -> int {
    let arg = e.args[0]
    if arg.kind == "StringLit" {
        let str_id = poc_intern_str(arg.value)
        let strlen_v = len(arg.value)
        let ptr_vid = poc_fresh_vid()
        poc_emit(mn_str_addr(ptr_vid, str_id))
        let fd_vid = poc_fresh_vid()
        poc_emit(mn_load_imm(fd_vid, 1))
        let len_vid = poc_fresh_vid()
        poc_emit(mn_load_imm(len_vid, strlen_v))
        if fd_vid != 0  { poc_emit(mn_mov(0, fd_vid)) }
        if ptr_vid != 1 { poc_emit(mn_mov(1, ptr_vid)) }
        if len_vid != 2 { poc_emit(mn_mov(2, len_vid)) }
        poc_emit(mn_syscall3_prepared(33554436))
        return 0
    }
    println("[poc] print(...) needs StringLit (PoC)")
    return -1
}
