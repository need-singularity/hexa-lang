// self/poc/builtin/syscall.hexa
// @name syscall
//
//   syscall(num, a0)              → sys_exit etc.
//   syscall(num, a0, a1, a2)      → sys_write(fd, buf, len) etc.

use "poc/common"
use "mini_native"

fn poc_bi_syscall(e) -> int {
    if len(e.args) < 2 {
        println("[poc] syscall needs >=2 args (num, arg0)")
        return -1
    }
    let nr_expr = e.args[0]
    if nr_expr.kind != "IntLit" {
        println("[poc] syscall num must be IntLit literal (PoC)")
        return -1
    }
    let nr = to_int(nr_expr.value)
    if len(e.args) == 2 {
        let arg_vid = poc_lower_expr(e.args[1])
        if arg_vid < 0 { return -1 }
        poc_emit(mn_syscall1(nr, arg_vid))
        return arg_vid
    }
    if len(e.args) == 4 {
        // Lower each arg into its own vid first.
        let v0 = poc_lower_expr(e.args[1])
        let v1 = poc_lower_expr(e.args[2])
        let v2 = poc_lower_expr(e.args[3])
        if v0 < 0 || v1 < 0 || v2 < 0 { return -1 }
        // Marshal into x0, x1, x2 (= vids 0, 1, 2).
        if v0 != 0 { poc_emit(mn_mov(0, v0)) }
        if v1 != 1 { poc_emit(mn_mov(1, v1)) }
        if v2 != 2 { poc_emit(mn_mov(2, v2)) }
        poc_emit(mn_syscall3_prepared(nr))
        return 0
    }
    println("[poc] unsupported syscall arity: " + str(len(e.args)))
    return -1
}
