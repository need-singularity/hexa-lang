// self/poc/builtin/min_max.hexa
// @name min, max
// @arity 2

use "poc/common"
use "mini_native"

fn poc_bi_min_max(e) -> int {
    let av = poc_lower_expr(e.args[0])
    let bv = poc_lower_expr(e.args[1])
    if av < 0 || bv < 0 { return -1 }
    let result_vid = poc_fresh_vid()
    poc_emit(mn_mov(result_vid, av))
    let skip = poc_fresh_label()
    poc_emit(mn_cmp(av, bv))
    // min: keep a if a<=b — skip `mov result, b` when LE (13)
    // max: keep a if a>=b — skip `mov result, b` when GE (10)
    let skip_cond = if e.left.name == "min" { 13 } else { 10 }
    poc_emit(mn_br_cond(skip_cond, skip))
    poc_emit(mn_mov(result_vid, bv))
    poc_emit(mn_label(skip))
    return result_vid
}
