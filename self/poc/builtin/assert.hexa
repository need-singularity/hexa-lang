// self/poc/builtin/assert.hexa
// @name assert

use "poc/common"
use "mini_native"

fn poc_bi_assert(e) -> int {
    let bool_vid = poc_lower_expr(e.args[0])
    if bool_vid < 0 { return -1 }
    let skip = poc_fresh_label()
    poc_emit(mn_cmp(bool_vid, 31))
    poc_emit(mn_br_cond(1, skip))      // NE → skip exit (cond was true)
    // cond false → exit(1)
    let one_vid = poc_fresh_vid()
    poc_emit(mn_load_imm(one_vid, 1))
    poc_emit(mn_syscall1(33554433, one_vid))
    poc_emit(mn_label(skip))
    return 0
}
