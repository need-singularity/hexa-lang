// self/poc/builtin/println.hexa
// @name println
//
//   println(s: StringLit)  → syscall(write, 1, s+"\n", strlen+1)
//   println(int_expr)      → inline div/mod loop + write (delegates to
//                             poc_emit_println_int in main file for now)

use "poc/common"
use "mini_native"

fn poc_bi_println(e) -> int {
    let arg = e.args[0]
    if arg.kind == "StringLit" {
        let full = arg.value + "\n"
        let str_id = poc_intern_str(full)
        let strlen_v = len(full)
        let ptr_vid = poc_fresh_vid()
        poc_emit(mn_str_addr(ptr_vid, str_id))
        let fd_vid = poc_fresh_vid()
        poc_emit(mn_load_imm(fd_vid, 1))
        let len_vid = poc_fresh_vid()
        poc_emit(mn_load_imm(len_vid, strlen_v))
        if fd_vid != 0  { poc_emit(mn_mov(0, fd_vid)) }
        if ptr_vid != 1 { poc_emit(mn_mov(1, ptr_vid)) }
        if len_vid != 2 { poc_emit(mn_mov(2, len_vid)) }
        poc_emit(mn_syscall3_prepared(33554436))
        return 0
    }
    // Non-string: treat as int expression → emit div/mod loop.
    poc_emit_println_int(arg)
    return 0
}
