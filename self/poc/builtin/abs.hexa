// self/poc/builtin/abs.hexa
// @name abs

use "poc/common"
use "mini_native"

fn poc_bi_abs(e) -> int {
    let x_vid = poc_lower_expr(e.args[0])
    if x_vid < 0 { return -1 }
    let result_vid = poc_fresh_vid()
    poc_emit(mn_mov(result_vid, x_vid))
    let skip = poc_fresh_label()
    poc_emit(mn_cmp(result_vid, 31))        // cmp x, xzr
    poc_emit(mn_br_cond(10, skip))          // skip if GE 0
    poc_emit(mn_sub(result_vid, 31, result_vid))   // result = 0 - result
    poc_emit(mn_label(skip))
    return result_vid
}
