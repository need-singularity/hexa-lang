// self/poc/builtin/assert_eq.hexa
// @name assert_eq
// @arity 2

use "poc/common"
use "mini_native"

fn poc_bi_assert_eq(e) -> int {
    let av = poc_lower_expr(e.args[0])
    let bv = poc_lower_expr(e.args[1])
    if av < 0 || bv < 0 { return -1 }
    let skip = poc_fresh_label()
    poc_emit(mn_cmp(av, bv))
    poc_emit(mn_br_cond(0, skip))       // EQ → skip
    let one_vid = poc_fresh_vid()
    poc_emit(mn_load_imm(one_vid, 1))
    poc_emit(mn_syscall1(33554433, one_vid))
    poc_emit(mn_label(skip))
    return 0
}
