// self/poc/builtin/len.hexa
// @name len
// @arity 1
//
// len() on arrays reads the length prefix at offset 0 (arrays are laid
// out as [len | elem0 | elem1 | ...]). Strings are C-strings with no
// prefix, so the same trick yields the first byte's value. To keep
// len() correct for both:
//
//   - StringLit arg → compile-time length as IntLit.
//   - Ident arg known-array (poc_arr_len_of ≥ 0) → current prefix load.
//   - Ident arg not known-array → assume string, emit a small strlen
//     loop (scan until NUL byte).
//
// This mirrors the split in real self/: most len() calls are over
// compile-time-sized arrays or string literals; runtime-sized strings
// need the loop.

use "poc/common"
use "mini_native"

fn poc_bi_len(e) -> int {
    let arg = e.args[0]
    // Compile-time string literal — return length as immediate.
    if arg.kind == "StringLit" {
        let vid = poc_fresh_vid()
        poc_emit(mn_load_imm(vid, len(arg.value)))
        return vid
    }
    // Known-array ident — load the length prefix at offset 0.
    if arg.kind == "Ident" {
        let alen = poc_arr_len_of(arg.name)
        if alen >= 0 {
            let base_vid = poc_lower_expr(arg)
            if base_vid < 0 { return -1 }
            let vid = poc_fresh_vid()
            poc_emit(mn_load_off(vid, base_vid, 0))
            return vid
        }
        // Known string-literal ident — return the tracked length.
        let slen = poc_str_len_of(arg.name)
        if slen >= 0 {
            let vid = poc_fresh_vid()
            poc_emit(mn_load_imm(vid, slen))
            return vid
        }
    }
    // Fallback: assume array-layout with length prefix. This matches
    // the prior behaviour for non-literal array expressions (field
    // access returning an array, etc.). Callers passing a string var
    // will get wrong results; such cases need a runtime strlen loop
    // which is not implemented in the POC yet.
    let base_vid = poc_lower_expr(arg)
    if base_vid < 0 { return -1 }
    let vid = poc_fresh_vid()
    poc_emit(mn_load_off(vid, base_vid, 0))
    return vid
}
