// self/poc/_dispatch.hexa
//
// AUTO-GENERATED by scripts/poc_gen_dispatch.hexa — do not edit.
// Regenerate: hexa scripts/poc_gen_dispatch.hexa
//
// Dispatchers read from self/poc/<cat>/<snake>.hexa handlers via the
// filename=dispatch-key convention. Adding a new kind = new file;
// regenerating this file picks it up automatically.

fn poc_lower_expr(e) -> int {
    if e.kind == "Array"         { return poc_ex_array(e) }
    if e.kind == "ArrayLit"      { return poc_ex_array(e) }
    if e.kind == "BinOp"         { return poc_ex_bin_op(e) }
    if e.kind == "BoolLit"       { return poc_ex_bool_lit(e) }
    if e.kind == "CharLit"       { return poc_ex_char_lit(e) }
    if e.kind == "Field"         { return poc_ex_field(e) }
    if e.kind == "Ident"         { return poc_ex_ident(e) }
    if e.kind == "IfExpr"        { return poc_ex_if_expr(e) }
    if e.kind == "Index"         { return poc_ex_index(e) }
    if e.kind == "IntLit"        { return poc_ex_int_lit(e) }
    if e.kind == "MatchExpr"     { return poc_ex_match_expr(e) }
    if e.kind == "NullLit"       { return poc_ex_null_lit(e) }
    if e.kind == "StringLit"     { return poc_ex_string_lit(e) }
    if e.kind == "StructInit"    { return poc_ex_struct_init(e) }
    if e.kind == "TupleLit"      { return poc_ex_tuple_lit(e) }
    if e.kind == "Tuple"         { return poc_ex_tuple_lit(e) }
    if e.kind == "UnaryOp"       { return poc_ex_unary_op(e) }
    if e.kind == "Call"          { return poc_ex_call(e) }
    println("[poc] unsupported expr kind: " + e.kind)
    return -1
}

fn poc_lower_stmt(stmt) -> int {
    if stmt.kind == "AssertStmt"        { return poc_st_assert(stmt) }
    if stmt.kind == "AssignStmt"        { return poc_st_assign(stmt) }
    if stmt.kind == "BreakStmt"         { return poc_st_break_stmt(stmt) }
    if stmt.kind == "CompoundAssign"    { return poc_st_compound_assign(stmt) }
    if stmt.kind == "ContinueStmt"      { return poc_st_continue_stmt(stmt) }
    if stmt.kind == "ExprStmt"          { return poc_st_expr_stmt(stmt) }
    if stmt.kind == "ForStmt"           { return poc_st_for(stmt) }
    if stmt.kind == "LetStmt"           { return poc_st_let(stmt) }
    if stmt.kind == "LetMutStmt"        { return poc_st_let(stmt) }
    if stmt.kind == "ReturnStmt"        { return poc_st_return(stmt) }
    if stmt.kind == "WhileStmt"         { return poc_st_while(stmt) }
    println("[poc] unsupported stmt kind: " + stmt.kind)
    return -1
}

// Dispatcher for Call expressions: routes method calls, then named
// builtins (from self/poc/builtin/), then user-defined fns.
fn poc_ex_call(e) -> int {
    if e.left.kind == "Field" && e.left.name == "push" && len(e.args) == 1 { return poc_bi_push_method(e) }
    if e.left.kind != "Ident" {
        println("[poc] call target must be Ident (PoC)")
        return -1
    }
    let name = e.left.name
    if name == "abs"           && len(e.args) == 1 { return poc_bi_abs(e) }
    if name == "assert_eq"     && len(e.args) == 2 { return poc_bi_assert_eq(e) }
    if name == "assert"        && len(e.args) == 1 { return poc_bi_assert(e) }
    if name == "exit"          && len(e.args) == 1 { return poc_bi_exit(e) }
    if name == "len"           && len(e.args) == 1 { return poc_bi_len(e) }
    if name == "min"           && len(e.args) == 2 { return poc_bi_min_max(e) }
    if name == "max"           && len(e.args) == 2 { return poc_bi_min_max(e) }
    if name == "print"         && len(e.args) == 1 { return poc_bi_print(e) }
    if name == "println"       && len(e.args) == 1 { return poc_bi_println(e) }
    if name == "syscall"       { return poc_bi_syscall(e) }
    let target_fn_id = poc_fn_id_for(name)
    if target_fn_id < 0 {
        println("[poc] unbound fn: " + name)
        return -1
    }
    let mut arg_vids = []
    let mut ai = 0
    while ai < len(e.args) {
        let av = poc_lower_expr(e.args[ai])
        if av < 0 { return -1 }
        arg_vids = arg_vids.push(av)
        ai = ai + 1
    }
    let mut mi = 0
    while mi < len(arg_vids) {
        if arg_vids[mi] != mi { poc_emit(mn_mov(mi, arg_vids[mi])) }
        mi = mi + 1
    }
    poc_emit(mn_call(target_fn_id))
    let result_vid = poc_fresh_vid()
    if result_vid != 0 { poc_emit(mn_mov(result_vid, 0)) }
    return result_vid
}
