// self/poc/common.hexa
//
// Phase 0 — lowering state + core helpers for the self-host native POC.
// Handler files under `self/poc/<cat>/<snake>.hexa` read/mutate this
// state. Splitting this out keeps per-handler files focused and makes
// parallel edits (N agents on N handler files) collision-free.
//
// Freeze policy: new globals here require a separate iteration, so a
// feature PR stays to its own handler file.

use "mini_native"

// ── Lowering state ─────────────────────────────────────────────
//
// Simple linear v# allocator. Module-level `mut` mimics an IR builder.

let mut poc_instrs = []
let mut poc_next_vid = 0
let mut poc_next_label = 0
let mut poc_env_names = []
let mut poc_env_vids = []
let mut poc_fn_names = []     // fn_id → name
let mut poc_next_fn_id = 0
let mut poc_fn_ret_structs = []  // fn name → struct-name return type ("" if non-struct)
let mut poc_strings = []      // str_id → string literal
let mut poc_arr_off = 0       // next byte offset in per-fn 256-byte array scratch

// Global int constants (ConstStmt with IntLit RHS). Looked up like Ident.
let mut poc_const_names = []
let mut poc_const_values = []
fn poc_const_register(name: string, val: int) {
    poc_const_names = poc_const_names.push(name)
    poc_const_values = poc_const_values.push(val)
}
fn poc_const_lookup(name: string) -> int {
    let mut i = 0
    while i < len(poc_const_names) {
        if poc_const_names[i] == name { return poc_const_values[i] }
        i = i + 1
    }
    return -999999999   // sentinel for "not found"
}

// Compile-time-known array lengths per variable name.
let mut poc_var_arr_names = []
let mut poc_var_arr_lens = []

fn poc_bind_arr_len(name: string, length: int) {
    poc_var_arr_names = poc_var_arr_names.push(name)
    poc_var_arr_lens = poc_var_arr_lens.push(length)
}
fn poc_arr_len_of(name: string) -> int {
    let mut i = len(poc_var_arr_names) - 1
    while i >= 0 {
        if poc_var_arr_names[i] == name { return poc_var_arr_lens[i] }
        i = i - 1
    }
    return -1
}

// Compile-time-known string lengths per variable name (for `let s =
// "literal"` bindings). len() needs this because strings are C-strings
// without a length prefix — the array-style load-offset-0 trick would
// return the first byte.
let mut poc_var_str_names = []
let mut poc_var_str_lens = []

fn poc_bind_str_len(name: string, length: int) {
    poc_var_str_names = poc_var_str_names.push(name)
    poc_var_str_lens = poc_var_str_lens.push(length)
}
fn poc_str_len_of(name: string) -> int {
    let mut i = len(poc_var_str_names) - 1
    while i >= 0 {
        if poc_var_str_names[i] == name { return poc_var_str_lens[i] }
        i = i - 1
    }
    return -1
}

// Loop context stack for break/continue target resolution.
let mut poc_loop_break_labels = []
let mut poc_loop_cont_labels = []

fn poc_push_loop(break_label: int, cont_label: int) {
    poc_loop_break_labels = poc_loop_break_labels.push(break_label)
    poc_loop_cont_labels = poc_loop_cont_labels.push(cont_label)
}
fn poc_pop_loop() {
    poc_loop_break_labels = poc_loop_break_labels.pop()
    poc_loop_cont_labels = poc_loop_cont_labels.pop()
}
fn poc_top_break_label() -> int {
    if len(poc_loop_break_labels) == 0 { return -1 }
    return poc_loop_break_labels[len(poc_loop_break_labels) - 1]
}
fn poc_top_cont_label() -> int {
    if len(poc_loop_cont_labels) == 0 { return -1 }
    return poc_loop_cont_labels[len(poc_loop_cont_labels) - 1]
}

// Struct registry (global).
//   poc_struct_names    — parallel to poc_struct_field_lists
//   poc_struct_field_lists[i] is an array of field name strings for
//   struct poc_struct_names[i], in declaration order.
let mut poc_struct_names = []
let mut poc_struct_field_lists = []

// Per-fn var → struct_name binding (for field access type resolution).
let mut poc_var_names = []
let mut poc_var_structs = []

fn poc_struct_register(name: string, fields: array) {
    let mut field_names = []
    let mut i = 0
    while i < len(fields) {
        field_names = field_names.push(fields[i].name)
        i = i + 1
    }
    poc_struct_names = poc_struct_names.push(name)
    poc_struct_field_lists = poc_struct_field_lists.push(field_names)
}

fn poc_struct_is_registered(name: string) -> bool {
    let mut i = 0
    while i < len(poc_struct_names) {
        if poc_struct_names[i] == name { return true }
        i = i + 1
    }
    return false
}

fn poc_struct_field_index(struct_name: string, field_name: string) -> int {
    let mut i = 0
    while i < len(poc_struct_names) {
        if poc_struct_names[i] == struct_name {
            let fields = poc_struct_field_lists[i]
            let mut j = 0
            while j < len(fields) {
                if fields[j] == field_name { return j }
                j = j + 1
            }
            return -1
        }
        i = i + 1
    }
    return -1
}

fn poc_bind_var_struct(var_name: string, struct_name: string) {
    poc_var_names = poc_var_names.push(var_name)
    poc_var_structs = poc_var_structs.push(struct_name)
}

fn poc_var_struct_of(var_name: string) -> string {
    let mut i = len(poc_var_names) - 1
    while i >= 0 {
        if poc_var_names[i] == var_name { return poc_var_structs[i] }
        i = i - 1
    }
    return ""
}

fn poc_intern_str(s: string) -> int {
    let id = len(poc_strings)
    poc_strings = poc_strings.push(s)
    return id
}

fn poc_reset() {
    poc_instrs = []
    poc_next_vid = 0
    poc_next_label = 0
    poc_env_names = []
    poc_env_vids = []
    poc_fn_names = []
    poc_next_fn_id = 0
    poc_fn_ret_structs = []
    poc_strings = []
}

// Register a fn's struct-return type so callers can bind LetStmt vars
// with the right struct, enabling field access on the result.
fn poc_fn_ret_struct_register(fn_name: string, struct_name: string) {
    poc_fn_ret_structs = poc_fn_ret_structs.push(struct_name)
    // Index into poc_fn_ret_structs mirrors poc_fn_names — caller must
    // invoke this immediately after poc_fresh_fn_id for alignment.
}

fn poc_fn_ret_struct_of(fn_name: string) -> string {
    let mut i = 0
    while i < len(poc_fn_names) {
        if poc_fn_names[i] == fn_name {
            if i < len(poc_fn_ret_structs) { return poc_fn_ret_structs[i] }
            return ""
        }
        i = i + 1
    }
    return ""
}

fn poc_fresh_fn_id(name: string) -> int {
    let id = poc_next_fn_id
    poc_fn_names = poc_fn_names.push(name)
    poc_next_fn_id = poc_next_fn_id + 1
    return id
}

fn poc_fn_id_for(name: string) -> int {
    let mut i = 0
    while i < len(poc_fn_names) {
        if poc_fn_names[i] == name { return i }
        i = i + 1
    }
    return -1
}

fn poc_reset_fn_scope() {
    // Reset per-fn state — vids start at the callee-saved base so that
    // values survive across calls. Arg slots (x0..x7) are short-lived
    // regs used only for marshalling, not vid-owned.
    poc_next_vid = poc_local_vid_base()
    poc_next_label = 0
    poc_env_names = []
    poc_env_vids = []
    poc_arr_off = 0
    poc_var_names = []
    poc_var_structs = []
    poc_var_arr_names = []
    poc_var_arr_lens = []
    poc_var_str_names = []
    poc_var_str_lens = []
    poc_loop_break_labels = []
    poc_loop_cont_labels = []
}

fn poc_fresh_label() -> int {
    let l = poc_next_label
    poc_next_label = poc_next_label + 1
    return l
}

fn poc_bind(name: string, vid: int) {
    poc_env_names = poc_env_names.push(name)
    poc_env_vids = poc_env_vids.push(vid)
}

fn poc_lookup(name: string) -> int {
    let mut i = len(poc_env_names) - 1
    while i >= 0 {
        if poc_env_names[i] == name { return poc_env_vids[i] }
        i = i - 1
    }
    return -1
}

// Local vids start from 19 so they map to callee-saved x19..x28 (9 regs).
// Vids 0..7 are reserved for caller-saved arg slots (x0..x7), used only
// during argument marshalling before Calls / syscalls.
@pure fn poc_local_vid_base() -> int { return 19 }

fn poc_fresh_vid() -> int {
    let v = poc_next_vid
    poc_next_vid = poc_next_vid + 1
    return v
}

fn poc_emit(ins: MnInstr) {
    poc_instrs = poc_instrs.push(ins)
}

// Pick a result vid for a BinOp-like 2-operand op. If either operand
// is a fresh temp (allocated at or after `before` within the 10-slot
// callee-saved window x19..x28), its slot is dead after the op so we
// reuse it. Otherwise allocate fresh. Keeps vid pressure bounded for
// nested expressions like `a*a + b*b` that would otherwise overflow
// and silently spill to XZR.
fn poc_pick_binop_result_vid(lv: int, rv: int, before: int) -> int {
    if lv >= before && lv <= 28 {
        poc_next_vid = lv + 1
        return lv
    }
    if rv >= before && rv <= 28 {
        poc_next_vid = rv + 1
        return rv
    }
    return poc_fresh_vid()
}
