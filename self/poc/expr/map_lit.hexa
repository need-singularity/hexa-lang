// self/poc/expr/map_lit.hexa
// @kinds MapLit
//
// Layout: [length(8) | spare(8) | (key(8), value(8))*CAP_ENTS].
// Data (entries) at base+16. Each entry = 16 bytes.
// CAP_ENTS = max(nents*2, 4), capped at 32 — bounded so small programs
// stay within the per-fn 256-byte scratch region.
//
// Scope: construction-only PoC. Read/lookup by key is not wired yet;
// future Index[MapLit] + .get() method can reuse this layout.

use "poc/common"
use "mini_native"

fn poc_ex_map_lit(e) -> int {
    let entries = e.items
    let nents = len(entries)
    let mut cap_ents = nents * 2
    if cap_ents < 4  { cap_ents = 4 }
    if cap_ents > 32 { cap_ents = 32 }
    let base_off = poc_arr_off
    let base_vid = poc_fresh_vid()
    poc_emit(mn_add_sp_imm(base_vid, base_off))
    let scope_mark = poc_next_vid
    // length at [base+0]
    let len_vid = poc_fresh_vid()
    poc_emit(mn_load_imm(len_vid, nents))
    poc_emit(mn_store_off(base_vid, 0, len_vid))
    poc_next_vid = scope_mark
    // entries at [base+16 + i*16]   (k at +0, v at +8)
    let mut i = 0
    while i < nents {
        let entry = entries[i]
        let k_vid = poc_lower_expr(entry.left)
        if k_vid < 0 { return -1 }
        poc_emit(mn_store_off(base_vid, 16 + i * 16, k_vid))
        poc_next_vid = scope_mark
        let v_vid = poc_lower_expr(entry.right)
        if v_vid < 0 { return -1 }
        poc_emit(mn_store_off(base_vid, 16 + i * 16 + 8, v_vid))
        poc_next_vid = scope_mark
        i = i + 1
    }
    poc_arr_off = poc_arr_off + 16 + cap_ents * 16
    return base_vid
}
