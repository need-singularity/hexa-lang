// self/poc/expr/ident.hexa
// @kinds Ident

use "poc/common"
use "mini_native"

fn poc_ex_ident(e) -> int {
    if e.name == "true"  { let v = poc_fresh_vid(); poc_emit(mn_load_imm(v, 1)); return v }
    if e.name == "false" { let v = poc_fresh_vid(); poc_emit(mn_load_imm(v, 0)); return v }
    let bound = poc_lookup(e.name)
    if bound >= 0 { return bound }
    let cval = poc_const_lookup(e.name)
    if cval > -999999999 {
        let v = poc_fresh_vid()
        poc_emit(mn_load_imm(v, cval))
        return v
    }
    println("[poc] unbound ident: " + e.name)
    return -1
}
