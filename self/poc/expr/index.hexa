// self/poc/expr/index.hexa
// @kinds Index

use "poc/common"
use "mini_native"

fn poc_ex_index(e) -> int {
    // Map read path — e.left must be an Ident bound to a MapLit.
    if e.left.kind == "Ident" {
        let nents = poc_map_nents_of(e.left.name)
        if nents >= 0 {
            let base_vid = poc_lower_expr(e.left)
            if base_vid < 0 { return -1 }
            let key_vid = poc_lower_expr(e.right)
            if key_vid < 0 { return -1 }
            return poc_ex_index_map(base_vid, key_vid, nents)
        }
    }
    let base_vid = poc_lower_expr(e.left)
    if base_vid < 0 { return -1 }
    // Fast path: constant index via LDR [base, #16 + imm*8].
    if e.right.kind == "IntLit" {
        let idx = to_int(e.right.value)
        let vid = poc_fresh_vid()
        poc_emit(mn_load_off(vid, base_vid, 16 + idx * 8))
        return vid
    }
    // General: addr = base + 16 + (idx << 3) ; LDR [addr].
    let idx_vid = poc_lower_expr(e.right)
    if idx_vid < 0 { return -1 }
    let shift_vid = poc_fresh_vid()
    poc_emit(mn_load_imm(shift_vid, 3))
    let offset_vid = poc_fresh_vid()
    poc_emit(mn_shl(offset_vid, idx_vid, shift_vid))
    let addr_vid = poc_fresh_vid()
    poc_emit(mn_add(addr_vid, base_vid, offset_vid))
    poc_emit(mn_add_imm(addr_vid, addr_vid, 16))
    let vid = poc_fresh_vid()
    poc_emit(mn_load_off(vid, addr_vid, 0))
    return vid
}

// Emit an unrolled key-scan for map_var[key]. Layout (see map_lit.hexa):
// [length(8) | spare(8) | (key(8), value(8))*nents]. For each entry
// emit CMP+B.EQ to a per-entry hit label; if none match, result = 0.
fn poc_ex_index_map(base_vid: int, key_vid: int, nents: int) -> int {
    let result_vid = poc_fresh_vid()
    let done_label = poc_fresh_label()
    let mut hit_labels = []
    let mut e = 0
    while e < nents {
        let k_vid = poc_fresh_vid()
        poc_emit(mn_load_off(k_vid, base_vid, 16 + e * 16))
        poc_emit(mn_cmp(k_vid, key_vid))
        let hit = poc_fresh_label()
        poc_emit(mn_br_cond(0, hit))   // EQ
        hit_labels = hit_labels.push(hit)
        e = e + 1
    }
    // Miss: result = 0, jump to done.
    poc_emit(mn_load_imm(result_vid, 0))
    poc_emit(mn_jmp(done_label))
    // Hit blocks — load value at +8 from the matched entry.
    let mut h = 0
    while h < nents {
        poc_emit(mn_label(hit_labels[h]))
        poc_emit(mn_load_off(result_vid, base_vid, 16 + h * 16 + 8))
        if h < nents - 1 { poc_emit(mn_jmp(done_label)) }
        h = h + 1
    }
    poc_emit(mn_label(done_label))
    return result_vid
}
