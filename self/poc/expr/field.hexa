// self/poc/expr/field.hexa
// @kinds Field

use "poc/common"
use "mini_native"

fn poc_ex_field(e) -> int {
    // p.x — resolve p's struct type, find x's index, LDR from [base, #idx*8].
    if e.left.kind != "Ident" {
        println("[poc] field target must be Ident (PoC)")
        return -1
    }
    let obj_name = e.left.name
    let struct_name = poc_var_struct_of(obj_name)
    if struct_name == "" {
        println("[poc] unknown struct for var: " + obj_name)
        return -1
    }
    let fidx = poc_struct_field_index(struct_name, e.name)
    if fidx < 0 {
        println("[poc] unknown field: " + struct_name + "." + e.name)
        return -1
    }
    let base_vid = poc_lower_expr(e.left)
    if base_vid < 0 { return -1 }
    let vid = poc_fresh_vid()
    poc_emit(mn_load_off(vid, base_vid, fidx * 8))
    return vid
}
