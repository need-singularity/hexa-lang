// self/poc/expr/int_lit.hexa
// @kinds IntLit
//
// Phase 0 demo — first modularized handler under the
// `self/poc/<cat>/<snake_case>.hexa` convention.
//
// Rule: filename `int_lit.hexa` under `expr/` → fn `poc_ex_int_lit`.
// Annotation `@kinds IntLit` declares which AST kind(s) this handles.
// Dispatcher codegen (future) reads this annotation to emit the
// if-chain in `self/poc/lower_expr.hexa`.

fn poc_ex_int_lit(e) -> int {
    let vid = poc_fresh_vid()
    poc_emit(mn_load_imm(vid, to_int(e.value)))
    return vid
}
