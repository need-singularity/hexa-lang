// self/poc/expr/call.hexa
// @kinds Call
//
// Dispatcher for Call expressions. Routes:
//   1. Method calls (e.left = Field) → poc_ex_call_method (e.g. arr.push(v))
//   2. Named builtins → poc_bi_<name>  (under `self/poc/builtin/<name>.hexa`)
//   3. User-defined fn → generic BL emission

use "poc/common"
use "mini_native"

fn poc_ex_call(e) -> int {
    // Method call: e.left is Field. Only .push(v) supported (PoC).
    if e.left.kind == "Field" && e.left.name == "push" && len(e.args) == 1 {
        return poc_bi_push_method(e)
    }
    if e.left.kind != "Ident" {
        println("[poc] call target must be Ident (PoC)")
        return -1
    }
    let name = e.left.name
    if name == "assert"    && len(e.args) == 1 { return poc_bi_assert(e) }
    if name == "assert_eq" && len(e.args) == 2 { return poc_bi_assert_eq(e) }
    if name == "abs"       && len(e.args) == 1 { return poc_bi_abs(e) }
    if (name == "min" || name == "max") && len(e.args) == 2 { return poc_bi_min_max(e) }
    if name == "exit"      && len(e.args) == 1 { return poc_bi_exit(e) }
    if name == "print"     && len(e.args) == 1 { return poc_bi_print(e) }
    if name == "len"       && len(e.args) == 1 { return poc_bi_len(e) }
    if name == "println"   && len(e.args) == 1 { return poc_bi_println(e) }
    if name == "syscall" { return poc_bi_syscall(e) }

    // User-defined fn call — lookup target fn_id, marshal args, BL.
    let target_fn_id = poc_fn_id_for(name)
    if target_fn_id < 0 {
        println("[poc] unbound fn: " + name)
        return -1
    }
    // Lower each arg into a fresh vid.
    let mut arg_vids = []
    let mut ai = 0
    while ai < len(e.args) {
        let av = poc_lower_expr(e.args[ai])
        if av < 0 { return -1 }
        arg_vids = arg_vids.push(av)
        ai = ai + 1
    }
    // Marshal arg vids into x0..x_n (i.e. vids 0..n-1 physically).
    // We emit mov vid=i, src=arg_vid[i] when they differ. This can
    // clobber in-use low vids; POC simplification: caller must not
    // keep low-vid locals live across calls. Tests are written to
    // satisfy this.
    let mut mi = 0
    while mi < len(arg_vids) {
        if arg_vids[mi] != mi {
            poc_emit(mn_mov(mi, arg_vids[mi]))
        }
        mi = mi + 1
    }
    poc_emit(mn_call(target_fn_id))
    // Return value in x0 (vid 0). Copy to fresh vid for caller use.
    let result_vid = poc_fresh_vid()
    if result_vid != 0 {
        poc_emit(mn_mov(result_vid, 0))
    }
    return result_vid
}
