// self/poc/expr/match_expr.hexa
// @kinds MatchExpr

use "poc/common"
use "mini_native"

fn poc_ex_match_expr(e) -> int {
    // Lower scrutinee, then chain of cmp+br_ne per arm, Wildcard = fallthrough.
    // Result materialized in a single fresh vid so all arms unify.
    let scrut_vid = poc_lower_expr(e.left)
    if scrut_vid < 0 { return -1 }
    let result_vid = poc_fresh_vid()
    let end_label = poc_fresh_label()
    let arms = e.arms
    let mut i = 0
    while i < len(arms) {
        let arm = arms[i]
        let next_label = poc_fresh_label()
        if arm.left.kind != "Wildcard" {
            let sm = poc_next_vid
            let pat_vid = poc_lower_expr(arm.left)
            poc_emit(mn_cmp(scrut_vid, pat_vid))
            poc_next_vid = sm
            poc_emit(mn_br_cond(1, next_label))
        }
        // Arm body: emit all stmts; last ExprStmt's value → result_vid.
        // NOTE: `scope` is a reserved keyword (P51) — use `sv_mark`.
        let body = arm.body
        let mut bi = 0
        while bi < len(body) {
            let is_last = bi == len(body) - 1
            if is_last && body[bi].kind == "ExprStmt" {
                let sv_mark = poc_next_vid
                let v = poc_lower_expr(body[bi].left)
                if v < 0 { return -1 }
                poc_emit(mn_mov(result_vid, v))
                poc_next_vid = sv_mark
            } else {
                let r = poc_lower_stmt(body[bi])
                if r < 0 { return -1 }
            }
            bi = bi + 1
        }
        poc_emit(mn_jmp(end_label))
        poc_emit(mn_label(next_label))
        i = i + 1
    }
    poc_emit(mn_label(end_label))
    return result_vid
}
