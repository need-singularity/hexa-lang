// self/poc/expr/int_lit_test.hexa
// @test poc_ex_int_lit
//
// Co-located handler test for self/poc/expr/int_lit.hexa.
//
// Convention: filename `int_lit_test.hexa` under `expr/` →
//             fn `poc_test_ex_int_lit() -> int`, returning 0 on pass,
//             >0 on fail (failure count). See self/poc/TESTING.md.
//
// What this test covers:
//   1. Handler returns a non-negative vid (vid >= poc_local_vid_base()).
//   2. Handler emits exactly one MnInstr into poc_instrs.
//   3. The emitted instr is a `load_imm` with op="load",
//      imm=42, is_imm=true, and result==returned vid.

fn poc_test_ex_int_lit() -> int {
    // Reset module-level lowering state so the test is hermetic.
    poc_reset()
    poc_reset_fn_scope()

    // Construct a minimal AST node matching what the parser emits
    // for `42` — see node_int_lit() in self/parser.hexa (line 69).
    // Handler only reads .kind and .value, so we can use a dict
    // literal with just those two fields.
    let node = #{ "kind": "IntLit", "value": "42" }

    let before = len(poc_instrs)
    let vid = poc_ex_int_lit(node)
    let after = len(poc_instrs)

    let mut fails = 0

    // (1) vid must be a valid local vid.
    if vid < poc_local_vid_base() {
        println("[poc-test] FAIL int_lit: vid=" + str(vid) + " < local_base=" + str(poc_local_vid_base()))
        fails = fails + 1
    }

    // (2) exactly one instr emitted.
    let emitted = after - before
    if emitted != 1 {
        println("[poc-test] FAIL int_lit: expected 1 MnInstr, got " + str(emitted))
        fails = fails + 1
    }

    // (3) the emitted instr shape.
    if emitted == 1 {
        let ins = poc_instrs[after - 1]
        if ins.op != "load" {
            println("[poc-test] FAIL int_lit: op=" + ins.op + " expected 'load'")
            fails = fails + 1
        }
        if ins.is_imm != true {
            println("[poc-test] FAIL int_lit: is_imm=false expected true")
            fails = fails + 1
        }
        if ins.imm != 42 {
            println("[poc-test] FAIL int_lit: imm=" + str(ins.imm) + " expected 42")
            fails = fails + 1
        }
        if ins.result != vid {
            println("[poc-test] FAIL int_lit: instr.result=" + str(ins.result) + " != returned vid=" + str(vid))
            fails = fails + 1
        }
    }

    return fails
}
