// self/poc/expr/if_expr.hexa
// @kinds IfExpr

use "poc/common"
use "mini_native"

fn poc_ex_if_expr(e) -> int {
    // if-as-expression: each branch's last ExprStmt supplies the value.
    let else_label = poc_fresh_label()
    let end_label = poc_fresh_label()
    if !poc_lower_cond_branch(e.cond, else_label) { return -1 }
    let result_vid = poc_fresh_vid()
    // then branch
    let then_body = e.then_body
    let mut ti = 0
    while ti < len(then_body) {
        let is_last = ti == len(then_body) - 1
        if is_last && then_body[ti].kind == "ExprStmt" {
            let sv = poc_next_vid
            let v = poc_lower_expr(then_body[ti].left)
            if v < 0 { return -1 }
            poc_emit(mn_mov(result_vid, v))
            poc_next_vid = sv
        } else {
            let r = poc_lower_stmt(then_body[ti])
            if r < 0 { return -1 }
        }
        ti = ti + 1
    }
    poc_emit(mn_jmp(end_label))
    poc_emit(mn_label(else_label))
    // else branch
    let else_body = e.else_body
    let mut ei = 0
    while ei < len(else_body) {
        let is_last = ei == len(else_body) - 1
        if is_last && else_body[ei].kind == "ExprStmt" {
            let sv = poc_next_vid
            let v = poc_lower_expr(else_body[ei].left)
            if v < 0 { return -1 }
            poc_emit(mn_mov(result_vid, v))
            poc_next_vid = sv
        } else {
            let r = poc_lower_stmt(else_body[ei])
            if r < 0 { return -1 }
        }
        ei = ei + 1
    }
    poc_emit(mn_label(end_label))
    return result_vid
}
