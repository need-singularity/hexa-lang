// self/poc/expr/char_lit.hexa
// @kinds CharLit

use "poc/common"
use "mini_native"

fn poc_ex_char_lit(e) -> int {
    if len(e.value) >= 1 {
        let vid = poc_fresh_vid()
        // char_code(s, 0) — index 0 is safe (interp bug only affects non-zero idx).
        poc_emit(mn_load_imm(vid, char_code(e.value, 0)))
        return vid
    } else {
        print("[poc] CharLit empty")
        return -1
    }
}
