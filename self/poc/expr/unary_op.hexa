// self/poc/expr/unary_op.hexa
// @kinds UnaryOp

use "poc/common"
use "mini_native"

fn poc_ex_unary_op(e) -> int {
    let iv = poc_lower_expr(e.left)
    if iv < 0 { return -1 }
    if e.op == "-" {
        // neg = 0 - x
        let zero = poc_fresh_vid()
        poc_emit(mn_load_imm(zero, 0))
        let v = poc_fresh_vid()
        poc_emit(mn_sub(v, zero, iv))
        return v
    }
    if e.op == "!" {
        // logical not on 0/1: 1 - x
        let one = poc_fresh_vid()
        poc_emit(mn_load_imm(one, 1))
        let v = poc_fresh_vid()
        poc_emit(mn_sub(v, one, iv))
        return v
    }
    if e.op == "~" || e.op == "bitnot" {
        let v = poc_fresh_vid()
        poc_emit(mn_bnot(v, iv))
        return v
    }
    println("[poc] unsupported unary op: " + e.op)
    return -1
}
