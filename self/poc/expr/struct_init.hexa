// self/poc/expr/struct_init.hexa
// @kinds StructInit

use "poc/common"
use "mini_native"

fn poc_ex_struct_init(e) -> int {
    // Allocate struct fields in the 256-byte scratch frame.
    let struct_name = e.name
    let init_fields = e.fields
    let base_off = poc_arr_off
    let base_vid = poc_fresh_vid()
    poc_emit(mn_add_sp_imm(base_vid, base_off))
    let scope_mark = poc_next_vid
    let mut i = 0
    while i < len(init_fields) {
        let fi = init_fields[i]
        let fidx = poc_struct_field_index(struct_name, fi.name)
        if fidx < 0 {
            println("[poc] unknown struct field: " + struct_name + "." + fi.name)
            return -1
        }
        let val_vid = poc_lower_expr(fi.left)
        if val_vid < 0 { return -1 }
        poc_emit(mn_store_off(base_vid, fidx * 8, val_vid))
        poc_next_vid = scope_mark
        i = i + 1
    }
    poc_arr_off = poc_arr_off + len(init_fields) * 8
    return base_vid
}
