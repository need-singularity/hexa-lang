// self/poc/expr/bin_op.hexa
// @kinds BinOp

use "poc/common"
use "mini_native"

fn poc_ex_bin_op(e) -> int {
    let before = poc_next_vid
    // Comparison: materialize as 0/1 bool via CMP + CSET.
    let cmp_c = poc_cmp_code(e.op)
    if cmp_c >= 0 {
        let lv = poc_lower_expr(e.left)
        let rv = poc_lower_expr(e.right)
        let vid = poc_pick_binop_result_vid(lv, rv, before)
        poc_emit(mn_cmp_set(vid, lv, rv, cmp_c))
        return vid
    }
    let lv = poc_lower_expr(e.left)
    let rv = poc_lower_expr(e.right)
    let vid = poc_pick_binop_result_vid(lv, rv, before)
    if e.op == "+"  { poc_emit(mn_add(vid, lv, rv)); return vid }
    if e.op == "-"  { poc_emit(mn_sub(vid, lv, rv)); return vid }
    if e.op == "*"  { poc_emit(mn_mul(vid, lv, rv)); return vid }
    if e.op == "/"  { poc_emit(mn_div(vid, lv, rv)); return vid }
    if e.op == "%"  { poc_emit(mn_mod(vid, lv, rv)); return vid }
    if e.op == "&"  { poc_emit(mn_and(vid, lv, rv)); return vid }
    if e.op == "|"  { poc_emit(mn_or (vid, lv, rv)); return vid }
    if e.op == "^"  { poc_emit(mn_xor(vid, lv, rv)); return vid }
    if e.op == "<<" { poc_emit(mn_shl(vid, lv, rv)); return vid }
    if e.op == ">>" { poc_emit(mn_shr(vid, lv, rv)); return vid }
    // Logical ops treat operands as already 0/1 (no short-circuit in PoC).
    if e.op == "&&" { poc_emit(mn_and(vid, lv, rv)); return vid }
    if e.op == "||" { poc_emit(mn_or (vid, lv, rv)); return vid }
    println("[poc] unsupported BinOp: " + e.op)
    return -1
}
