// self/poc/expr/array.hexa
// @kinds Array, ArrayLit

use "poc/common"
use "mini_native"

fn poc_ex_array(e) -> int {
    // Layout: [length(8) | spare(8) | data(CAP*8)]. Data at base+16.
    // CAP = max(len*2, 16), capped at 128 — enough for small-program growth.
    let items = e.items
    let mut cap = len(items) * 2
    if cap < 16 { cap = 16 }
    if cap > 128 { cap = 128 }
    let base_off = poc_arr_off
    let base_vid = poc_fresh_vid()
    poc_emit(mn_add_sp_imm(base_vid, base_off))
    let scope_mark = poc_next_vid
    // length at [base+0]
    let len_vid = poc_fresh_vid()
    poc_emit(mn_load_imm(len_vid, len(items)))
    poc_emit(mn_store_off(base_vid, 0, len_vid))
    poc_next_vid = scope_mark
    // data at [base+16+i*8]
    let mut i = 0
    while i < len(items) {
        let val_vid = poc_lower_expr(items[i])
        if val_vid < 0 { return -1 }
        poc_emit(mn_store_off(base_vid, 16 + i * 8, val_vid))
        poc_next_vid = scope_mark
        i = i + 1
    }
    poc_arr_off = poc_arr_off + 16 + cap * 8
    return base_vid
}
