// self/poc/stmt/assert.hexa
// @kinds AssertStmt

use "poc/common"
use "mini_native"

fn poc_st_assert(stmt) -> int {
    // Same as assert builtin: if !cond, exit(1).
    let bool_vid = poc_lower_expr(stmt.left)
    if bool_vid < 0 { return -1 }
    let skip = poc_fresh_label()
    poc_emit(mn_cmp(bool_vid, 31))
    poc_emit(mn_br_cond(1, skip))
    let one_vid = poc_fresh_vid()
    poc_emit(mn_load_imm(one_vid, 1))
    poc_emit(mn_syscall1(33554433, one_vid))
    poc_emit(mn_label(skip))
    return 0
}
