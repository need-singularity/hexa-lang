// self/poc/stmt/assign.hexa
// @kinds AssignStmt

use "poc/common"
use "mini_native"

fn poc_st_assign(stmt) -> int {
    // Ident target: variable rebind.
    if stmt.left.kind == "Ident" {
        let target_vid = poc_lookup(stmt.left.name)
        if target_vid < 0 {
            println("[poc] assign to unbound: " + stmt.left.name)
            return -1
        }
        let scope_mark = poc_next_vid
        let rhs_vid = poc_lower_expr(stmt.right)
        if rhs_vid < 0 { return -1 }
        poc_emit(mn_mov(target_vid, rhs_vid))
        poc_next_vid = scope_mark
        return 0
    }
    // Index target: arr[i] = expr.
    // Field target: obj.name = expr.
    if stmt.left.kind == "Field" {
        let f_e = stmt.left
        if f_e.left.kind != "Ident" {
            println("[poc] field-assign target must be Ident.field (PoC)")
            return -1
        }
        let obj_name = f_e.left.name
        let struct_name = poc_var_struct_of(obj_name)
        if struct_name == "" {
            println("[poc] unknown struct for var: " + obj_name)
            return -1
        }
        let fidx = poc_struct_field_index(struct_name, f_e.name)
        if fidx < 0 {
            println("[poc] unknown field: " + struct_name + "." + f_e.name)
            return -1
        }
        let scope_mark = poc_next_vid
        let base_vid = poc_lower_expr(f_e.left)
        let rhs_vid = poc_lower_expr(stmt.right)
        if base_vid < 0 || rhs_vid < 0 { return -1 }
        poc_emit(mn_store_off(base_vid, fidx * 8, rhs_vid))
        poc_next_vid = scope_mark
        return 0
    }
    if stmt.left.kind == "Index" {
        let scope_mark = poc_next_vid
        let base_vid = poc_lower_expr(stmt.left.left)
        if base_vid < 0 { return -1 }
        let idx_e = stmt.left.right
        let rhs_vid = poc_lower_expr(stmt.right)
        if rhs_vid < 0 { return -1 }
        // Constant-index: STR rhs, [base, #16 + idx*8].
        if idx_e.kind == "IntLit" {
            let off = 16 + to_int(idx_e.value) * 8
            poc_emit(mn_store_off(base_vid, off, rhs_vid))
            poc_next_vid = scope_mark
            return 0
        }
        // General: addr = base + 16 + (idx << 3); STR rhs, [addr].
        let idx_vid = poc_lower_expr(idx_e)
        let shift_vid = poc_fresh_vid()
        poc_emit(mn_load_imm(shift_vid, 3))
        let offset_vid = poc_fresh_vid()
        poc_emit(mn_shl(offset_vid, idx_vid, shift_vid))
        let addr_vid = poc_fresh_vid()
        poc_emit(mn_add(addr_vid, base_vid, offset_vid))
        poc_emit(mn_add_imm(addr_vid, addr_vid, 16))
        poc_emit(mn_store_off(addr_vid, 0, rhs_vid))
        poc_next_vid = scope_mark
        return 0
    }
    println("[poc] unsupported assign target kind: " + stmt.left.kind)
    return -1
}
