// self/poc/stmt/for.hexa
// @kinds ForStmt

use "poc/common"
use "mini_native"

fn poc_st_for(stmt) -> int {
    let iter_e = stmt.iter_expr
    // for x in <ident> — iterate over compile-time-known-length array.
    if iter_e.kind == "Ident" {
        let base_vid = poc_lookup(iter_e.name)
        if base_vid < 0 { return -1 }
        // Length loaded at runtime from [base+0] (persistent per-loop).
        let alen_vid = poc_fresh_vid()
        poc_emit(mn_load_off(alen_vid, base_vid, 0))
        let idx_vid = poc_fresh_vid()
        poc_emit(mn_load_imm(idx_vid, 0))
        let elem_vid = poc_fresh_vid()
        poc_bind(stmt.name, elem_vid)
        let s_label = poc_fresh_label()
        let c_label = poc_fresh_label()
        let e_label = poc_fresh_label()
        poc_emit(mn_label(s_label))
        poc_emit(mn_cmp(idx_vid, alen_vid))
        poc_emit(mn_br_cond(10, e_label))  // GE → exit
        // elem = arr[idx] : addr = base + 16 + idx*8 ; elem = *addr
        let sm2 = poc_next_vid
        let sh_vid = poc_fresh_vid()
        poc_emit(mn_load_imm(sh_vid, 3))
        let off_vid = poc_fresh_vid()
        poc_emit(mn_shl(off_vid, idx_vid, sh_vid))
        let addr_vid = poc_fresh_vid()
        poc_emit(mn_add(addr_vid, base_vid, off_vid))
        poc_emit(mn_add_imm(addr_vid, addr_vid, 16))
        poc_emit(mn_load_off(elem_vid, addr_vid, 0))
        poc_next_vid = sm2
        // body
        poc_push_loop(e_label, c_label)
        let mut bi = 0
        while bi < len(stmt.body) {
            let r = poc_lower_stmt(stmt.body[bi])
            if r < 0 { poc_pop_loop(); return -1 }
            if r == 1 { break }
            bi = bi + 1
        }
        poc_pop_loop()
        poc_emit(mn_label(c_label))
        poc_emit(mn_add_imm(idx_vid, idx_vid, 1))
        poc_emit(mn_jmp(s_label))
        poc_emit(mn_label(e_label))
        return 0
    }
    if iter_e.kind != "Range" {
        println("[poc] for iter must be Range or Ident (PoC): " + iter_e.kind)
        return -1
    }
    let inclusive = iter_e.value == "inclusive"
    let start_vid = poc_lower_expr(iter_e.left)
    let loop_vid = poc_fresh_vid()
    poc_emit(mn_mov(loop_vid, start_vid))
    poc_bind(stmt.name, loop_vid)
    let end_vid = poc_fresh_vid()
    let end_init = poc_lower_expr(iter_e.right)
    if end_init != end_vid {
        poc_emit(mn_mov(end_vid, end_init))
    }
    let start_label = poc_fresh_label()
    let cont_label = poc_fresh_label()      // inc + back-edge target
    let end_label = poc_fresh_label()
    poc_emit(mn_label(start_label))
    poc_emit(mn_cmp(loop_vid, end_vid))
    let skip_cond = if inclusive { 12 } else { 10 }
    poc_emit(mn_br_cond(skip_cond, end_label))
    // body
    poc_push_loop(end_label, cont_label)
    let mut bi = 0
    while bi < len(stmt.body) {
        let r = poc_lower_stmt(stmt.body[bi])
        if r < 0 { poc_pop_loop(); return -1 }
        if r == 1 { break }
        bi = bi + 1
    }
    poc_pop_loop()
    poc_emit(mn_label(cont_label))
    let one_vid = poc_fresh_vid()
    poc_emit(mn_load_imm(one_vid, 1))
    let new_loop = poc_fresh_vid()
    poc_emit(mn_add(new_loop, loop_vid, one_vid))
    poc_emit(mn_mov(loop_vid, new_loop))
    poc_emit(mn_jmp(start_label))
    poc_emit(mn_label(end_label))
    return 0
}
