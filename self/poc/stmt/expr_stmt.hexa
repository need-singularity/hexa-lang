// self/poc/stmt/expr_stmt.hexa
// @kinds ExprStmt

use "poc/common"
use "mini_native"

fn poc_st_expr_stmt(stmt) -> int {
    if stmt.left.kind == "IfExpr" {
        return poc_lower_if_stmt(stmt.left)
    }
    let scope_mark = poc_next_vid
    let vid = poc_lower_expr(stmt.left)
    if vid < 0 { return -1 }
    poc_next_vid = scope_mark    // discard result — statement has no binding
    return 0
}
