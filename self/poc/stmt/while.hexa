// self/poc/stmt/while.hexa
// @kinds WhileStmt

use "poc/common"
use "mini_native"

fn poc_st_while(stmt) -> int {
    let start_label = poc_fresh_label()
    let end_label = poc_fresh_label()
    poc_emit(mn_label(start_label))
    if !poc_lower_cond_branch(stmt.cond, end_label) { return -1 }
    poc_push_loop(end_label, start_label)    // continue = re-test cond
    let mut bi = 0
    while bi < len(stmt.body) {
        let r = poc_lower_stmt(stmt.body[bi])
        if r < 0 { poc_pop_loop(); return -1 }
        if r == 1 { break }
        bi = bi + 1
    }
    poc_pop_loop()
    poc_emit(mn_jmp(start_label))
    poc_emit(mn_label(end_label))
    return 0
}
