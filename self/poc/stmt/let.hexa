// self/poc/stmt/let.hexa
// @kinds LetStmt, LetMutStmt

use "poc/common"
use "mini_native"

fn poc_st_let(stmt) -> int {
    let vid = poc_lower_expr(stmt.left)
    if vid < 0 { return -1 }
    poc_bind(stmt.name, vid)
    if stmt.left.kind == "StructInit" {
        poc_bind_var_struct(stmt.name, stmt.left.name)
        // Capture compile-time length for any StringLit-initialized
        // string field so len(t.field) can return the literal length
        // without a runtime strlen (POC has no ldrb).
        let mut k = 0
        while k < len(stmt.left.fields) {
            let fi = stmt.left.fields[k]
            if fi.left.kind == "StringLit" {
                poc_bind_field_str_len(stmt.name, fi.name, len(fi.left.value))
            }
            k = k + 1
        }
    }
    if stmt.left.kind == "Array" || stmt.left.kind == "ArrayLit" {
        poc_bind_arr_len(stmt.name, len(stmt.left.items))
    }
    if stmt.left.kind == "StringLit" {
        poc_bind_str_len(stmt.name, len(stmt.left.value))
    }
    if stmt.left.kind == "MapLit" {
        poc_bind_map(stmt.name, len(stmt.left.items))
    }
    // If RHS is a Call whose callee returns a registered struct,
    // propagate the struct type so field access on this var resolves.
    if stmt.left.kind == "Call" && stmt.left.left.kind == "Ident" {
        let rt = poc_fn_ret_struct_of(stmt.left.left.name)
        if rt != "" { poc_bind_var_struct(stmt.name, rt) }
    }
    return 0
}
