// self/poc/stmt/compound_assign.hexa
// @kinds CompoundAssign

use "poc/common"
use "mini_native"

fn poc_st_compound_assign(stmt) -> int {
    // x OP= expr → x = x OP expr. Only Ident target, int ops.
    if stmt.left.kind != "Ident" {
        println("[poc] compound-assign target must be Ident (PoC)")
        return -1
    }
    let target_vid = poc_lookup(stmt.left.name)
    if target_vid < 0 {
        println("[poc] compound-assign to unbound: " + stmt.left.name)
        return -1
    }
    let sm = poc_next_vid
    let rhs_vid = poc_lower_expr(stmt.right)
    if rhs_vid < 0 { return -1 }
    let result_vid = poc_fresh_vid()
    if stmt.op == "+" { poc_emit(mn_add(result_vid, target_vid, rhs_vid)) }
    else if stmt.op == "-" { poc_emit(mn_sub(result_vid, target_vid, rhs_vid)) }
    else if stmt.op == "*" { poc_emit(mn_mul(result_vid, target_vid, rhs_vid)) }
    else if stmt.op == "/" { poc_emit(mn_div(result_vid, target_vid, rhs_vid)) }
    else if stmt.op == "%" { poc_emit(mn_mod(result_vid, target_vid, rhs_vid)) }
    else {
        println("[poc] unsupported compound op: " + stmt.op)
        return -1
    }
    poc_emit(mn_mov(target_vid, result_vid))
    poc_next_vid = sm
    return 0
}
