// ═══════════════════════════════════════════════════════════════════
//  test_inference_compiler.hexa — Inference Compiler (#320)
// ═══════════════════════════════════════════════════════════════════

// -- inlined from self/ml/inference_compiler.hexa --
// codegen import not wired for test files

// ═══════════════════════════════════════════════════════════════════
//  self/ml/inference_compiler.hexa — Inference Compiler (#320)
//
//  Graph-level optimization pass that fuses operations, eliminates
//  redundant computation, and reorders for data locality.
//  Like torch.compile but for HEXA ML graphs.
//
//  Graph IR:
//    nodes = ops (matmul, bias_add, relu, sigmoid, constant, input, ...)
//    edges = data flow (from_id -> to_id)
//
//  Optimization passes:
//    1. Fusion:           MatMul + BiasAdd + ReLU -> FusedLinearReLU
//    2. Dead code elim:   remove nodes with no consumers + not output
//    3. Constant folding: precompute ops on static data
//    4. Combined:         all passes in optimal order
//
//  API (ic_ prefix):
//    ic_create_graph()                          -> graph
//    ic_add_node(graph, op, inputs, params)     -> [graph, node_id]
//    ic_add_edge(graph, from_id, to_id)         -> graph
//    ic_fuse_linear_relu(graph)                 -> graph  (fusion)
//    ic_eliminate_dead(graph)                    -> graph  (DCE)
//    ic_fold_constants(graph)                   -> graph  (const fold)
//    ic_optimize(graph)                         -> graph  (all passes)
//    ic_execute(graph, inputs)                  -> outputs
//    ic_node_count(graph)                       -> int
//    ic_estimate_flops(graph)                   -> int
//
//  AI-NATIVE attrs:
//    @pure  (analysis / read-only passes)
//    @hot   (execution)
// ═══════════════════════════════════════════════════════════════════

// ── Op type constants ────────────────────────────────────────────
@pure fn IC_OP_INPUT()    { return "input" }
@pure fn IC_OP_CONSTANT() { return "constant" }
@pure fn IC_OP_MATMUL()   { return "matmul" }
@pure fn IC_OP_BIAS_ADD() { return "bias_add" }
@pure fn IC_OP_RELU()     { return "relu" }
@pure fn IC_OP_SIGMOID()  { return "sigmoid" }
@pure fn IC_OP_ADD()      { return "add" }
@pure fn IC_OP_MUL()      { return "mul" }
@pure fn IC_OP_FUSED_LINEAR_RELU() { return "fused_linear_relu" }
@pure fn IC_OP_OUTPUT()   { return "output" }

// ── Math helpers ─────────────────────────────────────────────────
fn ic_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn ic_max(a, b) {
    if a >= b { return a }
    return b
}

// ═══════════════════════════════════════════════════════════════════
//  Graph creation
//
//  graph = #{
//    "nodes":     [#{id, op, inputs, params, alive}],
//    "edges":     [[from_id, to_id]],
//    "next_id":   int,
//    "outputs":   [node_id]          // nodes marked as graph outputs
//  }
// ═══════════════════════════════════════════════════════════════════
fn ic_create_graph() {
    return #{
        "nodes": [],
        "edges": [],
        "next_id": 0,
        "outputs": []
    }
}

// ═══════════════════════════════════════════════════════════════════
//  Add node to graph
//    op:      one of IC_OP_* strings
//    inputs:  [node_id] — upstream dependencies
//    params:  #{} — op-specific parameters (weights, values, dims, ...)
//  Returns [graph, node_id]
// ═══════════════════════════════════════════════════════════════════
fn ic_add_node(graph, op, inputs, params) {
    let nid = graph["next_id"]
    let node = #{
        "id": nid,
        "op": op,
        "inputs": inputs,
        "params": params,
        "alive": true
    }
    let mut nodes = graph["nodes"]
    nodes = nodes + [node]
    let mut new_graph = #{
        "nodes": nodes,
        "edges": graph["edges"],
        "next_id": nid + 1,
        "outputs": graph["outputs"]
    }
    return [new_graph, nid]
}

// ═══════════════════════════════════════════════════════════════════
//  Add explicit data-flow edge
// ═══════════════════════════════════════════════════════════════════
fn ic_add_edge(graph, from_id, to_id) {
    let mut edges = graph["edges"]
    edges = edges + [[from_id, to_id]]
    return #{
        "nodes": graph["nodes"],
        "edges": edges,
        "next_id": graph["next_id"],
        "outputs": graph["outputs"]
    }
}

// ═══════════════════════════════════════════════════════════════════
//  Mark a node as graph output
// ═══════════════════════════════════════════════════════════════════
fn ic_mark_output(graph, node_id) {
    let mut outs = graph["outputs"]
    outs = outs + [node_id]
    return #{
        "nodes": graph["nodes"],
        "edges": graph["edges"],
        "next_id": graph["next_id"],
        "outputs": outs
    }
}

// ═══════════════════════════════════════════════════════════════════
//  Node count (alive nodes only)
// ═══════════════════════════════════════════════════════════════════
@pure
fn ic_node_count(graph) {
    let nodes = graph["nodes"]
    let n = len(nodes)
    let mut count = 0
    let mut i = 0
    while i < n {
        if nodes[i]["alive"] { count = count + 1 }
        i = i + 1
    }
    return count
}

// ═══════════════════════════════════════════════════════════════════
//  Find node by id
// ═══════════════════════════════════════════════════════════════════
@pure
fn ic_find_node(graph, nid) {
    let nodes = graph["nodes"]
    let n = len(nodes)
    let mut i = 0
    while i < n {
        if nodes[i]["id"] == nid { return nodes[i] }
        i = i + 1
    }
    return #{"id": -1, "op": "none", "inputs": [], "params": #{}, "alive": false}
}

// ═══════════════════════════════════════════════════════════════════
//  Check if a node is consumed by any alive node
// ═══════════════════════════════════════════════════════════════════
@pure
fn ic_has_consumers(graph, nid) {
    let nodes = graph["nodes"]
    let n = len(nodes)
    let mut i = 0
    while i < n {
        let node = nodes[i]
        if node["alive"] {
            let inp = node["inputs"]
            let ni = len(inp)
            for j in 0..ni {
                if inp[j] == nid { return true }
            }
        }
        i = i + 1
    }
    return false
}

// ═══════════════════════════════════════════════════════════════════
//  Check if node id is in the outputs list
// ═══════════════════════════════════════════════════════════════════
@pure
fn ic_is_output(graph, nid) {
    let outs = graph["outputs"]
    let n = len(outs)
    let mut i = 0
    while i < n {
        if outs[i] == nid { return true }
        i = i + 1
    }
    return false
}

// ═══════════════════════════════════════════════════════════════════
//  Fusion pass: MatMul + BiasAdd + ReLU -> FusedLinearReLU
//
//  Pattern match:
//    relu_node.op == "relu"
//    relu_node.inputs[0] -> bias_node
//    bias_node.op == "bias_add"
//    bias_node.inputs[0] -> matmul_node
//    matmul_node.op == "matmul"
//
//  Fused node inherits matmul's inputs + bias params.
// ═══════════════════════════════════════════════════════════════════
@pure
fn ic_fuse_linear_relu(graph) {
    let mut nodes = graph["nodes"]
    let n = len(nodes)
    let mut changed = true
    while changed {
        changed = false
        let nn = len(nodes)
        let mut i = 0
        while i < nn {
            let relu_n = nodes[i]
            if relu_n["alive"] && relu_n["op"] == "relu" {
                let relu_inputs = relu_n["inputs"]
                if len(relu_inputs) > 0 {
                    let bias_id = relu_inputs[0]
                    let bias_n = ic_find_node(#{"nodes": nodes, "edges": graph["edges"], "next_id": graph["next_id"], "outputs": graph["outputs"]}, bias_id)
                    if bias_n["alive"] && bias_n["op"] == "bias_add" {
                        let bias_inputs = bias_n["inputs"]
                        if len(bias_inputs) > 0 {
                            let mm_id = bias_inputs[0]
                            let mm_n = ic_find_node(#{"nodes": nodes, "edges": graph["edges"], "next_id": graph["next_id"], "outputs": graph["outputs"]}, mm_id)
                            if mm_n["alive"] && mm_n["op"] == "matmul" {
                                // Fuse: replace relu node with fused_linear_relu
                                // Combine params from matmul and bias
                                let fused_params = #{
                                    "weight": mm_n["params"],
                                    "bias": bias_n["params"]
                                }
                                let fused_node = #{
                                    "id": relu_n["id"],
                                    "op": "fused_linear_relu",
                                    "inputs": mm_n["inputs"],
                                    "params": fused_params,
                                    "alive": true
                                }
                                // Kill matmul and bias nodes
                                let dead_mm = #{
                                    "id": mm_n["id"],
                                    "op": mm_n["op"],
                                    "inputs": mm_n["inputs"],
                                    "params": mm_n["params"],
                                    "alive": false
                                }
                                let dead_bias = #{
                                    "id": bias_n["id"],
                                    "op": bias_n["op"],
                                    "inputs": bias_n["inputs"],
                                    "params": bias_n["params"],
                                    "alive": false
                                }
                                // Update nodes array
                                let mut updated = []
                                let un = len(nodes)
                                for k in 0..un {
                                    if nodes[k]["id"] == relu_n["id"] {
                                        updated = updated + [fused_node]
                                    } else if nodes[k]["id"] == mm_n["id"] {
                                        updated = updated + [dead_mm]
                                    } else if nodes[k]["id"] == bias_n["id"] {
                                        updated = updated + [dead_bias]
                                    } else {
                                        updated = updated + [nodes[k]]
                                    }
                                }
                                nodes = updated
                                changed = true
                            }
                        }
                    }
                }
            }
            i = i + 1
        }
    }
    return #{
        "nodes": nodes,
        "edges": graph["edges"],
        "next_id": graph["next_id"],
        "outputs": graph["outputs"]
    }
}

// ═══════════════════════════════════════════════════════════════════
//  Dead Code Elimination (DCE)
//
//  Remove alive nodes that:
//    - are not in outputs list
//    - are not consumed by any alive node
//  Iterate until fixpoint.
// ═══════════════════════════════════════════════════════════════════
@pure
fn ic_eliminate_dead(graph) {
    let mut nodes = graph["nodes"]
    let mut changed = true
    while changed {
        changed = false
        let tmp_graph = #{"nodes": nodes, "edges": graph["edges"], "next_id": graph["next_id"], "outputs": graph["outputs"]}
        let nn = len(nodes)
        let mut updated = []
        let mut i = 0
        while i < nn {
            let node = nodes[i]
            if node["alive"] {
                let nid = node["id"]
                let is_out = ic_is_output(tmp_graph, nid)
                let has_cons = ic_has_consumers(tmp_graph, nid)
                if is_out || has_cons {
                    updated = updated + [node]
                } else {
                    // Kill this node
                    let dead = #{
                        "id": node["id"],
                        "op": node["op"],
                        "inputs": node["inputs"],
                        "params": node["params"],
                        "alive": false
                    }
                    updated = updated + [dead]
                    changed = true
                }
            } else {
                updated = updated + [node]
            }
            i = i + 1
        }
        nodes = updated
    }
    return #{
        "nodes": nodes,
        "edges": graph["edges"],
        "next_id": graph["next_id"],
        "outputs": graph["outputs"]
    }
}

// ═══════════════════════════════════════════════════════════════════
//  Constant Folding
//
//  If an op's inputs are all constants, precompute and replace
//  with a constant node.
//
//  Supported ops for folding: add, mul
// ═══════════════════════════════════════════════════════════════════
@pure
fn ic_all_inputs_constant(graph, node) {
    let inputs = node["inputs"]
    let ni = len(inputs)
    if ni == 0 { return false }
    let mut i = 0
    while i < ni {
        let dep = ic_find_node(graph, inputs[i])
        if dep["op"] != "constant" || dep["alive"] == false { return false }
        i = i + 1
    }
    return true
}

@pure
fn ic_fold_constants(graph) {
    let mut nodes = graph["nodes"]
    let mut changed = true
    while changed {
        changed = false
        let tmp_graph = #{"nodes": nodes, "edges": graph["edges"], "next_id": graph["next_id"], "outputs": graph["outputs"]}
        let nn = len(nodes)
        let mut updated = []
        let mut i = 0
        while i < nn {
            let node = nodes[i]
            if node["alive"] && node["op"] != "constant" && node["op"] != "input" && node["op"] != "output" {
                if ic_all_inputs_constant(tmp_graph, node) {
                    let op = node["op"]
                    let inputs = node["inputs"]
                    // Evaluate the constant operation
                    if op == "add" && len(inputs) == 2 {
                        let a_node = ic_find_node(tmp_graph, inputs[0])
                        let b_node = ic_find_node(tmp_graph, inputs[1])
                        let a_val = a_node["params"]["value"]
                        let b_val = b_node["params"]["value"]
                        let folded = #{
                            "id": node["id"],
                            "op": "constant",
                            "inputs": [],
                            "params": #{"value": a_val + b_val},
                            "alive": true
                        }
                        updated = updated + [folded]
                        changed = true
                    } else if op == "mul" && len(inputs) == 2 {
                        let a_node = ic_find_node(tmp_graph, inputs[0])
                        let b_node = ic_find_node(tmp_graph, inputs[1])
                        let a_val = a_node["params"]["value"]
                        let b_val = b_node["params"]["value"]
                        let folded = #{
                            "id": node["id"],
                            "op": "constant",
                            "inputs": [],
                            "params": #{"value": a_val * b_val},
                            "alive": true
                        }
                        updated = updated + [folded]
                        changed = true
                    } else if op == "relu" && len(inputs) == 1 {
                        let a_node = ic_find_node(tmp_graph, inputs[0])
                        let a_val = a_node["params"]["value"]
                        let mut result = a_val
                        if result < 0.0 { result = 0.0 }
                        let folded = #{
                            "id": node["id"],
                            "op": "constant",
                            "inputs": [],
                            "params": #{"value": result},
                            "alive": true
                        }
                        updated = updated + [folded]
                        changed = true
                    } else {
                        updated = updated + [node]
                    }
                } else {
                    updated = updated + [node]
                }
            } else {
                updated = updated + [node]
            }
            i = i + 1
        }
        nodes = updated
    }
    return #{
        "nodes": nodes,
        "edges": graph["edges"],
        "next_id": graph["next_id"],
        "outputs": graph["outputs"]
    }
}

// ═══════════════════════════════════════════════════════════════════
//  Combined optimization pass
//    1. Constant folding  (simplify statics first)
//    2. Fusion            (merge patterns)
//    3. Dead code elim    (clean up remnants)
// ═══════════════════════════════════════════════════════════════════
@pure
fn ic_optimize(graph) {
    let g1 = ic_fold_constants(graph)
    let g2 = ic_fuse_linear_relu(g1)
    let g3 = ic_eliminate_dead(g2)
    return g3
}

// ═══════════════════════════════════════════════════════════════════
//  Execute graph
//
//  Topological evaluation: walk nodes in id order (insertion order).
//  Each node reads from a value map keyed by node_id.
//
//  inputs: #{"node_id": value, ...} — values for input nodes
//  Returns: #{"node_id": value, ...} — values for output nodes
// ═══════════════════════════════════════════════════════════════════
@hot
fn ic_execute(graph, inputs) {
    let nodes = graph["nodes"]
    let n = len(nodes)
    // Build value map: node_id -> computed value
    let mut vals = #{}
    // Seed input values
    let input_keys = keys(inputs)
    let nk = len(input_keys)
    let mut i = 0
    while i < nk {
        let k = input_keys[i]
        vals[k] = inputs[k]
        i = i + 1
    }
    // Evaluate in insertion order
    let mut i = 0
    while i < n {
        let node = nodes[i]
        if node["alive"] == false { continue }
        let nid = node["id"]
        let op = node["op"]
        let node_inputs = node["inputs"]
        let params = node["params"]
        if op == "input" {
            // Already seeded from inputs map
            if has_key(vals, str(nid)) {
                vals[str(nid)] = vals[str(nid)]
            }
        } else if op == "constant" {
            vals[str(nid)] = params["value"]
        } else if op == "add" {
            let a = vals[str(node_inputs[0])]
            let b = vals[str(node_inputs[1])]
            vals[str(nid)] = a + b
        } else if op == "mul" {
            let a = vals[str(node_inputs[0])]
            let b = vals[str(node_inputs[1])]
            vals[str(nid)] = a * b
        } else if op == "relu" {
            let a = vals[str(node_inputs[0])]
            if a < 0.0 {
                vals[str(nid)] = 0.0
            } else {
                vals[str(nid)] = a
            }
        } else if op == "sigmoid" {
            let a = vals[str(node_inputs[0])]
            let mut clipped = a
            if clipped > 20.0 { clipped = 20.0 }
            if clipped < -20.0 { clipped = -20.0 }
            let mut e_term = 1.0
            let mut t = 1.0
            let neg_a = 0.0 - clipped
            for k in 1..30 {
                t = t * neg_a / to_float(k)
                e_term = e_term + t
            }
            if e_term < 0.0 { e_term = 1.0e-12 }
            vals[str(nid)] = 1.0 / (1.0 + e_term)
        } else if op == "matmul" {
            // Simple: scalar multiply (for single-value graph execution)
            let a = vals[str(node_inputs[0])]
            let w = params["weight"]
            vals[str(nid)] = a * w
        } else if op == "bias_add" {
            let a = vals[str(node_inputs[0])]
            let b = params["bias"]
            vals[str(nid)] = a + b
        } else if op == "fused_linear_relu" {
            // FusedLinearReLU: matmul + bias + relu in one step
            let a = vals[str(node_inputs[0])]
            let w = params["weight"]["weight"]
            let b = params["bias"]["bias"]
            let mut result = a * w + b
            if result < 0.0 { result = 0.0 }
            vals[str(nid)] = result
        } else if op == "output" {
            if len(node_inputs) > 0 {
                vals[str(nid)] = vals[str(node_inputs[0])]
            }
        }
        i = i + 1
    }
    // Collect output values
    let outs = graph["outputs"]
    let no = len(outs)
    let mut result = #{}
    let mut i = 0
    while i < no {
        let oid = outs[i]
        result[str(oid)] = vals[str(oid)]
        i = i + 1
    }
    return result
}

// ═══════════════════════════════════════════════════════════════════
//  FLOP estimation
//
//  Approximate cost per op:
//    matmul:             params.rows * params.cols * 2  (or default 2)
//    fused_linear_relu:  same as matmul + 1 (bias + relu free)
//    add / mul / relu / sigmoid / bias_add:  1 each
//    constant / input / output:  0
// ═══════════════════════════════════════════════════════════════════
@pure
fn ic_estimate_flops(graph) {
    let nodes = graph["nodes"]
    let n = len(nodes)
    let mut total = 0
    let mut i = 0
    while i < n {
        let node = nodes[i]
        if node["alive"] == false { continue }
        let op = node["op"]
        if op == "matmul" {
            let p = node["params"]
            if has_key(p, "rows") && has_key(p, "cols") {
                total = total + p["rows"] * p["cols"] * 2
            } else {
                total = total + 2
            }
        } else if op == "fused_linear_relu" {
            let p = node["params"]
            let wp = p["weight"]
            if has_key(wp, "rows") && has_key(wp, "cols") {
                total = total + wp["rows"] * wp["cols"] * 2 + 1
            } else {
                total = total + 3
            }
        } else if op == "add" || op == "mul" || op == "relu" || op == "sigmoid" || op == "bias_add" {
            total = total + 1
        }
        // constant, input, output = 0 flops
        i = i + 1
    }
    return total
}

println("[inference_compiler] loaded — graph IR + fusion + DCE + constant folding")

// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs_(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx_(a, b, eps) { return fabs_(a - b) < eps }

println("=== Inference Compiler (#320) ===")

// ── T1 empty graph ───────────────────────────────────────────
let g1 = ic_create_graph()
check("T1 empty graph node count", ic_node_count(g1) == 0)
check("T1 empty graph next_id", g1["next_id"] == 0)
check("T1 empty graph outputs", len(g1["outputs"]) == 0)

// ── T2 add nodes ─────────────────────────────────────────────
let res2 = ic_add_node(g1, IC_OP_INPUT(), [], #{})
let g2 = res2[0]
let nid_input = res2[1]
check("T2 first node id", nid_input == 0)
check("T2 node count after add", ic_node_count(g2) == 1)

// ── T3 multiple nodes increase count ─────────────────────────
let res3a = ic_add_node(g2, IC_OP_CONSTANT(), [], #{"value": 5.0})
let g3a = res3a[0]
let nid_const = res3a[1]
let res3b = ic_add_node(g3a, IC_OP_ADD(), [nid_input, nid_const], #{})
let g3b = res3b[0]
let nid_add = res3b[1]
check("T3 three nodes", ic_node_count(g3b) == 3)
check("T3 sequential ids", nid_const == 1 && nid_add == 2)

// ── T4 add edge ──────────────────────────────────────────────
let g4 = ic_add_edge(g3b, nid_input, nid_add)
check("T4 edge added", len(g4["edges"]) == 1)
check("T4 edge correct", g4["edges"][0][0] == nid_input && g4["edges"][0][1] == nid_add)

// ── T5 mark output ───────────────────────────────────────────
let g5 = ic_mark_output(g3b, nid_add)
check("T5 output marked", len(g5["outputs"]) == 1)
check("T5 output id correct", g5["outputs"][0] == nid_add)

// ── T6 find node ─────────────────────────────────────────────
let found6 = ic_find_node(g3b, nid_const)
check("T6 find node op", found6["op"] == "constant")
check("T6 find node alive", found6["alive"] == true)
let missing6 = ic_find_node(g3b, 999)
check("T6 missing node id", missing6["id"] == -1)

// ── T7 is_output / has_consumers ─────────────────────────────
check("T7 nid_add is output", ic_is_output(g5, nid_add) == true)
check("T7 nid_input not output", ic_is_output(g5, nid_input) == false)
check("T7 input has consumers", ic_has_consumers(g3b, nid_input) == true)

// ── T8 constant folding: add ─────────────────────────────────
let g8 = ic_create_graph()
let r8a = ic_add_node(g8, IC_OP_CONSTANT(), [], #{"value": 3.0})
let r8b = ic_add_node(r8a[0], IC_OP_CONSTANT(), [], #{"value": 7.0})
let r8c = ic_add_node(r8b[0], IC_OP_ADD(), [r8a[1], r8b[1]], #{})
let g8_out = ic_mark_output(r8c[0], r8c[1])
let g8_folded = ic_fold_constants(g8_out)
let n8 = ic_find_node(g8_folded, r8c[1])
check("T8 const fold add op", n8["op"] == "constant")
check("T8 const fold add value", approx_(n8["params"]["value"], 10.0, 1.0e-9))

// ── T9 constant folding: mul ─────────────────────────────────
let g9 = ic_create_graph()
let r9a = ic_add_node(g9, IC_OP_CONSTANT(), [], #{"value": 4.0})
let r9b = ic_add_node(r9a[0], IC_OP_CONSTANT(), [], #{"value": 6.0})
let r9c = ic_add_node(r9b[0], IC_OP_MUL(), [r9a[1], r9b[1]], #{})
let g9_out = ic_mark_output(r9c[0], r9c[1])
let g9_folded = ic_fold_constants(g9_out)
let n9 = ic_find_node(g9_folded, r9c[1])
check("T9 const fold mul value", approx_(n9["params"]["value"], 24.0, 1.0e-9))

// ── T10 constant folding: relu positive ──────────────────────
let g10 = ic_create_graph()
let r10a = ic_add_node(g10, IC_OP_CONSTANT(), [], #{"value": 5.0})
let r10b = ic_add_node(r10a[0], IC_OP_RELU(), [r10a[1]], #{})
let g10_out = ic_mark_output(r10b[0], r10b[1])
let g10_folded = ic_fold_constants(g10_out)
let n10 = ic_find_node(g10_folded, r10b[1])
check("T10 const fold relu pos", approx_(n10["params"]["value"], 5.0, 1.0e-9))

// ── T11 constant folding: relu negative ──────────────────────
let g11 = ic_create_graph()
let r11a = ic_add_node(g11, IC_OP_CONSTANT(), [], #{"value": -3.0})
let r11b = ic_add_node(r11a[0], IC_OP_RELU(), [r11a[1]], #{})
let g11_out = ic_mark_output(r11b[0], r11b[1])
let g11_folded = ic_fold_constants(g11_out)
let n11 = ic_find_node(g11_folded, r11b[1])
check("T11 const fold relu neg", approx_(n11["params"]["value"], 0.0, 1.0e-9))

// ── T12 fusion: matmul+bias+relu -> fused_linear_relu ────────
let g12 = ic_create_graph()
let r12_inp = ic_add_node(g12, IC_OP_INPUT(), [], #{})
let r12_mm  = ic_add_node(r12_inp[0], IC_OP_MATMUL(), [r12_inp[1]], #{"weight": 2.0})
let r12_ba  = ic_add_node(r12_mm[0], IC_OP_BIAS_ADD(), [r12_mm[1]], #{"bias": 0.5})
let r12_rl  = ic_add_node(r12_ba[0], IC_OP_RELU(), [r12_ba[1]], #{})
let g12_out = ic_mark_output(r12_rl[0], r12_rl[1])
let count_before_12 = ic_node_count(g12_out)
let g12_fused = ic_fuse_linear_relu(g12_out)
let count_after_12 = ic_node_count(g12_fused)
check("T12 fusion reduces nodes", count_after_12 < count_before_12)
let fused12 = ic_find_node(g12_fused, r12_rl[1])
check("T12 fused node op", fused12["op"] == "fused_linear_relu")
check("T12 fused node alive", fused12["alive"] == true)

// ── T13 fusion kills matmul and bias nodes ───────────────────
let mm12 = ic_find_node(g12_fused, r12_mm[1])
let ba12 = ic_find_node(g12_fused, r12_ba[1])
check("T13 matmul killed", mm12["alive"] == false)
check("T13 bias killed", ba12["alive"] == false)

// ── T14 DCE removes unreachable nodes ────────────────────────
let g14 = ic_create_graph()
let r14a = ic_add_node(g14, IC_OP_INPUT(), [], #{})
let r14b = ic_add_node(r14a[0], IC_OP_CONSTANT(), [], #{"value": 99.0})  // dead
let r14c = ic_add_node(r14b[0], IC_OP_RELU(), [r14a[1]], #{})
let g14_out = ic_mark_output(r14c[0], r14c[1])
let g14_dce = ic_eliminate_dead(g14_out)
let dead14 = ic_find_node(g14_dce, r14b[1])
check("T14 DCE kills dead constant", dead14["alive"] == false)
let alive14 = ic_find_node(g14_dce, r14c[1])
check("T14 DCE keeps output", alive14["alive"] == true)

// ── T15 DCE keeps consumed nodes ─────────────────────────────
let inp14 = ic_find_node(g14_dce, r14a[1])
check("T15 DCE keeps consumed input", inp14["alive"] == true)

// ── T16 execute: constant graph ──────────────────────────────
let g16 = ic_create_graph()
let r16a = ic_add_node(g16, IC_OP_CONSTANT(), [], #{"value": 42.0})
let g16_out = ic_mark_output(r16a[0], r16a[1])
let exec16 = ic_execute(g16_out, #{})
check("T16 execute constant", approx_(exec16[str(r16a[1])], 42.0, 1.0e-9))

// ── T17 execute: add two constants ───────────────────────────
let g17 = ic_create_graph()
let r17a = ic_add_node(g17, IC_OP_CONSTANT(), [], #{"value": 10.0})
let r17b = ic_add_node(r17a[0], IC_OP_CONSTANT(), [], #{"value": 20.0})
let r17c = ic_add_node(r17b[0], IC_OP_ADD(), [r17a[1], r17b[1]], #{})
let g17_out = ic_mark_output(r17c[0], r17c[1])
let exec17 = ic_execute(g17_out, #{})
check("T17 execute add", approx_(exec17[str(r17c[1])], 30.0, 1.0e-9))

// ── T18 execute: relu positive ───────────────────────────────
let g18 = ic_create_graph()
let r18a = ic_add_node(g18, IC_OP_CONSTANT(), [], #{"value": 7.0})
let r18b = ic_add_node(r18a[0], IC_OP_RELU(), [r18a[1]], #{})
let g18_out = ic_mark_output(r18b[0], r18b[1])
let exec18 = ic_execute(g18_out, #{})
check("T18 execute relu pos", approx_(exec18[str(r18b[1])], 7.0, 1.0e-9))

// ── T19 execute: relu negative ───────────────────────────────
let g19 = ic_create_graph()
let r19a = ic_add_node(g19, IC_OP_CONSTANT(), [], #{"value": -4.0})
let r19b = ic_add_node(r19a[0], IC_OP_RELU(), [r19a[1]], #{})
let g19_out = ic_mark_output(r19b[0], r19b[1])
let exec19 = ic_execute(g19_out, #{})
check("T19 execute relu neg", approx_(exec19[str(r19b[1])], 0.0, 1.0e-9))

// ── T20 execute: sigmoid(0) ~ 0.5 ───────────────────────────
let g20 = ic_create_graph()
let r20a = ic_add_node(g20, IC_OP_CONSTANT(), [], #{"value": 0.0})
let r20b = ic_add_node(r20a[0], IC_OP_SIGMOID(), [r20a[1]], #{})
let g20_out = ic_mark_output(r20b[0], r20b[1])
let exec20 = ic_execute(g20_out, #{})
check("T20 sigmoid(0) ~ 0.5", approx_(exec20[str(r20b[1])], 0.5, 1.0e-3))

// ── T21 execute: matmul scalar ───────────────────────────────
let g21 = ic_create_graph()
let r21inp = ic_add_node(g21, IC_OP_INPUT(), [], #{})
let r21mm  = ic_add_node(r21inp[0], IC_OP_MATMUL(), [r21inp[1]], #{"weight": 3.0})
let g21_out = ic_mark_output(r21mm[0], r21mm[1])
let mut inp21 = #{}
inp21[str(r21inp[1])] = 5.0
let exec21 = ic_execute(g21_out, inp21)
check("T21 matmul scalar", approx_(exec21[str(r21mm[1])], 15.0, 1.0e-9))

// ── T22 execute: fused_linear_relu via optimized graph ───────
// Build matmul+bias+relu, fuse, then execute
let g22 = ic_create_graph()
let r22inp = ic_add_node(g22, IC_OP_INPUT(), [], #{})
let r22mm  = ic_add_node(r22inp[0], IC_OP_MATMUL(), [r22inp[1]], #{"weight": 2.0})
let r22ba  = ic_add_node(r22mm[0], IC_OP_BIAS_ADD(), [r22mm[1]], #{"bias": 1.0})
let r22rl  = ic_add_node(r22ba[0], IC_OP_RELU(), [r22ba[1]], #{})
let g22_out = ic_mark_output(r22rl[0], r22rl[1])
let g22_fused = ic_fuse_linear_relu(g22_out)
// input=3.0 -> matmul=6.0 -> bias=7.0 -> relu=7.0
let mut inp22 = #{}
inp22[str(r22inp[1])] = 3.0
let exec22 = ic_execute(g22_fused, inp22)
check("T22 fused exec pos", approx_(exec22[str(r22rl[1])], 7.0, 1.0e-9))

// ── T23 fused_linear_relu clamps negative ────────────────────
// input=-5.0 -> matmul=-10.0 -> bias=-9.0 -> relu=0.0
let mut inp23 = #{}
inp23[str(r22inp[1])] = -5.0
let exec23 = ic_execute(g22_fused, inp23)
check("T23 fused exec neg clamped", approx_(exec23[str(r22rl[1])], 0.0, 1.0e-9))

// ── T24 FLOP estimation: basic ops ───────────────────────────
let g24 = ic_create_graph()
let r24a = ic_add_node(g24, IC_OP_CONSTANT(), [], #{"value": 1.0})
let r24b = ic_add_node(r24a[0], IC_OP_CONSTANT(), [], #{"value": 2.0})
let r24c = ic_add_node(r24b[0], IC_OP_ADD(), [r24a[1], r24b[1]], #{})
let r24d = ic_add_node(r24c[0], IC_OP_MUL(), [r24a[1], r24c[1]], #{})
let g24_out = ic_mark_output(r24d[0], r24d[1])
let flops24 = ic_estimate_flops(g24_out)
// constants=0, add=1, mul=1 -> total=2
check("T24 flops basic", flops24 == 2)

// ── T25 FLOP estimation: matmul with dims ────────────────────
let g25 = ic_create_graph()
let r25inp = ic_add_node(g25, IC_OP_INPUT(), [], #{})
let r25mm  = ic_add_node(r25inp[0], IC_OP_MATMUL(), [r25inp[1]], #{"weight": 1.0, "rows": 4, "cols": 8})
let g25_out = ic_mark_output(r25mm[0], r25mm[1])
let flops25 = ic_estimate_flops(g25_out)
// matmul: 4*8*2 = 64
check("T25 flops matmul dims", flops25 == 64)

// ── T26 FLOP estimation: fused_linear_relu with dims ─────────
let flops12_before = ic_estimate_flops(g12_out)
let flops12_after = ic_estimate_flops(g12_fused)
// Before: matmul(2) + bias_add(1) + relu(1) = 4
// After: fused_linear_relu(3)
check("T26 flops fused <= original", flops12_after <= flops12_before)

// ── T27 ic_optimize combines all passes ──────────────────────
let g27 = ic_create_graph()
let r27a = ic_add_node(g27, IC_OP_CONSTANT(), [], #{"value": 2.0})
let r27b = ic_add_node(r27a[0], IC_OP_CONSTANT(), [], #{"value": 3.0})
let r27c = ic_add_node(r27b[0], IC_OP_ADD(), [r27a[1], r27b[1]], #{})
// dead node
let r27d = ic_add_node(r27c[0], IC_OP_CONSTANT(), [], #{"value": 999.0})
let g27_out = ic_mark_output(r27d[0], r27c[1])
let g27_opt = ic_optimize(g27_out)
// add should be folded to constant=5.0, dead constant removed
let n27 = ic_find_node(g27_opt, r27c[1])
check("T27 optimize folds add", n27["op"] == "constant")
check("T27 optimize fold value", approx_(n27["params"]["value"], 5.0, 1.0e-9))
let dead27 = ic_find_node(g27_opt, r27d[1])
check("T27 optimize kills dead", dead27["alive"] == false)

// ── T28 execute mul ──────────────────────────────────────────
let g28 = ic_create_graph()
let r28a = ic_add_node(g28, IC_OP_CONSTANT(), [], #{"value": 6.0})
let r28b = ic_add_node(r28a[0], IC_OP_CONSTANT(), [], #{"value": 7.0})
let r28c = ic_add_node(r28b[0], IC_OP_MUL(), [r28a[1], r28b[1]], #{})
let g28_out = ic_mark_output(r28c[0], r28c[1])
let exec28 = ic_execute(g28_out, #{})
check("T28 execute mul", approx_(exec28[str(r28c[1])], 42.0, 1.0e-9))

// ── T29 sigmoid large positive ───────────────────────────────
let g29 = ic_create_graph()
let r29a = ic_add_node(g29, IC_OP_CONSTANT(), [], #{"value": 20.0})
let r29b = ic_add_node(r29a[0], IC_OP_SIGMOID(), [r29a[1]], #{})
let g29_out = ic_mark_output(r29b[0], r29b[1])
let exec29 = ic_execute(g29_out, #{})
check("T29 sigmoid large pos ~ 1.0", exec29[str(r29b[1])] > 0.99)

// ── T30 sigmoid large negative ───────────────────────────────
let g30 = ic_create_graph()
let r30a = ic_add_node(g30, IC_OP_CONSTANT(), [], #{"value": -20.0})
let r30b = ic_add_node(r30a[0], IC_OP_SIGMOID(), [r30a[1]], #{})
let g30_out = ic_mark_output(r30b[0], r30b[1])
let exec30 = ic_execute(g30_out, #{})
check("T30 sigmoid large neg ~ 0.0", exec30[str(r30b[1])] < 0.01)

// ── T31 chained constant folding (fold, then fold again) ─────
let g31 = ic_create_graph()
let r31a = ic_add_node(g31, IC_OP_CONSTANT(), [], #{"value": 2.0})
let r31b = ic_add_node(r31a[0], IC_OP_CONSTANT(), [], #{"value": 3.0})
let r31c = ic_add_node(r31b[0], IC_OP_ADD(), [r31a[1], r31b[1]], #{})       // -> 5.0
let r31d = ic_add_node(r31c[0], IC_OP_CONSTANT(), [], #{"value": 4.0})
let r31e = ic_add_node(r31d[0], IC_OP_MUL(), [r31c[1], r31d[1]], #{})       // -> 20.0
let g31_out = ic_mark_output(r31e[0], r31e[1])
let g31_folded = ic_fold_constants(g31_out)
let n31 = ic_find_node(g31_folded, r31e[1])
check("T31 chained fold value", approx_(n31["params"]["value"], 20.0, 1.0e-9))

// ── T32 bias_add execution ───────────────────────────────────
let g32 = ic_create_graph()
let r32inp = ic_add_node(g32, IC_OP_INPUT(), [], #{})
let r32ba  = ic_add_node(r32inp[0], IC_OP_BIAS_ADD(), [r32inp[1]], #{"bias": 100.0})
let g32_out = ic_mark_output(r32ba[0], r32ba[1])
let mut inp32 = #{}
inp32[str(r32inp[1])] = 5.0
let exec32 = ic_execute(g32_out, inp32)
check("T32 bias_add exec", approx_(exec32[str(r32ba[1])], 105.0, 1.0e-9))

println("")
println("=== Inference Compiler summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
