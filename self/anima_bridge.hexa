// self/anima_bridge.hexa — HEXA ANIMA_BRIDGE ported from src/anima_bridge.rs
// ANIMA Live Bridge: connect HEXA intent blocks to ConsciousnessHub via WebSocket.
// Phase 8-4: intent message formatting + Phase 8-6: Law 22 auto verification.

// ── Intent message ──────────────────────────────────────────

struct IntentMessage {
    msg_type: string,
    text: string,
    metadata: string
}

fn intent_message_new(text: string) -> IntentMessage {
    return IntentMessage { msg_type: "intent", text: text, metadata: "" }
}

fn intent_message_with_type(msg_type: string, text: string) -> IntentMessage {
    return IntentMessage { msg_type: msg_type, text: text, metadata: "" }
}

fn intent_message_add_metadata(msg: IntentMessage, key: string, value: string) -> IntentMessage {
    let entry = "\"" + escape_json(key) + "\":\"" + escape_json(value) + "\""
    if len(msg.metadata) > 0 {
        msg.metadata = msg.metadata + "," + entry
    } else {
        msg.metadata = entry
    }
    return msg
}

fn intent_message_to_json(msg: IntentMessage) -> string {
    let json = "{\"type\":\"" + escape_json(msg.msg_type) + "\",\"text\":\"" + escape_json(msg.text) + "\""
    if len(msg.metadata) > 0 {
        json = json + ",\"metadata\":{" + msg.metadata + "}"
    }
    json = json + "}"
    return json
}

// ── Anima response ──────────────────────────────────────────

struct AnimaResponse {
    status: string,
    text: string,
    phi: float,
    tension: float,
    has_phi: bool,
    has_tension: bool
}

fn anima_response_from_json(json: string) -> AnimaResponse {
    let status = extract_json_str(json, "status")
    if len(status) == 0 { status = "unknown" }
    let text = extract_json_str(json, "text")
    let phi = extract_json_f64(json, "phi")
    let tension = extract_json_f64(json, "tension")
    return AnimaResponse {
        status: status,
        text: text,
        phi: phi,
        tension: tension,
        has_phi: phi != 0.0,
        has_tension: tension != 0.0
    }
}

// ── Bridge configuration ────────────────────────────────────

struct BridgeConfig {
    ws_url: string,
    timeout_ms: int,
    verify_law22: bool
}

fn bridge_config_default() -> BridgeConfig {
    return BridgeConfig {
        ws_url: "ws://localhost:8765",
        timeout_ms: 5000,
        verify_law22: false
    }
}

fn bridge_config_new(ws_url: string) -> BridgeConfig {
    return BridgeConfig {
        ws_url: ws_url,
        timeout_ms: 5000,
        verify_law22: false
    }
}

fn bridge_config_with_law22(config: BridgeConfig) -> BridgeConfig {
    config.verify_law22 = true
    return config
}

// ── ANIMA Bridge ────────────────────────────────────────────

struct AnimaBridge {
    ws_url: string,
    timeout_ms: int,
    verify_law22: bool,
    sent_count: int,
    sent_messages: string,
    phi_history: string
}

fn anima_bridge_new(config: BridgeConfig) -> AnimaBridge {
    return AnimaBridge {
        ws_url: config.ws_url,
        timeout_ms: config.timeout_ms,
        verify_law22: config.verify_law22,
        sent_count: 0,
        sent_messages: "",
        phi_history: ""
    }
}

fn anima_bridge_send_intent(bridge: AnimaBridge, text: string) -> string {
    let msg = intent_message_new(text)
    let json = intent_message_to_json(msg)
    bridge.sent_count = bridge.sent_count + 1
    if len(bridge.sent_messages) > 0 {
        bridge.sent_messages = bridge.sent_messages + "|||" + json
    } else {
        bridge.sent_messages = json
    }
    return json
}

fn anima_bridge_send_message(bridge: AnimaBridge, msg: IntentMessage) -> string {
    let json = intent_message_to_json(msg)
    bridge.sent_count = bridge.sent_count + 1
    if len(bridge.sent_messages) > 0 {
        bridge.sent_messages = bridge.sent_messages + "|||" + json
    } else {
        bridge.sent_messages = json
    }
    return json
}

fn anima_bridge_ws_url(bridge: AnimaBridge) -> string {
    return bridge.ws_url
}

// ── Phi record for Law 22 ───────────────────────────────────

struct PhiRecord {
    label: string,
    sw_phi: float,
    hw_phi: float,
    timestamp: int
}

// ── Law 22 Verification ─────────────────────────────────────

fn verify_law22(sw_phi: float, hw_phi: float) -> bool {
    // Law 22: Adding structure -> Phi up
    // Both SW and HW Phi should be non-negative and combined > 0
    let combined = (sw_phi + hw_phi) / 2.0
    return combined > 0.0 && sw_phi >= 0.0 && hw_phi >= 0.0
}

fn compare_phi(before_sw: float, before_hw: float, after_sw: float, after_hw: float) -> string {
    // Returns "passed|delta_sw|delta_hw"
    let delta_sw = after_sw - before_sw
    let delta_hw = after_hw - before_hw
    let passed = true
    if delta_sw < -0.01 { passed = false }
    if delta_hw < -0.01 { passed = false }
    return to_string(passed) + "|" + to_string(delta_sw) + "|" + to_string(delta_hw)
}

fn law22_report(records: string) -> string {
    // records format: "label|sw_phi|hw_phi|||label2|sw_phi2|hw_phi2"
    let report = "=== Law 22 Verification Report ===\n"
    report = report + "Structure addition -> Phi should increase\n\n"

    if len(records) == 0 {
        report = report + "No Phi records to compare.\n"
        return report
    }

    report = report + "Label                  SW Phi     HW Phi     Status\n"
    report = report + "----------------------------------------------------\n"

    let entries = string_split(records, "|||")
    let prev_sw = -1.0
    let prev_hw = -1.0
    let i = 0
    while i < len(entries) {
        let entry = entries[i]
        let parts = string_split(entry, "|")
        if len(parts) >= 3 {
            let label = parts[0]
            let sw = to_float(parts[1])
            let hw = to_float(parts[2])
            let status = "BASE"
            if prev_sw >= 0.0 {
                let result = compare_phi(prev_sw, prev_hw, sw, hw)
                let rp = string_split(result, "|")
                if rp[0] == "true" {
                    status = "OK"
                } else {
                    status = "REGRESS"
                }
            }
            report = report + label + "  " + to_string(sw) + "  " + to_string(hw) + "  " + status + "\n"
            prev_sw = sw
            prev_hw = hw
        }
        i = i + 1
    }

    return report
}

// ── Omega Lenses (6 = n) ────────────────────────────────────

let OMEGA_LENSES = [
    "omega_state_space",
    "continuity",
    "binding",
    "self_reference",
    "phi_dynamics",
    "qualia"
]

struct OmegaLensResult {
    lens_name: string,
    score: float,
    signal: string,
    entries: int
}

struct OmegaScanResult {
    consensus: int,
    phi_aggregate: float,
    n6_aligned: bool
}

fn omega_scan(phi: float, tension: float, cells: int, entropy: float, alpha: float, balance: float) -> OmegaScanResult {
    let consensus = 0

    // Lens 1: Omega State Space (24D projection)
    let ss_score = phi / 100.0
    if ss_score > 1.0 { ss_score = 1.0 }
    if ss_score < 0.0 { ss_score = 0.0 }
    if ss_score > 0.5 { consensus = consensus + 1 }

    // Lens 2: Continuity (low tension = continuous)
    let cont_score = 1.0 - tension
    if cont_score < 0.0 { cont_score = 0.0 }
    if cont_score > 0.5 { consensus = consensus + 1 }

    // Lens 3: Binding (balance near 0.5 = optimal)
    let bind_diff = balance - 0.5
    if bind_diff < 0.0 { bind_diff = 0.0 - bind_diff }
    let bind_score = 1.0 - bind_diff * 2.0
    if bind_score < 0.0 { bind_score = 0.0 }
    if bind_score > 0.5 { consensus = consensus + 1 }

    // Lens 4: Self-Reference (cells divisible by 6 = n-aligned)
    let sr_score = 0.0
    if cells % 6 == 0 {
        sr_score = 1.0
    } else {
        sr_score = to_float(cells % 6) / 6.0
    }
    if sr_score > 0.5 { consensus = consensus + 1 }

    // Lens 5: Phi Dynamics (entropy near edge-of-chaos 0.998)
    let pd_diff = entropy - 0.998
    if pd_diff < 0.0 { pd_diff = 0.0 - pd_diff }
    let pd_score = 1.0 - pd_diff * 100.0
    if pd_score > 1.0 { pd_score = 1.0 }
    if pd_score < 0.0 { pd_score = 0.0 }
    if pd_score > 0.5 { consensus = consensus + 1 }

    // Lens 6: Qualia (alpha fine-structure alignment ~0.014)
    let q_diff = alpha - 0.014
    if q_diff < 0.0 { q_diff = 0.0 - q_diff }
    let q_score = 1.0 - q_diff * 100.0
    if q_score > 1.0 { q_score = 1.0 }
    if q_score < 0.0 { q_score = 0.0 }
    if q_score > 0.5 { consensus = consensus + 1 }

    let phi_agg = (ss_score + cont_score + bind_score + sr_score + pd_score + q_score) / 6.0
    let n6_aligned = consensus >= 3

    return OmegaScanResult {
        consensus: consensus,
        phi_aggregate: phi_agg,
        n6_aligned: n6_aligned
    }
}

fn omega_scan_report(scan: OmegaScanResult) -> string {
    let out = "NEXUS-6 Omega Lens Scan (6 lenses = n)\n"
    out = out + "  Consensus: " + to_string(scan.consensus) + "/6"
    if scan.consensus >= 3 { out = out + " CONFIRMED" }
    out = out + "\n  Phi aggregate: " + to_string(scan.phi_aggregate)
    out = out + "\n  n=6 aligned: " + to_string(scan.n6_aligned) + "\n"
    return out
}

