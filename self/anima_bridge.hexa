// ── JSON helpers ────────────────────────────────────────────

fn escape_json(s: string) -> string {
    let mut parts = []
    let i = 0
    while i < len(s) {
        let ch = s[i]
        if ch == "\"" {
            parts.push("\\\"")
        } else {
            if ch == "\\" {
                parts.push("\\\\")
            } else {
                if ch == "\n" {
                    parts.push("\\n")
                } else {
                    if ch == "\r" {
                        parts.push("\\r")
                    } else {
                        if ch == "\t" {
                            parts.push("\\t")
                        } else {
                            parts.push(ch)
                        }
                    }
                }
            }
        }
        i = i + 1
    }
    return parts.join("")
}

fn extract_json_str(json: string, key: string) -> string {
    let pattern = "\"" + key + "\""
    let pos = string_find(json, pattern)
    if pos < 0 { return "" }
    let after = string_slice(json, pos + len(pattern), len(json))
    let colon = string_find(after, ":")
    if colon < 0 { return "" }
    let value_part = string_trim(string_slice(after, colon + 1, len(after)))
    if string_starts_with(value_part, "\"") {
        let end = string_find(string_slice(value_part, 1, len(value_part)), "\"")
        if end >= 0 {
            return string_slice(value_part, 1, 1 + end)
        }
    }
    return ""
}

fn extract_json_f64(json: string, key: string) -> float {
    let pattern = "\"" + key + "\""
    let pos = string_find(json, pattern)
    if pos < 0 { return 0.0 }
    let after = string_slice(json, pos + len(pattern), len(json))
    let colon = string_find(after, ":")
    if colon < 0 { return 0.0 }
    let value_part = string_trim(string_slice(after, colon + 1, len(after)))
    let num_str = ""
    let i = 0
    while i < len(value_part) {
        let ch = value_part[i]
        if ch == "0" || ch == "1" || ch == "2" || ch == "3" || ch == "4" || ch == "5" || ch == "6" || ch == "7" || ch == "8" || ch == "9" || ch == "." || ch == "-" || ch == "e" || ch == "E" || ch == "+" {
            num_str = num_str + ch
        } else {
            i = len(value_part)
        }
        i = i + 1
    }
    if len(num_str) == 0 { return 0.0 }
    return to_float(num_str)
}
