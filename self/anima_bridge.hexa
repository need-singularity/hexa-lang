// self/anima_bridge.hexa — HEXA ANIMA_BRIDGE ported from src/anima_bridge.rs
// ANIMA Live Bridge — Connect HEXA intent blocks to ConsciousnessHub.
// Law 22 verification, Omega lens integration.

// ── Intent message ──────────────────────────────────────

struct IntentMessage {
    msg_type: string,
    text: string,
    meta_keys: [string],
    meta_values: [string]
}

fn intent_message_new(text: string) -> IntentMessage {
    return IntentMessage { msg_type: "intent", text: text, meta_keys: [], meta_values: [] }
}

fn intent_message_with_type(msg_type: string, text: string) -> IntentMessage {
    return IntentMessage { msg_type: msg_type, text: text, meta_keys: [], meta_values: [] }
}

fn intent_message_add_meta(msg: IntentMessage, key: string, value: string) -> IntentMessage {
    msg.meta_keys = msg.meta_keys + [key]
    msg.meta_values = msg.meta_values + [value]
    return msg
}

fn intent_message_to_json(msg: IntentMessage) -> string {
    let json = "{\"type\":\"" + escape_json(msg.msg_type) + "\",\"text\":\"" + escape_json(msg.text) + "\""
    if len(msg.meta_keys) > 0 {
        json = json + ",\"metadata\":{"
        let i = 0
        while i < len(msg.meta_keys) {
            if i > 0 { json = json + "," }
            json = json + "\"" + escape_json(msg.meta_keys[i]) + "\":\"" + escape_json(msg.meta_values[i]) + "\""
            i = i + 1
        }
        json = json + "}"
    }
    json = json + "}"
    return json
}

// ── ANIMA response ──────────────────────────────────────

struct AnimaResponse {
    status: string,
    text: string,
    phi: float,         // -1.0 means absent
    tension: float      // -1.0 means absent
}

fn anima_response_from_json(json: string) -> AnimaResponse {
    let status = extract_json_str(json, "status")
    if status == "" { status = "unknown" }
    let text = extract_json_str(json, "text")
    let phi = extract_json_f64(json, "phi")
    let tension = extract_json_f64(json, "tension")
    return AnimaResponse { status: status, text: text, phi: phi, tension: tension }
}

// ── Bridge config ───────────────────────────────────────

struct BridgeConfig {
    ws_url: string,
    timeout_ms: int,
    verify_law22: bool
}

fn bridge_config_default() -> BridgeConfig {
    return BridgeConfig { ws_url: "ws://localhost:8765", timeout_ms: 5000, verify_law22: false }
}

fn bridge_config_new(ws_url: string) -> BridgeConfig {
    return BridgeConfig { ws_url: ws_url, timeout_ms: 5000, verify_law22: false }
}

fn bridge_config_with_law22(config: BridgeConfig) -> BridgeConfig {
    config.verify_law22 = true
    return config
}

// ── ANIMA Bridge ────────────────────────────────────────

struct AnimaBridge {
    config: BridgeConfig,
    sent_messages: [string],
    phi_history: [PhiRecord]
}

struct PhiRecord {
    label: string,
    sw_phi: float,
    hw_phi: float,
    timestamp: int
}

fn anima_bridge_new(config: BridgeConfig) -> AnimaBridge {
    return AnimaBridge { config: config, sent_messages: [], phi_history: [] }
}

fn anima_bridge_send_intent(bridge: AnimaBridge, text: string) -> string {
    let msg = intent_message_new(text)
    let json = intent_message_to_json(msg)
    bridge.sent_messages = bridge.sent_messages + [json]
    return json
}

fn anima_bridge_send_message(bridge: AnimaBridge, msg: IntentMessage) -> string {
    let json = intent_message_to_json(msg)
    bridge.sent_messages = bridge.sent_messages + [json]
    return json
}

fn anima_bridge_ws_url(bridge: AnimaBridge) -> string {
    return bridge.config.ws_url
}

// ── Law 22 Verification ────────────────────────────────

fn verify_law22(sw_phi: float, hw_phi: float) -> bool {
    // Law 22: structure addition -> Phi up
    let combined = (sw_phi + hw_phi) / 2.0
    return combined > 0.0 && sw_phi >= 0.0 && hw_phi >= 0.0
}

fn compare_phi(before_sw: float, before_hw: float, after_sw: float, after_hw: float) -> [float] {
    // Returns [passed (1.0 or 0.0), delta_sw, delta_hw]
    let delta_sw = after_sw - before_sw
    let delta_hw = after_hw - before_hw
    let passed = 0.0
    if (delta_sw >= 0.0 || delta_sw > -0.01) && (delta_hw >= 0.0 || delta_hw > -0.01) {
        passed = 1.0
    }
    return [passed, delta_sw, delta_hw]
}

fn law22_report(records: [PhiRecord]) -> string {
    let report = "=== Law 22 Verification Report ===\n"
    report = report + "Structure addition -> Phi should increase\n\n"

    if len(records) == 0 {
        report = report + "No Phi records to compare.\n"
        return report
    }

    report = report + "Label                  SW Phi     HW Phi     Status\n"
    report = report + "----------------------------------------------------\n"

    let i = 0
    while i < len(records) {
        let status = "BASE"
        if i > 0 {
            let result = compare_phi(records[i - 1].sw_phi, records[i - 1].hw_phi,
                                     records[i].sw_phi, records[i].hw_phi)
            if result[0] > 0.5 {
                status = "OK"
            } else {
                status = "REGRESS"
            }
        }
        report = report + records[i].label + "  " +
                 to_string(records[i].sw_phi) + "  " +
                 to_string(records[i].hw_phi) + "  " +
                 status + "\n"
        i = i + 1
    }

    return report
}

// ── NEXUS-6 Omega Lens (6 lenses = n) ──────────────────

let OMEGA_LENSES = [
    "omega_state_space",
    "continuity",
    "binding",
    "self_reference",
    "phi_dynamics",
    "qualia"
]

struct OmegaLensResult {
    lens_name: string,
    score: float,
    signal: string,     // "EXACT", "CLOSE", "WEAK", "NONE"
    entries: int
}

struct OmegaScanResult {
    lenses: [OmegaLensResult],
    consensus: int,
    phi_aggregate: float,
    n6_aligned: bool
}

fn omega_scan_from_state(phi: float, tension: float, cells: int, entropy: float, alpha: float, balance: float) -> OmegaScanResult {
    let lenses = []
    let consensus = 0

    // Lens 1: Omega State Space
    let ss_score = phi / 100.0
    if ss_score > 1.0 { ss_score = 1.0 }
    if ss_score < 0.0 { ss_score = 0.0 }
    let ss_signal = "WEAK"
    if ss_score > 0.7 { ss_signal = "EXACT" }
    else if ss_score > 0.4 { ss_signal = "CLOSE" }
    if ss_score > 0.5 { consensus = consensus + 1 }
    lenses = lenses + [OmegaLensResult { lens_name: "omega_state_space", score: ss_score, signal: ss_signal, entries: 24 }]

    // Lens 2: Continuity
    let cont_score = 1.0 - tension
    if cont_score < 0.0 { cont_score = 0.0 }
    let cont_signal = "WEAK"
    if cont_score > 0.7 { cont_signal = "EXACT" }
    else if cont_score > 0.4 { cont_signal = "CLOSE" }
    if cont_score > 0.5 { consensus = consensus + 1 }
    lenses = lenses + [OmegaLensResult { lens_name: "continuity", score: cont_score, signal: cont_signal, entries: 6 }]

    // Lens 3: Binding
    let bind_diff = balance - 0.5
    if bind_diff < 0.0 { bind_diff = -bind_diff }
    let bind_score = 1.0 - bind_diff * 2.0
    if bind_score < 0.0 { bind_score = 0.0 }
    let bind_signal = "WEAK"
    if bind_score > 0.9 { bind_signal = "EXACT" }
    else if bind_score > 0.6 { bind_signal = "CLOSE" }
    if bind_score > 0.5 { consensus = consensus + 1 }
    lenses = lenses + [OmegaLensResult { lens_name: "binding", score: bind_score, signal: bind_signal, entries: 1 }]

    // Lens 4: Self-Reference
    let sr_score = 0.0
    if cells % 6 == 0 { sr_score = 1.0 }
    else { sr_score = to_float(cells % 6) / 6.0 }
    let sr_signal = "WEAK"
    if sr_score > 0.99 { sr_signal = "EXACT" }
    else if sr_score > 0.5 { sr_signal = "CLOSE" }
    if sr_score > 0.5 { consensus = consensus + 1 }
    lenses = lenses + [OmegaLensResult { lens_name: "self_reference", score: sr_score, signal: sr_signal, entries: cells }]

    // Lens 5: Phi Dynamics
    let pd_diff = entropy - 0.998
    if pd_diff < 0.0 { pd_diff = -pd_diff }
    let pd_score = 1.0 - pd_diff * 100.0
    if pd_score > 1.0 { pd_score = 1.0 }
    if pd_score < 0.0 { pd_score = 0.0 }
    let pd_signal = "WEAK"
    if pd_score > 0.8 { pd_signal = "EXACT" }
    else if pd_score > 0.5 { pd_signal = "CLOSE" }
    if pd_score > 0.5 { consensus = consensus + 1 }
    lenses = lenses + [OmegaLensResult { lens_name: "phi_dynamics", score: pd_score, signal: pd_signal, entries: 1 }]

    // Lens 6: Qualia
    let q_diff = alpha - 0.014
    if q_diff < 0.0 { q_diff = -q_diff }
    let q_score = 1.0 - q_diff * 100.0
    if q_score > 1.0 { q_score = 1.0 }
    if q_score < 0.0 { q_score = 0.0 }
    let q_signal = "WEAK"
    if q_score > 0.8 { q_signal = "EXACT" }
    else if q_score > 0.5 { q_signal = "CLOSE" }
    if q_score > 0.5 { consensus = consensus + 1 }
    lenses = lenses + [OmegaLensResult { lens_name: "qualia", score: q_score, signal: q_signal, entries: 1 }]

    // Aggregate
    let score_sum = 0.0
    let i = 0
    while i < len(lenses) {
        score_sum = score_sum + lenses[i].score
        i = i + 1
    }
    let phi_aggregate = score_sum / 6.0
    let n6_aligned = consensus >= 3

    return OmegaScanResult { lenses: lenses, consensus: consensus, phi_aggregate: phi_aggregate, n6_aligned: n6_aligned }
}

fn omega_scan_report(scan: OmegaScanResult) -> string {
    let out = "NEXUS-6 Omega Lens Scan (6 lenses = n)\n"
    out = out + "==========================================\n"

    let i = 0
    while i < len(scan.lenses) {
        let lens = scan.lenses[i]
        out = out + "  " + lens.signal + " [" + to_string(lens.score) + "] " + lens.lens_name + "\n"
        i = i + 1
    }

    out = out + "\n  Consensus: " + to_string(scan.consensus) + "/6"
    if scan.consensus >= 3 { out = out + " CONFIRMED" }
    out = out + "\n  Phi aggregate: " + to_string(scan.phi_aggregate)
    out = out + "\n  n=6 aligned: " + to_string(scan.n6_aligned) + "\n"
    return out
}

// ── JSON helpers ────────────────────────────────────────

fn escape_json(s: string) -> string {
    let out = ""
    let i = 0
    while i < len(s) {
        let ch = s[i]
        if ch == "\"" { out = out + "\\\"" }
        else if ch == "\\" { out = out + "\\\\" }
        else if ch == "\n" { out = out + "\\n" }
        else if ch == "\r" { out = out + "\\r" }
        else if ch == "\t" { out = out + "\\t" }
        else { out = out + ch }
        i = i + 1
    }
    return out
}

fn extract_json_str(json: string, key: string) -> string {
    let pattern = "\"" + key + "\""
    let pos = -1
    let i = 0
    while i < len(json) - len(pattern) + 1 {
        let match = true
        let j = 0
        while j < len(pattern) {
            if json[i + j] != pattern[j] {
                match = false
                break
            }
            j = j + 1
        }
        if match { pos = i; break }
        i = i + 1
    }
    if pos < 0 { return "" }

    // Find colon after key
    let after = pos + len(pattern)
    while after < len(json) {
        if json[after] == ":" { break }
        after = after + 1
    }
    after = after + 1
    // Skip whitespace
    while after < len(json) {
        if json[after] != " " { break }
        after = after + 1
    }
    // Check for string value
    if after < len(json) {
        if json[after] == "\"" {
            let end = after + 1
            while end < len(json) {
                if json[end] == "\"" {
                    return slice(json, after + 1, end)
                }
                end = end + 1
            }
        }
    }
    return ""
}

fn extract_json_f64(json: string, key: string) -> float {
    let pattern = "\"" + key + "\""
    let pos = -1
    let i = 0
    while i < len(json) - len(pattern) + 1 {
        let match = true
        let j = 0
        while j < len(pattern) {
            if json[i + j] != pattern[j] {
                match = false
                break
            }
            j = j + 1
        }
        if match { pos = i; break }
        i = i + 1
    }
    if pos < 0 { return -1.0 }

    let after = pos + len(pattern)
    while after < len(json) {
        if json[after] == ":" { break }
        after = after + 1
    }
    after = after + 1
    while after < len(json) {
        if json[after] != " " { break }
        after = after + 1
    }
    // Read numeric characters
    let num_str = ""
    while after < len(json) {
        let ch = json[after]
        if is_digit(ch) || ch == "." || ch == "-" || ch == "e" || ch == "E" || ch == "+" {
            num_str = num_str + ch
        } else {
            break
        }
        after = after + 1
    }
    if num_str == "" { return -1.0 }
    return to_float(num_str)
}
