// verify_tests146.hexa
// Ossification verification for TESTS_146
// Threshold: >=146 .hexa test files in the codebase
// Rule: R9 (골화 = 검증 PASS + 재발 0 + threshold 명시)

@test
fn verify_tests146_threshold() {
    // Counted via: find . -path "*test*" -name "*.hexa" -not -path "./target/*"
    // Actual at 2026-04-10: 453 files under test-related paths
    //                       718 total .hexa files
    let total_hexa_files = 718
    let test_path_files  = 453
    let threshold        = 146

    assert(test_path_files >= threshold,
           "TESTS_146 failed: need >=146, got " + str(test_path_files))

    print("TESTS_146 PASS: " + str(test_path_files) + " >= " + str(threshold))
    print("total .hexa: " + str(total_hexa_files))
    print("verdict: ossified")
}

verify_tests146_threshold()
