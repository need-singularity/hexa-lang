struct ExternFnDecl {
    name: string,
    params: [string],
    ret_type: string
}

fn collect_extern_decls(stmts: [string]) -> [ExternFnDecl] {
    let result = []
    // In full impl, filter Stmt::Extern from stmts
    return result
}
