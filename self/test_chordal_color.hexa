// self/ml/chordal_color.hexa — ROI #73: Chordal Graph Coloring
//
// For chordal interference graphs (common in SSA-form programs),
// uses polynomial-time perfect elimination ordering for optimal
// coloring instead of NP-hard general graph coloring.
//
// Pipeline: live_ranges -> interference graph -> PEO -> greedy color

fn anp_cc_has_color(arr, val) {
    let mut i = 0
    while i < len(arr) {
        if arr[i] == val { return true }
        i = i + 1
    }
    return false
}

fn anp_cc_index(arr, val) {
    let mut i = 0
    while i < len(arr) {
        if arr[i] == val { return i }
        i = i + 1
    }
    return -1
}

fn anp_cc_remove(arr, val) {
    let mut out = []
    let mut found = false
    let mut i = 0
    while i < len(arr) {
        if arr[i] == val && !found {
            found = true
        } else {
            out.push(arr[i])
        }
        i = i + 1
    }
    return out
}

// Build an interference graph from live ranges.
// live_ranges: array of [var_id, start, end]
// Returns: [nodes, adj] where nodes=[var_ids], adj=[[neighbors], ...]
fn anp_build_interference(live_ranges) {
    let mut nodes = []
    let mut i = 0
    while i < len(live_ranges) {
        let vid = live_ranges[i][0]
        if !anp_cc_has_color(nodes, vid) {
            nodes.push(vid)
        }
        i = i + 1
    }
    nodes = nodes.sort()
    let n = len(nodes)
    let mut adj = []
    i = 0
    while i < n {
        adj.push([])
        i = i + 1
    }
    i = 0
    while i < len(live_ranges) {
        let mut j = i + 1
        while j < len(live_ranges) {
            let a_id = live_ranges[i][0]
            let b_id = live_ranges[j][0]
            if a_id != b_id {
                let a_start = live_ranges[i][1]
                let a_end = live_ranges[i][2]
                let b_start = live_ranges[j][1]
                let b_end = live_ranges[j][2]
                if !(a_end <= b_start || b_end <= a_start) {
                    let ai = anp_cc_index(nodes, a_id)
                    let bi = anp_cc_index(nodes, b_id)
                    if !anp_cc_has_color(adj[ai], b_id) {
                        adj[ai] = adj[ai].push(b_id)
                    }
                    if !anp_cc_has_color(adj[bi], a_id) {
                        adj[bi] = adj[bi].push(a_id)
                    }
                }
            }
            j = j + 1
        }
        i = i + 1
    }
    return [nodes, adj]
}

// Compute Perfect Elimination Ordering (PEO) via Maximum Cardinality Search.
// graph: [nodes, adj]
// Returns: array of node ids in perfect elimination order
fn anp_perfect_elimination_order(graph) {
    let nodes = graph[0]
    let adj = graph[1]
    let n = len(nodes)
    if n == 0 { return [] }
    let mut weight = []
    let mut numbered = []
    let mut i = 0
    while i < n {
        weight.push(0)
        numbered.push(false)
        i = i + 1
    }
    let mut order = []
    let mut step = 0
    while step < n {
        let mut best_idx = -1
        let mut best_w = -1
        i = 0
        while i < n {
            if !numbered[i] {
                if weight[i] > best_w {
                    best_w = weight[i]
                    best_idx = i
                }
            }
            i = i + 1
        }
        numbered[best_idx] = true
        order.push(nodes[best_idx])
        let neighbors = adj[best_idx]
        let mut k = 0
        while k < len(neighbors) {
            let nb_id = neighbors[k]
            let nb_idx = anp_cc_index(nodes, nb_id)
            if nb_idx >= 0 && !numbered[nb_idx] {
                weight[nb_idx] = weight[nb_idx] + 1
            }
            k = k + 1
        }
        step = step + 1
    }
    let mut rev = []
    i = len(order) - 1
    while i >= 0 {
        rev.push(order[i])
        i = i - 1
    }
    return rev
}

// Verify that an ordering is a valid PEO for a chordal graph.
// For each vertex v, neighbors after v in ordering must form a clique.
fn anp_verify_peo(graph, peo) {
    let nodes = graph[0]
    let adj = graph[1]
    let n = len(nodes)
    if n <= 1 { return true }
    let mut pos = []
    let mut i = 0
    while i < n {
        pos.push(0)
        i = i + 1
    }
    i = 0
    while i < len(peo) {
        let idx = anp_cc_index(nodes, peo[i])
        if idx >= 0 {
            pos[idx] = i
        }
        i = i + 1
    }
    i = 0
    while i < len(peo) {
        let v = peo[i]
        let v_idx = anp_cc_index(nodes, v)
        let neighbors = adj[v_idx]
        let mut later = []
        let mut k = 0
        while k < len(neighbors) {
            let nb = neighbors[k]
            let nb_idx = anp_cc_index(nodes, nb)
            if nb_idx >= 0 && pos[nb_idx] > i {
                later.push(nb)
            }
            k = k + 1
        }
        let mut a = 0
        while a < len(later) {
            let mut b = a + 1
            while b < len(later) {
                let a_idx = anp_cc_index(nodes, later[a])
                if !anp_cc_has_color(adj[a_idx], later[b]) {
                    return false
                }
                b = b + 1
            }
            a = a + 1
        }
        i = i + 1
    }
    return true
}

// Greedy coloring using a Perfect Elimination Ordering.
// Processes vertices in reverse PEO.
// Returns: [colors] array parallel to graph nodes (0-indexed colors)
fn anp_greedy_color(graph, peo) {
    let nodes = graph[0]
    let adj = graph[1]
    let n = len(nodes)
    if n == 0 { return [] }
    let mut colors = []
    let mut i = 0
    while i < n {
        colors.push(-1)
        i = i + 1
    }
    i = len(peo) - 1
    while i >= 0 {
        let v = peo[i]
        let v_idx = anp_cc_index(nodes, v)
        let mut used = []
        let neighbors = adj[v_idx]
        let mut k = 0
        while k < len(neighbors) {
            let nb = neighbors[k]
            let nb_idx = anp_cc_index(nodes, nb)
            if nb_idx >= 0 && colors[nb_idx] >= 0 {
                if !anp_cc_has_color(used, colors[nb_idx]) {
                    used.push(colors[nb_idx])
                }
            }
            k = k + 1
        }
        let mut c = 0
        while anp_cc_has_color(used, c) {
            c = c + 1
        }
        colors[v_idx] = c
        i = i - 1
    }
    return colors
}

// Compute the chromatic number from a coloring result
fn anp_chromatic_number(colors) {
    if len(colors) == 0 { return 0 }
    let mut mx = -1
    let mut i = 0
    while i < len(colors) {
        if colors[i] > mx { mx = colors[i] }
        i = i + 1
    }
    return mx + 1
}

// Validate coloring: no two adjacent nodes share a color
fn anp_valid_coloring(graph, colors) {
    let nodes = graph[0]
    let adj = graph[1]
    let mut i = 0
    while i < len(nodes) {
        let neighbors = adj[i]
        let mut k = 0
        while k < len(neighbors) {
            let nb = neighbors[k]
            let nb_idx = anp_cc_index(nodes, nb)
            if nb_idx >= 0 && colors[i] == colors[nb_idx] {
                return false
            }
            k = k + 1
        }
        i = i + 1
    }
    return true
}

// Compute maximum clique size (omega) for small graphs.
// For chordal graphs, chromatic number == clique number.
fn anp_max_clique_size(graph) {
    let nodes = graph[0]
    let adj = graph[1]
    let n = len(nodes)
    if n == 0 { return 0 }
    let mut best = 1
    let mut i = 0
    while i < n {
        let mut j = i + 1
        while j < n {
            if anp_cc_has_color(adj[i], nodes[j]) {
                if 2 > best { best = 2 }
                let mut k = j + 1
                while k < n {
                    if anp_cc_has_color(adj[i], nodes[k]) && anp_cc_has_color(adj[j], nodes[k]) {
                        if 3 > best { best = 3 }
                        let mut m = k + 1
                        while m < n {
                            if anp_cc_has_color(adj[i], nodes[m]) && anp_cc_has_color(adj[j], nodes[m]) && anp_cc_has_color(adj[k], nodes[m]) {
                                if 4 > best { best = 4 }
                            }
                            m = m + 1
                        }
                    }
                    k = k + 1
                }
            }
            j = j + 1
        }
        i = i + 1
    }
    return best
}

// Build a graph directly from node list and edge pairs.
// edges: array of [node_a, node_b] pairs
fn anp_build_graph_from_edges(all_nodes, edges) {
    let mut nodes = []
    let mut i = 0
    while i < len(all_nodes) {
        nodes.push(all_nodes[i])
        i = i + 1
    }
    nodes = nodes.sort()
    let n = len(nodes)
    let mut adj = []
    i = 0
    while i < n {
        adj.push([])
        i = i + 1
    }
    i = 0
    while i < len(edges) {
        let a = edges[i][0]
        let b = edges[i][1]
        let ai = anp_cc_index(nodes, a)
        let bi = anp_cc_index(nodes, b)
        if ai >= 0 && bi >= 0 {
            if !anp_cc_has_color(adj[ai], b) {
                adj[ai] = adj[ai].push(b)
            }
            if !anp_cc_has_color(adj[bi], a) {
                adj[bi] = adj[bi].push(a)
            }
        }
        i = i + 1
    }
    return [nodes, adj]
}

// Full chordal coloring pass on an AST.
// Scans for functions, builds interference from let bindings,
// applies chordal graph coloring for register allocation.
fn anp_chordal_color_pass(ast) {
    let mut total_colored = 0
    let mut total_regs_saved = 0
    let mut total_functions = 0
    let mut i = 0
    while i < len(ast) {
        let node = ast[i]
        if type_of(node) == "array" && len(node) >= 4 {
            let tag = node[0]
            if tag == "fn" || tag == "FnDecl" {
                total_functions = total_functions + 1
                let body = node[3]
                let mut live_ranges = []
                let mut var_id = 0
                let mut j = 0
                while j < len(body) {
                    let stmt = body[j]
                    if type_of(stmt) == "array" && len(stmt) >= 1 {
                        let stag = stmt[0]
                        if stag == "let" || stag == "Let" {
                            let end_pos = min(j + 5, len(body))
                            live_ranges.push([var_id, j, end_pos])
                            var_id = var_id + 1
                        }
                    }
                    j = j + 1
                }
                if len(live_ranges) >= 2 {
                    let graph = anp_build_interference(live_ranges)
                    let peo = anp_perfect_elimination_order(graph)
                    let colors = anp_greedy_color(graph, peo)
                    let num_regs = anp_chromatic_number(colors)
                    let naive_regs = len(live_ranges)
                    if num_regs < naive_regs {
                        total_regs_saved = total_regs_saved + (naive_regs - num_regs)
                    }
                    total_colored = total_colored + 1
                }
            }
        }
        i = i + 1
    }
    if total_colored > 0 {
        println("[ai-native] chordal-color: " + to_string(total_colored) + " fn(s), " + to_string(total_regs_saved) + " reg(s) saved")
    }
    return ast
}


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

