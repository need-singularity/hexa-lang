// ═══════════════════════════════════════════════════════════════
//  test_fsdp.hexa — FSDP (Fully Sharded Data Parallel) #157
//
//  Tests (35):
//    T1  shard boundary: begin[0] = 0
//    T2  shard boundary: end[last] = total_d
//    T3  shard sizes sum == total_d (even)
//    T4  shard sizes sum == total_d (uneven)
//    T5  init N=1: shard == original
//    T6  init N=4: num_ranks correct
//    T7  all-gather: reconstructed == original (N=2)
//    T8  all-gather: reconstructed == original (N=4)
//    T9  all-gather: length matches total_d
//    T10 forward N=2 == single rank
//    T11 forward N=4 == single rank
//    T12 backward N=2: reduce-scatter == N * grad
//    T13 backward N=4: reduce-scatter == N * grad
//    T14 reduce-scatter direct sum test
//    T15 shard spec: should_shard true
//    T16 shard spec: should_shard false
//    T17 apply_shard_spec: sharded splits params
//    T18 apply_shard_spec: not sharded replicates
//    T19 fp16 cast: small values close
//    T20 fp16 cast: clamp large values
//    T21 mixed precision init: fp16 shards created
//    T22 mixed precision: fp16 shard close to original
//    T23 mixed precision forward: in FP16 range
//    T24 mixed update master: params decrease with pos grads
//    T25 checkpoint forward: activations computed
//    T26 checkpoint recompute: matches forward
//    T27 checkpoint memory saved: positive for large hidden
//    T28 full state dict: weights == original
//    T29 sharded state dict: has rank_shards
//    T30 load full state: roundtrip preserves weights
//    T31 load sharded state: roundtrip preserves shards
//    T32 reshard config: immediate true
//    T33 reshard config: deferred false
//    T34 CPU offload: flag set
//    T35 CPU offload: roundtrip preserves weights
//    T36 optimizer step: shard update correct
//    T37 memory no shard: 4P
//    T38 memory full shard: 4P/N
//    T39 memory grad shard: P + 3P/N
//    T40 memory savings ratio: positive for N>1
//    T41 memory savings factor: N=8 gives 8x
//    T42 wrap policy: small layers excluded
//    T43 wrap policy: large layers included
//    T44 wrap count correct
//    T45 comm volume: 2P
//    T46 effective batch size correct
//    T47 grad norm sharded: correct norm
//
//  Run: cargo run --release -- self/test_fsdp.hexa
