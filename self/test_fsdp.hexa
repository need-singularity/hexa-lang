check("T34 CPU offload flag set", st_cpu.cpu_offload == true)

let st_gpu = fsdp_load_to_gpu(st_cpu)
let flat_trip = fsdp_flatten_shards(st_gpu)
check("T35 offload roundtrip preserves weights", fsdp_l2_diff(w_off, flat_trip) < 1.0e-12)

// ═══════════════════════════════════════════════════════════════
//  Optimizer step
// ═══════════════════════════════════════════════════════════════

let w_opt = [10.0, 20.0, 30.0, 40.0]
