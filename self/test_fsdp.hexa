while i < len(y_mpf) {
    if tfabs(y_mpf[i]) > 65504.0 { yf_ok = false }
}
check("T23 mixed fwd output in FP16 range", yf_ok)

let master = [1.0, 2.0, 3.0]
let grads_mu = [0.1, 0.2, 0.3]
let updated_mu = fsdp_mixed_update_master(master, grads_mu, 0.1)
check("T24 mixed update: params decrease", updated_mu[0] < master[0] && updated_mu[1] < master[1])

// ═══════════════════════════════════════════════════════════════
//  6. Activation checkpointing
// ═══════════════════════════════════════════════════════════════

let ckpt_params = [2.0, 3.0, 4.0]
