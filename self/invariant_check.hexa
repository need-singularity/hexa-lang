// ═══════════════════════════════════════════════════════════
//  self/invariant_check.hexa — T3 Phase A: @invariant DSL checker
//
//  목적: hexa_full.hexa 헤더의 shell-grep 하드코딩 가드(I1~I4) 를
//        AST 기반 declarative DSL 로 이관. parser.hexa 가
//        InvariantDecl AST 노드를 만들고, 본 스크립트가 그 노드를
//        읽어 predicate 별 checker 를 실행한다.
//
//  사용:
//    hexa check <file>
//      → file 안의 @invariant {...} 블록을 모두 수집
//      → 같은 file 에 대해 각 invariant 의 predicate 검사 수행
//      → violation 발견 시 stderr 풍 출력 + exit(1)
//
//  현 phase 구현 범위:
//    I1 (deny_method, target="push") — 완전 구현 (라인 기반 스캔)
//    I2~I4 — TODO 로 인쇄만, 위반 카운트는 0 처리
//
//  설계 메모:
//    - stage0 의 `&&` 단축평가는 chars[pos] 같은 lookahead 가드에 안전하지
//      않다 (out-of-bounds 회귀 확인). 따라서 본 스크립트는 직접 토큰화하지
//      않고 라인 단위 텍스트 스캔 + 단순 substring 으로 동작한다.
//    - 'AST 기반' 의미는: @invariant 선언이 free-form 주석이 아닌
//      파서가 이해하는 InvariantDecl 노드라는 뜻. 향후 phase 에서 본
//      checker 도 stage0 의 parse() 를 호출하도록 업그레이드 가능
//      (단축평가 버그 해결 후).
// ═══════════════════════════════════════════════════════════

// ── DSL 블록 추출 ──────────────────────────────────────────
// 입력: 파일 전체 소스
// 반환: 배열 — 각 원소는 { id, name, predicate, target, context, exempt[], line }
fn ic_extract_invariants(src) {
    let lines = src.split("\n")
    let mut invs = []
    let n = len(lines)
    let mut i = 0
    while i < n {
        let line = lines[i]
        let trimmed = ic_lstrip(line)
        if trimmed.starts_with("@invariant") {
            // start DSL block — find the opening `{` (same line or skip blanks)
            let opener_idx = ic_find_char(line, '{')
            let mut block_start = i
            let mut found_open = false
            if opener_idx >= 0 { found_open = true }
            // collect lines until matching `}` at top level
            let mut depth = 0
            if found_open { depth = 1 }
            let mut j = i
            // Walk character by character to find matching }, preserving content
            let mut buf_parts = []
            buf_parts = buf_parts.push(line)
            let mut closed = false
            if found_open {
                // Count opens/closes in the rest of `line` after opener_idx
                let after = line.substring(opener_idx + 1, len(line))
                let opens = ic_count_char(after, '{')
                let closes = ic_count_char(after, '}')
                depth = depth + opens - closes
                if depth == 0 { closed = true }
            }
            while !closed {
                j = j + 1
                if j >= n { closed = true }
                else {
                    let nl = lines[j]
                    buf_parts = buf_parts.push(nl)
                    if !found_open {
                        let oi = ic_find_char(nl, '{')
                        if oi >= 0 {
                            found_open = true
                            depth = 1
                            let after2 = nl.substring(oi + 1, len(nl))
                            let opens2 = ic_count_char(after2, '{')
                            let closes2 = ic_count_char(after2, '}')
                            depth = depth + opens2 - closes2
                            if depth == 0 { closed = true }
                        }
                    } else {
                        let opens3 = ic_count_char(nl, '{')
                        let closes3 = ic_count_char(nl, '}')
                        depth = depth + opens3 - closes3
                        if depth == 0 { closed = true }
                    }
                }
            }
            let block = buf_parts.join("\n")
            let inv = ic_parse_dsl_block(block, block_start + 1)
            invs = invs.push(inv)
            i = j + 1
        } else {
            i = i + 1
        }
    }
    return invs
}

// Trim leading whitespace (no String.trim_start in stage0)
fn ic_lstrip(s) {
    let cs = s.chars()
    let total = len(cs)
    let mut i = 0
    while i < total {
        let c = cs[i]
        if c == ' ' || c == '\t' { i = i + 1 }
        else { return s.substring(i, len(s)) }
    }
    return ""
}

// Find first occurrence of char in string; -1 if absent
fn ic_find_char(s, ch) {
    let cs = s.chars()
    let total = len(cs)
    let mut i = 0
    while i < total {
        if cs[i] == ch { return i }
        i = i + 1
    }
    return -1
}

// Count occurrences of char in string
fn ic_count_char(s, ch) {
    let cs = s.chars()
    let total = len(cs)
    let mut i = 0
    let mut n = 0
    while i < total {
        if cs[i] == ch { n = n + 1 }
        i = i + 1
    }
    return n
}

// Parse a `key: "value"` style DSL block.
// 매우 단순한 line-based 파서 — JSON-ish 가 아니므로 escape, multi-line
// 문자열 등은 미지원. 본 phase 의 5개 키만 인식.
fn ic_parse_dsl_block(block, line_no) {
    let mut id_str = ""
    let mut name_str = ""
    let mut pred_str = ""
    let mut tgt_str = ""
    let mut ctx_str = ""
    let mut exempt_list = []
    let lines = block.split("\n")
    let n = len(lines)
    let mut i = 0
    while i < n {
        let raw = lines[i]
        let line = ic_lstrip(raw)
        // skip empty / brace-only lines
        if len(line) == 0 {
            i = i + 1
        } else {
            let first = line.chars()[0]
            if first == '@' || first == '{' || first == '}' || first == '/' {
                i = i + 1
            } else {
                // try to parse key: value
                let colon = ic_find_char(line, ':')
                if colon < 0 {
                    i = i + 1
                } else {
                    let k = ic_rstrip(line.substring(0, colon))
                    let rest = ic_lstrip(line.substring(colon + 1, len(line)))
                    if k == "exempt" {
                        // accept "[a, b]" or "[]"
                        exempt_list = ic_parse_exempt_array(rest)
                    } else if k == "pattern" {
                        // pattern: { target: "...", context: "..." }
                        // 단순화 — 같은 줄 또는 중괄호 내용을 하나로 합쳐 파싱
                        let inner = ic_extract_inner_braces(block, i)
                        let p_target = ic_extract_dsl_value(inner, "target")
                        let p_context = ic_extract_dsl_value(inner, "context")
                        if len(p_target) > 0 { tgt_str = p_target }
                        if len(p_context) > 0 { ctx_str = p_context }
                    } else {
                        let v = ic_unquote(rest)
                        if k == "id" { id_str = v }
                        else if k == "name" { name_str = v }
                        else if k == "predicate" { pred_str = v }
                        else if k == "target" { tgt_str = v }
                        else if k == "context" { ctx_str = v }
                    }
                    i = i + 1
                }
            }
        }
    }
    return #{
        "id": id_str, "name": name_str, "predicate": pred_str,
        "target": tgt_str, "context": ctx_str, "exempt": exempt_list,
        "line": line_no
    }
}

// Strip trailing whitespace + comma
fn ic_rstrip(s) {
    let cs = s.chars()
    let mut e = len(cs)
    while e > 0 {
        let c = cs[e - 1]
        if c == ' ' || c == '\t' || c == ',' { e = e - 1 }
        else { return s.substring(0, e) }
    }
    return ""
}

// Strip surrounding quotes/comma whitespace
fn ic_unquote(s) {
    let t = ic_rstrip(s)
    let cs = t.chars()
    let total = len(cs)
    if total >= 2 {
        let first = cs[0]
        let last = cs[total - 1]
        if first == '"' && last == '"' {
            return t.substring(1, total - 1)
        }
    }
    return t
}

// "[a, b, c]" → [a, b, c]  (string elements)
fn ic_parse_exempt_array(s) {
    let mut out = []
    let trimmed = ic_lstrip(s)
    let cs = trimmed.chars()
    let total = len(cs)
    if total < 2 { return out }
    if cs[0] != '[' { return out }
    // find matching ]
    let mut end_idx = -1
    let mut k = 1
    while k < total {
        if cs[k] == ']' { end_idx = k; k = total }
        else { k = k + 1 }
    }
    if end_idx < 0 { return out }
    let inside = trimmed.substring(1, end_idx)
    let parts = inside.split(",")
    let nparts = len(parts)
    let mut pi = 0
    while pi < nparts {
        let raw = ic_lstrip(parts[pi])
        let trimmed2 = ic_rstrip(raw)
        let v = ic_unquote(trimmed2)
        if len(v) > 0 { out = out.push(v) }
        pi = pi + 1
    }
    return out
}

// Find inner braces content starting from line `from` in block — used for
// pattern: { ... }. Returns concatenated content between { and matching }.
fn ic_extract_inner_braces(block, from_line) {
    let lines = block.split("\n")
    let n = len(lines)
    let mut depth = 0
    let mut started = false
    let mut buf = []
    let mut i = from_line
    while i < n {
        let line = lines[i]
        let cs = line.chars()
        let total = len(cs)
        let mut j = 0
        while j < total {
            let ch = cs[j]
            if !started {
                if ch == '{' { started = true; depth = 1 }
            } else {
                if ch == '{' { depth = depth + 1; buf = buf.push(to_string(ch)) }
                else if ch == '}' {
                    depth = depth - 1
                    if depth == 0 { return buf.join("") }
                    else { buf = buf.push(to_string(ch)) }
                } else {
                    buf = buf.push(to_string(ch))
                }
            }
            j = j + 1
        }
        buf = buf.push("\n")
        i = i + 1
    }
    return buf.join("")
}

// Find `key: "value"` inside a flat string
fn ic_extract_dsl_value(s, key) {
    let needle = key + ":"
    let cs = s.chars()
    let nlen = len(needle)
    let nc = needle.chars()
    let total = len(cs)
    let mut i = 0
    while i + nlen <= total {
        let mut match_ok = true
        let mut k = 0
        while k < nlen {
            if cs[i + k] != nc[k] { match_ok = false; k = nlen }
            else { k = k + 1 }
        }
        if match_ok {
            // look for next quote
            let mut j = i + nlen
            while j < total {
                if cs[j] == '"' { j = total + 1 }
                else if cs[j] == ',' || cs[j] == '}' { return "" }
                else { j = j + 1 }
            }
            // walk after first quote
            let mut start = -1
            let mut p = i + nlen
            while p < total {
                if cs[p] == '"' { start = p + 1; p = total + 1 }
                else { p = p + 1 }
            }
            if start < 0 { return "" }
            let mut end = -1
            let mut q = start
            while q < total {
                if cs[q] == '"' { end = q; q = total + 1 }
                else { q = q + 1 }
            }
            if end < 0 { return "" }
            return s.substring(start, end)
        }
        i = i + 1
    }
    return ""
}

// ── I1 checker — deny_method on MethodCall.<target> ─────────
// 입력: src 전체, target method 이름, exempt 함수 이름 리스트
// 반환: violations 배열 — 각 원소 #{invariant_id, line, col, snippet, fn_name}
//
// 알고리즘 (라인 기반 스캔, context="statement"):
//   1) 라인 단위 순회. 각 라인의 leading non-space 가 `fn ident`...{ 이면
//      현재 fn_name 추적.
//   2) 주석 라인 (// ...) skip.
//   3) "Statement-level" push 만 검출: trimmed line 이 `<ident>.<target>(` 으로
//      시작하는 경우만 violation. 예:
//        arr.push(x)          ← 위반 (statement-level mutation)
//        arr = arr.push(x)    ← OK (functional reassign — value-style)
//      이는 기존 grep `^\s+\w+\.push\(` 와 동일한 의미.
//   4) col = 매치 시작 컬럼 (1-indexed).
//
// 한계: 멀티라인 문자열 안의 push, 매크로 안의 push 등은 false positive 가능.
fn check_invariant_deny_method(src, target, exempt) {
    let mut viols = []
    let lines = src.split("\n")
    let n = len(lines)
    let mut cur_fn = ""
    let mut i = 0
    while i < n {
        let line = lines[i]
        let trimmed = ic_lstrip(line)
        // Detect `fn name(` declarations to track current scope
        if trimmed.starts_with("fn ") {
            let after_fn = trimmed.substring(3, len(trimmed))
            let mut nm_end = -1
            let csn = after_fn.chars()
            let totaln = len(csn)
            let mut k = 0
            while k < totaln {
                let ch = csn[k]
                if ch == '(' || ch == ' ' || ch == '\t' || ch == '<' { nm_end = k; k = totaln }
                else { k = k + 1 }
            }
            if nm_end > 0 {
                cur_fn = after_fn.substring(0, nm_end)
            }
        }
        // Skip pure-comment lines
        if trimmed.starts_with("//") {
            i = i + 1
        } else {
            // Statement-level: trimmed must start with `<ident>.<target>(`
            // Walk leading ident chars in `trimmed`
            let cs = trimmed.chars()
            let total = len(cs)
            let mut p = 0
            while p < total {
                let c = cs[p]
                let is_id = ic_is_ident_char(c)
                if is_id { p = p + 1 }
                else { p = total + 1 }
            }
            // If we exited via the else branch, p = total + 1; restore actual position
            let mut id_end = 0
            let mut q = 0
            while q < total {
                let c2 = cs[q]
                let is_id2 = ic_is_ident_char(c2)
                if is_id2 { q = q + 1 }
                else { id_end = q; q = total + 1 }
            }
            // After the identifier we expect `.target(`
            let needle = "." + target + "("
            let nlen = len(needle.chars())
            let mut matched = false
            if id_end > 0 {
                if id_end + nlen <= total {
                    let suffix = trimmed.substring(id_end, id_end + nlen)
                    if suffix == needle { matched = true }
                }
            }
            if matched {
                let is_exempt = ic_list_contains(exempt, cur_fn)
                if !is_exempt {
                    // Compute column in original line (account for leading ws)
                    let leading = len(line) - len(trimmed)
                    let col = leading + id_end + 1
                    viols = viols.push(#{
                        "invariant_id": "I1",
                        "line": i + 1,
                        "col": col,
                        "snippet": trimmed,
                        "fn_name": cur_fn
                    })
                }
            }
            i = i + 1
        }
    }
    return viols
}

fn ic_is_ident_char(c) {
    if c == '_' { return true }
    if c == '0' || c == '1' || c == '2' || c == '3' || c == '4' { return true }
    if c == '5' || c == '6' || c == '7' || c == '8' || c == '9' { return true }
    if c == 'a' || c == 'b' || c == 'c' || c == 'd' || c == 'e' { return true }
    if c == 'f' || c == 'g' || c == 'h' || c == 'i' || c == 'j' { return true }
    if c == 'k' || c == 'l' || c == 'm' || c == 'n' || c == 'o' { return true }
    if c == 'p' || c == 'q' || c == 'r' || c == 's' || c == 't' { return true }
    if c == 'u' || c == 'v' || c == 'w' || c == 'x' || c == 'y' || c == 'z' { return true }
    if c == 'A' || c == 'B' || c == 'C' || c == 'D' || c == 'E' { return true }
    if c == 'F' || c == 'G' || c == 'H' || c == 'I' || c == 'J' { return true }
    if c == 'K' || c == 'L' || c == 'M' || c == 'N' || c == 'O' { return true }
    if c == 'P' || c == 'Q' || c == 'R' || c == 'S' || c == 'T' { return true }
    if c == 'U' || c == 'V' || c == 'W' || c == 'X' || c == 'Y' || c == 'Z' { return true }
    return false
}

fn ic_list_contains(lst, item) {
    let n = len(lst)
    let mut i = 0
    while i < n {
        if lst[i] == item { return true }
        i = i + 1
    }
    return false
}

fn ic_find_substr(haystack, needle) {
    let hs = haystack.chars()
    let ns = needle.chars()
    let hl = len(hs)
    let nl = len(ns)
    if nl == 0 { return 0 }
    if nl > hl { return -1 }
    let mut i = 0
    let last = hl - nl + 1
    while i < last {
        let mut k = 0
        let mut ok = true
        while k < nl {
            if hs[i + k] != ns[k] { ok = false; k = nl }
            else { k = k + 1 }
        }
        if ok { return i }
        i = i + 1
    }
    return -1
}

// ── I1 wrapper ────────────────────────────────────────────
fn check_invariant_I1(src) {
    return check_invariant_deny_method(src, "push", [])
}

// ── 모든 invariant 순회 ───────────────────────────────────
// 입력: src, invs (ic_extract_invariants 결과)
// 반환: violations 배열
fn verify_all_invariants(src, invs) {
    let mut all_viols = []
    let n = len(invs)
    let mut i = 0
    while i < n {
        let inv = invs[i]
        let pred = inv["predicate"]
        if pred == "deny_method" {
            let tgt = inv["target"]
            let exempt = inv["exempt"]
            let viols = check_invariant_deny_method(src, tgt, exempt)
            // attach inv id to each violation
            let nv = len(viols)
            let mut vi = 0
            while vi < nv {
                let v = viols[vi]
                let v2 = #{
                    "invariant_id": inv["id"],
                    "line": v["line"],
                    "col": v["col"],
                    "snippet": v["snippet"],
                    "fn_name": v["fn_name"]
                }
                all_viols = all_viols.push(v2)
                vi = vi + 1
            }
        } else if pred == "ident_name" || pred == "host_args_offset" || pred == "binary_gitignored" {
            // I2~I4 stubs — TODO checker not implemented yet
            println("  [TODO] " + inv["id"] + " predicate=" + pred + " not yet implemented")
        } else {
            println("  [WARN] " + inv["id"] + " unknown predicate=" + pred)
        }
        i = i + 1
    }
    return all_viols
}

// ── CLI 진입점 ────────────────────────────────────────────
fn main_check() {
    let av = args()
    // host_args() forwards av[3..] when invoked via `hexa run`. With
    // dispatcher `hexa check <file>` we register file as av[3].
    // But when this script is invoked directly via stage0 (host_args may
    // differ), accept av[2] as fallback.
    let mut file = ""
    if len(av) >= 4 { file = av[3] }
    else if len(av) >= 3 { file = av[2] }
    if len(file) == 0 {
        println("usage: hexa check <file>")
        exit(2)
    }
    let exists = exec("test -f '" + file + "' && printf yes || printf no")
    if exists != "yes" {
        println("error: file not found: " + file)
        exit(2)
    }
    let src = read_file(file)
    println("=== hexa check " + file + " ===")
    let invs = ic_extract_invariants(src)
    let n_invs = len(invs)
    println("found " + to_string(n_invs) + " @invariant declaration(s)")
    if n_invs == 0 {
        // Default — check I1 implicit (push deny) for hexa_full.hexa parity
        println("no @invariant DSL blocks; running implicit I1 (deny push)")
        let v_impl = check_invariant_I1(src)
        ic_report_viols(v_impl)
        if len(v_impl) > 0 { exit(1) } else { exit(0) }
    }
    // List declared invariants
    let mut li = 0
    while li < n_invs {
        let inv = invs[li]
        println("  " + inv["id"] + " " + inv["name"] + " predicate=" + inv["predicate"]
            + " target=" + inv["target"])
        li = li + 1
    }
    let viols = verify_all_invariants(src, invs)
    ic_report_viols(viols)
    if len(viols) > 0 { exit(1) }
    println("OK: all invariants passed")
}

fn ic_report_viols(viols) {
    let n = len(viols)
    if n == 0 {
        println("0 violation(s)")
    } else {
        println(to_string(n) + " violation(s):")
        let mut i = 0
        while i < n {
            let v = viols[i]
            let loc = to_string(v["line"]) + ":" + to_string(v["col"])
            let inside = v["fn_name"]
            let inside_tag = if len(inside) > 0 { " (in fn " + inside + ")" } else { "" }
            println("  " + v["invariant_id"] + " " + loc + inside_tag + " — " + v["snippet"])
            i = i + 1
        }
    }
}

main_check()
