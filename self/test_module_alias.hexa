// self/test_module_alias.hexa — I1-IMPORT-ALIAS unit test (RFC-016 P1)
//
// Self-contained: inlines the helpers added to self/module_loader.hexa
// (ml_parse_import_alias / ml_apply_alias_prefix / ml_rewrite_alias_refs)
// so the test runs without bootstrapping the loader. Once the binary is
// rebuilt with the parser+loader changes wired in, an end-to-end test
// will live at bench/import_chain.hexa under an `as` alias variant.

let mut pass_count = 0
let mut total_count = 0
let mut failed_name = ""

fn check(name, cond) {
    total_count = total_count + 1
    if cond {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name)
    }
}

// ── inline helpers (mirror module_loader.hexa) ─────────────────────────

fn ml_trim_left(s) {
    let n = len(s)
    let mut i = 0
    while i < n {
        let c = s[i]
        if c != ' ' && c != '\t' { break }
        i = i + 1
    }
    if i == 0 { return s }
    return s.substring(i, n)
}

fn ml_starts_with(s, prefix) {
    let pn = len(prefix)
    let sn = len(s)
    if sn < pn { return false }
    let mut i = 0
    while i < pn { if s[i] != prefix[i] { return false } i = i + 1 }
    return true
}

fn ml_parse_import_alias(line) {
    let trimmed = ml_trim_left(line)
    let mut prefix_len = 0
    if ml_starts_with(trimmed, "import ") { prefix_len = 7 }
    else if ml_starts_with(trimmed, "use ") { prefix_len = 4 }
    else { return "" }
    let n = len(trimmed)
    if prefix_len >= n { return "" }
    let rest = ml_trim_left(trimmed.substring(prefix_len, n))
    let rn = len(rest)
    if rn < 2 { return "" }
    if rest[0] != '"' { return "" }
    let mut i = 1
    while i < rn { if rest[i] == '"' { break } i = i + 1 }
    if i >= rn { return "" }
    let after = ml_trim_left(rest.substring(i + 1, rn))
    let an = len(after)
    if an < 4 { return "" }
    if after.substring(0, 3) != "as " { return "" }
    let alias_part = ml_trim_left(after.substring(3, an))
    let apn = len(alias_part)
    let mut j = 0
    while j < apn {
        let c = alias_part[j]
        let is_alpha = (c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z') || c == '_'
        let is_digit = c >= '0' && c <= '9'
        if !is_alpha && !is_digit { break }
        j = j + 1
    }
    if j == 0 { return "" }
    return alias_part.substring(0, j)
}

fn ml_apply_alias_prefix(src, alias) {
    if len(alias) == 0 { return src }
    let mut p = []
    p.push("__mod_") p.push(alias) p.push("__")
    let pre = p.join("")
    let mut s = src
    if ml_starts_with(s, "pub fn ")     { s = "pub fn "     + pre + s.substring(7,  len(s)) }
    if ml_starts_with(s, "pub let ")    { s = "pub let "    + pre + s.substring(8,  len(s)) }
    s = s.replace("\npub fn ",     "\npub fn @@MARK_FN@@")
    s = s.replace("\npub let ",    "\npub let @@MARK_LET@@")
    s = s.replace("@@MARK_FN@@",  pre)
    s = s.replace("@@MARK_LET@@", pre)
    return s
}

fn ml_rewrite_alias_refs(src, alias) {
    if len(alias) == 0 { return src }
    let mut p = []
    p.push("__mod_") p.push(alias) p.push("__")
    let pre = p.join("")
    let mut s = src
    let mut a = []
    a.push(" ") a.push("\n") a.push("\t") a.push("(") a.push(",") a.push("=")
    a.push("[") a.push("{") a.push(";")
    let mut i = 0
    while i < len(a) {
        let lhs = a[i]
        let needle = lhs + alias + "."
        let repl   = lhs + pre
        s = s.replace(needle, repl)
        i = i + 1
    }
    return s
}

// ── tests ──────────────────────────────────────────────────────────────

fn main() {
    // ml_parse_import_alias
    check("parse no-alias",       ml_parse_import_alias("import \"foo.hexa\"") == "")
    check("parse simple alias",   ml_parse_import_alias("import \"foo.hexa\" as foo") == "foo")
    check("parse with leading ws",ml_parse_import_alias("    import \"foo.hexa\" as bar") == "bar")
    check("parse use form",       ml_parse_import_alias("use \"x.hexa\" as x") == "x")
    check("parse alias underscore", ml_parse_import_alias("import \"y.hexa\" as my_alias") == "my_alias")
    check("parse alias with trail",  ml_parse_import_alias("import \"y.hexa\" as foo // tail") == "foo")
    check("parse no quote rejects", ml_parse_import_alias("import foo.hexa as foo") == "")
    check("parse missing as",       ml_parse_import_alias("import \"y.hexa\" foo") == "")

    // ml_apply_alias_prefix
    let src = "pub fn abs(x) { return x }\npub let pi = 3.14\nfn helper() {}\n"
    let out = ml_apply_alias_prefix(src, "math")
    check("prefix first-line fn",   out.contains("pub fn __mod_math__abs("))
    check("prefix interior let",    out.contains("pub let __mod_math__pi"))
    check("prefix preserves helper",out.contains("fn helper()"))
    check("prefix empty alias no-op", ml_apply_alias_prefix(src, "") == src)

    // ml_rewrite_alias_refs
    let caller = "let x = math.abs(5)\nlet y = math.pi\n(math.foo) + math.bar"
    let rewritten = ml_rewrite_alias_refs(caller, "math")
    check("rewrite assigned call", rewritten.contains("__mod_math__abs(5)"))
    check("rewrite let read",      rewritten.contains("__mod_math__pi"))
    check("rewrite paren prefix",  rewritten.contains("(__mod_math__foo)"))
    check("rewrite plus prefix",   rewritten.contains(" __mod_math__bar"))
    check("rewrite empty alias no-op", ml_rewrite_alias_refs(caller, "") == caller)

    // composition: prefix the module body, then rewrite caller refs.
    let mod_body = "pub fn abs(x) { return x }\n"
    let caller_body = "let v = math.abs(7)\n"
    let pref = ml_apply_alias_prefix(mod_body, "math")
    let crew = ml_rewrite_alias_refs(caller_body, "math")
    let combined = pref + crew
    check("composed contains prefixed def", combined.contains("pub fn __mod_math__abs"))
    check("composed contains prefixed call", combined.contains("__mod_math__abs(7)"))

    println("PASS " + to_string(pass_count) + "/" + to_string(total_count))
    if failed_name != "" {
        println("first fail: " + failed_name)
        exit(1)
    }
}
