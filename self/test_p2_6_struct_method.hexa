// P2-6: self interpreter struct + method dispatch smoke test
// Runs through self/interpreter.hexa? No — this file is a direct hexa test
// verifying the features the self interpreter needs to support.

struct Point { x: int, y: int }

impl Point {
    fn distance(self, other) {
        let dx = self.x - other.x
        let dy = self.y - other.y
        return dx * dx + dy * dy
    }
}

fn main() {
    let a = Point { x: 0, y: 0 }
    let b = Point { x: 3, y: 4 }
    println(a.distance(b))  // 25
}

main()
