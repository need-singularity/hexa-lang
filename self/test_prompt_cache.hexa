// ═══════════════════════════════════════════════════════════════
//  test_prompt_cache.hexa — Prompt Caching correctness tests
//
//  Verifies:
//    1. Prefix hashing determinism + collision resistance
//    2. Radix tree insert / lookup / split
//    3. Longest common prefix matching
//    4. KV snapshot storage and retrieval
//    5. LRU eviction with max_entries
//    6. Cache hit/miss rate tracking
//    7. Edge cases: empty tokens, single token, full overlap
//    8. prompt_cache_serve convenience API
//
//  Run: ./hexa self/test_prompt_cache.hexa
// ═══════════════════════════════════════════════════════════════

// -- inlined from self/ml/prompt_cache.hexa --
// codegen import not wired for test files

// ═══════════════════════════════════════════════════════════════
//  self/ml/prompt_cache.hexa — Prompt Caching: prefix KV reuse
//
//  Implements:
//    1. Prefix hash: FNV-1a-like hash of token sequences for cache key
//    2. Radix tree: hierarchical prefix matching (longest common prefix)
//    3. KV snapshot: store computed KV pairs for matched prefixes
//    4. Cache eviction: LRU policy with max entries
//    5. Lookup: find longest cached prefix, return KV + remaining tokens
//    6. Cache hit rate tracking
//
//  All data structures are immutable-style: mutations return new structs.
//  No semicolons. No complex index assignment. Flat 1D arrays.
//
//  Run: ./hexa self/test_prompt_cache.hexa
// ═══════════════════════════════════════════════════════════════

// ── Prefix Hashing ───────────────────────────────────────────
// FNV-1a-style hash for token sequences.
// tokens: array of int (token ids)
// Returns an int hash.

fn prefix_hash(tokens) {
    let mut h = 2166136261
    let mut i = 0
    while i < len(tokens) {
        let t = tokens[i]
        // XOR + multiply (FNV-1a core)
        h = h + t * 16777619
        // fold to avoid overflow issues: keep it positive
        if h < 0 {
            h = 0 - h
        }
        i = i + 1
    }
    return h
}

// Hash a sub-range of tokens: tokens[start..end_idx]
fn prefix_hash_range(tokens, start, end_idx) {
    let mut h = 2166136261
    let mut i = start
    while i < end_idx {
        let t = tokens[i]
        h = h + t * 16777619
        if h < 0 {
            h = 0 - h
        }
        i = i + 1
    }
    return h
}

// ── Radix Tree Node ──────────────────────────────────────────
// Each node stores a token-segment (edge label) and optional KV data.
// children: array of RadixNode
// kv_keys / kv_values: flat 1D arrays (KV snapshot) or empty
// has_kv: bool indicating whether this node holds a cached KV

struct RadixNode {
    segment: array,
    children: array,
    kv_keys: array,
    kv_values: array,
    has_kv: bool,
    seq_len: int
}

fn radix_node_new(segment) {
    return RadixNode {
        segment: segment,
        children: [],
        kv_keys: [],
        kv_values: [],
        has_kv: false,
        seq_len: 0
    }
}

fn radix_node_with_kv(segment, kv_keys, kv_values, seq_len) {
    return RadixNode {
        segment: segment,
        children: [],
        kv_keys: kv_keys,
        kv_values: kv_values,
        has_kv: true,
        seq_len: seq_len
    }
}

// ── Array helpers ────────────────────────────────────────────

fn arr_slice(arr, start, end_idx) {
    let mut result = []
    let mut i = start
    while i < end_idx {
        result.push(arr[i])
        i = i + 1
    }
    return result
}

fn arr_eq(a, b) {
    if len(a) != len(b) {
        return false
    }
    let mut i = 0
    while i < len(a) {
        if a[i] != b[i] {
            return false
        }
        i = i + 1
    }
    return true
}

fn arr_starts_with(arr, prefix) {
    if len(prefix) > len(arr) {
        return false
    }
    let mut i = 0
    while i < len(prefix) {
        if arr[i] != prefix[i] {
            return false
        }
        i = i + 1
    }
    return true
}

// Find length of common prefix between two arrays
fn common_prefix_len(a, b) {
    let la = len(a)
    let lb = len(b)
    let mut lim = la
    if lb < lim {
        lim = lb
    }
    let mut i = 0
    while i < lim {
        if a[i] != b[i] {
            return i
        }
        i = i + 1
    }
    return lim
}

// ── Radix Tree Insert ────────────────────────────────────────
// Insert tokens into radix tree with KV data at the leaf.
// Returns a new RadixNode (root).

fn radix_insert(node: RadixNode, tokens, kv_keys, kv_values, seq_len) {
    if len(tokens) == 0 {
        // Mark this node with KV
        return RadixNode {
            segment: node.segment,
            children: node.children,
            kv_keys: kv_keys,
            kv_values: kv_values,
            has_kv: true,
            seq_len: seq_len
        }
    }

    // Find child whose segment shares a prefix with tokens
    let mut found_idx = 0 - 1
    let mut i = 0
    while i < len(node.children) {
        let child = node.children[i]
        if len(child.segment) > 0 {
            if child.segment[0] == tokens[0] {
                found_idx = i
            }
        }
        i = i + 1
    }

    if found_idx < 0 {
        // No matching child: create a new leaf
        let leaf = radix_node_with_kv(tokens, kv_keys, kv_values, seq_len)
        let mut new_children = []
        let mut j = 0
        while j < len(node.children) {
            new_children.push(node.children[j])
            j = j + 1
        }
        new_children.push(leaf)
        return RadixNode {
            segment: node.segment,
            children: new_children,
            kv_keys: node.kv_keys,
            kv_values: node.kv_values,
            has_kv: node.has_kv,
            seq_len: node.seq_len
        }
    }

    // Found matching child at found_idx
    let child = node.children[found_idx]
    let cpl = common_prefix_len(child.segment, tokens)

    if cpl == len(child.segment) {
        // Entire child segment matches; recurse into child
        let remaining = arr_slice(tokens, cpl, len(tokens))
        let new_child = radix_insert(child, remaining, kv_keys, kv_values, seq_len)
        let mut new_children = []
        let mut j = 0
        while j < len(node.children) {
            if j == found_idx {
                new_children.push(new_child)
            } else {
                new_children.push(node.children[j])
            }
            j = j + 1
        }
        return RadixNode {
            segment: node.segment,
            children: new_children,
            kv_keys: node.kv_keys,
            kv_values: node.kv_values,
            has_kv: node.has_kv,
            seq_len: node.seq_len
        }
    }

    // Partial match: split the child
    let shared_seg = arr_slice(child.segment, 0, cpl)
    let child_tail = arr_slice(child.segment, cpl, len(child.segment))
    let token_tail = arr_slice(tokens, cpl, len(tokens))

    // Old child with trimmed segment
    let old_child_trimmed = RadixNode {
        segment: child_tail,
        children: child.children,
        kv_keys: child.kv_keys,
        kv_values: child.kv_values,
        has_kv: child.has_kv,
        seq_len: child.seq_len
    }

    // New leaf for the remaining tokens
    let new_leaf = radix_node_with_kv(token_tail, kv_keys, kv_values, seq_len)

    // Split node holds the shared segment
    let mut split_children = [old_child_trimmed]
    if len(token_tail) > 0 {
        split_children.push(new_leaf)
    }
    let mut split_has_kv = false
    let mut split_kk = []
    let mut split_kv = []
    let mut split_sl = 0
    if len(token_tail) == 0 {
        split_has_kv = true
        split_kk = kv_keys
        split_kv = kv_values
        split_sl = seq_len
    }
    let split_node = RadixNode {
        segment: shared_seg,
        children: split_children,
        kv_keys: split_kk,
        kv_values: split_kv,
        has_kv: split_has_kv,
        seq_len: split_sl
    }

    let mut new_children = []
    let mut j = 0
    while j < len(node.children) {
        if j == found_idx {
            new_children.push(split_node)
        } else {
            new_children.push(node.children[j])
        }
        j = j + 1
    }
    return RadixNode {
        segment: node.segment,
        children: new_children,
        kv_keys: node.kv_keys,
        kv_values: node.kv_values,
        has_kv: node.has_kv,
        seq_len: node.seq_len
    }
}

// ── Radix Tree Lookup ────────────────────────────────────────
// Find the longest cached prefix matching tokens.
// Returns: [matched_len, kv_keys, kv_values, seq_len]
// If no match: matched_len=0, kv_keys=[], kv_values=[], seq_len=0

struct RadixLookupResult {
    matched_len: int,
    kv_keys: array,
    kv_values: array,
    seq_len: int
}

fn radix_lookup(node: RadixNode, tokens) {
    return radix_lookup_inner(node, tokens, 0)
}

fn radix_lookup_inner(node: RadixNode, tokens, depth) {
    // Best result so far: this node if it has KV
    let mut best_len = 0
    let mut best_kk = []
    let mut best_kv = []
    let mut best_sl = 0
    if node.has_kv {
        best_len = depth
        best_kk = node.kv_keys
        best_kv = node.kv_values
        best_sl = node.seq_len
    }

    if depth >= len(tokens) {
        return RadixLookupResult {
            matched_len: best_len,
            kv_keys: best_kk,
            kv_values: best_kv,
            seq_len: best_sl
        }
    }

    // Search children
    let mut i = 0
    while i < len(node.children) {
        let child = node.children[i]
        if len(child.segment) > 0 {
            if child.segment[0] == tokens[depth] {
                // Check if entire segment matches
                let remaining_tokens = arr_slice(tokens, depth, len(tokens))
                let cpl = common_prefix_len(child.segment, remaining_tokens)
                if cpl == len(child.segment) {
                    // Full segment match: recurse
                    let sub = radix_lookup_inner(child, tokens, depth + cpl)
                    if sub.matched_len > best_len {
                        best_len = sub.matched_len
                        best_kk = sub.kv_keys
                        best_kv = sub.kv_values
                        best_sl = sub.seq_len
                    }
                }
                // Partial match: no deeper child can match
            }
        }
        i = i + 1
    }

    return RadixLookupResult {
        matched_len: best_len,
        kv_keys: best_kk,
        kv_values: best_kv,
        seq_len: best_sl
    }
}

// ── LRU Entry ────────────────────────────────────────────────

struct LRUEntry {
    hash_key: int,
    tokens: array,
    kv_keys: array,
    kv_values: array,
    seq_len: int,
    last_access: int
}

// ── Prompt Cache ─────────────────────────────────────────────

struct PromptCache {
    root: RadixNode,
    entries: array,
    max_entries: int,
    access_counter: int,
    hits: int,
    misses: int,
    total_lookups: int
}

fn prompt_cache_new(max_entries) {
    return PromptCache {
        root: radix_node_new([]),
        entries: [],
        max_entries: max_entries,
        access_counter: 0,
        hits: 0,
        misses: 0,
        total_lookups: 0
    }
}

// ── Insert ───────────────────────────────────────────────────
// Cache the KV for a given token prefix.

fn prompt_cache_insert(cache: PromptCache, tokens, kv_keys, kv_values) {
    let h = prefix_hash(tokens)
    let new_counter = cache.access_counter + 1
    let sl = len(tokens)

    // Check if already exists (same hash + tokens)
    let mut exists_idx = 0 - 1
    let mut i = 0
    while i < len(cache.entries) {
        let e = cache.entries[i]
        if e.hash_key == h {
            if arr_eq(e.tokens, tokens) {
                exists_idx = i
            }
        }
        i = i + 1
    }

    let new_entry = LRUEntry {
        hash_key: h,
        tokens: tokens,
        kv_keys: kv_keys,
        kv_values: kv_values,
        seq_len: sl,
        last_access: new_counter
    }

    let mut new_entries = []
    if exists_idx >= 0 {
        // Replace existing
        let mut i = 0
        while i < len(cache.entries) {
            if i == exists_idx {
                new_entries.push(new_entry)
            } else {
                new_entries.push(cache.entries[i])
            }
            i = i + 1
        }
    } else {
        // Add new
        let mut i = 0
        while i < len(cache.entries) {
            new_entries.push(cache.entries[i])
            i = i + 1
        }
        new_entries.push(new_entry)
    }

    // Evict if over max_entries
    if len(new_entries) > cache.max_entries {
        new_entries = lru_evict(new_entries)
    }

    // Insert into radix tree
    let new_root = radix_insert(cache.root, tokens, kv_keys, kv_values, sl)

    return PromptCache {
        root: new_root,
        entries: new_entries,
        max_entries: cache.max_entries,
        access_counter: new_counter,
        hits: cache.hits,
        misses: cache.misses,
        total_lookups: cache.total_lookups
    }
}

// ── LRU Eviction ─────────────────────────────────────────────
// Remove the entry with the smallest last_access (least recently used).

fn lru_evict(entries) {
    if len(entries) == 0 {
        return entries
    }
    let mut min_access = entries[0].last_access
    let mut min_idx = 0
    let mut i = 1
    while i < len(entries) {
        if entries[i].last_access < min_access {
            min_access = entries[i].last_access
            min_idx = i
        }
        i = i + 1
    }
    let mut result = []
    let mut i = 0
    while i < len(entries) {
        if i != min_idx {
            result.push(entries[i])
        }
        i = i + 1
    }
    return result
}

// ── Lookup ───────────────────────────────────────────────────
// Find the longest cached prefix. Returns:
//   PromptCacheLookup { matched_len, kv_keys, kv_values, remaining_tokens, hit }

struct PromptCacheLookup {
    matched_len: int,
    kv_keys: array,
    kv_values: array,
    remaining_tokens: array,
    hit: bool
}

fn prompt_cache_lookup(cache: PromptCache, tokens) {
    let result = radix_lookup(cache.root, tokens)
    let hit = result.matched_len > 0

    let remaining = arr_slice(tokens, result.matched_len, len(tokens))

    // Update hit/miss stats (returned in new cache via prompt_cache_lookup_update)
    return PromptCacheLookup {
        matched_len: result.matched_len,
        kv_keys: result.kv_keys,
        kv_values: result.kv_values,
        remaining_tokens: remaining,
        hit: hit
    }
}

// Update stats after a lookup
fn prompt_cache_record_lookup(cache: PromptCache, hit) {
    let new_hits = cache.hits
    let new_misses = cache.misses
    let mut h = new_hits
    let mut m = new_misses
    if hit {
        h = h + 1
    } else {
        m = m + 1
    }
    return PromptCache {
        root: cache.root,
        entries: cache.entries,
        max_entries: cache.max_entries,
        access_counter: cache.access_counter + 1,
        hits: h,
        misses: m,
        total_lookups: cache.total_lookups + 1
    }
}

// Update LRU timestamp for matching entry
fn prompt_cache_touch(cache: PromptCache, tokens) {
    let h = prefix_hash(tokens)
    let new_counter = cache.access_counter + 1
    let mut new_entries = []
    let mut i = 0
    while i < len(cache.entries) {
        let e = cache.entries[i]
        if e.hash_key == h {
            if arr_eq(e.tokens, tokens) {
                let updated = LRUEntry {
                    hash_key: e.hash_key,
                    tokens: e.tokens,
                    kv_keys: e.kv_keys,
                    kv_values: e.kv_values,
                    seq_len: e.seq_len,
                    last_access: new_counter
                }
                new_entries.push(updated)
            } else {
                new_entries.push(e)
            }
        } else {
            new_entries.push(e)
        }
        i = i + 1
    }
    return PromptCache {
        root: cache.root,
        entries: new_entries,
        max_entries: cache.max_entries,
        access_counter: new_counter,
        hits: cache.hits,
        misses: cache.misses,
        total_lookups: cache.total_lookups
    }
}

// ── Stats ────────────────────────────────────────────────────

fn prompt_cache_hit_rate(cache: PromptCache) {
    if cache.total_lookups == 0 {
        return 0.0
    }
    return cache.hits * 1.0 / cache.total_lookups
}

fn prompt_cache_miss_rate(cache: PromptCache) {
    if cache.total_lookups == 0 {
        return 0.0
    }
    return cache.misses * 1.0 / cache.total_lookups
}

fn prompt_cache_size(cache: PromptCache) {
    return len(cache.entries)
}

// ── Reset ────────────────────────────────────────────────────

fn prompt_cache_reset(cache: PromptCache) {
    return prompt_cache_new(cache.max_entries)
}

// ── Convenience: lookup + insert in one step ─────────────────
// Try cache first. If hit, return cached KV + remaining.
// If miss, caller computes full KV and can insert afterwards.

fn prompt_cache_serve(cache: PromptCache, tokens) {
    let lookup = prompt_cache_lookup(cache, tokens)
    let updated = prompt_cache_record_lookup(cache, lookup.hit)
    let mut final_cache = updated
    if lookup.hit {
        // Touch LRU for the matched prefix
        let matched_tokens = arr_slice(tokens, 0, lookup.matched_len)
        final_cache = prompt_cache_touch(final_cache, matched_tokens)
    }
    return [final_cache, lookup]
}

// ── Count nodes in radix tree (for debugging) ────────────────

fn radix_node_count(node: RadixNode) {
    let mut count = 1
    let mut i = 0
    while i < len(node.children) {
        count = count + radix_node_count(node.children[i])
        i = i + 1
    }
    return count
}

fn radix_kv_count(node: RadixNode) {
    let mut count = 0
    if node.has_kv {
        count = 1
    }
    let mut i = 0
    while i < len(node.children) {
        count = count + radix_kv_count(node.children[i])
        i = i + 1
    }
    return count
}


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  Prompt Cache Test Suite")
println("═══════════════════════════════════════════════════════")

// ── Test 1: prefix_hash determinism ──────────────────────────
let h1 = prefix_hash([1, 2, 3])
let h2 = prefix_hash([1, 2, 3])
check("prefix_hash deterministic", h1 == h2)

// ── Test 2: different sequences -> different hashes ──────────
let h3 = prefix_hash([1, 2, 4])
check("prefix_hash different for [1,2,3] vs [1,2,4]", h1 != h3)

// ── Test 3: empty sequence hash ──────────────────────────────
let h_empty = prefix_hash([])
check("prefix_hash empty is base value", h_empty == 2166136261)

// ── Test 4: single token hash ────────────────────────────────
let h_single = prefix_hash([42])
check("prefix_hash single token != empty", h_single != h_empty)

// ── Test 5: prefix_hash_range matches full hash ──────────────
let tokens_full = [10, 20, 30, 40, 50]
let h_full = prefix_hash(tokens_full)
let h_range = prefix_hash_range(tokens_full, 0, 5)
check("prefix_hash_range(0,5) == prefix_hash", h_full == h_range)

// ── Test 6: prefix_hash_range sub-range ──────────────────────
let h_sub = prefix_hash_range(tokens_full, 0, 3)
let h_sub2 = prefix_hash([10, 20, 30])
check("prefix_hash_range(0,3) == hash([10,20,30])", h_sub == h_sub2)

// ── Test 7: arr_slice basic ──────────────────────────────────
let sl = arr_slice([10, 20, 30, 40], 1, 3)
check("arr_slice [1:3]", arr_eq(sl, [20, 30]))

// ── Test 8: arr_eq true ──────────────────────────────────────
check("arr_eq identical", arr_eq([1, 2, 3], [1, 2, 3]))

// ── Test 9: arr_eq false ─────────────────────────────────────
check("arr_eq different", !arr_eq([1, 2, 3], [1, 2, 4]))

// ── Test 10: common_prefix_len ───────────────────────────────
check("common_prefix_len [1,2,3] vs [1,2,5]", common_prefix_len([1, 2, 3], [1, 2, 5]) == 2)

// ── Test 11: common_prefix_len full overlap ──────────────────
check("common_prefix_len full overlap", common_prefix_len([1, 2], [1, 2, 3]) == 2)

// ── Test 12: common_prefix_len no overlap ────────────────────
check("common_prefix_len no overlap", common_prefix_len([5, 6], [1, 2]) == 0)

// ── Test 13: prompt_cache_new empty ──────────────────────────
let cache0 = prompt_cache_new(4)
check("new cache size == 0", prompt_cache_size(cache0) == 0)
check("new cache hit_rate == 0.0", prompt_cache_hit_rate(cache0) == 0.0)

// ── Test 14: insert and lookup (exact match) ─────────────────
let tokens_a = [100, 200, 300]
let kv_k_a = [1.0, 2.0, 3.0, 4.0]
let kv_v_a = [5.0, 6.0, 7.0, 8.0]
let mut cache1 = prompt_cache_insert(cache0, tokens_a, kv_k_a, kv_v_a)
let look1 = prompt_cache_lookup(cache1, tokens_a)
check("exact lookup hit", look1.hit)
check("exact lookup matched_len == 3", look1.matched_len == 3)
check("exact lookup kv_keys correct", arr_eq(look1.kv_keys, kv_k_a))
check("exact lookup remaining empty", len(look1.remaining_tokens) == 0)

// ── Test 15: lookup with longer tokens (prefix match) ────────
let tokens_b = [100, 200, 300, 400, 500]
let look2 = prompt_cache_lookup(cache1, tokens_b)
check("prefix lookup hit", look2.hit)
check("prefix lookup matched_len == 3", look2.matched_len == 3)
check("prefix lookup remaining == [400,500]", arr_eq(look2.remaining_tokens, [400, 500]))

// ── Test 16: lookup miss (no common prefix) ──────────────────
let tokens_c = [999, 888]
let look3 = prompt_cache_lookup(cache1, tokens_c)
check("miss: no prefix", !look3.hit)
check("miss: matched_len == 0", look3.matched_len == 0)

// ── Test 17: multiple inserts, longest prefix wins ───────────
// Insert a longer prefix that extends tokens_a
let tokens_d = [100, 200, 300, 400]
let kv_k_d = [10.0, 20.0, 30.0, 40.0, 50.0]
let kv_v_d = [60.0, 70.0, 80.0, 90.0, 100.0]
let mut cache2 = prompt_cache_insert(cache1, tokens_d, kv_k_d, kv_v_d)
let look4 = prompt_cache_lookup(cache2, [100, 200, 300, 400, 500])
check("longest prefix: matched_len == 4", look4.matched_len == 4)
check("longest prefix: correct kv_keys", arr_eq(look4.kv_keys, kv_k_d))
check("longest prefix: remaining == [500]", arr_eq(look4.remaining_tokens, [500]))

// ── Test 18: shorter query still matches shorter cache ───────
let look5 = prompt_cache_lookup(cache2, [100, 200])
// tokens_a starts with [100,200,300] but query is only [100,200] -> no full node match
// The radix tree has node with segment [100,200,300] which won't fully match [100,200]
check("partial prefix: no full segment match", !look5.hit)

// ── Test 19: two separate branches in radix tree ─────────────
let tokens_e = [500, 600, 700]
let kv_k_e = [1.5, 2.5]
let kv_v_e = [3.5, 4.5]
let mut cache3 = prompt_cache_insert(cache2, tokens_e, kv_k_e, kv_v_e)
let look6 = prompt_cache_lookup(cache3, tokens_e)
check("second branch: exact hit", look6.hit)
check("second branch: matched_len == 3", look6.matched_len == 3)
// Original branch still works
let look7 = prompt_cache_lookup(cache3, tokens_a)
check("original branch still works", look7.hit)

// ── Test 20: cache hit rate tracking ─────────────────────────
let mut cache4 = prompt_cache_new(8)
cache4 = prompt_cache_insert(cache4, [1, 2, 3], [1.0], [2.0])
// 2 hits
cache4 = prompt_cache_record_lookup(cache4, true)
cache4 = prompt_cache_record_lookup(cache4, true)
// 1 miss
cache4 = prompt_cache_record_lookup(cache4, false)
check("hit rate 2/3", prompt_cache_hit_rate(cache4) > 0.66)
check("hit rate 2/3 < 0.67", prompt_cache_hit_rate(cache4) < 0.67)
check("miss rate 1/3", prompt_cache_miss_rate(cache4) > 0.33)
check("total lookups == 3", cache4.total_lookups == 3)

// ── Test 21: LRU eviction ────────────────────────────────────
// max_entries=2, insert 3 entries -> oldest evicted
let mut cache5 = prompt_cache_new(2)
cache5 = prompt_cache_insert(cache5, [1], [1.0], [1.0])
cache5 = prompt_cache_insert(cache5, [2], [2.0], [2.0])
check("before eviction: size == 2", prompt_cache_size(cache5) == 2)
cache5 = prompt_cache_insert(cache5, [3], [3.0], [3.0])
check("after eviction: size == 2", prompt_cache_size(cache5) == 2)

// ── Test 22: LRU evicts least recently used ──────────────────
// Entry [1] was first inserted (access=1), should be evicted
let mut found_1 = false
let mut found_2 = false
let mut found_3 = false
let mut i = 0

while i < len(cache5.entries) {
    if arr_eq(cache5.entries[i].tokens, [1]) {
        found_1 = true
    }
    if arr_eq(cache5.entries[i].tokens, [2]) {
        found_2 = true
    }
    if arr_eq(cache5.entries[i].tokens, [3]) {
        found_3 = true
    }
}
check("LRU: entry [1] evicted", !found_1)
check("LRU: entry [2] kept", found_2)
check("LRU: entry [3] kept", found_3)

// ── Test 23: prompt_cache_touch updates LRU timestamp ────────
let mut cache6 = prompt_cache_new(2)
cache6 = prompt_cache_insert(cache6, [10], [1.0], [1.0])
cache6 = prompt_cache_insert(cache6, [20], [2.0], [2.0])
// Touch [10] so it becomes most recent
cache6 = prompt_cache_touch(cache6, [10])
// Insert [30] -> should evict [20] (least recent now)
cache6 = prompt_cache_insert(cache6, [30], [3.0], [3.0])
let mut has_10 = false
let mut has_20 = false
let mut i = 0

while i < len(cache6.entries) {
    if arr_eq(cache6.entries[i].tokens, [10]) {
        has_10 = true
    }
    if arr_eq(cache6.entries[i].tokens, [20]) {
        has_20 = true
    }
}
check("touch: [10] kept after touch", has_10)
check("touch: [20] evicted (not touched)", !has_20)

// ── Test 24: prompt_cache_serve convenience ──────────────────
let mut cache7 = prompt_cache_new(4)
cache7 = prompt_cache_insert(cache7, [7, 8, 9], [77.0], [88.0])
let serve_result = prompt_cache_serve(cache7, [7, 8, 9, 10])
let cache7_updated = serve_result[0]
let serve_lookup = serve_result[1]
check("serve: hit", serve_lookup.hit)
check("serve: matched_len == 3", serve_lookup.matched_len == 3)
check("serve: remaining == [10]", arr_eq(serve_lookup.remaining_tokens, [10]))
check("serve: stats updated", cache7_updated.total_lookups == 1)
check("serve: hits == 1", cache7_updated.hits == 1)

// ── Test 25: prompt_cache_serve miss ─────────────────────────
let serve_miss = prompt_cache_serve(cache7, [999])
let cache7_miss = serve_miss[0]
let miss_lookup = serve_miss[1]
check("serve miss: no hit", !miss_lookup.hit)
check("serve miss: misses == 1", cache7_miss.misses == 1)

// ── Test 26: cache reset ─────────────────────────────────────
let cache8 = prompt_cache_reset(cache7)
check("reset: size == 0", prompt_cache_size(cache8) == 0)
check("reset: hit_rate == 0.0", prompt_cache_hit_rate(cache8) == 0.0)

// ── Test 27: radix_node_count ────────────────────────────────
let mut cache9 = prompt_cache_new(8)
cache9 = prompt_cache_insert(cache9, [1, 2, 3], [1.0], [1.0])
cache9 = prompt_cache_insert(cache9, [1, 2, 4], [2.0], [2.0])
let nc = radix_node_count(cache9.root)
// root + split([1,2]) + child([3]) + child([4])
check("radix node count >= 3", nc >= 3)

// ── Test 28: radix_kv_count ──────────────────────────────────
let kvc = radix_kv_count(cache9.root)
check("radix kv_count == 2", kvc == 2)

// ── Test 29: overwrite existing entry ────────────────────────
let mut cache10 = prompt_cache_new(4)
cache10 = prompt_cache_insert(cache10, [5, 6], [1.0], [2.0])
cache10 = prompt_cache_insert(cache10, [5, 6], [9.0], [8.0])
check("overwrite: size still 1", prompt_cache_size(cache10) == 1)
let look_ow = prompt_cache_lookup(cache10, [5, 6])
check("overwrite: kv updated", arr_eq(look_ow.kv_keys, [9.0]))

// ── Test 30: radix tree split correctness ────────────────────
// Insert [1,2,3] then [1,2,5] => split at [1,2] with children [3] and [5]
let mut cache11 = prompt_cache_new(8)
cache11 = prompt_cache_insert(cache11, [1, 2, 3], [10.0], [20.0])
cache11 = prompt_cache_insert(cache11, [1, 2, 5], [30.0], [40.0])
let look_s1 = prompt_cache_lookup(cache11, [1, 2, 3])
let look_s2 = prompt_cache_lookup(cache11, [1, 2, 5])
check("split: [1,2,3] still findable", look_s1.hit)
check("split: [1,2,5] findable", look_s2.hit)
check("split: [1,2,3] kv correct", arr_eq(look_s1.kv_keys, [10.0]))
check("split: [1,2,5] kv correct", arr_eq(look_s2.kv_keys, [30.0]))

// ═══════════════════════════════════════════════════════════════
println("")
println("pass=" + to_string(pass_count) + " fail=" + to_string(fail_count))
if fail_count == 0 {
    println("ALL PASS")
} else {
    println("FAILED")
}
println(to_string(pass_count) + " passed")
