// =============================================================
//  test_devirtualize.hexa -- Devirtualize direct call tests
//  Tests: static dispatch for single-impl interfaces (ROI id=23)
// =============================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("=============================================================")
println("  HEXA Devirtualize Tests (ROI id=23)")
println("=============================================================")
println("")

// -- 1. Direct function call (baseline) --

println("--- Direct call baseline ---")

fn direct_add(a, b) {
    return a + b
}

check("direct_add(3,4)", direct_add(3, 4), 7)
check("direct_add(10,20)", direct_add(10, 20), 30)

// -- 2. Function dispatch via map (simulated vtable) --

println("")
println("--- Simulated dispatch ---")

fn impl_square(x) { return x * x }
fn impl_double(x) { return x * 2 }

fn dispatch_call(method_name, arg) {
    if method_name == "square" { return impl_square(arg) }
    if method_name == "double" { return impl_double(arg) }
    return 0
}

check("dispatch square(5)", dispatch_call("square", 5), 25)
check("dispatch double(5)", dispatch_call("double", 5), 10)

// -- 3. Single implementation detection --

println("")
println("--- Single impl pattern ---")

// When only one type implements a method, the call can be devirtualized
fn area_rect(w, h) { return w * h }

fn compute_area(shape_type, w, h) {
    // Only rect exists -- devirtualizable
    if shape_type == "rect" {
        return area_rect(w, h)
    }
    return 0
}

check("devirt area_rect", compute_area("rect", 5, 3), 15)
check("devirt area_rect 2", compute_area("rect", 10, 10), 100)

// -- 4. Multiple dispatch targets (should NOT devirtualize) --

println("")
println("--- Multiple dispatch ---")

fn calc_circle(r) { return 3 * r * r }
fn calc_square_area(s) { return s * s }
fn calc_triangle(b, h) { return (b * h) / 2 }

fn multi_dispatch(shape, a, b) {
    if shape == "circle" { return calc_circle(a) }
    if shape == "square" { return calc_square_area(a) }
    if shape == "triangle" { return calc_triangle(a, b) }
    return 0
}

check("multi circle", multi_dispatch("circle", 5, 0), 75)
check("multi square", multi_dispatch("square", 4, 0), 16)
check("multi triangle", multi_dispatch("triangle", 6, 4), 12)

// -- 5. Chained calls --

println("")
println("--- Chained devirtualizable ---")

fn step1(x) { return x + 1 }
fn step2(x) { return x * 2 }
fn step3(x) { return x - 3 }

fn pipeline(x) {
    let a = step1(x)
    let b = step2(a)
    let c = step3(b)
    return c
}

check("pipeline(5)", pipeline(5), 9)
check("pipeline(10)", pipeline(10), 19)

// -- 6. Recursive single-impl --

println("")
println("--- Recursive single-impl ---")

// decreases depth — structural
fn tree_sum(depth) {
    if depth <= 0 { return 1 }
    return tree_sum(depth - 1) + tree_sum(depth - 1)
}

check("tree_sum(0)", tree_sum(0), 1)
check("tree_sum(3)", tree_sum(3), 8)
check("tree_sum(5)", tree_sum(5), 32)

// -- Summary --
println("")
println("=============================================================")
println("  Devirtualize: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("=============================================================")
