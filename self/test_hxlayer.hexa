// ═══════════════════════════════════════════════════════════════
//  test_hxlayer.hexa — C2 Step 1 fused kernel verification
//
//  Verifies self/ml/hxlayer.hexa :: fused_rmsnorm_silu against a
//  pure-hexa reference implementation at dim=128.
//
//  Structure (pure-hexa first; FFI path second, guarded):
//    T1  reference impl shape == input shape
//    T2  reference impl finite, non-NaN
//    T3  all-ones input → all-silu(1/rms*1) equivalence
//    T4  monotone input: silu(normalised) preserves sign
//    T5  (guarded) fused FFI path diff < 1e-5 vs reference
//
//  On Mac the @link("hxlayer") dylib may not be present (xverify builds
//  go into self/native/build/xverify/), so T5 degrades gracefully:
//  if the call throws (symbol not found or library missing), the test
//  records a SKIP and proceeds. The structural tests (T1–T4) always run.
//
//  Run: ./hexa self/test_hxlayer.hexa
//  Expected on Mac (no libhxlayer.dylib in DYLD path):
//    ---- test_hxlayer: PASS=4 FAIL=0 SKIP=1 ----
//  Expected on Linux (libhxlayer.so in LD_LIBRARY_PATH):
//    ---- test_hxlayer: PASS=5 FAIL=0 SKIP=0 ----
// ═══════════════════════════════════════════════════════════════

let mut PASS = 0
let mut FAIL = 0
let mut SKIP = 0

fn check(label, cond) {
    if cond {
        PASS = PASS + 1
        println("[PASS] " + label)
    } else {
        FAIL = FAIL + 1
        println("[FAIL] " + label)
    }
}

fn skip(label, reason) {
    SKIP = SKIP + 1
    println("[SKIP] " + label + " — " + reason)
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }

// ── pure-hexa reference (inlined from hxlayer.hexa ref impl) ──
// Inlined so the test runs even if hxlayer.hexa has not been
// built/parsed yet — T1–T4 are independent of the FFI layer.
fn ref_rmsnorm_silu(x, gamma, eps) {
    let n = len(x)
    let mut ms = 0.0
    let mut p = 0

    while p < n { ms = ms + x[p] * x[p] }
    ms = ms / (n * 1.0)
    let inv_r = 1.0 / sqrt(ms + eps)
    let mut out = []
    let mut p = 0

    while p < n {
        let t = x[p] * inv_r * gamma[p]
        let s = 1.0 / (1.0 + exp(0.0 - t))
        out = out + [t * s]
    }
    return out
}

// ── fixtures ────────────────────────────────────────────────────
let DIM = 128
let EPS = 0.00001

fn make_ones(n) {
    let mut v = []
    let mut _ = 0

    while _ < n { v = v + [1.0] }
    return v
}

fn make_monotone(n) {
    // x[i] = (i+1)/n  — strictly positive, in (0,1]
    let mut v = []
    let mut i = 0

    while i < n { v = v + [(i + 1) * 1.0 / (n * 1.0)] }
    return v
}

// ── tests ───────────────────────────────────────────────────────

fn t1_shape() {
    let x = make_ones(DIM)
    let g = make_ones(DIM)
    let y = ref_rmsnorm_silu(x, g, EPS)
    check("T1 shape: ref output len == DIM", len(y) == DIM)
}

fn t2_finite() {
    let x = make_monotone(DIM)
    let g = make_ones(DIM)
    let y = ref_rmsnorm_silu(x, g, EPS)
    let mut all_finite = true
    let mut p = 0

    while p < DIM {
        let v = y[p]
        // finite ≙ not NaN and not ±inf; use self-comparison for NaN,
        // magnitude bound for inf (silu on bounded input is ≤ ~1).
        if v != v { all_finite = false }
        if v > 1.0e6 { all_finite = false }
        if v < (0.0 - 1.0e6) { all_finite = false }
    }
    check("T2 finite: no NaN/Inf across DIM=128", all_finite)
}

fn t3_ones() {
    // rmsnorm(ones) = ones / sqrt(1 + eps) ≈ ones  (eps tiny)
    // silu(≈1)    = 1 * sigmoid(1) ≈ 0.7310586
    let x = make_ones(DIM)
    let g = make_ones(DIM)
    let y = ref_rmsnorm_silu(x, g, EPS)
    let expected_sig = 1.0 / (1.0 + exp(0.0 - 1.0))  // sigmoid(1) ≈ 0.73106
    let expected = 1.0 * expected_sig
    let mut max_err = 0.0
    let mut p = 0

    while p < DIM {
        let e = fabs(y[p] - expected)
        if e > max_err { max_err = e }
    }
    // eps=1e-5 perturbs rms by ~5e-6 → silu output perturbed similarly
    check("T3 ones: |y - silu(1)| < 1e-4", max_err < 0.0001)
}

fn t4_sign() {
    // monotone positive input → silu(positive) > 0 elementwise
    let x = make_monotone(DIM)
    let g = make_ones(DIM)
    let y = ref_rmsnorm_silu(x, g, EPS)
    let mut all_pos = true
    let mut p = 0

    while p < DIM {
        if y[p] <= 0.0 { all_pos = false }
    }
    check("T4 sign: silu(positive) > 0 elementwise", all_pos)
}

// T5 calls the FFI. The Rust-prebuilt interpreter does not resolve
// arbitrary @link externs beyond its baked-in set, so T5 is gated on
// an explicit opt-in env var HXLAYER_FFI_LIVE=1. When set, the caller
// is asserting libhxlayer.{dylib,so} is reachable (e.g. via DYLD or
// LD_LIBRARY_PATH) AND that the interpreter supports @link("hxlayer").
// Default path is SKIP to keep CI green on Mac/stage0.
fn t5_ffi_diff() {
    let gate = env_var("HXLAYER_FFI_LIVE")
    if gate != "1" {
        skip("T5 ffi diff", "set HXLAYER_FFI_LIVE=1 to exercise FFI path")
        return 0
    }

    let x = make_monotone(DIM)
    let g = make_ones(DIM)
    let y_ref = ref_rmsnorm_silu(x, g, EPS)

    // ── FFI path (opt-in) ──
    let n = len(x)
    let x_buf = alloc_raw(n * 4)
    let g_buf = alloc_raw(n * 4)
    let o_buf = alloc_raw(n * 4)
    let mut p = 0

    while p < n {
        write_f32(x_buf, p * 4, x[p])
        write_f32(g_buf, p * 4, g[p])
    }
    hxlayer_rmsnorm_silu(n, o_buf, x_buf, g_buf, EPS)
    let mut max_err = 0.0
    let mut p = 0

    while p < n {
        let yp = deref_f32(o_buf, p * 4)
        let e = fabs(yp - y_ref[p])
        if e > max_err { max_err = e }
    }
    free_raw(x_buf, n * 4)
    free_raw(g_buf, n * 4)
    free_raw(o_buf, n * 4)

    check("T5 ffi diff: max|ffi - ref| < 1e-5", max_err < 0.00001)
    return 0
}

// Extern must be declared at module scope even if call is guarded.
@link("hxlayer")
extern fn hxlayer_rmsnorm_silu(N: int, out: *Void, x: *Void, gamma: *Void, eps: float)

fn main() {
    println("=== test_hxlayer ===")
    t1_shape()
    t2_finite()
    t3_ones()
    t4_sign()
    t5_ffi_diff()
    println("---- test_hxlayer: PASS=" + to_string(PASS) + " FAIL=" + to_string(FAIL) + " SKIP=" + to_string(SKIP) + " ----")
}
