// ═══════════════════════════════════════════════════════════════
//  self/ml/t1_attr_micro.hexa — relative speedup of AI-native @attr
//  vs dense baseline matmul.
//
//  Baseline: matmul(1024, 1024, 1024) native cblas
//  Compare:
//    - @sparse(0.5): CSR path (sparse_mm.hexa)
//    - @lowrank(32): low-rank path (lowrank_mm.hexa)
//    - @matmul_fused(ReLU): single-pass matmul+activation
// ═══════════════════════════════════════════════════════════════

import "ml/lowrank_mm.hexa"
import "ml/matmul_fused.hexa"

let N = 1024
let R = 32

fn bench_dense(iters) {
    let A = tensor_zeros(N * N)
    let B = tensor_zeros(N * N)
    let _ = matmul(A, B, N, N, N)  // warmup
    let s0 = clock()
    let mut i = 0
    while i < iters {
        let _ = matmul(A, B, N, N, N)
        i = i + 1
    }
    let elapsed = s1_s0_safe(s0)
    return elapsed / to_float(str(iters))
}

fn s1_s0_safe(s0) {
    let s1 = clock()
    return s1 - s0
}

fn bench_lowrank(iters) {
    // W = U @ V : (N×R) @ (R×N)
    let U = tensor_zeros(N * R)
    let V = tensor_zeros(R * N)
    let X = tensor_zeros(N * N)
    // 1 warmup call direct
    let _ = lowrank_mm(U, V, X, N, R, N, N)
    let s0 = clock()
    let mut i = 0
    while i < iters {
        let _ = lowrank_mm(U, V, X, N, R, N, N)
        i = i + 1
    }
    let elapsed = s1_s0_safe(s0)
    return elapsed / to_float(str(iters))
}

fn bench_fused(iters) {
    let A = tensor_zeros(N * N)
    let B = tensor_zeros(N * N)
    let _ = matmul_relu(A, B, N, N, N)
    let s0 = clock()
    let mut i = 0
    while i < iters {
        let _ = matmul_relu(A, B, N, N, N)
        i = i + 1
    }
    let elapsed = s1_s0_safe(s0)
    return elapsed / to_float(str(iters))
}

println("[t1_attr_micro] relative speedup test (N=1024)")

let dense_s = bench_dense(5)
let lowrank_s = bench_lowrank(5)
let fused_s = bench_fused(3)

let speedup_lowrank = dense_s / lowrank_s
let speedup_fused = dense_s / fused_s

let mut line = "{"
line = line + "\"N\":" + str(N)
line = line + ",\"R\":" + str(R)
line = line + ",\"dense_ms\":" + str(dense_s * 1000.0)
line = line + ",\"lowrank_ms\":" + str(lowrank_s * 1000.0)
line = line + ",\"fused_ms\":" + str(fused_s * 1000.0)
line = line + ",\"lowrank_speedup\":" + str(speedup_lowrank)
line = line + ",\"fused_speedup\":" + str(speedup_fused)
line = line + "}"
println(line)
