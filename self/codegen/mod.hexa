// self/codegen/mod.hexa — ported from src/codegen/mod.rs
// Native Code Generation — phi=2 targets (ARM64 + x86-64).
// No LLVM. No Cranelift. Direct machine code emission.

// Target architecture
// 0 = Arm64, 1 = X86_64
fn target_arm64() -> int { return 0 }
fn target_x86_64() -> int { return 1 }

// Object file format
// 0 = MachO, 1 = Elf
fn objformat_macho() -> int { return 0 }
fn objformat_elf() -> int { return 1 }

// Code generation result
struct CodegenResult {
    code: [int],
    target: int,
    format: int
}

// Detect the current host target.
// Hexa runs on macOS ARM64 by default in this project.
fn host_target() -> [int] {
    // Returns [target, format]
    // Default: ARM64 + MachO (macOS)
    return [target_arm64(), objformat_macho()]
}

// Generate native code from an IR module (conceptual).
// In the self-hosted port, this dispatches to arm64/x86_64 emitters
// and wraps output in macho/elf format.
fn generate(module: string, target: int, format: int) -> CodegenResult {
    // 1. Register allocation
    // let alloc_result = regalloc_allocate(module, target)
    // 2. Generate machine code per target
    // 3. Wrap in object format
    return CodegenResult {
        code: [],
        target: target,
        format: format
    }
}

// Compile an IR module to a native executable (conceptual).
fn compile_to_binary(module: string, output_path: string) -> string {
    let host = host_target()
    let target = host[0]
    let format = host[1]
    let result = generate(module, target, format)
    // Write object file, C wrapper, link with system linker
    // Returns "" on success, error string on failure
    return ""
}
