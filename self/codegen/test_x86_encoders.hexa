// ═══════════════════════════════════════════════════════════
//  self/codegen/test_x86_encoders.hexa
//
//  Smoke test for the x86-64 ALU/compare/branch/push/pop encoders
//  added in the ARM64 parity pass. Verifies byte-level encoding
//  against Intel SDM reference; all values cross-checked with
//  GCC `objdump -d` golden output for the same mnemonics.
//
//  Intentionally uses the top-level test-harness style from
//  test_regalloc_coverage — no framework, just `assert` + prints.
//  Run:  ./build/hexa_interp self/codegen/test_x86_encoders.hexa
//
// ═══════════════════════════════════════════════════════════

use "x86_64"

fn expect_bytes(label: string, actual: [int], expected: [int]) -> int {
    if len(actual) != len(expected) {
        println("FAIL " + label + ": len actual=" + str(len(actual)) + " expected=" + str(len(expected)))
        return 1
    }
    let mut i = 0
    while i < len(actual) {
        if actual[i] != expected[i] {
            println("FAIL " + label + " @" + str(i) + ": actual=" + str(actual[i]) + " expected=" + str(expected[i]))
            return 1
        }
        i = i + 1
    }
    println("PASS " + label)
    return 0
}

let mut fails = 0

// add rbx, rax  →  48 01 c3
fails = fails + expect_bytes("add rbx,rax",
    x86_emit_add_rr([], 3, 0),
    [0x48, 0x01, 0xc3])

// sub rcx, rdx  →  48 29 d1
fails = fails + expect_bytes("sub rcx,rdx",
    x86_emit_sub_rr([], 1, 2),
    [0x48, 0x29, 0xd1])

// imul rax, rbx  →  48 0f af c3
fails = fails + expect_bytes("imul rax,rbx",
    x86_emit_imul_rr([], 0, 3),
    [0x48, 0x0f, 0xaf, 0xc3])

// cmp rax, rbx  →  48 39 d8  (cmp lhs=rax, rhs=rbx: emits ModRM with rhs in /r)
fails = fails + expect_bytes("cmp rax,rbx",
    x86_emit_cmp_rr([], 0, 3),
    [0x48, 0x39, 0xd8])

// test rcx, rcx  →  48 85 c9
fails = fails + expect_bytes("test rcx,rcx",
    x86_emit_test_rr([], 1),
    [0x48, 0x85, 0xc9])

// jmp rel32=0x00000010  →  e9 10 00 00 00
fails = fails + expect_bytes("jmp rel32=0x10",
    x86_emit_jmp_rel32([], 0x10),
    [0xe9, 0x10, 0x00, 0x00, 0x00])

// je rel32=0x20  (tttn=0x04)  →  0f 84 20 00 00 00
fails = fails + expect_bytes("je rel32=0x20",
    x86_emit_jcc_rel32([], 0x04, 0x20),
    [0x0f, 0x84, 0x20, 0x00, 0x00, 0x00])

// call rel32=0x100  →  e8 00 01 00 00
fails = fails + expect_bytes("call rel32=0x100",
    x86_emit_call_rel32([], 0x100),
    [0xe8, 0x00, 0x01, 0x00, 0x00])

// ret  →  c3
fails = fails + expect_bytes("ret",
    x86_emit_ret([]),
    [0xc3])

// push rax  →  50
fails = fails + expect_bytes("push rax",
    x86_emit_push_reg([], 0),
    [0x50])

// push r9  →  41 51
fails = fails + expect_bytes("push r9",
    x86_emit_push_reg([], 9),
    [0x41, 0x51])

// pop rdi  →  5f
fails = fails + expect_bytes("pop rdi",
    x86_emit_pop_reg([], 7),
    [0x5f])

// pop r13  →  41 5d
fails = fails + expect_bytes("pop r13",
    x86_emit_pop_reg([], 13),
    [0x41, 0x5d])

// Patch smoke: emit jmp with placeholder rel=0, then patch to rel=0x50.
// Pre-patch bytes: e9 00 00 00 00
// Post-patch bytes: e9 50 00 00 00
let pre = x86_emit_jmp_rel32([], 0)
fails = fails + expect_bytes("jmp pre-patch",
    pre,
    [0xe9, 0x00, 0x00, 0x00, 0x00])
let post = x86_patch_rel32(pre, 0, 0, 0x50)
fails = fails + expect_bytes("jmp post-patch",
    post,
    [0xe9, 0x50, 0x00, 0x00, 0x00])

// Patch jcc (op_kind=1): disp starts at offset+2.
let jpre = x86_emit_jcc_rel32([], 0x04, 0)
let jpost = x86_patch_rel32(jpre, 0, 1, 0x80)
fails = fails + expect_bytes("je post-patch",
    jpost,
    [0x0f, 0x84, 0x80, 0x00, 0x00, 0x00])

// ── Backward rel32 — negative-value two's-complement normalization ───
// Pre-fix, x86_emit_*_rel32 lost high-byte sign extension for negative rel
// (Hexa % follows dividend sign). Verifies all three rel32 forms + patch.

// jmp rel32=-1 → e9 ff ff ff ff
fails = fails + expect_bytes("jmp rel32=-1",
    x86_emit_jmp_rel32([], 0 - 1),
    [0xe9, 0xff, 0xff, 0xff, 0xff])

// je rel32=-16 → 0f 84 f0 ff ff ff
fails = fails + expect_bytes("je rel32=-16",
    x86_emit_jcc_rel32([], 0x04, 0 - 16),
    [0x0f, 0x84, 0xf0, 0xff, 0xff, 0xff])

// call rel32=-35 → e8 dd ff ff ff
fails = fails + expect_bytes("call rel32=-35",
    x86_emit_call_rel32([], 0 - 35),
    [0xe8, 0xdd, 0xff, 0xff, 0xff])

// patch (op_kind=0) with rel=-5 → e9 fb ff ff ff
let npre = x86_emit_jmp_rel32([], 0)
let npost = x86_patch_rel32(npre, 0, 0, 0 - 5)
fails = fails + expect_bytes("jmp patch rel=-5",
    npost,
    [0xe9, 0xfb, 0xff, 0xff, 0xff])

// movabs rax, -0x200000000 → 48 b8 00 00 00 00 fe ff ff ff
fails = fails + expect_bytes("movabs rax, neg i64",
    x86_emit_mov_imm64([], 0, 0 - 8589934592),
    [0x48, 0xb8, 0x00, 0x00, 0x00, 0x00, 0xfe, 0xff, 0xff, 0xff])

// ── r8-r15 REX.R/B encoding — previously broken (plain 0x48 collapsed r8+→rax) ───
// mov r8, rax → 49 89 c0   (REX.W+B, src=rax=0, dst=r8=8)
fails = fails + expect_bytes("mov r8,rax",
    x86_emit_mov_rr([], 8, 0),
    [0x49, 0x89, 0xc0])

// mov rax, r9 → 4c 89 c8   (REX.W+R, src=r9=9, dst=rax=0)
fails = fails + expect_bytes("mov rax,r9",
    x86_emit_mov_rr([], 0, 9),
    [0x4c, 0x89, 0xc8])

// add r10, r11 → 4d 01 da  (REX.W+R+B, src=r11=11, dst=r10=10)
fails = fails + expect_bytes("add r10,r11",
    x86_emit_add_rr([], 10, 11),
    [0x4d, 0x01, 0xda])

// test r12, r12 → 4d 85 e4
fails = fails + expect_bytes("test r12,r12",
    x86_emit_test_rr([], 12),
    [0x4d, 0x85, 0xe4])

// movabs r14, 1 → 49 be 01 00 00 00 00 00 00 00
fails = fails + expect_bytes("movabs r14,1",
    x86_emit_mov_imm64([], 14, 1),
    [0x49, 0xbe, 0x01, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00, 0x00])

// setcc al → 40 0f 94 c0 48 0f b6 c0 (REX required to disambiguate AH vs AL family)
fails = fails + expect_bytes("sete al",
    x86_emit_setcc([], 0, 0x04),
    [0x40, 0x0f, 0x94, 0xc0, 0x48, 0x0f, 0xb6, 0xc0])

// setcc dil → 40 0f 94 c7 48 0f b6 ff
// Pre-fix this emitted 0f 94 c7 → SETcc BH (WRONG register — legacy high-byte).
fails = fails + expect_bytes("sete dil",
    x86_emit_setcc([], 7, 0x04),
    [0x40, 0x0f, 0x94, 0xc7, 0x48, 0x0f, 0xb6, 0xff])

// setcc r10b → 41 0f 94 c2 4d 0f b6 d2
fails = fails + expect_bytes("sete r10b",
    x86_emit_setcc([], 10, 0x04),
    [0x41, 0x0f, 0x94, 0xc2, 0x4d, 0x0f, 0xb6, 0xd2])

// Condition code mapping: arm64 eq=0 → x86 tttn=0x04
if x86_cc_from_arm64(0) != 0x04 { println("FAIL cc map eq"); fails = fails + 1 }
if x86_cc_from_arm64(1) != 0x05 { println("FAIL cc map ne"); fails = fails + 1 }
if x86_cc_from_arm64(10) != 0x0d { println("FAIL cc map ge"); fails = fails + 1 }
if x86_cc_from_arm64(11) != 0x0c { println("FAIL cc map lt"); fails = fails + 1 }
if x86_cc_from_arm64(12) != 0x0f { println("FAIL cc map gt"); fails = fails + 1 }
if x86_cc_from_arm64(13) != 0x0e { println("FAIL cc map le"); fails = fails + 1 }

if fails == 0 {
    println("[test_x86_encoders] all PASS")
} else {
    println("[test_x86_encoders] FAILS=" + str(fails))
    exit(1)
}
