// self/codegen/macho.hexa — ported from src/codegen/macho.rs
// Mach-O binary format wrapper — macOS object files.
// Wraps raw machine code in Mach-O 64-bit relocatable object format (.o).

fn mh_magic_64() -> int { return 0xFEEDFACF }
fn mh_object() -> int { return 1 }
fn cpu_type_arm64() -> int { return 0x0100000C }
fn cpu_subtype_all() -> int { return 0 }
fn lc_segment_64() -> int { return 0x19 }
fn lc_symtab() -> int { return 0x02 }
fn lc_build_version() -> int { return 0x32 }
fn s_attr_pure_instructions() -> int { return 0x80000000 }
fn s_attr_some_instructions() -> int { return 0x00000400 }
fn n_ext() -> int { return 0x01 }
fn n_sect() -> int { return 0x0e }

fn align_to(val: int, align: int) -> int {
    return (val + align - 1) / align * align
}

// Wrap machine code in Mach-O relocatable object (.o) format.
fn macho_wrap(code: [int], main_offset: int) -> [int] {
    let mut out = []
    let code_size = len(code)
    let symbol_name = "_hexa_main"

    let header_size = 32
    let segment_cmd_size = 152  // 72 + 80
    let symtab_cmd_size = 24
    let build_version_cmd_size = 24
    let sizeofcmds = segment_cmd_size + symtab_cmd_size + build_version_cmd_size

    let code_offset = align_to(header_size + sizeofcmds, 8)
    let symtab_offset = align_to(code_offset + code_size, 4)
    let nlist_size = 16
    let strtab_offset = symtab_offset + nlist_size
    let strtab_size = 1 + 11  // \0 + _hexa_main\0

    // Mach-O Header (32 bytes)
    out = push_u32_le(out, mh_magic_64())
    out = push_u32_le(out, cpu_type_arm64())
    out = push_u32_le(out, cpu_subtype_all())
    out = push_u32_le(out, mh_object())
    out = push_u32_le(out, 3)              // ncmds
    out = push_u32_le(out, sizeofcmds)
    out = push_u32_le(out, 0)              // flags
    out = push_u32_le(out, 0)              // reserved

    // LC_SEGMENT_64
    out = push_u32_le(out, lc_segment_64())
    out = push_u32_le(out, segment_cmd_size)
    // segname: 16 zero bytes
    let mut i = 0
    while i < 16 { out = out.push(0); i = i + 1 }
    out = push_u64_le(out, 0)              // vmaddr
    out = push_u64_le(out, align_to(strtab_offset + strtab_size, 8))  // vmsize
    out = push_u64_le(out, code_offset)    // fileoff
    out = push_u64_le(out, strtab_offset + strtab_size - code_offset)  // filesize
    out = push_u32_le(out, 7)              // maxprot
    out = push_u32_le(out, 7)              // initprot
    out = push_u32_le(out, 1)              // nsects
    out = push_u32_le(out, 0)              // flags

    // Section header: __text (80 bytes)
    // sectname "__text" + padding
    out = out.push(95).push(95).push(116).push(101).push(120).push(116)
    let mut j = 0
    while j < 10 { out = out.push(0); j = j + 1 }
    // segname "__TEXT" + padding
    out = out.push(95).push(95).push(84).push(69).push(88).push(84)
    j = 0
    while j < 10 { out = out.push(0); j = j + 1 }
    out = push_u64_le(out, 0)              // addr
    out = push_u64_le(out, code_size)      // size
    out = push_u32_le(out, code_offset)    // offset
    out = push_u32_le(out, 2)              // align
    out = push_u32_le(out, 0)              // reloff
    out = push_u32_le(out, 0)              // nreloc
    out = push_u32_le(out, s_attr_pure_instructions() + s_attr_some_instructions())
    out = push_u32_le(out, 0)              // reserved1
    out = push_u32_le(out, 0)              // reserved2
    out = push_u32_le(out, 0)              // reserved3

    // LC_SYMTAB
    out = push_u32_le(out, lc_symtab())
    out = push_u32_le(out, symtab_cmd_size)
    out = push_u32_le(out, symtab_offset)
    out = push_u32_le(out, 1)              // nsyms
    out = push_u32_le(out, strtab_offset)
    out = push_u32_le(out, strtab_size)

    // LC_BUILD_VERSION
    out = push_u32_le(out, lc_build_version())
    out = push_u32_le(out, build_version_cmd_size)
    out = push_u32_le(out, 1)              // platform = MACOS
    out = push_u32_le(out, 0x000E0000)     // minos = 14.0
    out = push_u32_le(out, 0x000E0000)     // sdk = 14.0
    out = push_u32_le(out, 0)              // ntools

    // Pad to code_offset
    while len(out) < code_offset { out = out.push(0) }

    // Code section
    let mut k = 0
    while k < len(code) { out = out.push(code[k]); k = k + 1 }

    // Pad to symtab_offset
    while len(out) < symtab_offset { out = out.push(0) }

    // Symbol table: nlist_64 (16 bytes)
    out = push_u32_le(out, 1)              // n_strx
    out = out.push(n_sect() + n_ext())     // n_type
    out = out.push(1)                      // n_sect
    out = push_u16_le(out, 0)              // n_desc
    out = push_u64_le(out, main_offset)    // n_value

    // String table
    out = out.push(0)  // leading null
    // "_hexa_main\0"
    out = out.push(95).push(104).push(101).push(120).push(97)
    out = out.push(95).push(109).push(97).push(105).push(110).push(0)

    return out
}

// Helper: push 16-bit LE
fn push_u16_le(buf: [int], val: int) -> [int] {
    return buf.push(val % 256).push((val / 256) % 256)
}

// Helper: push 32-bit LE
fn push_u32_le(buf: [int], val: int) -> [int] {
    return buf.push(val % 256).push((val / 256) % 256).push((val / 65536) % 256).push((val / 16777216) % 256)
}

// Helper: push 64-bit LE
fn push_u64_le(buf: [int], val: int) -> [int] {
    let mut b = push_u32_le(buf, val % 0x100000000)
    return push_u32_le(b, val / 0x100000000)
}
