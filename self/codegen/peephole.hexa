// self/codegen/peephole.hexa — ported from src/codegen/peephole.rs
// ARM64 Peephole Optimizer — length-preserving post-emit pass.
// 12 rewrite rules (sigma=12 alignment), sliding 4-wide window.

// NOTE ON CONSTANT STYLE: this file uses decimal literals for 32-bit ARM64
// encoding values rather than hex. Both forms compile identically in the
// native path, but the hexa interpreter (used by self/test_peephole_arm64.hexa
// and future standalone harnesses) currently evaluates hex literals whose top
// bit might flip (i.e. anything ≥ 0x80000000, and in some builds any hex) to 0.
// Using decimal keeps the decoder masks (top10 = 997 for LDR, etc.) distinct
// under both execution modes. Hex values are kept in comments for readability.

fn nop_word() -> int { return 3573751839 } // 0xd503201f

// Decoded instruction tag constants
fn TAG_RAW() -> int { return 0 }
fn TAG_NOP() -> int { return 1 }
fn TAG_MOV() -> int { return 2 }
fn TAG_ADD() -> int { return 3 }
fn TAG_SUB() -> int { return 4 }
fn TAG_MUL() -> int { return 5 }
fn TAG_CMP() -> int { return 6 }
fn TAG_LDR() -> int { return 7 }
fn TAG_STR() -> int { return 8 }
fn TAG_MADD() -> int { return 9 }
fn TAG_MSUB() -> int { return 10 }
fn TAG_CBNZ() -> int { return 11 }
fn TAG_BRANCH() -> int { return 12 }
fn TAG_BCOND() -> int { return 13 }

// Decoded instruction: [tag, field1, field2, field3, field4]
// Fields depend on tag. For MOV: [TAG_MOV, rd, rn, 0, 0]
// For ADD: [TAG_ADD, rd, rn, rm, 0]

struct PeepholeStats {
    identity_nop: int,
    mul_add_to_madd: int,
    mul_sub_to_msub: int,
    str_ldr_elim: int,
    redundant_reverse_mov: int,
    ldp_fuse: int,
    stp_fuse: int,
    mov_zero_to_xzr: int,
    add_zero_to_mov: int,
    sub_zero_to_mov: int,
    // Tier-2 counters (ROI #166)
    cmp_beq_to_cbz: int,
    cmp_bne_to_cbnz: int,
    mul_add_fuse: int,
    mul_sub_fuse: int,
    movz_str_to_strxzr: int,
    rounds: int
}

fn peephole_stats_default() -> PeepholeStats {
    return PeepholeStats {
        identity_nop: 0,
        mul_add_to_madd: 0,
        mul_sub_to_msub: 0,
        str_ldr_elim: 0,
        redundant_reverse_mov: 0,
        ldp_fuse: 0,
        stp_fuse: 0,
        mov_zero_to_xzr: 0,
        add_zero_to_mov: 0,
        sub_zero_to_mov: 0,
        cmp_beq_to_cbz: 0,
        cmp_bne_to_cbnz: 0,
        mul_add_fuse: 0,
        mul_sub_fuse: 0,
        movz_str_to_strxzr: 0,
        rounds: 0
    }
}

fn peephole_stats_total(s: PeepholeStats) -> int {
    return s.identity_nop + s.mul_add_to_madd + s.mul_sub_to_msub + s.str_ldr_elim + s.redundant_reverse_mov + s.ldp_fuse + s.stp_fuse + s.mov_zero_to_xzr + s.add_zero_to_mov + s.sub_zero_to_mov + s.cmp_beq_to_cbz + s.cmp_bne_to_cbnz + s.mul_add_fuse + s.mul_sub_fuse + s.movz_str_to_strxzr
}

// Decode a 32-bit ARM64 word into a tag.
fn decode_tag(word: int) -> int {
    if word == nop_word() { return TAG_NOP() }
    // Check MOV pattern: ORR Xd, XZR, Xm (base 0xAA0003E0 = 2852127712)
    if (word / 32) * 32 == (2852127712 / 32) * 32 {
        return TAG_MOV()
    }
    return TAG_RAW()
}

// Run the peephole optimizer over a code buffer (array of bytes).
// Returns updated stats. Code is modified in-place conceptually.
// In Hexa, we return updated (code, stats) pair.
struct PeepholeResult {
    code: [int],
    stats: PeepholeStats
}

// Read a 32-bit LE word at byte offset `off` in code buffer.
fn peep_read_word_le(code: [int], off: int) -> int {
    return code[off] + code[off + 1] * 256 + code[off + 2] * 65536 + code[off + 3] * 16777216
}

// Write a 32-bit LE word at byte offset `off` in code buffer.
// Rebuilds the array rather than using `c[i] = v` index-assignment,
// which is not reliable under the hexa interpreter (only native codegen
// honors in-place array index assignment). The rebuild form works in
// both interpreted and native paths.
fn peep_write_word_le(code: [int], off: int, word: int) -> [int] {
    let b0 = word % 256
    let b1 = (word / 256) % 256
    let b2 = (word / 65536) % 256
    let b3 = (word / 16777216) % 256
    let mut out = []
    let mut i = 0
    let n = len(code)
    while i < n {
        if i == off {
            out = out.push(b0)
        } else if i == off + 1 {
            out = out.push(b1)
        } else if i == off + 2 {
            out = out.push(b2)
        } else if i == off + 3 {
            out = out.push(b3)
        } else {
            out = out.push(code[i])
        }
        i = i + 1
    }
    return out
}

// Decode MOV Xd, Xn  (ORR Xd, XZR, Xn encoding: 0xAA0003E0 + (rm<<16) + rd)
// Returns [rd, rn] if word is a MOV, else [-1, -1]. Opcode mask bits [31:21]
// are 0x550 after the shift — match against 0xAA0003E0's top 11 bits == 0x550.
fn peep_decode_mov(word: int) -> [int] {
    // Top 11 bits (mask 0xFFE00000) must equal 0xAA000000's top 11: 0x550 = 1360.
    let top11 = (word / 2097152) % 2048
    if top11 != 1360 { return [0 - 1, 0 - 1] }
    // ORR form uses Rn = XZR (31). Extract Rn (bits 5..9).
    let rn_field = (word / 32) % 32
    if rn_field != 31 { return [0 - 1, 0 - 1] }
    let rd = word % 32
    let rm = (word / 65536) % 32
    return [rd, rm]
}

// Decode LDR Xt, [Xn, #imm12*8] unsigned-offset 64-bit form.
// Encoding: 0xF9400000 | (imm12<<10) | (Rn<<5) | Rt   (top 10 bits = 0x3E5 = 997)
// Returns [rt, rn, imm12] on match, else [-1,-1,-1]
fn peep_decode_ldr_uoff(word: int) -> [int] {
    let top10 = (word / 4194304) % 1024
    if top10 != 997 { return [0 - 1, 0 - 1, 0 - 1] }
    let rt = word % 32
    let rn = (word / 32) % 32
    let imm12 = (word / 1024) % 4096
    return [rt, rn, imm12]
}

// Decode STR Xt, [Xn, #imm12*8] unsigned-offset 64-bit form.
// Encoding: 0xF9000000 | (imm12<<10) | (Rn<<5) | Rt   (top 10 bits = 0x3E4 = 996)
fn peep_decode_str_uoff(word: int) -> [int] {
    let top10 = (word / 4194304) % 1024
    if top10 != 996 { return [0 - 1, 0 - 1, 0 - 1] }
    let rt = word % 32
    let rn = (word / 32) % 32
    let imm12 = (word / 1024) % 4096
    return [rt, rn, imm12]
}

// Encode LDP Xt1, Xt2, [Xn, #imm7*8] signed-offset 64-bit form.
// Base 0xA9400000 = 2839543808 | (imm7 & 0x7F) << 15 | Rt2<<10 | Rn<<5 | Rt1
// imm7 signed, scaled *8, range -64..63 (i.e. -512..504 bytes).
fn peep_enc_ldp_soff(rt1: int, rt2: int, rn: int, imm7: int) -> int {
    let imm7m = imm7 % 128
    if imm7m < 0 { return 2839543808 + (imm7m + 128) * 32768 + rt2 * 1024 + rn * 32 + rt1 }
    return 2839543808 + imm7m * 32768 + rt2 * 1024 + rn * 32 + rt1
}

// Encode STP Xt1, Xt2, [Xn, #imm7*8] signed-offset 64-bit form.
// Base 0xA9000000 = 2835349504 | (imm7 & 0x7F) << 15 | Rt2<<10 | Rn<<5 | Rt1
fn peep_enc_stp_soff(rt1: int, rt2: int, rn: int, imm7: int) -> int {
    let imm7m = imm7 % 128
    if imm7m < 0 { return 2835349504 + (imm7m + 128) * 32768 + rt2 * 1024 + rn * 32 + rt1 }
    return 2835349504 + imm7m * 32768 + rt2 * 1024 + rn * 32 + rt1
}

// Encode MOV Xd, XZR  (ORR Xd, XZR, XZR) = 0xAA1F03E0 = 2854159328 | Rd
fn peep_enc_mov_xzr(rd: int) -> int {
    return 2854159328 + rd
}

// Encode MOV Xd, Xs  (ORR Xd, XZR, Xs) = 0xAA0003E0 = 2852127712 | (Rs<<16) | Rd
fn peep_enc_mov_reg(rd: int, rs: int) -> int {
    return 2852127712 + rs * 65536 + rd
}

// Decode MOVZ Xd, #imm16, LSL #0 (64-bit). Returns [rd, imm16] if matches, else [-1,-1].
// Encoding: 0xD2800000 | (hw<<21) | (imm16<<5) | Rd.  We match hw==0 only (LSL #0).
// Top 9 bits (mask 0xFF800000) must equal 0xD2800000's top 9: 0x1A5 = 421.
fn peep_decode_movz(word: int) -> [int] {
    let top9 = (word / 8388608) % 512
    if top9 != 421 { return [0 - 1, 0 - 1] }
    // hw = bits [22:21], must be 0 for LSL #0
    let hw = (word / 2097152) % 4
    if hw != 0 { return [0 - 1, 0 - 1] }
    let rd = word % 32
    let imm16 = (word / 32) % 65536
    return [rd, imm16]
}

// Decode ADD Xd, Xs, #imm12 (imm form, shift=0, 64-bit, S=0).
// Encoding: 0x91000000 | (shift<<22) | (imm12<<10) | (Rs<<5) | Rd
// Top 9 bits (mask 0xFF800000) must equal 0x91000000's top 9: 0x122 = 290.
// shift bits [23:22] must be 0.
fn peep_decode_add_imm(word: int) -> [int] {
    let top9 = (word / 8388608) % 512
    if top9 != 290 { return [0 - 1, 0 - 1, 0 - 1] }
    let shift = (word / 4194304) % 4
    if shift != 0 { return [0 - 1, 0 - 1, 0 - 1] }
    let rd = word % 32
    let rs = (word / 32) % 32
    let imm12 = (word / 1024) % 4096
    return [rd, rs, imm12]
}

// Decode SUB Xd, Xs, #imm12 (imm form, shift=0, 64-bit, S=0).
// Encoding: 0xD1000000 | (shift<<22) | (imm12<<10) | (Rs<<5) | Rd
// Top 9 bits must equal 0xD1000000's top 9: 0x1A2 = 418.
fn peep_decode_sub_imm(word: int) -> [int] {
    let top9 = (word / 8388608) % 512
    if top9 != 418 { return [0 - 1, 0 - 1, 0 - 1] }
    let shift = (word / 4194304) % 4
    if shift != 0 { return [0 - 1, 0 - 1, 0 - 1] }
    let rd = word % 32
    let rs = (word / 32) % 32
    let imm12 = (word / 1024) % 4096
    return [rd, rs, imm12]
}

// ──────────────────────────────────────────────────────────────
//  Tier-2 decoders / encoders (ROI #166)
// ──────────────────────────────────────────────────────────────

// Decode CMP Xn, #imm12 (= SUBS XZR, Xn, #imm12, shift=0, 64-bit).
// Encoding: 0xF1000000 | (shift<<22) | (imm12<<10) | (Rn<<5) | 31
// Top 9 bits = 0xF1000000 >> 23 = 0x1E2 = 482. Rd must be 31.
// Returns [rn, imm12] on match, else [-1, -1].
fn peep_decode_cmp_imm(word: int) -> [int] {
    let top9 = (word / 8388608) % 512
    if top9 != 482 { return [0 - 1, 0 - 1] }
    let shift = (word / 4194304) % 4
    if shift != 0 { return [0 - 1, 0 - 1] }
    let rd = word % 32
    if rd != 31 { return [0 - 1, 0 - 1] }
    let rn = (word / 32) % 32
    let imm12 = (word / 1024) % 4096
    return [rn, imm12]
}

// Decode B.cond imm19 (conditional branch).
// Encoding: 0x54000000 | (imm19<<5) | (0<<4) | cond.
// Top 8 bits (bits 24..31) must equal 0x54 = 84. Bit 4 must be 0.
// Returns [cond, imm19_signed] on match, else [-1, 0].
// imm19 is returned raw (unsigned 19-bit); caller interprets sign via bit 18.
fn peep_decode_bcond(word: int) -> [int] {
    let top8 = (word / 16777216) % 256
    if top8 != 84 { return [0 - 1, 0] }
    let bit4 = (word / 16) % 2
    if bit4 != 0 { return [0 - 1, 0] }
    let cond = word % 16
    let imm19 = (word / 32) % 524288
    return [cond, imm19]
}

// Decode MUL Xd, Xn, Xm (= MADD Xd, Xn, Xm, XZR), 64-bit.
// Encoding: 0x9B000000 | (Rm<<16) | (31<<10) | (Rn<<5) | Rd
// Top 11 bits (mask 0xFFE00000) must equal 0x9B000000 >> 21 = 0x4D8 = 1240.
// Ra field (bits 10..14) must equal 31 (XZR) for pure MUL.
// Returns [rd, rn, rm] on match, else [-1,-1,-1].
fn peep_decode_mul(word: int) -> [int] {
    let top11 = (word / 2097152) % 2048
    if top11 != 1240 { return [0 - 1, 0 - 1, 0 - 1] }
    let ra = (word / 1024) % 32
    if ra != 31 { return [0 - 1, 0 - 1, 0 - 1] }
    // Bit 15 (o0) must be 0 for MADD (MSUB sets it to 1).
    let bit15 = (word / 32768) % 2
    if bit15 != 0 { return [0 - 1, 0 - 1, 0 - 1] }
    let rd = word % 32
    let rn = (word / 32) % 32
    let rm = (word / 65536) % 32
    return [rd, rn, rm]
}

// Decode ADD Xd, Xn, Xm (shifted register form, shift=0, imm6=0, 64-bit).
// Encoding: 0x8B000000 | (shift<<22) | (Rm<<16) | (imm6<<10) | (Rn<<5) | Rd
// Top 8 bits (bits 24..31) must equal 0x8B = 139. shift=0, imm6=0.
// Returns [rd, rn, rm] on match.
fn peep_decode_add_reg(word: int) -> [int] {
    let top8 = (word / 16777216) % 256
    if top8 != 139 { return [0 - 1, 0 - 1, 0 - 1] }
    // bits 21..23 must be 0 (shift=LSL ∧ op[21]=0)
    let mid = (word / 2097152) % 8
    if mid != 0 { return [0 - 1, 0 - 1, 0 - 1] }
    let imm6 = (word / 1024) % 64
    if imm6 != 0 { return [0 - 1, 0 - 1, 0 - 1] }
    let rd = word % 32
    let rn = (word / 32) % 32
    let rm = (word / 65536) % 32
    return [rd, rn, rm]
}

// Decode SUB Xd, Xn, Xm (shifted register form, shift=0, imm6=0, 64-bit).
// Encoding: 0xCB000000 | (shift<<22) | (Rm<<16) | (imm6<<10) | (Rn<<5) | Rd
// Top 8 bits = 0xCB = 203.
fn peep_decode_sub_reg(word: int) -> [int] {
    let top8 = (word / 16777216) % 256
    if top8 != 203 { return [0 - 1, 0 - 1, 0 - 1] }
    let mid = (word / 2097152) % 8
    if mid != 0 { return [0 - 1, 0 - 1, 0 - 1] }
    let imm6 = (word / 1024) % 64
    if imm6 != 0 { return [0 - 1, 0 - 1, 0 - 1] }
    let rd = word % 32
    let rn = (word / 32) % 32
    let rm = (word / 65536) % 32
    return [rd, rn, rm]
}

// Encode CBZ Xt, imm19 (compare-and-branch-if-zero, 64-bit).
// Encoding: 0xB4000000 | (imm19<<5) | Rt.  Base = 0xB4000000 = 3019898880.
// imm19 raw (already masked to 19 bits by caller for negative).
fn peep_enc_cbz(rt: int, imm19: int) -> int {
    let m = imm19 % 524288
    if m < 0 { return 3019898880 + (m + 524288) * 32 + rt }
    return 3019898880 + m * 32 + rt
}

// Encode CBNZ Xt, imm19 (compare-and-branch-if-nonzero, 64-bit).
// Encoding: 0xB5000000 | (imm19<<5) | Rt.  Base = 0xB5000000 = 3036676096.
fn peep_enc_cbnz(rt: int, imm19: int) -> int {
    let m = imm19 % 524288
    if m < 0 { return 3036676096 + (m + 524288) * 32 + rt }
    return 3036676096 + m * 32 + rt
}

// Encode MADD Xd, Xn, Xm, Xa (64-bit).
// Encoding: 0x9B000000 | (Rm<<16) | (0<<15) | (Ra<<10) | (Rn<<5) | Rd.
// Base = 0x9B000000 = 2600468480.
fn peep_enc_madd(rd: int, rn: int, rm: int, ra: int) -> int {
    return 2600468480 + rm * 65536 + ra * 1024 + rn * 32 + rd
}

// Encode MSUB Xd, Xn, Xm, Xa (64-bit).
// Encoding: 0x9B008000 | (Rm<<16) | (1<<15) | (Ra<<10) | (Rn<<5) | Rd.
// Base = 0x9B008000 = 2600501248 (= 2600468480 + 32768).
fn peep_enc_msub(rd: int, rn: int, rm: int, ra: int) -> int {
    return 2600501248 + rm * 65536 + ra * 1024 + rn * 32 + rd
}

// Encode STR Xt, [Xn, #imm12*8] unsigned-offset 64-bit (matching decode_str_uoff).
// Base 0xF9000000 = 4177526784.
fn peep_enc_str_uoff(rt: int, rn: int, imm12: int) -> int {
    return 4177526784 + imm12 * 1024 + rn * 32 + rt
}

// Run the peephole optimizer over a code buffer (array of bytes).
// Currently implements rule 1 of the 12: identity-MOV → NOP.
// Detects MOV Xd, Xd (same src/dst via ORR Xd,XZR,Xd encoding) and rewrites
// to HINT #0 (0xD503201F). Length-preserving (4-byte word swap).
fn run_peephole(code: [int]) -> PeepholeResult {
    let mut stats = peephole_stats_default()
    if len(code) % 4 != 0 { return PeepholeResult { code: code, stats: stats } }
    if len(code) == 0 { return PeepholeResult { code: code, stats: stats } }

    let mut c = code
    let nop = nop_word()

    // Rule 1 pass — identity MOV Xd, Xd → NOP
    let mut off = 0
    while off + 4 <= len(c) {
        let word = peep_read_word_le(c, off)
        let mov = peep_decode_mov(word)
        let rd = mov[0]
        let rn = mov[1]
        if rd >= 0 && rd == rn && rd != 31 {
            c = peep_write_word_le(c, off, nop)
            stats.identity_nop = stats.identity_nop + 1
        }
        off = off + 4
    }

    // Rule 2 pass — redundant reverse MOV
    //   MOV Xa, Xb ; MOV Xb, Xa   →   MOV Xa, Xb ; NOP
    // After first MOV, Xa == Xb's old value. Second MOV Xb, Xa copies that
    // same value back into Xb which already holds it (assuming no external
    // write between — adjacent-only window guarantees that).
    off = 0
    while off + 8 <= len(c) {
        let w1 = peep_read_word_le(c, off)
        let w2 = peep_read_word_le(c, off + 4)
        let m1 = peep_decode_mov(w1)
        let m2 = peep_decode_mov(w2)
        let a1 = m1[0]   // rd1 (Xa)
        let b1 = m1[1]   // rn1 (Xb source)
        let a2 = m2[0]   // rd2
        let b2 = m2[1]   // rn2
        if a1 >= 0 && a2 >= 0 && a1 != 31 && b1 != 31 && a1 == b2 && b1 == a2 {
            c = peep_write_word_le(c, off + 4, nop)
            stats.redundant_reverse_mov = stats.redundant_reverse_mov + 1
        }
        off = off + 4
    }

    // Rule 3 pass — LDP fusion.
    //   LDR Xt1, [Xn, #off] ; LDR Xt2, [Xn, #off+8]  →  LDP Xt1, Xt2, [Xn, #off] ; NOP
    // Constraint: Rt1 != Rt2, offsets 8-byte aligned, fits signed imm7 (imm12<=63).
    // Also: Rt1 != Rn (first LDR must not clobber base before second load in original;
    // LDP loads both atomically so we need the base unchanged — if Rt1==Rn the original
    // sequence would have used the clobbered base for load#2 which is already UB-adjacent,
    // but conservatively we skip.)
    off = 0
    while off + 8 <= len(c) {
        let w1 = peep_read_word_le(c, off)
        let w2 = peep_read_word_le(c, off + 4)
        let l1 = peep_decode_ldr_uoff(w1)
        let l2 = peep_decode_ldr_uoff(w2)
        let rt1 = l1[0]
        let rn1 = l1[1]
        let im1 = l1[2]
        let rt2 = l2[0]
        let rn2 = l2[1]
        let im2 = l2[2]
        if rt1 >= 0 && rt2 >= 0 && rn1 == rn2 && rt1 != rt2 && im2 == im1 + 1 && im1 <= 63 && rt1 != rn1 {
            let ldp = peep_enc_ldp_soff(rt1, rt2, rn1, im1)
            c = peep_write_word_le(c, off, ldp)
            c = peep_write_word_le(c, off + 4, nop)
            stats.ldp_fuse = stats.ldp_fuse + 1
            off = off + 8
        } else {
            off = off + 4
        }
    }

    // Rule 4 pass — STP fusion.
    //   STR Xt1, [Xn, #off] ; STR Xt2, [Xn, #off+8]  →  STP Xt1, Xt2, [Xn, #off] ; NOP
    // Store side is safer than load (no dst-base clobber concern) — still require imm fits.
    off = 0
    while off + 8 <= len(c) {
        let w1 = peep_read_word_le(c, off)
        let w2 = peep_read_word_le(c, off + 4)
        let s1 = peep_decode_str_uoff(w1)
        let s2 = peep_decode_str_uoff(w2)
        let rt1 = s1[0]
        let rn1 = s1[1]
        let im1 = s1[2]
        let rt2 = s2[0]
        let rn2 = s2[1]
        let im2 = s2[2]
        if rt1 >= 0 && rt2 >= 0 && rn1 == rn2 && im2 == im1 + 1 && im1 <= 63 {
            let stp = peep_enc_stp_soff(rt1, rt2, rn1, im1)
            c = peep_write_word_le(c, off, stp)
            c = peep_write_word_le(c, off + 4, nop)
            stats.stp_fuse = stats.stp_fuse + 1
            off = off + 8
        } else {
            off = off + 4
        }
    }

    // Rule 5 pass — MOV Xd, #0  →  MOV Xd, XZR (ORR Xd, XZR, XZR)
    // Size-identical rewrite (both 4 bytes) — switches from MOVZ to ORR-XZR form.
    // Rd==31 (XZR) would be a no-op write to the zero register; skip.
    off = 0
    while off + 4 <= len(c) {
        let w = peep_read_word_le(c, off)
        let mz = peep_decode_movz(w)
        let rd = mz[0]
        let imm = mz[1]
        if rd >= 0 && imm == 0 && rd != 31 {
            c = peep_write_word_le(c, off, peep_enc_mov_xzr(rd))
            stats.mov_zero_to_xzr = stats.mov_zero_to_xzr + 1
        }
        off = off + 4
    }

    // Rule 6 pass — ADD Xd, Xs, #0  →  MOV Xd, Xs
    // Identity add with zero immediate. Size-identical.
    off = 0
    while off + 4 <= len(c) {
        let w = peep_read_word_le(c, off)
        let a = peep_decode_add_imm(w)
        let rd = a[0]
        let rs = a[1]
        let imm = a[2]
        if rd >= 0 && imm == 0 && rd != 31 && rs != 31 {
            c = peep_write_word_le(c, off, peep_enc_mov_reg(rd, rs))
            stats.add_zero_to_mov = stats.add_zero_to_mov + 1
        }
        off = off + 4
    }

    // Rule 7 pass — SUB Xd, Xs, #0  →  MOV Xd, Xs
    off = 0
    while off + 4 <= len(c) {
        let w = peep_read_word_le(c, off)
        let s = peep_decode_sub_imm(w)
        let rd = s[0]
        let rs = s[1]
        let imm = s[2]
        if rd >= 0 && imm == 0 && rd != 31 && rs != 31 {
            c = peep_write_word_le(c, off, peep_enc_mov_reg(rd, rs))
            stats.sub_zero_to_mov = stats.sub_zero_to_mov + 1
        }
        off = off + 4
    }

    // ──────────────────────────────────────────────────────────
    //  Tier-2 passes (ROI #166)
    // ──────────────────────────────────────────────────────────

    // Rule 8 pass — CMP Xn, #0 ; B.EQ target  →  CBZ Xn, target ; NOP
    // B.EQ at offset+4 uses imm19 measured from +4. After collapsing CMP to
    // CBZ at offset 0, the branch needs +1 word adjustment so it still lands
    // at the same target address.
    off = 0
    while off + 8 <= len(c) {
        let w1 = peep_read_word_le(c, off)
        let w2 = peep_read_word_le(c, off + 4)
        let cmp_parts = peep_decode_cmp_imm(w1)
        let b_parts = peep_decode_bcond(w2)
        let cn = cmp_parts[0]
        let ci = cmp_parts[1]
        let cond = b_parts[0]
        let imm19 = b_parts[1]
        if cn >= 0 && ci == 0 && cond == 0 {
            // Adjust imm19: B.cond offset is from +4, CBZ offset from 0.
            // So new imm19 = old imm19 + 1 (word). Preserve sign by raw-mod.
            // Detect sign: bit 18 set → negative in 19-bit two's complement.
            let neg = imm19 / 262144
            let new_imm = imm19 + 1
            // If new_imm overflows 19-bit range after +1, skip the rewrite.
            let overflowed = (neg == 0 && new_imm >= 262144) || (neg == 1 && new_imm >= 524288)
            if overflowed == false {
                let cbz = peep_enc_cbz(cn, new_imm)
                c = peep_write_word_le(c, off, cbz)
                c = peep_write_word_le(c, off + 4, nop)
                stats.cmp_beq_to_cbz = stats.cmp_beq_to_cbz + 1
                off = off + 8
            } else {
                off = off + 4
            }
        } else {
            off = off + 4
        }
    }

    // Rule 9 pass — CMP Xn, #0 ; B.NE target  →  CBNZ Xn, target ; NOP
    off = 0
    while off + 8 <= len(c) {
        let w1 = peep_read_word_le(c, off)
        let w2 = peep_read_word_le(c, off + 4)
        let cmp_parts = peep_decode_cmp_imm(w1)
        let b_parts = peep_decode_bcond(w2)
        let cn = cmp_parts[0]
        let ci = cmp_parts[1]
        let cond = b_parts[0]
        let imm19 = b_parts[1]
        if cn >= 0 && ci == 0 && cond == 1 {
            let neg = imm19 / 262144
            let new_imm = imm19 + 1
            let overflowed = (neg == 0 && new_imm >= 262144) || (neg == 1 && new_imm >= 524288)
            if overflowed == false {
                let cbnz = peep_enc_cbnz(cn, new_imm)
                c = peep_write_word_le(c, off, cbnz)
                c = peep_write_word_le(c, off + 4, nop)
                stats.cmp_bne_to_cbnz = stats.cmp_bne_to_cbnz + 1
                off = off + 8
            } else {
                off = off + 4
            }
        } else {
            off = off + 4
        }
    }

    // Rule 10 pass — MUL Xt, Xa, Xb ; ADD Xd, Xc, Xt  →  MADD Xd, Xa, Xb, Xc ; NOP
    // Conditions:
    //   - ADD Rm == MUL Rd (Xt is the multiplier result feeding ADD)
    //   - ADD Rn != MUL Rd (accumulator must not also be the multiplier dst)
    //   - MUL Rd != 31 and ADD Rd != 31 (XZR writes forbidden)
    //   - shift=0/imm6=0 ADD register form (enforced by decoder)
    off = 0
    while off + 8 <= len(c) {
        let w1 = peep_read_word_le(c, off)
        let w2 = peep_read_word_le(c, off + 4)
        let mul_parts = peep_decode_mul(w1)
        let add_parts = peep_decode_add_reg(w2)
        let mrd = mul_parts[0]
        let mrn = mul_parts[1]
        let mrm = mul_parts[2]
        let ard = add_parts[0]
        let arn = add_parts[1]
        let arm = add_parts[2]
        if mrd >= 0 && ard >= 0 && arm == mrd && arn != mrd && mrd != 31 && ard != 31 {
            let madd = peep_enc_madd(ard, mrn, mrm, arn)
            c = peep_write_word_le(c, off, madd)
            c = peep_write_word_le(c, off + 4, nop)
            stats.mul_add_fuse = stats.mul_add_fuse + 1
            off = off + 8
        } else {
            off = off + 4
        }
    }

    // Rule 11 pass — MUL Xt, Xa, Xb ; SUB Xd, Xc, Xt  →  MSUB Xd, Xa, Xb, Xc ; NOP
    off = 0
    while off + 8 <= len(c) {
        let w1 = peep_read_word_le(c, off)
        let w2 = peep_read_word_le(c, off + 4)
        let mul_parts = peep_decode_mul(w1)
        let sub_parts = peep_decode_sub_reg(w2)
        let mrd = mul_parts[0]
        let mrn = mul_parts[1]
        let mrm = mul_parts[2]
        let srd = sub_parts[0]
        let srn = sub_parts[1]
        let srm = sub_parts[2]
        if mrd >= 0 && srd >= 0 && srm == mrd && srn != mrd && mrd != 31 && srd != 31 {
            let msub = peep_enc_msub(srd, mrn, mrm, srn)
            c = peep_write_word_le(c, off, msub)
            c = peep_write_word_le(c, off + 4, nop)
            stats.mul_sub_fuse = stats.mul_sub_fuse + 1
            off = off + 8
        } else {
            off = off + 4
        }
    }

    // Rule 12 pass — MOV Xd, #0 ; STR Xd, [Xn, #imm]  →  NOP ; STR XZR, [Xn, #imm]
    // Recognise both the MOVZ form (raw emit) and the post-rule-5 ORR-XZR form
    // (MOV Xd, XZR). Rule 5 runs earlier in this same pass, so in practice we'll
    // usually see the ORR-XZR form here. Guard: Xd must equal STR's Rt, Xd!=Xn,
    // and we conservatively require Xd != 31 (otherwise the MOV is already a nop).
    off = 0
    while off + 8 <= len(c) {
        let w1 = peep_read_word_le(c, off)
        let w2 = peep_read_word_le(c, off + 4)
        // Try MOV Xd, XZR form first (rule-5 output)
        let mov_parts = peep_decode_mov(w1)
        let mrd = mov_parts[0]
        let mrs = mov_parts[1]
        let is_zero_mov = (mrd >= 0 && mrs == 31 && mrd != 31)
        // Else try MOVZ Xd, #0 form (raw)
        if is_zero_mov == false {
            let mz = peep_decode_movz(w1)
            if mz[0] >= 0 && mz[1] == 0 && mz[0] != 31 {
                mrd = mz[0]
                is_zero_mov = true
            }
        }
        if is_zero_mov == true {
            let str_parts = peep_decode_str_uoff(w2)
            let srt = str_parts[0]
            let srn = str_parts[1]
            let simm = str_parts[2]
            if srt >= 0 && srt == mrd && srn != mrd {
                // Rewrite STR Xd,... → STR XZR,...
                c = peep_write_word_le(c, off, nop)
                c = peep_write_word_le(c, off + 4, peep_enc_str_uoff(31, srn, simm))
                stats.movz_str_to_strxzr = stats.movz_str_to_strxzr + 1
                off = off + 8
            } else {
                off = off + 4
            }
        } else {
            off = off + 4
        }
    }

    stats.rounds = 1
    return PeepholeResult { code: c, stats: stats }
}
