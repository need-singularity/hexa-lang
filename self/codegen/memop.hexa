// self/codegen/memop.hexa — P7-7b typed load/store lowering
//
// Emits single-instruction load/store for 8/16/32/64-bit widths on
// ARM64 (LDRB/STRB/LDRH/STRH/LDR/STR) and x86_64 (MOV r/m with
// appropriate width prefix + MOVZX for sub-word loads). Driven by
// IR lowering of the __mem_load{8,16,32,64} / __mem_store{8,16,32,64}
// builtins exposed in self/rt/alloc.hexa.
//
// Spec: self/rt/alloc.hexa L241-313 (Memory intrinsics)
//
// Contract:
//   Inputs
//     arch:     0 = ARM64, 1 = x86_64
//     addr_reg: physical register holding the base address (no imm offset;
//               callers pre-add ptr + offset on the hexa side — see
//               hexa_ptr_write_byte / hexa_ptr_read_64).
//     val_reg:  (stores only) physical register holding the value to write.
//               For loads, this slot is the destination register.
//     dst_reg:  (loads only) physical register to receive the zero-extended
//               value. ARM64 uses Wdst for 8/16/32-bit forms (upper bits
//               auto-zeroed); x86_64 uses MOVZX for <64-bit loads.
//
//   Output
//     bytes   : instruction bytes appended to `code`
//
// Clobbers: none (pure memory op; addr_reg + val_reg + dst_reg are the only
// registers touched, and they are caller-supplied).
//
// Aliasing: none — there is no argument marshalling. The caller (ir_to_arm64 /
// ir_to_x86) reads operands directly from the IR and passes them to the
// encoder.

// ═══════════════════════════════════════════════════════════════════
//  ARM64 encoders — immediate offset = 0 (base-register addressing)
// ═══════════════════════════════════════════════════════════════════
//
// All forms use the "unsigned immediate" encoding with imm12 = 0:
//   STRB Wt, [Xn]     : 0x39000000 | (Xn<<5) | Wt
//   LDRB Wt, [Xn]     : 0x39400000 | (Xn<<5) | Wt
//   STRH Wt, [Xn]     : 0x79000000 | (Xn<<5) | Wt
//   LDRH Wt, [Xn]     : 0x79400000 | (Xn<<5) | Wt
//   STR  Wt, [Xn]     : 0xB9000000 | (Xn<<5) | Wt
//   LDR  Wt, [Xn]     : 0xB9400000 | (Xn<<5) | Wt
//   STR  Xt, [Xn]     : 0xF9000000 | (Xn<<5) | Xt
//   LDR  Xt, [Xn]     : 0xF9400000 | (Xn<<5) | Xt
//
// Wt and Xt share the same 5-bit encoding slot; the size/V bits in the
// top of the opcode select the operand width and zero/sign-extension
// semantics. LDRB/LDRH zero-extend into the full 64-bit destination by
// virtue of writing the W-subregister.

fn arm64_enc_strb(rt: int, rn: int) -> int { return 956301312 + (rn * 32) + rt }      // 0x39000000
fn arm64_enc_ldrb(rt: int, rn: int) -> int { return 960495616 + (rn * 32) + rt }      // 0x39400000
fn arm64_enc_strh(rt: int, rn: int) -> int { return 2030043136 + (rn * 32) + rt }     // 0x79000000
fn arm64_enc_ldrh(rt: int, rn: int) -> int { return 2034237440 + (rn * 32) + rt }     // 0x79400000
fn arm64_enc_str32(rt: int, rn: int) -> int { return 3103784960 + (rn * 32) + rt }    // 0xB9000000
fn arm64_enc_ldr32(rt: int, rn: int) -> int { return 3107979264 + (rn * 32) + rt }    // 0xB9400000
fn arm64_enc_str64(rt: int, rn: int) -> int { return 4177526784 + (rn * 32) + rt }    // 0xF9000000
fn arm64_enc_ldr64(rt: int, rn: int) -> int { return 4181721088 + (rn * 32) + rt }    // 0xF9400000

// ═══════════════════════════════════════════════════════════════════
//  ARM64 emitters — 8 one-instruction forms
// ═══════════════════════════════════════════════════════════════════

fn emit_arm64_mem_store8(code: [int], addr_reg: int, val_reg: int) -> [int] {
    return emit32(code, arm64_enc_strb(val_reg, addr_reg))
}

fn emit_arm64_mem_load8(code: [int], addr_reg: int, dst_reg: int) -> [int] {
    return emit32(code, arm64_enc_ldrb(dst_reg, addr_reg))
}

fn emit_arm64_mem_store16(code: [int], addr_reg: int, val_reg: int) -> [int] {
    return emit32(code, arm64_enc_strh(val_reg, addr_reg))
}

fn emit_arm64_mem_load16(code: [int], addr_reg: int, dst_reg: int) -> [int] {
    return emit32(code, arm64_enc_ldrh(dst_reg, addr_reg))
}

fn emit_arm64_mem_store32(code: [int], addr_reg: int, val_reg: int) -> [int] {
    return emit32(code, arm64_enc_str32(val_reg, addr_reg))
}

fn emit_arm64_mem_load32(code: [int], addr_reg: int, dst_reg: int) -> [int] {
    return emit32(code, arm64_enc_ldr32(dst_reg, addr_reg))
}

fn emit_arm64_mem_store64(code: [int], addr_reg: int, val_reg: int) -> [int] {
    return emit32(code, arm64_enc_str64(val_reg, addr_reg))
}

fn emit_arm64_mem_load64(code: [int], addr_reg: int, dst_reg: int) -> [int] {
    return emit32(code, arm64_enc_ldr64(dst_reg, addr_reg))
}

// ═══════════════════════════════════════════════════════════════════
//  x86_64 emitters — base-only [Raddr] addressing (ModR/M mod=00, rm=reg)
// ═══════════════════════════════════════════════════════════════════
//
// Encoding layout (all forms):
//   [legacy size prefix?] [REX] [opcode bytes] [ModR/M = 00 reg rm]
//
// ModR/M byte for [Raddr] base-only is: (reg_low << 3) | addr_low.
// Caveat: addr_low == 5 (rbp/r13) would clamp ModRM to [rip+disp32] or
// require a disp8; avoided here because regalloc in the bootstrap
// budget never hands out rbp/r13 for loop-carried pointers. A future
// pass should add a 0-displacement ModR/M (mod=01, disp8=0) fallback.
//
// Widths:
//   8-bit  store (MOV m8, r8)   : 88 /r             (REX optional for spl/bpl/sil/dil)
//   8-bit  load  (MOVZX r, m8)  : 0F B6 /r          (REX.W zero-extends to 64)
//   16-bit store (MOV m16, r16) : 66 89 /r          (66 = operand-size prefix)
//   16-bit load  (MOVZX r, m16) : 0F B7 /r
//   32-bit store (MOV m32, r32) : 89 /r             (no REX.W — 32-bit op auto-zeros upper)
//   32-bit load  (MOV r32, m32) : 8B /r
//   64-bit store (MOV m64, r64) : REX.W 89 /r
//   64-bit load  (MOV r64, m64) : REX.W 8B /r

// ModR/M byte for [Raddr] with no displacement (mod=00).
fn x86_memop_modrm(reg_low: int, rm_low: int) -> int {
    return (reg_low * 8) + rm_low
}

// 8-bit store: MOV byte ptr [addr], val8. Emits REX (empty 0x40 or with
// R/B ext) to force spl/bpl/sil/dil low-byte addressing, then 88 /r.
fn emit_x86_mem_store8(code: [int], addr_reg: int, val_reg: int) -> [int] {
    let mut rex = 0x40
    if val_reg >= 8 { rex = rex + 4 }       // REX.R
    if addr_reg >= 8 { rex = rex + 1 }      // REX.B
    let modrm = x86_memop_modrm(val_reg % 8, addr_reg % 8)
    return code.push(rex).push(0x88).push(modrm)
}

// 8-bit load: MOVZX r64, byte ptr [addr]. REX.W zero-extends to full 64.
fn emit_x86_mem_load8(code: [int], addr_reg: int, dst_reg: int) -> [int] {
    let mut rex = 0x48                      // REX.W
    if dst_reg >= 8 { rex = rex + 4 }       // REX.R
    if addr_reg >= 8 { rex = rex + 1 }      // REX.B
    let modrm = x86_memop_modrm(dst_reg % 8, addr_reg % 8)
    return code.push(rex).push(0x0f).push(0xb6).push(modrm)
}

// 16-bit store: MOV word ptr [addr], val16. 0x66 operand-size prefix.
fn emit_x86_mem_store16(code: [int], addr_reg: int, val_reg: int) -> [int] {
    let mut c = code.push(0x66)
    if val_reg >= 8 || addr_reg >= 8 {
        let mut rex = 0x40
        if val_reg >= 8 { rex = rex + 4 }
        if addr_reg >= 8 { rex = rex + 1 }
        c = c.push(rex)
    }
    let modrm = x86_memop_modrm(val_reg % 8, addr_reg % 8)
    return c.push(0x89).push(modrm)
}

// 16-bit load: MOVZX r64, word ptr [addr]. REX.W zero-extends to full 64.
fn emit_x86_mem_load16(code: [int], addr_reg: int, dst_reg: int) -> [int] {
    let mut rex = 0x48                      // REX.W
    if dst_reg >= 8 { rex = rex + 4 }
    if addr_reg >= 8 { rex = rex + 1 }
    let modrm = x86_memop_modrm(dst_reg % 8, addr_reg % 8)
    return code.push(rex).push(0x0f).push(0xb7).push(modrm)
}

// 32-bit store: MOV dword ptr [addr], val32. No REX.W (32-bit op).
fn emit_x86_mem_store32(code: [int], addr_reg: int, val_reg: int) -> [int] {
    let mut c = code
    if val_reg >= 8 || addr_reg >= 8 {
        let mut rex = 0x40
        if val_reg >= 8 { rex = rex + 4 }
        if addr_reg >= 8 { rex = rex + 1 }
        c = c.push(rex)
    }
    let modrm = x86_memop_modrm(val_reg % 8, addr_reg % 8)
    return c.push(0x89).push(modrm)
}

// 32-bit load: MOV r32, dword ptr [addr]. 32-bit destination auto-zeros
// upper 32 bits of the 64-bit register — no explicit MOVZX needed.
fn emit_x86_mem_load32(code: [int], addr_reg: int, dst_reg: int) -> [int] {
    let mut c = code
    if dst_reg >= 8 || addr_reg >= 8 {
        let mut rex = 0x40
        if dst_reg >= 8 { rex = rex + 4 }
        if addr_reg >= 8 { rex = rex + 1 }
        c = c.push(rex)
    }
    let modrm = x86_memop_modrm(dst_reg % 8, addr_reg % 8)
    return c.push(0x8b).push(modrm)
}

// 64-bit store: MOV qword ptr [addr], val64. REX.W.
fn emit_x86_mem_store64(code: [int], addr_reg: int, val_reg: int) -> [int] {
    let mut rex = 0x48                      // REX.W
    if val_reg >= 8 { rex = rex + 4 }
    if addr_reg >= 8 { rex = rex + 1 }
    let modrm = x86_memop_modrm(val_reg % 8, addr_reg % 8)
    return code.push(rex).push(0x89).push(modrm)
}

// 64-bit load: MOV r64, qword ptr [addr]. REX.W.
fn emit_x86_mem_load64(code: [int], addr_reg: int, dst_reg: int) -> [int] {
    let mut rex = 0x48                      // REX.W
    if dst_reg >= 8 { rex = rex + 4 }
    if addr_reg >= 8 { rex = rex + 1 }
    let modrm = x86_memop_modrm(dst_reg % 8, addr_reg % 8)
    return code.push(rex).push(0x8b).push(modrm)
}

// ═══════════════════════════════════════════════════════════════════
//  Arch-neutral dispatch — called by IR→machine lowering
// ═══════════════════════════════════════════════════════════════════
//
// Called from ir_to_arm64.hexa and ir_to_x86.hexa when encountering an
// IRInstr whose op is one of "mem_load{8,16,32,64}" / "mem_store{8,16,32,64}".
//
//   width: 8 | 16 | 32 | 64
//   is_store: 1 = store (addr_reg + val_reg), 0 = load (addr_reg → dst_reg)

fn emit_memop_arm64(code: [int], width: int, is_store: int, addr_reg: int, val_or_dst: int) -> [int] {
    if is_store == 1 {
        if width == 8  { return emit_arm64_mem_store8(code, addr_reg, val_or_dst) }
        if width == 16 { return emit_arm64_mem_store16(code, addr_reg, val_or_dst) }
        if width == 32 { return emit_arm64_mem_store32(code, addr_reg, val_or_dst) }
        return emit_arm64_mem_store64(code, addr_reg, val_or_dst)
    }
    if width == 8  { return emit_arm64_mem_load8(code, addr_reg, val_or_dst) }
    if width == 16 { return emit_arm64_mem_load16(code, addr_reg, val_or_dst) }
    if width == 32 { return emit_arm64_mem_load32(code, addr_reg, val_or_dst) }
    return emit_arm64_mem_load64(code, addr_reg, val_or_dst)
}

fn emit_memop_x86(code: [int], width: int, is_store: int, addr_reg: int, val_or_dst: int) -> [int] {
    if is_store == 1 {
        if width == 8  { return emit_x86_mem_store8(code, addr_reg, val_or_dst) }
        if width == 16 { return emit_x86_mem_store16(code, addr_reg, val_or_dst) }
        if width == 32 { return emit_x86_mem_store32(code, addr_reg, val_or_dst) }
        return emit_x86_mem_store64(code, addr_reg, val_or_dst)
    }
    if width == 8  { return emit_x86_mem_load8(code, addr_reg, val_or_dst) }
    if width == 16 { return emit_x86_mem_load16(code, addr_reg, val_or_dst) }
    if width == 32 { return emit_x86_mem_load32(code, addr_reg, val_or_dst) }
    return emit_x86_mem_load64(code, addr_reg, val_or_dst)
}

fn emit_memop_generic(arch: int, code: [int], width: int, is_store: int, addr_reg: int, val_or_dst: int) -> [int] {
    if arch == 0 {
        return emit_memop_arm64(code, width, is_store, addr_reg, val_or_dst)
    }
    return emit_memop_x86(code, width, is_store, addr_reg, val_or_dst)
}

// ═══════════════════════════════════════════════════════════════════
//  Op-name parsing — decode "mem_load8" / "mem_store64" → (width, is_store)
// ═══════════════════════════════════════════════════════════════════
//
// Returns [width, is_store] on match, [0, -1] if the op is not a memop.
// Caller pattern in ir_to_arm64 / ir_to_x86 / mod.hexa:
//   let info = memop_decode(op)
//   if info[1] >= 0 { ...dispatch emit_memop_{arch}... }

fn memop_decode(op: string) -> [int] {
    if op == "mem_load8"   { return [8, 0] }
    if op == "mem_store8"  { return [8, 1] }
    if op == "mem_load16"  { return [16, 0] }
    if op == "mem_store16" { return [16, 1] }
    if op == "mem_load32"  { return [32, 0] }
    if op == "mem_store32" { return [32, 1] }
    if op == "mem_load64"  { return [64, 0] }
    if op == "mem_store64" { return [64, 1] }
    return [0, -1]
}

fn memop_is_store(op: string) -> bool {
    if op == "mem_store8"  { return true }
    if op == "mem_store16" { return true }
    if op == "mem_store32" { return true }
    if op == "mem_store64" { return true }
    return false
}

fn memop_is_load(op: string) -> bool {
    if op == "mem_load8"  { return true }
    if op == "mem_load16" { return true }
    if op == "mem_load32" { return true }
    if op == "mem_load64" { return true }
    return false
}

// ═══════════════════════════════════════════════════════════════════
//  Size model — byte count per arch (for pass-1 layout sizing)
// ═══════════════════════════════════════════════════════════════════
//
// ARM64: every form is a single 4-byte instruction.
// x86_64: variable — depends on REX / 0x66 / 0x0F prefix bytes. The
// bootstrap budget keeps regs in 0..7, so REX is always unneeded for
// the addr+val slots, but 0x66 (16-bit) and 0x0F (MOVZX) are counted.
//
// Sizes match the emitters above when addr_reg < 8 && val_reg < 8.

fn memop_arm64_bytes() -> int { return 4 }

fn memop_x86_bytes(width: int, is_store: int, addr_reg: int, val_or_dst: int) -> int {
    let high = (addr_reg >= 8) || (val_or_dst >= 8)
    if width == 8 {
        // REX always present (0x40 or with R/B): 1 + opcode(1) + modrm(1) = 3
        //   store: 88 /r        → REX + 88 + modrm  = 3
        //   load:  0F B6 /r     → REX.W + 0F + B6 + modrm = 4
        if is_store == 1 { return 3 }
        return 4
    }
    if width == 16 {
        //   store: 66 [REX?] 89 /r   = 3 + (high ? 1 : 0)
        //   load:  REX.W 0F B7 /r    = 4
        if is_store == 1 {
            if high { return 4 }
            return 3
        }
        return 4
    }
    if width == 32 {
        //   store: [REX?] 89 /r      = 2 + (high ? 1 : 0)
        //   load:  [REX?] 8B /r      = 2 + (high ? 1 : 0)
        if high { return 3 }
        return 2
    }
    // width == 64 — REX.W always present.
    //   store: REX.W 89 /r   = 3
    //   load:  REX.W 8B /r   = 3
    return 3
}
