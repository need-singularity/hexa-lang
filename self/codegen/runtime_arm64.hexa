// ═══════════════════════════════════════════════════════════════
// NEON SIMD string operations (HX5: AI-native algorithm replacement)
// ═══════════════════════════════════════════════════════════════
// These replace naive byte-loop string ops with 16-byte-wide NEON
// (Advanced SIMD) operations for 2-5× throughput on aligned strings.
//
// All encodings below have been validated against `as -arch arm64`
// disassembly (see commit notes). Decimals are little-endian bytes.

// ── rt_memcpy_neon ───────────────────────────────────────────
// memcpy(x0=dst, x1=src, x2=len) — NEON 16-byte bulk copy
//
// Algorithm:
//   head_loop: while len >= 16:
//     LD1 {v0.16b}, [x1], #16   // load 16 bytes, post-increment
//     ST1 {v0.16b}, [x0], #16   // store 16 bytes, post-increment
//     sub x2, x2, #16
//   tail_loop: byte-wise copy for remaining len < 16
//
// 15 instructions, 60 bytes

fn rt_memcpy_neon() {
    let mut c = []
    // stp x29, x30, [sp, #-16]!     0xA9BF7BFD
    c = c.push(253)
    c = c.push(123)
    c = c.push(191)
    c = c.push(169)
    // mov x29, sp                    0x910003FD
    c = c.push(253)
    c = c.push(3)
    c = c.push(0)
    c = c.push(145)
    // head_loop:
    // cmp x2, #16                    0xF100405F
    c = c.push(95)
    c = c.push(64)
    c = c.push(0)
    c = c.push(241)
    // b.lt tail_loop (+20 = +5 instrs)  0x540000AB
    c = c.push(171)
    c = c.push(0)
    c = c.push(0)
    c = c.push(84)
    // ld1 {v0.16b}, [x1], #16        0x4CDF7020
    c = c.push(32)
    c = c.push(112)
    c = c.push(223)
    c = c.push(76)
    // st1 {v0.16b}, [x0], #16        0x4C9F7000
    c = c.push(0)
    c = c.push(112)
    c = c.push(159)
    c = c.push(76)
    // sub x2, x2, #16                0xD1004042
    c = c.push(66)
    c = c.push(64)
    c = c.push(0)
    c = c.push(209)
    // b head_loop (-16 = -4 instrs)  0x17FFFFFB
    c = c.push(251)
    c = c.push(255)
    c = c.push(255)
    c = c.push(23)
    // tail_loop:
    // cbz x2, done (+20 = +5 instrs) 0xB40000A2
    c = c.push(162)
    c = c.push(0)
    c = c.push(0)
    c = c.push(180)
    // ldrb w3, [x1], #1              0x38401423
    c = c.push(35)
    c = c.push(20)
    c = c.push(64)
    c = c.push(56)
    // strb w3, [x0], #1              0x38001403
    c = c.push(3)
    c = c.push(20)
    c = c.push(0)
    c = c.push(56)
    // sub x2, x2, #1                 0xD1000442
    c = c.push(66)
    c = c.push(4)
    c = c.push(0)
    c = c.push(209)
    // b tail_loop (-16 = -4 instrs)  0x17FFFFFC
    c = c.push(252)
    c = c.push(255)
    c = c.push(255)
    c = c.push(23)
    // done:
    // ldp x29, x30, [sp], #16        0xA8C17BFD
    c = c.push(253)
    c = c.push(123)
    c = c.push(193)
    c = c.push(168)
    // ret                            0xD65F03C0
    c = c.push(192)
    c = c.push(3)
    c = c.push(95)
    c = c.push(214)
    return c
}

// ── rt_strlen_neon ───────────────────────────────────────────
// strlen(x0=str) — length of null-terminated string
//
// Algorithm:
//   chunk_loop: load 16 bytes, CMEQ vs 0 → 0xFF where null.
//     UMAXV byte = max of 16 lanes. If max==0 → no null → advance 16.
//     Else → branch to byte_scan (we know null is within this chunk).
//   byte_scan: byte-wise find the exact null position.
//   result: x0 = cur_ptr - original_ptr
//
// NOTE: Reads up to 15 bytes past the null terminator. This matches
// glibc strlen behaviour; safe for null-terminated strings that don't
// straddle a page boundary right at the null. For pathological inputs
// use rt_str_len (byte-wise) above.
//
// 17 instructions, 68 bytes

fn rt_strlen_neon() {
    let mut c = []
    // stp x29, x30, [sp, #-16]!     0xA9BF7BFD
    c = c.push(253)
    c = c.push(123)
    c = c.push(191)
    c = c.push(169)
    // mov x29, sp                    0x910003FD
    c = c.push(253)
    c = c.push(3)
    c = c.push(0)
    c = c.push(145)
    // mov x1, x0  (x1 = cursor)      0xAA0003E1
    c = c.push(225)
    c = c.push(3)
    c = c.push(0)
    c = c.push(170)
    // chunk_loop:
    // ld1 {v0.16b}, [x1]             0x4C407020
    c = c.push(32)
    c = c.push(112)
    c = c.push(64)
    c = c.push(76)
    // cmeq v0.16b, v0.16b, #0        0x4E209800
    c = c.push(0)
    c = c.push(152)
    c = c.push(32)
    c = c.push(78)
    // umaxv b2, v0.16b               0x6E30A802
    c = c.push(2)
    c = c.push(168)
    c = c.push(48)
    c = c.push(110)
    // umov w3, v2.b[0]               0x0E013C43
    c = c.push(67)
    c = c.push(60)
    c = c.push(1)
    c = c.push(14)
    // cbnz w3, byte_scan (+12 = +3)  0x35000063
    c = c.push(99)
    c = c.push(0)
    c = c.push(0)
    c = c.push(53)
    // add x1, x1, #16                0x91004021
    c = c.push(33)
    c = c.push(64)
    c = c.push(0)
    c = c.push(145)
    // b chunk_loop (-24 = -6 instrs) 0x17FFFFFA
    c = c.push(250)
    c = c.push(255)
    c = c.push(255)
    c = c.push(23)
    // byte_scan:
    // ldrb w4, [x1]                  0x39400024
    c = c.push(36)
    c = c.push(0)
    c = c.push(64)
    c = c.push(57)
    // cbz w4, found (+12 = +3 instrs) 0x34000064
    c = c.push(100)
    c = c.push(0)
    c = c.push(0)
    c = c.push(52)
    // add x1, x1, #1                 0x91000421
    c = c.push(33)
    c = c.push(4)
    c = c.push(0)
    c = c.push(145)
    // b byte_scan (-12 = -3 instrs)  0x17FFFFFD
    c = c.push(253)
    c = c.push(255)
    c = c.push(255)
    c = c.push(23)
    // found:
    // sub x0, x1, x0                 0xCB000020
    c = c.push(32)
    c = c.push(0)
    c = c.push(0)
    c = c.push(203)
    // ldp x29, x30, [sp], #16        0xA8C17BFD
    c = c.push(253)
    c = c.push(123)
    c = c.push(193)
    c = c.push(168)
    // ret                            0xD65F03C0
    c = c.push(192)
    c = c.push(3)
    c = c.push(95)
    c = c.push(214)
    return c
}

// ── rt_memcmp_neon ───────────────────────────────────────────
// memcmp(x0=a, x1=b, x2=len) → x0 = 0 if equal, 1 otherwise
//
// Algorithm:
//   head_loop: while len >= 16:
//     load 16 bytes each, CMEQ → 0xFF where equal, 0x00 where differ.
//     UMINV = min across all 16 lanes. If min==0 → mismatch found → return 1.
//     Else advance both, sub 16 from len.
//   tail_loop: byte-wise compare for remaining len < 16.
//
// 25 instructions, 100 bytes

fn rt_memcmp_neon() {
    let mut c = []
    // stp x29, x30, [sp, #-16]!     0xA9BF7BFD
    c = c.push(253)
    c = c.push(123)
    c = c.push(191)
    c = c.push(169)
    // mov x29, sp                    0x910003FD
    c = c.push(253)
    c = c.push(3)
    c = c.push(0)
    c = c.push(145)
    // head_loop:
    // cmp x2, #16                    0xF100405F
    c = c.push(95)
    c = c.push(64)
    c = c.push(0)
    c = c.push(241)
    // b.lt tail_loop (+36 = +9 instrs)  0x5400012B
    c = c.push(43)
    c = c.push(1)
    c = c.push(0)
    c = c.push(84)
    // ld1 {v0.16b}, [x0], #16        0x4CDF7000
    c = c.push(0)
    c = c.push(112)
    c = c.push(223)
    c = c.push(76)
    // ld1 {v1.16b}, [x1], #16        0x4CDF7021
    c = c.push(33)
    c = c.push(112)
    c = c.push(223)
    c = c.push(76)
    // cmeq v0.16b, v0.16b, v1.16b    0x6E218C00
    c = c.push(0)
    c = c.push(140)
    c = c.push(33)
    c = c.push(110)
    // uminv b2, v0.16b               0x6E31A802
    c = c.push(2)
    c = c.push(168)
    c = c.push(49)
    c = c.push(110)
    // umov w3, v2.b[0]               0x0E013C43
    c = c.push(67)
    c = c.push(60)
    c = c.push(1)
    c = c.push(14)
    // cbz w3, ne (+52 = +13 instrs)  0x340001A3
    c = c.push(163)
    c = c.push(1)
    c = c.push(0)
    c = c.push(52)
    // sub x2, x2, #16                0xD1004042
    c = c.push(66)
    c = c.push(64)
    c = c.push(0)
    c = c.push(209)
    // b head_loop (-36 = -9 instrs)  0x17FFFFF7
    c = c.push(247)
    c = c.push(255)
    c = c.push(255)
    c = c.push(23)
    // tail_loop:
    // cbz x2, eq (+28 = +7 instrs)   0xB40000E2
    c = c.push(226)
    c = c.push(0)
    c = c.push(0)
    c = c.push(180)
    // ldrb w3, [x0], #1              0x38401403
    c = c.push(3)
    c = c.push(20)
    c = c.push(64)
    c = c.push(56)
    // ldrb w4, [x1], #1              0x38401424
    c = c.push(36)
    c = c.push(20)
    c = c.push(64)
    c = c.push(56)
    // sub w5, w3, w4                 0x4B040065
    c = c.push(101)
    c = c.push(0)
    c = c.push(4)
    c = c.push(75)
    // cbnz w5, ne (+24 = +6 instrs)  0x350000C5
    c = c.push(197)
    c = c.push(0)
    c = c.push(0)
    c = c.push(53)
    // sub x2, x2, #1                 0xD1000442
    c = c.push(66)
    c = c.push(4)
    c = c.push(0)
    c = c.push(209)
    // b tail_loop (-24 = -6 instrs)  0x17FFFFFA
    c = c.push(250)
    c = c.push(255)
    c = c.push(255)
    c = c.push(23)
    // eq:
    // mov x0, xzr  (return 0)        0xAA1F03E0
    c = c.push(224)
    c = c.push(3)
    c = c.push(31)
    c = c.push(170)
    // ldp x29, x30, [sp], #16        0xA8C17BFD
    c = c.push(253)
    c = c.push(123)
    c = c.push(193)
    c = c.push(168)
    // ret                            0xD65F03C0
    c = c.push(192)
    c = c.push(3)
    c = c.push(95)
    c = c.push(214)
    // ne:
    // mov x0, #1   (return 1)        0xD2800020
    c = c.push(32)
    c = c.push(0)
    c = c.push(128)
    c = c.push(210)
    // ldp x29, x30, [sp], #16        0xA8C17BFD
    c = c.push(253)
    c = c.push(123)
    c = c.push(193)
    c = c.push(168)
    // ret                            0xD65F03C0
    c = c.push(192)
    c = c.push(3)
    c = c.push(95)
    c = c.push(214)
    return c
}

// ── NEON self-test ────────────────────────────────────────────

fn test_neon_string_ops() {
    let mcpy = rt_memcpy_neon()
    let slen = rt_strlen_neon()
    let mcmp = rt_memcmp_neon()

    println("")
    println("NEON SIMD string ops (ARM64)")
    println("  rt_memcpy_neon : " + to_string(len(mcpy)) + " bytes")
    println("  rt_strlen_neon : " + to_string(len(slen)) + " bytes")
    println("  rt_memcmp_neon : " + to_string(len(mcmp)) + " bytes")

    let mut ok = true

    // Non-empty
    if len(mcpy) == 0 { println("  FAIL: rt_memcpy_neon empty"); ok = false }
    if len(slen) == 0 { println("  FAIL: rt_strlen_neon empty"); ok = false }
    if len(mcmp) == 0 { println("  FAIL: rt_memcmp_neon empty"); ok = false }

    // < 256 bytes (per spec)
    if len(mcpy) >= 256 { println("  FAIL: rt_memcpy_neon too big"); ok = false }
    if len(slen) >= 256 { println("  FAIL: rt_strlen_neon too big"); ok = false }
    if len(mcmp) >= 256 { println("  FAIL: rt_memcmp_neon too big"); ok = false }

    // Expected exact byte counts (from validated assembly)
    if len(mcpy) != 60 { println("  FAIL: rt_memcpy_neon expected 60, got " + to_string(len(mcpy))); ok = false }
    if len(slen) != 68 { println("  FAIL: rt_strlen_neon expected 68, got " + to_string(len(slen))); ok = false }
    if len(mcmp) != 100 { println("  FAIL: rt_memcmp_neon expected 100, got " + to_string(len(mcmp))); ok = false }

    // 4-byte alignment (ARM64 fixed-width)
    if len(mcpy) % 4 != 0 { println("  FAIL: rt_memcpy_neon not aligned"); ok = false }
    if len(slen) % 4 != 0 { println("  FAIL: rt_strlen_neon not aligned"); ok = false }
    if len(mcmp) % 4 != 0 { println("  FAIL: rt_memcmp_neon not aligned"); ok = false }

    // RET trailer check (last 4 bytes = 192, 3, 95, 214 = 0xD65F03C0)
    let nc = len(mcpy)
    if mcpy[nc - 4] != 192 { println("  FAIL: rt_memcpy_neon no RET"); ok = false }
    if mcpy[nc - 1] != 214 { println("  FAIL: rt_memcpy_neon RET byte3"); ok = false }
    let nl = len(slen)
    if slen[nl - 4] != 192 { println("  FAIL: rt_strlen_neon no RET"); ok = false }
    if slen[nl - 1] != 214 { println("  FAIL: rt_strlen_neon RET byte3"); ok = false }
    let nm = len(mcmp)
    if mcmp[nm - 4] != 192 { println("  FAIL: rt_memcmp_neon no RET"); ok = false }
    if mcmp[nm - 1] != 214 { println("  FAIL: rt_memcmp_neon RET byte3"); ok = false }

    // Verify first LD1 instruction in memcpy is at offset 16 (after 4-instr prologue)
    // Expected bytes: 32, 112, 223, 76 (0x4CDF7020 little-endian)
    if mcpy[16] != 32 { println("  FAIL: rt_memcpy_neon LD1 byte0 != 32"); ok = false }
    if mcpy[17] != 112 { println("  FAIL: rt_memcpy_neon LD1 byte1 != 112"); ok = false }
    if mcpy[18] != 223 { println("  FAIL: rt_memcpy_neon LD1 byte2 != 223"); ok = false }
    if mcpy[19] != 76 { println("  FAIL: rt_memcpy_neon LD1 byte3 != 76"); ok = false }

    if ok {
        println("  ALL CHECKS PASS")
    }
}

// ── self-test ────────────────────────────────────────────────

fn test_runtime_arm64() {
    let exit_bytes = rt_exit()
    let pstr = rt_print_str()
    let pln = rt_println()
    let pint = rt_print_int()
    let alloc_bytes = rt_alloc()
    let slen = rt_str_len()

    println("runtime_arm64 — ARM64 machine code byte arrays")
    println("  rt_exit      : " + to_string(len(exit_bytes)) + " bytes")
    println("  rt_print_str : " + to_string(len(pstr)) + " bytes")
    println("  rt_println   : " + to_string(len(pln)) + " bytes")
    println("  rt_print_int : " + to_string(len(pint)) + " bytes")
    println("  rt_alloc     : " + to_string(len(alloc_bytes)) + " bytes")
    println("  rt_str_len   : " + to_string(len(slen)) + " bytes")

    // Verify sizes match expected instruction counts * 4
    let mut ok = true
    if len(exit_bytes) != 16 { println("  FAIL: rt_exit expected 16, got " + to_string(len(exit_bytes))); ok = false }
    if len(pstr) != 36 { println("  FAIL: rt_print_str expected 36, got " + to_string(len(pstr))); ok = false }
    if len(pln) != 52 { println("  FAIL: rt_println expected 52, got " + to_string(len(pln))); ok = false }
    if len(pint) != 184 { println("  FAIL: rt_print_int expected 184, got " + to_string(len(pint))); ok = false }
    if len(alloc_bytes) != 48 { println("  FAIL: rt_alloc expected 48, got " + to_string(len(alloc_bytes))); ok = false }
    if len(slen) != 44 { println("  FAIL: rt_str_len expected 44, got " + to_string(len(slen))); ok = false }

    // Verify all sizes are multiples of 4 (ARM64 fixed-width)
    if len(exit_bytes) % 4 != 0 { println("  FAIL: rt_exit not aligned"); ok = false }
    if len(pstr) % 4 != 0 { println("  FAIL: rt_print_str not aligned"); ok = false }
    if len(pln) % 4 != 0 { println("  FAIL: rt_println not aligned"); ok = false }
    if len(pint) % 4 != 0 { println("  FAIL: rt_print_int not aligned"); ok = false }
    if len(alloc_bytes) % 4 != 0 { println("  FAIL: rt_alloc not aligned"); ok = false }
    if len(slen) % 4 != 0 { println("  FAIL: rt_str_len not aligned"); ok = false }

    // Verify RET trailer: last 4 bytes = 192, 3, 95, 214 (0xD65F03C0)
    // (except rt_exit which ends with svc)
    let n = len(pstr)
    if pstr[n - 4] != 192 { println("  FAIL: rt_print_str no RET"); ok = false }
    let n2 = len(pln)
    if pln[n2 - 4] != 192 { println("  FAIL: rt_println no RET"); ok = false }
    let n3 = len(pint)
    if pint[n3 - 4] != 192 { println("  FAIL: rt_print_int no RET"); ok = false }
    let n4 = len(alloc_bytes)
    if alloc_bytes[n4 - 4] != 192 { println("  FAIL: rt_alloc no RET"); ok = false }
    let n5 = len(slen)
    if slen[n5 - 4] != 192 { println("  FAIL: rt_str_len no RET"); ok = false }

    // Verify SVC trailer on rt_exit: last 4 bytes = 1, 16, 0, 212 (0xD4001001)
    let ne = len(exit_bytes)
    if exit_bytes[ne - 4] != 1 { println("  FAIL: rt_exit no SVC"); ok = false }

    if ok {
        println("  ALL CHECKS PASS")
    }
}

test_runtime_arm64()
test_neon_string_ops()
