    // mov x2, #0  (counter)         0xD2800002
    c = c.push(2)
    c = c.push(0)
    c = c.push(128)
    c = c.push(210)
    // loop: ldrb w3, [x1, x2]       0x38626823
    c = c.push(35)
    c = c.push(104)
    c = c.push(98)
    c = c.push(56)
    // cbz w3, +3 (done)             0x34000063
    c = c.push(99)
    c = c.push(0)
    c = c.push(0)
    c = c.push(52)
    // add x2, x2, #1                0x91000442
    c = c.push(66)
    c = c.push(4)
    c = c.push(0)
    c = c.push(145)
    // b -3 (back to loop)           0x17FFFFFD
    c = c.push(253)
    c = c.push(255)
    c = c.push(255)
    c = c.push(23)
    // done: mov x0, x2 (return len) 0xAA0203E0
    c = c.push(224)
    c = c.push(3)
    c = c.push(2)
    c = c.push(170)
    // ldp x29, x30, [sp], #16       0xA8C17BFD
    c = c.push(253)
    c = c.push(123)
