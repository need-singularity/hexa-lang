// self/codegen/runtime_arm64.hexa — ARM64 machine code for runtime primitives
// Replaces runtime.c — these produce raw ARM64 instruction bytes
// that get embedded directly into native Mach-O binaries.
//
// macOS ARM64 syscalls (svc #0x80):
//   SYS_exit  = 1
//   SYS_write = 4
//   SYS_mmap  = 197
//
// Each function returns a [int] of little-endian ARM64 instruction bytes.
// Byte values are pre-computed decimals to avoid hex-literal and
// large-integer precision issues in the stage0 NaN-boxing runtime.

// ── rt_exit ──────────────────────────────────────────────────
// exit(x0)  — x0 = exit code
// 4 instructions, 16 bytes

fn rt_exit() {
    let mut c = []
    // stp x29, x30, [sp, #-16]!     0xA9BF7BFD
    c = c.push(253)
    c = c.push(123)
    c = c.push(191)
    c = c.push(169)
    // mov x29, sp                    0x910003FD
    c = c.push(253)
    c = c.push(3)
    c = c.push(0)
    c = c.push(145)
    // mov x16, #1 (SYS_exit)        0xD2800030
    c = c.push(48)
    c = c.push(0)
    c = c.push(128)
    c = c.push(210)
    // svc #0x80                      0xD4001001
    c = c.push(1)
    c = c.push(16)
    c = c.push(0)
    c = c.push(212)
    // (no epilogue — exit never returns)
    return c
}

// ── rt_print_str ─────────────────────────────────────────────
// print_str(x0=ptr, x1=len) — write(1, ptr, len) via SYS_write
// 9 instructions, 36 bytes

fn rt_print_str() {
    let mut c = []
    // stp x29, x30, [sp, #-16]!     0xA9BF7BFD
    c = c.push(253)
    c = c.push(123)
    c = c.push(191)
    c = c.push(169)
    // mov x29, sp                    0x910003FD
    c = c.push(253)
    c = c.push(3)
    c = c.push(0)
    c = c.push(145)
    // mov x2, x1  (len -> x2)       0xAA0103E2
    c = c.push(226)
    c = c.push(3)
    c = c.push(1)
    c = c.push(170)
    // mov x1, x0  (buf -> x1)       0xAA0003E1
    c = c.push(225)
    c = c.push(3)
    c = c.push(0)
    c = c.push(170)
    // mov x0, #1  (fd=stdout)       0xD2800020
    c = c.push(32)
    c = c.push(0)
    c = c.push(128)
    c = c.push(210)
    // mov x16, #4 (SYS_write)       0xD2800090
    c = c.push(144)
    c = c.push(0)
    c = c.push(128)
    c = c.push(210)
    // svc #0x80                      0xD4001001
    c = c.push(1)
    c = c.push(16)
    c = c.push(0)
    c = c.push(212)
    // ldp x29, x30, [sp], #16       0xA8C17BFD
    c = c.push(253)
    c = c.push(123)
    c = c.push(193)
    c = c.push(168)
    // ret                            0xD65F03C0
    c = c.push(192)
    c = c.push(3)
    c = c.push(95)
    c = c.push(214)
    return c
}

// ── rt_println ───────────────────────────────────────────────
// println() — write(1, "\n", 1)
// Store newline byte on stack, write 1 byte via SYS_write.
// 13 instructions, 52 bytes

fn rt_println() {
    let mut c = []
    // stp x29, x30, [sp, #-16]!     0xA9BF7BFD
    c = c.push(253)
    c = c.push(123)
    c = c.push(191)
    c = c.push(169)
    // mov x29, sp                    0x910003FD
    c = c.push(253)
    c = c.push(3)
    c = c.push(0)
    c = c.push(145)
    // sub sp, sp, #16                0xD10043FF
    c = c.push(255)
    c = c.push(67)
    c = c.push(0)
    c = c.push(209)
    // mov w3, #10 (newline)          0x52800143
    c = c.push(67)
    c = c.push(1)
    c = c.push(128)
    c = c.push(82)
    // strb w3, [sp]                  0x390003E3
    c = c.push(227)
    c = c.push(3)
    c = c.push(0)
    c = c.push(57)
    // mov x0, #1  (fd=stdout)       0xD2800020
    c = c.push(32)
    c = c.push(0)
    c = c.push(128)
    c = c.push(210)
    // mov x1, sp  (buf=sp)          0x910003E1
    c = c.push(225)
    c = c.push(3)
    c = c.push(0)
    c = c.push(145)
    // mov x2, #1  (len=1)           0xD2800022
    c = c.push(34)
    c = c.push(0)
    c = c.push(128)
    c = c.push(210)
    // mov x16, #4 (SYS_write)       0xD2800090
    c = c.push(144)
    c = c.push(0)
    c = c.push(128)
    c = c.push(210)
    // svc #0x80                      0xD4001001
    c = c.push(1)
    c = c.push(16)
    c = c.push(0)
    c = c.push(212)
    // add sp, sp, #16                0x910043FF
    c = c.push(255)
    c = c.push(67)
    c = c.push(0)
    c = c.push(145)
    // ldp x29, x30, [sp], #16       0xA8C17BFD
    c = c.push(253)
    c = c.push(123)
    c = c.push(193)
    c = c.push(168)
    // ret                            0xD65F03C0
    c = c.push(192)
    c = c.push(3)
    c = c.push(95)
    c = c.push(214)
    return c
}

// ── rt_print_int ─────────────────────────────────────────────
// print_int(x0) — convert int to decimal ASCII, write to stdout + newline
//
// Algorithm: divide by 10 repeatedly, store digits backwards in a
// 20-byte stack buffer, then write(1, buf, len).
//
// Register usage:
//   x0  = input / quotient        x3  = constant 10
//   x1  = buffer pointer          x4  = quotient (x0/10)
//   x2  = digit count             x5  = remainder / digit
//   x19 = is-negative flag (callee-saved)
//
// 46 instructions, 184 bytes

fn rt_print_int() {
    let mut c = []

    // ── prologue ──
    // stp x29, x30, [sp, #-16]!     0xA9BF7BFD
    c = c.push(253)
    c = c.push(123)
    c = c.push(191)
    c = c.push(169)
    // mov x29, sp                    0x910003FD
    c = c.push(253)
    c = c.push(3)
    c = c.push(0)
    c = c.push(145)
    // stp x19, x20, [sp, #-16]!     0xA9BF53F3
    c = c.push(243)
    c = c.push(83)
    c = c.push(191)
    c = c.push(169)
    // sub sp, sp, #32                0xD10083FF
    c = c.push(255)
    c = c.push(131)
    c = c.push(0)
    c = c.push(209)

    // ── init ──
    // mov x19, #0  (neg flag)        0xD2800013
    c = c.push(19)
    c = c.push(0)
    c = c.push(128)
    c = c.push(210)
    // mov x1, sp                     0x910003E1
    c = c.push(225)
    c = c.push(3)
    c = c.push(0)
    c = c.push(145)
    // add x1, x1, #20               0x91005021
    c = c.push(33)
    c = c.push(80)
    c = c.push(0)
    c = c.push(145)
    // mov x2, #0  (digit count)     0xD2800002
    c = c.push(2)
    c = c.push(0)
    c = c.push(128)
    c = c.push(210)

    // ── handle negative ──
    // cmp x0, #0                     0xF100001F
    c = c.push(31)
    c = c.push(0)
    c = c.push(0)
    c = c.push(241)
    // b.ge +2 (skip neg)             0x5400004A
    c = c.push(74)
    c = c.push(0)
    c = c.push(0)
    c = c.push(84)
    // neg x0, x0                     0xCB0003E0
    c = c.push(224)
    c = c.push(3)
    c = c.push(0)
    c = c.push(203)
    // mov x19, #1                    0xD2800033
    c = c.push(51)
    c = c.push(0)
    c = c.push(128)
    c = c.push(210)

    // ── handle zero ──
    // cbnz x0, +6 (to loop)         0xB50000C0
    c = c.push(192)
    c = c.push(0)
    c = c.push(0)
    c = c.push(181)
    // mov w5, #48  (ASCII '0')      0x52800605
    c = c.push(5)
    c = c.push(6)
    c = c.push(128)
    c = c.push(82)
    // sub x1, x1, #1                0xD1000421
    c = c.push(33)
    c = c.push(4)
    c = c.push(0)
    c = c.push(209)
    // strb w5, [x1]                  0x39000025
    c = c.push(37)
    c = c.push(0)
    c = c.push(0)
    c = c.push(57)
    // add x2, x2, #1                0x91000442
    c = c.push(66)
    c = c.push(4)
    c = c.push(0)
    c = c.push(145)
    // b +10 (to write section)       0x1400000A
    c = c.push(10)
    c = c.push(0)
    c = c.push(0)
    c = c.push(20)

    // ── digit extraction loop ──
    // mov x3, #10                    0xD2800143
    c = c.push(67)
    c = c.push(1)
    c = c.push(128)
    c = c.push(210)
    // udiv x4, x0, x3               0x9AC30804
    c = c.push(4)
    c = c.push(8)
    c = c.push(195)
    c = c.push(154)
    // msub x5, x4, x3, x0           0x9B038085
    c = c.push(133)
    c = c.push(128)
    c = c.push(3)
    c = c.push(155)
    // add x5, x5, #48  (ASCII)      0x9100C0A5
    c = c.push(165)
    c = c.push(192)
    c = c.push(0)
    c = c.push(145)
    // sub x1, x1, #1                0xD1000421
    c = c.push(33)
    c = c.push(4)
    c = c.push(0)
    c = c.push(209)
    // strb w5, [x1]                  0x39000025
    c = c.push(37)
    c = c.push(0)
    c = c.push(0)
    c = c.push(57)
    // add x2, x2, #1                0x91000442
    c = c.push(66)
    c = c.push(4)
    c = c.push(0)
    c = c.push(145)
    // mov x0, x4  (quotient)        0xAA0403E0
    c = c.push(224)
    c = c.push(3)
    c = c.push(4)
    c = c.push(170)
    // cbnz x0, -8 (back to loop)    0xB5FFFF00
    c = c.push(0)
    c = c.push(255)
    c = c.push(255)
    c = c.push(181)

    // ── write section: prepend '-' if negative ──
    // cbz x19, +5 (skip minus)      0xB40000B3
    c = c.push(179)
    c = c.push(0)
    c = c.push(0)
    c = c.push(180)
    // mov w5, #45  (ASCII '-')      0x528005A5
    c = c.push(165)
    c = c.push(5)
    c = c.push(128)
    c = c.push(82)
    // sub x1, x1, #1                0xD1000421
    c = c.push(33)
    c = c.push(4)
    c = c.push(0)
    c = c.push(209)
    // strb w5, [x1]                  0x39000025
    c = c.push(37)
    c = c.push(0)
    c = c.push(0)
    c = c.push(57)
    // add x2, x2, #1                0x91000442
    c = c.push(66)
    c = c.push(4)
    c = c.push(0)
    c = c.push(145)

    // ── syscall write(1, x1, x2) ──
    // mov x0, #1  (fd=stdout)       0xD2800020
    c = c.push(32)
    c = c.push(0)
    c = c.push(128)
    c = c.push(210)
    // mov x16, #4 (SYS_write)       0xD2800090
    c = c.push(144)
    c = c.push(0)
    c = c.push(128)
    c = c.push(210)
    // svc #0x80                      0xD4001001
    c = c.push(1)
    c = c.push(16)
    c = c.push(0)
    c = c.push(212)

    // ── print newline ──
    // mov w3, #10                    0x52800143
    c = c.push(67)
    c = c.push(1)
    c = c.push(128)
    c = c.push(82)
    // strb w3, [sp]                  0x390003E3
    c = c.push(227)
    c = c.push(3)
    c = c.push(0)
    c = c.push(57)
    // mov x0, #1                     0xD2800020
    c = c.push(32)
    c = c.push(0)
    c = c.push(128)
    c = c.push(210)
    // mov x1, sp                     0x910003E1
    c = c.push(225)
    c = c.push(3)
    c = c.push(0)
    c = c.push(145)
    // mov x2, #1                     0xD2800022
    c = c.push(34)
    c = c.push(0)
    c = c.push(128)
    c = c.push(210)
    // mov x16, #4                    0xD2800090
    c = c.push(144)
    c = c.push(0)
    c = c.push(128)
    c = c.push(210)
    // svc #0x80                      0xD4001001
    c = c.push(1)
    c = c.push(16)
    c = c.push(0)
    c = c.push(212)

    // ── epilogue ──
    // add sp, sp, #32                0x910083FF
    c = c.push(255)
    c = c.push(131)
    c = c.push(0)
    c = c.push(145)
    // ldp x19, x20, [sp], #16       0xA8C153F3
    c = c.push(243)
    c = c.push(83)
    c = c.push(193)
    c = c.push(168)
    // ldp x29, x30, [sp], #16       0xA8C17BFD
    c = c.push(253)
    c = c.push(123)
    c = c.push(193)
    c = c.push(168)
    // ret                            0xD65F03C0
    c = c.push(192)
    c = c.push(3)
    c = c.push(95)
    c = c.push(214)

    return c
}

// ── rt_alloc ─────────────────────────────────────────────────
// alloc(x0=size) — anonymous mmap allocation, returns pointer in x0
// mmap(NULL, size, PROT_READ|PROT_WRITE, MAP_ANON|MAP_PRIVATE, -1, 0)
//   x0 = 0 (addr=NULL)     x3 = 0x1002 (MAP_ANON|MAP_PRIVATE, macOS)
//   x1 = size               x4 = -1 (fd)
//   x2 = 3 (PROT_RW)       x5 = 0 (offset)
//   x16 = 197 (SYS_mmap)
// 12 instructions, 48 bytes

fn rt_alloc() {
    let mut c = []
    // stp x29, x30, [sp, #-16]!     0xA9BF7BFD
    c = c.push(253)
    c = c.push(123)
    c = c.push(191)
    c = c.push(169)
    // mov x29, sp                    0x910003FD
    c = c.push(253)
    c = c.push(3)
    c = c.push(0)
    c = c.push(145)
    // mov x1, x0  (size -> x1)      0xAA0003E1
    c = c.push(225)
    c = c.push(3)
    c = c.push(0)
    c = c.push(170)
    // mov x0, #0  (addr=NULL)       0xD2800000
    c = c.push(0)
    c = c.push(0)
    c = c.push(128)
    c = c.push(210)
    // mov x2, #3  (PROT_RW)         0xD2800062
    c = c.push(98)
    c = c.push(0)
    c = c.push(128)
    c = c.push(210)
    // mov x3, #0x1002 (MAP)         0xD2820043
    c = c.push(67)
    c = c.push(0)
    c = c.push(130)
    c = c.push(210)
    // movn x4, #0 (fd=-1)           0x92800004
    c = c.push(4)
    c = c.push(0)
    c = c.push(128)
    c = c.push(146)
    // mov x5, #0  (offset)          0xD2800005
    c = c.push(5)
    c = c.push(0)
    c = c.push(128)
    c = c.push(210)
    // mov x16, #197 (SYS_mmap)      0xD28018B0
    c = c.push(176)
    c = c.push(24)
    c = c.push(128)
    c = c.push(210)
    // svc #0x80                      0xD4001001
    c = c.push(1)
    c = c.push(16)
    c = c.push(0)
    c = c.push(212)
    // ldp x29, x30, [sp], #16       0xA8C17BFD
    c = c.push(253)
    c = c.push(123)
    c = c.push(193)
    c = c.push(168)
    // ret                            0xD65F03C0
    c = c.push(192)
    c = c.push(3)
    c = c.push(95)
    c = c.push(214)
    return c
}

// ── rt_str_len ───────────────────────────────────────────────
// str_len(x0=ptr) — length of null-terminated string, returned in x0
// 11 instructions, 44 bytes

fn rt_str_len() {
    let mut c = []
    // stp x29, x30, [sp, #-16]!     0xA9BF7BFD
    c = c.push(253)
    c = c.push(123)
    c = c.push(191)
