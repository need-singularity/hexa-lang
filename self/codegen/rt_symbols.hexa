// self/codegen/rt_symbols.hexa — P7-7 runtime symbol routing SSOT
//
// Single source of truth mapping built-in names emitted by codegen_c2.hexa
// to their target C symbol. Two targets:
//
//   "c"      — classic path, emits `hexa_*` linked against self/runtime.c
//   "rt"     — self-hosted path, emits `rt_*` linked against self/rt/*.hexa
//              (transpiled to C alongside the main unit)
//
// Usage from codegen_c2.hexa:
//
//     let target = rt_target()                    // "c" | "rt"
//     let sym    = rt_symbol_for(target, name)    // resolved C symbol
//
// Until `rt_target()` is wired to a CLI flag or build-time constant,
// `rt_target()` returns "c" unconditionally — zero behavior change.
//
// When flipping to "rt":
//   1. Ensure corresponding rt/*.hexa fn exists and is transpiled into
//      the link unit (build_interp.hexa must add the rt/*.hexa tree).
//   2. Signature compatibility: rt/ fns that take/return hexa types must
//      match the HexaVal ABI of the caller. Category A wrappers below
//      have explicit mapping; Category B (float-only math) needs a
//      marshalling wrapper in the rt.c output (rt_math_sqrt_v = HexaVal →
//      float unwrap → math_sqrt → HexaVal wrap).

// ═══════════════════════════════════════════════════════════════════
// Target selection
// ═══════════════════════════════════════════════════════════════════

@pure fn rt_target() -> string { return "c" }

// Single switch point for migration. When "rt" is returned, codegen
// emits rt_* symbols; else legacy hexa_* symbols.

// ═══════════════════════════════════════════════════════════════════
// Math category — runtime.c L5318-5335 (libm wrappers)
// ═══════════════════════════════════════════════════════════════════
//
// Under "rt", emits marshalling wrappers that unwrap HexaVal → float,
// call rt/math.hexa pure-hexa body, wrap back. Wrappers are defined in
// self/rt/math_abi.hexa (created when target flips to "rt").

@pure fn rt_math_symbol(name: string) -> string {
    if name == "abs"   { return "rt_math_abs_v" }
    if name == "sqrt"  { return "rt_math_sqrt_v" }
    if name == "floor" { return "rt_math_floor_v" }
    if name == "ceil"  { return "rt_math_ceil_v" }
    if name == "round" { return "rt_math_round_v" }
    if name == "pow"   { return "rt_math_pow_v" }
    if name == "min"   { return "rt_math_min_v" }
    if name == "max"   { return "rt_math_max_v" }
    if name == "sin"   { return "rt_math_sin_v" }
    if name == "cos"   { return "rt_math_cos_v" }
    if name == "tan"   { return "rt_math_tan_v" }
    if name == "asin"  { return "rt_math_asin_v" }
    if name == "acos"  { return "rt_math_acos_v" }
    if name == "atan"  { return "rt_math_atan_v" }
    if name == "atan2" { return "rt_math_atan2_v" }
    if name == "log"   { return "rt_math_log_v" }
    if name == "exp"   { return "rt_math_exp_v" }
    if name == "tanh"  { return "rt_math_tanh_v" }
    return ""
}

@pure fn legacy_math_symbol(name: string) -> string {
    if name == "abs"   { return "hexa_math_abs" }
    if name == "sqrt"  { return "hexa_math_sqrt" }
    if name == "floor" { return "hexa_math_floor" }
    if name == "ceil"  { return "hexa_math_ceil" }
    if name == "round" { return "hexa_math_round" }
    if name == "pow"   { return "hexa_math_pow" }
    if name == "min"   { return "hexa_math_min" }
    if name == "max"   { return "hexa_math_max" }
    if name == "sin"   { return "hexa_math_sin" }
    if name == "cos"   { return "hexa_math_cos" }
    if name == "tan"   { return "hexa_math_tan" }
    if name == "asin"  { return "hexa_math_asin" }
    if name == "acos"  { return "hexa_math_acos" }
    if name == "atan"  { return "hexa_math_atan" }
    if name == "atan2" { return "hexa_math_atan2" }
    if name == "log"   { return "hexa_math_log" }
    if name == "exp"   { return "hexa_math_exp" }
    if name == "tanh"  { return "hexa_math_tanh" }
    return ""
}

// ═══════════════════════════════════════════════════════════════════
// String category — runtime.c str_* (rt/string.hexa already parallel)
// ═══════════════════════════════════════════════════════════════════

@pure fn rt_string_symbol(name: string) -> string {
    if name == "str_concat"      { return "rt_str_concat_v" }
    if name == "str_contains"    { return "rt_str_contains_v" }
    if name == "str_eq"          { return "rt_str_eq_v" }
    if name == "str_substring"   { return "rt_str_substring_v" }
    if name == "str_slice"       { return "rt_str_slice_v" }
    if name == "str_trim"        { return "rt_str_trim_v" }
    if name == "str_trim_start"  { return "rt_str_trim_start_v" }
    if name == "str_trim_end"    { return "rt_str_trim_end_v" }
    if name == "str_replace"     { return "rt_str_replace_v" }
    if name == "str_pad_left"    { return "rt_str_pad_left_v" }
    if name == "str_pad_right"   { return "rt_str_pad_right_v" }
    if name == "str_repeat"      { return "rt_str_repeat_v" }
    if name == "str_index_of"    { return "rt_str_index_of_v" }
    if name == "str_reverse"     { return "rt_str_reverse_v" }
    if name == "str_split"       { return "rt_str_split_v" }
    if name == "str_join"        { return "rt_str_join_v" }
    if name == "str_to_upper"    { return "rt_str_to_upper_v" }
    if name == "str_to_lower"    { return "rt_str_to_lower_v" }
    if name == "str_char_at"     { return "rt_str_char_at_v" }
    if name == "str_char_code_at"{ return "rt_str_char_code_at_v" }
    if name == "str_parse_int"   { return "rt_str_parse_int_v" }
    if name == "str_parse_float" { return "rt_str_parse_float_v" }
    if name == "str_bytes"       { return "rt_str_bytes_v" }
    if name == "str_from_chars"  { return "rt_str_from_chars_v" }
    // Gap-closure 2026-04-19 (7 symbols, alphabetical):
    if name == "str_center"      { return "rt_str_center_v" }
    if name == "str_chars"       { return "rt_str_chars_v" }
    if name == "str_ends_with"   { return "rt_str_ends_with_v" }
    if name == "str_len"         { return "rt_str_len_v" }
    if name == "str_lines"       { return "rt_str_lines_v" }
    if name == "str_starts_with" { return "rt_str_starts_with_v" }
    if name == "str_substr"      { return "rt_str_substr_v" }
    return ""
}

@pure fn legacy_string_symbol(name: string) -> string {
    if name == "str_concat"      { return "hexa_str_concat" }
    if name == "str_contains"    { return "hexa_str_contains" }
    if name == "str_eq"          { return "hexa_str_eq" }
    if name == "str_substring"   { return "hexa_str_substring" }
    if name == "str_slice"       { return "hexa_str_slice" }
    if name == "str_trim"        { return "hexa_str_trim" }
    if name == "str_trim_start"  { return "hexa_str_trim_start" }
    if name == "str_trim_end"    { return "hexa_str_trim_end" }
    if name == "str_replace"     { return "hexa_str_replace" }
    if name == "str_pad_left"    { return "hexa_str_pad_left" }
    if name == "str_pad_right"   { return "hexa_str_pad_right" }
    if name == "str_repeat"      { return "hexa_str_repeat" }
    if name == "str_index_of"    { return "hexa_str_index_of" }
    if name == "str_reverse"     { return "hexa_str_reverse" }
    if name == "str_split"       { return "hexa_str_split" }
    if name == "str_join"        { return "hexa_str_join" }
    if name == "str_to_upper"    { return "hexa_str_to_upper" }
    if name == "str_to_lower"    { return "hexa_str_to_lower" }
    if name == "str_char_at"     { return "hexa_str_char_at" }
    if name == "str_char_code_at"{ return "hexa_str_char_code_at" }
    if name == "str_parse_int"   { return "hexa_str_parse_int" }
    if name == "str_parse_float" { return "hexa_str_parse_float" }
    if name == "str_bytes"       { return "hexa_str_bytes" }
    if name == "str_from_chars"  { return "hexa_str_from_chars" }
    // Gap-closure 2026-04-19 (7 symbols, alphabetical):
    if name == "str_center"      { return "hexa_str_center" }
    if name == "str_chars"       { return "hexa_str_chars" }
    if name == "str_ends_with"   { return "hexa_str_ends_with" }
    if name == "str_len"         { return "hexa_str_len" }
    if name == "str_lines"       { return "hexa_str_lines" }
    if name == "str_starts_with" { return "hexa_str_starts_with" }
    if name == "str_substr"      { return "hexa_str_substr" }
    return ""
}

// ═══════════════════════════════════════════════════════════════════
// IO category — rt/io.hexa keeps hexa_* names (to be renamed later)
// ═══════════════════════════════════════════════════════════════════
//
// Under "rt", io.hexa's hexa_print_val / hexa_read_file etc. are linked
// as the canonical definition. Legacy runtime.c versions will be dropped
// from the link. Same symbol name — no rename required in codegen_c2.

@pure fn rt_io_same_name(name: string) -> bool {
    if name == "print_val"       { return true }
    if name == "println"         { return true }
    if name == "eprint_val"      { return true }
    if name == "read_file"       { return true }
    if name == "read_file_bytes" { return true }
    if name == "write_file"      { return true }
    if name == "append_file"     { return true }
    if name == "read_lines"      { return true }
    if name == "delete_file"     { return true }
    if name == "file_size"       { return true }
    if name == "file_exists"     { return true }
    if name == "input"           { return true }
    return false
}

// ═══════════════════════════════════════════════════════════════════
// Top-level resolver
// ═══════════════════════════════════════════════════════════════════
//
// Given a category-tagged name (e.g. "math:sqrt", "string:str_concat"),
// return the C symbol for the current target. Category-free lookup is
// NOT provided — callers must know which category the name belongs to
// to avoid ambiguity (sqrt vs a user-defined sqrt).

@pure fn rt_symbol_for(category: string, name: string) -> string {
    let target = rt_target()
    if category == "math" {
        if target == "rt" { return rt_math_symbol(name) }
        return legacy_math_symbol(name)
    }
    if category == "string" {
        if target == "rt" { return rt_string_symbol(name) }
        return legacy_string_symbol(name)
    }
    if category == "io" {
        // same name for both targets
        return "hexa_" + name
    }
    return ""
}

// ═══════════════════════════════════════════════════════════════════
// Migration status — 2026-04-19 (session snapshot)
// ═══════════════════════════════════════════════════════════════════
//
//   math   : rt/math.hexa 100% surface. Needs rt/math_abi.hexa marshalling
//            wrappers (HexaVal ↔ float) before rt_target() can flip to "rt".
//   string : rt/string.hexa 100% surface. Same marshalling requirement
//            (HexaVal ↔ string). Strings are already C char* — wrapper is
//            thinner; mostly identity.
//   io     : rt/io.hexa 100% surface, same names — flip is one-line once
//            build pipeline links rt.c instead of runtime.c.
//   core   : rt/core.hexa polymorphic ops (add/sub/mul/div/mod/eq/cmp…);
//            deeply intertwined with HexaVal tag ABI — defer to last.
//   alloc  : rt/alloc.hexa needs __mem_* intrinsic lowering (P7-7a-2).
//   proc   : rt/proc.hexa Darwin pipe/dup2 blocked on 2-return syscall ABI.
//   fs     : ready.
//   intern : ready (map-backed scaffold).
//   except : Option A (Result-return) scaffold, needs codegen rewrite.
//   fmt    : ready (int/float/hex/bin/base64).
//   array_ops / map_ops : wrappers over runtime/array_pure.hexa — ready.
//   convert / json : TBD (this session).
