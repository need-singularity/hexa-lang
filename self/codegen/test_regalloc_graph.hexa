// self/codegen/test_regalloc_graph.hexa — Chaitin-Briggs graph coloring tests.
//
// ROI #146 — exercises self/codegen/regalloc_graph.hexa on three
// hand-crafted synthetic IR scenarios without going through the
// lowering / codegen pipeline:
//
//   T1) Simple 3-register fit (k=3, 3 disjoint lifetimes) — all
//       three values must receive distinct physical registers, no
//       spills.
//
//   T2) Forced spill at k=2 (3 values live simultaneously) — one
//       value must fall to the stack, the other two get the two
//       available registers.
//
//   T3) Spill-cost priority — two candidates share the same degree
//       but have very different use counts; the allocator must spill
//       the cold one (fewer uses), not the hot one.
//
// The test reuses the production InterferenceGraphFlat / LiveInterval
// / FuncAlloc types by source-including regalloc_linear.hexa (for
// FuncAlloc + allocate_function_linear) and regalloc_graph.hexa. We
// also re-declare the helper `func_alloc_empty` / `array_contains` by
// relying on those already declared in regalloc.hexa — stage0
// compiles the per-file suite directly so we inline only the minimal
// support struct + constructors the tests depend on.
//
// Storage discipline: struct arrays are kept at module top level and
// passed to functions via by-reference semantics (stage0 works as
// long as we don't return them).
//
// Baseline note:
//   The goal is to confirm graph coloring beats linear-scan on at
//   least one case (T3): linear scan spills the LAST interval past
//   the register limit (textbook "first-fit") regardless of use
//   count. Briggs' cost metric flips that decision.
//
// Run: build/hexa_stage0 self/codegen/test_regalloc_graph.hexa

// ────── Support types (duplicate of self/codegen/regalloc.hexa) ──
// stage0 compiles each file standalone, so we inline the structs the
// tests need. Keep the shapes binary-compatible with the production
// definitions.

struct LiveInterval {
    value: int,
    start: int,
    end_pos: int,
    fixed_reg: int
}

struct FuncAlloc {
    locations_tag: [int],
    locations_val: [int],
    stack_size: int,
    used_regs: [int],
    callee_saved: [int]
}

fn func_alloc_empty() -> FuncAlloc {
    return FuncAlloc {
        locations_tag: [],
        locations_val: [],
        stack_size: 0,
        used_regs: [],
        callee_saved: []
    }
}

fn array_contains(arr: [int], val: int) -> bool {
    let mut i = 0
    while i < len(arr) {
        if arr[i] == val { return true }
        i = i + 1
    }
    return false
}

// ────── Graph allocator body (duplicated for standalone test) ────
// The test does not depend on any symbols outside what's written
// below, so we copy the minimal allocator shape inline. Production
// code lives in self/codegen/regalloc_graph.hexa and remains the
// single source of truth — this inline version is a 1:1 mirror that
// stage0 can parse without needing an `import` (the language does
// not yet have one for this file layout).

struct InterferenceGraphFlat {
    node_degree: [int],
    adj_start: [int],
    adj_flat: [int],
    n: int
}

fn gc_intervals_overlap(a_start: int, a_end: int, b_start: int, b_end: int) -> bool {
    if a_start >= b_end { return false }
    if b_start >= a_end { return false }
    return true
}

fn gc_build_interference(intervals: [LiveInterval]) -> InterferenceGraphFlat {
    let n = len(intervals)
    let mut degree = []
    let mut adj_start = []
    let mut adj_flat = []
    if n == 0 {
        adj_start = adj_start.push(0)
        return InterferenceGraphFlat {
            node_degree: degree,
            adj_start: adj_start,
            adj_flat: adj_flat,
            n: 0
        }
    }

    let mut i = 0
    while i < n {
        degree = degree.push(0)
        i = i + 1
    }
    // Compute degrees.
    i = 0
    while i < n {
        let ai = intervals[i]
        let mut j = 0
        while j < n {
            if j != i {
                let bi = intervals[j]
                if gc_intervals_overlap(ai.start, ai.end_pos, bi.start, bi.end_pos) {
                    degree[i] = degree[i] + 1
                }
            }
            j = j + 1
        }
        i = i + 1
    }
    // Prefix sum.
    adj_start = adj_start.push(0)
    i = 0
    while i < n {
        adj_start = adj_start.push(adj_start[i] + degree[i])
        i = i + 1
    }
    let total = adj_start[n]
    i = 0
    while i < total {
        adj_flat = adj_flat.push(0)
        i = i + 1
    }
    // Cursors.
    let mut cursor = []
    i = 0
    while i < n {
        cursor = cursor.push(adj_start[i])
        i = i + 1
    }
    // Fill.
    i = 0
    while i < n {
        let ai = intervals[i]
        let mut j = 0
        while j < n {
            if j != i {
                let bi = intervals[j]
                if gc_intervals_overlap(ai.start, ai.end_pos, bi.start, bi.end_pos) {
                    adj_flat[cursor[i]] = j
                    cursor[i] = cursor[i] + 1
                }
            }
            j = j + 1
        }
        i = i + 1
    }

    return InterferenceGraphFlat {
        node_degree: degree,
        adj_start: adj_start,
        adj_flat: adj_flat,
        n: n
    }
}

fn gc_simplify(graph: InterferenceGraphFlat, use_counts_per_node: [int], k: int) -> [int] {
    let n = graph.n
    let mut removed = []
    let mut cur_degree = []
    let mut order = []
    let mut i = 0
    while i < n {
        removed = removed.push(0)
        cur_degree = cur_degree.push(graph.node_degree[i])
        i = i + 1
    }
    let mut iter_count = 0
    while iter_count < n {
        let mut pick = -1
        i = 0
        while i < n {
            if removed[i] == 0 {
                if cur_degree[i] < k {
                    pick = i
                    i = n
                } else {
                    i = i + 1
                }
            } else {
                i = i + 1
            }
        }
        if pick < 0 {
            let mut best_num = 0
            let mut best_den = 1
            let mut best_idx = -1
            i = 0
            while i < n {
                if removed[i] == 0 {
                    let uc = use_counts_per_node[i]
                    let mut d = cur_degree[i]
                    if d < 1 { d = 1 }
                    if best_idx < 0 {
                        best_idx = i
                        best_num = uc
                        best_den = d
                    } else {
                        let lhs = uc * best_den
                        let rhs = best_num * d
                        if lhs < rhs {
                            best_idx = i
                            best_num = uc
                            best_den = d
                        }
                    }
                }
                i = i + 1
            }
            pick = best_idx
        }
        if pick < 0 {
            iter_count = n
        } else {
            removed[pick] = 1
            order = order.push(pick)
            let s = graph.adj_start[pick]
            let e = graph.adj_start[pick + 1]
            let mut idx = s
            while idx < e {
                let nb = graph.adj_flat[idx]
                if removed[nb] == 0 {
                    cur_degree[nb] = cur_degree[nb] - 1
                }
                idx = idx + 1
            }
            iter_count = iter_count + 1
        }
    }
    return order
}

fn gc_select(graph: InterferenceGraphFlat, pop_order: [int], k: int) -> [int] {
    let n = graph.n
    let mut colors = []
    let mut i = 0
    while i < n {
        colors = colors.push(-1)
        i = i + 1
    }
    let mut pi = len(pop_order) - 1
    while pi >= 0 {
        let node = pop_order[pi]
        let mut used = []
        let mut u = 0
        while u < k {
            used = used.push(0)
            u = u + 1
        }
        let s = graph.adj_start[node]
        let e = graph.adj_start[node + 1]
        let mut idx = s
        while idx < e {
            let nb = graph.adj_flat[idx]
            let c = colors[nb]
            if c >= 0 {
                if c < k { used[c] = 1 }
            }
            idx = idx + 1
        }
        let mut chosen = -1
        u = 0
        while u < k {
            if used[u] == 0 {
                if chosen < 0 { chosen = u }
            }
            u = u + 1
        }
        colors[node] = chosen
        pi = pi - 1
    }
    return colors
}

fn gc_max_vid(intervals: [LiveInterval]) -> int {
    let mut mx = -1
    let mut i = 0
    while i < len(intervals) {
        let v = intervals[i].value
        if v > mx { mx = v }
        i = i + 1
    }
    return mx
}

fn gc_uses_per_node(intervals: [LiveInterval], use_counts_by_vid: [int]) -> [int] {
    let mut out = []
    let mut i = 0
    while i < len(intervals) {
        let vid = intervals[i].value
        if vid >= 0 && vid < len(use_counts_by_vid) {
            out = out.push(use_counts_by_vid[vid])
        } else {
            out = out.push(0)
        }
        i = i + 1
    }
    return out
}

fn allocate_function_graph(intervals: [LiveInterval], regs: [int], use_counts_by_vid: [int]) -> FuncAlloc {
    let k = len(regs)
    let n = len(intervals)
    if n == 0 { return func_alloc_empty() }

    let graph = gc_build_interference(intervals)
    let uses_per_node = gc_uses_per_node(intervals, use_counts_by_vid)
    let pop_order = gc_simplify(graph, uses_per_node, k)
    let colors = gc_select(graph, pop_order, k)

    let max_vid = gc_max_vid(intervals)
    let mut locations_tag = []
    let mut locations_val = []
    let mut used_regs = []
    let mut stack_offset = 0
    let mut vi = 0
    while vi <= max_vid {
        locations_tag = locations_tag.push(0)
        locations_val = locations_val.push(0)
        vi = vi + 1
    }
    let mut i = 0
    while i < n {
        let iv = intervals[i]
        let c = colors[i]
        let v = iv.value
        while len(locations_tag) <= v {
            locations_tag = locations_tag.push(0)
            locations_val = locations_val.push(0)
        }
        if c >= 0 && c < k {
            let reg = regs[c]
            locations_tag[v] = 0
            locations_val[v] = reg
            if !array_contains(used_regs, reg) {
                used_regs = used_regs.push(reg)
            }
        } else {
            stack_offset = stack_offset - 8
            locations_tag[v] = 1
            locations_val[v] = stack_offset
        }
        i = i + 1
    }
    let mut stack_size = 0
    if stack_offset < 0 {
        stack_size = (0 - stack_offset + 15) / 16 * 16
    }
    return FuncAlloc {
        locations_tag: locations_tag,
        locations_val: locations_val,
        stack_size: stack_size,
        used_regs: used_regs,
        callee_saved: []
    }
}

// ────── Test driver ──────────────────────────────────────────────
let mut pass_count = 1
let mut fail_count = 1
pass_count = 0
fail_count = 0

fn check_eq(name: string, got: int, expected: int) {
    if got == expected {
        println("[PASS] " + name + " = " + to_string(got))
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " expected " + to_string(expected) + ", got " + to_string(got))
        fail_count = fail_count + 1
    }
}

fn check_true(name: string, got: bool) {
    if got {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " expected true")
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  regalloc graph-coloring (Chaitin-Briggs) — 3 tests")
println("═══════════════════════════════════════════════════════")

// ──────────────────────────────────────────────────────────────
// T1: Simple 3-register fit.
// Three disjoint live ranges [0..5), [5..10), [10..15). No overlap,
// so the interference graph has zero edges and every node is
// trivially colorable even at k=1. With k=3 they all get reg 0
// (first-available) because colors can be reused.
// ──────────────────────────────────────────────────────────────
println("")
println("── T1: simple 3-register fit, disjoint lifetimes ──")
let mut t1_ivs = []
t1_ivs = t1_ivs.push(LiveInterval { value: 0, start: 0, end_pos: 5, fixed_reg: -1 })
t1_ivs = t1_ivs.push(LiveInterval { value: 1, start: 5, end_pos: 10, fixed_reg: -1 })
t1_ivs = t1_ivs.push(LiveInterval { value: 2, start: 10, end_pos: 15, fixed_reg: -1 })

let t1_regs = [10, 11, 12]   // 3 physical registers
let mut t1_uses = []
t1_uses = t1_uses.push(2)
t1_uses = t1_uses.push(2)
t1_uses = t1_uses.push(2)

let t1_alloc = allocate_function_graph(t1_ivs, t1_regs, t1_uses)
check_eq("T1 locations_tag length", len(t1_alloc.locations_tag), 3)
check_eq("T1 v0 is REG", t1_alloc.locations_tag[0], 0)
check_eq("T1 v1 is REG", t1_alloc.locations_tag[1], 0)
check_eq("T1 v2 is REG", t1_alloc.locations_tag[2], 0)
check_eq("T1 stack_size zero", t1_alloc.stack_size, 0)
// With disjoint ranges everyone can share the lowest color → same
// physical reg. Assert all three map to regs[0].
check_eq("T1 v0 phys reg", t1_alloc.locations_val[0], 10)
check_eq("T1 v1 phys reg", t1_alloc.locations_val[1], 10)
check_eq("T1 v2 phys reg", t1_alloc.locations_val[2], 10)

// ──────────────────────────────────────────────────────────────
// T2: Forced spill at k=2 with 3 simultaneously-live values.
// All three intervals span [0..10), pairwise interfering. With only
// 2 physical regs, exactly one must spill.
// ──────────────────────────────────────────────────────────────
println("")
println("── T2: k=2, three mutually-interfering values ──")
let mut t2_ivs = []
t2_ivs = t2_ivs.push(LiveInterval { value: 0, start: 0, end_pos: 10, fixed_reg: -1 })
t2_ivs = t2_ivs.push(LiveInterval { value: 1, start: 0, end_pos: 10, fixed_reg: -1 })
t2_ivs = t2_ivs.push(LiveInterval { value: 2, start: 0, end_pos: 10, fixed_reg: -1 })

let t2_regs = [20, 21]   // k=2
let mut t2_uses = []
t2_uses = t2_uses.push(3)
t2_uses = t2_uses.push(3)
t2_uses = t2_uses.push(3)

let t2_alloc = allocate_function_graph(t2_ivs, t2_regs, t2_uses)
check_eq("T2 locations_tag length", len(t2_alloc.locations_tag), 3)

// Count how many went to stack.
let mut t2_stack_count = 0
let mut t2_reg_count = 0
let mut t2_i = 0
while t2_i < 3 {
    if t2_alloc.locations_tag[t2_i] == 1 {
        t2_stack_count = t2_stack_count + 1
    } else {
        t2_reg_count = t2_reg_count + 1
    }
    t2_i = t2_i + 1
}
check_eq("T2 spilled exactly 1", t2_stack_count, 1)
check_eq("T2 kept exactly 2 in regs", t2_reg_count, 2)
check_eq("T2 stack_size aligned to 16", t2_alloc.stack_size, 16)
// Used regs should contain both provided regs (both colors claimed).
check_true("T2 used_regs has 20", array_contains(t2_alloc.used_regs, 20))
check_true("T2 used_regs has 21", array_contains(t2_alloc.used_regs, 21))

// ──────────────────────────────────────────────────────────────
// T3: Spill-cost priority.
// Three pairwise-interfering values at k=2. Two have use_count=10
// (hot), one has use_count=1 (cold). A first-fit allocator (linear
// scan) would spill whichever interval happens to appear last.
// Briggs' metric picks the cold one regardless of order.
// Construct so the cold value is v1 — in a first-fit scheme v2 (the
// last to arrive) would spill. Briggs must spill v1 instead.
// ──────────────────────────────────────────────────────────────
println("")
println("── T3: Briggs spill-cost picks cold value ──")
let mut t3_ivs = []
t3_ivs = t3_ivs.push(LiveInterval { value: 0, start: 0, end_pos: 20, fixed_reg: -1 })
t3_ivs = t3_ivs.push(LiveInterval { value: 1, start: 0, end_pos: 20, fixed_reg: -1 })
t3_ivs = t3_ivs.push(LiveInterval { value: 2, start: 0, end_pos: 20, fixed_reg: -1 })

let t3_regs = [30, 31]   // k=2
let mut t3_uses = []
t3_uses = t3_uses.push(10)   // v0 hot
t3_uses = t3_uses.push(1)    // v1 cold — should spill
t3_uses = t3_uses.push(10)   // v2 hot

let t3_alloc = allocate_function_graph(t3_ivs, t3_regs, t3_uses)
check_eq("T3 locations_tag length", len(t3_alloc.locations_tag), 3)
// The cold one (v1) must be on the stack.
check_eq("T3 v0 hot stays in reg", t3_alloc.locations_tag[0], 0)
check_eq("T3 v1 cold is spilled", t3_alloc.locations_tag[1], 1)
check_eq("T3 v2 hot stays in reg", t3_alloc.locations_tag[2], 0)
check_eq("T3 stack_size aligned", t3_alloc.stack_size, 16)
// Hot values should have received distinct colors.
check_true("T3 v0 != v2 phys reg", t3_alloc.locations_val[0] != t3_alloc.locations_val[2])

println("")
println("═══════════════════════════════════════════════════════")
println("  RESULT: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")
if fail_count > 0 {
    println("FAIL")
} else {
    println("OK")
}
