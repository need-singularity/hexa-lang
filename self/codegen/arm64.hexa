// self/codegen/arm64.hexa — ported from src/codegen/arm64.rs
// ARM64 (AArch64) Machine Code Emitter — primary target.
// Generates raw ARM64 instructions (4 bytes each, fixed width).

fn arm64_fp() -> int { return 29 }
fn arm64_lr() -> int { return 30 }
fn arm64_sp() -> int { return 31 }
fn arm64_tmp1() -> int { return 16 }
fn arm64_tmp2() -> int { return 17 }

// Emit a 32-bit instruction as 4 little-endian bytes into code buffer.
fn emit32(code: [int], instr: int) -> [int] {
    let b0 = instr % 256
    let b1 = (instr / 256) % 256
    let b2 = (instr / 65536) % 256
    let b3 = (instr / 16777216) % 256
    return code.push(b0).push(b1).push(b2).push(b3)
}

// Encode ADD/SUB Xd, Xn, Xm (3-register form)
fn encode_rrr(base: int, rd: int, rn: int, rm: int) -> int {
    return base + (rm * 65536) + (rn * 32) + rd
}

// Encode MUL Xd, Xn, Xm
fn encode_mul(rd: int, rn: int, rm: int) -> int {
    return 0x9b007c00 + (rm * 65536) + (rn * 32) + rd
}

// Encode SDIV Xd, Xn, Xm
fn encode_div(rd: int, rn: int, rm: int) -> int {
    return 0x9ac00c00 + (rm * 65536) + (rn * 32) + rd
}

// Encode MSUB Xd, Xn, Xm, Xa
fn encode_msub(rd: int, rn: int, rm: int, ra: int) -> int {
    return 0x9b008000 + (rm * 65536) + (ra * 1024) + (rn * 32) + rd
}

// Encode MOV Xd, Xn (ORR Xd, XZR, Xn)
fn encode_mov(rd: int, rn: int) -> int {
    return 0xaa0003e0 + (rn * 65536) + rd
}

// Emit MOVZ Xreg, #imm16 (+ optional MOVK for wider values).
// Negative `val` uses the MOVN/MOVK sequence: since val = NOT(nv) over 64 bit
// where nv = -val - 1, each halfword of val's bit pattern equals
// 0xFFFF - halfword(nv). MOVN fills upper halves with 1s (== 0xFFFF) so we
// only need MOVK when a halfword of val differs from 0xFFFF — i.e., when
// the corresponding halfword of nv is non-zero.
fn emit_mov_imm(code: [int], reg: int, val: int) -> [int] {
    let mut c = code
    if val < 0 {
        let nv = (0 - val) - 1
        let hw0 = nv % 65536
        let hw1 = (nv / 65536) % 65536
        let hw2 = (nv / 0x100000000) % 65536
        let hw3 = (nv / 0x1000000000000) % 65536
        // MOVN rd, #hw0, LSL #0   →  0x92800000 | (hw0 << 5) | rd
        c = emit32(c, 0x92800000 + (hw0 * 32) + reg)
        // MOVK with val's halfword = 0xFFFF - nv's halfword (only if differs
        // from the sign-fill 0xFFFF, which happens iff nv's halfword != 0).
        if hw1 != 0 {
            let vhw1 = 0xFFFF - hw1
            c = emit32(c, 0xf2a00000 + (vhw1 * 32) + reg)
        }
        if hw2 != 0 {
            let vhw2 = 0xFFFF - hw2
            c = emit32(c, 0xf2c00000 + (vhw2 * 32) + reg)
        }
        if hw3 != 0 {
            let vhw3 = 0xFFFF - hw3
            c = emit32(c, 0xf2e00000 + (vhw3 * 32) + reg)
        }
        return c
    }
    let v = val
    // movz Xreg, #imm16 (low 16 bits)
    c = emit32(c, 0xd2800000 + ((v % 65536) * 32) + reg)
    if v > 65535 {
        c = emit32(c, 0xf2a00000 + (((v / 65536) % 65536) * 32) + reg)
    }
    if v > 0xFFFFFFFF {
        c = emit32(c, 0xf2c00000 + (((v / 0x100000000) % 65536) * 32) + reg)
    }
    return c
}

// Emit prologue: save FP/LR, set up frame pointer, allocate stack.
// ARM64 SUB immediate encodes imm12 (bits 10-21) with optional LSL#12
// (bit 22 sh flag). Supports stacks up to 16,773,120 bytes via two SUBs:
// the `imm_hi` part shifted, then `imm_lo`. Prior form used `% 4096` which
// silently truncated stacks > 4095 bytes — big spilled functions corrupted
// their frame with quieter errors than a stack overflow.
fn emit_prologue(code: [int], stack_size: int) -> [int] {
    let mut c = code
    // stp x29, x30, [sp, #-16]!
    c = emit32(c, 0xa9bf7bfd)
    // mov x29, sp
    c = emit32(c, 0x910003fd)
    if stack_size > 0 {
        let imm_hi = stack_size / 4096
        let imm_lo = stack_size % 4096
        if imm_hi > 0 {
            // SUB sp, sp, #imm_hi, LSL#12  (sh=1)  → 0xd14003ff + imm_hi*1024
            c = emit32(c, 0xd14003ff + (imm_hi * 1024))
        }
        if imm_lo > 0 {
            // SUB sp, sp, #imm_lo  (sh=0)  → 0xd10003ff + imm_lo*1024
            c = emit32(c, 0xd10003ff + (imm_lo * 1024))
        }
    }
    return c
}

// Emit epilogue: deallocate stack, restore FP/LR, ret.
// Symmetric 2-part ADD for stacks > 4095, matching emit_prologue's SUB pair.
fn emit_epilogue(code: [int], stack_size: int) -> [int] {
    let mut c = code
    if stack_size > 0 {
        let imm_hi = stack_size / 4096
        let imm_lo = stack_size % 4096
        if imm_lo > 0 {
            // ADD sp, sp, #imm_lo  (sh=0)  → 0x910003ff + imm_lo*1024
            c = emit32(c, 0x910003ff + (imm_lo * 1024))
        }
        if imm_hi > 0 {
            // ADD sp, sp, #imm_hi, LSL#12  (sh=1)  → 0x914003ff + imm_hi*1024
            c = emit32(c, 0x914003ff + (imm_hi * 1024))
        }
    }
    // ldp x29, x30, [sp], #16
    c = emit32(c, 0xa8c17bfd)
    // ret
    c = emit32(c, 0xd65f03c0)
    return c
}

// Patch a branch instruction at given byte offset with relative target.
fn patch_branch(code: [int], offset: int, rel: int) -> [int] {
    let mut c = code
    if offset + 4 <= len(c) {
        let existing = c[offset] + c[offset + 1] * 256 + c[offset + 2] * 65536 + c[offset + 3] * 16777216
        let op_bits = existing / 16777216 * 16777216
        if op_bits == 0xB5000000 {
            // cbnz: imm19 in bits [23:5]. Normalize negative rel to unsigned
            // 19-bit (patch_call_fixups_arm64 parity, 54737977 class).
            let mut urel = rel % 524288
            if urel < 0 { urel = urel + 524288 }
            let imm19 = urel * 32
            let patched = (existing / 16777216 * 16777216) + (existing % 32) + imm19
            c[offset] = patched % 256
            c[offset + 1] = (patched / 256) % 256
            c[offset + 2] = (patched / 65536) % 256
            c[offset + 3] = (patched / 16777216) % 256
        } else {
            // b/bl: imm26 in bits [25:0]
            let masked = existing / 67108864 * 67108864
            let mut imm26 = rel % 67108864
            if imm26 < 0 { imm26 = imm26 + 67108864 }
            let patched = masked + imm26
            c[offset] = patched % 256
            c[offset + 1] = (patched / 256) % 256
            c[offset + 2] = (patched / 65536) % 256
            c[offset + 3] = (patched / 16777216) % 256
        }
    }
    return c
}

// Check if n is a positive power of 2. Returns shift amount or -1.
fn is_power_of_2(n: int) -> int {
    if n <= 0 { return -1 }
    if n == 1 { return 0 }
    let mut v = n
    let mut shift = 0
    while v > 1 {
        if v % 2 != 0 { return -1 }
        v = v / 2
        shift = shift + 1
    }
    return shift
}

// ═══════════════════════════════════════════════════════════════
//  ARM64 SYSCALL EMISSION — Darwin + Linux
// ═══════════════════════════════════════════════════════════════
// Syscall number goes in x16 (Darwin) or x8 (Linux).
// Args go in x0, x1, x2, ... per AAPCS.
// Trap instruction: svc #0x80 (Darwin) / svc #0 (Linux).
//
// Darwin numbers are defined with a class prefix (0x2000000 = Unix class):
//   SYS_exit  = 0x2000001
//   SYS_write = 0x2000004
// Linux numbers follow the AArch64 unistd table:
//   __NR_write = 64
//   __NR_exit  = 93
//
// `os` parameter convention: 0 = Darwin (macOS), 1 = Linux.

fn os_darwin() -> int { return 0 }
fn os_linux() -> int { return 1 }

// Encode SVC #imm16 — main branch immediate in bits [20:5], opcode 0xd4000001.
// For Darwin svc #0x80 this yields 0xd4001001; for Linux svc #0 -> 0xd4000001.
fn encode_svc(imm16: int) -> int {
    return 0xd4000001 + (imm16 * 32)
}

// Emit the syscall trap appropriate for the target OS.
fn emit_arm64_svc(code: [int], os: int) -> [int] {
    if os == os_darwin() {
        // svc #0x80
        return emit32(code, encode_svc(0x80))
    }
    // Linux: svc #0
    return emit32(code, encode_svc(0))
}

// Move syscall number into the syscall-number register:
//   Darwin: x16
//   Linux : x8
fn emit_arm64_syscall_nr(code: [int], os: int, nr: int) -> [int] {
    let nr_reg = if os == os_linux() { 8 } else { 16 }
    return emit_mov_imm(code, nr_reg, nr)
}

// Move value in src register into dst register, if different.
fn emit_arm64_mov_if_diff(code: [int], dst: int, src: int) -> [int] {
    if src == dst { return code }
    return emit32(code, encode_mov(dst, src))
}

// encode_syscall_write — write(fd_reg, buf_reg, len_reg)
// Marshals the three args into x0, x1, x2, loads the write syscall
// number into the NR register, then traps via SVC.
fn encode_syscall_write(arch: int, os: int, fd_reg: int, buf_reg: int, len_reg: int) -> [int] {
    let mut code = []
    // NOTE: arch is carried through to keep the interface identical
    // across ARM64/x86-64 call sites; the ARM64 path ignores it.
    // Order of argument moves matters if the sources alias the
    // destinations. We use a tmp register (x17) when src→dst chain
    // would clobber a not-yet-read source.

    // Stage: read all three sources into temporaries to avoid aliasing.
    // We stash buf_reg into x17 (arm64_tmp2) and len_reg into x16 before
    // reloading x16 with the syscall number. This is overkill for the
    // common case but correct under arbitrary aliasing.
    //
    // Simpler pattern: move from lowest-index arg register outward,
    // which is safe whenever src regs are not x0..x2 from a prior call.
    // Here we spell it out to cover the aliasing case.

    // Put fd into x0 (unless already there).
    code = emit_arm64_mov_if_diff(code, 0, fd_reg)
    // Put buf into x1 (unless already there).
    code = emit_arm64_mov_if_diff(code, 1, buf_reg)
    // Put len into x2 (unless already there).
    code = emit_arm64_mov_if_diff(code, 2, len_reg)

    // Syscall number into x16 (Darwin) or x8 (Linux).
    let nr = if os == os_linux() { 64 } else { 0x2000004 }
    code = emit_arm64_syscall_nr(code, os, nr)

    // Trap.
    code = emit_arm64_svc(code, os)
    return code
}

// encode_syscall_exit — exit(code_reg)
fn encode_syscall_exit(arch: int, os: int, code_reg: int) -> [int] {
    let mut code = []
    // Move exit code into x0.
    code = emit_arm64_mov_if_diff(code, 0, code_reg)
    // Syscall number.
    let nr = if os == os_linux() { 93 } else { 0x2000001 }
    code = emit_arm64_syscall_nr(code, os, nr)
    // Trap.
    code = emit_arm64_svc(code, os)
    return code
}
