// self/codegen/regalloc_linear.hexa — ported from src/codegen/regalloc_linear.rs
// Register Allocation — Linear Scan (Poletto & Sarkar 1999).
// O(n log n) linear scan pass on SSA HEXA-IR.

// A single live range for a ValueId.
struct LiveInterval {
    value: int,        // ValueId
    start: int,        // global instruction index of first def
    end_pos: int,      // global instruction index of last use (inclusive)
    fixed_reg: int     // -1 if not pinned, otherwise register index
}

fn live_interval_new(value: int, start: int, end_pos: int, fixed_reg: int) -> LiveInterval {
    return LiveInterval {
        value: value,
        start: start,
        end_pos: end_pos,
        fixed_reg: fixed_reg
    }
}

// Sentinel ValueId for synthetic param-register reservations.
fn reserved_vid() -> int { return 0x7FFFFFFF }

// Insert into active list keeping sorted by interval end (ascending).
fn insert_active(active_regs: [int], active_intervals: [LiveInterval], reg: int, iv: LiveInterval) -> [[int]] {
    // Returns [new_active_regs_as_ints, ...] — conceptual
    // In practice, we maintain parallel arrays sorted by end_pos.
    let mut ar = active_regs
    let mut ai_vals = []
    let mut ai_starts = []
    let mut ai_ends = []
    let mut ai_fixed = []
    // Rebuild from intervals (simplified representation)
    let mut i = 0
    let n = len(ar)
    let mut inserted = false
    // For now, just append — full sort would be done in production
    ar = ar.push(reg)
    return [ar]
}

// Linear-scan register allocation for a single function.
// regs: array of physical register indices.
// intervals: pre-computed live intervals.
// Returns FuncAlloc.
fn allocate_function_linear(intervals: [LiveInterval], regs: [int]) -> FuncAlloc {
    let k = len(regs)
    if len(intervals) == 0 {
        return func_alloc_empty()
    }

    // Sort intervals by start (simplified: assume pre-sorted)
    let mut locations_tag = []
    let mut locations_val = []
    let mut used_regs = []
    let mut stack_offset = 0

    // Free registers stack
    let mut free_regs = []
    let mut i = k - 1
    while i >= 0 {
        free_regs = free_regs.push(i)
        i = i - 1
    }

    // Active list: (register_index, interval_end)
    let mut active_reg = []
    let mut active_end = []

    i = 0
    while i < len(intervals) {
        let iv = intervals[i]

        // Expire old intervals
        let mut j = 0
        while j < len(active_end) {
            if active_end[j] < iv.start {
                free_regs = free_regs.push(active_reg[j])
                // Remove from active (shift)
                let mut new_ar = []
                let mut new_ae = []
                let mut k2 = 0
                while k2 < len(active_reg) {
                    if k2 != j {
                        new_ar = new_ar.push(active_reg[k2])
                        new_ae = new_ae.push(active_end[k2])
                    }
                    k2 = k2 + 1
                }
                active_reg = new_ar
                active_end = new_ae
            } else {
                j = j + 1
            }
        }

        // Ensure locations arrays are big enough
        while len(locations_tag) <= iv.value {
            locations_tag = locations_tag.push(0)
            locations_val = locations_val.push(0)
        }

        if len(active_reg) == k {
            // Spill: pick interval with largest end
            stack_offset = stack_offset - 8
            locations_tag[iv.value] = 1  // LOC_STACK
            locations_val[iv.value] = stack_offset
        } else {
            // Pop top of free_regs stack. Prior form accidentally cleared
            // the whole free list after reading the top (`free_regs = []`),
            // so every value after the first spilled. Rebuild without the
            // last element instead.
            let top = len(free_regs) - 1
            let reg_idx = free_regs[top]
            let mut new_free = []
            let mut fi = 0
            while fi < top {
                new_free = new_free.push(free_regs[fi])
                fi = fi + 1
            }
            free_regs = new_free

            let reg = regs[reg_idx]
            locations_tag[iv.value] = 0  // LOC_REG
            locations_val[iv.value] = reg
            if !array_contains(used_regs, reg) {
                used_regs = used_regs.push(reg)
            }
            active_reg = active_reg.push(reg_idx)
            active_end = active_end.push(iv.end_pos)
        }

        i = i + 1
    }

    // Align stack to 16 bytes
    let mut stack_size = 0
    if stack_offset < 0 {
        stack_size = (0 - stack_offset + 15) / 16 * 16
    }

    return FuncAlloc {
        locations_tag: locations_tag,
        locations_val: locations_val,
        stack_size: stack_size,
        used_regs: used_regs,
        callee_saved: []
    }
}
