// ═══════════════════════════════════════════════════════════
//  test_interp_e2e.hexa — Self-Hosting Interpreter E2E Test
//  Pipeline: source string -> tokenize() -> parse() -> interpret() -> output
//  Verifies the self-hosting lexer/parser/interpreter can execute programs
// ═══════════════════════════════════════════════════════════

let HEXA = "/Users/ghost/Dev/hexa-lang/hexa"
let SELF_DIR = "/Users/ghost/Dev/hexa-lang/self"
let TMP_DIR = "/tmp/hexa_interp_e2e"

exec("mkdir -p " + TMP_DIR)

let mut pass_count = 0
let mut fail_count = 0
let mut test_count = 0

// ── Load self-hosting pipeline sources ──────────────────
let lexer_src = read_file(SELF_DIR + "/lexer.hexa")
let parser_src = read_file(SELF_DIR + "/parser.hexa")
let interp_src = read_file(SELF_DIR + "/interpreter.hexa")

println("Loaded pipeline sources:")
println("  lexer.hexa:       " + to_string(len(lexer_src)) + " chars")
println("  parser.hexa:      " + to_string(len(parser_src)) + " chars")
println("  interpreter.hexa: " + to_string(len(interp_src)) + " chars")
println("")

// Build combined module: lexer + parser + interpreter
let pipeline_src = lexer_src + "\n" + parser_src + "\n" + interp_src + "\n"

// ── Marker-based output extraction ──────────────────────
// The interpreter.hexa prints a banner on load (8 lines).
// We use a unique marker to delimit actual test output.

let MARKER = "___E2E_RESULT___"

// ── Test runner ─────────────────────────────────────────
// For each test:
//   1. Build a .hexa driver = pipeline + driver code
//   2. Driver calls tokenize -> parse -> interpret on the test source
//   3. exec() the driver, extract output after marker
//   4. Compare with expected

fn run_test(name, hexa_source, expected) {
    test_count = test_count + 1
    let driver_file = TMP_DIR + "/test_" + name + ".hexa"

    // Escape the test source for embedding in a string literal.
    // We write it to a file and read it back to avoid escaping issues.
    let src_file = TMP_DIR + "/src_" + name + ".hexa"
    write_file(src_file, hexa_source)

    // Driver: load pipeline, then read test source from file, run pipeline
    let driver_code = pipeline_src + "\n" + "println(\"" + MARKER + "\")\n" + "let __test_src = read_file(\"" + src_file + "\")\n" + "let __tokens = tokenize(__test_src)\n" + "let __ast = parse(__tokens)\n" + "interpret(__ast)\n" + "println(\"" + MARKER + "\")\n"

    write_file(driver_file, driver_code)

    // Run the driver
    let result = exec(HEXA + " " + driver_file + " 2>&1")

    if type_of(result) == "error" {
        println("[FAIL] " + name + ": exec error: " + to_string(result))
        fail_count = fail_count + 1
        return false
    }

    // Extract output between markers
    let lines = result.split("\n")
    let mut capture = false
    let mut output_lines = []
    for line in lines {
        if line == MARKER {
            if capture {
                // End marker
                capture = false
            } else {
                // Start marker
                capture = true
            }
        } else {
            if capture {
                output_lines = output_lines.push(line)
            }
        }
    }

    let actual = output_lines.join("\n")

    if actual == expected {
        println("[PASS] " + name + ": \"" + actual + "\"")
        pass_count = pass_count + 1
        return true
    } else {
        println("[FAIL] " + name)
        println("  expected: \"" + expected + "\"")
        println("  actual:   \"" + actual + "\"")
        fail_count = fail_count + 1
        return false
    }
}

// ═══════════════════════════════════════════════════════════
//  TEST CASES
// ═══════════════════════════════════════════════════════════

println("═══════════════════════════════════════════════════════")
println("  HEXA Self-Hosting Interpreter E2E Test")
println("  source -> tokenize() -> parse() -> interpret()")
println("═══════════════════════════════════════════════════════")
println("")

// T1: println(42)
run_test("t1_println_42", "println(42)", "42")

// T2: let + arithmetic
run_test("t2_let_add", "let x = 10\nprintln(x + 5)", "15")

// T3: function definition and call
run_test("t3_fn_double", "fn twice(n) {\n  return n * 2\n}\nprintln(twice(21))", "42")

// T4: string literal
run_test("t4_string", "println(\"hello\")", "hello")

// T5: boolean
run_test("t5_bool", "println(true)", "true")

// T6: if-else
run_test("t6_if_else", "let x = 10\nif x > 5 {\n  println(\"big\")\n} else {\n  println(\"small\")\n}", "big")

// T7: while loop
run_test("t7_while", "let mut i = 0\nlet mut sum = 0\nwhile i < 5 {\n  i = i + 1\n  sum = sum + i\n}\nprintln(sum)", "15")

// T8: nested function calls
run_test("t8_nested_fn", "fn add(a, b) {\n  return a + b\n}\nfn mul(a, b) {\n  return a * b\n}\nprintln(add(mul(3, 4), 5))", "17")

// T9: recursive factorial
run_test("t9_factorial", "fn fact(n) {\n  if n <= 1 {\n    return 1\n  }\n  return n * fact(n - 1)\n}\nprintln(fact(6))", "720")

// T10: multiple println
run_test("t10_multi_print", "println(1)\nprintln(2)\nprintln(3)", "1\n2\n3")

// ═══════════════════════════════════════════════════════════
//  NEW FEATURE TESTS (closure, match, try/catch, for-in, struct methods)
// ═══════════════════════════════════════════════════════════

// T11: Closure / Lambda — single expression
run_test("t11_lambda_expr", "let double = |x| x * 2\nprintln(double(21))", "42")

// T12: Closure captures variable
run_test("t12_closure_capture", "let base = 100\nlet add_base = |x| x + base\nprintln(add_base(42))", "142")

// T13: Lambda with block body
run_test("t13_lambda_block", "let greet = |name| {\n  return \"hello \" + name\n}\nprintln(greet(\"world\"))", "hello world")

// T14: Match expression — int patterns
run_test("t14_match_int", "let x = 2\nlet r = match x {\n  1 -> \"one\",\n  2 -> \"two\",\n  _ -> \"other\"\n}\nprintln(r)", "two")

// T15: Match expression — wildcard default
run_test("t15_match_wildcard", "let x = 99\nlet r = match x {\n  0 -> \"zero\",\n  _ -> \"default\"\n}\nprintln(r)", "default")

// T16: Match expression — string patterns
run_test("t16_match_string", "let s = \"hi\"\nlet r = match s {\n  \"hello\" -> \"formal\",\n  \"hi\" -> \"casual\",\n  _ -> \"unknown\"\n}\nprintln(r)", "casual")

// T17: Try/catch — no error
run_test("t17_try_no_error", "let mut result = \"\"\ntry {\n  result = \"ok\"\n} catch(e) {\n  result = \"error\"\n}\nprintln(result)", "ok")

// T18: Try/catch — catch thrown error
run_test("t18_try_catch_throw", "let mut result = \"\"\ntry {\n  throw \"boom\"\n  result = \"never\"\n} catch(e) {\n  result = e\n}\nprintln(result)", "{message: boom, trace: Stack trace:}")

// T19: For-in loop over array
run_test("t19_for_in_array", "let mut sum = 0\nlet arr = [10, 20, 30]\nfor x in arr {\n  sum = sum + x\n}\nprintln(sum)", "60")

// T20: For-in loop with range
run_test("t20_for_in_range", "let mut sum = 0\nfor i in 0..5 {\n  sum = sum + i\n}\nprintln(sum)", "10")

// T21: Struct init + field access
run_test("t21_struct_init", "struct Point {\n  x: int,\n  y: int\n}\nlet p = Point { x: 3, y: 4 }\nprintln(p.x + p.y)", "7")

// T22: Struct with impl method
run_test("t22_struct_method", "struct Rect {\n  w: int,\n  h: int\n}\nimpl Rect {\n  fn area(self) {\n    return self.w * self.h\n  }\n}\nlet r = Rect { w: 5, h: 3 }\nprintln(r.area())", "15")

// T23: Closure passed to array.map
run_test("t23_closure_map", "let arr = [1, 2, 3]\nlet doubled = arr.map(|x| x * 2)\nprintln(doubled.join(\", \"))", "2, 4, 6")

// T24: Match with block body
run_test("t24_match_block", "let x = 1\nlet r = match x {\n  1 -> {\n    let a = 10\n    let b = 20\n    a + b\n  },\n  _ -> 0\n}\nprintln(r)", "30")

// ═══════════════════════════════════════════════════════════
//  SUMMARY
// ═══════════════════════════════════════════════════════════

println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL / " + to_string(test_count) + " total")
if fail_count == 0 {
    println("  ALL TESTS PASSED — Self-hosting interpreter pipeline verified!")
} else {
    println("  SOME TESTS FAILED")
}
println("═══════════════════════════════════════════════════════")

// Cleanup
exec("rm -rf " + TMP_DIR)
