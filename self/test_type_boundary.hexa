// ═══════════════════════════════════════════════════════════
//  test_type_boundary.hexa — Type System Boundary Cases
//  Tests: Int/Float/Bool/String boundary conversions, type errors,
//         overflow-like edge cases, mixed-type comparisons,
//         null/empty handling, type identity preservation
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA Type Boundary Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Int boundary values ───────────────────────────────

println("--- Int Boundaries ---")

check("zero is int", type_of(0), "int")
check("large positive", 999999999 + 1, 1000000000)
check("large negative", -999999999 - 1, -1000000000)
check("int identity 0", 0 + 0, 0)
check("neg zero is zero", -0, 0)
check("int division truncation", 7 / 2, 3)
check("neg int division", -7 / 2, -3)

// ── 2. Float boundary values ─────────────────────────────

println("")
println("--- Float Boundaries ---")

check("float zero", 0.0 + 0.0, 0.0)
check("float zero type", type_of(0.0), "float")
check("small float", 0.001 + 0.001, 0.002)
check("float precision", 0.1 + 0.2 > 0.29, true)
check("float precision2", 0.1 + 0.2 < 0.31, true)
check("neg float", -3.14 + 3.14, 0.0)
check("float mul zero", 999.99 * 0.0, 0.0)
check("float div", 1.0 / 3.0 * 3.0 > 0.99, true)

// ── 3. Bool edge cases ───────────────────────────────────

println("")
println("--- Bool Boundaries ---")

check("true is bool", type_of(true), "bool")
check("false is bool", type_of(false), "bool")
check("not true", !true, false)
check("not false", !false, true)
check("double not", !!true, true)
check("triple not", !!!true, false)
check("bool and short-circuit", false && true, false)
check("bool or short-circuit", true || false, true)
check("complex bool", (true && false) || (true && true), true)

// ── 4. String edge cases ─────────────────────────────────

println("")
println("--- String Boundaries ---")

check("empty string type", type_of(""), "string")
check("empty string len", len(""), 0)
check("single char len", len("a"), 1)
check("string equality", "abc" == "abc", true)
check("string inequality", "abc" != "xyz", true)
check("concat empty", "" + "hello", "hello")
check("concat empty left", "hello" + "", "hello")
check("concat two empty", "" + "", "")

// ── 5. Cross-type conversions ────────────────────────────

println("")
println("--- Cross-Type Conversions ---")

check("int to float via calc", type_of(to_float("42")), "float")
check("float to int truncate", to_int(3.9), 3)
check("float to int neg trunc", to_int(-3.9), -3)
check("float to int zero", to_int(0.0), 0)
check("int to string to int", to_int(to_string(12345)), 12345)
check("float to str to float", to_float(to_string(3.14)), 3.14)
check("bool to string true", to_string(true), "true")
check("bool to string false", to_string(false), "false")

// ── 6. Type preservation through operations ──────────────

println("")
println("--- Type Preservation ---")

let a = 10
let b = 20
check("int+int stays int", type_of(a + b), "int")
check("int*int stays int", type_of(a * b), "int")
check("int-int stays int", type_of(a - b), "int")

let f1 = 1.5
let f2 = 2.5
check("float+float stays float", type_of(f1 + f2), "float")
check("float*float stays float", type_of(f1 * f2), "float")

// Int + Float -> Float promotion
check("int+float promotes", type_of(a + f1), "float")
check("float+int promotes", type_of(f1 + a), "float")

// ── 7. Invalid conversion handling ───────────────────────

println("")
println("--- Invalid Conversion Guards ---")

let mut caught = false
try {
    let bad = to_int("not_a_number")
} catch e {
    caught = true
}
check("to_int invalid string throws", caught, true)

let mut caught2 = false
try {
    let bad2 = to_float("abc")
} catch e {
    caught2 = true
}
check("to_float invalid string throws", caught2, true)

// ── 8. Comparison edge cases ─────────────────────────────

println("")
println("--- Comparison Boundaries ---")

check("0 == 0", 0 == 0, true)
check("0 == 0.0", 0 == 0.0, true)
check("-0 == 0", -0 == 0, true)
check("1 < 2", 1 < 2, true)
check("2 > 1", 2 > 1, true)
check("1 <= 1", 1 <= 1, true)
check("1 >= 1", 1 >= 1, true)
check("string compare eq", "abc" == "abc", true)
check("string compare neq", "abc" == "abd", false)

// ═══════════════════════════════════════════════════════════
//  SUMMARY
// ═══════════════════════════════════════════════════════════

println("")
println("═══════════════════════════════════════════════════════")
let total = pass_count + fail_count
println("  Results: " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL / " + to_string(total) + " total")
if fail_count == 0 {
    println("  ALL TYPE BOUNDARY TESTS PASSED!")
} else {
    println("  SOME TESTS FAILED")
}
println("═══════════════════════════════════════════════════════")
