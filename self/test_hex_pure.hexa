// self/test_hex_pure.hexa -- Tests for self/runtime/hex_pure.hexa

let HEX_CHARS = "0123456789abcdef"
let HEX_CHARS_UP = "0123456789ABCDEF"

fn hex_of_byte_pure(b) {
    if type_of(b) != "int" { return "00" }
    let bb = if b < 0 { 0 } else if b > 255 { 255 } else { b }
    let hi = HEX_CHARS.substring(bb / 16, bb / 16 + 1)
    let lo = HEX_CHARS.substring(bb % 16, bb % 16 + 1)
    hi + lo
}

fn hex_encode_pure(s) {
    if type_of(s) != "string" { return "" }
    let n = len(s)
    let mut out = ""
    let mut i = 0
    while i < n {
        let b = ord(s.substring(i, i + 1))
        out = out + HEX_CHARS.substring(b / 16, b / 16 + 1)
        out = out + HEX_CHARS.substring(b % 16, b % 16 + 1)
        i = i + 1
    }
    out
}

fn hex_encode_upper_pure(s) {
    if type_of(s) != "string" { return "" }
    let n = len(s)
    let mut out = ""
    let mut i = 0
    while i < n {
        let b = ord(s.substring(i, i + 1))
        out = out + HEX_CHARS_UP.substring(b / 16, b / 16 + 1)
        out = out + HEX_CHARS_UP.substring(b % 16, b % 16 + 1)
        i = i + 1
    }
    out
}

fn _hex_digit_val(c) {
    let o = ord(c)
    if o >= 48 && o <= 57  { return o - 48 }
    if o >= 65 && o <= 70  { return o - 65 + 10 }
    if o >= 97 && o <= 102 { return o - 97 + 10 }
    -1
}

fn hex_decode_pure(s) {
    if type_of(s) != "string" { return [] }
    let n = len(s)
    if n % 2 != 0 { return [] }
    let mut out = []
    let mut i = 0
    while i < n {
        let hi = _hex_digit_val(s.substring(i, i + 1))
        let lo = _hex_digit_val(s.substring(i + 1, i + 2))
        if hi < 0 || lo < 0 { return [] }
        out = out.push(hi * 16 + lo)
        i = i + 2
    }
    out
}

fn int_to_hex_pure(n) {
    if type_of(n) != "int" { return "0" }
    if n == 0 { return "0" }
    let mut v = n
    let mut neg = false
    if v < 0 {
        neg = true
        v = 0 - v
    }
    let mut out = ""
    while v > 0 {
        out = HEX_CHARS.substring(v % 16, v % 16 + 1) + out
        v = v / 16
    }
    if neg { return "-" + out }
    out
}

// ── harness ──────────────────────────────────────────────────────

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  hex_pure.hexa — test runner")
println("═══════════════════════════════════════════════════════")

// ── hex_of_byte_pure ────────────────────────────────────────
println("")
println("--- hex_of_byte_pure ---")
check("0 → 00", hex_of_byte_pure(0), "00")
check("15 → 0f", hex_of_byte_pure(15), "0f")
check("255 → ff", hex_of_byte_pure(255), "ff")
check("100 → 64", hex_of_byte_pure(100), "64")
check("clip to 255", hex_of_byte_pure(300), "ff")
check("clip to 0", hex_of_byte_pure(-5), "00")
check("non-int", hex_of_byte_pure("x"), "00")

// ── hex_encode_pure / _upper ────────────────────────────────
println("")
println("--- hex_encode_pure ---")
check("empty", hex_encode_pure(""), "")
check("Ab", hex_encode_pure("A"), "41")
check("AB", hex_encode_pure("AB"), "4142")
check("hello", hex_encode_pure("hello"), "68656c6c6f")
check("upper variant", hex_encode_upper_pure("hello"), "68656C6C6F")
check("non-string", hex_encode_pure(42), "")

// ── hex_decode_pure ─────────────────────────────────────────
println("")
println("--- hex_decode_pure ---")
check("empty", hex_decode_pure(""), [])
check("41 → A", hex_decode_pure("41"), [65])
check("hello bytes", hex_decode_pure("68656c6c6f"), [104, 101, 108, 108, 111])
check("uppercase accepted", hex_decode_pure("68656C6C6F"), [104, 101, 108, 108, 111])
check("mixed case", hex_decode_pure("ff0A"), [255, 10])
check("odd length empty", hex_decode_pure("abc"), [])
check("bad char empty", hex_decode_pure("zz"), [])
check("non-string", hex_decode_pure(42), [])

// ── int_to_hex_pure ─────────────────────────────────────────
println("")
println("--- int_to_hex_pure ---")
check("0", int_to_hex_pure(0), "0")
check("15 → f", int_to_hex_pure(15), "f")
check("16 → 10", int_to_hex_pure(16), "10")
check("255 → ff", int_to_hex_pure(255), "ff")
check("256 → 100", int_to_hex_pure(256), "100")
check("4096 → 1000", int_to_hex_pure(4096), "1000")
check("neg −15", int_to_hex_pure(-15), "-f")
check("non-int", int_to_hex_pure("x"), "0")

// ── Summary ─────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    println("FAIL")
    exit(1)
}
println("ALL PASS")
