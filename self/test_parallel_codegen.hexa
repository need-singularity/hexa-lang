// test_parallel_codegen.hexa — @parallel / @simd C codegen tests
// Verifies that OpenMP pragmas are emitted correctly in generated C code.
// Usage: ./hexa self/test_parallel_codegen.hexa

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn contains(haystack, needle) {
    let hlen = haystack.len()
    let nlen = needle.len()
    if nlen > hlen { return false }
    let mut i = 0
    while i <= hlen - nlen {
        if haystack.substring(i, i + nlen) == needle { return true }
        i = i + 1
    }
    return false
}

println("=== @parallel / @simd C codegen tests ===")
println("")

// --- Test 1: @parallel function ---

let par_src = "@parallel fn sum_par() {\n    let mut total = 0\n    for i in 0..100 {\n        total = total + i\n    }\n    return total\n}\nprintln(sum_par())\n"
write_file("build/__test_par.hexa", par_src)
exec("./hexa self/build_c.hexa build/__test_par.hexa build/__test_par.c")
let par_c = read_file("build/__test_par.c")

check("@parallel: #pragma omp parallel for present", contains(par_c, "#pragma omp parallel for"))
check("@parallel: #include <omp.h> present", contains(par_c, "#include <omp.h>"))
check("@parallel: -fopenmp comment present", contains(par_c, "-fopenmp"))

// --- Test 2: @simd function ---

let simd_src = "@simd fn dot_simd() {\n    let mut s = 0\n    for i in 0..10 {\n        s = s + i * i\n    }\n    return s\n}\nprintln(dot_simd())\n"
write_file("build/__test_simd.hexa", simd_src)
exec("./hexa self/build_c.hexa build/__test_simd.hexa build/__test_simd.c")
let simd_c = read_file("build/__test_simd.c")

check("@simd: #pragma omp simd present", contains(simd_c, "#pragma omp simd"))
check("@simd: #include <omp.h> present", contains(simd_c, "#include <omp.h>"))

// --- Test 3: normal function (no OMP) ---

let norm_src = "fn sum_norm() {\n    let mut total = 0\n    for i in 0..100 {\n        total = total + i\n    }\n    return total\n}\nprintln(sum_norm())\n"
write_file("build/__test_norm.hexa", norm_src)
exec("./hexa self/build_c.hexa build/__test_norm.hexa build/__test_norm.c")
let norm_c = read_file("build/__test_norm.c")

check("normal fn: no #pragma omp parallel", !contains(norm_c, "#pragma omp parallel"))
check("normal fn: no #include <omp.h>", !contains(norm_c, "#include <omp.h>"))

// --- Test 4: @parallel with reduction ---
let par_red_src = "@parallel fn sum_reduce() {\n    let mut total = 0\n    for i in 0..50 {\n        total = total + i\n    }\n    return total\n}\nprintln(sum_reduce())\n"
write_file("build/__test_par_red.hexa", par_red_src)
exec("./hexa self/build_c.hexa build/__test_par_red.hexa build/__test_par_red.c")
let par_red_c = read_file("build/__test_par_red.c")

check("@parallel reduction: has omp pragma", contains(par_red_c, "#pragma omp"))
check("@parallel reduction: has function body", contains(par_red_c, "sum_reduce"))

// --- Test 5: @parallel with nested loop (only outer parallel) ---
let par_nest_src = "@parallel fn mat_sum() {\n    let mut total = 0\n    for i in 0..10 {\n        for j in 0..10 {\n            total = total + i * j\n        }\n    }\n    return total\n}\nprintln(mat_sum())\n"
write_file("build/__test_par_nest.hexa", par_nest_src)
exec("./hexa self/build_c.hexa build/__test_par_nest.hexa build/__test_par_nest.c")
let par_nest_c = read_file("build/__test_par_nest.c")

check("@parallel nested: has omp pragma", contains(par_nest_c, "#pragma omp"))
check("@parallel nested: has function", contains(par_nest_c, "mat_sum"))

// --- Test 6: @simd with accumulation ---
let simd_acc_src = "@simd fn vec_sum() {\n    let mut s = 0\n    for i in 0..20 {\n        s = s + i\n    }\n    return s\n}\nprintln(vec_sum())\n"
write_file("build/__test_simd_acc.hexa", simd_acc_src)
exec("./hexa self/build_c.hexa build/__test_simd_acc.hexa build/__test_simd_acc.c")
let simd_acc_c = read_file("build/__test_simd_acc.c")

check("@simd accumulation: has simd pragma", contains(simd_acc_c, "#pragma omp simd"))
check("@simd accumulation: has function", contains(simd_acc_c, "vec_sum"))

// --- Test 7: Multiple functions mixed attributes ---
let mixed_src = "@parallel fn par_fn() {\n    let mut t = 0\n    for i in 0..100 { t = t + i }\n    return t\n}\nfn norm_fn() {\n    return 42\n}\nprintln(par_fn())\nprintln(norm_fn())\n"
write_file("build/__test_mixed.hexa", mixed_src)
exec("./hexa self/build_c.hexa build/__test_mixed.hexa build/__test_mixed.c")
let mixed_c = read_file("build/__test_mixed.c")

check("mixed: par_fn has omp", contains(mixed_c, "#pragma omp"))
check("mixed: both functions present", contains(mixed_c, "par_fn") && contains(mixed_c, "norm_fn"))

// --- Test 8: Normal function has standard C structure ---
check("normal fn: has return statement", contains(norm_c, "return"))
check("normal fn: has function definition", contains(norm_c, "sum_norm"))

// --- Test 9: @parallel function has correct include guard ---
check("@parallel: pragma before for loop", contains(par_c, "for"))

// --- Test 10: @simd function has correct structure ---
check("@simd: has for loop", contains(simd_c, "for"))

// --- Test 11: Generated C has main function ---
check("normal: has main()", contains(norm_c, "main"))
check("parallel: has main()", contains(par_c, "main"))

// --- Test 12: Multiple @simd functions ---
let multi_simd_src = "@simd fn dot1() {\n    let mut s = 0\n    for i in 0..5 { s = s + i }\n    return s\n}\n@simd fn dot2() {\n    let mut s = 0\n    for i in 0..5 { s = s + i * 2 }\n    return s\n}\nprintln(dot1())\nprintln(dot2())\n"
write_file("build/__test_multi_simd.hexa", multi_simd_src)
exec("./hexa self/build_c.hexa build/__test_multi_simd.hexa build/__test_multi_simd.c")
let multi_simd_c = read_file("build/__test_multi_simd.c")

check("multi-simd: dot1 present", contains(multi_simd_c, "dot1"))
check("multi-simd: dot2 present", contains(multi_simd_c, "dot2"))
check("multi-simd: has simd pragma", contains(multi_simd_c, "#pragma omp simd"))

// --- Summary ---
println("")
println("=== Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed ===")
if fail_count > 0 {
    println("SOME TESTS FAILED")
} else {
    println("ALL TESTS PASSED")
}
