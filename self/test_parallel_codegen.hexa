// test_parallel_codegen.hexa — @parallel / @simd C codegen tests
// Verifies that OpenMP pragmas are emitted correctly in generated C code.
// Usage: ./hexa self/test_parallel_codegen.hexa

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn contains(haystack, needle) {
    let hlen = haystack.len()
    let nlen = needle.len()
    if nlen > hlen { return false }
    let mut i = 0
    while i <= hlen - nlen {
        if haystack.substring(i, i + nlen) == needle { return true }
        i = i + 1
    }
    return false
}

println("=== @parallel / @simd C codegen tests ===")
println("")

// --- Test 1: @parallel function ---

let par_src = "@parallel fn sum_par() {\n    let mut total = 0\n    for i in 0..100 {\n        total = total + i\n    }\n    return total\n}\nprintln(sum_par())\n"
write_file("build/__test_par.hexa", par_src)
exec("./target/release/hexa self/build_c.hexa build/__test_par.hexa build/__test_par.c")
let par_c = read_file("build/__test_par.c")

check("@parallel: #pragma omp parallel for present", contains(par_c, "#pragma omp parallel for"))
check("@parallel: #include <omp.h> present", contains(par_c, "#include <omp.h>"))
check("@parallel: -fopenmp comment present", contains(par_c, "-fopenmp"))

// --- Test 2: @simd function ---

let simd_src = "@simd fn dot_simd() {\n    let mut s = 0\n    for i in 0..10 {\n        s = s + i * i\n    }\n    return s\n}\nprintln(dot_simd())\n"
write_file("build/__test_simd.hexa", simd_src)
exec("./target/release/hexa self/build_c.hexa build/__test_simd.hexa build/__test_simd.c")
let simd_c = read_file("build/__test_simd.c")

check("@simd: #pragma omp simd present", contains(simd_c, "#pragma omp simd"))
check("@simd: #include <omp.h> present", contains(simd_c, "#include <omp.h>"))

// --- Test 3: normal function (no OMP) ---

let norm_src = "fn sum_norm() {\n    let mut total = 0\n    for i in 0..100 {\n        total = total + i\n    }\n    return total\n}\nprintln(sum_norm())\n"
write_file("build/__test_norm.hexa", norm_src)
exec("./target/release/hexa self/build_c.hexa build/__test_norm.hexa build/__test_norm.c")
let norm_c = read_file("build/__test_norm.c")

check("normal fn: no #pragma omp parallel", !contains(norm_c, "#pragma omp parallel"))
check("normal fn: no #include <omp.h>", !contains(norm_c, "#include <omp.h>"))

// --- Summary ---
println("")
println("=== Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed ===")
if fail_count > 0 {
    println("SOME TESTS FAILED")
} else {
    println("ALL TESTS PASSED")
}
