// self/std_web_template.hexa — HEXA STD_WEB_TEMPLATE ported from src/std_web_template.rs
//
// AST-based HTML template renderer for HEXA-LANG.
// Provides: html_escape, is_truthy, values_eq, render_template, render_node

// ── HTML void elements (self-closing) ──────────────────────

let VOID_ELEMENTS = [
    "area", "base", "br", "col", "embed", "hr", "img", "input",
    "link", "meta", "param", "source", "track", "wbr"
]

fn is_void_element(tag: string) -> bool {
    let i = 0
    while i < len(VOID_ELEMENTS) {
        if VOID_ELEMENTS[i] == tag {
            return true
        }
        i = i + 1
    }
    return false
}

// ── HTML escape (prevent XSS) ──────────────────────────────

fn html_escape(s: string) -> string {
    let out = ""
    let i = 0
    while i < len(s) {
        let ch = s[i]
        if ch == "&" {
            out = out + "&amp;"
        } else if ch == "<" {
            out = out + "&lt;"
        } else if ch == ">" {
            out = out + "&gt;"
        } else if ch == "\"" {
            out = out + "&quot;"
        } else if ch == "'" {
            out = out + "&#39;"
        } else {
            out = out + ch
        }
        i = i + 1
    }
    return out
}

// ── Truthiness evaluation ──────────────────────────────────

fn template_is_truthy(val) -> bool {
    if val == false { return false }
    if val == 0 { return false }
    if val == "" { return false }
    if val == [] { return false }
    if val == void { return false }
    return true
}

// ── Value equality for match arms ──────────────────────────

fn template_values_eq(a, b) -> bool {
    return a == b
}

// ── Value to string for template output ────────────────────

fn template_value_to_string(val) -> string {
    if val == void { return "" }
    return str(val)
}

// ── Template Node types ────────────────────────────────────
// Represented as structs for the template AST.

struct TemplateText {
    content: string
}

struct TemplateAttr {
    key: string,
    value: string
}

struct TemplateElement {
    tag: string,
    attrs: [TemplateAttr],
    children: [string]    // rendered HTML fragments
}

// ── Render functions ───────────────────────────────────────

fn render_text(text: string) -> string {
    return html_escape(text)
}

fn render_attrs(attrs: [TemplateAttr]) -> string {
    let out = ""
    let i = 0
    while i < len(attrs) {
        let attr = attrs[i]
        out = out + " " + html_escape(attr.key) + "=\"" + html_escape(attr.value) + "\""
        i = i + 1
    }
    return out
}

fn render_element(tag: string, attrs: [TemplateAttr], children_html: string) -> string {
    let tag_lower = tag   // assume already lowercase
    let html = "<" + tag_lower + render_attrs(attrs)
    if is_void_element(tag_lower) {
        return html + " />"
    }
    return html + ">" + children_html + "</" + tag_lower + ">"
}

fn render_for_loop(items: [], item_name: string, body_fn) -> string {
    let html = ""
    let i = 0
    while i < len(items) {
        html = html + str(body_fn(items[i]))
        i = i + 1
    }
    return html
}

fn render_if(cond, then_html: string, else_html: string) -> string {
    if template_is_truthy(cond) {
        return then_html
    }
    return else_html
}

fn render_match(scrutinee, arms: []) -> string {
    // arms: array of [pattern, html_string] pairs
    let i = 0
    while i < len(arms) {
        let arm = arms[i]
        let pattern = arm[0]
        let html = arm[1]
        if pattern == "_" || template_values_eq(scrutinee, pattern) {
            return html
        }
        i = i + 1
    }
    return ""
}

fn render_verify(val) -> string {
    if !template_is_truthy(val) {
        print("ERROR: template verify: assertion failed")
    }
    return ""
}

fn render_invariant(val) -> string {
    if !template_is_truthy(val) {
        print("ERROR: template invariant: invariant violated")
    }
    return ""
}

// ── Tests ──────────────────────────────────────────────────

fn test_html_escape_basic() {
    assert(html_escape("hello") == "hello")
    assert(html_escape("<b>") == "&lt;b&gt;")
    assert(html_escape("&") == "&amp;")
    assert(html_escape("\"") == "&quot;")
    assert(html_escape("'") == "&#39;")
    print("  PASS: html_escape_basic")
}

fn test_html_escape_xss() {
    let xss = "<script>alert('xss')</script>"
    let escaped = html_escape(xss)
    assert(escaped == "&lt;script&gt;alert(&#39;xss&#39;)&lt;/script&gt;")
    print("  PASS: html_escape_xss")
}

fn test_html_escape_amp_in_url() {
    assert(html_escape("a=1&b=2") == "a=1&amp;b=2")
    print("  PASS: html_escape_amp_in_url")
}

fn test_void_elements() {
    assert(is_void_element("br") == true)
    assert(is_void_element("img") == true)
    assert(is_void_element("input") == true)
    assert(is_void_element("hr") == true)
    assert(is_void_element("meta") == true)
    assert(is_void_element("link") == true)
    assert(is_void_element("div") == false)
    assert(is_void_element("span") == false)
    assert(is_void_element("p") == false)
    print("  PASS: void_elements")
}

fn test_template_is_truthy() {
    assert(template_is_truthy(true) == true)
    assert(template_is_truthy(false) == false)
    assert(template_is_truthy(1) == true)
    assert(template_is_truthy(0) == false)
    assert(template_is_truthy("hello") == true)
    assert(template_is_truthy("") == false)
    assert(template_is_truthy([1]) == true)
    assert(template_is_truthy([]) == false)
    print("  PASS: template_is_truthy")
}

fn test_template_values_eq() {
    assert(template_values_eq(42, 42) == true)
    assert(template_values_eq(1, 2) == false)
    assert(template_values_eq("hi", "hi") == true)
    assert(template_values_eq(true, false) == false)
    print("  PASS: template_values_eq")
}

fn test_render_element() {
    let html = render_element("div", [], "hello")
    assert(html == "<div>hello</div>")
    print("  PASS: render_element")
}

fn test_render_void_element() {
    let html = render_element("br", [], "")
    assert(html == "<br />")
    print("  PASS: render_void_element")
}

fn test_render_element_with_attrs() {
    let attrs = [TemplateAttr { key: "class", value: "main" }]
    let html = render_element("div", attrs, "content")
    assert(html == "<div class=\"main\">content</div>")
    print("  PASS: render_element_with_attrs")
}

fn test_render_if() {
    assert(render_if(true, "yes", "no") == "yes")
    assert(render_if(false, "yes", "no") == "no")
    assert(render_if(0, "yes", "no") == "no")
    assert(render_if(1, "yes", "no") == "yes")
    print("  PASS: render_if")
}

fn test_render_match() {
    let arms = [[1, "one"], [2, "two"], ["_", "other"]]
    assert(render_match(1, arms) == "one")
    assert(render_match(2, arms) == "two")
    assert(render_match(99, arms) == "other")
    print("  PASS: render_match")
}

// ── Main ───────────────────────────────────────────────────

print("=== std_web_template.hexa tests ===")
test_html_escape_basic()
test_html_escape_xss()
test_html_escape_amp_in_url()
test_void_elements()
test_template_is_truthy()
test_template_values_eq()
test_render_element()
test_render_void_element()
test_render_element_with_attrs()
test_render_if()
test_render_match()
print("All std_web_template tests passed.")
