// ═══════════════════════════════════════════════════════════
//  test_jump_thread.hexa — #46 Jump Threading pass validation
//
//  Verifies that conditional branch chains are shortened by
//  threading jumps directly to the final target block.
//
//  Pattern: if c1 { if c2 { X } else { Y } } else { Y }
//  Threaded: if c1 && c2 { X } else { Y }
//
//  실행: ./hexa test self/test_jump_thread.hexa
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn check_eq(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  #46 Jump Threading Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Basic chain: if c1 { if c2 { A } else { B } } else { B }
//    Semantically: c1 && c2 → A, else B

fn classify_basic(x, y) {
    if x > 0 {
        if y > 0 {
            return "both_positive"
        } else {
            return "fallback"
        }
    } else {
        return "fallback"
    }
}

check_eq("basic: both positive", classify_basic(1, 1), "both_positive")
check_eq("basic: x neg", classify_basic(-1, 1), "fallback")
check_eq("basic: y neg", classify_basic(1, -1), "fallback")
check_eq("basic: both neg", classify_basic(-1, -1), "fallback")

// ── 2. Triple condition chain
fn classify_triple(a, b, c) {
    if a > 0 {
        if b > 0 {
            if c > 0 {
                return "all_positive"
            } else {
                return "default"
            }
        } else {
            return "default"
        }
    } else {
        return "default"
    }
}

check_eq("triple: all pos", classify_triple(1, 2, 3), "all_positive")
check_eq("triple: a neg", classify_triple(-1, 2, 3), "default")
check_eq("triple: b neg", classify_triple(1, -2, 3), "default")
check_eq("triple: c neg", classify_triple(1, 2, -3), "default")

// ── 3. With computation in branches
fn compute_branch(x) {
    let mut result = 0
    if x > 10 {
        if x < 100 {
            result = x * 2
        } else {
            result = -1
        }
    } else {
        result = -1
    }
    return result
}

check_eq("compute: in range 50", compute_branch(50), 100)
check_eq("compute: too low 5", compute_branch(5), -1)
check_eq("compute: too high 200", compute_branch(200), -1)
check_eq("compute: boundary 10", compute_branch(10), -1)
check_eq("compute: boundary 11", compute_branch(11), 22)

// ── 4. Boolean logic equivalence verification
// jump threading of (c1 && c2) should be semantically identical
fn original_chain(a, b) {
    if a {
        if b {
            return 1
        } else {
            return 0
        }
    } else {
        return 0
    }
}

fn threaded_equiv(a, b) {
    if a && b {
        return 1
    } else {
        return 0
    }
}

check_eq("equiv: T,T", original_chain(true, true), threaded_equiv(true, true))
check_eq("equiv: T,F", original_chain(true, false), threaded_equiv(true, false))
check_eq("equiv: F,T", original_chain(false, true), threaded_equiv(false, true))
check_eq("equiv: F,F", original_chain(false, false), threaded_equiv(false, false))

// ── 5. Non-threadable: different else branches (must NOT thread)
fn different_else(x) {
    if x > 0 {
        if x > 10 {
            return "big"
        } else {
            return "small_positive"
        }
    } else {
        return "negative"
    }
}

check_eq("no-thread: big", different_else(20), "big")
check_eq("no-thread: small pos", different_else(5), "small_positive")
check_eq("no-thread: negative", different_else(-5), "negative")

// ── 6. Loop with conditional chain inside
fn loop_with_chain(arr) {
    let mut count = 0
    let mut i = 0
    while i < len(arr) {
        let v = arr[i]
        if v > 0 {
            if v < 100 {
                count = count + 1
            }
        }
        i = i + 1
    }
    return count
}

check_eq("loop chain: [1,50,200,-5]", loop_with_chain([1, 50, 200, -5]), 2)
check_eq("loop chain: empty", loop_with_chain([]), 0)
check_eq("loop chain: all valid", loop_with_chain([1, 2, 3, 99]), 4)
check_eq("loop chain: none valid", loop_with_chain([-1, 0, 100, 200]), 0)

// ── 7. stmts_equal_shallow correctness
// Verify that shallow equality check works for return stmts
fn branch_return_int(x, y) {
    if x > 0 {
        if y > 0 {
            return 42
        } else {
            return 0
        }
    } else {
        return 0
    }
}

check_eq("shallow eq: both pos", branch_return_int(1, 1), 42)
check_eq("shallow eq: x neg", branch_return_int(-1, 1), 0)
check_eq("shallow eq: y neg", branch_return_int(1, -1), 0)

// ── 8. Edge case: single-statement chains
fn single_stmt_chain(flag) {
    if flag {
        return "yes"
    } else {
        return "no"
    }
}

check_eq("single: true", single_stmt_chain(true), "yes")
check_eq("single: false", single_stmt_chain(false), "no")

// ── Summary
println("")
println("═══════════════════════════════════════════════════════")
println("  #46 Jump Threading: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")
assert(fail_count == 0)
