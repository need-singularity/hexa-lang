// ═══════════════════════════════════════════════════════════
//  self/verify_native_determinism.hexa — roi.json #174
//  native_backend bit-exact 결정성 검증 (scaffold)
//
//  목표:
//    동일 seed / 동일 입력 → 동일 비트 출력.
//    native_backend 가 컴파일러/인터프리터 실행 사이에서
//    비트-정확(bit-exact) 재현성을 가지는지 확인하기 위한
//    pure-Hexa scaffold.
//
//  접근:
//    1. FNV-1a-32 기반 간단한 SHA-like fingerprint (nd_fingerprint)
//    2. "native_backend" 를 대리(stub)하는 결정적 함수 (nd_native_kernel)
//       — 동일 (seed, input) 에서 동일 결과 벡터를 반환
//    3. 같은 입력으로 커널을 2회 호출 → 출력 바이트 비교
//       → 불일치 시 fail, 일치 시 pass
//
//  호출 규약:
//    nd_verify_determinism(seed, input) -> #{ "ok": bool,
//                                             "fp_a": int,
//                                             "fp_b": int,
//                                             "bytes_a": [int],
//                                             "bytes_b": [int] }
//
//  의존성: 순수 .hexa. Rust 수정 없음.
//  쓰임: self/test_native_determinism.hexa 가 이 파일 로직을 재호출.
// ═══════════════════════════════════════════════════════════

// ── FNV-1a 32-bit constants (mirrors self/runtime/hash_pure.hexa) ──
let ND_FNV_OFFSET_32 = 2166136261   // 0x811C9DC5
let ND_FNV_PRIME_32  = 16777619     // 0x01000193
let ND_FNV_MOD_32    = 4294967296   // 2^32

// ── nd_fingerprint_bytes — FNV-1a over a byte vector ──────────────
// bytes: [int]  (각 원소는 0..255 범위의 정수)
// return: 32-bit fingerprint (int)
fn nd_fingerprint_bytes(bytes) {
    let mut h = ND_FNV_OFFSET_32
    let n = len(bytes)
    let mut i = 0
    while i < n {
        let b = bytes[i] % 256
        h = h ^ b
        h = (h * ND_FNV_PRIME_32) % ND_FNV_MOD_32
        i = i + 1
    }
    return h
}

// ── nd_ints_to_bytes — int 벡터 → little-endian byte 벡터 ─────────
// 각 int 를 4바이트 LE 로 직렬화. 음수는 2^32 보정.
fn nd_ints_to_bytes(ints) {
    let mut out = []
    let n = len(ints)
    let mut i = 0
    while i < n {
        let mut v = ints[i]
        if v < 0 { v = v + ND_FNV_MOD_32 }
        let b0 = v % 256
        let b1 = (v / 256) % 256
        let b2 = (v / 65536) % 256
        let b3 = (v / 16777216) % 256
        out = out + [b0]
        out = out + [b1]
        out = out + [b2]
        out = out + [b3]
        i = i + 1
    }
    return out
}

// ── nd_lcg — 결정적 PRNG (Linear Congruential Generator) ───────────
// native_backend 의 결정적 커널을 대리. 동일 seed → 동일 상태 열.
fn nd_lcg(state) {
    return (state * 1103515245 + 12345) % 2147483648
}

// ── nd_native_kernel — "native backend" 실행을 대리하는 결정적 커널
// seed 와 input 에 전적으로 의존 (시계 / 전역 상태 / PRNG 의존 없음).
// native_backend 가 실제로 빌릴 수 있는 성질과 동일: 결정적 변환.
//
// 동작:
//   state = seed
//   for x in input:
//       state = lcg(state ^ x)
//       out  += [ (state ^ x) & 0xFFFFFFFF ]
//
// 같은 (seed, input) 에 대해 항상 같은 out 을 반환해야 함.
fn nd_native_kernel(seed, input) {
    let mut state = seed
    if state <= 0 { state = 1 }
    let mut out = []
    let n = len(input)
    let mut i = 0
    while i < n {
        let x = input[i]
        state = nd_lcg(state ^ x)
        let v = (state ^ x) % ND_FNV_MOD_32
        out = out + [v]
        i = i + 1
    }
    return out
}

// ── nd_bytes_equal — 두 byte 벡터의 정확한 비트-동일성 검사 ──────
fn nd_bytes_equal(a, b) {
    let la = len(a)
    let lb = len(b)
    if la != lb { return false }
    let mut i = 0
    while i < la {
        if a[i] != b[i] { return false }
        i = i + 1
    }
    return true
}

// ── nd_verify_determinism — 동일 (seed, input) 을 2회 실행하여
//    출력 바이트가 비트-동일한지 검증 ─────────────────────────────
fn nd_verify_determinism(seed, input) {
    let out_a = nd_native_kernel(seed, input)
    let out_b = nd_native_kernel(seed, input)
    let bytes_a = nd_ints_to_bytes(out_a)
    let bytes_b = nd_ints_to_bytes(out_b)
    let fp_a = nd_fingerprint_bytes(bytes_a)
    let fp_b = nd_fingerprint_bytes(bytes_b)
    let ok = nd_bytes_equal(bytes_a, bytes_b) && fp_a == fp_b
    return #{
        "ok": ok,
        "fp_a": fp_a,
        "fp_b": fp_b,
        "bytes_a": bytes_a,
        "bytes_b": bytes_b
    }
}

// ── nd_verify_cross_seed — 서로 다른 seed 는 서로 다른 결과 ──────
// 결정성의 반대쪽 가정: seed 가 바뀌면 출력도 달라져야 한다
// (= native_backend 가 seed 를 실제로 반영한다는 sanity check).
fn nd_verify_cross_seed(seed_a, seed_b, input) {
    let out_a = nd_native_kernel(seed_a, input)
    let out_b = nd_native_kernel(seed_b, input)
    let bytes_a = nd_ints_to_bytes(out_a)
    let bytes_b = nd_ints_to_bytes(out_b)
    let differ = !nd_bytes_equal(bytes_a, bytes_b)
    return #{
        "differ": differ,
        "fp_a": nd_fingerprint_bytes(bytes_a),
        "fp_b": nd_fingerprint_bytes(bytes_b)
    }
}
