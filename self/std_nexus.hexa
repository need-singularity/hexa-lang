// self/std_nexus.hexa — HEXA NEXUS ported from src/std_nexus.rs
//
// NEXUS-6 integration for HEXA-LANG.
// The 13th stdlib module (sigma + mu = 12 + 1 = 13).
//
// Provides:
//   nexus_scan(domain)      — Run NEXUS-6 full scan on a domain
//   nexus_verify(value)     — Check if a value matches n=6 constants
//   nexus_omega(phi, tension, cells, entropy, alpha, balance) — Run 6 Omega lenses
//   nexus_lenses()          — List the 6 Omega lens names
//   nexus_consensus(data)   — Compute consensus score across lenses
//   nexus_n6_check(value)   — Quick n=6 constant check

// n=6 constants for verification
struct N6Constant {
    value: float,
    formula: string
}

fn n6_constants() -> [N6Constant] {
    return [
        N6Constant { value: 6.0,   formula: "n" },
        N6Constant { value: 12.0,  formula: "sigma(6)" },
        N6Constant { value: 4.0,   formula: "tau(6)" },
        N6Constant { value: 2.0,   formula: "phi(6)" },
        N6Constant { value: 5.0,   formula: "sopfr(6)" },
        N6Constant { value: 24.0,  formula: "J2(6)" },
        N6Constant { value: 1.0,   formula: "mu(6)" },
        N6Constant { value: 8.0,   formula: "sigma-tau" },
        N6Constant { value: 10.0,  formula: "sigma-phi" },
        N6Constant { value: 48.0,  formula: "sigma*tau" },
        N6Constant { value: 53.0,  formula: "sigma*tau+sopfr" },
        N6Constant { value: 11.0,  formula: "sigma-mu" }
    ]
}

// -- nexus_scan(domain) -> string --

fn nexus_scan(domain) -> string {
    // Delegates to Anima bridge builtin
    return __builtin_nexus_scan(domain)
}

// -- nexus_verify(value) -> string --

fn nexus_verify(value) -> string {
    return __builtin_nexus_verify(value)
}

// -- nexus_omega --

fn nexus_omega(phi, tension, cells, entropy, alpha, balance) -> string {
    return __builtin_nexus_omega(phi, tension, cells, entropy, alpha, balance)
}

// -- nexus_lenses() -> [string] --

fn nexus_lenses() -> [string] {
    return [
        "Topological",
        "Spectral",
        "Information",
        "Categorical",
        "Dynamical",
        "Algebraic"
    ]
}

// -- nexus_consensus(data) -> string --

fn nexus_consensus(data) -> string {
    let constants = n6_constants()
    let matches = 0
    let total = len(data)

    let i = 0
    while i < total {
        let val = data[i] + 0.0
        let j = 0
        while j < len(constants) {
            let diff = val - constants[j].value
            if diff < 0.0 { diff = 0.0 - diff }
            if diff < 0.001 {
                matches = matches + 1
                break
            }
            j = j + 1
        }
        i = i + 1
    }

    let ratio = 0.0
    if total > 0 { ratio = matches / total }

    let signal = "NONE"
    if ratio > 0.7 { signal = "EXACT" }
    else { if ratio > 0.4 { signal = "CLOSE" }
    else { if ratio > 0.1 { signal = "WEAK" } } }

    return "n=6 consensus: " + to_string(matches) + "/" + to_string(total) + " (" + to_string(math_round(ratio * 100.0)) + "%) -- " + signal
}

// -- nexus_n6_check(value) -> string --

fn nexus_n6_check(value) -> string {
    let constants = n6_constants()
    let val = value + 0.0

    // Exact match
    let i = 0
    while i < len(constants) {
        let diff = val - constants[i].value
        if diff < 0.0 { diff = 0.0 - diff }
        if diff < 0.001 {
            return "EXACT: " + to_string(val) + " = " + constants[i].formula
        }
        i = i + 1
    }

    // Find closest
    let closest_idx = 0
    let closest_diff = 999999.0
    i = 0
    while i < len(constants) {
        let diff = val - constants[i].value
        if diff < 0.0 { diff = 0.0 - diff }
        if diff < closest_diff {
            closest_diff = diff
            closest_idx = i
        }
        i = i + 1
    }

    let c = constants[closest_idx]
    let error_pct = closest_diff / c.value * 100.0
    if error_pct < 0.0 { error_pct = 0.0 - error_pct }

    if error_pct < 10.0 {
        return "CLOSE: " + to_string(val) + " ~ " + to_string(c.value) + " = " + c.formula + " (error: " + to_string(math_round(error_pct * 10.0) / 10.0) + "%)"
    }

    return "NONE: " + to_string(val) + " has no n=6 match (nearest: " + to_string(c.value) + " = " + c.formula + ")"
}
