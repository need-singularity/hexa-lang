// verify_interp_builtins.hexa
// Regression test for self/interpreter.hexa 44 builtins
// Covers the 14 new builtins: write_file, read_file, eprintln, assert,
// range, sort, tan, ln, log10, exp, enumerate, .sort(), .repeat(), time, random
// Rule: R9 (골화 = 검증 PASS + 재발 0 + threshold 명시)

use "self/core/law_io"

let mut pass = 0
let mut fail = 0

fn check(name, got, want) {
    if got == want {
        pass = pass + 1
        print("  PASS: " + name)
    } else {
        fail = fail + 1
        print("  FAIL: " + name + " — got " + str(got) + ", want " + str(want))
    }
}

fn check_approx(name, got, want, eps) {
    let diff = got - want
    if diff < 0 { diff = 0 - diff }
    if diff < eps {
        pass = pass + 1
        print("  PASS: " + name)
    } else {
        fail = fail + 1
        print("  FAIL: " + name + " — got " + str(got) + ", want ~" + str(want))
    }
}

// ── write_file + read_file roundtrip ────────────────────
let tmp_path = "/tmp/_hexa_builtin_test.txt"
let tmp_content = "hello from hexa builtins"
safe_write_file(tmp_path, tmp_content)
let readback = read_file(tmp_path)
check("write_file+read_file roundtrip", readback, tmp_content)

// ── eprintln (no crash = pass) ──────────────────────────
eprintln("verify_interp_builtins: eprintln smoke test (ignore this line)")
pass = pass + 1
print("  PASS: eprintln no crash")

// ── assert ──────────────────────────────────────────────
assert(true, "assert(true) should not panic")
pass = pass + 1
print("  PASS: assert(true, msg) does not panic")
// NOTE: assert(false, ...) would panic — intentionally not called

// ── range ───────────────────────────────────────────────
check("range(5)", range(5), [0, 1, 2, 3, 4])
check("range(2,5)", range(2, 5), [2, 3, 4])

// ── sort (free function) ────────────────────────────────
check("sort([3,1,2])", sort([3, 1, 2]), [1, 2, 3])

// ── tan ─────────────────────────────────────────────────
check_approx("tan(0) ~= 0", tan(0), 0.0, 0.0001)

// ── ln / log10 / exp ────────────────────────────────────
check_approx("ln(1) == 0", ln(1), 0.0, 0.0001)
check_approx("exp(0) == 1", exp(0), 1.0, 0.0001)
check_approx("log10(100) == 2", log10(100), 2.0, 0.0001)

// ── enumerate (method on array) ─────────────────────────
check("[1,2,3].enumerate()", [1, 2, 3].enumerate(), [[0, 1], [1, 2], [2, 3]])

// ── .sort() method on array ─────────────────────────────
check("[3,1,2].sort()", [3, 1, 2].sort(), [1, 2, 3])

// ── .repeat() method on string ──────────────────────────
check("\"abc\".repeat(3)", "abc".repeat(3), "abcabcabc")

// ── time() returns positive int ─────────────────────────
let t = time()
if t > 0 {
    pass = pass + 1
    print("  PASS: time() > 0 (got " + str(t) + ")")
} else {
    fail = fail + 1
    print("  FAIL: time() should be > 0, got " + str(t))
}

// ── random() returns 0..1 ───────────────────────────────
let r = random()
if r >= 0.0 && r < 1.0 {
    pass = pass + 1
    print("  PASS: random() in [0,1) (got " + str(r) + ")")
} else {
    fail = fail + 1
    print("  FAIL: random() should be in [0,1), got " + str(r))
}

// ── Summary ─────────────────────────────────────────────
print("")
print("verify_interp_builtins: " + str(pass) + " PASS, " + str(fail) + " FAIL")
if fail == 0 {
    print("verdict: ALL PASS")
} else {
    print("verdict: " + str(fail) + " FAILURES")
}
