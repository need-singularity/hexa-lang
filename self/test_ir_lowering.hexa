let f42b = lr42[0]
let env42b = lr42[1]
// x = 1
let r42one = lower_int_lit(f42b, expr_int(1))
let f42c = r42one[0]
let v42one = r42one[1]
let slot42 = env_lookup(env42b, "x")
let f42d_instrs = f42c.instrs.push(Instr { op: "store", ty: "void", a: slot42, b: v42one, imm: 0, is_imm: false })
let f42d = Func { name: f42c.name, ret_type: f42c.ret_type, instrs: f42d_instrs, next_vid: f42c.next_vid }
// x = 2
