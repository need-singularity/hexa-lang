let f42e = r42two[0]
let v42two = r42two[1]
let f42f_instrs = f42e.instrs.push(Instr { op: "store", ty: "void", a: slot42, b: v42two, imm: 0, is_imm: false })
let f42f = Func { name: f42e.name, ret_type: f42e.ret_type, instrs: f42f_instrs, next_vid: f42e.next_vid }
// read x
let r42r = lower_ident_read(f42f, env42b, "x", "i64")
let f42g = r42r[0]
let v42r = r42r[1]
let f42h = lower_return(f42g, v42r)
check_ops("T42 triple mut reassign",
    collect_opcodes(f42h),
    ["load", "alloc", "store", "load", "store", "load", "store", "load", "ret"])

// T43: Deep nested arithmetic — ((a+b)*c)-d → load×4, add, mul, sub, ret.
