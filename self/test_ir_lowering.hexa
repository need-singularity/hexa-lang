let r61a = lower_bool_lit(f61, expr_bool(true))
let f61a = r61a[0]
let v61a = r61a[1]
let r61b = lower_bool_lit(f61a, expr_bool(false))
let f61b = r61b[0]
let v61b = r61b[1]
