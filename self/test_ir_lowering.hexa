let f54a = r54[0]
let v54 = r54[1]
let f54b = lower_return(f54a, v54)
check_ops("T54 ArrayLit []", collect_opcodes(f54b), ["alloc", "ret"])

// T55: neg on call result — call f(3), then neg on result.
let f55 = lower_fn_decl("neg_call", "i64")
let r55a = lower_int_lit(f55, expr_int(3))
let f55a = r55a[0]
let v55arg = r55a[1]
let r55c = lower_call(f55a, 42, 1, "i64")
let f55b = r55c[0]
let v55call = r55c[1]
let r55n = lower_unary(f55b, "neg", v55call, "i64")
let f55c = r55n[0]
let v55n = r55n[1]
let f55d = lower_return(f55c, v55n)
check_ops("T55 neg on call result",
    collect_opcodes(f55d),
    ["load", "call", "neg", "ret"])

// T56: Chained comparison via mul — (a < b) * (b < c) — shares middle vid.
let f56 = lower_fn_decl("chain_cmp", "bool")
let r56a = lower_int_lit(f56, expr_int(1))
let f56a = r56a[0]
let va56 = r56a[1]
let r56b = lower_int_lit(f56a, expr_int(2))
let f56b = r56b[0]
let vb56 = r56b[1]
let r56c = lower_int_lit(f56b, expr_int(3))
let f56c = r56c[0]
let vc56 = r56c[1]
let r56ab = lower_cmp(f56c, "lt", va56, vb56)
let f56d = r56ab[0]
let vab56 = r56ab[1]
let r56bc = lower_cmp(f56d, "lt", vb56, vc56)
let f56e = r56bc[0]
let vbc56 = r56bc[1]
let r56m = lower_binop(f56e, "mul", vab56, vbc56, "bool")
let f56f = r56m[0]
let vm56 = r56m[1]
let f56g = lower_return(f56f, vm56)
check_ops("T56 chained cmp (a<b)*(b<c)",
    collect_opcodes(f56g),
    ["load", "load", "load", "sub", "sub", "mul", "ret"])

// T57: Array-assign via store — `arr[i] = x` lowers to store(arr, x, imm=i).
let f57 = lower_fn_decl("arr_assign", "void")
let r57a = func_emit(f57, mk_instr("alloc", "ptr"))
let f57a = r57a[0]
let v57arr = r57a[1]
let r57x = lower_int_lit(f57a, expr_int(99))
let f57b = r57x[0]
let v57x = r57x[1]
let store_instr = Instr { op: "store", ty: "i64", a: v57arr, b: v57x, imm: 2, is_imm: true }
let f57c_instrs = f57b.instrs.push(store_instr)
let f57c = Func { name: f57b.name, ret_type: f57b.ret_type, instrs: f57c_instrs, next_vid: f57b.next_vid }
let f57d = lower_return(f57c, -1)
check_ops("T57 arr[i]=x store",
    collect_opcodes(f57d),
    ["alloc", "load", "store", "ret"])

// T58: bitnot on ident read — immutable ident passes through, then bitnot.
let f58 = lower_fn_decl("bitnot_id", "i64")
let env58 = mk_env()
let r58a = lower_int_lit(f58, expr_int(7))
let f58a = r58a[0]
let v58 = r58a[1]
let env58b = env_bind(env58, "z", v58, false)
let r58r = lower_ident_read(f58a, env58b, "z", "i64")
let f58b = r58r[0]
let v58r = r58r[1]
let r58n = lower_unary(f58b, "bitnot", v58r, "i64")
let f58c = r58n[0]
let v58bn = r58n[1]
let f58d = lower_return(f58c, v58bn)
// bitnot expands to load(-1) + sub, so: load(7), load(-1), sub, ret
check_ops("T58 bitnot on immutable ident",
    collect_opcodes(f58d),
    ["load", "load", "sub", "ret"])

// ── T59-T64: Phase 7 — 6 more AST node shapes ──────────────

// T59: String concat `"a" + "b"` → load, load, add, ret.
