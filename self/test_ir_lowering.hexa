check_int("T66 rhs true imm=1", f66d.instrs[1].imm, 1)

// T67: return inside while body — header+branch, load, ret (no jump back).
let f67 = lower_fn_decl("early_ret", "i64")
let r67w = lower_while_skeleton(f67, 0)
let f67a = r67w[0]
let hdr67 = r67w[1]
let end67 = r67w[2]
let r67c = lower_int_lit(f67a, expr_int(1))
let f67b = r67c[0]
let v67c = r67c[1]
let f67d = emit_branch_if_false(f67b, v67c, end67)
let r67v = lower_int_lit(f67d, expr_int(42))
let f67e = r67v[0]
let v67v = r67v[1]
let f67f = lower_return_stmt(f67e, v67v)
check_ops("T67 return inside while",
    collect_opcodes(f67f),
    ["label", "load", "branch", "load", "ret"])

// T68: Deep if-else-if chain — nested 2-level if-expr producing nested phi.
let f68 = lower_fn_decl("chain_if", "i64")
let r68c = lower_int_lit(f68, expr_int(1))
let f68a = r68c[0]
let v68c = r68c[1]
let ie68 = lower_if_expr_skeleton(f68a, v68c, 0)
let f68b = ie68[0]
let else68 = ie68[1]
let end68 = ie68[2]
let ctr68 = ie68[3]
// outer then: load 10, jump end
let r68t = lower_int_lit(f68b, expr_int(10))
let f68c = r68t[0]
let v68t = r68t[1]
let f68d = emit_jump(f68c, end68)
// outer else label → nested if
let f68e = emit_label(f68d, else68)
let r68c2 = lower_int_lit(f68e, expr_int(0))
let f68f = r68c2[0]
let v68c2 = r68c2[1]
let ie68b = lower_if_expr_skeleton(f68f, v68c2, ctr68)
let f68g = ie68b[0]
let else68b = ie68b[1]
let end68b = ie68b[2]
// inner then: load 20, jump inner end
let r68t2 = lower_int_lit(f68g, expr_int(20))
let f68h = r68t2[0]
let v68t2 = r68t2[1]
let f68i = emit_jump(f68h, end68b)
// inner else: load 30, jump inner end
let f68j = emit_label(f68i, else68b)
let r68e = lower_int_lit(f68j, expr_int(30))
let f68k = r68e[0]
let v68e = r68e[1]
let f68l = emit_jump(f68k, end68b)
// inner end label + phi
let f68m = emit_label(f68l, end68b)
let phi68b = lower_if_expr_close(f68m, v68t2, v68e, "i64")
let f68n = phi68b[0]
let v68phib = phi68b[1]
let f68o = emit_jump(f68n, end68)
// outer end label + outer phi
let f68p = emit_label(f68o, end68)
let phi68 = lower_if_expr_close(f68p, v68t, v68phib, "i64")
let f68q = phi68[0]
let v68phi = phi68[1]
let f68r = lower_return_stmt(f68q, v68phi)
check_ops("T68 if-else-if chain nested phi",
    collect_opcodes(f68r),
    ["load", "branch", "load", "jump", "label", "load", "branch",
     "load", "jump", "label", "load", "jump", "label", "phi", "jump",
     "label", "phi", "ret"])

// T69: Range `0..10` — modeled as 2 int loads (start, end) with no op.
let f69 = lower_fn_decl("mk_range", "i64")
let r69s = lower_int_lit(f69, expr_int(0))
let f69a = r69s[0]
let v69s = r69s[1]
let r69e = lower_int_lit(f69a, expr_int(10))
let f69b = r69e[0]
let v69e = r69e[1]
let f69c = lower_return(f69b, v69e)
check_ops("T69 Range 0..10 as 2 loads",
