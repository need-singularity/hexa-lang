let f92f = r92f[0]
let v92f = r92f[1]
let r92g = lower_int_lit(f92f, expr_int(7))
let f92g = r92g[0]
let v92g = r92g[1]
let r92h = lower_int_lit(f92g, expr_int(8))
let f92h = r92h[0]
let v92h = r92h[1]
let r92arr = lower_array_lit(f92h,
    [v92a, v92b, v92c, v92d, v92e, v92f, v92g, v92h], "i64")
let f92i = r92arr[0]
let v92arr = r92arr[1]
let f92j = lower_return(f92i, v92arr)
