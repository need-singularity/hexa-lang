check_ops("T90 MOD op a%b",
    collect_opcodes(f90d),
    ["load", "load", "mod", "ret"])
check_str("T90 mod ty", f90d.instrs[2].op, "mod")

// T91: nested call — f(g(x)). Inner call result feeds outer call's single arg.
let f91 = lower_fn_decl("nested_call", "i64")
let r91x = lower_int_lit(f91, expr_int(5))
let f91a = r91x[0]
let v91x = r91x[1]
// inner: g(x) — arg already materialized (v91x load), then call(g, 1)
let r91g = lower_call(f91a, 1, 1, "i64")
let f91b = r91g[0]
let v91g = r91g[1]
// outer: f(g_result) — call(f, 2, 1)
let r91f = lower_call(f91b, 2, 1, "i64")
let f91c = r91f[0]
let v91f = r91f[1]
let f91d = lower_return(f91c, v91f)
check_ops("T91 nested call f(g(x))",
    collect_opcodes(f91d),
    ["load", "call", "call", "ret"])

// T92: array literal with 8 elements.
let f92 = lower_fn_decl("arr8", "array")
let r92a = lower_int_lit(f92, expr_int(1))
let f92a = r92a[0]
let v92a = r92a[1]
let r92b = lower_int_lit(f92a, expr_int(2))
