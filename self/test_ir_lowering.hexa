let lr41a = lower_let(f41a, env41, "a", va41, false, "i64")
let f41b = lr41a[0]
let env41a = lr41a[1]
let r41b = lower_int_lit(f41b, expr_int(2))
let f41c = r41b[0]
let vb41 = r41b[1]
let lr41b = lower_let(f41c, env41a, "b", vb41, false, "i64")
let f41d = lr41b[0]
let env41b = lr41b[1]
let r41c = lower_int_lit(f41d, expr_int(3))
let f41e = r41c[0]
let vc41 = r41c[1]
let lr41c = lower_let(f41e, env41b, "c", vc41, false, "i64")
let f41f = lr41c[0]
let env41c = lr41c[1]
// a + b
let r41ab = lower_binop(f41f, "add", env_lookup(env41c, "a"), env_lookup(env41c, "b"), "i64")
let f41g = r41ab[0]
let vab41 = r41ab[1]
// (a+b) + c
let r41abc = lower_binop(f41g, "add", vab41, env_lookup(env41c, "c"), "i64")
let f41h = r41abc[0]
let vabc41 = r41abc[1]
let f41i = lower_return(f41h, vabc41)
check_ops("T41 three immutable lets + add",
    collect_opcodes(f41i),
    ["load", "load", "load", "add", "add", "ret"])

// T42: Mut reassign multiple times — 3 stores to same slot.
//   let mut x = 0; x = 1; x = 2; return x
let f42 = lower_fn_decl("triple_asn", "i64")
let env42 = mk_env()
let r42z = lower_int_lit(f42, expr_int(0))
let f42a = r42z[0]
let v42z = r42z[1]
