    collect_opcodes(f93d),
    ["load", "call", "neg", "ret"])

// T94: long arithmetic — a + b + c + d (left-associative chain).
let f94 = lower_fn_decl("long_add", "i64")
let r94a = lower_int_lit(f94, expr_int(1))
let f94a = r94a[0]
let v94a = r94a[1]
let r94b = lower_int_lit(f94a, expr_int(2))
let f94b = r94b[0]
let v94b = r94b[1]
let r94ab = lower_binop(f94b, "add", v94a, v94b, "i64")
let f94c = r94ab[0]
let v94ab = r94ab[1]
let r94c = lower_int_lit(f94c, expr_int(3))
let f94d = r94c[0]
let v94c = r94c[1]
let r94abc = lower_binop(f94d, "add", v94ab, v94c, "i64")
let f94e = r94abc[0]
let v94abc = r94abc[1]
let r94d = lower_int_lit(f94e, expr_int(4))
let f94f = r94d[0]
let v94d = r94d[1]
let r94abcd = lower_binop(f94f, "add", v94abc, v94d, "i64")
let f94g = r94abcd[0]
let v94abcd = r94abcd[1]
let f94h = lower_return(f94g, v94abcd)
check_ops("T94 long arithmetic a+b+c+d",
    collect_opcodes(f94h),
    ["load", "load", "add", "load", "add", "load", "add", "ret"])

// ── Summary ─────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  lowering tests: " + to_string(pass_count) + " pass, " + to_string(fail_count) + " fail")
println("═══════════════════════════════════════════════════════")
if fail_count > 0 {
    println("FAIL")
} else {
    println("ALL PASS")
}
