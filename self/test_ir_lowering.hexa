// T50: Chained field access — obj.x.y → alloc, load(x), load(y), ret.
let f50 = lower_fn_decl("get_xy", "i64")
let r50a = func_emit(f50, mk_instr("alloc", "ptr"))
let f50a = r50a[0]
let v50obj = r50a[1]
let r50x = lower_field(f50a, v50obj, 0, "ptr")
let f50b = r50x[0]
let v50x = r50x[1]
let r50y = lower_field(f50b, v50x, 1, "i64")
let f50c = r50y[0]
let v50y = r50y[1]
let f50d = lower_return(f50c, v50y)
