// T74: Long chain `a + b * c - d / e` — 5 loads + mul + div + add + sub.
let f74 = lower_fn_decl("long_chain", "i64")
let r74a = lower_int_lit(f74, expr_int(10))
let f74a = r74a[0]
let va = r74a[1]
let r74b = lower_int_lit(f74a, expr_int(2))
let f74b = r74b[0]
let vb = r74b[1]
let r74c = lower_int_lit(f74b, expr_int(3))
let f74c = r74c[0]
let vc = r74c[1]
let r74d = lower_int_lit(f74c, expr_int(8))
let f74d = r74d[0]
let vd = r74d[1]
let r74e = lower_int_lit(f74d, expr_int(4))
let f74e = r74e[0]
let ve = r74e[1]
// b * c
let r74m = lower_binop(f74e, "mul", vb, vc, "i64")
let f74f = r74m[0]
let vbc = r74m[1]
// d / e
let r74dv = lower_binop(f74f, "div", vd, ve, "i64")
let f74g = r74dv[0]
let vde = r74dv[1]
// a + (b*c)
let r74ad = lower_binop(f74g, "add", va, vbc, "i64")
let f74h = r74ad[0]
let vabc = r74ad[1]
// (a+b*c) - (d/e)
let r74sb = lower_binop(f74h, "sub", vabc, vde, "i64")
let f74i = r74sb[0]
let vfin = r74sb[1]
let f74j = lower_return(f74i, vfin)
check_ops("T74 a+b*c-d/e chain",
    collect_opcodes(f74j),
    ["load", "load", "load", "load", "load", "mul", "div", "add", "sub", "ret"])

// T75: arr[i] in condition — index load feeds branch_if_false.
let f75 = lower_fn_decl("cond_idx", "i64")
let r75arr = func_emit(f75, mk_instr("alloc", "ptr"))
let f75a = r75arr[0]
let v75arr = r75arr[1]
let r75i = lower_int_lit(f75a, expr_int(0))
let f75b = r75i[0]
let v75i = r75i[1]
let r75ix = lower_index(f75b, v75arr, v75i, "i64")
let f75c = r75ix[0]
let v75ix = r75ix[1]
let ifs75 = lower_if_skeleton(f75c, v75ix, 0)
let f75d = ifs75[0]
let else75 = ifs75[1]
let end75 = ifs75[2]
let r75ret = lower_int_lit(f75d, expr_int(1))
let f75e = r75ret[0]
let v75r = r75ret[1]
let f75f = emit_jump(f75e, end75)
let f75g = emit_label(f75f, else75)
let f75h = emit_label(f75g, end75)
let f75i = lower_return_stmt(f75h, v75r)
check_ops("T75 arr[i] in if-cond",
    collect_opcodes(f75i),
    ["alloc", "load", "load", "branch", "load", "jump", "label", "label", "ret"])

// T76: Bitnot applied to expr `~x` — load + bitnot + ret.
let f76 = lower_fn_decl("bitnot_expr", "i64")
let r76a = lower_int_lit(f76, expr_int(15))
let f76a = r76a[0]
let v76a = r76a[1]
let r76b = lower_unary(f76a, "bitnot", v76a, "i64")
let f76b = r76b[0]
let v76b = r76b[1]
let f76c = lower_return(f76b, v76b)
check_ops("T76 bitnot ~x as (-1)-x",
    collect_opcodes(f76c),
    ["load", "load", "sub", "ret"])
check_int("T76 bitnot neg-one imm=-1", f76c.instrs[1].imm, -1)

// ── T77-T82: Phase 10 — 6 more AST node shapes ──────────────

// T77: FieldAssign `obj.x = 5` — alloc obj, load 5, store to field slot.
let f77 = lower_fn_decl("set_x", "i64")
let r77o = func_emit(f77, mk_instr("alloc", "ptr"))
let f77a = r77o[0]
let v77o = r77o[1]
let r77v = lower_int_lit(f77a, expr_int(5))
let f77b = r77v[0]
let v77v = r77v[1]
// store field_idx=0 (x) ← v77v
let f77c_instrs = f77b.instrs.push(Instr { op: "store", ty: "void", a: v77o, b: v77v, imm: 0, is_imm: false })
let f77c = Func { name: f77b.name, ret_type: f77b.ret_type, instrs: f77c_instrs, next_vid: f77b.next_vid }
let f77d = lower_return(f77c, v77v)
check_ops("T77 FieldAssign obj.x = 5",
    collect_opcodes(f77d),
    ["alloc", "load", "store", "ret"])
check_int("T77 store imm=0 (x field)", f77d.instrs[2].imm, 0)

// T78: Deep nested call `f(g(h(x)))` — 3 chained calls.
let f78 = lower_fn_decl("deep_nest", "i64")
let r78x = lower_int_lit(f78, expr_int(7))
let f78a = r78x[0]
let v78x = r78x[1]
let r78h = lower_call(f78a, 0, 1, "i64")   // h(x)
let f78b = r78h[0]
let v78h = r78h[1]
let r78g = lower_call(f78b, 1, 1, "i64")   // g(h_result)
let f78c = r78g[0]
let v78g = r78g[1]
let r78f = lower_call(f78c, 2, 1, "i64")   // f(g_result)
let f78d = r78f[0]
let v78f = r78f[1]
let f78e = lower_return(f78d, v78f)
check_ops("T78 deep nested call f(g(h(x)))",
    collect_opcodes(f78e),
    ["load", "call", "call", "call", "ret"])

// T79: StringLit with escape chars — still a single load with ty=str.
let f79 = lower_fn_decl("esc_str", "str")
let r79 = lower_string_lit(f79, expr_string("hi\\n\\t\\\""))
let f79a = r79[0]
let v79 = r79[1]
let f79b = lower_return(f79a, v79)
check_ops("T79 StringLit with escapes",
    collect_opcodes(f79b),
    ["load", "ret"])
check_str("T79 ty=str", f79b.instrs[0].ty, "str")

// T80: if-else-if with inner if nested in else branch's then — simpler 2-level
//   if c1 { return 10 } else { if c2 { return 20 } else { return 30 } }
let f80 = lower_fn_decl("if_in_else", "i64")
let r80c1 = lower_int_lit(f80, expr_int(1))
let f80a = r80c1[0]
let v80c1 = r80c1[1]
let if80 = lower_if_skeleton(f80a, v80c1, 0)
let f80b = if80[0]
let else80 = if80[1]
let end80 = if80[2]
// then: load 10, ret
let r80t = lower_int_lit(f80b, expr_int(10))
let f80c = r80t[0]
let v80t = r80t[1]
let f80d = lower_return(f80c, v80t)
// else label + nested if
let f80e = emit_label(f80d, else80)
let r80c2 = lower_int_lit(f80e, expr_int(1))
let f80f = r80c2[0]
let v80c2 = r80c2[1]
let if80b = lower_if_skeleton(f80f, v80c2, 10)
let f80g = if80b[0]
let else80b = if80b[1]
let end80b = if80b[2]
let r80t2 = lower_int_lit(f80g, expr_int(20))
let f80h = r80t2[0]
let v80t2 = r80t2[1]
let f80i = lower_return(f80h, v80t2)
let f80j = emit_label(f80i, else80b)
let r80e2 = lower_int_lit(f80j, expr_int(30))
let f80k = r80e2[0]
let v80e2 = r80e2[1]
let f80l = lower_return(f80k, v80e2)
let f80m = emit_label(f80l, end80b)
let f80n = emit_label(f80m, end80)
check_ops("T80 if-in-else nested",
    collect_opcodes(f80n),
    ["load", "branch", "load", "ret",
     "label", "load", "branch", "load", "ret",
     "label", "load", "ret", "label", "label"])

// T81: While body with 3 statements (two mut vars updated).
//   let mut a = 0; let mut b = 0
//   while a < 5 { a = a + 1; b = b + 2 }
let f81 = lower_fn_decl("two_muts", "i64")
let env81 = mk_env()
let r81a0 = lower_int_lit(f81, expr_int(0))
let f81a = r81a0[0]
let v81a0 = r81a0[1]
let la81 = lower_let(f81a, env81, "a", v81a0, true, "i64")
let f81b = la81[0]
let env81b = la81[1]
let r81b0 = lower_int_lit(f81b, expr_int(0))
let f81c = r81b0[0]
let v81b0 = r81b0[1]
let lb81 = lower_let(f81c, env81b, "b", v81b0, true, "i64")
let f81d = lb81[0]
let env81c = lb81[1]
let r81w = lower_while_skeleton(f81d, 0)
let f81e = r81w[0]
let hdr81 = r81w[1]
let end81 = r81w[2]
// header: load(a), load(5), cmp_lt, branch
let r81ra = lower_ident_read(f81e, env81c, "a", "i64")
let f81f = r81ra[0]
let v81ra = r81ra[1]
let r81five = lower_int_lit(f81f, expr_int(5))
let f81g = r81five[0]
let v81five = r81five[1]
let r81lt = lower_cmp(f81g, "lt", v81ra, v81five)
let f81h = r81lt[0]
let v81lt = r81lt[1]
let f81i = emit_branch_if_false(f81h, v81lt, end81)
// body stmt 1: a = a + 1
let r81ra2 = lower_ident_read(f81i, env81c, "a", "i64")
let f81j = r81ra2[0]
let v81ra2 = r81ra2[1]
let r81one = lower_int_lit(f81j, expr_int(1))
let f81k = r81one[0]
let v81one = r81one[1]
let r81add_a = lower_binop(f81k, "add", v81ra2, v81one, "i64")
let f81l = r81add_a[0]
let v81add_a = r81add_a[1]
let slot81a = env_lookup(env81c, "a")
let f81m_instrs = f81l.instrs.push(Instr { op: "store", ty: "void", a: slot81a, b: v81add_a, imm: 0, is_imm: false })
let f81m = Func { name: f81l.name, ret_type: f81l.ret_type, instrs: f81m_instrs, next_vid: f81l.next_vid }
// body stmt 2: b = b + 2
let r81rb = lower_ident_read(f81m, env81c, "b", "i64")
let f81n = r81rb[0]
let v81rb = r81rb[1]
let r81two = lower_int_lit(f81n, expr_int(2))
let f81o = r81two[0]
let v81two = r81two[1]
let r81add_b = lower_binop(f81o, "add", v81rb, v81two, "i64")
let f81p = r81add_b[0]
let v81add_b = r81add_b[1]
let slot81b = env_lookup(env81c, "b")
let f81q_instrs = f81p.instrs.push(Instr { op: "store", ty: "void", a: slot81b, b: v81add_b, imm: 0, is_imm: false })
let f81q = Func { name: f81p.name, ret_type: f81p.ret_type, instrs: f81q_instrs, next_vid: f81p.next_vid }
let f81r = emit_jump(f81q, hdr81)
let f81s = emit_label(f81r, end81)
let f81t = lower_return_stmt(f81s, v81a0)
check_ops("T81 while 3-stmt body two muts",
    collect_opcodes(f81t),
    ["load", "alloc", "store",
     "load", "alloc", "store",
     "label",
     "load", "load", "sub", "branch",
     "load", "load", "add", "store",
     "load", "load", "add", "store",
     "jump", "label", "ret"])

// T82: Array index in call arg — `f(arr[0])`.
let f82 = lower_fn_decl("call_idx_arg", "i64")
let r82arr = func_emit(f82, mk_instr("alloc", "ptr"))
let f82a = r82arr[0]
let v82arr = r82arr[1]
let r82i = lower_int_lit(f82a, expr_int(0))
let f82b = r82i[0]
let v82i = r82i[1]
let r82ix = lower_index(f82b, v82arr, v82i, "i64")
let f82c = r82ix[0]
let v82ix = r82ix[1]
let r82c = lower_call(f82c, 0, 1, "i64")
let f82d = r82c[0]
let v82c = r82c[1]
let f82e = lower_return(f82d, v82c)
check_ops("T82 call with arr[i] arg",
    collect_opcodes(f82e),
    ["alloc", "load", "load", "call", "ret"])

// ── T83-T88: Phase 11 — 6 more AST node shapes ──────────────

// T83: break from outermost of 3 nested loops — break targets outer end.
//   while c1 { while c2 { while c3 { break_to_outermost } } }
// We only need to verify break emits a jump to the outermost end label.
let f83 = lower_fn_decl("break_outer3", "i64")
let r83w1 = lower_while_skeleton(f83, 0)
let f83a = r83w1[0]
let hdr83a = r83w1[1]
let end83a = r83w1[2]
let r83w2 = lower_while_skeleton(f83a, 10)
let f83b = r83w2[0]
let hdr83b = r83w2[1]
let end83b = r83w2[2]
let r83w3 = lower_while_skeleton(f83b, 20)
let f83c = r83w3[0]
let hdr83c = r83w3[1]
let end83c = r83w3[2]
// break to outermost (end83a)
let ctx83_outer = loop_ctx(hdr83a, end83a)
let f83d = lower_break(f83c, ctx83_outer)
let f83e = emit_label(f83d, end83c)
let f83f = emit_label(f83e, end83b)
let f83g = emit_label(f83f, end83a)
let r83r = lower_int_lit(f83g, expr_int(0))
let f83h = r83r[0]
let v83r = r83r[1]
let f83i = lower_return_stmt(f83h, v83r)
check_ops("T83 break from outermost of 3 nested loops",
    collect_opcodes(f83i),
    ["label", "label", "label",
     "jump",
     "label", "label", "label",
     "load", "ret"])

// T84: continue inside nested if — continue jumps to loop header unconditionally
//   while c { if x { continue } }
let f84 = lower_fn_decl("cont_in_if", "i64")
let r84w = lower_while_skeleton(f84, 0)
let f84a = r84w[0]
let hdr84 = r84w[1]
let end84 = r84w[2]
let r84c = lower_int_lit(f84a, expr_int(1))
let f84b = r84c[0]
let v84c = r84c[1]
let f84c = emit_branch_if_false(f84b, v84c, end84)
// nested if
let r84x = lower_int_lit(f84c, expr_int(1))
let f84d = r84x[0]
let v84x = r84x[1]
let if84 = lower_if_skeleton(f84d, v84x, 10)
let f84e = if84[0]
let else84 = if84[1]
let end_if84 = if84[2]
// then: continue
let ctx84 = loop_ctx(hdr84, end84)
let f84f = lower_continue(f84e, ctx84)
let f84g = emit_label(f84f, else84)
let f84h = emit_label(f84g, end_if84)
let f84i = emit_jump(f84h, hdr84)
let f84j = emit_label(f84i, end84)
let f84k = lower_return_stmt(f84j, v84c)
check_ops("T84 continue inside nested if",
    collect_opcodes(f84k),
    ["label",
     "load", "branch",
     "load", "branch",
     "jump",
     "label", "label",
     "jump",
     "label", "ret"])

// T85: return from inner loop — return emits ret inside the loop body.
//   while c { return 42 }
let f85 = lower_fn_decl("ret_inner", "i64")
let r85w = lower_while_skeleton(f85, 0)
let f85a = r85w[0]
let hdr85 = r85w[1]
let end85 = r85w[2]
let r85c = lower_int_lit(f85a, expr_int(1))
let f85b = r85c[0]
let v85c = r85c[1]
let f85c = emit_branch_if_false(f85b, v85c, end85)
// body: return 42
let r85v = lower_int_lit(f85c, expr_int(42))
let f85d = r85v[0]
let v85v = r85v[1]
let f85e = lower_return_stmt(f85d, v85v)
let f85f = emit_label(f85e, end85)
let f85g = lower_return_stmt(f85f, v85c)
check_ops("T85 return from inner loop",
    collect_opcodes(f85g),
    ["label",
     "load", "branch",
     "load", "ret",
     "label", "ret"])

// T86: array literal with 5 elements.
let f86 = lower_fn_decl("arr5", "array")
let r86a = lower_int_lit(f86, expr_int(1))
let f86a = r86a[0]
let v86a = r86a[1]
let r86b = lower_int_lit(f86a, expr_int(2))
let f86b = r86b[0]
let v86b = r86b[1]
let r86c = lower_int_lit(f86b, expr_int(3))
let f86c = r86c[0]
let v86c = r86c[1]
let r86d = lower_int_lit(f86c, expr_int(4))
let f86d = r86d[0]
let v86d = r86d[1]
let r86e = lower_int_lit(f86d, expr_int(5))
let f86e = r86e[0]
let v86e = r86e[1]
let r86arr = lower_array_lit(f86e, [v86a, v86b, v86c, v86d, v86e], "i64")
let f86f = r86arr[0]
let v86arr = r86arr[1]
let f86g = lower_return(f86f, v86arr)
check_ops("T86 ArrayLit [1,2,3,4,5]",
    collect_opcodes(f86g),
    ["load", "load", "load", "load", "load",
     "alloc",
     "store", "store", "store", "store", "store",
     "ret"])

// T87: boolean expr in return — `return a < b`
let f87 = lower_fn_decl("ret_bool", "bool")
let r87a = lower_int_lit(f87, expr_int(3))
let f87a = r87a[0]
let v87a = r87a[1]
let r87b = lower_int_lit(f87a, expr_int(5))
let f87b = r87b[0]
let v87b = r87b[1]
let r87lt = lower_cmp(f87b, "lt", v87a, v87b)
let f87c = r87lt[0]
let v87lt = r87lt[1]
let f87d = lower_return(f87c, v87lt)
check_ops("T87 return bool expr a<b",
    collect_opcodes(f87d),
    ["load", "load", "sub", "ret"])

// T88: shadowed `let mut` — two distinct slots + stores for name `x`.
//   let mut x = 1; { let mut x = 2; use(x) }
let f88 = lower_fn_decl("shadow_mut_x", "i64")
let env88 = mk_env()
let r88a = lower_int_lit(f88, expr_int(1))
let f88a = r88a[0]
let v88a = r88a[1]
let l88a = lower_let(f88a, env88, "x", v88a, true, "i64")
let f88b = l88a[0]
let env88b = l88a[1]
let r88c = lower_int_lit(f88b, expr_int(2))
let f88c = r88c[0]
let v88c = r88c[1]
let l88b = lower_let(f88c, env88b, "x", v88c, true, "i64")
let f88d = l88b[0]
let env88c = l88b[1]
let r88r = lower_ident_read(f88d, env88c, "x", "i64")
let f88e = r88r[0]
let v88r = r88r[1]
let f88f = lower_return(f88e, v88r)
check_ops("T88 shadowed let mut inside inner block",
    collect_opcodes(f88f),
    ["load", "alloc", "store",
     "load", "alloc", "store",
     "load", "ret"])

// ── T89-T94: Phase 12 — 6 more AST node shapes ──────────────

// T89: multiply by constant 0 — `x * 0`.
let f89 = lower_fn_decl("mul_zero", "i64")
let r89a = lower_int_lit(f89, expr_int(7))
let f89a = r89a[0]
let v89a = r89a[1]
let r89b = lower_int_lit(f89a, expr_int(0))
let f89b = r89b[0]
let v89b = r89b[1]
let r89m = lower_binop(f89b, "mul", v89a, v89b, "i64")
let f89c = r89m[0]
let v89m = r89m[1]
let f89d = lower_return(f89c, v89m)
check_ops("T89 multiply by 0",
    collect_opcodes(f89d),
    ["load", "load", "mul", "ret"])

// T90: MOD operation — `a % b` (AST "rem" → IR "mod").
let f90 = lower_fn_decl("mod_op", "i64")
let r90a = lower_int_lit(f90, expr_int(10))
let f90a = r90a[0]
let v90a = r90a[1]
let r90b = lower_int_lit(f90a, expr_int(3))
let f90b = r90b[0]
let v90b = r90b[1]
let r90m = lower_binop(f90b, "rem", v90a, v90b, "i64")
let f90c = r90m[0]
let v90m = r90m[1]
