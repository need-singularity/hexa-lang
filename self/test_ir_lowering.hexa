// T46: Comparison — lt then gt on same operands, combined with and-ish sequencing.
// (a < b) returns one vid; (a > b) returns another. Both share the same loads.
let f46 = lower_fn_decl("cmp_pair", "bool")
let r46a = lower_int_lit(f46, expr_int(3))
let f46a = r46a[0]
let va46 = r46a[1]
let r46b = lower_int_lit(f46a, expr_int(5))
let f46b = r46b[0]
let vb46 = r46b[1]
let r46lt = lower_cmp(f46b, "lt", va46, vb46)
let f46c = r46lt[0]
let vlt = r46lt[1]
let r46gt = lower_cmp(f46c, "gt", va46, vb46)
let f46d = r46gt[0]
let vgt = r46gt[1]
// Return both via mul (bool*bool acts as and in this harness).
let r46and = lower_binop(f46d, "mul", vlt, vgt, "bool")
let f46e = r46and[0]
let vand = r46and[1]
let f46f = lower_return(f46e, vand)
check_ops("T46 cmp lt + gt chain",
    collect_opcodes(f46f),
    ["load", "load", "sub", "sub", "mul", "ret"])
check_int("T46 lt code", f46f.instrs[2].imm, 3)
check_int("T46 gt code", f46f.instrs[3].imm, 5)

// ── T47-T52: Phase 5 — 6 more AST node shapes ──────────────

