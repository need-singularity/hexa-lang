let f40b = ms40[0]
let arms40 = ms40[1]
let default40 = ms40[2]
let end40 = ms40[3]
// arm 0
let f40c = emit_label(f40b, arms40[0])
let r40a0 = lower_int_lit(f40c, expr_int(100))
let f40d = r40a0[0]
let f40e = emit_jump(f40d, end40)
// default
let f40f = emit_label(f40e, default40)
let r40d = lower_int_lit(f40f, expr_int(0))
let f40g = r40d[0]
let f40h = emit_jump(f40g, end40)
let f40i = emit_label(f40h, end40)
let f40j = lower_return(f40i, v40s)
check_ops("T40 MatchExpr 1 arm + default",
    collect_opcodes(f40j),
    ["load", "switch",
     "label", "load", "jump",
     "label", "load", "jump",
     "label", "ret"])
check_int("T40 switch case count", f40j.instrs[1].b, 1)

// T41: Multiple immutable lets (SSA chain, no new instrs from binds).
//   let a = 1; let b = 2; let c = 3; return a + b + c
let f41 = lower_fn_decl("three_lets", "i64")
let env41 = mk_env()
let r41a = lower_int_lit(f41, expr_int(1))
let f41a = r41a[0]
