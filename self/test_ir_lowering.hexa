     "ret"])

// T93: unary minus on call result — `-f(x)`.
let f93 = lower_fn_decl("neg_call", "i64")
let r93a = lower_int_lit(f93, expr_int(3))
let f93a = r93a[0]
let v93a = r93a[1]
let r93c = lower_call(f93a, 5, 1, "i64")
let f93b = r93c[0]
let v93c = r93c[1]
