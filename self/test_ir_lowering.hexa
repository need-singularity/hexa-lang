    ["load", "load", "ret"])
check_int("T69 start imm=0", f69c.instrs[0].imm, 0)
check_int("T69 end imm=10", f69c.instrs[1].imm, 10)

// T70: @pure fn body — call-free, side-effect-free: load 7, load 3, mul.
let f70 = lower_fn_decl("pure_mul", "i64")
let r70a = lower_int_lit(f70, expr_int(7))
let f70a = r70a[0]
let v70a = r70a[1]
let r70b = lower_int_lit(f70a, expr_int(3))
let f70b = r70b[0]
let v70b = r70b[1]
let r70c = lower_binop(f70b, "mul", v70a, v70b, "i64")
let f70c = r70c[0]
let v70c = r70c[1]
let f70d = lower_return(f70c, v70c)
check_ops("T70 @pure fn body mul",
    collect_opcodes(f70d),
