// T66: Boolean `||` via add — (true || false) modeled as load+load, add.
let f66 = lower_fn_decl("bool_or", "i64")
let r66a = lower_bool_lit(f66, expr_bool(false))
let f66a = r66a[0]
let v66a = r66a[1]
let r66b = lower_bool_lit(f66a, expr_bool(true))
let f66b = r66b[0]
let v66b = r66b[1]
let r66c = lower_binop(f66b, "add", v66a, v66b, "i64")
let f66c = r66c[0]
let v66c = r66c[1]
