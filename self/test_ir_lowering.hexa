check_int("T61 rhs false imm=0", f61d.instrs[1].imm, 0)

// T62: If-expr producing value used in add — phi + binop.
let f62 = lower_fn_decl("if_plus", "i64")
let r62c = lower_int_lit(f62, expr_int(1))
let f62a = r62c[0]
let v62c = r62c[1]
let ie62 = lower_if_expr_skeleton(f62a, v62c, 0)
let f62b = ie62[0]
let else62 = ie62[1]
let end62 = ie62[2]
let r62t = lower_int_lit(f62b, expr_int(10))
let f62c = r62t[0]
let v62t = r62t[1]
let f62d = emit_jump(f62c, end62)
let f62e = emit_label(f62d, else62)
let r62e = lower_int_lit(f62e, expr_int(20))
let f62f = r62e[0]
let v62e = r62e[1]
let f62g = emit_jump(f62f, end62)
let f62h = emit_label(f62g, end62)
let phi62 = lower_if_expr_close(f62h, v62t, v62e, "i64")
let f62i = phi62[0]
let v62phi = phi62[1]
// + 5 on phi result
let r62five = lower_int_lit(f62i, expr_int(5))
let f62j = r62five[0]
let v62five = r62five[1]
let r62add = lower_binop(f62j, "add", v62phi, v62five, "i64")
let f62k = r62add[0]
let v62sum = r62add[1]
let f62l = lower_return_stmt(f62k, v62sum)
check_ops("T62 (if c then 10 else 20) + 5",
    collect_opcodes(f62l),
    ["load", "branch", "load", "jump", "label", "load", "jump", "label", "phi", "load", "add", "ret"])
check_str("T62 phi ty", f62l.instrs[8].ty, "i64")

// T63: let mut binding emits alloc + store — `let mut x = 7`.
let f63 = lower_fn_decl("let_mut", "void")
let env63 = mk_env()
let r63v = lower_int_lit(f63, expr_int(7))
let f63a = r63v[0]
let v63v = r63v[1]
let lr63 = lower_let(f63a, env63, "x", v63v, true, "i64")
let f63b = lr63[0]
let env63b = lr63[1]
let f63c = lower_return(f63b, -1)
check_ops("T63 let mut x = 7",
    collect_opcodes(f63c),
    ["load", "alloc", "store", "ret"])
check_int("T63 x is mut in env", to_int(env_is_mut(env63b, "x")), 1)

// T64: Deep field chain obj.a.b.c — 3 nested loads on alloc.
let f64 = lower_fn_decl("get_abc", "i64")
let r64o = func_emit(f64, mk_instr("alloc", "ptr"))
let f64a = r64o[0]
let v64o = r64o[1]
let r64a = lower_field(f64a, v64o, 0, "ptr")
let f64b = r64a[0]
let v64fa = r64a[1]
let r64b = lower_field(f64b, v64fa, 1, "ptr")
let f64c = r64b[0]
let v64fb = r64b[1]
let r64c = lower_field(f64c, v64fb, 2, "i64")
let f64d = r64c[0]
let v64fc = r64c[1]
let f64e = lower_return(f64d, v64fc)
check_ops("T64 obj.a.b.c 3-deep field",
    collect_opcodes(f64e),
    ["alloc", "load", "load", "load", "ret"])
check_int("T64 field c idx=2", f64e.instrs[3].b, 2)

// ── T65-T70: Phase 8 — 6 more AST node shapes ──────────────

// T65: Negative float literal `-3.14` — neg on float load.
let f65 = lower_fn_decl("neg_float", "f64")
let r65a = lower_float_lit(f65, expr_float(3.14))
let f65a = r65a[0]
let v65a = r65a[1]
