check_int("T50 inner field on x", f50d.instrs[2].a, v50x)
check_int("T50 inner field idx=1", f50d.instrs[2].b, 1)

// T51: Nested call — f(g(1)) → load(1), call g, call f, ret.
let f51 = lower_fn_decl("nested_call", "i64")
let r51a = lower_int_lit(f51, expr_int(1))
let f51a = r51a[0]
let v51one = r51a[1]
let r51g = lower_call(f51a, 100, 1, "i64")    // g(1) — callee_id=100, 1 arg
let f51b = r51g[0]
let v51g = r51g[1]
let r51f = lower_call(f51b, 200, 1, "i64")    // f(g) — callee_id=200, 1 arg
let f51c = r51f[0]
let v51f = r51f[1]
let f51d = lower_return(f51c, v51f)
check_ops("T51 f(g(1)) nested call",
    collect_opcodes(f51d),
    ["load", "call", "call", "ret"])
check_int("T51 inner callee=100", f51d.instrs[1].a, 100)
check_int("T51 outer callee=200", f51d.instrs[2].a, 200)

// T52: Comparison ne — encodes cmp code=2 on sub-with-imm.
let f52 = lower_fn_decl("cmp_ne", "bool")
let r52a = lower_int_lit(f52, expr_int(4))
let f52a = r52a[0]
let v52a = r52a[1]
let r52b = lower_int_lit(f52a, expr_int(5))
let f52b = r52b[0]
let v52b = r52b[1]
let r52c = lower_cmp(f52b, "ne", v52a, v52b)
let f52c = r52c[0]
let v52c = r52c[1]
let f52d = lower_return(f52c, v52c)
check_ops("T52 cmp ne", collect_opcodes(f52d),
    ["load", "load", "sub", "ret"])
check_int("T52 cmp ne code=2", f52d.instrs[2].imm, 2)
check_str("T52 cmp ne ty=bool", f52d.instrs[2].ty, "bool")

// ── T53-T58: Phase 6 — 6 more AST node shapes ──────────────

// T53: FloatLit alone — load f64, ret.
