// ═══════════════════════════════════════════════════════════
//  self/test_ir_lowering.hexa — Standalone self-test for
//  self/ir/lowering.hexa (T11 P1, 5 AST kinds).
//
//  Standalone shape: uses functional `arr.push(x)` + struct
//  re-materialization rather than in-place `push(field, x)`, so
//  `./hexa build` can transpile without a global `push` symbol.
//  This file mirrors the semantics of lowering.hexa but is self-
//  contained; lowering.hexa is the source-of-truth once it gets
//  concat-linked into hexa_full.hexa.
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

// ── Minimal AST node (subset of ast.hexa::Expr) ─────────────
struct Expr {
    kind: string,
    int_val: int,
    float_val: float,
    bool_val: bool,
    str_val: string,
    name: string,
    op: string
}

fn expr_int(v) {
    return Expr { kind: "int_lit", int_val: v, float_val: 0.0, bool_val: false, str_val: "", name: "", op: "" }
}

fn expr_float(v) {
    return Expr { kind: "float_lit", int_val: 0, float_val: v, bool_val: false, str_val: "", name: "", op: "" }
}

fn expr_string(v) {
    return Expr { kind: "string_lit", int_val: 0, float_val: 0.0, bool_val: false, str_val: v, name: "", op: "" }
}

fn expr_bool(v) {
    return Expr { kind: "bool_lit", int_val: 0, float_val: 0.0, bool_val: v, str_val: "", name: "", op: "" }
}

// ── Minimal IR Instruction record ───────────────────────────
struct Instr {
    op: string,
    ty: string,
    a: int,
    b: int,
    imm: int,
    is_imm: bool
}

fn mk_instr(op, ty) {
    return Instr { op: op, ty: ty, a: 0, b: 0, imm: 0, is_imm: false }
}

fn mk_instr_imm(op, ty, imm) {
    return Instr { op: op, ty: ty, a: 0, b: 0, imm: imm, is_imm: true }
}

fn mk_instr_bin(op, ty, a, b) {
    return Instr { op: op, ty: ty, a: a, b: b, imm: 0, is_imm: false }
}

// ── Minimal IrFunction — single entry block (array of Instr) ─
struct Func {
    name: string,
    ret_type: string,
    instrs: array,     // array of Instr (flat, single block)
    next_vid: int
}

fn func_new(name, ret_type) {
    return Func { name: name, ret_type: ret_type, instrs: [], next_vid: 0 }
}

// Emit an instruction; returns (func_updated, vid).
fn func_emit(f, instr) {
    let vid = f.next_vid
    let new_instrs = f.instrs.push(instr)
    let f2 = Func { name: f.name, ret_type: f.ret_type, instrs: new_instrs, next_vid: vid + 1 }
    return [f2, vid]
}

// ── Lowering primitives (mirror self/ir/lowering.hexa) ──────

fn lower_int_lit(f, e) {
    // load imm_i64 → ValueId
    return func_emit(f, mk_instr_imm("load", "i64", e.int_val))
}

fn lower_float_lit(f, e) {
    // load imm_f64 → ValueId (store placeholder imm=0; real f64 table TBD)
    return func_emit(f, mk_instr_imm("load", "f64", 0))
}

fn lower_binop_mnemonic(op_str) {
    if op_str == "add" { return "add" }
    if op_str == "sub" { return "sub" }
    if op_str == "mul" { return "mul" }
    if op_str == "div" { return "div" }
    if op_str == "rem" { return "mod" }   // AST uses "rem"; IR opcode is "mod"
    if op_str == "mod" { return "mod" }
    return ""
}

// BinOp lowering assumes lhs_vid / rhs_vid are already materialized.
// Returns [func_updated, vid] on success, or [func, -1] on failure.
fn lower_binop(f, op_str, lhs_vid, rhs_vid, ty) {
    let mnem = lower_binop_mnemonic(op_str)
    if mnem == "" {
        // TODO: lower BinOp kind unsupported (op_str)
        return [f, -1]
    }
    return func_emit(f, mk_instr_bin(mnem, ty, lhs_vid, rhs_vid))
}

fn lower_return(f, val_vid) {
    // Ret with operand if val_vid >= 0, else void ret.
    let instr = Instr { op: "ret", ty: "void", a: val_vid, b: 0, imm: 0, is_imm: false }
    let new_instrs = f.instrs.push(instr)
    return Func { name: f.name, ret_type: f.ret_type, instrs: new_instrs, next_vid: f.next_vid }
}

fn lower_fn_decl(name, ret_type) {
    return func_new(name, ret_type)
}

// ── T11 P2 additions: Call / If / While / Let ───────────────
// Standalone (single-block) model: label/branch/jump are emitted as flat
// instructions whose `a` field points at a label id (counter-backed). The
// real self/ir/lowering.hexa variant threads multi-block CFG via builder.

fn lower_call(f, callee_id, arg_count, ret_ty) {
    // Emit `call` with a=callee_id, b=arg_count. Caller already emitted the
    // arg-eval `load` instructions L→R before this.
    let vid = f.next_vid
    let instr = Instr { op: "call", ty: ret_ty, a: callee_id, b: arg_count, imm: 0, is_imm: false }
    let new_instrs = f.instrs.push(instr)
    let f2 = Func { name: f.name, ret_type: f.ret_type, instrs: new_instrs, next_vid: vid + 1 }
    return [f2, vid]
}

// label markers: pseudo-instructions that print as op="label" with a=id.
fn emit_label(f, id) {
    let instr = Instr { op: "label", ty: "void", a: id, b: 0, imm: 0, is_imm: false }
    let new_instrs = f.instrs.push(instr)
    return Func { name: f.name, ret_type: f.ret_type, instrs: new_instrs, next_vid: f.next_vid }
}

fn emit_jump(f, target_id) {
    let instr = Instr { op: "jump", ty: "void", a: target_id, b: 0, imm: 0, is_imm: false }
    let new_instrs = f.instrs.push(instr)
    return Func { name: f.name, ret_type: f.ret_type, instrs: new_instrs, next_vid: f.next_vid }
}

fn emit_branch_if_false(f, cond_vid, else_id) {
    // BRANCH (truthy → fallthrough, falsy → jump to else_id)
    let instr = Instr { op: "branch", ty: "void", a: cond_vid, b: else_id, imm: 0, is_imm: false }
    let new_instrs = f.instrs.push(instr)
    return Func { name: f.name, ret_type: f.ret_type, instrs: new_instrs, next_vid: f.next_vid }
}

// fresh label id — scoped per-function via an external counter passed in.
// Returns [f_unused, next_id] so callers can chain without globals.
fn fresh_label(counter) {
    let id = counter
    return [counter + 1, id]
}

// lower_if: caller passes the already-lowered cond_vid and gets back
// [f_after_branch, else_label, end_label, counter_after]. The caller then
// emits the `then` body, a JUMP to end_label, the else_label marker,
// the `else` body, and finally the end_label marker — wiring is done by
// the test to keep the shape visible.
fn lower_if_skeleton(f, cond_vid, counter) {
    let r1 = fresh_label(counter)
    let c1 = r1[0]
    let else_id = r1[1]
    let r2 = fresh_label(c1)
    let c2 = r2[0]
    let end_id = r2[1]
    let f2 = emit_branch_if_false(f, cond_vid, else_id)
    return [f2, else_id, end_id, c2]
}

// lower_while: emits header label, returns [f_with_header, header_id,
// end_id, counter_after]. Caller lowers cond into header, emits a
// branch_if_false→end_id, then body, then jump→header, then end_id label.
fn lower_while_skeleton(f, counter) {
    let r1 = fresh_label(counter)
    let c1 = r1[0]
    let header_id = r1[1]
    let r2 = fresh_label(c1)
    let c2 = r2[0]
    let end_id = r2[1]
    let f2 = emit_label(f, header_id)
    return [f2, header_id, end_id, c2]
}

// Minimal env for let-binding. immutable: vid = ssa reg.
// mutable:    vid = alloc-slot id, reads go through load, writes via store.
fn mk_env() {
    return [[], [], []]   // [names, vids, muts]
}

fn env_bind(env, name, vid, is_mut) {
    let names = env[0].push(name)
    let vids  = env[1].push(vid)
    let muts  = env[2].push(is_mut)
    return [names, vids, muts]
}

fn env_lookup(env, name) {
    let names = env[0]
    let vids = env[1]
    let i = 0
    while i < len(names) {
        if names[i] == name {
            return vids[i]
        }
        i = i + 1
    }
    return -1
}

fn env_is_mut(env, name) {
    let names = env[0]
    let muts = env[2]
    let i = 0
    while i < len(names) {
        if names[i] == name {
            return muts[i]
        }
        i = i + 1
    }
    return false
}

// lower_let: immutable → SSA bind; mutable → ALLOC slot + STORE init.
// Returns [f_updated, env_updated].
fn lower_let(f, env, name, value_vid, mut_flag, ty) {
    if !mut_flag {
        let env2 = env_bind(env, name, value_vid, false)
        return [f, env2]
    }
    // emit alloc → slot vid
    let slot_vid = f.next_vid
    let alloc_instr = Instr { op: "alloc", ty: ty, a: 0, b: 0, imm: 0, is_imm: false }
    let f1_instrs = f.instrs.push(alloc_instr)
    let f1 = Func { name: f.name, ret_type: f.ret_type, instrs: f1_instrs, next_vid: slot_vid + 1 }
    // emit store slot, value
    let store_instr = Instr { op: "store", ty: "void", a: slot_vid, b: value_vid, imm: 0, is_imm: false }
    let f2_instrs = f1.instrs.push(store_instr)
    let f2 = Func { name: f.name, ret_type: f.ret_type, instrs: f2_instrs, next_vid: f1.next_vid }
    let env2 = env_bind(env, name, slot_vid, true)
    return [f2, env2]
}

// ── Helpers ──────────────────────────────────────────────────

fn collect_opcodes(f) {
    let out = []
    let i = 0
    while i < len(f.instrs) {
        out = out.push(f.instrs[i].op)
        i = i + 1
    }
    return out
}

fn ops_to_str(a) {
    let out = "["
    let i = 0
    while i < len(a) {
        if i > 0 {
            out = out + ","
        }
        out = out + a[i]
        i = i + 1
    }
    return out + "]"
}

fn check_ops(name, got, expected) {
    let g = ops_to_str(got)
    let e = ops_to_str(expected)
    if g == e {
        println("[PASS] " + name + " -> " + g)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " expected " + e + ", got " + g)
        fail_count = fail_count + 1
    }
}

fn check_int(name, got, expected) {
    if got == expected {
        println("[PASS] " + name + " = " + to_string(got))
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " expected " + to_string(expected) + ", got " + to_string(got))
        fail_count = fail_count + 1
    }
}

fn check_str(name, got, expected) {
    if got == expected {
        println("[PASS] " + name + " = " + got)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " expected " + expected + ", got " + got)
        fail_count = fail_count + 1
    }
}

// ── Tests ───────────────────────────────────────────────────

println("═══════════════════════════════════════════════════════")
println("  AST → HEXA-IR Lowering — T11 P1 self-test")
println("═══════════════════════════════════════════════════════")

// T1: IntLit + Return → load, ret
let f1 = lower_fn_decl("k42", "i64")
let r1 = lower_int_lit(f1, expr_int(42))
let f1b = r1[0]
let v1 = r1[1]
let f1c = lower_return(f1b, v1)
check_ops("T1 IntLit->Return", collect_opcodes(f1c), ["load", "ret"])

// T2: 3 + 4 → load, load, add, ret
let f2 = lower_fn_decl("add", "i64")
let r2a = lower_int_lit(f2, expr_int(3))
let f2a = r2a[0]
let l2 = r2a[1]
let r2b = lower_int_lit(f2a, expr_int(4))
let f2b = r2b[0]
let rr2 = r2b[1]
let r2c = lower_binop(f2b, "add", l2, rr2, "i64")
let f2c = r2c[0]
let sum2 = r2c[1]
let f2d = lower_return(f2c, sum2)
check_ops("T2 3+4", collect_opcodes(f2d), ["load", "load", "add", "ret"])

// T3: (3*4) - (2+1) → load, load, mul, load, load, add, sub, ret
let f3 = lower_fn_decl("mix", "i64")
let ra = lower_int_lit(f3, expr_int(3))
let f3a = ra[0]
let va = ra[1]
let rc = lower_int_lit(f3a, expr_int(4))
let f3b = rc[0]
let vc = rc[1]
let rprod = lower_binop(f3b, "mul", va, vc, "i64")
let f3c = rprod[0]
let vprod = rprod[1]
let rx = lower_int_lit(f3c, expr_int(2))
let f3d = rx[0]
let vx = rx[1]
let ry = lower_int_lit(f3d, expr_int(1))
let f3e = ry[0]
let vy = ry[1]
let rsum = lower_binop(f3e, "add", vx, vy, "i64")
let f3f = rsum[0]
let vsum = rsum[1]
let rdiff = lower_binop(f3f, "sub", vprod, vsum, "i64")
let f3g = rdiff[0]
let vdiff = rdiff[1]
let f3h = lower_return(f3g, vdiff)
check_ops("T3 (3*4)-(2+1)", collect_opcodes(f3h),
    ["load", "load", "mul", "load", "load", "add", "sub", "ret"])

// T4: div & mod (AST "rem" → IR "mod")
let f4 = lower_fn_decl("dm", "i64")
let r4a = lower_int_lit(f4, expr_int(10))
let f4a = r4a[0]
let v4a = r4a[1]
let r4b = lower_int_lit(f4a, expr_int(3))
let f4b = r4b[0]
let v4b = r4b[1]
let r4q = lower_binop(f4b, "div", v4a, v4b, "i64")
let f4c = r4q[0]
let vq = r4q[1]
let r4c = lower_int_lit(f4c, expr_int(10))
let f4d = r4c[0]
let v4c = r4c[1]
let r4d = lower_int_lit(f4d, expr_int(3))
let f4e = r4d[0]
let v4d = r4d[1]
let r4r = lower_binop(f4e, "rem", v4c, v4d, "i64")
let f4f = r4r[0]
let vr = r4r[1]
let r4s = lower_binop(f4f, "add", vq, vr, "i64")
let f4g = r4s[0]
let vs = r4s[1]
let f4h = lower_return(f4g, vs)
check_ops("T4 div+mod", collect_opcodes(f4h),
    ["load", "load", "div", "load", "load", "mod", "add", "ret"])

// T5: FloatLit → load f64
let f5 = lower_fn_decl("pi", "f64")
let r5 = lower_float_lit(f5, expr_float(3.14))
let f5a = r5[0]
let v5 = r5[1]
let f5b = lower_return(f5a, v5)
check_int("T5 instr count", len(f5b.instrs), 2)
check_str("T5 op[0]", f5b.instrs[0].op, "load")
check_str("T5 ty[0]", f5b.instrs[0].ty, "f64")
check_str("T5 op[1]", f5b.instrs[1].op, "ret")

// T6: unsupported BinOp ("pow") → vid == -1
let f6 = lower_fn_decl("bad", "i64")
let r6a = lower_int_lit(f6, expr_int(1))
let f6a = r6a[0]
let v6a = r6a[1]
let r6b = lower_int_lit(f6a, expr_int(2))
let f6b = r6b[0]
let v6b = r6b[1]
let r6c = lower_binop(f6b, "pow", v6a, v6b, "i64")
let v_bad = r6c[1]
check_int("T6 unsupported pow -> -1", v_bad, -1)

// T7: Call — eval args L→R then emit CALL.
//     id(7)  →  load(7), call, ret
let f7 = lower_fn_decl("c", "i64")
let r7a = lower_int_lit(f7, expr_int(7))
let f7a = r7a[0]
let v7arg = r7a[1]
let r7b = lower_call(f7a, 0, 1, "i64")   // callee_id=0 (id fn), 1 arg
let f7b = r7b[0]
let v7ret = r7b[1]
let f7c = lower_return(f7b, v7ret)
check_ops("T7 call id(7)", collect_opcodes(f7c), ["load", "call", "ret"])

// T8: If — cond + branch → then jump → else label → end label → ret.
let f8 = lower_fn_decl("if_test", "i64")
let r8a = lower_int_lit(f8, expr_int(1))
let f8a = r8a[0]
let v8cond = r8a[1]
let r8 = lower_if_skeleton(f8a, v8cond, 0)   // counter starts at 0
let f8b = r8[0]
let else_id8 = r8[1]
let end_id8 = r8[2]
// then body: just jump to end
let f8c = emit_jump(f8b, end_id8)
// else label + (empty else body) + jump end
let f8d = emit_label(f8c, else_id8)
let f8e = emit_jump(f8d, end_id8)
// end label + ret
let f8f = emit_label(f8e, end_id8)
let f8g = lower_return(f8f, v8cond)
check_ops("T8 if skeleton",
    collect_opcodes(f8g),
    ["load", "branch", "jump", "label", "jump", "label", "ret"])

// T9: While — header label + cond + branch_if_false → body → jump header → end label.
let f9 = lower_fn_decl("w_test", "i64")
let r9 = lower_while_skeleton(f9, 0)
let f9a = r9[0]
let header_id9 = r9[1]
let end_id9 = r9[2]
// header already emitted; lower cond into header then branch
let r9c = lower_int_lit(f9a, expr_int(0))
let f9b = r9c[0]
let v9cond = r9c[1]
let f9c = emit_branch_if_false(f9b, v9cond, end_id9)
// body: jump back to header (backedge)
let f9d = emit_jump(f9c, header_id9)
// end label + ret
let f9e = emit_label(f9d, end_id9)
let f9f = lower_return(f9e, v9cond)
check_ops("T9 while skeleton",
    collect_opcodes(f9f),
    ["label", "load", "branch", "jump", "label", "ret"])

// T10: Let immutable — SSA bind only, no alloc/store.
let f10 = lower_fn_decl("let_imm", "i64")
let env10 = mk_env()
let r10a = lower_int_lit(f10, expr_int(42))
let f10a = r10a[0]
let v10 = r10a[1]
let lr10 = lower_let(f10a, env10, "x", v10, false, "i64")
let f10b = lr10[0]
let env10b = lr10[1]
check_int("T10 env lookup x", env_lookup(env10b, "x"), v10)
check_int("T10 mut flag", to_int(env_is_mut(env10b, "x")), 0)
let f10c = lower_return(f10b, v10)
check_ops("T10 let immutable", collect_opcodes(f10c), ["load", "ret"])

// T11: Let mutable — ALLOC + STORE; env records mut=true.
let f11 = lower_fn_decl("let_mut", "i64")
let env11 = mk_env()
let r11a = lower_int_lit(f11, expr_int(7))
let f11a = r11a[0]
let v11 = r11a[1]
let lr11 = lower_let(f11a, env11, "y", v11, true, "i64")
let f11b = lr11[0]
let env11b = lr11[1]
check_int("T11 mut flag", to_int(env_is_mut(env11b, "y")), 1)
let f11c = lower_return(f11b, v11)
check_ops("T11 let mutable", collect_opcodes(f11c),
    ["load", "alloc", "store", "ret"])

// T12: If-inside-While — combined control flow.
let f12 = lower_fn_decl("if_in_while", "i64")
let rw = lower_while_skeleton(f12, 0)
let f12a = rw[0]
let hdr12 = rw[1]
let wend12 = rw[2]
let ctr12 = rw[3]
// header: cond + branch_if_false → wend
let rwc = lower_int_lit(f12a, expr_int(1))
let f12b = rwc[0]
let wcond = rwc[1]
let f12c = emit_branch_if_false(f12b, wcond, wend12)
// body: inner if
let rcc = lower_int_lit(f12c, expr_int(0))
let f12d = rcc[0]
let icond = rcc[1]
let rif = lower_if_skeleton(f12d, icond, ctr12)
let f12e = rif[0]
let else_id12 = rif[1]
let end_id12 = rif[2]
// then body
let f12f = emit_jump(f12e, end_id12)
// else label + empty + jump end
let f12g = emit_label(f12f, else_id12)
let f12h = emit_jump(f12g, end_id12)
// if.end label
let f12i = emit_label(f12h, end_id12)
// backedge to while header
let f12j = emit_jump(f12i, hdr12)
// while end label + ret
let f12k = emit_label(f12j, wend12)
let f12l = lower_return(f12k, wcond)
check_ops("T12 if-in-while",
    collect_opcodes(f12l),
    ["label", "load", "branch", "load", "branch",
     "jump", "label", "jump", "label", "jump", "label", "ret"])

// T21: StringLit → load str (standalone model: imm=0 placeholder index).
fn lower_string_lit(f, e) {
    // In standalone model, emit load with str type. Real lowering interns
    // in module.string_pool; here we use imm=0 as placeholder index.
    return func_emit(f, mk_instr_imm("load", "str", 0))
}

let f21 = lower_fn_decl("greet", "str")
let r21 = lower_string_lit(f21, expr_string("hello"))
let f21a = r21[0]
let v21 = r21[1]
let f21b = lower_return(f21a, v21)
check_ops("T21 StringLit", collect_opcodes(f21b), ["load", "ret"])
check_str("T21 ty[0]", f21b.instrs[0].ty, "str")

// T22: BoolLit → load i64 (1 for true, 0 for false).
fn lower_bool_lit(f, e) {
    let v = 0
    if e.bool_val { v = 1 }
    return func_emit(f, mk_instr_imm("load", "i64", v))
}

let f22 = lower_fn_decl("flag", "i64")
let r22a = lower_bool_lit(f22, expr_bool(true))
let f22a = r22a[0]
let v22t = r22a[1]
let r22b = lower_bool_lit(f22a, expr_bool(false))
let f22b = r22b[0]
let v22f = r22b[1]
let f22c = lower_return(f22b, v22t)
check_ops("T22 BoolLit", collect_opcodes(f22c), ["load", "load", "ret"])
check_str("T22 ty[0]", f22c.instrs[0].ty, "i64")
check_int("T22 true imm", f22c.instrs[0].imm, 1)
check_int("T22 false imm", f22c.instrs[1].imm, 0)

// ── T23-T27: 5 high-frequency AST nodes (P7-6 scale-up) ─────
// Mirror the lowering primitives from self/ir/lowering.hexa in the
// standalone single-block model.

// T23: UnaryOp — "neg" emits NEG; "not" synthesizes (1 - x); "bitnot"
// synthesizes ((-1) - x). Returns -1 for unsupported op.
fn lower_unary(f, op_str, operand_vid, ty) {
    if op_str == "neg" {
        let vid = f.next_vid
        let instr = Instr { op: "neg", ty: ty, a: operand_vid, b: 0, imm: 0, is_imm: false }
        let new_instrs = f.instrs.push(instr)
        let f2 = Func { name: f.name, ret_type: f.ret_type, instrs: new_instrs, next_vid: vid + 1 }
        return [f2, vid]
    }
    if op_str == "not" {
        // (1 - x)
        let r1 = func_emit(f, mk_instr_imm("load", ty, 1))
        let f1 = r1[0]
        let one_vid = r1[1]
        return func_emit(f1, mk_instr_bin("sub", ty, one_vid, operand_vid))
    }
    if op_str == "bitnot" {
        // (-1) - x
        let r1 = func_emit(f, mk_instr_imm("load", ty, -1))
        let f1 = r1[0]
        let neg_one_vid = r1[1]
        return func_emit(f1, mk_instr_bin("sub", ty, neg_one_vid, operand_vid))
    }
    return [f, -1]
}

// T23a: neg x → load, neg, ret
let f23 = lower_fn_decl("negate", "i64")
let r23a = lower_int_lit(f23, expr_int(42))
let f23a = r23a[0]
let v23 = r23a[1]
let r23b = lower_unary(f23a, "neg", v23, "i64")
let f23b = r23b[0]
let v23r = r23b[1]
let f23c = lower_return(f23b, v23r)
check_ops("T23 Unary neg", collect_opcodes(f23c), ["load", "neg", "ret"])

// T23b: not x → load(x), load(1), sub, ret
let f23n = lower_fn_decl("lognot", "i64")
let r23n_a = lower_int_lit(f23n, expr_int(0))
let f23n_a = r23n_a[0]
let v23n = r23n_a[1]
let r23n_b = lower_unary(f23n_a, "not", v23n, "i64")
let f23n_b = r23n_b[0]
let v23n_r = r23n_b[1]
let f23n_c = lower_return(f23n_b, v23n_r)
check_ops("T23 Unary not", collect_opcodes(f23n_c), ["load", "load", "sub", "ret"])

// T23c: unsupported unary → -1
let f23u = lower_fn_decl("bad_un", "i64")
let r23u_a = lower_int_lit(f23u, expr_int(1))
let f23u_a = r23u_a[0]
let v23u = r23u_a[1]
let r23u_b = lower_unary(f23u_a, "weird", v23u, "i64")
let v23u_r = r23u_b[1]
check_int("T23 unsupported unary -> -1", v23u_r, -1)

// T24: Comparison BinOp (eq) — reuses Sub opcode with cmp tag, result bool.
// Standalone model encodes cmp as `sub` with imm=cmp-code (eq=1,ne=2,...).
fn lower_cmp(f, kind, lhs_vid, rhs_vid) {
    let code = 0
    if kind == "eq" { code = 1 }
    if kind == "ne" { code = 2 }
    if kind == "lt" { code = 3 }
    if kind == "le" { code = 4 }
    if kind == "gt" { code = 5 }
    if kind == "ge" { code = 6 }
    if code == 0 { return [f, -1] }
    let vid = f.next_vid
    let instr = Instr { op: "sub", ty: "bool", a: lhs_vid, b: rhs_vid, imm: code, is_imm: true }
    let new_instrs = f.instrs.push(instr)
    let f2 = Func { name: f.name, ret_type: f.ret_type, instrs: new_instrs, next_vid: vid + 1 }
    return [f2, vid]
}

// eq(3, 3) → load, load, sub, ret. Result type "bool" on the sub.
let f24 = lower_fn_decl("cmp_eq", "bool")
let r24a = lower_int_lit(f24, expr_int(3))
let f24a = r24a[0]
let v24a = r24a[1]
let r24b = lower_int_lit(f24a, expr_int(3))
let f24b = r24b[0]
let v24b = r24b[1]
let r24c = lower_cmp(f24b, "eq", v24a, v24b)
let f24c = r24c[0]
let v24c = r24c[1]
let f24d = lower_return(f24c, v24c)
check_ops("T24 cmp eq", collect_opcodes(f24d), ["load", "load", "sub", "ret"])
check_str("T24 cmp result ty", f24d.instrs[2].ty, "bool")
check_int("T24 cmp eq code", f24d.instrs[2].imm, 1)

// Unsupported cmp → -1
let r24u = lower_cmp(f24, "weird", 0, 0)
let v24u = r24u[1]
check_int("T24 unsupported cmp -> -1", v24u, -1)

// T25: Ident as expression — immutable bind returns SSA vid; mut bind
// emits LOAD through slot on read.
fn lower_ident_read(f, env, name, ty) {
    let vid = env_lookup(env, name)
    if vid < 0 { return [f, -1] }
    if env_is_mut(env, name) {
        // mut: emit load slot
        let new_vid = f.next_vid
        let instr = Instr { op: "load", ty: ty, a: vid, b: 0, imm: 0, is_imm: false }
        let new_instrs = f.instrs.push(instr)
        let f2 = Func { name: f.name, ret_type: f.ret_type, instrs: new_instrs, next_vid: new_vid + 1 }
        return [f2, new_vid]
    }
    // immutable: return existing SSA vid, no new instr
    return [f, vid]
}

// T25a: immutable ident → no new instr, returns bound vid.
let f25 = lower_fn_decl("read_imm", "i64")
let env25 = mk_env()
let r25a = lower_int_lit(f25, expr_int(99))
let f25a = r25a[0]
let v25 = r25a[1]
let env25b = env_bind(env25, "a", v25, false)
let r25b = lower_ident_read(f25a, env25b, "a", "i64")
let f25b = r25b[0]
let v25r = r25b[1]
check_int("T25 imm ident returns SSA vid", v25r, v25)
let f25c = lower_return(f25b, v25r)
check_ops("T25 ident immutable", collect_opcodes(f25c), ["load", "ret"])

// T25b: mutable ident → LOAD from slot.
let f25m = lower_fn_decl("read_mut", "i64")
let env25m = mk_env()
let r25m_a = lower_int_lit(f25m, expr_int(7))
let f25m_a = r25m_a[0]
let v25m = r25m_a[1]
let lr25m = lower_let(f25m_a, env25m, "b", v25m, true, "i64")
let f25m_b = lr25m[0]
let env25m_b = lr25m[1]
let r25m_c = lower_ident_read(f25m_b, env25m_b, "b", "i64")
let f25m_c = r25m_c[0]
let v25m_r = r25m_c[1]
let f25m_d = lower_return(f25m_c, v25m_r)
// load(7), alloc, store, load(slot), ret
check_ops("T25 ident mutable -> load", collect_opcodes(f25m_d),
    ["load", "alloc", "store", "load", "ret"])

// Unresolved ident → -1
let env25u = mk_env()
let r25u = lower_ident_read(f25, env25u, "missing", "i64")
let v25u = r25u[1]
check_int("T25 unresolved ident -> -1", v25u, -1)

// T26: FieldAccess — obj.field → LOAD with [obj, field_idx] operands.
// Standalone model: encode as load with a=obj_vid, b=field_idx.
fn lower_field(f, obj_vid, field_idx, field_ty) {
    let vid = f.next_vid
    let instr = Instr { op: "load", ty: field_ty, a: obj_vid, b: field_idx, imm: 0, is_imm: false }
    let new_instrs = f.instrs.push(instr)
    let f2 = Func { name: f.name, ret_type: f.ret_type, instrs: new_instrs, next_vid: vid + 1 }
    return [f2, vid]
}

// Simulate:  let p = alloc struct;  return p.x  (field_idx 2, ty i64)
let f26 = lower_fn_decl("get_field", "i64")
// pretend obj is vid 0 (parameter-like); in real lowering it would come from
// an alloc or param load. Here we use a placeholder load to stand in.
let r26a = func_emit(f26, mk_instr("alloc", "ptr"))
let f26a = r26a[0]
let obj = r26a[1]
let r26b = lower_field(f26a, obj, 2, "i64")
let f26b = r26b[0]
let v26 = r26b[1]
let f26c = lower_return(f26b, v26)
check_ops("T26 FieldAccess", collect_opcodes(f26c), ["alloc", "load", "ret"])
check_int("T26 field obj operand", f26c.instrs[1].a, obj)
check_int("T26 field idx", f26c.instrs[1].b, 2)
check_str("T26 field result ty", f26c.instrs[1].ty, "i64")

// T27: Index — arr[i] → LOAD with [arr, idx] operands.
// Standalone model: encode as load with a=arr_vid, b=idx_vid.
fn lower_index(f, arr_vid, idx_vid, elem_ty) {
    let vid = f.next_vid
    let instr = Instr { op: "load", ty: elem_ty, a: arr_vid, b: idx_vid, imm: 0, is_imm: false }
    let new_instrs = f.instrs.push(instr)
    let f2 = Func { name: f.name, ret_type: f.ret_type, instrs: new_instrs, next_vid: vid + 1 }
    return [f2, vid]
}

// Simulate:  return arr[3]   where arr comes from an alloc stand-in.
let f27 = lower_fn_decl("get_at", "i64")
let r27a = func_emit(f27, mk_instr("alloc", "ptr"))
let f27a = r27a[0]
let arr = r27a[1]
let r27b = lower_int_lit(f27a, expr_int(3))
let f27b = r27b[0]
let idx = r27b[1]
let r27c = lower_index(f27b, arr, idx, "i64")
let f27c = r27c[0]
let v27 = r27c[1]
let f27d = lower_return(f27c, v27)
check_ops("T27 Index arr[3]", collect_opcodes(f27d),
    ["alloc", "load", "load", "ret"])
check_int("T27 index arr operand", f27d.instrs[2].a, arr)
check_int("T27 index idx operand", f27d.instrs[2].b, idx)
check_str("T27 index result ty", f27d.instrs[2].ty, "i64")

// ── T28-T34: Control flow (P7-6 next tier) ─────────────────
// ReturnStmt, BreakStmt, ContinueStmt, WhileStmt, MatchExpr, IfExpr
// Standalone single-block model: labels + jumps emitted as flat instrs.

// T28: ReturnStmt wrapper — lower_return already covers; variant with -1
// should emit a void `ret` (a=-1 sentinel means no operand).
fn lower_return_stmt(f, val_vid) {
    // identical to lower_return — alias for the AST node name.
    return lower_return(f, val_vid)
}

// T28a: return 7 → load, ret
let f28 = lower_fn_decl("rs", "i64")
let r28a = lower_int_lit(f28, expr_int(7))
let f28a = r28a[0]
let v28 = r28a[1]
let f28b = lower_return_stmt(f28a, v28)
check_ops("T28 ReturnStmt", collect_opcodes(f28b), ["load", "ret"])

// T28b: return; → ret (void, a=-1)
let f28v = lower_fn_decl("rv", "void")
let f28v2 = lower_return_stmt(f28v, -1)
check_ops("T28 ReturnStmt void", collect_opcodes(f28v2), ["ret"])
check_int("T28 void ret has a=-1", f28v2.instrs[0].a, -1)

// T29: BreakStmt — inside a loop, emits jump to end_label.
// LoopCtx is represented as [header_id, end_id].
fn loop_ctx(header_id, end_id) {
    return [header_id, end_id]
}

fn lower_break(f, ctx) {
    return emit_jump(f, ctx[1])
}

fn lower_continue(f, ctx) {
    return emit_jump(f, ctx[0])
}

// T29: break → jump end
let f29 = lower_fn_decl("brk", "i64")
let r29w = lower_while_skeleton(f29, 0)
let f29a = r29w[0]
let hdr29 = r29w[1]
let end29 = r29w[2]
// header: cond + branch_if_false → end
let r29c = lower_int_lit(f29a, expr_int(1))
let f29b = r29c[0]
let v29c = r29c[1]
let f29c = emit_branch_if_false(f29b, v29c, end29)
// body: break
let ctx29 = loop_ctx(hdr29, end29)
let f29d = lower_break(f29c, ctx29)
// end label + ret
let f29e = emit_label(f29d, end29)
let f29f = lower_return_stmt(f29e, v29c)
check_ops("T29 BreakStmt",
    collect_opcodes(f29f),
    ["label", "load", "branch", "jump", "label", "ret"])

// T30: ContinueStmt — jump header
let f30 = lower_fn_decl("cont", "i64")
let r30w = lower_while_skeleton(f30, 0)
let f30a = r30w[0]
let hdr30 = r30w[1]
let end30 = r30w[2]
let r30c = lower_int_lit(f30a, expr_int(1))
let f30b = r30c[0]
let v30c = r30c[1]
let f30c = emit_branch_if_false(f30b, v30c, end30)
let ctx30 = loop_ctx(hdr30, end30)
let f30d = lower_continue(f30c, ctx30)
let f30e = emit_label(f30d, end30)
let f30f = lower_return_stmt(f30e, v30c)
check_ops("T30 ContinueStmt",
    collect_opcodes(f30f),
    ["label", "load", "branch", "jump", "label", "ret"])

// T31: WhileStmt with bin_op cond + assign body (end-to-end shape).
//   let mut i = 0
//   while i < 10 { i = i + 1 }
let f31 = lower_fn_decl("wba", "i64")
let env31 = mk_env()
let r31z = lower_int_lit(f31, expr_int(0))
let f31a = r31z[0]
let v31z = r31z[1]
let lr31 = lower_let(f31a, env31, "i", v31z, true, "i64")
let f31b = lr31[0]
let env31b = lr31[1]
let r31w = lower_while_skeleton(f31b, 0)
let f31c = r31w[0]
let hdr31 = r31w[1]
let end31 = r31w[2]
// header: load(i), load(10), cmp_lt (encoded as sub-with-imm), branch
let r31ri = lower_ident_read(f31c, env31b, "i", "i64")
let f31d = r31ri[0]
let v31i = r31ri[1]
let r31t = lower_int_lit(f31d, expr_int(10))
let f31e = r31t[0]
let v31t = r31t[1]
let r31lt = lower_cmp(f31e, "lt", v31i, v31t)
let f31f = r31lt[0]
let v31lt = r31lt[1]
let f31g = emit_branch_if_false(f31f, v31lt, end31)
// body: load(i), load(1), add, store, jump(header)
let r31ri2 = lower_ident_read(f31g, env31b, "i", "i64")
let f31h = r31ri2[0]
let v31i2 = r31ri2[1]
let r31one = lower_int_lit(f31h, expr_int(1))
let f31i = r31one[0]
let v31one = r31one[1]
let r31add = lower_binop(f31i, "add", v31i2, v31one, "i64")
let f31j = r31add[0]
let v31add = r31add[1]
// assign i = next  (emit store to slot)
let slot31 = env_lookup(env31b, "i")
let f31k_instrs = f31j.instrs.push(Instr { op: "store", ty: "void", a: slot31, b: v31add, imm: 0, is_imm: false })
let f31k = Func { name: f31j.name, ret_type: f31j.ret_type, instrs: f31k_instrs, next_vid: f31j.next_vid }
let f31l = emit_jump(f31k, hdr31)
let f31m = emit_label(f31l, end31)
let f31n = lower_return_stmt(f31m, v31z)
// entry: load(0), alloc, store
// while skeleton: label(header)
// header: load(i), load(10), sub(cmp), branch
// body: load(i), load(1), add, store, jump(header), label(end), ret
check_ops("T31 WhileStmt cond+assign",
    collect_opcodes(f31n),
    ["load", "alloc", "store",
     "label",
     "load", "load", "sub", "branch",
     "load", "load", "add", "store", "jump",
     "label", "ret"])

// T32: MatchExpr on int — 2 arms + default, encoded as `switch`.
// Standalone model: emit switch opcode with a=scrutinee_vid, b=case_count;
// default target is separate `default` instr (represented as label); each
// arm body ends with jump→end.
fn lower_match_skeleton_std(f, scrutinee_vid, case_count, counter) {
    // allocate labels: N arms + default + end
    let mut c = counter
    let mut arm_ids = []
    let mut i = 0
    while i < case_count {
        let r = fresh_label(c)
        c = r[0]
        arm_ids = arm_ids.push(r[1])
        i = i + 1
    }
    let rd = fresh_label(c)
    c = rd[0]
    let default_id = rd[1]
    let re = fresh_label(c)
    c = re[0]
    let end_id = re[1]
    // emit switch instr — a = scrutinee, b = case_count, imm = default_id
    let instr = Instr { op: "switch", ty: "void", a: scrutinee_vid,
                        b: case_count, imm: default_id, is_imm: true }
    let new_instrs = f.instrs.push(instr)
    let f2 = Func { name: f.name, ret_type: f.ret_type, instrs: new_instrs, next_vid: f.next_vid }
    return [f2, arm_ids, default_id, end_id, c]
}

let f32 = lower_fn_decl("mm", "i64")
let r32s = lower_int_lit(f32, expr_int(2))
let f32a = r32s[0]
let v32s = r32s[1]
let ms32 = lower_match_skeleton_std(f32a, v32s, 2, 0)
let f32b = ms32[0]
let arms32 = ms32[1]
let default32 = ms32[2]
let end32 = ms32[3]
// arm 0: label + body(const 10) + jump end
let f32c = emit_label(f32b, arms32[0])
let r32a0 = lower_int_lit(f32c, expr_int(10))
let f32d = r32a0[0]
let f32e = emit_jump(f32d, end32)
// arm 1: label + body(const 20) + jump end
let f32f = emit_label(f32e, arms32[1])
let r32a1 = lower_int_lit(f32f, expr_int(20))
let f32g = r32a1[0]
let f32h = emit_jump(f32g, end32)
// default: label + body(const 0) + jump end
let f32i = emit_label(f32h, default32)
let r32d = lower_int_lit(f32i, expr_int(0))
let f32j = r32d[0]
let f32k = emit_jump(f32j, end32)
// end
let f32l = emit_label(f32k, end32)
let f32m = lower_return_stmt(f32l, v32s)
check_ops("T32 MatchExpr 2 arms + default",
    collect_opcodes(f32m),
    ["load", "switch",
     "label", "load", "jump",
     "label", "load", "jump",
     "label", "load", "jump",
     "label", "ret"])
check_int("T32 switch case count", f32m.instrs[1].b, 2)

// T33: IfExpr — value-producing if with phi merge.
// Encoded as: branch cond→then-path; then-body; jump end; else-body; jump end;
// end-label; phi instr with a=then_vid, b=else_vid.
fn lower_if_expr_skeleton(f, cond_vid, counter) {
    let r1 = fresh_label(counter)
    let c1 = r1[0]
    let else_id = r1[1]
    let r2 = fresh_label(c1)
    let c2 = r2[0]
    let end_id = r2[1]
    let f2 = emit_branch_if_false(f, cond_vid, else_id)
    return [f2, else_id, end_id, c2]
}

fn lower_if_expr_close(f, then_vid, else_vid, ty) {
    let vid = f.next_vid
    let instr = Instr { op: "phi", ty: ty, a: then_vid, b: else_vid, imm: 0, is_imm: false }
    let new_instrs = f.instrs.push(instr)
    let f2 = Func { name: f.name, ret_type: f.ret_type, instrs: new_instrs, next_vid: vid + 1 }
    return [f2, vid]
}

let f33 = lower_fn_decl("ifx", "i64")
let r33c = lower_int_lit(f33, expr_int(1))
let f33a = r33c[0]
let v33c = r33c[1]
let ie33 = lower_if_expr_skeleton(f33a, v33c, 0)
let f33b = ie33[0]
let else33 = ie33[1]
let end33 = ie33[2]
// then branch: load 1, jump end
let r33t = lower_int_lit(f33b, expr_int(1))
let f33c = r33t[0]
let v33t = r33t[1]
let f33d = emit_jump(f33c, end33)
// else label + body + jump end
let f33e = emit_label(f33d, else33)
let r33e = lower_int_lit(f33e, expr_int(2))
let f33f = r33e[0]
let v33e = r33e[1]
let f33g = emit_jump(f33f, end33)
// end label + phi + ret
let f33h = emit_label(f33g, end33)
let phi33 = lower_if_expr_close(f33h, v33t, v33e, "i64")
let f33i = phi33[0]
let v33phi = phi33[1]
let f33j = lower_return_stmt(f33i, v33phi)
check_ops("T33 IfExpr with phi",
    collect_opcodes(f33j),
    ["load", "branch", "load", "jump", "label", "load", "jump", "label", "phi", "ret"])
check_str("T33 phi ty", f33j.instrs[8].ty, "i64")

// T34: Nested — while with IfExpr assigning to mut slot in body.
//   let mut n = 0
//   while n < 3 { n = if n < 1 { n + 1 } else { n + 2 } }
let f34 = lower_fn_decl("wif", "i64")
let env34 = mk_env()
let r34z = lower_int_lit(f34, expr_int(0))
let f34a = r34z[0]
let v34z = r34z[1]
let lr34 = lower_let(f34a, env34, "n", v34z, true, "i64")
let f34b = lr34[0]
let env34b = lr34[1]
let r34w = lower_while_skeleton(f34b, 0)
let f34c = r34w[0]
let hdr34 = r34w[1]
let end34 = r34w[2]
let ctr34 = r34w[3]
// header: n < 3, branch
let r34rn = lower_ident_read(f34c, env34b, "n", "i64")
let f34d = r34rn[0]
let v34n = r34rn[1]
let r34th = lower_int_lit(f34d, expr_int(3))
let f34e = r34th[0]
let v34th = r34th[1]
let r34lt = lower_cmp(f34e, "lt", v34n, v34th)
let f34f = r34lt[0]
let v34lt = r34lt[1]
let f34g = emit_branch_if_false(f34f, v34lt, end34)
// body: if n < 1 { n + 1 } else { n + 2 } → phi
let r34rn2 = lower_ident_read(f34g, env34b, "n", "i64")
let f34h = r34rn2[0]
let v34n2 = r34rn2[1]
let r34one = lower_int_lit(f34h, expr_int(1))
let f34i = r34one[0]
let v34one = r34one[1]
let r34cmp2 = lower_cmp(f34i, "lt", v34n2, v34one)
let f34j = r34cmp2[0]
let v34cmp2 = r34cmp2[1]
let ie34 = lower_if_expr_skeleton(f34j, v34cmp2, ctr34)
let f34k = ie34[0]
let else34 = ie34[1]
let end34if = ie34[2]
// then: n + 1
let r34rn3 = lower_ident_read(f34k, env34b, "n", "i64")
let f34l = r34rn3[0]
let v34n3 = r34rn3[1]
let r34one2 = lower_int_lit(f34l, expr_int(1))
let f34m = r34one2[0]
let v34one2 = r34one2[1]
let r34add1 = lower_binop(f34m, "add", v34n3, v34one2, "i64")
let f34n = r34add1[0]
let v34then = r34add1[1]
let f34o = emit_jump(f34n, end34if)
// else label + n + 2 + jump end
let f34p = emit_label(f34o, else34)
let r34rn4 = lower_ident_read(f34p, env34b, "n", "i64")
let f34q = r34rn4[0]
let v34n4 = r34rn4[1]
let r34two = lower_int_lit(f34q, expr_int(2))
let f34r = r34two[0]
let v34two = r34two[1]
let r34add2 = lower_binop(f34r, "add", v34n4, v34two, "i64")
let f34s = r34add2[0]
let v34else = r34add2[1]
let f34t = emit_jump(f34s, end34if)
// end-if label + phi
let f34u = emit_label(f34t, end34if)
let phi34 = lower_if_expr_close(f34u, v34then, v34else, "i64")
let f34v = phi34[0]
let v34phi = phi34[1]
// assign n = phi
let slot34 = env_lookup(env34b, "n")
let f34w_instrs = f34v.instrs.push(Instr { op: "store", ty: "void", a: slot34, b: v34phi, imm: 0, is_imm: false })
let f34w = Func { name: f34v.name, ret_type: f34v.ret_type, instrs: f34w_instrs, next_vid: f34v.next_vid }
// backedge + end + ret
let f34x = emit_jump(f34w, hdr34)
let f34y = emit_label(f34x, end34)
let f34zz = lower_return_stmt(f34y, v34z)
// Shape-check via count rather than full trace — many ops.
check_int("T34 nested while+ifexpr instr count", len(f34zz.instrs), 27)
// Find phi index dynamically (its exact position depends on label/branch order).
let mut t34_phi_idx = -1
let mut t34_i = 0
while t34_i < len(f34zz.instrs) {
    if f34zz.instrs[t34_i].op == "phi" {
        t34_phi_idx = t34_i
    }
    t34_i = t34_i + 1
}
let t34_has_phi = 0
if t34_phi_idx >= 0 { t34_has_phi = 1 }
check_int("T34 has exactly one phi", t34_has_phi, 1)
check_str("T34 phi ty i64", f34zz.instrs[t34_phi_idx].ty, "i64")

// ── T35-T46: Phase 4 — 12 more AST node / combination tests ─
// All use existing primitives above; no new lowering logic required.

// T35: ArrayLit — alloc + N stores (simulating `let arr = [1, 2, 3]`).
// Standalone model: alloc produces slot, each element is lowered then stored.
fn lower_array_lit(f, elem_vids, elem_ty) {
    let alloc_vid = f.next_vid
    let alloc_instr = Instr { op: "alloc", ty: "array", a: 0, b: 0, imm: 0, is_imm: false }
    let f1_instrs = f.instrs.push(alloc_instr)
    let mut fcur = Func { name: f.name, ret_type: f.ret_type, instrs: f1_instrs, next_vid: alloc_vid + 1 }
    let mut i = 0
    while i < len(elem_vids) {
        let store_instr = Instr { op: "store", ty: elem_ty, a: alloc_vid, b: elem_vids[i], imm: i, is_imm: true }
        let new_instrs = fcur.instrs.push(store_instr)
        fcur = Func { name: fcur.name, ret_type: fcur.ret_type, instrs: new_instrs, next_vid: fcur.next_vid }
        i = i + 1
    }
    return [fcur, alloc_vid]
}

let f35 = lower_fn_decl("arr3", "array")
let r35a = lower_int_lit(f35, expr_int(1))
let f35a = r35a[0]
let v35a = r35a[1]
let r35b = lower_int_lit(f35a, expr_int(2))
let f35b = r35b[0]
let v35b = r35b[1]
let r35c = lower_int_lit(f35b, expr_int(3))
let f35c = r35c[0]
let v35c = r35c[1]
let r35arr = lower_array_lit(f35c, [v35a, v35b, v35c], "i64")
let f35d = r35arr[0]
let v35arr = r35arr[1]
let f35e = lower_return(f35d, v35arr)
check_ops("T35 ArrayLit [1,2,3]",
    collect_opcodes(f35e),
    ["load", "load", "load", "alloc", "store", "store", "store", "ret"])

// T36: Nested Call — `outer(inner(5))`.
// First inner arg is loaded (5), inner call emits `call`, outer gets inner-vid as arg
// (no extra load needed since it's already SSA), outer call emits `call`, ret.
let f36 = lower_fn_decl("nested_c", "i64")
let r36a = lower_int_lit(f36, expr_int(5))
let f36a = r36a[0]
let v36a = r36a[1]
let r36b = lower_call(f36a, 0, 1, "i64")  // inner(5)
let f36b = r36b[0]
let v36b = r36b[1]
let r36c = lower_call(f36b, 1, 1, "i64")  // outer(inner_result)
let f36c = r36c[0]
let v36c = r36c[1]
let f36d = lower_return(f36c, v36c)
check_ops("T36 nested call outer(inner(5))",
    collect_opcodes(f36d), ["load", "call", "call", "ret"])

// T37: If with early-return in then branch (no phi — stmt form).
//   if cond { return 1 } else { return 2 }
let f37 = lower_fn_decl("if_ret", "i64")
let r37c = lower_int_lit(f37, expr_int(1))
let f37a = r37c[0]
let v37c = r37c[1]
let r37if = lower_if_skeleton(f37a, v37c, 0)
let f37b = r37if[0]
let else37 = r37if[1]
let end37 = r37if[2]
// then: load 1, ret (no jump to end since we return)
let r37t = lower_int_lit(f37b, expr_int(1))
let f37c = r37t[0]
let v37t = r37t[1]
let f37d = lower_return(f37c, v37t)
// else label + load 2 + ret
let f37e = emit_label(f37d, else37)
let r37e = lower_int_lit(f37e, expr_int(2))
let f37f = r37e[0]
let v37e = r37e[1]
let f37g = lower_return(f37f, v37e)
// end label (unreachable, but marks the structural end)
let f37h = emit_label(f37g, end37)
check_ops("T37 if with early-return",
    collect_opcodes(f37h),
    ["load", "branch", "load", "ret", "label", "load", "ret", "label"])

// T38: Break from nested loop — inner break uses inner ctx (only exits inner).
let f38 = lower_fn_decl("brk_inner", "i64")
let r38w1 = lower_while_skeleton(f38, 0)
let f38a = r38w1[0]
let outer_hdr = r38w1[1]
let outer_end = r38w1[2]
let ctr38 = r38w1[3]
// outer header: cond + branch
let r38c1 = lower_int_lit(f38a, expr_int(1))
let f38b = r38c1[0]
let v38c1 = r38c1[1]
let f38c = emit_branch_if_false(f38b, v38c1, outer_end)
// outer body: inner while
let r38w2 = lower_while_skeleton(f38c, ctr38)
let f38d = r38w2[0]
let inner_hdr = r38w2[1]
let inner_end = r38w2[2]
// inner header: cond + branch
let r38c2 = lower_int_lit(f38d, expr_int(1))
let f38e = r38c2[0]
let v38c2 = r38c2[1]
let f38f = emit_branch_if_false(f38e, v38c2, inner_end)
// inner body: break inner
let inner_ctx = loop_ctx(inner_hdr, inner_end)
let f38g = lower_break(f38f, inner_ctx)
// inner end label + backedge to outer header
let f38h = emit_label(f38g, inner_end)
let f38i = emit_jump(f38h, outer_hdr)
// outer end label + ret
let f38j = emit_label(f38i, outer_end)
let f38k = lower_return(f38j, v38c1)
check_ops("T38 break from inner nested loop",
    collect_opcodes(f38k),
    ["label", "load", "branch",
     "label", "load", "branch",
     "jump", "label", "jump",
     "label", "ret"])

// T39: Continue at start of body — jumps back to header before any other work.
let f39 = lower_fn_decl("cont_start", "i64")
let r39w = lower_while_skeleton(f39, 0)
let f39a = r39w[0]
let hdr39 = r39w[1]
let end39 = r39w[2]
let r39c = lower_int_lit(f39a, expr_int(1))
let f39b = r39c[0]
let v39c = r39c[1]
let f39c = emit_branch_if_false(f39b, v39c, end39)
let ctx39 = loop_ctx(hdr39, end39)
let f39d = lower_continue(f39c, ctx39)
// Dead code (never reached) — add a store after to prove continue terminated body.
let r39d = lower_int_lit(f39d, expr_int(99))
let f39e = r39d[0]
let f39f = emit_label(f39e, end39)
let f39g = lower_return(f39f, v39c)
check_ops("T39 continue at start",
    collect_opcodes(f39g),
    ["label", "load", "branch", "jump", "load", "label", "ret"])

// T40: Match with single arm + default (degenerate 1-case switch).
let f40 = lower_fn_decl("match1", "i64")
let r40s = lower_int_lit(f40, expr_int(7))
let f40a = r40s[0]
let v40s = r40s[1]
