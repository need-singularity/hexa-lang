// ═══════════════════════════════════════════════════════════════════
//  test_bit_higher_pure.hexa — coverage for bit_higher_pure.hexa
//
//  Tests: popcount32_pure, gray_encode_pure, gray_decode_pure,
//         swap_adjacent_bits_pure, interleave_bits16_pure
//
//  (codegen import not wired for test files; inline the module body,
//   same pattern as test_bit_pure.hexa / test_bitops_pure.hexa.)
// ═══════════════════════════════════════════════════════════════════

// ── INLINED from self/runtime/bit_higher_pure.hexa ──

@pure
fn _pow2(n) {
    let mut r = 1
    let mut i = 0
    while i < n {
        r = r * 2
        i = i + 1
    }
    return r
}

@pure
fn popcount32_pure(n) {
    let mask32 = 0xFFFFFFFF
    let mut x = n & mask32
    let mut c = 0
    while x != 0 {
        x = x & (x - 1)
        c = c + 1
    }
    return c
}

@pure
fn gray_encode_pure(n) {
    let mask = 0xFFFFFFFFFFFFFFFF
    let nn = n & mask
    return nn ^ (nn / 2)
}

@pure
fn gray_decode_pure(g) {
    let mask = 0xFFFFFFFFFFFFFFFF
    let mut n = g & mask
    let mut shift = 1
    while shift < 64 {
        n = n ^ (n / _pow2(shift))
        shift = shift * 2
    }
    return n & mask
}

@pure
fn swap_adjacent_bits_pure(n) {
    let mask32 = 0xFFFFFFFF
    let odd_mask  = 0xAAAAAAAA
    let even_mask = 0x55555555
    let x = n & mask32
    let odd  = (x & odd_mask) / 2
    let even = (x & even_mask) * 2
    let swapped = (odd + even) & mask32
    let hi = n - x
    return hi + swapped
}

@pure
fn interleave_bits16_pure(a, b) {
    let mask16 = 0xFFFF
    let aa = a & mask16
    let bb = b & mask16
    let mut r = 0
    let mut i = 0
    while i < 16 {
        let bit_i   = _pow2(i)
        let slot_a  = _pow2(i * 2)
        let slot_b  = _pow2(i * 2 + 1)
        if (aa & bit_i) != 0 {
            r = r + slot_a
        }
        if (bb & bit_i) != 0 {
            r = r + slot_b
        }
        i = i + 1
    }
    return r
}

// ── END inlined ────────────────────────────────────────────────────

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  Pure-Hexa Bit-Higher Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── popcount32_pure ────────────────────────────────────────────────
println("--- popcount32_pure ---")
check("popcount32 0",           popcount32_pure(0),          0)
check("popcount32 1",           popcount32_pure(1),          1)
check("popcount32 2",           popcount32_pure(2),          1)
check("popcount32 3",           popcount32_pure(3),          2)
check("popcount32 0xFF",        popcount32_pure(0xFF),       8)
check("popcount32 0x55555555",  popcount32_pure(0x55555555), 16)
check("popcount32 0xAAAAAAAA",  popcount32_pure(0xAAAAAAAA), 16)
check("popcount32 0xFFFFFFFF",  popcount32_pure(0xFFFFFFFF), 32)
check("popcount32 masks hi",    popcount32_pure(0x100000001), 1)

// ── gray_encode_pure ───────────────────────────────────────────────
println("")
println("--- gray_encode_pure ---")
check("gray_enc 0",  gray_encode_pure(0),  0)
check("gray_enc 1",  gray_encode_pure(1),  1)
check("gray_enc 2",  gray_encode_pure(2),  3)
check("gray_enc 3",  gray_encode_pure(3),  2)
check("gray_enc 4",  gray_encode_pure(4),  6)
check("gray_enc 5",  gray_encode_pure(5),  7)
check("gray_enc 6",  gray_encode_pure(6),  5)
check("gray_enc 7",  gray_encode_pure(7),  4)
check("gray_enc 8",  gray_encode_pure(8),  12)

// ── gray_decode_pure ───────────────────────────────────────────────
println("")
println("--- gray_decode_pure ---")
check("gray_dec 0",  gray_decode_pure(0),  0)
check("gray_dec 1",  gray_decode_pure(1),  1)
check("gray_dec 3",  gray_decode_pure(3),  2)
check("gray_dec 2",  gray_decode_pure(2),  3)
check("gray_dec 6",  gray_decode_pure(6),  4)
check("gray_dec 7",  gray_decode_pure(7),  5)
check("gray_dec 5",  gray_decode_pure(5),  6)
check("gray_dec 4",  gray_decode_pure(4),  7)
check("gray roundtrip 42",     gray_decode_pure(gray_encode_pure(42)),       42)
check("gray roundtrip 1000",   gray_decode_pure(gray_encode_pure(1000)),     1000)
check("gray roundtrip 0xABCD", gray_decode_pure(gray_encode_pure(0xABCD)),   0xABCD)

// ── swap_adjacent_bits_pure ────────────────────────────────────────
println("")
println("--- swap_adjacent_bits_pure ---")
check("swap_adj 0",       swap_adjacent_bits_pure(0),        0)
check("swap_adj 0b1010",  swap_adjacent_bits_pure(0xA),      0x5)   // 1010 -> 0101
check("swap_adj 0b0101",  swap_adjacent_bits_pure(0x5),      0xA)   // 0101 -> 1010
check("swap_adj 0b0110",  swap_adjacent_bits_pure(0x6),      0x9)   // 0110 -> 1001
check("swap_adj 0b11",    swap_adjacent_bits_pure(0x3),      0x3)   // pair is symmetric
check("swap_adj 0xFFFF",  swap_adjacent_bits_pure(0xFFFF),   0xFFFF)
check("swap_adj involution", swap_adjacent_bits_pure(swap_adjacent_bits_pure(0x12345678)), 0x12345678)

// ── interleave_bits16_pure ─────────────────────────────────────────
println("")
println("--- interleave_bits16_pure ---")
check("morton (0,0)",       interleave_bits16_pure(0, 0),            0)
check("morton (1,0)",       interleave_bits16_pure(1, 0),            1)
check("morton (0,1)",       interleave_bits16_pure(0, 1),            2)
check("morton (3,0)",       interleave_bits16_pure(3, 0),            5)    // 0101
check("morton (0,3)",       interleave_bits16_pure(0, 3),            10)   // 1010
check("morton (0xFF,0)",    interleave_bits16_pure(0xFF, 0),         0x5555)
check("morton (0,0xFF)",    interleave_bits16_pure(0, 0xFF),         0xAAAA)
check("morton (0xFFFF,0xFFFF)", interleave_bits16_pure(0xFFFF, 0xFFFF), 0xFFFFFFFF)

println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    println("FAIL")
    exit(1)
}
println("ALL PASS")
