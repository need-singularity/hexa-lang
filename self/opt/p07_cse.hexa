// self/opt/p07_cse.hexa — ported from src/opt/p07_cse.rs
// P7: Common Subexpression Elimination — deduplicate identical computations.
// Enhanced with cross-block CSE, operand canonicalization for commutative ops.

// Check if opcode is commutative (a op b == b op a).
fn is_commutative(op: int) -> bool {
    return op == 0 || op == 2   // Add or Mul
}

// Canonicalize operands: for commutative ops, sort operand keys
// so (a+b) and (b+a) produce the same expression key.
fn canonicalize_pair(op: int, a: int, b: int) -> [int] {
    if is_commutative(op) {
        if a > b { return [b, a] }
    }
    return [a, b]
}

// Expression key for CSE lookup: [opcode, operand1, operand2, ...]
// Two instructions with the same key are identical computations.
fn expr_key(op: int, operands: [int]) -> [int] {
    let mut key = [op]
    if len(operands) == 2 && is_commutative(op) {
        let pair = canonicalize_pair(op, operands[0], operands[1])
        key = key.push(pair[0]).push(pair[1])
    } else {
        let mut i = 0
        while i < len(operands) {
            key = key.push(operands[i])
            i = i + 1
        }
    }
    return key
}

fn run_cse_conceptual() -> PassResult {
    let mut eliminated = 0
    // Global (cross-block) expression table: ExprKey -> first result ValueId
    // For each function:
    //   For each block, for each instruction:
    //     Skip side-effecting, terminator, proof, Phi, Load
    //     Build ExprKey, check if seen
    //     If seen: mark for replacement
    //     Else: record in table
    //   Apply replacements: rewrite operand references
    //   Convert replaced instructions to Load(replacement_value)
    return PassResult {
        changed: eliminated > 0,
        stat_keys: ["eliminated"],
        stat_vals: [eliminated]
    }
}
