// self/opt/p01_type_infer.hexa — ported from src/opt/p01_type_infer.rs
// P1: Type Inference — resolve untyped values via context propagation.

// Infer a more specific type from the operation and operand types.
// op: opcode tag, operand_types: array of type strings.
// Returns inferred type string or "" if no inference possible.
fn infer_from_op(op: int, operand_types: [string]) -> string {
    // Arithmetic inherits from first operand
    // op tags: 0=Add, 1=Sub, 2=Mul, 3=Div, 4=Mod
    if op >= 0 && op <= 4 {
        if len(operand_types) > 0 {
            return operand_types[0]
        }
    }
    // Assert/Assume/Invariant -> Void
    // (op tags for proof ops)
    return ""
}

// Run type inference pass over all functions.
// Returns PassResult with count of inferred types.
fn run_type_infer(func_instrs: [[[int]]]) -> PassResult {
    let mut changed = false
    let mut inferred = 0
    // For each function, for each block, for each instruction:
    //   if type == I64, try to infer better type from operands
    // (In self-hosted version, types are tracked in parallel arrays)
    return PassResult {
        changed: changed,
        stat_keys: ["inferred"],
        stat_vals: [inferred]
    }
}
