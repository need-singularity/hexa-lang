// self/opt/pass_policy.hexa — ported from src/opt/pass_policy.rs
// Pass Selector Policy — decides opt pass order per round.

// Policy tags
fn POLICY_FIXED() -> int { return 0 }
fn POLICY_ADAPTIVE() -> int { return 1 }
fn POLICY_HYBRID() -> int { return 2 }

// 12 pass names in fixed sigma=12 order.
fn fixed_pass_order() -> [string] {
    return [
        "type_infer", "ownership_proof", "dead_store", "const_fold",
        "inlining", "licm", "cse", "strength_reduction",
        "code_sinking", "coalesce", "final_dce", "verify"
    ]
}

// Decide next-round pass order based on policy + last-round metrics.
fn next_order(policy: int, round: int, last_metrics: [PassMetric]) -> [string] {
    if policy == POLICY_FIXED() {
        return fixed_pass_order()
    }
    if policy == POLICY_ADAPTIVE() {
        return adaptive_order(last_metrics)
    }
    // Hybrid: alternate fixed/adaptive
    if round % 2 == 0 {
        return fixed_pass_order()
    }
    return adaptive_order(last_metrics)
}

// Adaptive order: sort by impact (instr reduction) descending.
// Verify always stays last.
fn adaptive_order(last: [PassMetric]) -> [string] {
    if len(last) == 0 {
        return fixed_pass_order()
    }
    // Collect reducers (excluding verify)
    let mut names = []
    let mut impacts = []
    let mut i = 0
    while i < len(last) {
        if last[i].pass_name != "verify" {
            names.push(last[i].pass_name)
            impacts.push(0 - pass_metric_delta_instr(last[i]))
        }
        i = i + 1
    }
    // Sort by impact descending (bubble sort)
    let n = len(names)
    let mut a = 0
    while a < n {
        let mut b = a + 1
        while b < n {
            if impacts[b] > impacts[a] {
                let tmp_n = names[a]
                names[a] = names[b]
                names[b] = tmp_n
                let tmp_i = impacts[a]
                impacts[a] = impacts[b]
                impacts[b] = tmp_i
            }
            b = b + 1
        }
        a = a + 1
    }
    names.push("verify")
    return names
}
