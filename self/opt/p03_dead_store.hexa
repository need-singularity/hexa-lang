// self/opt/p03_dead_store.hexa — ported from src/opt/p03_dead_store.rs
// P3: Dead Store Elimination + Store-Load forwarding.
//
// 1. Remove stores to values that are never loaded
// 2. Forward store->load: if Store(ptr, val) immediately followed by Load(ptr),
//    replace Load with Copy(val)

fn run_dead_store_elim_conceptual() -> PassResult {
    let mut eliminated = 0
    let mut forwarded = 0

    // Phase 1: Store-Load forwarding within each block
    // Track last stored value for each alloca pointer.
    // When Load(ptr) seen, if last_stored[ptr] known, replace with Copy(val).
    // Call instructions invalidate all stores (callee may modify memory).

    // Phase 2: Dead store elimination
    // Collect all used values (referenced as operands).
    // Remove Store instructions where the ptr is never used.

    return PassResult {
        changed: eliminated > 0 || forwarded > 0,
        stat_keys: ["eliminated", "forwarded"],
        stat_vals: [eliminated, forwarded]
    }
}
