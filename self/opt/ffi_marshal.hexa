// ═══════════════════════════════════════════════════════════
//  self/opt/ffi_marshal.hexa — S-5 FFI marshalling skeleton
//
//  Plan: docs/plans/s5_ffi_plan.md
//  Roadmap item: S-5 / S5-1 (FFI marshalling 최소화)
//
//  STATUS: SKELETON ONLY — no real marshalling logic. Bodies
//  return a placeholder sentinel so that callers can start
//  wiring against stable names / constants while step (b) of
//  the rollout (stub + tests) lands in parallel.
//
//  Runtime truth (self/runtime.c):
//    - hexa_ffi_marshal_arg  (L3494) — per-tag switch to int64
//    - hexa_call_extern_raw  (L3509) — 0..14 arg dispatch
//    - hexa_extern_call      (L3550) — marshal + call + unmarshal
//    - hexa_extern_call_typed (L3571) — float_mask SIMD routing
//  This module's future job is to feed per-arg `target_repr`
//  tags into that pipeline so the fast path can short-circuit.
// ═══════════════════════════════════════════════════════════

// ── target_repr string constants ────────────────────────────
// Six canonical representations match the switch in
// hexa_ffi_marshal_arg exactly. Keep the names stable — any
// future consumer (parser attr, codegen, docs generator) will
// import these by name.
let FFI_REPR_I64  = "c_i64"
let FFI_REPR_F64  = "c_f64"
let FFI_REPR_BOOL = "c_bool"
let FFI_REPR_CSTR = "c_cstr"
let FFI_REPR_PTR  = "c_ptr"
let FFI_REPR_VOID = "c_void"

// Sentinel returned by every stub body. Callers MUST treat any
// result containing this token as "not implemented yet".
let FFI_MARSHAL_TODO_SENTINEL = "__ffi_marshal_TODO__"

// ── surface: marshal_in / marshal_out / repr query ──────────

// Hexa value → C bytes (opaque string for now).
// TODO(S-5 step b): switch on target_repr and produce the
// correct C-ABI lane (int64 / double-bits / c_str pointer).
fn marshal_in(val, target_repr) {
    // TODO: inspect tag(val); dispatch per target_repr.
    return FFI_MARSHAL_TODO_SENTINEL
}

// C bytes → hexa value.
// TODO(S-5 step b): decode based on target_repr; handle
// lifetime for c_cstr borrows per the spec in the plan doc.
fn marshal_out(bytes, target_repr) {
    // TODO: decode bytes; honour borrow vs. copy semantics.
    return FFI_MARSHAL_TODO_SENTINEL
}

// Predicate — is this a repr the skeleton knows about?
// Used by future parser validation so @cffi("x: c_bogus") fails early.
fn ffi_repr_is_known(target_repr) {
    if target_repr == FFI_REPR_I64  { return true }
    if target_repr == FFI_REPR_F64  { return true }
    if target_repr == FFI_REPR_BOOL { return true }
    if target_repr == FFI_REPR_CSTR { return true }
    if target_repr == FFI_REPR_PTR  { return true }
    if target_repr == FFI_REPR_VOID { return true }
    return false
}

// Canonical list — exposed so tests / registries can walk it
// without hard-coding duplicates.
fn ffi_repr_list() {
    let mut out = []
    out = out.push(FFI_REPR_I64)
    out = out.push(FFI_REPR_F64)
    out = out.push(FFI_REPR_BOOL)
    out = out.push(FFI_REPR_CSTR)
    out = out.push(FFI_REPR_PTR)
    out = out.push(FFI_REPR_VOID)
    return out
}

// ── optional: module self-check (no side effect on import) ──
// Not called automatically. A future driver can invoke this
// to assert the skeleton still returns the sentinel unchanged.
fn ffi_marshal_self_check() {
    let a = marshal_in(0, FFI_REPR_I64)
    let b = marshal_out("", FFI_REPR_I64)
    if a != FFI_MARSHAL_TODO_SENTINEL { return false }
    if b != FFI_MARSHAL_TODO_SENTINEL { return false }
    if ffi_repr_is_known("c_bogus")   { return false }
    if !ffi_repr_is_known(FFI_REPR_I64) { return false }
    return true
}
