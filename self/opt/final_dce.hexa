// self/opt/p11_final_dce.hexa — ported from src/opt/p11_final_dce.rs
// P11: Final Dead Code Elimination — remove all unused instructions.
// Mark-sweep DCE with phi cleanup, empty block elimination.

fn pass_final_dce_name() -> string { return "final_dce" }

fn pass_final_dce_run(module: IrModule) -> PassResult {
    let mut changed = false
    let mut eliminated = 0
    let mut simplified_phis = 0
    let mut removed_blocks = 0

    let mut fi = 0
    while fi < len(module.functions) {
        let func = module.functions[fi]

        // Phase 1: Phi cleanup — replace phi where all values identical
        let mut phi_repls: [KvPair] = []
        let mut bi = 0
        while bi < len(func.blocks) {
            let mut ii = 0
            while ii < len(func.blocks[bi].instructions) {
                let instr = func.blocks[bi].instructions[ii]
                if instr.op == "phi" {
                    let mut vals: [int] = []
                    let mut oi = 0
                    while oi < len(instr.operands) {
                        if instr.operands[oi].kind == "phi_entry" {
                            if !int_list_contains(vals, instr.operands[oi].value_id) {
                                vals = vals.push(instr.operands[oi].value_id)
                            }
                        }
                        oi = oi + 1
                    }
                    if len(vals) == 1 { phi_repls = kv_set(phi_repls, instr.result, vals[0]) }
                }
                ii = ii + 1
            }
            bi = bi + 1
        }
        let mut ri = 0
        while ri < len(phi_repls) {
            bi = 0
            while bi < len(func.blocks) {
                let mut ii = 0
                while ii < len(func.blocks[bi].instructions) {
                    let instr = func.blocks[bi].instructions[ii]
                    if instr.result == phi_repls[ri].key && instr.op == "phi" {
                        instr.op = "copy"
                        instr.operands = [Operand { kind: "value", value_id: phi_repls[ri].val }]
                        changed = true
                        simplified_phis = simplified_phis + 1
                    }
                    ii = ii + 1
                }
                bi = bi + 1
            }
            ri = ri + 1
        }

        // Phase 2: Mark-sweep DCE
        let mut used: [int] = []
        let mut worklist: [int] = []

        bi = 0
        while bi < len(func.blocks) {
            let mut ii = 0
            while ii < len(func.blocks[bi].instructions) {
                let instr = func.blocks[bi].instructions[ii]
                let is_root = is_terminator_op(instr.op) || has_side_effect_op(instr.op) || is_proof_op(instr.op) || instr.op == "return"
                if is_root {
                    let mut oi = 0
                    while oi < len(instr.operands) {
                        if instr.operands[oi].kind == "value" { worklist = worklist.push(instr.operands[oi].value_id) }
                        if instr.operands[oi].kind == "phi_entry" { worklist = worklist.push(instr.operands[oi].value_id) }
                        oi = oi + 1
                    }
                    used = int_list_add_unique(used, instr.result)
                }
                ii = ii + 1
            }
            bi = bi + 1
        }

        while len(worklist) > 0 {
            let v = worklist[len(worklist) - 1]
            worklist = list_pop(worklist)
            if !int_list_contains(used, v) {
                used = used.push(v)
                bi = 0
                while bi < len(func.blocks) {
                    let mut ii = 0
                    while ii < len(func.blocks[bi].instructions) {
                        if func.blocks[bi].instructions[ii].result == v {
                            let mut oi = 0
                            while oi < len(func.blocks[bi].instructions[ii].operands) {
                                let op = func.blocks[bi].instructions[ii].operands[oi]
                                if op.kind == "value" { worklist = worklist.push(op.value_id) }
                                if op.kind == "phi_entry" { worklist = worklist.push(op.value_id) }
                                oi = oi + 1
                            }
                        }
                        ii = ii + 1
                    }
                    bi = bi + 1
                }
            }
        }

        // Sweep
        bi = 0
        while bi < len(func.blocks) {
            let mut new_instrs: [IrInstr] = []
            let mut ii = 0
            while ii < len(func.blocks[bi].instructions) {
                let instr = func.blocks[bi].instructions[ii]
                if int_list_contains(used, instr.result) || is_terminator_op(instr.op) || has_side_effect_op(instr.op) || is_proof_op(instr.op) {
                    new_instrs = new_instrs.push(instr)
                } else {
                    changed = true
                    eliminated = eliminated + 1
                }
                ii = ii + 1
            }
            func.blocks[bi].instructions = new_instrs
            bi = bi + 1
        }

        // Phase 3: Empty block elimination
        let mut redirect: [KvPair] = []
        bi = 0
        while bi < len(func.blocks) {
            let block = func.blocks[bi]
            if len(block.instructions) == 1 && block.instructions[0].op == "jump" && len(block.instructions[0].operands) > 0 && block.instructions[0].operands[0].kind == "block" {
                redirect = kv_set(redirect, block.id, block.instructions[0].operands[0].block_id)
            }
            bi = bi + 1
        }

        ri = 0
        while ri < len(redirect) {
            let empty_id = redirect[ri].key
            let target_id = redirect[ri].val
            if len(func.blocks) > 0 && func.blocks[0].id == empty_id { ri = ri + 1; continue }
            bi = 0
            while bi < len(func.blocks) {
                if func.blocks[bi].id == empty_id { bi = bi + 1; continue }
                let mut ii = 0
                while ii < len(func.blocks[bi].instructions) {
                    if is_terminator_op(func.blocks[bi].instructions[ii].op) {
                        let mut oi = 0
                        while oi < len(func.blocks[bi].instructions[ii].operands) {
                            let op = func.blocks[bi].instructions[ii].operands[oi]
                            if (op.kind == "block" || op.kind == "switch_case" || op.kind == "phi_entry") && op.block_id == empty_id {
                                func.blocks[bi].instructions[ii].operands[oi].block_id = target_id
                                changed = true
                            }
                            oi = oi + 1
                        }
                    }
                    ii = ii + 1
                }
                bi = bi + 1
            }
            ri = ri + 1
        }

        // Remove redirected blocks
        let entry_id = func.blocks[0].id
        let mut new_blocks: [BasicBlock] = []
        bi = 0
        while bi < len(func.blocks) {
            let mut is_redir = false
            if func.blocks[bi].id != entry_id {
                let mut ri2 = 0
                while ri2 < len(redirect) {
                    if redirect[ri2].key == func.blocks[bi].id { is_redir = true }
                    ri2 = ri2 + 1
                }
            }
            if !is_redir {
                new_blocks = new_blocks.push(func.blocks[bi])
            } else {
                removed_blocks = removed_blocks + 1
                changed = true
            }
            bi = bi + 1
        }
        func.blocks = new_blocks
        fi = fi + 1
    }

    return PassResult {
        changed: changed,
        stats: [
            StatEntry { key: "eliminated", value: eliminated },
            StatEntry { key: "simplified_phis", value: simplified_phis },
            StatEntry { key: "removed_blocks", value: removed_blocks }
        ]
    }
}

fn list_pop(arr: [int]) -> [int] {
    let mut result: [int] = []
    let mut i = 0
    while i < len(arr) - 1 {
        result = result.push(arr[i])
        i = i + 1
    }
    return result
}
