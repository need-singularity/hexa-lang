// self/opt/p10_coalesce.hexa — ported from src/opt/p10_coalesce.rs
// P10: Copy Coalescing — eliminate unnecessary copy/move instructions.

fn pass_coalesce_name() -> string { return "coalesce" }

fn pass_coalesce_run(module: IrModule) -> PassResult {
    let mut changed = false
    let mut coalesced = 0

    let mut fi = 0
    while fi < len(module.functions) {
        let func = module.functions[fi]
        let mut alias: [KvPair] = []

        // Find copy/move chains
        let mut bi = 0
        while bi < len(func.blocks) {
            let block = func.blocks[bi]
            let mut ii = 0
            while ii < len(block.instructions) {
                let instr = block.instructions[ii]
                if (instr.op == "copy" || instr.op == "move") && len(instr.operands) > 0 && instr.operands[0].kind == "value" {
                    let src = instr.operands[0].value_id
                    let mut root = src
                    let mut r = kv_get(alias, root)
                    while r != -1 { root = r; r = kv_get(alias, root) }
                    alias = kv_set(alias, instr.result, root)
                    coalesced = coalesced + 1
                }
                ii = ii + 1
            }
            bi = bi + 1
        }

        if len(alias) > 0 {
            changed = true
            bi = 0
            while bi < len(func.blocks) {
                let block = func.blocks[bi]
                let mut ii = 0
                while ii < len(block.instructions) {
                    let mut oi = 0
                    while oi < len(block.instructions[ii].operands) {
                        if block.instructions[ii].operands[oi].kind == "value" {
                            let v = block.instructions[ii].operands[oi].value_id
                            let mut root = v
                            let mut r = kv_get(alias, root)
                            while r != -1 { root = r; r = kv_get(alias, root) }
                            if root != v { block.instructions[ii].operands[oi].value_id = root }
                        }
                        oi = oi + 1
                    }
                    ii = ii + 1
                }
                bi = bi + 1
            }
        }
        fi = fi + 1
    }

    return PassResult {
        changed: changed,
        stats: [StatEntry { key: "coalesced", value: coalesced }]
    }
}
