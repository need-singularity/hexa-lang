// self/opt/p12_verify.hexa — ported from src/opt/p12_verify.rs
// P12: IR Verification — read-only invariant check (no mutations).
// Validates that the IR is well-formed after all optimization passes.

fn pass_verify_name() -> string { return "verify" }

fn pass_verify_run(module: IrModule) -> PassResult {
    let mut errors = 0

    let mut fi = 0
    while fi < len(module.functions) {
        let func = module.functions[fi]

        // 1. Every block must end with a terminator
        let mut bi = 0
        while bi < len(func.blocks) {
            let block = func.blocks[bi]
            if len(block.instructions) > 0 {
                let last = block.instructions[len(block.instructions) - 1]
                if !is_terminator_op(last.op) { errors = errors + 1 }
            }
            bi = bi + 1
        }

        // 2. SSA: every value must be defined before use
        let mut defined: [int] = []
        let mut pi = 0
        while pi < len(func.params) {
            defined.push(pi)
            pi = pi + 1
        }
        bi = 0
        while bi < len(func.blocks) {
            let mut ii = 0
            while ii < len(func.blocks[bi].instructions) {
                let instr = func.blocks[bi].instructions[ii]
                let mut oi = 0
                while oi < len(instr.operands) {
                    let op = instr.operands[oi]
                    if op.kind == "value" && !int_list_contains(defined, op.value_id) && instr.op != "phi" {
                        errors = errors + 1
                    }
                    oi = oi + 1
                }
                defined = int_list_add_unique(defined, instr.result)
                ii = ii + 1
            }
            bi = bi + 1
        }

        // 3. No duplicate value definitions
        let mut all_defs: [int] = []
        bi = 0
        while bi < len(func.blocks) {
            let mut ii = 0
            while ii < len(func.blocks[bi].instructions) {
                let vid = func.blocks[bi].instructions[ii].result
                if int_list_contains(all_defs, vid) { errors = errors + 1 }
                all_defs.push(vid)
                ii = ii + 1
            }
            bi = bi + 1
        }

        // 4. Branch targets must exist
        let mut block_ids: [int] = []
        bi = 0
        while bi < len(func.blocks) {
            block_ids.push(func.blocks[bi].id)
            bi = bi + 1
        }
        bi = 0
        while bi < len(func.blocks) {
            let mut ii = 0
            while ii < len(func.blocks[bi].instructions) {
                let mut oi = 0
                while oi < len(func.blocks[bi].instructions[ii].operands) {
                    let op = func.blocks[bi].instructions[ii].operands[oi]
                    if (op.kind == "block" || op.kind == "switch_case" || op.kind == "phi_entry") && !int_list_contains(block_ids, op.block_id) {
                        errors = errors + 1
                    }
                    oi = oi + 1
                }
                ii = ii + 1
            }
            bi = bi + 1
        }

        // 5. Call targets must reference valid functions
        let mut func_ids: [int] = []
        let mut fk = 0
        while fk < len(module.functions) {
            func_ids.push(module.functions[fk].id)
            fk = fk + 1
        }
        bi = 0
        while bi < len(func.blocks) {
            let mut ii = 0
            while ii < len(func.blocks[bi].instructions) {
                let instr = func.blocks[bi].instructions[ii]
                if instr.op == "call" && len(instr.operands) > 0 && instr.operands[0].kind == "func" {
                    if !int_list_contains(func_ids, instr.operands[0].func_id) { errors = errors + 1 }
                }
                ii = ii + 1
            }
            bi = bi + 1
        }
        fi = fi + 1
    }

    return PassResult {
        changed: false,
        stats: [StatEntry { key: "errors", value: errors }]
    }
}
