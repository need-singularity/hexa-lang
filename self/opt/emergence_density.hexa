// self/opt/emergence_density.hexa — ported from src/opt/emergence_density.rs
// Emergence Density (ED) — convergence quality metric.
// ED = (1 - change_ratio) * speedup
// where change_ratio = current_changes / baseline_changes (0.0 = fully converged),
// and speedup = baseline_ns / current_ns (>= 1.0 = faster).

struct EdInput {
    baseline_changes: int,
    current_changes: int,
    baseline_ns: int,
    current_ns: int
}

// Compute emergence density. Returns ED * 1000 (integer millis).
// Use integer arithmetic to avoid float dependency.
fn compute_ed(input: EdInput) -> int {
    if input.current_ns == 0 { return 0 }
    if input.baseline_changes == 0 { return 0 }
    // change_ratio = current_changes / baseline_changes (x1000)
    let change_ratio_milli = input.current_changes * 1000 / input.baseline_changes
    // convergence = (1000 - change_ratio_milli) (clamped to >= 0)
    let mut convergence = 1000 - change_ratio_milli
    if convergence < 0 { convergence = 0 }
    // speedup = baseline_ns / current_ns (x1000)
    let speedup_milli = input.baseline_ns * 1000 / input.current_ns
    // ED = convergence * speedup / 1000 (in millis)
    return convergence * speedup_milli / 1000
}

struct EdHistory {
    values: [int]
}

fn ed_history_new() -> EdHistory {
    return EdHistory { values: [] }
}

fn ed_history_push(h: EdHistory, v: int) -> EdHistory {
    return EdHistory { values: h.values.push(v) }
}

// True if last 3 values are monotonically non-decreasing.
fn ed_history_is_monotone_up(h: EdHistory) -> bool {
    let n = len(h.values)
    if n < 3 { return true }
    return h.values[n - 3] <= h.values[n - 2] && h.values[n - 2] <= h.values[n - 1]
}

// True if last 3 values are strictly decreasing (regression).
fn ed_history_is_regressing(h: EdHistory) -> bool {
    let n = len(h.values)
    if n < 3 { return false }
    return h.values[n - 3] > h.values[n - 2] && h.values[n - 2] > h.values[n - 1]
}
