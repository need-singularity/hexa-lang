// self/opt/p05_inlining.hexa — ported from src/opt/p05_inlining.rs
// P5: Function Inlining — inline small functions at call sites.
// Threshold: sigma-tau = 8 instructions max.

fn inline_threshold() -> int { return 8 }
fn max_inlines_per_func() -> int { return 3 }

// Check if a function is inlinable: not main, <= 8 instructions.
fn is_inlinable(func_name: string, instr_count: int) -> bool {
    if func_name == "main" { return false }
    return instr_count <= inline_threshold()
}

// Inline a single call site (conceptual).
// Steps:
// 1. Allocate fresh ValueIds and BlockIds for cloned callee
// 2. Clone callee blocks with remapped operands
// 3. Replace Return with Jump to merge block
// 4. Split caller block at call site
// 5. Add Jump from caller to callee entry
// 6. Rewrite post-call instructions to use inlined return value
fn inline_call_site_conceptual() -> bool {
    return true
}

fn run_inlining_conceptual() -> PassResult {
    let mut inlined = 0
    let mut candidates = 0
    // Phase 1: Collect snapshots of inlinable callees
    // Phase 2: For each caller, find Call sites and inline (max 3 per func)
    // Process sites in reverse order so indices remain stable
    return PassResult {
        changed: inlined > 0,
        stat_keys: ["candidates", "inlined", "threshold"],
        stat_vals: [candidates, inlined, inline_threshold()]
    }
}
