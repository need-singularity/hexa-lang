// self/opt/mod.hexa — ported from src/opt/mod.rs
// sigma=12 Optimization Pipeline — 3 waves x 4 passes, fixed order.
//
// Front (P1-P4): TypeInfer -> OwnershipProof -> DeadStoreElim -> ConstFold
// Mid   (P5-P8): Inlining -> LICM -> CSE -> StrengthReduction
// Back  (P9-P12): CodeSinking -> Coalesce -> FinalDCE -> Verify

// Shared types used across all passes

struct IrModule {
    name: string,
    functions: [IrFunction]
}

struct IrFunction {
    id: int,
    name: string,
    params: [ParamDef],
    ret_type: string,
    blocks: [BasicBlock],
    value_types: [TypeEntry],
    next_value: int,
    next_block: int
}

struct BasicBlock {
    id: int,
    name: string,
    instructions: [IrInstr],
    preds: [int],
    succs: [int]
}

struct IrInstr {
    result: int,
    op: string,
    operands: [Operand],
    ty: string
}

struct Operand {
    kind: string,        // "value", "imm_i64", "imm_f64", "imm_bool", "block", "func",
                         // "param", "phi_entry", "switch_case", "string_ref", "cmp"
    value_id: int,
    int_val: int,
    float_val: float,
    bool_val: bool,
    block_id: int,
    func_id: int,
    param_idx: int,
    str_val: string
}

struct PassResult {
    changed: bool,
    stats: [StatEntry]
}

struct StatEntry {
    key: string,
    value: int
}

struct PipelineResult {
    pass_results: [PassResultEntry]
}

struct PassResultEntry {
    name: string,
    result: PassResult
}

// Run the full sigma=12 optimization pipeline.
fn run_pipeline(module: IrModule) -> PipelineResult {
    let pass_names = fixed_pass_order()
    let mut results: [PassResultEntry] = []

    let mut i = 0
    while i < len(pass_names) {
        let name = pass_names[i]
        let result = run_pass(module, name)
        results = results.push(PassResultEntry { name: name, result: result })
        i = i + 1
    }

    return PipelineResult { pass_results: results }
}

fn run_pass(module: IrModule, name: string) -> PassResult {
    if name == "type_infer" { return pass_type_infer_run(module) }
    if name == "ownership_proof" { return pass_ownership_proof_run(module) }
    if name == "dead_store" { return pass_dead_store_elim_run(module) }
    if name == "const_fold" { return pass_const_fold_run(module) }
    if name == "inlining" { return pass_inlining_run(module) }
    if name == "licm" { return pass_licm_run(module) }
    if name == "cse" { return pass_cse_run(module) }
    if name == "strength_reduction" { return pass_strength_reduction_run(module) }
    if name == "code_sinking" { return pass_code_sinking_run(module) }
    if name == "coalesce" { return pass_coalesce_run(module) }
    if name == "final_dce" { return pass_final_dce_run(module) }
    if name == "verify" { return pass_verify_run(module) }
    return PassResult { changed: false, stats: [] }
}

fn pipeline_total_changes(pr: PipelineResult) -> int {
    let mut count = 0
    let mut i = 0
    while i < len(pr.pass_results) {
        if pr.pass_results[i].result.changed { count = count + 1 }
        i = i + 1
    }
    return count
}

fn pipeline_summary(pr: PipelineResult) -> string {
    let mut out = "sigma=12 Pipeline: " + to_string(pipeline_total_changes(pr)) + "/12 passes made changes\n"
    let mut i = 0
    while i < len(pr.pass_results) {
        let entry = pr.pass_results[i]
        let mut status = "."
        if entry.result.changed { status = "+" }
        out = out + "  " + status + " " + entry.name
        let mut si = 0
        while si < len(entry.result.stats) {
            out = out + " [" + entry.result.stats[si].key + "=" + to_string(entry.result.stats[si].value) + "]"
            si = si + 1
        }
        out = out + "\n"
        i = i + 1
    }
    return out
}

struct EsoPipelineResult {
    pipeline: PipelineResult,
    metrics: [PassMetric]
}

// Run pipeline with policy-based pass ordering and metrics collection.
fn run_pipeline_with_policy(module: IrModule, policy: int, round: int, last_metrics: [PassMetric]) -> EsoPipelineResult {
    let order = next_order(policy, round, last_metrics)

    let mut results: [PassResultEntry] = []
    let mut metrics: [PassMetric] = []

    let mut i = 0
    while i < len(order) {
        let name = order[i]
        let before = capture_stats_from_module(module)
        let start_ns = time_ns()
        let result = run_pass(module, name)
        let elapsed = time_ns() - start_ns
        let after = capture_stats_from_module(module)

        metrics = metrics.push(PassMetric {
            pass_name: name,
            before: before,
            after: after,
            elapsed_ns: elapsed
        })
        results = results.push(PassResultEntry { name: name, result: result })
        i = i + 1
    }

    return EsoPipelineResult {
        pipeline: PipelineResult { pass_results: results },
        metrics: metrics
    }
}

fn capture_stats_from_module(module: IrModule) -> Stats {
    let mut ic = 0
    let mut bc = 0
    let mut fi = 0
    while fi < len(module.functions) {
        let func = module.functions[fi]
        bc = bc + len(func.blocks)
        let mut bi = 0
        while bi < len(func.blocks) {
            ic = ic + len(func.blocks[bi].instructions)
            bi = bi + 1
        }
        fi = fi + 1
    }
    return Stats { instr_count: ic, block_count: bc, func_count: len(module.functions) }
}

// Shared helpers used across passes

fn is_terminator_op(op: string) -> bool {
    return op == "jump" || op == "branch" || op == "return" || op == "switch"
}

fn has_side_effect_op(op: string) -> bool {
    return op == "store" || op == "call" || op == "print"
}

fn is_proof_op(op: string) -> bool {
    return op == "assert" || op == "assume" || op == "invariant"
}

// KvPair: simple int->int map
struct KvPair { key: int, val: int }

fn kv_set(pairs: [KvPair], key: int, val: int) -> [KvPair] {
    let mut i = 0
    while i < len(pairs) {
        if pairs[i].key == key { pairs[i].val = val; return pairs }
        i = i + 1
    }
    return pairs.push(KvPair { key: key, val: val })
}

fn kv_get(pairs: [KvPair], key: int) -> int {
    let mut i = 0
    while i < len(pairs) {
        if pairs[i].key == key { return pairs[i].val }
        i = i + 1
    }
    return -1
}

fn int_list_contains(list: [int], val: int) -> bool {
    let mut i = 0
    while i < len(list) {
        if list[i] == val { return true }
        i = i + 1
    }
    return false
}

fn int_list_add_unique(list: [int], val: int) -> [int] {
    if int_list_contains(list, val) { return list }
    return list.push(val)
}
