// self/opt/p02_ownership.hexa — ported from src/opt/p02_ownership.rs
// P2: mem2reg — promote alloca variables to SSA registers with phi insertion.
//
// Phase ordering (critical for correctness):
//   Phase 2 runs FIRST: Cross-block phi insertion for while loops
//   Phase 1 runs SECOND: Same-block store->load forwarding (simple)

// Find the last Store(alloca_id, val) in a block.
// block_instrs: array of instructions [result, op, operand1, operand2, ...]
// alloca_id: the ValueId of the alloca to search for.
// Returns the stored ValueId or -1 if not found.
fn find_last_store_val(block_instrs: [[int]], alloca_id: int) -> int {
    let mut last = -1
    let mut i = 0
    while i < len(block_instrs) {
        let instr = block_instrs[i]
        // instr[1] == STORE opcode (assume opcode tag for Store)
        // instr[2] == ptr operand, instr[3] == val operand
        if len(instr) >= 4 {
            if instr[1] == 5 {  // Store opcode tag
                if instr[2] == alloca_id {
                    last = instr[3]
                }
            }
        }
        i = i + 1
    }
    return last
}

// Promote allocas to SSA registers.
// Returns count of promoted operations.
fn promote_allocas_conceptual(num_blocks: int) -> int {
    // Phase 2: Cross-block phi insertion
    // 1. Find alloca ValueIds
    // 2. Check promotability (only used in Store as ptr, and Load as ptr)
    // 3. Detect back-edges for loops
    // 4. For each loop: find preheader init value and body update value
    // 5. Insert Phi at header block
    // 6. Replace Load(alloca) with Copy(phi_vid) in loop body
    //
    // Phase 1: Same-block store->load forwarding
    // 1. Walk block instructions sequentially
    // 2. Track last stored value per alloca pointer
    // 3. When Load(ptr) seen and last_stored[ptr] known, replace with Copy(val)
    return 0
}

fn run_ownership_proof() -> PassResult {
    let promoted = promote_allocas_conceptual(0)
    return PassResult {
        changed: promoted > 0,
        stat_keys: ["promoted"],
        stat_vals: [promoted]
    }
}
