// self/opt/p08_strength.hexa — ported from src/opt/p08_strength.rs
// P8: Strength Reduction — replace expensive ops with cheaper equivalents.

// Strength reduction rules:
//   x * 0 -> 0
//   x * 1 -> x (Copy)
//   x * 2 -> x + x
//   x / 1 -> x (Copy)
//   x / x -> 1
//   x % 1 -> 0
//   x % x -> 0
//   x + 0 -> x (Copy)
//   x - 0 -> x (Copy)
//   x - x -> 0
//   neg(neg(x)) -> x

// Check if immediate value triggers a strength reduction for given opcode.
// op: 0=Add, 1=Sub, 2=Mul, 3=Div, 4=Mod
// Returns: 0=no reduction, 1=identity(Copy), 2=zero, 3=double(Add)
fn strength_reduce_imm(op: int, imm: int) -> int {
    // Mul reductions
    if op == 2 {
        if imm == 0 { return 2 }   // x * 0 = 0
        if imm == 1 { return 1 }   // x * 1 = x
        if imm == 2 { return 3 }   // x * 2 = x + x
    }
    // Div reductions
    if op == 3 {
        if imm == 1 { return 1 }   // x / 1 = x
    }
    // Mod reductions
    if op == 4 {
        if imm == 1 { return 2 }   // x % 1 = 0
    }
    // Add reductions
    if op == 0 {
        if imm == 0 { return 1 }   // x + 0 = x
    }
    // Sub reductions
    if op == 1 {
        if imm == 0 { return 1 }   // x - 0 = x
    }
    return 0
}

// Check if two operands are the same SSA value -> special reduction.
fn strength_reduce_same_val(op: int) -> int {
    if op == 3 { return 11 }   // x / x = 1
    if op == 4 { return 2 }    // x % x = 0
    if op == 1 { return 2 }    // x - x = 0
    return 0
}

fn run_strength_reduction_conceptual() -> PassResult {
    let mut reduced = 0
    // For each function, block, instruction:
    //   Match (op, operands) against reduction rules
    //   Apply transformation: Copy, Load(0), Add(x,x), etc.
    // Second sweep: detect neg(neg(x)) -> Copy(x)
    return PassResult {
        changed: reduced > 0,
        stat_keys: ["reduced"],
        stat_vals: [reduced]
    }
}
