// self/opt/p08_strength.hexa — ported from src/opt/p08_strength.rs
// P8: Strength Reduction — replace expensive ops with cheaper equivalents.

fn pass_strength_reduction_name() -> string { return "strength_reduction" }

struct NegRepl { result_id: int, orig_op: Operand }

fn pass_strength_reduction_run(module: IrModule) -> PassResult {
    let mut changed = false
    let mut reduced = 0

    let mut fi = 0
    while fi < len(module.functions) {
        let func = module.functions[fi]

        let mut bi = 0
        while bi < len(func.blocks) {
            let block = func.blocks[bi]
            let mut ii = 0
            while ii < len(block.instructions) {
                let instr = block.instructions[ii]
                let ops = instr.operands
                let n = len(ops)

                // Multiply reductions
                if instr.op == "mul" && n == 2 {
                    // x * 0 -> 0
                    if (ops[0].kind == "value" && ops[1].kind == "imm_i64" && ops[1].int_val == 0) || (ops[0].kind == "imm_i64" && ops[0].int_val == 0 && ops[1].kind == "value") {
                        instr.op = "load"; instr.operands = [Operand { kind: "imm_i64", int_val: 0 }]
                        changed = true; reduced = reduced + 1
                    }
                    // x * 1 -> x
                    else if ops[0].kind == "value" && ops[1].kind == "imm_i64" && ops[1].int_val == 1 {
                        instr.op = "copy"; instr.operands = [ops[0]]
                        changed = true; reduced = reduced + 1
                    } else if ops[0].kind == "imm_i64" && ops[0].int_val == 1 && ops[1].kind == "value" {
                        instr.op = "copy"; instr.operands = [ops[1]]
                        changed = true; reduced = reduced + 1
                    }
                    // x * 2 -> x + x
                    else if ops[0].kind == "value" && ops[1].kind == "imm_i64" && ops[1].int_val == 2 {
                        instr.op = "add"; instr.operands = [ops[0], ops[0]]
                        changed = true; reduced = reduced + 1
                    } else if ops[0].kind == "imm_i64" && ops[0].int_val == 2 && ops[1].kind == "value" {
                        instr.op = "add"; instr.operands = [ops[1], ops[1]]
                        changed = true; reduced = reduced + 1
                    }
                }

                // Division reductions
                if instr.op == "div" && n == 2 {
                    if ops[0].kind == "value" && ops[1].kind == "imm_i64" && ops[1].int_val == 1 {
                        instr.op = "copy"; instr.operands = [ops[0]]
                        changed = true; reduced = reduced + 1
                    } else if ops[0].kind == "value" && ops[1].kind == "value" && ops[0].value_id == ops[1].value_id {
                        instr.op = "load"; instr.operands = [Operand { kind: "imm_i64", int_val: 1 }]
                        changed = true; reduced = reduced + 1
                    }
                }

                // Modulo reductions
                if instr.op == "mod" && n == 2 {
                    if ops[1].kind == "imm_i64" && ops[1].int_val == 1 {
                        instr.op = "load"; instr.operands = [Operand { kind: "imm_i64", int_val: 0 }]
                        changed = true; reduced = reduced + 1
                    } else if ops[0].kind == "value" && ops[1].kind == "value" && ops[0].value_id == ops[1].value_id {
                        instr.op = "load"; instr.operands = [Operand { kind: "imm_i64", int_val: 0 }]
                        changed = true; reduced = reduced + 1
                    }
                }

                // Addition: x + 0 -> x
                if instr.op == "add" && n == 2 {
                    if ops[0].kind == "value" && ops[1].kind == "imm_i64" && ops[1].int_val == 0 {
                        instr.op = "copy"; instr.operands = [ops[0]]
                        changed = true; reduced = reduced + 1
                    } else if ops[0].kind == "imm_i64" && ops[0].int_val == 0 && ops[1].kind == "value" {
                        instr.op = "copy"; instr.operands = [ops[1]]
                        changed = true; reduced = reduced + 1
                    }
                }

                // Subtraction: x - 0 -> x, x - x -> 0
                if instr.op == "sub" && n == 2 {
                    if ops[0].kind == "value" && ops[1].kind == "imm_i64" && ops[1].int_val == 0 {
                        instr.op = "copy"; instr.operands = [ops[0]]
                        changed = true; reduced = reduced + 1
                    } else if ops[0].kind == "value" && ops[1].kind == "value" && ops[0].value_id == ops[1].value_id {
                        instr.op = "load"; instr.operands = [Operand { kind: "imm_i64", int_val: 0 }]
                        changed = true; reduced = reduced + 1
                    }
                }
                ii = ii + 1
            }
            bi = bi + 1
        }

        // Second sweep: neg(neg(x)) -> x
        let mut neg_repls: [NegRepl] = []
        bi = 0
        while bi < len(func.blocks) {
            let block = func.blocks[bi]
            let mut ii = 0
            while ii < len(block.instructions) {
                let instr = block.instructions[ii]
                if instr.op == "neg" && len(instr.operands) > 0 && instr.operands[0].kind == "value" {
                    let inner_id = instr.operands[0].value_id
                    let mut b2 = 0
                    while b2 < len(func.blocks) {
                        let mut i2 = 0
                        while i2 < len(func.blocks[b2].instructions) {
                            let inst2 = func.blocks[b2].instructions[i2]
                            if inst2.result == inner_id && inst2.op == "neg" && len(inst2.operands) > 0 {
                                neg_repls = neg_repls.push(NegRepl { result_id: instr.result, orig_op: inst2.operands[0] })
                            }
                            i2 = i2 + 1
                        }
                        b2 = b2 + 1
                    }
                }
                ii = ii + 1
            }
            bi = bi + 1
        }
        let mut ni = 0
        while ni < len(neg_repls) {
            bi = 0
            while bi < len(func.blocks) {
                let mut ii = 0
                while ii < len(func.blocks[bi].instructions) {
                    if func.blocks[bi].instructions[ii].result == neg_repls[ni].result_id {
                        func.blocks[bi].instructions[ii].op = "copy"
                        func.blocks[bi].instructions[ii].operands = [neg_repls[ni].orig_op]
                        changed = true; reduced = reduced + 1
                    }
                    ii = ii + 1
                }
                bi = bi + 1
            }
            ni = ni + 1
        }
        fi = fi + 1
    }

    return PassResult {
        changed: changed,
        stats: [StatEntry { key: "reduced", value: reduced }]
    }
}
