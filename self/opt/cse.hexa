// self/opt/p07_cse.hexa — ported from src/opt/p07_cse.rs
// P7: Common Subexpression Elimination — deduplicate identical computations.
//
// Cross-block CSE, operand canonicalization for commutative ops, dead removal.

fn pass_cse_name() -> string { return "cse" }

struct ExprEntry { key: string, vid: int }

fn pass_cse_run(module: IrModule) -> PassResult {
    let mut changed = false
    let mut eliminated = 0

    let mut fi = 0
    while fi < len(module.functions) {
        let func = module.functions[fi]
        let mut seen: [ExprEntry] = []
        let mut replacements: [KvPair] = []

        let mut bi = 0
        while bi < len(func.blocks) {
            let block = func.blocks[bi]
            let mut ii = 0
            while ii < len(block.instructions) {
                let instr = block.instructions[ii]

                if has_side_effect_op(instr.op) || is_terminator_op(instr.op) || is_proof_op(instr.op) || instr.op == "phi" || instr.op == "load" {
                    ii = ii + 1
                    continue
                }

                let key = make_expr_key(instr.op, instr.operands)
                let existing = expr_lookup(seen, key)
                if existing != -1 {
                    replacements = kv_set(replacements, instr.result, existing)
                    changed = true
                    eliminated = eliminated + 1
                } else {
                    seen.push(ExprEntry { key: key, vid: instr.result })
                }
                ii = ii + 1
            }
            bi = bi + 1
        }

        if len(replacements) > 0 {
            // Rewrite operand references
            bi = 0
            while bi < len(func.blocks) {
                let block = func.blocks[bi]
                let mut ii = 0
                while ii < len(block.instructions) {
                    let mut oi = 0
                    while oi < len(block.instructions[ii].operands) {
                        if block.instructions[ii].operands[oi].kind == "value" {
                            let r = kv_get(replacements, block.instructions[ii].operands[oi].value_id)
                            if r != -1 { block.instructions[ii].operands[oi].value_id = r }
                        }
                        oi = oi + 1
                    }
                    ii = ii + 1
                }
                bi = bi + 1
            }
            // Convert replaced instructions to Load
            bi = 0
            while bi < len(func.blocks) {
                let block = func.blocks[bi]
                let mut ii = 0
                while ii < len(block.instructions) {
                    let r = kv_get(replacements, block.instructions[ii].result)
                    if r != -1 {
                        block.instructions[ii].op = "load"
                        block.instructions[ii].operands = [Operand { kind: "value", value_id: r }]
                    }
                    ii = ii + 1
                }
                bi = bi + 1
            }
        }
        fi = fi + 1
    }

    return PassResult {
        changed: changed,
        stats: [StatEntry { key: "eliminated", value: eliminated }]
    }
}

fn is_commutative_op(op: string) -> bool {
    return op == "add" || op == "mul"
}

fn make_expr_key(op: string, operands: [Operand]) -> string {
    let mut keys: [string] = []
    let mut i = 0
    while i < len(operands) {
        keys.push(op_key(operands[i]))
        i = i + 1
    }
    if is_commutative_op(op) && len(keys) == 2 && keys[0] > keys[1] {
        let tmp = keys[0]
        keys[0] = keys[1]
        keys[1] = tmp
    }
    let mut result = op
    i = 0
    while i < len(keys) {
        result = result + "|" + keys[i]
        i = i + 1
    }
    return result
}

fn op_key(op: Operand) -> string {
    if op.kind == "value" { return "v" + to_string(op.value_id) }
    if op.kind == "imm_i64" { return "i" + to_string(op.int_val) }
    if op.kind == "imm_f64" { return "f" + to_string(op.float_val) }
    if op.kind == "imm_bool" { return "b" + to_string(op.bool_val) }
    if op.kind == "block" { return "B" + to_string(op.block_id) }
    return "?"
}

fn expr_lookup(seen: [ExprEntry], key: string) -> int {
    let mut i = 0
    while i < len(seen) {
        if seen[i].key == key { return seen[i].vid }
        i = i + 1
    }
    return -1
}
