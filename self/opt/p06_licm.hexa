// self/opt/p06_licm.hexa — ported from src/opt/p06_licm.rs
// P6: Loop Invariant Code Motion — hoist constants and invariant
// computations out of loops into the preheader (entry block).

// Check if all operands of an instruction are loop-invariant.
fn all_operands_invariant(operand_vids: [int], invariant_set: [int]) -> bool {
    let mut i = 0
    while i < len(operand_vids) {
        let vid = operand_vids[i]
        if vid >= 0 {
            if !array_contains(invariant_set, vid) {
                return false
            }
        }
        i = i + 1
    }
    return true
}

// Check if instruction is a constant load (Load with immediate operand).
fn is_const_load(op: int, first_operand_tag: int) -> bool {
    // op == Load opcode tag, first_operand is ImmI64/ImmF64/ImmBool
    return op == 4 && first_operand_tag >= 0 && first_operand_tag <= 2
}

// Collect loop body blocks via predecessor walk.
fn collect_loop_body(preds: [[int]], node: int, header: int, body: [int]) -> [int] {
    let mut b = body
    if node < 0 { return b }
    let node_preds = preds[node]
    let mut i = 0
    while i < len(node_preds) {
        let pred = node_preds[i]
        if !array_contains(b, pred) {
            b = b.push(pred)
            if pred != header {
                b = collect_loop_body(preds, pred, header, b)
            }
        }
        i = i + 1
    }
    return b
}

fn run_licm_conceptual() -> PassResult {
    let mut hoisted = 0
    // For each function:
    //   1. Rebuild CFG, detect back-edges (B->H where H.id < B.id)
    //   2. Collect loop body blocks
    //   3. Identify invariant values (defined outside loop)
    //   4. Iteratively find hoistable instructions
    //   5. Clone to entry block, replace originals with Copy
    return PassResult {
        changed: hoisted > 0,
        stat_keys: ["hoisted"],
        stat_vals: [hoisted]
    }
}
