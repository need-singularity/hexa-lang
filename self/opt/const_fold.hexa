// self/opt/p04_const_fold.hexa — ported from src/opt/p04_const_fold.rs
// P4: Constant Folding — evaluate constant expressions at compile time.
//
// Enhanced with value tracking, float/boolean folding, fixpoint iteration.

fn pass_const_fold_name() -> string {
    return "const_fold"
}

struct ConstEntry { vid: int, op: Operand }

fn pass_const_fold_run(module: IrModule) -> PassResult {
    let mut total_folded = 0
    let mut changed_any = false

    let mut fi = 0
    while fi < len(module.functions) {
        let func = module.functions[fi]

        // Fixpoint: keep folding until no more changes
        let mut keep_going = true
        while keep_going {
            let mut changed = false
            let mut folded = 0

            // Phase 1: Build value->constant map from Load instructions
            let mut known: [ConstEntry] = []
            let mut bi = 0
            while bi < len(func.blocks) {
                let block = func.blocks[bi]
                let mut ii = 0
                while ii < len(block.instructions) {
                    let instr = block.instructions[ii]
                    if instr.op == "load" && len(instr.operands) == 1 {
                        let op = instr.operands[0]
                        if op.kind == "imm_i64" || op.kind == "imm_f64" || op.kind == "imm_bool" {
                            known = const_set(known, instr.result, op)
                        }
                    }
                    ii = ii + 1
                }
                bi = bi + 1
            }

            // Phase 2: Try to fold each instruction
            bi = 0
            while bi < len(func.blocks) {
                let block = func.blocks[bi]
                let mut ii = 0
                while ii < len(block.instructions) {
                    let instr = block.instructions[ii]
                    if instr.op == "load" || has_side_effect_op(instr.op) || is_terminator_op(instr.op) || is_proof_op(instr.op) {
                        ii = ii + 1
                        continue
                    }

                    // Resolve operands
                    let mut resolved: [Operand] = []
                    let mut oi = 0
                    while oi < len(instr.operands) {
                        let op = instr.operands[oi]
                        if op.kind == "value" {
                            let known_op = const_get(known, op.value_id)
                            if known_op.kind != "" {
                                resolved.push(known_op)
                            } else {
                                resolved.push(op)
                            }
                        } else {
                            resolved.push(op)
                        }
                        oi = oi + 1
                    }

                    let result = try_fold(instr.op, resolved)
                    if result.kind != "" {
                        known = const_set(known, instr.result, result)
                        instr.op = "load"
                        instr.operands = [result]
                        changed = true
                        folded = folded + 1
                    }
                    ii = ii + 1
                }
                bi = bi + 1
            }

            total_folded = total_folded + folded
            if changed { changed_any = true } else { keep_going = false }
        }
        fi = fi + 1
    }

    return PassResult {
        changed: changed_any,
        stats: [StatEntry { key: "folded", value: total_folded }]
    }
}

fn try_fold(op: string, ops: [Operand]) -> Operand {
    let n = len(ops)
    // Integer arithmetic
    if op == "add" && n == 2 && ops[0].kind == "imm_i64" && ops[1].kind == "imm_i64" {
        return Operand { kind: "imm_i64", int_val: ops[0].int_val + ops[1].int_val }
    }
    if op == "sub" && n == 2 && ops[0].kind == "imm_i64" && ops[1].kind == "imm_i64" {
        return Operand { kind: "imm_i64", int_val: ops[0].int_val - ops[1].int_val }
    }
    if op == "mul" && n == 2 && ops[0].kind == "imm_i64" && ops[1].kind == "imm_i64" {
        return Operand { kind: "imm_i64", int_val: ops[0].int_val * ops[1].int_val }
    }
    if op == "div" && n == 2 && ops[0].kind == "imm_i64" && ops[1].kind == "imm_i64" && ops[1].int_val != 0 {
        return Operand { kind: "imm_i64", int_val: ops[0].int_val / ops[1].int_val }
    }
    if op == "mod" && n == 2 && ops[0].kind == "imm_i64" && ops[1].kind == "imm_i64" && ops[1].int_val != 0 {
        return Operand { kind: "imm_i64", int_val: ops[0].int_val % ops[1].int_val }
    }
    if op == "neg" && n == 1 && ops[0].kind == "imm_i64" {
        return Operand { kind: "imm_i64", int_val: 0 - ops[0].int_val }
    }
    // Float arithmetic
    if op == "add" && n == 2 && ops[0].kind == "imm_f64" && ops[1].kind == "imm_f64" {
        return Operand { kind: "imm_f64", float_val: ops[0].float_val + ops[1].float_val }
    }
    if op == "sub" && n == 2 && ops[0].kind == "imm_f64" && ops[1].kind == "imm_f64" {
        return Operand { kind: "imm_f64", float_val: ops[0].float_val - ops[1].float_val }
    }
    if op == "mul" && n == 2 && ops[0].kind == "imm_f64" && ops[1].kind == "imm_f64" {
        return Operand { kind: "imm_f64", float_val: ops[0].float_val * ops[1].float_val }
    }
    if op == "div" && n == 2 && ops[0].kind == "imm_f64" && ops[1].kind == "imm_f64" && ops[1].float_val != 0.0 {
        return Operand { kind: "imm_f64", float_val: ops[0].float_val / ops[1].float_val }
    }
    if op == "neg" && n == 1 && ops[0].kind == "imm_f64" {
        return Operand { kind: "imm_f64", float_val: 0.0 - ops[0].float_val }
    }
    // Identity: x + 0, 0 + x, x - 0
    if op == "add" && n == 2 {
        if ops[0].kind == "value" && ops[1].kind == "imm_i64" && ops[1].int_val == 0 { return ops[0] }
        if ops[1].kind == "value" && ops[0].kind == "imm_i64" && ops[0].int_val == 0 { return ops[1] }
        if ops[0].kind == "value" && ops[1].kind == "imm_f64" && ops[1].float_val == 0.0 { return ops[0] }
        if ops[1].kind == "value" && ops[0].kind == "imm_f64" && ops[0].float_val == 0.0 { return ops[1] }
    }
    if op == "sub" && n == 2 {
        if ops[0].kind == "value" && ops[1].kind == "imm_i64" && ops[1].int_val == 0 { return ops[0] }
        if ops[0].kind == "value" && ops[1].kind == "imm_f64" && ops[1].float_val == 0.0 { return ops[0] }
    }
    if op == "mul" && n == 2 {
        if ops[0].kind == "value" && ops[1].kind == "imm_i64" && ops[1].int_val == 1 { return ops[0] }
        if ops[1].kind == "value" && ops[0].kind == "imm_i64" && ops[0].int_val == 1 { return ops[1] }
        if ops[0].kind == "value" && ops[1].kind == "imm_f64" && ops[1].float_val == 1.0 { return ops[0] }
        if ops[1].kind == "value" && ops[0].kind == "imm_f64" && ops[0].float_val == 1.0 { return ops[1] }
    }
    // x * 0 = 0
    if op == "mul" && n == 2 {
        if ops[1].kind == "imm_i64" && ops[1].int_val == 0 { return Operand { kind: "imm_i64", int_val: 0 } }
        if ops[0].kind == "imm_i64" && ops[0].int_val == 0 { return Operand { kind: "imm_i64", int_val: 0 } }
        if ops[1].kind == "imm_f64" && ops[1].float_val == 0.0 { return Operand { kind: "imm_f64", float_val: 0.0 } }
        if ops[0].kind == "imm_f64" && ops[0].float_val == 0.0 { return Operand { kind: "imm_f64", float_val: 0.0 } }
    }
    return Operand { kind: "" }
}

fn has_side_effect_op(op: string) -> bool {
    return op == "store" || op == "call" || op == "print"
}

fn is_proof_op(op: string) -> bool {
    return op == "assert" || op == "assume" || op == "invariant"
}

fn const_set(entries: [ConstEntry], vid: int, op: Operand) -> [ConstEntry] {
    let mut i = 0
    while i < len(entries) {
        if entries[i].vid == vid { entries[i].op = op; return entries }
        i = i + 1
    }
    return entries.push(ConstEntry { vid: vid, op: op })
}

fn const_get(entries: [ConstEntry], vid: int) -> Operand {
    let mut i = 0
    while i < len(entries) {
        if entries[i].vid == vid { return entries[i].op }
        i = i + 1
    }
    return Operand { kind: "" }
}
