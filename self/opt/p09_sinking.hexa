// self/opt/p09_sinking.hexa — ported from src/opt/p09_sinking.rs
// P9: Code Sinking — move computations closer to their use sites.
// Sinks instructions from a dominator block into the single successor
// that uses the result, reducing register pressure.

// Check if an instruction can safely be moved (sinkable).
fn is_sinkable(op: int) -> bool {
    // Not side-effecting, not terminator, not proof, not phi
    // In the Hexa port, we check against known non-sinkable opcode tags.
    // Terminators: Jump, Branch, Return, Switch
    // Side-effecting: Store, Call, Free
    // Proof: Assert, Assume, Invariant
    // Phi: must stay at block start
    let non_sinkable = [20, 21, 22, 23, 5, 6, 7, 30, 31, 32, 33]
    let mut i = 0
    while i < len(non_sinkable) {
        if op == non_sinkable[i] { return false }
        i = i + 1
    }
    return true
}

// Simple dominator check: B dominates S if B is S's only predecessor.
fn dominates_simple(block_b: int, block_s: int, pred_map: [[int]]) -> bool {
    if block_s < len(pred_map) {
        let preds = pred_map[block_s]
        return len(preds) == 1 && preds[0] == block_b
    }
    return false
}

fn run_code_sinking_conceptual() -> PassResult {
    let mut sunk = 0
    // For each function:
    //   Rebuild CFG
    //   Loop (fixpoint):
    //     Build pred_map, succ_map, use_sites, def_site maps
    //     Find one sink candidate: instruction used in exactly one successor block
    //     Check: target is successor, B dominates target, operands available
    //     Move instruction from source to target (insert after phis)
    //   Until no more candidates
    return PassResult {
        changed: sunk > 0,
        stat_keys: ["sunk"],
        stat_vals: [sunk]
    }
}
