// self/opt/p01_type_infer.hexa — ported from src/opt/p01_type_infer.rs
// P1: Type Inference — resolve untyped values via context propagation.

fn pass_type_infer_name() -> string {
    return "type_infer"
}

fn pass_type_infer_run(module: IrModule) -> PassResult {
    let mut changed = false
    let mut inferred = 0

    let mut fi = 0
    while fi < len(module.functions) {
        let func = module.functions[fi]
        let mut bi = 0
        while bi < len(func.blocks) {
            let block = func.blocks[bi]
            let mut ii = 0
            while ii < len(block.instructions) {
                let instr = block.instructions[ii]
                if instr.ty == "i64" {
                    let better = infer_from_op(instr.op, func.value_types, instr.operands)
                    if better != "" && better != instr.ty {
                        instr.ty = better
                        changed = true
                        inferred = inferred + 1
                    }
                }
                ii = ii + 1
            }
            bi = bi + 1
        }
        fi = fi + 1
    }

    return PassResult {
        changed: changed,
        stats: [StatEntry { key: "inferred", value: inferred }]
    }
}

fn infer_from_op(op: string, types: [TypeEntry], operands: [Operand]) -> string {
    // Arithmetic inherits from first operand
    if op == "add" || op == "sub" || op == "mul" || op == "div" || op == "mod" {
        if len(operands) > 0 && operands[0].kind == "value" {
            return type_entry_get(types, operands[0].value_id)
        }
    }
    // Assert/Assume/Invariant produce void
    if op == "assert" || op == "assume" || op == "invariant" {
        return "void"
    }
    // Load from immediate
    if op == "load" && len(operands) > 0 {
        if operands[0].kind == "imm_f64" { return "f64" }
        if operands[0].kind == "imm_bool" { return "bool" }
        if operands[0].kind == "string_ref" { return "str" }
    }
    return ""
}

struct TypeEntry {
    vid: int,
    ty: string
}

fn type_entry_get(entries: [TypeEntry], vid: int) -> string {
    let mut i = 0
    while i < len(entries) {
        if entries[i].vid == vid { return entries[i].ty }
        i = i + 1
    }
    return ""
}
