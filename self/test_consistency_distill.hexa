// ═══════════════════════════════════════════════════════════════════
//  test_consistency_distill.hexa — Consistency Distillation (#344)
// ═══════════════════════════════════════════════════════════════════

import "ml/consistency_distill.hexa"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs_(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx_(a, b, eps) { return fabs_(a - b) < eps }

println("=== Consistency Distillation (#344) ===")

let dim = 2
let hidden = 4
let sigma_data = 0.5
let eps_val = 0.002

let student = cd_init(dim, hidden, sigma_data, eps_val, 42)
let teacher = cd_teacher_init(dim, hidden, 999)
let ema = cd_ema_init(student)

// ── T1 student model init shapes ──────────────────────────────
check("T1 W1 shape", len(student["W1"]) == hidden)
check("T1 W1[0] shape", len(student["W1"][0]) == dim)
check("T1 W2 shape", len(student["W2"]) == dim)
check("T1 W2[0] shape", len(student["W2"][0]) == hidden)
check("T1 W_t len", len(student["W_t"]) == hidden)
check("T1 b1 len", len(student["b1"]) == hidden)
check("T1 b2 len", len(student["b2"]) == dim)

// ── T2 teacher model init shapes ──────────────────────────────
check("T2 teacher W1 shape", len(teacher["W1"]) == hidden)
check("T2 teacher dim", teacher["dim"] == dim)

// ── T3 EMA is a copy of student ───────────────────────────────
let mut ema_match = true
for i in 0..hidden {
    for j in 0..dim {
        if fabs_(ema["W1"][i][j] - student["W1"][i][j]) > 1.0e-9 {
            ema_match = false
        }
    }
}
check("T3 EMA init matches student", ema_match)

// ── T4 skip coefficient boundary condition ────────────────────
let c_skip_at_eps = cd_skip_coeff(sigma_data, eps_val, eps_val)
check("T4 c_skip(eps) = 1.0", approx_(c_skip_at_eps, 1.0, 1.0e-6))

// c_skip(t) in (0, 1] for t > eps
let c_skip_mid = cd_skip_coeff(sigma_data, eps_val, 1.0)
check("T4 c_skip(1.0) in (0,1]", c_skip_mid > 0.0)
check("T4 c_skip(1.0) <= 1", c_skip_mid <= 1.0)

// c_skip decreases with t
let c_skip_high = cd_skip_coeff(sigma_data, eps_val, 10.0)
check("T4 c_skip decreasing", c_skip_high < c_skip_mid)

// ── T5 out coefficient boundary condition ─────────────────────
let c_out_at_eps = cd_out_coeff(sigma_data, eps_val, eps_val)
check("T5 c_out(eps) ~ 0", fabs_(c_out_at_eps) < 0.01)

let c_out_1 = cd_out_coeff(sigma_data, eps_val, 1.0)
let c_out_5 = cd_out_coeff(sigma_data, eps_val, 5.0)
check("T5 c_out grows with t", fabs_(c_out_5) > fabs_(c_out_1))

// ── T6 boundary condition: f(x, eps) = x ──────────────────────
let x_test = [0.7, -0.3]
let f_at_eps = cd_denoise(student, x_test, eps_val)
let mut boundary_ok = true
for i in 0..dim {
    if fabs_(f_at_eps[i] - x_test[i]) > 0.05 { boundary_ok = false }
}
check("T6 f(x, eps) ~ x boundary", boundary_ok)

// ── T7 denoise output dimension ───────────────────────────────
let x_noisy = [1.0, -0.5]
let f_out = cd_denoise(student, x_noisy, 1.0)
check("T7 denoise output dim", len(f_out) == dim)

// ── T8 teacher denoise output dimension ───────────────────────
let t_out = cd_teacher_denoise(teacher, x_noisy, 1.0)
check("T8 teacher denoise dim", len(t_out) == dim)

// ── T9 ODE step output dimension ──────────────────────────────
let x_ode_in = [0.5, -0.2]
let x_ode_out = cd_ode_step(teacher, x_ode_in, 2.0, 1.0)
check("T9 ODE step output dim", len(x_ode_out) == dim)

// ── T10 ODE step changes x ────────────────────────────────────
let mut ode_changed = false
for i in 0..dim {
    if fabs_(x_ode_out[i] - x_ode_in[i]) > 1.0e-9 { ode_changed = true }
}
check("T10 ODE step modifies x", ode_changed)

// ── T11 Karras schedule properties ────────────────────────────
let sched = cd_karras_schedule(0.002, 80.0, 5, 7.0)
check("T11 schedule length", len(sched) == 5)
check("T11 schedule starts at sigma_max", approx_(sched[0], 80.0, 1.0))
check("T11 schedule ends near sigma_min", sched[4] < 0.1)
// Monotonically decreasing
let mut sched_mono = true
for i in 1..5 {
    if sched[i] >= sched[i - 1] { sched_mono = false }
}
check("T11 schedule monotone decreasing", sched_mono)

// ── T12 distillation loss is non-negative ─────────────────────
let x0 = [0.5, 0.3]
let noise = [0.1, -0.2]
let loss_val = cd_distill_loss(student, ema, teacher, x0, noise, 2.0, 1.0)
check("T12 distill loss >= 0", loss_val >= 0.0)

// ── T13 Huber loss is non-negative ────────────────────────────
let a_vec = [1.0, 2.0, 3.0]
let b_vec = [1.1, 2.2, 2.8]
let hub = cd_huber_loss(a_vec, b_vec, 0.5)
check("T13 Huber loss >= 0", hub >= 0.0)

// Huber loss is 0 for identical vectors
let hub_zero = cd_huber_loss(a_vec, a_vec, 0.5)
check("T13 Huber(a,a) = 0", approx_(hub_zero, 0.0, 1.0e-9))

// ── T14 Huber distill loss is non-negative ────────────────────
let hub_loss = cd_distill_loss_huber(student, ema, teacher, x0, noise, 2.0, 1.0, 0.5)
check("T14 Huber distill loss >= 0", hub_loss >= 0.0)

// ── T15 add_noise correctness ─────────────────────────────────
let x0_15 = [1.0, 2.0]
let n_15 = [0.5, -0.5]
let xt_15 = cd_add_noise(x0_15, n_15, 2.0)
check("T15 add_noise x0+t*noise", approx_(xt_15[0], 2.0, 1.0e-9))
check("T15 add_noise y component", approx_(xt_15[1], 1.0, 1.0e-9))

// ── T16 1-step sampling output dimension ──────────────────────
let z = [0.3, -0.7]
let sample_1 = cd_sample_1step(student, z)
check("T16 1-step sample dim", len(sample_1) == dim)

// ── T17 2-step sampling output dimension ──────────────────────
let sample_2 = cd_sample_2step(student, z, 5.0)
check("T17 2-step sample dim", len(sample_2) == dim)

// ── T18 deterministic: same seed same model ───────────────────
let s_a = cd_init(dim, hidden, sigma_data, eps_val, 7)
let s_b = cd_init(dim, hidden, sigma_data, eps_val, 7)
let fa = cd_denoise(s_a, [0.1, 0.2], 1.0)
let fb = cd_denoise(s_b, [0.1, 0.2], 1.0)
let mut det_ok = true
for i in 0..dim {
    if fabs_(fa[i] - fb[i]) > 1.0e-9 { det_ok = false }
}
check("T18 deterministic init", det_ok)

// ── T19 different seeds differ ────────────────────────────────
let s_c = cd_init(dim, hidden, sigma_data, eps_val, 42)
let s_d = cd_init(dim, hidden, sigma_data, eps_val, 99)
let fc = cd_denoise(s_c, [0.1, 0.2], 1.0)
let fd = cd_denoise(s_d, [0.1, 0.2], 1.0)
let mut diff_ok = false
for i in 0..dim {
    if fabs_(fc[i] - fd[i]) > 1.0e-6 { diff_ok = true }
}
check("T19 different seeds differ", diff_ok)

// ── T20 EMA update blends params ──────────────────────────────
let ema2 = cd_ema_update(ema, student, 0.5)
let mut blend_ok = true
for i in 0..hidden {
    for j in 0..dim {
        let expected = 0.5 * ema["W1"][i][j] + 0.5 * student["W1"][i][j]
        if fabs_(ema2["W1"][i][j] - expected) > 1.0e-9 { blend_ok = false }
    }
}
check("T20 EMA update blends at 0.5", blend_ok)

// ── T21 EMA decay=1.0 keeps old ema unchanged ────────────────
let ema_same = cd_ema_update(ema, student, 1.0)
let mut ema_kept = true
for i in 0..hidden {
    for j in 0..dim {
        if fabs_(ema_same["W1"][i][j] - ema["W1"][i][j]) > 1.0e-9 { ema_kept = false }
    }
}
check("T21 EMA decay=1.0 keeps old", ema_kept)

// ── T22 perceptual loss ───────────────────────────────────────
let pl_a = [1.0, 2.0, 3.0]
let pl_b = [1.1, 2.0, 3.2]
let pl = cd_perceptual_loss(pl_a, pl_b)
check("T22 perceptual loss >= 0", pl >= 0.0)
let pl_zero = cd_perceptual_loss(pl_a, pl_a)
check("T22 perceptual(a,a) = 0", approx_(pl_zero, 0.0, 1.0e-9))

// ── T23 adaptive N steps ──────────────────────────────────────
let n_start = cd_adaptive_n_steps(0, 100, 2, 150)
let n_end = cd_adaptive_n_steps(100, 100, 2, 150)
check("T23 adaptive N start", n_start >= 2)
check("T23 adaptive N end", n_end <= 150)
check("T23 adaptive N increases", n_end > n_start)

// ── T24 training reduces loss ─────────────────────────────────
let batch_x0 = [[0.5, 0.3], [0.2, -0.1]]
let batch_noise = [[0.1, -0.2], [-0.1, 0.3]]
let batch_tn = [2.0, 2.0]
let batch_tn1 = [1.0, 1.0]

let mut loss_before = 0.0
for n in 0..2 {
    loss_before = loss_before + cd_distill_loss(student, ema, teacher, batch_x0[n], batch_noise[n], batch_tn[n], batch_tn1[n])
}
loss_before = loss_before / 2.0

let mut trained = student
let mut trained_ema = ema
for _step in 0..10 {
    let result = cd_train_step(trained, trained_ema, teacher, batch_x0, batch_noise, batch_tn, batch_tn1, 0.01, 0.999)
    trained = result[0]
    trained_ema = result[1]
}

let mut loss_after = 0.0
for n in 0..2 {
    loss_after = loss_after + cd_distill_loss(trained, trained_ema, teacher, batch_x0[n], batch_noise[n], batch_tn[n], batch_tn1[n])
}
loss_after = loss_after / 2.0
check("T24 loss decreases after training", loss_after < loss_before)

// ── T25 boundary preserved after training ─────────────────────
let f_eps_trained = cd_denoise(trained, [0.4, -0.6], eps_val)
let mut boundary_trained_ok = true
for i in 0..dim {
    if fabs_(f_eps_trained[i] - [0.4, -0.6][i]) > 0.05 { boundary_trained_ok = false }
}
check("T25 boundary preserved after training", boundary_trained_ok)

println("")
println("=== Consistency Distillation (#344) summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
