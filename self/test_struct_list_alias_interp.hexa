// ═══════════════════════════════════════════════════════════
//  test_struct_list_alias_interp.hexa — ROI #154 repro + regression
//
//  Interpreter-path twin of self/test_struct_list_alias.hexa (ROI #148).
//
//  Native path: self/runtime.c hexa_struct_pack_map was patched in
//  commit ef98e4ec to shallow-clone TAG_ARRAY fields at struct
//  construction, breaking caller->struct-field buffer aliasing.
//
//  Interpreter path: hexa_full.hexa's val_struct stored the field_map
//  by reference, so two struct instances built from the same source
//  array shared the array_store slot index. Because val_struct did not
//  incref array-typed field values, array_is_sole_owner returned true
//  on the shared slot and subsequent .push mutations leaked across
//  sibling struct instances and the original source array.
//
//  Fix: val_struct in hexa_full.hexa now walks the field map, detects
//  TAG_ARRAY values, and substitutes a fresh val_array(copy-of-items)
//  before storing the field_map into struct_store.
//
//  This test exercises all six canary scenarios (A..H minus merged
//  trivial ones) through interpreter-only constructs; the same patterns
//  are expected to pass on the native path already.
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " - expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("=======================================================")
println("  ROI #154: struct list field aliasing (interpreter)")
println("=======================================================")

struct Box { items: array }

// ── A. Distinct-literal construction ──────────────────────
let mut a = Box { items: [1, 2] }
let mut b = Box { items: [3, 4] }
check("A.0 a.items[0]", a.items[0], 1)
check("A.1 b.items[0]", b.items[0], 3)
a = Box { items: a.items.push(99) }
check("A.2 a len after push", len(a.items), 3)
check("A.3 b len unchanged", len(b.items), 2)
check("A.4 a.items[2]", a.items[2], 99)

// ── B. Shared source array via variable ────────────────────
let shared = [10, 20]
let mut c = Box { items: shared }
let mut d = Box { items: shared }
c = Box { items: c.items.push(77) }
check("B.0 c len after push", len(c.items), 3)
check("B.1 d len unchanged", len(d.items), 2)
check("B.2 shared len unchanged", len(shared), 2)

// ── D. In-place field assignment path ─────────────────────
let mut e = Box { items: [100, 200] }
let mut f = Box { items: [300, 400] }
e.items = e.items.push(500)
check("D.0 e len", len(e.items), 3)
check("D.1 e.items[2]", e.items[2], 500)
check("D.2 f len unchanged", len(f.items), 2)
check("D.3 f.items[0] unchanged", f.items[0], 300)

// ── E. Same variable used twice as field source ───────────
let xs = [7, 8, 9]
let mut g = Box { items: xs }
let mut h = Box { items: xs }
g.items = g.items.push(77)
check("E.0 g len after push", len(g.items), 4)
check("E.1 h len unchanged", len(h.items), 3)
check("E.2 xs len unchanged", len(xs), 3)

// ── F. Pre-grown buffer ────────────────────────────────────
let mut pre = []
pre.push(1)
pre.push(2)
let mut p = Box { items: pre }
let mut q = Box { items: pre }
p.items = p.items.push(999)
check("F.0 p len", len(p.items), 3)
check("F.1 q len unchanged", len(q.items), 2)
check("F.2 pre len unchanged", len(pre), 2)

// ── H. Canonical H repro (the ROI #148 failure mode) ──────
let mut base = []
base.push(10)
base.push(20)
let mut h1 = Box { items: base }
let mut h2 = Box { items: base }
h1.items = h1.items.push(333)
h2.items = h2.items.push(444)
check("H.0 h1.items[2] is 333", h1.items[2], 333)
check("H.1 h2.items[2] is 444", h2.items[2], 444)
check("H.2 h1.items[0] is 10", h1.items[0], 10)
check("H.3 h2.items[0] is 10", h2.items[0], 10)
check("H.4 base len unchanged", len(base), 2)

// =======================================================
println("=======================================================")
let total = pass_count + fail_count
println("  Results: " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL / " + to_string(total) + " total")
if fail_count == 0 {
    println("  ROI #154 struct list aliasing (interpreter) - NO LEAK")
} else {
    println("  ROI #154 struct list aliasing (interpreter) - LEAK DETECTED")
}
println("=======================================================")
