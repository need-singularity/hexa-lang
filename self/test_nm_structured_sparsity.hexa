// ═══════════════════════════════════════════════════════════════════
//  test_nm_structured_sparsity.hexa — N:M Structured Sparsity tests
//
//  Validates:
//    1.  2:4 mask has exactly 2 non-zeros per group of 4
//    2.  4:8 mask has exactly 4 non-zeros per group of 8
//    3.  Mask selects top-N by magnitude
//    4.  Apply mask zeros out correct positions
//    5.  Sparse matmul matches dense matmul with mask
//    6.  Cubic schedule: step=0 -> initial
//    7.  Cubic schedule: step=total -> final
//    8.  Cubic schedule: monotonic
//    9.  Gradual prune: early step keeps all weights
//   10.  Gradual prune: final step enforces N:M
//   11.  Gradient regrowth: mask from gradient magnitudes
//   12.  Validate mask: correct pattern
//   13.  Validate mask: wrong pattern detected
//   14.  Compute sparsity: 2:4 -> 0.5
//   15.  Compute sparsity: 4:8 -> 0.5
//   16.  Multi-row mask consistency
//
//  Run: ./hexa self/test_nm_structured_sparsity.hexa
// ═══════════════════════════════════════════════════════════════════

// -- inlined from self/ml/nm_structured_sparsity.hexa --
// codegen import not wired for test files

// ═══════════════════════════════════════════════════════════════════
//  self/ml/nm_structured_sparsity.hexa — N:M Structured Sparsity
//
//  2:4 and 4:8 structured sparsity runtime — magnitude-based pruning
//  with structured masks for hardware-accelerated sparse inference.
//
//  Implements:
//    1. Mask generation: top-N-by-magnitude per M-group
//    2. Supported patterns: 2:4, 4:8
//    3. Sparse matmul: apply mask during forward pass
//    4. Gradual pruning: cubic sparsity schedule
//    5. Weight regrowth: periodic mask update by gradient magnitude
//
//  API (pure):
//    nm_abs(x)                                   -> float
//    nm_generate_mask(weights, n, m)              -> [[int]]
//    nm_apply_mask(weights, mask)                 -> [[float]]
//    nm_sparse_matmul(weights, mask, input)       -> [float]
//    nm_cubic_schedule(step, total, s_i, s_f)     -> float
//    nm_gradual_prune(weights, step, total, n, m) -> [[float]]
//    nm_gradient_regrowth(weights, grads, n, m)   -> [[int]]
//    nm_validate_mask(mask, n, m)                 -> bool
//    nm_compute_sparsity(mask)                    -> float
//
//  AI-NATIVE attrs:
//    @pure     — no side effects
//    @parallel — per-group mask generation is independent
// ═══════════════════════════════════════════════════════════════════

// ── helpers ──────────────────────────────────────────────────────

fn nm_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn nm_copy_1d(v) {
    let mut out = []
    for i in 0..len(v) { out = out + [v[i]] }
    return out
}

fn nm_copy_2d(w) {
    let rows = len(w)
    let mut out = []
    for i in 0..rows {
        let mut row = []
        for j in 0..len(w[i]) { row = row + [w[i][j]] }
        out = out + [row]
    }
    return out
}

fn nm_zeros_2d(r, c) {
    let mut m = []
    for _i in 0..r {
        let mut row = []
        for _j in 0..c { row = row + [0.0] }
        m = m + [row]
    }
    return m
}

fn nm_zeros_2d_int(r, c) {
    let mut m = []
    for _i in 0..r {
        let mut row = []
        for _j in 0..c { row = row + [0] }
        m = m + [row]
    }
    return m
}

// ═══════════════════════════════════════════════════════════════════
//  Mask Generation
//
//  For each contiguous group of M elements in a row, keep the top N
//  by absolute magnitude. Mask is 1 (keep) or 0 (prune).
//  If row length is not a multiple of M, the tail group is left dense.
// ═══════════════════════════════════════════════════════════════════
@pure @parallel
fn nm_generate_mask(weights, n, m) {
    let rows = len(weights)
    let cols = len(weights[0])
    let mut mask = nm_zeros_2d_int(rows, cols)

    for i in 0..rows {
        let num_groups = cols / m
        // Process full groups
        for g in 0..num_groups {
            let base = g * m
            // Collect magnitudes with indices within group
            let mut mags = []
            for k in 0..m {
                mags = mags + [nm_abs(weights[i][base + k])]
            }
            // Find top-N indices by magnitude (selection sort descending, pick first N)
            let mut indices = []
            for k in 0..m { indices = indices + [k] }
            for a in 0..m {
                for b in (a + 1)..m {
                    if mags[indices[b]] > mags[indices[a]] {
                        let tmp = indices[a]
                        indices[a] = indices[b]
                        indices[b] = tmp
                    }
                }
            }
            // Set top-N positions to 1
            for k in 0..n {
                mask[i][base + indices[k]] = 1
            }
        }
        // Tail elements (not a full group) — keep dense
        let tail_start = num_groups * m
        for j in tail_start..cols {
            mask[i][j] = 1
        }
    }
    return mask
}

// ═══════════════════════════════════════════════════════════════════
//  Apply Mask — element-wise multiply weights by mask (0/1)
// ═══════════════════════════════════════════════════════════════════
@pure @parallel
fn nm_apply_mask(weights, mask) {
    let rows = len(weights)
    let cols = len(weights[0])
    let mut out = nm_zeros_2d(rows, cols)
    for i in 0..rows {
        for j in 0..cols {
            out[i][j] = weights[i][j] * to_float(mask[i][j])
        }
    }
    return out
}

// ═══════════════════════════════════════════════════════════════════
//  Sparse MatMul — y = (W * mask) @ x
//  Applies mask during forward pass to skip pruned weights.
// ═══════════════════════════════════════════════════════════════════
@pure @parallel
fn nm_sparse_matmul(weights, mask, input) {
    let rows = len(weights)
    let cols = len(weights[0])
    let mut y = []
    for i in 0..rows {
        let mut s = 0.0
        for j in 0..cols {
            if mask[i][j] == 1 {
                s = s + weights[i][j] * input[j]
            }
        }
        y = y + [s]
    }
    return y
}

// ═══════════════════════════════════════════════════════════════════
//  Cubic Sparsity Schedule
//
//  s(t) = s_f + (s_i - s_f) * (1 - t/T)^3
// ═══════════════════════════════════════════════════════════════════
@pure
fn nm_cubic_schedule(step, total_steps, initial, final_s) {
    if step >= total_steps { return final_s }
    if step <= 0 { return initial }
    let ratio = 1.0 - to_float(step) / to_float(total_steps)
    let cube = ratio * ratio * ratio
    return final_s + (initial - final_s) * cube
}

// ═══════════════════════════════════════════════════════════════════
//  Gradual Pruning — apply N:M mask at current schedule step
//
//  At each training step, compute the cubic schedule fraction,
//  then generate and apply the N:M mask. Early steps keep more
//  weights; later steps enforce strict N:M.
// ═══════════════════════════════════════════════════════════════════
fn nm_gradual_prune(weights, step, total_steps, n, m) {
    let frac = nm_cubic_schedule(step, total_steps, 1.0, to_float(n) / to_float(m))
    // When frac >= 1.0 (early training), keep all weights
    if frac >= 1.0 { return nm_copy_2d(weights) }
    // Otherwise apply N:M structured mask
    let mask = nm_generate_mask(weights, n, m)
    return nm_apply_mask(weights, mask)
}

// ═══════════════════════════════════════════════════════════════════
//  Gradient-Based Regrowth
//
//  Re-generate the N:M mask using gradient magnitudes instead of
//  weight magnitudes. Positions with largest |grad| are unmasked,
//  allowing pruned weights to regrow if gradients indicate importance.
// ═══════════════════════════════════════════════════════════════════
@pure @parallel
fn nm_gradient_regrowth(weights, grads, n, m) {
    // Use gradient magnitude for mask selection
    return nm_generate_mask(grads, n, m)
}

// ═══════════════════════════════════════════════════════════════════
//  Validate Mask — check that every M-group has exactly N ones
// ═══════════════════════════════════════════════════════════════════
@pure
fn nm_validate_mask(mask, n, m) {
    let rows = len(mask)
    let cols = len(mask[0])
    for i in 0..rows {
        let num_groups = cols / m
        for g in 0..num_groups {
            let base = g * m
            let mut count = 0
            for k in 0..m {
                if mask[i][base + k] == 1 { count = count + 1 }
            }
            if count != n { return false }
        }
    }
    return true
}

// ═══════════════════════════════════════════════════════════════════
//  Compute Sparsity from Mask — fraction of zeros
// ═══════════════════════════════════════════════════════════════════
@pure
fn nm_compute_sparsity(mask) {
    let rows = len(mask)
    let cols = len(mask[0])
    let total = rows * cols
    let mut zeros = 0
    for i in 0..rows {
        for j in 0..cols {
            if mask[i][j] == 0 { zeros = zeros + 1 }
        }
    }
    return to_float(zeros) / to_float(total)
}


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("PASS " + name)
        pass_count = pass_count + 1
    } else {
        println("FAIL " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx(a, b, eps) { return fabs(a - b) < eps }

// ═══════════ Tests ═════════════════════════════════════════════

fn main() {
    println("=== N:M Structured Sparsity Tests ===")

    // --- Test 1: 2:4 mask validity ---
    let w1 = [[4.0, 1.0, 3.0, 2.0, 8.0, 5.0, 7.0, 6.0]]
    let mask1 = nm_generate_mask(w1, 2, 4)
    check("2:4 mask valid", nm_validate_mask(mask1, 2, 4))

    // --- Test 2: 4:8 mask validity ---
    let w2 = [[1.0, 8.0, 3.0, 6.0, 2.0, 7.0, 4.0, 5.0]]
    let mask2 = nm_generate_mask(w2, 4, 8)
    check("4:8 mask valid", nm_validate_mask(mask2, 4, 8))

    // --- Test 3: Mask selects top-N by magnitude ---
    // Group [4.0, 1.0, 3.0, 2.0]: top-2 are indices 0 (4.0) and 2 (3.0)
    check("2:4 top-N idx0 kept", mask1[0][0] == 1)
    check("2:4 top-N idx2 kept", mask1[0][2] == 1)
    check("2:4 bottom idx1 pruned", mask1[0][1] == 0)
    check("2:4 bottom idx3 pruned", mask1[0][3] == 0)

    // --- Test 4: Apply mask zeros correct positions ---
    let masked = nm_apply_mask(w1, mask1)
    let mut zeros_ok = true
    for j in 0..8 {
        if mask1[0][j] == 0 {
            if fabs(masked[0][j]) > 1.0e-10 { zeros_ok = false }
        }
        if mask1[0][j] == 1 {
            if fabs(masked[0][j] - w1[0][j]) > 1.0e-10 { zeros_ok = false }
        }
    }
    check("Apply mask correctness", zeros_ok)

    // --- Test 5: Sparse matmul matches masked dense ---
    let w3 = [[2.0, 0.0, 3.0, 0.0], [0.0, 4.0, 0.0, 1.0]]
    let mask3 = [[1, 0, 1, 0], [0, 1, 0, 1]]
    let inp = [1.0, 2.0, 3.0, 4.0]
    let y_sparse = nm_sparse_matmul(w3, mask3, inp)
    // Row 0: 2*1 + 3*3 = 11.0
    // Row 1: 4*2 + 1*4 = 12.0
    check("Sparse matmul row0", approx(y_sparse[0], 11.0, 0.001))
    check("Sparse matmul row1", approx(y_sparse[1], 12.0, 0.001))

    // --- Test 6: Cubic schedule step=0 -> initial ---
    let cs0 = nm_cubic_schedule(0, 100, 1.0, 0.5)
    check("Cubic step=0 -> initial", approx(cs0, 1.0, 0.001))

    // --- Test 7: Cubic schedule step=total -> final ---
    let cs_end = nm_cubic_schedule(100, 100, 1.0, 0.5)
    check("Cubic step=T -> final", approx(cs_end, 0.5, 0.001))

    // --- Test 8: Cubic schedule monotonic ---
    let cs_25 = nm_cubic_schedule(25, 100, 1.0, 0.5)
    let cs_75 = nm_cubic_schedule(75, 100, 1.0, 0.5)
    check("Cubic monotonic (decreasing to final)", cs_75 < cs_25)

    // --- Test 9: Gradual prune early step keeps all ---
    let w4 = [[5.0, 1.0, 3.0, 2.0]]
    let gp_early = nm_gradual_prune(w4, 0, 100, 2, 4)
    // step=0 -> frac=1.0, should keep all
    let mut all_kept = true
    for j in 0..4 {
        if fabs(gp_early[0][j] - w4[0][j]) > 1.0e-10 { all_kept = false }
    }
    check("Gradual prune early keeps all", all_kept)

    // --- Test 10: Gradual prune final step enforces N:M ---
    let gp_final = nm_gradual_prune(w4, 100, 100, 2, 4)
    let gp_mask = nm_generate_mask(gp_final, 2, 4)
    check("Gradual prune final enforces 2:4", nm_validate_mask(gp_mask, 2, 4))

    // --- Test 11: Gradient regrowth uses gradient magnitude ---
    let weights5 = [[0.1, 0.2, 0.3, 0.4]]
    let grads5 = [[4.0, 1.0, 3.0, 2.0]]
    let regrown = nm_gradient_regrowth(weights5, grads5, 2, 4)
    // Gradient top-2: indices 0 (4.0) and 2 (3.0)
    check("Regrowth idx0 from grad", regrown[0][0] == 1)
    check("Regrowth idx2 from grad", regrown[0][2] == 1)

    // --- Test 12: Validate mask correct pattern ---
    let good_mask = [[1, 0, 1, 0, 0, 1, 1, 0]]
    check("Validate correct 2:4", nm_validate_mask(good_mask, 2, 4))

    // --- Test 13: Validate mask wrong pattern ---
    let bad_mask = [[1, 1, 1, 0, 0, 1, 1, 0]]
    check("Validate bad 3-of-4 detected", !nm_validate_mask(bad_mask, 2, 4))

    // --- Test 14: Sparsity 2:4 -> 0.5 ---
    let sp1 = nm_compute_sparsity(good_mask)
    check("Sparsity 2:4 = 0.5", approx(sp1, 0.5, 0.001))

    // --- Test 15: Sparsity 4:8 ---
    let mask_48 = nm_generate_mask(w2, 4, 8)
    let sp2 = nm_compute_sparsity(mask_48)
    check("Sparsity 4:8 = 0.5", approx(sp2, 0.5, 0.001))

    // --- Test 16: Multi-row mask consistency ---
    let w6 = [[4.0, 1.0, 3.0, 2.0], [2.0, 3.0, 1.0, 4.0], [1.0, 4.0, 2.0, 3.0]]
    let mask6 = nm_generate_mask(w6, 2, 4)
    check("Multi-row all valid 2:4", nm_validate_mask(mask6, 2, 4))
    // Row 0: top-2 by mag = indices 0,2; Row 1: indices 1,3; Row 2: indices 1,3
    check("Row1 top idx3", mask6[1][3] == 1)
    check("Row2 top idx1", mask6[2][1] == 1)

    println("")
    println("nm_structured_sparsity: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
    if fail_count == 0 {
        println("ALL PASS")
    } else {
        println("FAILED")
    }
    println(to_string(pass_count) + " passed")
}

main()
