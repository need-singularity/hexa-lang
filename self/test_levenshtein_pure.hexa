// test_levenshtein_pure.hexa — Tests for self/runtime/levenshtein_pure.hexa
// Covers: levenshtein_pure, levenshtein_ratio_pure, hamming_pure
// 30 tests: empty, identical, single char, transposition, longer, ratio, hamming

import "runtime/levenshtein_pure.hexa"

let mut pass = 0
let mut fail = 0

fn eq(name, a, b) {
    if a == b { pass = pass + 1 } else {
        fail = fail + 1
        println("[FAIL] " + name + " got " + to_string(a) + " want " + to_string(b))
    }
}

fn check(name, cond) {
    if cond { pass = pass + 1 } else {
        fail = fail + 1
        println("[FAIL] " + name)
    }
}

fn near(name, actual, expected, tol) {
    let diff = actual - expected
    let ad = if diff < 0.0 { 0.0 - diff } else { diff }
    if ad <= tol { pass = pass + 1 } else {
        fail = fail + 1
        println("[FAIL] " + name + " got " + to_string(actual) + " want " + to_string(expected))
    }
}

println("=== levenshtein_pure test suite ===")

// ── 1. empty strings ────────────────────────────────────────
eq("both empty", levenshtein_pure("", ""), 0)
eq("a empty", levenshtein_pure("", "abc"), 3)
eq("b empty", levenshtein_pure("abc", ""), 3)

// ── 2. identical strings ────────────────────────────────────
eq("identical single", levenshtein_pure("a", "a"), 0)
eq("identical word", levenshtein_pure("hello", "hello"), 0)
eq("identical long", levenshtein_pure("abcdefghij", "abcdefghij"), 0)

// ── 3. single char differences ──────────────────────────────
eq("insert one", levenshtein_pure("", "x"), 1)
eq("delete one", levenshtein_pure("x", ""), 1)
eq("replace one", levenshtein_pure("a", "b"), 1)
eq("append one", levenshtein_pure("abc", "abcd"), 1)
eq("prepend one", levenshtein_pure("abc", "xabc"), 1)

// ── 4. transposition (adjacent swap) ────────────────────────
eq("transpose ab->ba", levenshtein_pure("ab", "ba"), 2)
eq("transpose abcd->abdc", levenshtein_pure("abcd", "abdc"), 2)

// ── 5. classic known distances ──────────────────────────────
eq("kitten/sitting", levenshtein_pure("kitten", "sitting"), 3)
eq("saturday/sunday", levenshtein_pure("saturday", "sunday"), 3)
eq("flaw/lawn", levenshtein_pure("flaw", "lawn"), 2)
eq("gumbo/gambol", levenshtein_pure("gumbo", "gambol"), 2)
eq("book/back", levenshtein_pure("book", "back"), 2)
eq("abc/axc", levenshtein_pure("abc", "axc"), 1)

// ── 6. symmetry ─────────────────────────────────────────────
eq("sym kitten/sitting", levenshtein_pure("sitting", "kitten"), 3)
eq("sym flaw/lawn", levenshtein_pure("lawn", "flaw"), 2)

// ── 7. longer strings ───────────────────────────────────────
eq("long 1-char diff", levenshtein_pure("abcdefghij", "abcdefghik"), 1)
eq("completely different 3", levenshtein_pure("abc", "xyz"), 3)

// ── 8. ratio tests ──────────────────────────────────────────
near("ratio identical", levenshtein_ratio_pure("hello", "hello"), 1.0, 0.001)
near("ratio both empty", levenshtein_ratio_pure("", ""), 1.0, 0.001)
near("ratio all different", levenshtein_ratio_pure("abc", "xyz"), 0.0, 0.001)
near("ratio one empty", levenshtein_ratio_pure("abc", ""), 0.0, 0.001)
near("ratio kitten/sitting", levenshtein_ratio_pure("kitten", "sitting"), 1.0 - 3.0 / 7.0, 0.01)
near("ratio single sub", levenshtein_ratio_pure("abc", "axc"), 1.0 - 1.0 / 3.0, 0.01)

// ── 9. hamming tests ────────────────────────────────────────
eq("hamming identical", hamming_pure("abc", "abc"), 0)
eq("hamming one diff", hamming_pure("abc", "axc"), 1)
eq("hamming all diff", hamming_pure("abc", "xyz"), 3)
eq("hamming empty", hamming_pure("", ""), 0)
eq("hamming unequal", hamming_pure("ab", "abc"), -1)

// ── summary ─────────────────────────────────────────────────
let total = pass + fail
println("--- " + to_string(pass) + "/" + to_string(total) + " passed ---")
if fail == 0 { println("ALL PASS") } else { println("FAILURES: " + to_string(fail)) }
