// ═══════════════════════════════════════════════════════════
//  test_list_to_array.hexa — #49 Linked List → Array pass validation
//
//  Verifies that sequential-access linked list patterns are
//  correctly detected and restructured to contiguous Vec-based
//  layout for cache efficiency.
//
//  Pattern:  while node != nil { ... node = node.next }
//  Becomes:  collect into array, then iterate contiguously
//
//  Linked list nodes are simulated with maps: #{"val": V, "nxt": <node>}
//  since hexa maps support dynamic field access.
//
//  실행: ./hexa self/test_list_to_array.hexa
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn check_eq(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_arr(name, actual, expected) {
    if len(actual) != len(expected) {
        println("[FAIL] " + name + " — len mismatch: " + to_string(len(actual)) + " vs " + to_string(len(expected)))
        fail_count = fail_count + 1
        return
    }
    let mut ok = true
    let mut i = 0
    while i < len(actual) {
        if actual[i] != expected[i] { ok = false }
        i = i + 1
    }
    if ok {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — actual: " + to_string(actual) + ", expected: " + to_string(expected))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  #49 Linked List → Array Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── Simulate linked list using maps (key-based nodes) ──────
// Each node: #{"val": V, "nxt": <node or 0>}
// Use 0 as nil sentinel (no null in hexa maps)

fn make_node(val, nxt) {
    let mut n = #{"val": val, "nxt": nxt}
    return n
}

fn make_list(arr) {
    let mut node = 0
    let mut i = len(arr) - 1
    while i >= 0 {
        node = make_node(arr[i], node)
        i = i - 1
    }
    return node
}

// ── 1. Linked list traversal: sum all values
fn list_sum(head) {
    let mut total = 0
    let mut node = head
    while node != 0 {
        total = total + node["val"]
        node = node["nxt"]
    }
    return total
}

let list1 = make_list([1, 2, 3, 4, 5])
check_eq("list sum: [1..5]", list_sum(list1), 15)
check_eq("list sum: empty", list_sum(0), 0)
check_eq("list sum: single", list_sum(make_node(42, 0)), 42)

// ── 2. Array-based equivalent (what the pass produces)
fn array_sum(arr) {
    let mut total = 0
    let mut i = 0
    while i < len(arr) {
        total = total + arr[i]
        i = i + 1
    }
    return total
}

check_eq("array sum: [1..5]", array_sum([1, 2, 3, 4, 5]), 15)
check_eq("equiv: list vs array", list_sum(list1), array_sum([1, 2, 3, 4, 5]))

// ── 3. Linked list to array collection
fn list_to_vec(head) {
    let mut result = []
    let mut node = head
    while node != 0 {
        result = result.push(node["val"])
        node = node["nxt"]
    }
    return result
}

check_arr("to_vec: [1..5]", list_to_vec(list1), [1, 2, 3, 4, 5])
check_arr("to_vec: empty", list_to_vec(0), [])
check_arr("to_vec: single", list_to_vec(make_node(99, 0)), [99])

// ── 4. Linked list length
fn list_len(head) {
    let mut count = 0
    let mut node = head
    while node != 0 {
        count = count + 1
        node = node["nxt"]
    }
    return count
}

check_eq("len: 5 nodes", list_len(list1), 5)
check_eq("len: empty", list_len(0), 0)
check_eq("len: single", list_len(make_node(1, 0)), 1)

// ── 5. Process via list vs array (max value)
fn max_via_list(head) {
    let mut max_val = 0
    let mut node = head
    while node != 0 {
        if node["val"] > max_val {
            max_val = node["val"]
        }
        node = node["nxt"]
    }
    return max_val
}

fn max_via_array(arr) {
    let mut max_val = 0
    let mut i = 0
    while i < len(arr) {
        if arr[i] > max_val {
            max_val = arr[i]
        }
        i = i + 1
    }
    return max_val
}

let list2 = make_list([3, 7, 2, 9, 1])
check_eq("max via list", max_via_list(list2), 9)
check_eq("max via array", max_via_array([3, 7, 2, 9, 1]), 9)
check_eq("max equiv", max_via_list(list2), max_via_array([3, 7, 2, 9, 1]))

// ── 6. Filter positive values
fn list_filter_positive(head) {
    let mut result = []
    let mut node = head
    while node != 0 {
        if node["val"] > 0 {
            result = result.push(node["val"])
        }
        node = node["nxt"]
    }
    return result
}

fn array_filter_positive(arr) {
    let mut result = []
    let mut i = 0
    while i < len(arr) {
        if arr[i] > 0 {
            result = result.push(arr[i])
        }
        i = i + 1
    }
    return result
}

let list3 = make_list([3, -1, 4, -5, 2])
check_arr("list filter pos", list_filter_positive(list3), [3, 4, 2])
check_arr("array filter pos", array_filter_positive([3, -1, 4, -5, 2]), [3, 4, 2])
check_arr("filter equiv", list_filter_positive(list3), array_filter_positive([3, -1, 4, -5, 2]))

// ── 7. Map (double) via list and array
fn list_double(head) {
    let mut result = []
    let mut node = head
    while node != 0 {
        result = result.push(node["val"] * 2)
        node = node["nxt"]
    }
    return result
}

fn array_double(arr) {
    let mut result = []
    let mut i = 0
    while i < len(arr) {
        result = result.push(arr[i] * 2)
        i = i + 1
    }
    return result
}

let list4 = make_list([10, 20, 30])
check_arr("list double", list_double(list4), [20, 40, 60])
check_arr("array double", array_double([10, 20, 30]), [20, 40, 60])

// ── 8. Reverse via collect + reverse
fn list_reverse_to_array(head) {
    let mut arr = []
    let mut node = head
    while node != 0 {
        arr = arr.push(node["val"])
        node = node["nxt"]
    }
    let mut rev = []
    let mut i = len(arr) - 1
    while i >= 0 {
        rev = rev.push(arr[i])
        i = i - 1
    }
    return rev
}

check_arr("list reverse", list_reverse_to_array(make_list([1, 2, 3])), [3, 2, 1])
check_arr("list reverse single", list_reverse_to_array(make_node(42, 0)), [42])

// ── 9. Sum of squares via list and array
fn squares_list(head) {
    let mut total = 0
    let mut node = head
    while node != 0 {
        total = total + node["val"] * node["val"]
        node = node["nxt"]
    }
    return total
}

fn squares_array(arr) {
    let mut total = 0
    let mut i = 0
    while i < len(arr) {
        total = total + arr[i] * arr[i]
        i = i + 1
    }
    return total
}

let list5 = make_list([1, 2, 3, 4])
check_eq("squares list", squares_list(list5), 30)
check_eq("squares array", squares_array([1, 2, 3, 4]), 30)
check_eq("squares equiv", squares_list(list5), squares_array([1, 2, 3, 4]))

// ── 10. Larger list correctness
fn make_range_list(n) {
    let mut arr = []
    let mut i = 0
    while i < n {
        arr = arr.push(i)
        i = i + 1
    }
    return make_list(arr)
}

let big_list = make_range_list(50)
check_eq("big list len", list_len(big_list), 50)
check_eq("big list sum", list_sum(big_list), 1225)

// ── 11. Collect + process as array (two-phase pattern)
fn list_collect_and_process(head) {
    let arr = list_to_vec(head)
    let mut sum = 0
    let mut i = 0
    while i < len(arr) {
        sum = sum + arr[i]
        i = i + 1
    }
    return sum
}

check_eq("collect+process", list_collect_and_process(list1), 15)
check_eq("collect+process empty", list_collect_and_process(0), 0)

// ── 12. No data loss verification
let test_values = [7, 3, 9, 1, 5, 8, 2, 6, 4, 0]
let test_list = make_list(test_values)
check_arr("no data loss", list_to_vec(test_list), test_values)

// ── Summary
println("")
println("═══════════════════════════════════════════════════════")
println("  #49 Linked List → Array: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")
assert(fail_count == 0)
