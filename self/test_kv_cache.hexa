// ═══════════════════════════════════════════════════════════════════
//  self/test_kv_cache.hexa — correctness test for ROI #78 kv_cache
//
//  Verifies:
//    1. kv_init returns empty cache, seq_len=0
//    2. 10 kv_append steps → seq_len=10, k_cache / v_cache lengths match
//    3. For each decode step t in 0..10:
//         q_t        = queries[t]
//         incr_out_t = kv_attend(cache_t, q_t) after appending k_t,v_t
//         full_out_t = batch attention of q_t over K[0..t+1], V[0..t+1]
//       incr_out_t must equal full_out_t within tolerance 1e-5.
//    4. kv_append beyond max_seq returns sentinel seq_len == -1.
//
//  flop bookkeeping:
//    full batch at step t costs ~ 2·(t+1)·D (scores) + 2·(t+1)·D (weighted sum)
//                              = 4·(t+1)·D
//    incremental per step is identical — the saving comes from skipping
//    the RECOMPUTATION of the 0..t prefix on EACH step, i.e.
//      full decode 10 steps:  Σ_{t=0..9} 4·(t+1)·D  = 4·55·D = 220·D
//      incr decode 10 steps:  10·(one attention) ≤ 220·D (identical)
//      but full redo per step: 10·Σ_{t=0..9} 4·(t+1)·D  ≈ 2200·D   (20x)
//    The test prints these three counts as a sanity check.
// ═══════════════════════════════════════════════════════════════════

// -- inlined from self/ai_native/kv_cache.hexa --
// codegen import not wired for test files

// ═══════════════════════════════════════════════════════════════════
//  self/ai_native/kv_cache.hexa — Single-layer KV-cache for @kv_cache
//                                 AI-native attribute (ROI #78)
//
//  Purpose: provide the minimal serving-path KV cache referenced by
//  the @kv_cache attribute. Each @kv_cache-annotated attention call
//  appends one token's K / V to the cache and attends over the
//  cumulative sequence, so incremental decode tok/s matches the
//  full-batch attention numerically while doing O(seq_len · d)
//  rather than O(seq_len² · d) work per step.
//
//  Shape:
//    k_cache : array of per-token key   vectors, each length n_heads·head_dim
//    v_cache : array of per-token value vectors, each length n_heads·head_dim
//    seq_len : current filled length (0 ≤ seq_len ≤ max_seq)
//    max_seq : hard ceiling; exceeding it raises an explicit error —
//              padding / eviction is the caller's responsibility
//    n_heads, head_dim : attention geometry (head dim used to scale)
//
//  Immutable update pattern:
//    kv_append returns a NEW KVCache (old + [new_k] / [new_v]) to sidestep
//    the "struct field list aliasing" pitfall (see feedback memory notes).
//    Callers must rebind: cache = kv_append(cache, k, v).
//
//  Pitfall notes:
//    • struct-literal inside `if` body is unsupported — we bind a local
//      first and return it (grammar G5).
//    • slice precedence: any `a[i+1 .. j]` uses parenthesised addends
//      (not used here but noted for future extensions).
//
//  Related: self/ml/kv_cache.hexa (multi-layer flat-1D variant) —
//  this file is the narrower serving-path helper the @kv_cache
//  attribute expands into.
// ═══════════════════════════════════════════════════════════════════

// ── small numeric helpers (file-local, as_ prefix to avoid collisions)

@pure
fn kv_sqrt(x) {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    let mut _i = 0

    while _i < 30 {
        g = (g + x / g) / 2.0
    }
    return g
}

@pure
fn kv_exp(x) {
    let mut c = x
    if c > 20.0  { c =  20.0 }
    if c < -20.0 { c = -20.0 }
    let mut result = 1.0
    let mut term   = 1.0
    let mut i = 1

    while i < 25 {
        term   = term * c / to_float(i)
        result = result + term
    }
    if result < 1.0e-30 { return 1.0e-30 }
    return result
}

@pure
fn kv_dot(a, b) {
    let n = len(a)
    let mut s = 0.0
    let mut i = 0

    while i < n {
        s = s + a[i] * b[i]
    }
    return s
}

// ── struct ─────────────────────────────────────────────────────────

struct KVCache {
    k_cache: array,
    v_cache: array,
    seq_len: int,
    max_seq: int,
    n_heads: int,
    head_dim: int
}

// ── constructor ────────────────────────────────────────────────────
//  Pre-allocates empty K / V arrays and records shape metadata.
//  The storage grows by one vector per kv_append; bounded by max_seq.

fn kv_init(max_seq, n_heads, head_dim) {
    return KVCache {
        k_cache: [],
        v_cache: [],
        seq_len: 0,
        max_seq: max_seq,
        n_heads: n_heads,
        head_dim: head_dim
    }
}

// ── append ─────────────────────────────────────────────────────────
//  Returns a NEW KVCache with new_k / new_v appended and seq_len+1.
//  Raises a visible error (returns tagged KVCache with seq_len = -1)
//  when max_seq would be exceeded — pure hexa has no `raise`, but the
//  interpreter's `panic`-equivalent is `println + return` of an error
//  sentinel that the caller must branch on. We print and return the
//  unchanged cache with seq_len set to -1 so callers can detect it.

@hot
fn kv_append(cache: KVCache, new_k, new_v) {
    if cache.seq_len >= cache.max_seq {
        println("[kv_cache] ERROR: max_seq=" + to_string(cache.max_seq) + " exceeded (seq_len=" + to_string(cache.seq_len) + ")")
        return KVCache {
            k_cache: cache.k_cache,
            v_cache: cache.v_cache,
            seq_len: -1,
            max_seq: cache.max_seq,
            n_heads: cache.n_heads,
            head_dim: cache.head_dim
        }
    }
    let new_k_arr = cache.k_cache + [new_k]
    let new_v_arr = cache.v_cache + [new_v]
    return KVCache {
        k_cache: new_k_arr,
        v_cache: new_v_arr,
        seq_len: cache.seq_len + 1,
        max_seq: cache.max_seq,
        n_heads: cache.n_heads,
        head_dim: cache.head_dim
    }
}

// ── attend ─────────────────────────────────────────────────────────
//  q  : single query vector  of length n_heads·head_dim (decode path)
//  Returns output vector of length n_heads·head_dim:
//      scores_i = (q · k_i) / sqrt(head_dim)       for i in 0..seq_len
//      w        = softmax(scores)
//      out      = Σ_i w_i · v_i
//  head_dim is used for the scaling; multi-head split is caller-side.
//  (For the serving-path @kv_cache expansion, the multi-head reshape
//  happens around this helper — this function treats the K/V vectors
//  as flattened vectors of length n_heads·head_dim.)

@hot
fn kv_attend(cache: KVCache, q) {
    let n = cache.seq_len
    let d = cache.head_dim
    let scale = 1.0 / kv_sqrt(to_float(d))

    // scores
    let mut scores = []
    let mut i = 0

    while i < n {
        let s = kv_dot(q, cache.k_cache[i]) * scale
        scores = scores + [s]
    }

    // softmax (max-shift for stability)
    let mut mx = 0.0
    if n > 0 { mx = scores[0] }
    let mut i = 1

    while i < n {
        if scores[i] > mx { mx = scores[i] }
    }
    let mut exps  = []
    let mut total = 0.0
    let mut i = 0

    while i < n {
        let e = kv_exp(scores[i] - mx)
        exps  = exps + [e]
        total = total + e
    }
    if total <= 0.0 { total = 1.0e-30 }

    // weighted sum over value vectors
    let vec_len = cache.n_heads * d
    let mut out = []
    let mut _j = 0

    while _j < vec_len { out = out + [0.0] }
    let mut i = 0

    while i < n {
        let w = exps[i] / total
        let vi = cache.v_cache[i]
        let mut j = 0

        while j < vec_len {
            out[j] = out[j] + w * vi[j]
        }
    }
    return out
}


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn abs_f(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn close(a, b) {
    return abs_f(a - b) < 0.00001
}

// deterministic pseudo-random vector from (seed, len)
fn gen_vec(seed, vlen) {
    let mut v = []
    let mut s = seed
    let mut i = 0

    while i < vlen {
        s = (s * 1103515245 + 12345) % 2147483647
        let x = to_float(s % 1000) / 500.0 - 1.0
        v = v + [x]
    }
    return v
}

// reference full-batch attention over explicit K_list / V_list
fn ref_attend(q, K_list, V_list, head_dim, n_heads) {
    let n = len(K_list)
    let d = head_dim
    let scale = 1.0 / kv_sqrt(to_float(d))

    let mut scores = []
    let mut i = 0

    while i < n {
        let s = kv_dot(q, K_list[i]) * scale
        scores = scores + [s]
    }
    let mut mx = 0.0
    if n > 0 { mx = scores[0] }
    let mut i = 1

    while i < n {
        if scores[i] > mx { mx = scores[i] }
    }
    let mut exps  = []
    let mut total = 0.0
    let mut i = 0

    while i < n {
        let e = kv_exp(scores[i] - mx)
        exps  = exps + [e]
        total = total + e
    }
    if total <= 0.0 { total = 1.0e-30 }
    let vec_len = n_heads * d
    let mut out = []
    let mut _j = 0

    while _j < vec_len { out = out + [0.0] }
    let mut i = 0

    while i < n {
        let w = exps[i] / total
        let vi = V_list[i]
        let mut j = 0

        while j < vec_len {
            out[j] = out[j] + w * vi[j]
        }
    }
    return out
}

println("═══════════════════════════════════════════════════════")
println("  ROI #78 — self/ai_native/kv_cache.hexa correctness")
println("═══════════════════════════════════════════════════════")

let n_heads  = 2
let head_dim = 4
let vec_len  = n_heads * head_dim   // 8
let max_seq  = 10
let n_steps  = 10

// ── 1. kv_init ────────────────────────────────────────────────────

let cache0 = kv_init(max_seq, n_heads, head_dim)
check("kv_init seq_len = 0",  cache0.seq_len == 0)
check("kv_init max_seq",      cache0.max_seq == max_seq)
check("kv_init n_heads",      cache0.n_heads == n_heads)
check("kv_init head_dim",     cache0.head_dim == head_dim)
check("kv_init k_cache empty", len(cache0.k_cache) == 0)
check("kv_init v_cache empty", len(cache0.v_cache) == 0)

// ── 2. Prepare 10 K / V / Q vectors (deterministic)────────────────

let mut Ks = []
let mut Vs = []
let mut Qs = []
let mut t = 0

while t < n_steps {
    Ks = Ks + [gen_vec(100 + t, vec_len)]
    Vs = Vs + [gen_vec(200 + t, vec_len)]
    Qs = Qs + [gen_vec(300 + t, vec_len)]
}

// ── 3. Incremental decode with kv_append / kv_attend ──────────────

let mut cache  = cache0
let mut incr_outs = []
let mut t = 0

while t < n_steps {
    cache = kv_append(cache, Ks[t], Vs[t])
    let out_t = kv_attend(cache, Qs[t])
    incr_outs = incr_outs + [out_t]
}
check("incremental seq_len = " + to_string(n_steps), cache.seq_len == n_steps)
check("incremental k_cache length", len(cache.k_cache) == n_steps)
check("incremental v_cache length", len(cache.v_cache) == n_steps)

// ── 4. Reference full-batch attention at each step ────────────────

let mut ref_outs = []
let mut t = 0

while t < n_steps {
    let mut K_prefix = []
    let mut V_prefix = []
    let mut i = 0

    while i < (t + 1) {
        K_prefix = K_prefix + [Ks[i]]
        V_prefix = V_prefix + [Vs[i]]
    }
    let ref_t = ref_attend(Qs[t], K_prefix, V_prefix, head_dim, n_heads)
    ref_outs = ref_outs + [ref_t]
}

// ── 5. Element-wise equality check (tolerance 1e-5)─────────────────

let mut max_err = 0.0
let mut total_err = 0.0
let mut elem_count = 0
let mut t = 0

while t < n_steps {
    let a = incr_outs[t]
    let b = ref_outs[t]
    let mut j = 0

    while j < vec_len {
        let e = abs_f(a[j] - b[j])
        if e > max_err { max_err = e }
        total_err = total_err + e
        elem_count = elem_count + 1
    }
}
let mean_err = total_err / to_float(elem_count)

println("")
println("numerical diagnostics:")
println("  steps      = " + to_string(n_steps))
println("  vec_len    = " + to_string(vec_len))
println("  elements   = " + to_string(elem_count))
println("  max |err|  = " + to_string(max_err))
println("  mean |err| = " + to_string(mean_err))

check("max elem error < 1e-5",  max_err < 0.00001)
check("mean elem error < 1e-6", mean_err < 0.000001)

// ── 6. flop bookkeeping ───────────────────────────────────────────

let mut flop_incr = 0
let mut flop_naive_redo = 0
let mut t = 0

while t < n_steps {
    let t1 = t + 1
    let per_step = 4 * t1 * head_dim
    flop_incr = flop_incr + per_step
    // naive "redo from scratch" would reconstruct AND re-attend
    // over every prior step at each new token: Σ_{s=0..t} per_step(s)
    let mut redo = 0
    let mut s = 0

    while s < t1 {
        redo = redo + 4 * (s + 1) * head_dim
    }
    flop_naive_redo = flop_naive_redo + redo
}

println("")
println("flop comparison (4·(t+1)·D units):")
println("  incremental decode total = " + to_string(flop_incr))
println("  naive full-rebuild total = " + to_string(flop_naive_redo))
let ratio_x100 = (flop_naive_redo * 100) / flop_incr
println("  saved factor ≈ " + to_string(ratio_x100) + "/100 (i.e. naive is ~" + to_string(ratio_x100 / 100) + "× incremental)")

check("naive rebuild costs more than incremental",   flop_naive_redo > flop_incr)

// ── 7. max_seq overflow behaviour ─────────────────────────────────

let full_cache = cache                         // already at seq_len = max_seq
let k_extra = gen_vec(999, vec_len)
let v_extra = gen_vec(888, vec_len)
let overflow = kv_append(full_cache, k_extra, v_extra)
check("overflow sentinel seq_len == -1", overflow.seq_len == -1)
check("overflow leaves original cache untouched", full_cache.seq_len == max_seq)

// ── summary ───────────────────────────────────────────────────────

println("")
println("═══════════════════════════════════════════════════════")
println("  PASS " + to_string(pass_count) + " / FAIL " + to_string(fail_count))
println("═══════════════════════════════════════════════════════")

if fail_count == 0 {
    println("ROI #78 kv_cache: ALL GREEN")
} else {
    println("ROI #78 kv_cache: FAIL (see above)")
}
