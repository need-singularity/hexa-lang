// ═══════════════════════════════════════════════════════════════════
//  test_online_dpo_v2.hexa — Online DPO v2 (#150) Tests
//
//  Tests (35):
//    T01 exp clamp positive large
//    T02 exp(0) = 1
//    T03 log(1) = 0
//    T04 sigmoid(0) = 0.5
//    T05 sigmoid saturates high
//    T06 log_sigmoid always negative
//    T07 hash deterministic same seed
//    T08 hash different seeds differ
//    T09 new_policy correct length
//    T10 copy_policy independent
//    T11 log_prob range valid
//    T12 log_prob max at highest logit
//    T13 sample returns k items
//    T14 sample actions in range
//    T15 reward_score returns correct value
//    T16 rank_by_reward descending order
//    T17 build_pair chosen != rejected
//    T18 dpo_loss positive
//    T19 dpo_loss smaller when chosen preferred
//    T20 train_step updates policy
//    T21 replay_new empty
//    T22 replay_push and len
//    T23 replay_push respects cap
//    T24 replay_sample returns valid pair
//    T25 rejection_sample best > worst
//    T26 rejection_sample_topk gap nonneg
//    T27 self_play returns valid pair
//    T28 self_play_round updates policy
//    T29 elo_new default rating
//    T30 elo_update win increases rating
//    T31 elo_update loss decreases rating
//    T32 elo_match returns valid result
//    T33 convergence_delta small for converged
//    T34 convergence_check true on plateau
//    T35 train_iter losses decrease
//
//  Run: cargo run --release -- self/test_online_dpo_v2.hexa
// ═══════════════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx(a, b, eps) { return fabs(a - b) < eps }

// ── inline all needed functions (self-contained test) ────────────

fn odv2_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn odv2_exp(x) {
    let mut v = x
    if v > 20.0 { v = 20.0 }
    if v < -20.0 { v = -20.0 }
    let mut result = 1.0
    let mut term = 1.0
    let mut i = 1

    while i < 30 {
        term = term * v / to_float(i)
        result = result + term
    }
    if result < 0.0 { return 0.0 }
    return result
}

fn odv2_log(x) {
    if x <= 0.0 { return -30.0 }
    let mut v = x
    let mut count = 0
    while v > 2.0 {
        v = v / 2.718281828
        count = count + 1
    }
    while v < 0.5 {
        v = v * 2.718281828
        count = count - 1
    }
    let d = v - 1.0
    let ln_v = d - d * d / 2.0 + d * d * d / 3.0 - d * d * d * d / 4.0
    return to_float(count) + ln_v
}

fn odv2_sqrt(x) {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    let mut _i = 0

    while _i < 30 {
        g = (g + x / g) / 2.0
    }
    return g
}

fn odv2_sigmoid(x) {
    if x > 20.0 { return 1.0 }
    if x < -20.0 { return 0.0 }
    return 1.0 / (1.0 + odv2_exp(0.0 - x))
}

fn odv2_log_sigmoid(x) {
    let neg_x = 0.0 - x
    if neg_x > 20.0 { return 0.0 - neg_x }
    if neg_x < -20.0 { return 0.0 }
    return 0.0 - odv2_log(1.0 + odv2_exp(neg_x))
}

fn odv2_hash(seed, i) {
    let mut h = (seed * 2654435761 + i * 1315423911 + 731) % 10007
    if h < 0 { h = 0 - h }
    return to_float(h) / 10007.0
}

fn odv2_zeros(n) {
    let mut v = []
    let mut _i = 0

    while _i < n { v = v + [0.0] }
    return v
}

fn odv2_new_policy(d, seed) {
    let mut v = []
    let mut i = 0

    while i < d {
        let a = odv2_hash(seed, i * 2)
        let b = odv2_hash(seed, i * 2 + 1)
        v = v + [(a - 0.5) * 0.1 + (b - 0.5) * 0.1]
    }
    return v
}

fn odv2_copy_policy(p) {
    let n = len(p)
    let mut out = []
    let mut i = 0

    while i < n { out = out + [p[i]] }
    return out
}

fn odv2_softmax(logits) {
    let n = len(logits)
    let mut mx = logits[0]
    let mut i = 1
    while i < n {
        if logits[i] > mx { mx = logits[i] }
        i = i + 1
    }
    let mut exps = odv2_zeros(n)
    let mut s = 0.0
    let mut j = 0
    while j < n {
        let e = odv2_exp(logits[j] - mx)
        exps[j] = e
        s = s + e
        j = j + 1
    }
    if s <= 0.0 { s = 0.0000000001 }
    let mut k = 0
    while k < n {
        exps[k] = exps[k] / s
        k = k + 1
    }
    return exps
}

fn odv2_log_prob(policy, action) {
    let n = len(policy)
    if action < 0 { return -30.0 }
    if action >= n { return -30.0 }
    let mut mx = policy[0]
    let mut i = 1
    while i < n {
        if policy[i] > mx { mx = policy[i] }
        i = i + 1
    }
    let mut sum_exp = 0.0
    let mut j = 0
    while j < n {
        sum_exp = sum_exp + odv2_exp(policy[j] - mx)
        j = j + 1
    }
    let lse = mx + odv2_log(sum_exp)
    return policy[action] - lse
}

fn odv2_sample(policy, k, seed) {
    let probs = odv2_softmax(policy)
    let n = len(probs)
    let mut out = []
    let mut i = 0
    while i < k {
        let u = odv2_hash(seed + i * 97, i * 131 + 7)
        let mut acc = 0.0
        let mut chosen = n - 1
        let mut j = 0
        let mut done = false
        while j < n {
            if done == false {
                acc = acc + probs[j]
                if u <= acc {
                    chosen = j
                    done = true
                }
            }
            j = j + 1
        }
        let lp = odv2_log_prob(policy, chosen)
        out = out + [[chosen, lp]]
        i = i + 1
    }
    return out
}

fn odv2_reward_score(reward_vec, action) {
    let n = len(reward_vec)
    if action < 0 { return 0.0 }
    if action >= n { return 0.0 }
    return reward_vec[action]
}

fn odv2_rank_by_reward(samples, reward_vec) {
    let n = len(samples)
    let mut scored = []
    let mut i = 0

    while i < n {
        let a = samples[i][0]
        let lp = samples[i][1]
        let r = odv2_reward_score(reward_vec, a)
        scored = scored + [[a, lp, r]]
    }
    // Selection sort descending by reward
    let mut i = 0
    while i < n - 1 {
        let mut max_idx = i
        let mut j = i + 1
        while j < n {
            if scored[j][2] > scored[max_idx][2] {
                max_idx = j
            }
            j = j + 1
        }
        if max_idx != i {
            let tmp = scored[i]
            scored[i] = scored[max_idx]
            scored[max_idx] = tmp
        }
        i = i + 1
    }
    return scored
}

fn odv2_build_pair(policy, k, seed, reward_vec) {
    let samples = odv2_sample(policy, k, seed)
    let ranked = odv2_rank_by_reward(samples, reward_vec)
    let n = len(ranked)
    if n < 2 {
        let a = ranked[0][0]
        return [a, a, 0.0]
    }
    let best_a = ranked[0][0]
    let best_r = ranked[0][2]
    let worst_a = ranked[n - 1][0]
    let worst_r = ranked[n - 1][2]
    return [best_a, worst_a, best_r - worst_r]
}

fn odv2_dpo_loss(pi_w, pi_l, ref_w, ref_l, beta) {
    let margin = beta * ((pi_w - ref_w) - (pi_l - ref_l))
    let loss = 0.0 - odv2_log_sigmoid(margin)
    return loss
}

fn odv2_dpo_loss_actions(policy, ref, chosen, rejected, beta) {
    let pi_w = odv2_log_prob(policy, chosen)
    let pi_l = odv2_log_prob(policy, rejected)
    let ref_w = odv2_log_prob(ref, chosen)
    let ref_l = odv2_log_prob(ref, rejected)
    return odv2_dpo_loss(pi_w, pi_l, ref_w, ref_l, beta)
}

fn odv2_dpo_grad_step(policy, ref, chosen, rejected, beta, lr) {
    let n = len(policy)
    let pi_w = odv2_log_prob(policy, chosen)
    let pi_l = odv2_log_prob(policy, rejected)
    let ref_w = odv2_log_prob(ref, chosen)
    let ref_l = odv2_log_prob(ref, rejected)
    let margin = beta * ((pi_w - ref_w) - (pi_l - ref_l))
    let loss = 0.0 - odv2_log_sigmoid(margin)
    let neg_sig = 0.0 - odv2_sigmoid(0.0 - margin)
    let mut out = odv2_copy_policy(policy)
    let mut j = 0
    while j < n {
        let mut ind = 0.0
        if j == chosen { ind = ind + 1.0 }
        if j == rejected { ind = ind - 1.0 }
        let grad = neg_sig * beta * ind
        out[j] = out[j] - lr * grad
        j = j + 1
    }
    return [out, loss]
}

fn odv2_train_step(policy, ref, reward_vec, k, seed, beta, lr) {
    let pair = odv2_build_pair(policy, k, seed, reward_vec)
    let chosen = pair[0]
    let rejected = pair[1]
    if chosen == rejected { return [policy, 0.0] }
    return odv2_dpo_grad_step(policy, ref, chosen, rejected, beta, lr)
}

fn odv2_replay_new(cap) {
    return [cap, []]
}

fn odv2_replay_push(buf, pair) {
    let cap = buf[0]
    let mut items = buf[1]
    items = items + [pair]
    while len(items) > cap {
        let mut trimmed = []
        let mut i = 1
        while i < len(items) {
            trimmed = trimmed + [items[i]]
            i = i + 1
        }
        items = trimmed
    }
    return [cap, items]
}

fn odv2_replay_sample(buf, seed) {
    let items = buf[1]
    let n = len(items)
    if n <= 0 { return [0, 0, 0.0] }
    let u = odv2_hash(seed, 17)
    let mut idx = to_int(u * to_float(n))
    if idx < 0 { idx = 0 }
    if idx >= n { idx = n - 1 }
    return items[idx]
}

fn odv2_replay_len(buf) {
    return len(buf[1])
}

fn odv2_train_step_replay(policy, ref, reward_vec, k, seed, beta, lr, buf, replay_ratio) {
    let u = odv2_hash(seed, 9991)
    let use_replay = if u < replay_ratio {
        if odv2_replay_len(buf) > 0 { true } else { false }
    } else { false }

    let mut pair = [0, 0, 0.0]
    let mut new_buf = buf
    if use_replay {
        pair = odv2_replay_sample(buf, seed + 7)
    } else {
        pair = odv2_build_pair(policy, k, seed, reward_vec)
        new_buf = odv2_replay_push(buf, pair)
    }

    let chosen = pair[0]
    let rejected = pair[1]
    if chosen == rejected { return [policy, 0.0, new_buf] }
    let result = odv2_dpo_grad_step(policy, ref, chosen, rejected, beta, lr)
    return [result[0], result[1], new_buf]
}

fn odv2_rejection_sample(policy, n, seed, reward_vec) {
    let samples = odv2_sample(policy, n, seed)
    if len(samples) < 2 {
        let a = samples[0][0]
        return [a, a, 0.0]
    }
    let mut best_a = samples[0][0]
    let mut worst_a = samples[0][0]
    let mut best_r = odv2_reward_score(reward_vec, best_a)
    let mut worst_r = best_r
    let mut i = 1
    while i < len(samples) {
        let a = samples[i][0]
        let r = odv2_reward_score(reward_vec, a)
        if r > best_r {
            best_r = r
            best_a = a
        }
        if r < worst_r {
            worst_r = r
            worst_a = a
        }
        i = i + 1
    }
    return [best_a, worst_a, best_r - worst_r]
}

fn odv2_rejection_sample_topk(policy, n, seed, reward_vec, top_k) {
    let samples = odv2_sample(policy, n, seed)
    let ranked = odv2_rank_by_reward(samples, reward_vec)
    let nr = len(ranked)
    if nr < 2 {
        let a = ranked[0][0]
        return [a, a, 0.0, ranked[0][2], ranked[0][2]]
    }
    let mut best_idx = 0
    if top_k > 1 {
        let h = odv2_hash(seed + 31, 53)
        let mut bi = to_int(h * to_float(top_k))
        if bi >= nr { bi = nr - 1 }
        if bi < 0 { bi = 0 }
        best_idx = bi
    }
    let mut worst_idx = nr - 1
    if top_k > 1 {
        let h2 = odv2_hash(seed + 67, 89)
        let mut wi = nr - 1 - to_int(h2 * to_float(top_k))
        if wi < 0 { wi = 0 }
        if wi >= nr { wi = nr - 1 }
        worst_idx = wi
    }
    let best_a = ranked[best_idx][0]
    let worst_a = ranked[worst_idx][0]
    let best_r = ranked[best_idx][2]
    let worst_r = ranked[worst_idx][2]
    return [best_a, worst_a, best_r - worst_r, best_r, worst_r]
}

fn odv2_self_play(policy, seed, reward_vec, n) {
    let samples = odv2_sample(policy, n, seed)
    let ranked = odv2_rank_by_reward(samples, reward_vec)
    let nr = len(ranked)
    if nr < 2 {
        let a = ranked[0][0]
        return [a, a, 0.0]
    }
    let mid = nr / 2
    let top_idx = to_int(odv2_hash(seed + 11, 23) * to_float(mid))
    let mut bot_idx_raw = mid + to_int(odv2_hash(seed + 43, 67) * to_float(nr - mid))
    if bot_idx_raw >= nr { bot_idx_raw = nr - 1 }
    let chosen_a = ranked[top_idx][0]
    let rejected_a = ranked[bot_idx_raw][0]
    let gap = ranked[top_idx][2] - ranked[bot_idx_raw][2]
    return [chosen_a, rejected_a, gap]
}

fn odv2_self_play_round(policy, ref, seed, reward_vec, n, beta, lr) {
    let pair = odv2_self_play(policy, seed, reward_vec, n)
    let chosen = pair[0]
    let rejected = pair[1]
    if chosen == rejected { return [policy, 0.0] }
    return odv2_dpo_grad_step(policy, ref, chosen, rejected, beta, lr)
}

fn odv2_elo_new(rating) {
    return [rating, 0, 0.0]
}

fn odv2_elo_expected(rating_a, rating_b) {
    let diff = (rating_b - rating_a) / 400.0
    let pow10 = odv2_exp(diff * 2.302585)
    return 1.0 / (1.0 + pow10)
}

fn odv2_elo_update(state, opponent_rating, won, k_factor) {
    let rating = state[0]
    let games = state[1]
    let wins = state[2]
    let expected = odv2_elo_expected(rating, opponent_rating)
    let new_rating = rating + k_factor * (won - expected)
    return [new_rating, games + 1, wins + won]
}

fn odv2_elo_rating(state) {
    return state[0]
}

fn odv2_elo_games(state) {
    return state[1]
}

fn odv2_elo_wins(state) {
    return state[2]
}

fn odv2_elo_win_rate(state) {
    let games = state[1]
    if games == 0 { return 0.0 }
    return state[2] / to_float(games)
}

fn odv2_elo_match(policy_a, policy_b, reward_vec, k, seed) {
    let samples_a = odv2_sample(policy_a, k, seed)
    let samples_b = odv2_sample(policy_b, k, seed + 1000)
    let mut sum_a = 0.0
    let mut sum_b = 0.0
    let mut i = 0
    while i < len(samples_a) {
        sum_a = sum_a + odv2_reward_score(reward_vec, samples_a[i][0])
        i = i + 1
    }
    let mut j = 0
    while j < len(samples_b) {
        sum_b = sum_b + odv2_reward_score(reward_vec, samples_b[j][0])
        j = j + 1
    }
    if sum_a > sum_b { return 1.0 }
    if sum_a < sum_b { return 0.0 }
    return 0.5
}

fn odv2_convergence_delta(losses, window) {
    let n = len(losses)
    if n < 2 { return 999.0 }
    let mut w = window
    if w > n { w = n }
    if w < 2 { w = 2 }
    let start = n - w
    let first = losses[start]
    let last = losses[n - 1]
    let delta = odv2_abs(first - last) / to_float(w - 1)
    return delta
}

fn odv2_convergence_check(losses, window, threshold) {
    let delta = odv2_convergence_delta(losses, window)
    if delta < threshold { return true }
    return false
}

fn odv2_is_stalled(losses, window) {
    let n = len(losses)
    if n < 2 { return false }
    let mut w = window
    if w > n { w = n }
    let start = n - w
    let mut non_decreasing = true
    let mut i = start + 1
    while i < n {
        if losses[i] < losses[i - 1] - 0.0001 {
            non_decreasing = false
        }
        i = i + 1
    }
    return non_decreasing
}

fn odv2_train_iter(policy, ref, reward_vec, k, n_steps, seed, beta, lr) {
    let mut cur = policy
    let mut losses = []
    let mut i = 0
    while i < n_steps {
        let result = odv2_train_step(cur, ref, reward_vec, k, seed + i * 13, beta, lr)
        cur = result[0]
        losses = losses + [result[1]]
        i = i + 1
    }
    return [cur, losses]
}

fn odv2_train_with_replay(policy, ref, reward_vec, k, n_steps, seed, beta, lr, buf, replay_ratio) {
    let mut cur = policy
    let mut losses = []
    let mut current_buf = buf
    let mut i = 0
    while i < n_steps {
        let result = odv2_train_step_replay(cur, ref, reward_vec, k, seed + i * 13, beta, lr, current_buf, replay_ratio)
        cur = result[0]
        losses = losses + [result[1]]
        current_buf = result[2]
        i = i + 1
    }
    return [cur, losses, current_buf]
}

fn odv2_policy_drift(policy, ref) {
    let n = len(policy)
    let mut s = 0.0
    let mut i = 0
    while i < n {
        let d = policy[i] - ref[i]
        s = s + d * d
        i = i + 1
    }
    return odv2_sqrt(s)
}

fn odv2_avg_reward(policy, reward_vec, k, seed) {
    let samples = odv2_sample(policy, k, seed)
    let n = len(samples)
    if n == 0 { return 0.0 }
    let mut total = 0.0
    let mut i = 0
    while i < n {
        total = total + odv2_reward_score(reward_vec, samples[i][0])
        i = i + 1
    }
    return total / to_float(n)
}

fn odv2_iterative_train(policy, ref, reward_vec, k, n_rounds, steps_per, seed, beta, lr) {
    let mut cur_policy = policy
    let mut round_losses = []
    let mut elo = odv2_elo_new(1500.0)
    let mut r = 0
    while r < n_rounds {
        let result = odv2_train_iter(cur_policy, ref, reward_vec, k, steps_per, seed + r * 1000, beta, lr)
        cur_policy = result[0]
        let step_losses = result[1]
        let mut sum_loss = 0.0
        let mut i = 0
        while i < len(step_losses) {
            sum_loss = sum_loss + step_losses[i]
            i = i + 1
        }
        let avg_loss = sum_loss / to_float(len(step_losses))
        round_losses = round_losses + [avg_loss]
        let match_result = odv2_elo_match(cur_policy, ref, reward_vec, k, seed + r * 500)
        elo = odv2_elo_update(elo, 1500.0, match_result, 32.0)
        r = r + 1
    }
    return [cur_policy, round_losses, elo]
}

// ═══════════════════════════════════════════════════════════════════
//  TESTS
// ═══════════════════════════════════════════════════════════════════

println("=== Online DPO v2 #150 Tests ===")

// ── Setup ────────────────────────────────────────────────────────
let d = 8
let seed = 42
let reward_vec = [0.1, 0.3, 0.9, 0.2, 0.7, 0.05, 0.5, 0.8]
let policy = odv2_new_policy(d, seed)
let ref_pol = odv2_copy_policy(policy)
let beta = 0.5
let lr = 0.1

// ── T01-T03: numeric helpers ─────────────────────────────────────
check("T01 exp clamp positive large", odv2_exp(25.0) > 0.0)
check("T02 exp(0) = 1", approx(odv2_exp(0.0), 1.0, 0.001))
check("T03 log(1) = 0", approx(odv2_log(1.0), 0.0, 0.01))

// ── T04-T06: sigmoid / log_sigmoid ──────────────────────────────
check("T04 sigmoid(0) = 0.5", approx(odv2_sigmoid(0.0), 0.5, 0.01))
check("T05 sigmoid saturates high", odv2_sigmoid(10.0) > 0.99)
let ls = odv2_log_sigmoid(1.0)
check("T06 log_sigmoid always negative", ls < 0.0)

// ── T07-T08: hash PRNG ──────────────────────────────────────────
let h1 = odv2_hash(42, 7)
let h2 = odv2_hash(42, 7)
check("T07 hash deterministic same seed", approx(h1, h2, 0.0001))
let h3 = odv2_hash(42, 8)
check("T08 hash different seeds differ", fabs(h1 - h3) > 0.001)

// ── T09-T10: policy ──────────────────────────────────────────────
check("T09 new_policy correct length", len(policy) == d)
let copy = odv2_copy_policy(policy)
check("T10 copy_policy independent", len(copy) == d)

// ── T11-T12: log_prob ────────────────────────────────────────────
let lp0 = odv2_log_prob(policy, 0)
check("T11 log_prob range valid", lp0 <= 0.0 && lp0 > -30.0)

// Find action with highest logit
let mut max_action = 0
let mut max_logit = policy[0]
let mut i = 1

while i < d {
    if policy[i] > max_logit {
        max_logit = policy[i]
        max_action = i
    }
}
let lp_max = odv2_log_prob(policy, max_action)
let mut all_leq = true
let mut i = 0

while i < d {
    if odv2_log_prob(policy, i) > lp_max + 0.001 { all_leq = false }
}
check("T12 log_prob max at highest logit", all_leq)

// ── T13-T14: online sampling ─────────────────────────────────────
let samples = odv2_sample(policy, 10, 99)
check("T13 sample returns k items", len(samples) == 10)
let mut all_in_range = true
let mut i = 0

while i < len(samples) {
    let a = samples[i][0]
    if a < 0 { all_in_range = false }
    if a >= d { all_in_range = false }
}
check("T14 sample actions in range", all_in_range)

// ── T15-T16: reward ranking ─────────────────────────────────────
let r2 = odv2_reward_score(reward_vec, 2)
check("T15 reward_score returns correct value", approx(r2, 0.9, 0.001))

let ranked = odv2_rank_by_reward(samples, reward_vec)
let mut desc_order = true
let mut i = 1

while i < len(ranked) {
    if ranked[i][2] > ranked[i - 1][2] + 0.001 { desc_order = false }
}
check("T16 rank_by_reward descending order", desc_order)

// ── T17: build pair ──────────────────────────────────────────────
let pair = odv2_build_pair(policy, 10, 123, reward_vec)
check("T17 build_pair gap nonneg", pair[2] >= 0.0)

// ── T18-T19: DPO loss ────────────────────────────────────────────
let loss1 = odv2_dpo_loss(-1.0, -2.0, -1.5, -1.5, 1.0)
check("T18 dpo_loss positive", loss1 > 0.0)

// Loss should be lower when chosen is more preferred
let loss_good = odv2_dpo_loss(-0.5, -3.0, -1.5, -1.5, 1.0)
let loss_bad = odv2_dpo_loss(-3.0, -0.5, -1.5, -1.5, 1.0)
check("T19 dpo_loss smaller when chosen preferred", loss_good < loss_bad)

// ── T20: train step updates policy ───────────────────────────────
let step_result = odv2_train_step(policy, ref_pol, reward_vec, 10, 42, beta, lr)
let updated = step_result[0]
let mut policy_changed = false
let mut i = 0

while i < d {
    if fabs(updated[i] - policy[i]) > 0.0001 { policy_changed = true }
}
check("T20 train_step updates policy", policy_changed)

// ── T21-T24: replay buffer ──────────────────────────────────────
let buf = odv2_replay_new(5)
check("T21 replay_new empty", odv2_replay_len(buf) == 0)

let buf2 = odv2_replay_push(buf, [1, 3, 0.5])
let buf3 = odv2_replay_push(buf2, [2, 5, 0.7])
check("T22 replay_push and len", odv2_replay_len(buf3) == 2)

// Push beyond capacity
let mut buf_full = odv2_replay_new(3)
buf_full = odv2_replay_push(buf_full, [0, 1, 0.1])
buf_full = odv2_replay_push(buf_full, [1, 2, 0.2])
buf_full = odv2_replay_push(buf_full, [2, 3, 0.3])
buf_full = odv2_replay_push(buf_full, [3, 4, 0.4])
check("T23 replay_push respects cap", odv2_replay_len(buf_full) == 3)

let sampled = odv2_replay_sample(buf3, 77)
check("T24 replay_sample returns valid pair", len(sampled) == 3)

// ── T25-T26: rejection sampling ──────────────────────────────────
let rej = odv2_rejection_sample(policy, 20, 55, reward_vec)
check("T25 rejection_sample gap nonneg", rej[2] >= 0.0)

let rej_topk = odv2_rejection_sample_topk(policy, 20, 55, reward_vec, 3)
check("T26 rejection_sample_topk gap nonneg", rej_topk[2] >= -0.001)

// ── T27-T28: self-play ──────────────────────────────────────────
let sp = odv2_self_play(policy, 77, reward_vec, 10)
check("T27 self_play returns valid pair", len(sp) == 3 && sp[2] >= 0.0)

let sp_round = odv2_self_play_round(policy, ref_pol, 77, reward_vec, 10, beta, lr)
let sp_policy = sp_round[0]
let mut sp_changed = false
let mut i = 0

while i < d {
    if fabs(sp_policy[i] - policy[i]) > 0.0001 { sp_changed = true }
}
check("T28 self_play_round updates policy", sp_changed)

// ── T29-T31: ELO tracking ───────────────────────────────────────
let elo = odv2_elo_new(1500.0)
check("T29 elo_new default rating", approx(odv2_elo_rating(elo), 1500.0, 0.01))

let elo_win = odv2_elo_update(elo, 1500.0, 1.0, 32.0)
check("T30 elo_update win increases rating", odv2_elo_rating(elo_win) > 1500.0)

let elo_loss = odv2_elo_update(elo, 1500.0, 0.0, 32.0)
check("T31 elo_update loss decreases rating", odv2_elo_rating(elo_loss) < 1500.0)

// ── T32: ELO match ───────────────────────────────────────────────
// Create a strong policy (biased towards high-reward actions)
let mut strong = odv2_copy_policy(policy)
strong[2] = strong[2] + 5.0
let match_r = odv2_elo_match(strong, policy, reward_vec, 10, 42)
check("T32 elo_match returns valid result", match_r >= 0.0 && match_r <= 1.0)

// ── T33-T34: convergence ─────────────────────────────────────────
let converged_losses = [1.0, 0.99, 0.985, 0.982, 0.981]
let conv_delta = odv2_convergence_delta(converged_losses, 3)
check("T33 convergence_delta small for converged", conv_delta < 0.01)

check("T34 convergence_check true on plateau", odv2_convergence_check(converged_losses, 3, 0.01))

// ── T35: train_iter losses ───────────────────────────────────────
let iter_result = odv2_train_iter(policy, ref_pol, reward_vec, 8, 5, 42, beta, lr)
let iter_losses = iter_result[1]
check("T35 train_iter produces losses", len(iter_losses) == 5)

// ═══════════════════════════════════════════════════════════════════
println("")
println("=== Online DPO v2 #150 summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
