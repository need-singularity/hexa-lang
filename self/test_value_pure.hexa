// test_value_pure.hexa

// -- inlined from self/runtime/value_pure.hexa --
// codegen import not wired for test files

// self/runtime/value_pure.hexa
// Tag-aware value helpers as pure hexa.
// Replaces portions of runtime.c: hexa_type_of, hexa_eq, hexa_truthy,
// and tag-dispatch bits of hexa_to_string that do not need the
// small-int/cached-string hotpath.
//
// These helpers use the surface `type_of(v)` builtin, which returns one
// of: int, float, string, bool, array, map, void, function.

@pure
pub fn value_type_pure(v) {
    return type_of(v)
}

// value_truthy_pure — mirrors hexa_truthy:
//   int      → v != 0
//   float    → v != 0.0
//   string   → len > 0
//   bool     → v
//   array    → len > 0
//   map      → key count > 0 (approximated by casting to string non-empty)
//   void     → false
//   function → always true
@pure
pub fn value_truthy_pure(v) {
    let t = type_of(v)
    if t == "void" { return false }
    if t == "bool" { return v }
    if t == "int" { return v != 0 }
    if t == "float" { return v != 0.0 }
    if t == "string" { return len(v) > 0 }
    if t == "array" { return len(v) > 0 }
    if t == "map" {
        let ks = keys(v)
        return len(ks) > 0
    }
    return true
}

// value_eq_pure — structural equality.
//   primitive tags compare via `==`.
//   arrays compare element-wise with recursion.
//   maps compare key-set then value-wise.
//   different tags → false (no coercion).
@pure
pub fn value_eq_pure(a, b) {
    let ta = type_of(a)
    let tb = type_of(b)
    if ta != tb { return false }
    if ta == "array" {
        let na = len(a)
        if na != len(b) { return false }
        let mut i = 0
        while i < na {
            if !value_eq_pure(a[i], b[i]) { return false }
            i = i + 1
        }
        return true
    }
    if ta == "map" {
        let ka = keys(a)
        let kb = keys(b)
        if len(ka) != len(kb) { return false }
        let mut i = 0
        while i < len(ka) {
            let k = ka[i]
            if !value_eq_pure(a[k], b[k]) { return false }
            i = i + 1
        }
        return true
    }
    return a == b
}

// value_cmp_pure — tri-state ordering (-1, 0, 1). Undefined between
// incompatible tags (returns 0).
@pure
pub fn value_cmp_pure(a, b) {
    let ta = type_of(a)
    let tb = type_of(b)
    if ta != tb { return 0 }
    if a < b { return -1 }
    if a > b { return 1 }
    return 0
}

@pure
pub fn value_lt_pure(a, b) { return value_cmp_pure(a, b) < 0 }

@pure
pub fn value_le_pure(a, b) { return value_cmp_pure(a, b) <= 0 }

@pure
pub fn value_gt_pure(a, b) { return value_cmp_pure(a, b) > 0 }

@pure
pub fn value_ge_pure(a, b) { return value_cmp_pure(a, b) >= 0 }

// value_to_string_pure — structural stringifier that round-trips
// tests use. Does NOT match runtime.c cached-interning behavior; for
// hot paths keep the C version. Here `to_string` already handles the
// scalar cases; we only need to recurse into arrays and maps for a
// JSON-shaped representation.
@pure
pub fn value_to_string_pure(v) {
    let t = type_of(v)
    if t == "void" { return "void" }
    if t == "bool" { if v { return "true" } return "false" }
    if t == "int" { return to_string(v) }
    if t == "float" { return to_string(v) }
    if t == "string" { return "\"" + v + "\"" }
    if t == "array" {
        let mut parts = []
        let n = len(v)
        let mut i = 0
        while i < n {
            parts.push(value_to_string_pure(v[i]))
            i = i + 1
        }
        return "[" + parts.join(", ") + "]"
    }
    if t == "map" {
        let ks = keys(v)
        let mut parts = []
        let mut i = 0
        while i < len(ks) {
            let k = ks[i]
            let kstr = "\"" + k + "\""
            parts.push(kstr + ": " + value_to_string_pure(v[k]))
            i = i + 1
        }
        return "{" + parts.join(", ") + "}"
    }
    return to_string(v)
}

// value_is_numeric_pure — convenience predicate for int|float.
@pure
pub fn value_is_numeric_pure(v) {
    let t = type_of(v)
    return t == "int" || t == "float"
}

// value_is_collection_pure — array|map.
@pure
pub fn value_is_collection_pure(v) {
    let t = type_of(v)
    return t == "array" || t == "map"
}

// value_hash_pure — FNV-1a over the stringified representation. Not
// cryptographic. Tests can use it to detect structural change.
//
// Iterates via `str.bytes()` — interp's `char_code(s, i>0)` is broken
// (feedback_hexa_parser_quirks). The .bytes() method returns the full
// byte array, so we walk that instead.
@pure
pub fn value_hash_pure(v) {
    let s = value_to_string_pure(v)
    let bs = s.bytes()
    let mut h = 2166136261
    let n = len(bs)
    let mut i = 0
    while i < n {
        h = (h ^ bs[i]) * 16777619
        h = h & 0xFFFFFFFF
        i = i + 1
    }
    return h
}


// -- end inlined --

let mut pass = 0
let mut fail = 0

fn check(name, cond) {
    if cond { pass = pass + 1 } else {
        fail = fail + 1
        println("[FAIL] " + name)
    }
}

fn eq(name, a, b) {
    if a == b { pass = pass + 1 } else {
        fail = fail + 1
        println("[FAIL] " + name + " got " + to_string(a) + " want " + to_string(b))
    }
}

println("=== value_pure test suite ===")

// ---- value_type_pure (thin wrapper) ----
eq("type int", value_type_pure(1), "int")
eq("type float", value_type_pure(1.5), "float")
eq("type string", value_type_pure("hi"), "string")
eq("type array", value_type_pure([1, 2]), "array")
eq("type bool", value_type_pure(true), "bool")

// ---- truthy ----
check("truthy 1", value_truthy_pure(1))
check("truthy -1", value_truthy_pure(-1))
check("truthy false 0", !value_truthy_pure(0))
check("truthy false 0.0", !value_truthy_pure(0.0))
check("truthy 1.5", value_truthy_pure(1.5))
check("truthy true", value_truthy_pure(true))
check("truthy false", !value_truthy_pure(false))
check("truthy 'x'", value_truthy_pure("x"))
check("truthy ''", !value_truthy_pure(""))
check("truthy [1]", value_truthy_pure([1]))
check("truthy []", !value_truthy_pure([]))
check("truthy {a:1}", value_truthy_pure(#{"a": 1}))
check("truthy {}", !value_truthy_pure(#{}))

// ---- eq ----
check("eq 1==1", value_eq_pure(1, 1))
check("eq 1==2 false", !value_eq_pure(1, 2))
check("eq 'a'=='a'", value_eq_pure("a", "a"))
check("eq []==[]", value_eq_pure([], []))
check("eq [1,2]==[1,2]", value_eq_pure([1, 2], [1, 2]))
check("eq [1,2]!=[1,3]", !value_eq_pure([1, 2], [1, 3]))
check("eq [1]!=[1,2]", !value_eq_pure([1], [1, 2]))
check("eq nested arr", value_eq_pure([[1, 2], [3]], [[1, 2], [3]]))
check("eq nested arr diff", !value_eq_pure([[1, 2], [3]], [[1, 2], [4]]))
check("eq map", value_eq_pure(#{"a": 1, "b": 2}, #{"a": 1, "b": 2}))
check("eq map diff val", !value_eq_pure(#{"a": 1}, #{"a": 2}))
check("eq map diff keys", !value_eq_pure(#{"a": 1}, #{"b": 1}))
check("eq cross type", !value_eq_pure(1, "1"))
check("eq cross type2", !value_eq_pure([1], 1))

// ---- cmp / lt / le / gt / ge ----
eq("cmp 1<2", value_cmp_pure(1, 2), -1)
eq("cmp 2==2", value_cmp_pure(2, 2), 0)
eq("cmp 3>2", value_cmp_pure(3, 2), 1)
check("lt true", value_lt_pure(1, 2))
check("le true eq", value_le_pure(2, 2))
check("gt false", !value_gt_pure(1, 2))
check("ge true eq", value_ge_pure(2, 2))

// ---- to_string ----
eq("str int", value_to_string_pure(42), "42")
eq("str bool", value_to_string_pure(true), "true")
eq("str void", value_to_string_pure(void), "void")
eq("str string", value_to_string_pure("hi"), "\"hi\"")
eq("str array", value_to_string_pure([1, 2, 3]), "[1, 2, 3]")
eq("str empty array", value_to_string_pure([]), "[]")
eq("str nested", value_to_string_pure([[1], [2, 3]]), "[[1], [2, 3]]")
eq("str map 1", value_to_string_pure(#{"a": 1}), "{\"a\": 1}")

// ---- is_numeric / is_collection ----
check("is_numeric int", value_is_numeric_pure(3))
check("is_numeric float", value_is_numeric_pure(3.14))
check("is_numeric string false", !value_is_numeric_pure("3"))
check("is_collection array", value_is_collection_pure([1]))
check("is_collection map", value_is_collection_pure(#{}))
check("is_collection string false", !value_is_collection_pure("abc"))

// ---- hash ----
let h1 = value_hash_pure("hello")
let h2 = value_hash_pure("hello")
let h3 = value_hash_pure("hell0")
check("hash determ same", h1 == h2)
check("hash differs", h1 != h3)
check("hash array stable", value_hash_pure([1, 2, 3]) == value_hash_pure([1, 2, 3]))
check("hash array diff", value_hash_pure([1, 2, 3]) != value_hash_pure([1, 2, 4]))

println("===========================================================")
println("  Results: " + to_string(pass) + " passed, " + to_string(fail) + " failed")
println("===========================================================")
if fail == 0 { println("ALL PASS") } else { println("SOME FAIL") }
