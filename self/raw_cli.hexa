// self/raw_cli.hexa — hexa-native raw CLI
// usage:
//   hexa self/raw_cli.hexa               — raw(L0) + own(L1) 병합 표
//   hexa self/raw_cli.hexa list          — 동일 (명시적)
//   hexa self/raw_cli.hexa show <id>     — 상세
//   hexa self/raw_cli.hexa check         — 전체 위반 리포트 (read-only)
//   hexa self/raw_cli.hexa check <file>  — 특정 파일만
//   hexa self/raw_cli.hexa install       — pre-commit 스탠자 설치 (safety net)
//
// 2 레이어:
//   · raw core  (L0): shared/hexa-lang/raw.json — hexa-lang 전역 공통 6+
//   · own local (L1): .own-rules.json — 프로젝트 고유 절대 규칙 (HX11 패턴)
//
// 목적: CLAUDE.md 의존 축소. hexa 바이너리 자체가 raw 공표 + 검사 + 설치.

let _raw_args = args()
let mut cli_args = []
let mut _ai = 2
while _ai < len(_raw_args) {
    cli_args = cli_args.push(_raw_args[_ai])
    _ai = _ai + 1
}

// ─── 6 raw (raw.json 과 1:1, install 상태 동적 감지) ─────
// per-stanza 감지 — 각 rule 고유 마커를 개별 확인하여 display drift 방지
fn _hook_path() -> string {
    let mut pwd = env("PWD")
    if pwd == "" { pwd = to_string(exec("pwd")).trim() }
    return pwd + "/.git/hooks/pre-commit"
}

fn _raw3_installed() -> bool {
    let hook = _hook_path()
    // tolerant pattern: `raw #3`, `raw#3`, `raw  #3` 모두 매치
    let c = to_string(exec("grep -cE 'raw *#? *3' '" + hook + "' 2>/dev/null || echo 0")).trim()
    return c != "0"
}

fn _raw5_installed() -> bool {
    let hook = _hook_path()
    let c = to_string(exec("grep -cE 'raw *#? *5' '" + hook + "' 2>/dev/null || echo 0")).trim()
    return c != "0"
}

fn _raw8_installed() -> bool {
    // proof-carrying 은 standalone — drift_scanner.hexa 존재 여부로 판정
    let mut pwd = env("PWD")
    if pwd == "" { pwd = to_string(exec("pwd")).trim() }
    let path = pwd + "/scripts/drift_scanner.hexa"
    let e = to_string(exec("test -f '" + path + "' && echo y || echo n")).trim()
    return e == "y"
}

fn raw_rows() {
    let s3 = if _raw3_installed() { "live" } else { "unwired" }
    let s5 = if _raw5_installed() { "live" } else { "unwired" }
    let s8 = if _raw8_installed() { "live" } else { "new" }
    return [
        ["1", "ai-native 24 @attr",              "warn",     "git-hook",    "AST scan — hot fn attr 누락 경고"],
        ["2", "ai-native 알고리즘",               "deferred", "-",           "semantic — 2026-10 까지 연기"],
        ["3", "@attr 네이밍",                    s3,         "git-hook",    "_naming 규칙 — check_naming_all"],
        ["4", "폴더명 (F4 generic_dir)",          "live",     "git-hook",    "utils/helpers/common/lib 차단"],
        ["5", "트리구조 (F5 loner + F6 parent)",  s5,         "git-hook",    "F5/F6 scan block 승격"],
        ["6", "파일명 (F1 _v + F2 stage + F3 _)", "live",     "git-hook",    "_v\\d+ / stage|phase / _old|_bak"],
        ["7", "HEXA-ONLY (.rs/.toml/.py/.sh)",    "live",     "git-hook",    "언어 순도 — HX4 + AN13"],
        ["8", "proof-carrying mark",              s8,         "git-hook",    "done 선언 = proof_path 파일 + state 확인"],
        ["9", "AI-native default-on",             "new",      "git-hook",    "#!hexa lax 없으면 strict 강제 (grandfather)"]
    ]
}

fn _status_mark(s: string) -> string {
    if s == "live"     { return "✅" }
    if s == "warn"     { return "⚠" }
    if s == "unwired"  { return "❌" }
    if s == "deferred" { return "⏸" }
    if s == "convention" { return "📖" }
    if s == "new"      { return "🆕" }
    return "?"
}

// ─── own (L1, project-local) 파싱 ────────────────────────
// .own-rules.json 간이 파서 — id/name/status/enforce_level 추출
fn _own_rows() {
    let mut pwd = env("PWD")
    if pwd == "" { pwd = to_string(exec("pwd")).trim() }
    let path = pwd + "/.own-rules.json"
    let exists = to_string(exec("test -f '" + path + "' && echo y || echo n")).trim()
    if exists != "y" { return [] }

    let mut out = []
    let raw = to_string(exec("cat '" + path + "' 2>/dev/null"))
    // rule 블록 split: `"id":` 매번
    let parts = split(raw, "\"id\":")
    let mut i = 1  // 첫 chunk 는 _meta 이전이라 skip
    while i < len(parts) {
        let chunk = parts[i]
        // id 추출 — chunk 맨앞 숫자
        let mut id_str = ""
        let trimmed = chunk.trim_start()
        let mut k = 0
        while k < len(trimmed) {
            let c = trimmed.substring(k, k + 1)
            if c == "," || c == " " || c == "\n" || c == "}" { break }
            id_str = id_str + c
            k = k + 1
        }

        // field extractor — 단일 라인 `"key": "value"`
        let name = _own_extract_str(chunk, "name")
        let status = _own_extract_str(chunk, "status")
        let level = _own_extract_str(chunk, "enforce_level")
        let action = _own_extract_str(chunk, "action")

        if id_str != "" && name != "" {
            out = out.push([id_str, name, status, level, action])
        }
        i = i + 1
    }
    return out
}

fn _own_extract_str(chunk: string, key: string) -> string {
    let needle = "\"" + key + "\": \""
    let idx = chunk.index_of(needle)
    if idx < 0 { return "" }
    let after = chunk.substring(idx + len(needle), len(chunk))
    let end = after.index_of("\"")
    if end < 0 { return "" }
    return after.substring(0, end)
}

fn print_list() {
    // L0 — raw core
    println("── raw core (L0, universal) ─────────────────────")
    println("# | status | level     | name")
    println("──|────────|───────────|─────────────────────────────────────")
    let rows = raw_rows()
    for r in rows {
        let mark = _status_mark(r[2])
        let mut ps = r[2]
        while len(ps) < 8 { ps = ps + " " }
        let mut pl = r[3]
        while len(pl) < 9 { pl = pl + " " }
        println(r[0] + " | " + mark + " " + ps + "| " + pl + " | " + r[1])
    }

    // L1 — own local
    // P51: `own` is a reserved keyword (ownership DSL) — use `owned_rows`.
    let owned_rows = _own_rows()
    if len(owned_rows) > 0 {
        println("")
        println("── own local (L1, project-specific) ────────────")
        println("#   | status     | level      | name")
        println("────|────────────|────────────|──────────────────────────────")
        for r in owned_rows {
            let mark = _status_mark(r[2])
            let mut ps = r[2]
            while len(ps) < 10 { ps = ps + " " }
            let mut pl = r[3]
            while len(pl) < 10 { pl = pl + " " }
            let mut pid = r[0]
            while len(pid) < 3 { pid = pid + " " }
            println(pid + " | " + mark + " " + ps + " | " + pl + " | " + r[1])
        }
    }

    println("")
    println("SSOT L0 : shared/hexa-lang/raw.json")
    if len(owned_rows) > 0 { println("SSOT L1 : .own-rules.json") }
    println("상세    : hexa self/raw_cli.hexa show <id>")
    println("검사    : hexa self/raw_cli.hexa check")
    println("설치    : hexa self/raw_cli.hexa install")
    println("")

    // rollup 동적 계산 (L0 + L1)
    let mut n_live = 0
    let mut n_warn = 0
    let mut n_unwired = 0
    let mut n_deferred = 0
    let mut n_other = 0
    for r in rows {
        if r[2] == "live"     { n_live     = n_live + 1 }
        else if r[2] == "warn"     { n_warn     = n_warn + 1 }
        else if r[2] == "unwired"  { n_unwired  = n_unwired + 1 }
        else if r[2] == "deferred" { n_deferred = n_deferred + 1 }
        else { n_other = n_other + 1 }
    }
    for r in owned_rows {
        if r[2] == "live"     { n_live     = n_live + 1 }
        else if r[2] == "warn"     { n_warn     = n_warn + 1 }
        else if r[2] == "unwired"  { n_unwired  = n_unwired + 1 }
        else if r[2] == "deferred" { n_deferred = n_deferred + 1 }
        else { n_other = n_other + 1 }
    }
    let total = len(rows) + len(owned_rows)
    println("rollup : total " + to_string(total) +
            " | live " + to_string(n_live) +
            " / warn " + to_string(n_warn) +
            " / unwired " + to_string(n_unwired) +
            " / deferred " + to_string(n_deferred) +
            (if n_other > 0 { " / other " + to_string(n_other) } else { "" }))
    println("원칙   : low level 강제 — 새 세션 인지 없이도 위반 불가")
}

fn print_show(id: string) {
    let rows = raw_rows()
    for r in rows {
        if r[0] == id {
            println("── raw #" + id + " ──")
            println("  이름     : " + r[1])
            println("  상태     : " + r[2] + " " + _status_mark(r[2]))
            println("  레벨     : " + r[3])
            println("  동작     : " + r[4])
            println("")
            println("  SSOT     : shared/hexa-lang/raw.json")
            return
        }
    }
    eprintln("error: raw id 없음 — " + id)
    exit(1)
}

// ─── check: 기존 도구 다 돌림 (read-only) ─────────────────────
fn run_check(target: string) {
    let mut pwd = env("PWD")
    if pwd == "" { pwd = to_string(exec("pwd")).trim() }

    println("── raw check ─────────────────────────────────")
    let mut violations = 0

    // Rule 3 — @attr naming (check_naming_all 호출 시 위반 출력)
    println("")
    println("[3] @attr 네이밍 — _naming 규칙 검사")
    let naming_out = to_string(exec("cd '" + pwd + "' && hexa self/attrs/_registry.hexa 2>&1 | grep -E 'viol|fail|error' || echo '  (pass)'"))
    println(naming_out.trim())

    // Rule 4/5/6 — ai_native_scan
    println("")
    println("[4/5/6] 폴더/트리/파일명 — ai_native_scan")
    let scan_exists = to_string(exec("cd '" + pwd + "' && test -f scripts/ai_native_scan.hexa && echo y || echo n")).trim()
    if scan_exists == "y" {
        let scan_out = to_string(exec("cd '" + pwd + "' && hexa scripts/ai_native_scan.hexa 2>&1 | tail -20"))
        println(scan_out.trim())
    } else {
        println("  (skip — scripts/ai_native_scan.hexa 없음)")
    }

    // Rule 1 — ai-native 24 @attr (stub)
    println("")
    println("[1] ai-native 24 @attr — warn-only (scan 미구현)")

    println("")
    println("── 종료 ────────────────────────────────────────")
    if target != "" {
        println("target: " + target)
    }
}

// ─── install: pre-commit 스탠자 설치 ─────────────────────────
fn run_install() {
    let mut pwd = env("PWD")
    if pwd == "" { pwd = to_string(exec("pwd")).trim() }
    let hook_path = pwd + "/.git/hooks/pre-commit"

    let exists = to_string(exec("test -f '" + hook_path + "' && echo y || echo n")).trim()
    if exists != "y" {
        eprintln("error: " + hook_path + " 없음 — git repo 아님?")
        exit(1)
    }

    // 이미 raw 스탠자 있는지 검사
    let marker = to_string(exec("grep -c '@raw-stanza' '" + hook_path + "' 2>/dev/null || echo 0")).trim()
    if marker != "0" {
        println("already installed — '" + hook_path + "' 에 @raw-stanza 마커 존재")
        println("재설치 하려면 해당 블록 수동 삭제 후 재실행")
        exit(0)
    }

    // 3개 스탠자 append
    let stanza = "\n" +
        "# @raw-stanza — generated by self/raw_cli.hexa install (DO NOT EDIT)\n" +
        "# ── raw #3: @attr 네이밍 ────────────────────\n" +
        "EDICT_STAGED_HEXA=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null | grep '\\.hexa$' || true)\n" +
        "if [ -n \"$EDICT_STAGED_HEXA\" ] && [ -x \"./hexa\" ]; then\n" +
        "    EDICT_OUT=$(./hexa self/attrs/_registry.hexa 2>&1 | grep -E 'violation|fail' || true)\n" +
        "    if [ -n \"$EDICT_OUT\" ]; then\n" +
        "        echo \"🚫 raw#3 @attr 네이밍 위반\" >&2\n" +
        "        echo \"$EDICT_OUT\" >&2\n" +
        "        exit 1\n" +
        "    fi\n" +
        "fi\n" +
        "\n" +
        "# ── raw #5: 트리구조 (F5/F6) ─────────────────\n" +
        "if [ -x \"./hexa\" ] && [ -f \"scripts/ai_native_scan.hexa\" ]; then\n" +
        "    SCAN_F5F6=$(./hexa scripts/ai_native_scan.hexa 2>&1 | grep -E '^(F5|F6)' || true)\n" +
        "    if [ -n \"$SCAN_F5F6\" ]; then\n" +
        "        echo \"🚫 raw#5 트리구조 위반 (F5 loner / F6 parent-child)\" >&2\n" +
        "        echo \"$SCAN_F5F6\" >&2\n" +
        "        exit 1\n" +
        "    fi\n" +
        "fi\n" +
        "\n" +
        "# ── raw #1: ai-native 24 @attr (warn-only) ──\n" +
        "# (현 단계 warn 만 — block 승격은 Tier 2/3 semantic 분석 후)\n" +
        "# @raw-stanza-end\n"

    try {
        let existing = to_string(read_file(hook_path))
        write_file(hook_path, existing + stanza)
        exec("chmod +x '" + hook_path + "'")
        println("✅ installed — " + hook_path)
        println("   3 stanzas: raw#3 (attr naming), raw#5 (F5/F6), raw#1 (warn stub)")
        println("   제거: @raw-stanza ~ @raw-stanza-end 블록 수동 삭제")
    } catch e {
        eprintln("error: 쓰기 실패 " + hook_path)
        exit(1)
    }
}

// ─── dispatch ────────────────────────────────────────────────
if len(cli_args) == 0 {
    print_list()
    exit(0)
}

let sub = cli_args[0]

if sub == "list" {
    print_list()
    exit(0)
}

if sub == "show" {
    if len(cli_args) < 2 { eprintln("usage: show <id>"); exit(1) }
    print_show(cli_args[1])
    exit(0)
}

if sub == "check" {
    let target = if len(cli_args) >= 2 { cli_args[1] } else { "" }
    run_check(target)
    exit(0)
}

if sub == "install" {
    run_install()
    exit(0)
}

eprintln("usage:")
eprintln("  hexa self/raw_cli.hexa [list|show <id>|check [file]|install]")
exit(1)
