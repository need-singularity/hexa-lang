// self/raw_cli.hexa — hexa-native raw CLI
// usage:
//   hexa self/raw_cli.hexa                 — raw(L0) + own(L1) 병합 표
//   hexa self/raw_cli.hexa list            — 동일 (명시적)
//   hexa self/raw_cli.hexa show <ref>      — 상세 (ref = num 또는 slug)
//   hexa self/raw_cli.hexa verify          — pool/format/whitelist 검증
//
// SSOT:
//   L0 raw : /.raw (프로젝트 루트, universal rule)
//   L1 own : /.own (프로젝트 루트, project-local rule)
//
// 파서: self/raw_loader.hexa (inlined — interp module loader 회피, seed-freeze 기간)

use "self/stdlib/law_io"

// ─── inlined from self/raw_loader.hexa ──────────────────────────
// 배열풀 SSOT = .raw 의 raw:self-format rule (keys / statuses-rule / statuses-roadmap / statuses-loop).
// 코드는 런타임 파싱만 — 하드코딩 pool 없음. 풀 미선언 시 tolerant (accept-all) fallback.

fn _rstrip(s: string) -> string {
    let mut end = len(s)
    while end > 0 {
        let c = s.substring(end - 1, end)
        if c == " " || c == "\t" || c == "\r" {
            end = end - 1
        } else {
            break
        }
    }
    return s.substring(0, end)
}

// Public entry point for bracket-array values — `['a','b','c']` syntax.
// Also the conventional parser for the `refs` key (cross-rule slug lists).
// Mirrors self/raw_loader.hexa:parse_slug_array — inlined here during the
// seed-freeze period that blocks interp module loader.
pub fn parse_slug_array(s: string) -> array {
    let t = s.trim()
    let n = len(t)
    if n < 2 { return [] }
    if t.substring(0, 1) != "[" { return [] }
    if t.substring(n - 1, n) != "]" { return [] }
    let inner = t.substring(1, n - 1)
    let parts = split(inner, ",")
    let mut out = []
    for p in parts {
        let q = p.trim()
        let qn = len(q)
        if qn == 0 { continue }
        let first = q.substring(0, 1)
        let last = q.substring(qn - 1, qn)
        if (first == "'" && last == "'") || (first == "\"" && last == "\"") {
            out.push(q.substring(1, qn - 1))
        } else {
            out.push(q)
        }
    }
    return out
}

let mut __pool_raw_path_cache = ""
fn _pool_raw_path() -> string {
    // Cached — called ~130+ times on verify (every is_valid_raw_key/status +
    // every allowed_status_for_kind). Single `p + "/.raw"` concat amortized.
    if __pool_raw_path_cache != "" { return __pool_raw_path_cache }
    let mut p = env("PWD")
    if p == "" { p = to_string(exec("pwd")).trim() }
    let parts = [p, "/.raw"]
    __pool_raw_path_cache = parts.join("")
    return __pool_raw_path_cache
}

// 텍스트 스캔만 — is_valid_raw_key 호출 없음 (chicken-egg 회피)
fn _extract_pool() -> array {
    let path = _pool_raw_path()
    if !file_exists(path) { return [[], [], [], []] }
    let src = to_string(read_file(path))
    let lines = split(src, "\n")
    let mut in_target = false
    let mut p_keys = []
    let mut p_sr = []
    let mut p_sm = []
    let mut p_sl = []
    for raw_line in lines {
        let line = _rstrip(raw_line)
        if len(line) == 0 { in_target = false; continue }
        let first = line.substring(0, 1)
        if first == "#" { continue }
        if first != " " && first != "\t" {
            in_target = false
            continue
        }
        let stripped = line.trim_start()
        let sp = stripped.index_of(" ")
        if sp < 0 { continue }
        let k = stripped.substring(0, sp)
        let v = stripped.substring(sp + 1, len(stripped)).trim()
        if k == "slug" {
            if v == "self-format" { in_target = true } else { in_target = false }
            continue
        }
        if !in_target { continue }
        if k == "keys"             { p_keys = parse_slug_array(v) }
        else if k == "statuses-rule"    { p_sr   = parse_slug_array(v) }
        else if k == "statuses-roadmap" { p_sm   = parse_slug_array(v) }
        else if k == "statuses-loop"    { p_sl   = parse_slug_array(v) }
    }
    return [p_keys, p_sr, p_sm, p_sl]
}

pub fn is_valid_raw_status(s: string) -> bool {
    let pool = _extract_pool()
    let arr = pool[1]
    if len(arr) == 0 { return true }
    for v in arr { if v == s { return true } }
    return false
}

pub fn is_valid_raw_key(k: string) -> bool {
    let pool = _extract_pool()
    let arr = pool[0]
    if len(arr) == 0 { return true }
    for v in arr { if v == k { return true } }
    return false
}

fn _parse_header(line: string) -> array {
    let sp1 = line.index_of(" ")
    if sp1 < 0 { return [] }
    let kind = line.substring(0, sp1)
    if kind != "raw" && kind != "own" { return [] }

    let rest1 = line.substring(sp1 + 1, len(line))
    let sp2 = rest1.index_of(" ")
    if sp2 < 0 { return [] }
    let id = rest1.substring(0, sp2)

    let rest2 = rest1.substring(sp2 + 1, len(rest1))
    let sp3 = rest2.index_of(" ")
    if sp3 < 0 { return [] }
    let status = rest2.substring(0, sp3)
    if !is_valid_raw_status(status) { return [] }

    let mut name = rest2.substring(sp3 + 1, len(rest2)).trim()
    if len(name) >= 2 && name.substring(0, 1) == "\"" {
        name = name.substring(1, len(name) - 1)
    }
    return [kind, id, status, name]
}

// ─── strict format validator (spec A) ──────────────────────────────
// 규칙:
//   · column 0: 3종만 — rule header / # 주석 / 빈 줄 (whitespace-only 금지)
//   · column 2: `  <key>(\s+.*)?` — 정확히 2 스페이스 indent + key 토큰
//   · 전역 금지: tab 문자, trailing whitespace, 0/2 이외 indent
//   · 구조: 2 rule header 사이 ≥1 빈 줄 (EOF 는 관대)
// 반환: error 문자열 배열 (빈 배열 = pass). 포맷:
//   "[<path>:<lineno>] <reason>: <line>"  (line >80 자 truncate)
fn _fmt_trunc(s: string) -> string {
    if len(s) <= 80 { return s }
    return s.substring(0, 80) + "…"
}

fn _fmt_is_header_token(line: string) -> bool {
    let sp = line.index_of(" ")
    if sp < 0 { return false }
    let kind = line.substring(0, sp)
    if kind != "raw" && kind != "own" && kind != "ext" && kind != "roadmap" && kind != "loop" && kind != "checkpoint" { return false }
    return true
}

fn _fmt_count_leading_spaces(line: string) -> int {
    let mut i = 0
    let n = len(line)
    while i < n {
        let c = line.substring(i, i + 1)
        if c != " " { break }
        i = i + 1
    }
    return i
}

fn _fmt_has_tab(line: string) -> bool {
    return line.contains("\t")
}

fn _fmt_trailing_ws(line: string) -> bool {
    let n = len(line)
    if n == 0 { return false }
    let last = line.substring(n - 1, n)
    if last == " " || last == "\t" || last == "\r" { return true }
    return false
}

fn _fmt_alpha() -> string { return "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ" }
fn _fmt_alnum() -> string { return "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_-" }
fn _fmt_digits() -> string { return "0123456789" }

fn _fmt_is_ident_char(c: string, first: bool) -> bool {
    if len(c) == 0 { return false }
    if first { return _fmt_alpha().contains(c) }
    return _fmt_alnum().contains(c)
}

fn _fmt_validate_key_line(line: string) -> bool {
    let n = len(line)
    if n < 3 { return false }
    let first_c = line.substring(2, 3)
    if !_fmt_is_ident_char(first_c, true) { return false }
    let mut i = 3
    while i < n {
        let c = line.substring(i, i + 1)
        if c == " " || c == "\t" { return true }
        if !_fmt_is_ident_char(c, false) { return false }
        i = i + 1
    }
    return true
}

// kind-aware status whitelist — 런타임에 .raw raw:self-format 에서 읽음.
// raw/own/ext = statuses-rule, roadmap = statuses-roadmap, loop = statuses-loop.
pub fn allowed_status_for_kind(kind: string) -> array {
    let pool = _extract_pool()
    if kind == "raw" || kind == "own" || kind == "ext" { return pool[1] }
    if kind == "roadmap" { return pool[2] }
    if kind == "loop"    { return pool[3] }
    if kind == "checkpoint" {
        // checkpoint-kind (.roadmap inline anchors). No dedicated pool slot —
        // returns the statuses-checkpoint ladder so is_valid_status_for_kind
        // passes. Hardcoded: a second indexed pool needs parallel SSOT work.
        return ["planned", "active", "done", "deferred"]
    }
    return []
}

pub fn is_valid_status_for_kind(kind: string, s: string) -> bool {
    let arr = allowed_status_for_kind(kind)
    if len(arr) == 0 { return true }
    for v in arr { if v == s { return true } }
    return false
}

pub fn whitelist_str_for_kind(kind: string) -> string {
    let mut parts = []
    for v in allowed_status_for_kind(kind) {
        parts.push(v)
    }
    return parts.join(" ")
}

fn _fmt_validate_header(line: string) -> bool {
    let sp1 = line.index_of(" ")
    if sp1 < 0 { return false }
    let kind = line.substring(0, sp1)
    if kind != "raw" && kind != "own" && kind != "ext" && kind != "roadmap" && kind != "loop" && kind != "checkpoint" { return false }

    let rest1 = line.substring(sp1 + 1, len(line))
    let sp2 = rest1.index_of(" ")
    if sp2 < 0 { return false }
    let id = rest1.substring(0, sp2)
    if len(id) == 0 { return false }
    let mut i = 0
    if kind == "checkpoint" {
        let alnum = _fmt_alnum()
        while i < len(id) {
            let c = id.substring(i, i + 1)
            if !alnum.contains(c) { return false }
            i = i + 1
        }
    } else {
        let digits = _fmt_digits()
        while i < len(id) {
            let c = id.substring(i, i + 1)
            if !digits.contains(c) { return false }
            i = i + 1
        }
    }

    let rest2 = rest1.substring(sp2 + 1, len(rest1))
    // checkpoint headers have no explicit status — name follows id directly.
    if kind == "checkpoint" {
        let np2 = len(rest2)
        if np2 < 2 { return false }
        if rest2.substring(0, 1) != "\"" { return false }
        if rest2.substring(np2 - 1, np2) != "\"" { return false }
        if np2 < 3 { return false }
        return true
    }
    let sp3 = rest2.index_of(" ")
    if sp3 < 0 { return false }
    let status = rest2.substring(0, sp3)
    if !is_valid_status_for_kind(kind, status) { return false }

    let name_part = rest2.substring(sp3 + 1, len(rest2))
    let np = len(name_part)
    if np < 2 { return false }
    if name_part.substring(0, 1) != "\"" { return false }
    if name_part.substring(np - 1, np) != "\"" { return false }
    if np < 3 { return false }
    return true
}

fn _fmt_err(path: string, line_no: int, reason: string, raw_line: string) -> string {
    // Lazy error assembly — only called when an issue is detected, so hot
    // PASS loop emits 0 concats instead of ~4 per input line × 5 files.
    let parts = ["[", path, ":", to_string(line_no), "] ", reason, _fmt_trunc(raw_line)]
    return parts.join("")
}

pub fn validate_strict(path: string) -> array {
    let mut errs = []
    if !file_exists(path) { return errs }

    let src = to_string(read_file(path))
    let lines = split(src, "\n")

    let mut prev_kind = "none"
    let mut saw_blank_since = true
    let mut line_no = 0
    let total = len(lines)

    for raw_line in lines {
        line_no = line_no + 1
        if line_no == total && len(raw_line) == 0 { continue }

        if _fmt_has_tab(raw_line) {
            errs.push(_fmt_err(path, line_no, "tab forbidden: ", raw_line))
        }
        if _fmt_trailing_ws(raw_line) {
            errs.push(_fmt_err(path, line_no, "trailing whitespace: ", raw_line))
        }

        let ln_len = len(raw_line)
        if ln_len == 0 {
            saw_blank_since = true
            continue
        }

        let lead = _fmt_count_leading_spaces(raw_line)
        if lead == ln_len {
            saw_blank_since = true
            continue
        }

        if lead == 0 && raw_line.substring(0, 1) == "#" {
            prev_kind = "comment"
            saw_blank_since = false
            continue
        }

        if lead == 0 {
            if !_fmt_is_header_token(raw_line) {
                errs.push(_fmt_err(path, line_no, "unknown column-0 line (expected `raw|own|ext|roadmap|loop` header or `#` comment): ", raw_line))
                prev_kind = "header"
                saw_blank_since = false
                continue
            }
            if !_fmt_validate_header(raw_line) {
                errs.push(_fmt_err(path, line_no, "malformed rule header: ", raw_line))
            }
            if prev_kind == "key" && !saw_blank_since {
                errs.push(_fmt_err(path, line_no, "rule header needs preceding blank line: ", raw_line))
            }
            prev_kind = "header"
            saw_blank_since = false
            continue
        }

        if lead == 2 {
            if !_fmt_validate_key_line(raw_line) {
                errs.push(_fmt_err(path, line_no, "malformed key line (expected `  <ident>[ value]`): ", raw_line))
            }
            prev_kind = "key"
            saw_blank_since = false
            continue
        }

        let parts = ["bad indent (only 0 or 2 spaces allowed, got ", to_string(lead), "): "]
        errs.push(_fmt_err(path, line_no, parts.join(""), raw_line))
        prev_kind = "key"
        saw_blank_since = false
    }

    return errs
}

pub fn load_raw_file(path: string) -> array {
    if !file_exists(path) { return [] }

    let src = to_string(read_file(path))
    let lines = split(src, "\n")

    let mut rules = []
    let mut cur_id = ""
    let mut cur_status = ""
    let mut cur_name = ""
    let mut cur_keys = []
    let mut has_rule = false
    let mut line_no = 0

    for raw_line in lines {
        line_no = line_no + 1
        let line = _rstrip(raw_line)
        if len(line) == 0 {
            if has_rule {
                rules.push([cur_id, cur_status, cur_name, cur_keys])
                has_rule = false
                cur_keys = []
            }
            continue
        }
        let first = line.substring(0, 1)
        if first == "#" { continue }

        if first == " " || first == "\t" {
            if !has_rule { continue }
            let stripped = line.trim_start()
            let sp = stripped.index_of(" ")
            if sp < 0 { continue }
            let key = stripped.substring(0, sp)
            let val = stripped.substring(sp + 1, len(stripped)).trim()
            if !is_valid_raw_key(key) {
                if key == "hook" {
                    // deprecated 2026-04-19: git-hooks fully removed. silent skip.
                    continue
                }
                eprintln("warn[raw_loader]: " + path + ":" + to_string(line_no) +
                         " unknown key '" + key + "' (whitelist 외) — 14 키 확인")
                continue
            }
            cur_keys.push([key, val])
        } else {
            if has_rule {
                rules.push([cur_id, cur_status, cur_name, cur_keys])
                cur_keys = []
            }
            let hdr = _parse_header(line)
            if len(hdr) == 0 {
                eprintln("warn[raw_loader]: " + path + ":" + to_string(line_no) +
                         " bad header — " + line)
                has_rule = false
                continue
            }
            cur_id = hdr[1]
            cur_status = hdr[2]
            cur_name = hdr[3]
            has_rule = true
        }
    }
    if has_rule {
        rules.push([cur_id, cur_status, cur_name, cur_keys])
    }
    return rules
}

pub fn keys_first(keys: array, key: string) -> string {
    for kv in keys {
        if kv[0] == key { return kv[1] }
    }
    return ""
}

pub fn keys_all(keys: array, key: string) -> array {
    let mut out = []
    for kv in keys {
        if kv[0] == key { out.push(kv[1]) }
    }
    return out
}

pub fn rule_level(rule: array) -> string {
    let keys = rule[3]
    if keys_first(keys, "enforce") != "" { return "script" }
    if rule[1] == "deferred" { return "-" }
    return "convention"
}

pub fn rule_action(rule: array) -> string {
    let keys = rule[3]
    let why = keys_first(keys, "why")
    if why != "" { return why }
    let note = keys_first(keys, "note")
    if note != "" { return note }
    let decl = keys_first(keys, "decl")
    if decl != "" { return "decl: " + decl }
    return ""
}
// ─── end inlined raw_loader ─────────────────────────────────────

let _raw_args = args()
let mut cli_args = []
let mut _ai = 2
while _ai < len(_raw_args) {
    cli_args.push(_raw_args[_ai])
    _ai = _ai + 1
}

fn _pwd() -> string {
    let mut p = env("PWD")
    if p == "" { p = to_string(exec("pwd")).trim() }
    return p
}

fn _raw_path() -> string { return _pwd() + "/.raw" }
fn _own_path() -> string { return _pwd() + "/.own" }
fn _ext_path() -> string { return _pwd() + "/.ext" }
fn _roadmap_path() -> string { return _pwd() + "/.roadmap" }
fn _loop_path() -> string { return _pwd() + "/.loop" }

fn _has_path(p: string) -> bool {
    return file_exists(p)
}

fn _status_mark(s: string) -> string {
    if s == "live"       { return "✅" }
    if s == "warn"       { return "⚠" }
    if s == "new"        { return "🆕" }
    if s == "deferred"   { return "⏸" }
    if s == "convention" { return "📖" }
    return "?"
}

fn _pad_right(s: string, n: int) -> string {
    let need = n - len(s)
    if need <= 0 { return s }
    let mut parts = [s]
    let mut i = 0
    while i < need {
        parts.push(" ")
        i = i + 1
    }
    return parts.join("")
}

fn _print_table(title: string, rules: array) {
    if len(rules) == 0 { return }
    println("── " + title + " ─────────────────────")
    println("#  | status     | level     | name")
    println("───|────────────|───────────|─────────────────────────────")
    for r in rules {
        let id_s = _pad_right(r[0], 2)
        let st = r[1]
        let mark = _status_mark(st)
        let st_pad = _pad_right(st, 10)
        let level = _pad_right(rule_level(r), 9)
        println(id_s + " | " + mark + " " + st_pad + " | " + level + " | " + r[2])
    }
}

fn print_list() {
    let raws = load_raw_file(_raw_path())
    let owns = load_raw_file(_own_path())

    if len(raws) == 0 && len(owns) == 0 {
        eprintln("error: /.raw, /.own 둘 다 없음 — " + _pwd())
        exit(1)
    }

    _print_table("raw (L0, universal)", raws)
    if len(owns) > 0 {
        println("")
        _print_table("own (L1, project-local)", owns)
    }

    println("")
    println("SSOT L0 : .raw")
    if len(owns) > 0 { println("SSOT L1 : .own") }
    println("상세    : hexa self/raw_cli.hexa show <ref>  (ref = num 또는 slug)")
    println("검증    : hexa self/raw_cli.hexa verify")
    println("")

    // rollup
    let mut counts = [0, 0, 0, 0, 0]  // live warn new deferred convention
    let all_rules = _concat_rules(raws, owns)
    for r in all_rules {
        if r[1] == "live"       { counts[0] = counts[0] + 1 }
        else if r[1] == "warn"       { counts[1] = counts[1] + 1 }
        else if r[1] == "new"        { counts[2] = counts[2] + 1 }
        else if r[1] == "deferred"   { counts[3] = counts[3] + 1 }
        else if r[1] == "convention" { counts[4] = counts[4] + 1 }
    }
    let total = len(all_rules)
    println("rollup : total " + to_string(total) +
            " | live " + to_string(counts[0]) +
            " / warn " + to_string(counts[1]) +
            " / new " + to_string(counts[2]) +
            " / deferred " + to_string(counts[3]) +
            " / convention " + to_string(counts[4]))
    println("원칙   : low level 강제 — 새 세션 인지 없이도 위반 불가")
}

fn _concat_rules(a: array, b: array) -> array {
    let mut out = []
    for r in a { out.push(r) }
    for r in b { out.push(r) }
    return out
}

fn _is_brackarr_value(v: string) -> bool {
    let t = v.trim()
    let n = len(t)
    if n < 2 { return false }
    if t.substring(0, 1) != "[" { return false }
    if t.substring(n - 1, n) != "]" { return false }
    return true
}

fn _print_show_rule(layer: string, r: array) {
    println("── " + layer + " #" + r[0] + " ──")
    println("  이름    : " + r[2])
    println("  상태    : " + r[1] + " " + _status_mark(r[1]))
    println("  레벨    : " + rule_level(r))
    for kv in r[3] {
        let k = _pad_right(kv[0], 12)
        let v = kv[1]
        if _is_brackarr_value(v) {
            // bracket-array pretty-print — each slug on its own bullet line.
            // Used for `refs` (cross-rule slug references) and pool keys
            // (keys / statuses-rule / statuses-roadmap / statuses-loop).
            println("  " + k + ":")
            for slug in parse_slug_array(v) {
                println("               - " + slug)
            }
        } else {
            println("  " + k + ": " + v)
        }
    }
}

fn _match_ref(r: array, ref: string) -> bool {
    if r[0] == ref { return true }
    if keys_first(r[3], "slug") == ref { return true }
    return false
}

fn print_show(ref: string) {
    let raws = load_raw_file(_raw_path())
    for r in raws {
        if _match_ref(r, ref) {
            _print_show_rule("raw", r)
            println("")
            println("  SSOT    : .raw")
            return
        }
    }
    let owns = load_raw_file(_own_path())
    for r in owns {
        if _match_ref(r, ref) {
            _print_show_rule("own", r)
            println("")
            println("  SSOT    : .own")
            return
        }
    }
    eprintln("error: ref 매치 없음 — " + ref + " (num 또는 slug, raw+own 양쪽 확인)")
    exit(1)
}

// verify: whitelist/status/required-keys 검증
fn _check_rule(layer: string, r: array) -> int {
    let id = r[0]
    let status = r[1]
    let keys = r[3]
    let mut e = 0
    if !is_valid_raw_status(status) {
        eprintln("  [" + layer + " #" + id + "] invalid status: " + status)
        e = e + 1
    }
    // 필수: enforce OR (deferred + defer-until + why). git-hook 은 2026-04-19 폐기.
    let has_enf = keys_first(keys, "enforce") != ""
    if status == "deferred" {
        if keys_first(keys, "defer-until") == "" {
            eprintln("  [" + layer + " #" + id + "] deferred rule missing 'defer-until'")
            e = e + 1
        }
        if keys_first(keys, "why") == "" {
            eprintln("  [" + layer + " #" + id + "] deferred rule missing 'why'")
            e = e + 1
        }
    } else if status != "convention" && !has_enf {
        eprintln("  [" + layer + " #" + id + "] active rule missing 'enforce'")
        e = e + 1
    }
    return e
}

fn _run_strict_for(layer: string, path: string) -> int {
    if !_has_path(path) { return 0 }
    let errs = validate_strict(path)
    if len(errs) == 0 { return 0 }
    for e in errs {
        eprintln("  [" + layer + " strict] " + e)
    }
    return len(errs)
}

// ─── pool completeness gate (raw#2 self-format enforcement) ─────────
// .raw 의 raw:self-format rule 이 4 배열풀 전부 선언해야 함.
// (코드엔 하드코딩 0 — pool 자체가 SSOT, 누락 시 runtime tolerant fallback 발생 → FAIL.)
fn _check_pool_complete() -> int {
    let pool = _extract_pool()
    let labels = ["keys", "statuses-rule", "statuses-roadmap", "statuses-loop"]
    let mut e = 0
    let mut i = 0
    while i < 4 {
        let arr = pool[i]
        if len(arr) == 0 {
            eprintln("  [raw:self-format] pool '" + labels[i] + "' 미선언 또는 빈 배열 — .raw 의 slug=self-format rule 확인")
            e = e + 1
        }
        i = i + 1
    }
    return e
}

fn run_verify() {
    let raws = load_raw_file(_raw_path())
    let owns = load_raw_file(_own_path())
    let mut errs = 0
    println("── raw verify ──")
    for r in raws { errs = errs + _check_rule("raw", r) }
    for r in owns { errs = errs + _check_rule("own", r) }

    // strict format (spec A) — .raw / .own / .ext / .roadmap / .loop
    println("── strict format ──")
    errs = errs + _run_strict_for("raw", _raw_path())
    errs = errs + _run_strict_for("own", _own_path())
    errs = errs + _run_strict_for("ext", _ext_path())
    errs = errs + _run_strict_for("roadmap", _roadmap_path())
    errs = errs + _run_strict_for("loop", _loop_path())

    // pool completeness (raw:self-format SSOT — 4 배열 전부 선언 필수)
    println("── pool completeness ──")
    errs = errs + _check_pool_complete()

    let ext_exists = _has_path(_ext_path())
    let roadmap_exists = _has_path(_roadmap_path())
    let loop_exists = _has_path(_loop_path())
    println("")
    if errs == 0 {
        let mut summary = to_string(len(raws)) + " raw + " + to_string(len(owns)) + " own"
        if ext_exists { summary = summary + " + .ext" }
        if roadmap_exists { summary = summary + " + .roadmap" }
        if loop_exists { summary = summary + " + .loop" }
        summary = summary + " strict"
        println("✅ PASS — " + summary)
    } else {
        eprintln("🚫 FAIL — " + to_string(errs) + " issues")
        exit(1)
    }
}

// ── dispatch ──
if len(cli_args) == 0 {
    print_list()
    exit(0)
}

let sub = cli_args[0]

if sub == "list" { print_list(); exit(0) }

if sub == "show" {
    if len(cli_args) < 2 { eprintln("usage: show <ref>  (ref = num 또는 slug)"); exit(1) }
    print_show(cli_args[1])
    exit(0)
}

if sub == "verify" { run_verify(); exit(0) }

eprintln("usage:")
eprintln("  hexa self/raw_cli.hexa [list|show <id>|verify]")
exit(1)
