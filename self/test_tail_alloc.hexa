// ═══════════════════════════════════════════════════════════════════
//  test_tail_alloc.hexa — #62 @tail_alloc pass validation
//
//  Verifies that functions with tail-position allocations produce
//  correct results. The @tail_alloc pass rewrites allocations at
//  function return positions to reuse caller stack frames instead
//  of heap allocation, reducing GC pressure.
//
//  Patterns tested:
//    (a) return [expr, ...]          — direct array return
//    (b) return #{...}               — direct map return
//    (c) let x = [...]; return x     — let + immediate return
//    (d) if/else branches returning allocations
//    (e) constructor calls at tail position
//    (f) negative cases (non-tail, escaping, etc.)
//
//  Run: ./hexa test self/test_tail_alloc.hexa
// ═══════════════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn check_eq(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_arr(name, actual, expected) {
    if len(actual) != len(expected) {
        println("[FAIL] " + name + " — len mismatch: " + to_string(len(actual)) + " vs " + to_string(len(expected)))
        fail_count = fail_count + 1
        return
    }
    let mut ok = true
    let mut i = 0
    while i < len(actual) {
        if actual[i] != expected[i] { ok = false }
        i = i + 1
    }
    if ok {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — actual: " + to_string(actual) + ", expected: " + to_string(expected))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  #62 @tail_alloc Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── Pattern (a): direct return of array literal ─────────────

fn make_triple(a, b, c) {
    return [a, b, c]
}

check_arr("#62-01 direct return array", make_triple(1, 2, 3), [1, 2, 3])

fn make_empty_arr() {
    return []
}

check_arr("#62-02 direct return empty array", make_empty_arr(), [])

fn make_single(x) {
    return [x]
}

check_arr("#62-03 direct return single elem", make_single(42), [42])

// ── Pattern (b): direct return of map literal ───────────────

fn make_point(x, y) {
    return #{"x": x, "y": y}
}

let p = make_point(10, 20)
check_eq("#62-04 direct return map x", p["x"], 10)
check_eq("#62-05 direct return map y", p["y"], 20)

fn make_empty_map() {
    return #{}
}

let em = make_empty_map()
check_eq("#62-06 direct return empty map", to_string(em), to_string(#{}))

// ── Pattern (c): let x = alloc; return x ────────────────────

fn build_pair(a, b) {
    let result = [a, b]
    return result
}

check_arr("#62-07 let+return array", build_pair(5, 10), [5, 10])

fn build_record(name, age) {
    let rec = #{"name": name, "age": age}
    return rec
}

let r = build_record("alice", 30)
check_eq("#62-08 let+return map name", r["name"], "alice")
check_eq("#62-09 let+return map age", r["age"], 30)

fn build_mut_arr() {
    let mut arr = [1, 2, 3]
    return arr
}

check_arr("#62-10 let mut+return array", build_mut_arr(), [1, 2, 3])

// ── Pattern (d): if/else branches returning allocs ──────────

fn make_response(ok) {
    if ok {
        return [1, 0]
    } else {
        return [0, 1]
    }
}

check_arr("#62-11 branch alloc: ok=true", make_response(true), [1, 0])
check_arr("#62-12 branch alloc: ok=false", make_response(false), [0, 1])

fn make_either_map(flag) {
    if flag {
        return #{"type": "left", "val": 1}
    } else {
        return #{"type": "right", "val": 2}
    }
}

let ml = make_either_map(true)
check_eq("#62-13 branch map left type", ml["type"], "left")
let mr = make_either_map(false)
check_eq("#62-14 branch map right val", mr["val"], 2)

// ── Pattern (c) in branch: let + return in if/else ──────────

fn make_sized(n) {
    if n > 0 {
        let arr = [n, n * 2]
        return arr
    } else {
        let arr = [0]
        return arr
    }
}

check_arr("#62-15 branch let+return pos", make_sized(3), [3, 6])
check_arr("#62-16 branch let+return zero", make_sized(0), [0])

// ── Computed tail alloc (array built then returned) ─────────

fn range_arr(n) {
    let mut out = []
    let mut i = 0
    while i < n {
        out.push(i)
        i = i + 1
    }
    return out
}

check_arr("#62-17 computed tail array", range_arr(5), [0, 1, 2, 3, 4])
check_arr("#62-18 computed tail empty", range_arr(0), [])

// ── Nested function returning alloc ─────────────────────────

fn outer_alloc(x) {
    let inner = x * 2
    return [inner, inner + 1]
}

check_arr("#62-19 nested expr in tail array", outer_alloc(5), [10, 11])

// ── Multiple return paths ───────────────────────────────────

fn multi_return(x) {
    if x < 0 {
        return [-1]
    }
    if x == 0 {
        return [0]
    }
    return [x, x * x]
}

check_arr("#62-20 multi return neg", multi_return(-5), [-1])
check_arr("#62-21 multi return zero", multi_return(0), [0])
check_arr("#62-22 multi return pos", multi_return(3), [3, 9])

// ── Tail alloc with computation before return ───────────────

fn sum_and_wrap(a, b) {
    let s = a + b
    let d = a - b
    return [s, d]
}

check_arr("#62-23 compute+return", sum_and_wrap(10, 3), [13, 7])

// ── Deep nesting: tail alloc inside while→if→return ─────────

fn find_and_wrap(arr, target) {
    let mut i = 0
    while i < len(arr) {
        if arr[i] == target {
            return [i, target]
        }
        i = i + 1
    }
    return [-1, target]
}

check_arr("#62-24 find wrap found", find_and_wrap([10, 20, 30], 20), [1, 20])
check_arr("#62-25 find wrap not found", find_and_wrap([10, 20, 30], 99), [-1, 99])

// ── Chained tail alloc: one fn calls another ────────────────

fn wrap_in_arr(x) {
    return [x]
}

fn double_wrap(x) {
    let inner = wrap_in_arr(x)
    return [inner[0], inner[0] * 2]
}

check_arr("#62-26 chained tail alloc", double_wrap(7), [7, 14])

// ── Semantic equivalence: ensure values survive ─────────────

fn make_and_sum() {
    let arr = [10, 20, 30, 40]
    return arr
}

let ms = make_and_sum()
let mut total = 0
let mut idx = 0
while idx < len(ms) {
    total = total + ms[idx]
    idx = idx + 1
}
check_eq("#62-27 tail alloc value survives", total, 100)

// ── Summary ─────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  #62 @tail_alloc: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")
assert(fail_count == 0)
