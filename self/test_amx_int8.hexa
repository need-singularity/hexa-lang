// -- inlined from self/ml/amx_int8.hexa --
// codegen import not wired for test files

// ===================================================================
//  amx_int8.hexa — INT8 symmetric quantized matrix multiply (ML #184)
//
//  INT8 quantization + matmul targeting Apple Silicon AMX via the
//  Accelerate framework's integer BLAS routines.  Current implementation
//  is pure hexa; Accelerate extern stubs are provided for future
//  native AMX dispatch.
//
//  Quantization scheme: symmetric per-tensor and per-channel.
//    scale = absmax / 127
//    q     = clamp(round(w / scale), -128, 127)
//    deq   = q * scale
//
//  Functions:
//    -- primitives --
//    int8_absmax(w, n)                              -> float
//    int8_scale(w, n)                               -> float
//    int8_quantize(w, n, scale)                     -> [int]
//    int8_dequantize(qw, n, scale)                  -> [float]
//    int8_quantize_symmetric(w, n)                  -> [qw, scale]
//
//    -- per-channel --
//    int8_quantize_per_channel(w, rows, cols)       -> [qw_flat, scales]
//    int8_dequantize_per_channel(qw, sc, rows, cols)-> [float]
//
//    -- matmul --
//    int8_matmul(A_q, A_s, B_q, B_s, M, N, K)      -> [float]
//    int8_matmul_per_channel(A_q, A_sc, B_q, B_sc, M, N, K) -> [float]
//    int8_matmul_mixed(A_f, B_q, B_s, M, N, K)     -> [float]
//
//    -- dynamic quantization --
//    int8_dynamic_quantize(input, n)                -> [q_input, scale]
//    int8_dynamic_matmul(input, W_q, W_s, M, N, K) -> [float]
//
//    -- quality metrics --
//    int8_quantize_error(orig, recon, n)            -> float  (MSE)
//    int8_snr(orig, recon, n)                       -> float  (dB)
//    int8_max_error(orig, recon, n)                 -> float
//
//  Pure hexa — no Rust, no extern.
// ===================================================================

// ── Math helpers (private, prefixed _i8 to avoid collision) ──────

fn _i8_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn _i8_abs_int(x) {
    if x < 0 { return 0 - x }
    return x
}

fn _i8_max(a, b) {
    if a >= b { return a }
    return b
}

fn _i8_log10(x) {
    if x <= 0.0 { return -999.0 }
    let mut v = x
    let mut result = 0.0
    while v >= 10.0 {
        v = v / 10.0
        result = result + 1.0
    }
    while v < 1.0 {
        v = v * 10.0
        result = result - 1.0
    }
    let t = (v - 1.0) / (v + 1.0)
    let t2 = t * t
    let ln_v = 2.0 * (t + t * t2 / 3.0 + t * t2 * t2 / 5.0 + t * t2 * t2 * t2 / 7.0 + t * t2 * t2 * t2 * t2 / 9.0)
    result = result + ln_v / 2.302585
    return result
}

// ── Integer helpers ─────────────────────────────────────────────

fn int8_clamp(val, lo, hi) {
    if val < lo { return lo }
    if val > hi { return hi }
    return val
}

fn int8_round(x) {
    if x >= 0.0 { return int(x + 0.5) }
    return int(x - 0.5)
}

// ===================================================================
//  Quantization primitives
// ===================================================================

// int8_absmax(w, n) -> float
//   Find the maximum absolute value in weight array w of length n.
fn int8_absmax(w, n) {
    let mut mx = 0.0
    let mut i = 0
    while i < n {
        let a = _i8_abs(w[i])
        if a > mx { mx = a }
        i = i + 1
    }
    return mx
}

// int8_scale(w, n) -> float
//   Compute the symmetric quantization scale: absmax / 127.
//   Returns 0.0 if all weights are zero (avoids division by zero).
fn int8_scale(w, n) {
    let mx = int8_absmax(w, n)
    if mx == 0.0 { return 0.0 }
    return mx / 127.0
}

// int8_quantize(w, n, scale) -> [int]
//   Quantize float weights to int8 using the given scale.
//   q[i] = clamp(round(w[i] / scale), -128, 127)
//   If scale is 0, returns all zeros.
fn int8_quantize(w, n, scale) {
    let mut out = []
    let mut i = 0
    if scale == 0.0 {
        while i < n {
            out = out + [0]
            i = i + 1
        }
        return out
    }
    while i < n {
        let q = int8_clamp(int8_round(w[i] / scale), 0 - 128, 127)
        out = out + [q]
        i = i + 1
    }
    return out
}

// int8_dequantize(qw, n, scale) -> [float]
//   Restore float weights from quantized int8: w[i] = qw[i] * scale
fn int8_dequantize(qw, n, scale) {
    let mut out = []
    let mut i = 0
    while i < n {
        out = out + [to_float(qw[i]) * scale]
        i = i + 1
    }
    return out
}

// int8_quantize_symmetric(w, n) -> [qweights, scale]
//   Convenience: compute scale from absmax, then quantize.
//   Returns a two-element array [quantized_weights, scale].
fn int8_quantize_symmetric(w, n) {
    let s = int8_scale(w, n)
    let q = int8_quantize(w, n, s)
    return [q, s]
}

// ===================================================================
//  Per-channel quantization
// ===================================================================

// int8_quantize_per_channel(w, rows, cols) -> [qweights_flat, scales]
//   Per-row (per-output-channel) symmetric quantization.
//   w is a flat row-major array of shape (rows, cols).
//   Returns [qweights (flat, length rows*cols), scales (length rows)].
fn int8_quantize_per_channel(w, rows, cols) {
    let mut qflat = []
    let mut scales = []
    let mut r = 0
    while r < rows {
        // extract row
        let mut row = []
        let mut c = 0
        while c < cols {
            row = row + [w[r * cols + c]]
            c = c + 1
        }
        let s = int8_scale(row, cols)
        scales = scales + [s]
        let qrow = int8_quantize(row, cols, s)
        let mut ci = 0
        while ci < cols {
            qflat = qflat + [qrow[ci]]
            ci = ci + 1
        }
        r = r + 1
    }
    return [qflat, scales]
}

// int8_dequantize_per_channel(qw, scales, rows, cols) -> [float]
//   Restore float weights using per-row scales.
fn int8_dequantize_per_channel(qw, scales, rows, cols) {
    let mut out = []
    let mut r = 0
    while r < rows {
        let s = scales[r]
        let mut c = 0
        while c < cols {
            out = out + [to_float(qw[r * cols + c]) * s]
            c = c + 1
        }
        r = r + 1
    }
    return out
}

// ===================================================================
//  Quantized matmul
// ===================================================================

// int8_matmul(A_q, A_scale, B_q, B_scale, M, N, K) -> [float]
//   INT8 matmul with per-tensor scales.
//   A_q: (M, K) quantized int8, B_q: (K, N) quantized int8.
//   C[i][j] = A_scale * B_scale * sum_k(A_q[i,k] * B_q[k,j])
//   Returns flat (M, N) float output.
fn int8_matmul(A_q, A_scale, B_q, B_scale, M, N, K) {
    let combined_scale = A_scale * B_scale
    let mut out = []
    let mut i = 0
    while i < M {
        let mut j = 0
        while j < N {
            let mut acc = 0
            let mut k = 0
            while k < K {
                acc = acc + A_q[i * K + k] * B_q[k * N + j]
                k = k + 1
            }
            out = out + [combined_scale * to_float(acc)]
            j = j + 1
        }
        i = i + 1
    }
    return out
}

// int8_matmul_per_channel(A_q, A_scales, B_q, B_scales, M, N, K) -> [float]
//   INT8 matmul with per-channel (per-row) scales.
//   A_q: (M, K) with per-row A_scales (length M).
//   B_q: (K, N) with per-row B_scales (length K).
//   C[i][j] = sum_k( A_scales[i] * B_scales[k] * A_q[i,k] * B_q[k,j] )
fn int8_matmul_per_channel(A_q, A_scales, B_q, B_scales, M, N, K) {
    let mut out = []
    let mut i = 0
    while i < M {
        let a_s = A_scales[i]
        let mut j = 0
        while j < N {
            let mut acc = 0.0
            let mut k = 0
            while k < K {
                let prod = A_q[i * K + k] * B_q[k * N + j]
                acc = acc + a_s * B_scales[k] * to_float(prod)
                k = k + 1
            }
            out = out + [acc]
            j = j + 1
        }
        i = i + 1
    }
    return out
}

// int8_matmul_mixed(A_float, B_q, B_scale, M, N, K) -> [float]
//   Mixed-precision matmul: float activations x quantized int8 weights.
//   Common serving pattern — activations stay float, weights are int8.
//   B_q: (K, N) int8 weights, B_scale: per-tensor scale.
//   C[i][j] = sum_k( A_float[i,k] * B_scale * B_q[k,j] )
fn int8_matmul_mixed(A_float, B_q, B_scale, M, N, K) {
    let mut out = []
    let mut i = 0
    while i < M {
        let mut j = 0
        while j < N {
            let mut acc = 0.0
            let mut k = 0
            while k < K {
                acc = acc + A_float[i * K + k] * to_float(B_q[k * N + j])
                k = k + 1
            }
            out = out + [acc * B_scale]
            j = j + 1
        }
        i = i + 1
    }
    return out
}

// ===================================================================
//  Dynamic quantization
// ===================================================================

// int8_dynamic_quantize(input, n) -> [q_input, scale]
//   Quantize activations on-the-fly at runtime.
//   Returns [quantized_int8_array, scale].
fn int8_dynamic_quantize(input, n) {
    return int8_quantize_symmetric(input, n)
}

// int8_dynamic_matmul(input, W_q, W_scale, M, N, K) -> [float]
//   Dynamically quantize the input, then perform int8 matmul.
//   input: (M, K) float activations.
//   W_q: (K, N) pre-quantized int8 weights.
//   W_scale: per-tensor weight scale.
fn int8_dynamic_matmul(input, W_q, W_scale, M, N, K) {
    let n = M * K
    let dq = int8_dynamic_quantize(input, n)
    let q_input = dq[0]
    let input_scale = dq[1]
    return int8_matmul(q_input, input_scale, W_q, W_scale, M, N, K)
}

// ===================================================================
//  Quality metrics
// ===================================================================

// int8_quantize_error(original, reconstructed, n) -> float
//   Mean squared error between original and dequantized weights.
fn int8_quantize_error(original, reconstructed, n) {
    let mut sse = 0.0
    let mut i = 0
    while i < n {
        let e = original[i] - reconstructed[i]
        sse = sse + e * e
        i = i + 1
    }
    return sse / to_float(n)
}

// int8_snr(original, reconstructed, n) -> float
//   Signal-to-noise ratio in dB: 10 * log10(signal_power / noise_power).
fn int8_snr(original, reconstructed, n) {
    let mut sig_power = 0.0
    let mut noise_power = 0.0
    let mut i = 0
    while i < n {
        sig_power = sig_power + original[i] * original[i]
        let e = original[i] - reconstructed[i]
        noise_power = noise_power + e * e
        i = i + 1
    }
    if noise_power == 0.0 { return 999.0 }
    return 10.0 * _i8_log10(sig_power / noise_power)
}

// int8_max_error(original, reconstructed, n) -> float
//   Maximum absolute error across all elements.
fn int8_max_error(original, reconstructed, n) {
    let mut mx = 0.0
    let mut i = 0
    while i < n {
        let e = _i8_abs(original[i] - reconstructed[i])
        if e > mx { mx = e }
        i = i + 1
    }
    return mx
}

// ===================================================================
//  Accelerate stubs (future AMX int8)
// ===================================================================
//
// Apple Silicon AMX supports integer matrix operations through the
// Accelerate framework. When Accelerate's integer GEMM becomes
// available as a HEXA extern, these stubs can be activated.
//
// Future: Accelerate integer GEMM when available
// @link("Accelerate")
// @symbol("cblas_gemm_s8u8s32")
// extern fn amx_gemm_int8(order, transA, transB, offsetC,
//     M, N, K, alpha, A, lda, ao, B, ldb, bo,
//     beta, C, ldc, co) -> int
//
// @link("Accelerate")
// @symbol("vDSP_vfixr8")
// extern fn amx_float_to_int8(src, dst, n) -> void
//
// fn int8_matmul_amx(A_q, A_scale, B_q, B_scale, M, N, K) {
//     // Allocate C buffer of M*N int32 accumulators
//     // Call amx_gemm_int8 with CblasRowMajor, CblasNoTrans, CblasNoTrans
//     // Scale result: C_float[i] = A_scale * B_scale * C_int32[i]
//     // Return C_float
// }

// ===================================================================
//  Reference float matmul (for testing / comparison)
// ===================================================================

// _i8_float_matmul(A, B, M, N, K) -> [float]
//   Standard float matmul for reference comparisons.
fn _i8_float_matmul(A, B, M, N, K) {
    let mut out = []
    let mut i = 0
    while i < M {
        let mut j = 0
        while j < N {
            let mut acc = 0.0
            let mut k = 0
            while k < K {
                acc = acc + A[i * K + k] * B[k * N + j]
                k = k + 1
            }
            out = out + [acc]
            j = j + 1
        }
        i = i + 1
    }
    return out
}


// -- end inlined --

let mut PASS = 0
let mut FAIL = 0

fn check(label, cond) {
    if cond {
        PASS = PASS + 1
    } else {
        FAIL = FAIL + 1
        println("  FAIL: " + label)
    }
}

fn t_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn t_max_err_vec(a, b) {
    let n = len(a)
    let mut m = 0.0
    let mut i = 0
    while i < n {
        let e = t_abs(a[i] - b[i])
        if e > m { m = e }
        i = i + 1
    }
    return m
}

// -- Deterministic PRNG (LCG) for reproducibility --
let mut _SEED = 314159

fn t_rand() {
    _SEED = (_SEED * 1664525 + 1013904223) % 2147483648
    return _SEED
}

fn t_rand_float() {
    let r = t_rand()
    return (to_float(r) / 1073741824.0) - 1.0
}

fn t_rand_vec(n) {
    let mut out = []
    let mut i = 0
    while i < n {
        out = out + [t_rand_float()]
        i = i + 1
    }
    return out
}

// Reference float matmul for comparison
fn ref_matmul(A, B, M, N, K) {
    let mut out = []
    let mut i = 0
    while i < M {
        let mut j = 0
        while j < N {
            let mut acc = 0.0
            let mut k = 0
            while k < K {
                acc = acc + A[i * K + k] * B[k * N + j]
                k = k + 1
            }
            out = out + [acc]
            j = j + 1
        }
        i = i + 1
    }
    return out
}

// ===================================================================
//  Test 1: absmax — all positive
// ===================================================================
println("--- Test 1: absmax positive ---")

let w1 = [0.5, 1.0, 0.3, 0.8]
check("absmax positive", t_abs(int8_absmax(w1, 4) - 1.0) < 0.0001)

// ===================================================================
//  Test 2: absmax — all negative
// ===================================================================
println("--- Test 2: absmax negative ---")

let w2 = [0.0 - 0.5, 0.0 - 1.5, 0.0 - 0.3]
check("absmax negative", t_abs(int8_absmax(w2, 3) - 1.5) < 0.0001)

// ===================================================================
//  Test 3: absmax — mixed
// ===================================================================
println("--- Test 3: absmax mixed ---")

let w3 = [0.0 - 2.0, 1.0, 0.5]
check("absmax mixed", t_abs(int8_absmax(w3, 3) - 2.0) < 0.0001)

// ===================================================================
//  Test 4: absmax — single element
// ===================================================================
println("--- Test 4: absmax single ---")

let w4 = [0.0 - 3.14]
check("absmax single", t_abs(int8_absmax(w4, 1) - 3.14) < 0.0001)

// ===================================================================
//  Test 5: scale computation
// ===================================================================
println("--- Test 5: scale ---")

let w5 = [0.0 - 2.0, 1.0, 0.5]
let s5 = int8_scale(w5, 3)
// scale = 2.0 / 127.0 = 0.015748...
check("scale value", t_abs(s5 - 2.0 / 127.0) < 0.0001)

// ===================================================================
//  Test 6: quantize basic
// ===================================================================
println("--- Test 6: quantize basic ---")

let w6 = [1.0, 0.0 - 1.0, 0.5, 0.0 - 0.5]
let s6 = int8_scale(w6, 4)
let q6 = int8_quantize(w6, 4, s6)
// 1.0 / s6 = 127.0 -> q = 127
// -1.0 / s6 = -127.0 -> q = -127
check("q[0]=127", q6[0] == 127)
check("q[1]=-127", q6[1] == 0 - 127)
// 0.5 / s6 ~= 63.5 -> round = 64 or 63
let q6_2_expected = int8_round(0.5 / s6)
check("q[2] half", q6[2] == q6_2_expected)

// ===================================================================
//  Test 7: quantize zero maps to 0
// ===================================================================
println("--- Test 7: quantize zero ---")

let w7 = [0.0, 1.0, 0.0 - 1.0]
let s7 = int8_scale(w7, 3)
let q7 = int8_quantize(w7, 3, s7)
check("zero -> 0", q7[0] == 0)

// ===================================================================
//  Test 8: quantize/dequantize round-trip
// ===================================================================
println("--- Test 8: round-trip ---")

let w8 = [0.3, 0.0 - 0.7, 1.2, 0.0 - 0.1, 0.9, 0.0 - 1.5]
let n8 = 6
let s8 = int8_scale(w8, n8)
let q8 = int8_quantize(w8, n8, s8)
let d8 = int8_dequantize(q8, n8, s8)
// Round-trip error should be at most ~scale (quantization step)
let mut rt_ok = true
let mut i8 = 0
while i8 < n8 {
    if t_abs(w8[i8] - d8[i8]) > s8 + 0.001 {
        rt_ok = false
    }
    i8 = i8 + 1
}
check("round-trip error < scale", rt_ok)

// ===================================================================
//  Test 9: clamp — values outside [-128, 127]
// ===================================================================
println("--- Test 9: clamp ---")

// Use a scale that would put large values outside int8 range
let w9 = [100.0, 0.0 - 100.0, 0.5]
let small_scale = 0.1
let q9 = int8_quantize(w9, 3, small_scale)
// 100 / 0.1 = 1000 -> clamped to 127
// -100 / 0.1 = -1000 -> clamped to -128
check("clamp high to 127", q9[0] == 127)
check("clamp low to -128", q9[1] == 0 - 128)
check("clamp normal", q9[2] == int8_round(0.5 / small_scale))

// ===================================================================
//  Test 10: symmetric quantize structure
// ===================================================================
println("--- Test 10: symmetric structure ---")

let w10 = [0.5, 0.0 - 0.5, 1.0, 0.0 - 1.0]
let sym10 = int8_quantize_symmetric(w10, 4)
let q10 = sym10[0]
let sc10 = sym10[1]
check("sym returns 2-elem", len(sym10) == 2)
check("sym scale correct", t_abs(sc10 - 1.0 / 127.0) < 0.0001)
check("sym q length", len(q10) == 4)

// ===================================================================
//  Test 11: per-channel — different scales per row
// ===================================================================
println("--- Test 11: per-channel scales ---")

// Row 0: [0.5, -0.5]  absmax=0.5, scale=0.5/127
// Row 1: [2.0, -2.0]  absmax=2.0, scale=2.0/127
let w11 = [0.5, 0.0 - 0.5, 2.0, 0.0 - 2.0]
let pc11 = int8_quantize_per_channel(w11, 2, 2)
let qpc11 = pc11[0]
let spc11 = pc11[1]
check("pc scales len", len(spc11) == 2)
check("pc scale[0]", t_abs(spc11[0] - 0.5 / 127.0) < 0.0001)
check("pc scale[1]", t_abs(spc11[1] - 2.0 / 127.0) < 0.0001)
// With per-row scale, each row's max maps to 127
check("pc q row0 max", qpc11[0] == 127)
check("pc q row1 max", qpc11[2] == 127)

// ===================================================================
//  Test 12: per-channel round-trip
// ===================================================================
println("--- Test 12: per-channel round-trip ---")

let d11 = int8_dequantize_per_channel(qpc11, spc11, 2, 2)
check("pc deq length", len(d11) == 4)
check("pc deq[0]~0.5", t_abs(d11[0] - 0.5) < 0.01)
check("pc deq[1]~-0.5", t_abs(d11[1] + 0.5) < 0.01)
check("pc deq[2]~2.0", t_abs(d11[2] - 2.0) < 0.02)
check("pc deq[3]~-2.0", t_abs(d11[3] + 2.0) < 0.02)

// ===================================================================
//  Test 13: int8 matmul 2x2
// ===================================================================
println("--- Test 13: matmul 2x2 ---")

// A = [[1.0, 2.0], [3.0, 4.0]], B = [[5.0, 6.0], [7.0, 8.0]]
// C = [[19, 22], [43, 50]]
let A13 = [1.0, 2.0, 3.0, 4.0]
let B13 = [5.0, 6.0, 7.0, 8.0]
let sa13 = int8_scale(A13, 4)
let sb13 = int8_scale(B13, 4)
let qa13 = int8_quantize(A13, 4, sa13)
let qb13 = int8_quantize(B13, 4, sb13)
let c13 = int8_matmul(qa13, sa13, qb13, sb13, 2, 2, 2)
let cref13 = ref_matmul(A13, B13, 2, 2, 2)
check("matmul 2x2 len", len(c13) == 4)
// Error should be < 1% of expected
let rel_err_13_0 = t_abs(c13[0] - cref13[0]) / t_abs(cref13[0])
let rel_err_13_3 = t_abs(c13[3] - cref13[3]) / t_abs(cref13[3])
check("matmul 2x2 [0,0] <1%", rel_err_13_0 < 0.01)
check("matmul 2x2 [1,1] <1%", rel_err_13_3 < 0.01)

// ===================================================================
//  Test 14: int8 matmul 3x3 vs float reference
// ===================================================================
println("--- Test 14: matmul 3x3 ---")

_SEED = 42
let A14 = t_rand_vec(9)
let B14 = t_rand_vec(9)
let sa14 = int8_scale(A14, 9)
let sb14 = int8_scale(B14, 9)
let qa14 = int8_quantize(A14, 9, sa14)
let qb14 = int8_quantize(B14, 9, sb14)
let c14 = int8_matmul(qa14, sa14, qb14, sb14, 3, 3, 3)
let cref14 = ref_matmul(A14, B14, 3, 3, 3)
check("matmul 3x3 len", len(c14) == 9)
let maxerr14 = t_max_err_vec(c14, cref14)
// INT8 quantization of [-1,1] values: scale~1/127, so product error is small
check("matmul 3x3 error < 5%", maxerr14 < 0.05)

// ===================================================================
//  Test 15: mixed matmul — float x int8
// ===================================================================
println("--- Test 15: mixed matmul ---")

let A15 = [1.0, 0.5, 0.0 - 0.5, 1.0]
let B15 = [0.2, 0.0 - 0.3, 0.4, 0.1]
let sb15 = int8_scale(B15, 4)
let qb15 = int8_quantize(B15, 4, sb15)
let c15 = int8_matmul_mixed(A15, qb15, sb15, 2, 2, 2)
let cref15 = ref_matmul(A15, B15, 2, 2, 2)
check("mixed matmul len", len(c15) == 4)
let maxerr15 = t_max_err_vec(c15, cref15)
check("mixed matmul error < 0.02", maxerr15 < 0.02)

// ===================================================================
//  Test 16: dynamic quantize
// ===================================================================
println("--- Test 16: dynamic quantize ---")

let act16 = [0.3, 0.0 - 0.7, 1.0, 0.0 - 0.2]
let dq16 = int8_dynamic_quantize(act16, 4)
let qa16 = dq16[0]
let sa16 = dq16[1]
check("dyn quant returns 2", len(dq16) == 2)
check("dyn quant scale>0", sa16 > 0.0)
check("dyn quant q len", len(qa16) == 4)
// Max value 1.0 should map to 127
check("dyn quant max->127", qa16[2] == 127)

// ===================================================================
//  Test 17: dynamic matmul
// ===================================================================
println("--- Test 17: dynamic matmul ---")

let inp17 = [1.0, 2.0, 3.0, 4.0]
let W17 = [0.5, 0.0 - 0.5, 1.0, 0.0 - 1.0]
let sw17 = int8_scale(W17, 4)
let qw17 = int8_quantize(W17, 4, sw17)
let c17 = int8_dynamic_matmul(inp17, qw17, sw17, 2, 2, 2)
let cref17 = ref_matmul(inp17, W17, 2, 2, 2)
check("dyn matmul len", len(c17) == 4)
let maxerr17 = t_max_err_vec(c17, cref17)
check("dyn matmul error < 5%", maxerr17 < 0.05 * (t_abs(cref17[0]) + 1.0))

// ===================================================================
//  Test 18: identity matrix quantized matmul
// ===================================================================
println("--- Test 18: identity matmul ---")

// I = [[1,0],[0,1]], V = [[3.0, 4.0],[5.0, 6.0]]
// I * V = V
let I18 = [1.0, 0.0, 0.0, 1.0]
let V18 = [3.0, 4.0, 5.0, 6.0]
let si18 = int8_scale(I18, 4)
let sv18 = int8_scale(V18, 4)
let qi18 = int8_quantize(I18, 4, si18)
let qv18 = int8_quantize(V18, 4, sv18)
let c18 = int8_matmul(qi18, si18, qv18, sv18, 2, 2, 2)
check("identity matmul [0,0]~3", t_abs(c18[0] - 3.0) < 0.1)
check("identity matmul [0,1]~4", t_abs(c18[1] - 4.0) < 0.1)
check("identity matmul [1,0]~5", t_abs(c18[2] - 5.0) < 0.1)
check("identity matmul [1,1]~6", t_abs(c18[3] - 6.0) < 0.1)

// ===================================================================
//  Test 19: zero matrix matmul
// ===================================================================
println("--- Test 19: zero matrix ---")

let Z19 = [0.0, 0.0, 0.0, 0.0]
let A19 = [1.0, 2.0, 3.0, 4.0]
let sz19 = int8_scale(Z19, 4)
let sa19 = int8_scale(A19, 4)
let qz19 = int8_quantize(Z19, 4, sz19)
let qa19 = int8_quantize(A19, 4, sa19)
let c19 = int8_matmul(qa19, sa19, qz19, sz19, 2, 2, 2)
check("zero matmul all zero [0]", c19[0] == 0.0)
check("zero matmul all zero [1]", c19[1] == 0.0)
check("zero matmul all zero [2]", c19[2] == 0.0)
check("zero matmul all zero [3]", c19[3] == 0.0)

// ===================================================================
//  Test 20: MSE metric
// ===================================================================
println("--- Test 20: MSE metric ---")

let orig20 = [1.0, 2.0, 3.0, 4.0]
let recon20 = [1.1, 1.9, 3.2, 3.8]
let mse20 = int8_quantize_error(orig20, recon20, 4)
// MSE = (0.01 + 0.01 + 0.04 + 0.04) / 4 = 0.025
check("mse value", t_abs(mse20 - 0.025) < 0.001)

// ===================================================================
//  Test 21: SNR > 20 dB for typical weights
// ===================================================================
println("--- Test 21: SNR ---")

_SEED = 9999
let w21 = t_rand_vec(256)
let sym21 = int8_quantize_symmetric(w21, 256)
let q21 = sym21[0]
let s21 = sym21[1]
let d21 = int8_dequantize(q21, 256, s21)
let snr21 = int8_snr(w21, d21, 256)
check("snr > 20dB", snr21 > 20.0)

// ===================================================================
//  Test 22: max error metric
// ===================================================================
println("--- Test 22: max error ---")

let orig22 = [1.0, 2.0, 3.0]
let recon22 = [1.0, 2.5, 3.0]
let me22 = int8_max_error(orig22, recon22, 3)
check("max error = 0.5", t_abs(me22 - 0.5) < 0.0001)

// ===================================================================
//  Test 23: perfect reconstruction SNR
// ===================================================================
println("--- Test 23: perfect SNR ---")

let orig23 = [1.0, 2.0, 3.0]
let snr23 = int8_snr(orig23, orig23, 3)
check("perfect snr = 999", snr23 > 900.0)

// ===================================================================
//  Test 24: large matrix 16x16 error bound
// ===================================================================
println("--- Test 24: large 16x16 ---")

_SEED = 2026
let A24 = t_rand_vec(16 * 16)
let B24 = t_rand_vec(16 * 16)
let sa24 = int8_scale(A24, 256)
let sb24 = int8_scale(B24, 256)
let qa24 = int8_quantize(A24, 256, sa24)
let qb24 = int8_quantize(B24, 256, sb24)
let c24 = int8_matmul(qa24, sa24, qb24, sb24, 16, 16, 16)
let cref24 = ref_matmul(A24, B24, 16, 16, 16)
check("16x16 output len", len(c24) == 256)
// Compute relative error: max |c-cref| / max |cref|
let maxerr24 = t_max_err_vec(c24, cref24)
let mut maxval24 = 0.0
let mut i24 = 0
while i24 < 256 {
    let av = t_abs(cref24[i24])
    if av > maxval24 { maxval24 = av }
    i24 = i24 + 1
}
let rel24 = maxerr24 / (maxval24 + 0.0001)
check("16x16 rel error < 5%", rel24 < 0.05)

// ===================================================================
//  Test 25: int8_clamp helper
// ===================================================================
println("--- Test 25: clamp helper ---")

check("clamp mid", int8_clamp(50, 0 - 128, 127) == 50)
check("clamp lo", int8_clamp(0 - 200, 0 - 128, 127) == 0 - 128)
check("clamp hi", int8_clamp(200, 0 - 128, 127) == 127)
check("clamp exact lo", int8_clamp(0 - 128, 0 - 128, 127) == 0 - 128)
check("clamp exact hi", int8_clamp(127, 0 - 128, 127) == 127)

// ===================================================================
//  Test 26: int8_round helper
// ===================================================================
println("--- Test 26: round helper ---")

check("round 0.5 -> 1", int8_round(0.5) == 1)
check("round 0.4 -> 0", int8_round(0.4) == 0)
check("round -0.5 -> -1", int8_round(0.0 - 0.5) == 0 - 1)
check("round -0.4 -> 0", int8_round(0.0 - 0.4) == 0)
check("round 1.7 -> 2", int8_round(1.7) == 2)

// ===================================================================
//  Test 27: scale of zero vector
// ===================================================================
println("--- Test 27: zero scale ---")

let w27 = [0.0, 0.0, 0.0]
let s27 = int8_scale(w27, 3)
check("zero vec scale = 0", s27 == 0.0)
// Quantize zero vector should return all zeros
let q27 = int8_quantize(w27, 3, s27)
check("zero quant [0]", q27[0] == 0)
check("zero quant [1]", q27[1] == 0)
check("zero quant [2]", q27[2] == 0)

// ===================================================================
//  Test 28: negative absmax
// ===================================================================
println("--- Test 28: negative absmax ---")

let w28 = [0.0 - 5.0, 0.0 - 3.0, 0.0 - 1.0]
check("neg absmax = 5.0", t_abs(int8_absmax(w28, 3) - 5.0) < 0.0001)

// ===================================================================
//  Test 29: per-channel dequantize correctness
// ===================================================================
println("--- Test 29: per-channel deq ---")

_SEED = 5050
let w29 = t_rand_vec(3 * 4)
let pc29 = int8_quantize_per_channel(w29, 3, 4)
let qpc29 = pc29[0]
let spc29 = pc29[1]
let d29 = int8_dequantize_per_channel(qpc29, spc29, 3, 4)
check("pc deq len", len(d29) == 12)
// Each element error bounded by row scale
let mut pc_ok = true
let mut i29 = 0
while i29 < 3 {
    let mut j29 = 0
    while j29 < 4 {
        let idx = i29 * 4 + j29
        let err_29 = t_abs(w29[idx] - d29[idx])
        if err_29 > spc29[i29] + 0.001 {
            pc_ok = false
        }
        j29 = j29 + 1
    }
    i29 = i29 + 1
}
check("pc deq error bounded", pc_ok)

// ===================================================================
//  Test 30: matmul per-channel
// ===================================================================
println("--- Test 30: matmul per-channel ---")

let A30 = [1.0, 0.5, 0.0 - 0.5, 1.0, 0.0 - 1.0, 0.5]
let B30 = [0.2, 0.0 - 0.3, 0.4, 0.1, 0.0 - 0.5, 0.6]
let pcA30 = int8_quantize_per_channel(A30, 2, 3)
let pcB30 = int8_quantize_per_channel(B30, 3, 2)
let c30 = int8_matmul_per_channel(pcA30[0], pcA30[1], pcB30[0], pcB30[1], 2, 2, 3)
let cref30 = ref_matmul(A30, B30, 2, 2, 3)
check("pc matmul len", len(c30) == 4)
let maxerr30 = t_max_err_vec(c30, cref30)
check("pc matmul error < 0.1", maxerr30 < 0.1)

// ===================================================================
//  Test 31: mixed matmul correctness vs float
// ===================================================================
println("--- Test 31: mixed matmul vs float ---")

_SEED = 7777
let A31 = t_rand_vec(4 * 4)
let B31 = t_rand_vec(4 * 4)
let sb31 = int8_scale(B31, 16)
let qb31 = int8_quantize(B31, 16, sb31)
let c31 = int8_matmul_mixed(A31, qb31, sb31, 4, 4, 4)
// Dequantize B for reference
let db31 = int8_dequantize(qb31, 16, sb31)
let cref31 = ref_matmul(A31, db31, 4, 4, 4)
let maxerr31 = t_max_err_vec(c31, cref31)
check("mixed vs deq-ref error tiny", maxerr31 < 0.001)

// ===================================================================
//  Test 32: dynamic matmul vs static matmul
// ===================================================================
println("--- Test 32: dynamic vs static ---")

let A32 = [0.5, 0.0 - 0.3, 0.8, 0.0 - 0.1]
let W32 = [0.4, 0.0 - 0.6, 0.2, 0.0 - 0.8]
let sw32 = int8_scale(W32, 4)
let qw32 = int8_quantize(W32, 4, sw32)
let c_dyn32 = int8_dynamic_matmul(A32, qw32, sw32, 2, 2, 2)
// Static: quantize A32 manually, then matmul
let sa32 = int8_scale(A32, 4)
let qa32 = int8_quantize(A32, 4, sa32)
let c_stat32 = int8_matmul(qa32, sa32, qw32, sw32, 2, 2, 2)
let maxerr32 = t_max_err_vec(c_dyn32, c_stat32)
check("dyn vs static identical", maxerr32 < 0.0001)

// ===================================================================
//  Test 33: quantize preserves sign
// ===================================================================
println("--- Test 33: sign preservation ---")

let w33 = [0.5, 0.0 - 0.5, 0.0]
let s33 = int8_scale(w33, 3)
let q33 = int8_quantize(w33, 3, s33)
check("pos sign preserved", q33[0] > 0)
check("neg sign preserved", q33[1] < 0)
check("zero sign zero", q33[2] == 0)

// ===================================================================
//  Test 34: large value saturation
// ===================================================================
println("--- Test 34: saturation ---")

// Extreme values: absmax=1000, scale=1000/127~7.87
// Then within-range values should still map correctly
let w34 = [1000.0, 0.0 - 1000.0, 500.0, 0.0]
let s34 = int8_scale(w34, 4)
let q34 = int8_quantize(w34, 4, s34)
check("sat max -> 127", q34[0] == 127)
check("sat min -> -127", q34[1] == 0 - 127)
// 500 / (1000/127) = 63.5 -> round to 64 or 63
let expected34 = int8_round(500.0 / s34)
check("sat mid correct", q34[2] == expected34)
check("sat zero -> 0", q34[3] == 0)

