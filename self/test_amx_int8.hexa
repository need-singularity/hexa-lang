//  Summary
// ===================================================================
println("")
println("=== amx_int8 tests ===")
println("PASS: " + str(PASS))
println("FAIL: " + str(FAIL))
println("TOTAL: " + str(PASS + FAIL))
if FAIL == 0 {
    println("ALL TESTS PASSED")
} else {
    println("SOME TESTS FAILED")
}
