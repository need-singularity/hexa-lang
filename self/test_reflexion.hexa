// ═══════════════════════════════════════════════════════════════
//  test_reflexion.hexa — Reflexion Loop verification (#73)
//
//  Tests:
//    T1  empty memory has zero trace length
//    T2  rfx_trace_push grows trace + preserves last_action
//    T3  rfx_last_reward returns most recent reward
//    T4  rfx_last_critique returns most recent critique string
//    T5  rfx_verifier passes within tolerance, fails outside
//    T6  rfx_reward is 1.0 at exact match and decays with distance
//    T7  rfx_self_critique returns "too_low" / "too_high" / "success"
//    T8  cold-start agent returns 0.0 with empty memory
//    T9  rfx_run converges to target within max_iter (success detected)
//    T10 rfx_improvement_trend is > 0 on converging run
//    T11 max_iter cap honored — run stops at max_iter even if no success
//    T12 rfx_success_iter returns earliest success (or -1)
//    T13 critique injection visibly alters next action direction
//    T14 best reward monotonically reached over iterations
//
//  run: ./hexa self/test_reflexion.hexa
// ═══════════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx(a, b, eps) { return fabs(a - b) < eps }

// ── inlined from self/ml/reflexion.hexa ─────────────────────────

fn rfx_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn rfx_min(a, b) {
    if a < b { return a }
    return b
}

fn rfx_max(a, b) {
    if a > b { return a }
    return b
}

fn rfx_new_memory() {
    let m = #{}
    m["actions"] = []
    m["rewards"] = []
    m["critiques"] = []
    m["success"] = []
    return m
}

fn rfx_trace_push(memory, action, reward, critique, success) {
    memory["actions"] = memory["actions"] + [action]
    memory["rewards"] = memory["rewards"] + [reward]
    memory["critiques"] = memory["critiques"] + [critique]
    memory["success"] = memory["success"] + [success]
    return memory
}

fn rfx_trace_len(memory) {
    return len(memory["actions"])
}

fn rfx_last_action(memory) {
    let n = len(memory["actions"])
    if n == 0 { return 0.0 }
    return memory["actions"][n - 1]
}

fn rfx_last_reward(memory) {
    let n = len(memory["rewards"])
    if n == 0 { return 0.0 }
    return memory["rewards"][n - 1]
}

fn rfx_last_critique(memory) {
    let n = len(memory["critiques"])
    if n == 0 { return "" }
    return memory["critiques"][n - 1]
}

fn rfx_verifier(target, action, tol) {
    if rfx_abs(target - action) <= tol { return 1 }
    return 0
}

fn rfx_reward(target, action) {
    let d = rfx_abs(target - action)
    return 1.0 / (1.0 + d)
}

fn rfx_self_critique(target, action) {
    let d = target - action
    if rfx_abs(d) < 1.0e-6 { return "success" }
    if d > 0.0 { return "too_low" }
    return "too_high"
}

fn rfx_agent_step(target, memory) {
    let n = len(memory["actions"])
    if n == 0 { return 0.0 }
    let last = memory["actions"][n - 1]
    let critique = memory["critiques"][n - 1]
    let last_reward = memory["rewards"][n - 1]
    let mut step = (1.0 - last_reward) * rfx_max(rfx_abs(target), 1.0)
    if step < 0.1 { step = 0.1 }
    if step > 1000.0 { step = 1000.0 }
    let halved = step / to_float(n + 1)
    if critique == "too_low" { return last + halved }
    if critique == "too_high" { return last - halved }
    return last
}

fn rfx_run(target, max_iter, tol) {
    let mut memory = rfx_new_memory()
    for _i in 0..max_iter {
        let action = rfx_agent_step(target, memory)
        let reward = rfx_reward(target, action)
        let succ = rfx_verifier(target, action, tol)
        let critique = rfx_self_critique(target, action)
        memory = rfx_trace_push(memory, action, reward, critique, succ)
        if succ == 1 { return memory }
    }
    return memory
}

fn rfx_improvement_trend(memory) {
    let n = len(memory["rewards"])
    if n < 2 { return 0.0 }
    let mut sum_delta = 0.0
    for i in 1..n {
        sum_delta = sum_delta + (memory["rewards"][i] - memory["rewards"][i - 1])
    }
    return sum_delta / to_float(n - 1)
}

fn rfx_success_iter(memory) {
    let n = len(memory["success"])
    for i in 0..n {
        if memory["success"][i] == 1 { return i }
    }
    return -1
}

fn rfx_best_reward(memory) {
    let n = len(memory["rewards"])
    if n == 0 { return 0.0 }
    let mut best = memory["rewards"][0]
    for i in 1..n {
        if memory["rewards"][i] > best { best = memory["rewards"][i] }
    }
    return best
}

// ═══════════════════════════════════════════════════════════════
//  TESTS
// ═══════════════════════════════════════════════════════════════

// T1: empty memory
let m1 = rfx_new_memory()
check("T1 empty memory trace_len=0", rfx_trace_len(m1) == 0)

// T2: trace push grows memory + last_action
let mut m2 = rfx_new_memory()
m2 = rfx_trace_push(m2, 3.14, 0.5, "too_low", 0)
m2 = rfx_trace_push(m2, 4.20, 0.9, "too_high", 0)
check("T2a trace_len=2 after 2 pushes", rfx_trace_len(m2) == 2)
check("T2b last_action=4.20", approx(rfx_last_action(m2), 4.20, 0.001))

// T3: last_reward
check("T3 last_reward=0.9", approx(rfx_last_reward(m2), 0.9, 0.001))

// T4: last_critique
check("T4 last_critique=too_high", rfx_last_critique(m2) == "too_high")

// T5: verifier tolerance boundaries
check("T5a verifier pass within tol", rfx_verifier(10.0, 10.05, 0.1) == 1)
check("T5b verifier fail outside tol", rfx_verifier(10.0, 10.5, 0.1) == 0)

// T6: reward behaves — 1.0 at exact match, decays with distance
check("T6a reward=1.0 exact", approx(rfx_reward(5.0, 5.0), 1.0, 0.001))
let r_near = rfx_reward(5.0, 5.5)
let r_far = rfx_reward(5.0, 10.0)
check("T6b reward decays with distance", r_near > r_far)

// T7: self-critique direction classification
check("T7a critique too_low", rfx_self_critique(10.0, 3.0) == "too_low")
check("T7b critique too_high", rfx_self_critique(10.0, 15.0) == "too_high")
check("T7c critique success", rfx_self_critique(10.0, 10.0) == "success")

// T8: cold-start agent step
let m8 = rfx_new_memory()
check("T8 cold-start action=0.0", approx(rfx_agent_step(7.0, m8), 0.0, 0.001))

// T9: rfx_run converges (success detected within max_iter)
let run_mem = rfx_run(5.0, 100, 0.2)
let s_iter = rfx_success_iter(run_mem)
check("T9 rfx_run reaches success", s_iter >= 0)

// T10: improvement trend is positive on a converging run
let trend = rfx_improvement_trend(run_mem)
check("T10 improvement trend > 0 on converging run", trend > 0.0)

// T11: max_iter cap honored — unreachable target with tiny tol
//      forces trace length == max_iter (no early exit)
let capped = rfx_run(1.0e9, 5, 1.0e-9)
check("T11 max_iter cap respected (len<=5)", rfx_trace_len(capped) == 5)
check("T11b no success for unreachable target", rfx_success_iter(capped) == -1)

// T12: success_iter returns -1 on never-success
check("T12 success_iter=-1 when no success", rfx_success_iter(capped) == -1)

// T13: critique injection alters next action direction
//      After "too_low" the next step should MOVE UP from last action.
let mut m13 = rfx_new_memory()
m13 = rfx_trace_push(m13, 2.0, 0.5, "too_low", 0)
let next_up = rfx_agent_step(10.0, m13)
check("T13a too_low critique pushes action up", next_up > 2.0)
let mut m13b = rfx_new_memory()
m13b = rfx_trace_push(m13b, 20.0, 0.5, "too_high", 0)
let next_dn = rfx_agent_step(10.0, m13b)
check("T13b too_high critique pushes action down", next_dn < 20.0)

// T14: best reward grows over iterations on converging run
let best = rfx_best_reward(run_mem)
check("T14 best_reward reached >= 0.8 on convergence", best >= 0.8)

// ═══════════════════════════════════════════════════════════════
println("")
println("=== reflexion test summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
