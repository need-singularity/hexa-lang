// ═══════════════════════════════════════════════════════════
//  test_result_type.hexa — Result Type & Error Propagation Tests
//  Tests: Result/Option enums, constructors, queries, extractors,
//         combinators (map, and_then, or_else), pattern matching,
//         error propagation (try_call), chaining, conversions
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA Result Type & Error Propagation Tests")
println("═══════════════════════════════════════════════════════")

// ═══════════════════════════════════════════════════════════
//  Stdlib definitions (inline for self-contained test)
// ═══════════════════════════════════════════════════════════

enum Result { Ok(val), Err(msg) }
enum Option { Some(val), None }

fn ok(val) { return Result::Ok(val) }
fn err(msg) { return Result::Err(msg) }

fn is_ok(r) {
    return match r { Ok(_) -> true, Err(_) -> false }
}
fn is_err(r) {
    return match r { Ok(_) -> false, Err(_) -> true }
}

fn unwrap(r) {
    return match r {
        Ok(x) -> x,
        Err(e) -> { throw "unwrap called on Err: " + to_string(e) }
    }
}
fn unwrap_or(r, default) {
    return match r { Ok(x) -> x, Err(_) -> default }
}
fn unwrap_or_else(r, fallback_fn) {
    return match r { Ok(x) -> x, Err(e) -> fallback_fn(e) }
}
fn unwrap_err(r) {
    return match r {
        Ok(x) -> { throw "unwrap_err called on Ok: " + to_string(x) },
        Err(e) -> e
    }
}

fn map_result(r, map_fn) {
    return match r { Ok(x) -> Result::Ok(map_fn(x)), Err(e) -> Result::Err(e) }
}
fn map_err(r, err_fn) {
    return match r { Ok(x) -> Result::Ok(x), Err(e) -> Result::Err(err_fn(e)) }
}
fn and_then(r, then_fn) {
    return match r { Ok(x) -> then_fn(x), Err(e) -> Result::Err(e) }
}
fn or_else(r, else_fn) {
    return match r { Ok(x) -> Result::Ok(x), Err(e) -> else_fn(e) }
}

fn some(val) { return Option::Some(val) }
fn none() { return Option::None }
fn is_some(o) { return match o { Some(_) -> true, None -> false } }
fn is_none(o) { return match o { Some(_) -> false, None -> true } }
fn unwrap_option(o) {
    return match o { Some(x) -> x, None -> { throw "unwrap called on None" } }
}
fn unwrap_option_or(o, default) {
    return match o { Some(x) -> x, None -> default }
}
fn map_option(o, opt_fn) {
    return match o { Some(x) -> Option::Some(opt_fn(x)), None -> Option::None }
}
fn and_then_option(o, opt_then) {
    return match o { Some(x) -> opt_then(x), None -> Option::None }
}

fn result_to_option(r) {
    return match r { Ok(x) -> Option::Some(x), Err(_) -> Option::None }
}
fn option_to_result(o, err_msg) {
    return match o { Some(x) -> Result::Ok(x), None -> Result::Err(err_msg) }
}

fn try_call(call_fn) {
    let mut result = Result::Err("unknown")
    try { result = Result::Ok(call_fn()) } catch e { result = Result::Err(to_string(e)) }
    return result
}
fn try_call1(call1_fn, arg) {
    let mut result = Result::Err("unknown")
    try { result = Result::Ok(call1_fn(arg)) } catch e { result = Result::Err(to_string(e)) }
    return result
}
fn try_call2(call2_fn, a, b) {
    let mut result = Result::Err("unknown")
    try { result = Result::Ok(call2_fn(a, b)) } catch e { result = Result::Err(to_string(e)) }
    return result
}

// ═══════════════════════════════════════════════════════════
//  1. Basic Ok/Err Creation
// ═══════════════════════════════════════════════════════════

println("")
println("--- 1. Basic Ok/Err Creation ---")

let r1 = Result::Ok(42)
check("Ok(42) toString", to_string(r1), "Result::Ok(42)")

let r2 = Result::Err("not found")
check("Err toString", to_string(r2), "Result::Err(not found)")

let r3 = ok(100)
check("ok(100) toString", to_string(r3), "Result::Ok(100)")

let r4 = err("bad input")
check("err() toString", to_string(r4), "Result::Err(bad input)")

// Ok with different value types
let r_str = ok("hello")
check("ok string", to_string(r_str), "Result::Ok(hello)")

let r_bool = ok(true)
check("ok bool", to_string(r_bool), "Result::Ok(true)")

let r_arr = ok([1, 2, 3])
check("ok array", to_string(r_arr), "Result::Ok([1, 2, 3])")

// ═══════════════════════════════════════════════════════════
//  2. is_ok / is_err Queries
// ═══════════════════════════════════════════════════════════

println("")
println("--- 2. is_ok / is_err ---")

check("is_ok(Ok)", is_ok(ok(1)), true)
check("is_ok(Err)", is_ok(err("x")), false)
check("is_err(Ok)", is_err(ok(1)), false)
check("is_err(Err)", is_err(err("x")), true)

// ═══════════════════════════════════════════════════════════
//  3. Pattern Matching on Result
// ═══════════════════════════════════════════════════════════

println("")
println("--- 3. Pattern Matching ---")

fn describe(r) {
    return match r {
        Ok(x) -> "got: " + to_string(x),
        Err(e) -> "error: " + to_string(e)
    }
}

check("match Ok", describe(ok(42)), "got: 42")
check("match Err", describe(err("oops")), "error: oops")

// Match with full prefix
let r5 = Result::Ok(99)
let v5 = match r5 {
    Result::Ok(x) -> x * 2,
    Result::Err(e) -> -1
}
check("match full prefix", v5, 198)

// Match with shorthand
let r6 = Result::Err("fail")
let v6 = match r6 {
    Ok(x) -> x,
    Err(e) -> e
}
check("match shorthand Err", v6, "fail")

// ═══════════════════════════════════════════════════════════
//  4. unwrap / unwrap_or / unwrap_or_else
// ═══════════════════════════════════════════════════════════

println("")
println("--- 4. Extractors ---")

check("unwrap Ok", unwrap(ok(42)), 42)
check("unwrap Ok str", unwrap(ok("hi")), "hi")

// unwrap on Err should throw
let mut caught = false
try {
    unwrap(err("boom"))
} catch e {
    caught = true
}
check("unwrap Err throws", caught, true)

check("unwrap_or Ok", unwrap_or(ok(10), 0), 10)
check("unwrap_or Err", unwrap_or(err("x"), 0), 0)
check("unwrap_or Err string", unwrap_or(err("x"), "default"), "default")

// unwrap_or_else
let v7 = unwrap_or_else(ok(5), |e| -1)
check("unwrap_or_else Ok", v7, 5)

let v8 = unwrap_or_else(err("bad"), |e| -1)
check("unwrap_or_else Err", v8, -1)

// unwrap_err
check("unwrap_err on Err", unwrap_err(err("msg")), "msg")

let mut caught2 = false
try {
    unwrap_err(ok(42))
} catch e {
    caught2 = true
}
check("unwrap_err on Ok throws", caught2, true)

// ═══════════════════════════════════════════════════════════
//  5. map_result
// ═══════════════════════════════════════════════════════════

println("")
println("--- 5. map_result ---")

let m1 = map_result(ok(5), |x| x * 2)
check("map Ok", unwrap(m1), 10)

let m2 = map_result(err("nope"), |x| x * 2)
check("map Err passthrough", is_err(m2), true)
check("map Err value", unwrap_err(m2), "nope")

let m3 = map_result(ok("hello"), |s| s + " world")
check("map Ok string", unwrap(m3), "hello world")

// Chained maps
let m4 = map_result(map_result(ok(3), |x| x + 1), |x| x * 10)
check("chained map", unwrap(m4), 40)

// ═══════════════════════════════════════════════════════════
//  6. map_err
// ═══════════════════════════════════════════════════════════

println("")
println("--- 6. map_err ---")

let me1 = map_err(ok(42), |e| "wrapped: " + e)
check("map_err Ok passthrough", unwrap(me1), 42)

let me2 = map_err(err("raw"), |e| "wrapped: " + e)
check("map_err Err", unwrap_err(me2), "wrapped: raw")

// ═══════════════════════════════════════════════════════════
//  7. and_then (flatMap / bind)
// ═══════════════════════════════════════════════════════════

println("")
println("--- 7. and_then ---")

fn parse_positive(x) {
    if x > 0 { return ok(x) }
    return err("not positive")
}

fn halve_even(x) {
    if x % 2 == 0 { return ok(x / 2) }
    return err("not even")
}

// Chain: parse_positive -> halve_even
// Note: use lambda wrappers to avoid runtime scope leakage with named fns
let at1 = and_then(parse_positive(10), |x| halve_even(x))
check("and_then Ok->Ok", unwrap(at1), 5)

let at2 = and_then(parse_positive(-5), |x| halve_even(x))
check("and_then Err short-circuit", is_err(at2), true)
check("and_then Err msg", unwrap_err(at2), "not positive")

let at3 = and_then(parse_positive(7), |x| halve_even(x))
check("and_then Ok->Err", is_err(at3), true)
check("and_then Ok->Err msg", unwrap_err(at3), "not even")

// Triple chain using intermediate variables
fn double_if_small(x) {
    if x < 100 { return ok(x * 2) }
    return err("too large")
}

let at4_step1 = and_then(parse_positive(4), |x| halve_even(x))
let at4 = and_then(at4_step1, |x| double_if_small(x))
check("triple chain Ok", unwrap(at4), 4)

let at5_step1 = and_then(parse_positive(6), |x| halve_even(x))
let at5 = and_then(at5_step1, |x| double_if_small(x))
check("triple chain Ok 2", unwrap(at5), 6)

// ═══════════════════════════════════════════════════════════
//  8. or_else (Error Recovery)
// ═══════════════════════════════════════════════════════════

println("")
println("--- 8. or_else ---")

fn try_backup(e) {
    return ok(0)
}

let oe1 = or_else(ok(42), |e| ok(0))
check("or_else Ok passthrough", unwrap(oe1), 42)

let oe2 = or_else(err("fail"), |e| ok(0))
check("or_else Err recovers", unwrap(oe2), 0)

// Recovery chain
let oe3_step1 = or_else(err("primary failed"), |e| err("secondary failed"))
let oe3 = or_else(oe3_step1, |e| ok(-1))
check("or_else chain recovery", unwrap(oe3), -1)

// ═══════════════════════════════════════════════════════════
//  9. Option Type
// ═══════════════════════════════════════════════════════════

println("")
println("--- 9. Option Type ---")

let o1 = some(42)
let o2 = none()

check("is_some(Some)", is_some(o1), true)
check("is_some(None)", is_some(o2), false)
check("is_none(Some)", is_none(o1), false)
check("is_none(None)", is_none(o2), true)

check("unwrap_option Some", unwrap_option(o1), 42)
check("unwrap_option_or Some", unwrap_option_or(o1, 0), 42)
check("unwrap_option_or None", unwrap_option_or(o2, 0), 0)

let mut opt_caught = false
try { unwrap_option(none()) } catch e { opt_caught = true }
check("unwrap_option None throws", opt_caught, true)

// map_option
let om1 = map_option(some(5), |x| x * 3)
check("map_option Some", unwrap_option(om1), 15)

let om2 = map_option(none(), |x| x * 3)
check("map_option None", is_none(om2), true)

// and_then_option
fn safe_sqrt(x) {
    if x >= 0 { return some(x) }
    return none()
}

let ato1 = and_then_option(some(16), safe_sqrt)
check("and_then_option Some->Some", unwrap_option(ato1), 16)

let ato2 = and_then_option(some(-4), safe_sqrt)
check("and_then_option Some->None", is_none(ato2), true)

let ato3 = and_then_option(none(), safe_sqrt)
check("and_then_option None", is_none(ato3), true)

// ═══════════════════════════════════════════════════════════
//  10. Result <-> Option Conversions
// ═══════════════════════════════════════════════════════════

println("")
println("--- 10. Conversions ---")

let co1 = result_to_option(ok(42))
check("result_to_option Ok", unwrap_option(co1), 42)

let co2 = result_to_option(err("x"))
check("result_to_option Err", is_none(co2), true)

let co3 = option_to_result(some(10), "missing")
check("option_to_result Some", unwrap(co3), 10)

let co4 = option_to_result(none(), "missing")
check("option_to_result None", unwrap_err(co4), "missing")

// ═══════════════════════════════════════════════════════════
//  11. try_call — Wrap Throwing Functions
// ═══════════════════════════════════════════════════════════

println("")
println("--- 11. try_call Error Propagation ---")

fn safe_div(a, b) {
    if b == 0 { throw "division by zero" }
    return a / b
}

let tc1 = try_call2(safe_div, 10, 2)
check("try_call2 ok", unwrap(tc1), 5)

let tc2 = try_call2(safe_div, 10, 0)
check("try_call2 err", is_err(tc2), true)
check("try_call2 err msg", unwrap_err(tc2), "Error(division by zero)")

fn must_positive(x) {
    if x <= 0 { throw "must be positive" }
    return x * 10
}

let tc3 = try_call1(|x| must_positive(x), 5)
check("try_call1 ok", unwrap(tc3), 50)

let tc4 = try_call1(|x| must_positive(x), -3)
check("try_call1 err", is_err(tc4), true)

// try_call with no args — inline to avoid fn param scope leakage
fn get_answer() { return 42 }
let tc5 = try_call(get_answer)
check("try_call ok", unwrap(tc5), 42)

// Separate try_call_err to avoid param leakage
fn try_call_err(fail_fn) {
    let mut result = Result::Err("unknown")
    try { result = Result::Ok(fail_fn()) } catch e { result = Result::Err(to_string(e)) }
    return result
}
fn always_fail() { throw "always" }
let tc6 = try_call_err(always_fail)
check("try_call err", is_err(tc6), true)
check("try_call err msg", unwrap_err(tc6), "Error(always)")

// ═══════════════════════════════════════════════════════════
//  12. Error Propagation Pipeline
// ═══════════════════════════════════════════════════════════

println("")
println("--- 12. Propagation Pipeline ---")

// Real-world pattern: parse -> validate -> transform
fn parse_input(s) {
    if s == "" { return err("empty input") }
    let mut n = 0
    try {
        n = to_int(s)
    } catch e {
        return err("not a number: " + s)
    }
    return ok(n)
}

fn validate_range(n) {
    if n < 0 { return err("negative: " + to_string(n)) }
    if n > 1000 { return err("too large: " + to_string(n)) }
    return ok(n)
}

fn transform(n) {
    return ok(n * 2 + 1)
}

fn process(input) {
    let step1 = and_then(parse_input(input), |n| validate_range(n))
    return and_then(step1, |n| transform(n))
}

check("pipeline valid", unwrap(process("42")), 85)
check("pipeline empty", unwrap_err(process("")), "empty input")
check("pipeline negative", unwrap_err(process("-5")), "negative: -5")
check("pipeline too large", unwrap_err(process("2000")), "too large: 2000")

// ═══════════════════════════════════════════════════════════
//  13. Collecting Results
// ═══════════════════════════════════════════════════════════

println("")
println("--- 13. Collecting Results ---")

fn collect_results(inputs) {
    let mut values = []
    let mut errors = []
    for inp in inputs {
        let r = process(inp)
        if is_ok(r) {
            values = values.push(unwrap(r))
        } else {
            errors = errors.push(unwrap_err(r))
        }
    }
    return [values, errors]
}

let batch = ["10", "20", "", "50", "-1", "100"]
let collected = collect_results(batch)
let vals = collected[0]
let errs = collected[1]

check("collect values count", len(vals), 4)
check("collect errors count", len(errs), 2)
check("collect val[0]", vals[0], 21)
check("collect val[1]", vals[1], 41)
check("collect val[2]", vals[2], 101)
check("collect val[3]", vals[3], 201)

// ═══════════════════════════════════════════════════════════
//  14. Result in Loop with Recovery
// ═══════════════════════════════════════════════════════════

println("")
println("--- 14. Loop Recovery ---")

let mut total = 0
let mut err_count = 0
let items = [ok(10), err("skip"), ok(20), err("skip"), ok(30)]
for item in items {
    if is_ok(item) {
        total = total + unwrap(item)
    } else {
        err_count = err_count + 1
    }
}
check("loop total", total, 60)
check("loop errors", err_count, 2)

// ═══════════════════════════════════════════════════════════
//  15. Nested Result
// ═══════════════════════════════════════════════════════════

println("")
println("--- 15. Nested Result ---")

// Result containing another Result (flatten pattern)
let nested = ok(ok(42))
let inner = unwrap(nested)
check("nested unwrap outer", is_ok(inner), true)
check("nested unwrap inner", unwrap(inner), 42)

// Manual flatten
fn flatten(r) {
    return match r {
        Ok(inner) -> inner,
        Err(e) -> err(e)
    }
}

let flat = flatten(ok(ok(99)))
check("flatten ok(ok)", unwrap(flat), 99)

let flat2 = flatten(ok(err("deep")))
check("flatten ok(err)", unwrap_err(flat2), "deep")

let flat3 = flatten(err("top"))
check("flatten err", unwrap_err(flat3), "top")

// ═══════════════════════════════════════════════════════════
//  16. Result with Struct Values
// ═══════════════════════════════════════════════════════════

println("")
println("--- 16. Struct in Result ---")

struct User {
    name: string,
    age: int
}

fn create_user(name, age) {
    if name == "" { return err("empty name") }
    if age < 0 { return err("negative age") }
    if age > 150 { return err("unreasonable age") }
    return ok(User { name: name, age: age })
}

let u1 = create_user("Alice", 30)
check("user ok", is_ok(u1), true)
check("user name", unwrap(u1).name, "Alice")
check("user age", unwrap(u1).age, 30)

let u2 = create_user("", 25)
check("user empty name", unwrap_err(u2), "empty name")

let u3 = create_user("Bob", -5)
check("user neg age", unwrap_err(u3), "negative age")

// ═══════════════════════════════════════════════════════════
//  17. Practical: Safe Array Access
// ═══════════════════════════════════════════════════════════

println("")
println("--- 17. Safe Array Access ---")

fn safe_get(arr, idx) {
    if idx < 0 || idx >= len(arr) {
        return err("index out of bounds: " + to_string(idx))
    }
    return ok(arr[idx])
}

let data = [10, 20, 30, 40, 50]

check("safe_get 0", unwrap(safe_get(data, 0)), 10)
check("safe_get 4", unwrap(safe_get(data, 4)), 50)
check("safe_get -1", is_err(safe_get(data, -1)), true)
check("safe_get 5", is_err(safe_get(data, 5)), true)

// Chain safe access
let idx_result = and_then(safe_get(data, 2), |v| {
    if v > 25 { return ok(v) }
    return err("too small")
})
check("safe_get chain", unwrap(idx_result), 30)

// ═══════════════════════════════════════════════════════════
//  SUMMARY
// ═══════════════════════════════════════════════════════════

println("")
println("═══════════════════════════════════════════════════════")
let total_tests = pass_count + fail_count
println("  Results: " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL / " + to_string(total_tests) + " total")
if fail_count == 0 {
    println("  ALL RESULT TYPE TESTS PASSED!")
} else {
    println("  SOME TESTS FAILED")
}
println("═══════════════════════════════════════════════════════")
