// ═══════════════════════════════════════════════════════════
//  test_codegen_output.hexa — codegen_c2 출력 C 코드 정확성 검증
//
//  .hexa 소스를 파싱 → codegen_c2_full → 생성된 C 문자열에
//  특정 패턴이 포함되는지 확인. 49 assertions.
// ═══════════════════════════════════════════════════════════

let _hexa_root = if len(env_var("HEXA_LANG")) > 0 { env_var("HEXA_LANG") } else { "." }
let HEXA = _hexa_root + "/hexa"
let SELF_DIR = _hexa_root + "/self"
let TMP_DIR = "/tmp/hexa_codegen_output_test"

exec("mkdir -p " + TMP_DIR)

// ── Load pipeline source ─────────────────────────────────
let lexer_src = read_file(SELF_DIR + "/lexer.hexa")
let parser_src = read_file(SELF_DIR + "/parser.hexa")
let cg_src = read_file(SELF_DIR + "/codegen_c2.hexa")
let pipeline_src = lexer_src + "\n" + parser_src + "\n" + cg_src + "\n"

let mut pass_count = 0
let mut fail_count = 0

// Run a driver that outputs either PASS or FAIL lines
fn run_checks(name, driver_code) {
    let driver_file = TMP_DIR + "/" + name + ".hexa"
    let full = pipeline_src + "\n" + driver_code
    write_file(driver_file, full)
    let result = exec(HEXA + " " + driver_file + " 2>&1")
    return result
}

fn parse_results(output) {
    let lines = output.split("\n")
    let mut i = 0
    while i < len(lines) {
        let line = lines[i]
        if line.starts_with("[PASS]") {
            println(line)
            pass_count = pass_count + 1
        } else if line.starts_with("[FAIL]") {
            println(line)
            fail_count = fail_count + 1
        }
        i = i + 1
    }
}

println("=== codegen_c2 Output Verification (49 assertions) ===")
println("")

// ═══════════════════════════════════════════════════════════
//  All checks in a single driver for speed
// ═══════════════════════════════════════════════════════════

let driver = "
fn gen_c(src) {
    let tokens = tokenize(src)
    let ast = parse(tokens)
    return codegen_c2_full(ast)
}

fn ck(name, haystack, needle) {
    if haystack.contains(needle) {
        println(\"[PASS] \" + name)
    } else {
        println(\"[FAIL] \" + name + \" — missing: \" + needle)
    }
}

// ── 1. Basic structure ──
let c1 = gen_c(\"println(42)\")
ck(\"01 includes runtime.c\", c1, \"#include\")
ck(\"02 has int main()\", c1, \"int main()\")
ck(\"03 has return 0\", c1, \"return 0;\")
ck(\"04 println maps to hexa_println\", c1, \"hexa_println\")

// ── 2. Function declarations ──
let c2 = gen_c(\"fn add(a, b) { return a + b }\")
ck(\"05 fn HexaVal return type\", c2, \"HexaVal add(\")
ck(\"06 fn params are HexaVal\", c2, \"HexaVal a, HexaVal b\")
ck(\"07 fn forward decl\", c2, \"HexaVal add(HexaVal a, HexaVal b);\")
ck(\"08 fn body return hexa_add\", c2, \"return hexa_add(a, b);\")

let c2b = gen_c(\"fn greet() { println(42) }\")
ck(\"09 zero-param fn uses void\", c2b, \"HexaVal greet(void)\")

// ── 3. Struct → constructor ──
let c3 = gen_c(\"struct Point { x: int, y: int }\")
ck(\"10 struct → C function\", c3, \"HexaVal Point(\")
ck(\"11 struct field params\", c3, \"HexaVal x, HexaVal y\")
ck(\"12 struct body creates map\", c3, \"hexa_map_new()\")
ck(\"13 struct __type__ tag\", c3, \"__type__\")
ck(\"14 struct sets field x\", c3, \"hexa_map_set(__s,\")
ck(\"15 struct return __s\", c3, \"return __s;\")

// ── 4. Impl → mangled method ──
let c4_src = \"struct Vec2 { x: int, y: int }\" + \"\\n\" + \"impl Vec2 {\" + \"\\n\" + \"    fn magnitude(self) {\" + \"\\n\" + \"        return self.x\" + \"\\n\" + \"    }\" + \"\\n\" + \"}\"
let c4 = gen_c(c4_src)
ck(\"16 impl Type__method\", c4, \"Vec2__magnitude\")
ck(\"17 impl forward decl\", c4, \"HexaVal Vec2__magnitude(\")
ck(\"18 impl self param\", c4, \"HexaVal self\")

// ── 5. Enum → #define ──
let c5 = gen_c(\"enum Color { Red, Green, Blue }\")
ck(\"19 enum Red=0\", c5, \"#define Color_Red hexa_int(0)\")
ck(\"20 enum Green=1\", c5, \"#define Color_Green hexa_int(1)\")
ck(\"21 enum Blue=2\", c5, \"#define Color_Blue hexa_int(2)\")
ck(\"22 enum comment\", c5, \"// enum Color\")

// ── 6. Let/LetMut ──
let c6 = gen_c(\"fn foo() { let x = 42 }\")
ck(\"23 let HexaVal decl\", c6, \"HexaVal x = hexa_int(42)\")

let c6b = gen_c(\"fn foo() { let mut y = 99 }\")
ck(\"24 let mut HexaVal\", c6b, \"HexaVal y = hexa_int(99)\")

// ── 7. Arithmetic ──
let c7 = gen_c(\"fn foo() { let a = 10 - 3 }\")
ck(\"25 subtraction .i -\", c7, \".i - (\")

let c7b = gen_c(\"fn foo() { let b = 4 * 5 }\")
ck(\"26 multiplication .i *\", c7b, \".i * (\")

let c7c = gen_c(\"fn foo() { let c = 10 / 2 }\")
ck(\"27 division .i /\", c7c, \".i / (\")

let c7d = gen_c(\"fn foo() { let d = 7 % 3 }\")
ck(\"28 modulo .i %\", c7d, \".i % (\")

let c7e = gen_c(\"fn foo() { let t = true }\")
ck(\"29 bool true\", c7e, \"hexa_bool(1)\")

let c7f = gen_c(\"fn foo() { let f = false }\")
ck(\"30 bool false\", c7f, \"hexa_bool(0)\")

// ── 8. Control flow ──
let c8 = gen_c(\"fn foo() { let mut i = 0\" + \"\\n\" + \"while i < 10 {\" + \"\\n\" + \"i = i + 1\" + \"\\n\" + \"} }\")
ck(\"31 while hexa_truthy\", c8, \"while (hexa_truthy(\")

let c8b = gen_c(\"fn foo() { for i in 0..10 {\" + \"\\n\" + \"println(i)\" + \"\\n\" + \"} }\")
ck(\"32 for-range C for\", c8b, \"for (HexaVal i =\")
ck(\"33 for-range bound\", c8b, \".i < (\")

// ── 9. Array ──
let c9 = gen_c(\"fn foo() { let arr = [1, 2, 3] }\")
ck(\"34 array new\", c9, \"hexa_array_new()\")
ck(\"35 array push\", c9, \"hexa_array_push(\")

// ── 10. Method calls ──
let c10 = gen_c(\"fn foo() { let s = to_string(42) }\")
ck(\"36 to_string builtin\", c10, \"hexa_to_string(\")

let c10b = gen_c(\"fn foo() { let n = len(42) }\")
ck(\"37 len builtin\", c10b, \"hexa_int(hexa_len(\")

// ── 11. String literal ──
let c11 = gen_c(\"fn foo() { let s = 42 }\")
ck(\"38 int literal\", c11, \"hexa_int(42)\")

// ── 12. Return ──
let c12 = gen_c(\"fn foo() { return 99 }\")
ck(\"39 return hexa_int\", c12, \"return hexa_int(99)\")
ck(\"40 default return void\", c12, \"return hexa_void();\")

// ── 13. Builtins ──
let c13 = gen_c(\"fn foo() { let t = type_of(1) }\")
ck(\"41 type_of builtin\", c13, \"hexa_type_of(\")

let c13b = gen_c(\"fn foo() { let r = sqrt(4.0) }\")
ck(\"42 sqrt builtin\", c13b, \"hexa_sqrt(\")

let c13c = gen_c(\"fn foo() { let r = abs(3) }\")
ck(\"43 abs builtin\", c13c, \"hexa_abs(\")

// ── 14. Comparisons ──
let c14 = gen_c(\"fn foo() { let a = 1 == 2 }\")
ck(\"44 eq hexa_eq\", c14, \"hexa_eq(\")

let c14b = gen_c(\"fn foo() { let b = 3 != 4 }\")
ck(\"45 neq negated hexa_eq\", c14b, \"!hexa_truthy(hexa_eq(\")

let c14c = gen_c(\"fn foo() { let c = 5 < 6 }\")
ck(\"46 lt .i <\", c14c, \".i < (\")

// ── 15. Field access ──
let c15 = gen_c(\"struct Pt { x: int }\" + \"\\n\" + \"fn foo() { let p = Pt { x: 10 }\" + \"\\n\" + \"let v = p.x }\")
ck(\"47 field hexa_map_get\", c15, \"hexa_map_get(p,\")

// ── 16. Float literal ──
let c16 = gen_c(\"fn foo() { let pi = 3.14 }\")
ck(\"48 float hexa_float\", c16, \"hexa_float(3.14)\")

// ── 17. Addition ──
let c17 = gen_c(\"fn foo() { let z = 1 + 2 }\")
ck(\"49 add hexa_add\", c17, \"hexa_add(hexa_int(1), hexa_int(2))\")

println(\"DONE\")
"

let result = run_checks("all", driver)
parse_results(result)

// ═══════════════════════════════════════════════════════════
//  Summary
// ═══════════════════════════════════════════════════════════
println("")
println("════════════════════════════════════════")
println("Total: " + to_string(pass_count + fail_count) + "  PASS: " + to_string(pass_count) + "  FAIL: " + to_string(fail_count))
if fail_count == 0 {
    println("ALL PASS")
} else {
    println("SOME TESTS FAILED")
}
println("════════════════════════════════════════")
println(to_string(pass_count) + " passed")
