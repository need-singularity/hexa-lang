// ═══════════════════════════════════════════════════════════
//  test_pre_registration.hexa — FIX-9-1 regression test
//  Top-level FnDecl / AsyncFnDecl / PureFnDecl must be
//  env_define'd BEFORE the main exec loop, so that forward
//  references, mutual recursion, and @attr pre-registration
//  all work regardless of declaration order.
//
//  Cases:
//    A. Forward reference: top-level let uses fn declared later
//    B. Mutual recursion: is_even / is_odd cross-reference
//    C. @memo pre-reg: fib memoized, called before its decl
//    D. Scale test: 50 sequential forward-chained fns
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA FIX-9-1 Pre-Registration Regression Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── Case A: Forward reference ─────────────────────────────
// `later()` is called at top level BEFORE its fn declaration.
// Without FIX-9-1 pre-reg, env_lookup("later") fails here.

println("--- Case A: Forward Reference ---")

let a_val = later()
check("A: forward let x = later()", a_val, 42)

fn later() {
    return 42
}

// Sanity: later() after declaration still works.
check("A: later() post-decl", later(), 42)

// ── Case B: Mutual Recursion ──────────────────────────────
// is_even calls is_odd which is declared after it.
// Call site is BEFORE both declarations.

println("")
println("--- Case B: Mutual Recursion ---")

let b_even10 = is_even_preg(10)
let b_odd7 = is_odd_preg(7)
let b_even7 = is_even_preg(7)
let b_odd10 = is_odd_preg(10)

check("B: is_even_preg(10)", b_even10, true)
check("B: is_odd_preg(7)",  b_odd7,  true)
check("B: is_even_preg(7)",  b_even7,  false)
check("B: is_odd_preg(10)",  b_odd10,  false)

fn is_even_preg(n) {
    if n == 0 { return true }
    return is_odd_preg(n - 1)
}

fn is_odd_preg(n) {
    if n == 0 { return false }
    return is_even_preg(n - 1)
}

// ── Case C: @memo pre-registration ────────────────────────
// fib_preg is @memo and called BEFORE declaration; this
// verifies fn_attrs_set runs in the pre-reg pass so memo
// interception activates on first call.

println("")
println("--- Case C: @memo Pre-Reg ---")

let c_y = fib_preg(10)
check("C: fib_preg(10) before decl", c_y, 55)

@memo
fn fib_preg(n) {
    if n < 2 { return n }
    return fib_preg(n - 1) + fib_preg(n - 2)
}

// Post-decl call should hit memo cache (same result).
check("C: fib_preg(10) post-decl", fib_preg(10), 55)
check("C: fib_preg(15)", fib_preg(15), 610)

// ── Case D: 50-fn forward chain ───────────────────────────
// f_0 -> f_1 -> ... -> f_49 -> f_50 (base returns 50)
// All defined AFTER the call site. Each fn forward-refs
// the next, so pre-reg must register every single FnDecl
// up-front.

println("")
println("--- Case D: 50-fn Forward Chain ---")

let d_val = f_0()
check("D: f_0() chain to f_50", d_val, 50)

fn f_0()  { return f_1() }
fn f_1()  { return f_2() }
fn f_2()  { return f_3() }
fn f_3()  { return f_4() }
fn f_4()  { return f_5() }
fn f_5()  { return f_6() }
fn f_6()  { return f_7() }
fn f_7()  { return f_8() }
fn f_8()  { return f_9() }
fn f_9()  { return f_10() }
fn f_10() { return f_11() }
fn f_11() { return f_12() }
fn f_12() { return f_13() }
fn f_13() { return f_14() }
fn f_14() { return f_15() }
fn f_15() { return f_16() }
fn f_16() { return f_17() }
fn f_17() { return f_18() }
fn f_18() { return f_19() }
fn f_19() { return f_20() }
fn f_20() { return f_21() }
fn f_21() { return f_22() }
fn f_22() { return f_23() }
fn f_23() { return f_24() }
fn f_24() { return f_25() }
fn f_25() { return f_26() }
fn f_26() { return f_27() }
fn f_27() { return f_28() }
fn f_28() { return f_29() }
fn f_29() { return f_30() }
fn f_30() { return f_31() }
fn f_31() { return f_32() }
fn f_32() { return f_33() }
fn f_33() { return f_34() }
fn f_34() { return f_35() }
fn f_35() { return f_36() }
fn f_36() { return f_37() }
fn f_37() { return f_38() }
fn f_38() { return f_39() }
fn f_39() { return f_40() }
fn f_40() { return f_41() }
fn f_41() { return f_42() }
fn f_42() { return f_43() }
fn f_43() { return f_44() }
fn f_44() { return f_45() }
fn f_45() { return f_46() }
fn f_46() { return f_47() }
fn f_47() { return f_48() }
fn f_48() { return f_49() }
fn f_49() { return f_50() }
fn f_50() { return 50 }

// ═══════════════════════════════════════════════════════════
//  SUMMARY
// ═══════════════════════════════════════════════════════════

println("")
println("═══════════════════════════════════════════════════════")
let total = pass_count + fail_count
println("  Results: " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL / " + to_string(total) + " total")
if fail_count == 0 {
    println("  ALL FIX-9-1 PRE-REGISTRATION TESTS PASSED!")
} else {
    println("  SOME TESTS FAILED — FIX-9-1 regression?")
}
println("═══════════════════════════════════════════════════════")
