// ω-runtime-1 Phase A — persistent-pipe primitive selftest (2026-04-26).
//
// Exercises the five new builtins defined in self/native/persistent_pipe.c
// via the hexa_full.hexa interpreter dispatch arms. Run with:
//
//   ~/core/hexa-lang/hexa self/persistent_pipe_selftest.hexa
//
// Exit 0 iff all 7 tests PASS. Print one line per test.

let mut _pp_pass = 0
let mut _pp_fail = 0

fn _pp_check(name, ok) {
    if ok {
        _pp_pass = _pp_pass + 1
        println("[PASS] " + name)
    } else {
        _pp_fail = _pp_fail + 1
        println("[FAIL] " + name)
    }
}

// ── T1: spawn cat → send_line "hello" → recv_line == "hello" → close → alive == false ──
fn t1_basic_roundtrip() {
    let h = pipe_spawn("cat")
    if h < 0 {
        _pp_check("T1_basic_roundtrip", false)
        return
    }
    let sent = pipe_send_line(h, "hello")
    let line = pipe_recv_line(h, 1000)
    let closed = pipe_close(h)
    let still_alive = pipe_alive(h)
    let ok = sent && line == "hello" && closed && !still_alive
    if !ok {
        println("  T1 detail: sent=" + str(sent) + " line='" + line + "' closed=" + str(closed) + " alive=" + str(still_alive))
    }
    _pp_check("T1_basic_roundtrip", ok)
}

// ── T2: spawn nonexistent_cmd → spawn returns -1 ──
fn t2_spawn_error() {
    let h = pipe_spawn("__hexa_definitely_not_a_real_command_2026__")
    let ok = h < 0
    if !ok {
        println("  T2 detail: h=" + str(h))
        // cleanup if non-error
        pipe_close(h)
    }
    _pp_check("T2_spawn_error", ok)
}

// ── T3: spawn `sleep 0.1; echo done` → recv_line(timeout=500) == "done" ──
fn t3_async_response() {
    let h = pipe_spawn("sleep 0.1; echo done")
    if h < 0 {
        _pp_check("T3_async_response", false)
        return
    }
    let line = pipe_recv_line(h, 1000)
    pipe_close(h)
    let ok = line == "done"
    if !ok {
        println("  T3 detail: line='" + line + "'")
    }
    _pp_check("T3_async_response", ok)
}

// ── T4: spawn cat → close → recv_line returns empty (closed handle) ──
fn t4_close_then_recv() {
    let h = pipe_spawn("cat")
    if h < 0 {
        _pp_check("T4_close_then_recv", false)
        return
    }
    pipe_close(h)
    let line = pipe_recv_line(h, 100)
    let ok = line == ""
    if !ok {
        println("  T4 detail: line='" + line + "'")
    }
    _pp_check("T4_close_then_recv", ok)
}

// ── T5: parallel handles — spawn cat × 3, send/recv to each, verify isolation ──
fn t5_parallel_handles() {
    let h1 = pipe_spawn("cat")
    let h2 = pipe_spawn("cat")
    let h3 = pipe_spawn("cat")
    if h1 < 0 || h2 < 0 || h3 < 0 {
        if h1 >= 0 { pipe_close(h1) }
        if h2 >= 0 { pipe_close(h2) }
        if h3 >= 0 { pipe_close(h3) }
        _pp_check("T5_parallel_handles", false)
        return
    }
    pipe_send_line(h1, "alpha")
    pipe_send_line(h2, "beta")
    pipe_send_line(h3, "gamma")
    let r1 = pipe_recv_line(h1, 1000)
    let r2 = pipe_recv_line(h2, 1000)
    let r3 = pipe_recv_line(h3, 1000)
    pipe_close(h1)
    pipe_close(h2)
    pipe_close(h3)
    let ok = r1 == "alpha" && r2 == "beta" && r3 == "gamma" && h1 != h2 && h2 != h3 && h1 != h3
    if !ok {
        println("  T5 detail: h1=" + str(h1) + " r1='" + r1 + "' h2=" + str(h2) + " r2='" + r2 + "' h3=" + str(h3) + " r3='" + r3 + "'")
    }
    _pp_check("T5_parallel_handles", ok)
}

// ── T6: timeout — spawn cat → recv_line(timeout=100) without send → returns empty ──
//        within ~200ms (not blocked indefinitely)
fn t6_timeout() {
    let h = pipe_spawn("cat")
    if h < 0 {
        _pp_check("T6_timeout", false)
        return
    }
    let t0 = now_ms()
    let line = pipe_recv_line(h, 100)
    let t1 = now_ms()
    let elapsed = t1 - t0
    pipe_close(h)
    let ok = line == "" && elapsed < 500
    if !ok {
        println("  T6 detail: line='" + line + "' elapsed=" + str(elapsed) + "ms")
    }
    _pp_check("T6_timeout", ok)
}

// ── T7: alive after child exits — spawn `echo hi` → recv → after exit, alive==false ──
fn t7_alive_after_exit() {
    let h = pipe_spawn("echo hi")
    if h < 0 {
        _pp_check("T7_alive_after_exit", false)
        return
    }
    let line = pipe_recv_line(h, 1000)
    // Give child a moment to fully exit
    let mut tries = 0
    let mut still = true
    while tries < 20 && still {
        if !pipe_alive(h) {
            still = false
        } else {
            // tiny sleep — use exec("sleep 0.01")? we have sleep_s as builtin.
            sleep_ms(10)
            tries = tries + 1
        }
    }
    pipe_close(h)
    let ok = line == "hi" && !still
    if !ok {
        println("  T7 detail: line='" + line + "' still_alive=" + str(still) + " tries=" + str(tries))
    }
    _pp_check("T7_alive_after_exit", ok)
}

// ── helpers ───────────────────────────────────────────────────
fn now_ms() {
    // Use python3 for portable ms timestamp (macOS `date` lacks %N).
    let s = exec("python3 -c 'import time;print(int(time.time()*1000))'").trim()
    return to_int(s)
}

fn sleep_ms(ms) {
    let secs = ms / 1000
    let frac = ms - secs * 1000
    let secs_str = str(secs)
    let frac_str = if frac < 10 { "00" + str(frac) } else if frac < 100 { "0" + str(frac) } else { str(frac) }
    exec("sleep " + secs_str + "." + frac_str)
}

// ── runner ────────────────────────────────────────────────────
println("─── ω-runtime-1 Phase A persistent-pipe selftest ───")
t1_basic_roundtrip()
t2_spawn_error()
t3_async_response()
t4_close_then_recv()
t5_parallel_handles()
t6_timeout()
t7_alive_after_exit()
println("─── result: " + str(_pp_pass) + " PASS / " + str(_pp_fail) + " FAIL ───")
if _pp_fail > 0 {
    exit(1)
}
exit(0)
