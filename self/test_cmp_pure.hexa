// self/test_cmp_pure.hexa -- Tests for self/runtime/cmp_pure.hexa
//
// Reference behavior: byte-wise lex compare, matching strcmp/memcmp.

// ── inlined from self/runtime/cmp_pure.hexa ───────────────────────

fn str_cmp_pure(a, b) {
    let aa = if type_of(a) == "string" { a } else { "" }
    let bb = if type_of(b) == "string" { b } else { "" }
    let na = len(aa)
    let nb = len(bb)
    let lim = if na < nb { na } else { nb }
    let mut i = 0
    while i < lim {
        let ca = ord(aa.substring(i, i + 1))
        let cb = ord(bb.substring(i, i + 1))
        if ca < cb { return 0 - 1 }
        if ca > cb { return 1 }
        i = i + 1
    }
    if na < nb { return 0 - 1 }
    if na > nb { return 1 }
    0
}

fn str_eq_pure(a, b) { str_cmp_pure(a, b) == 0 }
fn str_lt_pure(a, b) { str_cmp_pure(a, b) < 0 }
fn str_gt_pure(a, b) { str_cmp_pure(a, b) > 0 }
fn str_le_pure(a, b) { str_cmp_pure(a, b) <= 0 }
fn str_ge_pure(a, b) { str_cmp_pure(a, b) >= 0 }

fn cmp_int_pure(a, b) {
    let ta = type_of(a)
    let tb = type_of(b)
    let aa = if ta == "int" || ta == "float" { a } else { 0 }
    let bb = if tb == "int" || tb == "float" { b } else { 0 }
    if aa < bb { return 0 - 1 }
    if aa > bb { return 1 }
    0
}

fn min_str_pure(a, b) {
    if str_cmp_pure(a, b) <= 0 { return a }
    b
}

fn max_str_pure(a, b) {
    if str_cmp_pure(a, b) >= 0 { return a }
    b
}

// ── end inlined ───────────────────────────────────────────────────

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  cmp_pure.hexa — test runner")
println("═══════════════════════════════════════════════════════")

// ── str_cmp_pure — equal pairs ──────────────────────────────────
println("")
println("--- str_cmp_pure (equal) ---")
check("'' == ''",      str_cmp_pure("", ""),       0)
check("'a' == 'a'",    str_cmp_pure("a", "a"),     0)
check("'abc' == 'abc'", str_cmp_pure("abc", "abc"), 0)
check("'hello' == 'hello'", str_cmp_pure("hello", "hello"), 0)

// ── str_cmp_pure — ordering ─────────────────────────────────────
println("")
println("--- str_cmp_pure (ordering) ---")
check("'a' < 'b'",     str_cmp_pure("a", "b"),     0 - 1)
check("'b' > 'a'",     str_cmp_pure("b", "a"),     1)
check("'A' < 'a'",     str_cmp_pure("A", "a"),     0 - 1)  // 65 < 97
check("'abc' < 'abd'", str_cmp_pure("abc", "abd"), 0 - 1)
check("'abd' > 'abc'", str_cmp_pure("abd", "abc"), 1)

// ── str_cmp_pure — prefix / length ──────────────────────────────
println("")
println("--- str_cmp_pure (prefix/length) ---")
check("'ab' < 'abc'",  str_cmp_pure("ab", "abc"),  0 - 1)  // shorter wins
check("'abc' > 'ab'",  str_cmp_pure("abc", "ab"),  1)
check("'' < 'a'",      str_cmp_pure("", "a"),      0 - 1)
check("'a' > ''",      str_cmp_pure("a", ""),      1)

// ── str_cmp_pure — non-string coercion ──────────────────────────
println("")
println("--- str_cmp_pure (non-string) ---")
check("42 vs 'a' (=='' vs 'a')", str_cmp_pure(42, "a"),  0 - 1)
check("'a' vs 42 (=='a' vs '')", str_cmp_pure("a", 42),  1)
check("42 vs nil (both='')",     str_cmp_pure(42, nil),  0)

// ── boolean wrappers ────────────────────────────────────────────
println("")
println("--- boolean wrappers ---")
check("eq true",  str_eq_pure("x", "x"), true)
check("eq false", str_eq_pure("x", "y"), false)
check("lt true",  str_lt_pure("a", "b"), true)
check("lt false", str_lt_pure("b", "a"), false)
check("lt eq=false", str_lt_pure("a", "a"), false)
check("gt true",  str_gt_pure("b", "a"), true)
check("gt eq=false", str_gt_pure("a", "a"), false)
check("le eq=true", str_le_pure("a", "a"), true)
check("le strict",  str_le_pure("a", "b"), true)
check("ge eq=true", str_ge_pure("a", "a"), true)
check("ge strict",  str_ge_pure("b", "a"), true)

// ── cmp_int_pure ────────────────────────────────────────────────
println("")
println("--- cmp_int_pure ---")
check("0 == 0",       cmp_int_pure(0, 0),       0)
check("1 < 2",        cmp_int_pure(1, 2),       0 - 1)
check("5 > 3",        cmp_int_pure(5, 3),       1)
check("-1 < 0",       cmp_int_pure(0 - 1, 0),   0 - 1)
check("0 > -1",       cmp_int_pure(0, 0 - 1),   1)
check("3.14 > 3.0",   cmp_int_pure(3.14, 3.0),  1)
check("'x' coerce 0", cmp_int_pure("x", 1),     0 - 1)

// ── min_str_pure / max_str_pure ─────────────────────────────────
println("")
println("--- min_str_pure / max_str_pure ---")
check("min('a','b')",      min_str_pure("a", "b"),  "a")
check("min('b','a')",      min_str_pure("b", "a"),  "a")
check("min eq returns 1st", min_str_pure("x", "x"), "x")
check("max('a','b')",      max_str_pure("a", "b"),  "b")
check("max('b','a')",      max_str_pure("b", "a"),  "b")
check("max eq returns 1st", max_str_pure("x", "x"), "x")
check("min lex 'apple'/'banana'", min_str_pure("apple", "banana"), "apple")
check("max lex 'apple'/'banana'", max_str_pure("apple", "banana"), "banana")

// ── trichotomy / antisymmetry sanity ────────────────────────────
println("")
println("--- trichotomy / antisymmetry ---")
check("a<b iff b>a",          str_lt_pure("a", "b") == str_gt_pure("b", "a"), true)
check("a==b iff !(a<b||a>b)", (str_lt_pure("x", "x") || str_gt_pure("x", "x")) == false, true)
check("cmp negates on swap",  str_cmp_pure("abc", "abd") == 0 - str_cmp_pure("abd", "abc"), true)

// ── Summary ─────────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    println("FAIL")
    exit(1)
}
println("ALL PASS")
