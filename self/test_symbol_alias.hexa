// test_symbol_alias.hexa — G1: @symbol("name") attribute for extern fn
// Tests that @symbol("c_name") maps a hexa function name to a different C symbol.
//
// Usage: hexa ready/self/test_symbol_alias.hexa
// (Requires the self-hosting lexer/parser/interpreter to be loaded)

println("=== G1: @symbol Alias Tests ===")

// ── Lexer tests ─────────────────────────────────────────────

println("L1: @ tokenizes to Attribute")
let toks1 = tokenize("@symbol")
assert toks1[0].kind == "Attribute"
assert toks1[0].value == "symbol"
println("  PASS")

println("L2: @link tokenizes to Attribute")
let toks2 = tokenize("@link")
assert toks2[0].kind == "Attribute"
assert toks2[0].value == "link"
println("  PASS")

// ── Parser tests ────────────────────────────────────────────

println("P1: extern fn without @symbol — value is empty")
let ast1 = parse(tokenize("extern fn getpid() -> Int"))
assert ast1[0].kind == "ExternFnDecl"
assert ast1[0].name == "getpid"
assert ast1[0].value == ""
println("  PASS")

println("P2: @symbol(\"objc_msgSend\") extern fn objc_send3")
let ast2 = parse(tokenize("@symbol(\"objc_msgSend\")\nextern fn objc_send3(obj, sel, a1) -> Int"))
assert ast2[0].kind == "ExternFnDecl"
assert ast2[0].name == "objc_send3"
assert ast2[0].value == "objc_msgSend"
assert len(ast2[0].params) == 3
println("  PASS")

println("P3: multiple @symbol aliases to same C symbol")
let ast3 = parse(tokenize("@symbol(\"objc_msgSend\")\nextern fn send2(a, b) -> Int\n@symbol(\"objc_msgSend\")\nextern fn send5(a, b, c, d, e) -> Int"))
assert len(ast3) == 2
assert ast3[0].name == "send2"
assert ast3[0].value == "objc_msgSend"
assert ast3[1].name == "send5"
assert ast3[1].value == "objc_msgSend"
assert len(ast3[0].params) == 2
assert len(ast3[1].params) == 5
println("  PASS")

println("P4: @link + @symbol combined")
let ast4 = parse(tokenize("@link(\"libobjc\")\n@symbol(\"objc_msgSend\")\nextern fn send3(a, b, c) -> Int"))
assert ast4[0].kind == "ExternFnDecl"
assert ast4[0].name == "send3"
assert ast4[0].value == "objc_msgSend"
assert ast4[0].op == "libobjc"
println("  PASS")

println("P5: @symbol does not leak to next extern fn")
let ast5 = parse(tokenize("@symbol(\"objc_msgSend\")\nextern fn send2(a, b) -> Int\nextern fn getpid() -> Int"))
assert ast5[0].value == "objc_msgSend"
assert ast5[1].value == ""
assert ast5[1].name == "getpid"
println("  PASS")

// ── Interpreter tests ───────────────────────────────────────

println("I1: ExternFnDecl registers in extern_fns store")
let ast6 = parse(tokenize("@symbol(\"objc_msgSend\")\nextern fn objc_send3(obj, sel, a1) -> Int"))
// Reset interpreter state
extern_fns = []
// Manually call exec_stmt to register
exec_stmt(ast6[0])
assert len(extern_fns) == 1
assert extern_fns[0][0] == "objc_send3"
assert extern_fns[0][1] == "objc_msgSend"
println("  PASS")

println("I2: extern_c_symbol returns alias when set")
assert extern_c_symbol("objc_send3") == "objc_msgSend"
println("  PASS")

println("I3: extern_c_symbol returns name when no alias")
extern_fns = extern_fns.push(["getpid", "getpid", "Int", ""])
assert extern_c_symbol("getpid") == "getpid"
println("  PASS")

println("I4: extern_c_symbol returns name for unregistered function")
assert extern_c_symbol("unknown_fn") == "unknown_fn"
println("  PASS")

println("")
println("=== G1: ALL @symbol ALIAS TESTS PASSED ===")
