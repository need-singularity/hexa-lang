// test_symbol_alias.hexa — G1: @symbol("name") attribute lexer tests
// Tests that @symbol / @link / @attr tokenize correctly via self-hosted lexer.
//
// NOTE: Parser/Interpreter tests blocked by p_tokens scope leak on import.
import "lexer.hexa"

println("=== G1: @symbol Alias Tests ===")

let mut passed = 0
let mut total = 0

// Self-hosted lexer tokenizes @ as At + Ident (not Attribute)

total = total + 1
println("L1: @symbol -> At + Ident(symbol)")
let toks1 = tokenize("@symbol")
assert toks1[0].kind == "At"
assert toks1[1].kind == "Ident"
assert toks1[1].value == "symbol"
println("  PASS")
passed = passed + 1

total = total + 1
println("L2: @link -> At + Ident(link)")
let toks2 = tokenize("@link")
assert toks2[0].kind == "At"
assert toks2[1].kind == "Ident"
assert toks2[1].value == "link"
println("  PASS")
passed = passed + 1

total = total + 1
println("L3: @symbol(\"name\") full sequence")
let toks3 = tokenize("@symbol(\"objc_msgSend\")")
assert toks3[0].kind == "At"
assert toks3[1].kind == "Ident"
assert toks3[1].value == "symbol"
assert toks3[2].kind == "LParen"
assert toks3[3].kind == "StringLit"
assert toks3[3].value == "objc_msgSend"
assert toks3[4].kind == "RParen"
println("  PASS")
passed = passed + 1

total = total + 1
println("L4: @memoize -> At + Ident(memoize)")
let toks4 = tokenize("@memoize")
assert toks4[0].kind == "At"
assert toks4[1].value == "memoize"
println("  PASS")
passed = passed + 1

total = total + 1
println("L5: @fuse -> At + Ident(fuse)")
let toks5 = tokenize("@fuse")
assert toks5[0].kind == "At"
assert toks5[1].value == "fuse"
println("  PASS")
passed = passed + 1

total = total + 1
println("L6: @pure -> At + Ident(pure)")
let toks6 = tokenize("@pure")
assert toks6[0].kind == "At"
assert toks6[1].value == "pure"
println("  PASS")
passed = passed + 1

total = total + 1
println("L7: multiple attrs in sequence")
let toks7 = tokenize("@link(\"libm\")\n@symbol(\"cos\")\nextern fn my_cos(x) -> Float")
// Count At tokens
let mut at_count = 0
for t in toks7 {
    if t.kind == "At" { at_count = at_count + 1 }
}
assert at_count == 2
println("  PASS")
passed = passed + 1

println("")
println("=== G1: " + to_string(passed) + "/" + to_string(total) + " @symbol ALIAS TESTS PASSED ===")
println(to_string(passed) + " passed")
