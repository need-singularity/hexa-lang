// ===================================================================
//  test_dijkstra_pure.hexa -- coverage for self/runtime/dijkstra_pure.hexa
//
//  20+ tests: single node, two nodes, triangle, diamond, disconnected,
//  zero-weight edges, path reconstruction, linear chain, self-loop,
//  heap helpers, large fan-out, bidirectional, etc.
//
//  Pitfalls honored: P1 no semicolons, P15 let mut, P29 push rebind,
//  while loops only
// ===================================================================

import "runtime/dijkstra_pure.hexa"

let mut pass = 0
let mut fail = 0

fn check(name, cond) {
    if cond {
        pass = pass + 1
    } else {
        fail = fail + 1
        println("[FAIL] " + name)
    }
}

fn eq(name, actual, expected) {
    if actual == expected {
        pass = pass + 1
    } else {
        fail = fail + 1
        println("[FAIL] " + name + " expected=" + to_string(expected) + " got=" + to_string(actual))
    }
}

fn eq_arr(name, actual, expected) {
    let n = len(actual)
    if n != len(expected) {
        fail = fail + 1
        println("[FAIL] " + name + " len expected=" + to_string(len(expected)) + " got=" + to_string(n))
        return void
    }
    let mut i = 0
    let mut ok = true
    while i < n {
        if actual[i] != expected[i] { ok = false }
        i = i + 1
    }
    if ok {
        pass = pass + 1
    } else {
        fail = fail + 1
        println("[FAIL] " + name + " actual=" + to_string(actual) + " expected=" + to_string(expected))
    }
}

println("=== dijkstra_pure test suite ===")

let inf = 999999999

// ── 1: Single node, no edges ────────────────────────────────────
let d1 = dijkstra_pure(1, [], 0)
eq("single node dist[0]", d1[0], 0)

// ── 2: Single node path to self ─────────────────────────────────
let p2 = dijkstra_path_pure(1, [], 0, 0)
eq_arr("single node path 0->0", p2, [0])

// ── 3: Two nodes, one edge ──────────────────────────────────────
let d3 = dijkstra_pure(2, [[0, 1, 7]], 0)
eq("two nodes dist[0]", d3[0], 0)
eq("two nodes dist[1]", d3[1], 7)

// ── 4: Two nodes path ───────────────────────────────────────────
let p4 = dijkstra_path_pure(2, [[0, 1, 7]], 0, 1)
eq_arr("two nodes path 0->1", p4, [0, 1])

// ── 5: Two nodes, no edge from 0 to 1 (disconnected) ───────────
let d5 = dijkstra_pure(2, [], 0)
eq("two disconnected dist[1]", d5[1], inf)

// ── 6: Disconnected path returns empty ──────────────────────────
let p6 = dijkstra_path_pure(2, [], 0, 1)
eq_arr("two disconnected path", p6, [])

// ── 7: Triangle — shorter via intermediate ──────────────────────
// 0->1:1, 1->2:2, 0->2:10  => 0->2 shortest = 3 via 1
let tri_edges = [[0, 1, 1], [1, 2, 2], [0, 2, 10]]
let d7 = dijkstra_pure(3, tri_edges, 0)
eq("triangle dist[0]", d7[0], 0)
eq("triangle dist[1]", d7[1], 1)
eq("triangle dist[2]", d7[2], 3)

// ── 8: Triangle path reconstruction ─────────────────────────────
let p8 = dijkstra_path_pure(3, tri_edges, 0, 2)
eq_arr("triangle path 0->2", p8, [0, 1, 2])

// ── 9: Triangle direct path ─────────────────────────────────────
let p9 = dijkstra_path_pure(3, tri_edges, 0, 1)
eq_arr("triangle path 0->1", p9, [0, 1])

// ── 10: Diamond graph ───────────────────────────────────────────
// 0->1:1, 0->2:2, 1->3:1, 2->3:1  => 0->3 = 2 via 1
let dia_edges = [[0, 1, 1], [0, 2, 2], [1, 3, 1], [2, 3, 1]]
let d10 = dijkstra_pure(4, dia_edges, 0)
eq("diamond dist[3]", d10[3], 2)

// ── 11: Diamond path ────────────────────────────────────────────
let p11 = dijkstra_path_pure(4, dia_edges, 0, 3)
eq_arr("diamond path 0->3", p11, [0, 1, 3])

// ── 12: Linear chain ────────────────────────────────────────────
// 0->1->2->3->4, each weight 3
let chain_edges = [[0, 1, 3], [1, 2, 3], [2, 3, 3], [3, 4, 3]]
let d12 = dijkstra_pure(5, chain_edges, 0)
eq("chain dist[4]", d12[4], 12)

// ── 13: Chain path ──────────────────────────────────────────────
let p13 = dijkstra_path_pure(5, chain_edges, 0, 4)
eq_arr("chain path 0->4", p13, [0, 1, 2, 3, 4])

// ── 14: Source == destination ────────────────────────────────────
let p14 = dijkstra_path_pure(3, tri_edges, 1, 1)
eq_arr("self path 1->1", p14, [1])

// ── 15: Zero-weight edges ───────────────────────────────────────
let zw_edges = [[0, 1, 0], [1, 2, 0], [0, 2, 5]]
let d15 = dijkstra_pure(3, zw_edges, 0)
eq("zero-weight dist[2]", d15[2], 0)

// ── 16: Zero-weight path ────────────────────────────────────────
let p16 = dijkstra_path_pure(3, zw_edges, 0, 2)
eq_arr("zero-weight path 0->2", p16, [0, 1, 2])

// ── 17: Disconnected node in larger graph ───────────────────────
// 0->1:5, node 2 isolated
let d17 = dijkstra_pure(3, [[0, 1, 5]], 0)
eq("disconnected node dist[2]", d17[2], inf)

// ── 18: Disconnected path returns empty ─────────────────────────
let p18 = dijkstra_path_pure(3, [[0, 1, 5]], 0, 2)
eq_arr("disconnected node path", p18, [])

// ── 19: Heap push/pop basic ─────────────────────────────────────
let mut h = []
h = heap_push_pure(h, [10, 0])
h = heap_push_pure(h, [3, 1])
h = heap_push_pure(h, [7, 2])
let r19 = heap_pop_pure(h)
eq("heap pop min dist", r19[0][0], 3)
eq("heap pop min node", r19[0][1], 1)

// ── 20: Heap pop ordering ───────────────────────────────────────
let mut h20 = r19[1]
let r20 = heap_pop_pure(h20)
eq("heap pop second dist", r20[0][0], 7)

// ── 21: Heap pop last ───────────────────────────────────────────
let mut h21 = r20[1]
let r21 = heap_pop_pure(h21)
eq("heap pop third dist", r21[0][0], 10)

// ── 22: Heap pop empty ──────────────────────────────────────────
let r22 = heap_pop_pure([])
check("heap pop empty item is nil", type_of(r22[0]) != "array")

// ── 23: Bidirectional edges ─────────────────────────────────────
// 0<->1:2, 1<->2:3
let bi_edges = [[0, 1, 2], [1, 0, 2], [1, 2, 3], [2, 1, 3]]
let d23 = dijkstra_pure(3, bi_edges, 0)
eq("bidir dist[2]", d23[2], 5)

// ── 24: Star topology (fan-out) ─────────────────────────────────
// 0->1:1, 0->2:2, 0->3:3, 0->4:4
let star_edges = [[0, 1, 1], [0, 2, 2], [0, 3, 3], [0, 4, 4]]
let d24 = dijkstra_pure(5, star_edges, 0)
eq("star dist[1]", d24[1], 1)
eq("star dist[4]", d24[4], 4)

// ── Report ──────────────────────────────────────────────────────
println("")
println("dijkstra_pure: " + to_string(pass) + " passed, " + to_string(fail) + " failed")
if fail > 0 {
    println("SOME TESTS FAILED")
} else {
    println("ALL PASS")
}
