// ═══════════════════════════════════════════════════════════════════
//  test_dijkstra_pure.hexa — coverage for self/runtime/dijkstra_pure.hexa
//
//  8 test groups: triangle, unreachable, single node, path reconstruction,
//  equal weights (BFS), diamond unequal, linear chain, build_weighted_adj.
//
//  Pitfalls honored: P1 no semicolons, P15 let mut, push() not concat
// ═══════════════════════════════════════════════════════════════════

// ── INLINED from runtime/dijkstra_pure.hexa ──

let INF = 1000000000.0

pub fn build_weighted_adj(num_nodes, edge_list) {
    let mut adj = []
    let mut i = 0
    while i < num_nodes {
        adj.push([])
        i = i + 1
    }
    let mut e = 0
    while e < len(edge_list) {
        let edge = edge_list[e]
        let u = edge[0]
        let v = edge[1]
        let w = edge[2]
        adj[u].push([v, w])
        e = e + 1
    }
    return adj
}

pub fn dijkstra(num_nodes, edges, source) {
    let mut dist = []
    let mut prev = []
    let mut visited = []
    let mut i = 0
    while i < num_nodes {
        dist.push(INF)
        prev.push(-1)
        visited.push(false)
        i = i + 1
    }
    dist[source] = 0.0

    let mut step = 0
    while step < num_nodes {
        let mut u = -1
        let mut best = INF + 1.0
        let mut j = 0
        while j < num_nodes {
            if !visited[j] && dist[j] < best {
                best = dist[j]
                u = j
            }
            j = j + 1
        }
        if u == -1 {
            step = num_nodes
        } else {
            visited[u] = true
            let neighbors = edges[u]
            let mut k = 0
            while k < len(neighbors) {
                let nb = neighbors[k]
                let v = nb[0]
                let w = nb[1]
                let alt = dist[u] + w
                if alt < dist[v] {
                    dist[v] = alt
                    prev[v] = u
                }
                k = k + 1
            }
            step = step + 1
        }
    }
    return #{"dist": dist, "prev": prev}
}

pub fn shortest_path(num_nodes, edges, source, target) {
    let result = dijkstra(num_nodes, edges, source)
    let d = result["dist"]
    let prev_arr = result["prev"]
    if d[target] >= INF {
        return []
    }
    let mut path = []
    let mut cur = target
    while cur != -1 {
        path.push(cur)
        cur = prev_arr[cur]
    }
    let mut reversed = []
    let mut r = len(path) - 1
    while r >= 0 {
        reversed.push(path[r])
        r = r - 1
    }
    return reversed
}

pub fn shortest_distance(num_nodes, edges, source, target) {
    let result = dijkstra(num_nodes, edges, source)
    let d = result["dist"][target]
    if d >= INF {
        return -1.0
    }
    return d
}

pub fn is_reachable(num_nodes, edges, source, target) {
    let result = dijkstra(num_nodes, edges, source)
    return result["dist"][target] < INF
}

// ── END INLINED ──

let mut pass = 0
let mut fail = 0

fn check(name, cond) {
    if cond {
        pass = pass + 1
        println("[PASS] " + name)
    } else {
        fail = fail + 1
        println("[FAIL] " + name)
    }
}

fn eq(name, actual, expected) {
    if actual == expected {
        pass = pass + 1
        println("[PASS] " + name)
    } else {
        fail = fail + 1
        println("[FAIL] " + name + " expected=" + to_string(expected) + " got=" + to_string(actual))
    }
}

fn eq_arr(name, actual, expected) {
    let n = len(actual)
    if n != len(expected) {
        fail = fail + 1
        println("[FAIL] " + name + " len expected=" + to_string(len(expected)) + " got=" + to_string(n))
        return void
    }
    let mut i = 0
    let mut ok = true
    while i < n {
        if actual[i] != expected[i] { ok = false }
        i = i + 1
    }
    if ok {
        pass = pass + 1
        println("[PASS] " + name)
    } else {
        fail = fail + 1
        println("[FAIL] " + name + " actual=" + to_string(actual) + " expected=" + to_string(expected))
    }
}

fn near(name, actual, expected, tol) {
    let diff = actual - expected
    let mut abs_diff = diff
    if abs_diff < 0.0 { abs_diff = 0.0 - abs_diff }
    if abs_diff < tol {
        pass = pass + 1
        println("[PASS] " + name)
    } else {
        fail = fail + 1
        println("[FAIL] " + name + " expected=" + to_string(expected) + " got=" + to_string(actual))
    }
}

println("===================================================")
println("  dijkstra_pure.hexa -- test runner")
println("===================================================")

// ── Test 1: Simple triangle graph ──
println("")
println("--- 1. triangle graph ---")
let tri_edges = build_weighted_adj(3, [[0, 1, 1.0], [1, 2, 2.0], [0, 2, 10.0]])
let tri_result = dijkstra(3, tri_edges, 0)
let tri_dist = tri_result["dist"]
near("triangle dist[0]", tri_dist[0], 0.0, 0.001)
near("triangle dist[1]", tri_dist[1], 1.0, 0.001)
near("triangle dist[2]", tri_dist[2], 3.0, 0.001)

// ── Test 2: Unreachable node ──
println("")
println("--- 2. unreachable node ---")
let iso_edges = build_weighted_adj(3, [[0, 1, 5.0]])
check("unreachable is_reachable false", !is_reachable(3, iso_edges, 0, 2))
check("reachable is_reachable true", is_reachable(3, iso_edges, 0, 1))
near("unreachable shortest_distance", shortest_distance(3, iso_edges, 0, 2), -1.0, 0.001)
near("reachable shortest_distance", shortest_distance(3, iso_edges, 0, 1), 5.0, 0.001)
let unreach_path = shortest_path(3, iso_edges, 0, 2)
eq("unreachable path empty", len(unreach_path), 0)

// ── Test 3: Single node graph ──
println("")
println("--- 3. single node ---")
let single_edges = build_weighted_adj(1, [])
let single_result = dijkstra(1, single_edges, 0)
near("single dist[0]", single_result["dist"][0], 0.0, 0.001)
let single_path = shortest_path(1, single_edges, 0, 0)
eq_arr("single path 0->0", single_path, [0])
check("single is_reachable self", is_reachable(1, single_edges, 0, 0))

// ── Test 4: Path reconstruction correctness ──
println("")
println("--- 4. path reconstruction ---")
let tri_path = shortest_path(3, tri_edges, 0, 2)
eq_arr("triangle path 0->2", tri_path, [0, 1, 2])
let tri_path_direct = shortest_path(3, tri_edges, 0, 1)
eq_arr("triangle path 0->1", tri_path_direct, [0, 1])

let self_path = shortest_path(3, tri_edges, 1, 1)
eq_arr("self path 1->1", self_path, [1])

// ── Test 5: All equal weights = BFS order ──
println("")
println("--- 5. equal weights (BFS order) ---")
let bfs_edges = build_weighted_adj(4, [[0, 1, 1.0], [0, 2, 1.0], [1, 3, 1.0], [2, 3, 1.0]])
let bfs_result = dijkstra(4, bfs_edges, 0)
let bfs_dist = bfs_result["dist"]
near("bfs dist[0]", bfs_dist[0], 0.0, 0.001)
near("bfs dist[1]", bfs_dist[1], 1.0, 0.001)
near("bfs dist[2]", bfs_dist[2], 1.0, 0.001)
near("bfs dist[3]", bfs_dist[3], 2.0, 0.001)

let bfs_path = shortest_path(4, bfs_edges, 0, 3)
eq("bfs path len", len(bfs_path), 3)
eq("bfs path start", bfs_path[0], 0)
eq("bfs path end", bfs_path[2], 3)

// ── Test 6: Diamond with unequal weights ──
println("")
println("--- 6. diamond unequal ---")
let dia_edges = build_weighted_adj(4, [[0, 1, 1.0], [0, 2, 2.0], [1, 3, 1.0], [2, 3, 1.0]])
near("diamond dist[3]", shortest_distance(4, dia_edges, 0, 3), 2.0, 0.001)
let dia_path = shortest_path(4, dia_edges, 0, 3)
eq_arr("diamond path 0->3", dia_path, [0, 1, 3])

// ── Test 7: Linear chain ──
println("")
println("--- 7. linear chain ---")
let chain_edges = build_weighted_adj(5, [[0, 1, 3.0], [1, 2, 3.0], [2, 3, 3.0], [3, 4, 3.0]])
near("chain dist[4]", shortest_distance(5, chain_edges, 0, 4), 12.0, 0.001)
let chain_path = shortest_path(5, chain_edges, 0, 4)
eq_arr("chain path 0->4", chain_path, [0, 1, 2, 3, 4])

// ── Test 8: build_weighted_adj correctness ──
println("")
println("--- 8. build_weighted_adj ---")
let adj = build_weighted_adj(3, [[0, 1, 2.5], [0, 2, 3.5], [1, 2, 1.0]])
eq("adj len", len(adj), 3)
eq("adj[0] len", len(adj[0]), 2)
eq("adj[1] len", len(adj[1]), 1)
eq("adj[2] len", len(adj[2]), 0)
eq("adj[0][0] target", adj[0][0][0], 1)
near("adj[0][0] weight", adj[0][0][1], 2.5, 0.001)

// ── Report ──
println("")
println("===================================================")
println("dijkstra_pure: " + to_string(pass) + " passed, " + to_string(fail) + " failed")
if fail > 0 {
    println("SOME TESTS FAILED")
} else {
    println("ALL TESTS PASSED")
}
