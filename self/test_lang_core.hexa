// ═══════════════════════════════════════════════════════════
//  test_lang_core.hexa — Core Language Feature Tests
//  Tests: let/mut, arithmetic, comparison, logical, scope, shadowing,
//         operator precedence, string ops, type conversions
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA Core Language Feature Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Let bindings ────────────────────────────────────────

println("--- Let / Mut Bindings ---")

let a = 42
check("let binding int", a, 42)

let s = "hello"
check("let binding string", s, "hello")

let b = true
check("let binding bool", b, true)

let f = 3.14
check("let binding float", f, 3.14)

let mut x = 10
check("mut initial", x, 10)
x = 20
check("mut reassign", x, 20)
x = x + 5
check("mut self-add", x, 25)

// ── 2. Arithmetic operators ───────────────────────────────

println("")
println("--- Arithmetic ---")

check("add int", 3 + 4, 7)
check("sub int", 10 - 3, 7)
check("mul int", 6 * 7, 42)
check("div int", 15 / 3, 5)
check("mod int", 17 % 5, 2)
check("neg sub", 3 - 10, -7)
check("zero mul", 999 * 0, 0)
check("large add", 100000 + 200000, 300000)
check("float add", 1.5 + 2.5, 4.0)
check("float mul", 2.0 * 3.5, 7.0)
check("mixed chain", (3 + 4) * 2 - 1, 13)

// ── 3. Operator precedence ────────────────────────────────

println("")
println("--- Operator Precedence ---")

check("mul before add", 2 + 3 * 4, 14)
check("parens override", (2 + 3) * 4, 20)
check("left assoc sub", 10 - 3 - 2, 5)
check("mixed prec", 2 * 3 + 4 * 5, 26)
check("nested parens", ((2 + 3) * (4 + 1)), 25)

// ── 4. Comparison operators ───────────────────────────────

println("")
println("--- Comparison ---")

check("eq true", 5 == 5, true)
check("eq false", 5 == 3, false)
check("neq true", 5 != 3, true)
check("neq false", 5 != 5, false)
check("lt true", 3 < 5, true)
check("lt false", 5 < 3, false)
check("gt true", 5 > 3, true)
check("gt false", 3 > 5, false)
check("lte equal", 5 <= 5, true)
check("lte less", 3 <= 5, true)
check("lte greater", 6 <= 5, false)
check("gte equal", 5 >= 5, true)
check("gte greater", 7 >= 5, true)
check("gte less", 3 >= 5, false)

// ── 5. Logical operators ──────────────────────────────────

println("")
println("--- Logical ---")

check("and TT", true && true, true)
check("and TF", true && false, false)
check("and FT", false && true, false)
check("and FF", false && false, false)
check("or TT", true || true, true)
check("or TF", true || false, true)
check("or FT", false || true, true)
check("or FF", false || false, false)
check("not true", !true, false)
check("not false", !false, true)
check("complex logic", (true && false) || true, true)
check("nested logic", !(false || false) && true, true)

// ── 6. String operations ──────────────────────────────────

println("")
println("--- String Operations ---")

check("str concat", "hello" + " " + "world", "hello world")
check("str len", len("hello"), 5)
check("str empty len", len(""), 0)
check("str eq", "abc" == "abc", true)
check("str neq", "abc" != "xyz", true)

let greeting = "hello world"
let parts = greeting.split(" ")
check("str split len", len(parts), 2)
check("str split[0]", parts[0], "hello")
check("str split[1]", parts[1], "world")

check("str contains", greeting.contains("world"), true)
check("str not contains", greeting.contains("xyz"), false)

// ── 7. Type conversions ───────────────────────────────────

println("")
println("--- Type Conversions ---")

check("to_string int", to_string(42), "42")
check("to_string bool", to_string(true), "true")
check("to_string float", to_string(3.0), "3.0")
check("to_int str", to_int("123"), 123)
check("to_int float", to_int(3.7), 3)
check("type_of int", type_of(42), "int")
check("type_of str", type_of("hello"), "string")
check("type_of bool", type_of(true), "bool")
check("type_of float", type_of(3.14), "float")
check("type_of array", type_of([1, 2]), "array")

// ── 8. Scope and shadowing ────────────────────────────────

println("")
println("--- Scope / Shadowing ---")

let outer = 10
if true {
    let outer = 20
    check("inner shadow", outer, 20)
}
check("outer preserved", outer, 10)

let mut counter = 0
let mut i = 0
while i < 3 {
    let local = i * 10
    counter = counter + local
    i = i + 1
}
check("loop scope accum", counter, 30)

// ── 9. If/else expressions ────────────────────────────────

println("")
println("--- If/Else ---")

let r1 = if true { 42 } else { 0 }
check("if-expr true", r1, 42)

let r2 = if false { 42 } else { 0 }
check("if-expr false", r2, 0)

fn classify(n) {
    if n > 100 {
        return "big"
    } else {
        if n > 10 {
            return "medium"
        } else {
            return "small"
        }
    }
}
check("nested if big", classify(200), "big")
check("nested if med", classify(50), "medium")
check("nested if small", classify(5), "small")

// ── 10. While loops ───────────────────────────────────────

println("")
println("--- While Loops ---")

let mut sum = 0
let mut j = 1
while j <= 10 {
    sum = sum + j
    j = j + 1
}
check("while sum 1..10", sum, 55)

let mut fact = 1
let mut k = 1
while k <= 6 {
    fact = fact * k
    k = k + 1
}
check("while factorial 6", fact, 720)

// zero iterations
let mut zero_loop = 0
while false {
    zero_loop = 1
}
check("while false", zero_loop, 0)

// ── 11. Math builtins ─────────────────────────────────────

println("")
println("--- Math Builtins ---")

check("abs positive", abs(5), 5)
check("abs negative", abs(-5), 5)
check("abs zero", abs(0), 0)
check("min", min(3, 7), 3)
check("max", max(3, 7), 7)
check("pow", pow(2, 10), 1024)
check("floor", floor(3.7), 3)
check("ceil", ceil(3.2), 4)
check("round", round(3.5), 4)

// ── 12. Number theory builtins ────────────────────────────

println("")
println("--- Number Theory ---")

check("sigma(6)", sigma(6), 12)
check("sigma(1)", sigma(1), 1)
check("sigma(12)", sigma(12), 28)
check("phi(6)", phi(6), 2)
check("phi(1)", phi(1), 1)
check("phi(10)", phi(10), 4)
check("tau(6)", tau(6), 4)
check("tau(12)", tau(12), 6)
check("sopfr(6)", sopfr(6), 5)
check("sopfr(12)", sopfr(12), 7)

// H-PL identity: sigma(6) * phi(6) = 6 * tau(6) = 24 = J2(6)
check("J2 identity", sigma(6) * phi(6), 6 * tau(6))

// ═══════════════════════════════════════════════════════════
//  SUMMARY
// ═══════════════════════════════════════════════════════════

println("")
println("═══════════════════════════════════════════════════════")
let total = pass_count + fail_count
println("  Results: " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL / " + to_string(total) + " total")
if fail_count == 0 {
    println("  ALL CORE LANGUAGE TESTS PASSED!")
} else {
    println("  SOME TESTS FAILED")
}
println("═══════════════════════════════════════════════════════")
