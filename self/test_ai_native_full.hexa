@test fn t_arith() { assert(1 + 1 == 2); assert(6 * 7 == 42) }
t_arith()
check("@test arith passed", true, true)

@test fn t_cmp() { assert(1 < 2); assert(3 > 2); assert(5 == 5); assert(5 != 6) }
t_cmp()
check("@test cmp passed", true, true)

@test fn t_bool() { assert(true); assert(!false); assert(true || false); assert(true && true) }
t_bool()
check("@test bool passed", true, true)

@bench fn b_array() {
    let mut arr = []
    let mut i = 0
    while i < 100 { arr = arr.push(i); i = i + 1 }
    return len(arr)
}
check("@bench array", b_array(), 100)

@bench fn b_str() {
    let mut s = ""
    let mut i = 0
    while i < 50 { s = s + "x"; i = i + 1 }
    return len(s)
}
check("@bench str", b_str(), 50)

@bench fn b_compute() {
    let mut s = 0
    let mut i = 0
    while i < 1000 { s = s + i; i = i + 1 }
    return s
}
check("@bench compute", b_compute(), 499500)

