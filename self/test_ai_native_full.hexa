// ═══════════════════════════════════════════════════════════
//  test_ai_native_full.hexa — AI-Native @attr Mega Test Suite
//  Target: 200+ PASS covering all AI-native attributes
//
//  Attributes tested:
//    @memoize / @memo — recursive caching
//    @cache           — LRU bounded memoize
//    @pure            — CSE / referential transparency
//    @inline          — function body inlining
//    @hot / @cold     — branch prediction hints
//    @test / @bench   — test & benchmark markers
//    @bounded(N)      — recursion depth limit
//    @deprecated      — deprecation marker
//    @specialize      — type-specialized code gen
//    @lazy            — deferred evaluation (thunk wrapping)
//    @autograd        — automatic differentiation (forward mode)
//    @quantize        — int8/int4 quantization simulation
//    @reduce          — accumulator fold detection
//    @profile         — call-count/timing wrapper
//    @fuse            — operation fusion
//    @optimize        — auto optimization
//    @evolve          — evolution annotation
//    @simd            — SIMD vectorization annotation
//    @parallel        — parallel execution annotation
//    @tensor          — tensor operation annotation
//    Combinations     — multi-attr stacking
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_bool(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA AI-Native @attr MEGA TEST SUITE")
println("  Target: 200+ PASS")
println("═══════════════════════════════════════════════════════")
println("")

// ═══════════════════════════════════════════════════════════
//  SECTION 1: @memoize (40 tests)
// ═══════════════════════════════════════════════════════════

println("══════ SECTION 1: @memoize ══════")
println("")

// 1.1 Fibonacci
println("--- 1.1 @memoize fibonacci ---")

@memoize fn m_fib(n: int) -> int {
    if n <= 1 { return n }
    return m_fib(n - 1) + m_fib(n - 2)
}

check("m_fib(0)", m_fib(0), 0)
check("m_fib(1)", m_fib(1), 1)
check("m_fib(2)", m_fib(2), 1)
check("m_fib(3)", m_fib(3), 2)
check("m_fib(5)", m_fib(5), 5)
check("m_fib(10)", m_fib(10), 55)
check("m_fib(15)", m_fib(15), 610)
check("m_fib(20)", m_fib(20), 6765)
check("m_fib(15b)", m_fib(15), 610)
check("m_fib(20b)", m_fib(20), 6765)

// 1.2 Factorial
println("")
println("--- 1.2 @memoize factorial ---")

@memoize fn m_fact(n: int) -> int {
    if n <= 1 { return 1 }
    return n * m_fact(n - 1)
}

check("m_fact(0)", m_fact(0), 1)
check("m_fact(1)", m_fact(1), 1)
check("m_fact(5)", m_fact(5), 120)
check("m_fact(8)", m_fact(8), 40320)
check("m_fact(10)", m_fact(10), 3628800)
check("m_fact(12)", m_fact(12), 479001600)

// 1.3 Binomial coefficient
println("")
println("--- 1.3 @memoize binomial ---")

@memoize fn m_binom(n: int, k: int) -> int {
    if k == 0 { return 1 }
    if k == n { return 1 }
    if k > n { return 0 }
    return m_binom(n - 1, k - 1) + m_binom(n - 1, k)
}

check("C(0,0)", m_binom(0, 0), 1)
check("C(5,0)", m_binom(5, 0), 1)
check("C(5,5)", m_binom(5, 5), 1)
check("C(5,2)", m_binom(5, 2), 10)
check("C(5,3)", m_binom(5, 3), 10)
check("C(10,3)", m_binom(10, 3), 120)
check("C(10,5)", m_binom(10, 5), 252)
check("C(15,7)", m_binom(15, 7), 6435)
check("C(20,10)", m_binom(20, 10), 184756)

// 1.4 Catalan numbers
println("")
println("--- 1.4 @memoize Catalan ---")

@memoize fn m_catalan(n: int) -> int {
    if n <= 1 { return 1 }
    let mut sum = 0
    let mut i = 0
    while i < n {
        sum = sum + m_catalan(i) * m_catalan(n - 1 - i)
        i = i + 1
    }
    return sum
}

check("catalan(0)", m_catalan(0), 1)
check("catalan(1)", m_catalan(1), 1)
check("catalan(2)", m_catalan(2), 2)
check("catalan(3)", m_catalan(3), 5)
check("catalan(4)", m_catalan(4), 14)
check("catalan(5)", m_catalan(5), 42)
check("catalan(6)", m_catalan(6), 132)

// 1.5 Collatz length
println("")
println("--- 1.5 @memoize Collatz ---")

@memoize fn m_collatz(n: int) -> int {
    if n <= 1 { return 0 }
    if n % 2 == 0 { return 1 + m_collatz(n / 2) }
    return 1 + m_collatz(3 * n + 1)
}

check("collatz(1)", m_collatz(1), 0)
check("collatz(2)", m_collatz(2), 1)
check("collatz(3)", m_collatz(3), 7)
check("collatz(6)", m_collatz(6), 8)
check("collatz(27)", m_collatz(27), 111)

// 1.6 Cache consistency
println("")
println("--- 1.6 @memoize cache consistency ---")
let f10a = m_fib(10)
let f10b = m_fib(10)
check("fib cache hit", f10a == f10b, true)
check("fact cache hit", m_fact(10) == m_fact(10), true)
check("binom cache hit", m_binom(10, 5) == m_binom(10, 5), true)

// ═══════════════════════════════════════════════════════════
//  SECTION 2: @memo alias (5 tests)
// ═══════════════════════════════════════════════════════════

println("")
println("══════ SECTION 2: @memo alias ══════")
println("")

@memo fn memo_tri(n: int) -> int {
    if n <= 0 { return 0 }
    return n + memo_tri(n - 1)
}

check("@memo tri(0)", memo_tri(0), 0)
check("@memo tri(1)", memo_tri(1), 1)
check("@memo tri(5)", memo_tri(5), 15)
check("@memo tri(10)", memo_tri(10), 55)
check("@memo tri(100)", memo_tri(100), 5050)

// ═══════════════════════════════════════════════════════════
//  SECTION 3: @cache (10 tests)
// ═══════════════════════════════════════════════════════════

println("")
println("══════ SECTION 3: @cache ══════")
println("")

@cache fn c_square(x: int) -> int { return x * x }
@cache fn c_fib(n: int) -> int {
    if n <= 1 { return n }
    return c_fib(n - 1) + c_fib(n - 2)
}
@cache fn c_pow(base: int, exp: int) -> int {
    if exp == 0 { return 1 }
    return base * c_pow(base, exp - 1)
}

check("@cache square(5)", c_square(5), 25)
check("@cache square(0)", c_square(0), 0)
check("@cache square(12)", c_square(12), 144)
check("@cache fib(10)", c_fib(10), 55)
check("@cache fib(20)", c_fib(20), 6765)
check("@cache pow(2,0)", c_pow(2, 0), 1)
check("@cache pow(2,10)", c_pow(2, 10), 1024)
check("@cache pow(3,5)", c_pow(3, 5), 243)
check("@cache hit", c_square(5) == c_square(5), true)
check("@cache fib hit", c_fib(10) == c_fib(10), true)

// ═══════════════════════════════════════════════════════════
//  SECTION 4: @pure (15 tests)
// ═══════════════════════════════════════════════════════════

println("")
println("══════ SECTION 4: @pure ══════")
println("")

@pure fn p_square(x: int) -> int { x * x }
@pure fn p_add(a: int, b: int) -> int { a + b }
@pure fn p_max(a: int, b: int) -> int {
    if a > b { return a }
    return b
}
@pure fn p_min(a: int, b: int) -> int {
    if a < b { return a }
    return b
}
@pure fn p_clamp(val: int, lo: int, hi: int) -> int {
    return p_min(p_max(val, lo), hi)
}
@pure fn p_sum_range(n: int) -> int {
    let mut s = 0
    let mut i = 0
    while i < n { s = s + i; i = i + 1 }
    return s
        i = i + 1
}

check("@pure square(7)", p_square(7), 49)
check("@pure CSE same", p_square(7) == p_square(7), true)
check("@pure add(3,4)", p_add(3, 4), 7)
check("@pure max(3,7)", p_max(3, 7), 7)
check("@pure max(7,3)", p_max(7, 3), 7)
check("@pure min(3,7)", p_min(3, 7), 3)
check("@pure min(7,3)", p_min(7, 3), 3)
check("@pure clamp(5,0,10)", p_clamp(5, 0, 10), 5)
check("@pure clamp(-5,0,10)", p_clamp(-5, 0, 10), 0)
check("@pure clamp(15,0,10)", p_clamp(15, 0, 10), 10)
check("@pure sum_range(10)", p_sum_range(10), 45)
check("@pure sum_range(100)", p_sum_range(100), 4950)
check("@pure sum_range(0)", p_sum_range(0), 0)
check("@pure idempotent", p_sum_range(50) == p_sum_range(50), true)
check("@pure diff args", p_square(5) != p_square(7), true)

// ═══════════════════════════════════════════════════════════
//  SECTION 5: @inline (10 tests)
// ═══════════════════════════════════════════════════════════

println("")
println("══════ SECTION 5: @inline ══════")
println("")

@inline fn i_inc(x: int) -> int { x + 1 }
@inline fn i_dec(x: int) -> int { x - 1 }
@inline fn i_dbl(x: int) -> int { x * 2 }
@inline fn i_half(x: int) -> int { x / 2 }
@inline fn i_neg(x: int) -> int { 0 - x }
@inline fn i_abs(x: int) -> int { if x < 0 { return 0 - x } return x }

check("@inline inc", i_inc(41), 42)
check("@inline dec", i_dec(43), 42)
check("@inline dbl", i_dbl(21), 42)
check("@inline half", i_half(84), 42)
check("@inline neg", i_neg(-42), 42)
check("@inline abs(5)", i_abs(5), 5)
check("@inline abs(-5)", i_abs(-5), 5)
check("@inline chain", i_dbl(i_inc(20)), 42)
check("@inline chain2", i_half(i_dbl(42)), 42)

let mut inline_sum = 0
let mut ii = 0
while ii < 100 { inline_sum = inline_sum + i_inc(ii); ii = ii + 1 }