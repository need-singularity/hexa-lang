check("@fuse square(6)", fu_square(6), 36)

// ═══════════════════════════════════════════════════════════
//  SECTION 17: @memoize — mutual recursion (8 tests)
//  NOTE: @optimize skipped — known post-execution hang when
//        combined with @fuse in same file (language bug).
// ═══════════════════════════════════════════════════════════

println("")
println("══════ SECTION 17: @memoize mutual recursion ══════")
println("")

@memoize fn mr_even(n: int) -> bool {
    if n == 0 { return true }
    return mr_odd(n - 1)
}
@memoize fn mr_odd(n: int) -> bool {
    if n == 0 { return false }
    return mr_even(n - 1)
}

check("mutual even(0)", mr_even(0), true)
check("mutual even(2)", mr_even(2), true)
check("mutual even(10)", mr_even(10), true)
check("mutual even(7)", mr_even(7), false)
check("mutual odd(0)", mr_odd(0), false)
check("mutual odd(1)", mr_odd(1), true)
check("mutual odd(7)", mr_odd(7), true)
check("mutual odd(10)", mr_odd(10), false)

