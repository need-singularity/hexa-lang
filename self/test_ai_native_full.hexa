// ═══════════════════════════════════════════════════════════
//  SECTION 22: Attribute Combinations (20 tests)
// ═══════════════════════════════════════════════════════════

println("")
println("══════ SECTION 22: Attribute Combinations ══════")
println("")

// @pure + @inline
@pure @inline fn pi_combo(a: int, b: int) -> int { return a * a + b }
check("@pure @inline combo(3,4)", pi_combo(3, 4), 13)
check("@pure @inline CSE", pi_combo(5, 1) == pi_combo(5, 1), true)

// @hot + @inline
@hot @inline fn hi_abs(x: int) -> int {
    if x < 0 { return 0 - x }
    return x
}
check("@hot @inline abs(42)", hi_abs(42), 42)
check("@hot @inline abs(-42)", hi_abs(-42), 42)
check("@hot @inline abs(0)", hi_abs(0), 0)

// @pure + @cache
@pure @cache fn pc_sq(x: int) -> int { return x * x + 1 }
check("@pure @cache sq+1(6)", pc_sq(6), 37)
check("@pure @cache sq+1(0)", pc_sq(0), 1)

// @inline + @specialize
@inline @specialize fn is_mul5(x: int) -> int { return x * 5 }
check("@inline @specialize mul5(9)", is_mul5(9), 45)
check("@inline @specialize mul5(0)", is_mul5(0), 0)

// @pure + @inline + @specialize
@pure @inline @specialize fn pis_combo(x: int) -> int { return x * x + x }
check("@pure @inline @specialize(5)", pis_combo(5), 30)
check("@pure @inline @specialize(0)", pis_combo(0), 0)

// @pure + @reduce
@pure @reduce fn pr_sum(n: int) -> int {
    let mut s = 0
    let mut i = 1
    while i <= n { s = s + i; i = i + 1 }
    return s
}
check("@pure @reduce 1..10", pr_sum(10), 55)
check("@pure @reduce 1..100", pr_sum(100), 5050)
check("@pure @reduce idempotent", pr_sum(50) == pr_sum(50), true)

// @deprecated + @memoize
@deprecated @memoize fn dm_fib(n: int) -> int {
    if n <= 1 { return n }
    return dm_fib(n - 1) + dm_fib(n - 2)
}
check("@deprecated @memoize fib(10)", dm_fib(10), 55)
check("@deprecated @memoize fib(20)", dm_fib(20), 6765)

// @hot + @memoize
@hot @memoize fn hm_fact(n: int) -> int {
    if n <= 1 { return 1 }
    return n * hm_fact(n - 1)
}
check("@hot @memoize fact(10)", hm_fact(10), 3628800)
check("@hot @memoize fact(12)", hm_fact(12), 479001600)

// ═══════════════════════════════════════════════════════════
//  SECTION 23: @memoize edge cases (10 tests)
// ═══════════════════════════════════════════════════════════

println("")
println("══════ SECTION 23: @memoize edge cases ══════")
println("")

// String argument memoization
@memoize fn ms_len(s: string) -> int { return len(s) }
check("@memo strlen hello", ms_len("hello"), 5)
check("@memo strlen empty", ms_len(""), 0)
check("@memo strlen cached", ms_len("hello"), 5)

// Boolean return memoization
@memoize fn me_even(n: int) -> bool { return n % 2 == 0 }
check("@memo is_even(4)", me_even(4), true)
check("@memo is_even(7)", me_even(7), false)
check("@memo is_even(0)", me_even(0), true)

// GCD memoized
@memoize fn m_gcd(a: int, b: int) -> int {
    if b == 0 { return a }
    return m_gcd(b, a % b)
}
check("@memo gcd(12,8)", m_gcd(12, 8), 4)
check("@memo gcd(100,75)", m_gcd(100, 75), 25)
check("@memo gcd(17,13)", m_gcd(17, 13), 1)
check("@memo gcd(0,5)", m_gcd(0, 5), 5)

// ═══════════════════════════════════════════════════════════
//  SECTION 24: @memoize Ackermann (4 tests)
// ═══════════════════════════════════════════════════════════

println("")
println("══════ SECTION 24: @memoize Ackermann ══════")
println("")

@memoize fn m_ack(m: int, n: int) -> int {
    if m == 0 { return n + 1 }
    if n == 0 { return m_ack(m - 1, 1) }
    return m_ack(m - 1, m_ack(m, n - 1))
}

check("ack(0,0)", m_ack(0, 0), 1)
check("ack(1,1)", m_ack(1, 1), 3)
check("ack(2,2)", m_ack(2, 2), 7)
check("ack(3,3)", m_ack(3, 3), 61)

// ═══════════════════════════════════════════════════════════
//  SECTION 25: @memoize call counting (5 tests)
// ═══════════════════════════════════════════════════════════

println("")
println("══════ SECTION 25: @memoize call counting ══════")
println("")

let mut cc_count = 0
@memoize fn cc_square(n: int) -> int {
    cc_count = cc_count + 1
    return n * n
}

cc_square(5)
cc_square(5)
cc_square(5)
check("@memo call_count after 3x same", cc_count, 1)

cc_square(10)
check("@memo call_count after new arg", cc_count, 2)

cc_square(5)
cc_square(10)
check("@memo no new calls from cache", cc_count, 2)

let mut cc_noarg = 0
@memoize fn cc_const() -> int {
    cc_noarg = cc_noarg + 1
    return 42
}
cc_const()
cc_const()
check("@memo 0-arg cached", cc_noarg, 1)
check("@memo 0-arg value", cc_const(), 42)

