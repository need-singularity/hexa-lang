@quantize fn q_scale(x: int) -> int { return x * 127 }
@quantize fn q_add(a: int, b: int) -> int { return a + b }
@quantize fn q_clamp(x: int) -> int {
    if x > 127 { return 127 }
    if x < -128 { return -128 }
    return x
}
@quantize fn q_relu(x: int) -> int {
    if x < 0 { return 0 }
    return x
}

check("@quantize scale(1)", q_scale(1), 127)
check("@quantize scale(2)", q_scale(2), 254)
check("@quantize add(50,77)", q_add(50, 77), 127)
check("@quantize clamp(200)", q_clamp(200), 127)
check("@quantize clamp(-200)", q_clamp(-200), -128)
check("@quantize clamp(50)", q_clamp(50), 50)
check("@quantize relu(-5)", q_relu(-5), 0)
check("@quantize relu(10)", q_relu(10), 10)
check("@quantize relu(0)", q_relu(0), 0)

// ═══════════════════════════════════════════════════════════
//  SECTION 14: @reduce (11 tests)
// ═══════════════════════════════════════════════════════════

println("")
println("══════ SECTION 14: @reduce ══════")
println("")

@reduce fn r_sum(n: int) -> int {
    let mut s = 0
    let mut i = 0
    while i < n { s = s + i; i = i + 1 }
    return s
}

@reduce fn r_product(n: int) -> int {
    let mut p = 1
    let mut i = 1
    while i <= n { p = p * i; i = i + 1 }
    return p
}

@reduce fn r_sum_sq(n: int) -> int {
    let mut s = 0
    let mut i = 1
    while i <= n { s = s + i * i; i = i + 1 }
    return s
}

@reduce fn r_count_odd(n: int) -> int {
    let mut c = 0
    let mut i = 0
    while i < n { if i % 2 == 1 { c = c + 1 }; i = i + 1 }
    return c
}

@reduce fn r_pow2(n: int) -> int {
    let mut r = 1
    let mut i = 0
    while i < n { r = r * 2; i = i + 1 }
    return r
}

check("@reduce sum(10)", r_sum(10), 45)
check("@reduce sum(100)", r_sum(100), 4950)
check("@reduce sum(0)", r_sum(0), 0)
check("@reduce product(5)", r_product(5), 120)
check("@reduce product(10)", r_product(10), 3628800)
check("@reduce sum_sq(5)", r_sum_sq(5), 55)
check("@reduce sum_sq(10)", r_sum_sq(10), 385)
check("@reduce count_odd(10)", r_count_odd(10), 5)
check("@reduce count_odd(100)", r_count_odd(100), 50)
check("@reduce pow2(10)", r_pow2(10), 1024)
check("@reduce pow2(0)", r_pow2(0), 1)

