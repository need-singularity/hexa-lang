// ═══════════════════════════════════════════════════════════

println("")
println("══════ SECTION 5: @inline ══════")
println("")

@inline fn i_inc(x: int) -> int { x + 1 }
@inline fn i_dec(x: int) -> int { x - 1 }
@inline fn i_dbl(x: int) -> int { x * 2 }
@inline fn i_half(x: int) -> int { x / 2 }
@inline fn i_neg(x: int) -> int { 0 - x }
@inline fn i_abs(x: int) -> int { if x < 0 { return 0 - x } return x }

check("@inline inc", i_inc(41), 42)
check("@inline dec", i_dec(43), 42)
check("@inline dbl", i_dbl(21), 42)
check("@inline half", i_half(84), 42)
check("@inline neg", i_neg(-42), 42)
check("@inline abs(5)", i_abs(5), 5)
check("@inline abs(-5)", i_abs(-5), 5)
check("@inline chain", i_dbl(i_inc(20)), 42)
check("@inline chain2", i_half(i_dbl(42)), 42)

let mut inline_sum = 0
let mut ii = 0
while ii < 100 { inline_sum = inline_sum + i_inc(ii); ii = ii + 1 }
check("@inline loop sum", inline_sum, 5050)

// ═══════════════════════════════════════════════════════════
//  SECTION 6: @hot / @cold (8 tests)
// ═══════════════════════════════════════════════════════════

println("")
println("══════ SECTION 6: @hot / @cold ══════")
println("")

@hot fn h_sum(n: int) -> int {
    let mut s = 0
    let mut i = 0
    while i < n { s = s + i; i = i + 1 }
    return s
}

@hot fn h_fib_iter(n: int) -> int {
    if n <= 1 { return n }
    let mut a = 0
    let mut b = 1
    let mut i = 2
    while i <= n { let t = a + b; a = b; b = t; i = i + 1 }
    return b
}

@cold fn cold_err(code: int) -> string {
    if code == 404 { return "not found" }
    if code == 500 { return "server error" }
    return "unknown"
}

check("@hot sum(100)", h_sum(100), 4950)
check("@hot sum(0)", h_sum(0), 0)
check("@hot fib_iter(10)", h_fib_iter(10), 55)
check("@hot fib_iter(20)", h_fib_iter(20), 6765)
check("@hot fib_iter(30)", h_fib_iter(30), 832040)
check("@cold 404", cold_err(404), "not found")
check("@cold 500", cold_err(500), "server error")
check("@cold 999", cold_err(999), "unknown")

