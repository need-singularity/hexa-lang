println("══════ SECTION 18: @evolve ══════")
println("")

@evolve fn ev_square(x: int) -> int { return x * x }
@evolve fn ev_add(a: int, b: int) -> int { return a + b }
@evolve fn ev_sum(n: int) -> int {
    let mut s = 0
    let mut i = 0
    while i < n { s = s + i; i = i + 1 }
    return s
}

check("@evolve square(7)", ev_square(7), 49)
check("@evolve add(20,22)", ev_add(20, 22), 42)
check("@evolve sum(10)", ev_sum(10), 45)
check("@evolve sum(0)", ev_sum(0), 0)
check("@evolve square(0)", ev_square(0), 0)

