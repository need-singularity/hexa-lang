@bounded(200) fn bd_count(n: int) -> int {
    if n <= 0 { return 0 }
    return 1 + bd_count(n - 1)
}

@bounded(500) fn bd_sum(n: int) -> int {
    if n <= 0 { return 0 }
    return n + bd_sum(n - 1)
}

