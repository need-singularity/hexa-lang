@specialize fn sp_mul10(x: int) -> int { return x * 10 }
@specialize fn sp_poly(x: int) -> int { return x * x + 3 * x + 5 }
@specialize fn sp_abs(x: int) -> int {
    if x < 0 { return 0 - x }
    return x
}
@specialize fn sp_pow2(n: int) -> int {
    let mut r = 1
    let mut i = 0
    while i < n { r = r * 2; i = i + 1 }
    return r
}

check("@specialize mul10(5)", sp_mul10(5), 50)
check("@specialize mul10(0)", sp_mul10(0), 0)
