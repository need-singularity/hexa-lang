println("══════ SECTION 26: Additional math ══════")
println("")

// Power function with @pure
@pure fn pu_pow_iter(base: int, exp: int) -> int {
    let mut r = 1
    let mut i = 0
    while i < exp { r = r * base; i = i + 1 }
    return r
}

check("@pure pow_iter(2,10)", pu_pow_iter(2, 10), 1024)
check("@pure pow_iter(3,4)", pu_pow_iter(3, 4), 81)
check("@pure pow_iter(5,0)", pu_pow_iter(5, 0), 1)

// Tribonacci with @memoize
@memoize fn m_trib(n: int) -> int {
    if n == 0 { return 0 }
    if n == 1 { return 0 }
    if n == 2 { return 1 }
    return m_trib(n - 1) + m_trib(n - 2) + m_trib(n - 3)
}

check("@memo trib(0)", m_trib(0), 0)
check("@memo trib(2)", m_trib(2), 1)
check("@memo trib(4)", m_trib(4), 2)
check("@memo trib(7)", m_trib(7), 13)
check("@memo trib(10)", m_trib(10), 81)

