println("══════ SECTION 20: @parallel ══════")
println("")

@parallel fn par_sum(n: int) -> int {
    let mut s = 0
    let mut i = 0
    while i < n { s = s + i; i = i + 1 }
    return s
}
@parallel fn par_product(n: int) -> int {
    let mut p = 1
    let mut i = 1
    while i <= n { p = p * i; i = i + 1 }
    return p
}

check("@parallel sum(10)", par_sum(10), 45)
check("@parallel sum(100)", par_sum(100), 4950)
check("@parallel sum(0)", par_sum(0), 0)
check("@parallel product(5)", par_product(5), 120)
check("@parallel product(10)", par_product(10), 3628800)

