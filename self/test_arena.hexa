// ═══════════════════════════════════════════════════════════
//  test_arena.hexa — @arena attribute: arena allocation tests
//  ROI id=26, P3, effect 4x — bulk arena alloc/free
//  Tests:
//    1. @arena fn with alloc sites → detected + rewritten
//    2. @arena fn without allocs → violation
//    3. Arena runtime builtins (arena_new, arena_alloc, arena_free)
//    4. Nested alloc inside while → counted
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA @arena Tests — Arena Allocation (ROI #26)")
println("═══════════════════════════════════════════════════════")
println("")

// ── Test 1: @arena fn with allocation sites ──────────────
// The @arena pass should detect push/append calls as alloc sites.

@arena fn arena_build_list(n) {
    let mut result = []
    let mut i = 0
    while i < n {
        result = result.push(i * 2)
        i = i + 1
    }
    return result
}

let list = arena_build_list(5)
check("arena_build_list len", len(list), 5)
check("arena_build_list[0]", list[0], 0)
check("arena_build_list[4]", list[4], 8)

// ── Test 2: @arena fn with multiple alloc sites ──────────

@arena fn arena_multi_alloc(a, b) {
    let xs = [1, 2, 3]
    let ys = [4, 5, 6]
    let mut zs = []
    let mut i = 0
    while i < len(xs) {
        zs = zs.push(xs[i] + ys[i])
        i = i + 1
    }
    return zs
}

let merged = arena_multi_alloc(0, 0)
check("arena_multi_alloc len", len(merged), 3)
check("arena_multi_alloc[0]", merged[0], 5)
check("arena_multi_alloc[2]", merged[2], 9)

// ── Test 3: Arena semantics — bulk free at block end ──────
// The key arena semantic: allocations within the block are bulk-freed
// when the function returns. No individual free needed.

@arena fn arena_lifecycle(n) {
    let mut items = []
    let mut i = 0
    while i < n {
        let item = [i, i * 10]
        items = items.push(item)
        i = i + 1
    }
    // All items allocated in arena; freed on return
    return len(items)
}

check("arena_lifecycle(10)", arena_lifecycle(10), 10)
check("arena_lifecycle(0)", arena_lifecycle(0), 0)
check("arena_lifecycle(100)", arena_lifecycle(100), 100)

// ── Test 4: @arena with no allocs (violation expected) ───

@arena fn arena_no_allocs(x) {
    return x + 1
}

let r = arena_no_allocs(10)
check("arena_no_allocs result", r, 11)

// ── Test 5: @arena with nested while allocs ──────────────

@arena fn arena_nested(n) {
    let mut outer = []
    let mut i = 0
    while i < n {
        let mut inner = []
        let mut j = 0
        while j < 3 {
            inner = inner.push(i * 10 + j)
            j = j + 1
        }
        outer = outer.push(inner)
        i = i + 1
    }
    return outer
}

let nested = arena_nested(2)
check("arena_nested len", len(nested), 2)
check("arena_nested[0] len", len(nested[0]), 3)
check("arena_nested[1][2]", nested[1][2], 12)

// ── Summary ──────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  @arena: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")
