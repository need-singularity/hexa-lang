// ═══════════════════════════════════════════════════════════
//  test_ipcp.hexa — Interprocedural Constant Propagation Tests
//  M974: When a function is always called with the same constant
//  argument, IPCP inlines that constant into the function body.
//  Tests verify algorithm correctness for functions that IPCP
//  would specialize in the compiler pipeline.
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA IPCP (Interprocedural Constant Propagation) Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Basic IPCP: function always called with same constant ──

println("--- Basic IPCP ---")

fn scale_by_ten(x) {
    return x * 10
}

let r1 = scale_by_ten(5)
check("ipcp scale 5*10", r1, 50)
let r2 = scale_by_ten(3)
check("ipcp scale 3*10", r2, 30)

// ── 2. Constant argument propagation ─────────────────────

println("")
println("--- Constant Arg Propagation ---")

fn add_offset(x, offset) {
    return x + offset
}

// IPCP would detect offset=100 is always the same across all sites
fn use_add_offset() {
    let a = add_offset(1, 100)
    let b = add_offset(2, 100)
    let c = add_offset(3, 100)
    return a + b + c
}

let r3 = use_add_offset()
check("ipcp constant offset sum", r3, 306)

// ── 3. Multi-caller constant detection ───────────────────

println("")
println("--- Multi-caller Detection ---")

fn double_val(n) {
    return n * 2
}

fn caller_a() {
    return double_val(7)
}

fn caller_b() {
    return double_val(7)
}

fn caller_c() {
    return double_val(7)
}

check("ipcp caller_a", caller_a(), 14)
check("ipcp caller_b", caller_b(), 14)
check("ipcp caller_c", caller_c(), 14)

// ── 4. Non-constant args should NOT be specialized ───────

println("")
println("--- Non-constant args (no IPCP) ---")

fn generic_add(a, b) {
    return a + b
}

let r4 = generic_add(1, 2)
let r5 = generic_add(3, 4)
let r6 = generic_add(5, 6)
check("no-ipcp varied 1+2", r4, 3)
check("no-ipcp varied 3+4", r5, 7)
check("no-ipcp varied 5+6", r6, 11)

// ── 5. Recursive function with constant base ─────────────

println("")
println("--- Recursive with constant ---")

fn power_of_two(n) {
    if n <= 0 { return 1 }
    return 2 * power_of_two(n - 1)
}

check("power_of_two(0)", power_of_two(0), 1)
check("power_of_two(1)", power_of_two(1), 2)
check("power_of_two(4)", power_of_two(4), 16)
check("power_of_two(8)", power_of_two(8), 256)

// ── 6. IPCP with constant folding synergy ────────────────

println("")
println("--- IPCP + const folding synergy ---")

fn compute_fixed(x) {
    let base = 10
    let scale = 3
    return x * scale + base
}

check("ipcp+fold 5", compute_fixed(5), 25)
check("ipcp+fold 0", compute_fixed(0), 10)
check("ipcp+fold 10", compute_fixed(10), 40)

// ── 7. Zero-param function (no IPCP applicable) ──────────

println("")
println("--- Zero-param (skip) ---")

fn get_magic() {
    return 42
}

check("zero-param magic", get_magic(), 42)

// ── 8. IPCP substitution correctness ─────────────────────

println("")
println("--- IPCP substitution correctness ---")

fn multiply_by(x, factor) {
    return x * factor
}

// All calls use factor=5 — IPCP would inline factor=5
fn use_multiply() {
    let a = multiply_by(1, 5)
    let b = multiply_by(2, 5)
    let c = multiply_by(10, 5)
    return a + b + c
}

check("ipcp multiply sum", use_multiply(), 65)

// ── 9. Nested call with constant ─────────────────────────

println("")
println("--- Nested call constant ---")

fn inner_compute(n, base) {
    return n * n + base
}

fn outer_compute(x) {
    return inner_compute(x, 10) + inner_compute(x + 1, 10)
}

check("nested ipcp(3)", outer_compute(3), 45)
check("nested ipcp(0)", outer_compute(0), 21)

// ── Summary ──────────────────────────────────────────────

println("")
println("═══════════════════════════════════════════════════════")
println("  IPCP Tests: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")
if fail_count > 0 {
    println("SOME TESTS FAILED")
}
