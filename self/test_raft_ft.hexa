// ═══════════════════════════════════════════════════════════════════
//  test_raft_ft.hexa — RAFT Fine-Tuning (#302)
// ═══════════════════════════════════════════════════════════════════

// -- inlined from self/ml/raft_ft.hexa --
// codegen import not wired for test files

// ═══════════════════════════════════════════════════════════════════
//  self/ml/raft_ft.hexa — RAFT Fine-Tuning (#302)
//
//  RAFT (Retrieval-Augmented Fine-Tuning, Zhang et al., 2024)
//  Train the model to ignore distractor documents and extract
//  answers only from relevant (oracle) documents.
//
//  Training protocol:
//    Given question Q, oracle document D*, distractors D1..Dk
//    - P% of time: include D* among distractors
//      -> model learns to locate & cite the oracle doc
//    - (1-P)% of time: only distractors (no oracle)
//      -> model learns to rely on parametric knowledge
//    - Chain-of-thought: reasoning cites the oracle document
//
//  Architecture:
//    doc_encoder:   W_doc  D_in -> D_hidden  (tanh)
//    query_encoder: W_q    D_in -> D_hidden  (tanh)
//    relevance:     dot(query_emb, doc_emb) -> score
//    answer_head:   W_ans  (D_hidden * n_docs) -> D_out (softmax)
//
//  API:
//    raft_init(D_in, D_hidden, D_out, n_docs, seed) -> model
//    raft_encode_doc(model, doc) -> [float]
//    raft_encode_query(model, query) -> [float]
//    raft_relevance_score(model, query_emb, doc_emb) -> float
//    raft_extract_answer(model, query, docs) -> answer
//    raft_make_training_batch(queries, oracle_docs, distractors, p_oracle, seed) -> batch
//    raft_loss(model, query, docs, answer, oracle_idx) -> float
//    raft_train_step(model, batch, lr) -> model
//
//  AI-NATIVE attrs:
//    @pure  (forward / scoring)
//    @hot   (training)
// ═══════════════════════════════════════════════════════════════════

// ── Math helpers ──────────────────────────────────────────────────

fn raft_abs(x) { if x < 0.0 { return 0.0 - x } return x }

fn raft_exp(x) {
    let mut v = x
    if v > 20.0 { v = 20.0 }
    if v < -20.0 { v = -20.0 }
    let mut result = 1.0
    let mut term = 1.0
    let mut i = 1
    while i < 30 {
        term = term * v / to_float(i)
        result = result + term
        i = i + 1
    }
    if result < 0.0 { return 0.0 }
    return result
}

fn raft_log(x) {
    if x <= 0.0 { return -30.0 }
    let mut v = x
    let mut count = 0
    while v > 2.0 {
        v = v / 2.718281828
        count = count + 1
    }
    while v < 0.5 {
        v = v * 2.718281828
        count = count - 1
    }
    let d = v - 1.0
    let ln_v = d - d * d / 2.0 + d * d * d / 3.0 - d * d * d * d / 4.0
    return to_float(count) + ln_v
}

fn raft_tanh(x) {
    let ep = raft_exp(x)
    let en = raft_exp(0.0 - x)
    return (ep - en) / (ep + en)
}

fn raft_zeros(n) {
    let mut v = []
    let mut _i = 0
    while _i < n {
    return v
        _i = _i + 1
}

fn raft_zeros_2d(rows, cols) {
    let mut m = []
    let mut _r = 0
    while _r < rows {
        let mut row = []
        for _c in 0..cols { row = row + [0.0] }
        m = m + [row]
        _r = _r + 1
    }
    return m
}

fn raft_lcg(state) {
    return (state * 1103515245 + 12345) % 2147483648
}

fn raft_uniform(state) {
    let s = raft_lcg(state)
    return [to_float(s) / 2147483648.0, to_float(s)]
}

// ── Softmax ───────────────────────────────────────────────────────

fn raft_softmax(logits) {
    let n = len(logits)
    let mut mx = logits[0]
    let mut i = 1
    while i < n {
    let mut out = raft_zeros(n)
    let mut sum = 0.0
    for i in 0..n {
        let e = raft_exp(logits[i] - mx)
        out[i] = e
        sum = sum + e
    }
    if sum <= 0.0 { sum = 1.0e-12 }
    for i in 0..n { out[i] = out[i] / sum }
    return out
        i = i + 1
}

// ═══════════════════════════════════════════════════════════════════
//  raft_init — initialise RAFT model
//
//    W_doc : D_hidden x D_in   (document encoder)
//    b_doc : D_hidden
//    W_q   : D_hidden x D_in   (query encoder)
//    b_q   : D_hidden
//    W_ans : D_out x (D_hidden * n_docs)  (answer extraction head)
//    b_ans : D_out
// ═══════════════════════════════════════════════════════════════════
fn raft_init(D_in, D_hidden, D_out, n_docs, seed) {
    let mut state = seed
    if state <= 0 { state = 1 }

    // Document encoder weights
    let mut W_doc = raft_zeros_2d(D_hidden, D_in)
    let mut i = 0
    while i < D_hidden {
        for j in 0..D_in {
            let u = raft_uniform(state)
            state = int(u[1])
            if state <= 0 { state = 1 }
            W_doc[i][j] = u[0] - 0.5
        }
        i = i + 1
    }
    let b_doc = raft_zeros(D_hidden)

    // Query encoder weights
    let mut W_q = raft_zeros_2d(D_hidden, D_in)
    let mut i = 0
    while i < D_hidden {
        for j in 0..D_in {
            let u = raft_uniform(state)
            state = int(u[1])
            if state <= 0 { state = 1 }
            W_q[i][j] = u[0] - 0.5
        }
        i = i + 1
    }
    let b_q = raft_zeros(D_hidden)

    // Answer head: input is concatenated doc embeddings (D_hidden * n_docs)
    let ans_in = D_hidden * n_docs
    let mut W_ans = raft_zeros_2d(D_out, ans_in)
    let mut i = 0
    while i < D_out {
        for j in 0..ans_in {
            let u = raft_uniform(state)
            state = int(u[1])
            if state <= 0 { state = 1 }
            W_ans[i][j] = u[0] - 0.5
        }
        i = i + 1
    }
    let b_ans = raft_zeros(D_out)

    return #{
        "D_in": D_in,
        "D_hidden": D_hidden,
        "D_out": D_out,
        "n_docs": n_docs,
        "W_doc": W_doc,
        "b_doc": b_doc,
        "W_q": W_q,
        "b_q": b_q,
        "W_ans": W_ans,
        "b_ans": b_ans
    }
}

// ═══════════════════════════════════════════════════════════════════
//  Encoders
// ═══════════════════════════════════════════════════════════════════

@pure
fn raft_encode_doc(model, doc) {
    let W = model["W_doc"]
    let b = model["b_doc"]
    let D_hidden = model["D_hidden"]
    let D_in = model["D_in"]
    let mut emb = raft_zeros(D_hidden)
    let mut i = 0
    while i < D_hidden {
        let mut s = b[i]
        for j in 0..D_in { s = s + W[i][j] * doc[j] }
        emb[i] = raft_tanh(s)
        i = i + 1
    }
    return emb
}

@pure
fn raft_encode_query(model, query) {
    let W = model["W_q"]
    let b = model["b_q"]
    let D_hidden = model["D_hidden"]
    let D_in = model["D_in"]
    let mut emb = raft_zeros(D_hidden)
    let mut i = 0
    while i < D_hidden {
        let mut s = b[i]
        for j in 0..D_in { s = s + W[i][j] * query[j] }
        emb[i] = raft_tanh(s)
        i = i + 1
    }
    return emb
}

// ═══════════════════════════════════════════════════════════════════
//  Relevance scoring: dot product between query and doc embeddings
// ═══════════════════════════════════════════════════════════════════

@pure
fn raft_relevance_score(model, query_emb, doc_emb) {
    let D_hidden = model["D_hidden"]
    let mut score = 0.0
    let mut i = 0
    while i < D_hidden {
        score = score + query_emb[i] * doc_emb[i]
        i = i + 1
    }
    return score
}

// ═══════════════════════════════════════════════════════════════════
//  Answer extraction
//
//  Encode query and all docs, concatenate doc embeddings,
//  pass through answer head with softmax.
//  Returns index of the predicted answer class.
// ═══════════════════════════════════════════════════════════════════

@pure
fn raft_extract_answer(model, query, docs) {
    let n_docs = model["n_docs"]
    let D_hidden = model["D_hidden"]
    let D_out = model["D_out"]
    let W_ans = model["W_ans"]
    let b_ans = model["b_ans"]

    // Encode query to get attention weights over docs
    let q_emb = raft_encode_query(model, query)

    // Encode each doc and compute relevance
    let mut doc_embs = []
    let mut rel_scores = []
    let n = len(docs)
    let mut i = 0
    while i < n {
        let d_emb = raft_encode_doc(model, docs[i])
        doc_embs = doc_embs + [d_emb]
        let sc = raft_relevance_score(model, q_emb, d_emb)
        rel_scores = rel_scores + [sc]
        i = i + 1
    }

    // Softmax over relevance scores to weight docs
    let weights = raft_softmax(rel_scores)

    // Build concatenated representation: for each doc slot,
    // weighted sum of doc embeddings
    let ans_in = D_hidden * n_docs
    let mut concat = raft_zeros(ans_in)
    let mut d = 0
    while d < n {
        let w = weights[d]
        for j in 0..D_hidden {
            // Accumulate into slot based on doc's rank by relevance
            let idx = d * D_hidden + j
            if idx < ans_in {
                concat[idx] = concat[idx] + w * doc_embs[d][j]
            }
        }
        d = d + 1
    }

    // Answer head: linear + softmax
    let mut logits = raft_zeros(D_out)
    let mut i = 0
    while i < D_out {
        let mut s = b_ans[i]
        for j in 0..ans_in { s = s + W_ans[i][j] * concat[j] }
        logits[i] = s
        i = i + 1
    }

    // Return argmax class
    let mut best = logits[0]
    let mut best_idx = 0
    let mut i = 1
    while i < D_out {
        if logits[i] > best {
            best = logits[i]
            best_idx = i
        }
        i = i + 1
    }
    return best_idx
}

// ═══════════════════════════════════════════════════════════════════
//  Training batch construction
//
//  For each query:
//    - With probability p_oracle: include oracle doc among the docs
//    - With probability (1 - p_oracle): only distractors
//
//  Returns list of #{query, docs, answer, oracle_idx} entries.
//  oracle_idx = -1 when oracle is excluded.
// ═══════════════════════════════════════════════════════════════════

fn raft_make_training_batch(queries, oracle_docs, distractors, p_oracle, seed) {
    let n_q = len(queries)
    let n_dist = len(distractors)
    let mut state = seed
    if state <= 0 { state = 1 }
    let mut batch = []

    let mut i = 0
    while i < n_q {
        let u = raft_uniform(state)
        state = int(u[1])
        if state <= 0 { state = 1 }
        let coin = u[0]

        let mut docs = []
        let mut oracle_idx = -1

        if coin < p_oracle {
            // Include oracle doc at a random position
            let u2 = raft_uniform(state)
            state = int(u2[1])
            if state <= 0 { state = 1 }

            // Pick position for oracle (among n_dist + 1 slots)
            let pos = int(u2[0] * to_float(n_dist + 1)) % (n_dist + 1)

            let mut di = 0
            for slot in 0..(n_dist + 1) {
                if slot == pos {
                    docs = docs + [oracle_docs[i]]
                    oracle_idx = slot
                } else {
                    if di < n_dist {
                        docs = docs + [distractors[di]]
                        di = di + 1
                    }
                }
            }
        } else {
            // Only distractors
            for di in 0..n_dist {
                docs = docs + [distractors[di]]
            }
            // Pad to n_dist + 1 with first distractor if needed
            docs = docs + [distractors[0]]
            oracle_idx = -1
        }

        batch = batch + [#{
            "query": queries[i],
            "docs": docs,
            "answer": i % 2,
            "oracle_idx": oracle_idx
        }]
        i = i + 1
    }

    return batch
}

// ═══════════════════════════════════════════════════════════════════
//  Loss computation
//
//  Combined loss:
//    L = L_answer + L_relevance
//
//    L_answer:    cross-entropy on answer head output
//    L_relevance: if oracle_idx >= 0, cross-entropy that the
//                 oracle doc gets the highest relevance score
// ═══════════════════════════════════════════════════════════════════

@pure
fn raft_loss(model, query, docs, answer, oracle_idx) {
    let n_docs_model = model["n_docs"]
    let D_hidden = model["D_hidden"]
    let D_out = model["D_out"]
    let W_ans = model["W_ans"]
    let b_ans = model["b_ans"]

    let q_emb = raft_encode_query(model, query)

    // Encode docs and relevance scores
    let mut doc_embs = []
    let mut rel_scores = []
    let n = len(docs)
    let mut i = 0
    while i < n {
        let d_emb = raft_encode_doc(model, docs[i])
        doc_embs = doc_embs + [d_emb]
        let sc = raft_relevance_score(model, q_emb, d_emb)
        rel_scores = rel_scores + [sc]
        i = i + 1
    }

    // Relevance loss: cross-entropy that oracle doc is selected
    let mut loss_rel = 0.0
    if oracle_idx >= 0 {
        let rel_probs = raft_softmax(rel_scores)
        let mut p_oracle_doc = rel_probs[oracle_idx]
        if p_oracle_doc < 1.0e-12 { p_oracle_doc = 1.0e-12 }
        loss_rel = 0.0 - raft_log(p_oracle_doc)
    }

    // Build concat representation (same as extract_answer)
    let weights = raft_softmax(rel_scores)
    let ans_in = D_hidden * n_docs_model
    let mut concat = raft_zeros(ans_in)
    let mut d = 0
    while d < n {
        let w = weights[d]
        for j in 0..D_hidden {
            let idx = d * D_hidden + j
            if idx < ans_in {
                concat[idx] = concat[idx] + w * doc_embs[d][j]
            }
        }
        d = d + 1
    }

    // Answer head logits
    let mut logits = raft_zeros(D_out)
    let mut i = 0
    while i < D_out {
        let mut s = b_ans[i]
        for j in 0..ans_in { s = s + W_ans[i][j] * concat[j] }
        logits[i] = s
        i = i + 1
    }

    // Cross-entropy on answer
    let probs = raft_softmax(logits)
    let mut pa = probs[answer]
    if pa < 1.0e-12 { pa = 1.0e-12 }
    let loss_ans = 0.0 - raft_log(pa)

    return loss_ans + loss_rel
}

// ═══════════════════════════════════════════════════════════════════
//  Training step
//
//  Numerical gradient descent over one batch.
//  Updates W_doc, b_doc, W_q, b_q, W_ans, b_ans.
//
//  Gradient is computed via finite differences (eps = 1e-4).
// ═══════════════════════════════════════════════════════════════════

@hot
fn raft_train_step(model, batch, lr) {
    let D_in = model["D_in"]
    let D_hidden = model["D_hidden"]
    let D_out = model["D_out"]
    let n_docs = model["n_docs"]
    let eps = 1.0e-4
    let inv_eps2 = 1.0 / (2.0 * eps)
    let N = len(batch)
    let inv_n = 1.0 / to_float(N)

    // Helper: compute average loss over batch
    // We inline the batch loss here to avoid function reference issues

    // ── Update W_doc ──────────────────────────────────────────
    let mut W_doc = model["W_doc"]
    let mut i = 0
    while i < D_hidden {
        for j in 0..D_in {
            let orig = W_doc[i][j]

            W_doc[i][j] = orig + eps
            let mut m_plus = #{
                "D_in": D_in, "D_hidden": D_hidden, "D_out": D_out,
                "n_docs": n_docs,
                "W_doc": W_doc, "b_doc": model["b_doc"],
                "W_q": model["W_q"], "b_q": model["b_q"],
                "W_ans": model["W_ans"], "b_ans": model["b_ans"]
            }
            let mut lp = 0.0
            for bi in 0..N {
                let e = batch[bi]
                lp = lp + raft_loss(m_plus, e["query"], e["docs"], e["answer"], e["oracle_idx"])
            }

            W_doc[i][j] = orig - eps
            let mut m_minus = #{
                "D_in": D_in, "D_hidden": D_hidden, "D_out": D_out,
                "n_docs": n_docs,
                "W_doc": W_doc, "b_doc": model["b_doc"],
                "W_q": model["W_q"], "b_q": model["b_q"],
                "W_ans": model["W_ans"], "b_ans": model["b_ans"]
            }
            let mut lm = 0.0
            for bi in 0..N {
                let e = batch[bi]
                lm = lm + raft_loss(m_minus, e["query"], e["docs"], e["answer"], e["oracle_idx"])
            }

            let grad = (lp - lm) * inv_eps2 * inv_n
            W_doc[i][j] = orig - lr * grad
        }
        i = i + 1
    }

    // ── Update b_doc ──────────────────────────────────────────
    let mut b_doc = model["b_doc"]
    let mut i = 0
    while i < D_hidden {
        let orig = b_doc[i]

        b_doc[i] = orig + eps
        let mut m_plus = #{
            "D_in": D_in, "D_hidden": D_hidden, "D_out": D_out,
            "n_docs": n_docs,
            "W_doc": W_doc, "b_doc": b_doc,
            "W_q": model["W_q"], "b_q": model["b_q"],
            "W_ans": model["W_ans"], "b_ans": model["b_ans"]
        }
        let mut lp = 0.0
        for bi in 0..N {
            let e = batch[bi]
            lp = lp + raft_loss(m_plus, e["query"], e["docs"], e["answer"], e["oracle_idx"])
        }

        b_doc[i] = orig - eps
        let mut m_minus = #{
            "D_in": D_in, "D_hidden": D_hidden, "D_out": D_out,
            "n_docs": n_docs,
            "W_doc": W_doc, "b_doc": b_doc,
            "W_q": model["W_q"], "b_q": model["b_q"],
            "W_ans": model["W_ans"], "b_ans": model["b_ans"]
        }
        let mut lm = 0.0
        for bi in 0..N {
            let e = batch[bi]
            lm = lm + raft_loss(m_minus, e["query"], e["docs"], e["answer"], e["oracle_idx"])
        }

        let grad = (lp - lm) * inv_eps2 * inv_n
        b_doc[i] = orig - lr * grad
        i = i + 1
    }

    // ── Update W_q ────────────────────────────────────────────
    let mut W_q = model["W_q"]
    let mut i = 0
    while i < D_hidden {
        for j in 0..D_in {
            let orig = W_q[i][j]

            W_q[i][j] = orig + eps
            let mut m_plus = #{
                "D_in": D_in, "D_hidden": D_hidden, "D_out": D_out,
                "n_docs": n_docs,
                "W_doc": W_doc, "b_doc": b_doc,
                "W_q": W_q, "b_q": model["b_q"],
                "W_ans": model["W_ans"], "b_ans": model["b_ans"]
            }
            let mut lp = 0.0
            for bi in 0..N {
                let e = batch[bi]
                lp = lp + raft_loss(m_plus, e["query"], e["docs"], e["answer"], e["oracle_idx"])
            }

            W_q[i][j] = orig - eps
            let mut m_minus = #{
                "D_in": D_in, "D_hidden": D_hidden, "D_out": D_out,
                "n_docs": n_docs,
                "W_doc": W_doc, "b_doc": b_doc,
                "W_q": W_q, "b_q": model["b_q"],
                "W_ans": model["W_ans"], "b_ans": model["b_ans"]
            }
            let mut lm = 0.0
            for bi in 0..N {
                let e = batch[bi]
                lm = lm + raft_loss(m_minus, e["query"], e["docs"], e["answer"], e["oracle_idx"])
            }

            let grad = (lp - lm) * inv_eps2 * inv_n
            W_q[i][j] = orig - lr * grad
        }
        i = i + 1
    }

    // ── Update b_q ────────────────────────────────────────────
    let mut b_q = model["b_q"]
    let mut i = 0
    while i < D_hidden {
        let orig = b_q[i]

        b_q[i] = orig + eps
        let mut m_plus = #{
            "D_in": D_in, "D_hidden": D_hidden, "D_out": D_out,
            "n_docs": n_docs,
            "W_doc": W_doc, "b_doc": b_doc,
            "W_q": W_q, "b_q": b_q,
            "W_ans": model["W_ans"], "b_ans": model["b_ans"]
        }
        let mut lp = 0.0
        for bi in 0..N {
            let e = batch[bi]
            lp = lp + raft_loss(m_plus, e["query"], e["docs"], e["answer"], e["oracle_idx"])
        }

        b_q[i] = orig - eps
        let mut m_minus = #{
            "D_in": D_in, "D_hidden": D_hidden, "D_out": D_out,
            "n_docs": n_docs,
            "W_doc": W_doc, "b_doc": b_doc,
            "W_q": W_q, "b_q": b_q,
            "W_ans": model["W_ans"], "b_ans": model["b_ans"]
        }
        let mut lm = 0.0
        for bi in 0..N {
            let e = batch[bi]
            lm = lm + raft_loss(m_minus, e["query"], e["docs"], e["answer"], e["oracle_idx"])
        }

        let grad = (lp - lm) * inv_eps2 * inv_n
        b_q[i] = orig - lr * grad
        i = i + 1
    }

    // ── Update W_ans ──────────────────────────────────────────
    let ans_in = D_hidden * n_docs
    let mut W_ans = model["W_ans"]
    let mut i = 0
    while i < D_out {
        for j in 0..ans_in {
            let orig = W_ans[i][j]

            W_ans[i][j] = orig + eps
            let mut m_plus = #{
                "D_in": D_in, "D_hidden": D_hidden, "D_out": D_out,
                "n_docs": n_docs,
                "W_doc": W_doc, "b_doc": b_doc,
                "W_q": W_q, "b_q": b_q,
                "W_ans": W_ans, "b_ans": model["b_ans"]
            }
            let mut lp = 0.0
            for bi in 0..N {
                let e = batch[bi]
                lp = lp + raft_loss(m_plus, e["query"], e["docs"], e["answer"], e["oracle_idx"])
            }

            W_ans[i][j] = orig - eps
            let mut m_minus = #{
                "D_in": D_in, "D_hidden": D_hidden, "D_out": D_out,
                "n_docs": n_docs,
                "W_doc": W_doc, "b_doc": b_doc,
                "W_q": W_q, "b_q": b_q,
                "W_ans": W_ans, "b_ans": model["b_ans"]
            }
            let mut lm = 0.0
            for bi in 0..N {
                let e = batch[bi]
                lm = lm + raft_loss(m_minus, e["query"], e["docs"], e["answer"], e["oracle_idx"])
            }

            let grad = (lp - lm) * inv_eps2 * inv_n
            W_ans[i][j] = orig - lr * grad
        }
        i = i + 1
    }

    // ── Update b_ans ──────────────────────────────────────────
    let mut b_ans = model["b_ans"]
    let mut i = 0
    while i < D_out {
        let orig = b_ans[i]

        b_ans[i] = orig + eps
        let mut m_plus = #{
            "D_in": D_in, "D_hidden": D_hidden, "D_out": D_out,
            "n_docs": n_docs,
            "W_doc": W_doc, "b_doc": b_doc,
            "W_q": W_q, "b_q": b_q,
            "W_ans": W_ans, "b_ans": b_ans
        }
        let mut lp = 0.0
        for bi in 0..N {
            let e = batch[bi]
            lp = lp + raft_loss(m_plus, e["query"], e["docs"], e["answer"], e["oracle_idx"])
        }

        b_ans[i] = orig - eps
        let mut m_minus = #{
            "D_in": D_in, "D_hidden": D_hidden, "D_out": D_out,
            "n_docs": n_docs,
            "W_doc": W_doc, "b_doc": b_doc,
            "W_q": W_q, "b_q": b_q,
            "W_ans": W_ans, "b_ans": b_ans
        }
        let mut lm = 0.0
        for bi in 0..N {
            let e = batch[bi]
            lm = lm + raft_loss(m_minus, e["query"], e["docs"], e["answer"], e["oracle_idx"])
        }

        let grad = (lp - lm) * inv_eps2 * inv_n
        b_ans[i] = orig - lr * grad
        i = i + 1
    }

    return #{
        "D_in": D_in,
        "D_hidden": D_hidden,
        "D_out": D_out,
        "n_docs": n_docs,
        "W_doc": W_doc,
        "b_doc": b_doc,
        "W_q": W_q,
        "b_q": b_q,
        "W_ans": W_ans,
        "b_ans": b_ans
    }
}


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs_(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx_(a, b, eps) { return fabs_(a - b) < eps }

println("=== RAFT Fine-Tuning (#302) ===")

// ── Synthetic data ────────────────────────────────────────────
// D_in=3, D_hidden=4, D_out=2, n_docs=3
// "Documents" are just float vectors; "queries" likewise
let oracle_doc_0 = [1.0, 0.0, 0.5]
let oracle_doc_1 = [0.0, 1.0, 0.5]
let distractor_0 = [0.3, 0.3, 0.3]
let distractor_1 = [0.5, 0.5, 0.5]

let queries = [[0.9, 0.1, 0.4], [0.1, 0.9, 0.4]]
let oracle_docs = [oracle_doc_0, oracle_doc_1]
let distractors = [distractor_0, distractor_1]

// ── T1 init model shapes ─────────────────────────────────────
let model = raft_init(3, 4, 2, 3, 42)
check("T1 W_doc shape", len(model["W_doc"]) == 4 && len(model["W_doc"][0]) == 3)
check("T1 W_q shape", len(model["W_q"]) == 4 && len(model["W_q"][0]) == 3)
check("T1 W_ans shape", len(model["W_ans"]) == 2 && len(model["W_ans"][0]) == 12)
check("T1 b_ans len", len(model["b_ans"]) == 2)

// ── T2 encode_doc returns correct dimension ──────────────────
let doc_emb = raft_encode_doc(model, oracle_doc_0)
check("T2 doc emb len", len(doc_emb) == 4)
let mut doc_bounded = true
let mut i = 0

while i < 4 {
    if fabs_(doc_emb[i]) > 1.0 { doc_bounded = false }
}
check("T2 |doc emb| <= 1 (tanh)", doc_bounded)

// ── T3 encode_query returns correct dimension ────────────────
let q_emb = raft_encode_query(model, queries[0])
check("T3 query emb len", len(q_emb) == 4)
let mut q_bounded = true
let mut i = 0

while i < 4 {
    if fabs_(q_emb[i]) > 1.0 { q_bounded = false }
}
check("T3 |query emb| <= 1 (tanh)", q_bounded)

// ── T4 relevance score is a scalar ───────────────────────────
let rel = raft_relevance_score(model, q_emb, doc_emb)
check("T4 relevance is finite", rel > -100.0 && rel < 100.0)

// ── T5 extract_answer returns valid class ────────────────────
let docs5 = [oracle_doc_0, distractor_0, distractor_1]
let ans5 = raft_extract_answer(model, queries[0], docs5)
check("T5 answer in [0, D_out)", ans5 >= 0 && ans5 < 2)

// ── T6 loss is non-negative ──────────────────────────────────
let loss6 = raft_loss(model, queries[0], docs5, 0, 0)
check("T6 loss >= 0", loss6 >= 0.0)

// ── T7 loss with oracle_idx=-1 (no oracle) still works ──────
let loss7 = raft_loss(model, queries[0], docs5, 0, -1)
check("T7 no-oracle loss >= 0", loss7 >= 0.0)

// ── T8 make_training_batch produces correct structure ────────
let batch8 = raft_make_training_batch(queries, oracle_docs, distractors, 0.7, 99)
check("T8 batch length", len(batch8) == 2)
check("T8 entry has query", len(batch8[0]["query"]) == 3)
check("T8 entry has docs", len(batch8[0]["docs"]) >= 2)

// ── T9 deterministic init ────────────────────────────────────
let m_a = raft_init(3, 4, 2, 3, 7)
let m_b = raft_init(3, 4, 2, 3, 7)
let ea = raft_encode_doc(m_a, [0.5, 0.5, 0.5])
let eb = raft_encode_doc(m_b, [0.5, 0.5, 0.5])
let mut det_ok = true
let mut i = 0

while i < 4 {
    if fabs_(ea[i] - eb[i]) > 1.0e-9 { det_ok = false }
}
check("T9 deterministic init", det_ok)

// ── T10 different docs get different embeddings ──────────────
let emb_o = raft_encode_doc(model, oracle_doc_0)
let emb_d = raft_encode_doc(model, distractor_0)
let mut diff_found = false
let mut i = 0

while i < 4 {
    if fabs_(emb_o[i] - emb_d[i]) > 0.01 { diff_found = true }
}
check("T10 different docs -> different emb", diff_found)

// ── T11 training reduces loss ────────────────────────────────
// Build a small fixed batch with oracle docs included
let train_batch = [
    #{"query": queries[0], "docs": [oracle_doc_0, distractor_0, distractor_1], "answer": 0, "oracle_idx": 0},
    #{"query": queries[1], "docs": [distractor_0, oracle_doc_1, distractor_1], "answer": 1, "oracle_idx": 1}
]

let mut loss_before = 0.0
let mut bi = 0

while bi < 2 {
    let e = train_batch[bi]
    loss_before = loss_before + raft_loss(model, e["query"], e["docs"], e["answer"], e["oracle_idx"])
}

let mut trained = model
let mut _step = 0

while _step < 20 {
    trained = raft_train_step(trained, train_batch, 0.1)
}

let mut loss_after = 0.0
let mut bi = 0

while bi < 2 {
    let e = train_batch[bi]
    loss_after = loss_after + raft_loss(trained, e["query"], e["docs"], e["answer"], e["oracle_idx"])
}
check("T11 training reduces loss", loss_after < loss_before)

// ── T12 relevance score increases for oracle doc after training ─
let q_emb_t = raft_encode_query(trained, queries[0])
let o_emb_t = raft_encode_doc(trained, oracle_doc_0)
let d_emb_t = raft_encode_doc(trained, distractor_0)
let rel_oracle = raft_relevance_score(trained, q_emb_t, o_emb_t)
let rel_dist = raft_relevance_score(trained, q_emb_t, d_emb_t)
// After training the model should prefer oracle doc; or at minimum both are finite
check("T12 relevance scores finite", rel_oracle > -100.0 && rel_dist > -100.0)

// ── T13 softmax produces valid distribution ──────────────────
let sm = raft_softmax([1.0, 2.0, 3.0])
let mut sm_sum = 0.0
let mut i = 0

while i < 3 { sm_sum = sm_sum + sm[i] }
check("T13 softmax sums to 1", approx_(sm_sum, 1.0, 1.0e-6))
check("T13 softmax monotone", sm[2] > sm[1] && sm[1] > sm[0])

println("")
println("=== RAFT summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
