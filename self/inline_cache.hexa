// self/inline_cache.hexa — HEXA inline cache ported from src/inline_cache.rs
// Monomorphic inline caching for method dispatch.
// Each call site remembers the last type it saw. On match, skip hash lookup
// and jump straight to cached method body. On mismatch, fall back and update.

// ── Public types ───────────────────────────────────────────────

struct CallSiteId {
    line: int,
    col: int,
    method: string
}

fn call_site_id_new(line: int, col: int, method: string) -> CallSiteId {
    return CallSiteId { line: line, col: col, method: method }
}

fn call_site_id_eq(a: CallSiteId, b: CallSiteId) -> bool {
    return a.line == b.line && a.col == b.col && a.method == b.method
}

struct InlineCacheEntry {
    cached_type: string,
    cached_params: [string],
    hits: int,
    misses: int
}

struct InlineCache {
    entries: [CacheSlot]
}

struct CacheSlot {
    site: CallSiteId,
    entry: InlineCacheEntry
}

fn inline_cache_new() -> InlineCache {
    return InlineCache { entries: [] }
}

// ── Probe ──────────────────────────────────────────────────────

struct ProbeResult {
    found: bool,
    params: [string]
}

fn inline_cache_probe(self: InlineCache, site: CallSiteId, actual_type: string) -> ProbeResult {
    for slot in self.entries {
        if call_site_id_eq(slot.site, site) {
            if slot.entry.cached_type == actual_type {
                slot.entry.hits = slot.entry.hits + 1
                return ProbeResult { found: true, params: slot.entry.cached_params }
            }
            // Type changed -- megamorphic transition
            slot.entry.misses = slot.entry.misses + 1
            return ProbeResult { found: false, params: [] }
        }
    }
    return ProbeResult { found: false, params: [] }
}

// ── Update ─────────────────────────────────────────────────────

fn inline_cache_update(self: InlineCache, site: CallSiteId, type_name: string, params: [string]) {
    for slot in self.entries {
        if call_site_id_eq(slot.site, site) {
            slot.entry.cached_type = type_name
            slot.entry.cached_params = params
            return
        }
    }
    self.entries.push(CacheSlot {
        site: site,
        entry: InlineCacheEntry {
            cached_type: type_name,
            cached_params: params,
            hits: 0,
            misses: 0
        }
    })
}

// ── Invalidate type ────────────────────────────────────────────

fn inline_cache_invalidate_type(self: InlineCache, type_name: string) {
    let mut kept = []
    for slot in self.entries {
        if slot.entry.cached_type != type_name {
            kept = kept.push(slot)
        }
    }
    self.entries = kept
}

// ── Clear ──────────────────────────────────────────────────────

fn inline_cache_clear(self: InlineCache) {
    self.entries = []
}

// ── Stats ──────────────────────────────────────────────────────

struct CacheStats {
    hits: int,
    misses: int
}

fn inline_cache_stats(self: InlineCache) -> CacheStats {
    let hits = 0
    let misses = 0
    for slot in self.entries {
        hits = hits + slot.entry.hits
        misses = misses + slot.entry.misses
    }
    return CacheStats { hits: hits, misses: misses }
}

fn inline_cache_len(self: InlineCache) -> int {
    return self.entries.length()
}

fn inline_cache_is_empty(self: InlineCache) -> bool {
    return self.entries.length() == 0
}
