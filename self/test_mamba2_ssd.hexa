//    T8  ssd_zeros_2d shape
//    T9  ssd_hash deterministic
//    T10 ssd_hash in (-0.5, 0.5)
//    T11 ssd_exp(0) = 1
//    T12 ssd_exp monotonic
//    T13 ssd_softplus(0) > 0
//    T14 ssd_softplus large x ~ x
//    T15 ssd_sigmoid(0) = 0.5
//    T16 ssd_sigmoid bounds [0,1]
//    T17 ssd_silu(0) = 0
//    T18 ssd_silu_vec length preserved
//    T19 ssd_create_layer dim/state_dim/n_heads
//    T20 ssd_create_layer head_dim = dim/n_heads
//    T21 ssd_create_layer A_diag shape
//    T22 ssd_create_layer W_in shape
//    T23 ssd_create_layer conv_kernel shape
//    T24 ssd_discretize output lengths
//    T25 ssd_discretize delta=0 => A_bar=1, B_bar=0
//    T26 ssd_recurrent_step length preserved
//    T27 ssd_recurrent_step formula
//    T28 ssd_recurrent_scan output length
//    T29 ssd_compute_L_matrix shape
//    T30 ssd_compute_L_matrix diagonal=1.0
//    T31 ssd_compute_L_matrix upper=0.0 (causal)
//    T32 ssd_quadratic_attention output shape
//    T33 ssd_quadratic_attention bounded
//    T34 ssd_chunk_scan output length
//    T35 ssd_chunk_scan == recurrent_scan (duality)
//    T36 ssd_input_dependent_delta dim
//    T37 ssd_input_dependent_B shape [n_heads, state_dim]
//    T38 ssd_input_dependent_C shape [n_heads, state_dim]
//    T39 ssd_forward output length = seq_len
//    T40 ssd_multi_head output shape [seq_len, dim]
//    T41 ssd_block output shape [seq_len, dim]
//    T42 ssd_linear y = W*x + b
//    T43 ssd_conv1d output shape
//    T44 ssd_conv1d causal (t=0 only uses k=0)
//
//  Run: ./hexa self/test_mamba2_ssd.hexa
