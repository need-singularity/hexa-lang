// self/test_speculative_decode_attr.hexa — @speculative_decode scaffold tests (ROI #163)
//
// 검증 대상 (SCAFFOLD — mock 기준):
//   (A) attr 선언 파서 (parse_specdecode_decl)
//   (B) attr 정적 검증 (check_specdecode_decl — draft/verify 누락, k 범위)
//   (C) mock draft/verify runtime loop (specdecode_step / specdecode_loop)
//   (D) 실제 @speculative_decode 어노테이션 fn 이 hexa 파서 수용
//   (E) HX11 rules 로더 scaffold (find_specdecode_rules)
//
// self-contained — self/attrs/_own/speculative_decode.hexa 의 함수들이 inline 되어
// module loader 없이 interp 인터프리터에서 직접 동작. 실제 SSOT 정의는 해당 attr
// 파일이며, 여기는 동치성 검증용 mirror 이다. 변경 시 두 곳 동기화.

// ═══════════════════════════════════════════════════════════
//  scaffold core (mirror of self/attrs/_own/speculative_decode.hexa)
// ═══════════════════════════════════════════════════════════

fn _sd_find_open(lines) -> int {
    let mut i = 0
    for line in lines {
        i = i + 1
        let t = line.trim()
        if t.starts_with("//") { continue }
        if t.contains("@speculative_decode(") { return i }
    }
    return -1
}

fn _sd_extract_body(lines, start_line: int) {
    if start_line <= 0 || start_line > len(lines) {
        return [false, true, "no_open", "", start_line]
    }
    let raw = lines[start_line - 1]
    let idx = raw.index_of("@speculative_decode(")
    if idx < 0 { return [false, true, "no_open", "", start_line] }
    let after = raw.substring(idx + 20, len(raw))
    let close = after.index_of(")")
    if close < 0 { return [true, true, "paren_unclosed", after, start_line] }
    return [true, false, "", after.substring(0, close), start_line]
}

fn _sd_split_pairs(body: string) {
    let mut pairs = []
    let mut cur = ""
    let mut paren = 0
    let mut br = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let c = body.substring(i, i + 1)
        if c == "(" { paren = paren + 1; cur = cur + c }
        else if c == ")" { paren = paren - 1; cur = cur + c }
        else if c == "[" { br = br + 1; cur = cur + c }
        else if c == "]" { br = br - 1; cur = cur + c }
        else if c == "," && paren == 0 && br == 0 {
            let tt = cur.trim()
            if len(tt) > 0 { pairs.push(tt) }
            cur = ""
        } else { cur = cur + c }
        i = i + 1
    }
    let tt = cur.trim()
    if len(tt) > 0 { pairs.push(tt) }
    return pairs
}

fn parse_specdecode_decl(lines) {
    let start_line = _sd_find_open(lines)
    if start_line < 0 {
        return #{"found": false, "malformed": false, "reason": "",
                 "draft": "", "verify": "", "k": 4, "decl_line": -1}
    }
    let ext = _sd_extract_body(lines, start_line)
    let ext_malformed = ext[1]
    let ext_reason = ext[2]
    let ext_body = ext[3]
    if ext_malformed {
        return #{"found": true, "malformed": true, "reason": ext_reason,
                 "draft": "", "verify": "", "k": 4, "decl_line": start_line}
    }
    let pairs = _sd_split_pairs(ext_body)
    let mut draft_s = ""
    let mut verify_s = ""
    let mut k = 4
    for p in pairs {
        let eqi = p.index_of("=")
        if eqi < 0 { continue }
        let key = p.substring(0, eqi).trim()
        let val = p.substring(eqi + 1, len(p)).trim()
        if key == "draft"  { draft_s  = val }
        else if key == "verify" { verify_s = val }
        else if key == "k" {
            try { k = to_int(val) } catch e { k = 4 }
        }
    }
    return #{"found": true, "malformed": false, "reason": "",
             "draft": draft_s, "verify": verify_s, "k": k, "decl_line": start_line}
}

struct SDMsg { level: string, line: int, msg: string }

fn _mkmsg(level: string, line: int, msg: string) -> SDMsg {
    return SDMsg { level: level, line: line, msg: msg }
}

fn check_specdecode_decl(decl, source: string) {
    let mut out = []
    if !decl["found"] { return out }
    if decl["malformed"] {
        out.push(_mkmsg("error", decl["decl_line"],
            "malformed: " + decl["reason"]))
        return out
    }
    if decl["draft"] == "" {
        out.push(_mkmsg("error", decl["decl_line"], "missing draft="))
    }
    if decl["verify"] == "" {
        out.push(_mkmsg("error", decl["decl_line"], "missing verify="))
    }
    let k = decl["k"]
    if k < 1 {
        out.push(_mkmsg("error", decl["decl_line"], "k must be >= 1"))
    } else if k > 64 {
        out.push(_mkmsg("warn", decl["decl_line"], "k=" + to_string(k) + " unusually high"))
    }
    return out
}

fn mock_draft_fn(ctx, k: int) {
    let mut toks = []
    let mut i = 0
    let ctx_len = len(ctx)
    while i < k {
        toks.push("t" + to_string(ctx_len + i))
        i = i + 1
    }
    return toks
}

fn mock_verify_fn(ctx, draft_toks) {
    let mut mask = []
    for _ in draft_toks { mask.push(true) }
    return mask
}

fn specdecode_step(ctx, draft_fn, verify_fn, k: int) {
    let draft_toks = draft_fn(ctx, k)
    let mask = verify_fn(ctx, draft_toks)
    let mut accepted = []
    let mut i = 0
    let n = len(mask)
    while i < n {
        if mask[i] { accepted.push(draft_toks[i]) } else { break }
        i = i + 1
    }
    let mut new_ctx = ctx
    for t in accepted { new_ctx.push(t) }
    let rollback = k - len(accepted)
    return [accepted, new_ctx, rollback]
}

fn specdecode_loop(initial_ctx, draft_fn, verify_fn, k: int, steps: int) {
    let mut ctx = initial_ctx
    let mut total_accept = 0
    let mut total_rb = 0
    let mut s = 0
    while s < steps {
        let r = specdecode_step(ctx, draft_fn, verify_fn, k)
        let accepted = r[0]
        ctx = r[1]
        total_rb = total_rb + r[2]
        total_accept = total_accept + len(accepted)
        if len(accepted) == 0 { break }
        s = s + 1
    }
    return [ctx, total_accept, total_rb]
}

fn find_specdecode_rules(source: string) {
    return #{}
}

fn specdecode_builtin_rules() {
    let mut r = #{}
    r["min_k"] = 1
    r["max_k"] = 64
    return r
}

// ═══════════════════════════════════════════════════════════
//  tests
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  @speculative_decode scaffold tests (ROI #163)")
println("═══════════════════════════════════════════════════════")
println("")

// ── A. 정적 선언 파싱 ──────────────────────────────────────
println("--- A. parse_specdecode_decl ---")

let lines1 = [
    "// test fixture 1",
    "@speculative_decode(draft=small, verify=large, k=4)",
    "fn decode(prompt: string) -> string { return prompt }"
]
let d1 = parse_specdecode_decl(lines1)
check("decl found", d1["found"], true)
check("decl malformed", d1["malformed"], false)
check("decl draft", d1["draft"], "small")
check("decl verify", d1["verify"], "large")
check("decl k", d1["k"], 4)
check("decl line", d1["decl_line"], 2)

let lines2 = ["// no attr here", "fn plain() {}"]
let d2 = parse_specdecode_decl(lines2)
check("no decl", d2["found"], false)

let lines3 = ["@speculative_decode(draft=a, verify=b)"]
let d3 = parse_specdecode_decl(lines3)
check("k default", d3["k"], 4)
check("default draft", d3["draft"], "a")

let lines4 = ["@speculative_decode(draft=a, verify=b, k=2"]
let d4 = parse_specdecode_decl(lines4)
check("malformed found", d4["found"], true)
check("malformed flag", d4["malformed"], true)
check("malformed reason", d4["reason"], "paren_unclosed")

// ── B. 정적 검증 ─────────────────────────────────────────
println("")
println("--- B. check_specdecode_decl ---")

let good_msgs = check_specdecode_decl(d1, "test.hexa")
check("valid decl no errors", len(good_msgs), 0)

let lines_nodraft = ["@speculative_decode(verify=large, k=4)"]
let dnd = parse_specdecode_decl(lines_nodraft)
let nd_msgs = check_specdecode_decl(dnd, "test.hexa")
check("missing draft emits error", len(nd_msgs), 1)

let lines_noverify = ["@speculative_decode(draft=small, k=4)"]
let dnv = parse_specdecode_decl(lines_noverify)
let nv_msgs = check_specdecode_decl(dnv, "test.hexa")
check("missing verify emits error", len(nv_msgs), 1)

let lines_k0 = ["@speculative_decode(draft=a, verify=b, k=0)"]
let dk0 = parse_specdecode_decl(lines_k0)
let k0_msgs = check_specdecode_decl(dk0, "test.hexa")
check("k=0 emits error", len(k0_msgs), 1)

let lines_k128 = ["@speculative_decode(draft=a, verify=b, k=128)"]
let dk128 = parse_specdecode_decl(lines_k128)
let k128_msgs = check_specdecode_decl(dk128, "test.hexa")
check("k=128 emits warn", len(k128_msgs), 1)
check("k=128 level is warn", k128_msgs[0].level, "warn")

let mf_msgs = check_specdecode_decl(d4, "test.hexa")
check("malformed emits error", len(mf_msgs), 1)

let no_msgs = check_specdecode_decl(d2, "test.hexa")
check("no decl no messages", len(no_msgs), 0)

// ── C. Mock runtime loop ─────────────────────────────────
println("")
println("--- C. specdecode_step / specdecode_loop (mock) ---")

let ctx0 = []
let step_r = specdecode_step(ctx0, mock_draft_fn, mock_verify_fn, 4)
let accepted = step_r[0]
let new_ctx = step_r[1]
let rb = step_r[2]
check("step accepted count", len(accepted), 4)
check("step new_ctx count", len(new_ctx), 4)
check("step rollback", rb, 0)
check("step first token", accepted[0], "t0")
check("step last token", accepted[3], "t3")

let loop_r = specdecode_loop([], mock_draft_fn, mock_verify_fn, 2, 3)
let final_ctx = loop_r[0]
let total_accept = loop_r[1]
let total_rb = loop_r[2]
check("loop total accepted", total_accept, 6)
check("loop total rollback", total_rb, 0)
check("loop final ctx len", len(final_ctx), 6)
check("loop final ctx t0", final_ctx[0], "t0")
check("loop final ctx t5", final_ctx[5], "t5")

fn partial_verify(ctx, toks) {
    let mut m = []
    let mut i = 0
    for _ in toks {
        if i < 2 { m.push(true) } else { m.push(false) }
        i = i + 1
    }
    return m
}

let pr = specdecode_step([], mock_draft_fn, partial_verify, 5)
check("partial accepted", len(pr[0]), 2)
check("partial rollback", pr[2], 3)

fn reject_verify(ctx, toks) {
    let mut m = []
    for _ in toks { m.push(false) }
    return m
}
let rj = specdecode_step([], mock_draft_fn, reject_verify, 4)
check("all reject accept=0", len(rj[0]), 0)
check("all reject rollback=k", rj[2], 4)

let rj_loop = specdecode_loop([], mock_draft_fn, reject_verify, 4, 5)
check("reject loop accept=0", rj_loop[1], 0)
check("reject loop rollback=k (one step)", rj_loop[2], 4)

// ── D. 실제 @speculative_decode 어노테이션 fn (parser 수용) ──
println("")
println("--- D. live annotation syntax ---")

@speculative_decode(draft=mock_draft_fn, verify=mock_verify_fn, k=3)
fn decode_demo(prompt: string) -> string {
    return "decoded:" + prompt
}

check("annotated fn callable", decode_demo("hello"), "decoded:hello")

// ── E. HX11 rules 로더 (scaffold empty) ───────────────────
println("")
println("--- E. find_specdecode_rules (scaffold) ---")

let rules = find_specdecode_rules("self/test_speculative_decode_attr.hexa")
check("scaffold rules empty", len(keys(rules)), 0)

let builtin = specdecode_builtin_rules()
check("builtin min_k", builtin["min_k"], 1)
check("builtin max_k", builtin["max_k"], 64)

