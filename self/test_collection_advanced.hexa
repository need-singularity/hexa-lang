// ═══════════════════════════════════════════════════════════
//  test_collection_advanced.hexa — Advanced Collection Tests
//  Tests: Map iteration, nested arrays, slice patterns,
//         map merge/diff, array dedup, groupBy, zip,
//         multi-level nesting, collection transforms
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_arr(name, actual, expected) {
    if len(actual) != len(expected) {
        println("[FAIL] " + name + " — len mismatch: " + to_string(len(actual)) + " vs " + to_string(len(expected)))
        fail_count = fail_count + 1
        return
    }
    let mut ok = true
    let mut i = 0
    while i < len(actual) {
        if to_string(actual[i]) != to_string(expected[i]) {
            ok = false
        }
        i = i + 1
    }
    if ok {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — actual: " + to_string(actual) + ", expected: " + to_string(expected))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA Advanced Collection Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Map key iteration ─────────────────────────────────

println("--- Map Key Iteration ---")

let config = #{"host": "localhost", "port": "8080", "debug": "true"}
let ks = config.keys()
check("map keys count", len(ks), 3)

// Verify all expected keys present
let mut found_host = false
let mut found_port = false
let mut found_debug = false
for k in ks {
    if k == "host" { found_host = true }
    if k == "port" { found_port = true }
    if k == "debug" { found_debug = true }
}
check("has key host", found_host, true)
check("has key port", found_port, true)
check("has key debug", found_debug, true)

// ── 2. Map values iteration ──────────────────────────────

println("")
println("--- Map Values Iteration ---")

let scores = #{"math": 95, "sci": 88, "eng": 92}
let vals = scores.values()
check("values count", len(vals), 3)

let mut val_sum = 0
for v in vals {
    val_sum = val_sum + v
}
check("values sum", val_sum, 275)

// ── 3. Map-based frequency counter ───────────────────────

println("")
println("--- Frequency Counter ---")

fn frequency(arr) {
    let mut freq = #{}
    for item in arr {
        let key = to_string(item)
        if freq.contains_key(key) {
            freq[key] = freq[key] + 1
        } else {
            freq[key] = 1
        }
    }
    return freq
}

let f = frequency([1, 2, 2, 3, 3, 3, 4, 4, 4, 4])
check("freq 1", f["1"], 1)
check("freq 2", f["2"], 2)
check("freq 3", f["3"], 3)
check("freq 4", f["4"], 4)

let fw = frequency(["a", "b", "a", "c", "b", "a"])
check("freq a", fw["a"], 3)
check("freq b", fw["b"], 2)
check("freq c", fw["c"], 1)

// ── 4. Nested array transformations ──────────────────────

println("")
println("--- Nested Array Transforms ---")

let matrix = [[1, 2, 3], [4, 5, 6], [7, 8, 9]]

// Flatten
fn flatten(mat) {
    let mut result = []
    for row in mat {
        for item in row {
            result.push(item)
        }
    }
    return result
}

let flat = flatten(matrix)
check("flatten len", len(flat), 9)
check("flatten[0]", flat[0], 1)
check("flatten[4]", flat[4], 5)
check("flatten[8]", flat[8], 9)

// Transpose
fn transpose(mat) {
    let rows = len(mat)
    let cols = len(mat[0])
    let mut result = []
    let mut c = 0
    while c < cols {
        let mut row = []
        let mut r = 0
        while r < rows {
            row.push(mat[r][c])
            r = r + 1
        }
        result.push(row)
        c = c + 1
    }
    return result
}

let t = transpose(matrix)
check_arr("transpose[0]", t[0], [1, 4, 7])
check_arr("transpose[1]", t[1], [2, 5, 8])
check_arr("transpose[2]", t[2], [3, 6, 9])

// ── 5. Slice patterns ────────────────────────────────────

println("")
println("--- Slice Patterns ---")

let data = [10, 20, 30, 40, 50, 60, 70]

let head = data.slice(0, 1)
check("slice head", head[0], 10)

let tail = data.slice(1, 7)
check("slice tail len", len(tail), 6)
check("slice tail[0]", tail[0], 20)

let mid = data.slice(2, 5)
check_arr("slice middle", mid, [30, 40, 50])

let last2 = data.slice(5, 7)
check_arr("slice last2", last2, [60, 70])

// ── 6. Zip pattern ───────────────────────────────────────

println("")
println("--- Zip Pattern ---")

fn zip(a, b) {
    let mut result = []
    let min_len = len(a)
    if len(b) < min_len { min_len = len(b) }
    let mut i = 0
    while i < min_len {
        result.push([a[i], b[i]])
        i = i + 1
    }
    return result
}

let names = ["alice", "bob", "charlie"]
let ages = [30, 25, 35]
let zipped = zip(names, ages)
check("zip len", len(zipped), 3)
check("zip[0][0]", zipped[0][0], "alice")
check("zip[0][1]", zipped[0][1], 30)
check("zip[2][0]", zipped[2][0], "charlie")

// Zip unequal lengths
let short = [1, 2]
let long = [10, 20, 30, 40]
let z2 = zip(short, long)
check("zip unequal len", len(z2), 2)

// ── 7. GroupBy pattern ───────────────────────────────────

println("")
println("--- GroupBy Pattern ---")

fn group_by(arr, key_fn) {
    let mut groups = #{}
    for item in arr {
        let k = key_fn(item)
        if groups.contains_key(k) {
            groups[k] = groups[k].push(item)
        } else {
            groups[k] = [item]
        }
    }
    return groups
}

let numbers = [1, 2, 3, 4, 5, 6, 7, 8]
let grouped = group_by(numbers, |n| {
    if n % 2 == 0 { return "even" }
    return "odd"
})
check("group even count", len(grouped["even"]), 4)
check("group odd count", len(grouped["odd"]), 4)
check("group even[0]", grouped["even"][0], 2)
check("group odd[0]", grouped["odd"][0], 1)

// ── 8. Dedup pattern ─────────────────────────────────────

println("")
println("--- Dedup Pattern ---")

fn dedup(arr) {
    let mut seen = #{}
    let mut result = []
    for item in arr {
        let k = to_string(item)
        if !seen.contains_key(k) {
            seen[k] = true
            result.push(item)
        }
    }
    return result
}

let duped = [1, 2, 3, 2, 1, 4, 3, 5]
let unique = dedup(duped)
check_arr("dedup result", unique, [1, 2, 3, 4, 5])

let all_same = [7, 7, 7, 7]
check("dedup all same", len(dedup(all_same)), 1)

let no_dupes = [1, 2, 3, 4]
check("dedup no dupes", len(dedup(no_dupes)), 4)

