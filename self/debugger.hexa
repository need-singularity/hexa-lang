// self/debugger.hexa — HEXA DEBUGGER ported from src/debugger.rs

// Debug Adapter Protocol (DAP) server for HEXA-LANG.
// Speaks DAP JSON messages over stdin/stdout with Content-Length framing.
// Supports: initialize, launch, disconnect, setBreakpoints,
// configurationDone, threads, stackTrace, scopes, variables,
// continue, next, stepIn, stepOut, evaluate.

// ── Debug commands (DAP client -> interpreter) ──────────────

// Commands sent from the DAP server thread to the interpreter thread.
// Represented as strings: "continue", "next", "stepin", "stepout", "disconnect"

// ── Debug events (interpreter -> DAP server) ─────────────────

struct DebugEvent {
    kind: string,      // "stopped", "terminated", "output"
    reason: string,    // "breakpoint", "step", "entry" (for stopped)
    line: int,
    file: string,
    text: string       // for output events
}

fn debug_event_stopped(reason: string, line: int, file: string) -> DebugEvent {
    return DebugEvent { kind: "stopped", reason: reason, line: line, file: file, text: "" }
}

fn debug_event_terminated() -> DebugEvent {
    return DebugEvent { kind: "terminated", reason: "", line: 0, file: "", text: "" }
}

fn debug_event_output(text: string) -> DebugEvent {
    return DebugEvent { kind: "output", reason: "", line: 0, file: "", text: text }
}

// ── StepMode ──────────────────────────────────────────────────

struct StepMode {
    mode: string,    // "continue", "stepin", "next", "stepout"
    depth: int       // for next/stepout
}

fn step_mode_continue() -> StepMode {
    return StepMode { mode: "continue", depth: 0 }
}

fn step_mode_stepin() -> StepMode {
    return StepMode { mode: "stepin", depth: 0 }
}

fn step_mode_next(depth: int) -> StepMode {
    return StepMode { mode: "next", depth: depth }
}

fn step_mode_stepout(depth: int) -> StepMode {
    return StepMode { mode: "stepout", depth: depth }
}

// ── StackFrame ────────────────────────────────────────────────

struct StackFrame {
    id: int,
    name: string,
    file: string,
    line: int
}

// ── Variable snapshot entry ───────────────────────────────────

struct VarSnapshot {
    name: string,
    value: string,
    var_type: string
}

// ── DebugHook ─────────────────────────────────────────────────

struct DebugHook {
    breakpoint_files: [string],
    breakpoint_lines: [int],
    step_mode: StepMode,
    call_depth: int,
    call_stack: [StackFrame],
    disconnected: bool,
    variable_snapshot: [VarSnapshot],
    file_name: string
}

fn debug_hook_new(file_name: string) -> DebugHook {
    let initial_frame = StackFrame { id: 1, name: "<main>", file: file_name, line: 1 }
    return DebugHook {
        breakpoint_files: [],
        breakpoint_lines: [],
        step_mode: step_mode_stepin(),
        call_depth: 0,
        call_stack: [initial_frame],
        disconnected: false,
        variable_snapshot: [],
        file_name: file_name
    }
}

fn debug_hook_is_breakpoint(self: DebugHook, file: string, line: int) -> bool {
    let mut i = 0
    while i < len(self.breakpoint_files) {
        if self.breakpoint_files[i] == file {
            if self.breakpoint_lines[i] == line {
                return true
            }
        }
        i = i + 1
    }
    return false
}

// Called by the interpreter before executing each statement.
// Returns true if execution should continue, false if disconnect.
fn debug_hook_on_statement(self: DebugHook, line: int, file: string) -> bool {
    if self.disconnected { return false }

    let should_stop = false
    if self.step_mode.mode == "continue" {
        should_stop = debug_hook_is_breakpoint(self, file, line)
    }
    if self.step_mode.mode == "stepin" {
        should_stop = true
    }
    if self.step_mode.mode == "next" {
        if self.call_depth <= self.step_mode.depth { should_stop = true }
    }
    if self.step_mode.mode == "stepout" {
        if self.call_depth < self.step_mode.depth { should_stop = true }
    }

    if !should_stop { return true }

    // Would notify DAP server and wait for command here
    return true
}

fn debug_hook_on_function_entry(self: DebugHook, name: string, file: string, line: int) -> DebugHook {
    let new_frame = StackFrame { id: len(self.call_stack) + 1, name: name, file: file, line: line }
    return DebugHook {
        breakpoint_files: self.breakpoint_files,
        breakpoint_lines: self.breakpoint_lines,
        step_mode: self.step_mode,
        call_depth: self.call_depth + 1,
        call_stack: self.call_stack + [new_frame],
        disconnected: self.disconnected,
        variable_snapshot: self.variable_snapshot,
        file_name: self.file_name
    }
}

fn debug_hook_on_function_exit(self: DebugHook) -> DebugHook {
    let new_depth = self.call_depth
    if new_depth > 0 { new_depth = new_depth - 1 }
    // pop last frame (simplified)
    return DebugHook {
        breakpoint_files: self.breakpoint_files,
        breakpoint_lines: self.breakpoint_lines,
        step_mode: self.step_mode,
        call_depth: new_depth,
        call_stack: self.call_stack,
        disconnected: self.disconnected,
        variable_snapshot: self.variable_snapshot,
        file_name: self.file_name
    }
}

// ── Value type name ───────────────────────────────────────────

fn value_type_name(kind: string) -> string {
    if kind == "int" { return "int" }
    if kind == "float" { return "float" }
    if kind == "bool" { return "bool" }
    if kind == "char" { return "char" }
    if kind == "string" { return "string" }
    if kind == "byte" { return "byte" }
    if kind == "void" { return "void" }
    if kind == "array" { return "array" }
    if kind == "map" { return "map" }
    if kind == "lambda" { return "lambda" }
    return kind
}

// ── DAP protocol constants ────────────────────────────────────

let THREAD_ID = 1

// ── DAP message builders ──────────────────────────────────────

fn make_dap_response(seq: int, request_seq: int, command: string, success: bool, body: string) -> string {
    let success_str = "false"
    if success { success_str = "true" }
    return "{\"seq\":" + to_string(seq) + ",\"type\":\"response\",\"request_seq\":" + to_string(request_seq) + ",\"success\":" + success_str + ",\"command\":\"" + command + "\",\"body\":" + body + "}"
}

fn make_dap_event(seq: int, event: string, body: string) -> string {
    return "{\"seq\":" + to_string(seq) + ",\"type\":\"event\",\"event\":\"" + event + "\",\"body\":" + body + "}"
}

// ── DAP Server entry point ────────────────────────────────────

fn run_dap(file_path: string) {
    // 1. Read and parse source
    // 2. Create debug hook with channels
    // 3. Spawn interpreter thread
    // 4. Run DAP message loop on main thread (stdin/stdout)
    print("HEXA DAP debugger started for: " + file_path)
}
