// self/test_json_mini_pure.hexa -- Tests for self/runtime/json_mini_pure.hexa
//
// Reference vectors confirmed by hand + Python json.dumps (ASCII-only inputs).

// ── inline copy of the 5 fns + helpers (standalone runnable) ──────

@pure fn _json_escape_char(c) {
    let o = ord(c)
    if o == 34 { return "\\\"" }
    if o == 92 { return "\\\\" }
    if o == 47 { return "\\/" }
    if o == 10 { return "\\n" }
    if o == 13 { return "\\r" }
    if o == 9  { return "\\t" }
    if o == 8  { return "\\b" }
    if o == 12 { return "\\f" }
    c
}

@pure fn _json_escape_body(s) {
    let n = len(s)
    let mut parts = []
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        parts.push(_json_escape_char(c))
        i = i + 1
    }
    parts.join("")
}

fn json_escape_string_pure(s) {
    if type_of(s) != "string" { return "\"\"" }
    "\"" + _json_escape_body(s) + "\""
}

fn json_encode_int_pure(n) {
    if type_of(n) != "int" { return "0" }
    to_string(n)
}

fn json_encode_string_array_pure(arr) {
    if type_of(arr) != "array" { return "[]" }
    let n = len(arr)
    let mut parts = []
    parts.push("[")
    let mut i = 0
    while i < n {
        let e = arr[i]
        let es = if type_of(e) == "string" { e } else { to_string(e) }
        parts.push("\"")
        parts.push(_json_escape_body(es))
        parts.push("\"")
        if i + 1 < n { parts.push(",") }
        i = i + 1
    }
    parts.push("]")
    parts.join("")
}

fn json_format_object_int_pure(keys, values) {
    if type_of(keys) != "array" { return "{}" }
    if type_of(values) != "array" { return "{}" }
    let nk = len(keys)
    let nv = len(values)
    let n = if nk < nv { nk } else { nv }
    let mut parts = []
    parts.push("{")
    let mut i = 0
    while i < n {
        let k = keys[i]
        let v = values[i]
        let ks = if type_of(k) == "string" { k } else { to_string(k) }
        parts.push("\"")
        parts.push(_json_escape_body(ks))
        parts.push("\":")
        parts.push(json_encode_int_pure(v))
        if i + 1 < n { parts.push(",") }
        i = i + 1
    }
    parts.push("}")
    parts.join("")
}

fn json_unescape_string_pure(s) {
    if type_of(s) != "string" { return "" }
    let n = len(s)
    if n < 2 { return "" }
    if s.substring(0, 1) != "\"" { return "" }
    if s.substring(n - 1, n) != "\"" { return "" }
    let mut parts = []
    let mut i = 1
    let end = n - 1
    while i < end {
        let c = s.substring(i, i + 1)
        if c == "\\" && (i + 1) < end {
            let esc = s.substring(i + 1, i + 2)
            if esc == "\"" { parts.push("\"") }
            else if esc == "\\" { parts.push("\\") }
            else if esc == "/" { parts.push("/") }
            else if esc == "n" { parts.push("\n") }
            else if esc == "r" { parts.push("\r") }
            else if esc == "t" { parts.push("\t") }
            else if esc == "b" { parts.push(from_char_code(8)) }
            else if esc == "f" { parts.push(from_char_code(12)) }
            else { parts.push(esc) }
            i = i + 2
        } else {
            parts.push(c)
            i = i + 1
        }
    }
    parts.join("")
}

// ── test harness ──────────────────────────────────────────────────

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  json_mini_pure.hexa — test runner")
println("═══════════════════════════════════════════════════════")

// ── json_escape_string_pure ────────────────────────────────
println("")
println("--- json_escape_string_pure ---")
check("empty", json_escape_string_pure(""), "\"\"")
check("plain", json_escape_string_pure("hello"), "\"hello\"")
check("inner quote", json_escape_string_pure("a\"b"), "\"a\\\"b\"")
check("backslash", json_escape_string_pure("a\\b"), "\"a\\\\b\"")
check("slash", json_escape_string_pure("a/b"), "\"a\\/b\"")
check("newline", json_escape_string_pure("a\nb"), "\"a\\nb\"")
check("tab", json_escape_string_pure("a\tb"), "\"a\\tb\"")
check("cr", json_escape_string_pure("a\rb"), "\"a\\rb\"")
check("non-string", json_escape_string_pure(42), "\"\"")

// ── json_encode_int_pure ───────────────────────────────────
println("")
println("--- json_encode_int_pure ---")
check("zero", json_encode_int_pure(0), "0")
check("positive", json_encode_int_pure(42), "42")
check("negative", json_encode_int_pure(-7), "-7")
check("large", json_encode_int_pure(1000000), "1000000")
check("non-int", json_encode_int_pure("x"), "0")

// ── json_encode_string_array_pure ──────────────────────────
println("")
println("--- json_encode_string_array_pure ---")
check("empty arr", json_encode_string_array_pure([]), "[]")
check("single", json_encode_string_array_pure(["a"]), "[\"a\"]")
check("two", json_encode_string_array_pure(["a", "b"]), "[\"a\",\"b\"]")
check("three", json_encode_string_array_pure(["x", "y", "z"]), "[\"x\",\"y\",\"z\"]")
check("with quote", json_encode_string_array_pure(["he\"llo"]), "[\"he\\\"llo\"]")
check("non-array", json_encode_string_array_pure("x"), "[]")

// ── json_format_object_int_pure ────────────────────────────
println("")
println("--- json_format_object_int_pure ---")
check("empty", json_format_object_int_pure([], []), "{}")
check("single", json_format_object_int_pure(["a"], [1]), "{\"a\":1}")
check("two", json_format_object_int_pure(["a", "b"], [1, 2]), "{\"a\":1,\"b\":2}")
check("neg val", json_format_object_int_pure(["x"], [-5]), "{\"x\":-5}")
check("escaped key", json_format_object_int_pure(["a\"b"], [9]), "{\"a\\\"b\":9}")
check("mismatch short-keys", json_format_object_int_pure(["a"], [1, 2]), "{\"a\":1}")
check("non-array lhs", json_format_object_int_pure("x", [1]), "{}")

// ── json_unescape_string_pure ──────────────────────────────
println("")
println("--- json_unescape_string_pure ---")
check("empty quoted", json_unescape_string_pure("\"\""), "")
check("plain", json_unescape_string_pure("\"hello\""), "hello")
check("esc quote", json_unescape_string_pure("\"a\\\"b\""), "a\"b")
check("esc backslash", json_unescape_string_pure("\"a\\\\b\""), "a\\b")
check("esc slash", json_unescape_string_pure("\"a\\/b\""), "a/b")
check("esc newline", json_unescape_string_pure("\"a\\nb\""), "a\nb")
check("esc tab", json_unescape_string_pure("\"a\\tb\""), "a\tb")
check("not quoted", json_unescape_string_pure("hello"), "")
check("non-string", json_unescape_string_pure(0), "")

// ── roundtrip ──────────────────────────────────────────────
println("")
println("--- roundtrip escape↔unescape ---")
let rt1 = json_unescape_string_pure(json_escape_string_pure("hello world"))
check("plain rt", rt1, "hello world")
let rt2 = json_unescape_string_pure(json_escape_string_pure("a\"b\\c/d"))
check("mixed escapes rt", rt2, "a\"b\\c/d")
let rt3 = json_unescape_string_pure(json_escape_string_pure("line1\nline2\tcol"))
check("whitespace rt", rt3, "line1\nline2\tcol")

// ── Summary ─────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    println("FAIL")
    exit(1)
}
println("ALL PASS")
