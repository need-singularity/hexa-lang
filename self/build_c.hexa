#!hexa lax
// self/build_c.hexa — N1.1a self-host C 트랜스파일러 (확장판)
// 지원: let, 정수, 문자열 리터럴, +-*/, println 다중 인자, // 주석
//
// 사용: ./hexa self/build_c.hexa  → 고정 입력 examples/calc_min.hexa
// 출력: build/calc_min.c  →  clang으로 빌드해서 실행

use "self/stdlib/law_io"

// ══════════════════════════════════════════════════════════════
// 유틸 (README "char ==" 한계 우회)
// ══════════════════════════════════════════════════════════════
// 모든 인덱싱은 codepoint 기준 (한글 주석 등 멀티바이트 안전).
// 1-char 문자열로 환원해 == 비교 (README "char ==" 한계 우회).
fn cs_at(cs, i) {
    // cs는 char 배열. 1-char 문자열로 변환해 == 비교 가능하게.
    return ("" + cs[i])
}

fn is_digit_s(c) {
    return c == "0" || c == "1" || c == "2" || c == "3" || c == "4" || c == "5" || c == "6" || c == "7" || c == "8" || c == "9"
}
// 빌트인 is_alpha(char) / is_alphanumeric(char) 사용
fn is_alpha_at(cs, i) {
    if cs_at(cs, i) == "_" { return true }
    return is_alpha(cs[i])
}
fn is_alnum_at(cs, i) {
    if cs_at(cs, i) == "_" { return true }
    return is_alphanumeric(cs[i])
}
fn is_space_s(c) { return c == " " || c == "\t" || c == "\r" }
// chars 배열 슬라이스 → string
fn slice_str(cs, a, b) {
    // perf: chunks.push + join — avoid O(n²) string concat
    let mut parts = []
    let mut k = a
    while k < b {
        parts = parts.push("" + cs[k])
        k = k + 1
    }
    return parts.join("")
}

// ══════════════════════════════════════════════════════════════
// 토크나이저
// ══════════════════════════════════════════════════════════════
struct Tok { kind: string, value: string }

fn mk(k, v) { return Tok { kind: k, value: v } }

fn tokenize(src) {
    let cs = src.chars()
    let n = len(cs)
    let mut toks = []
    let mut i = 0
    while i < n {
        let c = cs_at(cs, i)
        if is_space_s(c) {
            i = i + 1
        } else if c == "\n" {
            toks = toks.push(mk("NL", "\n"))
            i = i + 1
        } else if i + 1 < n && c == "/" && cs_at(cs, i + 1) == "/" {
            while i < n && cs_at(cs, i) != "\n" { i = i + 1 }
        } else if is_digit_s(c) {
            let start = i
            while i < n && is_digit_s(cs_at(cs, i)) { i = i + 1 }
            let mut is_float = false
            // . 다음에 숫자가 오면 float
            if i < n && cs_at(cs, i) == "." && i + 1 < n && is_digit_s(cs_at(cs, i + 1)) {
                is_float = true
                i = i + 1
                while i < n && is_digit_s(cs_at(cs, i)) { i = i + 1 }
            }
            // 지수 e/E 다음에 (옵션 부호) + 숫자
            if i < n && (cs_at(cs, i) == "e" || cs_at(cs, i) == "E") {
                is_float = true
                i = i + 1
                if i < n && (cs_at(cs, i) == "+" || cs_at(cs, i) == "-") { i = i + 1 }
                while i < n && is_digit_s(cs_at(cs, i)) { i = i + 1 }
            }
            if is_float {
                toks = toks.push(mk("Float", slice_str(cs, start, i)))
            } else {
                toks = toks.push(mk("Int", slice_str(cs, start, i)))
            }
        } else if is_alpha_at(cs, i) {
            let start = i
            while i < n && is_alnum_at(cs, i) { i = i + 1 }
            let word = slice_str(cs, start, i)
            if word == "let" {
                toks = toks.push(mk("Let", word))
            } else if word == "mut" {
                toks = toks.push(mk("Mut", word))
            } else if word == "if" {
                toks = toks.push(mk("If", word))
            } else if word == "else" {
                toks = toks.push(mk("Else", word))
            } else if word == "while" {
                toks = toks.push(mk("While", word))
            } else if word == "for" {
                toks = toks.push(mk("For", word))
            } else if word == "in" {
                toks = toks.push(mk("In", word))
            } else if word == "struct" {
                toks = toks.push(mk("Struct", word))
            } else if word == "enum" {
                toks = toks.push(mk("Enum", word))
            } else if word == "extern" {
                toks = toks.push(mk("Extern", word))
            } else if word == "fn" {
                toks = toks.push(mk("Fn", word))
            } else if word == "return" {
                toks = toks.push(mk("Return", word))
            } else if word == "break" {
                toks = toks.push(mk("Break", word))
            } else if word == "continue" {
                toks = toks.push(mk("Continue", word))
            } else if word == "match" {
                toks = toks.push(mk("Match", word))
            } else if word == "try" {
                toks = toks.push(mk("Try", word))
            } else if word == "catch" {
                toks = toks.push(mk("Catch", word))
            } else if word == "pub" {
                // skip — visibility modifier, no C equivalent
            } else if word == "pure" {
                // skip
            } else if word == "comptime" {
                // skip
            } else if word == "const" {
                toks = toks.push(mk("Let", "let"))
            } else if word == "static" {
                toks = toks.push(mk("Let", "let"))
            } else if word == "proof" {
                toks = toks.push(mk("ProofBlock", word))
            } else if word == "theorem" {
                toks = toks.push(mk("TheoremBlock", word))
            } else if word == "assert" {
                toks = toks.push(mk("Assert", word))
            } else if word == "true" {
                toks = toks.push(mk("True", word))
            } else if word == "false" {
                toks = toks.push(mk("False", word))
            } else {
                toks = toks.push(mk("Ident", word))
            }
        } else if c == "\"" {
            i = i + 1
            let mut s = ""
            while i < n && cs_at(cs, i) != "\"" {
                let ch = cs_at(cs, i)
                if ch == "\\" && i + 1 < n {
                    // 이스케이프: 원본 \X를 C로 그대로 넘김 — C도 동일 시퀀스 이해
                    let nx = cs_at(cs, i + 1)
                    s = s + "\\" + nx
                    i = i + 2
                } else {
                    s = s + ch
                    i = i + 1
                }
            }
            if i < n { i = i + 1 }
            toks = toks.push(mk("Str", s))
        } else if c == "'" {
            // Char literal: 'x' or '\n' etc
            i = i + 1
            let mut ch_val = ""
            if i < n && cs_at(cs, i) == "\\" && i + 1 < n {
                let esc = cs_at(cs, i + 1)
                if esc == "n" { ch_val = "n" }
                else if esc == "t" { ch_val = "t" }
                else if esc == "r" { ch_val = "r" }
                else if esc == "0" { ch_val = "0" }
                else if esc == "\\" { ch_val = "\\" }
                else if esc == "'" { ch_val = "'" }
                else { ch_val = esc }
                i = i + 2
            } else if i < n {
                ch_val = cs_at(cs, i)
                i = i + 1
            }
            if i < n && cs_at(cs, i) == "'" { i = i + 1 }
            toks = toks.push(mk("CharLit", ch_val))
        } else if c == "(" {
            toks = toks.push(mk("LP", c))
            i = i + 1
        } else if c == ")" {
            toks = toks.push(mk("RP", c))
            i = i + 1
        } else if c == "," {
            toks = toks.push(mk("Comma", c))
            i = i + 1
        } else if c == "=" {
            if i + 1 < n && cs_at(cs, i + 1) == "=" {
                toks = toks.push(mk("EqEq", "=="))
                i = i + 2
            } else if i + 1 < n && cs_at(cs, i + 1) == ">" {
                toks = toks.push(mk("FatArrow", "=>"))
                i = i + 2
            } else {
                toks = toks.push(mk("Eq", c))
                i = i + 1
            }
        } else if c == "!" {
            if i + 1 < n && cs_at(cs, i + 1) == "=" {
                toks = toks.push(mk("NotEq", "!="))
                i = i + 2
            } else {
                toks = toks.push(mk("Bang", c))
                i = i + 1
            }
        } else if c == "<" {
            if i + 1 < n && cs_at(cs, i + 1) == "=" {
                toks = toks.push(mk("LE", "<="))
                i = i + 2
            } else {
                toks = toks.push(mk("LT", c))
                i = i + 1
            }
        } else if c == ">" {
            if i + 1 < n && cs_at(cs, i + 1) == "=" {
                toks = toks.push(mk("GE", ">="))
                i = i + 2
            } else {
                toks = toks.push(mk("GT", c))
                i = i + 1
            }
        } else if c == "&" {
            if i + 1 < n && cs_at(cs, i + 1) == "&" {
                toks = toks.push(mk("AndAnd", "&&"))
                i = i + 2
            } else {
                i = i + 1
            }
        } else if c == "|" {
            if i + 1 < n && cs_at(cs, i + 1) == "|" {
                toks = toks.push(mk("OrOr", "||"))
                i = i + 2
            } else {
                i = i + 1
            }
        } else if c == "{" {
            toks = toks.push(mk("LB", c))
            i = i + 1
        } else if c == "}" {
            toks = toks.push(mk("RB", c))
            i = i + 1
        } else if c == "[" {
            toks = toks.push(mk("LSq", c))
            i = i + 1
        } else if c == "]" {
            toks = toks.push(mk("RSq", c))
            i = i + 1
        } else if c == "@" {
            // @attr or @attr(args). We preserve simple string-literal arg
            // content so @link("m") becomes Attr value "link:m".
            i = i + 1
            let astart = i
            while i < n && (is_alpha_at(cs, i) || is_digit_s(cs_at(cs, i))) { i = i + 1 }
            let aname = slice_str(cs, astart, i)
            let mut arg_captured = ""
            if i < n && cs_at(cs, i) == "(" {
                let arg_start = i + 1
                let mut depth = 1
                i = i + 1
                while i < n && depth > 0 {
                    if cs_at(cs, i) == "(" { depth = depth + 1 }
                    if cs_at(cs, i) == ")" { depth = depth - 1 }
                    if depth > 0 { i = i + 1 }
                }
                // slice arg body between arg_start and i (exclusive of closing paren)
                let raw = slice_str(cs, arg_start, i)
                // strip surrounding quotes/whitespace for string literals like "m"
                let mut a = 0
                let mut b = len(raw)
                while a < b && (raw.substring(a, a + 1) == " " || raw.substring(a, a + 1) == "\"") { a = a + 1 }
                while b > a && (raw.substring(b - 1, b) == " " || raw.substring(b - 1, b) == "\"") { b = b - 1 }
                if b > a { arg_captured = raw.substring(a, b) }
                // consume closing paren
                if i < n && cs_at(cs, i) == ")" { i = i + 1 }
            }
            // Store as "name" or "name:arg" depending on whether we captured anything
            let attr_value = if arg_captured == "" { aname } else { aname + ":" + arg_captured }
            toks = toks.push(mk("Attr", attr_value))
        } else if c == "%" {
            toks = toks.push(mk("Percent", c))
            i = i + 1
        } else if c == ":" {
            if i + 1 < n && cs_at(cs, i + 1) == ":" {
                toks = toks.push(mk("ColonColon", "::"))
                i = i + 2
            } else {
                toks = toks.push(mk("Colon", c))
                i = i + 1
            }
        } else if c == "." {
            if i + 1 < n && cs_at(cs, i + 1) == "." {
                toks = toks.push(mk("DotDot", ".."))
                i = i + 2
            } else {
                toks = toks.push(mk("Dot", c))
                i = i + 1
            }
        } else if c == "+" {
            if i + 1 < n && cs_at(cs, i + 1) == "=" {
                toks = toks.push(mk("PlusEq", "+="))
                i = i + 2
            } else {
                toks = toks.push(mk("Plus", c))
                i = i + 1
            }
        } else if c == "-" {
            if i + 1 < n && cs_at(cs, i + 1) == "=" {
                toks = toks.push(mk("MinusEq", "-="))
                i = i + 2
            } else {
                toks = toks.push(mk("Minus", c))
                i = i + 1
            }
        } else if c == "*" {
            if i + 1 < n && cs_at(cs, i + 1) == "=" {
                toks = toks.push(mk("StarEq", "*="))
                i = i + 2
            } else {
                toks = toks.push(mk("Star", c))
                i = i + 1
            }
        } else if c == "/" {
            if i + 1 < n && cs_at(cs, i + 1) == "=" {
                toks = toks.push(mk("SlashEq", "/="))
                i = i + 2
            } else {
                toks = toks.push(mk("Slash", c))
                i = i + 1
            }
        } else if c == "#" {
            if i + 1 < n && cs_at(cs, i + 1) == "{" {
                toks = toks.push(mk("HashLB", "#{"))
                i = i + 2
            } else {
                i = i + 1
            }
        } else {
            i = i + 1
        }
    }
    toks = toks.push(mk("EOF", ""))
    return toks
}

// ══════════════════════════════════════════════════════════════
// 린터: brace 밸런스 자동 수정
// ══════════════════════════════════════════════════════════════
// hexa 인터프리터는 fn 경계에서 암시적 brace close를 허용하지만
// build_c 파서는 엄격한 RB 매칭이 필요. 이 전처리가 차이를 메운다.
fn lint_braces(toks) {
    let mut out = []
    let mut depth = 0
    let mut i = 0
    let n = len(toks)
    let mut fixes = 0
    let mut line = 1
    while i < n {
        let t = toks[i]
        if t.kind == "NL" { line = line + 1 }
        // top-level 선언이 depth>0 이면 누락된 } 자동 삽입
        if (t.kind == "Fn" || t.kind == "Struct" || t.kind == "Enum") && depth > 0 {
            let closes = depth
            while depth > 0 {
                out = out.push(mk("RB", "}"))
                depth = depth - 1
                fixes = fixes + 1
            }
            println("[lint] line ~", line, ": auto-closed ", closes, " brace(s) before ", t.kind)
        }
        if t.kind == "LB" { depth = depth + 1 }
        if t.kind == "RB" && depth > 0 { depth = depth - 1 }
        out = out.push(t)
        i = i + 1
    }
    // EOF 에서 남은 열린 brace 닫기
    if depth > 0 {
        let rem = depth
        while depth > 0 {
            out = out.push(mk("RB", "}"))
            depth = depth - 1
            fixes = fixes + 1
        }
        println("[lint] EOF: auto-closed ", rem, " remaining brace(s)")
    }
    if fixes > 0 {
        println("[lint] total brace auto-fixes: ", fixes)
    }
    return out
}

// ══════════════════════════════════════════════════════════════
// 파서 (recursive descent, 모듈 전역 상태)
// AST 노드: kind 별 필드 의미가 다른 단일 구조체
// ══════════════════════════════════════════════════════════════
struct Node {
    kind: string,
    value: string,
    op: string,
    left: string,
    right: string,
    cond: string,
    then_b: string,
    else_b: string,
    args: string
}

fn empty() {
    return Node { kind: "", value: "", op: "", left: "", right: "", cond: "", then_b: "", else_b: "", args: [] }
}
fn n_int(v) {
    return Node { kind: "Int", value: v, op: "", left: "", right: "", cond: "", then_b: "", else_b: "", args: [] }
}
fn n_float(v) {
    return Node { kind: "Float", value: v, op: "", left: "", right: "", cond: "", then_b: "", else_b: "", args: [] }
}
fn n_str(v) {
    return Node { kind: "Str", value: v, op: "", left: "", right: "", cond: "", then_b: "", else_b: "", args: [] }
}
fn n_bool(v) {
    return Node { kind: "Bool", value: v, op: "", left: "", right: "", cond: "", then_b: "", else_b: "", args: [] }
}
fn n_ident(v) {
    return Node { kind: "Ident", value: v, op: "", left: "", right: "", cond: "", then_b: "", else_b: "", args: [] }
}
fn n_bin(op, l, r) {
    return Node { kind: "Bin", value: "", op: op, left: l, right: r, cond: "", then_b: "", else_b: "", args: [] }
}
fn n_unary(op, e) {
    return Node { kind: "Unary", value: "", op: op, left: e, right: "", cond: "", then_b: "", else_b: "", args: [] }
}
fn n_call(callee, call_args) {
    return Node { kind: "Call", value: "", op: "", left: callee, right: "", cond: "", then_b: "", else_b: "", args: call_args }
}
fn n_let(name, val) {
    return Node { kind: "Let", value: name, op: "", left: val, right: "", cond: "", then_b: "", else_b: "", args: [] }
}
fn n_assign(name, val) {
    return Node { kind: "Assign", value: name, op: "", left: val, right: "", cond: "", then_b: "", else_b: "", args: [] }
}
fn n_exprstmt(e) {
    return Node { kind: "ExprStmt", value: "", op: "", left: e, right: "", cond: "", then_b: "", else_b: "", args: [] }
}
fn n_if(c, t, e) {
    return Node { kind: "If", value: "", op: "", left: "", right: "", cond: c, then_b: t, else_b: e, args: [] }
}
fn n_while(c, b) {
    return Node { kind: "While", value: "", op: "", left: "", right: "", cond: c, then_b: b, else_b: "", args: [] }
}
fn n_for_range(var_name, lo, hi, body) {
    // value = 변수명, left = lo, right = hi, then_b = body
    return Node { kind: "ForRange", value: var_name, op: "", left: lo, right: hi, cond: "", then_b: body, else_b: "", args: [] }
}
fn n_block(stmts) {
    return Node { kind: "Block", value: "", op: "", left: "", right: "", cond: "", then_b: "", else_b: "", args: stmts }
}
fn n_fn(name, params, body) {
    // params: 이름 문자열 배열, body: Block 노드
    // op 필드에 attribute joined string 저장
    let attrs_str = pending_attrs.join(",")
    pending_attrs = []
    return Node { kind: "Fn", value: name, op: attrs_str, left: "", right: body, cond: "", then_b: "", else_b: "", args: params }
}
fn n_return(e) {
    return Node { kind: "Return", value: "", op: "", left: e, right: "", cond: "", then_b: "", else_b: "", args: [] }
}
fn n_arrlit(elems) {
    return Node { kind: "ArrLit", value: "", op: "", left: "", right: "", cond: "", then_b: "", else_b: "", args: elems }
}
fn n_index(arr, idx) {
    return Node { kind: "Index", value: "", op: "", left: arr, right: idx, cond: "", then_b: "", else_b: "", args: [] }
}
fn n_structdecl(name, field_names) {
    return Node { kind: "StructDecl", value: name, op: "", left: "", right: "", cond: "", then_b: "", else_b: "", args: field_names }
}
fn n_structlit(name, vals) {
    return Node { kind: "StructLit", value: name, op: "", left: "", right: "", cond: "", then_b: "", else_b: "", args: vals }
}
fn n_field(obj, name) {
    return Node { kind: "Field", value: name, op: "", left: obj, right: "", cond: "", then_b: "", else_b: "", args: [] }
}
fn n_method(obj, name, m_args) {
    return Node { kind: "Method", value: name, op: "", left: obj, right: "", cond: "", then_b: "", else_b: "", args: m_args }
}
fn n_if_expr(c, te, ee) {
    // C 삼항 ?: 으로 emit
    return Node { kind: "IfExpr", value: "", op: "", left: te, right: ee, cond: c, then_b: "", else_b: "", args: [] }
}

// 파서 상태
let mut p_toks = []
let mut p_pos = 0
let mut for_in_counter = 0
let mut pending_attrs = []

fn p_peek() { return p_toks[p_pos] }
fn p_kind() { return p_toks[p_pos].kind }
fn p_advance() {
    let t = p_toks[p_pos]
    p_pos = p_pos + 1
    return t
}
fn p_eat(k) {
    if p_kind() == k {
        p_advance()
        return true
    }
    return false
}
fn p_skip_nl() {
    while p_kind() == "NL" { p_advance() }
}

// If stmt를 IfExpr (삼항)로 변환 (재귀적)
fn convert_if_to_expr(node) {
    if node.kind != "If" { return node }
    let te = extract_block_expr(node.then_b)
    let ee = extract_block_expr(node.else_b)
    return n_if_expr(node.cond, te, ee)
}

// 블록에서 단일 expression 추출 (if-expression의 then/else body)
fn extract_block_expr(blk) {
    if blk.kind != "Block" {
        // 블록이 아닌 단일 노드 — If면 IfExpr로 변환
        if blk.kind == "If" { return convert_if_to_expr(blk) }
        return blk
    }
    let stmts = blk.args
    if len(stmts) == 0 { return empty() }
    let last = stmts[len(stmts) - 1]
    if last.kind == "ExprStmt" { return last.left }
    if last.kind == "Return" { return last.left }
    if last.kind == "If" { return convert_if_to_expr(last) }
    return last
}

fn parse_primary() {
    let t = p_peek()
    if t.kind == "Try" {
        // try-as-expression: try { expr } catch e { ... }
        p_advance()
        let tb = parse_block()
        p_skip_nl()
        if p_kind() == "Catch" {
            p_advance()
            if p_kind() == "Ident" { p_advance() }
            if p_kind() == "LB" {
                p_advance()
                let mut depth = 1
                while depth > 0 && p_kind() != "EOF" {
                    if p_kind() == "LB" { depth = depth + 1 }
                    if p_kind() == "RB" { depth = depth - 1 }
                    p_advance()
                }
            }
        }
        return extract_block_expr(tb)
    }
    if t.kind == "If" {
        // if-expression: if cond { expr } else { expr }
        p_advance()
        let c = parse_expr()
        let tb = parse_block()
        p_skip_nl()
        let mut eb = empty()
        if p_kind() == "Else" {
            p_advance()
            p_skip_nl()
            eb = parse_block()
        }
        let te = extract_block_expr(tb)
        let ee = extract_block_expr(eb)
        return n_if_expr(c, te, ee)
    }
    if t.kind == "Int" {
        p_advance()
        return n_int(t.value)
    }
    if t.kind == "Float" {
        p_advance()
        return n_float(t.value)
    }
    if t.kind == "Str" {
        p_advance()
        return n_str(t.value)
    }
    if t.kind == "CharLit" {
        p_advance()
        return Node { kind: "CharLit", value: t.value, op: "", left: "", right: "", cond: "", then_b: "", else_b: "", args: [] }
    }
    if t.kind == "True" {
        p_advance()
        return n_bool("true")
    }
    if t.kind == "False" {
        p_advance()
        return n_bool("false")
    }
    if t.kind == "HashLB" {
        // Map literal: #{ "key": val, ... }
        p_advance()
        let mut keys = []
        let mut vals = []
        while p_kind() != "RB" && p_kind() != "EOF" {
            let key = parse_expr()
            if p_kind() == "Colon" { p_advance() }
            let val = parse_expr()
            keys = keys.push(key)
            vals = vals.push(val)
            if p_kind() == "Comma" { p_advance() }
            if p_kind() == "NL" { p_advance() }
        }
        if p_kind() == "RB" { p_advance() }
        // Interleave keys and vals into args: [k1, v1, k2, v2, ...]
        let mut pairs = []
        let mut pi = 0
        while pi < len(keys) {
            pairs = pairs.push(keys[pi])
            pairs = pairs.push(vals[pi])
            pi = pi + 1
        }
        return Node { kind: "MapLit", value: "", op: "", left: "", right: "", cond: "", then_b: "", else_b: "", args: pairs }
    }
    if t.kind == "Bang" {
        p_advance()
        return n_unary("!", parse_primary())
    }
    if t.kind == "Minus" {
        p_advance()
        return n_unary("-", parse_primary())
    }
    if t.kind == "Ident" {
        p_advance()
        // Name::Variant → 네임스페이스 skip, Variant만 사용
        if p_kind() == "ColonColon" {
            p_advance()
            if p_kind() == "Ident" {
                let v = p_advance()
                let mut node = n_ident(v.value)
                // 뒤에 (args)면 호출
                if p_kind() == "LP" {
                    p_advance()
                    p_skip_nl()
                    let mut call_args = []
                    if p_kind() != "RP" {
                        call_args = call_args.push(parse_expr())
                        p_skip_nl()
                        while p_eat("Comma") {
                            p_skip_nl()
                            if p_kind() == "RP" { break }
                            call_args = call_args.push(parse_expr())
                            p_skip_nl()
                        }
                    }
                    p_eat("RP")
                    node = n_call(n_ident(v.value), call_args)
                }
                return node
            }
        }
        let mut node = n_ident(t.value)
        // struct 리터럴: Ident { field: val, ... }
        // (블록과 구분: 다음이 LB이고, 그 다음이 Ident: 값 패턴)
        if p_kind() == "LB" && struct_field_index(t.value, "") >= -10 && len(struct_lookup_fields(t.value)) > 0 {
            p_advance() // {
            p_skip_nl()
            let mut vals = []
            while p_kind() != "RB" && p_kind() != "EOF" {
                let _fname = p_advance().value
                p_eat("Colon")
                vals = vals.push(parse_expr())
                if p_kind() == "Comma" { p_advance() }
                p_skip_nl()
            }
            p_eat("RB")
            node = n_structlit(t.value, vals)
        } else if p_kind() == "LP" {
            p_advance()
            p_skip_nl()
            let mut call_args = []
            if p_kind() != "RP" {
                call_args = call_args.push(parse_expr())
                p_skip_nl()
                while p_eat("Comma") {
                    p_skip_nl()
                    if p_kind() == "RP" { break }
                    call_args = call_args.push(parse_expr())
                    p_skip_nl()
                }
            }
            p_eat("RP")
            node = n_call(n_ident(t.value), call_args)
        }
        // postfix [idx] 또는 .field
        let mut cont = true
        while cont {
            if p_kind() == "LSq" {
                p_advance()
                let idx = parse_expr()
                p_eat("RSq")
                node = n_index(node, idx)
            } else if p_kind() == "Dot" {
                p_advance()
                let fname = p_advance().value
                if p_kind() == "LP" {
                    p_advance()
                    p_skip_nl()
                    let mut m_args = []
                    if p_kind() != "RP" {
                        m_args = m_args.push(parse_expr())
                        p_skip_nl()
                        while p_eat("Comma") {
                            p_skip_nl()
                            if p_kind() == "RP" { break }
                            m_args = m_args.push(parse_expr())
                            p_skip_nl()
                        }
                    }
                    p_eat("RP")
                    node = n_method(node, fname, m_args)
                } else {
                    node = n_field(node, fname)
                }
            } else {
                cont = false
            }
        }
        return node
    }
    if t.kind == "LP" {
        p_advance()
        let e = parse_expr()
        p_eat("RP")
        return e
    }
    if t.kind == "LSq" {
        p_advance()
        p_skip_nl()
        let mut elems = []
        if p_kind() != "RSq" {
            elems = elems.push(parse_expr())
            p_skip_nl()
            while p_eat("Comma") {
                p_skip_nl()
                if p_kind() == "RSq" { break }
                elems = elems.push(parse_expr())
                p_skip_nl()
            }
        }
        p_eat("RSq")
        return n_arrlit(elems)
    }
    let ek = t.kind
    let ev = t.value
    println("parse error: unexpected kind=" + ek + " val=" + ev)
    p_advance()
    return empty()
}

fn parse_mul() {
    let mut left = parse_primary()
    while p_kind() == "Star" || p_kind() == "Slash" || p_kind() == "Percent" {
        let op = p_advance().value
        let right = parse_primary()
        left = n_bin(op, left, right)
    }
    return left
}

fn parse_add() {
    let mut left = parse_mul()
    while p_kind() == "Plus" || p_kind() == "Minus" {
        // `->` 가드 — Minus 뒤가 GT이면 이항 연산 아님 (match arrow 또는 fn return type)
        if p_kind() == "Minus" && p_toks[p_pos + 1].kind == "GT" {
            return left
        }
        let op = p_advance().value
        let right = parse_mul()
        left = n_bin(op, left, right)
    }
    return left
}

fn parse_cmp() {
    let mut left = parse_add()
    while p_kind() == "EqEq" || p_kind() == "NotEq" || p_kind() == "LT" || p_kind() == "LE" || p_kind() == "GT" || p_kind() == "GE" {
        let op = p_advance().value
        let right = parse_add()
        left = n_bin(op, left, right)
    }
    return left
}

fn parse_and() {
    let mut left = parse_cmp()
    while p_kind() == "AndAnd" {
        p_advance()
        let right = parse_cmp()
        left = n_bin("&&", left, right)
    }
    return left
}

fn parse_or() {
    let mut left = parse_and()
    while p_kind() == "OrOr" {
        p_advance()
        let right = parse_and()
        left = n_bin("||", left, right)
    }
    return left
}

fn parse_expr() { return parse_or() }

fn parse_block() {
    p_eat("LB")
    p_skip_nl()
    let mut stmts = []
    while p_kind() != "RB" && p_kind() != "EOF" {
        stmts = stmts.push(parse_stmt())
        p_skip_nl()
    }
    p_eat("RB")
    return n_block(stmts)
}

fn parse_if() {
    p_eat("If")
    let c = parse_expr()
    let t = parse_block()
    p_skip_nl()
    let mut e = empty()
    if p_kind() == "Else" {
        p_advance()
        p_skip_nl()
        // else if 지원: else 다음이 If면 재귀, 아니면 블록.
        if p_kind() == "If" {
            // 체인을 단일-stmt 블록으로 감싸 emit_stmt가 처리
            let inner = parse_if()
            let mut stmts = []
            stmts = stmts.push(inner)
            e = n_block(stmts)
        } else {
            e = parse_block()
        }
    }
    return n_if(c, t, e)
}

fn parse_while() {
    p_eat("While")
    let c = parse_expr()
    let b = parse_block()
    return n_while(c, b)
}

fn parse_match() {
    // match expr {
    //     pattern1 => stmt_or_block
    //     pattern2 => stmt_or_block
    //     _ => stmt_or_block
    // }
    // → if (tmp == p1) { ... } else if (tmp == p2) { ... } else { ... }
    // subject expr는 임시 변수에 할당
    p_eat("Match")
    let subj = parse_expr()
    p_eat("LB")
    p_skip_nl()
    let mut patterns = []
    let mut bodies = []
    let mut has_default = false
    let mut default_body = empty()
    while p_kind() != "RB" && p_kind() != "EOF" {
        let pat = parse_expr()
        // arrow: => 또는 ->
        if p_kind() == "FatArrow" {
            p_advance()
        } else if p_kind() == "Minus" && p_toks[p_pos + 1].kind == "GT" {
            p_advance()
            p_advance()
        }
        // body: block 또는 단일 stmt (return 포함)
        let mut body = empty()
        if p_kind() == "LB" {
            body = parse_block()
        } else {
            let st = parse_stmt()
            let mut stmts = []
            stmts = stmts.push(st)
            body = n_block(stmts)
        }
        // wildcard _ → default
        if pat.kind == "Ident" && pat.value == "_" {
            has_default = true
            default_body = body
        } else {
            patterns = patterns.push(pat)
            bodies = bodies.push(body)
        }
        if p_kind() == "Comma" { p_advance() }
        p_skip_nl()
    }
    p_eat("RB")
    // desugar from the end
    let mut tail = default_body
    if !has_default {
        tail = empty()  // 빈 else
    }
    let mut k = len(patterns) - 1
    while k >= 0 {
        let cond = n_bin("==", subj, patterns[k])
        tail = n_if(cond, bodies[k], tail)
        k = k - 1
    }
    return tail
}

fn parse_for() {
    p_eat("For")
    let var_name = p_advance().value
    p_eat("In")
    let first = parse_expr()
    // range `lo..hi` OR array iteration `for v in arr`
    if p_kind() == "DotDot" {
        p_advance()
        let hi = parse_expr()
        let b = parse_block()
        return n_for_range(var_name, first, hi, b)
    }
    // for v in arr → while 루프 desugar
    // let mut __fi = 0; while __fi < len(arr) { let v = arr[__fi]; ...; __fi += 1 }
    let body = parse_block()
    // idx 변수 — 고유 카운터로 중복 피함
    for_in_counter = for_in_counter + 1
    let idx_name = "__fi_" + var_name + "_" + to_string(for_in_counter)
    // let v = arr[__fi]
    let idx_let = n_let(var_name, n_index(n_ident(idx_name), n_ident(idx_name)))
    // 재구성: arr의 Ident로 index
    let arr_index = n_index(first, n_ident(idx_name))
    let idx_let2 = n_let(var_name, arr_index)
    // inc: __fi = __fi + 1
    let inc_stmt = n_assign(idx_name, n_bin("+", n_ident(idx_name), n_int("1")))
    // while 본문 = [idx_let2, ...body.args, inc_stmt]
    let mut new_stmts = []
    new_stmts = new_stmts.push(idx_let2)
    let mut i = 0
    while i < len(body.args) {
        new_stmts = new_stmts.push(body.args[i])
        i = i + 1
    }
    new_stmts = new_stmts.push(inc_stmt)
    let new_block = n_block(new_stmts)
    // while __fi < len(arr) { ... }
    let len_call = n_call(n_ident("len"), [first])
    let cond = n_bin("<", n_ident(idx_name), len_call)
    let while_stmt = n_while(cond, new_block)
    // 전체를 Block으로 감싸: let mut __fi = 0; while ...
    let init_let = n_let(idx_name, n_int("0"))
    let mut wrap = []
    wrap = wrap.push(init_let)
    wrap = wrap.push(while_stmt)
    return n_block(wrap)
}

fn parse_struct() {
    p_eat("Struct")
    let name = p_advance().value
    p_eat("LB")
    p_skip_nl()
    let mut fields = []
    while p_kind() != "RB" && p_kind() != "EOF" {
        if p_kind() == "Ident" {
            let fname = p_advance().value
            fields = fields.push(fname)
            // 옵션 타입 어노테이션: `: type` 무시
            if p_kind() == "Colon" {
                p_advance()
                // 타입 토큰 1개 (Ident) 소비
                if p_kind() == "Ident" { p_advance() }
            }
            if p_kind() == "Comma" { p_advance() }
            p_skip_nl()
        } else {
            // 알 수 없는 토큰: 강제 진행 (무한 루프 방지)
            p_advance()
        }
    }
    p_eat("RB")
    struct_register(name, fields)
    return n_structdecl(name, fields)
}

fn type_word_to_hexa(w) {
    if w == "f64" { return "Float" }
    if w == "f32" { return "Float" }
    if w == "float" { return "Float" }
    if w == "double" { return "Float" }
    if w == "string" { return "Str" }
    if w == "str" { return "Str" }
    // list/array는 원소 타입 불명 — body 기반 추론에 맡김
    if w == "list" { return "" }
    if w == "array" { return "" }
    return "Int"
}

// 블록의 마지막 stmt를 implicit return으로 변환 (fn tail position)
// ExprStmt → Return, If → 재귀 (then/else 모두), Block → 재귀
fn make_tail_return(stmt) {
    if stmt.kind == "ExprStmt" {
        return n_return(stmt.left)
    }
    if stmt.kind == "If" {
        let new_then = make_tail_return_block(stmt.then_b)
        let new_else = make_tail_return_block(stmt.else_b)
        return n_if(stmt.cond, new_then, new_else)
    }
    if stmt.kind == "Block" {
        return make_tail_return_block(stmt)
    }
    return stmt
}
fn make_tail_return_block(blk) {
    // If가 else로 들어온 경우에도 변환 (match desugar nested if)
    if blk.kind == "If" {
        return make_tail_return(blk)
    }
    if blk.kind != "Block" { return blk }
    let stmts = blk.args
    let n = len(stmts)
    if n == 0 { return blk }
    let mut new_stmts = []
    let mut i = 0
    while i < n - 1 {
        new_stmts = new_stmts.push(stmts[i])
        i = i + 1
    }
    new_stmts = new_stmts.push(make_tail_return(stmts[n - 1]))
    return n_block(new_stmts)
}

// Parse `extern fn NAME(p: T, ...) -> RET` — no body.
// Attributes stacked in pending_attrs (e.g. @link("libname")) are consumed.
// Returns a node with kind "ExternFn" that the codegen maps to a C
// `extern RET NAME(PARAMS);` declaration and harvests @link targets.
fn parse_extern_fn() {
    p_eat("Extern")
    p_eat("Fn")
    let name = p_advance().value
    p_eat("LP")
    // Encode each param as "name:type" strings in args[], so the codegen
    // can read both name and type from a single node field.
    let mut params = []
    if p_kind() != "RP" {
        let pn = p_advance().value
        let mut pt = "int"
        if p_kind() == "Colon" {
            p_advance()
            if p_kind() == "Star" {
                p_advance()
                if p_kind() == "Ident" {
                    pt = "ptr_" + p_advance().value
                }
            } else if p_kind() == "Ident" {
                pt = p_advance().value
            }
        }
        params = params.push(pn + ":" + pt)
        while p_eat("Comma") {
            let pn2 = p_advance().value
            let mut pt2 = "int"
            if p_kind() == "Colon" {
                p_advance()
                if p_kind() == "Star" {
                    p_advance()
                    if p_kind() == "Ident" {
                        pt2 = "ptr_" + p_advance().value
                    }
                } else if p_kind() == "Ident" {
                    pt2 = p_advance().value
                }
            }
            params = params.push(pn2 + ":" + pt2)
        }
    }
    p_eat("RP")
    let mut ret_annot = "Void"
    if p_kind() == "Minus" && p_toks[p_pos + 1].kind == "GT" {
        p_advance()
        p_advance()
        if p_kind() == "Star" {
            p_advance()
            if p_kind() == "Ident" {
                ret_annot = "ptr_" + p_advance().value
            }
        } else if p_kind() == "Ident" {
            ret_annot = p_advance().value
        }
    }
    let attrs_str = pending_attrs.join(",")
    pending_attrs = []
    return Node {
        kind: "ExternFn",
        value: name,
        op: attrs_str,
        left: ret_annot,
        right: "",
        cond: "",
        then_b: "",
        else_b: "",
        args: params
    }
}

// Map a hexa extern type token to a C type for extern fn signatures.
// Convention: in extern fn contexts, `int` means C's `int` (32-bit) because
// that's what C APIs like CUDA/libc use for status codes, device ids, etc.
// Use `long` explicitly for 64-bit integer params/returns.
fn extern_type_to_c(t) {
    if t == "float" || t == "Float" { return "float" }
    if t == "double" || t == "Double" { return "double" }
    if t == "int" || t == "Int" { return "int" }
    if t == "long" || t == "Long" || t == "i64" { return "long" }
    if t == "size_t" || t == "usize" { return "size_t" }
    if t == "bool" || t == "Bool" { return "int" }
    // Pointer-to-Void / any struct → void*
    if t == "ptr_Void" || t == "ptr_void" { return "void*" }
    if t.substring(0, 4) == "ptr_" { return "void*" }
    if t == "Void" || t == "void" || t == "" { return "void" }
    // Fallback: treat as long (raw 64-bit word, works for ints and pointers)
    return "long"
}

fn parse_fn() {
    p_eat("Fn")
    let name = p_advance().value
    p_eat("LP")
    let mut params = []
    if p_kind() != "RP" {
        let pn = p_advance().value
        params = params.push(pn)
        if p_kind() == "Colon" {
            p_advance()
            if p_kind() == "Ident" {
                let tw = p_advance().value
                let ht = type_word_to_hexa(tw)
                if ht == "Float" { fn_mark_float_param(name, 0) }
                if ht == "Str" { fn_mark_str_param(name, 0) }
            }
        }
        let mut pidx = 1
        while p_eat("Comma") {
            let pn2 = p_advance().value
            params = params.push(pn2)
            if p_kind() == "Colon" {
                p_advance()
                if p_kind() == "Ident" {
                    let tw2 = p_advance().value
                    let ht2 = type_word_to_hexa(tw2)
                    if ht2 == "Float" { fn_mark_float_param(name, pidx) }
                    if ht2 == "Str" { fn_mark_str_param(name, pidx) }
                }
            }
            pidx = pidx + 1
        }
    }
    p_eat("RP")
    let mut ret_annot = ""
    if p_kind() == "Minus" && p_toks[p_pos + 1].kind == "GT" {
        p_advance()
        p_advance()
        if p_kind() == "Ident" {
            ret_annot = p_advance().value
        }
    }
    let raw_body = parse_block()
    let body = make_tail_return_block(raw_body)
    // 반환 타입 어노테이션 honor
    if ret_annot != "" {
        let fields = struct_lookup_fields(ret_annot)
        if len(fields) > 0 {
            fn_register_struct(name, "StructPtr", ret_annot)
        } else {
            let ht = type_word_to_hexa(ret_annot)
            if ht == "Str" || ht == "Float" || ht == "DynArr" {
                fn_register(name, ht)
            }
        }
    }
    return n_fn(name, params, body)
}

fn parse_stmt() {
    p_skip_nl()
    // Attr 누적 (Pure/inline/memoize 등)
    while p_kind() == "Attr" {
        pending_attrs = pending_attrs.push(p_advance().value)
        p_skip_nl()
    }
    let k = p_kind()
    if k == "Let" {
        p_advance()
        if p_kind() == "Mut" { p_advance() }
        let name = p_advance().value
        // 옵션 `: type` skip
        if p_kind() == "Colon" {
            p_advance()
            if p_kind() == "Ident" { p_advance() }
        }
        p_eat("Eq")
        let val = parse_expr()
        return n_let(name, val)
    }
    if k == "Struct" { return parse_struct() }
    if k == "Enum" {
        // enum Name { V1, V2(...), V3 }
        // → top-level에 V1=0, V2=1, ... 상수 등록
        p_advance()
        if p_kind() == "Ident" { p_advance() }  // enum name
        p_eat("LB")
        p_skip_nl()
        let mut idx = 0
        while p_kind() != "RB" && p_kind() != "EOF" {
            if p_kind() == "Ident" {
                let vname = p_advance().value
                // 옵션 페이로드 `(type, ...)` skip
                if p_kind() == "LP" {
                    let mut depth = 1
                    p_advance()
                    while depth > 0 && p_kind() != "EOF" {
                        if p_kind() == "LP" { depth = depth + 1 }
                        if p_kind() == "RP" { depth = depth - 1 }
                        p_advance()
                    }
                }
                // 상수로 글로벌 등록 — top-level Let hoist가 알아서 emit
                // 바로 env에 등록 + out에 넣을 수 있게 top-level Let처럼 반환
                env_set(vname, "Int")
                // idx를 직접 Node로 push 하는 대신, 이 parse_stmt는 StructDecl 비슷한 noop 반환 후
                // emit_program에서 별도 처리? 그건 복잡함.
                // 대신 parse 시점에서 enum_tab에 저장 후 emit_program에서 const 생성.
                enum_tab_names = enum_tab_names.push(vname)
                enum_tab_values = enum_tab_values.push(idx)
            }
            if p_kind() == "Comma" { p_advance() }
            p_skip_nl()
            idx = idx + 1
        }
        p_eat("RB")
        return empty()
    }
    if k == "Fn" { return parse_fn() }
    if k == "Extern" { return parse_extern_fn() }
    if k == "ProofBlock" || k == "TheoremBlock" {
        // 이름 + 블록 소비, 아무것도 emit하지 않음
        p_advance()
        if p_kind() == "Ident" { p_advance() }
        // 블록 { ... } 균형 맞춰 건너뛰기
        if p_kind() == "LB" {
            p_advance()
            let mut depth = 1
            while depth > 0 && p_kind() != "EOF" {
                if p_kind() == "LB" { depth = depth + 1 }
                if p_kind() == "RB" { depth = depth - 1 }
                p_advance()
            }
        }
        return empty()
    }
    if k == "Return" {
        p_advance()
        // bare `return` (다음이 NL/RB/EOF)
        let nk = p_kind()
        if nk == "NL" || nk == "RB" || nk == "EOF" {
            return n_return(empty())
        }
        let e = parse_expr()
        return n_return(e)
    }
    if k == "Break" {
        p_advance()
        return Node { kind: "Break", value: "", op: "", left: "", right: "", cond: "", then_b: "", else_b: "", args: [] }
    }
    if k == "Continue" {
        p_advance()
        return Node { kind: "Continue", value: "", op: "", left: "", right: "", cond: "", then_b: "", else_b: "", args: [] }
    }
    if k == "If" { return parse_if() }
    if k == "While" { return parse_while() }
    if k == "For" { return parse_for() }
    if k == "Match" { return parse_match() }
    if k == "Assert" {
        p_advance()
        let e = parse_expr()
        return Node { kind: "Assert", value: "", op: "", left: e, right: "", cond: "", then_b: "", else_b: "", args: [] }
    }
    if k == "Try" {
        p_advance()
        let tb = parse_block()
        p_skip_nl()
        if p_kind() == "Catch" {
            p_advance()
            if p_kind() == "Ident" { p_advance() }  // catch 변수
            // catch 블록 skip
            if p_kind() == "LB" {
                p_advance()
                let mut depth = 1
                while depth > 0 && p_kind() != "EOF" {
                    if p_kind() == "LB" { depth = depth + 1 }
                    if p_kind() == "RB" { depth = depth - 1 }
                    p_advance()
                }
            }
        }
        return tb
    }
    // 식별자로 시작 → 할당, 복합할당, Index 할당, 또는 식
    if k == "Ident" {
        let next_k = p_toks[p_pos + 1].kind
        if next_k == "Eq" {
            let name = p_advance().value
            p_advance()
            let val = parse_expr()
            return n_assign(name, val)
        }
        // Index 할당: name[idx] = val 또는 name[idx] += val
        if next_k == "LSq" {
            let save_pos = p_pos
            let lhs = parse_primary()
            if lhs.kind == "Index" {
                if p_kind() == "Eq" {
                    p_advance()
                    let val = parse_expr()
                    return Node { kind: "IndexAssign", value: "", op: "", left: lhs.left, right: lhs.right, cond: "", then_b: "", else_b: "", args: [val] }
                }
                // 복합 할당: arr[i] += v → arr[i] = arr[i] + v
                if p_kind() == "PlusEq" || p_kind() == "MinusEq" || p_kind() == "StarEq" || p_kind() == "SlashEq" {
                    let op_tok = p_advance()
                    let rhs = parse_expr()
                    let bin_op = op_tok.value.substring(0, 1)
                    let new_rhs = n_bin(bin_op, lhs, rhs)
                    return Node { kind: "IndexAssign", value: "", op: "", left: lhs.left, right: lhs.right, cond: "", then_b: "", else_b: "", args: [new_rhs] }
                }
            }
            p_pos = save_pos
        }
        // 복합할당: x += y  →  x = x + y
        if next_k == "PlusEq" || next_k == "MinusEq" || next_k == "StarEq" || next_k == "SlashEq" {
            let name = p_advance().value
            let op_tok = p_advance()
            let rhs = parse_expr()
            let bin_op = op_tok.value.substring(0, 1)  // "+" "-" "*" "/"
            let new_rhs = n_bin(bin_op, n_ident(name), rhs)
            return n_assign(name, new_rhs)
        }
    }
    let e = parse_expr()
    return n_exprstmt(e)
}

fn parse_program(toks) {
    p_toks = toks
    p_pos = 0
    let mut stmts = []
    p_skip_nl()
    while p_kind() != "EOF" {
        stmts = stmts.push(parse_stmt())
        p_skip_nl()
    }
    return stmts
}

// ══════════════════════════════════════════════════════════════
// 타입 추론 (아주 단순: Int/Str)
// ══════════════════════════════════════════════════════════════
let mut env_names = []
let mut env_types = []
let mut env_lens = []  // 배열/struct length

// struct 테이블: 이름 + 필드명 배열 (parallel arrays)
let mut struct_tab_names = []
let mut struct_tab_fields = []  // 각 원소: 필드명 string 배열

// enum 테이블: variant 이름 + 값 (parallel arrays)
let mut enum_tab_names = []
let mut enum_tab_values = []

// fn 테이블: 이름 + 반환 타입 (Int/Str/Float/DynArr/StructPtr)
let mut fn_tab_names = []
let mut fn_tab_rets = []
let mut fn_tab_struct = []  // StructPtr일 때 실제 struct 이름 ("" = unknown)
// 매개변수 Float/Str 힌트: 이름+인덱스 조합으로 추적 ("fnname/0" 등)
let mut fn_float_params = []
let mut fn_str_params = []

// ── TIER 1 perf: O(1) 64-bucket char-sum hash caches ──────────
// Mirrors type_checker.hexa tc_fn_cache / tc_scope_cache (commits
// 73386ae, 4f8e630f). build_c.hexa has 6 quadratic lookup fns over
// 5 growing module-level lists. Pattern: hash→bucket→idx lookup,
// defensive linear fallback per-call (not just on uninitialized).
// All caches are lazily initialized in emit_program().
//   bc_fn_cache         — fn_tab_names (for fn_lookup_ret + _struct)
//   bc_fn_float_cache   — fn_float_params (set membership)
//   bc_fn_str_cache     — fn_str_params (set membership)
//   bc_str_arr_cache    — str_arr_promoted (set membership)
//   bc_float_var_cache  — float_vars (set membership)
//   bc_env_cache        — env_names (stack w/ shadowing; newest-idx-wins)
let mut bc_fn_cache = []
let mut bc_fn_float_cache = []
let mut bc_fn_str_cache = []
let mut bc_str_arr_cache = []
let mut bc_float_var_cache = []
let mut bc_env_cache = []

fn bc_hash(name) {
    let mut h = 0
    let mut i = 0
    let n = len(name)
    while i < n {
        h = h + char_code(name, i)
        i = i + 1
    }
    while h < 0 {
        h = h + 64
    }
    return h % 64
}
fn bc_empty64() {
    let mut b = []
    let mut i = 0
    while i < 64 {
        b = b.push([])
        i = i + 1
    }
    return b
}
fn bc_caches_init() {
    bc_fn_cache = bc_empty64()
    // VB3 fix (2026-04-11): bc_fn_float_cache / bc_fn_str_cache are
    // populated during parse_fn via fn_mark_{float,str}_param() from
    // the `: type` annotations. Resetting them here (called at the top
    // of emit_program) wiped every parse-time annotation before
    // emit_fn_decl could read it, so fn_param_is_str() short-circuited
    // to false even though fn_str_params still held the key. Both
    // caches are lazy-initialized by their _add helpers, so no reset
    // is required. Keeping them in sync with the persistent lists.
    bc_str_arr_cache = bc_empty64()
    bc_float_var_cache = bc_empty64()
    bc_env_cache = bc_empty64()
}

// --- fn_tab cache ---
fn bc_fn_cache_add(name, idx) {
    if len(bc_fn_cache) != 64 { bc_fn_cache = bc_empty64() }
    let b = bc_hash(name)
    bc_fn_cache[b] = bc_fn_cache[b].push([name, idx])
}
fn bc_fn_cache_lookup(name) {
    if len(bc_fn_cache) != 64 { return -1 }
    let bucket = bc_fn_cache[bc_hash(name)]
    let mut best = -1
    let mut bi = 0
    let bn = len(bucket)
    while bi < bn {
        let e = bucket[bi]
        if e[0] == name { if e[1] > best { best = e[1] } }
        bi = bi + 1
    }
    return best
}

// --- set-membership caches (bool) ---
fn bc_fn_float_cache_add(key) {
    if len(bc_fn_float_cache) != 64 { bc_fn_float_cache = bc_empty64() }
    let b = bc_hash(key)
    bc_fn_float_cache[b] = bc_fn_float_cache[b].push(key)
}
fn bc_fn_float_cache_has(key) {
    if len(bc_fn_float_cache) != 64 { return false }
    let bucket = bc_fn_float_cache[bc_hash(key)]
    let mut bi = 0
    let bn = len(bucket)
    while bi < bn {
        if bucket[bi] == key { return true }
        bi = bi + 1
    }
    return false
}
fn bc_fn_str_cache_add(key) {
    if len(bc_fn_str_cache) != 64 { bc_fn_str_cache = bc_empty64() }
    let b = bc_hash(key)
    bc_fn_str_cache[b] = bc_fn_str_cache[b].push(key)
}
fn bc_fn_str_cache_has(key) {
    if len(bc_fn_str_cache) != 64 { return false }
    let bucket = bc_fn_str_cache[bc_hash(key)]
    let mut bi = 0
    let bn = len(bucket)
    while bi < bn {
        if bucket[bi] == key { return true }
        bi = bi + 1
    }
    return false
}
fn bc_str_arr_cache_add(name) {
    if len(bc_str_arr_cache) != 64 { bc_str_arr_cache = bc_empty64() }
    let b = bc_hash(name)
    bc_str_arr_cache[b] = bc_str_arr_cache[b].push(name)
}
fn bc_str_arr_cache_has(name) {
    if len(bc_str_arr_cache) != 64 { return false }
    let bucket = bc_str_arr_cache[bc_hash(name)]
    let mut bi = 0
    let bn = len(bucket)
    while bi < bn {
        if bucket[bi] == name { return true }
        bi = bi + 1
    }
    return false
}
fn bc_float_var_cache_add(name) {
    if len(bc_float_var_cache) != 64 { bc_float_var_cache = bc_empty64() }
    let b = bc_hash(name)
    bc_float_var_cache[b] = bc_float_var_cache[b].push(name)
}
fn bc_float_var_cache_has(name) {
    if len(bc_float_var_cache) != 64 { return false }
    let bucket = bc_float_var_cache[bc_hash(name)]
    let mut bi = 0
    let bn = len(bucket)
    while bi < bn {
        if bucket[bi] == name { return true }
        bi = bi + 1
    }
    return false
}

// --- env cache (stack with shadowing, newest-idx-wins) ---
fn bc_env_cache_add(name, idx) {
    if len(bc_env_cache) != 64 { bc_env_cache = bc_empty64() }
    let b = bc_hash(name)
    bc_env_cache[b] = bc_env_cache[b].push([name, idx])
}
fn bc_env_cache_lookup(name) {
    if len(bc_env_cache) != 64 { return -1 }
    let bucket = bc_env_cache[bc_hash(name)]
    let mut best = -1
    let mut bi = 0
    let bn = len(bucket)
    while bi < bn {
        let e = bucket[bi]
        if e[0] == name { if e[1] > best { best = e[1] } }
        bi = bi + 1
    }
    return best
}

fn fn_register(name, ret_type) {
    let idx = len(fn_tab_names)
    fn_tab_names = fn_tab_names.push(name)
    fn_tab_rets = fn_tab_rets.push(ret_type)
    fn_tab_struct = fn_tab_struct.push("")
    bc_fn_cache_add(name, idx)
}
fn fn_register_struct(name, ret_type, struct_name) {
    let idx = len(fn_tab_names)
    fn_tab_names = fn_tab_names.push(name)
    fn_tab_rets = fn_tab_rets.push(ret_type)
    fn_tab_struct = fn_tab_struct.push(struct_name)
    bc_fn_cache_add(name, idx)
}
fn fn_lookup_ret(name) {
    let idx = bc_fn_cache_lookup(name)
    if idx >= 0 { return fn_tab_rets[idx] }
    let mut i = 0
    while i < len(fn_tab_names) {
        if fn_tab_names[i] == name { return fn_tab_rets[i] }
        i = i + 1
    }
    return "Int"
}
fn fn_lookup_struct(name) {
    let idx = bc_fn_cache_lookup(name)
    if idx >= 0 { return fn_tab_struct[idx] }
    let mut i = 0
    while i < len(fn_tab_names) {
        if fn_tab_names[i] == name { return fn_tab_struct[i] }
        i = i + 1
    }
    return ""
}

fn enum_lookup_value(name) {
    let mut i = 0
    while i < len(enum_tab_names) {
        if enum_tab_names[i] == name { return enum_tab_values[i] }
        i = i + 1
    }
    return -1
}
fn enum_is_variant(name) {
    let mut i = 0
    while i < len(enum_tab_names) {
        if enum_tab_names[i] == name { return true }
        i = i + 1
    }
    return false
}
fn fn_mark_float_param(name, idx) {
    let key = name + "/" + to_string(idx)
    if bc_fn_float_cache_has(key) { return }
    // Defensive linear scan (in case cache is uninitialized)
    let mut i = 0
    while i < len(fn_float_params) {
        if fn_float_params[i] == key { return }
        i = i + 1
    }
    fn_float_params = fn_float_params.push(key)
    bc_fn_float_cache_add(key)
}
fn fn_param_is_float(name, idx) {
    let key = name + "/" + to_string(idx)
    if bc_fn_float_cache_has(key) { return true }
    if len(bc_fn_float_cache) == 64 { return false }
    let mut i = 0
    while i < len(fn_float_params) {
        if fn_float_params[i] == key { return true }
        i = i + 1
    }
    return false
}
fn fn_mark_str_param(name, idx) {
    let key = name + "/" + to_string(idx)
    if bc_fn_str_cache_has(key) { return }
    let mut i = 0
    while i < len(fn_str_params) {
        if fn_str_params[i] == key { return }
        i = i + 1
    }
    fn_str_params = fn_str_params.push(key)
    bc_fn_str_cache_add(key)
}
fn fn_param_is_str(name, idx) {
    let key = name + "/" + to_string(idx)
    if bc_fn_str_cache_has(key) { return true }
    if len(bc_fn_str_cache) == 64 { return false }
    let mut i = 0
    while i < len(fn_str_params) {
        if fn_str_params[i] == key { return true }
        i = i + 1
    }
    return false
}

fn struct_register(name, fields) {
    struct_tab_names = struct_tab_names.push(name)
    struct_tab_fields = struct_tab_fields.push(fields)
}
fn struct_lookup_fields(name) {
    let mut i = 0
    while i < len(struct_tab_names) {
        if struct_tab_names[i] == name { return struct_tab_fields[i] }
        i = i + 1
    }
    return []
}
fn struct_field_index(struct_name, field_name) {
    let fields = struct_lookup_fields(struct_name)
    let mut i = 0
    while i < len(fields) {
        if fields[i] == field_name { return i }
        i = i + 1
    }
    return -1
}
// struct 이름 모를 때 등록된 모든 struct에서 field_name 검색 (첫 매치 반환)
fn struct_field_index_global(field_name) {
    let mut si = 0
    while si < len(struct_tab_names) {
        let fields = struct_tab_fields[si]
        let mut fi = 0
        while fi < len(fields) {
            if fields[fi] == field_name { return fi }
            fi = fi + 1
        }
        si = si + 1
    }
    return -1
}

fn env_lookup(name) {
    // O(1) avg: hash bucket, newest-idx-wins (shadowing). Defensive
    // linear fallback on miss in case a direct env_names.push bypassed
    // the cache add (see 7 call sites across emit_stmt / emit_fn_decl
    // / emit_program). The fallback mirrors the original "scan from
    // end" semantics exactly.
    let idx = bc_env_cache_lookup(name)
    if idx >= 0 { return env_types[idx] }
    let mut i = len(env_names) - 1
    while i >= 0 {
        if env_names[i] == name { return env_types[i] }
        i = i - 1
    }
    return "Int"
}
fn env_lookup_len(name) {
    let idx = bc_env_cache_lookup(name)
    if idx >= 0 { return env_lens[idx] }
    let mut i = len(env_names) - 1
    while i >= 0 {
        if env_names[i] == name { return env_lens[i] }
        i = i - 1
    }
    return -1
}
fn env_set(name, ty) {
    let idx = len(env_names)
    env_names = env_names.push(name)
    env_types = env_types.push(ty)
    env_lens = env_lens.push(-1)
    bc_env_cache_add(name, idx)
}
fn env_set_arr(name, alen) {
    let idx = len(env_names)
    env_names = env_names.push(name)
    env_types = env_types.push("Arr")
    env_lens = env_lens.push(alen)
    bc_env_cache_add(name, idx)
}
fn env_set_struct(name, struct_name) {
    let idx = len(env_names)
    env_names = env_names.push(name)
    env_types = env_types.push(struct_name)  // "Point" 등
    let fields = struct_lookup_fields(struct_name)
    env_lens = env_lens.push(len(fields))
    bc_env_cache_add(name, idx)
}

fn type_of(node) {
    if node.kind == "Int" { return "Int" }
    if node.kind == "Float" { return "Float" }
    if node.kind == "Str" { return "Str" }
    if node.kind == "Bool" { return "Int" }
    if node.kind == "CharLit" { return "Int" }
    if node.kind == "MapLit" { return "Map" }
    if node.kind == "Ident" { return env_lookup(node.value) }
    if node.kind == "Bin" {
        let lt = type_of(node.left)
        let rt = type_of(node.right)
        if node.op == "+" && (lt == "Str" || rt == "Str") { return "Str" }
        if node.op == "+" && (lt == "DynArr" || rt == "DynArr") { return "DynArr" }
        if node.op == "+" && (lt == "StrArr" || rt == "StrArr") { return "StrArr" }
        if lt == "Float" || rt == "Float" { return "Float" }
        return "Int"
    }
    if node.kind == "Unary" { return type_of(node.left) }
    if node.kind == "IfExpr" {
        let tt = type_of(node.left)
        if tt == "" || tt == "Int" { return type_of(node.right) }
        return tt
    }
    if node.kind == "Call" {
        let cl = node.left
        if cl.kind == "Ident" {
            if cl.value == "read_file" { return "Str" }
            if cl.value == "to_string" { return "Str" }
            if cl.value == "str" { return "Str" }
            if cl.value == "deref_f32" { return "Float" }
            if cl.value == "to_float" { return "Float" }
            if cl.value == "args" { return "StrArr" }
            if cl.value == "arg" { return "Str" }
            if cl.value == "argc" { return "Int" }
            if cl.value == "exec" { return "Str" }
            if cl.value == "exec_with_status" { return "Str" }
            if cl.value == "shell" { return "Str" }
            if cl.value == "read_stdin" { return "Str" }
            if cl.value == "append_file" { return "Int" }
            if cl.value == "delete_file" { return "Int" }
            if cl.value == "env_var" { return "Str" }
            if cl.value == "format" { return "Str" }
            if cl.value == "array_fill" { return "DynArr" }
            if cl.value == "http_serve" { return "Int" }
            if cl.value == "http_get" { return "Str" }
            if cl.value == "mem_stats" { return "Str" }
            if cl.value == "to_float" { return "Float" }
            if cl.value == "env" { return "Str" }
            if cl.value == "to_int" { return "Int" }
            if cl.value == "file_exists" { return "Int" }
            if cl.value == "dir_exists" { return "Int" }
            if cl.value == "mkdir" { return "Int" }
            if cl.value == "list_dir" { return "DynArr" }
            if cl.value == "time" { return "Int" }
            if cl.value == "time_unix" { return "Int" }
            if cl.value == "timestamp" { return "Str" }
            if cl.value == "contains" { return "Int" }
            if cl.value == "count_occurrences" { return "Int" }
            if cl.value == "starts_with" { return "Int" }
            if cl.value == "ends_with" { return "Int" }
            if cl.value == "index_of" { return "Int" }
            if cl.value == "trim" { return "Str" }
            if cl.value == "clock" { return "Float" }
            if cl.value == "sqrt" { return "Float" }
            if cl.value == "pow" { return "Float" }
            if cl.value == "sin" { return "Float" }
            if cl.value == "cos" { return "Float" }
            if cl.value == "tan" { return "Float" }
            if cl.value == "log" { return "Float" }
            if cl.value == "log10" { return "Float" }
            if cl.value == "exp" { return "Float" }
            if cl.value == "floor" { return "Float" }
            if cl.value == "ceil" { return "Float" }
            if cl.value == "round" { return "Float" }
            if cl.value == "abs" {
                let t = type_of(node.args[0])
                if t == "Float" { return "Float" }
                return "Int"
            }
            if cl.value == "min" || cl.value == "max" {
                let t1 = type_of(node.args[0])
                if t1 == "Float" { return "Float" }
                return "Int"
            }
            // 사용자 함수 lookup
            return fn_lookup_ret(cl.value)
        }
        return "Int"
    }
    if node.kind == "StructLit" { return node.value }
    if node.kind == "ArrLit" {
        if len(node.args) > 0 && type_of(node.args[0]) == "Str" { return "StrArr" }
        return "DynArr"
    }
    if node.kind == "Field" { return "Int" }
    if node.kind == "Index" {
        let o = node.left
        if o.kind == "Ident" && env_lookup(o.value) == "StrArr" { return "Str" }
        // Index on an expression whose type is StrArr (예: split() 결과)
        let ot = type_of(o)
        if ot == "StrArr" { return "Str" }
        return "Int"
    }
    if node.kind == "Method" {
        if node.value == "substring" { return "Str" }
        if node.value == "slice" { return "Str" }
        if node.value == "len" { return "Int" }
        if node.value == "push" { return "DynArr" }
        if node.value == "chars" { return "DynArr" }
        if node.value == "split" { return "StrArr" }
        if node.value == "trim" { return "Str" }
        if node.value == "to_upper" { return "Str" }
        if node.value == "to_lower" { return "Str" }
        if node.value == "replace" { return "Str" }
        return "Int"
    }
    return "Int"
}

// ══════════════════════════════════════════════════════════════
// C 코드젠
// ══════════════════════════════════════════════════════════════

fn coerce_str(node, t) {
    // bt 54: Str 인자는 (const char*) 캐스트로 long→ptr 변환 경고 차단.
    // pointer runtime에서 모든 값이 `long`으로 흘러오므로 리터럴이 아닌 한
    // 호출측에서 명시적 캐스트가 필수 (Apple clang 17 fatal).
    if t == "Str" { return "((const char*)(" + emit_expr(node) + "))" }
    if t == "Float" { return "hexa_float_to_str((double)(" + emit_expr(node) + "))" }
    return "hexa_int_to_str((long)(" + emit_expr(node) + "))"
}

// bt 54: 문자열을 기대하는 C 런타임 호출에 쓸 공통 캐스트 헬퍼.
// 모든 HEXA 값이 `long` 슬롯으로 통일되어 있어 strcmp/strstr 등은
// 인자를 const char* 로 명시 캐스트하지 않으면 clang 17이 fatal error.
fn emit_str_arg(node) {
    return "((const char*)(" + emit_expr(node) + "))"
}

fn emit_print(pl_args, newline) {
    let mut fmt = ""
    let mut vals = ""
    let mut i = 0
    while i < len(pl_args) {
        if i > 0 { fmt = fmt + " " }
        let a = pl_args[i]
        let t = type_of(a)
        if t == "Str" {
            fmt = fmt + "%s"
        } else if t == "Float" {
            fmt = fmt + "%g"
        } else if t == "DynArr" || t == "StrArr" {
            fmt = fmt + "[arr len=%ld]"
        } else {
            fmt = fmt + "%ld"
        }
        if len(vals) > 0 { vals = vals + ", " }
        if t == "Str" {
            // bt 54: printf %s 에 long→const char* 캐스트 강제
            vals = vals + "((const char*)(" + emit_expr(a) + "))"
        } else if t == "Float" {
            vals = vals + "(double)(" + emit_expr(a) + ")"
        } else if t == "DynArr" || t == "StrArr" {
            vals = vals + "(long)(_AN(" + emit_expr(a) + "))"
        } else {
            vals = vals + "(long)(" + emit_expr(a) + ")"
        }
        i = i + 1
    }
    if newline == 1 {
        fmt = fmt + "\\n"
    }
    if len(pl_args) == 0 {
        if newline == 1 { return "printf(\"\\n\")" }
        return "printf(\"\")"
    }
    return "printf(\"" + fmt + "\", " + vals + ")"
}

fn emit_expr(node) {
    if node.kind == "Int" { return node.value }
    if node.kind == "Float" { return node.value }
    if node.kind == "Bool" {
        if node.value == "true" { return "1" }
        return "0"
    }
    if node.kind == "Str" {
        // bt 54: C11 trigraph 회피 — "??=" 등 `??` 시퀀스는 `?\?`로 escape
        //        (build/interpreter.c 및 hexa_full_regen.c 의 -Wtrigraphs 1건 해소)
        let esc = node.value.replace("??", "?\\?")
        return "\"" + esc + "\""
    }
    if node.kind == "CharLit" {
        let cv = node.value
        if cv == "n" { return "'\\n'" }
        if cv == "t" { return "'\\t'" }
        if cv == "r" { return "'\\r'" }
        if cv == "0" { return "'\\0'" }
        if cv == "\\" { return "'\\\\'" }
        if cv == "'" { return "'\\''" }
        if cv == "\"" { return "'\"'" }
        return "'" + cv + "'"
    }
    if node.kind == "Ident" { return user_var_name(node.value) }
    if node.kind == "Bin" {
        // Str concat 런타임 호출 — bt 52: also detect literal Str on either side
        // (type_of may lose Str-ness through untyped params like `args` — the
        // literal kind check is a belt-and-suspenders guard so that a
        // `"foo" + x` subtree is *always* routed through hexa_concat instead
        // of emitting raw `+` which becomes invalid pointer arithmetic in C.)
        if node.op == "+" {
            let lt = type_of(node.left)
            let rt = type_of(node.right)
            let mut left_is_str = lt == "Str" || node.left.kind == "Str"
            let mut right_is_str = rt == "Str" || node.right.kind == "Str"
            // Also treat inner Bin("+", ...) whose subtree contains a Str
            // literal as Str — guards the `("a" + x) + "b"` left-assoc case.
            if node.left.kind == "Bin" && node.left.op == "+" {
                if node.left.left.kind == "Str" || node.left.right.kind == "Str" {
                    left_is_str = true
                }
            }
            if node.right.kind == "Bin" && node.right.op == "+" {
                if node.right.left.kind == "Str" || node.right.right.kind == "Str" {
                    right_is_str = true
                }
            }
            if left_is_str || right_is_str {
                let mut eff_lt = lt
                if left_is_str && lt != "Str" { eff_lt = "Str" }
                let mut eff_rt = rt
                if right_is_str && rt != "Str" { eff_rt = "Str" }
                let l_code = coerce_str(node.left, eff_lt)
                let r_code = coerce_str(node.right, eff_rt)
                return "hexa_concat(" + l_code + ", " + r_code + ")"
            }
            // 배열 concat (DynArr/StrArr)
            if lt == "DynArr" || lt == "StrArr" || rt == "DynArr" || rt == "StrArr" {
                return "hexa_arr_concat(" + emit_expr(node.left) + ", " + emit_expr(node.right) + ")"
            }
        }
        // Str 비교 연산자 → strcmp (한쪽이라도 Str 리터럴이면 적용)
        if node.op == "==" || node.op == "!=" || node.op == "<" || node.op == "<=" || node.op == ">" || node.op == ">=" {
            let lt = type_of(node.left)
            let rt = type_of(node.right)
            if lt == "Str" || rt == "Str" || node.left.kind == "Str" || node.right.kind == "Str" {
                // bt 54: Ident(long) 인자는 const char* 캐스트 필수
                let cmp = "strcmp(" + emit_str_arg(node.left) + ", " + emit_str_arg(node.right) + ")"
                if node.op == "==" { return "(" + cmp + " == 0)" }
                if node.op == "!=" { return "(" + cmp + " != 0)" }
                return "(" + cmp + " " + node.op + " 0)"
            }
        }
        return "(" + emit_expr(node.left) + " " + node.op + " " + emit_expr(node.right) + ")"
    }
    if node.kind == "Unary" {
        return "(" + node.op + emit_expr(node.left) + ")"
    }
    if node.kind == "IfExpr" {
        return "((" + emit_expr(node.cond) + ") ? (" + emit_expr(node.left) + ") : (" + emit_expr(node.right) + "))"
    }
    if node.kind == "Index" {
        let obj = node.left
        // 중첩 배열 인덱싱: arr[i][j] → _AD(arr.d[i])[j]
        if obj.kind == "Index" {
            let inner = emit_expr(obj)
            return "_AD(" + inner + ")[" + emit_expr(node.right) + "]"
        }
        if obj.kind == "Ident" {
            let t = env_lookup(obj.value)
            let uvn_o = user_var_name(obj.value)
            if t == "DynArr" {
                return "_AD(" + uvn_o + ")[" + emit_expr(node.right) + "]"
            }
            if t == "StrArr" {
                return "((const char*)_AD(" + uvn_o + ")[" + emit_expr(node.right) + "])"
            }
            if t == "Str" {
                // VB3 fix: string indexing returns the unsigned byte value
                // 0..255 so UTF-8 decoders see the correct high bytes instead
                // of sign-extended chars. Without this cast, `s[i]` reads a
                // signed char and breaks any byte-arithmetic decoder.
                return "((long)(unsigned char)" + uvn_o + "[" + emit_expr(node.right) + "])"
            }
        }
        // 식 전체 타입으로 분기 (ex. s.chars()[i] → hexa_arr.d[i])
        let ot = type_of(obj)
        if ot == "DynArr" {
            return "_AD(" + emit_expr(obj) + ")[" + emit_expr(node.right) + "]"
        }
        if ot == "StrArr" {
            return "((const char*)_AD(" + emit_expr(obj) + ")[" + emit_expr(node.right) + "])"
        }
        if ot == "Str" {
            return "((long)(unsigned char)(" + emit_expr(obj) + ")[" + emit_expr(node.right) + "])"
        }
        // fallback: 인덱싱 = 배열 가정 (pointer runtime)
        return "_AD(" + emit_expr(obj) + ")[" + emit_expr(node.right) + "]"
    }
    if node.kind == "Method" {
        let obj_code = emit_expr(node.left)
        // bt 54: 문자열 메서드들은 obj_code가 long이면 clang 17 fatal.
        // 한 번만 const char* 캐스트한 별칭을 만들어 각 helper에 재사용.
        let obj_str = "((const char*)(" + obj_code + "))"
        let mname = node.value
        if mname == "substring" {
            let a = emit_expr(node.args[0])
            let b = emit_expr(node.args[1])
            return "hexa_substr(" + obj_str + ", " + a + ", " + b + ")"
        }
        if mname == "slice" {
            let a = emit_expr(node.args[0])
            if len(node.args) >= 2 {
                let b = emit_expr(node.args[1])
                return "hexa_substr(" + obj_code + ", " + a + ", " + b + ")"
            }
            // 1-arg: start부터 끝까지
            return "hexa_substr(" + obj_str + ", " + a + ", hexa_str_len(" + obj_str + "))"
        }
        if mname == "len" {
            let lo = node.left
            if lo.kind == "Ident" {
                let lt = env_lookup(lo.value)
                if lt == "DynArr" || lt == "StrArr" {
                    return "_AN(" + user_var_name(lo.value) + ")"
                }
            }
            // 일반 타입 분기
            let ot = type_of(node.left)
            if ot == "DynArr" || ot == "StrArr" {
                return "_AN(" + obj_code + ")"
            }
            return "hexa_str_len(" + obj_str + ")"
        }
        if mname == "push" {
            let arg_expr = node.args[0]
            let arg_t = type_of(arg_expr)
            let arg_code = emit_expr(arg_expr)
            if arg_t == "Str" {
                return "hexa_arr_push(" + obj_code + ", (long)(" + arg_code + "))"
            }
            if arg_t == "DynArr" || arg_t == "StrArr" {
                return "hexa_arr_push(" + obj_code + ", " + arg_code + ")"
            }
            // ArrLit → already long (pointer)
            if arg_expr.kind == "ArrLit" {
                return "hexa_arr_push(" + obj_code + ", " + arg_code + ")"
            }
            return "hexa_arr_push(" + obj_code + ", " + arg_code + ")"
        }
        if mname == "chars" {
            return "hexa_chars(" + obj_str + ")"
        }
        if mname == "split" {
            return "hexa_split(" + obj_str + ", " + emit_str_arg(node.args[0]) + ")"
        }
        if mname == "contains" {
            return "hexa_contains(" + obj_str + ", " + emit_str_arg(node.args[0]) + ")"
        }
        if mname == "index_of" {
            return "hexa_index_of(" + obj_str + ", " + emit_str_arg(node.args[0]) + ")"
        }
        if mname == "starts_with" {
            return "hexa_starts_with(" + obj_str + ", " + emit_str_arg(node.args[0]) + ")"
        }
        if mname == "ends_with" {
            return "hexa_ends_with(" + obj_str + ", " + emit_str_arg(node.args[0]) + ")"
        }
        if mname == "trim" {
            return "hexa_trim(" + obj_str + ")"
        }
        if mname == "to_upper" {
            return "hexa_to_upper(" + obj_str + ")"
        }
        if mname == "to_lower" {
            return "hexa_to_lower(" + obj_str + ")"
        }
        if mname == "replace" {
            return "hexa_replace(" + obj_str + ", " + emit_str_arg(node.args[0]) + ", " + emit_str_arg(node.args[1]) + ")"
        }
        return "/* unsupported method ." + mname + " */ 0"
    }
    if node.kind == "Field" {
        // obj.field → ((long*)obj)[idx] — 모든 값 long 통일, 역캐스트
        let obj = node.left
        let mut sname = ""
        if obj.kind == "Ident" {
            sname = env_lookup(obj.value)
            // env에 struct 이름 없으면 lsb (let-struct-bind) 에서 찾기
            if sname == "" || sname == "Int" || sname == "StructPtr" {
                let lsb = lsb_get(obj.value)
                if lsb != "" { sname = lsb }
            }
        }
        if obj.kind == "StructLit" {
            sname = obj.value
        }
        let idx = struct_field_index(sname, node.value)
        if idx >= 0 {
            return "((long*)" + emit_expr(obj) + ")[" + to_string(idx) + "]"
        }
        // struct 이름 모를 때도 등록된 전체 struct에서 필드 검색
        let gidx = struct_field_index_global(node.value)
        if gidx >= 0 {
            return "((long*)" + emit_expr(obj) + ")[" + to_string(gidx) + "]"
        }
        // Map 필드 접근 폴백: node.field → hexa_map_get(node, "field")
        return "hexa_map_get(" + emit_expr(obj) + ", (long)\"" + node.value + "\")"
    }
    if node.kind == "MapLit" {
        // #{ "key": val, ... } → hexa_map_lit((long[]){(long)"key", (long)val, ...}, N)
        let mut s = "hexa_map_lit((long[]){"
        let mut i = 0
        while i < len(node.args) {
            if i > 0 { s = s + ", " }
            s = s + "(long)(" + emit_expr(node.args[i]) + ")"
            i = i + 1
        }
        s = s + "}, " + to_string(len(node.args)) + ")"
        return s
    }
    if node.kind == "StructLit" {
        let mut s = "(long)hexa_struct_alloc((long[]){"
        let mut i = 0
        while i < len(node.args) {
            if i > 0 { s = s + ", " }
            s = s + "(long)(" + emit_expr(node.args[i]) + ")"
            i = i + 1
        }
        s = s + "}, " + to_string(len(node.args)) + ")"
        return s
    }
    if node.kind == "ArrLit" {
        let n_items = len(node.args)
        if n_items == 0 {
            return "hexa_arr_new()"
        }
        let mut s = "hexa_arr_lit((long[]){"
        let mut i = 0
        while i < n_items {
            if i > 0 { s = s + ", " }
            s = s + "(long)(" + emit_expr(node.args[i]) + ")"
            i = i + 1
        }
        s = s + "}, " + to_string(n_items) + ")"
        return s
    }
    if node.kind == "Call" {
        let callee = node.left
        if callee.kind == "Ident" && callee.value == "println" {
            return emit_print(node.args, 1)
        }
        if callee.kind == "Ident" && callee.value == "print" {
            return emit_print(node.args, 0)
        }
        // len(arr): 정적 배열(compile-time) / DynArr / StrArr / 문자열
        if callee.kind == "Ident" && callee.value == "len" {
            if len(node.args) == 1 && node.args[0].kind == "Ident" {
                let vn = node.args[0].value
                let vt = env_lookup(vn)
                if vt == "DynArr" || vt == "StrArr" {
                    return "_AN(" + vn + ")"
                }
                let alen = env_lookup_len(vn)
                if alen >= 0 {
                    return to_string(alen)
                }
            }
            // 타입 불명 → 배열일 가능성 높음 → _AN 우선
            let at = type_of(node.args[0])
            if at == "Str" {
                return "hexa_str_len(" + emit_str_arg(node.args[0]) + ")"
            }
            return "_AN(" + emit_expr(node.args[0]) + ")"
        }
        // 파일 I/O + to_string (bt 54: const char* 캐스트 강제)
        if callee.kind == "Ident" && callee.value == "read_file" {
            return "hexa_read_file(" + emit_str_arg(node.args[0]) + ")"
        }
        if callee.kind == "Ident" && callee.value == "write_file" {
            return "hexa_write_file(" + emit_str_arg(node.args[0]) + ", " + emit_str_arg(node.args[1]) + ")"
        }
        if callee.kind == "Ident" && callee.value == "append_file" {
            return "hexa_append_file(" + emit_str_arg(node.args[0]) + ", " + emit_str_arg(node.args[1]) + ")"
        }
        if callee.kind == "Ident" && callee.value == "delete_file" {
            return "remove(" + emit_str_arg(node.args[0]) + ")"
        }
        if callee.kind == "Ident" && callee.value == "env_var" {
            return "hexa_env(" + emit_str_arg(node.args[0]) + ")"
        }
        if callee.kind == "Ident" && callee.value == "array_fill" {
            return "hexa_arr_fill((long)(" + emit_expr(node.args[0]) + "), (long)(" + emit_expr(node.args[1]) + "))"
        }
        // ── Pointer / raw memory builtins (cuda_ffi and other FFI code) ──
        // These map directly to C stdlib or inline expressions. Pointers are
        // passed through as `long` values (64-bit word) and cast on use.
        if callee.kind == "Ident" && callee.value == "alloc_raw" {
            return "((long)malloc((size_t)(" + emit_expr(node.args[0]) + ")))"
        }
        if callee.kind == "Ident" && callee.value == "free_raw" {
            // free_raw(ptr, size) — size arg is for bookkeeping only
            return "(free((void*)(" + emit_expr(node.args[0]) + ")), 0)"
        }
        if callee.kind == "Ident" && callee.value == "ptr_null" {
            return "((long)0)"
        }
        if callee.kind == "Ident" && callee.value == "ptr_from_int" {
            return "((long)(" + emit_expr(node.args[0]) + "))"
        }
        if callee.kind == "Ident" && callee.value == "ptr_addr" {
            return "((long)(" + emit_expr(node.args[0]) + "))"
        }
        if callee.kind == "Ident" && callee.value == "deref_f32" {
            // deref_f32(ptr, index) → ((float*)ptr)[index] as double
            return "((double)(((float*)(" + emit_expr(node.args[0]) + "))[" + emit_expr(node.args[1]) + "]))"
        }
        if callee.kind == "Ident" && callee.value == "write_f32" {
            // write_f32(ptr, index, value) → ((float*)ptr)[index] = value
            return "(((float*)(" + emit_expr(node.args[0]) + "))[" + emit_expr(node.args[1]) + "] = (float)(" + emit_expr(node.args[2]) + "), 0)"
        }
        if callee.kind == "Ident" && callee.value == "deref_i32" {
            return "((long)(((int*)(" + emit_expr(node.args[0]) + "))[" + emit_expr(node.args[1]) + "]))"
        }
        if callee.kind == "Ident" && callee.value == "write_i32" {
            return "(((int*)(" + emit_expr(node.args[0]) + "))[" + emit_expr(node.args[1]) + "] = (int)(" + emit_expr(node.args[2]) + "), 0)"
        }
        if callee.kind == "Ident" && callee.value == "write_i64" {
            return "(((long*)(" + emit_expr(node.args[0]) + "))[" + emit_expr(node.args[1]) + "] = (long)(" + emit_expr(node.args[2]) + "), 0)"
        }
        if callee.kind == "Ident" && callee.value == "mem_stats" {
            return "\"mem_stats: unavailable\""
        }
        if callee.kind == "Ident" && callee.value == "http_serve" {
            return "(fprintf(stderr, \"http_serve: stub only\\n\"), 0)"
        }
        if callee.kind == "Ident" && callee.value == "http_get" {
            // 동명 CLI 과 분리: builtin 형태 wrapper
            return "hexa_exec(hexa_concat(\"curl -sL --max-time 10 \", " + emit_str_arg(node.args[0]) + "))"
        }
        if callee.kind == "Ident" && callee.value == "format" {
            // format("fmt with {}", args...) — fmt 리터럴일 때만 컴파일 타임 치환
            let fmt_arg = node.args[0]
            if fmt_arg.kind == "Str" {
                let fmt = fmt_arg.value
                // split by "{}" 수동
                let mut parts = []
                let mut cur = ""
                let mut fi = 0
                let fn_len = len(fmt)
                while fi < fn_len {
                    if fi + 1 < fn_len && fmt.substring(fi, fi + 2) == "{}" {
                        parts = parts.push(cur)
                        cur = ""
                        fi = fi + 2
                    } else {
                        cur = cur + fmt.substring(fi, fi + 1)
                        fi = fi + 1
                    }
                }
                parts = parts.push(cur)
                // 조립: parts[0] + arg[1] + parts[1] + arg[2] + ... + parts[N]
                let mut result = "\"" + parts[0] + "\""
                let mut k = 1
                while k < len(parts) {
                    // 다음 arg (index k in node.args)
                    if k < len(node.args) {
                        let a = node.args[k]
                        let at = type_of(a)
                        if at == "Str" {
                            result = "hexa_concat(" + result + ", " + emit_expr(a) + ")"
                        } else if at == "Float" {
                            result = "hexa_concat(" + result + ", hexa_float_to_str((double)(" + emit_expr(a) + ")))"
                        } else {
                            result = "hexa_concat(" + result + ", hexa_int_to_str((long)(" + emit_expr(a) + ")))"
                        }
                    }
                    let part_k = parts[k]
                    if part_k != "" {
                        result = "hexa_concat(" + result + ", \"" + part_k + "\")"
                    }
                    k = k + 1
                }
                return result
            }
            // fmt이 리터럴이 아니면: fmt + args concat (fallback)
            let mut result = emit_expr(fmt_arg)
            let mut i = 1
            while i < len(node.args) {
                let a = node.args[i]
                let at = type_of(a)
                if at == "Str" {
                    result = "hexa_concat(" + result + ", " + emit_expr(a) + ")"
                } else if at == "Float" {
                    result = "hexa_concat(" + result + ", hexa_float_to_str((double)(" + emit_expr(a) + ")))"
                } else {
                    result = "hexa_concat(" + result + ", hexa_int_to_str((long)(" + emit_expr(a) + ")))"
                }
                i = i + 1
            }
            return result
        }
        if callee.kind == "Ident" && callee.value == "type_of" {
            // 런타임 타입 체크 함수 호출
            return "hexa_typeof(" + emit_expr(node.args[0]) + ")"
        }
        if callee.kind == "Ident" && callee.value == "exec" {
            return "hexa_exec(" + emit_str_arg(node.args[0]) + ")"
        }
        if callee.kind == "Ident" && callee.value == "exec_with_status" {
            return "hexa_exec_with_status(" + emit_str_arg(node.args[0]) + ")"
        }
        if callee.kind == "Ident" && callee.value == "shell" {
            return "hexa_exec(" + emit_str_arg(node.args[0]) + ")"
        }
        if callee.kind == "Ident" && callee.value == "read_stdin" {
            return "hexa_read_stdin()"
        }
        if callee.kind == "Ident" && callee.value == "exit" {
            return "exit(" + emit_expr(node.args[0]) + ")"
        }
        if callee.kind == "Ident" && (callee.value == "to_string" || callee.value == "str") {
            let t = type_of(node.args[0])
            if t == "Str" { return emit_expr(node.args[0]) }
            if t == "Float" {
                return "hexa_float_to_str((double)(" + emit_expr(node.args[0]) + "))"
            }
            return "hexa_int_to_str((long)(" + emit_expr(node.args[0]) + "))"
        }
        if callee.kind == "Ident" && callee.value == "is_alpha" {
            return "hexa_is_alpha(" + emit_expr(node.args[0]) + ")"
        }
        if callee.kind == "Ident" && callee.value == "is_alphanumeric" {
            return "hexa_is_alnum(" + emit_expr(node.args[0]) + ")"
        }
        if callee.kind == "Ident" && callee.value == "args" {
            return "hexa_args()"
        }
        if callee.kind == "Ident" && callee.value == "arg" {
            return "hexa_arg(" + emit_expr(node.args[0]) + ")"
        }
        if callee.kind == "Ident" && callee.value == "argc" {
            return "hexa_argc()"
        }
        if callee.kind == "Ident" && callee.value == "time" {
            return "hexa_time_unix()"
        }
        if callee.kind == "Ident" && callee.value == "timestamp" {
            return "hexa_timestamp()"
        }
        if callee.kind == "Ident" && callee.value == "contains" {
            return "hexa_contains(" + emit_str_arg(node.args[0]) + ", " + emit_str_arg(node.args[1]) + ")"
        }
        if callee.kind == "Ident" && callee.value == "count_occurrences" {
            // 단순: haystack의 needle 출현 횟수
            // bt 54: _h/_n 초기화에 const char* 캐스트 강제
            return "({ const char* _h = " + emit_str_arg(node.args[0]) + "; const char* _n = " + emit_str_arg(node.args[1]) + "; long _c = 0; const char* _p = _h; while ((_p = strstr(_p, _n)) != NULL) { _c++; _p += strlen(_n); } _c; })"
        }
        if callee.kind == "Ident" && callee.value == "starts_with" {
            return "hexa_starts_with(" + emit_str_arg(node.args[0]) + ", " + emit_str_arg(node.args[1]) + ")"
        }
        if callee.kind == "Ident" && callee.value == "ends_with" {
            return "hexa_ends_with(" + emit_str_arg(node.args[0]) + ", " + emit_str_arg(node.args[1]) + ")"
        }
        if callee.kind == "Ident" && callee.value == "index_of" {
            return "hexa_index_of(" + emit_str_arg(node.args[0]) + ", " + emit_str_arg(node.args[1]) + ")"
        }
        if callee.kind == "Ident" && callee.value == "trim" {
            return "hexa_trim(" + emit_str_arg(node.args[0]) + ")"
        }
        if callee.kind == "Ident" && callee.value == "time_unix" {
            return "hexa_time_unix()"
        }
        if callee.kind == "Ident" && callee.value == "clock" {
            return "hexa_clock()"
        }
        if callee.kind == "Ident" && callee.value == "sqrt" {
            return "hexa_sqrt((double)(" + emit_expr(node.args[0]) + "))"
        }
        if callee.kind == "Ident" && callee.value == "pow" {
            return "hexa_pow((double)(" + emit_expr(node.args[0]) + "), (double)(" + emit_expr(node.args[1]) + "))"
        }
        if callee.kind == "Ident" && callee.value == "abs" {
            let t = type_of(node.args[0])
            if t == "Float" {
                return "hexa_abs_f(" + emit_expr(node.args[0]) + ")"
            }
            return "hexa_abs_i((long)(" + emit_expr(node.args[0]) + "))"
        }
        if callee.kind == "Ident" && callee.value == "sin" {
            return "hexa_sin((double)(" + emit_expr(node.args[0]) + "))"
        }
        if callee.kind == "Ident" && callee.value == "cos" {
            return "hexa_cos((double)(" + emit_expr(node.args[0]) + "))"
        }
        if callee.kind == "Ident" && callee.value == "tan" {
            return "hexa_tan((double)(" + emit_expr(node.args[0]) + "))"
        }
        if callee.kind == "Ident" && callee.value == "log" {
            return "hexa_log((double)(" + emit_expr(node.args[0]) + "))"
        }
        if callee.kind == "Ident" && callee.value == "log10" {
            return "hexa_log10((double)(" + emit_expr(node.args[0]) + "))"
        }
        if callee.kind == "Ident" && callee.value == "exp" {
            return "hexa_exp((double)(" + emit_expr(node.args[0]) + "))"
        }
        if callee.kind == "Ident" && callee.value == "floor" {
            return "hexa_floor((double)(" + emit_expr(node.args[0]) + "))"
        }
        if callee.kind == "Ident" && callee.value == "ceil" {
            return "hexa_ceil((double)(" + emit_expr(node.args[0]) + "))"
        }
        if callee.kind == "Ident" && callee.value == "round" {
            return "hexa_round((double)(" + emit_expr(node.args[0]) + "))"
        }
        if callee.kind == "Ident" && callee.value == "min" {
            let a = emit_expr(node.args[0])
            let b = emit_expr(node.args[1])
            return "((" + a + ") < (" + b + ") ? (" + a + ") : (" + b + "))"
        }
        if callee.kind == "Ident" && callee.value == "max" {
            let a = emit_expr(node.args[0])
            let b = emit_expr(node.args[1])
            return "((" + a + ") > (" + b + ") ? (" + a + ") : (" + b + "))"
        }
        if callee.kind == "Ident" && callee.value == "parse_int" {
            return "hexa_parse_int(" + emit_str_arg(node.args[0]) + ")"
        }
        if callee.kind == "Ident" && callee.value == "to_float" {
            let t = type_of(node.args[0])
            if t == "Str" {
                return "hexa_to_float(" + emit_str_arg(node.args[0]) + ")"
            }
            return "((double)(" + emit_expr(node.args[0]) + "))"
        }
        if callee.kind == "Ident" && callee.value == "env" {
            return "hexa_env(" + emit_str_arg(node.args[0]) + ")"
        }
        if callee.kind == "Ident" && callee.value == "file_exists" {
            return "hexa_file_exists(" + emit_str_arg(node.args[0]) + ")"
        }
        if callee.kind == "Ident" && callee.value == "dir_exists" {
            return "hexa_dir_exists(" + emit_str_arg(node.args[0]) + ")"
        }
        if callee.kind == "Ident" && callee.value == "mkdir" {
            return "hexa_mkdir(" + emit_str_arg(node.args[0]) + ")"
        }
        if callee.kind == "Ident" && callee.value == "list_dir" {
            return "hexa_list_dir(" + emit_str_arg(node.args[0]) + ")"
        }
        if callee.kind == "Ident" && callee.value == "to_int" {
            let t = type_of(node.args[0])
            if t == "Str" {
                return "hexa_to_int_str(" + emit_str_arg(node.args[0]) + ")"
            }
            if t == "Float" {
                return "(long)(" + emit_expr(node.args[0]) + ")"
            }
            return "(long)(" + emit_expr(node.args[0]) + ")"
        }
        // enum variant 호출 → 단순 int 값 (페이로드 drop)
        if callee.kind == "Ident" && enum_is_variant(callee.value) {
            return to_string(enum_lookup_value(callee.value))
        }
        // 사용자 함수 호출 — 모든 인자 (long) 캐스트로 통일
        if callee.kind == "Ident" {
            let mut s = user_fn_name(callee.value) + "("
            let mut i = 0
            while i < len(node.args) {
                if i > 0 { s = s + ", " }
                let arg = node.args[i]
                let at = resolve_expr_type(arg)
                if at == "Str" || at == "StructPtr" || arg.kind == "Str" || arg.kind == "StructLit" {
                    s = s + "(long)(" + emit_expr(arg) + ")"
                } else {
                    s = s + emit_expr(arg)
                }
                i = i + 1
            }
            s = s + ")"
            return s
        }
        return "/* unsupported call */ 0"
    }
    return "0"
}

fn emit_println(pl_args) {
    let mut fmt = ""
    let mut vals = ""
    let mut i = 0
    while i < len(pl_args) {
        if i > 0 { fmt = fmt + " " }
        let a = pl_args[i]
        let t = type_of(a)
        if t == "Str" {
            fmt = fmt + "%s"
        } else if t == "Float" {
            fmt = fmt + "%g"
        } else if t == "DynArr" || t == "StrArr" {
            fmt = fmt + "[arr len=%ld]"
        } else {
            fmt = fmt + "%ld"
        }
        if len(vals) > 0 { vals = vals + ", " }
        if t == "Str" {
            // bt 54: printf %s 에 long→const char* 캐스트 강제
            vals = vals + "((const char*)(" + emit_expr(a) + "))"
        } else if t == "Float" {
            vals = vals + "(double)(" + emit_expr(a) + ")"
        } else if t == "DynArr" || t == "StrArr" {
            vals = vals + "(long)(_AN(" + emit_expr(a) + "))"
        } else {
            vals = vals + "(long)(" + emit_expr(a) + ")"
        }
        i = i + 1
    }
    fmt = fmt + "\\n"
    if len(pl_args) == 0 {
        return "printf(\"\\n\")"
    }
    return "printf(\"" + fmt + "\", " + vals + ")"
}

let mut indent_level = 1
let mut current_fn_ret = "Int"
let mut current_fn_simd = false
let mut current_fn_parallel = false
let mut needs_omp = false

fn pad() {
    let mut s = ""
    let mut k = 0
    while k < indent_level {
        s = s + "    "
        k = k + 1
    }
    return s
}

fn emit_stmt(node) {
    if node.kind == "" { return "" }
    if node.kind == "StructDecl" {
        return ""
    }
    if node.kind == "Let" {
        let val = node.left
        if val.kind == "ArrLit" {
            let n_items = len(val.args)
            let mut elem_type = "Int"
            if n_items > 0 {
                let e0 = val.args[0]
                if type_of(e0) == "Str" {
                    elem_type = "Str"
                }
            }
            if n_items == 0 && is_str_arr_promoted(node.value) {
                elem_type = "Str"
            }
            bc_env_cache_add(node.value, len(env_names))
            env_names = env_names.push(node.value)
            if elem_type == "Str" {
                env_types = env_types.push("StrArr")
            } else {
                env_types = env_types.push("DynArr")
            }
            env_lens = env_lens.push(-1)
            if n_items == 0 {
                return pad() + "long " + user_var_name(node.value) + " = hexa_arr_new();\n"
            }
            let mut s = pad() + "long " + user_var_name(node.value) + " = hexa_arr_lit((long[]){"
            let mut i = 0
            while i < n_items {
                if i > 0 { s = s + ", " }
                if elem_type == "Str" {
                    s = s + "(long)(" + emit_expr(val.args[i]) + ")"
                } else {
                    s = s + emit_expr(val.args[i])
                }
                i = i + 1
            }
            s = s + "}, " + to_string(n_items) + ");\n"
            return s
        }
        if val.kind == "StructLit" {
            env_set_struct(node.value, val.value)
            lsb_set(node.value, val.value)
            // Heap-allocate, cast to long for uniform value representation
            let n_fields = len(val.args)
            let mut s = pad() + "long " + node.value + " = (long)hexa_struct_alloc((long[]){"
            let mut i = 0
            while i < n_fields {
                if i > 0 { s = s + ", " }
                s = s + "(long)(" + emit_expr(val.args[i]) + ")"
                i = i + 1
            }
            s = s + "}, " + to_string(n_fields) + ");\n"
            return s
        }
        let t = type_of(val)
        env_set(node.value, t)
        let uvn = user_var_name(node.value)
        // `let _ = expr` discards the value — emit as (void)(expr) to avoid
        // redefinition errors when multiple let _ = ... appear in one scope.
        if node.value == "_" {
            return pad() + "(void)(" + emit_expr(val) + ");\n"
        }
        if t == "Str" {
            return pad() + "const char* " + uvn + " = " + emit_expr(val) + ";\n"
        }
        if t == "Float" {
            return pad() + "double " + uvn + " = " + emit_expr(val) + ";\n"
        }
        if t == "DynArr" {
            return pad() + "long " + uvn + " = " + emit_expr(val) + ";\n"
        }
        if t == "StructPtr" {
            if val.kind == "Call" && val.left.kind == "Ident" {
                let sn = fn_lookup_struct(val.left.value)
                if sn != "" {
                    env_set_struct(node.value, sn)
                    lsb_set(node.value, sn)
                } else {
                    env_set(node.value, "StructPtr")
                }
            } else {
                env_set(node.value, "StructPtr")
            }
            return pad() + "long " + uvn + " = " + emit_expr(val) + ";\n"
        }
        if t == "StrArr" {
            return pad() + "long " + uvn + " = " + emit_expr(val) + ";\n"
        }
        return pad() + "long " + uvn + " = " + emit_expr(val) + ";\n"
    }
    if node.kind == "Assign" {
        return pad() + user_var_name(node.value) + " = " + emit_expr(node.left) + ";\n"
    }
    if node.kind == "IndexAssign" {
        // arr[idx] = val
        let arr_node = node.left
        let idx_expr = emit_expr(node.right)
        let val_expr = emit_expr(node.args[0])
        if arr_node.kind == "Ident" {
            let at = env_lookup(arr_node.value)
            if at == "DynArr" || at == "StrArr" {
                if at == "StrArr" {
                    return pad() + "_AD(" + arr_node.value + ")[" + idx_expr + "] = (long)(" + val_expr + ");\n"
                }
                return pad() + "_AD(" + arr_node.value + ")[" + idx_expr + "] = " + val_expr + ";\n"
            }
        }
        return pad() + emit_expr(arr_node) + "[" + idx_expr + "] = " + val_expr + ";\n"
    }
    if node.kind == "ExprStmt" {
        return pad() + emit_expr(node.left) + ";\n"
    }
    if node.kind == "If" {
        // perf: chunks.push + join — avoid O(n²) string concat
        let mut if_parts = []
        if_parts = if_parts.push(pad() + "if (" + emit_expr(node.cond) + ") ")
        if_parts = if_parts.push(emit_block(node.then_b))
        let eb = node.else_b
        if eb.kind == "Block" {
            if_parts = if_parts.push(" else " + emit_block(eb))
        } else if eb.kind == "If" {
            if_parts = if_parts.push(" else ")
            let sub = emit_stmt(eb)
            let pn = len(pad())
            if_parts = if_parts.push(sub.substring(pn, sub.len()))
        }
        if_parts = if_parts.push("\n")
        return if_parts.join("")
    }
    if node.kind == "While" {
        let mut pragma = ""
        if current_fn_parallel { pragma = pragma + pad() + "#pragma omp parallel for\n" }
        if current_fn_simd { pragma = pragma + pad() + "#pragma omp simd\n" }
        return pragma + pad() + "while (" + emit_expr(node.cond) + ") " + emit_block(node.then_b) + "\n"
    }
    if node.kind == "ForRange" {
        let v = node.value
        env_set(v, "Int")
        let lo = emit_expr(node.left)
        let hi = emit_expr(node.right)
        let mut pragma2 = ""
        if current_fn_parallel { pragma2 = pragma2 + pad() + "#pragma omp parallel for\n" }
        if current_fn_simd { pragma2 = pragma2 + pad() + "#pragma omp simd\n" }
        return pragma2 + pad() + "for (long " + v + " = " + lo + "; " + v + " < " + hi + "; " + v + "++) " + emit_block(node.then_b) + "\n"
    }
    if node.kind == "Return" {
        if node.left.kind == "" {
            if current_fn_ret == "Str" { return pad() + "return \"\";\n" }
            if current_fn_ret == "Float" { return pad() + "return 0.0;\n" }
            if current_fn_ret == "DynArr" || current_fn_ret == "StrArr" { return pad() + "return hexa_arr_new();\n" }
            return pad() + "return 0;\n"
        }
        // fn 반환 타입과 값 타입 불일치 시 coerce
        let vt = type_of(node.left)
        if current_fn_ret == "Str" && vt != "Str" {
            // Int/Float/etc → 빈 문자열로 치환
            return pad() + "return \"\";\n"
        }
        if current_fn_ret == "Float" && vt == "Int" {
            return pad() + "return (double)(" + emit_expr(node.left) + ");\n"
        }
        return pad() + "return " + emit_expr(node.left) + ";\n"
    }
    if node.kind == "Break" {
        return pad() + "break;\n"
    }
    if node.kind == "Continue" {
        return pad() + "continue;\n"
    }
    if node.kind == "Assert" {
        // assert → C assert 매크로 (간단)
        return pad() + "if (!(" + emit_expr(node.left) + ")) { fprintf(stderr, \"assertion failed\\n\"); exit(1); }\n"
    }
    if node.kind == "Block" {
        // parse에서 desugar된 Block을 그대로 펼침
        // perf: chunks.push + join — avoid O(n²) string concat
        let mut blk_parts = []
        let stmts = node.args
        let mut i = 0
        while i < len(stmts) {
            blk_parts = blk_parts.push(emit_stmt(stmts[i]))
            i = i + 1
        }
        return blk_parts.join("")
    }
    return pad() + "/* unsupported stmt */\n"
}

// 재귀 탐색: pname을 가진 `pname.method(...)` 혹은 str concat 사용 검사
fn find_method_on_param(node, pname, mname) {
    if node.kind == "Method" {
        let obj = node.left
        if obj.kind == "Ident" && obj.value == pname && node.value == mname {
            return true
        }
    }
    if node.kind == "Bin" || node.kind == "Index" {
        if find_method_on_param(node.left, pname, mname) { return true }
        return find_method_on_param(node.right, pname, mname)
    }
    if node.kind == "Unary" || node.kind == "ExprStmt" || node.kind == "Return" || node.kind == "Let" || node.kind == "Assign" || node.kind == "Field" || node.kind == "Method" {
        if find_method_on_param(node.left, pname, mname) { return true }
    }
    if node.kind == "If" {
        if find_method_on_param(node.cond, pname, mname) { return true }
        if find_method_on_param(node.then_b, pname, mname) { return true }
        return find_method_on_param(node.else_b, pname, mname)
    }
    if node.kind == "While" || node.kind == "ForRange" {
        if find_method_on_param(node.cond, pname, mname) { return true }
        return find_method_on_param(node.then_b, pname, mname)
    }
    if node.kind == "Block" {
        let stmts = node.args
        let mut i = 0
        while i < len(stmts) {
            if find_method_on_param(stmts[i], pname, mname) { return true }
            i = i + 1
        }
    }
    if node.kind == "Call" || node.kind == "Method" {
        let a2 = node.args
        let mut i = 0
        while i < len(a2) {
            if find_method_on_param(a2[i], pname, mname) { return true }
            i = i + 1
        }
    }
    return false
}

// node 트리에서 `pname.field` 패턴을 찾아 struct 이름 추론
fn find_param_field(node, pname) {
    if node.kind == "Field" {
        let obj = node.left
        if obj.kind == "Ident" && obj.value == pname {
            // 필드명으로 등록된 struct 검색
            let fname = node.value
            let mut si = 0
            while si < len(struct_tab_names) {
                let sname = struct_tab_names[si]
                if struct_field_index(sname, fname) >= 0 {
                    return sname
                }
                si = si + 1
            }
        }
    }
    // 자식 노드 재귀 — 단일 자식 필드들
    if node.kind == "Bin" || node.kind == "Index" {
        let l = find_param_field(node.left, pname)
        if l != "" { return l }
        return find_param_field(node.right, pname)
    }
    if node.kind == "Unary" || node.kind == "Field" || node.kind == "ExprStmt" || node.kind == "Return" || node.kind == "Let" || node.kind == "Assign" {
        return find_param_field(node.left, pname)
    }
    if node.kind == "If" {
        let c = find_param_field(node.cond, pname)
        if c != "" { return c }
        let t = find_param_field(node.then_b, pname)
        if t != "" { return t }
        return find_param_field(node.else_b, pname)
    }
    if node.kind == "While" {
        let c = find_param_field(node.cond, pname)
        if c != "" { return c }
        return find_param_field(node.then_b, pname)
    }
    if node.kind == "Block" {
        let stmts = node.args
        let mut i = 0
        while i < len(stmts) {
            let r = find_param_field(stmts[i], pname)
            if r != "" { return r }
            i = i + 1
        }
    }
    if node.kind == "Call" {
        let args2 = node.args
        let mut i = 0
        while i < len(args2) {
            let r = find_param_field(args2[i], pname)
            if r != "" { return r }
            i = i + 1
        }
    }
    return ""
}

fn find_param_indexed(node, pname) {
    if node.kind == "Index" {
        let obj = node.left
        if obj.kind == "Ident" && obj.value == pname {
            return true
        }
    }
    if node.kind == "Bin" || node.kind == "Index" {
        if find_param_indexed(node.left, pname) { return true }
        return find_param_indexed(node.right, pname)
    }
    if node.kind == "Unary" || node.kind == "ExprStmt" || node.kind == "Return" || node.kind == "Let" || node.kind == "Assign" || node.kind == "Field" || node.kind == "Method" {
        if find_param_indexed(node.left, pname) { return true }
    }
    if node.kind == "If" {
        if find_param_indexed(node.cond, pname) { return true }
        if find_param_indexed(node.then_b, pname) { return true }
        return find_param_indexed(node.else_b, pname)
    }
    if node.kind == "While" || node.kind == "ForRange" {
        if find_param_indexed(node.cond, pname) { return true }
        return find_param_indexed(node.then_b, pname)
    }
    if node.kind == "Block" {
        let stmts = node.args
        let mut i = 0
        while i < len(stmts) {
            if find_param_indexed(stmts[i], pname) { return true }
            i = i + 1
        }
    }
    if node.kind == "Call" || node.kind == "Method" {
        let a2 = node.args
        let mut i = 0
        while i < len(a2) {
            if find_param_indexed(a2[i], pname) { return true }
            i = i + 1
        }
    }
    return false
}

fn find_len_call_on_param(node, pname) {
    if node.kind == "Call" {
        let c = node.left
        if c.kind == "Ident" && c.value == "len" && len(node.args) == 1 {
            let a0 = node.args[0]
            if a0.kind == "Ident" && a0.value == pname {
                return true
            }
        }
    }
    if node.kind == "Bin" || node.kind == "Index" {
        if find_len_call_on_param(node.left, pname) { return true }
        return find_len_call_on_param(node.right, pname)
    }
    if node.kind == "Unary" || node.kind == "ExprStmt" || node.kind == "Return" || node.kind == "Let" || node.kind == "Assign" || node.kind == "Field" || node.kind == "Method" {
        if find_len_call_on_param(node.left, pname) { return true }
    }
    if node.kind == "If" {
        if find_len_call_on_param(node.cond, pname) { return true }
        if find_len_call_on_param(node.then_b, pname) { return true }
        return find_len_call_on_param(node.else_b, pname)
    }
    if node.kind == "While" || node.kind == "ForRange" {
        if find_len_call_on_param(node.cond, pname) { return true }
        return find_len_call_on_param(node.then_b, pname)
    }
    if node.kind == "Block" {
        let stmts = node.args
        let mut i = 0
        while i < len(stmts) {
            if find_len_call_on_param(stmts[i], pname) { return true }
            i = i + 1
        }
    }
    if node.kind == "Call" || node.kind == "Method" {
        let a2 = node.args
        let mut i = 0
        while i < len(a2) {
            if find_len_call_on_param(a2[i], pname) { return true }
            i = i + 1
        }
    }
    return false
}

// 블록 내 로컬 Let 타입을 추적하며 return 타입 추론.
// 반환된 Ident의 타입은 동일 블록 내 Let 초기화 값의 타입으로 간주.
let mut local_env_names = []
let mut local_env_types = []
fn local_env_lookup(name) {
    let mut i = 0
    while i < len(local_env_names) {
        if local_env_names[i] == name { return local_env_types[i] }
        i = i + 1
    }
    return ""
}
fn local_env_set(name, t) {
    local_env_names = local_env_names.push(name)
    local_env_types = local_env_types.push(t)
}
fn resolve_expr_type(e) {
    if e.kind == "Int" { return "Int" }
    if e.kind == "Float" { return "Float" }
    if e.kind == "Str" { return "Str" }
    if e.kind == "Bool" { return "Int" }
    if e.kind == "StructLit" { return "StructPtr" }
    if e.kind == "Ident" {
        if is_str_arr_promoted(e.value) {
            // Str 변수 OR StrArr (같은 set)
            // Let path에서 ArrLit으로 선언된 경우 StrArr일 가능성 높음
        }
        let t = local_env_lookup(e.value)
        if t != "" { return t }
        return type_of(e)
    }
    if e.kind == "Bin" {
        let lt = resolve_expr_type(e.left)
        let rt = resolve_expr_type(e.right)
        if e.op == "+" && (lt == "Str" || rt == "Str") { return "Str" }
        if lt == "Float" || rt == "Float" { return "Float" }
        return "Int"
    }
    if e.kind == "Unary" { return resolve_expr_type(e.left) }
    if e.kind == "Call" { return type_of(e) }
    return type_of(e)
}

// Local struct binding map for return-type inference:
// `let t = Tensor { ... }; return t` should infer return type as Tensor.
let mut local_struct_binds_names = []
let mut local_struct_binds_types = []

fn lsb_clear() {
    local_struct_binds_names = []
    local_struct_binds_types = []
}

fn lsb_set(name, struct_name) {
    local_struct_binds_names = local_struct_binds_names.push(name)
    local_struct_binds_types = local_struct_binds_types.push(struct_name)
}

fn lsb_get(name) {
    let n = len(local_struct_binds_names)
    let mut i = n - 1
    while i >= 0 {
        if local_struct_binds_names[i] == name { return local_struct_binds_types[i] }
        i = i - 1
    }
    return ""
}

fn find_returned_struct_name(node) {
    if node.kind == "Let" {
        // Record let X = StructLit so a later `return X` resolves
        let v = node.left
        if type_of(v) != "string" && v.kind == "StructLit" {
            lsb_set(node.value, v.value)
        }
        return ""
    }
    if node.kind == "Return" {
        let e = node.left
        if e.kind == "StructLit" { return e.value }
        // `return X` where X was let-bound to a StructLit
        if e.kind == "Ident" {
            let sn = lsb_get(e.value)
            if sn != "" { return sn }
        }
        return ""
    }
    if node.kind == "Block" {
        let stmts = node.args
        let mut i = 0
        while i < len(stmts) {
            let n = find_returned_struct_name(stmts[i])
            if n != "" { return n }
            i = i + 1
        }
        return ""
    }
    if node.kind == "If" {
        let a = find_returned_struct_name(node.then_b)
        if a != "" { return a }
        return find_returned_struct_name(node.else_b)
    }
    if node.kind == "While" || node.kind == "ForRange" {
        return find_returned_struct_name(node.then_b)
    }
    return ""
}

// 더 구체적인 타입 우선: Str > Float > DynArr/StrArr > StructPtr > Int
fn ret_type_merge(a, b) {
    if a == "" { return b }
    if b == "" { return a }
    if a == "Str" || b == "Str" { return "Str" }
    if a == "Float" || b == "Float" { return "Float" }
    if a == "DynArr" || b == "DynArr" { return "DynArr" }
    if a == "StrArr" || b == "StrArr" { return "StrArr" }
    if a == "StructPtr" || b == "StructPtr" { return "StructPtr" }
    return a
}

fn find_return_type(node) {
    if node.kind == "Return" {
        if node.left.kind == "" { return "" }
        return resolve_expr_type(node.left)
    }
    if node.kind == "Let" {
        let mut t = resolve_expr_type(node.left)
        // 빈 ArrLit이 str_arr_promoted 면 StrArr
        if t == "DynArr" && is_str_arr_promoted(node.value) {
            t = "StrArr"
        }
        local_env_set(node.value, t)
        return ""
    }
    if node.kind == "Block" {
        let stmts = node.args
        let mut i = 0
        let mut acc = ""
        while i < len(stmts) {
            let t = find_return_type(stmts[i])
            acc = ret_type_merge(acc, t)
            i = i + 1
        }
        return acc
    }
    if node.kind == "If" {
        let t = find_return_type(node.then_b)
        let e = find_return_type(node.else_b)
        return ret_type_merge(t, e)
    }
    if node.kind == "While" || node.kind == "ForRange" {
        return find_return_type(node.then_b)
    }
    return ""
}

fn find_param_str_compare(node, pname) {
    // `pname == "literal"` 또는 `"literal" == pname`, 메서드 호출과의 비교 탐색
    if node.kind == "Bin" && (node.op == "==" || node.op == "!=") {
        let l = node.left
        let r = node.right
        let l_is_p = l.kind == "Ident" && l.value == pname
        let r_is_p = r.kind == "Ident" && r.value == pname
        if l_is_p && r.kind == "Str" { return true }
        if r_is_p && l.kind == "Str" { return true }
        // method call과 비교 → Str일 가능성 높음
        if l_is_p && r.kind == "Method" { return true }
        if r_is_p && l.kind == "Method" { return true }
    }
    if node.kind == "Bin" || node.kind == "Index" {
        if find_param_str_compare(node.left, pname) { return true }
        return find_param_str_compare(node.right, pname)
    }
    if node.kind == "Unary" || node.kind == "ExprStmt" || node.kind == "Return" || node.kind == "Let" || node.kind == "Assign" || node.kind == "Field" || node.kind == "Method" {
        if find_param_str_compare(node.left, pname) { return true }
    }
    if node.kind == "If" {
        if find_param_str_compare(node.cond, pname) { return true }
        if find_param_str_compare(node.then_b, pname) { return true }
        return find_param_str_compare(node.else_b, pname)
    }
    if node.kind == "While" {
        if find_param_str_compare(node.cond, pname) { return true }
        return find_param_str_compare(node.then_b, pname)
    }
    if node.kind == "ForRange" {
        if find_param_str_compare(node.left, pname) { return true }
        if find_param_str_compare(node.right, pname) { return true }
        return find_param_str_compare(node.then_b, pname)
    }
    if node.kind == "Block" {
        let stmts = node.args
        let mut i = 0
        while i < len(stmts) {
            if find_param_str_compare(stmts[i], pname) { return true }
            i = i + 1
        }
    }
    if node.kind == "Call" || node.kind == "Method" {
        let a2 = node.args
        let mut i = 0
        while i < len(a2) {
            if find_param_str_compare(a2[i], pname) { return true }
            i = i + 1
        }
    }
    return false
}

// body 안에서 `for v in pname` 루프의 v가 문자열 메서드로 쓰이면 true
fn for_in_uses_str(node, pname) {
    // ForRange는 parse_for에서 Block으로 desugar되므로 직접 파생된 패턴을 찾음:
    //   { let __fi_v = 0; while __fi_v < len(pname) { let v = pname[__fi_v]; ... } }
    // v가 문자열 메서드와 함께 쓰이면 StrArr.
    // 단순화: body 어디든 `pname[idx]`가 있고 그 결과가 string method / Str concat과 쓰이면
    // 본 fn에서는 pname을 StrArr로 간주.
    //
    // 휴리스틱: body에 `.trim()` 메서드 호출이 있거나 `parseN(pname[i])` 류 있으면 Str
    return find_param_indexed(node, pname) && has_str_ops(node)
}

fn has_str_ops(node) {
    if node.kind == "Method" {
        let m = node.value
        if m == "trim" || m == "substring" || m == "contains" || m == "starts_with" || m == "ends_with" || m == "split" || m == "replace" || m == "to_lower" || m == "to_upper" || m == "index_of" || m == "slice" {
            return true
        }
    }
    // Str 리터럴이 어딘가 있으면 string 처리 중일 가능성
    if node.kind == "Str" { return true }
    if node.kind == "Bin" || node.kind == "Index" {
        if has_str_ops(node.left) { return true }
        return has_str_ops(node.right)
    }
    if node.kind == "Unary" || node.kind == "ExprStmt" || node.kind == "Return" || node.kind == "Let" || node.kind == "Assign" || node.kind == "Field" || node.kind == "Method" {
        if has_str_ops(node.left) { return true }
    }
    if node.kind == "If" {
        if has_str_ops(node.cond) { return true }
        if has_str_ops(node.then_b) { return true }
        return has_str_ops(node.else_b)
    }
    if node.kind == "While" {
        if has_str_ops(node.cond) { return true }
        return has_str_ops(node.then_b)
    }
    if node.kind == "Block" {
        let stmts2 = node.args
        let mut i = 0
        while i < len(stmts2) {
            if has_str_ops(stmts2[i]) { return true }
            i = i + 1
        }
    }
    if node.kind == "Call" || node.kind == "Method" {
        let a2 = node.args
        let mut i = 0
        while i < len(a2) {
            if has_str_ops(a2[i]) { return true }
            i = i + 1
        }
    }
    return false
}

fn infer_param_c_type(body, pname) {
    let sname = find_param_field(body, pname)
    if sname != "" { return "struct:" + sname }
    if find_method_on_param(body, pname, "push") { return "dynarr" }
    // dynarr 감지 (len+idx) 또는 단순 idx만 (body에 Str op 있으면 StrArr)
    if find_len_call_on_param(body, pname) && find_param_indexed(body, pname) {
        if has_str_ops(body) { return "strarr" }
        return "dynarr"
    }
    if find_param_indexed(body, pname) {
        if has_str_ops(body) { return "strarr" }
        return "dynarr"
    }
    // body-based string 추론 비활성화 (pointer runtime: 전부 long)
    // `: string` 어노테이션만 fn_param_is_str에서 처리
    return "int"
}

fn fn_c_ret_type(node) {
    let rt = find_return_type(node.right)
    if rt == "Str" { return "const char*" }
    if rt == "Float" { return "long" }
    if rt == "DynArr" { return "long" }
    return "long"
}

fn user_var_name(name) {
    // 전역 수준에서만 충돌 — 일단 모두 동일 prefix
    if name == "log" { return "hexa_v_log" }
    if name == "exp" { return "hexa_v_exp" }
    if name == "pow" { return "hexa_v_pow" }
    if name == "index" { return "hexa_v_index" }
    if name == "time" { return "hexa_v_time" }
    if name == "clock" { return "hexa_v_clock" }
    if name == "exit" { return "hexa_v_exit" }
    return name
}

fn user_fn_name(name) {
    // C 예약어/라이브러리 함수 이름 충돌 방지
    if name == "main" { return "hexa_user_main" }
    if name == "double" { return "hexa_user_double" }
    if name == "float" { return "hexa_user_float" }
    if name == "int" { return "hexa_user_int" }
    if name == "long" { return "hexa_user_long" }
    if name == "char" { return "hexa_user_char" }
    if name == "log" { return "hexa_user_log" }
    if name == "exp" { return "hexa_user_exp" }
    if name == "pow" { return "hexa_user_pow" }
    if name == "sqrt" { return "hexa_user_sqrt" }
    if name == "abs" { return "hexa_user_abs" }
    if name == "sin" { return "hexa_user_sin" }
    if name == "cos" { return "hexa_user_cos" }
    if name == "tan" { return "hexa_user_tan" }
    if name == "floor" { return "hexa_user_floor" }
    if name == "ceil" { return "hexa_user_ceil" }
    if name == "round" { return "hexa_user_round" }
    if name == "time" { return "hexa_user_time" }
    if name == "clock" { return "hexa_user_clock" }
    if name == "exit" { return "hexa_user_exit" }
    if name == "read" { return "hexa_user_read" }
    if name == "write" { return "hexa_user_write" }
    if name == "open" { return "hexa_user_open" }
    if name == "close" { return "hexa_user_close" }
    if name == "index" { return "hexa_user_index" }
    if name == "bsearch" { return "hexa_user_bsearch" }
    if name == "qsort" { return "hexa_user_qsort" }
    if name == "strcmp" { return "hexa_user_strcmp" }
    if name == "strlen" { return "hexa_user_strlen" }
    if name == "strcpy" { return "hexa_user_strcpy" }
    if name == "malloc" { return "hexa_user_malloc" }
    if name == "free" { return "hexa_user_free" }
    if name == "printf" { return "hexa_user_printf" }
    if name == "scanf" { return "hexa_user_scanf" }
    if name == "fprintf" { return "hexa_user_fprintf" }
    if name == "fopen" { return "hexa_user_fopen" }
    if name == "fclose" { return "hexa_user_fclose" }
    return name
}

fn fn_has_attr(node, name) {
    let s = node.op
    if s == "" { return false }
    // s 안에 name이 있는지 검사 (간이: contains)
    if s == name { return true }
    let parts = s.split(",")
    let mut k = 0
    while k < len(parts) {
        if parts[k] == name { return true }
        k = k + 1
    }
    return false
}

fn emit_memoize_wrapper(node) {
    // @memoize fn name(p) { body }
    // → static long __memo_<name>_keys[1024], __memo_<name>_vals[1024], __memo_<name>_valid[1024]
    // → long __memo_orig_<name>(p) { body }
    // → long <name>(p) { 캐시 체크 → hit:return val / miss:compute+store }
    let name = node.value
    let params = node.args
    let nparams = len(params)
    // N-arg: 키 N개 모두 저장 (slot당 nparams long), 해시는 FNV-mix
    let mut s = ""
    s = s + "static long __memo_" + name + "_keys[4096 * " + to_string(nparams) + "];\n"
    s = s + "static long __memo_" + name + "_vals[4096];\n"
    s = s + "static char __memo_" + name + "_valid[4096];\n\n"
    // 원본 fn
    let orig_node = Node { kind: "Fn", value: "__memo_orig_" + name, op: "", left: "", right: node.right, cond: "", then_b: "", else_b: "", args: node.args }
    s = s + emit_fn_decl(orig_node)
    // wrapper
    let mut sig = "long " + name + "("
    let mut i = 0
    while i < nparams {
        if i > 0 { sig = sig + ", " }
        sig = sig + "long " + params[i]
        i = i + 1
    }
    sig = sig + ")"
    s = s + sig + " {\n"
    // 해시: FNV-style mix of all params
    s = s + "    unsigned long __h = 1469598103934665603UL;\n"
    let mut hi = 0
    while hi < nparams {
        s = s + "    __h = (__h ^ (unsigned long)(" + params[hi] + ")) * 1099511628211UL;\n"
        hi = hi + 1
    }
    s = s + "    long __idx = (long)(__h & 4095);\n"
    s = s + "    long __base = __idx * " + to_string(nparams) + ";\n"
    // 모든 키 일치 확인
    s = s + "    if (__memo_" + name + "_valid[__idx]"
    let mut ki = 0
    while ki < nparams {
        s = s + " && __memo_" + name + "_keys[__base + " + to_string(ki) + "] == " + params[ki]
        ki = ki + 1
    }
    s = s + ") {\n"
    s = s + "        return __memo_" + name + "_vals[__idx];\n"
    s = s + "    }\n"
    s = s + "    long __r = __memo_orig_" + name + "("
    let mut j = 0
    while j < nparams {
        if j > 0 { s = s + ", " }
        s = s + params[j]
        j = j + 1
    }
    s = s + ");\n"
    let mut si = 0
    while si < nparams {
        s = s + "    __memo_" + name + "_keys[__base + " + to_string(si) + "] = " + params[si] + ";\n"
        si = si + 1
    }
    s = s + "    __memo_" + name + "_vals[__idx] = __r;\n"
    s = s + "    __memo_" + name + "_valid[__idx] = 1;\n"
    s = s + "    return __r;\n"
    s = s + "}\n\n"
    return s
}

fn emit_fn_decl(node) {
    // @memoize / @optimize 처리 — @optimize는 재귀 fn에 자동 memoize 주입
    if fn_has_attr(node, "memoize") || fn_has_attr(node, "optimize") {
        return emit_memoize_wrapper(node)
    }
    // 파라미터 타입을 미리 env에 넣어 find_return_type이 Float 전파 가능
    let params = node.args
    // float param env 등록 비활성화 (pointer runtime — 전부 long)
    let mut pi3 = 0
    while pi3 < len(params) {
        pi3 = pi3 + 1
    }
    // 그 다음 return 타입 재계산
    local_env_names = []
    local_env_types = []
    let mut rt2 = find_return_type(node.right)
    // fn_tab에 annotation 기반 등록이 있으면 그것 우선 (body 분석보다 강함)
    let tab_rt = fn_lookup_ret(node.value)
    if tab_rt == "Str" || tab_rt == "Float" || tab_rt == "DynArr" || tab_rt == "StrArr" || tab_rt == "StructPtr" {
        rt2 = tab_rt
    }
    let mut ret_c = "long"
    if rt2 == "Str" { ret_c = "const char*" }
    if rt2 == "Float" { ret_c = "long" }
    if rt2 == "DynArr" { ret_c = "long" }
    if rt2 == "StrArr" { ret_c = "long" }
    if rt2 == "StructPtr" { ret_c = "long" }
    current_fn_ret = rt2
    current_fn_simd = fn_has_attr(node, "simd")
    current_fn_parallel = fn_has_attr(node, "parallel")
    if current_fn_parallel || current_fn_simd { needs_omp = true }
    // @inline / @hot / @cold / @pure 접두사
    let mut prefix = ""
    if fn_has_attr(node, "inline") { prefix = prefix + "static inline " }
    if fn_has_attr(node, "hot") { prefix = prefix + "__attribute__((hot)) " }
    if fn_has_attr(node, "cold") { prefix = prefix + "__attribute__((cold)) " }
    if fn_has_attr(node, "pure") { prefix = prefix + "__attribute__((pure)) " }
    let mut s = prefix + ret_c + " " + user_fn_name(node.value) + "("
    let mut i = 0
    while i < len(params) {
        if i > 0 { s = s + ", " }
        let pname = params[i]
        // pointer runtime: 모든 파라미터 long (타입 통일)
        s = s + "long " + pname
        env_set(pname, "Int")
        i = i + 1
    }
    s = s + ") "
    s = s + emit_block(node.right) + "\n\n"
    return s
}

fn emit_fn_proto(node) {
    // 반환 타입도 Float 힌트 고려해 재계산
    let params = node.args
    local_env_names = []
    local_env_types = []
    let mut pi4 = 0
    while pi4 < len(params) {
        // float param 비활성화 (pointer runtime)
        pi4 = pi4 + 1
    }
    let mut rt3 = find_return_type(node.right)
    let tab_rt3 = fn_lookup_ret(node.value)
    if tab_rt3 == "Str" || tab_rt3 == "Float" || tab_rt3 == "DynArr" || tab_rt3 == "StrArr" || tab_rt3 == "StructPtr" {
        rt3 = tab_rt3
    }
    let mut ret_c = "long"
    if rt3 == "Str" { ret_c = "const char*" }
    if rt3 == "Float" { ret_c = "long" }
    if rt3 == "DynArr" { ret_c = "long" }
    if rt3 == "StrArr" { ret_c = "long" }
    if rt3 == "StructPtr" { ret_c = "long" }
    let mut s = ret_c + " " + user_fn_name(node.value) + "("
    let mut i = 0
    while i < len(params) {
        if i > 0 { s = s + ", " }
        let pname = params[i]
        // pointer runtime: 모든 파라미터 long
        s = s + "long " + pname
        i = i + 1
    }
    s = s + ");\n"
    return s
}

fn emit_block(node) {
    // node.kind == "Block", node.args == stmts
    // perf: chunks.push + join — avoid O(n²) string concat
    let mut parts = []
    parts = parts.push("{\n")
    indent_level = indent_level + 1
    let stmts = node.args
    let mut i = 0
    while i < len(stmts) {
        parts = parts.push(emit_stmt(stmts[i]))
        i = i + 1
    }
    indent_level = indent_level - 1
    parts = parts.push(pad() + "}")
    return parts.join("")
}

fn emit_runtime() {
    // 최소 문자열/정수 런타임 — 정적 bump arena (64KB)
    // perf: chunks.push + join — avoid O(n²) string concat (~256 lines)
    let mut rp = []
    rp = rp.push("#include <stdio.h>\n")
    rp = rp.push("#include <string.h>\n")
    rp = rp.push("#include <stdlib.h>\n")
    rp = rp.push("#include <time.h>\n")
    rp = rp.push("#include <math.h>\n")
    rp = rp.push("#include <sys/wait.h>\n")
    rp = rp.push("#include <sys/stat.h>\n")
    rp = rp.push("#include <dirent.h>\n")
    rp = rp.push("#include <errno.h>\n")
    if needs_omp {
        rp = rp.push("#include <omp.h>\n")
        rp = rp.push("// NOTE: compile with -fopenmp flag (e.g. gcc -fopenmp output.c)\n")
    }
    rp = rp.push("\n")
    rp = rp.push("static const double PI = 3.14159265358979323846;\n")
    rp = rp.push("static const double E = 2.71828182845904523536;\n")
    rp = rp.push("static long hexa_time_unix(void) { return (long)time(NULL); }\n")
    rp = rp.push("static double hexa_clock(void) { return (double)clock() / CLOCKS_PER_SEC; }\n")
    rp = rp.push("static double hexa_sqrt(double x) { return sqrt(x); }\n")
    rp = rp.push("static double hexa_pow(double b, double e) { return pow(b, e); }\n")
    rp = rp.push("static double hexa_abs_f(double x) { return x < 0 ? -x : x; }\n")
    rp = rp.push("static long hexa_abs_i(long x) { return x < 0 ? -x : x; }\n")
    rp = rp.push("static double hexa_sin(double x) { return sin(x); }\n")
    rp = rp.push("static double hexa_cos(double x) { return cos(x); }\n")
    rp = rp.push("static double hexa_tan(double x) { return tan(x); }\n")
    rp = rp.push("static double hexa_log(double x) { return log(x); }\n")
    rp = rp.push("static double hexa_log10(double x) { return log10(x); }\n")
    rp = rp.push("static double hexa_exp(double x) { return exp(x); }\n")
    rp = rp.push("static double hexa_floor(double x) { return floor(x); }\n")
    rp = rp.push("static double hexa_ceil(double x) { return ceil(x); }\n")
    rp = rp.push("static double hexa_round(double x) { return (x >= 0) ? (long)(x + 0.5) : (long)(x - 0.5); }\n")
    rp = rp.push("// hexa_alloc: 단순 malloc wrapper (무제한)\n")
    rp = rp.push("static char* hexa_alloc(size_t n) {\n")
    rp = rp.push("    char* p = (char*)malloc(n);\n")
    rp = rp.push("    if (!p) { fprintf(stderr, \"hexa_alloc oom (%zu)\\n\", n); exit(1); }\n")
    rp = rp.push("    return p;\n")
    rp = rp.push("}\n")
    rp = rp.push("static const char* hexa_concat(const char* a, const char* b) {\n")
    rp = rp.push("    size_t la = strlen(a), lb = strlen(b);\n")
    rp = rp.push("    char* p = hexa_alloc(la + lb + 1);\n")
    rp = rp.push("    memcpy(p, a, la); memcpy(p + la, b, lb); p[la + lb] = 0;\n")
    rp = rp.push("    return p;\n")
    rp = rp.push("}\n")
    rp = rp.push("static const char* hexa_timestamp(void) {\n")
    rp = rp.push("    time_t t = time(NULL); struct tm* lt = localtime(&t);\n")
    rp = rp.push("    char* p = hexa_alloc(32);\n")
    rp = rp.push("    strftime(p, 32, \"%Y-%m-%d %H:%M:%S\", lt);\n")
    rp = rp.push("    return p;\n")
    rp = rp.push("}\n")
    rp = rp.push("static const char* hexa_int_to_str(long v) {\n")
    rp = rp.push("    char* p = hexa_alloc(24);\n")
    rp = rp.push("    snprintf(p, 24, \"%ld\", v);\n")
    rp = rp.push("    return p;\n")
    rp = rp.push("}\n")
    rp = rp.push("static const char* hexa_float_to_str(double v) {\n")
    rp = rp.push("    char* p = hexa_alloc(32);\n")
    rp = rp.push("    snprintf(p, 32, \"%g\", v);\n")
    rp = rp.push("    return p;\n")
    rp = rp.push("}\n")
    rp = rp.push("static const char* hexa_substr(const char* s, long a, long b) {\n")
    rp = rp.push("    long sl = (long)strlen(s);\n")
    rp = rp.push("    if (a < 0) a = 0; if (b > sl) b = sl; if (a > b) a = b;\n")
    rp = rp.push("    long n = b - a;\n")
    rp = rp.push("    char* p = hexa_alloc(n + 1);\n")
    rp = rp.push("    memcpy(p, s + a, n); p[n] = 0;\n")
    rp = rp.push("    return p;\n")
    rp = rp.push("}\n")
    rp = rp.push("static long hexa_str_len(const char* s) { return (long)strlen(s); }\n")
    rp = rp.push("static long hexa_contains(const char* h, const char* n) { return strstr(h, n) ? 1 : 0; }\n")
    rp = rp.push("static long hexa_index_of(const char* h, const char* n) {\n")
    rp = rp.push("    const char* p = strstr(h, n); if (!p) return -1;\n")
    rp = rp.push("    return (long)(p - h);\n")
    rp = rp.push("}\n")
    rp = rp.push("static long hexa_starts_with(const char* h, const char* n) {\n")
    rp = rp.push("    size_t ln = strlen(n); return strncmp(h, n, ln) == 0 ? 1 : 0;\n")
    rp = rp.push("}\n")
    rp = rp.push("static long hexa_ends_with(const char* h, const char* n) {\n")
    rp = rp.push("    size_t lh = strlen(h), ln = strlen(n);\n")
    rp = rp.push("    if (ln > lh) return 0; return strcmp(h + lh - ln, n) == 0 ? 1 : 0;\n")
    rp = rp.push("}\n")
    rp = rp.push("static const char* hexa_trim(const char* s) {\n")
    rp = rp.push("    while (*s == ' ' || *s == '\\t' || *s == '\\n' || *s == '\\r') s++;\n")
    rp = rp.push("    long n = (long)strlen(s);\n")
    rp = rp.push("    while (n > 0 && (s[n-1]==' '||s[n-1]=='\\t'||s[n-1]=='\\n'||s[n-1]=='\\r')) n--;\n")
    rp = rp.push("    char* p = hexa_alloc(n + 1);\n")
    rp = rp.push("    memcpy(p, s, n); p[n] = 0;\n")
    rp = rp.push("    return p;\n")
    rp = rp.push("}\n")
    rp = rp.push("static const char* hexa_to_upper(const char* s) {\n")
    rp = rp.push("    long n = (long)strlen(s); char* p = hexa_alloc(n + 1);\n")
    rp = rp.push("    for (long i = 0; i < n; i++) { char c = s[i]; p[i] = (c>='a'&&c<='z') ? c - 32 : c; }\n")
    rp = rp.push("    p[n] = 0; return p;\n")
    rp = rp.push("}\n")
    rp = rp.push("static const char* hexa_to_lower(const char* s) {\n")
    rp = rp.push("    long n = (long)strlen(s); char* p = hexa_alloc(n + 1);\n")
    rp = rp.push("    for (long i = 0; i < n; i++) { char c = s[i]; p[i] = (c>='A'&&c<='Z') ? c + 32 : c; }\n")
    rp = rp.push("    p[n] = 0; return p;\n")
    rp = rp.push("}\n")
    rp = rp.push("static long hexa_parse_int(const char* s) {\n")
    rp = rp.push("    while (*s == ' ' || *s == '\\t') s++;\n")
    rp = rp.push("    long sign = 1; if (*s == '-') { sign = -1; s++; } else if (*s == '+') s++;\n")
    rp = rp.push("    long v = 0; while (*s >= '0' && *s <= '9') { v = v*10 + (*s - '0'); s++; }\n")
    rp = rp.push("    return sign * v;\n")
    rp = rp.push("}\n")
    rp = rp.push("#include <stdlib.h>\n")
    rp = rp.push("static double hexa_to_float(const char* s) { return strtod(s, NULL); }\n")
    rp = rp.push("static long* hexa_struct_alloc(const long* items, long n) {\n")
    rp = rp.push("    long* p = (long*)hexa_alloc(n * sizeof(long));\n")
    rp = rp.push("    memcpy(p, items, n * sizeof(long));\n")
    rp = rp.push("    return p;\n")
    rp = rp.push("}\n")
    rp = rp.push("static const char* hexa_env(const char* name) {\n")
    rp = rp.push("    const char* v = getenv(name); return v ? v : \"\";\n")
    rp = rp.push("}\n")
    rp = rp.push("static const char* hexa_replace(const char* s, const char* old_, const char* new_) {\n")
    rp = rp.push("    long oln = (long)strlen(old_); if (oln == 0) return s;\n")
    rp = rp.push("    long sl = (long)strlen(s), nl = (long)strlen(new_);\n")
    rp = rp.push("    // 결과 최대 길이 = s 길이 * (new/old 비율)\n")
    rp = rp.push("    long cap = sl + 1; if (nl > oln) cap = sl * (nl / oln + 1) + 1;\n")
    rp = rp.push("    char* out = hexa_alloc(cap + 64);\n")
    rp = rp.push("    long oi = 0; const char* cur = s;\n")
    rp = rp.push("    while (*cur) {\n")
    rp = rp.push("        if (strncmp(cur, old_, oln) == 0) {\n")
    rp = rp.push("            memcpy(out + oi, new_, nl); oi += nl; cur += oln;\n")
    rp = rp.push("        } else { out[oi++] = *cur++; }\n")
    rp = rp.push("    }\n")
    rp = rp.push("    out[oi] = 0; return out;\n")
    rp = rp.push("}\n")
    rp = rp.push("static const char* hexa_read_file(const char* path) {\n")
    rp = rp.push("    FILE* f = fopen(path, \"rb\");\n")
    rp = rp.push("    if (!f) return \"\";\n")
    rp = rp.push("    fseek(f, 0, SEEK_END); long sz = ftell(f); fseek(f, 0, SEEK_SET);\n")
    rp = rp.push("    char* p = hexa_alloc(sz + 1);\n")
    rp = rp.push("    fread(p, 1, sz, f); p[sz] = 0; fclose(f);\n")
    rp = rp.push("    return p;\n")
    rp = rp.push("}\n")
    rp = rp.push("static long hexa_write_file(const char* path, const char* content) {\n")
    rp = rp.push("    FILE* f = fopen(path, \"wb\");\n")
    rp = rp.push("    if (!f) return 0;\n")
    rp = rp.push("    size_t n = strlen(content);\n")
    rp = rp.push("    fwrite(content, 1, n, f); fclose(f);\n")
    rp = rp.push("    return (long)n;\n")
    rp = rp.push("}\n")
    rp = rp.push("static long hexa_file_exists(const char* path) {\n")
    rp = rp.push("    FILE* f = fopen(path, \"rb\"); if (!f) return 0; fclose(f); return 1;\n")
    rp = rp.push("}\n")
    rp = rp.push("static long hexa_dir_exists(const char* path) {\n")
    rp = rp.push("    struct stat st; if (stat(path, &st) != 0) return 0; return S_ISDIR(st.st_mode) ? 1 : 0;\n")
    rp = rp.push("}\n")
    rp = rp.push("static long hexa_mkdir(const char* path) {\n")
    rp = rp.push("    char tmp[1024]; snprintf(tmp, sizeof(tmp), \"%s\", path);\n")
    rp = rp.push("    for (char* p = tmp + 1; *p; p++) { if (*p == '/') { *p = 0; mkdir(tmp, 0755); *p = '/'; } }\n")
    rp = rp.push("    return (mkdir(tmp, 0755) == 0 || errno == EEXIST) ? 0 : 1;\n")
    rp = rp.push("}\n")
    // 동적 배열 런타임 — pointer semantics (long = hexa_arr*)
    // 모든 배열은 힙 할당 포인터를 long으로 저장. 타입 통일.
    rp = rp.push("typedef struct { long* d; long n; long cap; } hexa_arr;\n")
    rp = rp.push("#define _HA(a) ((hexa_arr*)(a))\n")
    rp = rp.push("#define _AD(a) (_HA(a)->d)\n")
    rp = rp.push("#define _AN(a) (_HA(a)->n)\n")
    rp = rp.push("static long hexa_arr_new(void) {\n")
    rp = rp.push("    hexa_arr* p = (hexa_arr*)malloc(sizeof(hexa_arr));\n")
    rp = rp.push("    p->d = NULL; p->n = 0; p->cap = 0; return (long)p;\n")
    rp = rp.push("}\n")
    rp = rp.push("static long hexa_arr_lit(const long* items, long n) {\n")
    rp = rp.push("    hexa_arr* p = (hexa_arr*)malloc(sizeof(hexa_arr));\n")
    rp = rp.push("    p->d = (long*)malloc((n>0?n:1)*sizeof(long)); p->n = n; p->cap = (n>0?n:1);\n")
    rp = rp.push("    if (n > 0) memcpy(p->d, items, n*sizeof(long));\n")
    rp = rp.push("    return (long)p;\n")
    rp = rp.push("}\n")
    rp = rp.push("static long hexa_arr_push(long a, long x) {\n")
    rp = rp.push("    hexa_arr* p = _HA(a);\n")
    rp = rp.push("    if (p->n >= p->cap) {\n")
    rp = rp.push("        p->cap = p->cap ? p->cap * 2 : 4;\n")
    rp = rp.push("        p->d = (long*)realloc(p->d, p->cap * sizeof(long));\n")
    rp = rp.push("    }\n")
    rp = rp.push("    p->d[p->n++] = x;\n")
    rp = rp.push("    return a;\n")
    rp = rp.push("}\n")
    rp = rp.push("static long hexa_arr_len(long a) { return a ? _AN(a) : 0; }\n")
    rp = rp.push("static long hexa_arr_get(long a, long i) { return _AD(a)[i]; }\n")
    rp = rp.push("static long hexa_arr_fill(long n, long v) {\n")
    rp = rp.push("    hexa_arr* p = (hexa_arr*)malloc(sizeof(hexa_arr));\n")
    rp = rp.push("    p->n = n; p->cap = n > 0 ? n : 1;\n")
    rp = rp.push("    p->d = (long*)malloc(p->cap * sizeof(long));\n")
    rp = rp.push("    for (long i = 0; i < n; i++) p->d[i] = v;\n")
    rp = rp.push("    return (long)p;\n")
    rp = rp.push("}\n")
    rp = rp.push("static long hexa_arr_concat(long a, long b) {\n")
    rp = rp.push("    long an = a ? _AN(a) : 0, bn = b ? _AN(b) : 0;\n")
    rp = rp.push("    hexa_arr* p = (hexa_arr*)malloc(sizeof(hexa_arr));\n")
    rp = rp.push("    p->n = an + bn; p->cap = p->n > 0 ? p->n : 1;\n")
    rp = rp.push("    p->d = (long*)malloc(p->cap * sizeof(long));\n")
    rp = rp.push("    if (an > 0) memcpy(p->d, _AD(a), an * sizeof(long));\n")
    rp = rp.push("    if (bn > 0) memcpy(p->d + an, _AD(b), bn * sizeof(long));\n")
    rp = rp.push("    return (long)p;\n")
    rp = rp.push("}\n")
    rp = rp.push("static long hexa_list_dir(const char* path) {\n")
    rp = rp.push("    long a = hexa_arr_new();\n")
    rp = rp.push("    DIR* d = opendir(path); if (!d) return a;\n")
    rp = rp.push("    struct dirent* e; while ((e = readdir(d)) != NULL) {\n")
    rp = rp.push("        if (e->d_name[0] == '.' && (e->d_name[1] == 0 || (e->d_name[1] == '.' && e->d_name[2] == 0))) continue;\n")
    rp = rp.push("        char* s = hexa_alloc(strlen(e->d_name) + 1); strcpy(s, e->d_name);\n")
    rp = rp.push("        a = hexa_arr_push(a, (long)s);\n")
    rp = rp.push("    }\n")
    rp = rp.push("    closedir(d); return a;\n")
    rp = rp.push("}\n")
    rp = rp.push("static long hexa_to_int_str(const char* s) { return strtol(s, NULL, 10); }\n")
    rp = rp.push("static long hexa_append_file(const char* path, const char* content) {\n")
    rp = rp.push("    FILE* f = fopen(path, \"ab\");\n")
    rp = rp.push("    if (!f) return 0;\n")
    rp = rp.push("    size_t n = strlen(content);\n")
    rp = rp.push("    fwrite(content, 1, n, f); fclose(f);\n")
    rp = rp.push("    return (long)n;\n")
    rp = rp.push("}\n")
    rp = rp.push("static const char* hexa_read_stdin(void) {\n")
    rp = rp.push("    char buf[8192]; size_t total = 0;\n")
    rp = rp.push("    char* out = hexa_alloc(65536);\n")
    rp = rp.push("    size_t r; while ((r = fread(buf, 1, sizeof(buf), stdin)) > 0) {\n")
    rp = rp.push("        if (total + r >= 65535) break;\n")
    rp = rp.push("        memcpy(out + total, buf, r); total += r;\n")
    rp = rp.push("    }\n")
    rp = rp.push("    out[total] = 0; return out;\n")
    rp = rp.push("}\n")
    rp = rp.push("static const char* hexa_exec_with_status(const char* cmd) {\n")
    rp = rp.push("    FILE* f = popen(cmd, \"r\");\n")
    rp = rp.push("    if (!f) return \"-1|\";\n")
    rp = rp.push("    char buf[8192]; size_t total = 0;\n")
    rp = rp.push("    char* out = hexa_alloc(16384);\n")
    rp = rp.push("    size_t rd; while ((rd = fread(buf, 1, sizeof(buf), f)) > 0) {\n")
    rp = rp.push("        if (total + rd >= 16000) break;\n")
    rp = rp.push("        memcpy(out + total, buf, rd); total += rd;\n")
    rp = rp.push("    }\n")
    rp = rp.push("    out[total] = 0; int rc = pclose(f);\n")
    rp = rp.push("    while (total > 0 && (out[total-1] == '\\n' || out[total-1] == '\\r')) { out[--total] = 0; }\n")
    rp = rp.push("    char* formatted = hexa_alloc(total + 32);\n")
    rp = rp.push("    snprintf(formatted, total + 32, \"%d|%s\", WEXITSTATUS(rc), out);\n")
    rp = rp.push("    return formatted;\n")
    rp = rp.push("}\n")
    rp = rp.push("static const char* hexa_exec(const char* cmd) {\n")
    rp = rp.push("    FILE* f = popen(cmd, \"r\");\n")
    rp = rp.push("    if (!f) return \"\";\n")
    rp = rp.push("    char buf[8192]; size_t total = 0;\n")
    rp = rp.push("    char* out = hexa_alloc(8192);\n")
    rp = rp.push("    size_t r; while ((r = fread(buf, 1, sizeof(buf), f)) > 0) {\n")
    rp = rp.push("        if (total + r >= 8191) break;\n")
    rp = rp.push("        memcpy(out + total, buf, r); total += r;\n")
    rp = rp.push("    }\n")
    rp = rp.push("    out[total] = 0; pclose(f);\n")
    rp = rp.push("    while (total > 0 && (out[total-1] == '\\n' || out[total-1] == '\\r')) { out[--total] = 0; }\n")
    rp = rp.push("    return out;\n")
    rp = rp.push("}\n")
    // (hexa_arr definitions moved before hexa_list_dir — see above)
    // chars()/split/is_alpha/is_alphanumeric/args
    rp = rp.push("static long hexa_chars(const char* s) {\n")
    rp = rp.push("    long n = (long)strlen(s);\n")
    rp = rp.push("    long a = hexa_arr_new();\n")
    rp = rp.push("    for (long i = 0; i < n; i++) a = hexa_arr_push(a, (long)(unsigned char)s[i]);\n")
    rp = rp.push("    return a;\n")
    rp = rp.push("}\n")
    rp = rp.push("#include <ctype.h>\n")
    rp = rp.push("static long hexa_is_alpha(long c) { return (long)(isalpha((int)c) ? 1 : 0); }\n")
    rp = rp.push("static long hexa_is_alnum(long c) { return (long)(isalnum((int)c) ? 1 : 0); }\n")
    rp = rp.push("static int hexa_main_argc = 0;\n")
    rp = rp.push("static char** hexa_main_argv = NULL;\n")
    rp = rp.push("static long hexa_args(void) {\n")
    rp = rp.push("    long a = hexa_arr_new();\n")
    rp = rp.push("    for (int i = 0; i < hexa_main_argc; i++) a = hexa_arr_push(a, (long)hexa_main_argv[i]);\n")
    rp = rp.push("    return a;\n")
    rp = rp.push("}\n")
    rp = rp.push("static const char* hexa_arg(long i) {\n")
    rp = rp.push("    if (i < 0 || i >= hexa_main_argc) return \"\";\n")
    rp = rp.push("    return hexa_main_argv[i];\n")
    rp = rp.push("}\n")
    rp = rp.push("static long hexa_argc(void) { return (long)hexa_main_argc; }\n")
    rp = rp.push("static long hexa_split(const char* s, const char* sep) {\n")
    rp = rp.push("    long a = hexa_arr_new();\n")
    rp = rp.push("    long sl = (long)strlen(sep); if (sl == 0) { return hexa_arr_push(a, (long)s); }\n")
    rp = rp.push("    const char* cur = s;\n")
    rp = rp.push("    while (1) {\n")
    rp = rp.push("        const char* hit = strstr(cur, sep);\n")
    rp = rp.push("        if (!hit) {\n")
    rp = rp.push("            long ln = (long)strlen(cur);\n")
    rp = rp.push("            char* p = hexa_alloc(ln + 1);\n")
    rp = rp.push("            memcpy(p, cur, ln); p[ln] = 0;\n")
    rp = rp.push("            a = hexa_arr_push(a, (long)p);\n")
    rp = rp.push("            break;\n")
    rp = rp.push("        }\n")
    rp = rp.push("        long ln = hit - cur;\n")
    rp = rp.push("        char* p = hexa_alloc(ln + 1);\n")
    rp = rp.push("        memcpy(p, cur, ln); p[ln] = 0;\n")
    rp = rp.push("        a = hexa_arr_push(a, (long)p);\n")
    rp = rp.push("        cur = hit + sl;\n")
    rp = rp.push("    }\n")
    rp = rp.push("    return a;\n")
    rp = rp.push("}\n\n")
    return rp.join("")
}

// 식이 Float 리터럴을 포함하는지
fn expr_contains_float(e) {
    if e.kind == "Float" { return true }
    if e.kind == "Ident" && is_float_var(e.value) { return true }
    if e.kind == "Bin" {
        // 산술 연산자만 (비교/논리는 bool result)
        if e.op == "+" || e.op == "-" || e.op == "*" || e.op == "/" || e.op == "%" {
            if expr_contains_float(e.left) { return true }
            return expr_contains_float(e.right)
        }
        return false
    }
    if e.kind == "Unary" && (e.op == "-" || e.op == "+") {
        return expr_contains_float(e.left)
    }
    if e.kind == "Call" {
        // 명시적으로 Float를 반환하는 builtin만
        let cc = e.left
        if cc.kind == "Ident" {
            let v = cc.value
            if v == "sqrt" || v == "pow" || v == "sin" || v == "cos" || v == "tan" || v == "log" || v == "log10" || v == "exp" || v == "floor" || v == "ceil" || v == "round" || v == "to_float" {
                return true
            }
        }
        // 사용자 Call의 페이로드 스캔은 하지 않음 (false positive 방지)
    }
    return false
}

fn walk_collect_float_calls(node) {
    if node.kind == "Let" {
        // Let RHS에 Float가 있으면 변수를 Float 로 마킹
        if expr_contains_float(node.left) {
            mark_float_var(node.value)
        }
    }
    if node.kind == "Call" {
        let cl = node.left
        if cl.kind == "Ident" {
            let mut i = 0
            while i < len(node.args) {
                let ai = node.args[i]
                if ai.kind == "Float" || expr_contains_float(ai) {
                    fn_mark_float_param(cl.value, i)
                }
                if ai.kind == "Str" {
                    fn_mark_str_param(cl.value, i)
                }
                // 메서드 호출 결과가 Str인 경우
                if ai.kind == "Method" {
                    let mm = ai.value
                    if mm == "substring" || mm == "slice" || mm == "trim" || mm == "to_upper" || mm == "to_lower" || mm == "replace" {
                        fn_mark_str_param(cl.value, i)
                    }
                }
                // Call 결과가 Str인 경우 (fn_lookup_ret)
                if ai.kind == "Call" && ai.left.kind == "Ident" {
                    if fn_lookup_ret(ai.left.value) == "Str" {
                        fn_mark_str_param(cl.value, i)
                    }
                }
                // Ident가 str_arr_promoted(Str로 마킹)이면 전파
                if ai.kind == "Ident" && is_str_arr_promoted(ai.value) {
                    fn_mark_str_param(cl.value, i)
                }
                i = i + 1
            }
        }
    }
    if node.kind == "Bin" || node.kind == "Index" {
        walk_collect_float_calls(node.left)
        walk_collect_float_calls(node.right)
    }
    if node.kind == "Unary" || node.kind == "ExprStmt" || node.kind == "Return" || node.kind == "Let" || node.kind == "Assign" || node.kind == "Field" || node.kind == "Method" {
        walk_collect_float_calls(node.left)
    }
    if node.kind == "If" {
        walk_collect_float_calls(node.cond)
        walk_collect_float_calls(node.then_b)
        walk_collect_float_calls(node.else_b)
    }
    if node.kind == "While" {
        walk_collect_float_calls(node.cond)
        walk_collect_float_calls(node.then_b)
    }
    if node.kind == "ForRange" {
        walk_collect_float_calls(node.left)
        walk_collect_float_calls(node.right)
        walk_collect_float_calls(node.then_b)
    }
    if node.kind == "Block" {
        let stmts = node.args
        let mut i = 0
        while i < len(stmts) {
            walk_collect_float_calls(stmts[i])
            i = i + 1
        }
    }
    if node.kind == "Call" || node.kind == "Method" {
        let a2 = node.args
        let mut i = 0
        while i < len(a2) {
            walk_collect_float_calls(a2[i])
            i = i + 1
        }
    }
    if node.kind == "Fn" {
        walk_collect_float_calls(node.right)
    }
}

// 변수 이름이 어딘가에서 문자열로 확장되는지 scan
// (arr.push(str), arr = arr + [str], arr = arr.split(...))
let mut str_arr_promoted = []
let mut float_vars = []

fn mark_float_var(name) {
    if bc_float_var_cache_has(name) { return }
    let mut i = 0
    while i < len(float_vars) {
        if float_vars[i] == name { return }
        i = i + 1
    }
    float_vars = float_vars.push(name)
    bc_float_var_cache_add(name)
}
fn is_float_var(name) {
    if bc_float_var_cache_has(name) { return true }
    if len(bc_float_var_cache) == 64 { return false }
    let mut i = 0
    while i < len(float_vars) {
        if float_vars[i] == name { return true }
        i = i + 1
    }
    return false
}

fn mark_str_arr_promoted(name) {
    if bc_str_arr_cache_has(name) { return }
    let mut i = 0
    while i < len(str_arr_promoted) {
        if str_arr_promoted[i] == name { return }
        i = i + 1
    }
    str_arr_promoted = str_arr_promoted.push(name)
    bc_str_arr_cache_add(name)
}

fn is_str_arr_promoted(name) {
    if bc_str_arr_cache_has(name) { return true }
    if len(bc_str_arr_cache) == 64 { return false }
    let mut i = 0
    while i < len(str_arr_promoted) {
        if str_arr_promoted[i] == name { return true }
        i = i + 1
    }
    return false
}

fn walk_collect_str_arr(node) {
    if node.kind == "Assign" {
        let rhs = node.left
        // x = promoted_var
        if rhs.kind == "Ident" && is_str_arr_promoted(rhs.value) {
            mark_str_arr_promoted(node.value)
        }
        // x = method returning StrArr
        if rhs.kind == "Method" && rhs.value == "split" {
            mark_str_arr_promoted(node.value)
        }
        if rhs.kind == "Bin" && rhs.op == "+" {
            let r = rhs.right
            if r.kind == "ArrLit" && len(r.args) > 0 {
                let e0 = r.args[0]
                if type_of(e0) == "Str" {
                    mark_str_arr_promoted(node.value)
                }
                // Ident가 promoted면 이 변수도 승격
                if e0.kind == "Ident" && is_str_arr_promoted(e0.value) {
                    mark_str_arr_promoted(node.value)
                }
                // Method 문자열 반환이면 승격
                if e0.kind == "Method" {
                    let mn = e0.value
                    if mn == "substring" || mn == "slice" || mn == "trim" || mn == "to_upper" || mn == "to_lower" || mn == "replace" {
                        mark_str_arr_promoted(node.value)
                    }
                }
            }
        }
        if rhs.kind == "Method" {
            if rhs.value == "split" {
                mark_str_arr_promoted(node.value)
            }
            if rhs.value == "push" {
                if len(rhs.args) > 0 {
                    let pa = rhs.args[0]
                    if type_of(pa) == "Str" {
                        mark_str_arr_promoted(node.value)
                    }
                    // push arg이 Ident이고 그 Ident가 이미 str loop var로 마킹되었으면 전파
                    if pa.kind == "Ident" && is_str_arr_promoted(pa.value) {
                        mark_str_arr_promoted(node.value)
                    }
                }
            }
        }
    }
    // for v in arr (desugar Block): if arr is Ident and str arr promoted → v is Str
    // ForRange 패턴 (parse_for의 desugar 결과): Block with Let __fi=0, While
    // 여기선 원본 Assign만 처리하고, str_arr 식별은 Let __fi_ 시작 여부 등으로 추정 어려움
    // 대신 Let의 RHS가 split()이면 해당 변수가 StrArr임을 마킹
    if node.kind == "Let" {
        let v = node.left
        if v.kind == "Method" && v.value == "split" {
            mark_str_arr_promoted(node.value)
        }
        // let v = str_method_call(...) → v는 Str
        if v.kind == "Method" {
            let mn = v.value
            if mn == "trim" || mn == "substring" || mn == "slice" || mn == "to_upper" || mn == "to_lower" || mn == "replace" {
                mark_str_arr_promoted(node.value)
            }
        }
        // let v = arr_str_promoted_var[i] → v는 Str
        if v.kind == "Index" && v.left.kind == "Ident" && is_str_arr_promoted(v.left.value) {
            mark_str_arr_promoted(node.value)
        }
        // let v = Str 리터럴
        if v.kind == "Str" {
            mark_str_arr_promoted(node.value)
        }
        // let v = Str concat (Bin + with Str or promoted var)
        if v.kind == "Bin" && v.op == "+" {
            let lv = v.left
            let rv = v.right
            if lv.kind == "Str" || rv.kind == "Str" {
                mark_str_arr_promoted(node.value)
            }
            if lv.kind == "Ident" && is_str_arr_promoted(lv.value) {
                mark_str_arr_promoted(node.value)
            }
            if rv.kind == "Ident" && is_str_arr_promoted(rv.value) {
                mark_str_arr_promoted(node.value)
            }
        }
    }
    if node.kind == "Bin" || node.kind == "Index" {
        walk_collect_str_arr(node.left)
        walk_collect_str_arr(node.right)
    }
    if node.kind == "Unary" || node.kind == "ExprStmt" || node.kind == "Return" || node.kind == "Let" || node.kind == "Field" || node.kind == "Method" {
        walk_collect_str_arr(node.left)
    }
    if node.kind == "If" {
        walk_collect_str_arr(node.cond)
        walk_collect_str_arr(node.then_b)
        walk_collect_str_arr(node.else_b)
    }
    if node.kind == "While" {
        walk_collect_str_arr(node.cond)
        walk_collect_str_arr(node.then_b)
    }
    if node.kind == "ForRange" {
        walk_collect_str_arr(node.left)
        walk_collect_str_arr(node.right)
        walk_collect_str_arr(node.then_b)
    }
    if node.kind == "Block" {
        let stmts2 = node.args
        let mut i = 0
        while i < len(stmts2) {
            walk_collect_str_arr(stmts2[i])
            i = i + 1
        }
    }
    if node.kind == "Call" || node.kind == "Method" {
        let a2 = node.args
        let mut i = 0
        while i < len(a2) {
            walk_collect_str_arr(a2[i])
            i = i + 1
        }
    }
    if node.kind == "Fn" {
        walk_collect_str_arr(node.right)
    }
}

fn emit_program(stmts) {
    // TIER 1: initialize O(1) caches (mirrors type_checker type_check()).
    bc_caches_init()
    // -3) 내장 상수 등록
    env_set("PI", "Float")
    env_set("E", "Float")
    mark_float_var("PI")
    mark_float_var("E")
    // -2) StrArr promotion 수집 — fixed-point 반복 (fn_tab 등록 전)
    let mut fp_iter = 0
    while fp_iter < 3 {
        let mut pi3 = 0
        while pi3 < len(stmts) {
            walk_collect_str_arr(stmts[pi3])
            pi3 = pi3 + 1
        }
        fp_iter = fp_iter + 1
    }
    // -1) Float 호출 사이트 수집 — fixed-point 3-pass
    let mut fp_f = 0
    while fp_f < 3 {
        let mut pi2 = 0
        while pi2 < len(stmts) {
            walk_collect_float_calls(stmts[pi2])
            pi2 = pi2 + 1
        }
        fp_f = fp_f + 1
    }
    // 0) fn 테이블 등록 (walker 뒤) — find_return_type이 str_arr_promoted 반영
    let mut pi = 0
    while pi < len(stmts) {
        let s0 = stmts[pi]
        if s0.kind == "Fn" {
            local_env_names = []
            local_env_types = []
            lsb_clear()
            let existing = fn_lookup_ret(s0.value)
            if existing == "Int" {
                let rt = find_return_type(s0.right)
                // Always try the struct-name finder — it will record any
                // `let X = StructLit` and resolve a later `return X`.
                let sn = find_returned_struct_name(s0.right)
                if sn != "" {
                    fn_register_struct(s0.value, "StructPtr", sn)
                } else if rt == "StructPtr" {
                    fn_register_struct(s0.value, "StructPtr", "")
                } else if rt == "" {
                    fn_register(s0.value, "Int")
                } else {
                    fn_register(s0.value, rt)
                }
            }
        }
        pi = pi + 1
    }
    // 0.5) Call 인자 str 전파 재-pass (fn_tab 사용 가능) — Float 재-pass도
    let mut fp_r = 0
    while fp_r < 2 {
        let mut pir = 0
        while pir < len(stmts) {
            walk_collect_float_calls(stmts[pir])
            pir = pir + 1
        }
        fp_r = fp_r + 1
    }
    // pre-scan: @parallel / @simd 사용 여부 → needs_omp
    let mut ps = 0
    while ps < len(stmts) {
        if stmts[ps].kind == "Fn" {
            if fn_has_attr(stmts[ps], "parallel") || fn_has_attr(stmts[ps], "simd") {
                needs_omp = true
            }
        }
        ps = ps + 1
    }
    // perf: chunks.push + join — avoid O(n²) string concat in main codegen
    let mut out_parts = []
    out_parts = out_parts.push(emit_runtime())
    // 1) forward prototypes
    let mut i = 0
    while i < len(stmts) {
        if stmts[i].kind == "Fn" {
            // @inline은 static inline → forward decl 충돌 → skip
            if !fn_has_attr(stmts[i], "inline") {
                out_parts = out_parts.push(emit_fn_proto(stmts[i]))
            }
        }
        i = i + 1
    }
    out_parts = out_parts.push("\n")
    // 1.4) enum variants → C const
    let mut ei = 0
    while ei < len(enum_tab_names) {
        out_parts = out_parts.push("static long " + enum_tab_names[ei] + " = " + to_string(enum_tab_values[ei]) + ";\n")
        ei = ei + 1
    }
    if len(enum_tab_names) > 0 { out_parts = out_parts.push("\n") }
    // 1.5) top-level Let → C 전역 승격 (fn 정의보다 먼저) — 선언만, 초기화는 main 원 위치에서
    indent_level = 0
    let mut init_parts = []
    i = 0
    while i < len(stmts) {
        let s1 = stmts[i]
        if s1.kind == "Let" {
            let v = s1.left
            let uvn1 = user_var_name(s1.value)
            if v.kind == "Int" {
                env_set(s1.value, "Int")
                out_parts = out_parts.push("static long " + uvn1 + " = " + v.value + ";\n")
            } else if v.kind == "Float" {
                env_set(s1.value, "Float")
                out_parts = out_parts.push("static double " + uvn1 + " = " + v.value + ";\n")
            } else if v.kind == "Str" {
                env_set(s1.value, "Str")
                out_parts = out_parts.push("static const char* " + uvn1 + " = \"" + v.value + "\";\n")
            } else if v.kind == "Bool" {
                env_set(s1.value, "Int")
                let bv = if v.value == "true" { "1" } else { "0" }
                out_parts = out_parts.push("static long " + uvn1 + " = " + bv + ";\n")
            } else if v.kind == "ArrLit" {
                let n_items = len(v.args)
                let mut is_str = false
                if n_items > 0 && type_of(v.args[0]) == "Str" {
                    is_str = true
                }
                if n_items == 0 && is_str_arr_promoted(s1.value) {
                    is_str = true
                }
                bc_env_cache_add(s1.value, len(env_names))
                env_names = env_names.push(s1.value)
                if is_str {
                    env_types = env_types.push("StrArr")
                } else {
                    env_types = env_types.push("DynArr")
                }
                env_lens = env_lens.push(-1)
                out_parts = out_parts.push("static long " + uvn1 + ";\n")
                if n_items == 0 {
                    init_parts = init_parts.push("    " + uvn1 + " = hexa_arr_new();\n")
                } else {
                    let mut lit_parts = []
                    lit_parts = lit_parts.push("    " + uvn1 + " = hexa_arr_lit((long[]){")
                    let mut li = 0
                    while li < n_items {
                        if li > 0 { lit_parts = lit_parts.push(", ") }
                        lit_parts = lit_parts.push("(long)(" + emit_expr(v.args[li]) + ")")
                        li = li + 1
                    }
                    lit_parts = lit_parts.push("}, " + to_string(n_items) + ");\n")
                    init_parts = init_parts.push(lit_parts.join(""))
                }
            } else if v.kind == "StructLit" {
                env_set_struct(s1.value, v.value)
                out_parts = out_parts.push("static long* " + uvn1 + ";\n")
                init_parts = init_parts.push("    " + uvn1 + " = " + emit_expr(v) + ";\n")
            } else {
                let vt = type_of(v)
                if vt == "Str" {
                    env_set(s1.value, "Str")
                    out_parts = out_parts.push("static const char* " + uvn1 + ";\n")
                    init_parts = init_parts.push("    " + uvn1 + " = " + emit_expr(v) + ";\n")
                } else if vt == "Float" {
                    env_set(s1.value, "Float")
                    out_parts = out_parts.push("static double " + uvn1 + ";\n")
                    init_parts = init_parts.push("    " + uvn1 + " = " + emit_expr(v) + ";\n")
                } else if vt == "DynArr" || vt == "StrArr" {
                    bc_env_cache_add(s1.value, len(env_names))
                    env_names = env_names.push(s1.value)
                    env_types = env_types.push(vt)
                    env_lens = env_lens.push(-1)
                    out_parts = out_parts.push("static long " + uvn1 + ";\n")
                    init_parts = init_parts.push("    " + uvn1 + " = " + emit_expr(v) + ";\n")
                } else if vt == "StructPtr" {
                    // struct 반환 fn call 결과
                    if v.kind == "Call" && v.left.kind == "Ident" {
                        let sn = fn_lookup_struct(v.left.value)
                        if sn != "" {
                            env_set_struct(s1.value, sn)
                        } else {
                            env_set(s1.value, "StructPtr")
                        }
                    } else {
                        env_set(s1.value, "StructPtr")
                    }
                    out_parts = out_parts.push("static long* " + uvn1 + ";\n")
                    init_parts = init_parts.push("    " + uvn1 + " = " + emit_expr(v) + ";\n")
                } else {
                    env_set(s1.value, "Int")
                    out_parts = out_parts.push("static long " + uvn1 + ";\n")
                    init_parts = init_parts.push("    " + uvn1 + " = " + emit_expr(v) + ";\n")
                }
            }
        }
        i = i + 1
    }
    out_parts = out_parts.push("\n")
    // 1.5) extern fn declarations + @link library harvest
    //      Hexa `extern fn foo(a: T, b: *Void) -> int` becomes
    //      `extern long foo(long a, long b);` in C. @link("lib") attributes
    //      are collected into a comment so the caller can pass -lfoo.
    let mut linked_libs = []
    i = 0
    while i < len(stmts) {
        let es = stmts[i]
        if es.kind == "ExternFn" {
            // params encoded as "name:type" strings in args[]
            let mut params_c = ""
            let ep = es.args
            if len(ep) == 0 {
                params_c = "void"
            } else {
                let mut j = 0
                while j < len(ep) {
                    if j > 0 { params_c = params_c + ", " }
                    // parse "name:type"
                    let raw = ep[j]
                    let mut pname = raw
                    let mut ptype = "int"
                    let mut ci = 0
                    let rl = len(raw)
                    while ci < rl {
                        if raw.substring(ci, ci + 1) == ":" {
                            pname = raw.substring(0, ci)
                            ptype = raw.substring(ci + 1, rl)
                            ci = rl
                        }
                        ci = ci + 1
                    }
                    params_c = params_c + extern_type_to_c(ptype) + " " + pname
                    j = j + 1
                }
            }
            let ret = es.left
            let ret_c = extern_type_to_c(ret)
            // Record C prototype for linker; also register in fn_tab so
            // calls to this symbol downstream don't treat it as unknown.
            out_parts = out_parts.push("extern " + ret_c + " " + es.value + "(" + params_c + ");\n")
            fn_register(es.value, if ret == "float" || ret == "Float" { "Float" } else { "Int" })
            // Harvest @link("libname") from attrs
            let attrs = es.op
            if attrs != "" {
                // attrs is comma-separated: "link:m,hot,link:cublas"
                let mut ai = 0
                let mut cur = ""
                let la = len(attrs)
                while ai <= la {
                    let ch = if ai < la { attrs.substring(ai, ai + 1) } else { "," }
                    if ch == "," {
                        if cur.substring(0, 5) == "link:" {
                            let libn = cur.substring(5, len(cur))
                            // dedupe
                            let mut found = false
                            let mut li = 0
                            while li < len(linked_libs) {
                                if linked_libs[li] == libn { found = true }
                                li = li + 1
                            }
                            if !found { linked_libs = linked_libs.push(libn) }
                        }
                        cur = ""
                    } else {
                        cur = cur + ch
                    }
                    ai = ai + 1
                }
            }
        }
        i = i + 1
    }
    if len(linked_libs) > 0 {
        out_parts = out_parts.push("/* hexa @link libs: ")
        let mut li2 = 0
        while li2 < len(linked_libs) {
            if li2 > 0 { out_parts = out_parts.push(" ") }
            out_parts = out_parts.push("-l" + linked_libs[li2])
            li2 = li2 + 1
        }
        out_parts = out_parts.push(" */\n")
    }
    out_parts = out_parts.push("\n")
    // 2) function definitions
    i = 0
    while i < len(stmts) {
        if stmts[i].kind == "Fn" {
            out_parts = out_parts.push(emit_fn_decl(stmts[i]))
        }
        i = i + 1
    }
    out_parts = out_parts.push("\n")
    // 3) main with non-fn stmts (리터럴 Let는 이미 전역으로 emit됨, skip)
    // fn 정의 emit 시 env에 params가 추가되어 top-level 변수 shadow 가능 —
    // main 진입 전 top-level 변수 type을 다시 등록하여 최근 우선 확보.
    let mut rti = 0
    while rti < len(stmts) {
        let sr = stmts[rti]
        if sr.kind == "Let" {
            let vr = sr.left
            if vr.kind == "Int" || vr.kind == "Bool" {
                env_set(sr.value, "Int")
            } else if vr.kind == "Float" {
                env_set(sr.value, "Float")
            } else if vr.kind == "Str" {
                env_set(sr.value, "Str")
            } else if vr.kind == "ArrLit" {
                let mut is_s = false
                if len(vr.args) > 0 && type_of(vr.args[0]) == "Str" { is_s = true }
                if len(vr.args) == 0 && is_str_arr_promoted(sr.value) { is_s = true }
                bc_env_cache_add(sr.value, len(env_names))
                env_names = env_names.push(sr.value)
                if is_s { env_types = env_types.push("StrArr") } else { env_types = env_types.push("DynArr") }
                env_lens = env_lens.push(-1)
            } else if vr.kind == "StructLit" {
                env_set_struct(sr.value, vr.value)
            } else {
                let vt2 = type_of(vr)
                if vt2 == "Str" { env_set(sr.value, "Str") }
                else if vt2 == "Float" { env_set(sr.value, "Float") }
                else if vt2 == "DynArr" || vt2 == "StrArr" {
                    bc_env_cache_add(sr.value, len(env_names))
                    env_names = env_names.push(sr.value)
                    env_types = env_types.push(vt2)
                    env_lens = env_lens.push(-1)
                }
                else { env_set(sr.value, "Int") }
            }
        }
        rti = rti + 1
    }
    out_parts = out_parts.push("int main(int argc, char** argv) {\n")
    out_parts = out_parts.push("    hexa_main_argc = argc; hexa_main_argv = argv;\n")
    // @test fn 자동 실행 — 0 리턴 = pass
    let mut _ti = 0
    let mut _tpass = 0
    let mut _tfail = 0
    let mut _test_call_parts = []
    while _ti < len(stmts) {
        let _ts = stmts[_ti]
        if _ts.kind == "Fn" && fn_has_attr(_ts, "test") {
            _test_call_parts = _test_call_parts.push("    { long __r = " + user_fn_name(_ts.value) + "(); if (__r == 0) { __hexa_test_pass++; printf(\"  [PASS] " + _ts.value + "\\n\"); } else { __hexa_test_fail++; printf(\"  [FAIL] " + _ts.value + " (ret=%ld)\\n\", __r); } }\n")
            _tpass = _tpass + 1
        }
        _ti = _ti + 1
    }
    if _tpass > 0 {
        out_parts = out_parts.push("    long __hexa_test_pass = 0, __hexa_test_fail = 0;\n")
        out_parts = out_parts.push("    printf(\"=== @test runner ===\\n\");\n")
        out_parts = out_parts.push(_test_call_parts.join(""))
        out_parts = out_parts.push("    printf(\"=== %ld pass / %ld fail ===\\n\", __hexa_test_pass, __hexa_test_fail);\n")
    }
    indent_level = 1
    i = 0
    while i < len(stmts) {
        let s2 = stmts[i]
        if s2.kind == "Fn" {
            i = i + 1
        } else if s2.kind == "Let" {
            // top-level Let: 전역으로 선언은 됐지만 초기화는 원 위치에서
            let iv = s2.left
            if iv.kind == "Int" || iv.kind == "Float" || iv.kind == "Str" || iv.kind == "Bool" {
                // 리터럴 초기화는 static에서 이미 설정됨 — skip
            } else if iv.kind == "ArrLit" {
                // ArrLit init을 원 위치에서
                let n_items = len(iv.args)
                let mut is_str = false
                if n_items > 0 && type_of(iv.args[0]) == "Str" { is_str = true }
                if n_items == 0 && is_str_arr_promoted(s2.value) { is_str = true }
                let uvn2 = user_var_name(s2.value)
                if n_items == 0 {
                    out_parts = out_parts.push(pad() + uvn2 + " = hexa_arr_new();\n")
                } else {
                    // perf: chunks.push + join for arr literal
                    let mut lit_parts = []
                    lit_parts = lit_parts.push(pad() + uvn2 + " = hexa_arr_lit((long[]){")
                    let mut li = 0
                    while li < n_items {
                        if li > 0 { lit_parts = lit_parts.push(", ") }
                        lit_parts = lit_parts.push("(long)(" + emit_expr(iv.args[li]) + ")")
                        li = li + 1
                    }
                    lit_parts = lit_parts.push("}, " + to_string(n_items) + ");\n")
                    out_parts = out_parts.push(lit_parts.join(""))
                }
            } else {
                out_parts = out_parts.push(pad() + user_var_name(s2.value) + " = " + emit_expr(iv) + ";\n")
            }
            i = i + 1
        } else {
            out_parts = out_parts.push(emit_stmt(s2))
            i = i + 1
        }
    }
    // 사용자 `fn main` 이 정의되어 있으면 자동 호출
    // (hexa 소스 관례: fn main(args) — args는 전달하지 않고 builtin args() 사용 가정)
    // Skip auto-call if the user already invoked main() at the top level
    // (e.g. `let _ = main()` or bare `main()`) — otherwise main runs twice.
    let mut has_main = false
    let mut user_called_main = false
    let mut mi = 0
    while mi < len(stmts) {
        let st = stmts[mi]
        if st.kind == "Fn" && st.value == "main" {
            has_main = true
        }
        // Detect top-level main() call: bare Call or Let with main() as RHS.
        // Let node shape: { kind:"Let", value:name (str), left:rhs_node }
        if st.kind == "Call" {
            let cl = st.left
            if type_of(cl) != "string" && cl.kind == "Ident" && cl.value == "main" {
                user_called_main = true
            }
        }
        if st.kind == "Let" {
            let rhs = st.left
            if type_of(rhs) != "string" && rhs.kind == "Call" {
                let rcl = rhs.left
                if type_of(rcl) != "string" && rcl.kind == "Ident" && rcl.value == "main" {
                    user_called_main = true
                }
            }
        }
        mi = mi + 1
    }
    if has_main && !user_called_main {
        out_parts = out_parts.push("    hexa_user_main();\n")
    }
    out_parts = out_parts.push("    return 0;\n}\n")
    return out_parts.join("")
}

// ══════════════════════════════════════════════════════════════
// 엔트리
// ══════════════════════════════════════════════════════════════
// CLI: ./hexa self/build_c.hexa <input.hexa> [output.c]
// 인자 없으면 기본값(에라토스테네스).
fn cli_args() {
    return args()
}
let _argv = cli_args()
let mut input_path = "examples/struct_min.hexa"
let mut output_path = "build/struct_min.c"
let _argc = len(_argv)
if _argc >= 3 {
    input_path = _argv[2]
}
if _argc >= 4 {
    output_path = _argv[3]
}

// ── `use "name"` directive: textual preprocess ────────────
// Walks the source line by line. When it sees a `use "name"` line,
// replaces it with the content of name.hexa from one of these paths:
//   1. <dir-of-input>/<name>.hexa
//   2. <dir-of-input>/../<name>.hexa
//   3. self/ml/<name>.hexa
//   4. self/<name>.hexa
// Recursive: a use'd file can have its own `use` lines.
// Tracks already-resolved modules to avoid double-include.
let mut __resolved_modules = []

fn dirname_of(path) {
    let n = len(path)
    let mut i = n - 1
    while i >= 0 {
        if path.substring(i, i + 1) == "/" {
            return path.substring(0, i)
        }
        i = i - 1
    }
    return "."
}

fn try_resolve_use(name, base_dir) {
    let mut candidates = []
    candidates = candidates.push(base_dir + "/" + name + ".hexa")
    candidates = candidates.push(base_dir + "/../" + name + ".hexa")
    candidates = candidates.push("self/ml/" + name + ".hexa")
    candidates = candidates.push("self/" + name + ".hexa")
    let _hroot = env_var("HEXA_LANG")
    if len(_hroot) > 0 {
        candidates = candidates.push(_hroot + "/self/ml/" + name + ".hexa")
        candidates = candidates.push(_hroot + "/self/" + name + ".hexa")
    }
    let mut i = 0
    while i < len(candidates) {
        let p = candidates[i]
        if file_exists(p) {
            return p
        }
        i = i + 1
    }
    return ""
}

// Split a source string into lines (linear, no O(n²) concat)
fn split_lines(src) {
    let n = len(src)
    let mut lines = []
    let mut start = 0
    let mut i = 0
    while i < n {
        if src.substring(i, i + 1) == "\n" {
            lines = lines.push(src.substring(start, i))
            start = i + 1
        }
        i = i + 1
    }
    if start < n {
        lines = lines.push(src.substring(start, n))
    }
    return lines
}

// Check whether a module name is already resolved (linear scan).
fn __module_already_resolved(name) {
    let m = len(__resolved_modules)
    let mut k = 0
    while k < m {
        if __resolved_modules[k] == name { return true }
        k = k + 1
    }
    return false
}

// Parse `use "name"` from a line. Returns the name string, or "" on
// no match. Handles leading whitespace and an optional trailing `;`.
fn __parse_use_name(line) {
    let llen = len(line)
    let mut ti = 0
    while ti < llen && (line.substring(ti, ti + 1) == " " || line.substring(ti, ti + 1) == "\t") {
        ti = ti + 1
    }
    if ti + 4 > llen { return "" }
    if line.substring(ti, ti + 4) != "use " { return "" }
    let mut qi = ti + 4
    while qi < llen && (line.substring(qi, qi + 1) == " " || line.substring(qi, qi + 1) == "\t") {
        qi = qi + 1
    }
    if qi >= llen { return "" }
    if line.substring(qi, qi + 1) != "\"" { return "" }
    let mut ei = qi + 1
    while ei < llen && line.substring(ei, ei + 1) != "\"" {
        ei = ei + 1
    }
    if ei >= llen { return "" }
    return line.substring(qi + 1, ei)
}

// Resolve `use "name"` directives by inlining referenced `.hexa` files.
// Walks source line by line. On a `use "name"` line:
//   - if already resolved → emit a comment, skip
//   - else → search candidate paths via try_resolve_use, read the
//     file, mark resolved BEFORE recursing, recursively preprocess
//     the included content so chained `use` works, and inline it
//   - if no candidate found → emit a warning comment, continue
// Recursion is guarded by __resolved_modules (top-level mut list).
fn preprocess_use(src, base_dir) {
    let lines = split_lines(src)
    let n = len(lines)
    let mut out_parts = []
    let mut li = 0
    while li < n {
        let line = lines[li]
        let name = __parse_use_name(line)
        if name == "" {
            out_parts = out_parts.push(line)
        } else {
            if __module_already_resolved(name) {
                out_parts = out_parts.push("// [preprocess] already-included: " + name)
            } else {
                let resolved_path = try_resolve_use(name, base_dir)
                if resolved_path == "" {
                    out_parts = out_parts.push("// [preprocess] unresolved use: " + name + " (searched base_dir + self/{,ml}/)")
                } else {
                    // mark BEFORE recursing to break cycles
                    __resolved_modules = __resolved_modules.push(name)
                    let sub_src = read_file(resolved_path)
                    let sub_base = dirname_of(resolved_path)
                    let expanded = preprocess_use(sub_src, sub_base)
                    out_parts = out_parts.push("// [preprocess] begin inline: " + name + " (" + resolved_path + ")")
                    out_parts = out_parts.push(expanded)
                    out_parts = out_parts.push("// [preprocess] end inline: " + name)
                }
            }
        }
        li = li + 1
    }
    return out_parts.join("\n")
}

let src = read_file(input_path)
let base_dir = dirname_of(input_path)
// Guard against tokenize OOB at EOF by padding with trailing newline.
let preprocessed = preprocess_use(src, base_dir) + "\n"
println("[N1.1a] preprocessed: ", len(src), " → ", len(preprocessed), " bytes (", len(__resolved_modules), " modules inlined)")
let raw_toks = tokenize(preprocessed)
println("[N1.1a] tokens:", len(raw_toks))
let toks = lint_braces(raw_toks)
let ast = parse_program(toks)
println("[N1.1a] stmts:", len(ast))
let c_src = emit_program(ast)
safe_write_file(output_path, c_src)
println("[N1.1a] wrote", output_path, len(c_src), "bytes")
