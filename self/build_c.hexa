// self/build_c.hexa — N1.1a self-host C 트랜스파일러 (확장판)
// 지원: let, 정수, 문자열 리터럴, +-*/, println 다중 인자, // 주석
//
// 사용: ./hexa self/build_c.hexa  → 고정 입력 examples/calc_min.hexa
// 출력: build/calc_min.c  →  clang으로 빌드해서 실행

// ══════════════════════════════════════════════════════════════
// 유틸 (README "char ==" 한계 우회)
// ══════════════════════════════════════════════════════════════
// 모든 인덱싱은 codepoint 기준 (한글 주석 등 멀티바이트 안전).
// 1-char 문자열로 환원해 == 비교 (README "char ==" 한계 우회).
fn cs_at(cs, i) {
    // cs는 char 배열. 1-char 문자열로 변환해 == 비교 가능하게.
    return ("" + cs[i])
}

fn is_digit_s(c) {
    return c == "0" || c == "1" || c == "2" || c == "3" || c == "4" || c == "5" || c == "6" || c == "7" || c == "8" || c == "9"
}
// 빌트인 is_alpha(char) / is_alphanumeric(char) 사용
fn is_alpha_at(cs, i) {
    if cs_at(cs, i) == "_" { return true }
    return is_alpha(cs[i])
}
fn is_alnum_at(cs, i) {
    if cs_at(cs, i) == "_" { return true }
    return is_alphanumeric(cs[i])
}
fn is_space_s(c) { return c == " " || c == "\t" || c == "\r" }
// chars 배열 슬라이스 → string
fn slice_str(cs, a, b) {
    let mut out = ""
    let mut k = a
    while k < b {
        out = out + ("" + cs[k])
        k = k + 1
    }
    return out
}

// ══════════════════════════════════════════════════════════════
// 토크나이저
// ══════════════════════════════════════════════════════════════
struct Tok { kind: string, value: string }

fn mk(k, v) { return Tok { kind: k, value: v } }

fn tokenize(src) {
    let cs = src.chars()
    let n = len(cs)
    let mut toks = []
    let mut i = 0
    while i < n {
        let c = cs_at(cs, i)
        if is_space_s(c) {
            i = i + 1
        } else if c == "\n" {
            toks = toks.push(mk("NL", "\n"))
            i = i + 1
        } else if i + 1 < n && c == "/" && cs_at(cs, i + 1) == "/" {
            while i < n && cs_at(cs, i) != "\n" { i = i + 1 }
        } else if is_digit_s(c) {
            let start = i
            while i < n && is_digit_s(cs_at(cs, i)) { i = i + 1 }
            toks = toks.push(mk("Int", slice_str(cs, start, i)))
        } else if is_alpha_at(cs, i) {
            let start = i
            while i < n && is_alnum_at(cs, i) { i = i + 1 }
            let word = slice_str(cs, start, i)
            if word == "let" {
                toks = toks.push(mk("Let", word))
            } else {
                toks = toks.push(mk("Ident", word))
            }
        } else if c == "\"" {
            i = i + 1
            let start = i
            while i < n && cs_at(cs, i) != "\"" { i = i + 1 }
            let s = slice_str(cs, start, i)
            if i < n { i = i + 1 }
            toks = toks.push(mk("Str", s))
        } else if c == "(" {
            toks = toks.push(mk("LP", c))
            i = i + 1
        } else if c == ")" {
            toks = toks.push(mk("RP", c))
            i = i + 1
        } else if c == "," {
            toks = toks.push(mk("Comma", c))
            i = i + 1
        } else if c == "=" {
            toks = toks.push(mk("Eq", c))
            i = i + 1
        } else if c == "+" {
            toks = toks.push(mk("Plus", c))
            i = i + 1
        } else if c == "-" {
            toks = toks.push(mk("Minus", c))
            i = i + 1
        } else if c == "*" {
            toks = toks.push(mk("Star", c))
            i = i + 1
        } else if c == "/" {
            toks = toks.push(mk("Slash", c))
            i = i + 1
        } else {
            i = i + 1
        }
    }
    toks = toks.push(mk("EOF", ""))
    return toks
}

// ══════════════════════════════════════════════════════════════
// 파서 (recursive descent, 모듈 전역 상태)
// AST 노드: kind 별 필드 의미가 다른 단일 구조체
// ══════════════════════════════════════════════════════════════
struct Node {
    kind: string,    // "Int" | "Str" | "Ident" | "Bin" | "Call" | "Let" | "ExprStmt"
    value: string,   // 리터럴/이름
    op: string,      // 이진 연산자
    left: string,    // Node (any field)
    right: string,
    args: string     // Node[]
}

fn empty() {
    return Node { kind: "", value: "", op: "", left: "", right: "", args: [] }
}

fn n_int(v) {
    return Node { kind: "Int", value: v, op: "", left: "", right: "", args: [] }
}
fn n_str(v) {
    return Node { kind: "Str", value: v, op: "", left: "", right: "", args: [] }
}
fn n_ident(v) {
    return Node { kind: "Ident", value: v, op: "", left: "", right: "", args: [] }
}
fn n_bin(op, l, r) {
    return Node { kind: "Bin", value: "", op: op, left: l, right: r, args: [] }
}
fn n_call(callee, args) {
    return Node { kind: "Call", value: "", op: "", left: callee, right: "", args: args }
}
fn n_let(name, val) {
    return Node { kind: "Let", value: name, op: "", left: val, right: "", args: [] }
}
fn n_exprstmt(e) {
    return Node { kind: "ExprStmt", value: "", op: "", left: e, right: "", args: [] }
}

// 파서 상태
let mut p_toks = []
let mut p_pos = 0

fn p_peek() { return p_toks[p_pos] }
fn p_kind() { return p_toks[p_pos].kind }
fn p_advance() {
    let t = p_toks[p_pos]
    p_pos = p_pos + 1
    return t
}
fn p_eat(k) {
    if p_kind() == k {
        p_advance()
        return true
    }
    return false
}
fn p_skip_nl() {
    while p_kind() == "NL" { p_advance() }
}

fn parse_primary() {
    let t = p_peek()
    if t.kind == "Int" {
        p_advance()
        return n_int(t.value)
    }
    if t.kind == "Str" {
        p_advance()
        return n_str(t.value)
    }
    if t.kind == "Ident" {
        p_advance()
        if p_kind() == "LP" {
            // call
            p_advance()
            let mut args = []
            if p_kind() != "RP" {
                args = args.push(parse_expr())
                while p_eat("Comma") { args = args.push(parse_expr()) }
            }
            p_eat("RP")
            return n_call(n_ident(t.value), args)
        }
        return n_ident(t.value)
    }
    if t.kind == "LP" {
        p_advance()
        let e = parse_expr()
        p_eat("RP")
        return e
    }
    println("parse error: unexpected", t.kind, t.value)
    p_advance()
    return empty()
}

fn parse_mul() {
    let mut left = parse_primary()
    while p_kind() == "Star" || p_kind() == "Slash" {
        let op = p_advance().value
        let right = parse_primary()
        left = n_bin(op, left, right)
    }
    return left
}

fn parse_add() {
    let mut left = parse_mul()
    while p_kind() == "Plus" || p_kind() == "Minus" {
        let op = p_advance().value
        let right = parse_mul()
        left = n_bin(op, left, right)
    }
    return left
}

fn parse_expr() { return parse_add() }

fn parse_stmt() {
    p_skip_nl()
    if p_kind() == "Let" {
        p_advance()
        let name = p_advance().value
        p_eat("Eq")
        let val = parse_expr()
        return n_let(name, val)
    }
    let e = parse_expr()
    return n_exprstmt(e)
}

fn parse_program(toks) {
    p_toks = toks
    p_pos = 0
    let mut stmts = []
    p_skip_nl()
    while p_kind() != "EOF" {
        stmts = stmts.push(parse_stmt())
        p_skip_nl()
    }
    return stmts
}

// ══════════════════════════════════════════════════════════════
// 타입 추론 (아주 단순: Int/Str)
// ══════════════════════════════════════════════════════════════
let mut env_names = []
let mut env_types = []

fn env_lookup(name) {
    let mut i = 0
    while i < len(env_names) {
        if env_names[i] == name { return env_types[i] }
        i = i + 1
    }
    return "Int" // 기본
}

fn env_set(name, ty) {
    env_names = env_names.push(name)
    env_types = env_types.push(ty)
}

fn type_of(node) {
    if node.kind == "Int" { return "Int" }
    if node.kind == "Str" { return "Str" }
    if node.kind == "Ident" { return env_lookup(node.value) }
    if node.kind == "Bin" { return "Int" }
    if node.kind == "Call" { return "Int" }
    return "Int"
}

// ══════════════════════════════════════════════════════════════
// C 코드젠
// ══════════════════════════════════════════════════════════════

fn emit_expr(node) {
    if node.kind == "Int" { return node.value }
    if node.kind == "Str" { return "\"" + node.value + "\"" }
    if node.kind == "Ident" { return node.value }
    if node.kind == "Bin" {
        return "(" + emit_expr(node.left) + " " + node.op + " " + emit_expr(node.right) + ")"
    }
    if node.kind == "Call" {
        // println special-case → printf
        let callee = node.left
        if callee.kind == "Ident" && callee.value == "println" {
            return emit_println(node.args)
        }
        // 일반 호출: 미지원
        return "/* unsupported call */ 0"
    }
    return "0"
}

fn emit_println(args) {
    // 인자 개수만큼 fmt 조합. 인자 사이 공백.
    let mut fmt = ""
    let mut vals = ""
    let mut i = 0
    while i < len(args) {
        if i > 0 { fmt = fmt + " " }
        let a = args[i]
        let t = type_of(a)
        if t == "Str" {
            fmt = fmt + "%s"
        } else {
            fmt = fmt + "%ld"
        }
        if len(vals) > 0 { vals = vals + ", " }
        if t == "Str" {
            vals = vals + emit_expr(a)
        } else {
            vals = vals + "(long)(" + emit_expr(a) + ")"
        }
        i = i + 1
    }
    fmt = fmt + "\\n"
    if len(args) == 0 {
        return "printf(\"\\n\")"
    }
    return "printf(\"" + fmt + "\", " + vals + ")"
}

fn emit_stmt(node) {
    if node.kind == "Let" {
        let val = node.left
        let t = type_of(val)
        env_set(node.value, t)
        if t == "Str" {
            return "    const char* " + node.value + " = " + emit_expr(val) + ";\n"
        }
        return "    long " + node.value + " = " + emit_expr(val) + ";\n"
    }
    if node.kind == "ExprStmt" {
        return "    " + emit_expr(node.left) + ";\n"
    }
    return "    /* unsupported stmt */\n"
}

fn emit_program(stmts) {
    let mut out = "#include <stdio.h>\n\nint main(void) {\n"
    let mut i = 0
    while i < len(stmts) {
        out = out + emit_stmt(stmts[i])
        i = i + 1
    }
    out = out + "    return 0;\n}\n"
    return out
}

// ══════════════════════════════════════════════════════════════
// 엔트리
// ══════════════════════════════════════════════════════════════
let input_path = "examples/calc_min.hexa"
let output_path = "build/calc_min.c"

let src = read_file(input_path)
let toks = tokenize(src)
println("[N1.1a] tokens:", len(toks))
let ast = parse_program(toks)
println("[N1.1a] stmts:", len(ast))
let c_src = emit_program(ast)
write_file(output_path, c_src)
println("[N1.1a] wrote", output_path, len(c_src), "bytes")
