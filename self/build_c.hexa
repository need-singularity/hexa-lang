// self/build_c.hexa — N1.1a self-host C 트랜스파일러 (확장판)
// 지원: let, 정수, 문자열 리터럴, +-*/, println 다중 인자, // 주석
//
// 사용: ./hexa self/build_c.hexa  → 고정 입력 examples/calc_min.hexa
// 출력: build/calc_min.c  →  clang으로 빌드해서 실행

// ══════════════════════════════════════════════════════════════
// 유틸 (README "char ==" 한계 우회)
// ══════════════════════════════════════════════════════════════
// 모든 인덱싱은 codepoint 기준 (한글 주석 등 멀티바이트 안전).
// 1-char 문자열로 환원해 == 비교 (README "char ==" 한계 우회).
fn cs_at(cs, i) {
    // cs는 char 배열. 1-char 문자열로 변환해 == 비교 가능하게.
    return ("" + cs[i])
}

fn is_digit_s(c) {
    return c == "0" || c == "1" || c == "2" || c == "3" || c == "4" || c == "5" || c == "6" || c == "7" || c == "8" || c == "9"
}
// 빌트인 is_alpha(char) / is_alphanumeric(char) 사용
fn is_alpha_at(cs, i) {
    if cs_at(cs, i) == "_" { return true }
    return is_alpha(cs[i])
}
fn is_alnum_at(cs, i) {
    if cs_at(cs, i) == "_" { return true }
    return is_alphanumeric(cs[i])
}
fn is_space_s(c) { return c == " " || c == "\t" || c == "\r" }
// chars 배열 슬라이스 → string
fn slice_str(cs, a, b) {
    let mut out = ""
    let mut k = a
    while k < b {
        out = out + ("" + cs[k])
        k = k + 1
    }
    return out
}

// ══════════════════════════════════════════════════════════════
// 토크나이저
// ══════════════════════════════════════════════════════════════
struct Tok { kind: string, value: string }

fn mk(k, v) { return Tok { kind: k, value: v } }

fn tokenize(src) {
    let cs = src.chars()
    let n = len(cs)
    let mut toks = []
    let mut i = 0
    while i < n {
        let c = cs_at(cs, i)
        if is_space_s(c) {
            i = i + 1
        } else if c == "\n" {
            toks = toks.push(mk("NL", "\n"))
            i = i + 1
        } else if i + 1 < n && c == "/" && cs_at(cs, i + 1) == "/" {
            while i < n && cs_at(cs, i) != "\n" { i = i + 1 }
        } else if is_digit_s(c) {
            let start = i
            while i < n && is_digit_s(cs_at(cs, i)) { i = i + 1 }
            let mut is_float = false
            // . 다음에 숫자가 오면 float
            if i < n && cs_at(cs, i) == "." && i + 1 < n && is_digit_s(cs_at(cs, i + 1)) {
                is_float = true
                i = i + 1
                while i < n && is_digit_s(cs_at(cs, i)) { i = i + 1 }
            }
            // 지수 e/E 다음에 (옵션 부호) + 숫자
            if i < n && (cs_at(cs, i) == "e" || cs_at(cs, i) == "E") {
                is_float = true
                i = i + 1
                if i < n && (cs_at(cs, i) == "+" || cs_at(cs, i) == "-") { i = i + 1 }
                while i < n && is_digit_s(cs_at(cs, i)) { i = i + 1 }
            }
            if is_float {
                toks = toks.push(mk("Float", slice_str(cs, start, i)))
            } else {
                toks = toks.push(mk("Int", slice_str(cs, start, i)))
            }
        } else if is_alpha_at(cs, i) {
            let start = i
            while i < n && is_alnum_at(cs, i) { i = i + 1 }
            let word = slice_str(cs, start, i)
            if word == "let" {
                toks = toks.push(mk("Let", word))
            } else if word == "mut" {
                toks = toks.push(mk("Mut", word))
            } else if word == "if" {
                toks = toks.push(mk("If", word))
            } else if word == "else" {
                toks = toks.push(mk("Else", word))
            } else if word == "while" {
                toks = toks.push(mk("While", word))
            } else if word == "for" {
                toks = toks.push(mk("For", word))
            } else if word == "in" {
                toks = toks.push(mk("In", word))
            } else if word == "struct" {
                toks = toks.push(mk("Struct", word))
            } else if word == "fn" {
                toks = toks.push(mk("Fn", word))
            } else if word == "return" {
                toks = toks.push(mk("Return", word))
            } else if word == "break" {
                toks = toks.push(mk("Break", word))
            } else if word == "continue" {
                toks = toks.push(mk("Continue", word))
            } else if word == "match" {
                toks = toks.push(mk("Match", word))
            } else if word == "true" {
                toks = toks.push(mk("True", word))
            } else if word == "false" {
                toks = toks.push(mk("False", word))
            } else {
                toks = toks.push(mk("Ident", word))
            }
        } else if c == "\"" {
            i = i + 1
            let mut s = ""
            while i < n && cs_at(cs, i) != "\"" {
                let ch = cs_at(cs, i)
                if ch == "\\" && i + 1 < n {
                    // 이스케이프: 원본 \X를 C로 그대로 넘김 — C도 동일 시퀀스 이해
                    let nx = cs_at(cs, i + 1)
                    s = s + "\\" + nx
                    i = i + 2
                } else {
                    s = s + ch
                    i = i + 1
                }
            }
            if i < n { i = i + 1 }
            toks = toks.push(mk("Str", s))
        } else if c == "(" {
            toks = toks.push(mk("LP", c))
            i = i + 1
        } else if c == ")" {
            toks = toks.push(mk("RP", c))
            i = i + 1
        } else if c == "," {
            toks = toks.push(mk("Comma", c))
            i = i + 1
        } else if c == "=" {
            if i + 1 < n && cs_at(cs, i + 1) == "=" {
                toks = toks.push(mk("EqEq", "=="))
                i = i + 2
            } else if i + 1 < n && cs_at(cs, i + 1) == ">" {
                toks = toks.push(mk("FatArrow", "=>"))
                i = i + 2
            } else {
                toks = toks.push(mk("Eq", c))
                i = i + 1
            }
        } else if c == "!" {
            if i + 1 < n && cs_at(cs, i + 1) == "=" {
                toks = toks.push(mk("NotEq", "!="))
                i = i + 2
            } else {
                toks = toks.push(mk("Bang", c))
                i = i + 1
            }
        } else if c == "<" {
            if i + 1 < n && cs_at(cs, i + 1) == "=" {
                toks = toks.push(mk("LE", "<="))
                i = i + 2
            } else {
                toks = toks.push(mk("LT", c))
                i = i + 1
            }
        } else if c == ">" {
            if i + 1 < n && cs_at(cs, i + 1) == "=" {
                toks = toks.push(mk("GE", ">="))
                i = i + 2
            } else {
                toks = toks.push(mk("GT", c))
                i = i + 1
            }
        } else if c == "&" {
            if i + 1 < n && cs_at(cs, i + 1) == "&" {
                toks = toks.push(mk("AndAnd", "&&"))
                i = i + 2
            } else {
                i = i + 1
            }
        } else if c == "|" {
            if i + 1 < n && cs_at(cs, i + 1) == "|" {
                toks = toks.push(mk("OrOr", "||"))
                i = i + 2
            } else {
                i = i + 1
            }
        } else if c == "{" {
            toks = toks.push(mk("LB", c))
            i = i + 1
        } else if c == "}" {
            toks = toks.push(mk("RB", c))
            i = i + 1
        } else if c == "[" {
            toks = toks.push(mk("LSq", c))
            i = i + 1
        } else if c == "]" {
            toks = toks.push(mk("RSq", c))
            i = i + 1
        } else if c == "%" {
            toks = toks.push(mk("Percent", c))
            i = i + 1
        } else if c == ":" {
            toks = toks.push(mk("Colon", c))
            i = i + 1
        } else if c == "." {
            if i + 1 < n && cs_at(cs, i + 1) == "." {
                toks = toks.push(mk("DotDot", ".."))
                i = i + 2
            } else {
                toks = toks.push(mk("Dot", c))
                i = i + 1
            }
        } else if c == "+" {
            if i + 1 < n && cs_at(cs, i + 1) == "=" {
                toks = toks.push(mk("PlusEq", "+="))
                i = i + 2
            } else {
                toks = toks.push(mk("Plus", c))
                i = i + 1
            }
        } else if c == "-" {
            if i + 1 < n && cs_at(cs, i + 1) == "=" {
                toks = toks.push(mk("MinusEq", "-="))
                i = i + 2
            } else {
                toks = toks.push(mk("Minus", c))
                i = i + 1
            }
        } else if c == "*" {
            if i + 1 < n && cs_at(cs, i + 1) == "=" {
                toks = toks.push(mk("StarEq", "*="))
                i = i + 2
            } else {
                toks = toks.push(mk("Star", c))
                i = i + 1
            }
        } else if c == "/" {
            if i + 1 < n && cs_at(cs, i + 1) == "=" {
                toks = toks.push(mk("SlashEq", "/="))
                i = i + 2
            } else {
                toks = toks.push(mk("Slash", c))
                i = i + 1
            }
        } else {
            i = i + 1
        }
    }
    toks = toks.push(mk("EOF", ""))
    return toks
}

// ══════════════════════════════════════════════════════════════
// 파서 (recursive descent, 모듈 전역 상태)
// AST 노드: kind 별 필드 의미가 다른 단일 구조체
// ══════════════════════════════════════════════════════════════
struct Node {
    kind: string,
    value: string,
    op: string,
    left: string,
    right: string,
    cond: string,
    then_b: string,
    else_b: string,
    args: string
}

fn empty() {
    return Node { kind: "", value: "", op: "", left: "", right: "", cond: "", then_b: "", else_b: "", args: [] }
}
fn n_int(v) {
    return Node { kind: "Int", value: v, op: "", left: "", right: "", cond: "", then_b: "", else_b: "", args: [] }
}
fn n_float(v) {
    return Node { kind: "Float", value: v, op: "", left: "", right: "", cond: "", then_b: "", else_b: "", args: [] }
}
fn n_str(v) {
    return Node { kind: "Str", value: v, op: "", left: "", right: "", cond: "", then_b: "", else_b: "", args: [] }
}
fn n_bool(v) {
    return Node { kind: "Bool", value: v, op: "", left: "", right: "", cond: "", then_b: "", else_b: "", args: [] }
}
fn n_ident(v) {
    return Node { kind: "Ident", value: v, op: "", left: "", right: "", cond: "", then_b: "", else_b: "", args: [] }
}
fn n_bin(op, l, r) {
    return Node { kind: "Bin", value: "", op: op, left: l, right: r, cond: "", then_b: "", else_b: "", args: [] }
}
fn n_unary(op, e) {
    return Node { kind: "Unary", value: "", op: op, left: e, right: "", cond: "", then_b: "", else_b: "", args: [] }
}
fn n_call(callee, call_args) {
    return Node { kind: "Call", value: "", op: "", left: callee, right: "", cond: "", then_b: "", else_b: "", args: call_args }
}
fn n_let(name, val) {
    return Node { kind: "Let", value: name, op: "", left: val, right: "", cond: "", then_b: "", else_b: "", args: [] }
}
fn n_assign(name, val) {
    return Node { kind: "Assign", value: name, op: "", left: val, right: "", cond: "", then_b: "", else_b: "", args: [] }
}
fn n_exprstmt(e) {
    return Node { kind: "ExprStmt", value: "", op: "", left: e, right: "", cond: "", then_b: "", else_b: "", args: [] }
}
fn n_if(c, t, e) {
    return Node { kind: "If", value: "", op: "", left: "", right: "", cond: c, then_b: t, else_b: e, args: [] }
}
fn n_while(c, b) {
    return Node { kind: "While", value: "", op: "", left: "", right: "", cond: c, then_b: b, else_b: "", args: [] }
}
fn n_for_range(var_name, lo, hi, body) {
    // value = 변수명, left = lo, right = hi, then_b = body
    return Node { kind: "ForRange", value: var_name, op: "", left: lo, right: hi, cond: "", then_b: body, else_b: "", args: [] }
}
fn n_block(stmts) {
    return Node { kind: "Block", value: "", op: "", left: "", right: "", cond: "", then_b: "", else_b: "", args: stmts }
}
fn n_fn(name, params, body) {
    // params: 이름 문자열 배열, body: Block 노드
    return Node { kind: "Fn", value: name, op: "", left: "", right: body, cond: "", then_b: "", else_b: "", args: params }
}
fn n_return(e) {
    return Node { kind: "Return", value: "", op: "", left: e, right: "", cond: "", then_b: "", else_b: "", args: [] }
}
fn n_arrlit(elems) {
    return Node { kind: "ArrLit", value: "", op: "", left: "", right: "", cond: "", then_b: "", else_b: "", args: elems }
}
fn n_index(arr, idx) {
    return Node { kind: "Index", value: "", op: "", left: arr, right: idx, cond: "", then_b: "", else_b: "", args: [] }
}
fn n_structdecl(name, field_names) {
    return Node { kind: "StructDecl", value: name, op: "", left: "", right: "", cond: "", then_b: "", else_b: "", args: field_names }
}
fn n_structlit(name, vals) {
    return Node { kind: "StructLit", value: name, op: "", left: "", right: "", cond: "", then_b: "", else_b: "", args: vals }
}
fn n_field(obj, name) {
    return Node { kind: "Field", value: name, op: "", left: obj, right: "", cond: "", then_b: "", else_b: "", args: [] }
}
fn n_method(obj, name, m_args) {
    return Node { kind: "Method", value: name, op: "", left: obj, right: "", cond: "", then_b: "", else_b: "", args: m_args }
}

// 파서 상태
let mut p_toks = []
let mut p_pos = 0

fn p_peek() { return p_toks[p_pos] }
fn p_kind() { return p_toks[p_pos].kind }
fn p_advance() {
    let t = p_toks[p_pos]
    p_pos = p_pos + 1
    return t
}
fn p_eat(k) {
    if p_kind() == k {
        p_advance()
        return true
    }
    return false
}
fn p_skip_nl() {
    while p_kind() == "NL" { p_advance() }
}

fn parse_primary() {
    let t = p_peek()
    if t.kind == "Int" {
        p_advance()
        return n_int(t.value)
    }
    if t.kind == "Float" {
        p_advance()
        return n_float(t.value)
    }
    if t.kind == "Str" {
        p_advance()
        return n_str(t.value)
    }
    if t.kind == "True" {
        p_advance()
        return n_bool("true")
    }
    if t.kind == "False" {
        p_advance()
        return n_bool("false")
    }
    if t.kind == "Bang" {
        p_advance()
        return n_unary("!", parse_primary())
    }
    if t.kind == "Minus" {
        p_advance()
        return n_unary("-", parse_primary())
    }
    if t.kind == "Ident" {
        p_advance()
        let mut node = n_ident(t.value)
        // struct 리터럴: Ident { field: val, ... }
        // (블록과 구분: 다음이 LB이고, 그 다음이 Ident: 값 패턴)
        if p_kind() == "LB" && struct_field_index(t.value, "") >= -10 && len(struct_lookup_fields(t.value)) > 0 {
            p_advance() // {
            p_skip_nl()
            let mut vals = []
            while p_kind() != "RB" && p_kind() != "EOF" {
                let _fname = p_advance().value
                p_eat("Colon")
                vals = vals.push(parse_expr())
                if p_kind() == "Comma" { p_advance() }
                p_skip_nl()
            }
            p_eat("RB")
            node = n_structlit(t.value, vals)
        } else if p_kind() == "LP" {
            p_advance()
            let mut call_args = []
            if p_kind() != "RP" {
                call_args = call_args.push(parse_expr())
                while p_eat("Comma") { call_args = call_args.push(parse_expr()) }
            }
            p_eat("RP")
            node = n_call(n_ident(t.value), call_args)
        }
        // postfix [idx] 또는 .field
        let mut cont = true
        while cont {
            if p_kind() == "LSq" {
                p_advance()
                let idx = parse_expr()
                p_eat("RSq")
                node = n_index(node, idx)
            } else if p_kind() == "Dot" {
                p_advance()
                let fname = p_advance().value
                if p_kind() == "LP" {
                    p_advance()
                    let mut m_args = []
                    if p_kind() != "RP" {
                        m_args = m_args.push(parse_expr())
                        while p_eat("Comma") { m_args = m_args.push(parse_expr()) }
                    }
                    p_eat("RP")
                    node = n_method(node, fname, m_args)
                } else {
                    node = n_field(node, fname)
                }
            } else {
                cont = false
            }
        }
        return node
    }
    if t.kind == "LP" {
        p_advance()
        let e = parse_expr()
        p_eat("RP")
        return e
    }
    if t.kind == "LSq" {
        p_advance()
        let mut elems = []
        if p_kind() != "RSq" {
            elems = elems.push(parse_expr())
            while p_eat("Comma") { elems = elems.push(parse_expr()) }
        }
        p_eat("RSq")
        return n_arrlit(elems)
    }
    println("parse error: unexpected", t.kind, t.value)
    p_advance()
    return empty()
}

fn parse_mul() {
    let mut left = parse_primary()
    while p_kind() == "Star" || p_kind() == "Slash" || p_kind() == "Percent" {
        let op = p_advance().value
        let right = parse_primary()
        left = n_bin(op, left, right)
    }
    return left
}

fn parse_add() {
    let mut left = parse_mul()
    while p_kind() == "Plus" || p_kind() == "Minus" {
        let op = p_advance().value
        let right = parse_mul()
        left = n_bin(op, left, right)
    }
    return left
}

fn parse_cmp() {
    let mut left = parse_add()
    while p_kind() == "EqEq" || p_kind() == "NotEq" || p_kind() == "LT" || p_kind() == "LE" || p_kind() == "GT" || p_kind() == "GE" {
        let op = p_advance().value
        let right = parse_add()
        left = n_bin(op, left, right)
    }
    return left
}

fn parse_and() {
    let mut left = parse_cmp()
    while p_kind() == "AndAnd" {
        p_advance()
        let right = parse_cmp()
        left = n_bin("&&", left, right)
    }
    return left
}

fn parse_or() {
    let mut left = parse_and()
    while p_kind() == "OrOr" {
        p_advance()
        let right = parse_and()
        left = n_bin("||", left, right)
    }
    return left
}

fn parse_expr() { return parse_or() }

fn parse_block() {
    p_eat("LB")
    p_skip_nl()
    let mut stmts = []
    while p_kind() != "RB" && p_kind() != "EOF" {
        stmts = stmts.push(parse_stmt())
        p_skip_nl()
    }
    p_eat("RB")
    return n_block(stmts)
}

fn parse_if() {
    p_eat("If")
    let c = parse_expr()
    let t = parse_block()
    p_skip_nl()
    let mut e = empty()
    if p_kind() == "Else" {
        p_advance()
        p_skip_nl()
        // else if 지원: else 다음이 If면 재귀, 아니면 블록.
        if p_kind() == "If" {
            // 체인을 단일-stmt 블록으로 감싸 emit_stmt가 처리
            let inner = parse_if()
            let mut stmts = []
            stmts = stmts.push(inner)
            e = n_block(stmts)
        } else {
            e = parse_block()
        }
    }
    return n_if(c, t, e)
}

fn parse_while() {
    p_eat("While")
    let c = parse_expr()
    let b = parse_block()
    return n_while(c, b)
}

fn parse_match() {
    // match expr {
    //     pattern1 => stmt_or_block
    //     pattern2 => stmt_or_block
    //     _ => stmt_or_block
    // }
    // → if (tmp == p1) { ... } else if (tmp == p2) { ... } else { ... }
    // subject expr는 임시 변수에 할당
    p_eat("Match")
    let subj = parse_expr()
    p_eat("LB")
    p_skip_nl()
    let mut patterns = []
    let mut bodies = []
    let mut has_default = false
    let mut default_body = empty()
    while p_kind() != "RB" && p_kind() != "EOF" {
        let pat = parse_expr()
        p_eat("FatArrow")
        // body: block 또는 단일 stmt (return 포함)
        let mut body = empty()
        if p_kind() == "LB" {
            body = parse_block()
        } else {
            let st = parse_stmt()
            let mut stmts = []
            stmts = stmts.push(st)
            body = n_block(stmts)
        }
        // wildcard _ → default
        if pat.kind == "Ident" && pat.value == "_" {
            has_default = true
            default_body = body
        } else {
            patterns = patterns.push(pat)
            bodies = bodies.push(body)
        }
        if p_kind() == "Comma" { p_advance() }
        p_skip_nl()
    }
    p_eat("RB")
    // desugar from the end
    let mut tail = default_body
    if !has_default {
        tail = empty()  // 빈 else
    }
    let mut k = len(patterns) - 1
    while k >= 0 {
        let cond = n_bin("==", subj, patterns[k])
        tail = n_if(cond, bodies[k], tail)
        k = k - 1
    }
    return tail
}

fn parse_for() {
    p_eat("For")
    let var_name = p_advance().value
    p_eat("In")
    let lo = parse_expr()
    p_eat("DotDot")
    let hi = parse_expr()
    let b = parse_block()
    return n_for_range(var_name, lo, hi, b)
}

fn parse_struct() {
    p_eat("Struct")
    let name = p_advance().value
    p_eat("LB")
    p_skip_nl()
    let mut fields = []
    while p_kind() != "RB" && p_kind() != "EOF" {
        if p_kind() == "Ident" {
            let fname = p_advance().value
            fields = fields.push(fname)
            // 옵션 타입 어노테이션: `: type` 무시
            if p_kind() == "Colon" {
                p_advance()
                // 타입 토큰 1개 (Ident) 소비
                if p_kind() == "Ident" { p_advance() }
            }
            if p_kind() == "Comma" { p_advance() }
            p_skip_nl()
        } else {
            // 알 수 없는 토큰: 강제 진행 (무한 루프 방지)
            p_advance()
        }
    }
    p_eat("RB")
    struct_register(name, fields)
    return n_structdecl(name, fields)
}

fn parse_fn() {
    p_eat("Fn")
    let name = p_advance().value
    p_eat("LP")
    let mut params = []
    if p_kind() != "RP" {
        params = params.push(p_advance().value)
        while p_eat("Comma") {
            params = params.push(p_advance().value)
        }
    }
    p_eat("RP")
    let body = parse_block()
    return n_fn(name, params, body)
}

fn parse_stmt() {
    p_skip_nl()
    let k = p_kind()
    if k == "Let" {
        p_advance()
        if p_kind() == "Mut" { p_advance() }
        let name = p_advance().value
        p_eat("Eq")
        let val = parse_expr()
        return n_let(name, val)
    }
    if k == "Struct" { return parse_struct() }
    if k == "Fn" { return parse_fn() }
    if k == "Return" {
        p_advance()
        // bare `return` (다음이 NL/RB/EOF)
        let nk = p_kind()
        if nk == "NL" || nk == "RB" || nk == "EOF" {
            return n_return(empty())
        }
        let e = parse_expr()
        return n_return(e)
    }
    if k == "Break" {
        p_advance()
        return Node { kind: "Break", value: "", op: "", left: "", right: "", cond: "", then_b: "", else_b: "", args: [] }
    }
    if k == "Continue" {
        p_advance()
        return Node { kind: "Continue", value: "", op: "", left: "", right: "", cond: "", then_b: "", else_b: "", args: [] }
    }
    if k == "If" { return parse_if() }
    if k == "While" { return parse_while() }
    if k == "For" { return parse_for() }
    if k == "Match" { return parse_match() }
    // 식별자로 시작 → 할당, 복합할당, 또는 식
    if k == "Ident" {
        let next_k = p_toks[p_pos + 1].kind
        if next_k == "Eq" {
            let name = p_advance().value
            p_advance()
            let val = parse_expr()
            return n_assign(name, val)
        }
        // 복합할당: x += y  →  x = x + y
        if next_k == "PlusEq" || next_k == "MinusEq" || next_k == "StarEq" || next_k == "SlashEq" {
            let name = p_advance().value
            let op_tok = p_advance()
            let rhs = parse_expr()
            let bin_op = op_tok.value.substring(0, 1)  // "+" "-" "*" "/"
            let new_rhs = n_bin(bin_op, n_ident(name), rhs)
            return n_assign(name, new_rhs)
        }
    }
    let e = parse_expr()
    return n_exprstmt(e)
}

fn parse_program(toks) {
    p_toks = toks
    p_pos = 0
    let mut stmts = []
    p_skip_nl()
    while p_kind() != "EOF" {
        stmts = stmts.push(parse_stmt())
        p_skip_nl()
    }
    return stmts
}

// ══════════════════════════════════════════════════════════════
// 타입 추론 (아주 단순: Int/Str)
// ══════════════════════════════════════════════════════════════
let mut env_names = []
let mut env_types = []
let mut env_lens = []  // 배열/struct length

// struct 테이블: 이름 + 필드명 배열 (parallel arrays)
let mut struct_tab_names = []
let mut struct_tab_fields = []  // 각 원소: 필드명 string 배열

// fn 테이블: 이름 + 반환 타입 (Int/Str/Float/DynArr)
let mut fn_tab_names = []
let mut fn_tab_rets = []
// 매개변수 Float/Str 힌트: 이름+인덱스 조합으로 추적 ("fnname/0" 등)
let mut fn_float_params = []
let mut fn_str_params = []
fn fn_register(name, ret_type) {
    fn_tab_names = fn_tab_names.push(name)
    fn_tab_rets = fn_tab_rets.push(ret_type)
}
fn fn_lookup_ret(name) {
    let mut i = 0
    while i < len(fn_tab_names) {
        if fn_tab_names[i] == name { return fn_tab_rets[i] }
        i = i + 1
    }
    return "Int"
}
fn fn_mark_float_param(name, idx) {
    let key = name + "/" + to_string(idx)
    let mut i = 0
    while i < len(fn_float_params) {
        if fn_float_params[i] == key { return }
        i = i + 1
    }
    fn_float_params = fn_float_params.push(key)
}
fn fn_param_is_float(name, idx) {
    let key = name + "/" + to_string(idx)
    let mut i = 0
    while i < len(fn_float_params) {
        if fn_float_params[i] == key { return true }
        i = i + 1
    }
    return false
}
fn fn_mark_str_param(name, idx) {
    let key = name + "/" + to_string(idx)
    let mut i = 0
    while i < len(fn_str_params) {
        if fn_str_params[i] == key { return }
        i = i + 1
    }
    fn_str_params = fn_str_params.push(key)
}
fn fn_param_is_str(name, idx) {
    let key = name + "/" + to_string(idx)
    let mut i = 0
    while i < len(fn_str_params) {
        if fn_str_params[i] == key { return true }
        i = i + 1
    }
    return false
}

fn struct_register(name, fields) {
    struct_tab_names = struct_tab_names.push(name)
    struct_tab_fields = struct_tab_fields.push(fields)
}
fn struct_lookup_fields(name) {
    let mut i = 0
    while i < len(struct_tab_names) {
        if struct_tab_names[i] == name { return struct_tab_fields[i] }
        i = i + 1
    }
    return []
}
fn struct_field_index(struct_name, field_name) {
    let fields = struct_lookup_fields(struct_name)
    let mut i = 0
    while i < len(fields) {
        if fields[i] == field_name { return i }
        i = i + 1
    }
    return -1
}

fn env_lookup(name) {
    let mut i = 0
    while i < len(env_names) {
        if env_names[i] == name { return env_types[i] }
        i = i + 1
    }
    return "Int"
}
fn env_lookup_len(name) {
    let mut i = 0
    while i < len(env_names) {
        if env_names[i] == name { return env_lens[i] }
        i = i + 1
    }
    return -1
}
fn env_set(name, ty) {
    env_names = env_names.push(name)
    env_types = env_types.push(ty)
    env_lens = env_lens.push(-1)
}
fn env_set_arr(name, alen) {
    env_names = env_names.push(name)
    env_types = env_types.push("Arr")
    env_lens = env_lens.push(alen)
}
fn env_set_struct(name, struct_name) {
    env_names = env_names.push(name)
    env_types = env_types.push(struct_name)  // "Point" 등
    let fields = struct_lookup_fields(struct_name)
    env_lens = env_lens.push(len(fields))
}

fn type_of(node) {
    if node.kind == "Int" { return "Int" }
    if node.kind == "Float" { return "Float" }
    if node.kind == "Str" { return "Str" }
    if node.kind == "Bool" { return "Int" }
    if node.kind == "Ident" { return env_lookup(node.value) }
    if node.kind == "Bin" {
        let lt = type_of(node.left)
        let rt = type_of(node.right)
        if node.op == "+" && (lt == "Str" || rt == "Str") { return "Str" }
        if lt == "Float" || rt == "Float" { return "Float" }
        return "Int"
    }
    if node.kind == "Unary" { return type_of(node.left) }
    if node.kind == "Call" {
        let cl = node.left
        if cl.kind == "Ident" {
            if cl.value == "read_file" { return "Str" }
            if cl.value == "to_string" { return "Str" }
            if cl.value == "args" { return "StrArr" }
            if cl.value == "arg" { return "Str" }
            if cl.value == "argc" { return "Int" }
            if cl.value == "exec" { return "Str" }
            if cl.value == "append_file" { return "Int" }
            // 사용자 함수 lookup
            return fn_lookup_ret(cl.value)
        }
        return "Int"
    }
    if node.kind == "StructLit" { return node.value }
    if node.kind == "Field" { return "Int" }
    if node.kind == "Index" {
        let o = node.left
        if o.kind == "Ident" && env_lookup(o.value) == "StrArr" { return "Str" }
        return "Int"
    }
    if node.kind == "Method" {
        if node.value == "substring" { return "Str" }
        if node.value == "len" { return "Int" }
        if node.value == "push" { return "DynArr" }
        if node.value == "chars" { return "DynArr" }
        if node.value == "split" { return "StrArr" }
        if node.value == "trim" { return "Str" }
        if node.value == "to_upper" { return "Str" }
        if node.value == "to_lower" { return "Str" }
        return "Int"
    }
    return "Int"
}

// ══════════════════════════════════════════════════════════════
// C 코드젠
// ══════════════════════════════════════════════════════════════

fn coerce_str(node, t) {
    if t == "Str" { return emit_expr(node) }
    return "hexa_int_to_str((long)(" + emit_expr(node) + "))"
}

fn emit_expr(node) {
    if node.kind == "Int" { return node.value }
    if node.kind == "Float" { return node.value }
    if node.kind == "Bool" { return node.value }
    if node.kind == "Str" { return "\"" + node.value + "\"" }
    if node.kind == "Ident" { return node.value }
    if node.kind == "Bin" {
        // Str concat 런타임 호출
        if node.op == "+" {
            let lt = type_of(node.left)
            let rt = type_of(node.right)
            if lt == "Str" || rt == "Str" {
                let l_code = coerce_str(node.left, lt)
                let r_code = coerce_str(node.right, rt)
                return "hexa_concat(" + l_code + ", " + r_code + ")"
            }
        }
        // Str == / != → strcmp
        if node.op == "==" || node.op == "!=" {
            let lt = type_of(node.left)
            let rt = type_of(node.right)
            if lt == "Str" && rt == "Str" {
                let cmp = "strcmp(" + emit_expr(node.left) + ", " + emit_expr(node.right) + ")"
                if node.op == "==" { return "(" + cmp + " == 0)" }
                return "(" + cmp + " != 0)"
            }
        }
        return "(" + emit_expr(node.left) + " " + node.op + " " + emit_expr(node.right) + ")"
    }
    if node.kind == "Unary" {
        return "(" + node.op + emit_expr(node.left) + ")"
    }
    if node.kind == "Index" {
        let obj = node.left
        if obj.kind == "Ident" {
            let t = env_lookup(obj.value)
            if t == "DynArr" {
                return obj.value + ".d[" + emit_expr(node.right) + "]"
            }
            if t == "StrArr" {
                return "((const char*)" + obj.value + ".d[" + emit_expr(node.right) + "])"
            }
        }
        // 식 전체 타입으로 분기 (ex. s.chars()[i] → hexa_arr.d[i])
        let ot = type_of(obj)
        if ot == "DynArr" {
            return "(" + emit_expr(obj) + ").d[" + emit_expr(node.right) + "]"
        }
        if ot == "StrArr" {
            return "((const char*)(" + emit_expr(obj) + ").d[" + emit_expr(node.right) + "])"
        }
        return emit_expr(obj) + "[" + emit_expr(node.right) + "]"
    }
    if node.kind == "Method" {
        let obj_code = emit_expr(node.left)
        let mname = node.value
        if mname == "substring" {
            let a = emit_expr(node.args[0])
            let b = emit_expr(node.args[1])
            return "hexa_substr(" + obj_code + ", " + a + ", " + b + ")"
        }
        if mname == "len" {
            let lo = node.left
            if lo.kind == "Ident" {
                let lt = env_lookup(lo.value)
                if lt == "DynArr" || lt == "StrArr" {
                    return lo.value + ".n"
                }
            }
            // 일반 타입 분기
            let ot = type_of(node.left)
            if ot == "DynArr" || ot == "StrArr" {
                return "(" + obj_code + ").n"
            }
            return "hexa_str_len(" + obj_code + ")"
        }
        if mname == "push" {
            let arg_expr = node.args[0]
            let arg_t = type_of(arg_expr)
            let arg_code = emit_expr(arg_expr)
            if arg_t == "Str" {
                return "hexa_arr_push(" + obj_code + ", (long)(" + arg_code + "))"
            }
            return "hexa_arr_push(" + obj_code + ", " + arg_code + ")"
        }
        if mname == "chars" {
            return "hexa_chars(" + obj_code + ")"
        }
        if mname == "split" {
            return "hexa_split(" + obj_code + ", " + emit_expr(node.args[0]) + ")"
        }
        if mname == "contains" {
            return "hexa_contains(" + obj_code + ", " + emit_expr(node.args[0]) + ")"
        }
        if mname == "index_of" {
            return "hexa_index_of(" + obj_code + ", " + emit_expr(node.args[0]) + ")"
        }
        if mname == "starts_with" {
            return "hexa_starts_with(" + obj_code + ", " + emit_expr(node.args[0]) + ")"
        }
        if mname == "ends_with" {
            return "hexa_ends_with(" + obj_code + ", " + emit_expr(node.args[0]) + ")"
        }
        if mname == "trim" {
            return "hexa_trim(" + obj_code + ")"
        }
        if mname == "to_upper" {
            return "hexa_to_upper(" + obj_code + ")"
        }
        if mname == "to_lower" {
            return "hexa_to_lower(" + obj_code + ")"
        }
        return "/* unsupported method ." + mname + " */ 0"
    }
    if node.kind == "Field" {
        // obj.field → obj[idx], idx는 obj의 struct 타입에서 lookup
        let obj = node.left
        let mut sname = ""
        if obj.kind == "Ident" {
            sname = env_lookup(obj.value)
        }
        if obj.kind == "StructLit" {
            sname = obj.value
        }
        let idx = struct_field_index(sname, node.value)
        if idx < 0 {
            return "/* unknown field " + node.value + " */ 0"
        }
        return emit_expr(obj) + "[" + to_string(idx) + "]"
    }
    if node.kind == "StructLit" {
        // 컴파일된 형태: {v1, v2, ...} (initializer)
        // 또는 표현식 컨텍스트에서: (long[]){v1, v2, ...}
        let mut s = "(long[]){"
        let mut i = 0
        while i < len(node.args) {
            if i > 0 { s = s + ", " }
            s = s + emit_expr(node.args[i])
            i = i + 1
        }
        s = s + "}"
        return s
    }
    if node.kind == "Call" {
        let callee = node.left
        if callee.kind == "Ident" && callee.value == "println" {
            return emit_println(node.args)
        }
        // len(arr): 정적 배열(compile-time) / DynArr / StrArr / 문자열
        if callee.kind == "Ident" && callee.value == "len" {
            if len(node.args) == 1 && node.args[0].kind == "Ident" {
                let vn = node.args[0].value
                let vt = env_lookup(vn)
                if vt == "DynArr" || vt == "StrArr" {
                    return vn + ".n"
                }
                let alen = env_lookup_len(vn)
                if alen >= 0 {
                    return to_string(alen)
                }
            }
            return "hexa_str_len(" + emit_expr(node.args[0]) + ")"
        }
        // 파일 I/O + to_string
        if callee.kind == "Ident" && callee.value == "read_file" {
            return "hexa_read_file(" + emit_expr(node.args[0]) + ")"
        }
        if callee.kind == "Ident" && callee.value == "write_file" {
            return "hexa_write_file(" + emit_expr(node.args[0]) + ", " + emit_expr(node.args[1]) + ")"
        }
        if callee.kind == "Ident" && callee.value == "append_file" {
            return "hexa_append_file(" + emit_expr(node.args[0]) + ", " + emit_expr(node.args[1]) + ")"
        }
        if callee.kind == "Ident" && callee.value == "exec" {
            return "hexa_exec(" + emit_expr(node.args[0]) + ")"
        }
        if callee.kind == "Ident" && callee.value == "to_string" {
            let t = type_of(node.args[0])
            if t == "Str" { return emit_expr(node.args[0]) }
            return "hexa_int_to_str((long)(" + emit_expr(node.args[0]) + "))"
        }
        if callee.kind == "Ident" && callee.value == "is_alpha" {
            return "hexa_is_alpha(" + emit_expr(node.args[0]) + ")"
        }
        if callee.kind == "Ident" && callee.value == "is_alphanumeric" {
            return "hexa_is_alnum(" + emit_expr(node.args[0]) + ")"
        }
        if callee.kind == "Ident" && callee.value == "args" {
            return "hexa_args()"
        }
        if callee.kind == "Ident" && callee.value == "arg" {
            return "hexa_arg(" + emit_expr(node.args[0]) + ")"
        }
        if callee.kind == "Ident" && callee.value == "argc" {
            return "hexa_argc()"
        }
        if callee.kind == "Ident" && callee.value == "parse_int" {
            return "hexa_parse_int(" + emit_expr(node.args[0]) + ")"
        }
        // 사용자 함수 호출 (모두 long 반환 가정)
        if callee.kind == "Ident" {
            let mut s = callee.value + "("
            let mut i = 0
            while i < len(node.args) {
                if i > 0 { s = s + ", " }
                s = s + emit_expr(node.args[i])
                i = i + 1
            }
            s = s + ")"
            return s
        }
        return "/* unsupported call */ 0"
    }
    return "0"
}

fn emit_println(pl_args) {
    let mut fmt = ""
    let mut vals = ""
    let mut i = 0
    while i < len(pl_args) {
        if i > 0 { fmt = fmt + " " }
        let a = pl_args[i]
        let t = type_of(a)
        if t == "Str" {
            fmt = fmt + "%s"
        } else if t == "Float" {
            fmt = fmt + "%g"
        } else {
            fmt = fmt + "%ld"
        }
        if len(vals) > 0 { vals = vals + ", " }
        if t == "Str" {
            vals = vals + emit_expr(a)
        } else if t == "Float" {
            vals = vals + "(double)(" + emit_expr(a) + ")"
        } else {
            vals = vals + "(long)(" + emit_expr(a) + ")"
        }
        i = i + 1
    }
    fmt = fmt + "\\n"
    if len(pl_args) == 0 {
        return "printf(\"\\n\")"
    }
    return "printf(\"" + fmt + "\", " + vals + ")"
}

let mut indent_level = 1

fn pad() {
    let mut s = ""
    let mut k = 0
    while k < indent_level {
        s = s + "    "
        k = k + 1
    }
    return s
}

fn emit_stmt(node) {
    if node.kind == "StructDecl" {
        // codegen 시점엔 이미 struct_register 됐음. C 출력은 주석으로만 표시.
        return ""
    }
    if node.kind == "Let" {
        let val = node.left
        if val.kind == "ArrLit" {
            // 첫 원소 타입으로 DynArr vs StrArr 결정
            let n_items = len(val.args)
            let mut elem_type = "Int"
            if n_items > 0 {
                let e0 = val.args[0]
                if e0.kind == "Str" {
                    elem_type = "Str"
                }
            }
            env_names = env_names.push(node.value)
            if elem_type == "Str" {
                env_types = env_types.push("StrArr")
            } else {
                env_types = env_types.push("DynArr")
            }
            env_lens = env_lens.push(-1)
            if n_items == 0 {
                return pad() + "hexa_arr " + node.value + " = hexa_arr_new();\n"
            }
            let mut s = pad() + "hexa_arr " + node.value + " = hexa_arr_lit((long[]){"
            let mut i = 0
            while i < n_items {
                if i > 0 { s = s + ", " }
                if elem_type == "Str" {
                    s = s + "(long)(" + emit_expr(val.args[i]) + ")"
                } else {
                    s = s + emit_expr(val.args[i])
                }
                i = i + 1
            }
            s = s + "}, " + to_string(n_items) + ");\n"
            return s
        }
        if val.kind == "StructLit" {
            env_set_struct(node.value, val.value)
            let mut s = pad() + "long " + node.value + "[" + to_string(len(val.args)) + "] = {"
            let mut i = 0
            while i < len(val.args) {
                if i > 0 { s = s + ", " }
                s = s + emit_expr(val.args[i])
                i = i + 1
            }
            s = s + "};\n"
            return s
        }
        let t = type_of(val)
        env_set(node.value, t)
        if t == "Str" {
            return pad() + "const char* " + node.value + " = " + emit_expr(val) + ";\n"
        }
        if t == "Float" {
            return pad() + "double " + node.value + " = " + emit_expr(val) + ";\n"
        }
        if t == "DynArr" {
            return pad() + "hexa_arr " + node.value + " = " + emit_expr(val) + ";\n"
        }
        if t == "StrArr" {
            // env 타입 교정: env_set에서 StrArr로 저장되도록 마지막 entry 교체
            // env_set은 이미 "StrArr"로 저장됨 (t 그대로 push)
            return pad() + "hexa_arr " + node.value + " = " + emit_expr(val) + ";\n"
        }
        return pad() + "long " + node.value + " = " + emit_expr(val) + ";\n"
    }
    if node.kind == "Assign" {
        return pad() + node.value + " = " + emit_expr(node.left) + ";\n"
    }
    if node.kind == "ExprStmt" {
        return pad() + emit_expr(node.left) + ";\n"
    }
    if node.kind == "If" {
        let mut out = pad() + "if (" + emit_expr(node.cond) + ") "
        out = out + emit_block(node.then_b)
        let eb = node.else_b
        if eb.kind == "Block" {
            out = out + " else " + emit_block(eb)
        } else if eb.kind == "If" {
            // else-if 체인: 재귀 emit, 들여쓰기 조정
            out = out + " else "
            // trim 시작 공백 — emit_stmt는 pad() 앞에 붙임
            let sub = emit_stmt(eb)
            // pad 접두사 제거
            let pn = len(pad())
            out = out + sub.substring(pn, sub.len())
        }
        out = out + "\n"
        return out
    }
    if node.kind == "While" {
        return pad() + "while (" + emit_expr(node.cond) + ") " + emit_block(node.then_b) + "\n"
    }
    if node.kind == "ForRange" {
        let v = node.value
        env_set(v, "Int")
        let lo = emit_expr(node.left)
        let hi = emit_expr(node.right)
        return pad() + "for (long " + v + " = " + lo + "; " + v + " < " + hi + "; " + v + "++) " + emit_block(node.then_b) + "\n"
    }
    if node.kind == "Return" {
        if node.left.kind == "" {
            return pad() + "return 0;\n"
        }
        return pad() + "return " + emit_expr(node.left) + ";\n"
    }
    if node.kind == "Break" {
        return pad() + "break;\n"
    }
    if node.kind == "Continue" {
        return pad() + "continue;\n"
    }
    return pad() + "/* unsupported stmt */\n"
}

// 재귀 탐색: pname을 가진 `pname.method(...)` 혹은 str concat 사용 검사
fn find_method_on_param(node, pname, mname) {
    if node.kind == "Method" {
        let obj = node.left
        if obj.kind == "Ident" && obj.value == pname && node.value == mname {
            return true
        }
    }
    if node.kind == "Bin" || node.kind == "Index" {
        if find_method_on_param(node.left, pname, mname) { return true }
        return find_method_on_param(node.right, pname, mname)
    }
    if node.kind == "Unary" || node.kind == "ExprStmt" || node.kind == "Return" || node.kind == "Let" || node.kind == "Assign" || node.kind == "Field" || node.kind == "Method" {
        if find_method_on_param(node.left, pname, mname) { return true }
    }
    if node.kind == "If" {
        if find_method_on_param(node.cond, pname, mname) { return true }
        if find_method_on_param(node.then_b, pname, mname) { return true }
        return find_method_on_param(node.else_b, pname, mname)
    }
    if node.kind == "While" || node.kind == "ForRange" {
        if find_method_on_param(node.cond, pname, mname) { return true }
        return find_method_on_param(node.then_b, pname, mname)
    }
    if node.kind == "Block" {
        let stmts = node.args
        let mut i = 0
        while i < len(stmts) {
            if find_method_on_param(stmts[i], pname, mname) { return true }
            i = i + 1
        }
    }
    if node.kind == "Call" || node.kind == "Method" {
        let a2 = node.args
        let mut i = 0
        while i < len(a2) {
            if find_method_on_param(a2[i], pname, mname) { return true }
            i = i + 1
        }
    }
    return false
}

// node 트리에서 `pname.field` 패턴을 찾아 struct 이름 추론
fn find_param_field(node, pname) {
    if node.kind == "Field" {
        let obj = node.left
        if obj.kind == "Ident" && obj.value == pname {
            // 필드명으로 등록된 struct 검색
            let fname = node.value
            let mut si = 0
            while si < len(struct_tab_names) {
                let sname = struct_tab_names[si]
                if struct_field_index(sname, fname) >= 0 {
                    return sname
                }
                si = si + 1
            }
        }
    }
    // 자식 노드 재귀 — 단일 자식 필드들
    if node.kind == "Bin" || node.kind == "Index" {
        let l = find_param_field(node.left, pname)
        if l != "" { return l }
        return find_param_field(node.right, pname)
    }
    if node.kind == "Unary" || node.kind == "Field" || node.kind == "ExprStmt" || node.kind == "Return" || node.kind == "Let" || node.kind == "Assign" {
        return find_param_field(node.left, pname)
    }
    if node.kind == "If" {
        let c = find_param_field(node.cond, pname)
        if c != "" { return c }
        let t = find_param_field(node.then_b, pname)
        if t != "" { return t }
        return find_param_field(node.else_b, pname)
    }
    if node.kind == "While" {
        let c = find_param_field(node.cond, pname)
        if c != "" { return c }
        return find_param_field(node.then_b, pname)
    }
    if node.kind == "Block" {
        let stmts = node.args
        let mut i = 0
        while i < len(stmts) {
            let r = find_param_field(stmts[i], pname)
            if r != "" { return r }
            i = i + 1
        }
    }
    if node.kind == "Call" {
        let args2 = node.args
        let mut i = 0
        while i < len(args2) {
            let r = find_param_field(args2[i], pname)
            if r != "" { return r }
            i = i + 1
        }
    }
    return ""
}

fn find_param_indexed(node, pname) {
    if node.kind == "Index" {
        let obj = node.left
        if obj.kind == "Ident" && obj.value == pname {
            return true
        }
    }
    if node.kind == "Bin" || node.kind == "Index" {
        if find_param_indexed(node.left, pname) { return true }
        return find_param_indexed(node.right, pname)
    }
    if node.kind == "Unary" || node.kind == "ExprStmt" || node.kind == "Return" || node.kind == "Let" || node.kind == "Assign" || node.kind == "Field" || node.kind == "Method" {
        if find_param_indexed(node.left, pname) { return true }
    }
    if node.kind == "If" {
        if find_param_indexed(node.cond, pname) { return true }
        if find_param_indexed(node.then_b, pname) { return true }
        return find_param_indexed(node.else_b, pname)
    }
    if node.kind == "While" || node.kind == "ForRange" {
        if find_param_indexed(node.cond, pname) { return true }
        return find_param_indexed(node.then_b, pname)
    }
    if node.kind == "Block" {
        let stmts = node.args
        let mut i = 0
        while i < len(stmts) {
            if find_param_indexed(stmts[i], pname) { return true }
            i = i + 1
        }
    }
    if node.kind == "Call" || node.kind == "Method" {
        let a2 = node.args
        let mut i = 0
        while i < len(a2) {
            if find_param_indexed(a2[i], pname) { return true }
            i = i + 1
        }
    }
    return false
}

fn find_len_call_on_param(node, pname) {
    if node.kind == "Call" {
        let c = node.left
        if c.kind == "Ident" && c.value == "len" && len(node.args) == 1 {
            let a0 = node.args[0]
            if a0.kind == "Ident" && a0.value == pname {
                return true
            }
        }
    }
    if node.kind == "Bin" || node.kind == "Index" {
        if find_len_call_on_param(node.left, pname) { return true }
        return find_len_call_on_param(node.right, pname)
    }
    if node.kind == "Unary" || node.kind == "ExprStmt" || node.kind == "Return" || node.kind == "Let" || node.kind == "Assign" || node.kind == "Field" || node.kind == "Method" {
        if find_len_call_on_param(node.left, pname) { return true }
    }
    if node.kind == "If" {
        if find_len_call_on_param(node.cond, pname) { return true }
        if find_len_call_on_param(node.then_b, pname) { return true }
        return find_len_call_on_param(node.else_b, pname)
    }
    if node.kind == "While" || node.kind == "ForRange" {
        if find_len_call_on_param(node.cond, pname) { return true }
        return find_len_call_on_param(node.then_b, pname)
    }
    if node.kind == "Block" {
        let stmts = node.args
        let mut i = 0
        while i < len(stmts) {
            if find_len_call_on_param(stmts[i], pname) { return true }
            i = i + 1
        }
    }
    if node.kind == "Call" || node.kind == "Method" {
        let a2 = node.args
        let mut i = 0
        while i < len(a2) {
            if find_len_call_on_param(a2[i], pname) { return true }
            i = i + 1
        }
    }
    return false
}

// 블록 내 로컬 Let 타입을 추적하며 return 타입 추론.
// 반환된 Ident의 타입은 동일 블록 내 Let 초기화 값의 타입으로 간주.
let mut local_env_names = []
let mut local_env_types = []
fn local_env_lookup(name) {
    let mut i = 0
    while i < len(local_env_names) {
        if local_env_names[i] == name { return local_env_types[i] }
        i = i + 1
    }
    return ""
}
fn local_env_set(name, t) {
    local_env_names = local_env_names.push(name)
    local_env_types = local_env_types.push(t)
}
fn resolve_expr_type(e) {
    if e.kind == "Int" { return "Int" }
    if e.kind == "Float" { return "Float" }
    if e.kind == "Str" { return "Str" }
    if e.kind == "Bool" { return "Int" }
    if e.kind == "Ident" {
        let t = local_env_lookup(e.value)
        if t != "" { return t }
        return type_of(e)
    }
    if e.kind == "Bin" {
        let lt = resolve_expr_type(e.left)
        let rt = resolve_expr_type(e.right)
        if e.op == "+" && (lt == "Str" || rt == "Str") { return "Str" }
        if lt == "Float" || rt == "Float" { return "Float" }
        return "Int"
    }
    if e.kind == "Unary" { return resolve_expr_type(e.left) }
    if e.kind == "Call" { return type_of(e) }
    return type_of(e)
}

fn find_return_type(node) {
    if node.kind == "Return" {
        return resolve_expr_type(node.left)
    }
    if node.kind == "Let" {
        // body 순회 중 Let을 만나면 로컬 env 갱신
        local_env_set(node.value, resolve_expr_type(node.left))
        return ""
    }
    if node.kind == "Block" {
        let stmts = node.args
        let mut i = 0
        while i < len(stmts) {
            let t = find_return_type(stmts[i])
            if t != "" { return t }
            i = i + 1
        }
    }
    if node.kind == "If" {
        let t = find_return_type(node.then_b)
        if t != "" { return t }
        return find_return_type(node.else_b)
    }
    if node.kind == "While" || node.kind == "ForRange" {
        return find_return_type(node.then_b)
    }
    return ""
}

fn infer_param_c_type(body, pname) {
    // 우선순위: Struct > DynArr > Str > Int
    let sname = find_param_field(body, pname)
    if sname != "" { return "struct:" + sname }
    // DynArr: .push 또는 (len(p) + p[i])
    if find_method_on_param(body, pname, "push") { return "dynarr" }
    if find_len_call_on_param(body, pname) && find_param_indexed(body, pname) { return "dynarr" }
    // Str: .substring 또는 .len (메서드 형태)
    if find_method_on_param(body, pname, "substring") { return "str" }
    if find_method_on_param(body, pname, "len") { return "str" }
    return "int"
}

fn fn_c_ret_type(node) {
    let rt = find_return_type(node.right)
    if rt == "Str" { return "const char*" }
    if rt == "Float" { return "double" }
    if rt == "DynArr" { return "hexa_arr" }
    return "long"
}

fn emit_fn_decl(node) {
    // 파라미터 타입을 미리 env에 넣어 find_return_type이 Float 전파 가능
    let params = node.args
    let mut pi3 = 0
    while pi3 < len(params) {
        let pn = params[pi3]
        if fn_param_is_float(node.value, pi3) {
            env_set(pn, "Float")
        }
        pi3 = pi3 + 1
    }
    // 그 다음 return 타입 재계산
    local_env_names = []
    local_env_types = []
    let rt2 = find_return_type(node.right)
    let mut ret_c = "long"
    if rt2 == "Str" { ret_c = "const char*" }
    if rt2 == "Float" { ret_c = "double" }
    if rt2 == "DynArr" { ret_c = "hexa_arr" }
    let mut s = ret_c + " " + node.value + "("
    let mut i = 0
    while i < len(params) {
        if i > 0 { s = s + ", " }
        let pname = params[i]
        if fn_param_is_float(node.value, i) {
            s = s + "double " + pname
            env_set(pname, "Float")
            i = i + 1
        } else if fn_param_is_str(node.value, i) {
            s = s + "const char* " + pname
            env_set(pname, "Str")
            i = i + 1
        } else {
            let ty = infer_param_c_type(node.right, pname)
            if ty == "dynarr" {
                s = s + "hexa_arr " + pname
                env_names = env_names.push(pname)
                env_types = env_types.push("DynArr")
                env_lens = env_lens.push(-1)
            } else if ty == "str" {
                s = s + "const char* " + pname
                env_set(pname, "Str")
            } else if ty.substring(0, 7) == "struct:" {
                let sn = ty.substring(7, ty.len())
                s = s + "long *" + pname
                env_set_struct(pname, sn)
            } else {
                s = s + "long " + pname
                env_set(pname, "Int")
            }
            i = i + 1
        }
    }
    s = s + ") "
    s = s + emit_block(node.right) + "\n\n"
    return s
}

fn emit_fn_proto(node) {
    // 반환 타입도 Float 힌트 고려해 재계산
    let params = node.args
    local_env_names = []
    local_env_types = []
    let mut pi4 = 0
    while pi4 < len(params) {
        if fn_param_is_float(node.value, pi4) {
            local_env_set(params[pi4], "Float")
        }
        pi4 = pi4 + 1
    }
    let rt3 = find_return_type(node.right)
    let mut ret_c = "long"
    if rt3 == "Str" { ret_c = "const char*" }
    if rt3 == "Float" { ret_c = "double" }
    if rt3 == "DynArr" { ret_c = "hexa_arr" }
    let mut s = ret_c + " " + node.value + "("
    let mut i = 0
    while i < len(params) {
        if i > 0 { s = s + ", " }
        let pname = params[i]
        if fn_param_is_float(node.value, i) {
            s = s + "double " + pname
        } else if fn_param_is_str(node.value, i) {
            s = s + "const char* " + pname
        } else {
            let ty = infer_param_c_type(node.right, pname)
            if ty == "dynarr" {
                s = s + "hexa_arr " + pname
            } else if ty == "str" {
                s = s + "const char* " + pname
            } else if ty.substring(0, 7) == "struct:" {
                s = s + "long *" + pname
            } else {
                s = s + "long " + pname
            }
        }
        i = i + 1
    }
    s = s + ");\n"
    return s
}

fn emit_block(node) {
    // node.kind == "Block", node.args == stmts
    let mut out = "{\n"
    indent_level = indent_level + 1
    let stmts = node.args
    let mut i = 0
    while i < len(stmts) {
        out = out + emit_stmt(stmts[i])
        i = i + 1
    }
    indent_level = indent_level - 1
    out = out + pad() + "}"
    return out
}

fn emit_runtime() {
    // 최소 문자열/정수 런타임 — 정적 bump arena (64KB)
    let mut r = ""
    r = r + "#include <stdio.h>\n"
    r = r + "#include <string.h>\n"
    r = r + "#include <stdlib.h>\n\n"
    r = r + "#define HEXA_ARENA_SIZE (16*1024*1024)\n"
    r = r + "static char* hexa_arena = NULL;\n"
    r = r + "static size_t hexa_arena_p = 0;\n"
    r = r + "static void hexa_arena_init(void) {\n"
    r = r + "    if (!hexa_arena) hexa_arena = (char*)malloc(HEXA_ARENA_SIZE);\n"
    r = r + "}\n"
    r = r + "static char* hexa_alloc(size_t n) {\n"
    r = r + "    hexa_arena_init();\n"
    r = r + "    if (hexa_arena_p + n >= HEXA_ARENA_SIZE) { fprintf(stderr, \"hexa_arena overflow\\n\"); exit(1); }\n"
    r = r + "    char* p = &hexa_arena[hexa_arena_p];\n"
    r = r + "    hexa_arena_p += n;\n"
    r = r + "    return p;\n"
    r = r + "}\n"
    r = r + "static const char* hexa_concat(const char* a, const char* b) {\n"
    r = r + "    size_t la = strlen(a), lb = strlen(b);\n"
    r = r + "    char* p = hexa_alloc(la + lb + 1);\n"
    r = r + "    memcpy(p, a, la); memcpy(p + la, b, lb); p[la + lb] = 0;\n"
    r = r + "    return p;\n"
    r = r + "}\n"
    r = r + "static const char* hexa_int_to_str(long v) {\n"
    r = r + "    char* p = hexa_alloc(24);\n"
    r = r + "    snprintf(p, 24, \"%ld\", v);\n"
    r = r + "    return p;\n"
    r = r + "}\n"
    r = r + "static const char* hexa_substr(const char* s, long a, long b) {\n"
    r = r + "    long sl = (long)strlen(s);\n"
    r = r + "    if (a < 0) a = 0; if (b > sl) b = sl; if (a > b) a = b;\n"
    r = r + "    long n = b - a;\n"
    r = r + "    char* p = hexa_alloc(n + 1);\n"
    r = r + "    memcpy(p, s + a, n); p[n] = 0;\n"
    r = r + "    return p;\n"
    r = r + "}\n"
    r = r + "static long hexa_str_len(const char* s) { return (long)strlen(s); }\n"
    r = r + "static long hexa_contains(const char* h, const char* n) { return strstr(h, n) ? 1 : 0; }\n"
    r = r + "static long hexa_index_of(const char* h, const char* n) {\n"
    r = r + "    const char* p = strstr(h, n); if (!p) return -1;\n"
    r = r + "    return (long)(p - h);\n"
    r = r + "}\n"
    r = r + "static long hexa_starts_with(const char* h, const char* n) {\n"
    r = r + "    size_t ln = strlen(n); return strncmp(h, n, ln) == 0 ? 1 : 0;\n"
    r = r + "}\n"
    r = r + "static long hexa_ends_with(const char* h, const char* n) {\n"
    r = r + "    size_t lh = strlen(h), ln = strlen(n);\n"
    r = r + "    if (ln > lh) return 0; return strcmp(h + lh - ln, n) == 0 ? 1 : 0;\n"
    r = r + "}\n"
    r = r + "static const char* hexa_trim(const char* s) {\n"
    r = r + "    while (*s == ' ' || *s == '\\t' || *s == '\\n' || *s == '\\r') s++;\n"
    r = r + "    long n = (long)strlen(s);\n"
    r = r + "    while (n > 0 && (s[n-1]==' '||s[n-1]=='\\t'||s[n-1]=='\\n'||s[n-1]=='\\r')) n--;\n"
    r = r + "    char* p = hexa_alloc(n + 1);\n"
    r = r + "    memcpy(p, s, n); p[n] = 0;\n"
    r = r + "    return p;\n"
    r = r + "}\n"
    r = r + "static const char* hexa_to_upper(const char* s) {\n"
    r = r + "    long n = (long)strlen(s); char* p = hexa_alloc(n + 1);\n"
    r = r + "    for (long i = 0; i < n; i++) { char c = s[i]; p[i] = (c>='a'&&c<='z') ? c - 32 : c; }\n"
    r = r + "    p[n] = 0; return p;\n"
    r = r + "}\n"
    r = r + "static const char* hexa_to_lower(const char* s) {\n"
    r = r + "    long n = (long)strlen(s); char* p = hexa_alloc(n + 1);\n"
    r = r + "    for (long i = 0; i < n; i++) { char c = s[i]; p[i] = (c>='A'&&c<='Z') ? c + 32 : c; }\n"
    r = r + "    p[n] = 0; return p;\n"
    r = r + "}\n"
    r = r + "static long hexa_parse_int(const char* s) {\n"
    r = r + "    while (*s == ' ' || *s == '\\t') s++;\n"
    r = r + "    long sign = 1; if (*s == '-') { sign = -1; s++; } else if (*s == '+') s++;\n"
    r = r + "    long v = 0; while (*s >= '0' && *s <= '9') { v = v*10 + (*s - '0'); s++; }\n"
    r = r + "    return sign * v;\n"
    r = r + "}\n"
    r = r + "static const char* hexa_read_file(const char* path) {\n"
    r = r + "    FILE* f = fopen(path, \"rb\");\n"
    r = r + "    if (!f) { fprintf(stderr, \"hexa_read_file: %s\\n\", path); exit(1); }\n"
    r = r + "    fseek(f, 0, SEEK_END); long sz = ftell(f); fseek(f, 0, SEEK_SET);\n"
    r = r + "    char* p = hexa_alloc(sz + 1);\n"
    r = r + "    fread(p, 1, sz, f); p[sz] = 0; fclose(f);\n"
    r = r + "    return p;\n"
    r = r + "}\n"
    r = r + "static long hexa_write_file(const char* path, const char* content) {\n"
    r = r + "    FILE* f = fopen(path, \"wb\");\n"
    r = r + "    if (!f) return 0;\n"
    r = r + "    size_t n = strlen(content);\n"
    r = r + "    fwrite(content, 1, n, f); fclose(f);\n"
    r = r + "    return (long)n;\n"
    r = r + "}\n"
    r = r + "static long hexa_append_file(const char* path, const char* content) {\n"
    r = r + "    FILE* f = fopen(path, \"ab\");\n"
    r = r + "    if (!f) return 0;\n"
    r = r + "    size_t n = strlen(content);\n"
    r = r + "    fwrite(content, 1, n, f); fclose(f);\n"
    r = r + "    return (long)n;\n"
    r = r + "}\n"
    r = r + "static const char* hexa_exec(const char* cmd) {\n"
    r = r + "    FILE* f = popen(cmd, \"r\");\n"
    r = r + "    if (!f) return \"\";\n"
    r = r + "    char buf[8192]; size_t total = 0;\n"
    r = r + "    char* out = hexa_alloc(8192);\n"
    r = r + "    size_t r; while ((r = fread(buf, 1, sizeof(buf), f)) > 0) {\n"
    r = r + "        if (total + r >= 8191) break;\n"
    r = r + "        memcpy(out + total, buf, r); total += r;\n"
    r = r + "    }\n"
    r = r + "    out[total] = 0; pclose(f);\n"
    r = r + "    while (total > 0 && (out[total-1] == '\\n' || out[total-1] == '\\r')) { out[--total] = 0; }\n"
    r = r + "    return out;\n"
    r = r + "}\n"
    // 동적 배열 런타임 — value semantics (return-new)
    r = r + "typedef struct { long* d; long n; long cap; } hexa_arr;\n"
    r = r + "static hexa_arr hexa_arr_new(void) { hexa_arr a = {NULL, 0, 0}; return a; }\n"
    r = r + "static hexa_arr hexa_arr_lit(const long* items, long n) {\n"
    r = r + "    hexa_arr a; a.d = (long*)malloc((n>0?n:1)*sizeof(long)); a.n = n; a.cap = (n>0?n:1);\n"
    r = r + "    if (n > 0) memcpy(a.d, items, n*sizeof(long));\n"
    r = r + "    return a;\n"
    r = r + "}\n"
    r = r + "static hexa_arr hexa_arr_push(hexa_arr a, long x) {\n"
    r = r + "    if (a.n >= a.cap) {\n"
    r = r + "        a.cap = a.cap ? a.cap * 2 : 4;\n"
    r = r + "        a.d = (long*)realloc(a.d, a.cap * sizeof(long));\n"
    r = r + "    }\n"
    r = r + "    a.d[a.n++] = x;\n"
    r = r + "    return a;\n"
    r = r + "}\n"
    r = r + "static long hexa_arr_len(hexa_arr a) { return a.n; }\n"
    r = r + "static long hexa_arr_get(hexa_arr a, long i) { return a.d[i]; }\n"
    // chars()/split/is_alpha/is_alphanumeric/args
    r = r + "static hexa_arr hexa_chars(const char* s) {\n"
    r = r + "    long n = (long)strlen(s);\n"
    r = r + "    hexa_arr a; a.d = (long*)malloc((n>0?n:1)*sizeof(long)); a.n = n; a.cap = (n>0?n:1);\n"
    r = r + "    for (long i = 0; i < n; i++) a.d[i] = (long)(unsigned char)s[i];\n"
    r = r + "    return a;\n"
    r = r + "}\n"
    r = r + "#include <ctype.h>\n"
    r = r + "static long hexa_is_alpha(long c) { return (long)(isalpha((int)c) ? 1 : 0); }\n"
    r = r + "static long hexa_is_alnum(long c) { return (long)(isalnum((int)c) ? 1 : 0); }\n"
    r = r + "static int hexa_main_argc = 0;\n"
    r = r + "static char** hexa_main_argv = NULL;\n"
    r = r + "static hexa_arr hexa_args(void) {\n"
    r = r + "    hexa_arr a; a.n = hexa_main_argc; a.cap = hexa_main_argc;\n"
    r = r + "    a.d = (long*)malloc((hexa_main_argc>0?hexa_main_argc:1)*sizeof(long));\n"
    r = r + "    for (int i = 0; i < hexa_main_argc; i++) a.d[i] = (long)hexa_main_argv[i];\n"
    r = r + "    return a;\n"
    r = r + "}\n"
    r = r + "static const char* hexa_arg(long i) {\n"
    r = r + "    if (i < 0 || i >= hexa_main_argc) return \"\";\n"
    r = r + "    return hexa_main_argv[i];\n"
    r = r + "}\n"
    r = r + "static long hexa_argc(void) { return (long)hexa_main_argc; }\n"
    r = r + "static hexa_arr hexa_split(const char* s, const char* sep) {\n"
    r = r + "    hexa_arr a = hexa_arr_new();\n"
    r = r + "    long sl = (long)strlen(sep); if (sl == 0) { return hexa_arr_push(a, (long)s); }\n"
    r = r + "    const char* cur = s;\n"
    r = r + "    while (1) {\n"
    r = r + "        const char* hit = strstr(cur, sep);\n"
    r = r + "        if (!hit) {\n"
    r = r + "            long ln = (long)strlen(cur);\n"
    r = r + "            char* p = hexa_alloc(ln + 1);\n"
    r = r + "            memcpy(p, cur, ln); p[ln] = 0;\n"
    r = r + "            a = hexa_arr_push(a, (long)p);\n"
    r = r + "            break;\n"
    r = r + "        }\n"
    r = r + "        long ln = hit - cur;\n"
    r = r + "        char* p = hexa_alloc(ln + 1);\n"
    r = r + "        memcpy(p, cur, ln); p[ln] = 0;\n"
    r = r + "        a = hexa_arr_push(a, (long)p);\n"
    r = r + "        cur = hit + sl;\n"
    r = r + "    }\n"
    r = r + "    return a;\n"
    r = r + "}\n\n"
    return r
}

fn walk_collect_float_calls(node) {
    if node.kind == "Call" {
        let cl = node.left
        if cl.kind == "Ident" {
            let mut i = 0
            while i < len(node.args) {
                let ai = node.args[i]
                if ai.kind == "Float" {
                    fn_mark_float_param(cl.value, i)
                }
                if ai.kind == "Str" {
                    fn_mark_str_param(cl.value, i)
                }
                i = i + 1
            }
        }
    }
    if node.kind == "Bin" || node.kind == "Index" {
        walk_collect_float_calls(node.left)
        walk_collect_float_calls(node.right)
    }
    if node.kind == "Unary" || node.kind == "ExprStmt" || node.kind == "Return" || node.kind == "Let" || node.kind == "Assign" || node.kind == "Field" || node.kind == "Method" {
        walk_collect_float_calls(node.left)
    }
    if node.kind == "If" {
        walk_collect_float_calls(node.cond)
        walk_collect_float_calls(node.then_b)
        walk_collect_float_calls(node.else_b)
    }
    if node.kind == "While" {
        walk_collect_float_calls(node.cond)
        walk_collect_float_calls(node.then_b)
    }
    if node.kind == "ForRange" {
        walk_collect_float_calls(node.left)
        walk_collect_float_calls(node.right)
        walk_collect_float_calls(node.then_b)
    }
    if node.kind == "Block" {
        let stmts = node.args
        let mut i = 0
        while i < len(stmts) {
            walk_collect_float_calls(stmts[i])
            i = i + 1
        }
    }
    if node.kind == "Call" || node.kind == "Method" {
        let a2 = node.args
        let mut i = 0
        while i < len(a2) {
            walk_collect_float_calls(a2[i])
            i = i + 1
        }
    }
    if node.kind == "Fn" {
        walk_collect_float_calls(node.right)
    }
}

fn emit_program(stmts) {
    // -1) Float 호출 사이트 수집
    let mut pi2 = 0
    while pi2 < len(stmts) {
        walk_collect_float_calls(stmts[pi2])
        pi2 = pi2 + 1
    }
    // 0) fn 테이블 등록 — 반환 타입을 콜 사이트에서 알 수 있도록
    let mut pi = 0
    while pi < len(stmts) {
        let s0 = stmts[pi]
        if s0.kind == "Fn" {
            local_env_names = []
            local_env_types = []
            let rt = find_return_type(s0.right)
            if rt == "" {
                fn_register(s0.value, "Int")
            } else {
                fn_register(s0.value, rt)
            }
        }
        pi = pi + 1
    }
    let mut out = emit_runtime()
    out = out + ""
    // 1) forward prototypes
    let mut i = 0
    while i < len(stmts) {
        if stmts[i].kind == "Fn" {
            out = out + emit_fn_proto(stmts[i])
        }
        i = i + 1
    }
    out = out + "\n"
    // 2) function definitions
    i = 0
    while i < len(stmts) {
        if stmts[i].kind == "Fn" {
            out = out + emit_fn_decl(stmts[i])
        }
        i = i + 1
    }
    // 3) main with non-fn stmts
    out = out + "int main(int argc, char** argv) {\n"
    out = out + "    hexa_main_argc = argc; hexa_main_argv = argv;\n"
    indent_level = 1
    i = 0
    while i < len(stmts) {
        if stmts[i].kind != "Fn" {
            out = out + emit_stmt(stmts[i])
        }
        i = i + 1
    }
    out = out + "    return 0;\n}\n"
    return out
}

// ══════════════════════════════════════════════════════════════
// 엔트리
// ══════════════════════════════════════════════════════════════
// CLI: ./hexa self/build_c.hexa <input.hexa> [output.c]
// 인자 없으면 기본값(에라토스테네스).
fn cli_args() {
    return args()
}
let _argv = cli_args()
let mut input_path = "examples/struct_min.hexa"
let mut output_path = "build/struct_min.c"
let _argc = len(_argv)
if _argc >= 3 {
    input_path = _argv[2]
}
if _argc >= 4 {
    output_path = _argv[3]
}

let src = read_file(input_path)
let toks = tokenize(src)
println("[N1.1a] tokens:", len(toks))
let ast = parse_program(toks)
println("[N1.1a] stmts:", len(ast))
let c_src = emit_program(ast)
write_file(output_path, c_src)
println("[N1.1a] wrote", output_path, len(c_src), "bytes")
