// ═══════════════════════════════════════════════════════════════════
//  test_siphash_pure.hexa — Tests for self/runtime/siphash_pure.hexa
//
//  Verifies: determinism, key sensitivity, input sensitivity,
//  known test vectors (computed from reference Python SipHash-2-4).
//
//  Run: ./hexa self/test_siphash_pure.hexa
//  No semicolons (P1). let mut for mutable (P15).
// ═══════════════════════════════════════════════════════════════════

import "runtime/bit_pure.hexa"
import "runtime/siphash_pure.hexa"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_true(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  SipHash-2-4 Pure Hexa Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Determinism ──────────────────────────────────────────────
println("--- Determinism ---")
let h1 = siphash_simple("hello")
let h2 = siphash_simple("hello")
check("same input same output", h1, h2)

let h3 = siphash_2_4("test", 42, 99)
let h4 = siphash_2_4("test", 42, 99)
check("same input+key same output", h3, h4)

// ── 2. Key sensitivity ─────────────────────────────────────────
println("")
println("--- Key sensitivity ---")
let ks1 = siphash_2_4("test", 0, 0)
let ks2 = siphash_2_4("test", 1, 0)
let ks3 = siphash_2_4("test", 0, 1)
check_true("different k0 => different hash", ks1 != ks2)
check_true("different k1 => different hash", ks1 != ks3)
check_true("k0 vs k1 differ", ks2 != ks3)

// ── 3. Input sensitivity ────────────────────────────────────────
println("")
println("--- Input sensitivity ---")
let is1 = siphash_simple("hello")
let is2 = siphash_simple("hellp")
let is3 = siphash_simple("hell")
let is4 = siphash_simple("hello!")
check_true("1-char differ => different hash", is1 != is2)
check_true("shorter input => different hash", is1 != is3)
check_true("longer input => different hash", is1 != is4)

// ── 4. Empty string ─────────────────────────────────────────────
println("")
println("--- Empty string ---")
let empty1 = siphash_simple("")
let empty2 = siphash_simple("")
check("empty deterministic", empty1, empty2)
check_true("empty differs from nonempty", empty1 != is1)

// Reference: siphash_2_4("", 0, 0) = 2202906307356721367
check("empty k0=0 k1=0 known vector", empty1, 2202906307356721367)

// ── 5. Known test vectors (from reference Python) ───────────────
println("")
println("--- Known vectors ---")

// siphash_2_4("hello", 0, 0) = -8304253580878589255 (signed i64)
check("hello k0=0 k1=0", siphash_simple("hello"), 0 - 8304253580878589255)

// siphash_2_4("hello", 1, 2) = 2957200328589801622
check("hello k0=1 k1=2", siphash_2_4("hello", 1, 2), 2957200328589801622)

// siphash_2_4("world", 0, 0) = -6304122697672707986
check("world k0=0 k1=0", siphash_simple("world"), 0 - 6304122697672707986)

// siphash_2_4("abcdefgh", 0, 0) = -1847705707669741165 (exact 8 bytes)
check("abcdefgh k0=0 k1=0", siphash_simple("abcdefgh"), 0 - 1847705707669741165)

// siphash_2_4("abcdefghijklmno", 0, 0) = 1433117775615257267 (15 bytes)
check("abcdefghijklmno k0=0 k1=0", siphash_simple("abcdefghijklmno"), 1433117775615257267)

// ── 6. Distribution smoke ───────────────────────────────────────
println("")
println("--- Distribution smoke ---")
let d1 = siphash_simple("a")
let d2 = siphash_simple("b")
let d3 = siphash_simple("c")
let d4 = siphash_simple("d")
let d5 = siphash_simple("e")
check_true("a != b", d1 != d2)
check_true("b != c", d2 != d3)
check_true("c != d", d3 != d4)
check_true("d != e", d4 != d5)
check_true("a != e", d1 != d5)

// ── 7. All lengths 0..8 distinct ────────────────────────────────
println("")
println("--- Length distinctness ---")
let l0 = siphash_simple("")
let l1 = siphash_simple("a")
let l2 = siphash_simple("ab")
let l3 = siphash_simple("abc")
let l4 = siphash_simple("abcd")
let l5 = siphash_simple("abcde")
let l6 = siphash_simple("abcdef")
let l7 = siphash_simple("abcdefg")
let l8 = siphash_simple("abcdefgh")
check_true("len0 != len1", l0 != l1)
check_true("len1 != len2", l1 != l2)
check_true("len2 != len3", l2 != l3)
check_true("len3 != len4", l3 != l4)
check_true("len4 != len5", l4 != l5)
check_true("len5 != len6", l5 != l6)
check_true("len6 != len7", l6 != l7)
check_true("len7 != len8", l7 != l8)

// ── Summary ─────────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  Total: " + to_string(pass_count + fail_count) + "  PASS: " + to_string(pass_count) + "  FAIL: " + to_string(fail_count))
if fail_count == 0 {
    println("  ALL TESTS PASSED")
} else {
    println("  SOME TESTS FAILED")
}
println("═══════════════════════════════════════════════════════")
