// ═══════════════════════════════════════════════════════════════════
//  test_siphash_pure.hexa — coverage for self/runtime/siphash_pure.hexa
//
//  Reference values generated by Python SipHash-2-4 implementation.
//  All expected values are [hi32, lo32] pairs.
// ═══════════════════════════════════════════════════════════════════

import "runtime/bit_pure.hexa"
import "runtime/siphash_pure.hexa"

let mut pass = 0
let mut fail = 0

fn check(name, cond) {
    if cond {
        pass = pass + 1
    } else {
        fail = fail + 1
        println("[FAIL] " + name)
    }
}

fn eq(name, actual, expected) {
    let ok = actual == expected
    if ok {
        pass = pass + 1
    } else {
        fail = fail + 1
        println("[FAIL] " + name + " expected=" + to_string(expected) + " got=" + to_string(actual))
    }
}

// Compare [hi,lo] pair results
fn eq_pair(name, actual, exp_hi, exp_lo) {
    let a_hi = actual[0]
    let a_lo = actual[1]
    if a_hi == exp_hi && a_lo == exp_lo {
        pass = pass + 1
    } else {
        fail = fail + 1
        println("[FAIL] " + name + " expected=[" + to_string(exp_hi) + "," + to_string(exp_lo) + "] got=[" + to_string(a_hi) + "," + to_string(a_lo) + "]")
    }
}

println("═══════════════════════════════════════════════════════")
println("  siphash_pure.hexa — test runner")
println("═══════════════════════════════════════════════════════")

// ── Helper: pair building ──────────────────────────────────────
let zero_key0 = [0, 0]
let zero_key1 = [0, 0]

// Standard test key: 00 01 02 ... 0f
// k0 = 0x0706050403020100 = hi=0x07060504=117835012 lo=0x03020100=50462976
// k1 = 0x0f0e0d0c0b0a0908 = hi=0x0f0e0d0c=252579084 lo=0x0b0a0908=185207048
let std_key0 = [117835012, 50462976]
let std_key1 = [252579084, 185207048]

// ── 64-bit pair primitives ─────────────────────────────────────
println("")
println("--- pair primitives ---")
let a = [0x00FF00FF, 0xFF00FF00]
let b = [0xFF00FF00, 0x00FF00FF]
let xr = p_xor(a, b)
eq_pair("p_xor", xr, 0xFFFFFFFF, 0xFFFFFFFF)

let s1 = p_add([0, 0xFFFFFFFF], [0, 1])
eq_pair("p_add carry", s1, 1, 0)

let s2 = p_add([0x12345678, 0x9ABCDEF0], [0, 0])
eq_pair("p_add identity", s2, 0x12345678, 0x9ABCDEF0)

// rotl by 32 = swap hi/lo
let r32 = p_rotl([0xAAAAAAAA, 0x55555555], 32)
eq_pair("p_rotl 32 swap", r32, 0x55555555, 0xAAAAAAAA)

// rotl by 0 = identity
let r0 = p_rotl([0x12345678, 0x9ABCDEF0], 0)
eq_pair("p_rotl 0 identity", r0, 0x12345678, 0x9ABCDEF0)

// ── Empty input, zero key ──────────────────────────────────────
println("")
println("--- empty input, zero key ---")
let h_empty = siphash_2_4_pure("", zero_key0, zero_key1)
eq_pair("empty+zero_key", h_empty, 512904093, 1937178839)

// ── Empty input, standard key ──────────────────────────────────
println("")
println("--- empty input, standard key ---")
let h_empty_std = siphash_2_4_pure("", std_key0, std_key1)
eq_pair("empty+std_key", h_empty_std, 1919933255, 3708685873)

// ── Short inputs, zero key ─────────────────────────────────────
println("")
println("--- short inputs, zero key ---")
let h_a = siphash_2_4_pure("a", zero_key0, zero_key1)
eq_pair("a+zero_key", h_a, 2529298528, 3449004617)

let h_abc = siphash_2_4_pure("abc", zero_key0, zero_key1)
eq_pair("abc+zero_key", h_abc, 1070105750, 1198583518)

let h_hello = siphash_2_4_pure("hello", zero_key0, zero_key1)
eq_pair("hello+zero_key", h_hello, 2361482589, 3002553017)

// ── Medium inputs ──────────────────────────────────────────────
println("")
println("--- medium inputs ---")
let h_hw = siphash_2_4_pure("hello world", zero_key0, zero_key1)
eq_pair("hello_world+zero_key", h_hw, 1459136843, 1487637258)

// Exactly 8 bytes (one full word)
let h_8 = siphash_2_4_pure("12345678", zero_key0, zero_key1)
eq_pair("8bytes+zero_key", h_8, 1575480516, 3129076120)

// Exactly 16 bytes (two full words)
let h_16 = siphash_2_4_pure("1234567890abcdef", zero_key0, zero_key1)
eq_pair("16bytes+zero_key", h_16, 4161609992, 1186096467)

// ── Key variation ──────────────────────────────────────────────
println("")
println("--- key variation ---")
let h_a_std = siphash_2_4_pure("a", std_key0, std_key1)
eq_pair("a+std_key", h_a_std, 732162281, 2802927818)

let h_hello_std = siphash_2_4_pure("hello", std_key0, std_key1)
eq_pair("hello+std_key", h_hello_std, 5223320, 1466425217)

// Different keys produce different hashes
let h_a_k1 = siphash_2_4_pure("test", zero_key0, zero_key1)
let h_a_k2 = siphash_2_4_pure("test", std_key0, std_key1)
check("diff_keys_diff_hash", h_a_k1[0] != h_a_k2[0] || h_a_k1[1] != h_a_k2[1])

// Same input + same key = deterministic
let h_det1 = siphash_2_4_pure("determinism", zero_key0, zero_key1)
let h_det2 = siphash_2_4_pure("determinism", zero_key0, zero_key1)
check("deterministic", h_det1[0] == h_det2[0] && h_det1[1] == h_det2[1])

// ── Collision resistance spot check ───────────────────────────
println("")
println("--- collision resistance (diff inputs, same key) ---")
let cr_cat = siphash_2_4_simple("cat", 42, 99)
let cr_dog = siphash_2_4_simple("dog", 42, 99)
let cr_bat = siphash_2_4_simple("bat", 42, 99)
let cr_rat = siphash_2_4_simple("rat", 42, 99)
let cr_hat = siphash_2_4_simple("hat", 42, 99)
check("cat != dog", cr_cat != cr_dog)
check("cat != bat", cr_cat != cr_bat)
check("dog != rat", cr_dog != cr_rat)
check("bat != hat", cr_bat != cr_hat)
check("rat != cat", cr_rat != cr_cat)

// All lengths 0..8 produce distinct hashes
let mut cr_hashes = []
let cr_inputs = ["", "a", "ab", "abc", "abcd", "abcde", "abcdef", "abcdefg", "abcdefgh"]
let mut ci = 0
while ci < len(cr_inputs) {
    cr_hashes.push(siphash_2_4_simple(cr_inputs[ci], 7, 13))
    ci = ci + 1
}
let mut cr_all_distinct = true
let mut cj = 0
while cj < len(cr_hashes) {
    let mut ck = cj + 1
    while ck < len(cr_hashes) {
        if cr_hashes[cj] == cr_hashes[ck] {
            cr_all_distinct = false
        }
        ck = ck + 1
    }
    cj = cj + 1
}
check("9 lengths all distinct", cr_all_distinct)

// ── Simple wrapper ─────────────────────────────────────────────
println("")
println("--- simple wrapper ---")
let s_empty = siphash_2_4_simple("", 0, 0)
eq("simple_empty_lo", s_empty, 1937178839)

let s_a = siphash_2_4_simple("a", 0, 0)
eq("simple_a_lo", s_a, 3449004617)

// simple wrapper must equal lo32 of full API
let full_foobar = siphash_2_4_pure("foobar", [0, 123], [0, 456])
let simple_foobar = siphash_2_4_simple("foobar", 123, 456)
eq("simple==full lo32", simple_foobar, full_foobar[1])

// ── Key sensitivity via simple API ─────────────────────────────
println("")
println("--- key sensitivity (simple) ---")
let ks1 = siphash_2_4_simple("test", 0, 0)
let ks2 = siphash_2_4_simple("test", 1, 0)
let ks3 = siphash_2_4_simple("test", 0, 1)
check("diff k0_lo diff hash", ks1 != ks2)
check("diff k1_lo diff hash", ks1 != ks3)

// ── Summary ────────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass) + " passed, " + to_string(fail) + " failed")
println("═══════════════════════════════════════════════════════")

if fail > 0 {
    println("FAIL")
    exit(1)
}
println("ALL PASS")
