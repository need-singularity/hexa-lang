// ===================================================================
//  test_lean_tactic.hexa — Lean Tactic Integration 검증
//
//  검증:
//    1. formula constructors (atom/not/and/or/imp/iff)
//    2. formula_eq structural equality
//    3. formula_to_string pretty printer (basic shape)
//    4. formula_contains subterm check
//    5. formula_subst (rewrite primitive)
//    6. goal / state stack operations
//    7. tactic DSL constructors
//    8. apply_intro on (P -> P)
//    9. apply_split on (P /\ Q)
//   10. apply_assumption finds hyp
//   11. apply_exact checks identity
//   12. apply_apply backward modus ponens
//   13. apply_rewrite target substitution
//   14. apply_induction creates base + step
//   15. apply_contradiction finds pair
//   16. check_proof (P -> P)
//   17. verify_proof returns ["ok"]
//   18. verify_proof failure points to step
//   19. build_proof_tree linear structure
//   20. proof_modus_ponens end-to-end
//
//  실행: ./hexa self/test_lean_tactic.hexa
// ===================================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

// ── Formula encoding ───────────────────────────────────────

fn prop_atom(name) { return ["atom", name] }
fn prop_true()     { return ["true"] }
fn prop_false()    { return ["false"] }
fn prop_not(f)     { return ["not", f] }
fn prop_and(a, b)  { return ["and", a, b] }
fn prop_or(a, b)   { return ["or", a, b] }
fn prop_imp(a, b)  { return ["imp", a, b] }
fn prop_iff(a, b)  { return ["iff", a, b] }

fn formula_eq(a, b) {
    let ta = a[0]
    let tb = b[0]
    if ta != tb { return false }
    if ta == "atom" { return a[1] == b[1] }
    if ta == "true"  { return true }
    if ta == "false" { return true }
    if ta == "not"   { return formula_eq(a[1], b[1]) }
    if formula_eq(a[1], b[1]) {
        if formula_eq(a[2], b[2]) { return true }
    }
    return false
}

fn formula_to_string(f) {
    let t = f[0]
    if t == "atom"  { return f[1] }
    if t == "true"  { return "T" }
    if t == "false" { return "F" }
    if t == "not"   { return "~" + formula_to_string(f[1]) }
    if t == "and" {
        return "(" + formula_to_string(f[1]) + " /\\ " + formula_to_string(f[2]) + ")"
    }
    if t == "or" {
        return "(" + formula_to_string(f[1]) + " \\/ " + formula_to_string(f[2]) + ")"
    }
    if t == "imp" {
        return "(" + formula_to_string(f[1]) + " -> " + formula_to_string(f[2]) + ")"
    }
    if t == "iff" {
        return "(" + formula_to_string(f[1]) + " <-> " + formula_to_string(f[2]) + ")"
    }
    return "?"
}

fn formula_contains(f, g) {
    if formula_eq(f, g) { return true }
    let t = f[0]
    if t == "atom"  { return false }
    if t == "true"  { return false }
    if t == "false" { return false }
    if t == "not"   { return formula_contains(f[1], g) }
    if formula_contains(f[1], g) { return true }
    return formula_contains(f[2], g)
}

fn formula_subst(f, old, new) {
    if formula_eq(f, old) { return new }
    let t = f[0]
    if t == "atom"  { return f }
    if t == "true"  { return f }
    if t == "false" { return f }
    if t == "not"   { return ["not", formula_subst(f[1], old, new)] }
    let l = formula_subst(f[1], old, new)
    let r = formula_subst(f[2], old, new)
    return [t, l, r]
}

// ── Goals / proof state ────────────────────────────────────

fn mk_goal(hyps, target) { return ["goal", hyps, target] }
fn goal_hyps(g)          { return g[1] }
fn goal_target(g)        { return g[2] }
fn mk_state(goals)       { return ["state", goals] }
fn state_goals(st)       { return st[1] }
fn state_depth(st)       { return len(state_goals(st)) }
fn state_done(st)        { return len(state_goals(st)) == 0 }

fn state_current(st) {
    let gs = state_goals(st)
    if len(gs) == 0 { return ["none"] }
    return gs[0]
}

fn state_replace(st, subs) {
    let gs = state_goals(st)
    let mut ng = []
    let mut i = 0
    while i < len(subs) { ng = ng + [subs[i]]; i = i + 1 }
    i = 1
    while i < len(gs) { ng = ng + [gs[i]]; i = i + 1 }
    return mk_state(ng)
}

// ── Tactic DSL ─────────────────────────────────────────────

fn tac_intro()           { return ["tac", "intro"] }
fn tac_apply(f)          { return ["tac", "apply", f] }
fn tac_rewrite(lhs, rhs) { return ["tac", "rewrite", lhs, rhs] }
fn tac_induction(v)      { return ["tac", "induction", v] }
fn tac_split()           { return ["tac", "split"] }
fn tac_exact(f)          { return ["tac", "exact", f] }
fn tac_assumption()      { return ["tac", "assumption"] }
fn tac_contradiction()   { return ["tac", "contradiction"] }

fn tactic_name(t) { return t[1] }
fn tactic_args(t) {
    let mut out = []
    let mut i = 2
    while i < len(t) { out = out + [t[i]]; i = i + 1 }
    return out
        i = i + 1
}

// ── Results ────────────────────────────────────────────────

fn mk_ok(st)       { return ["ok", st] }
fn mk_err(msg)     { return ["error", msg] }
fn result_ok(r)    { return r[0] == "ok" }
fn result_state(r) { return r[1] }
fn result_error(r) { return r[1] }

fn hyps_contains(hs, f) {
    let mut i = 0
    while i < len(hs) {
        if formula_eq(hs[i], f) { return true }
        i = i + 1
    }
    return false
}

// ── Tactic rules ───────────────────────────────────────────

fn apply_intro(st) {
    let g = state_current(st)
    if g[0] != "goal" { return mk_err("intro: no goal") }
    let target = goal_target(g)
    if target[0] != "imp" { return mk_err("intro: target not Imp") }
    let hyps = goal_hyps(g)
    let new_hyps = hyps + [target[1]]
    let new_goal = mk_goal(new_hyps, target[2])
    return mk_ok(state_replace(st, [new_goal]))
}

fn apply_split(st) {
    let g = state_current(st)
    if g[0] != "goal" { return mk_err("split: no goal") }
    let target = goal_target(g)
    if target[0] != "and" { return mk_err("split: target not And") }
    let hyps = goal_hyps(g)
    let g1 = mk_goal(hyps, target[1])
    let g2 = mk_goal(hyps, target[2])
    return mk_ok(state_replace(st, [g1, g2]))
}

fn apply_exact(st, f) {
    let g = state_current(st)
    if g[0] != "goal" { return mk_err("exact: no goal") }
    let target = goal_target(g)
    if !formula_eq(f, target) { return mk_err("exact: formula != target") }
    let hyps = goal_hyps(g)
    if !hyps_contains(hyps, f) { return mk_err("exact: formula not in hyps") }
    return mk_ok(state_replace(st, []))
}

fn apply_assumption(st) {
    let g = state_current(st)
    if g[0] != "goal" { return mk_err("assumption: no goal") }
    let target = goal_target(g)
    let hyps = goal_hyps(g)
    if hyps_contains(hyps, target) {
        return mk_ok(state_replace(st, []))
    }
    return mk_err("assumption: target not in hyps")
}

fn apply_apply(st, f) {
    let g = state_current(st)
    if g[0] != "goal" { return mk_err("apply: no goal") }
    let target = goal_target(g)
    let hyps = goal_hyps(g)
    if f[0] != "imp" { return mk_err("apply: given not Imp") }
    if !formula_eq(f[2], target) { return mk_err("apply: conclusion != target") }
    if !hyps_contains(hyps, f) { return mk_err("apply: lemma not in hyps") }
    let new_goal = mk_goal(hyps, f[1])
    return mk_ok(state_replace(st, [new_goal]))
}

fn apply_rewrite(st, lhs, rhs) {
    let g = state_current(st)
    if g[0] != "goal" { return mk_err("rewrite: no goal") }
    let target = goal_target(g)
    if !formula_contains(target, lhs) { return mk_err("rewrite: lhs not in target") }
    let new_target = formula_subst(target, lhs, rhs)
    let hyps = goal_hyps(g)
    let new_goal = mk_goal(hyps, new_target)
    return mk_ok(state_replace(st, [new_goal]))
}

fn apply_induction(st, var_name) {
    let g = state_current(st)
    if g[0] != "goal" { return mk_err("induction: no goal") }
    let target = goal_target(g)
    let hyps = goal_hyps(g)
    let v = prop_atom(var_name)
    if !formula_contains(target, v) { return mk_err("induction: var not in target") }
    let base = formula_subst(target, v, prop_atom("0"))
    let step = formula_subst(target, v, prop_atom("succ"))
    let g1 = mk_goal(hyps, base)
    let g2 = mk_goal(hyps + [target], step)
    return mk_ok(state_replace(st, [g1, g2]))
}

fn apply_contradiction(st) {
    let g = state_current(st)
    if g[0] != "goal" { return mk_err("contradiction: no goal") }
    let hyps = goal_hyps(g)
    let n = len(hyps)
    let mut i = 0
    while i < n {
        let h = hyps[i]
        if h[0] == "not" {
            let inner = h[1]
            if hyps_contains(hyps, inner) {
                return mk_ok(state_replace(st, []))
            }
        }
        i = i + 1
    }
    return mk_err("contradiction: no pair found")
}

fn apply_tactic(st, tac) {
    let name = tactic_name(tac)
    let args = tactic_args(tac)
    if name == "intro"         { return apply_intro(st) }
    if name == "split"         { return apply_split(st) }
    if name == "assumption"    { return apply_assumption(st) }
    if name == "contradiction" { return apply_contradiction(st) }
    if name == "exact"         { return apply_exact(st, args[0]) }
    if name == "apply"         { return apply_apply(st, args[0]) }
    if name == "rewrite"       { return apply_rewrite(st, args[0], args[1]) }
    if name == "induction"     {
        let va = args[0]
        return apply_induction(st, va[1])
    }
    return mk_err("unknown tactic: " + name)
}

fn check_proof(goal, tacs) {
    let mut st = mk_state([goal])
    let n = len(tacs)
    let mut i = 0
    while i < n {
        let r = apply_tactic(st, tacs[i])
        if !result_ok(r) { return false }
        st = result_state(r)
        i = i + 1
    }
    return state_done(st)
}

fn verify_proof(goal, tacs) {
    let mut st = mk_state([goal])
    let n = len(tacs)
    let mut i = 0
    while i < n {
        let r = apply_tactic(st, tacs[i])
        if !result_ok(r) { return ["fail", to_string(i), result_error(r)] }
        st = result_state(r)
        i = i + 1
    }
    if state_done(st) { return ["ok"] }
    return ["fail", to_string(n), "goals remain"]
}

fn mk_node(tac, goal, children) { return ["node", tac, goal, children] }
fn node_children(n) { return n[3] }

fn build_proof_tree(goal, tacs) {
    let mut st = mk_state([goal])
    let mut cur_children = []
    let n = len(tacs)
    let mut i = 0
    while i < n {
        let snapshot = state_current(st)
        let r = apply_tactic(st, tacs[i])
        if !result_ok(r) {
            let err_node = mk_node(tacs[i], snapshot, [])
            cur_children = cur_children + [err_node]
            return mk_node(["tac", "root"], goal, cur_children)
        }
        st = result_state(r)
        let nd = mk_node(tacs[i], snapshot, [])
        cur_children = cur_children + [nd]
        i = i + 1
    }
    if state_done(st) {
        let qed = mk_node(["tac", "qed"], goal, [])
        cur_children = cur_children + [qed]
    } else {
        let rem = mk_node(["tac", "open"], state_current(st), [])
        cur_children = cur_children + [rem]
    }
    return mk_node(["tac", "root"], goal, cur_children)
}

// ═══════════ TEST DATA ═══════════════════════════════════════

let p = prop_atom("P")
let q = prop_atom("Q")
let r = prop_atom("R")
let p_and_q = prop_and(p, q)
let q_and_p = prop_and(q, p)
let p_imp_q = prop_imp(p, q)
let p_imp_p = prop_imp(p, p)

// ── T1: formula constructors ──────────────────────────────
check("atom tag", p[0] == "atom")
check("not tag",  prop_not(p)[0] == "not")
check("and tag",  p_and_q[0] == "and")
check("or tag",   prop_or(p, q)[0] == "or")
check("imp tag",  p_imp_q[0] == "imp")
check("iff tag",  prop_iff(p, q)[0] == "iff")

// ── T2: formula_eq ────────────────────────────────────────
check("eq: atom P == P", formula_eq(p, prop_atom("P")))
check("eq: P != Q",     !formula_eq(p, q))
check("eq: P /\\ Q structural", formula_eq(p_and_q, prop_and(p, q)))
check("eq: P /\\ Q != Q /\\ P", !formula_eq(p_and_q, q_and_p))

// ── T3: formula_to_string ─────────────────────────────────
let s_imp = formula_to_string(p_imp_q)
check("tostr imp contains ->", s_imp.contains("->"))
check("tostr atom P",          formula_to_string(p) == "P")
check("tostr true",            formula_to_string(prop_true()) == "T")

// ── T4: formula_contains ──────────────────────────────────
check("contains: P in P /\\ Q",  formula_contains(p_and_q, p))
check("contains: Q in P /\\ Q",  formula_contains(p_and_q, q))
check("contains: R not in P /\\ Q", !formula_contains(p_and_q, r))

// ── T5: formula_subst (rewrite primitive) ─────────────────
let subst1 = formula_subst(p_imp_q, q, r)
check("subst: (P -> Q)[Q/R] = (P -> R)", formula_eq(subst1, prop_imp(p, r)))

// ── T6: goal / state stack ────────────────────────────────
let g0 = mk_goal([], p_imp_p)
let st0 = mk_state([g0])
check("state depth 1",    state_depth(st0) == 1)
check("state not done",  !state_done(st0))
let st_pop = state_replace(st0, [])
check("state replace empty done", state_done(st_pop))

// ── T7: tactic DSL ────────────────────────────────────────
let t_intro = tac_intro()
check("tac intro name",       tactic_name(t_intro) == "intro")
check("tac apply args",        len(tactic_args(tac_apply(p_imp_q))) == 1)
check("tac rewrite args",      len(tactic_args(tac_rewrite(p, q))) == 2)

// ── T8: apply_intro on (P -> P) ───────────────────────────
let r1 = apply_intro(st0)
check("intro ok", result_ok(r1))
let st1 = result_state(r1)
let g1 = state_current(st1)
check("intro adds hyp", len(goal_hyps(g1)) == 1)
check("intro keeps target P", formula_eq(goal_target(g1), p))

// ── T9: apply_split on (P /\ Q) ───────────────────────────
let st_split = mk_state([mk_goal([], p_and_q)])
let r_split = apply_split(st_split)
check("split ok", result_ok(r_split))
let st_after = result_state(r_split)
check("split produces 2 goals", state_depth(st_after) == 2)

// ── T10: apply_assumption ─────────────────────────────────
let g_hyp = mk_goal([p, q], p)
let st_h = mk_state([g_hyp])
let r_h = apply_assumption(st_h)
check("assumption ok",   result_ok(r_h))
check("assumption done", state_done(result_state(r_h)))

let r_h_bad = apply_assumption(mk_state([mk_goal([q], p)]))
check("assumption fails when absent", !result_ok(r_h_bad))

// ── T11: apply_exact ──────────────────────────────────────
let r_ex = apply_exact(mk_state([mk_goal([p], p)]), p)
check("exact ok", result_ok(r_ex))
let r_ex_bad = apply_exact(mk_state([mk_goal([q], p)]), p)
check("exact fails when hyp missing", !result_ok(r_ex_bad))

// ── T12: apply_apply backward modus ponens ────────────────
let g_mp = mk_goal([p, p_imp_q], q)
let r_mp = apply_apply(mk_state([g_mp]), p_imp_q)
check("apply mp ok", result_ok(r_mp))
let st_mp = result_state(r_mp)
let g_mp_after = state_current(st_mp)
check("apply mp new target = P", formula_eq(goal_target(g_mp_after), p))

// ── T13: apply_rewrite ────────────────────────────────────
let g_rw = mk_goal([], p_imp_q)
let r_rw = apply_rewrite(mk_state([g_rw]), q, r)
check("rewrite ok", result_ok(r_rw))
let g_rw_after = state_current(result_state(r_rw))
check("rewrite target (P -> R)", formula_eq(goal_target(g_rw_after), prop_imp(p, r)))

// ── T14: apply_induction ──────────────────────────────────
let n_var = prop_atom("n")
let goal_ind = mk_goal([], prop_imp(n_var, n_var))
let r_ind = apply_induction(mk_state([goal_ind]), "n")
check("induction ok", result_ok(r_ind))
check("induction creates 2 subgoals", state_depth(result_state(r_ind)) == 2)

// ── T15: apply_contradiction ──────────────────────────────
let g_ctr = mk_goal([p, prop_not(p)], q)
let r_ctr = apply_contradiction(mk_state([g_ctr]))
check("contradiction ok", result_ok(r_ctr))
check("contradiction closes state", state_done(result_state(r_ctr)))

let r_ctr_bad = apply_contradiction(mk_state([mk_goal([p, q], r)]))
check("contradiction fails absent", !result_ok(r_ctr_bad))

// ── T16: check_proof (P -> P) ─────────────────────────────
let pp = [tac_intro(), tac_assumption()]
check("check_proof (P -> P)", check_proof(mk_goal([], p_imp_p), pp))

// ── T17: verify_proof returns ["ok"] ──────────────────────
let vr = verify_proof(mk_goal([], p_imp_p), pp)
check("verify ok",           vr[0] == "ok")

// ── T18: verify_proof failure points to step ──────────────
let bad_proof = [tac_intro(), tac_split()]
let vr_bad = verify_proof(mk_goal([], p_imp_p), bad_proof)
check("verify fail tag",     vr_bad[0] == "fail")
check("verify fail step 1",  vr_bad[1] == "1")

// ── T19: build_proof_tree linear ──────────────────────────
let tree = build_proof_tree(mk_goal([], p_imp_p), pp)
let tree_children = node_children(tree)
// children: intro, assumption, qed  → 3
check("tree has 3 children",     len(tree_children) == 3)

let bad_tree = build_proof_tree(mk_goal([], p_imp_p), [tac_split()])
// children: split (failed) → 1
check("bad tree has 1 child",    len(node_children(bad_tree)) == 1)

// ── T20: proof_modus_ponens end-to-end ────────────────────
let mp_tacs = [tac_apply(p_imp_q), tac_assumption()]
let mp_goal = mk_goal([p, p_imp_q], q)
check("mp proof check", check_proof(mp_goal, mp_tacs))
let mp_vr = verify_proof(mp_goal, mp_tacs)
check("mp proof verify", mp_vr[0] == "ok")

// ── 결과 ────────────────────────────────────────────────────
println("")
println("=== Lean Tactic test summary ===")
println("PASS: " + to_string(pass_count))
println("FAIL: " + to_string(fail_count))
if fail_count == 0 {
    println("ALL GREEN — Lean Tactic Integration OK")
}
println(to_string(pass_count) + " passed")
