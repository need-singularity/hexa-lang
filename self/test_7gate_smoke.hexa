// test_7gate_smoke.hexa — 7-gate roadmap smoke tests
//
// Verifies each phase gate's pass/fail conditions from
// shared/roadmaps/hexa-lang.json (P0-P4) + anima_hexa_common.json (P5)
// + VM perf gate (bt#85).
//
// Gate structure:
//   G0  P0 — Spec ossification (keywords/ops/types/tests)
//   G1  P1 — IR + Fused builtins + BLAS linking
//   G2  P2 — build_c codegen + hexa_cc 0-error
//   G3  P3 — Tagged-value runtime (HexaVal + gcc 0 errors)
//   G4  P4 — Self-host end-to-end bootstrap
//   G5  P5 — Zeta serving checkpoint (eval metrics)
//   G6  VM — Bytecode VM perf gate (bt#85: fib>=2x, call_heavy>=3x)
//
// Run: ./hexa self/test_7gate_smoke.hexa
// No semicolons (P1 pitfall). No mixed-type arrays (P53 pitfall).

// --- Pure Hexa implementations of number-theory builtins ---
// (sigma/tau/sopfr are interpreter-only builtins; inlined for native build)

// sigma(n) = sum of divisors
fn sigma(n) {
    let mut s = 0
    let mut d = 1
    while d <= n {
        if n % d == 0 { s = s + d }
        d = d + 1
    }
    return s
}

// tau(n) = number of divisors
fn tau(n) {
    let mut c = 0
    let mut d = 1
    while d <= n {
        if n % d == 0 { c = c + 1 }
        d = d + 1
    }
    return c
}

// sopfr(n) = sum of prime factors (with multiplicity)
fn sopfr(n) {
    let mut s = 0
    let mut x = n
    let mut d = 2
    while d <= x {
        while x % d == 0 {
            s = s + d
            x = x / d
        }
        d = d + 1
    }
    return s
}

// --- END number-theory builtins ---

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_true(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

println("=== 7-Gate Roadmap Smoke Tests ===")
println("")

// ── G0: P0 — Spec Ossification Gate ────────────────────────
// Criteria: KEYWORDS_53+, OPERATORS_24+, PRIMITIVES_8, TESTS_146+
// Smoke: verify language primitives exist and work

println("--- G0: Spec Ossification ---")

// Keywords: let, mut, fn, if, else, while, for, return, true, false all work
let g0_kw = 10
check("G0 core keywords usable", g0_kw, 10)

// Operators: arithmetic + comparison + logical
check("G0 arithmetic ops", 2 + 3 * 4, 14)
check("G0 comparison ops", (5 > 3) && (3 < 7), true)
check("G0 logical ops", true || false, true)

// 8 primitive types exist
check("G0 type int", type_of(42), "int")
check("G0 type float", type_of(3.14), "float")
check("G0 type bool", type_of(true), "bool")
check("G0 type string", type_of("hi"), "string")
check("G0 type array", type_of([1, 2]), "array")
check("G0 type map", type_of(#{}), "map")

// Number theory builtins (n=6 foundation)
check("G0 sigma(6)=12", sigma(6), 12)
check("G0 tau(6)=4", tau(6), 4)
check("G0 sopfr(6)=5", sopfr(6), 5)
// sigma * tau verify: sigma(6)=12, tau(6)=4, product=48
check("G0 sigma*tau product", sigma(6) * tau(6), 48)

println("")

// ── G1: P1 — IR + Fused Builtins Gate ──────────────────────
// Criteria: IR_PHASE1 ossified, FUSED_BUILTIN_FAMILY, BLAS linking
// Smoke: verify math/string builtins (fused family) work correctly

println("--- G1: IR + Fused Builtins ---")

// Math builtins (the foundation for fused ML kernels)
check("G1 abs(-7)", abs(-7), 7)
check("G1 min(3,9)", min(3, 9), 3)
check("G1 max(3,9)", max(3, 9), 9)
check("G1 pow(2,10)", pow(2, 10), 1024)
check("G1 floor(3.7)", floor(3.7), 3)
check("G1 ceil(3.2)", ceil(3.2), 4)
check("G1 sqrt(16)", sqrt(16), 4.0)

// String builtins (stdlib separation gate)
check("G1 split+join", "a,b,c".split(",").join("-"), "a-b-c")
check("G1 contains", "hello world".contains("world"), true)
check("G1 replace", "aXb".replace("X", "_"), "a_b")

// Array builtins (collection primitives)
let arr = [10, 20, 30, 40, 50]
check("G1 arr.len", len(arr), 5)
check("G1 arr[2]", arr[2], 30)
check("G1 arr last", arr[len(arr) - 1], 50)

println("")

// ── G2: P2 — Codegen Gate ──────────────────────────────────
// Criteria: build_c str/module/brace fixes, hexa_cc 0-error parse
// Smoke: verify fn declarations, string params, nested structures

println("--- G2: Codegen (build_c) ---")

// String parameter annotation (BUILD_C_STR_PARAM_ANNOTATION)
fn str_len_check(s) {
    return len(s)
}
check("G2 str param fn", str_len_check("hello"), 5)

// Nested array access (BUILD_C_NESTED_ARRAY_RUNTIME)
let nested = [[1, 2], [3, 4], [5, 6]]
check("G2 nested arr[1][0]", nested[1][0], 3)
check("G2 nested arr[2][1]", nested[2][1], 6)

// Recursive module-like fn (BUILD_C_USE_RECURSIVE_RESOLVE)
// decreases n — structural
fn fib(n) {
    if n <= 1 {
        return n
    }
    return fib(n - 1) + fib(n - 2)
}
check("G2 recursion fib(10)", fib(10), 55)

// Multi-line expressions (brace lint)
let multi = (1 +
    2 +
    3)
check("G2 multi-line expr", multi, 6)

println("")

// ── G3: P3 — Tagged-Value Runtime Gate ─────────────────────
// Criteria: HexaVal union runtime, gcc errors 0, native test suite PASS
// Smoke: verify mixed-type operations, type coercion, tagged dispatch

println("--- G3: Tagged-Value Runtime ---")

// Mixed arithmetic (int/float dispatch through tagged value)
let int_val = 42
let float_val = 3.14
check("G3 int type", type_of(int_val), "int")
check("G3 float type", type_of(float_val), "float")

// to_string on different types (tagged dispatch)
check("G3 to_string(int)", to_string(42), "42")
check("G3 to_string(float)", to_string(0.5), "0.5")
check("G3 to_string(bool)", to_string(true), "true")
check("G3 to_string(arr)", type_of(to_string([1, 2])), "string")

// Type conversion round-trip (tagged value coercion)
let n = to_int("123")
check("G3 to_int round-trip", n, 123)
let f = to_float("3.14")
check_true("G3 to_float round-trip", f > 3.13 && f < 3.15)

// Map operations (tagged value map dispatch)
let mut m = #{"a": 1, "b": 2}
check("G3 map get", m["a"], 1)
m["c"] = 3
check("G3 map set", m["c"], 3)
check("G3 has_key", has_key(m, "b"), true)
check("G3 has_key miss", has_key(m, "z"), false)

println("")

// ── G4: P4 — Self-Host Gate ────────────────────────────────
// Criteria: native hexa self-compile PASS, runtime.c replaces Rust
// Smoke: verify bootstrap-critical features (closures, try/catch, for)

println("--- G4: Self-Host Bootstrap ---")

// Closures (critical for self-host codegen)
fn make_adder(x) {
    return |y| { return x + y }
}
let add5 = make_adder(5)
check("G4 closure capture", add5(10), 15)

// Try/catch (error handling in compiler)
let mut caught = false
try {
    throw "gate error"
} catch e {
    caught = true
}
check("G4 try/catch", caught, true)

// For-range loop (iteration in self-host compiler)
let mut sum = 0
let mut idx = 0
while idx < 5 {
    sum = sum + idx
    idx = idx + 1
}
check("G4 loop sum 0..4", sum, 10)

// String methods (critical for codegen string manipulation)
check("G4 starts_with", "hexa_lang".starts_with("hexa"), true)
check("G4 index_of", "hello_world".index_of("world"), 6)
check("G4 substring", "abcdef".substring(2, 5), "cde")

// Nested fn + scope (compiler code structure)
// NOTE: nested fn decl inside fn body is not supported by native codegen;
// using closure (lambda) instead to test the same capture semantics.
fn outer_fn() {
    let a = 10
    let inner_fn = |b| { return a + b }
    return inner_fn(20)
}
check("G4 nested fn", outer_fn(), 30)

println("")

// ── G5: P5 — Zeta Serving Checkpoint Gate ──────────────────
// Criteria: eval metrics (PPL, accuracy, distinct-2, korean_ratio, length)
// Smoke: verify metric computation primitives work

println("--- G5: Zeta Eval Metrics ---")

// Log/exp for PPL computation (PPL = exp(mean(NLL)))
let log_val = log(2.718281828)
check_true("G5 log(e) near 1.0", log_val > 0.99 && log_val < 1.01)

// Argmax simulation (for top-1 accuracy metric)
fn argmax(arr) {
    let mut best_idx = 0
    let mut best_val = arr[0]
    let mut i = 1
    while i < len(arr) {
        if arr[i] > best_val {
            best_val = arr[i]
            best_idx = i
        }
        i = i + 1
    }
    return best_idx
}
check("G5 argmax", argmax([0.1, 0.7, 0.2]), 1)

// Distinct-N (bigram diversity metric)
fn count_distinct_bigrams(tokens) {
    let mut seen = #{}
    let mut i = 0
    while (i + 1) < len(tokens) {
        let key = to_string(tokens[i]) + "_" + to_string(tokens[(i + 1)])
        seen[key] = 1
        i = i + 1
    }
    return len(keys(seen))
}
check("G5 distinct bigrams", count_distinct_bigrams([1, 2, 3, 2, 3]), 3)

// Softmax denominator (for PPL numerics)
fn logsumexp(vals) {
    let mut mx = vals[0]
    let mut i = 1
    while i < len(vals) {
        if vals[i] > mx {
            mx = vals[i]
        }
        i = i + 1
    }
    let mut total = 0.0
    let mut j = 0
    while j < len(vals) {
        let diff = vals[j] - mx
        let mut exp_v = 1.0
        // Taylor approx for small |diff|: e^x ~ 1+x+x^2/2
        exp_v = 1.0 + diff + diff * diff / 2.0
        if exp_v < 0.0 {
            exp_v = 0.001
        }
        total = total + exp_v
        j = j + 1
    }
    return mx + log(total)
}
let lse = logsumexp([1.0, 2.0, 3.0])
check_true("G5 logsumexp finite", lse > 2.0 && lse < 5.0)

println("")

// ── G6: VM Perf Gate ───────────────────────────────────────
// Criteria: bt#85 — fib >= 2x speedup, call_heavy >= 3x
// Smoke: verify VM-critical patterns (recursion, heavy calls, closures)

println("--- G6: VM Perf Patterns ---")

// Recursive fib (the bt#85 fib benchmark target)
check("G6 fib(15)", fib(15), 610)
check("G6 fib(20)", fib(20), 6765)

// Call-heavy pattern (many small fn invocations)
fn square(x) {
    return x * x
}
let mut call_sum = 0
let mut ci = 0
while ci < 100 {
    call_sum = call_sum + square(ci)
    ci = ci + 1
}
check("G6 call_heavy sum(i^2,0..99)", call_sum, 328350)

// Closure through collection (VM closure capture stress)
let fns = [make_adder(1), make_adder(2), make_adder(3)]
let mut closure_sum = 0
let mut fi = 0
while fi < len(fns) {
    closure_sum = closure_sum + fns[fi](10)
    fi = fi + 1
}
check("G6 closure collection", closure_sum, 36)

// Accumulator pattern (VM loop + mutation stress)
let mut acc = 1
let mut ai = 0
while ai < 10 {
    acc = acc * 2
    ai = ai + 1
}
check("G6 accumulator 2^10", acc, 1024)

println("")

// ── Summary ────────────────────────────────────────────────

println("===================================================")
let total = pass_count + fail_count
println("  7-Gate Smoke: " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL / " + to_string(total) + " total")
if fail_count == 0 {
    println("  ALL 7-GATE SMOKE TESTS PASSED!")
} else {
    println("  SOME GATE TESTS FAILED")
}
println("===================================================")
