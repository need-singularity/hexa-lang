// HEXA-LANG library entry — module registry + tiered runner.
// Port of src/lib.rs to self-host. Re-exports the interpreter, formatter,
// and linter. Used by the WASM playground and as an embeddable Hexa runtime.
//
// Since self-host hexa uses import statements directly rather than
// `pub mod`, this file's role is (1) documenting the set of modules
// making up the self-host library and (2) providing the tiered run_source
// API so that external hosts can drive the interpreter via a single
// entry point.

import "lexer.hexa"
import "parser.hexa"
import "interpreter.hexa"

// ── Module registry ─────────────────────────────────────────
// Matches src/lib.rs `pub mod` declarations.
// Each entry: [module_name, wasm_ok, self_host_ok].
//   wasm_ok = false means the src/ version is cfg(not(target_arch = "wasm32"))
//   self_host_ok = true means a self/*.hexa port exists
pub let mut MODULE_REGISTRY = [
    ["token",             true,  true],
    ["lexer",             true,  true],
    ["ast",               true,  true],
    ["error",             true,  true],
    ["parser",            true,  true],
    ["env",               true,  true],
    ["interpreter",       true,  true],
    ["type_checker",      true,  true],
    ["compiler",          true,  true],
    ["vm",                true,  true],
    ["nanbox",            true,  true],
    ["formatter",         true,  true],
    ["linter",            true,  true],
    ["macro_expand",      true,  true],
    ["comptime",          true,  true],
    ["memory",            true,  true],
    ["ownership",         true,  true],
    ["dream",             true,  true],
    ["inline_cache",      true,  true],
    ["proof_engine",      true,  true],
    ["escape_analysis",   false, true],
    ["async_runtime",     false, true],
    ["dce",               true,  true],
    ["loop_unroll",       true,  true],
    ["simd_hint",         true,  true],
    ["pgo",               true,  true],
    ["work_stealing",     false, true],
    ["jit",               false, true],
    ["lsp",               false, true],
    ["debugger",          false, true],
    ["codegen_esp32",     false, true],
    ["codegen_verilog",   false, true],
    ["codegen_wgsl",      false, true],
    ["llm",               false, true],
    ["std_net",           false, true],
    ["std_fs",            false, true],
    ["std_io",            false, true],
    ["std_time",          false, true],
    ["std_collections",   false, true],
    ["std_encoding",      false, true],
    ["std_log",           false, true],
    ["std_math",          true,  true],
    ["std_testing",       true,  true],
    ["std_crypto",        false, true],
    ["std_consciousness", true,  true],
    ["std_nexus",         false, true],
    ["atomic_ops",        true,  true],
    ["anima_bridge",      false, true],
    ["package",           true,  true],
    ["singularity",       true,  true],
    ["ir",                true,  true],
    ["lower",             true,  true],
    ["opt",               true,  true],
    ["codegen",           false, true],
    ["alloc",             true,  true],
    ["trace_jit",         true,  true],
    ["std_web_template",  false, true]
]

fn module_count() { return len(MODULE_REGISTRY) }

fn module_lookup(name) {
    let mut i = 0
    while i < len(MODULE_REGISTRY) {
        if MODULE_REGISTRY[i][0] == name { return MODULE_REGISTRY[i] }
        i = i + 1
    }
    return ""
}

// ── Tiered execution entry points ───────────────────────────
// Mirrors src/lib.rs::run_source / run_source_tiered.
// Tier 1: VM (bytecode). Tier 2: tree-walk interpreter (this module).
// In self-host mode there is no bytecode VM yet, so we always fall to
// Tier 2. The tier_name is returned for UI symmetry with the host.

fn run_source(source) {
    return run_source_with_budget(source, 8388608)  // 8 * 1024 * 1024
}

fn run_source_with_budget(source, _budget) {
    let result = run_source_tiered(source, _budget)
    return [result[0], result[1]]
}

fn run_source_tiered(source, _budget) {
    let toks = tokenize(source)
    let ast = parse(toks)
    // Tier 1 (VM) not available in self-host; Tier 2 direct.
    // Capture interpret() output by reusing a bare interpret call;
    // in self-host we can't easily redirect stdout, so we rely on
    // interpret() printing to console directly.
    interpret(ast)
    return ["", "", "interpreter"]
}

fn run_source_vm_only(_source, _budget) {
    return ["", "VM compilation not available in self-host"]
}

fn run_source_interpreter_only(source, _budget) {
    let toks = tokenize(source)
    let ast = parse(toks)
    interpret(ast)
    return ["", ""]
}

// ── Diagnostic formatter (matches src::format_diagnostic) ───
fn format_diagnostic(err_class, err_message, err_line, err_col, err_hint, source_lines, file_name) {
    let mut msg = "error[" + err_class + "]: " + err_message + "\n"
    if err_line > 0 && err_line <= len(source_lines) {
        msg = msg + "  --> " + file_name + ":" + to_string(err_line) + ":" + to_string(err_col) + "\n"
        msg = msg + "   |\n"
        msg = msg + to_string(err_line).pad_left(3, " ") + " | " + source_lines[err_line - 1] + "\n"
        msg = msg + "   |"
        if err_col > 0 {
            let mut pad = ""
            let mut _pi = 0
            while _pi < err_col - 1 { pad = pad + " "; _pi = _pi + 1 }
            msg = msg + " " + pad + "^"
        }
        msg = msg + "\n"
    }
    if err_hint != "" {
        msg = msg + "hint: " + err_hint + "\n"
    }
    return msg
}
