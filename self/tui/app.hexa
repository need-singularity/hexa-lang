#!hexa strict
// self/tui/app.hexa — TUI-PRIM L5 app composer
//
// Frame loop that composes L1 (raw mode + signals) + L2 (input decode) +
// L3 (cell-grid + diff render) + L4 (widget draw). Closes Layer 5 of
// kick witness 2026-04-27_hexa-native-tui-implementation-plan_KICK_omega
// _cycle.json T1.A.
//
// The loop is the canonical fix for the input-lag hot-path identified by
// TUI-MEAS Level 2 (packages/tui/bench/level2-frame.bench.ts rapid p50=
// 16.33ms): only renders when state changes. There is NO 16ms throttle
// here — the loop blocks on input_drain_one(timeout) and renders only
// when the dispatch callback returns dirty=1.
//
// API
//   pub fn app_run(state, draw_fn, dispatch_fn, tick_ms) -> int
//     state        : opaque array passed to user callbacks
//     draw_fn      : fn(state) -> int   // L4 widget composition; uses
//                                          render_clear + render_put
//     dispatch_fn  : fn(state, event) -> int
//                                       // returns 1=dirty (re-render),
//                                          0=clean, -1=quit
//     tick_ms      : input poll timeout. <= 0 = block forever; >0 =
//                                          allow periodic redraws
//
//   Lifecycle:
//     0. render_init + input_init (raw mode, signals)
//     1. draw_fn(state) → render_flush (initial frame)
//     2. loop:
//          ev = input_drain_one(tick_ms)
//          rc = dispatch_fn(state, ev)
//          if rc == -1: break
//          if rc == 1: render_clear; draw_fn(state); render_flush
//          if ev[0] == "winsize": render_resize before next draw
//     3. render_close + input_close
//   Returns: dispatch_fn's last terminal return code (-1 → 0 / err →
//   propagated).

use "self/tui/render"
use "self/tui/input"

pub fn app_run(state: array, draw_fn: any, dispatch_fn: any, tick_ms: int) -> int {
    let r1 = render_init()
    if r1 != 0 { return -1 }
    let r2 = input_init()
    if r2 != 0 {
        let _ = render_close()
        return -2
    }

    // Initial paint
    let _d0 = draw_fn(state)
    let _f0 = render_flush()

    // Frame loop
    let mut running = 1
    let mut iters = 0
    while running == 1 {
        let ev = input_drain_one(tick_ms)
        // EOF (L1 POLLHUP) — stdin permanently dead. Exit BEFORE dispatch
        // so dispatch_fn impls don't need to opt-in. orphan/parent-closed
        // safety. Root-cause for 2026-05-05 hive-hexa-bin 36GB / 5h runaway:
        // PPID=1 orphan tight-looped poll() (POLLHUP collapsed to 0=timeout
        // pre-fix), pumping ["none"] into _dispatch every tick → array
        // alloc churn → 36GB RSS, 86% CPU. Fix: term_ffi.c returns -2 on
        // hangup, input_drain_one maps to ["eof"], app_run exits here.
        if len(ev) >= 1 && ev[0] == "eof" { running = 0 }
        if running == 0 { break }
        // WinSize triggers a render_resize BEFORE dispatch so the
        // callback sees up-to-date dims via render_dims().
        if len(ev) >= 1 && ev[0] == "winsize" {
            let _r = render_resize()
        }
        let rc = dispatch_fn(state, ev)
        if rc == -1 { running = 0 }
        if rc == 1 {
            let _c = render_clear()
            let _d = draw_fn(state)
            let _f = render_flush()
        }
        iters = iters + 1
        // Orphan-suicide defense-in-depth (every 64 iters): if our parent
        // died and the kernel reparented us to PID 1, exit. Catches the
        // case where stdin POLLHUP isn't delivered (e.g. stdin redirected
        // to /dev/null or to a still-live pipe whose writer leaked to a
        // sibling). 64-tick cadence keeps the syscall cost negligible
        // (~once per 2s at tick_ms=30) while bounding zombie lifetime.
        // term_getppid FFI shim is wired (term_ffi.c / runtime.c /
        // codegen_c2 / build_c / env), but bootstrapping hexa_v2 with the
        // new codegen entry requires a `hexa cc --regen` cycle. Until
        // that lands, the POLLHUP fix above is the primary safety net.
        // Re-enable by uncommenting once hexa_v2 carries the new mapping:
        //   if (iters & 63) == 0 {
        //       if term_getppid() == 1 { running = 0 }
        //   }
    }

    let _c1 = input_close()
    let _c2 = render_close()
    return 0
}

// ── selftest (dispatch-only — no FFI loop) ──────────────────────
//
// We can't drive the real input loop without a TTY harness (deferred to
// integration). The selftest exercises the dispatch contract: the
// frame-loop predicate (rc=-1 quit, rc=1 dirty, rc=0 clean) is
// implemented in pure hexa here as a parallel mock.

let mut _mock_draws = 0
let mut _mock_dispatches = 0

fn _mock_draw(state: array) -> int {
    _mock_draws = _mock_draws + 1
    return 0
}

fn _mock_dispatch_quit_after_3(state: array, ev: array) -> int {
    _mock_dispatches = _mock_dispatches + 1
    if _mock_dispatches >= 3 { return -1 }
    return 1
}

fn _mock_dispatch_clean(state: array, ev: array) -> int {
    _mock_dispatches = _mock_dispatches + 1
    if _mock_dispatches >= 5 { return -1 }
    return 0
}

// Pure-hexa loop mirror — same predicate as app_run, no FFI calls. Used
// to validate the loop control logic without depending on TTY context.
fn _selftest_loop_mirror(state: array, draw_fn: any, dispatch_fn: any) -> int {
    let initial = draw_fn(state)
    let _i = initial
    let mut running = 1
    while running == 1 {
        let ev = ["mock-event"]
        let rc = dispatch_fn(state, ev)
        if rc == -1 { running = 0 }
        if rc == 1 {
            let _ = draw_fn(state)
        }
    }
    return 0
}

pub fn app_selftest() -> int {
    println("self/tui/app — selftest (dispatch contract via mock loop)")

    // Reset mock counters
    _mock_draws = 0
    _mock_dispatches = 0

    // Test 1: dispatch returns dirty=1 twice, then quit=-1.
    //   Expected: initial draw + 2 redraws = 3 draws total. 3 dispatches.
    let _r1 = _selftest_loop_mirror([], _mock_draw, _mock_dispatch_quit_after_3)
    if _mock_draws != 3 { return 1 }
    if _mock_dispatches != 3 { return 2 }

    // Test 2: dispatch returns clean=0 four times, then quit. Only the
    //   initial draw fires.
    _mock_draws = 0
    _mock_dispatches = 0
    let _r2 = _selftest_loop_mirror([], _mock_draw, _mock_dispatch_clean)
    if _mock_draws != 1 { return 3 }
    if _mock_dispatches != 5 { return 4 }

    println("app selftest OK")
    return 0
}
