#!hexa strict
// self/tui/widget/table.hexa — TUI-PRIM L4 stage-2 table widget
//
// Aligned columnar display with optional header row. Stage-2 widget
// per kick T1.A scope. Use for diagnostics tables, key-value lists,
// command-result grids.
//
// API
//   pub fn table_draw(x, y, w, h, headers, rows, fg, bg, attrs) -> int
//     headers : array of column labels (or [] for no header row)
//     rows    : array of arrays — rows[i] is array of cell strings
//     fg/bg   : color for cells (header drawn with bold attr)
//     Returns number of rendered cells.
//
// Layout: column widths auto-fit to widest cell or header per column.
// Total rendered width capped at w; columns truncated if needed.
// Cells separated by " │ " (Unicode light vertical) when L3 supports
// multibyte (it does).

use "self/tui/render"
use "self/tui/widget/text"

fn _max(a: int, b: int) -> int { if a > b { return a } return b }

fn _compute_col_widths(headers: array, rows: array, ncols: int) -> array {
    let mut widths = []
    let mut c = 0
    while c < ncols {
        let mut w = 0
        if c < len(headers) { w = _max(w, len(headers[c])) }
        let mut r = 0
        while r < len(rows) {
            let row = rows[r]
            if c < len(row) { w = _max(w, len(row[c])) }
            r = r + 1
        }
        widths.push(w)
        c = c + 1
    }
    return widths
}

pub fn table_draw(x: int, y: int, w: int, h: int, headers: array, rows: array, fg: int, bg: int, attrs: int) -> int {
    if w < 1 || h < 1 { return -1 }

    // Determine column count from headers + max row length
    let mut ncols = len(headers)
    let mut r = 0
    while r < len(rows) {
        if len(rows[r]) > ncols { ncols = len(rows[r]) }
        r = r + 1
    }
    if ncols == 0 { return 0 }

    let widths = _compute_col_widths(headers, rows, ncols)

    let has_header = if len(headers) > 0 { 1 } else { 0 }
    let mut count = 0

    // Header row
    if has_header == 1 {
        let mut col_x = x
        let mut c = 0
        while c < ncols && col_x < x + w {
            let cell = if c < len(headers) { headers[c] } else { "" }
            let cw = widths[c]
            let avail = (x + w) - col_x
            let cap = if cw > avail { avail } else { cw }
            let n = text_draw(col_x, y, cell, cap, fg, bg, attrs | 1)
            count = count + n
            col_x = col_x + cw
            if c + 1 < ncols && col_x + 3 <= x + w {
                let _s = text_draw(col_x, y, " │ ", 3, fg, bg, attrs)
                count = count + 3
                col_x = col_x + 3
            }
            c = c + 1
        }
    }

    // Data rows
    let body_y = y + has_header
    let max_data_rows = h - has_header
    let mut row_idx = 0
    while row_idx < len(rows) && row_idx < max_data_rows {
        let row = rows[row_idx]
        let mut col_x = x
        let mut c = 0
        while c < ncols && col_x < x + w {
            let cell = if c < len(row) { row[c] } else { "" }
            let cw = widths[c]
            let avail = (x + w) - col_x
            let cap = if cw > avail { avail } else { cw }
            let n = text_draw(col_x, body_y + row_idx, cell, cap, fg, bg, attrs)
            count = count + n
            col_x = col_x + cw
            if c + 1 < ncols && col_x + 3 <= x + w {
                let _s = text_draw(col_x, body_y + row_idx, " │ ", 3, fg, bg, attrs)
                count = count + 3
                col_x = col_x + 3
            }
            c = c + 1
        }
        row_idx = row_idx + 1
    }

    return count
}

pub fn table_selftest() -> int {
    println("self/tui/widget/table — selftest")
    let _r = render_init()

    // 2-column 3-row table with headers
    let headers = ["name", "value"]
    let rows = [["one", "1"], ["two", "22"], ["three", "333"]]
    let n1 = table_draw(0, 0, 30, 5, headers, rows, -1, -1, 0)
    if n1 < 4 { return 1 }   // at minimum header (name + value) + 1 row drew

    // No header
    let n2 = table_draw(0, 6, 30, 3, [], rows, -1, -1, 0)
    if n2 < 3 { return 2 }

    // Bad geometry
    let n3 = table_draw(0, 0, 0, 5, headers, rows, -1, -1, 0)
    if n3 != -1 { return 3 }

    // Empty data
    let n4 = table_draw(0, 0, 30, 5, [], [], -1, -1, 0)
    if n4 != 0 { return 4 }

    // Width capping
    let long = [["very long name here", "x"]]
    let n5 = table_draw(0, 0, 10, 2, ["a", "b"], long, -1, -1, 0)
    if n5 < 0 { return 5 }

    // _compute_col_widths sanity
    let widths = _compute_col_widths(["x", "yy"], [["abc", "d"]], 2)
    if widths[0] != 3 { return 6 }  // max(len("x")=1, len("abc")=3) = 3
    if widths[1] != 2 { return 7 }  // max(len("yy")=2, len("d")=1) = 2

    println("table selftest OK")
    return 0
}
