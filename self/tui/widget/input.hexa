#!hexa strict
// self/tui/widget/input.hexa — TUI-PRIM L4 single-line input widget
//
// Renders a one-line text field with cursor mark. Caller owns the buffer
// + cursor index + dispatch (this is immediate-mode draw only — keystroke
// handling lives in L5 app composer using L2 input.hexa events).
//
// API
//   pub fn input_widget_draw(x, y, w, value, cursor_byte_offset, fg, bg, attrs) -> int
//     value = current buffer content (utf-8 string)
//     cursor_byte_offset = byte index in value (0..len(value))
//     Returns cells written. Cursor cell drawn with reverse attr.

use "self/tui/render"
use "self/tui/widget/text"

pub fn input_widget_draw(x: int, y: int, w: int, value: string, cursor_byte_offset: int, fg: int, bg: int, attrs: int) -> int {
    if w < 1 { return -1 }

    // Clear the whole field first so the gutter is consistent.
    let mut count = 0
    let mut col = 0
    while col < w {
        let r = render_put(x + col, y, " ", fg, bg, attrs)
        if r == 0 { count = count + 1 }
        col = col + 1
    }

    // Draw the value text up to w-1 cells (leave room for cursor at end).
    let _drawn = text_draw(x, y, value, w, fg, bg, attrs)

    // Cursor: count cells (codepoints) from start of value to cursor_byte_offset.
    let cursor_col = _byte_to_col(value, cursor_byte_offset)
    if cursor_col < w {
        // Re-render the cursor cell with reverse attr (4 bit).
        let cursor_glyph = _glyph_at_byte(value, cursor_byte_offset)
        let r2 = render_put(x + cursor_col, y, cursor_glyph, fg, bg, attrs | 4)
        if r2 == 0 { count = count + 1 }
    }

    return count
}

fn _byte_to_col(s: string, byte_offset: int) -> int {
    let mut col = 0
    let mut i = 0
    let n = len(s)
    while i < byte_offset && i < n {
        let b = char_code(s, i)
        let step = if b < 128 { 1 }
                   else if (b & 224) == 192 { 2 }
                   else if (b & 240) == 224 { 3 }
                   else if (b & 248) == 240 { 4 }
                   else { 1 }
        i = i + step
        col = col + 1
    }
    return col
}

fn _glyph_at_byte(s: string, byte_offset: int) -> string {
    let n = len(s)
    if byte_offset >= n { return " " }
    let b = char_code(s, byte_offset)
    let step = if b < 128 { 1 }
               else if (b & 224) == 192 { 2 }
               else if (b & 240) == 224 { 3 }
               else if (b & 248) == 240 { 4 }
               else { 1 }
    return s.substring(byte_offset, byte_offset + step)
}

pub fn input_widget_selftest() -> int {
    println("self/tui/widget/input — selftest")
    let r = render_init()
    if r != 0 { return 1 }

    // Empty buffer
    let n1 = input_widget_draw(0, 0, 10, "", 0, -1, -1, 0)
    if n1 != 11 { return 2 }     // 10 blank cells + 1 cursor cell at col 0

    // Mid-cursor
    let n2 = input_widget_draw(0, 1, 10, "hello", 3, -1, -1, 0)
    if n2 != 11 { return 3 }     // 10 blanks + 1 cursor

    // utf-8 byte → col
    let c1 = _byte_to_col("héllo", 0)
    if c1 != 0 { return 4 }
    let c2 = _byte_to_col("héllo", 3)   // 'h' (1) + 'é' (2) = byte 3, col 2
    if c2 != 2 { return 5 }

    // Bad width
    let n3 = input_widget_draw(0, 0, 0, "x", 0, -1, -1, 0)
    if n3 != -1 { return 6 }

    println("input widget selftest OK")
    return 0
}
