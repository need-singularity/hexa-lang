#!hexa strict
// self/tui/widget/text.hexa — TUI-PRIM L4 text widget
//
// Writes a string into the L3 back buffer cell-by-cell. UTF-8 boundaries
// honored via byte_decode_codepoint helper. Truncates at width w; wraps
// disabled (caller layout responsibility).
//
// API
//   pub fn text_draw(x, y, s, w, fg, bg, attrs) -> int
//     Draws s starting at (x,y), max w cells (column count). Returns
//     number of cells written. Multi-byte utf-8 sequences land in 1 cell
//     each (wide-char cell-spanning deferred to L5+ unicode_width).
//   pub fn text_label(x, y, s, fg, bg, attrs) -> int
//     Convenience: text_draw with w = len(s) (cap at 1024 bytes).

use "self/tui/render"

// Decode utf-8 starting at byte index i. Returns [codepoint, byte_count]
// or [-1, 0] on invalid. Same logic as L2 input.hexa (kept local to
// avoid cross-module import for L4 widget purity).
fn _utf8_step(s: string, i: int) -> array {
    let n = len(s)
    if i >= n { return [-1, 0] }
    let b0 = char_code(s, i)
    if b0 < 128 { return [b0, 1] }
    let cont = if (b0 & 224) == 192 { 1 }
               else if (b0 & 240) == 224 { 2 }
               else if (b0 & 248) == 240 { 3 }
               else { -1 }
    if cont < 0 { return [-1, 0] }
    if i + cont >= n { return [-1, 0] }
    let mask = if cont == 1 { 31 } else if cont == 2 { 15 } else { 7 }
    let mut cp = b0 & mask
    let mut k = 1
    while k <= cont {
        let bk = char_code(s, i + k)
        if (bk & 192) != 128 { return [-1, 0] }
        cp = (cp * 64) | (bk & 63)
        k = k + 1
    }
    return [cp, cont + 1]
}

pub fn text_draw(x: int, y: int, s: string, w: int, fg: int, bg: int, attrs: int) -> int {
    if w <= 0 { return 0 }
    let mut count = 0
    let mut col = 0
    let mut i = 0
    let n = len(s)
    while i < n && col < w {
        let step = _utf8_step(s, i)
        if step[1] == 0 {
            // Invalid utf-8 byte — skip 1
            i = i + 1
        } else {
            let cp = step[0]
            let cp_count = step[1]
            let glyph = s.substring(i, i + cp_count)
            let width = _unicode_width(cp)
            // Wide char (width=2) — only place if there's room for both
            // cells. Render the glyph in the first cell and a blank
            // continuation in the second so render_flush diff path
            // doesn't leak the previous frame's char in the right cell.
            if width == 2 && col + 1 < w {
                let r = render_put(x + col, y, glyph, fg, bg, attrs)
                if r == 0 { count = count + 1 }
                let r2 = render_put(x + col + 1, y, "", fg, bg, attrs)
                if r2 == 0 { count = count + 1 }
                col = col + 2
            } else if width == 2 {
                // Doesn't fit; truncate (skip) — we keep the column
                // budget exact rather than overflow.
                col = col + 1
            } else {
                let r = render_put(x + col, y, glyph, fg, bg, attrs)
                if r == 0 { count = count + 1 }
                col = col + 1
            }
            i = i + cp_count
        }
    }
    return count
}

// East Asian Width (subset). Returns 2 for typical full-width / wide
// codepoints, 1 otherwise. We intentionally avoid bundling the full
// Unicode width table — these ranges cover the practical 99% (CJK
// Unified Ideographs, Hangul Syllables, Hiragana/Katakana, Fullwidth
// ASCII, common emoji blocks). Future enhancement: link a real Unicode
// width data file.
fn _unicode_width(cp: int) -> int {
    // CJK Unified Ideographs (Basic + Ext A + Ext B…)
    if cp >= 0x4E00 && cp <= 0x9FFF { return 2 }       // CJK Unified
    if cp >= 0x3400 && cp <= 0x4DBF { return 2 }       // CJK Ext A
    if cp >= 0x20000 && cp <= 0x2FFFF { return 2 }     // CJK Ext B-F
    // Hangul Syllables + Jamo
    if cp >= 0xAC00 && cp <= 0xD7A3 { return 2 }
    if cp >= 0x1100 && cp <= 0x115F { return 2 }       // Hangul Jamo (leading)
    // Hiragana / Katakana
    if cp >= 0x3040 && cp <= 0x30FF { return 2 }
    // CJK Symbols and Punctuation
    if cp >= 0x3000 && cp <= 0x303E { return 2 }
    // Fullwidth ASCII / Halfwidth Katakana
    if cp >= 0xFF00 && cp <= 0xFF60 { return 2 }
    if cp >= 0xFFE0 && cp <= 0xFFE6 { return 2 }
    // Common emoji blocks (BMP)
    if cp >= 0x1F300 && cp <= 0x1F64F { return 2 }     // Misc Symbols + Emoticons
    if cp >= 0x1F680 && cp <= 0x1F6FF { return 2 }     // Transport
    if cp >= 0x1F900 && cp <= 0x1F9FF { return 2 }     // Supplemental Symbols
    return 1
}

// Public unicode width accessor — exposed for callers that need to
// pre-compute layout (e.g. centering wide-char content).
pub fn text_unicode_width(cp: int) -> int { return _unicode_width(cp) }

// Public visual width of a UTF-8 string. Sums per-codepoint width
// (text_unicode_width). Invalid utf-8 bytes count as 1 cell each
// (mirrors text_draw's skip-1 fallback). Used by callers that need
// cursor / layout column alignment for CJK / emoji input.
pub fn text_visual_width(s: string) -> int {
    let mut w = 0
    let mut i = 0
    let n = len(s)
    while i < n {
        let step = _utf8_step(s, i)
        if step[1] == 0 {
            // Invalid utf-8 byte — count as 1 cell, advance 1 byte
            w = w + 1
            i = i + 1
        } else {
            w = w + _unicode_width(step[0])
            i = i + step[1]
        }
    }
    return w
}

pub fn text_label(x: int, y: int, s: string, fg: int, bg: int, attrs: int) -> int {
    let n = len(s)
    let cap = if n < 1024 { n } else { 1024 }
    return text_draw(x, y, s, cap, fg, bg, attrs)
}

pub fn text_selftest() -> int {
    println("self/tui/widget/text — selftest")
    let r = render_init()
    if r != 0 { return 1 }

    // ASCII smoke
    let n1 = text_draw(0, 0, "hello", 5, 196, -1, 0)
    if n1 != 5 { return 2 }

    // Truncation
    let n2 = text_draw(0, 1, "abcdef", 3, -1, -1, 0)
    if n2 != 3 { return 3 }

    // Empty width
    let n3 = text_draw(0, 0, "x", 0, -1, -1, 0)
    if n3 != 0 { return 4 }

    // utf-8 step verification
    let st1 = _utf8_step("a", 0)
    if st1[0] != 97 || st1[1] != 1 { return 5 }
    let st2 = _utf8_step("é", 0)  // U+00E9 → 0xC3 0xA9
    if st2[0] != 233 || st2[1] != 2 { return 6 }
    let st3 = _utf8_step("中", 0)  // U+4E2D → 0xE4 0xB8 0xAD
    if st3[0] != 20013 || st3[1] != 3 { return 7 }

    // Multi-byte text
    let n4 = text_draw(0, 2, "héllo", 5, -1, -1, 0)
    if n4 != 5 { return 8 }

    // Wide-char width detection
    if _unicode_width(0x4E2D) != 2 { return 9 }     // 中
    if _unicode_width(0xAC00) != 2 { return 10 }    // 가 (Hangul)
    if _unicode_width(0x3042) != 2 { return 11 }    // あ (Hiragana)
    if _unicode_width(0xFF21) != 2 { return 12 }    // Ａ (Fullwidth)
    if _unicode_width(0x1F600) != 2 { return 13 }   // 😀 (Emoji)
    if _unicode_width(0x0061) != 1 { return 14 }    // 'a'
    if _unicode_width(0x00E9) != 1 { return 15 }    // é

    // text_draw with wide chars: "中A" should consume 3 columns (2 + 1)
    let n5 = text_draw(0, 3, "中A", 10, -1, -1, 0)
    // 1 wide cell (drawn) + 1 continuation cell + 1 narrow = 3 render_put OK
    if n5 != 3 { return 16 }

    // text_draw truncates wide char when only 1 column left
    let n6 = text_draw(0, 4, "A中", 2, -1, -1, 0)
    // 'A' fits at col 0; '中' needs cols 1+2 but only 1 left → truncated
    if n6 != 1 { return 17 }

    println("text selftest OK")
    return 0
}
