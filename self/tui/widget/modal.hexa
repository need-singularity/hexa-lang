#!hexa strict
// self/tui/widget/modal.hexa — TUI-PRIM L4 stage-2 modal widget
//
// Centered overlay box with title + multi-line content. Used for hover
// docs, dialog boxes, completion details. Stage-2 widget per kick T1.A
// scope ("table/modal/layout stage-2").
//
// API
//   pub fn modal_draw(parent_w, parent_h, title, lines, fg, bg, attrs) -> int
//     parent_w/h : surrounding screen dims (for centering)
//     title      : caption line at top of box (may be "")
//     lines      : array of content strings (1 per row)
//     attrs      : 1=bold etc. on title row
//
// Layout: centered horizontally, anchored 1/3 down vertically. Box
// auto-sizes to widest line + 2 padding cells, capped at parent_w-4
// and parent_h-6.

use "self/tui/render"
use "self/tui/widget/box"
use "self/tui/widget/text"

pub fn modal_draw(parent_w: int, parent_h: int, title: string, lines: array, fg: int, bg: int, attrs: int) -> int {
    if parent_w < 10 || parent_h < 6 { return -1 }

    // Compute content width: max line length, capped, padded
    let mut max_line = len(title)
    let mut i = 0
    while i < len(lines) {
        let l = len(lines[i])
        if l > max_line { max_line = l }
        i = i + 1
    }
    let inner = max_line + 4
    let max_w = parent_w - 4
    let w = if inner > max_w { max_w } else if inner < 20 { 20 } else { inner }
    let max_h = parent_h - 6
    let content_h = len(lines)
    let h_inner = if content_h > max_h - 2 { max_h - 2 } else { content_h }
    let h = h_inner + 3   // top border + title row + content + bottom border (= h_inner + 3)
    let x = (parent_w - w) / 2
    let y = parent_h / 3

    let _bf = box_fill(x + 1, y + 1, w - 2, h - 2, " ", fg, bg, 0)
    let _b = box_draw(x, y, w, h, fg, bg, attrs, 1)

    if len(title) > 0 {
        let _t = text_label(x + 2, y, " " + title + " ", fg, bg, attrs | 1)
    }

    let mut row = 0
    while row < h_inner && row < len(lines) {
        let _l = text_draw(x + 2, y + 1 + row, lines[row], w - 4, fg, bg, 0)
        row = row + 1
    }
    return row
}

pub fn modal_selftest() -> int {
    println("self/tui/widget/modal — selftest")
    let _r = render_init()

    // Basic dispatch — modal with title + 3 lines on 80x24 screen
    let n1 = modal_draw(80, 24, "Hover Info", ["void main() {", "  printf(\"hi\");", "}"], 195, -1, 0)
    if n1 != 3 { return 1 }

    // No title
    let n2 = modal_draw(80, 24, "", ["one"], -1, -1, 0)
    if n2 != 1 { return 2 }

    // Bad geometry
    let n3 = modal_draw(5, 5, "x", ["y"], -1, -1, 0)
    if n3 != -1 { return 3 }

    // Truncate when too many lines
    let many = ["a", "b", "c", "d", "e", "f", "g", "h", "i", "j", "k", "l", "m", "n", "o", "p", "q", "r", "s", "t"]
    let n4 = modal_draw(80, 24, "Truncate", many, -1, -1, 0)
    if n4 < 1 { return 4 }
    if n4 > 16 { return 5 }   // cap at parent_h - 6 - 2 = 16

    println("modal selftest OK")
    return 0
}
