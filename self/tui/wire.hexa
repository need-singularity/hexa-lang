#!hexa strict
// self/tui/wire.hexa — TUI-PRIM T1.C cross-surface wire contracts
//
// Per kick witness 2026-04-27_hexa-native-tui-implementation-plan_KICK_omega_cycle.json
// T1.C "cross-surface-wire-contract" — ships CONTRACT only; implementations
// (LSP widget host, editor bridge, pi TUI adapter) are forward-deferred to
// the parent self-host cycle.
//
// Four surfaces × 3 dimensions (wire shape, tui_compat, new_files):
//
// ┌─────────────────────────────────────┬──────────────────────────────┬─────────────────────────────────┬─────────────┐
// │ Surface                             │ Wire shape                   │ TUI compat                      │ New files    │
// ├─────────────────────────────────────┼──────────────────────────────┼─────────────────────────────────┼─────────────┤
// │ 1. hexa-compression-daemon (model)  │ stdio line-protocol          │ hexa TUI binary supports        │ ZERO         │
// │    packages/compression/hexa/*.hexa │   k1 / b / topK / query /    │   --line mode (default) +       │              │
// │                                     │   doc <id>\t<text>           │   --tui mode (PTY + alt-screen) │              │
// │                                     │                              │                                 │              │
// │ 2. pi TUI Component                 │ TS Component {               │ hexa app-composer line-array    │ ZERO         │
// │    packages/coding-agent/docs/tui   │   render(width): string[]    │   mode (cell-grid →             │   (adapter   │
// │                                     │   handleInput?(data)         │   newline-joined width-clamped  │   future)    │
// │                                     │   invalidate()               │   string[]); pi spawns hexa     │              │
// │                                     │ }                            │   binary as child component     │              │
// │                                     │                              │                                 │              │
// │ 3. LSP widget host                  │ JSON-RPC over stdio          │ L5 composer's lsp_widget_host   │ self/tui/    │
// │    hexa-lang LSP server (Phase 7)   │   textDocument/{hover,       │   maps LSP response → widget    │   wire/lsp_  │
// │                                     │   publishDiagnostics,        │   (modal=hover, list=            │   widget_    │
// │                                     │   completion}                │   diagnostics, text=completion) │   host.hexa  │
// │                                     │                              │                                 │   (forward)  │
// │                                     │                              │                                 │              │
// │ 4. editor (jetbrains/vscode)        │ stdin/stdout JSON-RPC bridge │ Methods: render / key / resize  │ self/tui/    │
// │    plugin bridge                    │   line-delimited JSON        │                                 │   wire/      │
// │                                     │                              │                                 │   editor_    │
// │                                     │                              │                                 │   bridge.hexa│
// │                                     │                              │                                 │   (forward)  │
// └─────────────────────────────────────┴──────────────────────────────┴─────────────────────────────────┴─────────────┘
//
// Composition surface: L5 app_composer.app_run(state, draw_fn, dispatch_fn, tick_ms)
// — all 4 surfaces plug in via different state/draw/dispatch implementations.
// This module exports CONTRACT helpers (line-array emit, JSON-RPC envelope
// build/parse) so future bridges can reuse them.

use "self/tui/render"

// ═════════════════════════════════════════════════════════════════
// Surface 1: hexa-compression-daemon (model — ZERO new files)
// ═════════════════════════════════════════════════════════════════
//
// Existing daemons in hive/packages/compression/hexa/*.hexa already use
// stdio line-protocol. The hexa TUI binary inherits the same spawn model:
//
//   parent     : spawn hexa-tui-binary, pipe stdin/stdout
//   child      : read line → react → emit line-or-frame → loop
//   line shape : "method\tpayload\n" — method ∈ {render, key, resize, quit}
//
// No code is shipped here — bm25-rank.hexa et al. are the reference.

// ═════════════════════════════════════════════════════════════════
// Surface 2: pi TUI Component (line-array mode — ZERO new files)
// ═════════════════════════════════════════════════════════════════
//
// pi/packages/coding-agent/docs/tui.md defines:
//
//   interface Component {
//     render(width: number): string[]
//     handleInput?(data: string): void
//     invalidate(): void
//   }
//
// The hexa TUI binary supports a line-array output mode (`--line-array`)
// where each render_flush() call emits ROWS lines on stdout instead of
// ANSI-positioned cell writes. pi's spawn-as-child-component path then
// gathers stdout lines and forwards them to its parent Component tree.
//
// Implementation: caller flips a hexa-side boolean, render_flush emits
// the alternate format (no ANSI escapes; just rows joined with "\n").

pub fn wire_pi_render_lines() -> array {
    // Returns the current back-buffer as a string[] of length _rows.
    // Each line is _cols cells joined as glyphs (no ANSI; no SGR).
    // For pi TUI Component.render(width) protocol consumption.
    //
    // 2026-04-28: real implementation — render_back_glyph(x, y) reads
    // the cell glyph from L3's back buffer. SGR/colors are intentionally
    // dropped because pi's TUI component model takes plain string[]
    // (the parent component re-renders this in its own ANSI context).
    let rows = render_rows()
    let cols = render_cols()
    let mut lines = []
    let mut y = 0
    while y < rows {
        let mut parts = []
        let mut x = 0
        while x < cols {
            parts.push(render_back_glyph(x, y))
            x = x + 1
        }
        lines.push(parts.join(""))
        y = y + 1
    }
    return lines
}

// ═════════════════════════════════════════════════════════════════
// Surface 3: LSP widget host (JSON-RPC over stdio — FORWARD)
// ═════════════════════════════════════════════════════════════════
//
// hexa-lang LSP server (parent cycle Phase 7) emits standard LSP JSON-RPC.
// The L5 composer's lsp_widget_host maps each response to a widget:
//
//   textDocument/hover           → modal widget   (markdown content)
//   textDocument/publishDiagnostics → list widget (severity-sorted)
//   textDocument/completion      → text widget    (completion menu)
//
// Wire envelope (line-delimited JSON-RPC 2.0):
//   {"jsonrpc":"2.0","id":1,"method":"textDocument/hover","params":{...}}
//   {"jsonrpc":"2.0","id":1,"result":{"contents":"..."}}
//
// This stub returns the canonical envelope keys; full
// dispatcher implementation lives in self/tui/wire/lsp_widget_host.hexa
// (forward).

pub fn wire_lsp_envelope_keys() -> array {
    return ["jsonrpc", "id", "method", "params", "result", "error"]
}

pub fn wire_lsp_supported_methods() -> array {
    return [
        "textDocument/hover",
        "textDocument/publishDiagnostics",
        "textDocument/completion"
    ]
}

pub fn wire_lsp_widget_for_method(method: string) -> string {
    if method == "textDocument/hover"               { return "modal" }
    if method == "textDocument/publishDiagnostics"  { return "list" }
    if method == "textDocument/completion"          { return "text" }
    return ""
}

// ═════════════════════════════════════════════════════════════════
// Surface 4: editor plugin bridge (JSON-RPC stdio — FORWARD)
// ═════════════════════════════════════════════════════════════════
//
// jetbrains/vscode plugins drive the hexa TUI binary via JSON-RPC line
// protocol. Three methods:
//
//   render(state)            → emit cell-array or line-array
//   key(byte | named-key)    → forward to L5 dispatch_fn
//   resize(rows, cols)       → render_resize(); reply ack
//
// Wire envelope: line-delimited JSON, same shape as LSP.
// Implementation in self/tui/wire/editor_bridge.hexa (forward).

pub fn wire_editor_methods() -> array {
    return ["render", "key", "resize"]
}

// ═════════════════════════════════════════════════════════════════
// Common: line-delimited JSON envelope helpers
// ═════════════════════════════════════════════════════════════════

pub fn wire_jsonrpc_request(id: int, method: string, params_json: string) -> string {
    return "{\"jsonrpc\":\"2.0\",\"id\":" + to_string(id) +
           ",\"method\":\"" + method + "\",\"params\":" + params_json + "}\n"
}

pub fn wire_jsonrpc_response(id: int, result_json: string) -> string {
    return "{\"jsonrpc\":\"2.0\",\"id\":" + to_string(id) +
           ",\"result\":" + result_json + "}\n"
}

pub fn wire_jsonrpc_error(id: int, code: int, message: string) -> string {
    return "{\"jsonrpc\":\"2.0\",\"id\":" + to_string(id) +
           ",\"error\":{\"code\":" + to_string(code) +
           ",\"message\":\"" + message + "\"}}\n"
}

// ═════════════════════════════════════════════════════════════════
// Selftest (T1.C contract verifier)
// ═════════════════════════════════════════════════════════════════

pub fn wire_selftest() -> int {
    println("self/tui/wire — T1.C cross-surface contract selftest")

    // Surface 1: model exists (no code to verify; reference is
    // packages/compression/hexa/bm25-rank.hexa). Skip.

    // Surface 2: pi line-array — render_init first, then put a glyph,
    // then verify the line-array reflects it.
    let _r = render_init()
    let _p = render_put(0, 0, "X", -1, -1, 0)
    let _p2 = render_put(2, 0, "Y", -1, -1, 0)
    let lines = wire_pi_render_lines()
    if len(lines) < 1 { return 1 }
    let row0 = lines[0]
    if len(row0) < 3 { return 15 }
    if row0.substring(0, 1) != "X" { return 16 }
    if row0.substring(2, 3) != "Y" { return 17 }
    // No ANSI escapes in line-array output
    if _str_contains(row0, chr(27)) { return 18 }

    // Surface 3: LSP widget host
    let env_keys = wire_lsp_envelope_keys()
    if len(env_keys) != 6 { return 2 }
    let methods = wire_lsp_supported_methods()
    if len(methods) != 3 { return 3 }
    if wire_lsp_widget_for_method("textDocument/hover") != "modal" { return 4 }
    if wire_lsp_widget_for_method("textDocument/publishDiagnostics") != "list" { return 5 }
    if wire_lsp_widget_for_method("textDocument/completion") != "text" { return 6 }
    if wire_lsp_widget_for_method("textDocument/unknown") != "" { return 7 }

    // Surface 4: editor bridge
    let edit_methods = wire_editor_methods()
    if len(edit_methods) != 3 { return 8 }

    // Common: JSON-RPC envelope helpers
    let req = wire_jsonrpc_request(42, "test", "{\"x\":1}")
    if !_str_contains(req, "\"jsonrpc\":\"2.0\"") { return 9 }
    if !_str_contains(req, "\"id\":42") { return 10 }
    if !_str_contains(req, "\"method\":\"test\"") { return 11 }

    let resp = wire_jsonrpc_response(42, "null")
    if !_str_contains(resp, "\"result\":null") { return 12 }

    let err = wire_jsonrpc_error(42, -32601, "method not found")
    if !_str_contains(err, "\"code\":-32601") { return 13 }
    if !_str_contains(err, "\"message\":\"method not found\"") { return 14 }

    println("wire selftest OK")
    return 0
}

fn _str_contains(haystack: string, needle: string) -> bool {
    let nh = len(haystack)
    let nn = len(needle)
    if nn > nh { return false }
    let mut i = 0
    while i + nn <= nh {
        if haystack.substring(i, i + nn) == needle { return true }
        i = i + 1
    }
    return false
}
