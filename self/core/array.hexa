// ═══════════════════════════════════════════════════════════
//  self/core/array.hexa — HEXA-native array utilities (T4)
//
//  T4 migration 의 두 번째 모듈. runtime.c 의 C 버전과 기능적 동등,
//  hexa.real-interp 경로만 사용 — anima hot path 무영향.
//
//  Usage:
//      use "stdlib/array"
//      let sum = array_sum([1,2,3,4,5])
//
//  See: docs/hexa-hot-path.md (T4 정책)
// ═══════════════════════════════════════════════════════════

// Reverse an array (new array, input unchanged).
pub fn array_reverse(arr) {
    let n = len(arr)
    let mut out = []
    let mut i = n - 1
    while i >= 0 {
        out = out.push(arr[i])
        i = i - 1
    }
    return out
}

// True if any element equals `x`.
pub fn array_contains(arr, x) {
    let n = len(arr)
    let mut i = 0
    while i < n {
        if arr[i] == x { return true }
        i = i + 1
    }
    return false
}

// First index of `x`, or -1 if not present.
pub fn array_index_of(arr, x) {
    let n = len(arr)
    let mut i = 0
    while i < n {
        if arr[i] == x { return i }
        i = i + 1
    }
    return -1
}

// Sum of numeric elements.
pub fn array_sum(arr) {
    let n = len(arr)
    let mut s = 0
    let mut i = 0
    while i < n {
        s = s + arr[i]
        i = i + 1
    }
    return s
}

// Product of numeric elements (empty → 1).
pub fn array_product(arr) {
    let n = len(arr)
    let mut p = 1
    let mut i = 0
    while i < n {
        p = p * arr[i]
        i = i + 1
    }
    return p
}

// Min of numeric elements (empty → 0).
pub fn array_min(arr) {
    let n = len(arr)
    if n == 0 { return 0 }
    let mut m = arr[0]
    let mut i = 1
    while i < n {
        if arr[i] < m { m = arr[i] }
        i = i + 1
    }
    return m
}

// Max of numeric elements (empty → 0).
pub fn array_max(arr) {
    let n = len(arr)
    if n == 0 { return 0 }
    let mut m = arr[0]
    let mut i = 1
    while i < n {
        if arr[i] > m { m = arr[i] }
        i = i + 1
    }
    return m
}

// Concatenate two arrays into a new one.
pub fn array_concat(a, b) {
    let mut out = []
    let na = len(a)
    let nb = len(b)
    let mut i = 0
    while i < na { out = out.push(a[i]); i = i + 1 }
    let mut j = 0
    while j < nb { out = out.push(b[j]); j = j + 1 }
    return out
}

// Take first n elements.
pub fn array_take(arr, n) {
    if n <= 0 { return [] }
    let total = len(arr)
    let k = if n < total { n } else { total }
    let mut out = []
    let mut i = 0
    while i < k { out = out.push(arr[i]); i = i + 1 }
    return out
}

// Drop first n elements.
pub fn array_drop(arr, n) {
    let total = len(arr)
    if n <= 0 { return arr }
    if n >= total { return [] }
    let mut out = []
    let mut i = n
    while i < total { out = out.push(arr[i]); i = i + 1 }
    return out
}

// Count elements equal to `x`.
pub fn array_count(arr, x) {
    let n = len(arr)
    let mut c = 0
    let mut i = 0
    while i < n {
        if arr[i] == x { c = c + 1 }
        i = i + 1
    }
    return c
}
