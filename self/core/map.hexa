// ═══════════════════════════════════════════════════════════
//  self/core/map.hexa — HEXA-native map utilities (T4)
//
//  T4 trio (string + array + map) 완성의 마지막 모듈. stage0 의 `#{...}`
//  map primitives (.keys(), .values(), m[key], m.key) 위에서 순수 HEXA
//  로직으로 고수준 오퍼레이션 구현.
//
//  Note: stage0 의 `len(m)` 은 map 에 대해 0 을 반환 (array 전용).
//  엔트리 개수는 `len(m.keys())` 로 계산. map_size() 가 편의 래퍼.
//
//  Usage:
//      use "stdlib/map"
//      let n = map_size(m)
// ═══════════════════════════════════════════════════════════

// Number of entries in a map.
pub fn map_size(m) {
    return len(m.keys())
}

// True if m has the given key.
pub fn map_contains_key(m, key) {
    let ks = m.keys()
    let n = len(ks)
    let mut i = 0
    while i < n {
        if ks[i] == key { return true }
        i = i + 1
    }
    return false
}

// Get value or default if key missing.
pub fn map_get_or(m, key, default_value) {
    if map_contains_key(m, key) {
        return m[key]
    }
    return default_value
}

// All keys as array (same as m.keys() — convenience wrapper for consistency).
pub fn map_keys(m) {
    return m.keys()
}

// All values as array (order matches map_keys).
pub fn map_values(m) {
    return m.values()
}

// Collect key-value pairs as array of [key, value] tuples.
// Each element is a 2-array: [ks[i], vs[i]].
pub fn map_entries(m) {
    let ks = m.keys()
    let vs = m.values()
    let n = len(ks)
    let mut out = []
    let mut i = 0
    while i < n {
        out.push([ks[i], vs[i]])
        i = i + 1
    }
    return out
}

// True if map is empty (size == 0).
pub fn map_is_empty(m) {
    return map_size(m) == 0
}

// Sum of all values (assumes numeric).
pub fn map_sum_values(m) {
    let vs = m.values()
    let n = len(vs)
    let mut s = 0
    let mut i = 0
    while i < n {
        s = s + vs[i]
        i = i + 1
    }
    return s
}

// Count entries whose value equals v.
pub fn map_count_values(m, v) {
    let vs = m.values()
    let n = len(vs)
    let mut c = 0
    let mut i = 0
    while i < n {
        if vs[i] == v { c = c + 1 }
        i = i + 1
    }
    return c
}
