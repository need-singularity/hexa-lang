// self/lib/set_emu.hexa — list-backed Set emulation (I10 우회)
//
// No native Set type → use list + linear search.
// O(n) ops but correct semantics. For small-to-medium N (<10k).
//
// 사용법:
//   let s = set_new()
//   let s2 = set_add(s, 3)
//   set_has(s2, 3)  // true

fn set_new() {
    return []
}

fn set_has(s, x) {
    let n = len(s)
    let mut i = 0
    while i < n {
        if s[i] == x { return true }
        i = i + 1
    }
    return false
}

fn set_add(s, x) {
    if set_has(s, x) { return s }
    return s.push(x)
}

fn set_remove(s, x) {
    let mut out = []
    let n = len(s)
    let mut i = 0
    while i < n {
        if s[i] != x { out.push(s[i]) }
        i = i + 1
    }
    return out
}

fn set_size(s) {
    return len(s)
}

fn set_union(a, b) {
    let mut out = a
    let n = len(b)
    let mut i = 0
    while i < n {
        out = set_add(out, b[i])
        i = i + 1
    }
    return out
}

fn set_intersect(a, b) {
    let mut out = []
    let n = len(a)
    let mut i = 0
    while i < n {
        if set_has(b, a[i]) { out.push(a[i]) }
        i = i + 1
    }
    return out
}

fn set_diff(a, b) {
    let mut out = []
    let n = len(a)
    let mut i = 0
    while i < n {
        if !set_has(b, a[i]) { out.push(a[i]) }
        i = i + 1
    }
    return out
}

fn set_from_list(l) {
    let mut out = []
    let n = len(l)
    let mut i = 0
    while i < n {
        out = set_add(out, l[i])
        i = i + 1
    }
    return out
}

// ----- tests -----
println("Test: set_new/add/has")
let s = set_new()
let s1 = set_add(s, 1)
let s2 = set_add(s1, 2)
let s3 = set_add(s2, 1)  // dup → no-op
assert set_has(s2, 1)
assert set_has(s2, 2)
assert !set_has(s2, 3)
assert set_size(s3) == 2
println("  PASS")

println("Test: set_remove")
let s4 = set_remove(s2, 1)
assert !set_has(s4, 1)
assert set_has(s4, 2)
println("  PASS")

println("Test: set_union")
let a = set_add(set_add(set_new(), 1), 2)
let b = set_add(set_add(set_new(), 2), 3)
let u = set_union(a, b)
assert set_size(u) == 3
assert set_has(u, 1)
assert set_has(u, 2)
assert set_has(u, 3)
println("  PASS")

println("Test: set_intersect")
let ix = set_intersect(a, b)
assert set_size(ix) == 1
assert set_has(ix, 2)
println("  PASS")

println("Test: set_diff")
let df = set_diff(a, b)
assert set_size(df) == 1
assert set_has(df, 1)
println("  PASS")

println("Test: set_from_list dedup")
let fl = set_from_list([1, 2, 2, 3, 1, 4])
assert set_size(fl) == 4
println("  PASS")

println("")
println("=== set_emu.hexa: ALL TESTS PASSED ===")
