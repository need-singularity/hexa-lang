#!hexa strict
// self/core/ai_err.hexa — AI-native structured error/ok emitter
//
// PURPOSE
//   Canonical stderr format for all tools touching the OS-level lock path
//   (tool/os_level_lock.hexa, tool/hx_edit.hexa, tool/pam_tid_check.hexa,
//   tool/raw_*). Agents downstream parse these messages programmatically —
//   so the shape is load-bearing and must stay stable.
//
// FORMAT (error)
//   err <domain>/<code>
//     slug: <slug>
//     file: <path>
//     cause: <one-line reason>
//     remedy:
//       - <step 1>
//       - <step 2>
//     ref: <ssot pointer>
//   <blank line>
//
// FORMAT (ok)
//   ok <summary>
//     <key>: <value>
//     ...
//   <blank line>
//
// CONTRACT
//   - Writes to stderr via eprintln (never silent — raw#12 compliance).
//   - ai_err_exit MUST emit the payload BEFORE exit(); never silent-exit.
//   - `fields` is array of [key, value] pairs; repeated `remedy` allowed.
//   - `domain` and `code` are kebab-case (parser convention).
//   - Unknown keys are tolerated (emitted verbatim); recommended keys are
//     slug / file / cause / remedy (multi) / ref.
//
// USAGE
//   use "self/core/ai_err"
//
//   ai_err("os-lock", "unknown-file", [
//       ["file", path],
//       ["cause", "file not in raw:os-lock scope"],
//       ["remedy", "add to _required_targets() in tool/os_level_lock.hexa"],
//       ["ref", "raw:os-lock"]
//   ])
//
//   ai_err_exit("hx-edit", "sudo-aborted", [
//       ["cause", "user ctrl-C during sudo prompt"],
//       ["remedy", "./hx edit --retry"],
//       ["ref", "raw:os-lock"]
//   ], 130)
//
//   ai_ok("os-lock/status", [
//       ["platform", "darwin"],
//       [".raw", "L2-schg"]
//   ])

// ─── internals ──────────────────────────────────────────────────

fn _is_kebab(s: string) -> bool {
    // Permissive: letters (lower), digits, dash. Reject empty / uppercase /
    // space / punctuation — enough to keep the literal agent-parseable.
    let n = len(s)
    if n == 0 { return false }
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        let pc = char_code(c, 0)
        let is_lower = pc >= 97 && pc <= 122
        let is_digit = pc >= 48 && pc <= 57
        let is_dash  = pc == 45
        if !(is_lower || is_digit || is_dash) { return false }
        i = i + 1
    }
    return true
}

fn _fmt_value(v: string) -> string {
    // Strip trailing newlines — we emit our own. Embedded newlines in value
    // would break parser, so we collapse them to spaces defensively.
    let s = v.trim()
    let parts = split(s, "\n")
    if len(parts) <= 1 { return s }
    return parts.join(" ")
}

// ─── public API ─────────────────────────────────────────────────

// Emit an ai-native error on stderr. Never silent — if domain/code are
// malformed we still emit with a best-effort prefix and a note.
pub fn ai_err(domain: string, code: string, fields: array) {
    let mut dom = domain
    let mut cod = code
    let mut shape_warn = ""
    if !_is_kebab(dom) {
        shape_warn = "domain not kebab-case"
        // keep raw value — parser will see it but this field marks it
    }
    if !_is_kebab(cod) {
        if shape_warn == "" { shape_warn = "code not kebab-case" }
        else { shape_warn = shape_warn + "; code not kebab-case" }
    }

    eprintln("err " + dom + "/" + cod)

    // Emit fields preserving order. Multi-`remedy` is rendered as a single
    // block under one `remedy:` header when ≥2 remedy entries appear.
    let mut remedy_count = 0
    for f in fields {
        if len(f) < 2 { continue }
        if f[0] == "remedy" { remedy_count = remedy_count + 1 }
    }

    let mut remedy_header_emitted = false
    for f in fields {
        if len(f) < 2 { continue }
        let k = f[0]
        let v = _fmt_value(f[1])
        if k == "remedy" {
            if remedy_count >= 2 {
                if !remedy_header_emitted {
                    eprintln("  remedy:")
                    remedy_header_emitted = true
                }
                eprintln("    - " + v)
            } else {
                // Single remedy — still use the block form for parser
                // uniformity (agents expect `remedy:` + `  - item`).
                eprintln("  remedy:")
                eprintln("    - " + v)
            }
        } else {
            eprintln("  " + k + ": " + v)
        }
    }

    if shape_warn != "" {
        eprintln("  shape-warn: " + shape_warn)
    }
    eprintln("")
}

// Error + exit (never silent — error is emitted BEFORE exit).
pub fn ai_err_exit(domain: string, code: string, fields: array, exit_code: int) {
    ai_err(domain, code, fields)
    // If someone calls this with exit_code=0 by mistake, we still exit 1
    // to preserve the invariant "ai_err_exit never returns a pass code".
    let mut rc = exit_code
    if rc == 0 { rc = 1 }
    exit(rc)
}

// Structured PASS/OK counterpart — agents parse the same way as ai_err.
pub fn ai_ok(summary: string, fields: array) {
    eprintln("ok " + summary)
    for f in fields {
        if len(f) < 2 { continue }
        let k = f[0]
        let v = _fmt_value(f[1])
        eprintln("  " + k + ": " + v)
    }
    eprintln("")
}

// ─── induce stub (no side effects on import) ────────────────────

pub fn ai_err_induce() -> string {
    return "self/core/ai_err — structured emitter. API: ai_err(domain, code, fields), " +
           "ai_err_exit(domain, code, fields, exit_code), ai_ok(summary, fields). " +
           "Format: `err <domain>/<code>` + indented key/value. Used by os-lock / hx-edit / pam-tid."
}
