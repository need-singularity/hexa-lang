// ═══════════════════════════════════════════════════════════
//  self/ai_native/mixed_precision.hexa — HEXA-native mixed precision
//
//  AI-native ROI item #93 — @mixed_precision fp16/bf16.
//  Activation/weight는 fp16/bf16으로 다운캐스트하여 메모리 반감,
//  accumulator는 fp32 유지로 정확도 보존.
//
//  Hexa에는 네이티브 fp16/bf16 타입이 없으므로 **시뮬레이션**:
//  fp32 수치를 목표 정밀도가 표현 가능한 가장 가까운 값으로
//  반올림/clamp 한 뒤 fp32 컨테이너에 재저장. 하드웨어 fp16/bf16의
//  메모리 반감 효과는 여기선 못 잡지만, **정확도 영향은 정확히**
//  재현한다 (quant/round/clamp error identical to real fp16/bf16).
//
//  Native HW 대비 한계:
//      (1) 메모리 반감 없음 (fp32 컨테이너 유지)
//      (2) subnormal 경계 근사 — hexa 부동소수점 분해 불가로
//          2^(-14) 미만은 단순 0 처리 (진짜 fp16 subnormal은
//          2^(-24) 까지 유지되며 gradual underflow 를 제공)
//      (3) round-to-even 대신 round-half-away-from-zero 사용
//
//  Usage:
//      use "ai_native/mixed_precision"
//      let y = fp16_quantize(1.234)
//      let C = mixed_matmul_fp16(A, B)   // fp32 ↔ fp16 ↔ fp32
//
//  Measured accuracy on Gaussian 32×32 matmul (scale≈1):
//      fp16 L2 rel err ≈ 0.0008
//      bf16 L2 rel err ≈ 0.006
//
//  See: docs/ai-native.md, CLAUDE.md HX5, feedback_hexa_parser_quirks.md
// ═══════════════════════════════════════════════════════════

// ── Helpers ────────────────────────────────────────────────

// mp_abs → abs_pure (math_pure.hexa)

// Round-half-away-from-zero (deterministic).
pub fn mp_round(x) {
    if x >= 0.0 {
        return floor(x + 0.5)
    }
    return 0.0 - floor((0.0 - x) + 0.5)
}

// Integer power of two for small exponents.
// Handles both positive (2^n) and negative (2^-n) via divide.
// We avoid bit tricks — pure arithmetic only (hexa parser 제약).
pub fn mp_pow2(e) {
    let mut p = 1.0
    if e >= 0 {
        let mut i = 0
        while i < e {
            p = p * 2.0
            i = i + 1
        }
        return p
    }
    // negative exponent
    let neg_e = 0 - e
    let mut i2 = 0
    while i2 < neg_e {
        p = p * 0.5
        i2 = i2 + 1
    }
    return p
}

// Extract the binade exponent `k` such that 2^k <= |x| < 2^(k+1).
// Uses repeated multiply/divide (no bit extraction).
// Returns 0 for x == 0.0 (caller should special-case).
pub fn mp_binade(x) {
    let ax = abs_pure(x)
    if ax == 0.0 { return 0 }
    let mut e = 0
    let mut v = ax
    if v >= 2.0 {
        while v >= 2.0 {
            v = v * 0.5
            e = e + 1
        }
        return e
    }
    // v < 1.0 case — scale up until >= 1
    while v < 1.0 {
        v = v * 2.0
        e = e - 1
    }
    return e
}

// ── fp16 simulation ─────────────────────────────────────────
//
// IEEE 754 half precision:
//   1 sign | 5 exponent (bias 15) | 10 mantissa
//   range  ≈ ±65504
//   smallest normal ≈ 6.10e-5  (2^-14)
//   smallest subnormal ≈ 5.96e-8 (2^-24)
//   mantissa bits = 10 → quantum = 2^(k-10) for binade k
//
// We reproduce the *quantization* (scale mantissa to 10 bits and
// round) and the *range clamp*. Subnormals below 2^-14 are flushed
// to zero — a deliberate simplification documented in the header.

pub fn fp16_quantize(x) {
    // Special: exact zero / NaN surrogate.
    if x == 0.0 { return 0.0 }
    // Sign handling.
    let sign = if x < 0.0 { 0.0 - 1.0 } else { 1.0 }
    let ax = abs_pure(x)
    // Overflow clamp.
    let fp16_max = 65504.0
    if ax > fp16_max { return sign * fp16_max }
    // Underflow flush (below smallest normal 2^-14).
    let fp16_min_normal = mp_pow2(0 - 14)
    if ax < fp16_min_normal {
        // Subnormal range: quantum = 2^-24. Round to that grid.
        let sub_q = mp_pow2(0 - 24)
        let rounded = mp_round(ax / sub_q) * sub_q
        return sign * rounded
    }
    // Normal range: quantum = 2^(k-10) where k = binade(ax).
    let k = mp_binade(ax)
    let quantum = mp_pow2(k - 10)
    let rounded2 = mp_round(ax / quantum) * quantum
    // Post-rounding overflow check (e.g. 65504 * (1 + 2^-11) rounds up).
    if rounded2 > fp16_max { return sign * fp16_max }
    return sign * rounded2
}

// ── bf16 simulation ─────────────────────────────────────────
//
// Brain float 16:
//   1 sign | 8 exponent (bias 127) | 7 mantissa
//   range  ≈ fp32 (±3.4e38) — 하위 16비트만 자름
//   mantissa bits = 7 → quantum = 2^(k-7) for binade k
//
// Because bf16 shares fp32's exponent, there's no clamp needed
// except for infinity surrogate (which we skip — no NaN path).

pub fn bf16_quantize(x) {
    if x == 0.0 { return 0.0 }
    let sign = if x < 0.0 { 0.0 - 1.0 } else { 1.0 }
    let ax = abs_pure(x)
    let k = mp_binade(ax)
    let quantum = mp_pow2(k - 7)
    let rounded = mp_round(ax / quantum) * quantum
    return sign * rounded
}

// ── Vector helpers — apply quantize elementwise ─────────────

pub fn vec_fp16(x) {
    let n = len(x)
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(fp16_quantize(x[i]))
        i = i + 1
    }
    return out
}

pub fn vec_bf16(x) {
    let n = len(x)
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(bf16_quantize(x[i]))
        i = i + 1
    }
    return out
}

// ── Matmul baseline + mixed-precision variants ──────────────
//
// Convention: A is (m × k), B is (k × n), both row-major flat
// arrays of length m*k and k*n. Result C is (m × n), length m*n.
// accumulator **always** fp32 — this is the whole point of mixed
// precision: downcast inputs, upcast the dot product.

pub fn mixed_matmul_naive(A, B, m, k, n) {
    let mut C = []
    let mut i = 0
    while i < m {
        let mut j = 0
        while j < n {
            let mut acc = 0.0
            let mut p = 0
            while p < k {
                acc = acc + A[i * k + p] * B[p * n + j]
                p = p + 1
            }
            C = C.push(acc)
            j = j + 1
        }
        i = i + 1
    }
    return C
}

pub fn mixed_matmul_fp16(A, B, m, k, n) {
    // Downcast inputs — in real HW this halves memory bandwidth.
    let A16 = vec_fp16(A)
    let B16 = vec_fp16(B)
    // fp32 accumulator (still a hexa float — 64-bit under the hood).
    let mut C = []
    let mut i = 0
    while i < m {
        let mut j = 0
        while j < n {
            let mut acc = 0.0
            let mut p = 0
            while p < k {
                acc = acc + A16[i * k + p] * B16[p * n + j]
                p = p + 1
            }
            C = C.push(acc)
            j = j + 1
        }
        i = i + 1
    }
    return C
}

pub fn mixed_matmul_bf16(A, B, m, k, n) {
    let AB = vec_bf16(A)
    let BB = vec_bf16(B)
    let mut C = []
    let mut i = 0
    while i < m {
        let mut j = 0
        while j < n {
            let mut acc = 0.0
            let mut p = 0
            while p < k {
                acc = acc + AB[i * k + p] * BB[p * n + j]
                p = p + 1
            }
            C = C.push(acc)
            j = j + 1
        }
        i = i + 1
    }
    return C
}

// ── Relative L2 error — shared helper ───────────────────────

pub fn mp_l2_rel_err(ref, approx) {
    let n = len(ref)
    let mut num = 0.0
    let mut den = 0.0
    let mut i = 0
    while i < n {
        let d = ref[i] - approx[i]
        num = num + d * d
        den = den + ref[i] * ref[i]
        i = i + 1
    }
    if den == 0.0 { return 0.0 }
    return sqrt(num) / sqrt(den)
}


// -- end inlined --
// ── abs_pure (from runtime/math_pure.hexa) ──
fn abs_pure(v) {
    let t = type_of(v)
    if t == "int" {
        if v < 0 { return 0 - v }
        return v
    }
    if t == "float" {
        if v < 0.0 { return 0.0 - v }
        return v
    }
    v
}
// ── end abs_pure ──


let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

// Gaussian-ish generator (CLT sum of 12 uniforms, mean 0 / var 1).
fn gen_gauss(n) {
    let mut w = []
    let mut i = 0
    while i < n {
        let mut s = 0.0
        let mut k = 0
        while k < 12 {
            s = s + (random() - 0.5)
            k = k + 1
        }
        w = w.push(s)
        i = i + 1
    }
    return w
}

println("═══════════════════════════════════════════════════════")
println("  HEXA AI-Native Mixed Precision Tests (ROI #93)")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Helpers ──────────────────────────────────────────────
println("--- helpers ---")
check("abs_pure(-3.5) == 3.5", abs_pure(0.0 - 3.5) == 3.5)
check("mp_round(2.6) == 3", mp_round(2.6) == 3.0)
check("mp_round(-2.6) == -3", mp_round(0.0 - 2.6) == 0.0 - 3.0)
check("mp_pow2(0) == 1", mp_pow2(0) == 1.0)
check("mp_pow2(3) == 8", mp_pow2(3) == 8.0)
check("mp_pow2(-2) == 0.25", mp_pow2(0 - 2) == 0.25)
check("mp_binade(1.0) == 0", mp_binade(1.0) == 0)
check("mp_binade(3.5) == 1", mp_binade(3.5) == 1)
check("mp_binade(0.25) == -2", mp_binade(0.25) == 0 - 2)

// ── 2. fp16 round-trip ──────────────────────────────────────
println("")
println("--- fp16 round-trip ---")

// Exact-representable values should round-trip identically.
check("fp16(0.0) == 0.0", fp16_quantize(0.0) == 0.0)
check("fp16(1.0) == 1.0", fp16_quantize(1.0) == 1.0)
check("fp16(-1.0) == -1.0", fp16_quantize(0.0 - 1.0) == 0.0 - 1.0)
check("fp16(0.5) == 0.5", fp16_quantize(0.5) == 0.5)
check("fp16(2.0) == 2.0", fp16_quantize(2.0) == 2.0)

// Near-approximate values — fp16 has ~3-4 digit precision.
let q100 = fp16_quantize(100.0)
println("  fp16(100.0) = " + to_string(q100))
let err100 = abs_pure(q100 - 100.0) / 100.0
check("fp16(100.0) rel err < 2e-3", err100 < 2.0e-3)

let qpi = fp16_quantize(3.14159)
let errpi = abs_pure(qpi - 3.14159) / 3.14159
println("  fp16(3.14159) = " + to_string(qpi) + "  rel err = " + to_string(errpi))
check("fp16(pi) rel err < 2e-3", errpi < 2.0e-3)

// Overflow clamp — anything above 65504 should saturate.
check("fp16(70000.0) == 65504", fp16_quantize(70000.0) == 65504.0)
check("fp16(-70000.0) == -65504", fp16_quantize(0.0 - 70000.0) == 0.0 - 65504.0)
check("fp16(1e8) == 65504", fp16_quantize(1.0e8) == 65504.0)

// Underflow flush — below smallest normal (2^-14 ≈ 6.1e-5) uses
// subnormal grid (2^-24 quantum). Very small values round to 0.
let qtiny = fp16_quantize(1.0e-10)
check("fp16(1e-10) flushed to 0", qtiny == 0.0)

// ── 3. bf16 round-trip ──────────────────────────────────────
println("")
println("--- bf16 round-trip ---")

check("bf16(0.0) == 0.0", bf16_quantize(0.0) == 0.0)
check("bf16(1.0) == 1.0", bf16_quantize(1.0) == 1.0)
check("bf16(-1.0) == -1.0", bf16_quantize(0.0 - 1.0) == 0.0 - 1.0)
check("bf16(2.0) == 2.0", bf16_quantize(2.0) == 2.0)
check("bf16(0.5) == 0.5", bf16_quantize(0.5) == 0.5)
check("bf16(256.0) == 256.0", bf16_quantize(256.0) == 256.0)

// bf16 shares fp32 range — huge values don't clamp.
let qhuge = bf16_quantize(1.0e30)
check("bf16(1e30) stays close", abs_pure(qhuge - 1.0e30) / 1.0e30 < 1.0e-2)

// bf16 has 7 mantissa bits → rel err bounded by 2^-7 ≈ 8e-3.
let qpi2 = bf16_quantize(3.14159)
let errpi2 = abs_pure(qpi2 - 3.14159) / 3.14159
println("  bf16(pi) = " + to_string(qpi2) + "  rel err = " + to_string(errpi2))
check("bf16(pi) rel err < 1e-2", errpi2 < 1.0e-2)

// ── 4. Mixed matmul: fp16 ──────────────────────────────────
println("")
println("--- mixed matmul fp16 (32x32) ---")

let dim = 32
let len_mat = dim * dim
let A = gen_gauss(len_mat)
let B = gen_gauss(len_mat)

let C_ref = mixed_matmul_naive(A, B, dim, dim, dim)
let C_fp16 = mixed_matmul_fp16(A, B, dim, dim, dim)

let err_fp16 = mp_l2_rel_err(C_ref, C_fp16)
println("  fp16 matmul L2 rel err = " + to_string(err_fp16))
check("fp16 shape preserved", len(C_fp16) == len_mat)
check("fp16 matmul L2 err < 0.01", err_fp16 < 0.01)

// ── 5. Mixed matmul: bf16 ──────────────────────────────────
println("")
println("--- mixed matmul bf16 (32x32) ---")

let C_bf16 = mixed_matmul_bf16(A, B, dim, dim, dim)
let err_bf16 = mp_l2_rel_err(C_ref, C_bf16)
println("  bf16 matmul L2 rel err = " + to_string(err_bf16))
check("bf16 shape preserved", len(C_bf16) == len_mat)
check("bf16 matmul L2 err < 0.02", err_bf16 < 0.02)

// ── 6. Precision ordering ──────────────────────────────────
println("")
println("--- precision ordering ---")
// fp16 (10-bit mantissa) should beat bf16 (7-bit) when values are
// in-range (our Gaussians are O(1), well within fp16).
check("fp16 err <= bf16 err", err_fp16 <= err_bf16)

// ── 7. Edge: fp16 overflow in matmul ───────────────────────
println("")
println("--- fp16 overflow edge ---")
// 2x2 case — element product 300*300 = 90000 > 65504 in fp16.
// But the accumulator is fp32, so the matmul itself is fine.
let Aover = [300.0, 0.0, 0.0, 300.0]
let Bover = [300.0, 0.0, 0.0, 300.0]
let Cover16 = mixed_matmul_fp16(Aover, Bover, 2, 2, 2)
println("  C[0,0] = " + to_string(Cover16[0]) + "  (expected 90000)")
check("fp16 matmul acc = 90000", abs_pure(Cover16[0] - 90000.0) < 1.0)

// If we *explicitly* quantize the output to fp16, it should clamp.
let qover = fp16_quantize(Cover16[0])
check("fp16_quantize(90000) clamps to 65504", qover == 65504.0)

// ── 8. Vec helpers ─────────────────────────────────────────
println("")
println("--- vec helpers ---")
let small = [1.0, 0.0 - 2.0, 3.14159, 0.5, 0.0]
let v16 = vec_fp16(small)
let vbf = vec_bf16(small)
check("vec_fp16 length", len(v16) == 5)
check("vec_bf16 length", len(vbf) == 5)
check("vec_fp16[0] == 1.0", v16[0] == 1.0)
check("vec_fp16[4] == 0.0", v16[4] == 0.0)
check("vec_bf16[1] == -2.0", vbf[1] == 0.0 - 2.0)

// ── Summary ─────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL")
if fail_count == 0 {
    println("  ALL MIXED PRECISION TESTS PASSED — ROI #93 completed_at: 2026-04-16")
} else {
    println("  MIXED PRECISION TESTS FAILED")
}
