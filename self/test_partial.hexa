// ===============================================================
//  test_partial.hexa -- @partial AI-native attribute tests
//
//  @partial = partial application optimization.
//  When some arguments are fixed (constants), a specialized version
//  can be generated with those args inlined, eliminating closure
//  overhead.
//
//  Static model: ai_native_pass.hexa validates:
//    - @partial requires >=2 params (at least one to fix, one to keep)
//    - 0 or 1 param triggers violation
//
//  Runtime: partial application is simulated by wrapping a fn call
//  with fixed args. The compiler can later monomorphize.
// ===============================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("===============================================================")
println("  HEXA @partial Partial Application Tests")
println("===============================================================")
println("")

// ── 1. Basic add with partial application ───────────────────

println("--- 1. Basic add ---")

@partial
fn partial_add(a, b) -> int {
    return a + b
}

// Full application
check("@partial add(3,4) = 7", partial_add(3, 4), 7)
check("@partial add(10,20) = 30", partial_add(10, 20), 30)

// Simulate partial: fix first arg
fn add_10(x) { return partial_add(10, x) }
check("@partial add_10(5) = 15", add_10(5), 15)
check("@partial add_10(0) = 10", add_10(0), 10)
println("")

// ── 2. Multiply with partial ────────────────────────────────

println("--- 2. Multiply ---")

@partial
fn partial_mul(a, b) -> int {
    return a * b
}

fn double(x) { return partial_mul(2, x) }
fn triple(x) { return partial_mul(3, x) }

check("@partial double(7) = 14", double(7), 14)
check("@partial triple(7) = 21", triple(7), 21)
check("@partial mul(6,7) = 42", partial_mul(6, 7), 42)
println("")

// ── 3. Three-arg function ───────────────────────────────────

println("--- 3. Three-arg ---")

@partial
fn partial_madd(a, b, c) -> int {
    return a * b + c
}

// Full
check("@partial madd(2,3,4) = 10", partial_madd(2, 3, 4), 10)

// Partial: fix first two
fn madd_2_3(c) { return partial_madd(2, 3, c) }
check("@partial madd_2_3(1) = 7", madd_2_3(1), 7)
check("@partial madd_2_3(10) = 16", madd_2_3(10), 16)

// Partial: fix first only
fn madd_5(b, c) { return partial_madd(5, b, c) }
check("@partial madd_5(4,3) = 23", madd_5(4, 3), 23)
println("")

// ── 4. String concatenation partial ─────────────────────────

println("--- 4. String concat ---")

@partial
fn partial_greet(prefix, name) -> string {
    return prefix + " " + name
}

fn hello(name) { return partial_greet("Hello", name) }
fn goodbye(name) { return partial_greet("Goodbye", name) }

check("@partial hello(World) = Hello World", hello("World"), "Hello World")
check("@partial goodbye(World) = Goodbye World", goodbye("World"), "Goodbye World")
println("")

// ── 5. Power function ───────────────────────────────────────

println("--- 5. Power ---")

@partial
fn partial_pow(base, exp) -> int {
    let mut r = 1
    let mut i = 0
    while i < exp {
        r = r * base
        i = i + 1
    }
    return r
}

fn square(x) { return partial_pow(x, 2) }
fn cube(x) { return partial_pow(x, 3) }
fn pow2(n) { return partial_pow(2, n) }

check("@partial square(5) = 25", square(5), 25)
check("@partial cube(3) = 27", cube(3), 27)
check("@partial pow2(8) = 256", pow2(8), 256)
check("@partial pow2(10) = 1024", pow2(10), 1024)
println("")

// ── 6. Array operations with partial ────────────────────────

println("--- 6. Array ops ---")

@partial
fn partial_scale(factor, arr) {
    let mut out = []
    let mut i = 0
    while i < len(arr) {
        out = out.push(arr[i] * factor)
        i = i + 1
    }
    return out
}

fn scale_by_2(arr) { return partial_scale(2, arr) }
fn scale_by_10(arr) { return partial_scale(10, arr) }

let s1 = scale_by_2([1, 2, 3])
check("@partial scale_by_2 [1,2,3] first", s1[0], 2)
check("@partial scale_by_2 [1,2,3] last", s1[2], 6)

let s2 = scale_by_10([5, 10])
check("@partial scale_by_10 [5,10] first", s2[0], 50)
check("@partial scale_by_10 [5,10] last", s2[1], 100)
println("")

// ── 7. Comparison function ──────────────────────────────────

println("--- 7. Comparison ---")

@partial
fn partial_clamp(lo, hi, val) -> int {
    if val < lo { return lo }
    if val > hi { return hi }
    return val
}

fn clamp_0_100(x) { return partial_clamp(0, 100, x) }

check("@partial clamp(-5) = 0", clamp_0_100(-5), 0)
check("@partial clamp(50) = 50", clamp_0_100(50), 50)
check("@partial clamp(200) = 100", clamp_0_100(200), 100)
println("")

// ── 8. Nested partial ───────────────────────────────────────

println("--- 8. Nested partial ---")

@partial
fn partial_linear(a, b, x) -> int {
    return a * x + b
}

fn f_2x_plus_1(x) { return partial_linear(2, 1, x) }
fn f_3x_minus_5(x) { return partial_linear(3, -5, x) }

check("@partial 2x+1 at x=0 = 1", f_2x_plus_1(0), 1)
check("@partial 2x+1 at x=5 = 11", f_2x_plus_1(5), 11)
check("@partial 3x-5 at x=3 = 4", f_3x_minus_5(3), 4)
check("@partial 3x-5 at x=10 = 25", f_3x_minus_5(10), 25)
println("")

// ── 9. Determinism ──────────────────────────────────────────

println("--- 9. Determinism ---")

let r9a = partial_add(7, 8)
let r9b = partial_add(7, 8)
check("@partial deterministic add", r9a == r9b, true)

let r9c = double(42)
let r9d = double(42)
check("@partial deterministic double", r9c == r9d, true)
println("")

// ── 10. Edge cases ──────────────────────────────────────────

println("--- 10. Edge cases ---")

check("@partial add(0,0) = 0", partial_add(0, 0), 0)
check("@partial mul(0,999) = 0", partial_mul(0, 999), 0)
check("@partial mul(1,42) = 42", partial_mul(1, 42), 42)
check("@partial pow(1, any) = 1", partial_pow(1, 100), 1)
println("")

// ── Summary ─────────────────────────────────────────────────

println("===============================================================")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("===============================================================")

if fail_count == 0 {
    println("")
    println("=== test_partial.hexa: ALL TESTS PASSED ===")
} else {
    println("")
    println("!!! SOME TESTS FAILED !!!")
}
