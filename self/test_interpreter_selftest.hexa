// ═══════════════════════════════════════════════════════════
//  test_p2_7_selftest.hexa — P2-7 Self-Hosting Interpreter Self-Test
//
//  Validates that the self-hosted interpreter (lexer+parser+interpreter)
//  can execute .hexa programs end-to-end:
//    source string -> tokenize() -> parse() -> interpret()
//
//  Categories tested:
//    T01-T04: Arithmetic & expressions
//    T05-T08: Variables (let, let mut, assignment)
//    T09-T14: Functions (basic, recursion, higher-order)
//    T15-T18: Conditionals (if, if-else, nested)
//    T19-T22: Loops (while, for-in, break, continue)
//    T23-T26: Strings & string ops
//    T27-T30: Arrays & array methods
//    T31-T34: Closures & lambdas
//    T35-T38: Structs
//    T39-T42: Match expressions
//    T43-T45: Error handling (try/catch)
//
//  Total: 45 assertions
// ═══════════════════════════════════════════════════════════

use "self/core/law_io"

let _hexa_root = if len(env_var("HEXA_LANG")) > 0 { env_var("HEXA_LANG") } else { "." }
let HEXA = _hexa_root + "/hexa"
let SELF_DIR = _hexa_root + "/self"
let TMP_DIR = "/tmp/hexa_p27_selftest"

exec("mkdir -p " + TMP_DIR)

let mut pass_count = 0
let mut fail_count = 0
let mut test_count = 0

// ── Load self-hosting pipeline sources ──────────────────
let lexer_src = read_file(SELF_DIR + "/lexer.hexa")
let parser_src = read_file(SELF_DIR + "/parser.hexa")
let interp_src = read_file(SELF_DIR + "/interpreter.hexa")
let pipeline_src = lexer_src + "\n" + parser_src + "\n" + interp_src + "\n"

println("═══════════════════════════════════════════════════════")
println("  P2-7 Self-Hosting Interpreter Self-Test")
println("  source -> tokenize() -> parse() -> interpret()")
println("═══════════════════════════════════════════════════════")
println("")

// ── Marker-based output extraction ──────────────────────
let MARKER = "___P27_SELFTEST___"

fn run_test(name, hexa_source, expected) {
    test_count = test_count + 1
    let src_file = TMP_DIR + "/src_" + name + ".hexa"
    safe_write_file(src_file, hexa_source)

    let driver_code = pipeline_src + "\n" + "println(\"" + MARKER + "\")\n" + "let __src = read_file(\"" + src_file + "\")\n" + "let __toks = tokenize(__src)\n" + "let __ast = parse(__toks)\n" + "interpret(__ast)\n" + "println(\"" + MARKER + "\")\n"

    let driver_file = TMP_DIR + "/drv_" + name + ".hexa"
    safe_write_file(driver_file, driver_code)

    let result = exec(HEXA + " " + driver_file + " 2>&1")

    if type_of(result) == "error" {
        println("[FAIL] " + name + ": exec error")
        fail_count = fail_count + 1
        return false
    }

    // Extract output between markers (line-by-line)
    let lines = result.split("\n")
    let mut capture = false
    let mut output_lines = []
    for line in lines {
        if line == MARKER {
            if capture {
                capture = false
            } else {
                capture = true
            }
        } else {
            if capture {
                output_lines.push(line)
            }
        }
    }
    let actual = output_lines.join("\n")

    if actual == expected {
        println("[PASS] " + name)
        pass_count = pass_count + 1
        return true
    } else {
        println("[FAIL] " + name)
        println("  expected: \"" + expected + "\"")
        println("  actual:   \"" + actual + "\"")
        fail_count = fail_count + 1
        return false
    }
}

// ═══════════════════════════════════════════════════════════
//  T01-T04: Arithmetic & Expressions
// ═══════════════════════════════════════════════════════════
println("--- Arithmetic & Expressions ---")

run_test("T01_add", "println(3 + 4)", "7")
run_test("T02_mul_sub", "println(10 * 3 - 5)", "25")
run_test("T03_div_mod", "println(17 / 3)\nprintln(17 % 3)", "5\n2")
run_test("T04_parens", "println((2 + 3) * (4 + 1))", "25")

// ═══════════════════════════════════════════════════════════
//  T05-T08: Variables
// ═══════════════════════════════════════════════════════════
println("--- Variables ---")

run_test("T05_let", "let x = 42\nprintln(x)", "42")
run_test("T06_let_mut", "let mut x = 10\nx = x + 5\nprintln(x)", "15")
run_test("T07_multi_var", "let a = 1\nlet b = 2\nlet c = a + b\nprintln(c)", "3")
run_test("T08_shadow", "let x = 10\nlet x = 20\nprintln(x)", "20")

// ═══════════════════════════════════════════════════════════
//  T09-T14: Functions
// ═══════════════════════════════════════════════════════════
println("--- Functions ---")

run_test("T09_fn_basic", "fn add(a, b) {\n  return a + b\n}\nprintln(add(3, 4))", "7")
run_test("T10_fn_nested_call", "fn double(n) {\n  return n * 2\n}\nfn inc(n) {\n  return n + 1\n}\nprintln(double(inc(5)))", "12")
run_test("T11_fn_recursive", "fn fact(n) {\n  if n <= 1 {\n    return 1\n  }\n  return n * fact(n - 1)\n}\nprintln(fact(6))", "720")
run_test("T12_fn_fib", "fn fib(n) {\n  if n <= 1 {\n    return n\n  }\n  return fib(n - 1) + fib(n - 2)\n}\nprintln(fib(10))", "55")
run_test("T13_fn_multi_return", "fn minmax(a, b) {\n  if a < b {\n    return a\n  }\n  return b\n}\nprintln(minmax(7, 3))", "3")
run_test("T14_fn_no_return", "fn greet(name) {\n  println(\"hello \" + name)\n}\ngreet(\"world\")", "hello world")

// ═══════════════════════════════════════════════════════════
//  T15-T18: Conditionals
// ═══════════════════════════════════════════════════════════
println("--- Conditionals ---")

run_test("T15_if_true", "if true {\n  println(\"yes\")\n}", "yes")
run_test("T16_if_else", "let x = 3\nif x > 5 {\n  println(\"big\")\n} else {\n  println(\"small\")\n}", "small")
run_test("T17_if_elif", "let x = 2\nif x == 1 {\n  println(\"one\")\n} else if x == 2 {\n  println(\"two\")\n} else {\n  println(\"other\")\n}", "two")
run_test("T18_nested_if", "let a = 10\nlet b = 20\nif a > 5 {\n  if b > 15 {\n    println(\"both\")\n  }\n}", "both")

// ═══════════════════════════════════════════════════════════
//  T19-T22: Loops
// ═══════════════════════════════════════════════════════════
println("--- Loops ---")

run_test("T19_while", "let mut i = 0\nlet mut sum = 0\nwhile i < 5 {\n  i = i + 1\n  sum = sum + i\n}\nprintln(sum)", "15")
run_test("T20_for_in_array", "let mut sum = 0\nfor i in [1, 2, 3, 4, 5] {\n  sum = sum + i\n}\nprintln(sum)", "15")
run_test("T21_break", "let mut i = 0\nwhile true {\n  i = i + 1\n  if i == 5 {\n    break\n  }\n}\nprintln(i)", "5")
run_test("T22_continue", "let mut sum = 0\nlet mut i = 0\nwhile i < 10 {\n  i = i + 1\n  if i % 2 == 0 {\n    continue\n  }\n  sum = sum + i\n}\nprintln(sum)", "25")

// ═══════════════════════════════════════════════════════════
//  T23-T26: Strings
// ═══════════════════════════════════════════════════════════
println("--- Strings ---")

run_test("T23_str_concat", "let s = \"hello\" + \" \" + \"world\"\nprintln(s)", "hello world")
run_test("T24_str_len", "println(len(\"abcde\"))", "5")
run_test("T25_str_index", "let s = \"hello world\"\nprintln(len(s))", "11")
run_test("T26_to_string", "println(to_string(42) + \" is the answer\")", "42 is the answer")

// ═══════════════════════════════════════════════════════════
//  T27-T30: Arrays
// ═══════════════════════════════════════════════════════════
println("--- Arrays ---")

run_test("T27_array_basic", "let arr = [1, 2, 3]\nprintln(arr[0])\nprintln(arr[2])", "1\n3")
run_test("T28_array_push", "let mut arr = [10]\narr = arr.push(20)\narr = arr.push(30)\nprintln(len(arr))", "3")
run_test("T29_array_for", "let arr = [10, 20, 30]\nlet mut sum = 0\nfor x in arr {\n  sum = sum + x\n}\nprintln(sum)", "60")
run_test("T30_array_iter", "let arr = [10, 20, 30]\nlet mut total = 0\nlet mut i = 0\nwhile i < len(arr) {\n  total = total + arr[i]\n  i = i + 1\n}\nprintln(total)", "60")

// ═══════════════════════════════════════════════════════════
//  T31-T34: Higher-Order & Scope
// ═══════════════════════════════════════════════════════════
println("--- Higher-Order & Scope ---")

run_test("T31_fn_as_val", "fn double(n) {\n  return n * 2\n}\nfn apply(f, x) {\n  return f(x)\n}\nprintln(apply(double, 21))", "42")
run_test("T32_nested_scope", "let x = 10\nif true {\n  let y = 20\n  println(x + y)\n}", "30")
run_test("T33_fn_chain", "fn add1(n) {\n  return n + 1\n}\nfn mul2(n) {\n  return n * 2\n}\nprintln(mul2(add1(3)))", "8")
run_test("T34_scope_shadow", "let x = 1\nfn foo() {\n  let x = 2\n  return x\n}\nprintln(x)\nprintln(foo())", "1\n2")

// ═══════════════════════════════════════════════════════════
//  T35-T38: Structs
// ═══════════════════════════════════════════════════════════
println("--- Structs ---")

run_test("T35_struct_basic", "struct Point { x: int, y: int }\nlet p = Point { x: 3, y: 4 }\nprintln(p.x)\nprintln(p.y)", "3\n4")
run_test("T36_struct_fn", "struct Rect { w: int, h: int }\nfn area(r) {\n  return r.w * r.h\n}\nlet r = Rect { w: 5, h: 3 }\nprintln(area(r))", "15")
run_test("T37_struct_nested", "struct V { x: int, y: int }\nfn add_v(a, b) {\n  return V { x: a.x + b.x, y: a.y + b.y }\n}\nlet r = add_v(V { x: 1, y: 2 }, V { x: 3, y: 4 })\nprintln(r.x)\nprintln(r.y)", "4\n6")
run_test("T38_struct_array", "struct Item { name: string, val: int }\nlet items = [Item { name: \"a\", val: 1 }, Item { name: \"b\", val: 2 }]\nprintln(items[0].name)\nprintln(items[1].val)", "a\n2")

// ═══════════════════════════════════════════════════════════
//  T39-T42: Match Expressions
// ═══════════════════════════════════════════════════════════
println("--- Match Expressions ---")

run_test("T39_match_int", "let x = 2\nlet r = match x {\n  1 ->\"one\",\n  2 ->\"two\",\n  _ ->\"other\"\n}\nprintln(r)", "two")
run_test("T40_match_str", "let s = \"ko\"\nlet g = match s {\n  \"en\" ->\"hello\",\n  \"ko\" ->\"annyeong\",\n  _ ->\"hi\"\n}\nprintln(g)", "annyeong")
run_test("T41_match_wildcard", "let x = 99\nlet r = match x {\n  1 ->\"one\",\n  _ ->\"many\"\n}\nprintln(r)", "many")
run_test("T42_match_in_fn", "fn classify(n) {\n  return match n {\n    0 ->\"zero\",\n    1 ->\"one\",\n    _ ->\"many\"\n  }\n}\nprintln(classify(0))\nprintln(classify(1))\nprintln(classify(42))", "zero\none\nmany")

// ═══════════════════════════════════════════════════════════
//  T43-T45: Error Handling (try/catch)
// ═══════════════════════════════════════════════════════════
println("--- Error Handling ---")

run_test("T43_try_catch", "let mut msg = \"\"\ntry {\n  throw \"oops\"\n} catch e {\n  msg = \"caught\"\n}\nprintln(msg)", "caught")
run_test("T44_try_no_throw", "let mut x = 0\ntry {\n  x = 42\n} catch e {\n  x = -1\n}\nprintln(x)", "42")
run_test("T45_fn_throw", "fn safe_div(a, b) {\n  if b == 0 {\n    throw \"div by zero\"\n  }\n  return a / b\n}\nlet mut ok = true\ntry {\n  println(safe_div(10, 2))\n  safe_div(10, 0)\n} catch e {\n  ok = false\n}\nprintln(ok)", "5\nfalse")

// ═══════════════════════════════════════════════════════════
//  SUMMARY
// ═══════════════════════════════════════════════════════════
println("")
println("═══════════════════════════════════════════════════════")
println("  P2-7 Self-Test Results: " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL / " + to_string(test_count) + " total")
println("═══════════════════════════════════════════════════════")

if fail_count == 0 {
    println("ALL " + to_string(test_count) + " TESTS PASSED -- P2-7 self-hosting verified!")
} else {
    println("WARNING: " + to_string(fail_count) + " tests failed")
}
