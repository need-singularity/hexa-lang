// self/test_url_pure.hexa -- Tests for self/runtime/url_pure.hexa

let HEX_DIGITS = "0123456789ABCDEF"

fn _is_unreserved(o) {
    if o >= 65 && o <= 90 { return true }
    if o >= 97 && o <= 122 { return true }
    if o >= 48 && o <= 57 { return true }
    if o == 45 { return true }
    if o == 95 { return true }
    if o == 46 { return true }
    if o == 126 { return true }
    false
}

fn _hex_to_int(c) {
    let o = ord(c)
    if o >= 48 && o <= 57  { return o - 48 }
    if o >= 65 && o <= 70  { return o - 65 + 10 }
    if o >= 97 && o <= 102 { return o - 97 + 10 }
    -1
}

fn url_encode_pure(s) {
    if type_of(s) != "string" { return "" }
    let n = len(s)
    let mut out = ""
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        let o = ord(c)
        if _is_unreserved(o) {
            out = out + c
        } else {
            let hi = HEX_DIGITS.substring(o / 16, o / 16 + 1)
            let lo = HEX_DIGITS.substring(o % 16, o % 16 + 1)
            out = out + "%" + hi + lo
        }
        i = i + 1
    }
    out
}

fn url_decode_pure(s) {
    if type_of(s) != "string" { return "" }
    let n = len(s)
    let mut out = ""
    let mut i = 0
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "+" {
            out = out + " "
            i = i + 1
        } else if c == "%" && i + 2 < n {
            let hi = _hex_to_int(s.substring(i + 1, i + 2))
            let lo = _hex_to_int(s.substring(i + 2, i + 3))
            if hi >= 0 && lo >= 0 {
                out = out + from_char_code(hi * 16 + lo)
                i = i + 3
            } else {
                out = out + c
                i = i + 1
            }
        } else if c == "%" && i + 2 >= n {
            out = out + s.substring(i, n)
            i = n
        } else {
            out = out + c
            i = i + 1
        }
    }
    out
}

// ── harness ────────────────────────────────────────────────────────

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  url_pure.hexa — test runner")
println("═══════════════════════════════════════════════════════")

// ── encode ──────────────────────────────────────────────────
println("")
println("--- url_encode_pure ---")
check("empty", url_encode_pure(""), "")
check("alpha only", url_encode_pure("abcXYZ"), "abcXYZ")
check("digits", url_encode_pure("0123"), "0123")
check("unreserved", url_encode_pure("a-_.~z"), "a-_.~z")
check("space", url_encode_pure("a b"), "a%20b")
check("slash", url_encode_pure("/path"), "%2Fpath")
check("ampersand", url_encode_pure("k=v&q=w"), "k%3Dv%26q%3Dw")
check("query style", url_encode_pure("hello world!"), "hello%20world%21")
check("unicode bytes", url_encode_pure("é"), "%C3%A9")
check("non-string", url_encode_pure(42), "")

// ── decode ──────────────────────────────────────────────────
println("")
println("--- url_decode_pure ---")
check("empty", url_decode_pure(""), "")
check("plain ascii", url_decode_pure("abcXYZ"), "abcXYZ")
check("%20 is space", url_decode_pure("a%20b"), "a b")
check("+ is space", url_decode_pure("a+b"), "a b")
check("mixed encoding", url_decode_pure("hello%20world%21"), "hello world!")
check("%2F slash", url_decode_pure("%2Fpath"), "/path")
check("lowercase hex", url_decode_pure("a%2fb"), "a/b")
// Unicode roundtrip NOTE: stage0 from_char_code treats its arg as a
// Unicode codepoint and re-emits as UTF-8 (so from_char_code(0xC3)
// yields "Ã" = 2 bytes "C3 83", not a raw 0xC3 byte). This means
// high-byte percent sequences cannot roundtrip into the original
// raw bytes in pure hexa today. The encode side is fine (uses real
// byte values via ord). The decode side needs either a raw-byte
// builtin or string concat from a precomputed byte table — deferred
// until the native runtime exposes a byte-oriented emit primitive.
// ASCII decode below is correct.
let decoded_ascii = url_decode_pure("%68%69")  // "hi"
check("ascii %XX decode", decoded_ascii, "hi")
check("partial bad", url_decode_pure("a%"), "a%")
check("invalid hex verbatim", url_decode_pure("a%ZZ"), "a%ZZ")
check("non-string", url_decode_pure(42), "")

// ── roundtrip ───────────────────────────────────────────────
println("")
println("--- roundtrip ---")
check("hello world rt", url_decode_pure(url_encode_pure("hello world!")), "hello world!")
check("query rt", url_decode_pure(url_encode_pure("k=v&q=w/x")), "k=v&q=w/x")

// ── Summary ─────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    println("FAIL")
    exit(1)
}
println("ALL PASS")
