// -- inlined from self/runtime/range_pure.hexa --
// codegen import not wired for test files

// ═══════════════════════════════════════════════════════════════════
//  self/runtime/range_pure.hexa — range/enumeration helpers (pure)
//
//  Replaces C `__hexa_range_array` and related helpers. All functions
//  are pure; the caller provides `start`, `end`, `step` and receives
//  a plain array they can iterate over with `for x in arr`.
//
//  Public API:
//      range_pure(start, end)                 // [start, end)
//      range_step_pure(start, end, step)      // [start, end) with step
//      range_inclusive_pure(start, end)       // [start, end]
//      count_pure(n)                          // [0, n)
//      reversed_range_pure(start, end)        // [end-1, start]
//      enumerate_pure(arr)                    // [(0,a0), (1,a1), ...]
//      zip_pure(a, b)                         // [(a0,b0), ...]
//      repeat_pure(val, n)                    // [val, val, ...] × n
//      steps_pure(start, count, step)         // arithmetic progression
//      linspace_int_pure(start, end, n)       // n points between start..end
// ═══════════════════════════════════════════════════════════════════

@pure
pub fn range_pure(start, end) {
    let mut out = []
    let mut i = start
    while i < end {
        out = out.push(i)
        i = i + 1
    }
    return out
}

@pure
pub fn range_step_pure(start, end, step) {
    let mut out = []
    if step == 0 { return out }
    let mut i = start
    if step > 0 {
        while i < end {
            out = out.push(i)
            i = i + step
        }
    } else {
        while i > end {
            out = out.push(i)
            i = i + step
        }
    }
    return out
}

@pure
pub fn range_inclusive_pure(start, end) {
    let mut out = []
    let mut i = start
    while i <= end {
        out = out.push(i)
        i = i + 1
    }
    return out
}

@pure
pub fn count_pure(n) {
    return range_pure(0, n)
}

@pure
pub fn reversed_range_pure(start, end) {
    let mut out = []
    let mut i = end - 1
    while i >= start {
        out = out.push(i)
        i = i - 1
    }
    return out
}

@pure
pub fn enumerate_pure(arr) {
    let mut out = []
    let n = len(arr)
    let mut i = 0
    while i < n {
        out = out.push([i, arr[i]])
        i = i + 1
    }
    return out
}

@pure
pub fn zip_pure(a, b) {
    let mut out = []
    let na = len(a)
    let nb = len(b)
    let n = if na < nb { na } else { nb }
    let mut i = 0
    while i < n {
        out = out.push([a[i], b[i]])
        i = i + 1
    }
    return out
}

@pure
pub fn repeat_pure(val, n) {
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(val)
        i = i + 1
    }
    return out
}

@pure
pub fn steps_pure(start, count, step) {
    let mut out = []
    let mut i = 0
    let mut v = start
    while i < count {
        out = out.push(v)
        v = v + step
        i = i + 1
    }
    return out
}

@pure
pub fn linspace_int_pure(start, end, n) {
    let mut out = []
    if n <= 0 { return out }
    if n == 1 {
        out = out.push(start)
        return out
    }
    let span = end - start
    let mut i = 0
    while i < n {
        let num = span * i
        let den = n - 1
        let off = num / den
        out = out.push(start + off)
        i = i + 1
    }
    return out
}


// -- end inlined --

let mut pass = 0
let mut fail = 0

fn check(name, cond) {
    if cond { pass = pass + 1 } else {
        fail = fail + 1
        println("[FAIL] " + name)
    }
}

fn eq_arr(name, a, b) {
    let na = len(a)
    let nb = len(b)
    if na != nb {
        fail = fail + 1
        println("[FAIL] " + name + " len mismatch " + to_string(na) + " vs " + to_string(nb))
        return
    }
    let mut i = 0
    while i < na {
        if a[i] != b[i] {
            fail = fail + 1
            println("[FAIL] " + name + " differs at " + to_string(i))
            return
        }
        i = i + 1
    }
    pass = pass + 1
}

fn eq(name, a, b) {
    if a == b { pass = pass + 1 } else {
        fail = fail + 1
        println("[FAIL] " + name + " got " + to_string(a) + " want " + to_string(b))
    }
}

println("=== range_pure test suite ===")

// ---- range_pure ----
eq_arr("range(0,5)", range_pure(0, 5), [0, 1, 2, 3, 4])
eq_arr("range(2,6)", range_pure(2, 6), [2, 3, 4, 5])
eq_arr("range(0,0) empty", range_pure(0, 0), [])
eq_arr("range(3,2) empty", range_pure(3, 2), [])
eq_arr("range(-2,2)", range_pure(-2, 2), [-2, -1, 0, 1])

// ---- range_step_pure ----
eq_arr("range_step(0,10,2)", range_step_pure(0, 10, 2), [0, 2, 4, 6, 8])
eq_arr("range_step(10,0,-2)", range_step_pure(10, 0, -2), [10, 8, 6, 4, 2])
eq_arr("range_step(0,5,0) empty", range_step_pure(0, 5, 0), [])
eq_arr("range_step(0,10,3)", range_step_pure(0, 10, 3), [0, 3, 6, 9])

// ---- range_inclusive_pure ----
eq_arr("range_incl(0,5)", range_inclusive_pure(0, 5), [0, 1, 2, 3, 4, 5])
eq_arr("range_incl(3,3)", range_inclusive_pure(3, 3), [3])
eq_arr("range_incl(5,3) empty", range_inclusive_pure(5, 3), [])

// ---- count_pure ----
eq_arr("count(0) empty", count_pure(0), [])
eq_arr("count(5)", count_pure(5), [0, 1, 2, 3, 4])
eq_arr("count(-1) empty", count_pure(-1), [])

// ---- reversed_range_pure ----
eq_arr("reversed(0,5)", reversed_range_pure(0, 5), [4, 3, 2, 1, 0])
eq_arr("reversed(2,4)", reversed_range_pure(2, 4), [3, 2])
eq_arr("reversed(3,3) empty", reversed_range_pure(3, 3), [])

// ---- enumerate_pure ----
let en = enumerate_pure(["a", "b", "c"])
eq("enumerate len", len(en), 3)
eq("enumerate[0][0]", en[0][0], 0)
eq("enumerate[0][1]", en[0][1], "a")
eq("enumerate[2][0]", en[2][0], 2)
eq("enumerate[2][1]", en[2][1], "c")
eq("enumerate [] empty", len(enumerate_pure([])), 0)

// ---- zip_pure ----
let z = zip_pure([1, 2, 3], ["a", "b", "c"])
eq("zip len", len(z), 3)
eq("zip[1][0]", z[1][0], 2)
eq("zip[1][1]", z[1][1], "b")
eq("zip shorter a", len(zip_pure([1, 2], [10, 20, 30])), 2)
eq("zip shorter b", len(zip_pure([1, 2, 3], [10, 20])), 2)
eq("zip empty", len(zip_pure([], [1])), 0)

// ---- repeat_pure ----
eq_arr("repeat 7 times 3", repeat_pure(7, 3), [7, 7, 7])
eq_arr("repeat 0 times", repeat_pure(9, 0), [])
eq_arr("repeat string", repeat_pure("x", 4), ["x", "x", "x", "x"])

// ---- steps_pure ----
eq_arr("steps(10, 5, 2)", steps_pure(10, 5, 2), [10, 12, 14, 16, 18])
eq_arr("steps(0, 4, -1)", steps_pure(0, 4, -1), [0, -1, -2, -3])
eq_arr("steps(5, 0, 1) empty", steps_pure(5, 0, 1), [])

// ---- linspace_int_pure ----
eq_arr("linspace(0, 10, 5)", linspace_int_pure(0, 10, 5), [0, 2, 5, 7, 10])
eq_arr("linspace single", linspace_int_pure(7, 20, 1), [7])
eq_arr("linspace empty", linspace_int_pure(0, 10, 0), [])
eq_arr("linspace endpoints", linspace_int_pure(0, 100, 2), [0, 100])

println("===========================================================")
println("  Results: " + to_string(pass) + " passed, " + to_string(fail) + " failed")
println("===========================================================")
if fail == 0 { println("ALL PASS") } else { println("SOME FAIL") }
