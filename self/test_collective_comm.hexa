// ===================================================================
//  test_collective_comm.hexa — Unit tests for Collective Comm Ops (#239)
//
//  Verifies AllReduce (naive + ring), AllGather (flat + ring),
//  ReduceScatter, ring topology helpers, chunking, and bandwidth
//  metrics. Broadcast is exercised via naive allreduce fan-out since
//  that is how the module exposes "broadcast to all ranks" semantics.
//
//  Run: PATH=$HOME/.cargo/bin:$PATH ./hexa self/test_collective_comm.hexa
//
//  ML roadmap #239 — Collective Comm Ops
// ===================================================================

// -- inlined from self/ml/collective_comm.hexa --
// codegen import not wired for test files

// ===================================================================
//  collective_comm.hexa — Collective Communication Ops
//
//  Pure .hexa CPU simulation of AllReduce, AllGather, ReduceScatter
//  with ring-based topology and bandwidth-optimal chunking.
//
//  Each "rank" is an index 0..num_workers-1 into arrays of local
//  tensors. Communication is simulated by reading/writing these
//  arrays — no NCCL, no network, no CUDA.
//
//  Primitives:
//    - AllReduce: ring-based sum/avg across workers
//    - AllGather: gather tensors from all workers into one full tensor
//    - ReduceScatter: reduce then scatter result shards
//    - Ring topology helpers: next/prev rank in circular order
//    - Bandwidth-optimal chunking: pipeline segments for large tensors
//
//  ML roadmap #239 — Collective Comm Ops
// ===================================================================

// ── Array helpers ────────────────────────────────────────────

fn cc_zeros(n) {
    let mut out = []
    let mut i = 0
    while i < n {
        out.push(0.0)
        i = i + 1
    }
    out
}

fn cc_copy(src) {
    let n = len(src)
    let mut out = []
    let mut i = 0
    while i < n {
        out.push(src[i])
        i = i + 1
    }
    out
}

fn cc_slice(src, begin, end) {
    let mut out = []
    let mut i = begin
    while i < end {
        out.push(src[i])
        i = i + 1
    }
    out
}

// ── Ring topology ────────────────────────────────────────────

fn cc_ring_next(rank, num_workers) {
    (rank + 1) % num_workers
}

fn cc_ring_prev(rank, num_workers) {
    (rank - 1 + num_workers) % num_workers
}

// Build ring order as an array [0, 1, 2, ..., num_workers-1]
fn cc_ring_order(num_workers) {
    let mut order = []
    let mut i = 0
    while i < num_workers {
        order.push(i)
        i = i + 1
    }
    order
}

// Verify ring connectivity: each rank's next wraps correctly
fn cc_verify_ring(num_workers) {
    let mut ok = true
    let mut r = 0
    while r < num_workers {
        let nxt = cc_ring_next(r, num_workers)
        let prv = cc_ring_prev(nxt, num_workers)
        if prv != r {
            ok = false
        }
        r = r + 1
    }
    ok
}

// ── Chunk helpers for bandwidth-optimal pipelining ──────────

// Split a flat tensor of length n into num_chunks roughly equal parts.
// Returns array of [begin, end] pairs.
fn cc_compute_chunks(n, num_chunks) {
    let mut chunks = []
    let mut c = 0
    while c < num_chunks {
        let begin = (n * c) / num_chunks
        let end = (n * (c + 1)) / num_chunks
        chunks.push([begin, end])
        c = c + 1
    }
    chunks
}

// Extract chunk c from flat tensor
fn cc_get_chunk(tensor, chunks, c) {
    let pair = chunks[c]
    let begin = pair[0]
    let end = pair[1]
    cc_slice(tensor, begin, end)
}

// Write chunk data back into tensor at chunk c position
fn cc_set_chunk(tensor, chunks, c, data) {
    let pair = chunks[c]
    let begin = pair[0]
    let end = pair[1]
    let mut out = cc_copy(tensor)
    let mut i = 0
    while i < end - begin {
        out[begin + i] = data[i]
        i = i + 1
    }
    out
}

// ═══════════════════════════════════════════════════════════════
//  AllReduce — ring-based sum
//
//  Algorithm (Baidu ring allreduce):
//    Phase 1 — Reduce-scatter: N-1 steps. Each step, rank r sends
//      chunk (r - step) to rank (r+1), which adds it to its local copy.
//      After N-1 steps each rank holds the fully reduced chunk for one
//      chunk index.
//    Phase 2 — AllGather: N-1 steps. Each step, rank r sends its
//      complete chunk to rank (r+1). After N-1 steps every rank has
//      all reduced chunks.
//
//  We simulate all workers in a single process using an array of
//  per-rank tensor copies.
// ═══════════════════════════════════════════════════════════════

fn cc_allreduce_ring_sum(tensors, num_workers) {
    let n = len(tensors[0])
    let num_chunks = num_workers
    let chunks = cc_compute_chunks(n, num_chunks)

    // Copy per-rank tensors into mutable buffers
    let mut bufs = []
    let mut r = 0
    while r < num_workers {
        bufs.push(cc_copy(tensors[r]))
        r = r + 1
    }

    // Phase 1: reduce-scatter
    let mut step = 0
    while step < num_workers - 1 {
        // Each rank sends a chunk to its ring neighbor
        let mut new_bufs = []
        let mut rr = 0
        while rr < num_workers {
            new_bufs.push(cc_copy(bufs[rr]))
            rr = rr + 1
        }

        rr = 0
        while rr < num_workers {
            let send_chunk_idx = ((rr - step) % num_chunks + num_chunks) % num_chunks
            let recv_rank = cc_ring_next(rr, num_workers)
            let send_data = cc_get_chunk(bufs[rr], chunks, send_chunk_idx)
            let recv_data = cc_get_chunk(new_bufs[recv_rank], chunks, send_chunk_idx)
            let chunk_pair = chunks[send_chunk_idx]
            let chunk_len = chunk_pair[1] - chunk_pair[0]
            let mut summed = []
            let mut i = 0
            while i < chunk_len {
                summed.push(recv_data[i] + send_data[i])
                i = i + 1
            }
            new_bufs[recv_rank] = cc_set_chunk(new_bufs[recv_rank], chunks, send_chunk_idx, summed)
            rr = rr + 1
        }

        bufs = new_bufs
        step = step + 1
    }

    // Phase 2: allgather
    step = 0
    while step < num_workers - 1 {
        let mut new_bufs = []
        let mut rr = 0
        while rr < num_workers {
            new_bufs.push(cc_copy(bufs[rr]))
            rr = rr + 1
        }

        rr = 0
        while rr < num_workers {
            let send_chunk_idx = ((rr - step + 1) % num_chunks + num_chunks) % num_chunks
            let recv_rank = cc_ring_next(rr, num_workers)
            let send_data = cc_get_chunk(bufs[rr], chunks, send_chunk_idx)
            new_bufs[recv_rank] = cc_set_chunk(new_bufs[recv_rank], chunks, send_chunk_idx, send_data)
            rr = rr + 1
        }

        bufs = new_bufs
        step = step + 1
    }

    bufs
}

// AllReduce with averaging (divide by num_workers after sum)
fn cc_allreduce_ring_avg(tensors, num_workers) {
    let summed = cc_allreduce_ring_sum(tensors, num_workers)
    let n = len(summed[0])
    let div = to_float(num_workers)
    let mut result = []
    let mut r = 0
    while r < num_workers {
        let mut avg = []
        let mut i = 0
        while i < n {
            avg.push(summed[r][i] / div)
            i = i + 1
        }
        result.push(avg)
        r = r + 1
    }
    result
}

// Simple (non-ring) allreduce for reference/correctness comparison
fn cc_allreduce_naive_sum(tensors, num_workers) {
    let n = len(tensors[0])
    let mut summed = cc_zeros(n)
    let mut r = 0
    while r < num_workers {
        let mut i = 0
        while i < n {
            summed[i] = summed[i] + tensors[r][i]
            i = i + 1
        }
        r = r + 1
    }
    // Broadcast to all ranks
    let mut result = []
    r = 0
    while r < num_workers {
        result.push(cc_copy(summed))
        r = r + 1
    }
    result
}

// ═══════════════════════════════════════════════════════════════
//  AllGather — gather per-rank shards into full tensor
//
//  Each rank holds a local shard. After allgather, every rank
//  holds the concatenation of all shards in rank order.
// ═══════════════════════════════════════════════════════════════

fn cc_allgather(shards, num_workers) {
    // Build full tensor by concatenation
    let mut full = []
    let mut r = 0
    while r < num_workers {
        let shard = shards[r]
        let sn = len(shard)
        let mut i = 0
        while i < sn {
            full.push(shard[i])
            i = i + 1
        }
        r = r + 1
    }
    // Broadcast full tensor to all ranks
    let mut result = []
    r = 0
    while r < num_workers {
        result.push(cc_copy(full))
        r = r + 1
    }
    result
}

// Ring-based allgather: simulate ring passing of shards
fn cc_allgather_ring(shards, num_workers) {
    let shard_len = len(shards[0])
    let full_len = shard_len * num_workers

    // Initialize per-rank buffers with their own shard in position
    let mut bufs = []
    let mut r = 0
    while r < num_workers {
        let mut buf = cc_zeros(full_len)
        let offset = r * shard_len
        let mut i = 0
        while i < shard_len {
            buf[offset + i] = shards[r][i]
            i = i + 1
        }
        bufs.push(buf)
        r = r + 1
    }

    // N-1 ring steps: each step, rank r sends a segment to rank r+1
    let mut step = 0
    while step < num_workers - 1 {
        let mut new_bufs = []
        let mut rr = 0
        while rr < num_workers {
            new_bufs.push(cc_copy(bufs[rr]))
            rr = rr + 1
        }

        rr = 0
        while rr < num_workers {
            // Rank rr sends segment (rr - step) mod N to next
            let seg_idx = ((rr - step) % num_workers + num_workers) % num_workers
            let seg_offset = seg_idx * shard_len
            let recv_rank = cc_ring_next(rr, num_workers)
            let mut i = 0
            while i < shard_len {
                new_bufs[recv_rank][seg_offset + i] = bufs[rr][seg_offset + i]
                i = i + 1
            }
            rr = rr + 1
        }

        bufs = new_bufs
        step = step + 1
    }

    bufs
}

// ═══════════════════════════════════════════════════════════════
//  ReduceScatter — reduce then scatter
//
//  Each rank starts with a full tensor. After reduce-scatter,
//  rank r holds only its shard of the element-wise sum.
// ═══════════════════════════════════════════════════════════════

fn cc_reducescatter(tensors, num_workers) {
    let n = len(tensors[0])
    let shard_size = n / num_workers

    // Element-wise sum all tensors
    let mut summed = cc_zeros(n)
    let mut r = 0
    while r < num_workers {
        let mut i = 0
        while i < n {
            summed[i] = summed[i] + tensors[r][i]
            i = i + 1
        }
        r = r + 1
    }

    // Scatter: rank r gets shard [r*shard_size .. (r+1)*shard_size)
    let mut result = []
    r = 0
    while r < num_workers {
        let begin = r * shard_size
        let end = begin + shard_size
        result.push(cc_slice(summed, begin, end))
        r = r + 1
    }
    result
}

// Ring-based reduce-scatter
// Uses the reduce-scatter phase of the ring allreduce algorithm.
// After N-1 ring steps, rank r holds the fully reduced chunk r.
fn cc_reducescatter_ring(tensors, num_workers) {
    let n = len(tensors[0])
    let num_chunks = num_workers
    let chunks = cc_compute_chunks(n, num_chunks)

    // Copy per-rank tensors
    let mut bufs = []
    let mut r = 0
    while r < num_workers {
        bufs.push(cc_copy(tensors[r]))
        r = r + 1
    }

    // N-1 ring reduce steps. In step s, rank rr sends chunk
    // ((rr+1) - s - 1) mod N  to rank (rr+1) mod N, which accumulates it.
    // After all steps, rank r owns the fully reduced chunk r.
    let mut step = 0
    while step < num_workers - 1 {
        let mut new_bufs = []
        let mut rr = 0
        while rr < num_workers {
            new_bufs.push(cc_copy(bufs[rr]))
            rr = rr + 1
        }

        rr = 0
        while rr < num_workers {
            let recv_rank = (rr + 1) % num_workers
            // The chunk that recv_rank will own at the end is recv_rank.
            // In step s, we accumulate chunk (recv_rank - s) mod N on recv_rank.
            let send_chunk_idx = ((recv_rank - step) % num_chunks + num_chunks) % num_chunks
            let chunk_pair = chunks[send_chunk_idx]
            let cbegin = chunk_pair[0]
            let cend = chunk_pair[1]
            let chunk_len = cend - cbegin
            let mut i = 0
            while i < chunk_len {
                new_bufs[recv_rank][cbegin + i] = new_bufs[recv_rank][cbegin + i] + bufs[rr][cbegin + i]
                i = i + 1
            }
            rr = rr + 1
        }

        bufs = new_bufs
        step = step + 1
    }

    // Each rank keeps only its own chunk
    let mut result = []
    r = 0
    while r < num_workers {
        let chunk_pair = chunks[r]
        result.push(cc_slice(bufs[r], chunk_pair[0], chunk_pair[1]))
        r = r + 1
    }
    result
}

// ── Bandwidth metrics ────────────────────────────────────────

// Compute the total data volume moved in a ring allreduce
// Formula: 2 * (N-1)/N * tensor_size (for sum: scatter + gather)
fn cc_ring_bandwidth_volume(tensor_size, num_workers) {
    let n = to_float(num_workers)
    2.0 * (n - 1.0) / n * to_float(tensor_size)
}

// Number of ring steps for allreduce
fn cc_ring_total_steps(num_workers) {
    2 * (num_workers - 1)
}

println("[collective_comm] module loaded — AllReduce/AllGather/ReduceScatter ready")


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn cc_test_fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn cc_test_approx(a, b, eps) { return cc_test_fabs(a - b) < eps }

fn check(idx, name, cond) {
    if cond {
        println("[PASS] #" + str(idx) + " " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] #" + str(idx) + " " + name)
        fail_count = fail_count + 1
    }
}

fn cc_arrays_near(a, b, tol) {
    if len(a) != len(b) { return false }
    let n = len(a)
    let mut i = 0
    while i < n {
        if !cc_test_approx(a[i], b[i], tol) { return false }
        i = i + 1
    }
    true
}

fn cc_array_sum(a) {
    let n = len(a)
    let mut s = 0.0
    let mut i = 0
    while i < n {
        s = s + a[i]
        i = i + 1
    }
    s
}

println("=== Collective Comm Ops (#239) Tests ===")

// ── Fixtures ────────────────────────────────────────────────────
let N_WORKERS = 4
let TENSOR_LEN = 8

// Per-rank tensors: rank r has values [r, r+1, ..., r+TENSOR_LEN-1] as float.
let mut worker_tensors = []
let mut r = 0
while r < N_WORKERS {
    let mut t = []
    let mut i = 0
    while i < TENSOR_LEN {
        t.push(to_float(r + i))
        i = i + 1
    }
    worker_tensors.push(t)
    r = r + 1
}

// Expected element-wise sum across ranks:
// sum[i] = sum_{r=0..N-1}(r + i) = (N*(N-1)/2) + N*i
let mut expected_sum = []
let mut i_init = 0
while i_init < TENSOR_LEN {
    let s = to_float(N_WORKERS * (N_WORKERS - 1) / 2 + N_WORKERS * i_init)
    expected_sum.push(s)
    i_init = i_init + 1
}

// ═══════════════════════════════════════════════════════════════
//  #1-#4 — Ring topology helpers
// ═══════════════════════════════════════════════════════════════

check(1, "cc_ring_next(0,4)=1", cc_ring_next(0, 4) == 1)
check(2, "cc_ring_next(3,4)=0 wraps", cc_ring_next(3, 4) == 0)
check(3, "cc_ring_prev(0,4)=3 wraps", cc_ring_prev(0, 4) == 3)
check(4, "cc_verify_ring(5)", cc_verify_ring(5))

let ring_order_4 = cc_ring_order(4)
check(5, "cc_ring_order(4) length=4 and ordered",
    len(ring_order_4) == 4
    && ring_order_4[0] == 0 && ring_order_4[1] == 1
    && ring_order_4[2] == 2 && ring_order_4[3] == 3)

// ═══════════════════════════════════════════════════════════════
//  #6-#8 — Chunking
// ═══════════════════════════════════════════════════════════════

let chunks = cc_compute_chunks(8, 4)
check(6, "compute_chunks count=4", len(chunks) == 4)

let c0 = chunks[0]
let c3 = chunks[3]
check(7, "chunk[0]=[0,2] chunk[3]=[6,8]",
    c0[0] == 0 && c0[1] == 2 && c3[0] == 6 && c3[1] == 8)

let sample = [10.0, 20.0, 30.0, 40.0, 50.0, 60.0, 70.0, 80.0]
let chunk_slice = cc_get_chunk(sample, chunks, 1)
check(8, "get_chunk(1) returns [30.0,40.0]",
    len(chunk_slice) == 2
    && cc_test_approx(chunk_slice[0], 30.0, 1.0e-9)
    && cc_test_approx(chunk_slice[1], 40.0, 1.0e-9))

// cc_set_chunk returns a new tensor with chunk overwritten
let replaced = cc_set_chunk(sample, chunks, 1, [3.0, 4.0])
check(9, "set_chunk writes chunk slice, preserves rest",
    cc_test_approx(replaced[0], 10.0, 1.0e-9)
    && cc_test_approx(replaced[2], 3.0, 1.0e-9)
    && cc_test_approx(replaced[3], 4.0, 1.0e-9)
    && cc_test_approx(replaced[4], 50.0, 1.0e-9))

// ═══════════════════════════════════════════════════════════════
//  #10-#13 — Naive AllReduce sum / avg & broadcast semantics
// ═══════════════════════════════════════════════════════════════

let naive_sum_all = cc_allreduce_naive_sum(worker_tensors, N_WORKERS)
check(10, "naive allreduce sum — one result per rank",
    len(naive_sum_all) == N_WORKERS)

check(11, "naive allreduce rank0 matches expected sum",
    cc_arrays_near(naive_sum_all[0], expected_sum, 1.0e-6))

// All ranks hold identical broadcast result
let mut bcast_ok = true
let mut rr = 1
while rr < N_WORKERS {
    if !cc_arrays_near(naive_sum_all[rr], naive_sum_all[0], 1.0e-9) {
        bcast_ok = false
    }
    rr = rr + 1
}
check(12, "naive allreduce broadcast identical across ranks", bcast_ok)

let naive_avg = cc_allreduce_ring_avg(worker_tensors, N_WORKERS)
let div = to_float(N_WORKERS)
let mut expected_avg = []
let mut i_avg = 0
while i_avg < TENSOR_LEN {
    expected_avg.push(expected_sum[i_avg] / div)
    i_avg = i_avg + 1
}
check(13, "ring allreduce avg rank0 = sum/N",
    cc_arrays_near(naive_avg[0], expected_avg, 1.0e-6))

// ═══════════════════════════════════════════════════════════════
//  #14-#17 — Ring AllReduce matches naive reference
// ═══════════════════════════════════════════════════════════════

let ring_sum = cc_allreduce_ring_sum(worker_tensors, N_WORKERS)
check(14, "ring allreduce rank0 matches naive",
    cc_arrays_near(ring_sum[0], naive_sum_all[0], 1.0e-5))

check(15, "ring allreduce rank1 matches naive",
    cc_arrays_near(ring_sum[1], naive_sum_all[1], 1.0e-5))

check(16, "ring allreduce rank2 matches naive",
    cc_arrays_near(ring_sum[2], naive_sum_all[2], 1.0e-5))

check(17, "ring allreduce rank3 matches naive",
    cc_arrays_near(ring_sum[3], naive_sum_all[3], 1.0e-5))

// ═══════════════════════════════════════════════════════════════
//  #18-#20 — AllGather (flat concatenation)
// ═══════════════════════════════════════════════════════════════

let shard_len = 3
let mut shards = []
let mut sh_r = 0
while sh_r < N_WORKERS {
    let mut s = []
    let mut j = 0
    while j < shard_len {
        s.push(to_float(sh_r * 100 + j))
        j = j + 1
    }
    shards.push(s)
    sh_r = sh_r + 1
}

let gathered = cc_allgather(shards, N_WORKERS)
check(18, "allgather rank count",
    len(gathered) == N_WORKERS
    && len(gathered[0]) == N_WORKERS * shard_len)

// Slot checks — gathered[0] should hold concatenation in rank order
check(19, "allgather rank0 concat layout",
    cc_test_approx(gathered[0][0], 0.0, 1.0e-9)
    && cc_test_approx(gathered[0][3], 100.0, 1.0e-9)
    && cc_test_approx(gathered[0][6], 200.0, 1.0e-9)
    && cc_test_approx(gathered[0][9], 300.0, 1.0e-9))

let mut gather_consistent = true
let mut gr = 1
while gr < N_WORKERS {
    if !cc_arrays_near(gathered[gr], gathered[0], 1.0e-9) {
        gather_consistent = false
    }
    gr = gr + 1
}
check(20, "allgather consistent across ranks", gather_consistent)

// ═══════════════════════════════════════════════════════════════
//  #21-#22 — Ring AllGather vs flat AllGather
// ═══════════════════════════════════════════════════════════════

let gathered_ring = cc_allgather_ring(shards, N_WORKERS)
check(21, "allgather_ring matches flat allgather rank0",
    cc_arrays_near(gathered_ring[0], gathered[0], 1.0e-9))

check(22, "allgather_ring rank3 matches flat allgather rank3",
    cc_arrays_near(gathered_ring[3], gathered[3], 1.0e-9))

// ═══════════════════════════════════════════════════════════════
//  #23-#25 — ReduceScatter
// ═══════════════════════════════════════════════════════════════

let rs = cc_reducescatter(worker_tensors, N_WORKERS)
let rs_shard_size = TENSOR_LEN / N_WORKERS
check(23, "reducescatter shard count and length",
    len(rs) == N_WORKERS && len(rs[0]) == rs_shard_size)

// Shard r should hold expected_sum[r*shard_size .. (r+1)*shard_size)
let mut rs_ok = true
let mut rr_rs = 0
while rr_rs < N_WORKERS {
    let begin = rr_rs * rs_shard_size
    let mut k = 0
    while k < rs_shard_size {
        if !cc_test_approx(rs[rr_rs][k], expected_sum[begin + k], 1.0e-6) {
            rs_ok = false
        }
        k = k + 1
    }
    rr_rs = rr_rs + 1
}
check(24, "reducescatter values match expected sum shards", rs_ok)

// Concatenating shards must reconstruct the full allreduce sum
let mut concat = []
let mut cr = 0
while cr < N_WORKERS {
    let mut ci = 0
    while ci < rs_shard_size {
        concat.push(rs[cr][ci])
        ci = ci + 1
    }
    cr = cr + 1
}
check(25, "reducescatter concat == full allreduce sum",
    cc_arrays_near(concat, expected_sum, 1.0e-6))

// ═══════════════════════════════════════════════════════════════
//  #26-#27 — Bandwidth metrics
// ═══════════════════════════════════════════════════════════════

// Ring bandwidth volume formula: 2*(N-1)/N * size
let bw = cc_ring_bandwidth_volume(100, 4)
check(26, "ring bandwidth volume 4 workers, size 100 -> 150",
    cc_test_approx(bw, 150.0, 1.0e-6))

check(27, "ring total steps 4 workers = 6",
    cc_ring_total_steps(4) == 6)

// ═══════════════════════════════════════════════════════════════
//  #28-#29 — 3-worker ring allreduce (odd N)
// ═══════════════════════════════════════════════════════════════

let mut wt3 = []
let mut r3 = 0
while r3 < 3 {
    let mut t = []
    let mut i = 0
    while i < 6 {
        t.push(to_float(r3 * 10 + i))
        i = i + 1
    }
    wt3.push(t)
    r3 = r3 + 1
}
let ring3 = cc_allreduce_ring_sum(wt3, 3)
let naive3 = cc_allreduce_naive_sum(wt3, 3)
check(28, "3-worker ring allreduce rank0 matches naive",
    cc_arrays_near(ring3[0], naive3[0], 1.0e-5))

check(29, "3-worker ring allreduce all ranks consistent",
    cc_arrays_near(ring3[1], naive3[1], 1.0e-5)
    && cc_arrays_near(ring3[2], naive3[2], 1.0e-5))

// ═══════════════════════════════════════════════════════════════
//  #30 — Identity: allreduce(zeros) == zeros (broadcast)
// ═══════════════════════════════════════════════════════════════

let mut zero_tensors = []
let mut zr = 0
while zr < N_WORKERS {
    zero_tensors.push(cc_zeros(TENSOR_LEN))
    zr = zr + 1
}
let zero_reduced = cc_allreduce_ring_sum(zero_tensors, N_WORKERS)
check(30, "allreduce zeros -> zeros",
    cc_test_approx(cc_array_sum(zero_reduced[0]), 0.0, 1.0e-9))

// ── summary ─────────────────────────────────────────────────────
println("")
println("=== Collective Comm test summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
