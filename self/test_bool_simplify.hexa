// ═══════════════════════════════════════════════════════════════
//  test_bool_simplify.hexa — ROI #58 Boolean Expression Simplification
//  Tests anp_simplify_bool() and anp_bool_simplify_pass()
//  Self-contained: no imports needed
// ═══════════════════════════════════════════════════════════════

// ── AstNode struct ──────────────────────────────────────────────
struct AstNode {
    kind: string,
    name: string,
    value: string,
    op: string,
    left: string,
    right: string,
    cond: string,
    then_body: string,
    else_body: string,
    params: string,
    body: string,
    args: string,
    fields: string,
    items: string,
    variants: string,
    arms: string,
    iter_expr: string,
    ret_type: string,
    target: string,
    trait_name: string,
    methods: string
}

// ── Boolean helpers ─────────────────────────────────────────────
fn is_bool_true(e) {
    if type_of(e) == "string" { return false }
    if e.kind != "BoolLit" { return false }
    return e.value == "true"
}

fn is_bool_false(e) {
    if type_of(e) == "string" { return false }
    if e.kind != "BoolLit" { return false }
    return e.value == "false"
}

fn make_bool_lit(v) {
    return AstNode {
        kind: "BoolLit", name: "", value: v, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_bool_lit_from_bool(b) {
    let mut v = "false"
    if b { v = "true" }
    return AstNode {
        kind: "BoolLit", name: "", value: v, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn same_ident(a, b) {
    if type_of(a) == "string" { return false }
    if type_of(b) == "string" { return false }
    if a.kind != "Ident" { return false }
    if b.kind != "Ident" { return false }
    return a.name == b.name
}

fn is_not_of(not_expr, ident_expr) {
    if type_of(not_expr) == "string" { return false }
    if type_of(ident_expr) == "string" { return false }
    if not_expr.kind != "UnaryOp" { return false }
    if not_expr.op != "!" { return false }
    return same_ident(not_expr.left, ident_expr)
}

fn rewrite_fn_with_body(fn_node, new_body) {
    return AstNode {
        kind: "FnDecl", name: fn_node.name, value: fn_node.value, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: fn_node.params, body: new_body, args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: fn_node.ret_type,
        target: "", trait_name: "", methods: ""
    }
}

// ── M978 counter ────────────────────────────────────────────────
let mut m978_bool_simpl = 0

// ── anp_simplify_bool ───────────────────────────────────────────
fn anp_simplify_bool(expr) {
    if type_of(expr) == "string" { return expr }
    // ── UnaryOp: logical NOT ──
    if expr.kind == "UnaryOp" && expr.op == "!" {
        let inner = anp_simplify_bool(expr.left)
        // !true -> false
        if is_bool_true(inner) {
            m978_bool_simpl = m978_bool_simpl + 1
            return make_bool_lit("false")
        }
        // !false -> true
        if is_bool_false(inner) {
            m978_bool_simpl = m978_bool_simpl + 1
            return make_bool_lit("true")
        }
        // !!x -> x
        if type_of(inner) != "string" && inner.kind == "UnaryOp" && inner.op == "!" {
            m978_bool_simpl = m978_bool_simpl + 1
            return anp_simplify_bool(inner.left)
        }
        // !(a == b) -> a != b
        if type_of(inner) != "string" && inner.kind == "BinOp" && inner.op == "==" {
            m978_bool_simpl = m978_bool_simpl + 1
            return AstNode {
                kind: "BinOp", name: "", value: "", op: "!=",
                left: inner.left, right: inner.right, cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            }
        }
        // !(a != b) -> a == b
        if type_of(inner) != "string" && inner.kind == "BinOp" && inner.op == "!=" {
            m978_bool_simpl = m978_bool_simpl + 1
            return AstNode {
                kind: "BinOp", name: "", value: "", op: "==",
                left: inner.left, right: inner.right, cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            }
        }
        return AstNode {
            kind: "UnaryOp", name: "", value: "", op: "!",
            left: inner, right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    // ── BinOp: &&, ||, ==, != with booleans ──
    if expr.kind == "BinOp" {
        let l = anp_simplify_bool(expr.left)
        let r = anp_simplify_bool(expr.right)
        let op = expr.op
        // a && true -> a, true && a -> a
        if op == "&&" {
            if is_bool_true(r) {
                m978_bool_simpl = m978_bool_simpl + 1
                return l
            }
            if is_bool_true(l) {
                m978_bool_simpl = m978_bool_simpl + 1
                return r
            }
            if is_bool_false(l) {
                m978_bool_simpl = m978_bool_simpl + 1
                return make_bool_lit("false")
            }
            if is_bool_false(r) {
                m978_bool_simpl = m978_bool_simpl + 1
                return make_bool_lit("false")
            }
            if same_ident(l, r) {
                m978_bool_simpl = m978_bool_simpl + 1
                return l
            }
            if is_not_of(l, r) || is_not_of(r, l) {
                m978_bool_simpl = m978_bool_simpl + 1
                return make_bool_lit("false")
            }
        }
        if op == "||" {
            if is_bool_true(l) {
                m978_bool_simpl = m978_bool_simpl + 1
                return make_bool_lit("true")
            }
            if is_bool_true(r) {
                m978_bool_simpl = m978_bool_simpl + 1
                return make_bool_lit("true")
            }
            if is_bool_false(l) {
                m978_bool_simpl = m978_bool_simpl + 1
                return r
            }
            if is_bool_false(r) {
                m978_bool_simpl = m978_bool_simpl + 1
                return l
            }
            if same_ident(l, r) {
                m978_bool_simpl = m978_bool_simpl + 1
                return l
            }
            if is_not_of(l, r) || is_not_of(r, l) {
                m978_bool_simpl = m978_bool_simpl + 1
                return make_bool_lit("true")
            }
        }
        if op == "==" {
            // const-fold both-BoolLit first
            if type_of(l) != "string" && type_of(r) != "string" {
                if l.kind == "BoolLit" && r.kind == "BoolLit" {
                    m978_bool_simpl = m978_bool_simpl + 1
                    return make_bool_lit_from_bool(l.value == r.value)
                }
            }
            if is_bool_true(r) {
                m978_bool_simpl = m978_bool_simpl + 1
                return l
            }
            if is_bool_true(l) {
                m978_bool_simpl = m978_bool_simpl + 1
                return r
            }
            if is_bool_false(r) {
                m978_bool_simpl = m978_bool_simpl + 1
                return AstNode {
                    kind: "UnaryOp", name: "", value: "", op: "!",
                    left: l, right: "", cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            }
            if is_bool_false(l) {
                m978_bool_simpl = m978_bool_simpl + 1
                return AstNode {
                    kind: "UnaryOp", name: "", value: "", op: "!",
                    left: r, right: "", cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            }
        }
        if op == "!=" {
            // const-fold both-BoolLit first
            if type_of(l) != "string" && type_of(r) != "string" {
                if l.kind == "BoolLit" && r.kind == "BoolLit" {
                    m978_bool_simpl = m978_bool_simpl + 1
                    return make_bool_lit_from_bool(l.value != r.value)
                }
            }
            if is_bool_true(r) {
                m978_bool_simpl = m978_bool_simpl + 1
                return AstNode {
                    kind: "UnaryOp", name: "", value: "", op: "!",
                    left: l, right: "", cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            }
            if is_bool_true(l) {
                m978_bool_simpl = m978_bool_simpl + 1
                return AstNode {
                    kind: "UnaryOp", name: "", value: "", op: "!",
                    left: r, right: "", cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            }
            if is_bool_false(r) {
                m978_bool_simpl = m978_bool_simpl + 1
                return l
            }
            if is_bool_false(l) {
                m978_bool_simpl = m978_bool_simpl + 1
                return r
            }
        }
        return AstNode {
            kind: "BinOp", name: "", value: "", op: op,
            left: l, right: r, cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    return expr
}

// ── anp_bool_simplify_body ──────────────────────────────────────
fn anp_bool_simplify_body(body) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ReturnStmt" || k == "ExprStmt" || k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" {
            let new_e = anp_simplify_bool(stmt.left)
            out = out.push(AstNode {
                kind: k, name: stmt.name, value: stmt.value, op: "",
                left: new_e, right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            })
        } else {
            if k == "AssignStmt" {
                let new_r = anp_simplify_bool(stmt.right)
                out = out.push(AstNode {
                    kind: "AssignStmt", name: "", value: "", op: "",
                    left: stmt.left, right: new_r, cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                })
            } else {
                if k == "WhileStmt" {
                    let new_cond = anp_simplify_bool(stmt.cond)
                    let new_body = anp_bool_simplify_body(stmt.body)
                    out = out.push(AstNode {
                        kind: "WhileStmt", name: "", value: "", op: "",
                        left: "", right: "", cond: new_cond, then_body: "", else_body: "",
                        params: "", body: new_body, args: "", fields: "", items: "",
                        variants: "", arms: "", iter_expr: "", ret_type: "",
                        target: "", trait_name: "", methods: ""
                    })
                } else {
                    if k == "IfStmt" {
                        let new_cond = anp_simplify_bool(stmt.cond)
                        let new_then = anp_bool_simplify_body(stmt.then_body)
                        let new_else = anp_bool_simplify_body(stmt.else_body)
                        out = out.push(AstNode {
                            kind: "IfStmt", name: "", value: "", op: "",
                            left: "", right: "", cond: new_cond, then_body: new_then, else_body: new_else,
                            params: "", body: "", args: "", fields: "", items: "",
                            variants: "", arms: "", iter_expr: "", ret_type: "",
                            target: "", trait_name: "", methods: ""
                        })
                    } else {
                        out = out.push(stmt)
                    }
                }
            }
        }
        i = i + 1
    }
    return out
}

// ── anp_bool_simplify_pass ──────────────────────────────────────
fn anp_bool_simplify_pass(ast) {
    if type_of(ast) != "array" { return ast }
    m978_bool_simpl = 0
    let mut out = []
    let n = len(ast)
    let mut i = 0
    while i < n {
        let node = ast[i]
        if type_of(node) != "string" && node.kind == "FnDecl" {
            if type_of(node.body) == "array" {
                let new_body = anp_bool_simplify_body(node.body)
                out = out.push(rewrite_fn_with_body(node, new_body))
            } else {
                out = out.push(node)
            }
        } else {
            out = out.push(node)
        }
        i = i + 1
    }
    if m978_bool_simpl > 0 {
        println("[ai-native] bool-simplify: " + to_string(m978_bool_simpl) + " boolean expression(s) simplified")
    }
    return out
}

// ── Test harness ────────────────────────────────────────────────
let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

// ── AST node constructors (local helpers) ────────────────────
fn mk_bool(v) {
    return AstNode {
        kind: "BoolLit", name: "", value: v, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn mk_ident(n) {
    return AstNode {
        kind: "Ident", name: n, value: "", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn mk_not(e) {
    return AstNode {
        kind: "UnaryOp", name: "", value: "", op: "!",
        left: e, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn mk_binop(op, l, r) {
    return AstNode {
        kind: "BinOp", name: "", value: "", op: op,
        left: l, right: r, cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn mk_int(v) {
    return AstNode {
        kind: "IntLit", name: "", value: to_string(v), op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

println("=== ROI #58: Boolean Expression Simplification ===")
println("")

// ── T1: !true → false ─────────────────────────────────────────
let t1 = anp_simplify_bool(mk_not(mk_bool("true")))
check("T1 !true -> false", t1.kind == "BoolLit" && t1.value == "false")

// ── T2: !false → true ────────────────────────────────────────
let t2 = anp_simplify_bool(mk_not(mk_bool("false")))
check("T2 !false -> true", t2.kind == "BoolLit" && t2.value == "true")

// ── T3: !!x → x ──────────────────────────────────────────────
let t3 = anp_simplify_bool(mk_not(mk_not(mk_ident("x"))))
check("T3 !!x -> x (kind)", t3.kind == "Ident")
check("T3 !!x -> x (name)", t3.name == "x")

// ── T4: !!!x → !x ────────────────────────────────────────────
let t4 = anp_simplify_bool(mk_not(mk_not(mk_not(mk_ident("y")))))
check("T4 !!!y -> !y (kind)", t4.kind == "UnaryOp" && t4.op == "!")
check("T4 !!!y -> !y (inner)", t4.left.kind == "Ident" && t4.left.name == "y")

// ── T5: a && true → a ────────────────────────────────────────
let t5 = anp_simplify_bool(mk_binop("&&", mk_ident("a"), mk_bool("true")))
check("T5 a && true -> a", t5.kind == "Ident" && t5.name == "a")

// ── T6: true && a → a ────────────────────────────────────────
let t6 = anp_simplify_bool(mk_binop("&&", mk_bool("true"), mk_ident("a")))
check("T6 true && a -> a", t6.kind == "Ident" && t6.name == "a")

// ── T7: a && false → false ───────────────────────────────────
let t7 = anp_simplify_bool(mk_binop("&&", mk_ident("a"), mk_bool("false")))
check("T7 a && false -> false", t7.kind == "BoolLit" && t7.value == "false")

// ── T8: false && a → false ───────────────────────────────────
let t8 = anp_simplify_bool(mk_binop("&&", mk_bool("false"), mk_ident("a")))
check("T8 false && a -> false", t8.kind == "BoolLit" && t8.value == "false")

// ── T9: a || true → true ─────────────────────────────────────
let t9 = anp_simplify_bool(mk_binop("||", mk_ident("a"), mk_bool("true")))
check("T9 a || true -> true", t9.kind == "BoolLit" && t9.value == "true")

// ── T10: true || a → true ────────────────────────────────────
let t10 = anp_simplify_bool(mk_binop("||", mk_bool("true"), mk_ident("a")))
check("T10 true || a -> true", t10.kind == "BoolLit" && t10.value == "true")

// ── T11: a || false → a ──────────────────────────────────────
let t11 = anp_simplify_bool(mk_binop("||", mk_ident("a"), mk_bool("false")))
check("T11 a || false -> a", t11.kind == "Ident" && t11.name == "a")

// ── T12: false || a → a ──────────────────────────────────────
let t12 = anp_simplify_bool(mk_binop("||", mk_bool("false"), mk_ident("a")))
check("T12 false || a -> a", t12.kind == "Ident" && t12.name == "a")

// ── T13: a == true → a ───────────────────────────────────────
let t13 = anp_simplify_bool(mk_binop("==", mk_ident("a"), mk_bool("true")))
check("T13 a == true -> a", t13.kind == "Ident" && t13.name == "a")

// ── T14: true == a → a ───────────────────────────────────────
let t14 = anp_simplify_bool(mk_binop("==", mk_bool("true"), mk_ident("a")))
check("T14 true == a -> a", t14.kind == "Ident" && t14.name == "a")

// ── T15: a == false → !a ─────────────────────────────────────
let t15 = anp_simplify_bool(mk_binop("==", mk_ident("a"), mk_bool("false")))
check("T15 a == false -> !a (kind)", t15.kind == "UnaryOp" && t15.op == "!")
check("T15 a == false -> !a (inner)", t15.left.kind == "Ident" && t15.left.name == "a")

// ── T16: false == a → !a ─────────────────────────────────────
let t16 = anp_simplify_bool(mk_binop("==", mk_bool("false"), mk_ident("a")))
check("T16 false == a -> !a (kind)", t16.kind == "UnaryOp" && t16.op == "!")
check("T16 false == a -> !a (inner)", t16.left.kind == "Ident" && t16.left.name == "a")

// ── T17: a != true → !a ──────────────────────────────────────
let t17 = anp_simplify_bool(mk_binop("!=", mk_ident("a"), mk_bool("true")))
check("T17 a != true -> !a (kind)", t17.kind == "UnaryOp" && t17.op == "!")
check("T17 a != true -> !a (inner)", t17.left.kind == "Ident" && t17.left.name == "a")

// ── T18: a != false → a ──────────────────────────────────────
let t18 = anp_simplify_bool(mk_binop("!=", mk_ident("a"), mk_bool("false")))
check("T18 a != false -> a", t18.kind == "Ident" && t18.name == "a")

// ── T19: x && x → x (idempotent) ─────────────────────────────
let t19 = anp_simplify_bool(mk_binop("&&", mk_ident("x"), mk_ident("x")))
check("T19 x && x -> x", t19.kind == "Ident" && t19.name == "x")

// ── T20: x || x → x (idempotent) ─────────────────────────────
let t20 = anp_simplify_bool(mk_binop("||", mk_ident("x"), mk_ident("x")))
check("T20 x || x -> x", t20.kind == "Ident" && t20.name == "x")

// ── T21: x && !x → false (contradiction) ─────────────────────
let t21 = anp_simplify_bool(mk_binop("&&", mk_ident("x"), mk_not(mk_ident("x"))))
check("T21 x && !x -> false", t21.kind == "BoolLit" && t21.value == "false")

// ── T22: !x && x → false (contradiction symmetric) ───────────
let t22 = anp_simplify_bool(mk_binop("&&", mk_not(mk_ident("x")), mk_ident("x")))
check("T22 !x && x -> false", t22.kind == "BoolLit" && t22.value == "false")

// ── T23: x || !x → true (tautology) ──────────────────────────
let t23 = anp_simplify_bool(mk_binop("||", mk_ident("x"), mk_not(mk_ident("x"))))
check("T23 x || !x -> true", t23.kind == "BoolLit" && t23.value == "true")

// ── T24: !x || x → true (tautology symmetric) ────────────────
let t24 = anp_simplify_bool(mk_binop("||", mk_not(mk_ident("x")), mk_ident("x")))
check("T24 !x || x -> true", t24.kind == "BoolLit" && t24.value == "true")

// ── T25: !(a == b) → a != b (De Morgan eq) ───────────────────
let t25 = anp_simplify_bool(mk_not(mk_binop("==", mk_ident("a"), mk_ident("b"))))
check("T25 !(a==b) -> a!=b (kind)", t25.kind == "BinOp" && t25.op == "!=")
check("T25 !(a==b) -> a!=b (left)", t25.left.kind == "Ident" && t25.left.name == "a")
check("T25 !(a==b) -> a!=b (right)", t25.right.kind == "Ident" && t25.right.name == "b")

// ── T26: !(a != b) → a == b (De Morgan ne) ───────────────────
let t26 = anp_simplify_bool(mk_not(mk_binop("!=", mk_ident("a"), mk_ident("b"))))
check("T26 !(a!=b) -> a==b (kind)", t26.kind == "BinOp" && t26.op == "==")

// ── T27: true == true → true (const fold) ────────────────────
let t27 = anp_simplify_bool(mk_binop("==", mk_bool("true"), mk_bool("true")))
check("T27 true==true -> true", t27.kind == "BoolLit" && t27.value == "true")

// ── T28: true == false → false (const fold) ──────────────────
let t28 = anp_simplify_bool(mk_binop("==", mk_bool("true"), mk_bool("false")))
check("T28 true==false -> false", t28.kind == "BoolLit" && t28.value == "false")

// ── T29: true != false → true (const fold) ───────────────────
let t29 = anp_simplify_bool(mk_binop("!=", mk_bool("true"), mk_bool("false")))
check("T29 true!=false -> true", t29.kind == "BoolLit" && t29.value == "true")

// ── T30: false != false → false (const fold) ─────────────────
let t30 = anp_simplify_bool(mk_binop("!=", mk_bool("false"), mk_bool("false")))
check("T30 false!=false -> false", t30.kind == "BoolLit" && t30.value == "false")

// ── T31: passthrough — non-bool BinOp (a + b) unchanged ──────
let t31 = anp_simplify_bool(mk_binop("+", mk_ident("a"), mk_ident("b")))
check("T31 a+b unchanged", t31.kind == "BinOp" && t31.op == "+")

// ── T32: passthrough — plain Ident unchanged ──────────────────
let t32 = anp_simplify_bool(mk_ident("z"))
check("T32 ident unchanged", t32.kind == "Ident" && t32.name == "z")

// ── T33: passthrough — string type returns as-is ──────────────
let t33 = anp_simplify_bool("")
check("T33 string passthrough", t33 == "")

// ── T34: nested: !(a && true) → simplify inner then negate ───
// a && true → a, then !a
let t34 = anp_simplify_bool(mk_not(mk_binop("&&", mk_ident("a"), mk_bool("true"))))
check("T34 !(a && true) -> !a", t34.kind == "UnaryOp" && t34.op == "!")
check("T34 !(a && true) -> !a inner", t34.left.kind == "Ident" && t34.left.name == "a")

// ── T35: counter increments ───────────────────────────────────
m978_bool_simpl = 0
let _t35 = anp_simplify_bool(mk_not(mk_bool("true")))
check("T35 counter incremented", m978_bool_simpl > 0)

// ── T36: false == b → !b ─────────────────────────────────────
let t36 = anp_simplify_bool(mk_binop("==", mk_bool("false"), mk_ident("b")))
check("T36 false==b -> !b", t36.kind == "UnaryOp" && t36.op == "!" && t36.left.name == "b")

// ── T37: true != b → !b ──────────────────────────────────────
let t37 = anp_simplify_bool(mk_binop("!=", mk_bool("true"), mk_ident("b")))
check("T37 true!=b -> !b", t37.kind == "UnaryOp" && t37.op == "!" && t37.left.name == "b")

// ── T38: false != b → b ──────────────────────────────────────
let t38 = anp_simplify_bool(mk_binop("!=", mk_bool("false"), mk_ident("b")))
check("T38 false!=b -> b", t38.kind == "Ident" && t38.name == "b")

// ── T39: anp_bool_simplify_pass on empty AST ─────────────────
let t39 = anp_bool_simplify_pass([])
check("T39 empty AST pass", len(t39) == 0)

// ── T40: anp_bool_simplify_pass on non-array ─────────────────
let t40 = anp_bool_simplify_pass("not_array")
check("T40 non-array passthrough", t40 == "not_array")

// ── Summary ────────────────────────────────────────────────────
println("")
println("=== SUMMARY ===")
println("PASS: " + to_string(pass_count))
println("FAIL: " + to_string(fail_count))
println("TOTAL: " + to_string(pass_count + fail_count))

if fail_count > 0 {
    println("RESULT: SOME TESTS FAILED")
} else {
    println("RESULT: ALL " + to_string(pass_count) + " TESTS PASSED")
}
