// ═══════════════════════════════════════════════════════════════════
//  test_memoize_grad.hexa — @memoize_grad prototype tests
// ═══════════════════════════════════════════════════════════════════

// -- inlined from self/ml/memoize_grad.hexa --
// codegen import not wired for test files

// ═══════════════════════════════════════════════════════════════════
//  self/ml/memoize_grad.hexa — @memoize_grad prototype (pure .hexa)
//
//  AI-native training optimization: cache gradients for repeated
//  minibatches. Forward/backward results keyed by a cheap XOR hash of
//  the input tensor's first N elements → FIFO ring of size K.
//
//  API (pure, no hidden state — caller owns the cache):
//    hash_minibatch(x)                    -> int
//    memo_grad_lookup(cache, key)         -> [found, grad_flat, shape]
//    memo_grad_store(cache, cap, k, g, s) -> updated cache (FIFO drop)
//    grad_mse(pred, target)               -> [float]
//    @memoize_grad compute_grad(cache, cap, x, tgt, stats)
//        -> [new_cache, grad_flat, new_stats]
//        stats = [calls, hits, miss]
//
//  NOTE: .hexa imported modules can't mutate their own file-scope
//  `let mut` globals when called from an importer — so this module is
//  strictly pure. Callers keep [cache, stats] and thread them.
//
//  Status: @memoize_grad attr is parser-accepted (probe passed) but has
//  no runtime hook yet; compute_grad() performs the cache logic
//  explicitly below. Pending: attr→runtime wiring.
// ═══════════════════════════════════════════════════════════════════

// ── XOR-based minibatch hash ────────────────────────────────────
fn hash_minibatch(x_tensor) {
    let n = len(x_tensor)
    let limit = if n < 16 { n } else { 16 }
    let mut h = 2654435761
    let mut i = 0
    while i < limit {
        let v = x_tensor[i]
        let scaled = to_int(v * 1000000.0)
        h = h ^ (scaled + i * 2147483)
        i = i + 1
    }
    h
}

// ── FIFO ring lookup ────────────────────────────────────────────
// Returns [found:bool, grad_flat:[float], shape:[int]]
fn memo_grad_lookup(cache, key) {
    let n = len(cache)
    let mut i = 0
    while i < n {
        let entry = cache[i]
        if entry[0] == key {
            return [true, entry[1], entry[2]]
        }
        i = i + 1
    }
    [false, [], []]
}

// ── FIFO ring store (drops oldest at head when full) ───────────
fn memo_grad_store(cache, cap, key, grad_flat, shape) {
    let entry = [key, grad_flat, shape]
    let n = len(cache)
    let mut out = []
    let start = if n >= cap { 1 } else { 0 }
    let mut i = start
    while i < n {
        out.push(cache[i])
        i = i + 1
    }
    out.push(entry)
    out
}

// ── Naive MSE gradient: 2*(pred-target)/n ───────────────────────
fn grad_mse(pred, target) {
    let n = len(pred)
    let mut out = []
    let mut i = 0
    let inv = 2.0 / (n * 1.0)
    while i < n {
        let d = pred[i] - target[i]
        out.push(d * inv)
        i = i + 1
    }
    out
}

// ── @memoize_grad compute_grad (pure, threaded state) ──────────
// stats = [calls, hits, miss]
// returns [new_cache, grad, new_stats]
@memoize_grad
fn compute_grad(cache, cap, x, target, stats) {
    let calls = stats[0] + 1
    let key = hash_minibatch(x)
    let probe = memo_grad_lookup(cache, key)
    if probe[0] {
        let hits = stats[1] + 1
        return [cache, probe[1], [calls, hits, stats[2]]]
    }
    let miss = stats[2] + 1
    let grad = grad_mse(x, target)
    let shape = [len(grad)]
    let new_cache = memo_grad_store(cache, cap, key, grad, shape)
    [new_cache, grad, [calls, stats[1], miss]]
}


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  @memoize_grad prototype tests")
println("═══════════════════════════════════════════════════════")

// ── Fixtures ────────────────────────────────────────────────────
let mb_a = [1.0, 2.0, 3.0, 4.0]
let mb_b = [0.5, 1.5, 2.5, 3.5]
let mb_c = [9.0, 8.0, 7.0, 6.0]
let tgt = [1.0, 1.0, 1.0, 1.0]

// ── 1. Hash stability & distinctness ────────────────────────────
let h1 = hash_minibatch(mb_a)
let h1b = hash_minibatch(mb_a)
let h2 = hash_minibatch(mb_b)
check("hash stable same input", h1, h1b)
let distinct = h1 != h2
check("hash distinct different input", distinct, true)

// ── 2. grad_mse manual check ────────────────────────────────────
// pred=mb_a, target=tgt, n=4, inv=0.5
// diffs: 0.0, 1.0, 2.0, 3.0  → grad: 0.0, 0.5, 1.0, 1.5
let manual = grad_mse(mb_a, tgt)
check("grad_mse[0]", manual[0], 0.0)
check("grad_mse[1]", manual[1], 0.5)
check("grad_mse[2]", manual[2], 1.0)
check("grad_mse[3]", manual[3], 1.5)

// ── 3. Threaded cache state ─────────────────────────────────────
let mut g_cache = []
let cap = 4
let mut g_stats = [0, 0, 0]  // calls, hits, miss

// First call: mb_a → miss
let r1 = compute_grad(g_cache, cap, mb_a, tgt, g_stats)
g_cache = r1[0]
let grad1 = r1[1]
g_stats = r1[2]
check("miss after 1st", g_stats[2], 1)
check("hits after 1st", g_stats[1], 0)
check("memoized grad matches manual [1]", grad1[1], 0.5)

// Same minibatch: mb_a → hit
let r2 = compute_grad(g_cache, cap, mb_a, tgt, g_stats)
g_cache = r2[0]
let grad2 = r2[1]
g_stats = r2[2]
check("miss frozen on repeat", g_stats[2], 1)
check("hits incremented", g_stats[1], 1)
check("cached grad equals fresh [3]", grad2[3], 1.5)

// Different minibatch: mb_c → new miss
let r3 = compute_grad(g_cache, cap, mb_c, tgt, g_stats)
g_cache = r3[0]
g_stats = r3[2]
check("miss after new mb", g_stats[2], 2)
check("hits unchanged on new mb", g_stats[1], 1)

// Repeat mb_c → hit
let r4 = compute_grad(g_cache, cap, mb_c, tgt, g_stats)
g_cache = r4[0]
g_stats = r4[2]
check("hits after repeat mb_c", g_stats[1], 2)
check("miss stable", g_stats[2], 2)

// Cache bounded by cap
let cs = len(g_cache)
let bounded = cs <= cap
check("cache bounded by cap", bounded, true)

// Calls total = 4
check("total calls", g_stats[0], 4)

// ── Summary ─────────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  Result: " + to_string(pass_count) + " PASS, " + to_string(fail_count) + " FAIL")
println("  Calls: " + to_string(g_stats[0]) + " | Hits: " + to_string(g_stats[1]) + " | Miss: " + to_string(g_stats[2]))
println("═══════════════════════════════════════════════════════")
