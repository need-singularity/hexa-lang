// ===================================================================

// -- inlined from self/runtime/union_find_pure.hexa --
// codegen import not wired for test files

// ═══════════════════════════════════════════════════════════════════
//  self/runtime/union_find_pure.hexa — disjoint-set (union-find)
//
//  Pure Hexa implementation. No C, no FFI.
//  Uses dict with "parent" and "rank" arrays.
//  Union by rank + path compression for near-O(alpha(n)) amortized.
//
//  Pitfalls honored: P1 no semicolons, P15 let mut, P29 push rebind,
//  while loops only
//
//  Public API:
//      uf_new_pure(n)                — create UF for n elements {0..n-1}
//      uf_find_pure(uf, x)           — find root with path compression
//      uf_union_pure(uf, x, y)       — union by rank, returns true if merged
//      uf_connected_pure(uf, x, y)   — are x and y in the same set?
//      uf_count_pure(uf)             — number of distinct sets
// ═══════════════════════════════════════════════════════════════════

// ── uf_new_pure — create union-find for n elements ──────────────
// Returns dict with keys "parent", "rank", "n"
// Each element is its own parent, rank 0.
@pure
pub fn uf_new_pure(n) {
    let mut parent = []
    let mut rank = []
    let mut i = 0
    while i < n {
        parent.push(i)
        rank.push(0)
        i = i + 1
    }
    let mut uf = #{}
    uf["parent"] = parent
    uf["rank"] = rank
    uf["n"] = n
    return uf
}

// ── uf_find_pure — find root with path compression ─────────────
// Iterative path compression: walk to root, then flatten.
@pure
pub fn uf_find_pure(uf, x) {
    let parent = uf["parent"]
    // Walk to root
    let mut r = x
    while parent[r] != r {
        r = parent[r]
    }
    // Path compression: set all nodes on path to point to root
    let mut c = x
    while c != r {
        let next = parent[c]
        parent[c] = r
        c = next
    }
    return r
}

// ── uf_union_pure — union by rank, returns true if merged ───────
@pure
pub fn uf_union_pure(uf, x, y) {
    let rx = uf_find_pure(uf, x)
    let ry = uf_find_pure(uf, y)
    if rx == ry {
        return false
    }
    let parent = uf["parent"]
    let rank = uf["rank"]
    if rank[rx] < rank[ry] {
        parent[rx] = ry
    } else {
        if rank[rx] > rank[ry] {
            parent[ry] = rx
        } else {
            parent[ry] = rx
            rank[rx] = rank[rx] + 1
        }
    }
    return true
}

// ── uf_connected_pure — are x and y in the same set? ────────────
@pure
pub fn uf_connected_pure(uf, x, y) {
    return uf_find_pure(uf, x) == uf_find_pure(uf, y)
}

// ── uf_count_pure — number of distinct sets ─────────────────────
@pure
pub fn uf_count_pure(uf) {
    let parent = uf["parent"]
    let n = uf["n"]
    let mut count = 0
    let mut i = 0
    while i < n {
        if uf_find_pure(uf, i) == i {
            count = count + 1
        }
        i = i + 1
    }
    return count
}


// -- end inlined --

let mut pass = 0
let mut fail = 0

fn check(name, cond) {
    if cond {
        pass = pass + 1
    } else {
        fail = fail + 1
        println("[FAIL] " + name)
    }
}

fn eq(name, actual, expected) {
    if actual == expected {
        pass = pass + 1
    } else {
        fail = fail + 1
        println("[FAIL] " + name + " expected=" + to_string(expected) + " got=" + to_string(actual))
    }
}

println("=== union_find_pure test suite ===")

// ── 1. uf_new_pure basic ────────────────────────────────────────
let uf1 = uf_new_pure(5)
eq("new n", uf1["n"], 5)
eq("new parent len", len(uf1["parent"]), 5)
eq("new rank len", len(uf1["rank"]), 5)
eq("new count", uf_count_pure(uf1), 5)

// ── 2. each element is its own root ─────────────────────────────
eq("find 0", uf_find_pure(uf1, 0), 0)
eq("find 1", uf_find_pure(uf1, 1), 1)
eq("find 4", uf_find_pure(uf1, 4), 4)

// ── 3. not connected initially ──────────────────────────────────
check("not connected 0-1", uf_connected_pure(uf1, 0, 1) == false)
check("not connected 2-3", uf_connected_pure(uf1, 2, 3) == false)

// ── 4. union merges sets ────────────────────────────────────────
let merged01 = uf_union_pure(uf1, 0, 1)
check("union 0-1 returns true", merged01 == true)
check("connected 0-1", uf_connected_pure(uf1, 0, 1))
eq("count after 1 union", uf_count_pure(uf1), 4)

// ── 5. duplicate union returns false ────────────────────────────
let dup = uf_union_pure(uf1, 0, 1)
check("dup union returns false", dup == false)
eq("count unchanged", uf_count_pure(uf1), 4)

// ── 6. self-union is no-op ──────────────────────────────────────
let self_u = uf_union_pure(uf1, 0, 0)
check("self union returns false", self_u == false)
eq("count after self union", uf_count_pure(uf1), 4)

// ── 7. chain of unions ──────────────────────────────────────────
let merged23 = uf_union_pure(uf1, 2, 3)
check("union 2-3 returns true", merged23 == true)
eq("count after 2 unions", uf_count_pure(uf1), 3)

let merged12 = uf_union_pure(uf1, 1, 2)
check("union 1-2 returns true", merged12 == true)
eq("count after 3 unions", uf_count_pure(uf1), 2)

// ── 8. transitivity ─────────────────────────────────────────────
check("transitive 0-3", uf_connected_pure(uf1, 0, 3))
check("transitive 0-2", uf_connected_pure(uf1, 0, 2))
check("transitive 1-3", uf_connected_pure(uf1, 1, 3))

// ── 9. element 4 still isolated ─────────────────────────────────
check("4 isolated from 0", uf_connected_pure(uf1, 0, 4) == false)
eq("count still 2", uf_count_pure(uf1), 2)

// ── 10. merge last element ──────────────────────────────────────
let merged04 = uf_union_pure(uf1, 0, 4)
check("union 0-4 returns true", merged04 == true)
eq("count all merged", uf_count_pure(uf1), 1)
check("all connected 2-4", uf_connected_pure(uf1, 2, 4))

// ── 11. larger graph: 10 nodes, known components ────────────────
let uf2 = uf_new_pure(10)
eq("big new count", uf_count_pure(uf2), 10)

// Component A: {0, 1, 2}
uf_union_pure(uf2, 0, 1)
uf_union_pure(uf2, 1, 2)

// Component B: {3, 4, 5, 6}
uf_union_pure(uf2, 3, 4)
uf_union_pure(uf2, 5, 6)
uf_union_pure(uf2, 4, 5)

// Component C: {7, 8}
uf_union_pure(uf2, 7, 8)

// 9 remains alone
eq("big count 4 components", uf_count_pure(uf2), 4)

// ── 12. cross-component checks ──────────────────────────────────
check("big A connected 0-2", uf_connected_pure(uf2, 0, 2))
check("big B connected 3-6", uf_connected_pure(uf2, 3, 6))
check("big C connected 7-8", uf_connected_pure(uf2, 7, 8))
check("big A-B not connected", uf_connected_pure(uf2, 0, 3) == false)
check("big B-C not connected", uf_connected_pure(uf2, 3, 7) == false)
check("big 9 isolated", uf_connected_pure(uf2, 0, 9) == false)

// ── 13. root consistency within component ───────────────────────
let root_a = uf_find_pure(uf2, 0)
eq("root consistency A1", uf_find_pure(uf2, 1), root_a)
eq("root consistency A2", uf_find_pure(uf2, 2), root_a)

let root_b = uf_find_pure(uf2, 3)
eq("root consistency B1", uf_find_pure(uf2, 4), root_b)
eq("root consistency B2", uf_find_pure(uf2, 5), root_b)
eq("root consistency B3", uf_find_pure(uf2, 6), root_b)

// ── 14. single element UF ───────────────────────────────────────
let uf0 = uf_new_pure(1)
eq("single count", uf_count_pure(uf0), 1)
eq("single find", uf_find_pure(uf0, 0), 0)
check("single self-connected", uf_connected_pure(uf0, 0, 0))

// ── 15. empty UF ────────────────────────────────────────────────
let ufe = uf_new_pure(0)
eq("empty count", uf_count_pure(ufe), 0)

// ── 16. large chain: 50 elements linked linearly ────────────────
let uf3 = uf_new_pure(50)
let mut k = 0
while k < 49 {
    uf_union_pure(uf3, k, k + 1)
    k = k + 1
}
eq("chain count", uf_count_pure(uf3), 1)
check("chain ends connected", uf_connected_pure(uf3, 0, 49))
check("chain mid connected", uf_connected_pure(uf3, 10, 40))

// ── 17. star topology: all connected to center ──────────────────
let uf4 = uf_new_pure(20)
let mut s = 1
while s < 20 {
    uf_union_pure(uf4, 0, s)
    s = s + 1
}
eq("star count", uf_count_pure(uf4), 1)
// All share same root
let star_root = uf_find_pure(uf4, 0)
let mut all_same = true
let mut j = 1
while j < 20 {
    if uf_find_pure(uf4, j) != star_root {
        all_same = false
    }
    j = j + 1
}
check("star all same root", all_same)

// ── 18. merge two large groups ──────────────────────────────────
let uf5 = uf_new_pure(10)
// group A: 0-4
let mut ga = 0
while ga < 4 {
    uf_union_pure(uf5, ga, ga + 1)
    ga = ga + 1
}
// group B: 5-9
let mut gb = 5
while gb < 9 {
    uf_union_pure(uf5, gb, gb + 1)
    gb = gb + 1
}
eq("two groups count", uf_count_pure(uf5), 2)
check("groups not connected", uf_connected_pure(uf5, 0, 5) == false)
// bridge them
uf_union_pure(uf5, 4, 5)
eq("bridged count", uf_count_pure(uf5), 1)
check("bridged connected 0-9", uf_connected_pure(uf5, 0, 9))

// ── 19. path compression correctness ────────────────────────────
// After find on deep chain, parent should be root
let uf6 = uf_new_pure(5)
uf_union_pure(uf6, 0, 1)
uf_union_pure(uf6, 1, 2)
uf_union_pure(uf6, 2, 3)
uf_union_pure(uf6, 3, 4)
// find(4) triggers compression
let r6 = uf_find_pure(uf6, 4)
// find again should return same root instantly
eq("compressed find stable", uf_find_pure(uf6, 4), r6)
eq("compressed find 0", uf_find_pure(uf6, 0), r6)

// ── 20. union idempotency (multiple times same pair) ────────────
let uf7 = uf_new_pure(3)
uf_union_pure(uf7, 0, 1)
let r1 = uf_union_pure(uf7, 0, 1)
let r2 = uf_union_pure(uf7, 1, 0)
check("repeat union false 1", r1 == false)
check("repeat union false 2", r2 == false)
eq("repeat union count", uf_count_pure(uf7), 2)

// ── 21. two elements ────────────────────────────────────────────
let uf8 = uf_new_pure(2)
check("2elem not connected", uf_connected_pure(uf8, 0, 1) == false)
uf_union_pure(uf8, 0, 1)
check("2elem connected after union", uf_connected_pure(uf8, 0, 1))
eq("2elem count", uf_count_pure(uf8), 1)

// ── 22. reverse union order ─────────────────────────────────────
let uf9 = uf_new_pure(4)
uf_union_pure(uf9, 3, 2)
uf_union_pure(uf9, 2, 1)
uf_union_pure(uf9, 1, 0)
eq("reverse count", uf_count_pure(uf9), 1)
check("reverse all connected", uf_connected_pure(uf9, 0, 3))

// ── summary ─────────────────────────────────────────────────────
println("")
println("pass: " + to_string(pass) + "  fail: " + to_string(fail))
if fail == 0 {
    println("ALL PASS")
} else {
    println("SOME TESTS FAILED")
}
