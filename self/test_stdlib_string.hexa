// ═══════════════════════════════════════════════════════════
//  test_stdlib_string.hexa — I4 Stdlib String Extension Tests
//  Tests: str_trim_start, str_trim_end, str_replace_all, str_count,
//         str_reverse, str_slice, str_insert, str_remove, str_lines,
//         str_words, str_is_digit, str_pad_left/right, and more.
//  Also verifies builtin .split/.join/.trim/.contains/.replace work.
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  I4: Stdlib String Extension Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── Load stdlib_string.hexa ────────────────────────────────
// Functions are defined as top-level in the lib, so we inline-load them
// by using the HEXA runtime directly (the functions use builtins).

// -- Helper re-implementations (since we can't "import" yet) --
// We redefine the stdlib functions inline for testing.

fn _is_whitespace(ch) {
    return ch == ' ' || ch == '\t' || ch == '\n' || ch == '\r'
}

fn str_trim_start(s) {
    let n = len(s)
    let mut i = 0
    while i < n {
        if !_is_whitespace(s[i]) {
            let mut parts = []
            let mut j = i
            while j < n {
                parts = parts.push(s[j])
                j = j + 1
            }
            return parts.join("")
        }
        i = i + 1
    }
    return ""
}

fn str_trim_end(s) {
    let n = len(s)
    let mut last = n - 1
    while last >= 0 {
        if !_is_whitespace(s[last]) {
            let mut parts = []
            let mut j = 0
            while j <= last {
                parts = parts.push(s[j])
                j = j + 1
            }
            return parts.join("")
        }
        last = last - 1
    }
    return ""
}

fn str_replace_all(s, old_str, new_str) {
    let mut result = s
    let old_len = len(old_str)
    if old_len == 0 { return result }
    let mut idx = result.index_of(old_str)
    while idx >= 0 {
        let mut prefix_parts = []
        let mut i = 0
        while i < idx {
            prefix_parts = prefix_parts.push(result[i])
            i = i + 1
        }
        let prefix = prefix_parts.join("")
        let suffix_start = idx + old_len
        let mut suffix_parts = []
        let mut j = suffix_start
        while j < len(result) {
            suffix_parts = suffix_parts.push(result[j])
            j = j + 1
        }
        let suffix = suffix_parts.join("")
        result = prefix + new_str + suffix
        let search_from = idx + len(new_str)
        let rlen = len(result)
        let olen = len(old_str)
        if search_from + olen > rlen {
            idx = 0 - 1
        } else {
            let mut k = search_from
            idx = 0 - 1
            while k <= rlen - olen {
                let mut match_ok = true
                let mut m = 0
                while m < olen {
                    if result[k + m] != old_str[m] {
                        match_ok = false
                        m = olen
                    }
                    m = m + 1
                }
                if match_ok {
                    idx = k
                    k = rlen
                }
                k = k + 1
            }
        }
    }
    return result
}

fn str_count(s, needle) {
    let nn = len(needle)
    if nn == 0 { return 0 }
    let sn = len(s)
    let mut count = 0
    let mut i = 0
    while i <= sn - nn {
        let mut match_ok = true
        let mut j = 0
        while j < nn {
            if s[i + j] != needle[j] {
                match_ok = false
                j = nn
            }
            j = j + 1
        }
        if match_ok {
            count = count + 1
            i = i + nn
        } else {
            i = i + 1
        }
    }
    return count
}

fn str_slice(s, start, end_idx) {
    let n = len(s)
    let mut lo = start
    let mut hi = end_idx
    if lo < 0 { lo = 0 }
    if hi > n { hi = n }
    let mut parts = []
    let mut i = lo
    while i < hi {
        parts = parts.push(s[i])
        i = i + 1
    }
    return parts.join("")
}

fn str_insert(s, pos, sub) {
    let prefix = str_slice(s, 0, pos)
    let suffix = str_slice(s, pos, len(s))
    return prefix + sub + suffix
}

fn str_remove(s, start, end_idx) {
    let prefix = str_slice(s, 0, start)
    let suffix = str_slice(s, end_idx, len(s))
    return prefix + suffix
}

fn str_reverse(s) {
    let n = len(s)
    let mut parts = []
    let mut i = n - 1
    while i >= 0 {
        parts = parts.push(s[i])
        i = i - 1
    }
    return parts.join("")
}

fn str_is_digit(ch) {
    return ch == "0" || ch == "1" || ch == "2" || ch == "3" || ch == "4" || ch == "5" || ch == "6" || ch == "7" || ch == "8" || ch == "9"
}

fn str_lines(s) {
    return s.split("\n")
}

fn str_words(s) {
    let raw = s.split(" ")
    let mut result = []
    for part in raw {
        if len(part) > 0 {
            result = result.push(part)
        }
    }
    return result
}

// ── 1. Builtin split ──────────────────────────────────────
println("--- 1. split ---")
let s1 = "a,b,c".split(",")
check("split len", len(s1), 3)
check("split[0]", s1[0], "a")
check("split[2]", s1[2], "c")

// ── 2. Builtin join ───────────────────────────────────────
println("")
println("--- 2. join ---")
check("join basic", ["x", "y", "z"].join("-"), "x-y-z")
check("join empty sep", ["a", "b"].join(""), "ab")
check("join single", ["only"].join(","), "only")

// ── 3. Builtin trim ──────────────────────────────────────
println("")
println("--- 3. trim ---")
check("trim both", "  hello  ".trim(), "hello")
check("trim left only", "  hi".trim(), "hi")
check("trim right only", "hi  ".trim(), "hi")
check("trim empty", "".trim(), "")

// ── 4. str_trim_start ─────────────────────────────────────
println("")
println("--- 4. str_trim_start ---")
check("trim_start spaces", str_trim_start("   abc"), "abc")
check("trim_start tabs", str_trim_start("\t\thello"), "hello")
check("trim_start none", str_trim_start("abc"), "abc")
check("trim_start all ws", str_trim_start("   "), "")

// ── 5. str_trim_end ───────────────────────────────────────
println("")
println("--- 5. str_trim_end ---")
check("trim_end spaces", str_trim_end("abc   "), "abc")
check("trim_end tabs", str_trim_end("hello\t\t"), "hello")
check("trim_end none", str_trim_end("abc"), "abc")
check("trim_end all ws", str_trim_end("   "), "")

// ── 6. Builtin contains ──────────────────────────────────
println("")
println("--- 6. contains ---")
check("contains yes", "hello world".contains("world"), true)
check("contains no", "hello".contains("xyz"), false)
check("contains empty", "abc".contains(""), true)

// ── 7. Builtin replace ──────────────────────────────────
println("")
println("--- 7. replace ---")
check("replace all", "aXbXc".replace("X", "_"), "a_b_c")

// ── 8. str_replace_all ────────────────────────────────────
println("")
println("--- 8. str_replace_all ---")
check("replace_all basic", str_replace_all("aXbXc", "X", "_"), "a_b_c")
check("replace_all none", str_replace_all("hello", "Z", "!"), "hello")
check("replace_all multi", str_replace_all("aaa", "a", "bb"), "bbbbbb")

// ── 9. str_count ──────────────────────────────────────────
println("")
println("--- 9. str_count ---")
check("count basic", str_count("abcabc", "a"), 2)
check("count none", str_count("hello", "z"), 0)
check("count overlap-free", str_count("aaa", "aa"), 1)
check("count empty needle", str_count("abc", ""), 0)

// ── 10. Builtin index_of ─────────────────────────────────
println("")
println("--- 10. index_of ---")
check("index_of found", "hello world".index_of("world"), 6)
check("index_of not found", "abc".index_of("xyz"), 0 - 1)
check("index_of start", "abc".index_of("a"), 0)

// ── 11. str_slice ─────────────────────────────────────────
println("")
println("--- 11. str_slice ---")
check("slice mid", str_slice("hello", 1, 4), "ell")
check("slice full", str_slice("abc", 0, 3), "abc")
check("slice overflow", str_slice("abc", 0, 100), "abc")
check("slice empty range", str_slice("abc", 2, 2), "")

// ── 12. str_insert ────────────────────────────────────────
println("")
println("--- 12. str_insert ---")
check("insert mid", str_insert("ac", 1, "b"), "abc")
check("insert start", str_insert("bc", 0, "a"), "abc")
check("insert end", str_insert("ab", 2, "c"), "abc")

// ── 13. str_remove ────────────────────────────────────────
println("")
println("--- 13. str_remove ---")
check("remove mid", str_remove("abXc", 2, 3), "abc")
check("remove start", str_remove("Xabc", 0, 1), "abc")
check("remove end", str_remove("abcX", 3, 4), "abc")

// ── 14. str_reverse ───────────────────────────────────────
println("")
println("--- 14. str_reverse ---")
check("reverse basic", str_reverse("hello"), "olleh")
check("reverse single", str_reverse("a"), "a")
check("reverse empty", str_reverse(""), "")
check("reverse palindrome", str_reverse("aba"), "aba")

// ── 15. Builtin to_upper/to_lower ─────────────────────────
println("")
println("--- 15. case conversion ---")
check("to_upper", "hello".to_upper(), "HELLO")
check("to_lower", "HELLO".to_lower(), "hello")
check("to_upper mixed", "Hello World".to_upper(), "HELLO WORLD")

// ── 16. Builtin starts_with/ends_with ─────────────────────
println("")
println("--- 16. starts/ends with ---")
check("starts_with yes", "hello world".starts_with("hello"), true)
check("starts_with no", "hello".starts_with("world"), false)
check("ends_with yes", "hello world".ends_with("world"), true)
check("ends_with no", "hello".ends_with("xyz"), false)

// ── 17. Builtin repeat ────────────────────────────────────
println("")
println("--- 17. repeat ---")
check("repeat 3", "ab".repeat(3), "ababab")
check("repeat 0", "x".repeat(0), "")
check("repeat 1", "hi".repeat(1), "hi")

// ── 18. str_is_digit ──────────────────────────────────────
println("")
println("--- 18. str_is_digit ---")
check("digit 0", str_is_digit("0"), true)
check("digit 9", str_is_digit("9"), true)
check("digit a", str_is_digit("a"), false)
check("digit space", str_is_digit(" "), false)

// ── 19. str_lines ─────────────────────────────────────────
println("")
println("--- 19. str_lines ---")
let lines = str_lines("a\nb\nc")
check("lines len", len(lines), 3)
check("lines[0]", lines[0], "a")
check("lines[2]", lines[2], "c")

// ── 20. str_words ─────────────────────────────────────────
println("")
println("--- 20. str_words ---")
let words = str_words("  hello   world  foo  ")
check("words len", len(words), 3)
check("words[0]", words[0], "hello")
check("words[2]", words[2], "foo")

// ── 21. Builtin pad_left/pad_right ─────────────────────────
println("")
println("--- 21. pad ---")
check("pad_left", "abc".pad_left(6, "0"), "000abc")
check("pad_left no-op", "abcdef".pad_left(3, "0"), "abcdef")
check("pad_right", "abc".pad_right(6, "0"), "abc000")

// ── 22. Builtin chars ──────────────────────────────────────
println("")
println("--- 22. chars ---")
let ch = "xyz".chars()
check("chars len", len(ch), 3)
check("chars[0]", ch[0], 'x')
check("chars[2]", ch[2], 'z')

// ── 23. Complex: split + join round trip ────────────────────
println("")
println("--- 23. split/join round trip ---")
let orig = "one:two:three"
let roundtrip = orig.split(":").join(":")
check("roundtrip", roundtrip, orig)

// ── 24. Complex: replace_all + count ────────────────────────
println("")
println("--- 24. replace_all + count ---")
let s24 = "aaabbbccc"
let replaced = str_replace_all(s24, "b", "X")
check("replace_all result", replaced, "aaaXXXccc")
check("count after replace", str_count(replaced, "X"), 3)

