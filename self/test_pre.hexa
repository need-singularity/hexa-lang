println("  HEXA ROI #66 — Partial Redundancy Elimination Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── Helper: make AST nodes for testing ──────────────────────────

fn mk_ident(n) {
    let r = AstNode { kind: "Ident", name: n, value: "", op: "", left: "", right: "", cond: "", then_body: "", else_body: "", params: "", body: "", args: "", fields: "", items: "", variants: "", arms: "", iter_expr: "", ret_type: "", target: "", trait_name: "", methods: "" }
    return r
}

fn mk_int(v) {
    let r = AstNode { kind: "IntLit", name: "", value: to_string(v), op: "", left: "", right: "", cond: "", then_body: "", else_body: "", params: "", body: "", args: "", fields: "", items: "", variants: "", arms: "", iter_expr: "", ret_type: "", target: "", trait_name: "", methods: "" }
    return r
}

fn mk_binop(op, l, r2) {
    let r = AstNode { kind: "BinOp", name: "", value: "", op: op, left: l, right: r2, cond: "", then_body: "", else_body: "", params: "", body: "", args: "", fields: "", items: "", variants: "", arms: "", iter_expr: "", ret_type: "", target: "", trait_name: "", methods: "" }
    return r
}

fn mk_let(name, expr) {
    let r = AstNode { kind: "LetStmt", name: name, value: "", op: "", left: expr, right: "", cond: "", then_body: "", else_body: "", params: "", body: "", args: "", fields: "", items: "", variants: "", arms: "", iter_expr: "", ret_type: "", target: "", trait_name: "", methods: "" }
    return r
}

fn mk_let_mut(name, expr) {
    let r = AstNode { kind: "LetMutStmt", name: name, value: "", op: "", left: expr, right: "", cond: "", then_body: "", else_body: "", params: "", body: "", args: "", fields: "", items: "", variants: "", arms: "", iter_expr: "", ret_type: "", target: "", trait_name: "", methods: "" }
    return r
}

fn mk_assign(lhs_ident, rhs_expr) {
    let r = AstNode { kind: "AssignStmt", name: "", value: "", op: "", left: lhs_ident, right: rhs_expr, cond: "", then_body: "", else_body: "", params: "", body: "", args: "", fields: "", items: "", variants: "", arms: "", iter_expr: "", ret_type: "", target: "", trait_name: "", methods: "" }
    return r
}

fn mk_return(expr) {
    let r = AstNode { kind: "ReturnStmt", name: "", value: "", op: "", left: expr, right: "", cond: "", then_body: "", else_body: "", params: "", body: "", args: "", fields: "", items: "", variants: "", arms: "", iter_expr: "", ret_type: "", target: "", trait_name: "", methods: "" }
    return r
}

fn mk_if(cond_expr, then_stmts, else_stmts) {
    let r = AstNode { kind: "IfExpr", name: "", value: "", op: "", left: "", right: "", cond: cond_expr, then_body: then_stmts, else_body: else_stmts, params: "", body: "", args: "", fields: "", items: "", variants: "", arms: "", iter_expr: "", ret_type: "", target: "", trait_name: "", methods: "" }
    return r
}

fn mk_while(cond_expr, body_stmts) {
    let r = AstNode { kind: "WhileStmt", name: "", value: "", op: "", left: "", right: "", cond: cond_expr, then_body: "", else_body: "", params: "", body: body_stmts, args: "", fields: "", items: "", variants: "", arms: "", iter_expr: "", ret_type: "", target: "", trait_name: "", methods: "" }
    return r
}

fn mk_fn(name, body_stmts) {
    let r = AstNode { kind: "FnDecl", name: name, value: "", op: "", left: "", right: "", cond: "", then_body: "", else_body: "", params: [], body: body_stmts, args: "", fields: "", items: "", variants: "", arms: "", iter_expr: "", ret_type: "", target: "", trait_name: "", methods: "" }
    return r
}

fn mk_call(callee_name, call_args) {
    let callee = mk_ident(callee_name)
    let r = AstNode { kind: "Call", name: "", value: "", op: "", left: callee, right: "", cond: "", then_body: "", else_body: "", params: "", body: "", args: call_args, fields: "", items: "", variants: "", arms: "", iter_expr: "", ret_type: "", target: "", trait_name: "", methods: "" }
    return r
}

// ── 1. CFG: empty body -> single block ──────────────────────────
println("--- CFG Construction ---")

let cfg1 = anp_pre_build_cfg([])
check("#66-01 empty body block_count=1", cfg1["block_count"] == 1)

// ── 2. CFG: linear body (no branches) -> single block ──────────
let linear_body = [mk_let("a", mk_binop("+", mk_ident("x"), mk_int(1))), mk_let("b", mk_binop("*", mk_ident("a"), mk_int(2)))]
let cfg2 = anp_pre_build_cfg(linear_body)
check("#66-02 linear body block_count=1", cfg2["block_count"] == 1)

// ── 3. CFG: if-else creates 4 blocks ───────────────────────────
let if_body = [mk_if(mk_ident("cond"), [mk_let("t", mk_int(1))], [mk_let("e", mk_int(2))])]
let cfg3 = anp_pre_build_cfg(if_body)
check("#66-03 if-else block_count=4", cfg3["block_count"] == 4)

// ── 4. CFG: while loop creates 4 blocks ────────────────────────
let while_body = [mk_while(mk_ident("cond"), [mk_let("x", mk_int(1))])]
let cfg4 = anp_pre_build_cfg(while_body)
check("#66-04 while loop block_count=4", cfg4["block_count"] == 4)

// ── 5. CFG: edges for if-else (4 edges) ────────────────────────
check("#66-05 if-else edge_count=4", len(cfg3["edges"]) == 4)

// ── 6. CFG: edges for while loop (4 edges) ─────────────────────
check("#66-06 while edge_count=4", len(cfg4["edges"]) == 4)

// ── 7. Predecessors: entry block has no predecessors ────────────
println("")
println("--- Predecessors/Successors ---")

let preds_entry = anp_pre_predecessors(cfg3["edges"], 0)
check("#66-07 entry block has 0 predecessors", len(preds_entry) == 0)

// ── 8. Predecessors: merge block has 2 predecessors ─────────────
let preds_merge = anp_pre_predecessors(cfg3["edges"], 3)
check("#66-08 merge block has 2 predecessors", len(preds_merge) == 2)

// ── 9. Successors: entry block with if has 2 successors ─────────
let succs_entry = anp_pre_successors(cfg3["edges"], 0)
check("#66-09 entry block has 2 successors (then+else)", len(succs_entry) == 2)

// ── 10. Successors: merge block (exit) has no successors ────────
let succs_merge = anp_pre_successors(cfg3["edges"], 3)
check("#66-10 merge block has 0 successors", len(succs_merge) == 0)

// ── 11. Block exprs: empty block ────────────────────────────────
println("")
println("--- Block Expression Collection ---")

let empty_exprs = anp_pre_block_exprs([])
check("#66-11 empty block has 0 exprs", len(empty_exprs) == 0)

// ── 12. Block exprs: LetStmt with binop ─────────────────────────
let block_with_let = [mk_let("a", mk_binop("+", mk_ident("x"), mk_int(1)))]
let let_exprs = anp_pre_block_exprs(block_with_let)
check("#66-12 let with binop has 1 expr sig", len(let_exprs) == 1)

// ── 13. Block exprs: AssignStmt ─────────────────────────────────
let block_with_assign = [mk_assign(mk_ident("a"), mk_binop("*", mk_ident("y"), mk_int(3)))]
let assign_exprs = anp_pre_block_exprs(block_with_assign)
check("#66-13 assign with binop has 1 expr sig", len(assign_exprs) == 1)

// ── 14. Kill detection: assignment kills referenced var ──────────
println("")
println("--- Kill Detection ---")

let kill_block = [mk_assign(mk_ident("x"), mk_int(42))]
let sig_with_x = "binop:+(id:x,int:1)"
let kills = anp_pre_block_kills_expr(kill_block, sig_with_x)
check("#66-14 assign to x kills expr using x", kills == true)

// ── 15. Kill detection: no kill when different var ──────────────
let no_kill_block = [mk_assign(mk_ident("y"), mk_int(42))]
let no_kills = anp_pre_block_kills_expr(no_kill_block, sig_with_x)
check("#66-15 assign to y does not kill expr using x", no_kills == false)

// ── 16. Extract IDs: simple id:foo ──────────────────────────────
println("")
println("--- ID Extraction ---")

let ids1 = anp_pre_extract_ids("id:foo")
check("#66-16 extract id:foo -> [foo]", len(ids1) == 1)

// ── 17. Extract IDs: binop with two ids ─────────────────────────
let ids2 = anp_pre_extract_ids("binop:+(id:alpha,id:beta)")
check("#66-17 extract binop ids -> 2 names", len(ids2) == 2)

// ── 18. Sig in: found ────────────────────────────────────────────
println("")
println("--- Sig Lookup ---")

let sigs = ["a", "b", "c"]
check("#66-18 sig_in finds 'b'", anp_pre_sig_in(sigs, "b") == true)

// ── 19. Sig in: not found ────────────────────────────────────────
check("#66-19 sig_in misses 'd'", anp_pre_sig_in(sigs, "d") == false)

// ── 20. Analyze: empty body -> no expr_sigs ─────────────────────
println("")
println("--- PRE Analysis ---")

let empty_cfg = anp_pre_build_cfg([])
let analysis0 = anp_pre_analyze(empty_cfg)
check("#66-20 empty body -> 0 expr_sigs", len(analysis0["expr_sigs"]) == 0)

// ── 21. Analyze: same expr both branches -> CSE detection ───────
//  fn foo(x) {
//    if cond {
//      let a = x + 1   // expr computed in then
//    } else {
//      let b = x + 1   // same expr in else
//    }
//  }
//  The expr x+1 is anticipated at the merge point and available
//  from both branches, so it should be detected.
let cse_then = [mk_let("a", mk_binop("+", mk_ident("x"), mk_int(1)))]
let cse_else = [mk_let("b", mk_binop("+", mk_ident("x"), mk_int(1)))]
let cse_body = [mk_if(mk_ident("cond"), cse_then, cse_else)]
let cse_cfg = anp_pre_build_cfg(cse_body)
let cse_analysis = anp_pre_analyze(cse_cfg)
check("#66-21 CSE: same expr both branches detected", len(cse_analysis["expr_sigs"]) > 0)

// ── 22. PRE insert: same expr both branches -> elimination ──────
let cse_result = anp_pre_insert(cse_cfg)
check("#66-22 PRE insert detects opportunity", cse_result["inserted"] >= 0)

// ── 23. PRE pass: non-array input returns unchanged ─────────────
println("")
println("--- PRE Pass ---")

let pass_result1 = anp_pre_pass("not_an_array")
check("#66-23 non-array returns unchanged", pass_result1 == "not_an_array")

// ── 24. PRE pass: no FnDecl -> no changes ───────────────────────
let no_fn = [mk_let("x", mk_int(42))]
let pass_result2 = anp_pre_pass(no_fn)
check("#66-24 no FnDecl -> 0 PRE eliminations", m978_pre_eliminated == 0)

// ── 25. PRE pass: FnDecl with branches -> analysis runs ─────────
let fn_with_branch = [mk_fn("test_fn", [
    mk_let("pre", mk_binop("+", mk_ident("x"), mk_int(1))),
    mk_if(mk_ident("cond"),
        [mk_let("a", mk_binop("+", mk_ident("x"), mk_int(1)))],
        [mk_let("b", mk_binop("*", mk_ident("y"), mk_int(2)))]
    )
])]
let pass_result3 = anp_pre_pass(fn_with_branch)
check("#66-25 FnDecl with branches runs PRE", type_of(pass_result3) == "array")

// ═══════════════════════════════════════════════════════════════════
// Summary
// ═══════════════════════════════════════════════════════════════════
println("")
println("═══════════════════════════════════════════════════════")
println("  RESULTS: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")
