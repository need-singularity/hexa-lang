// ═══════════════════════════════════════════════════════════════════
//  test_pre.hexa — ROI #66 Partial Redundancy Elimination (PRE) Tests
//
//  Verifies the PRE pass functions:
//    - anp_pre_build_cfg: CFG construction from function bodies
//    - anp_pre_analyze: dataflow analysis (AVAIL + ANTIC)
//    - anp_pre_insert: insertion/elimination point detection
//    - anp_pre_pass: top-level AST pass
//    - Helper functions: predecessors, successors, block_exprs, etc.
//
//  Tests (25):
//    1.  CFG: empty body -> single block
//    2.  CFG: linear body (no branches) -> single block
//    3.  CFG: if-else creates 4 blocks
//    4.  CFG: while loop creates 4 blocks
//    5.  CFG: edges for if-else (4 edges)
//    6.  CFG: edges for while loop (4 edges)
//    7.  Predecessors: entry block has no predecessors
//    8.  Predecessors: merge block has 2 predecessors
//    9.  Successors: entry block with if has 2 successors
//   10.  Successors: exit block has no successors
//   11.  Block exprs: empty block
//   12.  Block exprs: LetStmt with binop
//   13.  Block exprs: AssignStmt
//   14.  Kill detection: assignment kills referenced var
//   15.  Kill detection: no kill when different var
//   16.  Extract IDs: simple id:foo
//   17.  Extract IDs: binop with two ids
//   18.  Sig in: found
//   19.  Sig in: not found
//   20.  Analyze: empty body -> no expr_sigs
//   21.  Analyze: same expr both branches -> CSE (elimination)
//   22.  PRE insert: same expr both branches -> elimination detected
//   23.  PRE pass: non-array input returns unchanged
//   24.  PRE pass: no FnDecl -> no changes
//   25.  PRE pass: FnDecl with branches -> analysis runs
//
//  Run: ./hexa self/test_pre.hexa
// ═══════════════════════════════════════════════════════════════════

// ── Inlined dependencies (self-contained, no imports) ──────────────

struct AstNode {
    kind: string,
    name: string,
    value: string,
    op: string,
    left: string,
    right: string,
    cond: string,
    then_body: string,
    else_body: string,
    params: string,
    body: string,
    args: string,
    fields: string,
    items: string,
    variants: string,
    arms: string,
    iter_expr: string,
    ret_type: string,
    target: string,
    trait_name: string,
    methods: string
}

let mut m978_pre_eliminated = 0
let mut m978_pre_inserted = 0

// decreases expr — structural
fn gvn_expr_signature(expr) {
    if type_of(expr) == "string" { return "" }
    let k = expr.kind
    if k == "Call" {
        let callee = expr.left
        if type_of(callee) != "string" && callee.kind == "Ident" {
            let mut arg_sigs = []
            if type_of(expr.args) == "array" {
                let mut ai = 0
                while ai < len(expr.args) {
                    let as2 = gvn_expr_signature(expr.args[ai])
                    if as2 != "" {
                        arg_sigs.push(as2)
                    } else {
                        return ""
                    }
                    ai = ai + 1
                }
            }
            return "call:" + callee.name + "(" + arg_sigs.join(",") + ")"
        }
    }
    if k == "BinOp" {
        let ls = gvn_expr_signature(expr.left)
        let rs = gvn_expr_signature(expr.right)
        if ls != "" && rs != "" {
            return "binop:" + expr.op + "(" + ls + "," + rs + ")"
        }
    }
    if k == "Ident" { return "id:" + expr.name }
    if k == "IntLit" { return "int:" + expr.value }
    if k == "FloatLit" { return "float:" + expr.value }
    if k == "BoolLit" { return "bool:" + expr.value }
    if k == "StringLit" { return "str:" + expr.value }
    if k == "Index" {
        let ls2 = gvn_expr_signature(expr.left)
        let rs2 = gvn_expr_signature(expr.right)
        if ls2 != "" && rs2 != "" {
            return "idx:" + ls2 + "[" + rs2 + "]"
        }
    }
    if k == "FieldAccess" {
        let ls3 = gvn_expr_signature(expr.left)
        if ls3 != "" {
            return "field:" + ls3 + "." + expr.name
        }
    }
    return ""
}

fn anp_pre_build_cfg(body) {
    if type_of(body) != "array" {
        return #{"blocks": [[]], "edges": [], "block_count": 1}
    }
    let n = len(body)
    let mut blocks = [[]]
    let mut edges = []
    let mut cur_block = 0
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if type_of(stmt) != "string" && stmt.kind == "IfExpr" {
            let then_block = cur_block + 1
            let else_block = cur_block + 2
            let merge_block = cur_block + 3
            edges.push([cur_block, then_block])
            edges.push([cur_block, else_block])
            edges.push([then_block, merge_block])
            edges.push([else_block, merge_block])
            let mut tb = []
            if type_of(stmt.then_body) == "array" {
                let mut ti = 0
                while ti < len(stmt.then_body) {
                    tb.push(stmt.then_body[ti])
                    ti = ti + 1
                }
            }
            let mut eb = []
            if type_of(stmt.else_body) == "array" {
                let mut ei = 0
                while ei < len(stmt.else_body) {
                    eb.push(stmt.else_body[ei])
                    ei = ei + 1
                }
            }
            blocks.push(tb)
            blocks.push(eb)
            blocks.push([])
            cur_block = merge_block
        } else if type_of(stmt) != "string" && stmt.kind == "WhileStmt" {
            let header_block = cur_block + 1
            let loop_body_block = cur_block + 2
            let exit_block = cur_block + 3
            edges.push([cur_block, header_block])
            edges.push([header_block, loop_body_block])
            edges.push([loop_body_block, header_block])
            edges.push([header_block, exit_block])
            let mut lb = []
            if type_of(stmt.body) == "array" {
                let mut li = 0
                while li < len(stmt.body) {
                    lb.push(stmt.body[li])
                    li = li + 1
                }
            }
            blocks.push([])
            blocks.push(lb)
            blocks.push([])
            cur_block = exit_block
        } else {
            let cur_stmts = blocks[cur_block]
            let mut new_stmts = []
            let mut ci = 0
            while ci < len(cur_stmts) {
                new_stmts.push(cur_stmts[ci])
                ci = ci + 1
            }
            new_stmts.push(stmt)
            let mut new_blocks = []
            let mut bi = 0
            while bi < len(blocks) {
                if bi == cur_block {
                    new_blocks.push(new_stmts)
                } else {
                    new_blocks.push(blocks[bi])
                }
                bi = bi + 1
            }
            blocks = new_blocks
        }
        i = i + 1
    }
    let result_cfg = #{"blocks": blocks, "edges": edges, "block_count": len(blocks)}
    return result_cfg
}

fn anp_pre_predecessors(edges, block_id) {
    let mut preds = []
    let mut i = 0
    while i < len(edges) {
        let edge = edges[i]
        if edge[1] == block_id {
            let mut found = false
            let mut j = 0
            while j < len(preds) {
                if preds[j] == edge[0] { found = true }
                j = j + 1
            }
            if !found { preds.push(edge[0]) }
        }
        i = i + 1
    }
    return preds
}

fn anp_pre_successors(edges, block_id) {
    let mut succs = []
    let mut i = 0
    while i < len(edges) {
        let edge = edges[i]
        if edge[0] == block_id {
            let mut found = false
            let mut j = 0
            while j < len(succs) {
                if succs[j] == edge[1] { found = true }
                j = j + 1
            }
            if !found { succs.push(edge[1]) }
        }
        i = i + 1
    }
    return succs
}

fn anp_pre_block_exprs(block) {
    let mut sigs = []
    if type_of(block) != "array" { return sigs }
    let n = len(block)
    let mut i = 0
    while i < n {
        let stmt = block[i]
        if type_of(stmt) != "string" {
            if stmt.kind == "LetStmt" || stmt.kind == "LetMutStmt" {
                let sig = gvn_expr_signature(stmt.left)
                if sig != "" {
                    let mut found = false
                    let mut j = 0
                    while j < len(sigs) {
                        if sigs[j] == sig { found = true }
                        j = j + 1
                    }
                    if !found { sigs.push(sig) }
                }
            }
            if stmt.kind == "AssignStmt" {
                let sig = gvn_expr_signature(stmt.right)
                if sig != "" {
                    let mut found = false
                    let mut j = 0
                    while j < len(sigs) {
                        if sigs[j] == sig { found = true }
                        j = j + 1
                    }
                    if !found { sigs.push(sig) }
                }
            }
        }
        i = i + 1
    }
    return sigs
}

fn anp_pre_block_kills_expr(block, sig) {
    if type_of(block) != "array" { return false }
    let ref_names = anp_pre_extract_ids(sig)
    let n = len(block)
    let mut i = 0
    while i < n {
        let stmt = block[i]
        if type_of(stmt) != "string" {
            if stmt.kind == "AssignStmt" {
                if type_of(stmt.left) != "string" && stmt.left.kind == "Ident" {
                    let mut j = 0
                    while j < len(ref_names) {
                        if ref_names[j] == stmt.left.name { return true }
                        j = j + 1
                    }
                }
            }
            if stmt.kind == "LetMutStmt" {
                let mut j = 0
                while j < len(ref_names) {
                    if ref_names[j] == stmt.name { return true }
                    j = j + 1
                }
            }
        }
        i = i + 1
    }
    return false
}

fn anp_pre_extract_ids(sig) {
    let mut names = []
    let chars = sig.chars()
    let total = len(chars)
    let mut i = 0
    while i < total {
        if i + 2 < total {
            if to_string(chars[i]) == "i" && to_string(chars[i + 1]) == "d" && to_string(chars[i + 2]) == ":" {
                i = i + 3
                let mut name = ""
                while i < total {
                    let c = to_string(chars[i])
                    if c == "," || c == ")" || c == "]" || c == "[" || c == "(" {
                        i = i - 1
                        break
                    }
                    name = name + c
                    i = i + 1
                }
                if name != "" {
                    let mut found = false
                    let mut j = 0
                    while j < len(names) {
                        if names[j] == name { found = true }
                        j = j + 1
                    }
                    if !found { names.push(name) }
                }
            }
        }
        i = i + 1
    }
    return names
}

fn anp_pre_sig_in(sigs, sig) {
    let mut i = 0
    while i < len(sigs) {
        if sigs[i] == sig { return true }
        i = i + 1
    }
    return false
}

fn anp_pre_analyze(cfg) {
    let blocks = cfg["blocks"]
    let edges = cfg["edges"]
    let bc = cfg["block_count"]
    let mut all_sigs = []
    let mut bi = 0
    while bi < bc {
        let block_sigs = anp_pre_block_exprs(blocks[bi])
        let mut si = 0
        while si < len(block_sigs) {
            if !anp_pre_sig_in(all_sigs, block_sigs[si]) {
                all_sigs.push(block_sigs[si])
            }
            si = si + 1
        }
        bi = bi + 1
    }
    if len(all_sigs) == 0 {
        let empty_result = #{"expr_sigs": [], "avail": [], "antic": [], "insert_points": [], "elim_points": []}
        return empty_result
    }
    // AVAIL forward dataflow
    let mut avail_out = []
    let mut avi = 0
    while avi < bc {
        if avi == 0 {
            avail_out.push(anp_pre_block_exprs(blocks[0]))
        } else {
            let mut copy = []
            let mut ci = 0
            while ci < len(all_sigs) {
                copy.push(all_sigs[ci])
                ci = ci + 1
            }
            avail_out.push(copy)
        }
        avi = avi + 1
    }
    let mut fp_iter = 0
    while fp_iter < 3 {
        let mut bi2 = 1
        while bi2 < bc {
            let preds = anp_pre_predecessors(edges, bi2)
            let mut avail_in = []
            if len(preds) > 0 {
                let first_pred = preds[0]
                let mut ai2 = 0
                while ai2 < len(avail_out[first_pred]) {
                    avail_in.push(avail_out[first_pred][ai2])
                    ai2 = ai2 + 1
                }
                let mut pi = 1
                while pi < len(preds) {
                    let pred_avail = avail_out[preds[pi]]
                    let mut new_avail = []
                    let mut ni = 0
                    while ni < len(avail_in) {
                        if anp_pre_sig_in(pred_avail, avail_in[ni]) {
                            new_avail.push(avail_in[ni])
                        }
                        ni = ni + 1
                    }
                    avail_in = new_avail
                    pi = pi + 1
                }
            }
            let gen = anp_pre_block_exprs(blocks[bi2])
            let mut new_out = []
            let mut ki = 0
            while ki < len(avail_in) {
                if !anp_pre_block_kills_expr(blocks[bi2], avail_in[ki]) {
                    new_out.push(avail_in[ki])
                }
                ki = ki + 1
            }
            let mut gi = 0
            while gi < len(gen) {
                if !anp_pre_sig_in(new_out, gen[gi]) {
                    new_out.push(gen[gi])
                }
                gi = gi + 1
            }
            let mut new_avail_out = []
            let mut ui = 0
            while ui < len(avail_out) {
                if ui == bi2 {
                    new_avail_out.push(new_out)
                } else {
                    new_avail_out.push(avail_out[ui])
                }
                ui = ui + 1
            }
            avail_out = new_avail_out
            bi2 = bi2 + 1
        }
        fp_iter = fp_iter + 1
    }
    // ANTIC backward dataflow
    let mut antic_in = []
    let mut ai3 = 0
    while ai3 < bc {
        antic_in.push(anp_pre_block_exprs(blocks[ai3]))
        ai3 = ai3 + 1
    }
    let mut fp_iter2 = 0
    while fp_iter2 < 3 {
        let mut bi3 = bc - 1
        while bi3 >= 0 {
            let succs = anp_pre_successors(edges, bi3)
            let mut antic_out = []
            if len(succs) > 0 {
                let first_succ = succs[0]
                let mut si2 = 0
                while si2 < len(antic_in[first_succ]) {
                    antic_out.push(antic_in[first_succ][si2])
                    si2 = si2 + 1
                }
                let mut pi2 = 1
                while pi2 < len(succs) {
                    let succ_antic = antic_in[succs[pi2]]
                    let mut new_antic = []
                    let mut ni2 = 0
                    while ni2 < len(antic_out) {
                        if anp_pre_sig_in(succ_antic, antic_out[ni2]) {
                            new_antic.push(antic_out[ni2])
                        }
                        ni2 = ni2 + 1
                    }
                    antic_out = new_antic
                    pi2 = pi2 + 1
                }
            }
            let gen2 = anp_pre_block_exprs(blocks[bi3])
            let mut new_in = []
            let mut ki2 = 0
            while ki2 < len(antic_out) {
                if !anp_pre_block_kills_expr(blocks[bi3], antic_out[ki2]) {
                    new_in.push(antic_out[ki2])
                }
                ki2 = ki2 + 1
            }
            let mut gi2 = 0
            while gi2 < len(gen2) {
                if !anp_pre_sig_in(new_in, gen2[gi2]) {
                    new_in.push(gen2[gi2])
                }
                gi2 = gi2 + 1
            }
            let mut new_antic_in = []
            let mut ui2 = 0
            while ui2 < len(antic_in) {
                if ui2 == bi3 {
                    new_antic_in.push(new_in)
                } else {
                    new_antic_in.push(antic_in[ui2])
                }
                ui2 = ui2 + 1
            }
            antic_in = new_antic_in
            bi3 = bi3 - 1
        }
        fp_iter2 = fp_iter2 + 1
    }
    // Determine insertion and elimination points
    let mut insert_points = []
    let mut elim_points = []
    let mut bi4 = 0
    while bi4 < bc {
        let preds4 = anp_pre_predecessors(edges, bi4)
        let mut avail_in4 = []
        if len(preds4) > 0 {
            let mut ai4 = 0
            while ai4 < len(avail_out[preds4[0]]) {
                avail_in4.push(avail_out[preds4[0]][ai4])
                ai4 = ai4 + 1
            }
            let mut pi4 = 1
            while pi4 < len(preds4) {
                let p_avail = avail_out[preds4[pi4]]
                let mut new_ai = []
                let mut ni4 = 0
                while ni4 < len(avail_in4) {
                    if anp_pre_sig_in(p_avail, avail_in4[ni4]) {
                        new_ai.push(avail_in4[ni4])
                    }
                    ni4 = ni4 + 1
                }
                avail_in4 = new_ai
                pi4 = pi4 + 1
            }
        }
        let gen4 = anp_pre_block_exprs(blocks[bi4])
        let mut si4 = 0
        while si4 < len(antic_in[bi4]) {
            let sig4 = antic_in[bi4][si4]
            if !anp_pre_sig_in(avail_in4, sig4) {
                let ip = #{"block": bi4, "sig": sig4}
                insert_points.push(ip)
            }
            si4 = si4 + 1
        }
        let mut ei4 = 0
        while ei4 < len(gen4) {
            if anp_pre_sig_in(avail_in4, gen4[ei4]) {
                let ep = #{"block": bi4, "sig": gen4[ei4]}
                elim_points.push(ep)
            }
            ei4 = ei4 + 1
        }
        bi4 = bi4 + 1
    }
    let final_result = #{"expr_sigs": all_sigs, "avail": avail_out, "antic": antic_in, "insert_points": insert_points, "elim_points": elim_points}
    return final_result
}

fn anp_pre_insert(cfg) {
    let analysis = anp_pre_analyze(cfg)
    let insert_pts = analysis["insert_points"]
    let elim_pts = analysis["elim_points"]
    let inserted = len(insert_pts)
    let eliminated = len(elim_pts)
    let result = #{"inserted": inserted, "eliminated": eliminated, "insert_points": insert_pts, "elim_points": elim_pts}
    return result
}

fn anp_pre_pass(ast) {
    if type_of(ast) != "array" { return ast }
    let n = len(ast)
    let mut i = 0
    let mut total_inserted = 0
    let mut total_eliminated = 0
    while i < n {
        let node = ast[i]
        if type_of(node) != "string" && node.kind == "FnDecl" {
            if type_of(node.body) == "array" && len(node.body) > 0 {
                let cfg = anp_pre_build_cfg(node.body)
                if cfg["block_count"] > 1 {
                    let result = anp_pre_insert(cfg)
                    if result["inserted"] > 0 || result["eliminated"] > 0 {
                        total_inserted = total_inserted + result["inserted"]
                        total_eliminated = total_eliminated + result["eliminated"]
                    }
                }
            }
        }
        i = i + 1
    }
    m978_pre_eliminated = total_eliminated
    m978_pre_inserted = total_inserted
    return ast
}

// ── Test harness ────────────────────────────────────────────────────

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

