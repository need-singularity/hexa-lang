// =====================================================================
//  test_loop_fusion.hexa -- ROI #55 Loop Fusion pass verification
//
//  Verifies that adjacent for-loops with identical iteration ranges
//  are fused into a single loop, eliminating redundant memory traversals.
//
//  Tests (22):
//    1-9.   anp_expr_equal structural equality
//   10-15.  anp_detect_fusion (fusible / reject cases)
//   16-17.  anp_apply_fusion (merge + substitution)
//   18-22.  anp_fusion_body (multi-loop chains, intervening, nested)
//   23-30.  anp_fusion_pass (full AST walk)
//
//  Run: ./hexa self/test_loop_fusion.hexa
// =====================================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn check_eq(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

// ── Inline copy of fusion pass (self-contained test) ────────

let mut m979_fusion_candidates = 0
let mut m979_fusion_applied = 0

fn t_make_ident(name) {
    return #{
        "kind": "Ident", "name": name, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

fn anp_expr_equal(a, b) {
    if type_of(a) == "string" && type_of(b) == "string" { return a == b }
    if type_of(a) == "string" { return false }
    if type_of(b) == "string" { return false }
    if a.kind != b.kind { return false }
    if a.kind == "Ident" { return a.name == b.name }
    if a.kind == "IntLit" { return a.value == b.value }
    if a.kind == "FloatLit" { return a.value == b.value }
    if a.kind == "StringLit" { return a.value == b.value }
    if a.kind == "BoolLit" { return a.value == b.value }
    if a.kind == "BinOp" {
        if a.op != b.op { return false }
        if anp_expr_equal(a.left, b.left) == false { return false }
        return anp_expr_equal(a.right, b.right)
    }
    if a.kind == "UnaryOp" {
        if a.op != b.op { return false }
        return anp_expr_equal(a.left, b.left)
    }
    if a.kind == "Index" {
        if anp_expr_equal(a.left, b.left) == false { return false }
        return anp_expr_equal(a.right, b.right)
    }
    if a.kind == "Range" {
        if a.value != b.value { return false }
        if anp_expr_equal(a.left, b.left) == false { return false }
        return anp_expr_equal(a.right, b.right)
    }
    if a.kind == "FieldAccess" {
        if a.name != b.name { return false }
        return anp_expr_equal(a.left, b.left)
    }
    if a.kind == "Call" {
        if anp_expr_equal(a.left, b.left) == false { return false }
        if type_of(a.args) != type_of(b.args) { return false }
        if type_of(a.args) == "array" {
            if len(a.args) != len(b.args) { return false }
            let mut ci = 0
            while ci < len(a.args) {
                if anp_expr_equal(a.args[ci], b.args[ci]) == false { return false }
                ci = ci + 1
            }
            return true
        }
        return true
    }
    return false
}

fn anp_body_writes_name(body, name) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "AssignStmt" {
            if type_of(stmt.left) == "string" {
                if stmt.name == name { return true }
            }
            if type_of(stmt.left) != "string" {
                if stmt.left.kind == "Ident" && stmt.left.name == name { return true }
            }
        }
        if stmt.kind == "LetMutStmt" {
            if stmt.name == name { return true }
        }
        if stmt.kind == "LetStmt" {
            if stmt.name == name { return true }
        }
        if stmt.kind == "WhileStmt" {
            if anp_body_writes_name(stmt.body, name) { return true }
        }
        if stmt.kind == "ForStmt" {
            if anp_body_writes_name(stmt.body, name) { return true }
        }
        if stmt.kind == "IfStmt" {
            if type_of(stmt.then_body) == "array" {
                if anp_body_writes_name(stmt.then_body, name) { return true }
            }
            if type_of(stmt.else_body) == "array" {
                if anp_body_writes_name(stmt.else_body, name) { return true }
            }
        }
        i = i + 1
    }
    return false
}

fn anp_collect_scalar_writes(body) {
    if type_of(body) != "array" { return [] }
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "AssignStmt" {
            if type_of(stmt.left) != "string" {
                if stmt.left.kind == "Ident" {
                    out.push(stmt.left.name)
                }
            }
            if stmt.name != "" {
                if type_of(stmt.left) == "string" {
                    out.push(stmt.name)
                }
                if type_of(stmt.left) != "string" {
                    if stmt.left.kind != "Index" {
                        out.push(stmt.name)
                    }
                }
            }
        }
        if stmt.kind == "LetMutStmt" {
            out.push(stmt.name)
        }
        if stmt.kind == "LetStmt" {
            out.push(stmt.name)
        }
        i = i + 1
    }
    return out
}

fn anp_detect_fusion(loop1, loop2) {
    if loop1.kind != "ForStmt" { return false }
    if loop2.kind != "ForStmt" { return false }
    if type_of(loop1.body) != "array" { return false }
    if type_of(loop2.body) != "array" { return false }
    if type_of(loop1.iter_expr) == "string" { return false }
    if type_of(loop2.iter_expr) == "string" { return false }
    if loop1.iter_expr.kind != "Range" { return false }
    if loop2.iter_expr.kind != "Range" { return false }
    if anp_expr_equal(loop1.iter_expr, loop2.iter_expr) == false { return false }
    if anp_body_writes_name(loop2.body, loop1.name) { return false }
    if anp_body_writes_name(loop1.body, loop2.name) { return false }
    let writes1 = anp_collect_scalar_writes(loop1.body)
    let writes2 = anp_collect_scalar_writes(loop2.body)
    let mut wi = 0
    while wi < len(writes1) {
        let w1 = writes1[wi]
        let mut wj = 0
        while wj < len(writes2) {
            if writes2[wj] == w1 {
                if w1 != loop1.name && w1 != loop2.name {
                    return false
                }
            }
            wj = wj + 1
        }
        wi = wi + 1
    }
    return true
}

fn anp_subst_ident_expr(expr, old_name, new_name) {
    if type_of(expr) == "string" { return expr }
    if expr.kind == "Ident" {
        if expr.name == old_name {
            return t_make_ident(new_name)
        }
        return expr
    }
    if expr.kind == "BinOp" {
        let nl = anp_subst_ident_expr(expr.left, old_name, new_name)
        let nr = anp_subst_ident_expr(expr.right, old_name, new_name)
        return #{
            "kind": "BinOp", "name": "", "value": "", "op": expr.op,
            "left": nl, "right": nr, "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    if expr.kind == "UnaryOp" {
        let nl = anp_subst_ident_expr(expr.left, old_name, new_name)
        return #{
            "kind": "UnaryOp", "name": "", "value": "", "op": expr.op,
            "left": nl, "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    if expr.kind == "Index" {
        let nl = anp_subst_ident_expr(expr.left, old_name, new_name)
        let nr = anp_subst_ident_expr(expr.right, old_name, new_name)
        return #{
            "kind": "Index", "name": "", "value": "", "op": "",
            "left": nl, "right": nr, "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    if expr.kind == "Call" {
        let nl = anp_subst_ident_expr(expr.left, old_name, new_name)
        let mut new_args = []
        if type_of(expr.args) == "array" {
            let mut ai = 0
            while ai < len(expr.args) {
                new_args.push(anp_subst_ident_expr(expr.args[ai], old_name, new_name))
                ai = ai + 1
            }
        }
        return #{
            "kind": "Call", "name": "", "value": "", "op": "",
            "left": nl, "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": new_args, "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    if expr.kind == "FieldAccess" {
        let nl = anp_subst_ident_expr(expr.left, old_name, new_name)
        return #{
            "kind": "FieldAccess", "name": expr.name, "value": "", "op": "",
            "left": nl, "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    return expr
}

fn anp_subst_ident(stmt, old_name, new_name) {
    if type_of(stmt) == "string" { return stmt }
    let k = stmt.kind
    if k == "AssignStmt" {
        return #{
            "kind": "AssignStmt", "name": stmt.name, "value": stmt.value, "op": stmt.op,
            "left": anp_subst_ident_expr(stmt.left, old_name, new_name),
            "right": anp_subst_ident_expr(stmt.right, old_name, new_name),
            "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    if k == "LetStmt" || k == "LetMutStmt" {
        return #{
            "kind": k, "name": stmt.name, "value": stmt.value, "op": "",
            "left": anp_subst_ident_expr(stmt.left, old_name, new_name),
            "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    if k == "ExprStmt" {
        return #{
            "kind": "ExprStmt", "name": "", "value": "", "op": "",
            "left": anp_subst_ident_expr(stmt.left, old_name, new_name),
            "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    if k == "ReturnStmt" {
        return #{
            "kind": "ReturnStmt", "name": "", "value": "", "op": "",
            "left": anp_subst_ident_expr(stmt.left, old_name, new_name),
            "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    if k == "ForStmt" {
        let new_body = anp_subst_ident_body(stmt.body, old_name, new_name)
        let new_iter = anp_subst_ident_expr(stmt.iter_expr, old_name, new_name)
        return #{
            "kind": "ForStmt", "name": stmt.name, "value": "", "op": "",
            "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": new_body, "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": new_iter, "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    if k == "WhileStmt" {
        let new_body = anp_subst_ident_body(stmt.body, old_name, new_name)
        let new_cond = anp_subst_ident_expr(stmt.cond, old_name, new_name)
        return #{
            "kind": "WhileStmt", "name": "", "value": "", "op": "",
            "left": "", "right": "", "cond": new_cond, "then_body": "", "else_body": "",
            "params": "", "body": new_body, "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    if k == "IfStmt" {
        let new_cond = anp_subst_ident_expr(stmt.cond, old_name, new_name)
        let new_then = anp_subst_ident_body(stmt.then_body, old_name, new_name)
        let new_else = anp_subst_ident_body(stmt.else_body, old_name, new_name)
        return #{
            "kind": "IfStmt", "name": "", "value": "", "op": "",
            "left": "", "right": "", "cond": new_cond, "then_body": new_then, "else_body": new_else,
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    return stmt
}

fn anp_subst_ident_body(body, old_name, new_name) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        out.push(anp_subst_ident(body[i], old_name, new_name))
        i = i + 1
    }
    return out
}

fn anp_apply_fusion(loop1, loop2) {
    let mut merged_body = []
    let mut i = 0
    while i < len(loop1.body) {
        merged_body.push(loop1.body[i])
        i = i + 1
    }
    let need_subst = loop1.name != loop2.name
    let mut j = 0
    while j < len(loop2.body) {
        if need_subst {
            merged_body.push(anp_subst_ident(loop2.body[j], loop2.name, loop1.name))
        } else {
            merged_body.push(loop2.body[j])
        }
        j = j + 1
    }
    return #{
        "kind": "ForStmt", "name": loop1.name, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": merged_body, "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": loop1.iter_expr, "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

fn anp_fusion_body(body) {
    if type_of(body) != "array" { return body }
    let n = len(body)
    if n < 2 { return body }
    let mut out = []
    let mut i = 0
    while i < n {
        if i + 1 < n {
            let cur = body[i]
            let nxt = body[i + 1]
            if cur.kind == "ForStmt" && nxt.kind == "ForStmt" {
                if anp_detect_fusion(cur, nxt) {
                    m979_fusion_candidates = m979_fusion_candidates + 1
                    let fused = anp_apply_fusion(cur, nxt)
                    m979_fusion_applied = m979_fusion_applied + 1
                    out.push(fused)
                    i = i + 2
                } else {
                    out.push(cur)
                    i = i + 1
                }
            } else {
                out.push(cur)
                i = i + 1
            }
        } else {
            out.push(body[i])
            i = i + 1
        }
    }
    if len(out) < n {
        return anp_fusion_body(out)
    }
    return out
}

fn t_rewrite_fn_with_body(fn_node, new_body) {
    return #{
        "kind": "FnDecl", "name": fn_node.name, "value": fn_node.value, "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": fn_node.params, "body": new_body, "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": fn_node.ret_type,
        "target": "", "trait_name": "", "methods": ""
    }
}

fn anp_fusion_pass(ast) {
    m979_fusion_candidates = 0
    m979_fusion_applied = 0
    let mut out = []
    let n = len(ast)
    let mut i = 0
    while i < n {
        let node = ast[i]
        if node.kind == "FnDecl" {
            let before = m979_fusion_applied
            let new_body = anp_fusion_body(node.body)
            if m979_fusion_applied > before {
                out.push(t_rewrite_fn_with_body(node, new_body))
            } else {
                out.push(node)
            }
        } else {
            out.push(node)
        }
        i = i + 1
    }
    if m979_fusion_applied > 0 {
        println("[ai-native] loop-fusion: " + to_string(m979_fusion_candidates) + " candidate(s), " + to_string(m979_fusion_applied) + " fused")
    }
    return out
}

// ── AST node helpers ────────────────────────────────────────

fn mk_ident(name) {
    return #{
        "kind": "Ident", "name": name, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

fn mk_int(val) {
    return #{
        "kind": "IntLit", "name": "", "value": to_string(val), "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

fn mk_range(lo, hi) {
    return #{
        "kind": "Range", "name": "", "value": "exclusive", "op": "",
        "left": lo, "right": hi, "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

fn mk_range_incl(lo, hi) {
    return #{
        "kind": "Range", "name": "", "value": "inclusive", "op": "",
        "left": lo, "right": hi, "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

fn mk_binop(op, l, r) {
    return #{
        "kind": "BinOp", "name": "", "value": "", "op": op,
        "left": l, "right": r, "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

fn mk_index(arr, idx) {
    return #{
        "kind": "Index", "name": "", "value": "", "op": "",
        "left": arr, "right": idx, "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

fn mk_assign(lhs, rhs) {
    return #{
        "kind": "AssignStmt", "name": "", "value": "", "op": "=",
        "left": lhs, "right": rhs, "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

fn mk_let_mut(name, init) {
    return #{
        "kind": "LetMutStmt", "name": name, "value": "", "op": "",
        "left": init, "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

fn mk_for(var_name, iter_expr, body) {
    return #{
        "kind": "ForStmt", "name": var_name, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": body, "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": iter_expr, "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

fn mk_fn(name, body) {
    return #{
        "kind": "FnDecl", "name": name, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": [], "body": body, "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

fn mk_return(expr) {
    return #{
        "kind": "ReturnStmt", "name": "", "value": "", "op": "",
        "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

