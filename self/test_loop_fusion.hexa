println("")

// ── anp_expr_equal tests ────────────────────────────────────

println("--- anp_expr_equal ---")

check("expr_equal: same ident", anp_expr_equal(mk_ident("x"), mk_ident("x")))
check("expr_equal: diff ident", anp_expr_equal(mk_ident("x"), mk_ident("y")) == false)
check("expr_equal: same int", anp_expr_equal(mk_int(10), mk_int(10)))
check("expr_equal: diff int", anp_expr_equal(mk_int(10), mk_int(20)) == false)
check("expr_equal: same binop", anp_expr_equal(mk_binop("+", mk_ident("n"), mk_int(1)), mk_binop("+", mk_ident("n"), mk_int(1))))
check("expr_equal: diff binop op", anp_expr_equal(mk_binop("+", mk_ident("n"), mk_int(1)), mk_binop("-", mk_ident("n"), mk_int(1))) == false)
check("expr_equal: same range", anp_expr_equal(mk_range(mk_int(0), mk_ident("n")), mk_range(mk_int(0), mk_ident("n"))))
check("expr_equal: diff range end", anp_expr_equal(mk_range(mk_int(0), mk_ident("n")), mk_range(mk_int(0), mk_ident("m"))) == false)
check("expr_equal: excl vs incl", anp_expr_equal(mk_range(mk_int(0), mk_int(10)), mk_range_incl(mk_int(0), mk_int(10))) == false)

println("")
println("--- anp_detect_fusion ---")

fn make_arr_assign(arr, idx, rhs_arr, rhs_idx, op_val) {
    return mk_assign(mk_index(mk_ident(arr), mk_ident(idx)), mk_binop(op_val, mk_index(mk_ident(rhs_arr), mk_ident(rhs_idx)), mk_int(1)))
}

let range_0_n = mk_range(mk_int(0), mk_ident("n"))
let loop1_body = [make_arr_assign("a", "i", "b", "i", "+")]
let loop2_body = [make_arr_assign("c", "i", "a", "i", "*")]
let lp1 = mk_for("i", range_0_n, loop1_body)
let lp2 = mk_for("i", range_0_n, loop2_body)
check("detect_fusion: basic fusible", anp_detect_fusion(lp1, lp2))

let range_0_m = mk_range(mk_int(0), mk_ident("m"))
let lp3 = mk_for("i", range_0_m, loop2_body)
check("detect_fusion: diff range rejects", anp_detect_fusion(lp1, lp3) == false)

let range_0_n_incl = mk_range_incl(mk_int(0), mk_ident("n"))
let lp4 = mk_for("i", range_0_n_incl, loop2_body)
check("detect_fusion: excl vs incl rejects", anp_detect_fusion(lp1, lp4) == false)

let waw_body1 = [mk_assign(mk_ident("sum"), mk_binop("+", mk_ident("sum"), mk_ident("i")))]
let waw_body2 = [mk_assign(mk_ident("sum"), mk_binop("*", mk_ident("sum"), mk_int(2)))]
let lp_waw1 = mk_for("i", range_0_n, waw_body1)
let lp_waw2 = mk_for("i", range_0_n, waw_body2)
check("detect_fusion: scalar WAW rejects", anp_detect_fusion(lp_waw1, lp_waw2) == false)

let iter_write_body = [mk_assign(mk_ident("i"), mk_int(0))]
let lp_iter_write = mk_for("j", range_0_n, iter_write_body)
check("detect_fusion: iter var write rejects", anp_detect_fusion(lp1, lp_iter_write) == false)

let loop2_body_j = [make_arr_assign("c", "j", "a", "j", "*")]
let lp_j = mk_for("j", range_0_n, loop2_body_j)
check("detect_fusion: diff iter var fusible", anp_detect_fusion(lp1, lp_j))

println("")
println("--- anp_apply_fusion ---")

let fused = anp_apply_fusion(lp1, lp2)
check("apply_fusion: kind is ForStmt", fused.kind == "ForStmt")
check("apply_fusion: body len is 2", len(fused.body) == 2)
check("apply_fusion: iter var is i", fused.name == "i")

let fused_subst = anp_apply_fusion(lp1, lp_j)
check_eq("apply_fusion: subst body len", len(fused_subst.body), 2)
let stmt2 = fused_subst.body[1]
check("apply_fusion: subst iter var in body", stmt2.left.right.kind == "Ident" && stmt2.left.right.name == "i")

println("")
println("--- anp_fusion_body ---")

m979_fusion_candidates = 0
m979_fusion_applied = 0
let body_2loops = [lp1, lp2]
let fused_body = anp_fusion_body(body_2loops)
check_eq("fusion_body: 2->1 loop", len(fused_body), 1)
check("fusion_body: result is ForStmt", fused_body[0].kind == "ForStmt")
check_eq("fusion_body: merged body len", len(fused_body[0].body), 2)

m979_fusion_candidates = 0
m979_fusion_applied = 0
let loop3_body = [make_arr_assign("d", "i", "c", "i", "+")]
let lp3c = mk_for("i", range_0_n, loop3_body)
let body_3loops = [lp1, lp2, lp3c]
let fused_body3 = anp_fusion_body(body_3loops)
check_eq("fusion_body: 3->1 loop", len(fused_body3), 1)
check_eq("fusion_body: 3-chain body len", len(fused_body3[0].body), 3)

m979_fusion_candidates = 0
m979_fusion_applied = 0
let intervening = mk_let_mut("tmp", mk_int(0))
let body_interv = [lp1, intervening, lp2]
let fused_interv = anp_fusion_body(body_interv)
check_eq("fusion_body: intervening stmt blocks", len(fused_interv), 3)

m979_fusion_candidates = 0
m979_fusion_applied = 0
let body_single = [lp1]
let fused_single = anp_fusion_body(body_single)
check_eq("fusion_body: single loop unchanged", len(fused_single), 1)

println("")
println("--- anp_fusion_pass (top-level) ---")

m979_fusion_candidates = 0
m979_fusion_applied = 0
let fn_node = mk_fn("process", [lp1, lp2])
let ast = [fn_node]
let result = anp_fusion_pass(ast)
check_eq("fusion_pass: fn count", len(result), 1)
check("fusion_pass: rewritten fn", result[0].kind == "FnDecl")
check_eq("fusion_pass: fused body len", len(result[0].body), 1)
check("fusion_pass: counter > 0", m979_fusion_applied > 0)

m979_fusion_candidates = 0
m979_fusion_applied = 0
let other_node = mk_let_mut("global", mk_int(42))
let ast2 = [other_node, fn_node]
let result2 = anp_fusion_pass(ast2)
check_eq("fusion_pass: preserves other nodes", len(result2), 2)
check("fusion_pass: first node kept", result2[0].kind == "LetMutStmt")

m979_fusion_candidates = 0
m979_fusion_applied = 0
let loop4_body = [make_arr_assign("e", "i", "d", "i", "*")]
let lp4c = mk_for("i", range_0_n, loop4_body)
let fn_4chain = mk_fn("chain4", [lp1, lp2, lp3c, lp4c])
let res4 = anp_fusion_pass([fn_4chain])
check_eq("fusion_pass: 4-chain body count", len(res4[0].body), 1)
check_eq("fusion_pass: 4-chain body len", len(res4[0].body[0].body), 4)

m979_fusion_candidates = 0
m979_fusion_applied = 0
let fn_mixed = mk_fn("mixed", [lp1, lp2, intervening, lp3c])
let res_mixed = anp_fusion_pass([fn_mixed])
check_eq("fusion_pass: mixed result", len(res_mixed[0].body), 3)

m979_fusion_candidates = 0
m979_fusion_applied = 0
let lp_empty1 = mk_for("i", range_0_n, [])
let lp_empty2 = mk_for("i", range_0_n, [])
let fn_empty = mk_fn("empty_pair", [lp_empty1, lp_empty2])
let res_empty = anp_fusion_pass([fn_empty])
check_eq("fusion_pass: empty bodies fuse", len(res_empty[0].body), 1)

m979_fusion_candidates = 0
m979_fusion_applied = 0
let complex_range = mk_range(mk_binop("+", mk_ident("n"), mk_int(1)), mk_binop("*", mk_ident("n"), mk_int(2)))
let lp_cx1 = mk_for("i", complex_range, loop1_body)
let lp_cx2 = mk_for("i", complex_range, loop2_body)
let fn_cx = mk_fn("complex_range", [lp_cx1, lp_cx2])
let res_cx = anp_fusion_pass([fn_cx])
check_eq("fusion_pass: complex range fuses", len(res_cx[0].body), 1)

m979_fusion_candidates = 0
m979_fusion_applied = 0
let fn_noloop = mk_fn("noloop", [mk_return(mk_int(0))])
let res_noloop = anp_fusion_pass([fn_noloop])
check_eq("fusion_pass: no loops unchanged", len(res_noloop[0].body), 1)
check_eq("fusion_pass: no fusion counter", m979_fusion_applied, 0)

m979_fusion_candidates = 0
m979_fusion_applied = 0
let inner_loop = mk_for("j", mk_range(mk_int(0), mk_ident("m")), [make_arr_assign("x", "j", "y", "j", "+")])
let outer1 = mk_for("i", range_0_n, [inner_loop])
let outer2 = mk_for("i", range_0_n, [make_arr_assign("z", "i", "w", "i", "*")])
let fn_nested = mk_fn("nested", [outer1, outer2])
let res_nested = anp_fusion_pass([fn_nested])
check_eq("fusion_pass: nested inner preserved", len(res_nested[0].body), 1)
check_eq("fusion_pass: nested fused body", len(res_nested[0].body[0].body), 2)

m979_fusion_candidates = 0
m979_fusion_applied = 0
let incl_range = mk_range_incl(mk_int(1), mk_ident("n"))
let lp_incl1 = mk_for("i", incl_range, loop1_body)
let lp_incl2 = mk_for("i", incl_range, loop2_body)
let fn_incl = mk_fn("inclusive_fuse", [lp_incl1, lp_incl2])
let res_incl = anp_fusion_pass([fn_incl])
check_eq("fusion_pass: inclusive range fuses", len(res_incl[0].body), 1)

println("")
println("=====================================================")
println("  Loop Fusion: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("=====================================================")
if fail_count > 0 {
    println("FAIL")
} else {
    println("ALL PASS")
}
