// Test: lexer -> parser -> compiler -> bytecode disassembly
// Verifies the bytecode compilation path works end-to-end

let lexer_src = read_file("ready/self/lexer.hexa")
let parser_src = read_file("ready/self/parser.hexa")
let compiler_src = read_file("ready/self/compiler.hexa")

let tests = ["let x = 42\nprintln(x)", "fn add(a, b) {\n    return a + b\n}\nprintln(add(3, 4))"]
let names = ["simple let+println", "function call"]

let mut pass = 0
let mut i = 0
while i < len(tests) {
    let test_src = tests[i]
    let name = names[i]
    let driver = lexer_src + "\n" + parser_src + "\n" + compiler_src + "\n"
    driver = driver + "let __src = read_file(\"/tmp/__hexa_bc_test.hexa\")\n"
    driver = driver + "let __tokens = tokenize(__src)\n"
    driver = driver + "let __ast = parse(__tokens)\n"
    driver = driver + "let __code = compile(__ast)\n"
    driver = driver + "let __consts = get_constants()\n"
    driver = driver + "let __fns = get_functions()\n"
    driver = driver + "println(\"===BC_START===\")\n"
    driver = driver + "disassemble_all(__code, __consts, __fns)\n"
    driver = driver + "println(\"===BC_END===\")\n"
    write_file("/tmp/__hexa_bc_test.hexa", test_src)
    write_file("/tmp/__hexa_bc_driver.hexa", driver)
    let result = exec("./target/release/hexa /tmp/__hexa_bc_driver.hexa 2>&1")
    if result.contains("===BC_START===") {
        println("PASS: " + name)
        pass = pass + 1
    } else {
        println("FAIL: " + name + " — " + result.split("\n")[0])
    }
    i = i + 1
}
println(format("Bytecode pipeline: {} / {} PASS", pass, len(tests)))
