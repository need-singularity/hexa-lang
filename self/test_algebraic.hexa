// ================================================================
//  test_algebraic.hexa — M976 @algebraic closed-form series rewrite
//  Validates that @algebraic detects loop-based summation patterns
//  and rewrites them to O(1) closed-form expressions.
//
//  ROI id=7, P2, effect 5x: O(n) loop → O(1) formula.
//
//  Patterns:
//    1. Arithmetic series:  sum(1..n) → n*(n+1)/2  (Gauss)
//    2. Sum of squares:     sum(i^2)  → n*(n+1)*(2n+1)/6
//    3. Geometric series:   sum(a*r^i) → a*(r^n-1)/(r-1)
// ================================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("================================================================")
println("  HEXA M976: @algebraic closed-form series rewrite")
println("  Loop-based summation → O(1) closed form")
println("================================================================")
println("")

// ══════════════════════════════════════════════════════════════
//  SECTION 1: Arithmetic series — sum(1..n) = n*(n+1)/2
//  @algebraic triggers M976 pattern detection:
//    let mut s = 0; let mut i = 1;
//    while i <= n { s = s + i; i = i + 1 }
//    return s
//  → return n * (n + 1) / 2
// ══════════════════════════════════════════════════════════════

println("--- Section 1: Arithmetic series sum(1..n) ---")

@algebraic fn sum_1_to_n(n) {
    let mut s = 0
    let mut i = 1
    while i <= n {
        s = s + i
        i = i + 1
    }
    return s
}

// Reference: manual Gauss formula
fn gauss(n) {
    return n * (n + 1) / 2
}

// Correctness: small values
check("M976 sum(0)", sum_1_to_n(0), 0)
check("M976 sum(1)", sum_1_to_n(1), 1)
check("M976 sum(2)", sum_1_to_n(2), 3)
check("M976 sum(3)", sum_1_to_n(3), 6)
check("M976 sum(5)", sum_1_to_n(5), 15)
check("M976 sum(10)", sum_1_to_n(10), 55)
check("M976 sum(100)", sum_1_to_n(100), 5050)

// Equivalence: rewrite == Gauss for 0..50
let mut gauss_ok = true
let mut gi = 0
while gi <= 50 {
    if sum_1_to_n(gi) != gauss(gi) { gauss_ok = false }
    gi = gi + 1
}
check("M976 sum==gauss 0..50", gauss_ok, true)

// Large value
check("M976 sum(1000)", sum_1_to_n(1000), 500500)

println("")

// ══════════════════════════════════════════════════════════════
//  SECTION 2: Sum of squares — sum(i^2, i=1..n) = n*(n+1)*(2n+1)/6
// ══════════════════════════════════════════════════════════════

println("--- Section 2: Sum of squares ---")

@algebraic fn sum_squares(n) {
    let mut s = 0
    let mut i = 1
    while i <= n {
        s = s + i * i
        i = i + 1
    }
    return s
}

fn closed_sq(n) {
    return n * (n + 1) * (2 * n + 1) / 6
}

check("M976 sq(0)", sum_squares(0), 0)
check("M976 sq(1)", sum_squares(1), 1)
check("M976 sq(2)", sum_squares(2), 5)
check("M976 sq(3)", sum_squares(3), 14)
check("M976 sq(5)", sum_squares(5), 55)
check("M976 sq(10)", sum_squares(10), 385)

// Equivalence
let mut sq_ok = true
let mut si = 0
while si <= 30 {
    if sum_squares(si) != closed_sq(si) { sq_ok = false }
    si = si + 1
}
check("M976 sq==closed 0..30", sq_ok, true)

println("")

// ══════════════════════════════════════════════════════════════
//  SECTION 3: Geometric series — sum(a * r^0 + a * r^1 + ... )
//  = a * (r^n - 1) / (r - 1)
// ══════════════════════════════════════════════════════════════

println("--- Section 3: Geometric series ---")

@algebraic fn geo_sum(n) {
    let mut s = 0
    let mut term = 1
    let mut i = 0
    while i < n {
        s = s + term
        term = term * 2
        i = i + 1
    }
    return s
}

// Manual geometric: 1 + 2 + 4 + ... + 2^(n-1) = 2^n - 1
fn manual_geo(n) {
    let mut p = 1
    let mut i = 0
    while i < n {
        p = p * 2
        i = i + 1
    }
    return p - 1
}

check("M976 geo(0)", geo_sum(0), 0)
check("M976 geo(1)", geo_sum(1), 1)
check("M976 geo(2)", geo_sum(2), 3)
check("M976 geo(3)", geo_sum(3), 7)
check("M976 geo(4)", geo_sum(4), 15)
check("M976 geo(5)", geo_sum(5), 31)
check("M976 geo(10)", geo_sum(10), 1023)

// Equivalence
let mut geo_ok = true
let mut gei = 1
while gei <= 15 {
    if geo_sum(gei) != manual_geo(gei) { geo_ok = false }
    gei = gei + 1
}
check("M976 geo==manual 1..15", geo_ok, true)

println("")

// ══════════════════════════════════════════════════════════════
//  SECTION 4: Geometric series with ratio 3
// ══════════════════════════════════════════════════════════════

println("--- Section 4: Geometric series ratio=3 ---")

@algebraic fn geo_sum_3(n) {
    let mut s = 0
    let mut term = 1
    let mut i = 0
    while i < n {
        s = s + term
        term = term * 3
        i = i + 1
    }
    return s
}

// 1 + 3 + 9 + 27 = 40
check("M976 geo3(0)", geo_sum_3(0), 0)
check("M976 geo3(1)", geo_sum_3(1), 1)
check("M976 geo3(2)", geo_sum_3(2), 4)
check("M976 geo3(3)", geo_sum_3(3), 13)
check("M976 geo3(4)", geo_sum_3(4), 40)

println("")

// ══════════════════════════════════════════════════════════════
//  SECTION 5: Non-matching patterns (should NOT be rewritten)
// ══════════════════════════════════════════════════════════════

println("--- Section 5: Non-matching patterns ---")

// Product (not additive accumulation) — should not match
@algebraic fn product_loop(n) {
    let mut p = 1
    let mut i = 1
    while i <= n {
        p = p * i
        i = i + 1
    }
    return p
}

check("M976 product(5) = 120", product_loop(5), 120)
check("M976 product(1) = 1", product_loop(1), 1)

// Non-linear accumulation (acc += arr[i]) — should not match
@algebraic fn arr_sum(arr) {
    let mut s = 0
    let mut i = 0
    while i < len(arr) {
        s = s + arr[i]
        i = i + 1
    }
    return s
}

check("M976 arr_sum [1,2,3]", arr_sum([1, 2, 3]), 6)
check("M976 arr_sum [10,20]", arr_sum([10, 20]), 30)

println("")

// ── Summary ──
println("================================================================")
println("  M976 algebraic series: " + to_string(pass_count) + " PASS, " + to_string(fail_count) + " FAIL")
println("================================================================")

if fail_count > 0 {
    println("SOME TESTS FAILED")
}
