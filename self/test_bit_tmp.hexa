use "runtime/bit_pure"

// Test rotate_left_pure with values that have sign bit
let v = 0 - 1  // all bits set
let r = rotate_left_pure(v, 13, 64)
println("rotl(-1, 13, 64) = " + to_string(r))  // should be -1 (all bits)

// Test with a specific value
