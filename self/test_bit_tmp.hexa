let v0_init = 8317987319222330229  // 0x736f6d6570736575
println("v0_init = " + to_string(v0_init))

// 0x646f72616e646f6d = 7237128888997146989
let v1_init = 7237128888997146989
println("v1_init = " + to_string(v1_init))

