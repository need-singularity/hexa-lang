// ═══════════════════════════════════════════════════════════
//  test_data_structures.hexa — Complex Data Structure Tests
//  Tests: nested maps, array of maps, map of arrays, stack/queue
//         via arrays, graph representation, table/matrix ops,
//         tree-like structures, accumulation patterns
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA Complex Data Structure Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Nested maps ───────────────────────────────────────

println("--- Nested Maps ---")

let config = #{
    "db": #{"host": "localhost", "port": "5432"},
    "app": #{"name": "hexa", "version": "2.0"}
}
check("nested map db host", config["db"]["host"], "localhost")
check("nested map db port", config["db"]["port"], "5432")
check("nested map app name", config["app"]["name"], "hexa")

// ── 2. Array of maps ────────────────────────────────────

println("")
println("--- Array of Maps ---")

let users = [
    #{"name": "Alice", "score": "95"},
    #{"name": "Bob", "score": "87"},
    #{"name": "Carol", "score": "92"}
]
check("users len", len(users), 3)
check("users[0] name", users[0]["name"], "Alice")
check("users[1] score", users[1]["score"], "87")
check("users[2] name", users[2]["name"], "Carol")

// ── 3. Map of arrays ────────────────────────────────────

println("")
println("--- Map of Arrays ---")

let mut groups = #{}
groups["fruits"] = ["apple", "banana", "cherry"]
groups["vegs"] = ["carrot", "pea"]
check("group fruits len", len(groups["fruits"]), 3)
check("group fruits[0]", groups["fruits"][0], "apple")
check("group vegs[1]", groups["vegs"][1], "pea")

// ── 4. Stack via array (push/pop pattern) ─────────────────

println("")
println("--- Stack Pattern ---")

let mut stack = []
stack = stack.push(10)
stack = stack.push(20)
stack = stack.push(30)
check("stack len", len(stack), 3)
check("stack top", stack[len(stack) - 1], 30)

// pop simulation
let top = stack[len(stack) - 1]
let mut new_stack = []
let mut si = 0
while si < len(stack) - 1 {
    new_stack = new_stack.push(stack[si])
    si = si + 1
}
stack = new_stack
check("after pop top", top, 30)
check("after pop len", len(stack), 2)
check("after pop new top", stack[len(stack) - 1], 20)

// ── 5. Queue via array ───────────────────────────────────

println("")
println("--- Queue Pattern ---")

let mut queue = []
queue = queue.push("first")
queue = queue.push("second")
queue = queue.push("third")
check("queue len", len(queue), 3)
check("queue front", queue[0], "first")

// dequeue simulation
let front = queue[0]
let mut new_queue = []
let mut qi = 1
while qi < len(queue) {
    new_queue = new_queue.push(queue[qi])
    qi = qi + 1
}
queue = new_queue
check("dequeued", front, "first")
check("queue after deq len", len(queue), 2)
check("queue new front", queue[0], "second")

// ── 6. Matrix operations ─────────────────────────────────

println("")
println("--- Matrix Ops ---")

let mat = [[1, 2, 3], [4, 5, 6], [7, 8, 9]]

// Row sum
fn row_sum(m, r) {
    let mut s = 0
    let mut c = 0
    while c < len(m[r]) {
        s = s + m[r][c]
        c = c + 1
    }
    return s
}
check("row 0 sum", row_sum(mat, 0), 6)
check("row 1 sum", row_sum(mat, 1), 15)
check("row 2 sum", row_sum(mat, 2), 24)

// Column sum
fn col_sum(m, c) {
    let mut s = 0
    let mut r = 0
    while r < len(m) {
        s = s + m[r][c]
        r = r + 1
    }
    return s
}
check("col 0 sum", col_sum(mat, 0), 12)
check("col 1 sum", col_sum(mat, 1), 15)
check("col 2 sum", col_sum(mat, 2), 18)

// Diagonal sum
fn diag_sum(m) {
    let mut s = 0
    let mut i = 0
    while i < len(m) {
        s = s + m[i][i]
        i = i + 1
    }
    return s
}
check("diag sum", diag_sum(mat), 15)

// ── 7. Frequency counter ─────────────────────────────────

println("")
println("--- Frequency Counter ---")

let words = ["apple", "banana", "apple", "cherry", "banana", "apple"]
let mut freq = #{}
let mut wi = 0
while wi < len(words) {
    let w = words[wi]
    if freq.contains_key(w) {
        freq[w] = freq[w] + 1
    } else {
        freq[w] = 1
    }
    wi = wi + 1
}
check("freq apple", freq["apple"], 3)
check("freq banana", freq["banana"], 2)
check("freq cherry", freq["cherry"], 1)

// ── 8. Graph as adjacency list ───────────────────────────

println("")
println("--- Graph Adjacency ---")

let mut graph = #{}
graph["A"] = ["B", "C"]
graph["B"] = ["A", "D"]
graph["C"] = ["A"]
graph["D"] = ["B"]

check("A neighbors len", len(graph["A"]), 2)
check("A neighbors[0]", graph["A"][0], "B")
check("B neighbors len", len(graph["B"]), 2)
check("D neighbors[0]", graph["D"][0], "B")

// Degree count
fn degree(g, node) {
    return len(g[node])
}
check("degree A", degree(graph, "A"), 2)
check("degree C", degree(graph, "C"), 1)
check("degree D", degree(graph, "D"), 1)

// ── 9. Lookup table ──────────────────────────────────────

println("")
println("--- Lookup Table ---")

let roman = #{"I": 1, "V": 5, "X": 10, "L": 50, "C": 100}
check("roman I", roman["I"], 1)
check("roman V", roman["V"], 5)
check("roman C", roman["C"], 100)

fn roman_sum(table, chars) {
    let mut s = 0
    let mut i = 0
    while i < len(chars) {
        s = s + table[chars[i]]
        i = i + 1
    }
    return s
}
check("roman XVI", roman_sum(roman, ["X", "V", "I"]), 16)
check("roman LX", roman_sum(roman, ["L", "X"]), 60)

// ── 10. Accumulator map ──────────────────────────────────

println("")
println("--- Accumulator Map ---")

let data = [
    #{"cat": "A", "val": "10"},
    #{"cat": "B", "val": "20"},
    #{"cat": "A", "val": "30"},
    #{"cat": "B", "val": "5"},
    #{"cat": "A", "val": "15"}
]

let mut sums = #{}
let mut di = 0
while di < len(data) {
    let cat = data[di]["cat"]
    let val = to_int(data[di]["val"])
    if sums.contains_key(cat) {
        sums[cat] = sums[cat] + val
    } else {
        sums[cat] = val
    }
    di = di + 1
}
check("accum A", sums["A"], 55)
check("accum B", sums["B"], 25)

// ── Summary ──────────────────────────────────────────────

println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    throw "TESTS FAILED: " + to_string(fail_count)
}
