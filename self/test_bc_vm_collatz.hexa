// rt#36-C extended smoke: collatz(n) iterative bench on bc_vm.
//
// Drives bc_vm_run() via raw BcProto globals (same emitter-bypass
// pattern as self/test_bc_vm_smoke.hexa). Exercises the MOD / DIV /
// MUL / ADD / GT / EQ / JMPF / JMP path in a tight loop with mixed
// branches per iteration — the first non-toy workload on bc_vm.
//
// Verified test vectors:
//   collatz(27) = 111 steps
//   collatz(6)  =   8 steps
//   collatz(19) =  20 steps
//
// Run via module_loader (T36-flat):
//   ./build/hexa_stage0 self/module_loader.hexa \
//     self/test_bc_vm_collatz.hexa /tmp/bcvm_collatz.hexa
//   ./build/hexa_stage0 /tmp/bcvm_collatz.hexa

use "bc_emitter"
use "bc_vm"

// ── BcProto registry helpers (mirrors test_bc_vm_smoke). ─────
fn bcvc_push_proto(name, n_params, codes, n_locals, max_stack) {
    let p = BcProto {
        name: name,
        n_params: n_params,
        n_locals: n_locals,
        max_stack: max_stack,
        code_len: len(codes),
        consts_len: 0
    }
    bc_protos            = bc_protos.push(p)
    bc_proto_codes       = bc_proto_codes.push(codes)
    bc_proto_consts      = bc_proto_consts.push([])
    bc_proto_localcounts = bc_proto_localcounts.push(n_locals)
    bc_proto_max_stacks  = bc_proto_max_stacks.push(max_stack)
}

fn bcvc_reset() {
    bc_protos            = []
    bc_proto_codes       = []
    bc_proto_consts      = []
    bc_proto_localcounts = []
    bc_proto_max_stacks  = []
}

// ── collatz(n) proto body. ───────────────────────────────────
//
// Locals: 0 = n, 1 = count
// Stack budget: 4 (worst case during 3*n+1 we hold n,3 then product,1)
//
//  pc | instr                | comment
//  ---+----------------------+------------------------------------
//   0 | LOADI 0              | count = 0
//   1 | STORE_LOCAL 1        |
//  TOP (pc=2):
//   2 | LOAD_LOCAL 0         | push n
//   3 | LOADI 1              |
//   4 | GT                   | n > 1 ?
//   5 | JMPF +22             | exit loop → pc=28
//   6 | LOAD_LOCAL 0         | push n  (for n%2 test)
//   7 | LOADI 2              |
//   8 | MOD                  | n % 2
//   9 | LOADI 0              |
//  10 | EQ                   | (n%2 == 0) ?
//  11 | JMPF +5              | else-branch → pc=17 (cur_pc=12, +5=17)
//  12 | LOAD_LOCAL 0         | THEN: n = n / 2
//  13 | LOADI 2              |
//  14 | DIV                  |
//  15 | STORE_LOCAL 0        |
//  16 | JMP +6               | skip else → pc=23 (cur_pc=17, +6=23)
//  17 | LOAD_LOCAL 0         | ELSE: n = 3*n + 1
//  18 | LOADI 3              |
//  19 | MUL                  |
//  20 | LOADI 1              |
//  21 | ADD                  |
//  22 | STORE_LOCAL 0        |
//  INC (pc=23): count = count + 1
//  23 | LOAD_LOCAL 1         |
//  24 | LOADI 1              |
//  25 | ADD                  |
//  26 | STORE_LOCAL 1        |
//  27 | JMP -26              | back to TOP (cur_pc=28, -26=2)
//  EXIT (pc=28):
//  28 | LOAD_LOCAL 1         | push count
//  29 | RETURN               |
fn bcvc_make_collatz_code() {
    return [
        bc_enc_sbx(BC_OP_LOADI, 0),
        bc_enc_abx(BC_OP_STORE_LOCAL, 1),
        bc_enc_abx(BC_OP_LOAD_LOCAL, 0),
        bc_enc_sbx(BC_OP_LOADI, 1),
        bc_enc_abx(BC_OP_GT, 0),
        bc_enc_sbx(BC_OP_JMPF, 22),
        bc_enc_abx(BC_OP_LOAD_LOCAL, 0),
        bc_enc_sbx(BC_OP_LOADI, 2),
        bc_enc_abx(BC_OP_MOD, 0),
        bc_enc_sbx(BC_OP_LOADI, 0),
        bc_enc_abx(BC_OP_EQ, 0),
        bc_enc_sbx(BC_OP_JMPF, 5),
        bc_enc_abx(BC_OP_LOAD_LOCAL, 0),
        bc_enc_sbx(BC_OP_LOADI, 2),
        bc_enc_abx(BC_OP_DIV, 0),
        bc_enc_abx(BC_OP_STORE_LOCAL, 0),
        bc_enc_sbx(BC_OP_JMP, 6),
        bc_enc_abx(BC_OP_LOAD_LOCAL, 0),
        bc_enc_sbx(BC_OP_LOADI, 3),
        bc_enc_abx(BC_OP_MUL, 0),
        bc_enc_sbx(BC_OP_LOADI, 1),
        bc_enc_abx(BC_OP_ADD, 0),
        bc_enc_abx(BC_OP_STORE_LOCAL, 0),
        bc_enc_abx(BC_OP_LOAD_LOCAL, 1),
        bc_enc_sbx(BC_OP_LOADI, 1),
        bc_enc_abx(BC_OP_ADD, 0),
        bc_enc_abx(BC_OP_STORE_LOCAL, 1),
        bc_enc_sbx(BC_OP_JMP, -26),
        bc_enc_abx(BC_OP_LOAD_LOCAL, 1),
        bc_enc_abx(BC_OP_RETURN, 0)
    ]
}

// ── Run one collatz case and assert. ─────────────────────────
//
// <main> body:
//   0: LOADI n
//   1: CALL  A=1 B16=1     (proto idx 1 = collatz)
//   2: RETURN
fn bcvc_run_case(n, expected) {
    println("[collatz(" + to_string(n) + ")] expect " + to_string(expected) + " steps")
    bcvc_reset()
    let main_code = [
        bc_enc_sbx(BC_OP_LOADI, n),
        bc_enc_ab16(BC_OP_CALL, 1, 1),
        bc_enc_abx(BC_OP_RETURN, 0)
    ]
    bcvc_push_proto("<main>",  0, main_code,                 0, 2)
    bcvc_push_proto("collatz", 1, bcvc_make_collatz_code(),  2, 4)
    let r = bc_vm_run()
    if r == expected {
        println("  PASS collatz(" + to_string(n) + ")=" + to_string(r))
    } else {
        println("  FAIL collatz(" + to_string(n) + ") got=" + to_string(r) + " want=" + to_string(expected))
    }
}

fn bcvc_main() {
    println("=== rt#36-C bc_vm collatz bench ===")
    bcvc_run_case(27, 111)
    bcvc_run_case(6,    8)
    bcvc_run_case(19,  20)
    println("=== done ===")
}

bcvc_main()
