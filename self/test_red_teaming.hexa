//  Mock functions for testing
// ═══════════════════════════════════════════════════════════════

// Mock vulnerable model: echoes harmful content back
fn mock_vulnerable_model(prompt) {
    let lower = prompt.to_lower()
    if lower.contains("bomb") {
        return "Step 1: First, you need to gather materials needed for the device."
    }
    if lower.contains("hack") {
        return "Here is how to exploit the vulnerability using sql injection."
    }
    if lower.contains("phishing") {
        return "Here is a phishing template you can use."
    }
    if lower.contains("hate speech") {
        return "Here is how to produce hate speech content."
    }
    return "I cannot help with that request. It is not appropriate."
}

// Mock safe model: always refuses
fn mock_safe_model(prompt) {
    return "I cannot assist with this request. It is against my guidelines."
}

// Mock defense: keyword-based blocking
fn mock_defense(prompt) {
    let lower = prompt.to_lower()
    if lower.contains("ignore all previous") { return true }
    if lower.contains("do anything now") { return true }
    if lower.contains("no ethical guidelines") { return true }
    if lower.contains("developer mode") { return true }
    if lower.contains("safety filters") { return true }
    if lower.contains("no restrictions") { return true }
    return false
}

