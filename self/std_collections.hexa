// self/std_collections.hexa — HEXA COLLECTIONS ported from src/std_collections.rs
//
// Provides:
//   btree_new()                — create empty sorted map (array-based)
//   btree_set(bt, key, val)    — insert key-value
//   btree_get(bt, key)         — get value by key (void if missing)
//   btree_remove(bt, key)      — remove key
//   btree_keys(bt)             — sorted keys array
//   btree_len(bt)              — number of entries
//   pq_new()                   — create empty priority queue (min-heap)
//   pq_push(pq, priority, val) — push with priority
//   pq_pop(pq)                 — pop min-priority item
//   pq_len(pq)                 — number of items
//   deque_new()                — create empty deque
//   deque_push_front(dq, val)  — push to front
//   deque_push_back(dq, val)   — push to back
//   deque_pop_front(dq)        — pop from front
//   deque_pop_back(dq)         — pop from back
//   deque_len(dq)              — number of items

// ---- BTree (sorted array of [key, value] pairs) ----

struct BTree {
    entries: [string]
}

fn btree_new() -> BTree {
    return BTree { entries: [] }
}

fn btree_set(bt, key, val) -> BTree {
    let entries = bt.entries
    // Find position or update existing
    let i = 0
    while i < len(entries) {
        if entries[i][0] == key {
            entries[i] = [key, val]
            return BTree { entries: entries }
        }
        if entries[i][0] > key {
            // Insert before i (sorted order)
            let new_entries = []
            let j = 0
            while j < i {
                new_entries = array_push(new_entries, entries[j])
                j = j + 1
            }
            new_entries = array_push(new_entries, [key, val])
            while j < len(entries) {
                new_entries = array_push(new_entries, entries[j])
                j = j + 1
            }
            return BTree { entries: new_entries }
        }
        i = i + 1
    }
    // Append at end
    entries = array_push(entries, [key, val])
    return BTree { entries: entries }
}

fn btree_get(bt, key) {
    let i = 0
    while i < len(bt.entries) {
        if bt.entries[i][0] == key {
            return bt.entries[i][1]
        }
        i = i + 1
    }
    return void
}

fn btree_remove(bt, key) -> BTree {
    let entries = []
    let removed = void
    let i = 0
    while i < len(bt.entries) {
        if bt.entries[i][0] == key {
            removed = bt.entries[i][1]
        } else {
            entries = array_push(entries, bt.entries[i])
        }
        i = i + 1
    }
    return BTree { entries: entries }
}

fn btree_keys(bt) -> [string] {
    let keys = []
    let i = 0
    while i < len(bt.entries) {
        keys = array_push(keys, bt.entries[i][0])
        i = i + 1
    }
    return keys
}

fn btree_len(bt) -> int {
    return len(bt.entries)
}

// ---- Priority Queue (min-heap as array) ----

struct PriorityQueue {
    heap: [int],
    counter: int
}

fn pq_new() -> PriorityQueue {
    return PriorityQueue { heap: [], counter: 0 }
}

fn pq_push(pq, priority, val) -> PriorityQueue {
    let entry = [priority, pq.counter, val]
    let heap = array_push(pq.heap, entry)
    // Sift up
    let idx = len(heap) - 1
    while idx > 0 {
        let parent = (idx - 1) / 2
        if heap[idx][0] < heap[parent][0] {
            let tmp = heap[idx]
            heap[idx] = heap[parent]
            heap[parent] = tmp
            idx = parent
        } else {
            if heap[idx][0] == heap[parent][0] {
                if heap[idx][1] < heap[parent][1] {
                    let tmp = heap[idx]
                    heap[idx] = heap[parent]
                    heap[parent] = tmp
                    idx = parent
                } else {
                    idx = 0
                }
            } else {
                idx = 0
            }
        }
    }
    return PriorityQueue { heap: heap, counter: pq.counter + 1 }
}

fn pq_pop(pq) {
    if len(pq.heap) == 0 { return void }
    let top = pq.heap[0][2]
    let heap = pq.heap
    let last = len(heap) - 1
    heap[0] = heap[last]
    // Remove last element
    let new_heap = []
    let i = 0
    while i < last {
        new_heap = array_push(new_heap, heap[i])
        i = i + 1
    }
    // Sift down
    let idx = 0
    let size = len(new_heap)
    // @partial — Stage 0: pre-witness acknowledgement, refine in follow-up
    while true {
        let smallest = idx
        let left = 2 * idx + 1
        let right = 2 * idx + 2
        if left < size {
            if new_heap[left][0] < new_heap[smallest][0] { smallest = left }
            if new_heap[left][0] == new_heap[smallest][0] {
                if new_heap[left][1] < new_heap[smallest][1] { smallest = left }
            }
        }
        if right < size {
            if new_heap[right][0] < new_heap[smallest][0] { smallest = right }
            if new_heap[right][0] == new_heap[smallest][0] {
                if new_heap[right][1] < new_heap[smallest][1] { smallest = right }
            }
        }
        if smallest == idx { break }
        let tmp = new_heap[idx]
        new_heap[idx] = new_heap[smallest]
        new_heap[smallest] = tmp
        idx = smallest
    }
    pq.heap = new_heap
    return top
}

fn pq_len(pq) -> int {
    return len(pq.heap)
}

// ---- Deque (double-ended queue as array) ----

struct Deque {
    items: [string]
}

fn deque_new() -> Deque {
    return Deque { items: [] }
}

fn deque_push_front(dq, val) -> Deque {
    let new_items = [val]
    let i = 0
    while i < len(dq.items) {
        new_items = array_push(new_items, dq.items[i])
        i = i + 1
    }
    return Deque { items: new_items }
}

fn deque_push_back(dq, val) -> Deque {
    return Deque { items: array_push(dq.items, val) }
}

fn deque_pop_front(dq) {
    if len(dq.items) == 0 { return void }
    let val = dq.items[0]
    let new_items = []
    let i = 1
    while i < len(dq.items) {
        new_items = array_push(new_items, dq.items[i])
        i = i + 1
    }
    dq.items = new_items
    return val
}

fn deque_pop_back(dq) {
    if len(dq.items) == 0 { return void }
    let last = len(dq.items) - 1
    let val = dq.items[last]
    let new_items = []
    let i = 0
    while i < last {
        new_items = array_push(new_items, dq.items[i])
        i = i + 1
    }
    dq.items = new_items
    return val
}

fn deque_len(dq) -> int {
    return len(dq.items)
}
