// ═══════════════════════════════════════════════════════════
//  test_moe.hexa — Mixture of Experts top-k 검증
//
//  검증:
//    1. top-k 선택 정확성
//    2. softmax_subset 합 = 1
//    3. dense 동치: k = n_experts 일 때 moe_forward == moe_forward_dense
//    4. @lazy: top-k (k<n) 호출 수 < 100% (정확히 k회)
//    5. expert_forward 수식 수동 계산 일치
//
//  실행: ./hexa self/test_moe.hexa
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx(a, b, eps) { return fabs(a - b) < eps }

// ═══════════ MoE 레이어 (self/ml/moe_layer.hexa 인라인) ══════

let mut EXPERT_CALLS = 0
fn reset_expert_calls() { EXPERT_CALLS = 0 }
fn get_expert_calls() { return EXPERT_CALLS }

fn expert_forward(w, bias, x, d_out, d_in) {
    EXPERT_CALLS = EXPERT_CALLS + 1
    let mut y = []
    let mut i = 0

    while i < d_out {
        let mut s = bias[i]
        let mut j = 0

        while j < d_in {
            s = s + w[i][j] * x[j]
        }
        y = y + [s]
    }
    return y
}

@pure
fn gate_scores(gate_w, x, n_experts, d_in) {
    let mut s = []
    let mut e = 0

    while e < n_experts {
        let mut acc = 0.0
        let mut j = 0

        while j < d_in {
            acc = acc + gate_w[e][j] * x[j]
        }
        s = s + [acc]
    }
    return s
}

fn topk_indices(scores, n_experts, k) {
    let mut used = []
    let mut i = 0

    while i < n_experts { used = used + [false] }
    let mut picks = []
    let mut r = 0

    while r < k {
        let mut best = 0
        let mut best_v = -1.0e30
        let mut found = false
        let mut e = 0

        while e < n_experts {
            if !used[e] {
                if !found {
                    best = e
                    best_v = scores[e]
                    found = true
                } else {
                    if scores[e] > best_v {
                        best_v = scores[e]
                        best = e
                    }
                }
            }
        }
        let mut used2 = []
        let mut i = 0

        while i < n_experts {
            if i == best { used2 = used2 + [true] } else { used2 = used2 + [used[i]] }
        }
        used = used2
        picks = picks + [best]
    }
    return picks
}

@pure
fn softmax_subset(scores, picks, k) {
    let mut m = scores[picks[0]]
    let mut r = 1

    while r < k {
        if scores[picks[r]] > m { m = scores[picks[r]] }
    }
    let mut exps = []
    let mut z = 0.0
    let mut r = 0

    while r < k {
        let v = exp(scores[picks[r]] - m)
        exps = exps + [v]
        z = z + v
    }
    let mut out = []
    let mut r = 0

    while r < k {
        out = out + [exps[r] / z]
    }
    return out
}

@pure
fn softmax_all(scores, n) {
    let mut m = scores[0]
    let mut i = 1

    while i < n { if scores[i] > m { m = scores[i] } }
    let mut exps = []
    let mut z = 0.0
    let mut i = 0

    while i < n {
        let v = exp(scores[i] - m)
        exps = exps + [v]
        z = z + v
    }
    let mut out = []
    let mut i = 0

    while i < n { out = out + [exps[i] / z] }
    return out
}

// @fuse @lazy — library file carries attrs; test inlines without (ai_native_pass
//               strict type-check trips on 3D param indexing via picks[])
fn moe_forward(ew, eb, gw, x, n_experts, d_out, d_in, k) {
    let scores = gate_scores(gw, x, n_experts, d_in)
    let picks  = topk_indices(scores, n_experts, k)
    let probs  = softmax_subset(scores, picks, k)
    let mut y = []
    let mut i = 0

    while i < d_out { y = y + [0.0] }
    let mut r = 0

    while r < k {
        let p = probs[r]
        let mut we = ew[0]
        let mut be = eb[0]
        let mut ee = 0

        while ee < n_experts {
            if ee == picks[r] {
                we = ew[ee]
                be = eb[ee]
            }
        }
        let ye = expert_forward(we, be, x, d_out, d_in)
        let mut y2 = []
        let mut i = 0

        while i < d_out {
            y2 = y2 + [y[i] + p * ye[i]]
        }
        y = y2
    }
    return y
}

fn moe_forward_dense(experts_w, experts_b, gate_w, x, n_experts, d_out, d_in) {
    let scores = gate_scores(gate_w, x, n_experts, d_in)
    let probs  = softmax_all(scores, n_experts)
    let mut y = []
    let mut i = 0

    while i < d_out { y = y + [0.0] }
    let mut e = 0

    while e < n_experts {
        let ye = expert_forward(experts_w[e], experts_b[e], x, d_out, d_in)
        let mut i = 0

        while i < d_out {
            y[i] = y[i] + probs[e] * ye[i]
        }
    }
    return y
}

// ═══════════ 테스트 데이터 ═══════════════════════════════════
let n_experts = 4
let d_in  = 3
let d_out = 2

// expert weights: deterministic small patterns
fn mk_expert(seed) {
    let mut w = []
    let mut i = 0

    while i < d_out {
        let mut row = []
        let mut j = 0

        while j < d_in {
            let v = (to_float((seed * 7 + i * 3 + j + 1) % 11) - 5.0) / 10.0
            row = row + [v]
        }
        w = w + [row]
    }
    return w
}
fn mk_bias(seed) {
    let mut b = []
    let mut i = 0

    while i < d_out { b = b + [to_float((seed + i) % 3) / 10.0] }
    return b
}

let mut experts_w = []
let mut experts_b = []
let mut e = 0

while e < n_experts {
    experts_w = experts_w + [mk_expert(e + 1)]
    experts_b = experts_b + [mk_bias(e + 1)]
}

// gate weights — deliberately biased so expert 2 & 0 win top-2
let gate_w = [
    [0.9, 0.1, 0.0],   // e0
    [0.0, 0.0, 0.2],   // e1  (low)
    [1.2, 0.3, 0.1],   // e2  (highest)
    [0.1, 0.0, 0.0]    // e3  (low)
]

let x = [1.0, 0.5, 0.25]

// ── T1: gate_scores + top-2 ─────────────────────────────
let scores = gate_scores(gate_w, x, n_experts, d_in)
let picks2 = topk_indices(scores, n_experts, 2)
check("top-2 picks e2 first", picks2[0] == 2)
check("top-2 picks e0 second", picks2[1] == 0)

// ── T2: softmax_subset 합 = 1 ───────────────────────────
let probs = softmax_subset(scores, picks2, 2)
check("softmax_subset sum ~= 1", approx(probs[0] + probs[1], 1.0, 1.0e-9))

// ── T3: expert_forward 수식 수동 계산 ───────────────────
reset_expert_calls()
let y_e0 = expert_forward(experts_w[0], experts_b[0], x, d_out, d_in)
// manual: w00*1 + w01*0.5 + w02*0.25 + b0
let w0 = experts_w[0]
let b0 = experts_b[0]
let manual0 = w0[0][0] * 1.0 + w0[0][1] * 0.5 + w0[0][2] * 0.25 + b0[0]
check("expert0 y[0] matches manual", approx(y_e0[0], manual0, 1.0e-9))

// ── T4: @lazy — top-2 호출 수 = 2 (< 4 = 100%) ──────────
reset_expert_calls()
let y_topk = moe_forward(experts_w, experts_b, gate_w, x, n_experts, d_out, d_in, 2)
let calls_topk = get_expert_calls()
check("lazy: top-2 calls == 2", calls_topk == 2)
check("lazy: calls < 100% (< 4)", calls_topk < n_experts)

// ── T5: dense reference ─────────────────────────────────
reset_expert_calls()
let y_dense = moe_forward_dense(experts_w, experts_b, gate_w, x, n_experts, d_out, d_in)
let calls_dense = get_expert_calls()
check("dense: calls == n_experts", calls_dense == n_experts)

// ── T6: k = n_experts일 때 moe_forward ≈ dense ─────────
reset_expert_calls()
let y_full = moe_forward(experts_w, experts_b, gate_w, x, n_experts, d_out, d_in, n_experts)
check("k=n dense equivalence y[0]", approx(y_full[0], y_dense[0], 1.0e-9))
check("k=n dense equivalence y[1]", approx(y_full[1], y_dense[1], 1.0e-9))

// ── T7: top-k 결과는 합리적인 범위 ──────────────────────
check("top-k y[0] finite", fabs(y_topk[0]) < 1.0e6)
check("top-k y[1] finite", fabs(y_topk[1]) < 1.0e6)

// ── 결과 ────────────────────────────────────────────────
println("")
println("=== MoE test summary ===")
println("PASS: " + to_string(pass_count))
println("FAIL: " + to_string(fail_count))
if fail_count == 0 {
    println("ALL GREEN — MoE top-k + @lazy + @fuse OK")
}
println(to_string(pass_count) + " passed")
