// =============================================================
//  test_arena_pure.hexa -- Pure Hexa Arena Allocator Tests
//  Tests: bump alloc, scope push/pop, mark/reset, leak check
// =============================================================

// -- inline the arena implementation (stage0 has no module import) --

let ARENA_BLOCK_SIZE = 4096

let mut arena_blocks = []
let mut arena_block_used = []
let mut arena_cur_block = -1
let mut arena_marks = []
let mut arena_scope_marks = []
let mut arena_total_allocs = 0
let mut arena_enabled = true

fn arena_new_block(min_cap) {
    let cap = min_cap
    if cap < ARENA_BLOCK_SIZE {
        cap = ARENA_BLOCK_SIZE
    }
    let mut blk = []
    let mut i = 0
    while i < cap {
        blk = blk.push(0)
        i = i + 1
    }
    arena_blocks = arena_blocks.push(blk)
    arena_block_used = arena_block_used.push(0)
    let idx = len(arena_blocks) - 1
    arena_cur_block = idx
    return idx
}

fn arena_init() {
    arena_blocks = []
    arena_block_used = []
    arena_cur_block = -1
    arena_marks = []
    arena_scope_marks = []
    arena_total_allocs = 0
    arena_enabled = true
}

fn arena_alloc(n) {
    if n <= 0 { n = 1 }
    if arena_enabled == false { return nil }
    if arena_cur_block < 0 {
        arena_new_block(n)
    }
    let cur = arena_cur_block
    let used = arena_block_used[cur]
    let cap = len(arena_blocks[cur])
    if used + n <= cap {
        arena_block_used[cur] = used + n
        arena_total_allocs = arena_total_allocs + 1
        return {block_idx: cur, offset: used, size: n}
    }
    let num_blocks = len(arena_blocks)
    let mut search = cur + 1
    while search < num_blocks {
        let search_cap = len(arena_blocks[search])
        if search_cap >= n {
            arena_block_used[search] = n
            arena_cur_block = search
            arena_total_allocs = arena_total_allocs + 1
            return {block_idx: search, offset: 0, size: n}
        }
        search = search + 1
    }
    let new_idx = arena_new_block(n)
    arena_block_used[new_idx] = n
    arena_total_allocs = arena_total_allocs + 1
    return {block_idx: new_idx, offset: 0, size: n}
}

fn arena_read(alloc, idx) {
    if alloc == nil { return nil }
    if idx < 0 || idx >= alloc.size { return nil }
    return arena_blocks[alloc.block_idx][alloc.offset + idx]
}

fn arena_write(alloc, idx, val) {
    if alloc == nil { return nil }
    if idx < 0 || idx >= alloc.size { return nil }
    arena_blocks[alloc.block_idx][(alloc.offset + idx)] = val
    return val
}

fn arena_mark() {
    let cur = arena_cur_block
    let used = 0
    if cur >= 0 {
        used = arena_block_used[cur]
    }
    let m = {block: cur, used: used}
    arena_marks = arena_marks.push(m)
    return m
}

fn arena_rewind(m) {
    if m == nil { return nil }
    if m.block < 0 {
        let num = len(arena_block_used)
        let mut i = 0
        while i < num {
            arena_block_used[i] = 0
            i = i + 1
        }
        if num > 0 {
            arena_cur_block = 0
        }
        return nil
    }
    arena_block_used[m.block] = m.used
    let num = len(arena_block_used)
    let mut i = m.block + 1
    while i < num {
        arena_block_used[i] = 0
        i = i + 1
    }
    arena_cur_block = m.block
    return nil
}

fn arena_reset() {
    let num = len(arena_block_used)
    let mut i = 0
    while i < num {
        arena_block_used[i] = 0
        i = i + 1
    }
    if num > 0 {
        arena_cur_block = 0
    }
    arena_marks = []
    arena_scope_marks = []
}

fn arena_push_scope() {
    let cur = arena_cur_block
    let used = 0
    if cur >= 0 {
        used = arena_block_used[cur]
    }
    arena_scope_marks = arena_scope_marks.push({block: cur, used: used})
}

fn arena_pop_scope() {
    let depth = len(arena_scope_marks)
    if depth <= 0 { return nil }
    let m = arena_scope_marks[depth - 1]
    let mut new_marks = []
    let mut i = 0
    while i < depth - 1 {
        new_marks = new_marks.push(arena_scope_marks[i])
        i = i + 1
    }
    arena_scope_marks = new_marks
    if m.block < 0 {
        let num = len(arena_block_used)
        let mut j = 0
        while j < num {
            arena_block_used[j] = 0
            j = j + 1
        }
        if num > 0 {
            arena_cur_block = 0
        }
        return nil
    }
    arena_block_used[m.block] = m.used
    let num = len(arena_block_used)
    let mut j = m.block + 1
    while j < num {
        arena_block_used[j] = 0
        j = j + 1
    }
    arena_cur_block = m.block
    return nil
}

fn arena_scope_depth() {
    return len(arena_scope_marks)
}

fn arena_used_slots() {
    let num = len(arena_block_used)
    let mut total = 0
    let mut i = 0
    while i < num {
        total = total + arena_block_used[i]
        i = i + 1
    }
    return total
}

fn arena_block_count() {
    return len(arena_blocks)
}

fn arena_total_allocations() {
    return arena_total_allocs
}

// =============================================================
//  Test harness
// =============================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("=============================================================")
println("  HEXA Pure Arena Allocator Tests")
println("=============================================================")
println("")

// -- 1. Basic allocation --
println("--- Basic Allocation ---")

arena_init()

let a1 = arena_alloc(10)
check("alloc returns non-nil", a1 != nil, true)
check("alloc size", a1.size, 10)
check("alloc offset starts at 0", a1.offset, 0)
check("used slots after 10-alloc", arena_used_slots(), 10)
check("block count is 1", arena_block_count(), 1)

let a2 = arena_alloc(5)
check("second alloc non-nil", a2 != nil, true)
check("second alloc offset is 10", a2.offset, 10)
check("used slots after 10+5", arena_used_slots(), 15)
check("still 1 block", arena_block_count(), 1)

// -- 2. Read/Write --
println("")
println("--- Read/Write ---")

arena_write(a1, 0, 42)
arena_write(a1, 9, 99)
check("read slot 0", arena_read(a1, 0), 42)
check("read slot 9", arena_read(a1, 9), 99)
check("read out of bounds returns nil", arena_read(a1, 10), nil)
check("read negative index returns nil", arena_read(a1, -1), nil)

arena_write(a2, 0, 100)
arena_write(a2, 4, 200)
check("second alloc read 0", arena_read(a2, 0), 100)
check("second alloc read 4", arena_read(a2, 4), 200)

// -- 3. Mark/Rewind --
println("")
println("--- Mark/Rewind ---")

arena_init()
let pre_a = arena_alloc(20)
arena_write(pre_a, 0, 777)
let baseline = arena_used_slots()

let m1 = arena_mark()
let temp1 = arena_alloc(100)
let temp2 = arena_alloc(50)
check("used after mark allocs", arena_used_slots(), baseline + 150)

arena_rewind(m1)
check("used after rewind == baseline", arena_used_slots(), baseline)
check("pre-mark data survives rewind", arena_read(pre_a, 0), 777)

// -- 4. Scope Push/Pop --
println("")
println("--- Scope Push/Pop ---")

arena_init()
check("initial scope depth", arena_scope_depth(), 0)

let outer = arena_alloc(10)
arena_write(outer, 0, 111)
let outer_used = arena_used_slots()

arena_push_scope()
check("scope depth after push", arena_scope_depth(), 1)
let inner = arena_alloc(50)
arena_write(inner, 0, 222)
check("used in inner scope", arena_used_slots(), outer_used + 50)

arena_pop_scope()
check("scope depth after pop", arena_scope_depth(), 0)
check("used after pop == outer baseline", arena_used_slots(), outer_used)
check("outer data survives pop", arena_read(outer, 0), 111)

// -- 5. Nested Scopes --
println("")
println("--- Nested Scopes ---")

arena_init()
let base = arena_alloc(5)
let base_used = arena_used_slots()

arena_push_scope()
let s1 = arena_alloc(10)
let s1_used = arena_used_slots()

arena_push_scope()
let s2 = arena_alloc(20)
check("nested depth", arena_scope_depth(), 2)
check("nested used", arena_used_slots(), base_used + 10 + 20)

arena_pop_scope()
check("depth after inner pop", arena_scope_depth(), 1)
check("used after inner pop", arena_used_slots(), s1_used)

arena_pop_scope()
check("depth after outer pop", arena_scope_depth(), 0)
check("used after outer pop", arena_used_slots(), base_used)

// -- 6. Reset --
println("")
println("--- Reset ---")

arena_init()
arena_alloc(100)
arena_alloc(200)
arena_push_scope()
arena_alloc(50)
check("pre-reset used > 0", arena_used_slots() > 0, true)

arena_reset()
check("used after reset", arena_used_slots(), 0)
check("scope depth after reset", arena_scope_depth(), 0)
check("blocks preserved after reset", arena_block_count() > 0, true)

// Verify blocks are reusable after reset
let reuse = arena_alloc(10)
check("alloc after reset works", reuse != nil, true)
check("reuse block idx is 0", reuse.block_idx, 0)

// -- 7. Large allocation (exceeds block size) --
println("")
println("--- Large Allocation ---")

arena_init()
let big_size = ARENA_BLOCK_SIZE + 100
let big = arena_alloc(big_size)
check("large alloc non-nil", big != nil, true)
check("large alloc size", big.size, big_size)
arena_write(big, 0, 1)
arena_write(big, big_size - 1, 2)
check("large alloc read start", arena_read(big, 0), 1)
check("large alloc read end", arena_read(big, big_size - 1), 2)

// -- 8. Leak check: alloc/reset cycles --
println("")
println("--- Leak Check (alloc/reset cycles) ---")

arena_init()
let mut cycle = 0
while cycle < 5 {
    arena_alloc(100)
    arena_alloc(200)
    arena_push_scope()
    arena_alloc(50)
    arena_pop_scope()
    arena_reset()
    check("cycle " + to_string(cycle) + " used after reset", arena_used_slots(), 0)
    cycle = cycle + 1
}

// -- 9. Multiple marks --
println("")
println("--- Multiple Marks ---")

arena_init()
arena_alloc(10)
let m_a = arena_mark()
arena_alloc(20)
let m_b = arena_mark()
arena_alloc(30)
check("used after 10+20+30", arena_used_slots(), 60)

arena_rewind(m_b)
check("rewind to m_b", arena_used_slots(), 30)

arena_rewind(m_a)
check("rewind to m_a", arena_used_slots(), 10)

// -- 10. Pop on empty scope stack --
println("")
println("--- Edge: pop on empty scope ---")

arena_init()
arena_pop_scope()
check("pop on empty does not crash", true, true)
check("scope depth still 0", arena_scope_depth(), 0)

// -- 11. Alloc count stats --
println("")
println("--- Allocation Stats ---")

arena_init()
arena_alloc(1)
arena_alloc(1)
arena_alloc(1)
check("total_allocations", arena_total_allocations(), 3)

// -- Summary --
println("")
println("=============================================================")
println("  Arena Tests: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("=============================================================")
