// =====================================================================
//  test_string_concat_rewrite.hexa -- M981b (ROI #137) string-concat rewrite
//  Verifies semantic equivalence of:
//    (before) let mut s = ""; while ... { s = s + x }
//    (after)  let mut s = ""; let mut __sb_s = []; while ... { __sb_s = __sb_s.push(x) }
//             s = __sb_s.join("")
//  Target pass: self/ai_native_pass.hexa :: rewrite_str_concat_in_loop()
// =====================================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("=====================================================================")
println("  M981b (ROI #137): String-concat -> StringBuilder Rewrite Tests")
println("=====================================================================")
println("")

// ── Scenario 1: while loop, integer to_string accumulation ───────────

// (before)
fn concat_while_before(n) {
    let mut s = ""
    let mut i = 0
    while i < n {
        s = s + to_string(i)
        i = i + 1
    }
    return s
}

// (after — what the rewrite produces)
fn concat_while_after(n) {
    let mut s = ""
    let mut __sb_s = []
    let mut i = 0
    while i < n {
        __sb_s = __sb_s.push(to_string(i))
        i = i + 1
    }
    s = __sb_s.join("")
    return s
}

println("--- Scenario 1: while loop ---")
check("while n=0", concat_while_after(0), concat_while_before(0))
check("while n=1", concat_while_after(1), concat_while_before(1))
check("while n=5", concat_while_after(5), concat_while_before(5))
check("while n=10", concat_while_after(10), concat_while_before(10))
check("while literal", concat_while_after(4), "0123")
println("")

// ── Scenario 2: for-in loop over array of string literals ────────────

fn concat_forin_before(parts) {
    let mut s = ""
    for p in parts {
        s = s + p
    }
    return s
}

fn concat_forin_after(parts) {
    let mut s = ""
    let mut __sb_s = []
    for p in parts {
        __sb_s = __sb_s.push(p)
    }
    s = __sb_s.join("")
    return s
}

println("--- Scenario 2: for-in loop ---")
check("forin empty", concat_forin_after([]), concat_forin_before([]))
check("forin single", concat_forin_after(["x"]), concat_forin_before(["x"]))
check("forin abc", concat_forin_after(["a", "b", "c"]), concat_forin_before(["a", "b", "c"]))
check("forin literal", concat_forin_after(["hex", "a", "-", "lang"]), "hexa-lang")
println("")

// ── Scenario 3: concat of composite string expression (StrLit + call) ─

fn concat_composite_before(n) {
    let mut s = ""
    let mut i = 0
    while i < n {
        s = s + ("[" + to_string(i) + "]")
        i = i + 1
    }
    return s
}

fn concat_composite_after(n) {
    let mut s = ""
    let mut __sb_s = []
    let mut i = 0
    while i < n {
        __sb_s = __sb_s.push("[" + to_string(i) + "]")
        i = i + 1
    }
    s = __sb_s.join("")
    return s
}

println("--- Scenario 3: composite rhs expression ---")
check("composite n=0", concat_composite_after(0), concat_composite_before(0))
check("composite n=3", concat_composite_after(3), concat_composite_before(3))
check("composite literal", concat_composite_after(3), "[0][1][2]")
println("")

// ── Scenario 4: nested loops — rewrite applies per-scope ─────────────

fn nested_before(rows, cols) {
    let mut outer = ""
    let mut i = 0
    while i < rows {
        let mut inner = ""
        let mut j = 0
        while j < cols {
            inner = inner + to_string(i * cols + j)
            j = j + 1
        }
        outer = outer + (inner + ";")
        i = i + 1
    }
    return outer
}

fn nested_after(rows, cols) {
    let mut outer = ""
    let mut __sb_outer = []
    let mut i = 0
    while i < rows {
        let mut inner = ""
        let mut __sb_inner = []
        let mut j = 0
        while j < cols {
            __sb_inner = __sb_inner.push(to_string(i * cols + j))
            j = j + 1
        }
        inner = __sb_inner.join("")
        __sb_outer = __sb_outer.push(inner + ";")
        i = i + 1
    }
    outer = __sb_outer.join("")
    return outer
}

println("--- Scenario 4: nested loops ---")
check("nested 0x0", nested_after(0, 0), nested_before(0, 0))
check("nested 2x3", nested_after(2, 3), nested_before(2, 3))
check("nested 3x2", nested_after(3, 2), nested_before(3, 2))
check("nested literal", nested_after(2, 3), "012;345;")
println("")

// ── Scenario 5: emitted-form structural check (does output contain
//     parts.push + join pattern?). We construct the post-rewrite form
//     directly and assert characteristic invariants. ─────────────────

println("--- Scenario 5: StringBuilder structural invariants ---")

// Invariant 1: __sb_s is an array (len grows by 1 each iter)
fn sb_len_check(n) {
    let mut __sb_s = []
    let mut i = 0
    while i < n {
        __sb_s = __sb_s.push(to_string(i))
        i = i + 1
    }
    return len(__sb_s)
}

check("sb len 0", sb_len_check(0), 0)
check("sb len 5", sb_len_check(5), 5)
check("sb len 100", sb_len_check(100), 100)

// Invariant 2: join("") concatenates all pushed parts in order
check("sb join empty", [].join(""), "")
check("sb join abc", ["a", "b", "c"].join(""), "abc")

// Invariant 3: the rewrite preserves the original variable name `s`
// so any post-loop code reading `s` still works
fn post_loop_read_after(n) {
    let mut s = ""
    let mut __sb_s = []
    let mut i = 0
    while i < n {
        __sb_s = __sb_s.push("*")
        i = i + 1
    }
    s = __sb_s.join("")
    return s + "|END"
}

check("post-loop read 0", post_loop_read_after(0), "|END")
check("post-loop read 3", post_loop_read_after(3), "***|END")
println("")

// ── Summary ─────────────────────────────────────────────────────────
println("=====================================================================")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("=====================================================================")
assert(fail_count == 0)
