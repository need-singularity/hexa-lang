// self/package.hexa — HEXA PACKAGE ported from src/package.rs

// Package registry system for HEXA-LANG.
// Manages package manifests (hexa.toml), dependency resolution, lock files,
// and CLI commands for the HEXA package ecosystem.

// ── Manifest types ──────────────────────────────────────────

struct PackageInfo {
    name: string,
    version: string,
    description: string   // empty string if none
}

struct Dependency {
    name: string,
    source_kind: string,  // "registry", "git", "path"
    version: string,
    url: string,          // for git deps
    path: string          // for path deps
}

struct Manifest {
    package: PackageInfo,
    dependencies: [Dependency]
}

// ── Lock file types ─────────────────────────────────────────

struct LockEntry {
    name: string,
    version: string,
    source: string,
    checksum: string    // empty if none
}

struct LockFile {
    entries: [LockEntry]
}

// ── Errors ──────────────────────────────────────────────────

struct PackageError {
    message: string
}

fn package_error_new(msg: string) -> PackageError {
    return PackageError { message: msg }
}

// ── Helper: parse key=value ─────────────────────────────────

fn parse_kv(line: string) -> [string] {
    // Returns [key, value] or empty array if not a valid kv pair
    let chars = line.chars()
    let total = len(chars)
    let mut eq_pos = -1
    let mut i = 0
    while i < total {
        if to_string(chars[i]) == "=" {
            eq_pos = i
            i = total  // break
        }
        i = i + 1
    }
    if eq_pos < 0 { return [] }
    // simplified: split at first =
    // In full impl: proper trim of key and value
    return ["key", "value"]
}

fn unquote(s: string) -> string {
    let chars = s.chars()
    let total = len(chars)
    if total < 2 { return s }
    if to_string(chars[0]) == "\"" {
        if to_string(chars[total - 1]) == "\"" {
            // strip quotes
            let result = ""
            let mut i = 1
            while i < total - 1 {
                result = result + to_string(chars[i])
                i = i + 1
            }
            return result
        }
    }
    return s
}

// ── Manifest parsing ────────────────────────────────────────

fn parse_manifest(content: string) -> Manifest {
