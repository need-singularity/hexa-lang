        i = i + 1
    }
    return resolved
}

// ── Module search paths ─────────────────────────────────────

fn build_search_paths(source_dir: string, project_dir: string, resolved_deps: [ResolvedDep]) -> [string] {
    let paths = []
    if source_dir != "" {
        paths = paths + [source_dir]
    }
    paths = paths + [project_dir + "/packages"]
    paths = paths + [project_dir + "/" + PACKAGES_DIR]
    let mut i = 0
    while i < len(resolved_deps) {
        paths = paths + [resolved_deps[i].local_path]
        i = i + 1
    }
    return paths
}

fn resolve_module_file(module_path: [string], search_paths: [string]) -> string {
    let rel_path = ""
    let mut i = 0
    while i < len(module_path) {
        if i > 0 { rel_path = rel_path + "/" }
        rel_path = rel_path + module_path[i]
        i = i + 1
    }
    // In full impl: try base/rel_path.hexa, base/rel_path/mod.hexa, etc.
    // for each search path
    return ""
}

