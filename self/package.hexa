// self/package.hexa — HEXA PACKAGE ported from src/package.rs
// Package registry system: manifest parsing, dependency resolution,
// lock files, semver, and CLI commands for the HEXA package ecosystem.

// ── Manifest types ──────────────────────────────────────────

struct PackageInfo {
    name: string,
    version: string,
    description: string
}

struct Dependency {
    name: string,
    source_kind: string,
    version: string,
    url: string,
    path: string
}

struct Manifest {
    pkg_name: string,
    pkg_version: string,
    pkg_description: string,
    dep_count: int,
    deps: string
}

struct LockEntry {
    name: string,
    version: string,
    source: string,
    checksum: string
}

struct LockFile {
    entries: string,
    entry_count: int
}

struct PackageError {
    message: string
}

struct SemVer {
    major: int,
    minor: int,
    patch: int
}

struct ResolvedDep {
    name: string,
    version: string,
    source_desc: string,
    local_path: string
}

// ── PackageError ────────────────────────────────────────────

fn package_error_new(msg: string) -> PackageError {
    return PackageError { message: msg }
}

// ── Manifest parsing helpers ────────────────────────────────

fn parse_kv(line: string) -> string {
    // Returns "key\tvalue" or ""
    let eq_pos = string_find(line, "=")
    if eq_pos < 0 {
        return ""
    }
    let key = string_trim(string_slice(line, 0, eq_pos))
    let value = string_trim(string_slice(line, eq_pos + 1, len(line)))
    if len(key) == 0 {
        return ""
    }
    return key + "\t" + value
}

fn unquote(s: string) -> string {
    let t = string_trim(s)
    if len(t) >= 2 {
        if string_starts_with(t, "\"") {
            if string_ends_with(t, "\"") {
                return string_slice(t, 1, len(t) - 1)
            }
        }
    }
    return t
}

fn split_inline_entries(s: string) -> string {
    // Split on commas respecting quotes, return ";"-separated
    let result = ""
    let current = ""
    let in_quotes = false
    let i = 0
    while i < len(s) {
        let ch = s[i]
        if ch == "\"" {
            in_quotes = !in_quotes
            current = current + ch
        } else {
            if ch == "," {
                if !in_quotes {
                    if len(result) > 0 {
                        result = result + ";" + string_trim(current)
                    } else {
                        result = string_trim(current)
                    }
                    current = ""
                } else {
                    current = current + ch
                }
            } else {
                current = current + ch
            }
        }
        i = i + 1
    }
    if len(string_trim(current)) > 0 {
        if len(result) > 0 {
            result = result + ";" + string_trim(current)
        } else {
            result = string_trim(current)
        }
    }
    return result
}

// ── Parse manifest ──────────────────────────────────────────

fn parse_manifest(content: string) -> Manifest {
    let lines = string_split(content, "\n")
    let current_section = ""
    let name = ""
    let version = ""
    let description = ""
    let deps = ""
    let dep_count = 0

    let i = 0
    while i < len(lines) {
        let trimmed = string_trim(lines[i])
        if len(trimmed) == 0 {
            i = i + 1
            continue
        }
        if string_starts_with(trimmed, "#") {
            i = i + 1
            continue
        }
        if string_starts_with(trimmed, "[") {
            if string_ends_with(trimmed, "]") {
                current_section = string_slice(trimmed, 1, len(trimmed) - 1)
                i = i + 1
                continue
            }
        }
        let kv = parse_kv(trimmed)
        if len(kv) > 0 {
            let parts = string_split(kv, "\t")
            let key = parts[0]
            let value = parts[1]
            if current_section == "package" {
                if key == "name" { name = unquote(value) }
                if key == "version" { version = unquote(value) }
                if key == "description" { description = unquote(value) }
            }
            if current_section == "dependencies" {
                let entry = key + "=" + value
                if len(deps) > 0 {
                    deps = deps + "|||" + entry
                } else {
                    deps = entry
                }
                dep_count = dep_count + 1
            }
        }
        i = i + 1
    }

    if len(version) == 0 { version = "0.1.0" }

    return Manifest {
        pkg_name: name,
        pkg_version: version,
        pkg_description: description,
        dep_count: dep_count,
        deps: deps
    }
}

// ── Serialize manifest ──────────────────────────────────────

fn serialize_manifest(m: Manifest) -> string {
    let out = "[package]\n"
    out = out + "name = \"" + m.pkg_name + "\"\n"
    out = out + "version = \"" + m.pkg_version + "\"\n"
    if len(m.pkg_description) > 0 {
        out = out + "description = \"" + m.pkg_description + "\"\n"
    }
    out = out + "\n[dependencies]\n"
    if len(m.deps) > 0 {
        let entries = string_split(m.deps, "|||")
        let i = 0
        while i < len(entries) {
            let entry = entries[i]
            let eq_pos = string_find(entry, "=")
            if eq_pos > 0 {
                let dep_name = string_trim(string_slice(entry, 0, eq_pos))
                let dep_val = string_trim(string_slice(entry, eq_pos + 1, len(entry)))
                out = out + dep_name + " = " + dep_val + "\n"
            }
            i = i + 1
        }
    }
    return out
}

// ── SemVer ──────────────────────────────────────────────────

fn semver_new(major: int, minor: int, patch: int) -> SemVer {
    return SemVer { major: major, minor: minor, patch: patch }
}

fn semver_parse(s: string) -> SemVer {
    let t = string_trim(s)
    let parts = string_split(t, ".")
    let major = 0
    let minor = 0
    let patch = 0
    if len(parts) >= 1 { major = to_int(parts[0]) }
    if len(parts) >= 2 { minor = to_int(parts[1]) }
    if len(parts) >= 3 { patch = to_int(parts[2]) }
    return SemVer { major: major, minor: minor, patch: patch }
}

fn semver_to_string(v: SemVer) -> string {
    return to_string(v.major) + "." + to_string(v.minor) + "." + to_string(v.patch)
}

fn semver_cmp(a: SemVer, b: SemVer) -> int {
    if a.major != b.major {
        if a.major < b.major { return -1 }
        return 1
    }
    if a.minor != b.minor {
        if a.minor < b.minor { return -1 }
        return 1
    }
    if a.patch != b.patch {
        if a.patch < b.patch { return -1 }
        return 1
    }
    return 0
}

// ── Version matching ────────────────────────────────────────

fn version_matches(version: string, requirement: string) -> bool {
    let req = string_trim(requirement)
    if req == "latest" { return true }
    if req == "*" { return true }

    let ver = semver_parse(version)

    // Caret: ^1.2.3
    if string_starts_with(req, "^") {
        let r = semver_parse(string_slice(req, 1, len(req)))
        if ver.major != r.major { return false }
        if ver.minor < r.minor { return false }
        if ver.minor == r.minor {
            if ver.patch < r.patch { return false }
        }
        return true
    }

    // Tilde: ~1.2.3
    if string_starts_with(req, "~") {
        let r = semver_parse(string_slice(req, 1, len(req)))
        if ver.major != r.major { return false }
        if ver.minor != r.minor { return false }
        return ver.patch >= r.patch
    }

    // Exact: =1.2.3 or bare version
    if string_starts_with(req, "=") {
        let r = semver_parse(string_slice(req, 1, len(req)))
        return semver_cmp(ver, r) == 0
    }

    let r = semver_parse(req)
    return semver_cmp(ver, r) == 0
}

// ── Version conflict resolution ─────────────────────────────

fn resolve_version_conflict(requirements: string, available: string) -> string {
    // requirements: "^1.0|||~2.0|||..."
    // available: "1.0.0|||1.1.0|||2.0.0|||..."
    // Returns highest compatible version or ""
    let reqs = string_split(requirements, "|||")
    let versions = string_split(available, "|||")
    let best = ""
    let best_ver = semver_new(0, 0, 0)

    let i = 0
    while i < len(versions) {
        let v = string_trim(versions[i])
        if len(v) == 0 {
            i = i + 1
            continue
        }
        let sv = semver_parse(v)
        let all_match = true
        let j = 0
        while j < len(reqs) {
            let req = string_trim(reqs[j])
            if len(req) > 0 {
                if !version_matches(v, req) {
                    all_match = false
                }
            }
            j = j + 1
        }
        if all_match {
            if semver_cmp(sv, best_ver) > 0 {
                best_ver = sv
                best = v
            }
        }
        i = i + 1
    }
    return best
}

// ── Lock file ───────────────────────────────────────────────

fn lockfile_new() -> LockFile {
    return LockFile { entries: "", entry_count: 0 }
}

fn lockfile_add(lf: LockFile, name: string, version: string, source: string, checksum: string) {
    let entry = "name=\"" + name + "\"\nversion=\"" + version + "\"\nsource=\"" + source + "\""
    if len(checksum) > 0 {
        entry = entry + "\nchecksum=\"" + checksum + "\""
    }
    if len(lf.entries) > 0 {
        lf.entries = lf.entries + "\n\n" + entry
    } else {
        lf.entries = entry
    }
    lf.entry_count = lf.entry_count + 1
}

fn lockfile_serialize(lf: LockFile) -> string {
    return "# This file is auto-generated by `hexa install`. Do not edit.\n\n" + lf.entries + "\n"
}

fn lockfile_find(lf: LockFile, name: string) -> string {
    // Returns version or ""
    let key = "name=\"" + name + "\""
    let pos = string_find(lf.entries, key)
    if pos < 0 { return "" }
    let after = string_slice(lf.entries, pos, len(lf.entries))
    let ver_pos = string_find(after, "version=\"")
    if ver_pos < 0 { return "" }
    let ver_start = ver_pos + 9
    let ver_end = string_find(string_slice(after, ver_start, len(after)), "\"")
    if ver_end < 0 { return "" }
    return string_slice(after, ver_start, ver_start + ver_end)
}

// ── Module search paths ─────────────────────────────────────

fn resolve_module_file(module_name: string, search_paths: string) -> string {
    let paths = string_split(search_paths, ":")
    let i = 0
    while i < len(paths) {
        let base = string_trim(paths[i])
        if len(base) > 0 {
            // Try: base/module_name.hexa
            let candidate = base + "/" + module_name + ".hexa"
            // In full runtime: check file existence
            return candidate
        }
        i = i + 1
    }
    return ""
}

fn build_search_paths(source_dir: string, project_dir: string, dep_paths: string) -> string {
    let paths = ""
    if len(source_dir) > 0 { paths = source_dir }
    let packages = project_dir + "/packages"
    if len(paths) > 0 { paths = paths + ":" + packages } else { paths = packages }
    let hexa_packages = project_dir + "/.hexa-packages"
    paths = paths + ":" + hexa_packages
    if len(dep_paths) > 0 {
        paths = paths + ":" + dep_paths
    }
    return paths
}

// ── CLI commands ────────────────────────────────────────────

fn cmd_install(project_dir: string) -> string {
    // Read hexa.toml, resolve dependencies, generate lock file
    print("Resolving dependencies...")
    return "ok"
}

fn cmd_add_pkg(pkg_spec: string, path_opt: string, git_opt: string, project_dir: string) -> string {
    let at_pos = string_find(pkg_spec, "@")
    let name = pkg_spec
    let version = "latest"
    if at_pos >= 0 {
        name = string_slice(pkg_spec, 0, at_pos)
        version = string_slice(pkg_spec, at_pos + 1, len(pkg_spec))
    }
    print("Added '" + name + "' to [dependencies]")
    print("Updated hexa.lock")
    return "ok"
}

fn cmd_publish_pkg(project_dir: string) -> string {
    print("Package created.")
    print("To publish:")
    print("  1. Create a GitHub repository")
    print("  2. Push your code: git push origin main")
    print("  3. Create a release with git tag")
    return "ok"
}

fn cmd_search(query: string) -> string {
    print("Searching for hexa packages matching '" + query + "'...")
    print("To add a git dependency:")
    print("  hexa add " + query + " --git https://github.com/user/repo")
    return "ok"
}

