    let pkg = PackageInfo { name: pkg_name, version: pkg_version, description: pkg_description }
    return Manifest { package: pkg, dependencies: deps }
}

// ── Manifest serialization ──────────────────────────────────

fn serialize_manifest(manifest: Manifest) -> string {
    let out = ""
    out = out + "[package]\n"
    out = out + "name = \"" + manifest.package.name + "\"\n"
    out = out + "version = \"" + manifest.package.version + "\"\n"
    if manifest.package.description != "" {
        out = out + "description = \"" + manifest.package.description + "\"\n"
    }
    out = out + "\n[dependencies]\n"
    let mut i = 0
    while i < len(manifest.dependencies) {
        let dep = manifest.dependencies[i]
        if dep.source_kind == "registry" {
            out = out + dep.name + " = \"" + dep.version + "\"\n"
        }
        if dep.source_kind == "git" {
            out = out + dep.name + " = { version = \"" + dep.version + "\", git = \"" + dep.url + "\" }\n"
        }
        if dep.source_kind == "path" {
            out = out + dep.name + " = { path = \"" + dep.path + "\" }\n"
        }
        i = i + 1
    }
    return out
}

// ── Lock file ───────────────────────────────────────────────

fn lock_file_new() -> LockFile {
    return LockFile { entries: [] }
}

fn lock_file_serialize(self: LockFile) -> string {
    let out = "# This file is auto-generated by `hexa install`. Do not edit.\n\n"
    let mut i = 0
    while i < len(self.entries) {
        let entry = self.entries[i]
        out = out + "name = \"" + entry.name + "\"\n"
        out = out + "version = \"" + entry.version + "\"\n"
        out = out + "source = \"" + entry.source + "\"\n"
        if entry.checksum != "" {
            out = out + "checksum = \"" + entry.checksum + "\"\n"
        }
        out = out + "\n"
        i = i + 1
    }
    return out
}

fn lock_file_find(self: LockFile, name: string) -> LockEntry {
    let mut i = 0
    while i < len(self.entries) {
        if self.entries[i].name == name {
            return self.entries[i]
        }
        i = i + 1
    }
    return LockEntry { name: "", version: "", source: "", checksum: "" }
}

// ── SemVer ──────────────────────────────────────────────────

struct SemVer {
    major: int,
    minor: int,
    patch: int
}

fn semver_new(major: int, minor: int, patch: int) -> SemVer {
    return SemVer { major: major, minor: minor, patch: patch }
}

fn semver_parse(s: string) -> SemVer {
    // Parse "major.minor.patch" — simplified
    // In full impl: split by '.', parse each part
    return SemVer { major: 0, minor: 0, patch: 0 }
}

fn semver_to_string(self: SemVer) -> string {
    return to_string(self.major) + "." + to_string(self.minor) + "." + to_string(self.patch)
}

fn semver_cmp(a: SemVer, b: SemVer) -> int {
    if a.major != b.major {
        if a.major < b.major { return -1 }
        return 1
    }
    if a.minor != b.minor {
        if a.minor < b.minor { return -1 }
        return 1
    }
    if a.patch != b.patch {
        if a.patch < b.patch { return -1 }
        return 1
    }
    return 0
}

// ── Version requirement ─────────────────────────────────────

struct VersionReq {
    kind: string,       // "any", "exact", "caret", "tilde", "range"
    version: SemVer,
    lower: SemVer,
    lower_inclusive: bool,
    upper: SemVer,
    upper_inclusive: bool
}

fn version_req_any() -> VersionReq {
    let z = semver_new(0, 0, 0)
    return VersionReq { kind: "any", version: z, lower: z, lower_inclusive: false, upper: z, upper_inclusive: false }
}

fn version_req_exact(v: SemVer) -> VersionReq {
    let z = semver_new(0, 0, 0)
    return VersionReq { kind: "exact", version: v, lower: z, lower_inclusive: false, upper: z, upper_inclusive: false }
}

fn version_req_caret(v: SemVer) -> VersionReq {
    let z = semver_new(0, 0, 0)
    return VersionReq { kind: "caret", version: v, lower: z, lower_inclusive: false, upper: z, upper_inclusive: false }
}

fn version_req_matches(self: VersionReq, version: SemVer) -> bool {
    if self.kind == "any" { return true }
    if self.kind == "exact" {
        return semver_cmp(version, self.version) == 0
    }
    if self.kind == "caret" {
        if version.major != self.version.major { return false }
        if version.minor < self.version.minor { return false }
        if version.minor == self.version.minor {
            if version.patch < self.version.patch { return false }
        }
        return true
    }
    if self.kind == "tilde" {
        if version.major != self.version.major { return false }
        if version.minor != self.version.minor { return false }
        return version.patch >= self.version.patch
    }
    if self.kind == "range" {
        let lower_ok = true
        if self.lower_inclusive {
            if semver_cmp(version, self.lower) < 0 { lower_ok = false }
        } else {
            if semver_cmp(version, self.lower) <= 0 { lower_ok = false }
        }
        let upper_ok = true
        if self.upper_inclusive {
            if semver_cmp(version, self.upper) > 0 { upper_ok = false }
        } else {
            if semver_cmp(version, self.upper) >= 0 { upper_ok = false }
        }
        return lower_ok && upper_ok
    }
    return false
}

// ── Version matching (legacy compat) ─────────────────────────

fn version_matches(version: string, requirement: string) -> bool {
    if requirement == "latest" { return true }
    if requirement == "*" { return true }
    // In full impl: use semver_parse + version_req_matches
    return version == requirement
}

