// ═══════════════════════════════════════════════════════════════════
//  test_bitops_pure.hexa — coverage for self/runtime/bitops_pure.hexa
//
//  Tests: checked_add_pure, checked_mul_pure, wrapping_add_pure,
//         is_power_of_two_pure, next_power_of_two_pure,
//         isqrt_pure, log2_int_pure, ipow_pure, digit_sum_pure,
//         bit_reverse32_pure
//
//  (codegen import not wired for test files; inline the module body,
//   same pattern as test_bit_pure.hexa / test_char_pure.hexa.)
// ═══════════════════════════════════════════════════════════════════

// ── INLINED from self/runtime/bitops_pure.hexa ──

@pure
fn _i64_max() { return 9223372036854775807 }

@pure
fn _i64_min() { return 0 - 9223372036854775807 - 1 }

@pure
fn _pow2(n) {
    let mut r = 1
    let mut i = 0
    while i < n {
        r = r * 2
        i = i + 1
    }
    return r
}

@pure
fn checked_add_pure(a, b) {
    let hi = _i64_max()
    let lo = _i64_min()
    if b > 0 {
        if a > hi - b { return nil }
    }
    if b < 0 {
        if a < lo - b { return nil }
    }
    return a + b
}

@pure
fn checked_mul_pure(a, b) {
    if a == 0 { return 0 }
    if b == 0 { return 0 }
    let hi = _i64_max()
    let lo = _i64_min()
    if a == lo {
        if b == -1 { return nil }
    }
    if b == lo {
        if a == -1 { return nil }
    }
    let prod = a * b
    if b != 0 {
        if (prod / b) != a { return nil }
    }
    if prod > hi { return nil }
    if prod < lo { return nil }
    return prod
}

@pure
fn wrapping_add_pure(a, b, bits) {
    let sum = a + b
    if bits >= 64 { return sum }
    if bits <= 0 { return 0 }
    let modulus = _pow2(bits)
    let q = sum / modulus
    let mut r = sum - q * modulus
    if r < 0 { r = r + modulus }
    return r
}

@pure
fn is_power_of_two_pure(n) {
    if n <= 0 { return false }
    return (n & (n - 1)) == 0
}

@pure
fn next_power_of_two_pure(n) {
    if n <= 1 { return 1 }
    if is_power_of_two_pure(n) { return n }
    let cap = _pow2(62)
    if n > cap { return nil }
    let mut p = 1
    while p < n {
        p = p * 2
    }
    return p
}

@pure
fn isqrt_pure(n) {
    if n < 0 { return nil }
    if n < 2 { return n }
    let mut x = n
    let mut y = (x + 1) / 2
    while y < x {
        x = y
        y = (x + n / x) / 2
    }
    return x
}

@pure
fn log2_int_pure(n) {
    if n <= 0 { return nil }
    let mut x = n
    let mut k = 0
    while x > 1 {
        x = x / 2
        k = k + 1
    }
    return k
}

@pure
fn ipow_pure(base, exp) {
    if exp < 0 { return nil }
    let mut result = 1
    let mut b = base
    let mut e = exp
    while e > 0 {
        if (e & 1) == 1 {
            result = result * b
        }
        e = e / 2
        if e > 0 {
            b = b * b
        }
    }
    return result
}

@pure
fn digit_sum_pure(n) {
    let mut x = n
    if x < 0 { x = 0 - x }
    let mut s = 0
    if x == 0 { return 0 }
    while x > 0 {
        s = s + (x - (x / 10) * 10)
        x = x / 10
    }
    return s
}

@pure
fn bit_reverse32_pure(a) {
    let mask = _pow2(32) - 1
    let mut x = a & mask
    let mut r = 0
    let mut i = 0
    while i < 32 {
        let bit = x - (x / 2) * 2
        r = r * 2 + bit
        x = x / 2
        i = i + 1
    }
    return r
}

// ── END inlined ────────────────────────────────────────────────────

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_nil(name, actual) {
    if type_of(actual) == "void" {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected nil, got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  Pure-Hexa Arith-Overflow / Bitops Tests")
println("═══════════════════════════════════════════════════════")
println("")

let I64_MAX = 9223372036854775807
let I64_MIN = 0 - 9223372036854775807 - 1

// ── checked_add_pure ───────────────────────────────────────────────
println("--- checked_add_pure ---")
check("add 0 + 0",          checked_add_pure(0, 0),          0)
check("add 1 + 1",          checked_add_pure(1, 1),          2)
check("add -1 + 1",         checked_add_pure(-1, 1),         0)
check("add MAX + 0",        checked_add_pure(I64_MAX, 0),    I64_MAX)
check("add MIN + 0",        checked_add_pure(I64_MIN, 0),    I64_MIN)
check("add MAX-1 + 1",      checked_add_pure(I64_MAX - 1, 1), I64_MAX)
check_nil("add MAX + 1 overflow",     checked_add_pure(I64_MAX, 1))
check_nil("add MAX + MAX overflow",   checked_add_pure(I64_MAX, I64_MAX))
check_nil("add MIN + -1 underflow",   checked_add_pure(I64_MIN, -1))
check_nil("add MIN + MIN underflow",  checked_add_pure(I64_MIN, I64_MIN))

// ── checked_mul_pure ───────────────────────────────────────────────
println("")
println("--- checked_mul_pure ---")
check("mul 0 * MAX",        checked_mul_pure(0, I64_MAX),    0)
check("mul MAX * 0",        checked_mul_pure(I64_MAX, 0),    0)
check("mul 3 * 4",          checked_mul_pure(3, 4),          12)
check("mul -3 * 4",         checked_mul_pure(-3, 4),         -12)
check("mul MAX * 1",        checked_mul_pure(I64_MAX, 1),    I64_MAX)
check("mul MIN * 1",        checked_mul_pure(I64_MIN, 1),    I64_MIN)
check_nil("mul MIN * -1 overflow",   checked_mul_pure(I64_MIN, -1))
check_nil("mul -1 * MIN overflow",   checked_mul_pure(-1, I64_MIN))
check_nil("mul MAX * 2 overflow",    checked_mul_pure(I64_MAX, 2))
check_nil("mul 2 * MAX overflow",    checked_mul_pure(2, I64_MAX))
check_nil("mul MAX * MAX overflow",  checked_mul_pure(I64_MAX, I64_MAX))

// ── wrapping_add_pure ──────────────────────────────────────────────
println("")
println("--- wrapping_add_pure ---")
check("wrap 8-bit 200+100 -> 44",  wrapping_add_pure(200, 100, 8),      44)
check("wrap 8-bit 255+1   -> 0",   wrapping_add_pure(255, 1, 8),        0)
check("wrap 8-bit 0+0     -> 0",   wrapping_add_pure(0, 0, 8),          0)
check("wrap 16-bit 65535+1 -> 0",  wrapping_add_pure(65535, 1, 16),     0)
check("wrap 32-bit 0xFFFFFFFF+1",  wrapping_add_pure(0xFFFFFFFF, 1, 32), 0)
check("wrap 32-bit identity",      wrapping_add_pure(100, 200, 32),     300)
check("wrap 64-bit native",        wrapping_add_pure(1, 2, 64),         3)

// ── is_power_of_two_pure ───────────────────────────────────────────
println("")
println("--- is_power_of_two_pure ---")
check("pow2? 0",     is_power_of_two_pure(0),     false)
check("pow2? -1",    is_power_of_two_pure(-1),    false)
check("pow2? -8",    is_power_of_two_pure(-8),    false)
check("pow2? 1",     is_power_of_two_pure(1),     true)
check("pow2? 2",     is_power_of_two_pure(2),     true)
check("pow2? 3",     is_power_of_two_pure(3),     false)
check("pow2? 4",     is_power_of_two_pure(4),     true)
check("pow2? 7",     is_power_of_two_pure(7),     false)
check("pow2? 8",     is_power_of_two_pure(8),     true)
check("pow2? 1024",  is_power_of_two_pure(1024),  true)
check("pow2? 1023",  is_power_of_two_pure(1023),  false)
check("pow2? 2^62",  is_power_of_two_pure(4611686018427387904), true)
check("pow2? MAX",   is_power_of_two_pure(I64_MAX), false)

// ── next_power_of_two_pure ─────────────────────────────────────────
println("")
println("--- next_power_of_two_pure ---")
check("next_pow2 0",    next_power_of_two_pure(0),   1)
check("next_pow2 1",    next_power_of_two_pure(1),   1)
check("next_pow2 2",    next_power_of_two_pure(2),   2)
check("next_pow2 3",    next_power_of_two_pure(3),   4)
check("next_pow2 5",    next_power_of_two_pure(5),   8)
check("next_pow2 8",    next_power_of_two_pure(8),   8)
check("next_pow2 9",    next_power_of_two_pure(9),   16)
check("next_pow2 1000", next_power_of_two_pure(1000),1024)
check("next_pow2 1024", next_power_of_two_pure(1024),1024)
check("next_pow2 2^62", next_power_of_two_pure(4611686018427387904), 4611686018427387904)
check_nil("next_pow2 2^62+1 overflow", next_power_of_two_pure(4611686018427387905))
check_nil("next_pow2 MAX overflow",    next_power_of_two_pure(I64_MAX))

// ── isqrt_pure ─────────────────────────────────────────────────────
println("")
println("--- isqrt_pure ---")
check("isqrt 0",     isqrt_pure(0),     0)
check("isqrt 1",     isqrt_pure(1),     1)
check("isqrt 2",     isqrt_pure(2),     1)
check("isqrt 3",     isqrt_pure(3),     1)
check("isqrt 4",     isqrt_pure(4),     2)
check("isqrt 8",     isqrt_pure(8),     2)
check("isqrt 9",     isqrt_pure(9),     3)
check("isqrt 15",    isqrt_pure(15),    3)
check("isqrt 16",    isqrt_pure(16),    4)
check("isqrt 99",    isqrt_pure(99),    9)
check("isqrt 100",   isqrt_pure(100),   10)
check("isqrt 10000", isqrt_pure(10000), 100)
check("isqrt 123456789", isqrt_pure(123456789), 11111)
check_nil("isqrt -1 nil",  isqrt_pure(-1))
check_nil("isqrt -100 nil", isqrt_pure(-100))

// ── log2_int_pure ──────────────────────────────────────────────────
println("")
println("--- log2_int_pure ---")
check("log2_int 1",    log2_int_pure(1),    0)
check("log2_int 2",    log2_int_pure(2),    1)
check("log2_int 3",    log2_int_pure(3),    1)
check("log2_int 4",    log2_int_pure(4),    2)
check("log2_int 7",    log2_int_pure(7),    2)
check("log2_int 8",    log2_int_pure(8),    3)
check("log2_int 1023", log2_int_pure(1023), 9)
check("log2_int 1024", log2_int_pure(1024), 10)
check("log2_int 2^32", log2_int_pure(4294967296), 32)
check_nil("log2_int 0 nil",  log2_int_pure(0))
check_nil("log2_int -1 nil", log2_int_pure(-1))

// ── ipow_pure ──────────────────────────────────────────────────────
println("")
println("--- ipow_pure ---")
check("ipow 0^0",   ipow_pure(0, 0),   1)
check("ipow 0^5",   ipow_pure(0, 5),   0)
check("ipow 1^100", ipow_pure(1, 100), 1)
check("ipow 2^0",   ipow_pure(2, 0),   1)
check("ipow 2^1",   ipow_pure(2, 1),   2)
check("ipow 2^10",  ipow_pure(2, 10),  1024)
check("ipow 2^20",  ipow_pure(2, 20),  1048576)
check("ipow 3^7",   ipow_pure(3, 7),   2187)
check("ipow 10^9",  ipow_pure(10, 9),  1000000000)
check("ipow -2^3",  ipow_pure(-2, 3),  -8)
check("ipow -2^4",  ipow_pure(-2, 4),  16)
check_nil("ipow 2^-1 nil", ipow_pure(2, -1))

// ── digit_sum_pure ─────────────────────────────────────────────────
println("")
println("--- digit_sum_pure ---")
check("digit_sum 0",         digit_sum_pure(0),         0)
check("digit_sum 1",         digit_sum_pure(1),         1)
check("digit_sum 9",         digit_sum_pure(9),         9)
check("digit_sum 10",        digit_sum_pure(10),        1)
check("digit_sum 123",       digit_sum_pure(123),       6)
check("digit_sum 999",       digit_sum_pure(999),       27)
check("digit_sum 1000",      digit_sum_pure(1000),      1)
check("digit_sum 123456789", digit_sum_pure(123456789), 45)
check("digit_sum -42",       digit_sum_pure(-42),       6)
check("digit_sum -999",      digit_sum_pure(-999),      27)

// ── bit_reverse32_pure ─────────────────────────────────────────────
println("")
println("--- bit_reverse32_pure ---")
check("bit_rev32 0",          bit_reverse32_pure(0),          0)
check("bit_rev32 1",          bit_reverse32_pure(1),          0x80000000)
check("bit_rev32 0x80000000", bit_reverse32_pure(0x80000000), 1)
check("bit_rev32 0xFFFFFFFF", bit_reverse32_pure(0xFFFFFFFF), 0xFFFFFFFF)
check("bit_rev32 0xAAAAAAAA", bit_reverse32_pure(0xAAAAAAAA), 0x55555555)
check("bit_rev32 0x55555555", bit_reverse32_pure(0x55555555), 0xAAAAAAAA)
check("bit_rev32 0x12345678", bit_reverse32_pure(0x12345678), 0x1E6A2C48)
check("bit_rev32 involution", bit_reverse32_pure(bit_reverse32_pure(0x0F0F0F0F)), 0x0F0F0F0F)

println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    println("FAIL")
    exit(1)
}
println("ALL PASS")
