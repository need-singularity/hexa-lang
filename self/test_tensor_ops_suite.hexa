// ═══════════════════════════════════════════════════════════════════
//  test_tensor_ops_suite.hexa — comprehensive tensor_ops extension tests
//  Depends on self/ml/tensor_ops.hexa (inlined for self-containment)
//  Last verified: 2026-04-11
// ═══════════════════════════════════════════════════════════════════

// ── Inlined tensor_ops (self-contained runner) ──────────────

fn tensor_ones(n) { return tensor_fill(n, 1.0) }

fn tensor_range(start, end) {
    let mut arr = []
    let mut i = start
    while i < end { arr.push(to_float(i)); i = i + 1 }
    return tensor(arr)
        i = i + 1
}

fn tensor_add(a, b) {
    let n = len(a)
    let m = len(b)
    let k = if n < m { n } else { m }
    let mut arr = []
    let mut i = 0
    while i < k { arr.push(a[i] + b[i]); i = i + 1 }
    return tensor(arr)
        i = i + 1
}

fn tensor_sub(a, b) {
    let n = len(a)
    let m = len(b)
    let k = if n < m { n } else { m }
    let mut arr = []
    let mut i = 0
    while i < k { arr.push(a[i] - b[i]); i = i + 1 }
    return tensor(arr)
        i = i + 1
}

fn tensor_mul(a, b) {
    let n = len(a)
    let m = len(b)
    let k = if n < m { n } else { m }
    let mut arr = []
    let mut i = 0
    while i < k { arr.push(a[i] * b[i]); i = i + 1 }
    return tensor(arr)
        i = i + 1
}

fn tensor_scale(t, s) {
    let n = len(t)
    let mut arr = []
    let mut i = 0
    while i < n { arr.push(t[i] * s); i = i + 1 }
    return tensor(arr)
        i = i + 1
}

fn tensor_sum(t) {
    let n = len(t)
    let mut s = 0.0
    let mut i = 0
    while i < n { s = s + t[i]; i = i + 1 }
    return s
        i = i + 1
}

fn tensor_mean(t) {
    let n = len(t)
    if n == 0 { return 0.0 }
    return tensor_sum(t) / to_float(n)
}

fn tensor_max(t) {
    let n = len(t)
    if n == 0 { return 0.0 }
    let mut m = t[0]
    let mut i = 1
    while i < n { if t[i] > m { m = t[i] } i = i + 1 }
    return m
        i = i + 1
}

fn tensor_min(t) {
    let n = len(t)
    if n == 0 { return 0.0 }
    let mut m = t[0]
    let mut i = 1
    while i < n { if t[i] < m { m = t[i] } i = i + 1 }
    return m
        i = i + 1
}

fn tensor_neg(t) { return tensor_scale(t, -1.0) }

// ── Construction proofs ──────────────────────────────────────

proof t01_zeros_length { assert len(tensor_zeros(5)) == 5 }
proof t02_zeros_sum { assert tensor_sum(tensor_zeros(10)) == 0.0 }
proof t03_zeros_empty { assert len(tensor_zeros(0)) == 0 }
proof t04_ones_length { assert len(tensor_ones(7)) == 7 }
proof t05_ones_sum { assert tensor_sum(tensor_ones(5)) == 5.0 }
proof t06_ones_mean { assert tensor_mean(tensor_ones(100)) == 1.0 }
proof t07_fill_length { assert len(tensor_fill(6, 2.5)) == 6 }
proof t08_fill_sum { assert tensor_sum(tensor_fill(4, 3.0)) == 12.0 }
proof t09_fill_value { assert tensor_fill(5, 7.0)[0] == 7.0 }
proof t10_range_length { assert len(tensor_range(0, 6)) == 6 }

// ── Range semantics ──────────────────────────────────────────

proof t11_range_start { assert tensor_range(0, 5)[0] == 0.0 }
proof t12_range_end { assert tensor_range(0, 5)[4] == 4.0 }
proof t13_range_sum_5 { assert tensor_sum(tensor_range(0, 5)) == 10.0 }
proof t14_range_sum_10 { assert tensor_sum(tensor_range(0, 10)) == 45.0 }
proof t15_range_offset { assert tensor_sum(tensor_range(5, 10)) == 35.0 }

// ── Elementwise addition ─────────────────────────────────────

proof t16_add_zero { assert tensor_sum(tensor_add(tensor_zeros(5), tensor_ones(5))) == 5.0 }
proof t17_add_ones { assert tensor_sum(tensor_add(tensor_ones(4), tensor_ones(4))) == 8.0 }
proof t18_add_range { assert tensor_sum(tensor_add(tensor_range(0, 5), tensor_range(0, 5))) == 20.0 }
proof t19_add_commutative {
    let a = tensor_range(0, 10)
    let b = tensor_ones(10)
    assert tensor_sum(tensor_add(a, b)) == tensor_sum(tensor_add(b, a))
}
proof t20_add_identity {
    let a = tensor_range(0, 8)
    assert tensor_sum(tensor_add(a, tensor_zeros(8))) == tensor_sum(a)
}

// ── Elementwise subtraction ──────────────────────────────────

proof t21_sub_zero { assert tensor_sum(tensor_sub(tensor_ones(5), tensor_zeros(5))) == 5.0 }
proof t22_sub_self { assert tensor_sum(tensor_sub(tensor_ones(10), tensor_ones(10))) == 0.0 }
proof t23_sub_range { assert tensor_sum(tensor_sub(tensor_range(5, 10), tensor_range(0, 5))) == 25.0 }
proof t24_sub_identity {
    let a = tensor_range(0, 8)
    assert tensor_sum(tensor_sub(a, tensor_zeros(8))) == tensor_sum(a)
}
proof t25_sub_cancel {
    let a = tensor_range(0, 6)
    let b = tensor_ones(6)
    assert tensor_sum(tensor_add(tensor_sub(a, b), b)) == tensor_sum(a)
}

// ── Elementwise product ──────────────────────────────────────

proof t26_mul_zero { assert tensor_sum(tensor_mul(tensor_ones(5), tensor_zeros(5))) == 0.0 }
proof t27_mul_ones { assert tensor_sum(tensor_mul(tensor_ones(4), tensor_ones(4))) == 4.0 }
proof t28_mul_range { assert tensor_sum(tensor_mul(tensor_range(0, 5), tensor_range(0, 5))) == 30.0 }
proof t29_mul_commutative {
    let a = tensor_range(0, 6)
    let b = tensor_range(0, 6)
    assert tensor_sum(tensor_mul(a, b)) == tensor_sum(tensor_mul(b, a))
}
proof t30_mul_self_is_sq {
    let a = tensor_range(1, 5)
    // 1 + 4 + 9 + 16 = 30
    assert tensor_sum(tensor_mul(a, a)) == 30.0
}

// ── Scalar ops ───────────────────────────────────────────────

proof t31_scale_zero { assert tensor_sum(tensor_scale(tensor_ones(5), 0.0)) == 0.0 }
proof t32_scale_one { assert tensor_sum(tensor_scale(tensor_ones(5), 1.0)) == 5.0 }
proof t33_scale_two { assert tensor_sum(tensor_scale(tensor_ones(5), 2.0)) == 10.0 }
proof t34_scale_half { assert tensor_sum(tensor_scale(tensor_ones(10), 0.5)) == 5.0 }
proof t35_scale_neg { assert tensor_sum(tensor_scale(tensor_ones(5), -1.0)) == 0.0 - 5.0 }

// ── Reductions ───────────────────────────────────────────────

proof t36_sum_empty { assert tensor_sum(tensor_zeros(0)) == 0.0 }
proof t37_sum_large { assert tensor_sum(tensor_ones(1000)) == 1000.0 }
proof t38_mean_constant { assert tensor_mean(tensor_fill(100, 3.5)) == 3.5 }
proof t39_mean_range_5 { assert tensor_mean(tensor_range(0, 5)) == 2.0 }
proof t40_mean_range_10 { assert tensor_mean(tensor_range(0, 10)) == 4.5 }
proof t41_max_constant { assert tensor_max(tensor_fill(5, 7.0)) == 7.0 }
proof t42_max_range { assert tensor_max(tensor_range(0, 10)) == 9.0 }
proof t43_min_constant { assert tensor_min(tensor_fill(5, 7.0)) == 7.0 }
proof t44_min_range { assert tensor_min(tensor_range(0, 10)) == 0.0 }
proof t45_min_less_max {
    let r = tensor_range(1, 100)
    assert tensor_min(r) < tensor_max(r)
}

// ── Negation ─────────────────────────────────────────────────

proof t46_neg_zero { assert tensor_sum(tensor_neg(tensor_zeros(5))) == 0.0 }
proof t47_neg_ones { assert tensor_sum(tensor_neg(tensor_ones(5))) == 0.0 - 5.0 }
proof t48_neg_twice {
    let a = tensor_range(0, 10)
    assert tensor_sum(tensor_neg(tensor_neg(a))) == tensor_sum(a)
}
proof t49_neg_plus_self {
    let a = tensor_range(1, 6)
    assert tensor_sum(tensor_add(a, tensor_neg(a))) == 0.0
}
proof t50_neg_sum_identity {
    let a = tensor_range(0, 5)
    assert tensor_sum(tensor_neg(a)) == 0.0 - tensor_sum(a)
}

// ── Algebraic identities ─────────────────────────────────────

proof t51_distributive {
    let a = tensor_range(0, 4)
    let b = tensor_ones(4)
    let lhs = tensor_sum(tensor_scale(tensor_add(a, b), 2.0))
    let rhs = tensor_sum(tensor_add(tensor_scale(a, 2.0), tensor_scale(b, 2.0)))
    assert lhs == rhs
}
proof t52_add_zero_identity {
    let a = tensor_range(0, 10)
    assert tensor_sum(tensor_add(a, tensor_zeros(10))) == tensor_sum(a)
}
proof t53_sub_zero_identity {
    let a = tensor_range(0, 10)
    assert tensor_sum(tensor_sub(a, tensor_zeros(10))) == tensor_sum(a)
}
proof t54_double_via_add {
    let a = tensor_range(0, 6)
    assert tensor_sum(tensor_add(a, a)) == 2.0 * tensor_sum(a)
}
proof t55_double_via_scale {
    let a = tensor_range(0, 6)
    assert tensor_sum(tensor_scale(a, 2.0)) == 2.0 * tensor_sum(a)
}

// ── Dot product proofs ──────────────────────────────────────

proof t56_dot_zero { assert dot(tensor_zeros(5), tensor_ones(5)) == 0.0 }
proof t57_dot_ones { assert dot(tensor_ones(10), tensor_ones(10)) == 10.0 }
proof t58_dot_self_sq {
    let a = tensor_range(0, 5)
    // 0+1+4+9+16 = 30
    assert dot(a, a) == 30.0
}
proof t59_dot_commutative {
    let a = tensor_range(0, 8)
    let b = tensor_ones(8)
    assert dot(a, b) == dot(b, a)
}
proof t60_dot_scales {
    let a = tensor_ones(5)
    let b = tensor_ones(5)
    assert dot(tensor_scale(a, 3.0), b) == 3.0 * dot(a, b)
}

println("[test_tensor_ops_suite] 60 proofs declared — run with --test")
