// self/test_lfu_cache.hexa -- Tests for self/runtime/lfu_cache_pure.hexa

// ── inlined from self/runtime/lfu_cache_pure.hexa ──────────────
// codegen_c2 import/use resolution for runtime/*_pure.hexa is not wired
// for test files; inline the module contents (same pattern as test_rle_pure).

// Dict-based LFU to avoid nested-array codegen flattening
fn _lfu_make(keys, vals, freqs, cap) {
    let mut c = #{}
    c["k"] = keys
    c["v"] = vals
    c["f"] = freqs
    c["cap"] = cap
    return c
}

fn lfu_new(capacity) {
    return _lfu_make([], [], [], capacity)
}

fn _lfu_find(keys, key) {
    let mut i = 0
    while i < len(keys) {
        if to_string(keys[i]) == to_string(key) { return i }
        i = i + 1
    }
    -1
}

fn _lfu_set_at(arr, idx, val) {
    let mut out = []
    let mut i = 0
    while i < len(arr) {
        if i == idx {
            out.push(val)
        } else {
            out.push(arr[i])
        }
        i = i + 1
    }
    out
}

fn _lfu_remove_at(arr, idx) {
    let mut out = []
    let mut i = 0
    while i < len(arr) {
        if i != idx {
            out.push(arr[i])
        }
        i = i + 1
    }
    out
}

fn _lfu_min_freq_idx(freqs) {
    let mut min_idx = 0
    let mut min_val = freqs[0]
    let mut i = 1
    while i < len(freqs) {
        if freqs[i] < min_val {
            min_val = freqs[i]
            min_idx = i
        }
        i = i + 1
    }
    min_idx
}

fn lfu_get(cache, key) {
    let keys = cache["k"]
    let vals = cache["v"]
    let freqs = cache["f"]
    let cap = cache["cap"]
    let idx = _lfu_find(keys, key)
    if idx == -1 {
        let mut r = #{}
        r["cache"] = cache
        r["val"] = nil
        return r
    }
    let new_freqs = _lfu_set_at(freqs, idx, freqs[idx] + 1)
    let mut r = #{}
    r["cache"] = _lfu_make(keys, vals, new_freqs, cap)
    r["val"] = vals[idx]
    return r
}

fn lfu_put(cache, key, val) {
    let keys = cache["k"]
    let vals = cache["v"]
    let freqs = cache["f"]
    let cap = cache["cap"]
    let idx = _lfu_find(keys, key)
    if idx != -1 {
        let new_vals = _lfu_set_at(vals, idx, val)
        let new_freqs = _lfu_set_at(freqs, idx, freqs[idx] + 1)
        return _lfu_make(keys, new_vals, new_freqs, cap)
    }
    let mut k = keys
    let mut v = vals
    let mut f = freqs
    if len(k) >= cap {
        let evict = _lfu_min_freq_idx(f)
        k = _lfu_remove_at(k, evict)
        v = _lfu_remove_at(v, evict)
        f = _lfu_remove_at(f, evict)
    }
    k.push(key)
    v.push(val)
    f.push(1)
    return _lfu_make(k, v, f, cap)
}

fn lfu_size(cache) {
    len(cache["k"])
}

// ── end inlined ───────────────────────────────────────────────────

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  lfu_cache_pure.hexa — test runner")
println("═══════════════════════════════════════════════════════")

// ── new cache ──────────────────────────────────────────────────
println("")
println("--- lfu_new ---")
let mut c0_fresh = nil
c0_fresh = lfu_new(3)
check("new size", lfu_size(c0_fresh), 0)

// ── put and get ────────────────────────────────────���───────────
println("")
println("--- put and get ---")
let mut c1 = nil
c1 = lfu_put(lfu_new(3), "a", 10)
check("put a size", lfu_size(c1), 1)
let mut r1 = nil
r1 = lfu_get(c1, "a")
check("get a val", r1["val"], 10)

let mut c2 = nil
c2 = lfu_put(c1, "b", 20)
let mut c3 = nil
c3 = lfu_put(c2, "c", 30)
check("put 3 size", lfu_size(c3), 3)

let mut r2 = nil
r2 = lfu_get(c3, "b")
check("get b val", r2["val"], 20)
let mut r3 = nil
r3 = lfu_get(c3, "c")
check("get c val", r3["val"], 30)

// ── miss ───────────────────────────────────────────────────────
println("")
println("--- miss ---")
let mut r_miss = nil
r_miss = lfu_get(c3, "z")
check("miss val", r_miss["val"], nil)

// ── eviction ───────────────────────────────────────────────────
println("")
println("--- eviction (LFU) ---")
// Build a fresh cache with 3 items, then access a and b to increase freq
let mut ec = nil
ec = lfu_new(3)
ec = lfu_put(ec, "a", 10)
ec = lfu_put(ec, "b", 20)
ec = lfu_put(ec, "c", 30)
// Access "a" and "b" to increase their freq
let mut tmp1 = nil
tmp1 = lfu_get(ec, "a")
ec = tmp1["cache"]
let mut tmp2 = nil
tmp2 = lfu_get(ec, "b")
ec = tmp2["cache"]
// now a:freq=2, b:freq=2, c:freq=1
// insert "d" -> evicts "c" (freq=1)
ec = lfu_put(ec, "d", 40)
check("after evict size", lfu_size(ec), 3)
let mut r_d = nil
r_d = lfu_get(ec, "d")
check("get d val", r_d["val"], 40)
let mut r_c_evicted = nil
r_c_evicted = lfu_get(ec, "c")
check("c evicted", r_c_evicted["val"], nil)
let mut r_a_still = nil
r_a_still = lfu_get(ec, "a")
check("a still present", r_a_still["val"], 10)

// ── update existing ────────────────────────────────────────────
println("")
println("--- update existing ---")
let mut uc = nil
uc = lfu_new(2)
uc = lfu_put(uc, "x", 100)
uc = lfu_put(uc, "x", 200)
check("update size", lfu_size(uc), 1)
let mut r_upd = nil
r_upd = lfu_get(uc, "x")
check("update val", r_upd["val"], 200)

// ── capacity 1 ─────────────────────────────────────────────────
println("")
println("--- capacity 1 ---")
let mut tc = nil
tc = lfu_new(1)
tc = lfu_put(tc, "p", 1)
tc = lfu_put(tc, "q", 2)
check("cap1 size", lfu_size(tc), 1)
let mut rt1 = nil
rt1 = lfu_get(tc, "q")
check("cap1 has q", rt1["val"], 2)
let mut rt2 = nil
rt2 = lfu_get(tc, "p")
check("cap1 p evicted", rt2["val"], nil)

// ── Summary ────────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    println("FAIL")
    exit(1)
}
println("ALL PASS")
