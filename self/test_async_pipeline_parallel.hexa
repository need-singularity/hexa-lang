// ===================================================================
//  async_pipeline_parallel.hexa — Interleaved Microbatch Scheduling
//
//  Pure .hexa CPU simulation of advanced pipeline parallelism with:
//    - 1F1B schedule: one-forward-one-backward steady state
//    - Microbatch splitting: divide batch into M microbatches
//    - Pipeline stages: assign consecutive layers to stages
//    - Bubble ratio computation and measurement
//    - Chimera schedule: bidirectional pipeline for less bubble
//    - Activation stashing: store activations per microbatch for backward
//
//  This extends the basic pipeline_parallel module with async scheduling
//  and chimera bidirectional pipelining.
//
//  ML roadmap #242 — Async Pipeline Parallel
// ===================================================================

// ── Stage assignment ────────────────────────────────────────

struct AppStageConfig {
    num_stages: int,
    num_layers: int,
    num_micro: int,
    layer_bounds: array
}

fn app_init(num_stages, num_layers, num_micro) {
    let mut bounds = []
    let mut s = 0
    while s < num_stages {
        let begin = (num_layers * s) / num_stages
        let end = (num_layers * (s + 1)) / num_stages
        bounds.push([begin, end])
        s = s + 1
    }
    AppStageConfig {
        num_stages: num_stages,
        num_layers: num_layers,
        num_micro: num_micro,
        layer_bounds: bounds
    }
}

fn app_stage_begin(cfg, stage) {
    let b = cfg.layer_bounds[stage]
    b[0]
}

fn app_stage_end(cfg, stage) {
    let b = cfg.layer_bounds[stage]
    b[1]
}

// ── Toy linear model forward/backward ───────────────────────

fn app_stage_forward(x, weights, layer_begin, layer_end) {
    let mut y = x
    let mut l = layer_begin
    while l < layer_end {
        y = y + weights[l]
        l = l + 1
    }
    y
}

fn app_stage_backward(grad_out, layer_begin, layer_end) {
    let num_layers = layer_end - layer_begin
    let mut w_grads = []
    let mut l = 0
    while l < num_layers {
        w_grads.push(grad_out)
        l = l + 1
    }
    return [grad_out, w_grads]
}

// ── Microbatch splitting ────────────────────────────────────

fn app_split_batch(batch_data, num_micro) {
    let total = len(batch_data)
    let micro_size = total / num_micro
    let mut micros = []
    let mut m = 0
    while m < num_micro {
        let mut micro = []
        let mut i = 0
        while i < micro_size {
            micro.push(batch_data[m * micro_size + i])
            i = i + 1
        }
        micros.push(micro)
        m = m + 1
    }
    micros
}

// ═══════════════════════════════════════════════════════════════
//  1F1B Schedule Builder
//
//  Generates a list of [stage, kind, micro_id, step] events.
//  kind: 0 = forward, 1 = backward
//  Steady state: after warmup forwards, alternate 1 backward + 1 forward
// ═══════════════════════════════════════════════════════════════

fn app_build_1f1b(num_stages, num_micro) {
    let P = num_stages
    let M = num_micro
    let mut events = []

    // Per-stage tracking
    let mut next_f = []
    let mut next_b = []
    let mut s = 0
    while s < P {
        next_f.push(0)
        next_b.push(0)
        s = s + 1
    }

    let target = P * M
    let mut step = 0
    let mut done_f = 0
    let mut done_b = 0

    while done_f + done_b < 2 * target {
        let mut ss = P - 1
        while ss >= 0 {
            let nf = next_f[ss]
            let nb = next_b[ss]

            // Check backward eligibility
            let mut can_b = false
            if nb < M {
                if nf > nb {
                    if ss == P - 1 {
                        can_b = true
                    } else {
                        if next_b[ss + 1] > nb {
                            can_b = true
                        }
                    }
                }
            }

            // Check forward eligibility
            let mut can_f = false
            if nf < M {
                if ss == 0 {
                    can_f = true
                } else {
                    if next_f[ss - 1] > nf {
                        can_f = true
                    }
                }
            }

            // Prefer backward when available (1F1B policy)
            let mut did = false
            if can_b {
                events.push([ss, 1, nb, step])
                next_b[ss] = nb + 1
                done_b = done_b + 1
                did = true
            }
            if !did {
                if can_f {
                    events.push([ss, 0, nf, step])
                    next_f[ss] = nf + 1
                    done_f = done_f + 1
                    did = true
                }
            }

            ss = ss - 1
        }
        step = step + 1
        if step > 4 * target + 8 { break }
    }
    events
}

// ── Bubble ratio ────────────────────────────────────────────

fn app_bubble_ratio(num_stages, num_micro) {
    let p = to_float(num_stages)
    let m = to_float(num_micro)
    let den = m + p - 1.0
    if den <= 0.0 { return 0.0 }
    (p - 1.0) / den
}

fn app_bubble_ratio_measured(events, num_stages, num_micro) {
    // Count distinct time steps from the event list
    let n = len(events)
    if n == 0 { return 0.0 }

    // Find max step to determine total wall-clock steps
    let mut max_step = 0
    let mut i = 0
    while i < n {
        let e = events[i]
        if e[3] > max_step {
            max_step = e[3]
        }
        i = i + 1
    }
    let total_steps = max_step + 1
    let total_possible = total_steps * num_stages
    if total_possible == 0 { return 0.0 }
    1.0 - to_float(n) / to_float(total_possible)
}

// ═══════════════════════════════════════════════════════════════
//  1F1B Executor with Activation Stashing
// ═══════════════════════════════════════════════════════════════

struct AppResult {
    outputs: array,
    weight_grads: array,
    bubble_ratio: float,
    events_run: int
}

fn app_run_1f1b(cfg, inputs, weights) {
    let P = cfg.num_stages
    let M = cfg.num_micro
    let L = cfg.num_layers
    let events = app_build_1f1b(P, M)

    // Activation stash: per-stage, per-microbatch storage
    // stash[stage][micro] = intermediate activation
    let mut stash = []
    let mut s = 0
    while s < P {
        let mut micro_stash = []
        let mut m = 0
        while m < M {
            micro_stash.push(0.0)
            m = m + 1
        }
        stash.push(micro_stash)
        s = s + 1
    }

    // Inter-stage buffers
    let mut fwd_buf = []
    let mut bwd_buf = []
    let mut m = 0
    while m < M {
        fwd_buf.push(0.0)
        bwd_buf.push(0.0)
        m = m + 1
    }

    let mut outputs = []
    let mut wgrad = []
    m = 0
    while m < M { outputs.push(0.0); m = m + 1 }
    let mut l = 0
    while l < L { wgrad.push(0.0); l = l + 1 }

    let n_events = len(events)
    let mut ei = 0
    while ei < n_events {
        let e = events[ei]
        let stage = e[0]
        let kind = e[1]
        let mid = e[2]

        let lb = app_stage_begin(cfg, stage)
        let le = app_stage_end(cfg, stage)

        if kind == 0 {
            // Forward
            let mut x = 0.0
            if stage == 0 {
                x = inputs[mid]
            } else {
                x = fwd_buf[mid]
            }

            // Stash input activation for backward
            stash[stage][mid] = x

            let y = app_stage_forward(x, weights, lb, le)

            if stage == P - 1 {
                outputs[mid] = y
                bwd_buf[mid] = 1.0
            } else {
                fwd_buf[mid] = y
            }
        }

        if kind == 1 {
            // Backward
            let grad_out = bwd_buf[mid]
            let back = app_stage_backward(grad_out, lb, le)
            let grad_in = back[0]
            let w_grads = back[1]

            // Accumulate weight grads
            let mut ll = lb
            let mut k = 0
            while ll < le {
                wgrad[ll] = wgrad[ll] + w_grads[k]
                ll = ll + 1
                k = k + 1
            }

            if stage > 0 {
                bwd_buf[mid] = grad_in
            }
        }

        ei = ei + 1
    }

    let bubble = app_bubble_ratio_measured(events, P, M)

    AppResult {
        outputs: outputs,
        weight_grads: wgrad,
        bubble_ratio: bubble,
        events_run: n_events
    }
}

// ═══════════════════════════════════════════════════════════════
//  Chimera Schedule — Bidirectional Pipeline
//
//  Two pipeline directions run simultaneously:
//    - Forward direction: stages 0 -> 1 -> ... -> P-1
//    - Backward direction: stages P-1 -> P-2 -> ... -> 0
//  Half the microbatches go in each direction.
//  This reduces bubble by overlapping both directions.
// ═══════════════════════════════════════════════════════════════

fn app_build_chimera(num_stages, num_micro) {
    // Split microbatches: first half goes forward, second half goes backward
    let half = num_micro / 2
    let mut events = []

    // Build forward direction schedule for first half
    let fwd_events = app_build_1f1b(num_stages, half)
    let mut i = 0
    while i < len(fwd_events) {
        let e = fwd_events[i]
        // Mark as direction 0 (forward)
        events.push([e[0], e[1], e[2], e[3], 0])
        i = i + 1
    }

    // Build reversed direction schedule for second half
    // Reverse stage order: stage s -> (P-1-s)
    let bwd_events = app_build_1f1b(num_stages, num_micro - half)
    i = 0
    while i < len(bwd_events) {
        let e = bwd_events[i]
        let reversed_stage = num_stages - 1 - e[0]
        events.push([reversed_stage, e[1], e[2] + half, e[3], 1])
        i = i + 1
    }

    events
}

fn app_chimera_bubble_ratio(num_stages, num_micro) {
    // Chimera roughly halves the bubble compared to 1F1B
    let standard = app_bubble_ratio(num_stages, num_micro)
    standard * 0.5
}

// ── Throughput scaling estimate ─────────────────────────────

fn app_throughput_scaling(num_stages, num_micro) {
    // Ideal linear scaling minus bubble overhead
    let efficiency = 1.0 - app_bubble_ratio(num_stages, num_micro)
    to_float(num_stages) * efficiency
}

// ── Reference single forward ────────────────────────────────

fn app_single_forward(x, weights) {
    let L = len(weights)
    app_stage_forward(x, weights, 0, L)
}

println("[async_pipeline_parallel] module loaded — 1F1B + chimera scheduling ready")


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn app_test_fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn app_test_approx(a, b, eps) { return app_test_fabs(a - b) < eps }

fn check(idx, name, cond) {
    if cond {
        println("[PASS] #" + str(idx) + " " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] #" + str(idx) + " " + name)
        fail_count = fail_count + 1
    }
}

println("=== Async Pipeline Parallel (#242) Tests ===")

// ── Fixtures ────────────────────────────────────────────────────
let P = 4   // stages
let L = 8   // layers
let M = 6   // microbatches
let cfg = app_init(P, L, M)

// Toy weights: w[l] = 0.5
let mut weights = []
let mut li = 0
while li < L {
    weights.push(0.5)
    li = li + 1
}

// Inputs: one scalar per microbatch
let mut inputs = []
let mut mi = 0
while mi < M {
    inputs.push(to_float(mi))
    mi = mi + 1
}

// ═══════════════════════════════════════════════════════════════
//  #1-#4 — Stage config
// ═══════════════════════════════════════════════════════════════

check(1, "app_init fields", cfg.num_stages == P && cfg.num_layers == L && cfg.num_micro == M)
check(2, "interp layer range = [0,2)",
    app_stage_begin(cfg, 0) == 0 && app_stage_end(cfg, 0) == 2)
check(3, "stage3 layer range = [6,8)",
    app_stage_begin(cfg, 3) == 6 && app_stage_end(cfg, 3) == 8)

// Stage bounds partition [0, L) exactly
let mut partition_ok = true
let mut s_check = 0
while s_check < P {
    if s_check > 0 {
        if app_stage_begin(cfg, s_check) != app_stage_end(cfg, s_check - 1) {
            partition_ok = false
        }
    }
    s_check = s_check + 1
}
check(4, "stage bounds form a contiguous partition", partition_ok)

// ═══════════════════════════════════════════════════════════════
//  #5-#6 — Stage forward / reference
// ═══════════════════════════════════════════════════════════════

// Toy model: forward over L layers of bias 0.5 — y = x + L*0.5 = x + 4.0
let y_stage0 = app_stage_forward(0.0, weights, 0, 2)
check(5, "interp forward (2 layers): 0 + 1.0 = 1.0",
    app_test_approx(y_stage0, 1.0, 1.0e-9))

let full = app_single_forward(3.0, weights)
check(6, "single_forward(3.0) = 3.0 + 8*0.5 = 7.0",
    app_test_approx(full, 7.0, 1.0e-9))

// ═══════════════════════════════════════════════════════════════
//  #7-#8 — Microbatch splitting (dispatch)
// ═══════════════════════════════════════════════════════════════

let batch = [10.0, 20.0, 30.0, 40.0, 50.0, 60.0]
let micros = app_split_batch(batch, 3)
check(7, "split_batch 3 micros", len(micros) == 3 && len(micros[0]) == 2)
check(8, "split_batch values",
    app_test_approx(micros[0][0], 10.0, 1.0e-9)
    && app_test_approx(micros[1][0], 30.0, 1.0e-9)
    && app_test_approx(micros[2][1], 60.0, 1.0e-9))

// ═══════════════════════════════════════════════════════════════
//  #9-#14 — 1F1B schedule construction + counts
// ═══════════════════════════════════════════════════════════════

let events = app_build_1f1b(P, M)
check(9, "1F1B produces events", len(events) > 0)

// Count forwards and backwards: should be exactly P*M each
let mut fwd_count = 0
let mut bwd_count = 0
let mut ev_i = 0
while ev_i < len(events) {
    let e = events[ev_i]
    if e[1] == 0 { fwd_count = fwd_count + 1 }
    if e[1] == 1 { bwd_count = bwd_count + 1 }
    ev_i = ev_i + 1
}
check(10, "1F1B forward count = P*M", fwd_count == P * M)
check(11, "1F1B backward count = P*M", bwd_count == P * M)

// Stage 0 forward for micro 0 must appear (and before any backward on stage P-1)
let mut stage0_fwd0_idx = -1
let mut stage_last_bwd0_idx = -1
ev_i = 0
while ev_i < len(events) {
    let e = events[ev_i]
    if e[0] == 0 && e[1] == 0 && e[2] == 0 && stage0_fwd0_idx < 0 {
        stage0_fwd0_idx = ev_i
    }
    if e[0] == P - 1 && e[1] == 1 && e[2] == 0 && stage_last_bwd0_idx < 0 {
        stage_last_bwd0_idx = ev_i
    }
    ev_i = ev_i + 1
}
check(12, "1F1B has interp forward micro0", stage0_fwd0_idx >= 0)
check(13, "1F1B has last-stage backward micro0", stage_last_bwd0_idx >= 0)
check(14, "1F1B ordering: fwd interp micro0 before bwd stageLast micro0",
    stage0_fwd0_idx < stage_last_bwd0_idx)

// Per-stage forward ordering: forwards of stage s for micro 0..M-1 must be monotonic
let mut stage_order_ok = true
let mut s_o = 0
while s_o < P {
    let mut last_fwd_mid = -1
    let mut ei = 0
    while ei < len(events) {
        let e = events[ei]
        if e[0] == s_o && e[1] == 0 {
            if e[2] < last_fwd_mid { stage_order_ok = false }
            last_fwd_mid = e[2]
        }
        ei = ei + 1
    }
    s_o = s_o + 1
}
check(15, "per-stage forwards are in micro-id order", stage_order_ok)

// ═══════════════════════════════════════════════════════════════
//  #16-#18 — Bubble ratio
// ═══════════════════════════════════════════════════════════════

let bub = app_bubble_ratio(P, M)
check(16, "bubble_ratio in [0,1)", bub >= 0.0 && bub < 1.0)

// More microbatches -> lower bubble
check(17, "bubble_ratio(P, 12) < bubble_ratio(P, 3)",
    app_bubble_ratio(P, 12) < app_bubble_ratio(P, 3))

// Expected formula: (P-1)/(M+P-1) = 3/9 = 1/3 for P=4, M=6
check(18, "bubble_ratio P=4 M=6 formula",
    app_test_approx(app_bubble_ratio(4, 6), 3.0 / 9.0, 1.0e-6))

// ═══════════════════════════════════════════════════════════════
//  #19-#23 — Executor run + activation stashing
// ═══════════════════════════════════════════════════════════════

let res = app_run_1f1b(cfg, inputs, weights)
check(19, "events_run > 0", res.events_run > 0)
check(20, "outputs length = num_micro", len(res.outputs) == M)

// For our toy model each micro produces input + L*0.5
let mut out_ok = true
let mut oi = 0
while oi < M {
    let expected = to_float(oi) + to_float(L) * 0.5
    if !app_test_approx(res.outputs[oi], expected, 1.0e-6) { out_ok = false }
    oi = oi + 1
}
check(21, "1F1B executor outputs match single_forward per micro", out_ok)

// Weight grads should have shape L and all equal 1.0 * M (each micro contributes 1.0)
check(22, "weight_grads length = L", len(res.weight_grads) == L)

let mut wg_ok = true
let mut wi = 0
while wi < L {
    if !app_test_approx(res.weight_grads[wi], to_float(M), 1.0e-6) { wg_ok = false }
    wi = wi + 1
}
check(23, "weight_grads per layer = M (accumulated over microbatches)", wg_ok)

// Bubble ratio reported in result should be a finite float
check(24, "result bubble_ratio finite",
    res.bubble_ratio >= -1.0 && res.bubble_ratio < 2.0)

// ═══════════════════════════════════════════════════════════════
//  #25-#28 — Chimera bidirectional schedule
// ═══════════════════════════════════════════════════════════════

let chimera = app_build_chimera(P, M)
check(25, "chimera produces events", len(chimera) > 0)

// Chimera events include direction marker at index 4 (0 fwd, 1 bwd direction)
let mut dir0 = 0
let mut dir1 = 0
let mut cei = 0
while cei < len(chimera) {
    let e = chimera[cei]
    if e[4] == 0 { dir0 = dir0 + 1 }
    if e[4] == 1 { dir1 = dir1 + 1 }
    cei = cei + 1
}
check(26, "chimera has both directions", dir0 > 0 && dir1 > 0)

// Half microbatches should go each direction (approximately)
check(27, "chimera direction 0 count = 1F1B(P, M/2) * 2 (fwd+bwd)",
    dir0 == len(app_build_1f1b(P, M / 2)))

// Chimera bubble ratio < standard 1F1B bubble ratio
let chim_bub = app_chimera_bubble_ratio(P, M)
check(28, "chimera bubble ratio < standard 1F1B bubble ratio",
    chim_bub < app_bubble_ratio(P, M))

// ═══════════════════════════════════════════════════════════════
//  #29-#30 — Throughput scaling
// ═══════════════════════════════════════════════════════════════

let t1 = app_throughput_scaling(2, 8)
let t2 = app_throughput_scaling(4, 8)
check(29, "throughput 4 stages >= throughput 2 stages",
    t2 >= t1)

// Throughput should be less than num_stages (efficiency < 1)
check(30, "throughput scaling < num_stages (bubble overhead)",
    t2 < to_float(4))

// ── summary ─────────────────────────────────────────────────────
println("")
println("=== Async Pipeline Parallel test summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
