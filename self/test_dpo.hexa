// -- inlined from self/runtime/math_pure.hexa --
// codegen import not wired for test files

// ═══════════════════════════════════════════════════════════════════
//  self/runtime/math_pure.hexa — pure-Hexa math/numeric primitives
//
//  Replaces libm-dependent math functions from the C runtime with
//  pure Hexa implementations. Uses Taylor series, Newton-Raphson,
//  and range reduction — no syscalls, no libm, no FFI.
//
//  Public API (basic):
//      abs_pure(v)             neg_pure(v)
//      sign_pure(v)            null_coal_pure(a, b)
//      min_pure(a, b)          max_pure(a, b)
//      clamp_pure(v, lo, hi)   lerp_pure(a, b, t)
//
//  Public API (rounding):
//      floor_pure(x)           ceil_pure(x)
//      round_pure(x)           trunc_pure(x)
//      fmod_pure(x, y)
//
//  Public API (transcendental):
//      sqrt_pure(x)            cbrt_pure(x)
//      exp_pure(x)             log_pure(x)
//      log2_pure(x)            log10_pure(x)
//      pow_pure(base, exp)
//      sin_pure(x)             cos_pure(x)
//      tan_pure(x)             atan_pure(x)
//      asin_pure(x)            acos_pure(x)
//      atan2_pure(y, x)
//      sinh_pure(x)            cosh_pure(x)
//      tanh_pure(x)
//      hypot_pure(x, y)
//      degrees_pure(rad)       radians_pure(deg)
//
//  Public API (utilities):
//      is_close_pure(a, b, tol)
//      sum_pure(arr)           mean_pure(arr)
//      factorial_pure(n)       gcd_pure(a, b)
//      lcm_pure(a, b)
// ═══════════════════════════════════════════════════════════════════

// ── Constants (float64 precision) ────────────────────────────────
// We define these as functions to avoid global mutable state issues.

@pure
fn _pi() { return 3.14159265358979323846 }

@pure
fn _two_pi() { return 6.28318530717958647692 }

@pure
fn _half_pi() { return 1.57079632679489661923 }

@pure
fn _e() { return 2.71828182845904523536 }

@pure
fn _ln2() { return 0.69314718055994530942 }

@pure
fn _ln10() { return 2.30258509299404568402 }

@pure
fn _log2e() { return 1.44269504088896340736 }

@pure
fn _log10e() { return 0.43429448190325182765 }

@pure
fn _sqrt2() { return 1.41421356237309504880 }

// Public constant accessors
@pure
pub fn pi_pure() { return _pi() }

@pure
pub fn e_pure() { return _e() }

// ═══════════════════════════════════════════════════════════════════
//  SECTION 1: Basic arithmetic helpers
// ═══════════════════════════════════════════════════════════════════

// ── abs_pure ──────────────────────────────────────────────────────
@pure
pub fn abs_pure(v) {
    let t = type_of(v)
    if t == "int" {
        if v < 0 { return 0 - v }
        return v
    }
    if t == "float" {
        if v < 0.0 { return 0.0 - v }
        return v
    }
    v
}

// ── neg_pure ──────────────────────────────────────────────────────
@pure
pub fn neg_pure(v) {
    let t = type_of(v)
    if t == "int" { return 0 - v }
    if t == "float" { return 0.0 - v }
    v
}

// ── sign_pure ─────────────────────────────────────────────────────
@pure
pub fn sign_pure(v) {
    let t = type_of(v)
    if t == "int" {
        if v > 0 { return 1 }
        if v < 0 { return -1 }
        return 0
    }
    if t == "float" {
        if v > 0.0 { return 1.0 }
        if v < 0.0 { return -1.0 }
        return 0.0
    }
    0
}

// ── null_coal_pure ────────────────────────────────────────────────
@pure
pub fn null_coal_pure(a, b) {
    if type_of(a) == "void" { return b }
    if type_of(a) == "string" {
        if len(a) == 0 { return b }
    }
    a
}

// ── min_pure / max_pure ──────────────────────────────────────────
@pure
pub fn min_pure(a, b) {
    let ta = type_of(a)
    let tb = type_of(b)
    if ta != "int" {
        if ta != "float" { return a }
    }
    if tb != "int" {
        if tb != "float" { return a }
    }
    if a < b { return a }
    b
}

@pure
pub fn max_pure(a, b) {
    let ta = type_of(a)
    let tb = type_of(b)
    if ta != "int" {
        if ta != "float" { return a }
    }
    if tb != "int" {
        if tb != "float" { return a }
    }
    if a > b { return a }
    b
}

// ── clamp_pure ────────────────────────────────────────────────────
@pure
pub fn clamp_pure(v, lo, hi) {
    if lo > hi { return lo }
    if v < lo { return lo }
    if v > hi { return hi }
    v
}

// ── lerp_pure ─────────────────────────────────────────────────────
// Linear interpolation: a + t*(b - a)
@pure
pub fn lerp_pure(a, b, t) {
    return a + t * (b - a)
}

// ═══════════════════════════════════════════════════════════════════
//  SECTION 2: Rounding functions
// ═══════════════════════════════════════════════════════════════════

// ── _to_float — ensure we work with float64 ──────────────────────
@pure
fn _to_float(x) {
    if type_of(x) == "int" { return x * 1.0 }
    return x
}

// ── trunc_pure — truncate toward zero ─────────────────────────────
@pure
pub fn trunc_pure(x) {
    let f = _to_float(x)
    // Integer truncation: subtract the fractional part
    // For positive: floor; for negative: ceil (toward zero)
    if f >= 0.0 {
        // f - frac: compute integer part by repeated subtraction
        let mut i = 0.0
        let mut step = 1099511627776.0  // 2^40 starting step
        while step >= 1.0 {
            while (i + step) <= f {
                i = i + step
            }
            step = step * 0.5
            // Snap step to 1.0 once below 2.0
            if step < 1.0 { step = 0.0 }
        }
        return i
    }
    // Negative: trunc(-3.7) = -3.0
    let pos = 0.0 - f
    let mut i = 0.0
    let mut step = 1099511627776.0
    while step >= 1.0 {
        while (i + step) <= pos {
            i = i + step
        }
        step = step * 0.5
        if step < 1.0 { step = 0.0 }
    }
    return 0.0 - i
}

// ── floor_pure — round toward negative infinity ───────────────────
@pure
pub fn floor_pure(x) {
    let f = _to_float(x)
    let t = trunc_pure(f)
    // If already integer or positive truncation works
    if t == f { return t }
    // For negative non-integer, floor is trunc - 1
    if f < 0.0 { return t - 1.0 }
    return t
}

// ── ceil_pure — round toward positive infinity ────────────────────
@pure
pub fn ceil_pure(x) {
    let f = _to_float(x)
    let t = trunc_pure(f)
    if t == f { return t }
    if f > 0.0 { return t + 1.0 }
    return t
}

// ── round_pure — round half to even (banker's rounding) ──────────
// Simplified: round half away from zero
@pure
pub fn round_pure(x) {
    let f = _to_float(x)
    if f >= 0.0 {
        return floor_pure(f + 0.5)
    }
    return ceil_pure(f - 0.5)
}

// ── fmod_pure — floating point modulo ─────────────────────────────
@pure
pub fn fmod_pure(x, y) {
    if y == 0.0 { return 0.0 }
    let fx = _to_float(x)
    let fy = _to_float(y)
    let q = trunc_pure(fx / fy)
    return fx - q * fy
}

// ═══════════════════════════════════════════════════════════════════
//  SECTION 3: Square root — Newton-Raphson
// ═══════════════════════════════════════════════════════════════════

// ── sqrt_pure — Newton-Raphson iteration ─────────────────────────
// x_{n+1} = 0.5 * (x_n + S/x_n)
// Converges quadratically; 50 iterations is more than enough for
// float64 (53-bit mantissa).
@pure
pub fn sqrt_pure(x) {
    let s = _to_float(x)
    if s < 0.0 { return 0.0 - 1.0 }  // NaN-equivalent: return -1
    if s == 0.0 { return 0.0 }
    // Initial guess: start from s/2 or 1.0, whichever is more reasonable
    let mut guess = if s > 1.0 { s * 0.5 } else { 1.0 }
    let mut i = 0
    while i < 60 {
        let next = 0.5 * (guess + s / guess)
        // Check convergence
        let diff = next - guess
        let ad = if diff < 0.0 { 0.0 - diff } else { diff }
        if ad < 1.0e-15 * next {
            if ad < 1.0e-15 { return next }
        }
        guess = next
        i = i + 1
    }
    return guess
}

// ── cbrt_pure — cube root via Newton-Raphson ─────────────────────
// x_{n+1} = (2*x_n + S/(x_n^2)) / 3
@pure
pub fn cbrt_pure(x) {
    let s = _to_float(x)
    if s == 0.0 { return 0.0 }
    let neg = s < 0.0
    let a = if neg { 0.0 - s } else { s }
    let mut guess = a / 3.0
    if guess == 0.0 { guess = 1.0 }
    let mut i = 0
    while i < 80 {
        let g2 = guess * guess
        let next = (2.0 * guess + a / g2) / 3.0
        let diff = next - guess
        let ad = if diff < 0.0 { 0.0 - diff } else { diff }
        if ad < 1.0e-15 * (if next < 0.0 { 0.0 - next } else { next }) {
            if neg { return 0.0 - next }
            return next
        }
        guess = next
        i = i + 1
    }
    if neg { return 0.0 - guess }
    return guess
}

// ═══════════════════════════════════════════════════════════════════
//  SECTION 4: Exponential — Taylor series
// ═══════════════════════════════════════════════════════════════════

// ── exp_pure — e^x via Taylor series with range reduction ────────
// Range reduction: e^x = 2^k * e^r where r = x - k*ln(2), |r| < ln(2)/2
// Then compute e^r via Taylor: sum_{n=0}^{N} r^n / n!
@pure
pub fn exp_pure(x) {
    let f = _to_float(x)
    // Handle extreme values
    if f > 709.0 { return 1.0e308 }  // overflow guard
    if f < -709.0 { return 0.0 }     // underflow guard
    if f == 0.0 { return 1.0 }

    // Range reduction: split x = k*ln2 + r
    let ln2 = _ln2()
    let k_float = round_pure(f / ln2)
    let k = trunc_pure(k_float)
    let r = f - k * ln2

    // Taylor series for e^r with |r| < ln(2)/2 ≈ 0.347
    // e^r = 1 + r + r^2/2! + r^3/3! + ...
    let mut sum = 1.0
    let mut term = 1.0
    let mut n = 1
    while n <= 25 {
        term = term * r / (n * 1.0)
        sum = sum + term
        // Early termination
        let at = if term < 0.0 { 0.0 - term } else { term }
        if at < 1.0e-16 * (if sum < 0.0 { 0.0 - sum } else { sum }) {
            n = 26
        } else {
            n = n + 1
        }
    }

    // Multiply by 2^k
    let mut result = sum
    let mut ki = trunc_pure(k)
    if ki >= 0.0 {
        let mut j = 0
        while j * 1.0 < ki {
            result = result * 2.0
            j = j + 1
        }
    } else {
        let mut j = 0
        let nk = 0.0 - ki
        while j * 1.0 < nk {
            result = result * 0.5
            j = j + 1
        }
    }
    return result
}

// ═══════════════════════════════════════════════════════════════════
//  SECTION 5: Logarithm — series expansion
// ═══════════════════════════════════════════════════════════════════

// ── log_pure — natural logarithm via series expansion ────────────
// Uses: ln(x) = ln(m * 2^e) = e*ln(2) + ln(m), where 1 <= m < 2
// Then: ln(m) via the series ln((1+t)/(1-t)) = 2*(t + t^3/3 + t^5/5 + ...)
// where t = (m-1)/(m+1)
@pure
pub fn log_pure(x) {
    let f = _to_float(x)
    if f <= 0.0 { return 0.0 - 1.0 }  // undefined, return -1 as error
    if f == 1.0 { return 0.0 }

    // Range reduction: find e such that f = m * 2^e, 1 <= m < 2
    let mut m = f
    let mut e_count = 0
    while m >= 2.0 {
        m = m * 0.5
        e_count = e_count + 1
    }
    while m < 1.0 {
        m = m * 2.0
        e_count = e_count - 1
    }

    // Now m is in [1, 2), compute ln(m) via series
    // t = (m - 1) / (m + 1)
    let t = (m - 1.0) / (m + 1.0)
    let t2 = t * t
    let mut sum = t
    let mut power = t
    let mut n = 1
    while n <= 40 {
        power = power * t2
        let denom = (2 * n + 1) * 1.0
        let term = power / denom
        sum = sum + term
        let at = if term < 0.0 { 0.0 - term } else { term }
        if at < 1.0e-16 {
            n = 41
        } else {
            n = n + 1
        }
    }
    let ln_m = 2.0 * sum
    return (e_count * 1.0) * _ln2() + ln_m
}

// ── log2_pure — base-2 logarithm ─────────────────────────────────
@pure
pub fn log2_pure(x) {
    return log_pure(x) / _ln2()
}

// ── log10_pure — base-10 logarithm ───────────────────────────────
@pure
pub fn log10_pure(x) {
    return log_pure(x) / _ln10()
}

// ═══════════════════════════════════════════════════════════════════
//  SECTION 6: Power
// ═══════════════════════════════════════════════════════════════════

// ── pow_pure — a^b ───────────────────────────────────────────────
// Integer exponent: fast loop. Float exponent: exp(b * log(a)).
@pure
pub fn pow_pure(base, exponent) {
    let fb = _to_float(base)
    let fe = _to_float(exponent)

    // Special cases
    if fe == 0.0 { return 1.0 }
    if fb == 0.0 { return 0.0 }
    if fe == 1.0 { return fb }
    if fb == 1.0 { return 1.0 }

    // Check if exponent is integer
    let te = trunc_pure(fe)
    if te == fe {
        // Integer exponent: use fast exponentiation by squaring
        let neg_exp = fe < 0.0
        let mut n = if neg_exp { 0.0 - te } else { te }
        let mut result = 1.0
        let mut cur = fb
        while n >= 1.0 {
            // Check if n is odd via fmod
            let half = trunc_pure(n * 0.5)
            if half * 2.0 != n {
                result = result * cur
            }
            cur = cur * cur
            n = half
        }
        if neg_exp { return 1.0 / result }
        return result
    }

    // General case: a^b = exp(b * ln(a))
    if fb < 0.0 {
        // Negative base with non-integer exponent is undefined
        return 0.0 - 1.0
    }
    return exp_pure(fe * log_pure(fb))
}

// ═══════════════════════════════════════════════════════════════════
//  SECTION 7: Trigonometric functions — Taylor series
// ═══════════════════════════════════════════════════════════════════

// ── _reduce_angle — reduce x to [-pi, pi] ────────────────────────
@pure
fn _reduce_angle(x) {
    let tp = _two_pi()
    let mut r = x
    // Coarse reduction
    if r > tp {
        let n = trunc_pure(r / tp)
        r = r - n * tp
    }
    if r < 0.0 - tp {
        let n = trunc_pure((0.0 - r) / tp)
        r = r + n * tp
    }
    // Fine reduction to [-pi, pi]
    let p = _pi()
    while r > p {
        r = r - tp
    }
    while r < 0.0 - p {
        r = r + tp
    }
    return r
}

// ── sin_pure — sin(x) via Taylor series ──────────────────────────
// sin(x) = x - x^3/3! + x^5/5! - x^7/7! + ...
@pure
pub fn sin_pure(x) {
    let f = _to_float(x)
    let r = _reduce_angle(f)
    let r2 = r * r
    let mut term = r
    let mut sum = r
    let mut n = 1
    while n <= 20 {
        let d = 2 * n
        term = 0.0 - term * r2 / ((d * 1.0) * ((d + 1) * 1.0))
        sum = sum + term
        let at = if term < 0.0 { 0.0 - term } else { term }
        if at < 1.0e-16 {
            n = 21
        } else {
            n = n + 1
        }
    }
    return sum
}

// ── cos_pure — cos(x) via Taylor series ──────────────────────────
// cos(x) = 1 - x^2/2! + x^4/4! - x^6/6! + ...
@pure
pub fn cos_pure(x) {
    let f = _to_float(x)
    let r = _reduce_angle(f)
    let r2 = r * r
    let mut term = 1.0
    let mut sum = 1.0
    let mut n = 1
    while n <= 20 {
        let d = 2 * n
        term = 0.0 - term * r2 / (((d - 1) * 1.0) * (d * 1.0))
        sum = sum + term
        let at = if term < 0.0 { 0.0 - term } else { term }
        if at < 1.0e-16 {
            n = 21
        } else {
            n = n + 1
        }
    }
    return sum
}

// ── tan_pure — tan(x) = sin(x)/cos(x) ───────────────────────────
@pure
pub fn tan_pure(x) {
    let c = cos_pure(x)
    if c == 0.0 { return 1.0e308 }  // near-infinity
    return sin_pure(x) / c
}

// ═══════════════════════════════════════════════════════════════════
//  SECTION 8: Inverse trigonometric functions
// ═══════════════════════════════════════════════════════════════════

// ── atan_pure — arctangent via Taylor series with range reduction ─
// For |x| <= 1: atan(x) = x - x^3/3 + x^5/5 - x^7/7 + ...
// For |x| > 1: atan(x) = pi/2 - atan(1/x) if x > 0
//                        = -pi/2 - atan(1/x) if x < 0
@pure
pub fn atan_pure(x) {
    let f = _to_float(x)
    if f == 0.0 { return 0.0 }

    // For large |x|, use identity
    let neg = f < 0.0
    let a = if neg { 0.0 - f } else { f }

    if a > 1.0 {
        let inv_atan = _atan_small(1.0 / a)
        let result = _half_pi() - inv_atan
        if neg { return 0.0 - result }
        return result
    }

    let result = _atan_small(a)
    if neg { return 0.0 - result }
    return result
}

// ── _atan_small — atan for |x| <= 1 via Taylor ──────────────────
@pure
fn _atan_small(x) {
    // For better convergence near 1, use identity:
    // atan(x) = atan(c) + atan((x-c)/(1+x*c)) for known c
    // Use c = sqrt(3)/3 ≈ 0.5773... with atan(c) = pi/6
    if x > 0.4142 {
        // atan(x) = pi/4 + atan((x-1)/(x+1))
        let t = (x - 1.0) / (x + 1.0)
        return 0.7853981633974483 + _atan_taylor(t)
    }
    return _atan_taylor(x)
}

// ── _atan_taylor — raw Taylor series for |x| < 0.5 ──────────────
@pure
fn _atan_taylor(x) {
    let x2 = x * x
    let mut term = x
    let mut sum = x
    let mut n = 1
    while n <= 40 {
        term = 0.0 - term * x2
        let denom = (2 * n + 1) * 1.0
        sum = sum + term / denom
        let at = if term < 0.0 { 0.0 - term } else { term }
        if at / denom < 1.0e-16 {
            n = 41
        } else {
            n = n + 1
        }
    }
    return sum
}

// ── atan2_pure — two-argument arctangent ─────────────────────────
@pure
pub fn atan2_pure(y, x) {
    let fy = _to_float(y)
    let fx = _to_float(x)
    if fx > 0.0 { return atan_pure(fy / fx) }
    if fx < 0.0 {
        if fy >= 0.0 { return atan_pure(fy / fx) + _pi() }
        return atan_pure(fy / fx) - _pi()
    }
    // fx == 0
    if fy > 0.0 { return _half_pi() }
    if fy < 0.0 { return 0.0 - _half_pi() }
    return 0.0  // (0,0) undefined, return 0
}

// ── asin_pure — arcsine via atan identity ────────────────────────
// asin(x) = atan(x / sqrt(1 - x^2))
@pure
pub fn asin_pure(x) {
    let f = _to_float(x)
    if f < -1.0 { return 0.0 - _half_pi() }
    if f > 1.0 { return _half_pi() }
    if f == 1.0 { return _half_pi() }
    if f == -1.0 { return 0.0 - _half_pi() }
    let denom = sqrt_pure(1.0 - f * f)
    return atan_pure(f / denom)
}

// ── acos_pure — arccosine ────────────────────────────────────────
// acos(x) = pi/2 - asin(x)
@pure
pub fn acos_pure(x) {
    return _half_pi() - asin_pure(x)
}

// ═══════════════════════════════════════════════════════════════════
//  SECTION 9: Hyperbolic functions
// ═══════════════════════════════════════════════════════════════════

// ── sinh_pure — hyperbolic sine ──────────────────────────────────
// sinh(x) = (e^x - e^(-x)) / 2
@pure
pub fn sinh_pure(x) {
    let f = _to_float(x)
    let ep = exp_pure(f)
    let em = exp_pure(0.0 - f)
    return (ep - em) * 0.5
}

// ── cosh_pure — hyperbolic cosine ────────────────────────────────
// cosh(x) = (e^x + e^(-x)) / 2
@pure
pub fn cosh_pure(x) {
    let f = _to_float(x)
    let ep = exp_pure(f)
    let em = exp_pure(0.0 - f)
    return (ep + em) * 0.5
}

// ── tanh_pure — hyperbolic tangent ───────────────────────────────
// tanh(x) = sinh(x) / cosh(x) = (e^2x - 1) / (e^2x + 1)
@pure
pub fn tanh_pure(x) {
    let f = _to_float(x)
    // Avoid overflow for large |x|
    if f > 20.0 { return 1.0 }
    if f < -20.0 { return -1.0 }
    let e2x = exp_pure(2.0 * f)
    return (e2x - 1.0) / (e2x + 1.0)
}

// ═══════════════════════════════════════════════════════════════════
//  SECTION 10: Utility functions
// ═══════════════════════════════════════════════════════════════════

// ── hypot_pure — sqrt(x^2 + y^2) with overflow protection ───────
@pure
pub fn hypot_pure(x, y) {
    let fx = _to_float(x)
    let fy = _to_float(y)
    let ax = if fx < 0.0 { 0.0 - fx } else { fx }
    let ay = if fy < 0.0 { 0.0 - fy } else { fy }
    // Scale to avoid overflow
    let mx = if ax > ay { ax } else { ay }
    if mx == 0.0 { return 0.0 }
    let sx = ax / mx
    let sy = ay / mx
    return mx * sqrt_pure(sx * sx + sy * sy)
}

// ── degrees_pure / radians_pure — angle conversion ───────────────
@pure
pub fn degrees_pure(rad) {
    return _to_float(rad) * 180.0 / _pi()
}

@pure
pub fn radians_pure(deg) {
    return _to_float(deg) * _pi() / 180.0
}

// ── is_close_pure — approximate equality ─────────────────────────
@pure
pub fn is_close_pure(a, b, tol) {
    let fa = _to_float(a)
    let fb = _to_float(b)
    let diff = fa - fb
    let ad = if diff < 0.0 { 0.0 - diff } else { diff }
    return ad <= _to_float(tol)
}

// ── sum_pure — sum of numeric array ──────────────────────────────
@pure
pub fn sum_pure(arr) {
    let n = len(arr)
    let mut s = 0.0
    let mut i = 0
    while i < n {
        s = s + _to_float(arr[i])
        i = i + 1
    }
    return s
}

// ── mean_pure — arithmetic mean ──────────────────────────────────
@pure
pub fn mean_pure(arr) {
    let n = len(arr)
    if n == 0 { return 0.0 }
    return sum_pure(arr) / (n * 1.0)
}

// ── factorial_pure — n! for non-negative integer ─────────────────
@pure
pub fn factorial_pure(n) {
    if n <= 1 { return 1 }
    let mut result = 1
    let mut i = 2
    while i <= n {
        result = result * i
        i = i + 1
    }
    return result
}

// ── gcd_pure — greatest common divisor (Euclidean) ───────────────
@pure
pub fn gcd_pure(a, b) {
    let mut x = if a < 0 { 0 - a } else { a }
    let mut y = if b < 0 { 0 - b } else { b }
    while y != 0 {
        let tmp = y
        y = x - (x / y) * y
        x = tmp
    }
    return x
}

// ── lcm_pure — least common multiple ─────────────────────────────
@pure
pub fn lcm_pure(a, b) {
    if a == 0 { return 0 }
    if b == 0 { return 0 }
    let aa = if a < 0 { 0 - a } else { a }
    let bb = if b < 0 { 0 - b } else { b }
    return (aa / gcd_pure(aa, bb)) * bb
}


// -- end inlined --
import "ml/dpo.hexa"

let mut pass = 0
let mut fail = 0

fn assert_true(cond, label) {
    if cond {
        pass = pass + 1
    } else {
        println("FAIL: " + label)
        fail = fail + 1
    }
}

fn approx_eq(a, b, tol) {
    let diff = a - b
    let ad = if diff < 0.0 { 0.0 - diff } else { diff }
    return ad < tol
}

// ── sigmoid tests ───────────────────────────────────────────────
let s0 = sigmoid(0.0)
assert_true(approx_eq(s0, 0.5, 1.0e-10), "sigmoid(0) == 0.5")

let s_pos = sigmoid(10.0)
assert_true(s_pos > 0.999, "sigmoid(10) > 0.999")

let s_neg = sigmoid(-10.0)
assert_true(s_neg < 0.001, "sigmoid(-10) < 0.001")

// sigmoid(-x) == 1 - sigmoid(x)
let s3 = sigmoid(3.0)
let s3n = sigmoid(-3.0)
assert_true(approx_eq(s3 + s3n, 1.0, 1.0e-10), "sigmoid(x) + sigmoid(-x) == 1")

// ── log_sigmoid tests ───────────────────────────────────────────
let ls0 = log_sigmoid(0.0)
// log(0.5) ~ -0.6931
assert_true(approx_eq(ls0, 0.0 - 0.6931471805599453, 1.0e-6), "log_sigmoid(0) ~ -0.693")

let ls_big = log_sigmoid(20.0)
assert_true(ls_big > -1.0e-6, "log_sigmoid(20) ~ 0")

let ls_neg = log_sigmoid(-20.0)
assert_true(approx_eq(ls_neg, -20.0, 1.0), "log_sigmoid(-20) ~ -20")

// log_sigmoid(x) == log(sigmoid(x)) consistency
let ls5 = log_sigmoid(5.0)
let s5 = sigmoid(5.0)
let log_s5 = log_pure(s5)
assert_true(approx_eq(ls5, log_s5, 1.0e-8), "log_sigmoid(5) == log(sigmoid(5))")

// ── dpo_loss tests ──────────────────────────────────────────────
// Case: chosen clearly better than rejected
// pi prefers chosen more than ref does => positive logit => low loss
let pi_w  = [-1.0, -1.5, -0.8]
let pi_l  = [-3.0, -3.5, -2.8]
let ref_w = [-2.0, -2.0, -2.0]
let ref_l = [-2.5, -2.5, -2.5]

let loss1 = dpo_loss(pi_w, pi_l, ref_w, ref_l, 0.1)
assert_true(loss1 > 0.0, "dpo_loss > 0 (always positive)")

// Case: equal log-ratios => loss = log(2) ~ 0.693
let eq_w = [-2.0, -2.0]
let eq_l = [-2.0, -2.0]
let eq_ref_w = [-2.0, -2.0]
let eq_ref_l = [-2.0, -2.0]
let loss_eq = dpo_loss(eq_w, eq_l, eq_ref_w, eq_ref_l, 0.1)
assert_true(approx_eq(loss_eq, 0.6931471805599453, 1.0e-4), "dpo_loss(equal) ~ log(2)")

// Higher beta => stronger preference signal
let loss_low_beta = dpo_loss(pi_w, pi_l, ref_w, ref_l, 0.01)
let loss_high_beta = dpo_loss(pi_w, pi_l, ref_w, ref_l, 1.0)
// With chosen better, high beta => lower loss (stronger signal)
assert_true(loss_high_beta < loss_low_beta, "higher beta => lower loss when chosen preferred")

// ── dpo_reward tests ────────────────────────────────────────────
let rw = dpo_reward(pi_w, ref_w, 0.1)
let rl = dpo_reward(pi_l, ref_l, 0.1)
// Chosen should have higher reward when policy prefers chosen more than ref
assert_true(rw > rl, "reward_chosen > reward_rejected when chosen preferred")

// Zero diff => zero reward
let zero_r = dpo_reward([-2.0, -2.0], [-2.0, -2.0], 0.1)
assert_true(approx_eq(zero_r, 0.0, 1.0e-10), "dpo_reward == 0 when pi == ref")

// ── dpo_train_step tests ────────────────────────────────────────
let mut model_lp = #{}
model_lp["chosen"] = [-1.0, -1.5]
model_lp["rejected"] = [-3.0, -3.5]

let mut ref_lp = #{}
ref_lp["chosen"] = [-2.0, -2.0]
ref_lp["rejected"] = [-2.5, -2.5]

let result = dpo_train_step(model_lp, ref_lp, 0.1, 0.001)
assert_true(result["loss"] > 0.0, "train_step loss > 0")
assert_true(result["reward_margin"] > 0.0, "train_step reward_margin > 0 when chosen preferred")
assert_true(result["reward_chosen"] > result["reward_rejected"], "train_step rw > rl")

// ── simpo_loss tests ────────────────────────────────────────────
// Per-sample average log-probs (length-normalized)
let simpo_w = [-0.5, -0.6]
let simpo_l = [-1.5, -1.8]

let simpo_l1 = simpo_loss(simpo_w, simpo_l, 2.0, 0.5)
assert_true(simpo_l1 > 0.0, "simpo_loss > 0")

// Equal inputs with gamma > 0 => loss > log(2)
let simpo_eq = simpo_loss([-1.0], [-1.0], 1.0, 1.0)
// logit = beta*(0) - gamma = -1.0, so loss = -log_sigmoid(-1) = log(1+e) ~ 1.31
assert_true(simpo_eq > 0.693, "simpo_loss(equal, gamma>0) > log(2)")

// Gamma = 0 reduces simpo to basic preference loss (no ref)
let simpo_g0 = simpo_loss(simpo_w, simpo_l, 1.0, 0.0)
// With chosen clearly better, loss should be small
assert_true(simpo_g0 < 0.693, "simpo(chosen>>rejected, gamma=0) < log(2)")

// Higher gamma => harder to satisfy => higher loss
let simpo_lo_g = simpo_loss(simpo_w, simpo_l, 1.0, 0.0)
let simpo_hi_g = simpo_loss(simpo_w, simpo_l, 1.0, 5.0)
assert_true(simpo_hi_g > simpo_lo_g, "higher gamma => higher simpo_loss")

// ── Summary ─────────────────────────────────────────────────────
println("")
println("test_dpo: " + str(pass) + " PASS, " + str(fail) + " FAIL")
if fail > 0 {
    println("SOME TESTS FAILED")
} else {
    println("ALL TESTS PASSED")
}
