// ═══════════════════════════════════════════════════════════════════
//  self/test_dpo.hexa — tests for self/ml/dpo.hexa (pure Hexa DPO)
// ═══════════════════════════════════════════════════════════════════

import "runtime/math_pure.hexa"
import "ml/dpo.hexa"

let mut pass = 0
let mut fail = 0

fn assert_true(cond, label) {
    if cond {
        pass = pass + 1
    } else {
        println("FAIL: " + label)
        fail = fail + 1
    }
}

fn approx_eq(a, b, tol) {
    let diff = a - b
    let ad = if diff < 0.0 { 0.0 - diff } else { diff }
    return ad < tol
}

// ── sigmoid tests ───────────────────────────────────────────────
let s0 = sigmoid(0.0)
assert_true(approx_eq(s0, 0.5, 1.0e-10), "sigmoid(0) == 0.5")

let s_pos = sigmoid(10.0)
assert_true(s_pos > 0.999, "sigmoid(10) > 0.999")

let s_neg = sigmoid(-10.0)
assert_true(s_neg < 0.001, "sigmoid(-10) < 0.001")

// sigmoid(-x) == 1 - sigmoid(x)
let s3 = sigmoid(3.0)
let s3n = sigmoid(-3.0)
assert_true(approx_eq(s3 + s3n, 1.0, 1.0e-10), "sigmoid(x) + sigmoid(-x) == 1")

// ── log_sigmoid tests ───────────────────────────────────────────
let ls0 = log_sigmoid(0.0)
// log(0.5) ~ -0.6931
assert_true(approx_eq(ls0, 0.0 - 0.6931471805599453, 1.0e-6), "log_sigmoid(0) ~ -0.693")

let ls_big = log_sigmoid(20.0)
assert_true(ls_big > -1.0e-6, "log_sigmoid(20) ~ 0")

let ls_neg = log_sigmoid(-20.0)
assert_true(approx_eq(ls_neg, -20.0, 1.0), "log_sigmoid(-20) ~ -20")

// log_sigmoid(x) == log(sigmoid(x)) consistency
let ls5 = log_sigmoid(5.0)
let s5 = sigmoid(5.0)
let log_s5 = log_pure(s5)
assert_true(approx_eq(ls5, log_s5, 1.0e-8), "log_sigmoid(5) == log(sigmoid(5))")

// ── dpo_loss tests ──────────────────────────────────────────────
// Case: chosen clearly better than rejected
// pi prefers chosen more than ref does => positive logit => low loss
let pi_w  = [-1.0, -1.5, -0.8]
let pi_l  = [-3.0, -3.5, -2.8]
let ref_w = [-2.0, -2.0, -2.0]
let ref_l = [-2.5, -2.5, -2.5]

let loss1 = dpo_loss(pi_w, pi_l, ref_w, ref_l, 0.1)
assert_true(loss1 > 0.0, "dpo_loss > 0 (always positive)")

// Case: equal log-ratios => loss = log(2) ~ 0.693
let eq_w = [-2.0, -2.0]
let eq_l = [-2.0, -2.0]
let eq_ref_w = [-2.0, -2.0]
let eq_ref_l = [-2.0, -2.0]
let loss_eq = dpo_loss(eq_w, eq_l, eq_ref_w, eq_ref_l, 0.1)
assert_true(approx_eq(loss_eq, 0.6931471805599453, 1.0e-4), "dpo_loss(equal) ~ log(2)")

// Higher beta => stronger preference signal
let loss_low_beta = dpo_loss(pi_w, pi_l, ref_w, ref_l, 0.01)
let loss_high_beta = dpo_loss(pi_w, pi_l, ref_w, ref_l, 1.0)
// With chosen better, high beta => lower loss (stronger signal)
assert_true(loss_high_beta < loss_low_beta, "higher beta => lower loss when chosen preferred")

// ── dpo_reward tests ────────────────────────────────────────────
let rw = dpo_reward(pi_w, ref_w, 0.1)
let rl = dpo_reward(pi_l, ref_l, 0.1)
// Chosen should have higher reward when policy prefers chosen more than ref
assert_true(rw > rl, "reward_chosen > reward_rejected when chosen preferred")

// Zero diff => zero reward
let zero_r = dpo_reward([-2.0, -2.0], [-2.0, -2.0], 0.1)
assert_true(approx_eq(zero_r, 0.0, 1.0e-10), "dpo_reward == 0 when pi == ref")

// ── dpo_train_step tests ────────────────────────────────────────
let mut model_lp = #{}
model_lp["chosen"] = [-1.0, -1.5]
model_lp["rejected"] = [-3.0, -3.5]

let mut ref_lp = #{}
ref_lp["chosen"] = [-2.0, -2.0]
ref_lp["rejected"] = [-2.5, -2.5]

let result = dpo_train_step(model_lp, ref_lp, 0.1, 0.001)
assert_true(result["loss"] > 0.0, "train_step loss > 0")
assert_true(result["reward_margin"] > 0.0, "train_step reward_margin > 0 when chosen preferred")
assert_true(result["reward_chosen"] > result["reward_rejected"], "train_step rw > rl")

// ── simpo_loss tests ────────────────────────────────────────────
// Per-sample average log-probs (length-normalized)
let simpo_w = [-0.5, -0.6]
let simpo_l = [-1.5, -1.8]

let simpo_l1 = simpo_loss(simpo_w, simpo_l, 2.0, 0.5)
assert_true(simpo_l1 > 0.0, "simpo_loss > 0")

// Equal inputs with gamma > 0 => loss > log(2)
let simpo_eq = simpo_loss([-1.0], [-1.0], 1.0, 1.0)
// logit = beta*(0) - gamma = -1.0, so loss = -log_sigmoid(-1) = log(1+e) ~ 1.31
assert_true(simpo_eq > 0.693, "simpo_loss(equal, gamma>0) > log(2)")

// Gamma = 0 reduces simpo to basic preference loss (no ref)
let simpo_g0 = simpo_loss(simpo_w, simpo_l, 1.0, 0.0)
// With chosen clearly better, loss should be small
assert_true(simpo_g0 < 0.693, "simpo(chosen>>rejected, gamma=0) < log(2)")

// Higher gamma => harder to satisfy => higher loss
let simpo_lo_g = simpo_loss(simpo_w, simpo_l, 1.0, 0.0)
let simpo_hi_g = simpo_loss(simpo_w, simpo_l, 1.0, 5.0)
assert_true(simpo_hi_g > simpo_lo_g, "higher gamma => higher simpo_loss")

// ── Summary ─────────────────────────────────────────────────────
println("")
println("test_dpo: " + str(pass) + " PASS, " + str(fail) + " FAIL")
if fail > 0 {
    println("SOME TESTS FAILED")
} else {
    println("ALL TESTS PASSED")
}
