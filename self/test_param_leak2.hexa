fn apply(x, f) {
    return f(x)
}

fn double(x) { return x * 2 }
fn add_ten(x) { return x + 10 }

// Test without using result - just pure calls
println("r1 = " + to_string(apply(4, double)))
println("r2 = " + to_string(apply(6, add_ten)))
println("r3 = " + to_string(apply(3, double)))
println("r4 = " + to_string(apply(5, add_ten)))
