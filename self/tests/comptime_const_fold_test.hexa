// ═══════════════════════════════════════════════════════════
//  tests/comptime_const_fold_test.hexa
//  ComptimeConst const-fold 평가기 확장 (UnaryOp/비교/논리/BuiltinCall)
//
//  NOTE: 여기서 검증하는 것은 "fold 결과가 실행 시 올바른 값"이다.
//  codegen이 fold를 놓치더라도 runtime 경로로 동일 값이 계산되어야 하므로
//  모든 assert는 fold 성공/실패와 무관하게 PASS해야 한다.
//  (fold 자체의 시각화는 emitted C를 검사하는 별도 테스트에서 다룬다.)
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " expected=" + to_string(expected) + " got=" + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("── comptime const-fold extended tests ──")

// ── UnaryOp ────────────────────────────────────────────────
comptime const U_NEG_INT = -42
comptime const U_NEG_FLOAT = -1.5
comptime const U_NOT_T = !true
comptime const U_NOT_F = !false

check("unary neg int", U_NEG_INT, -42)
check("unary neg float", U_NEG_FLOAT, -1.5)
check("unary not true", U_NOT_T, false)
check("unary not false", U_NOT_F, true)

// ── 비교 연산자 ────────────────────────────────────────────
comptime const CMP_EQ_I = 3 == 3
comptime const CMP_NE_I = 3 != 4
comptime const CMP_LT_I = 2 < 3
comptime const CMP_GT_I = 5 > 1
comptime const CMP_LE_I = 4 <= 4
comptime const CMP_GE_I = 4 >= 5
comptime const CMP_EQ_F = 1.5 == 1.5
comptime const CMP_LT_MIX = 2 < 3.5
comptime const CMP_EQ_S = "foo" == "foo"
comptime const CMP_NE_S = "foo" != "bar"
comptime const CMP_EQ_B = true == true
comptime const CMP_NE_B = true != false

check("cmp == int", CMP_EQ_I, true)
check("cmp != int", CMP_NE_I, true)
check("cmp <  int", CMP_LT_I, true)
check("cmp >  int", CMP_GT_I, true)
check("cmp <= int", CMP_LE_I, true)
check("cmp >= int(false)", CMP_GE_I, false)
check("cmp == float", CMP_EQ_F, true)
check("cmp <  mix", CMP_LT_MIX, true)
check("cmp == str", CMP_EQ_S, true)
check("cmp != str", CMP_NE_S, true)
check("cmp == bool", CMP_EQ_B, true)
check("cmp != bool", CMP_NE_B, true)

// ── 논리 연산자 (단축 평가) ────────────────────────────────
comptime const L_AND_TT = true && true
comptime const L_AND_TF = true && false
comptime const L_AND_FX = false && true   // 단축 — RHS 평가 생략 가능
comptime const L_OR_FT  = false || true
comptime const L_OR_FF  = false || false
comptime const L_OR_TX  = true  || false   // 단축

check("&& tt", L_AND_TT, true)
check("&& tf", L_AND_TF, false)
check("&& fx", L_AND_FX, false)
check("|| ft", L_OR_FT,  true)
check("|| ff", L_OR_FF,  false)
check("|| tx", L_OR_TX,  true)

// ── BuiltinCall: abs / min / max / sqrt / floor / ceil ────
comptime const B_ABS_NEG = abs(-7)
comptime const B_ABS_POS = abs(7)
comptime const B_MIN_II = min(4, 9)
comptime const B_MAX_II = max(4, 9)
comptime const B_MIN_MIX = min(2, 1.5)
comptime const B_SQRT_I = sqrt(9)    // 9 = 3² → 3.0
comptime const B_FLOOR_I = floor(5)  // int 입력 → 5
comptime const B_CEIL_I  = ceil(5)

check("abs(-7)", B_ABS_NEG, 7)
check("abs(7)",  B_ABS_POS, 7)
check("min(4,9)", B_MIN_II, 4)
check("max(4,9)", B_MAX_II, 9)
check("min(2,1.5)", B_MIN_MIX, 1.5)
check("sqrt(9)", B_SQRT_I, 3.0)
check("floor(5)", B_FLOOR_I, 5)
check("ceil(5)",  B_CEIL_I,  5)

// ── IfExpr(comptime cond) → 선택 branch 평가 ──────────────
comptime const IF_TRUE  = if true  { 100 } else { 200 }
comptime const IF_FALSE = if false { "A" } else { "B" }

check("if true branch",  IF_TRUE,  100)
check("if false branch", IF_FALSE, "B")

// ── 실패 분기 (silent skip) — runtime 경로로도 동일 ──────
// 0 나눗셈 / 비교·논리 타입 불일치 등은 fold 실패 → 런타임에서 실제 오류
// 가 날 수 있으므로 assert에 포함하지 않는다. 여기선 "fold 실패해도
// 컴파일러가 panic하지 않고 silent skip"을 확인하기 위한 placeholder.

println("")
println("═══════════════════════════════════════════════════════")
println("  RESULT: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")
