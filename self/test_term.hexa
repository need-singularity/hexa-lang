// ═══════════════════════════════════════════════════════════════════════
//  self/test_term.hexa — runner for all 12 stdlib term/* selftests
//
//  Invokes each module's _selftest() in-process by importing them and
//  calling the public selftest entry directly. Aggregates per-module
//  PASS/FAIL counts. Exits non-zero iff any module fails.
//
//  Note: each module's bottom-of-file argv scanner gates on
//  --selftest + filename match, so importing them here without
//  --selftest in argv keeps each module quiescent — we then
//  manually fire each via the --selftest-<modulename> alias on
//  separate child processes (avoids re-entering the same hexa
//  runtime with conflicting top-level state).
//
//  Run: hexa run self/test_term.hexa
//  Output: __TERM_RUNNER__ PASS n=12 modules=12
// ═══════════════════════════════════════════════════════════════════════

// Pairs: [module_filename_stem, selftest_needle]
let modules = [
    ["term",         "__TERM_TERM_SELFTEST__"],
    ["term_ansi",    "__TERM_ANSI_SELFTEST__"],
    ["term_input",   "__TERM_INPUT_SELFTEST__"],
    ["term_cursor",  "__TERM_CURSOR_SELFTEST__"],
    ["term_screen",  "__TERM_SCREEN_SELFTEST__"],
    ["term_style",   "__TERM_STYLE_SELFTEST__"],
    ["term_box",     "__TERM_BOX_SELFTEST__"],
    ["term_resize",  "__TERM_RESIZE_SELFTEST__"],
    ["term_paste",   "__TERM_PASTE_SELFTEST__"],
    ["term_focus",   "__TERM_FOCUS_SELFTEST__"],
    ["term_mouse",   "__TERM_MOUSE_SELFTEST__"],
    ["term_unicode", "__TERM_UNICODE_SELFTEST__"]
]

let mut total_pass = 0
let mut total_fail = 0
let mut failed_modules = []

let mut i = 0
while i < len(modules) {
    let m = modules[i][0]
    let needle = modules[i][1]
    let cmd = "./hexa run self/stdlib/" + m + ".hexa --selftest 2>&1"
    let raw = to_string(exec(cmd))
    // Search line containing needle.
    let lines = raw.split("\n")
    let mut found = ""
    let mut k = 0
    while k < len(lines) {
        if lines[k].contains(needle) { found = lines[k] }
        k = k + 1
    }
    if len(found) == 0 {
        eprintln("[runner] " + m + ": NO SELFTEST OUTPUT")
        failed_modules.push(m)
        total_fail = total_fail + 1
    } else if found.contains(" PASS ") {
        println("[runner] " + m + ": " + found)
        total_pass = total_pass + 1
    } else {
        eprintln("[runner] " + m + ": " + found)
        failed_modules.push(m)
        total_fail = total_fail + 1
    }
    i = i + 1
}

println("")
if total_fail == 0 {
    println("__TERM_RUNNER__ PASS n=" + to_string(total_pass) + " modules=" + to_string(len(modules)))
    exit(0)
} else {
    eprintln("__TERM_RUNNER__ FAIL pass=" + to_string(total_pass) + " fail=" + to_string(total_fail))
    let mut fi = 0
    while fi < len(failed_modules) {
        eprintln("  failed: " + failed_modules[fi])
        fi = fi + 1
    }
    exit(1)
}
