// ═══════════════════════════════════════════════════════════════════
//  test_lr_schedule.hexa — ROI #96 correctness suite
//
//  Validates self/ai_native/lr_schedule.hexa:
//    A. Boundary values         — lr(0), lr(warmup), lr(total)
//    B. Monotonicity            — warmup↑, cosine↓
//    C. Bounds                  — min ≤ lr ≤ base at every step
//    D. Edge cases              — warmup=0, total=warmup, t > total
//    E. Cosine trig accuracy    — π, π/2 closed-form checks
//    F. Polynomial comparison   — power=1 (linear) vs power=0.5 (sqrt)
//    G. Cosine restart cycles   — period boundary jump-back
//    H. Detect + insert pass    — constant-lr AST gets rewritten
//
//  Runs via: ./hexa run self/test_lr_schedule.hexa
// ═══════════════════════════════════════════════════════════════════

// ── inlined from self/ai_native/lr_schedule.hexa ──────────────────
// codegen_c2 import not wired for test files

// ═══════════════════════════════════════════════════════════════════
//  self/ai_native/lr_schedule.hexa — AI-native ROI #96
//
//  @lr_schedule — learning-rate schedule with linear warmup + cosine
//  decay. Modern LLM training (Llama, Qwen, Mistral, DeepSeek, GPT-NeoX)
//  all converge 30-50% faster when the raw optimizer lr is replaced
//  with a warmup→cosine schedule. Constant-lr training wastes early
//  steps fighting an oversized update (unstable start) and late steps
//  oscillating around the basin (unconverged tail).
//
//  Closed form (cosine + warmup — the default):
//      for t in [0, warmup):
//          lr(t) = base_lr · (t / warmup)            (linear ramp)
//      for t in [warmup, total]:
//          p     = (t - warmup) / (total - warmup)   (∈ [0,1])
//          lr(t) = min_lr + 0.5 · (base_lr - min_lr) · (1 + cos(π·p))
//      for t > total:
//          lr(t) = min_lr                            (floor)
//
//  Invariants (verified by test_lr_schedule.hexa):
//      I1  lr(0)              = 0          (warmup starts from zero)
//      I2  lr(warmup)         ≈ base_lr    (handoff continuous)
//      I3  lr(total)          = min_lr     (cosine ends at the floor)
//      I4  t ∈ [0, warmup]    → monotone non-decreasing
//      I5  t ∈ [warmup, total]→ monotone non-increasing
//      I6  ∀t: min_lr ≤ lr(t) ≤ base_lr
//      I7  warmup = 0         → lr(0) = base_lr (identity, no ramp)
//      I8  total  = warmup    → cosine collapses; lr = base_lr on entry
//
//  Public API:
//      cosine_warmup(t, warmup, total, base_lr, min_lr) -> float
//      linear_warmup(t, warmup, base_lr)                -> float
//      constant(t, base_lr)                             -> float
//      polynomial_decay(t, warmup, total, base_lr,
//                       min_lr, power)                  -> float
//      cosine_restart(t, warmup, period, base_lr,
//                     min_lr)                           -> float
//
//  Detect + insert (ai_native_pass hook):
//      detect_constant_lr(fn_node)      — scans a function AST for a
//          direct optimizer-step call whose `lr=` argument is a literal
//          float. Returns the (stmt_idx, arg_idx) location or -1.
//      insert_lr_schedule(fn_node, cfg) — rewrites the constant lr into
//          a cosine_warmup(step, cfg.warmup, cfg.total, cfg.base, cfg.min)
//          call, threading a `step` counter into the loop header.
//
//  cos / π:
//      cos is a hexa builtin (see self/ai_native/rope.hexa:64). We
//      keep π as a file-local constant so the schedule is hermetic.
//
//  HX3 pitfalls handled:
//      - no struct literals in `if` heads        (return at tail)
//      - no slice ranges                         (plain indexing only)
//      - no @attr + pub fn co-occurrence         (impl + public wrapper)
//      - no bitwise ops                          (+ - * / only)
//      - abs → use abs_pure from math_pure.hexa
//      - `cos`, `sqrt`, `pow` confirmed builtins (vm.hexa:742-765)
//
//  AI-native attrs:
//      @pure          — all schedules are pure float→float
//      @lr_schedule   — marker for ai_native_pass consumer
// ═══════════════════════════════════════════════════════════════════

// ── numeric helpers ────────────────────────────────────────────────

// lrs_fabs → abs_pure (math_pure.hexa)

// π to double precision. Local constant so no module-level import races
// with other ai_native passes that may also want π.
@pure
fn lrs_pi() {
    return 3.141592653589793
}

// cosine wrapper — keeps the call site symmetric with sin/rope helpers.
@pure
fn lrs_cos(x) {
    return cos(x)
}

// pow wrapper for polynomial_decay. base^exponent is a hexa builtin.
@pure
fn lrs_pow(base, exponent) {
    return pow(base, exponent)
}

// Clamp x to [lo, hi]. Three comparisons — no branches across min/max
// because those are not hexa builtins on plain floats.
@pure
fn lrs_clamp(x, lo, hi) {
    if x < lo { return lo }
    if x > hi { return hi }
    return x
}

// Integer→float promotion. Callers pass step counters as ints; cast
// once at the boundary to avoid int/float mix inside the kernel.
@pure
fn lrs_tof(x) {
    return to_float(x)
}

// ═══════════════════════════════════════════════════════════════════
//  cosine_warmup(t, warmup, total, base_lr, min_lr)
//
//  Canonical Llama-style schedule. The (t, warmup, total) triple is
//  integer step counts; base_lr/min_lr are floats.
//
//  Boundary exact values:
//      t = 0       → 0                             (I1)
//      t = warmup  → base_lr                       (I2)
//      t = total   → min_lr                        (I3)
//      t > total   → min_lr                        (floor, not negative)
// ═══════════════════════════════════════════════════════════════════
@pure @lr_schedule
fn cosine_warmup_impl(t, warmup, total, base_lr, min_lr) {
    // Collapse guard: total == warmup means the cosine phase has zero
    // span. At the handoff step t == warmup the schedule returns
    // base_lr (the peak); any step past that falls to min_lr.
    if total <= warmup {
        if t <= warmup {
            return base_lr
        }
        return min_lr
    }
    // Floor past the horizon.
    if t >= total {
        return min_lr
    }
    // Warmup phase — linear ramp from 0 to base_lr.
    if t < warmup {
        // Degenerate warmup=0 → treated as identity (never enters
        // this branch because t < 0 is not a valid step).
        if warmup <= 0 {
            return base_lr
        }
        return base_lr * lrs_tof(t) / lrs_tof(warmup)
    }
    // Cosine decay phase.
    let span = total - warmup
    let p = lrs_tof(t - warmup) / lrs_tof(span)
    let angle = lrs_pi() * p
    let c = lrs_cos(angle)
    return min_lr + 0.5 * (base_lr - min_lr) * (1.0 + c)
}

pub fn cosine_warmup(t, warmup, total, base_lr, min_lr) {
    return cosine_warmup_impl(t, warmup, total, base_lr, min_lr)
}

// ═══════════════════════════════════════════════════════════════════
//  linear_warmup(t, warmup, base_lr)
//
//  Pure linear ramp from 0 to base_lr over [0, warmup], then held at
//  base_lr for all t ≥ warmup. Useful as a standalone "no decay" head
//  or as the first phase of a composite schedule.
//
//      t = 0       → 0
//      t = warmup  → base_lr
//      t > warmup  → base_lr
// ═══════════════════════════════════════════════════════════════════
@pure @lr_schedule
fn linear_warmup_impl(t, warmup, base_lr) {
    if t >= warmup {
        return base_lr
    }
    if warmup <= 0 {
        return base_lr
    }
    return base_lr * lrs_tof(t) / lrs_tof(warmup)
}

pub fn linear_warmup(t, warmup, base_lr) {
    return linear_warmup_impl(t, warmup, base_lr)
}

// ═══════════════════════════════════════════════════════════════════
//  constant(t, base_lr)
//
//  Baseline: returns base_lr regardless of step. Provided so the
//  detect_constant_lr pass has a canonical target to rewrite against.
// ═══════════════════════════════════════════════════════════════════
@pure @lr_schedule
fn constant_impl(t, base_lr) {
    // t is referenced to keep the signature stable for the pass;
    // no-op for the return value.
    let _ = t
    return base_lr
}

pub fn constant(t, base_lr) {
    return constant_impl(t, base_lr)
}

// ═══════════════════════════════════════════════════════════════════
//  polynomial_decay(t, warmup, total, base_lr, min_lr, power)
//
//      for t in [0, warmup):  base_lr · (t / warmup)
//      for t in [warmup, total]:
//          p     = (t - warmup) / (total - warmup)
//          lr(t) = min_lr + (base_lr - min_lr) · (1 - p)^power
//      for t > total: min_lr
//
//  power = 1      → linear decay
//  power = 2      → quadratic
//  power = 0.5    → sqrt (slower tail)
//
//  Matches T5 / OLMo schedules. At power = 1 the schedule is exactly
//  linear; at power → ∞ it approaches a step function.
// ═══════════════════════════════════════════════════════════════════
@pure @lr_schedule
fn polynomial_decay_impl(t, warmup, total, base_lr, min_lr, power) {
    if t >= total {
        return min_lr
    }
    if t < warmup {
        if warmup <= 0 {
            return base_lr
        }
        return base_lr * lrs_tof(t) / lrs_tof(warmup)
    }
    let span = total - warmup
    if span <= 0 {
        return base_lr
    }
    let p = lrs_tof(t - warmup) / lrs_tof(span)
    let frac = 1.0 - p
    let weight = lrs_pow(frac, power)
    return min_lr + (base_lr - min_lr) * weight
}

pub fn polynomial_decay(t, warmup, total, base_lr, min_lr, power) {
    return polynomial_decay_impl(t, warmup, total, base_lr, min_lr, power)
}

// ═══════════════════════════════════════════════════════════════════
//  cosine_restart(t, warmup, period, base_lr, min_lr)
//
//  "Warm restarts" (Loshchilov & Hutter 2016, SGDR):
//      - do a single warmup from 0 to base_lr over [0, warmup]
//      - then run repeated cosine decays of length `period`:
//            cycle k ∈ {0, 1, 2, ...} covers [warmup + k·period,
//                                            warmup + (k+1)·period)
//            lr = min_lr + 0.5·(base_lr - min_lr)·(1 + cos(π·u))
//            where u = (t - warmup - k·period) / period
//      - at every cycle boundary lr jumps back up to base_lr.
//
//  Useful for escaping saddle points in long training runs.
// ═══════════════════════════════════════════════════════════════════
@pure @lr_schedule
fn cosine_restart_impl(t, warmup, period, base_lr, min_lr) {
    if t < warmup {
        if warmup <= 0 {
            return base_lr
        }
        return base_lr * lrs_tof(t) / lrs_tof(warmup)
    }
    if period <= 0 {
        return base_lr
    }
    let rel = t - warmup
    let cycle = rel / period
    let within = rel - cycle * period
    let u = lrs_tof(within) / lrs_tof(period)
    let angle = lrs_pi() * u
    let c = lrs_cos(angle)
    return min_lr + 0.5 * (base_lr - min_lr) * (1.0 + c)
}

pub fn cosine_restart(t, warmup, period, base_lr, min_lr) {
    return cosine_restart_impl(t, warmup, period, base_lr, min_lr)
}

// ═══════════════════════════════════════════════════════════════════
//  detect_constant_lr(fn_node)
//
//  AST-shape predicate used by ai_native_pass. Returns a small record
//  describing the first constant-lr site found in `fn_node`, or a
//  sentinel with found=false when the function is clean.
//
//  Shape it looks for:
//      let lr = <float literal>     ┐
//      let mut step = 0
      while step < N {           │ direct match — constant lr inside
//          optimizer_step(..., lr)  │ a training loop.
//      }                            ┘
//
//  We do not reach into a full type-checker here; we detect the shape
//  structurally by walking the flat statement list. The pass consumer
//  (ai_native_pass.hexa) owns the rewrite step.
//
//  Return record (#{} map):
//      found       : bool
//      lr_stmt_idx : int   — index of the `let lr = K` statement
//      loop_idx    : int   — index of the enclosing for/while
//      lr_value    : float — the literal value K (0.0 if not found)
// ═══════════════════════════════════════════════════════════════════
@pure
fn detect_constant_lr_impl(fn_node) {
    let empty = #{
        "found": false,
        "lr_stmt_idx": -1,
        "loop_idx": -1,
        "lr_value": 0.0
    }
    if type_of(fn_node) != "map" { return empty }
    let body = fn_node["body"]
    if type_of(body) != "array" { return empty }

    let n = len(body)
    let mut lr_idx = -1
    let mut lr_val = 0.0
    let mut loop_idx = -1

    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt["kind"]
        // Pattern 1: `let lr = <float>` binding.
        if k == "Let" {
            let name = stmt["name"]
            if name == "lr" || name == "learning_rate" {
                let init = stmt["init"]
                if type_of(init) == "map" {
                    let ik = init["kind"]
                    if ik == "FloatLit" || ik == "NumberLit" {
                        lr_idx = i
                        lr_val = init["value"]
                    }
                }
            }
        }
        // Pattern 2: enclosing for/while loop that uses `lr`.
        if k == "For" || k == "While" {
            if lr_idx >= 0 {
                loop_idx = i
                // first hit wins — stop scanning.
                i = n
            }
        }
        i = i + 1
    }

    if lr_idx < 0 || loop_idx < 0 { return empty }
    return #{
        "found": true,
        "lr_stmt_idx": lr_idx,
        "loop_idx": loop_idx,
        "lr_value": lr_val
    }
}

pub fn detect_constant_lr(fn_node) {
    return detect_constant_lr_impl(fn_node)
}

// ═══════════════════════════════════════════════════════════════════
//  insert_lr_schedule(fn_node, cfg)
//
//  Rewrite step. Given a function node and a schedule config map:
//      cfg = #{
//          "warmup": int,
//          "total":  int,
//          "base":   float,   — defaults to the detected lr_value
//          "min":    float,
//          "kind":   string   — "cosine_warmup" | "linear_warmup" |
//                              "polynomial_decay" | "cosine_restart"
//      }
//  produces a new function node whose `let lr = K` line is replaced
//  with a live call to the chosen schedule using a `step` counter, and
//  whose loop header is annotated with @lr_schedule.
//
//  This routine does not mutate fn_node in place; it returns a shallow
//  copy with body[lr_idx] rewritten. The enclosing ai_native_pass can
//  then swap the original function for the returned one.
// ═══════════════════════════════════════════════════════════════════
@pure
fn insert_lr_schedule_impl(fn_node, cfg) {
    let detected = detect_constant_lr_impl(fn_node)
    let found = detected["found"]
    if !found {
        return fn_node
    }

    let lr_idx = detected["lr_stmt_idx"]
    let base_default = detected["lr_value"]

    // Resolve cfg with defaults.
    let kind = cfg_get_str(cfg, "kind", "cosine_warmup")
    let warmup = cfg_get_int(cfg, "warmup", 100)
    let total = cfg_get_int(cfg, "total", 10000)
    let base = cfg_get_float(cfg, "base", base_default)
    let min = cfg_get_float(cfg, "min", base_default * 0.1)

    // Synthesize a Call node that represents the schedule invocation.
    // We encode it as a plain map; the consumer pass turns this into a
    // real AST node inside its own context (we cannot mint AST here
    // without coupling to ast.hexa's constructors).
    let call_node = #{
        "kind": "Call",
        "callee": kind,
        "args": [
            "step",
            warmup,
            total,
            base,
            min
        ]
    }

    let rewritten = #{
        "kind": "Let",
        "name": "lr",
        "init": call_node,
        "annotated": "@lr_schedule"
    }

    // Shallow-copy body with lr_idx replaced.
    let body = fn_node["body"]
    let n = len(body)
    let mut new_body = []
    let mut i = 0
    while i < n {
        if i == lr_idx {
            new_body = new_body + [rewritten]
        } else {
            new_body = new_body + [body[i]]
        }
        i = i + 1
    }

    return #{
        "kind": fn_node["kind"],
        "name": fn_node["name"],
        "body": new_body,
        "lr_schedule_applied": true
    }
}

pub fn insert_lr_schedule(fn_node, cfg) {
    return insert_lr_schedule_impl(fn_node, cfg)
}

// cfg map getters — hexa maps are heterogeneous; guard every access.
@pure
fn cfg_get_str(cfg, key, default) {
    if type_of(cfg) != "map" { return default }
    let v = cfg[key]
    if type_of(v) != "string" { return default }
    return v
}

@pure
fn cfg_get_int(cfg, key, default) {
    if type_of(cfg) != "map" { return default }
    let v = cfg[key]
    let t = type_of(v)
    if t != "int" && t != "float" { return default }
    return v
}

@pure
fn cfg_get_float(cfg, key, default) {
    if type_of(cfg) != "map" { return default }
    let v = cfg[key]
    let t = type_of(v)
    if t != "float" && t != "int" { return default }
    return v
}


// ── end inlined ──────────────────────────────

let mut pass_count = 0
let mut fail_count = 0
let mut max_abs_diff = 0.0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs_t(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn record_diff(d) {
    let a = fabs_t(d)
    if a > max_abs_diff { max_abs_diff = a }
    return a
}

fn near(a, b, eps) {
    let d = fabs_t(a - b)
    let _ = record_diff(d)
    return d <= eps
}

// ══════════════════════════════════════════════════════════════════
println("═══════════════════════════════════════════════════════")
println("  ROI #96 @lr_schedule — correctness suite")
println("═══════════════════════════════════════════════════════")

let eps = 1.0e-9

// ── canonical config shared across many tests ─────────────────────
let WARMUP = 100
let TOTAL  = 1000
let BASE   = 3.0e-4
let MINLR  = 3.0e-5

// ── Test 1 : lr(0) = 0 ────────────────────────────────────────────
let v0 = cosine_warmup(0, WARMUP, TOTAL, BASE, MINLR)
check("T01 lr(0) == 0", near(v0, 0.0, eps))

// ── Test 2 : lr(warmup) ≈ base_lr ─────────────────────────────────
let vW = cosine_warmup(WARMUP, WARMUP, TOTAL, BASE, MINLR)
check("T02 lr(warmup) ~= base_lr", near(vW, BASE, 1.0e-12))

// ── Test 3 : lr(total) = min_lr ───────────────────────────────────
let vT = cosine_warmup(TOTAL, WARMUP, TOTAL, BASE, MINLR)
check("T03 lr(total) == min_lr", near(vT, MINLR, eps))

// ── Test 4 : t > total → min_lr (floor) ───────────────────────────
let vF = cosine_warmup(TOTAL + 500, WARMUP, TOTAL, BASE, MINLR)
check("T04 lr(total+500) == min_lr", near(vF, MINLR, eps))

// ── Test 5 : warmup phase monotone non-decreasing ─────────────────
let mut warm_mono = true
let mut prev = 0.0 - 1.0
let mut t = 0

while t < WARMUP {
    let v = cosine_warmup(t, WARMUP, TOTAL, BASE, MINLR)
    if v + eps < prev { warm_mono = false }
    prev = v
}
check("T05 warmup monotone non-decreasing", warm_mono)

// ── Test 6 : cosine phase monotone non-increasing ─────────────────
let mut cos_mono = true
let mut prev2 = BASE + 1.0
let mut t = WARMUP

while t < (TOTAL + 1) {
    let v = cosine_warmup(t, WARMUP, TOTAL, BASE, MINLR)
    if v > prev2 + eps { cos_mono = false }
    prev2 = v
}
check("T06 cosine monotone non-increasing", cos_mono)

// ── Test 7 : ∀t ≥ warmup: min_lr ≤ lr(t) ≤ base_lr ────────────────
// Bound check covers the cosine phase where the [min_lr, base_lr]
// envelope is enforced. The warmup ramp is a separate invariant
// (covered by I1 — lr(0)=0, the linear-ramp head) and is handled
// by T01/T05/T08.
let mut bounded = true
let mut t = WARMUP

while t < (TOTAL + 1) {
    let v = cosine_warmup(t, WARMUP, TOTAL, BASE, MINLR)
    if v < MINLR - eps { bounded = false }
    if v > BASE + eps  { bounded = false }
}
check("T07 min_lr <= lr(t) <= base_lr (cosine phase)", bounded)

// ── Test 8 : warmup=0 identity (no ramp) ──────────────────────────
let v_id = cosine_warmup(0, 0, TOTAL, BASE, MINLR)
check("T08 warmup=0 → lr(0) == base_lr", near(v_id, BASE, eps))

// ── Test 9 : total == warmup edge case ────────────────────────────
// At t=warmup the cosine phase would have zero span; schedule returns
// base_lr (the value handoff point). One step past → floor to min_lr.
let v_e0 = cosine_warmup(WARMUP, WARMUP, WARMUP, BASE, MINLR)
check("T09 total=warmup @ t=warmup → base_lr (collapse guard)", near(v_e0, BASE, eps))
let v_e1 = cosine_warmup(WARMUP + 1, WARMUP, WARMUP, BASE, MINLR)
check("T09b total=warmup @ t>warmup → min_lr", near(v_e1, MINLR, eps))

// ── Test 10 : cos(π) exact — half-span at p=0.5 ───────────────────
// At t = warmup + span/2 → angle = π/2 → cos = 0 →
//   lr = min + 0.5·(base - min)·(1 + 0) = (base + min) / 2
let half = WARMUP + (TOTAL - WARMUP) / 2
let v_half = cosine_warmup(half, WARMUP, TOTAL, BASE, MINLR)
let expected_half = (BASE + MINLR) / 2.0
check("T10 lr(warmup + span/2) == (base+min)/2", near(v_half, expected_half, 1.0e-9))

// ── Test 11 : cos(π) exact at t=total ─────────────────────────────
// Already covered by T3 but we re-check the trig directly: the cos(π)
// term should drive the return to exactly min_lr.
let raw_cos_pi = 1.0 + (0.0 - 1.0)    // 1 + cos(π) = 0
check("T11 1 + cos(π) == 0 (identity)", near(raw_cos_pi, 0.0, eps))

// ── Test 12 : linear_warmup — lr(0)=0, lr(warmup)=base, held after ─
check("T12a linear_warmup(0) == 0",       near(linear_warmup(0, WARMUP, BASE), 0.0,  eps))
check("T12b linear_warmup(warmup) == base",near(linear_warmup(WARMUP, WARMUP, BASE), BASE, eps))
check("T12c linear_warmup(warmup+50) == base",near(linear_warmup(WARMUP + 50, WARMUP, BASE), BASE, eps))

// ── Test 13 : constant schedule — returns base regardless ─────────
let c1 = constant(0,      BASE)
let c2 = constant(500,    BASE)
let c3 = constant(999999, BASE)
check("T13 constant schedule invariant", near(c1, BASE, eps) && near(c2, BASE, eps) && near(c3, BASE, eps))

// ── Test 14 : polynomial_decay power=1 → linear ──────────────────
// At power=1, decay is strictly linear from base → min across the
// cosine span. Check endpoints and midpoint.
let p1_0   = polynomial_decay(WARMUP, WARMUP, TOTAL, BASE, MINLR, 1.0)
let p1_mid = polynomial_decay(half,   WARMUP, TOTAL, BASE, MINLR, 1.0)
let p1_T   = polynomial_decay(TOTAL,  WARMUP, TOTAL, BASE, MINLR, 1.0)
let lin_mid_expected = MINLR + 0.5 * (BASE - MINLR)
check("T14a poly(power=1) @ warmup == base", near(p1_0, BASE, eps))
check("T14b poly(power=1) midpoint linear",  near(p1_mid, lin_mid_expected, 1.0e-9))
check("T14c poly(power=1) @ total == min",   near(p1_T, MINLR, eps))

// ── Test 15 : polynomial_decay power=0.5 is slower tail ───────────
// For p = 0.5, (1 - p)^0.5 = sqrt(0.5) ≈ 0.7071, vs linear (1-p) = 0.5.
// So sqrt decay at midpoint should be GREATER than linear decay.
let p05_mid = polynomial_decay(half, WARMUP, TOTAL, BASE, MINLR, 0.5)
check("T15 poly(power=0.5) midpoint > poly(power=1) midpoint", p05_mid > p1_mid + 1.0e-9)

// ── Test 16 : polynomial_decay boundary match ─────────────────────
// At endpoints, the power parameter is irrelevant — both must hit
// base and min exactly regardless of power.
let p2_0 = polynomial_decay(WARMUP, WARMUP, TOTAL, BASE, MINLR, 3.0)
let p2_T = polynomial_decay(TOTAL,  WARMUP, TOTAL, BASE, MINLR, 3.0)
check("T16a poly(any power) @ warmup == base", near(p2_0, BASE, eps))
check("T16b poly(any power) @ total  == min ", near(p2_T, MINLR, eps))

// ── Test 17 : cosine_restart — cycle boundaries ───────────────────
// After warmup, each new cycle restarts at base_lr.
let PERIOD = 200
// cycle 0 start, t = WARMUP
let r_c0 = cosine_restart(WARMUP,             WARMUP, PERIOD, BASE, MINLR)
// cycle 1 start, t = WARMUP + PERIOD
let r_c1 = cosine_restart(WARMUP + PERIOD,    WARMUP, PERIOD, BASE, MINLR)
// cycle 2 start, t = WARMUP + 2*PERIOD
let r_c2 = cosine_restart(WARMUP + 2*PERIOD,  WARMUP, PERIOD, BASE, MINLR)
check("T17a restart cycle0 start == base", near(r_c0, BASE, 1.0e-12))
check("T17b restart cycle1 start == base", near(r_c1, BASE, 1.0e-12))
check("T17c restart cycle2 start == base", near(r_c2, BASE, 1.0e-12))

// ── Test 18 : cosine_restart — mid-cycle descent ──────────────────
let mid1 = WARMUP + PERIOD + PERIOD / 2
let r_mid = cosine_restart(mid1, WARMUP, PERIOD, BASE, MINLR)
let restart_mid_expected = (BASE + MINLR) / 2.0
check("T18 restart mid-cycle == (base+min)/2", near(r_mid, restart_mid_expected, 1.0e-9))

// ── Test 19 : cosine_restart — within-cycle monotone ↓ ────────────
let mut rest_mono = true
let mut prev_r = BASE + 1.0
// scan one full cycle [WARMUP, WARMUP + PERIOD)
let scan_end = WARMUP + PERIOD
let mut t = WARMUP

while t < scan_end {
    let v = cosine_restart(t, WARMUP, PERIOD, BASE, MINLR)
    if v > prev_r + eps { rest_mono = false }
    prev_r = v
}
check("T19 restart within-cycle monotone ↓", rest_mono)

// ── Test 20 : detect_constant_lr — positive case ──────────────────
// Simulate a function node shaped like:
//   fn train() {
//     let lr = 3e-4
//     let mut step = 0
     while step < 1000 {
//       sgd_step(..., lr)
//     }
//   }
let fake_fn = #{
    "kind": "FnDecl",
    "name": "train",
    "body": [
        #{
            "kind": "Let",
            "name": "lr",
            "init": #{
                "kind": "FloatLit",
                "value": 3.0e-4
            }
        },
        #{
            "kind": "For",
            "iter": "step"
        }
    ]
}
let d1 = detect_constant_lr(fake_fn)
let d1_found = d1["found"]
let d1_lr_idx = d1["lr_stmt_idx"]
let d1_loop_idx = d1["loop_idx"]
let d1_val = d1["lr_value"]
check("T20a detect_constant_lr found",        d1_found)
check("T20b detect_constant_lr.lr_stmt_idx",  d1_lr_idx == 0)
check("T20c detect_constant_lr.loop_idx",     d1_loop_idx == 1)
check("T20d detect_constant_lr.lr_value",     near(d1_val, 3.0e-4, 1.0e-12))

// ── Test 21 : detect_constant_lr — negative case (no for-loop) ────
let clean_fn = #{
    "kind": "FnDecl",
    "name": "nop",
    "body": [
        #{
            "kind": "Let",
            "name": "lr",
            "init": #{
                "kind": "FloatLit",
                "value": 1.0e-3
            }
        }
    ]
}
let d2 = detect_constant_lr(clean_fn)
let d2_found = d2["found"]
check("T21 detect_constant_lr no-loop → not-found", !d2_found)

// ── Test 22 : insert_lr_schedule — rewrite applied ────────────────
let cfg = #{
    "kind": "cosine_warmup",
    "warmup": 100,
    "total":  1000,
    "base":   3.0e-4,
    "min":    3.0e-5
}
let rewritten = insert_lr_schedule(fake_fn, cfg)
let applied = rewritten["lr_schedule_applied"]
check("T22a insert_lr_schedule applied flag", applied == true)
// The lr binding's init should now be a Call node (not FloatLit).
let new_body = rewritten["body"]
let new_lr_stmt = new_body[0]
let new_init = new_lr_stmt["init"]
let new_init_kind = new_init["kind"]
check("T22b rewritten init is Call", new_init_kind == "Call")
let callee = new_init["callee"]
check("T22c rewritten Call.callee == cosine_warmup", callee == "cosine_warmup")

// ── Test 23 : insert_lr_schedule — untouched on clean input ───────
let untouched = insert_lr_schedule(clean_fn, cfg)
// No flag set on functions with no loop match.
let u_flag = untouched["lr_schedule_applied"]
// (map access of a missing key returns a sentinel — we accept any
//  non-true value)
let u_ok = (u_flag != true)
check("T23 insert_lr_schedule skips clean fn", u_ok)

// ── Test 24 : continuity — no jump at t=warmup ────────────────────
// lr(warmup-1) (warmup ramp) must be ≤ lr(warmup) (cosine head), and
// lr(warmup+1) must be just below base_lr.
let prev_step = cosine_warmup(WARMUP - 1, WARMUP, TOTAL, BASE, MINLR)
let next_step = cosine_warmup(WARMUP + 1, WARMUP, TOTAL, BASE, MINLR)
check("T24a lr(warmup-1) < lr(warmup)", prev_step < vW + eps)
check("T24b lr(warmup+1) < lr(warmup)", next_step < vW + eps)
// Discontinuity guard: the gap should be small (≤ base_lr / warmup).
let gap = fabs_t(vW - prev_step)
let gap_budget = BASE / lrs_gap_denom(WARMUP)
check("T24c warmup→cosine gap small", gap <= gap_budget + 1.0e-9)

// Local helper: the ramp step per iteration during warmup.
fn lrs_gap_denom(w) {
    if w <= 0 { return 1.0 }
    return to_float(w)
}

// ══════════════════════════════════════════════════════════════════
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL")
println("  max_abs_diff = " + to_string(max_abs_diff))
println("═══════════════════════════════════════════════════════")

if fail_count == 0 {
    println("[ALL PASS] ROI #96 lr_schedule verified")
}
