// ═══════════════════════════════════════════════════════════
//  test_scope_isolation.hexa — Scope & Namespace Isolation Tests
//  Tests: block scoping, function scoping, closure scoping,
//         shadowing, nested scope chains, variable lifetime
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA Scope & Isolation Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Block scoping with if ──────────────────────────────

println("--- Block Scoping ---")

let scope_a = 10
if true {
    let scope_a = 20
    check("inner shadow", scope_a, 20)
}
check("outer preserved after if", scope_a, 10)

let scope_b = "outer"
if true {
    let scope_b = "inner"
    check("string shadow inner", scope_b, "inner")
}
check("string shadow outer", scope_b, "outer")

// ── 2. While loop scoping ─────────────────────────────────

println("")
println("--- While Scoping ---")

let mut accum = 0
let mut wi = 0
while wi < 3 {
    let local = wi * 10
    accum = accum + local
    wi = wi + 1
}
check("while local accum", accum, 30)

// Variable declared outside, modified inside
let mut outer_var = 0
let mut wj = 0
while wj < 5 {
    outer_var = outer_var + 1
    wj = wj + 1
}
check("while modify outer", outer_var, 5)

// ── 3. Function scoping ──────────────────────────────────

println("")
println("--- Function Scoping ---")

let global_val = 100

fn read_global() {
    return global_val
}
check("fn read global", read_global(), 100)

fn local_shadow() {
    let global_val = 999
    return global_val
}
check("fn local shadow", local_shadow(), 999)
check("global after fn shadow", global_val, 100)

fn nested_fn_scope() {
    let a = 10
    fn inner() {
        let b = 20
        return b
    }
    return a + inner()
}
check("nested fn scope", nested_fn_scope(), 30)

// ── 4. Closure capture ───────────────────────────────────

println("")
println("--- Closure Capture ---")

let captured = 42
let closure1 = |x| x + captured
check("closure capture", closure1(8), 50)

// Closure captures value snapshot (not mutable reference)
let base_val = 10
let add_base = |x| x + base_val
check("closure value capture", add_base(5), 15)
check("closure value capture 2", add_base(20), 30)

// Factory pattern (each closure captures its own value)
fn make_adder(n) {
    return |x| x + n
}
let add5 = make_adder(5)
let add10 = make_adder(10)
check("factory add5", add5(3), 8)
check("factory add10", add10(3), 13)
check("factory independence", add5(1) + add10(1), 17)

// ── 5. Shadowing chains ─────────────────────────────────

println("")
println("--- Shadowing Chains ---")

let chain = 1
if true {
    let chain = 2
    if true {
        let chain = 3
        check("shadow depth 3", chain, 3)
    }
    check("shadow depth 2", chain, 2)
}
check("shadow depth 1", chain, 1)

// ── 6. For-in scoping ────────────────────────────────────

println("")
println("--- For-In Scoping ---")

let mut for_result = 0
for item in [10, 20, 30] {
    let doubled = item * 2
    for_result = for_result + doubled
}
check("for-in local var", for_result, 120)

// Nested for-in
let mut nested_sum = 0
for i in [1, 2, 3] {
    for j in [10, 20] {
        nested_sum = nested_sum + i * j
    }
}
// (1*10+1*20) + (2*10+2*20) + (3*10+3*20) = 30+60+90 = 180
check("nested for-in", nested_sum, 180)

// ── 7. Function does not pollute caller scope ─────────────

println("")
println("--- Function Isolation ---")

fn isolated_fn() {
    let isolated_var = 999
    return isolated_var
}
check("fn returns value", isolated_fn(), 999)

// isolated_var should not be accessible here (verified by not using it)

fn modify_param(x) {
    let x = x + 100
    return x
}
let orig = 5
check("param modification", modify_param(orig), 105)
check("original unchanged", orig, 5)

// ── 8. Recursive scope ───────────────────────────────────

println("")
println("--- Recursive Scope ---")

fn fib(n) {
    if n <= 1 { return n }
    return fib(n - 1) + fib(n - 2)
}
check("fib(0)", fib(0), 0)
check("fib(1)", fib(1), 1)
check("fib(6)", fib(6), 8)
check("fib(10)", fib(10), 55)

fn sum_recursive(arr, idx) {
    if idx >= len(arr) { return 0 }
    return arr[idx] + sum_recursive(arr, idx + 1)
}
check("recursive sum", sum_recursive([1, 2, 3, 4, 5], 0), 15)

// ── 9. Match in scope ────────────────────────────────────

println("")
println("--- Match Scope ---")

fn match_scope_test(x) {
    let result = match x {
        1 -> "one",
        2 -> "two",
        _ -> "other"
    }
    return result
}
check("match scope 1", match_scope_test(1), "one")
check("match scope 2", match_scope_test(2), "two")
check("match scope 9", match_scope_test(9), "other")

// ── 10. Try-catch scope ──────────────────────────────────

println("")
println("--- Try-Catch Scope ---")

let mut try_result = "none"
try {
    let inner_val = "success"
    try_result = inner_val
} catch e {
    try_result = "error"
}
check("try scope", try_result, "success")

let mut catch_result = "none"
try {
    throw "fail"
} catch e {
    catch_result = "caught"
}
check("catch scope", catch_result, "caught")

// ── 11. Closure scope isolation ─────────────────────────

println("")
println("--- Closure Scope Isolation ---")

fn make_adder2(base) {
    return |x| x + base
}

let add3 = make_adder2(3)
let add7 = make_adder2(7)
check("closure iso add3(10)", add3(10), 13)
check("closure iso add7(10)", add7(10), 17)
check("closure iso add3(0)", add3(0), 3)
check("closure iso add7(0)", add7(0), 7)
check("closure iso independence", add3(1) != add7(1), true)

// ── 12. Nested closure capture ──────────────────────────

println("")
println("--- Nested Closure Capture ---")

fn make_multiplier(factor) {
    return |x| x * factor
}

let double = make_multiplier(2)
let triple = make_multiplier(3)
check("multiplier double", double(7), 14)
check("multiplier triple", triple(7), 21)
check("multiplier independence", double(5) + triple(5), 25)

// ── 13. Variable shadowing in match ─────────────────────

println("")
println("--- Match Shadowing ---")

let mv = 42
let mr = match mv {
    42 -> "found",
    _ -> "other"
}
check("match val 42", mr, "found")
check("mv unchanged after match", mv, 42)

fn match_shadow_fn(x) {
    let result = match x {
        0 -> "zero",
        1 -> "one",
        2 -> "two",
        3 -> "three",
        _ -> "many"
    }
    return result
}
check("match shadow 0", match_shadow_fn(0), "zero")
check("match shadow 1", match_shadow_fn(1), "one")
check("match shadow 3", match_shadow_fn(3), "three")
check("match shadow 99", match_shadow_fn(99), "many")

// ── 14. Deep nesting scope ──────────────────────────────

println("")
println("--- Deep Nesting ---")

let d1 = 1
if true {
    let d2 = 2
    if true {
        let d3 = 3
        if true {
            let d4 = 4
            if true {
                let d5 = 5
                check("depth 5 sum", d1 + d2 + d3 + d4 + d5, 15)
            }
            check("depth 4 sum", d1 + d2 + d3 + d4, 10)
        }
        check("depth 3 sum", d1 + d2 + d3, 6)
    }
    check("depth 2 sum", d1 + d2, 3)
}
check("depth 1 val", d1, 1)

// ── 15. Struct scope ────────────────────────────────────

println("")
println("--- Struct Scope ---")

struct Point {
    x: int,
    y: int
}

fn make_point(a, b) {
    let p = Point { x: a, y: b }
    return p
}

let p1 = make_point(3, 4)
check("struct x", p1.x, 3)
check("struct y", p1.y, 4)

fn transform_point(p, dx, dy) {
    return Point { x: p.x + dx, y: p.y + dy }
}

let p2 = transform_point(p1, 10, 20)
check("transform x", p2.x, 13)
check("transform y", p2.y, 24)
check("original x unchanged", p1.x, 3)
check("original y unchanged", p1.y, 4)

// ── 16. Loop variable scoping ───────────────────────────

println("")
println("--- Loop Variable Scope ---")

let mut outer_sum = 0
for i in [1, 2, 3] {
    let sq = i * i
    outer_sum = outer_sum + sq
}
check("for sq sum", outer_sum, 14)

let mut pairs = []
for a in [1, 2] {
    for b in [10, 20] {
        pairs = pairs.push(a * 100 + b)
    }
}
check("nested for pair 0", pairs[0], 110)
check("nested for pair 1", pairs[1], 120)
check("nested for pair 2", pairs[2], 210)
check("nested for pair 3", pairs[3], 220)

// ── 17. Higher-order function scope ─────────────────────

println("")
println("--- Higher-Order Scope ---")

fn apply(f, x) {
    return f(x)
}

fn compose(f, g) {
    return |x| f(g(x))
}

let inc = |x| x + 1
let dbl = |x| x * 2

check("apply inc", apply(inc, 5), 6)
check("apply dbl", apply(dbl, 5), 10)

let inc_then_dbl = compose(dbl, inc)
let dbl_then_inc = compose(inc, dbl)
check("compose inc then dbl", inc_then_dbl(3), 8)
check("compose dbl then inc", dbl_then_inc(3), 7)

// ═══════════════════════════════════════════════════════════
//  SUMMARY
// ═══════════════════════════════════════════════════════════

println("")
println("═══════════════════════════════════════════════════════")
let total = pass_count + fail_count
println("  Results: " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL / " + to_string(total) + " total")
if fail_count == 0 {
    println("  ALL SCOPE ISOLATION TESTS PASSED!")
} else {
    println("  SOME TESTS FAILED")
}
println("═══════════════════════════════════════════════════════")
