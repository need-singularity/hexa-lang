// self/test_format_pure.hexa -- Tests for self/runtime/format_pure.hexa
//
// Run: build/hexa_interp self/test_format_pure.hexa

// ── inlined from self/runtime/format_pure.hexa ────────────────────

fn format_float_prec(val, prec) {
    let mut x = val
    if type_of(x) == "int" { x = x + 0.0 }
    let mut neg = false
    if x < 0.0 {
        neg = true
        x = 0.0 - x
    }
    let mut scale = 1
    let mut p = 0
    while p < prec {
        scale = scale * 10
        p = p + 1
    }
    let scaled = x * (scale + 0.0) + 0.5
    let trunc_str = to_string(scaled)
    let dot_idx = trunc_str.index_of(".")
    let mut int_part_str = trunc_str
    if dot_idx >= 0 {
        int_part_str = trunc_str.substring(0, dot_idx)
    }
    let n = len(int_part_str)
    let mut intp = ""
    let mut fracp = ""
    if n <= prec {
        intp = "0"
        let missing = prec - n
        let mut k = 0
        while k < missing {
            fracp = fracp + "0"
            k = k + 1
        }
        fracp = fracp + int_part_str
    } else {
        intp = int_part_str.substring(0, n - prec)
        fracp = int_part_str.substring(n - prec, n)
    }
    let mut out = intp
    if prec > 0 {
        out = out + "." + fracp
    }
    let mut is_zero = (intp == "0")
    if is_zero && prec > 0 {
        let mut zi = 0
        while zi < len(fracp) {
            if fracp.substring(zi, zi + 1) != "0" {
                is_zero = false
            }
            zi = zi + 1
        }
    }
    if neg && !is_zero {
        out = "-" + out
    }
    out
}

fn format_pure(fmt, arg) {
    if type_of(fmt) != "string" { return fmt }
    let pos = fmt.index_of("{}")
    if pos < 0 { return fmt }
    let sarg = to_string(arg)
    fmt.substring(0, pos) + sarg + fmt.substring(pos + 2, len(fmt))
}

fn format_n_pure(fmt, args) {
    if type_of(fmt) != "string" { return fmt }
    if type_of(args) != "array"  { return fmt }
    let n = len(fmt)
    let argc = len(args)
    let mut out = ""
    let mut i = 0
    let mut ai = 0
    while i < n {
        let c = fmt.substring(i, i + 1)
        if c == "{" && ai < argc {
            let close_rel = fmt.substring(i, n).index_of("}")
            if close_rel < 0 {
                out = out + c
                i = i + 1
            } else {
                let close = i + close_rel
                let spec = fmt.substring(i + 1, close)
                let arg = args[ai]
                ai = ai + 1
                if len(spec) >= 2 && spec.substring(0, 2) == ":." {
                    let prec_str = spec.substring(2, len(spec))
                    let mut prec = 0
                    let mut pi = 0
                    while pi < len(prec_str) {
                        let ch = ord(prec_str.substring(pi, pi + 1))
                        if ch >= 48 && ch <= 57 {
                            prec = prec * 10 + (ch - 48)
                        }
                        pi = pi + 1
                    }
                    out = out + format_float_prec(arg, prec)
                } else {
                    out = out + to_string(arg)
                }
                i = close + 1
            }
        } else {
            out = out + c
            i = i + 1
        }
    }
    out
}

// ── end inlined ───────────────────────────────────────────────────

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  format_pure.hexa — test runner")
println("═══════════════════════════════════════════════════════")

// ── format_pure ─────────────────────────────────────────────
println("")
println("--- format_pure (single-arg) ---")
check("basic", format_pure("hello, {}", "world"), "hello, world")
check("int arg", format_pure("n = {}", 42), "n = 42")
check("no placeholder", format_pure("plain text", "x"), "plain text")
check("placeholder at end", format_pure("x = {}", 7), "x = 7")
check("placeholder at start", format_pure("{} wins", "alice"), "alice wins")
check("only first replaced", format_pure("{}, {}", "a"), "a, {}")
check("non-string fmt", format_pure(42, "x"), 42)

// ── format_n_pure ───────────────────────────────────────────
println("")
println("--- format_n_pure (multi-arg) ---")
check("two args", format_n_pure("{} + {} = {}", [1, 2, 3]), "1 + 2 = 3")
check("strings", format_n_pure("{} / {}", ["foo", "bar"]), "foo / bar")
check("extra args ignored", format_n_pure("{}", [1, 2, 3]), "1")
check("too-few leaves literal", format_n_pure("{} and {}", ["a"]), "a and {}")
check("no placeholders", format_n_pure("plain", [1]), "plain")
check("non-string fmt", format_n_pure(42, [1]), 42)
check("non-array args", format_n_pure("{}", "notarr"), "{}")
check("unclosed brace passthru", format_n_pure("{oops", [1]), "{oops")

// ── precision {:.N} ─────────────────────────────────────────
println("")
println("--- format_n_pure {:.N} precision ---")
check("prec 2 of 3.14159", format_n_pure("{:.2}", [3.14159]), "3.14")
check("prec 0 of 3.7", format_n_pure("{:.0}", [3.7]), "4")
check("prec 3 of 1.0", format_n_pure("{:.3}", [1.0]), "1.000")
check("prec 2 negative", format_n_pure("{:.2}", [-2.5]), "-2.50")
check("prec 1 of int", format_n_pure("{:.1}", [42]), "42.0")
check("mixed spec", format_n_pure("{} = {:.2}", ["x", 1.23456]), "x = 1.23")

// ── Summary ─────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    println("FAIL")
    exit(1)
}
println("ALL PASS")
