// runtime_pure.hexa — Pure Hexa implementations of runtime.c functions
// Goal: eliminate C dependency for interpreter-reachable paths (HX4 self-host)
//
// STATUS KEY:
//   PURE   = fully ported, no C needed
//   FFI    = thin extern fn wrapper around unavoidable libc (malloc/popen/fopen)
//   HYBRID = hexa logic + minimal FFI for syscall
//
// Functions that remain C-only (not ported here):
//   - NaN-boxing tag machinery (HX_IS_STR, HX_INT, etc) — compiled binary only
//   - Arena allocator internals — performance-critical, stays in runtime.c
//   - ValStruct unwrapping (hexa_valstruct_*) — tag layout coupling
//   - setjmp/longjmp try/catch — no hexa equivalent

// ============================================================
// 0. Minimal FFI — unavoidable libc wrappers
// ============================================================

extern fn __c_popen(cmd: *Void, mode: *Void) -> *Void
extern fn __c_pclose(fp: *Void) -> int
extern fn __c_fgets(buf: *Void, size: int, fp: *Void) -> *Void
extern fn __c_fopen(path: *Void, mode: *Void) -> *Void
extern fn __c_fclose(fp: *Void) -> int
extern fn __c_fread(buf: *Void, size: int, count: int, fp: *Void) -> int
extern fn __c_fwrite(buf: *Void, size: int, count: int, fp: *Void) -> int
extern fn __c_fseek(fp: *Void, offset: int, whence: int) -> int
extern fn __c_ftell(fp: *Void) -> int
extern fn __c_malloc(size: int) -> *Void
extern fn __c_free(ptr: *Void)
extern fn __c_sqrt(x: float) -> float
extern fn __c_pow(base: float, exp: float) -> float
extern fn __c_exp(x: float) -> float
extern fn __c_log(x: float) -> float
extern fn __c_floor(x: float) -> float
extern fn __c_ceil(x: float) -> float
extern fn __c_round(x: float) -> float
extern fn __c_fabs(x: float) -> float
extern fn __c_tanh(x: float) -> float
extern fn __c_sin(x: float) -> float
extern fn __c_cos(x: float) -> float

// ============================================================
// 1. String Operations — PURE
// ============================================================

// str_len: return byte length of string
// STATUS: PURE
fn rt_str_len(s) {
    if type_of(s) != "string" { return 0 }
    let chars = s.len()
    return chars
}

// str_concat: concatenate two strings
// STATUS: PURE
fn rt_str_concat(a, b) {
    let sa = ""
    let sb = ""
    if type_of(a) == "string" { sa = a }
    if type_of(b) == "string" { sb = b }
    if sa == "" { return sb }
    if sb == "" { return sa }
    return sa + sb
}

// str_eq: string equality
// STATUS: PURE
fn rt_str_eq(a, b) {
    if type_of(a) != "string" { return false }
    if type_of(b) != "string" { return false }
    return a == b
}

// str_slice: byte-based slice [start, end) clamped to length
// STATUS: PURE
fn rt_str_slice(s, start, end_idx) {
    if type_of(s) != "string" { return "" }
    let slen = s.len()
    let mut a = start
    let mut b = end_idx
    if a < 0 { a = 0 }
    if b > slen { b = slen }
    if a > b { a = b }
    // Use builtin slice — grammar note: parens needed for addition in slice index
    let chars = []
    let mut i = a
    while i < b {
        chars.push(to_string(s[i]))
        i = i + 1
    }
    return chars.join("")
}

// str_contains: check if sub is in s
// STATUS: PURE
fn rt_str_contains(s, sub) {
    if type_of(s) != "string" { return false }
    if type_of(sub) != "string" { return false }
    let slen = s.len()
    let sublen = sub.len()
    if sublen == 0 { return true }
    if sublen > slen { return false }
    let mut i = 0
    while i <= slen - sublen {
        let mut match = true
        let mut j = 0
        while j < sublen {
            if s[(i + j)] != sub[j] {
                match = false
                j = sublen
            }
            j = j + 1
        }
        if match { return true }
        i = i + 1
    }
    return false
}

// str_starts_with: check prefix
// STATUS: PURE
fn rt_str_starts_with(s, prefix) {
    if type_of(s) != "string" { return false }
    if type_of(prefix) != "string" { return false }
    let plen = prefix.len()
    if plen > s.len() { return false }
    let mut i = 0
    while i < plen {
        if s[i] != prefix[i] { return false }
        i = i + 1
    }
    return true
}

// str_ends_with: check suffix
// STATUS: PURE
fn rt_str_ends_with(s, suffix) {
    if type_of(s) != "string" { return false }
    if type_of(suffix) != "string" { return false }
    let slen = s.len()
    let suflen = suffix.len()
    if suflen > slen { return false }
    let offset = slen - suflen
    let mut i = 0
    while i < suflen {
        if s[(offset + i)] != suffix[i] { return false }
        i = i + 1
    }
    return true
}

// str_index_of: find first occurrence of sub in s, return -1 if not found
// STATUS: PURE
fn rt_str_index_of(s, sub) {
    if type_of(s) != "string" { return -1 }
    if type_of(sub) != "string" { return -1 }
    let slen = s.len()
    let sublen = sub.len()
    if sublen == 0 { return 0 }
    if sublen > slen { return -1 }
    let mut i = 0
    while i <= slen - sublen {
        let mut match = true
        let mut j = 0
        while j < sublen {
            if s[(i + j)] != sub[j] {
                match = false
                j = sublen
            }
            j = j + 1
        }
        if match { return i }
        i = i + 1
    }
    return -1
}

// str_split: split string by delimiter
// STATUS: PURE
fn rt_str_split(s, delim) {
    if type_of(s) != "string" { return [] }
    if type_of(delim) != "string" { return [s] }
    let slen = s.len()
    let dlen = delim.len()
    if dlen == 0 { return [s] }
    let mut result = []
    let mut start = 0
    let mut i = 0
    while i <= slen - dlen {
        let mut found = true
        let mut j = 0
        while j < dlen {
            if s[(i + j)] != delim[j] {
                found = false
                j = dlen
            }
            j = j + 1
        }
        if found {
            result.push(rt_str_slice(s, start, i))
            start = i + dlen
            i = start
        } else {
            i = i + 1
        }
    }
    result.push(rt_str_slice(s, start, slen))
    return result
}

// str_trim: remove leading/trailing whitespace
// STATUS: PURE
fn rt_str_trim(s) {
    if type_of(s) != "string" { return s }
    let slen = s.len()
    // find first non-whitespace
    let mut start = 0
    let mut found_start = false
    while start < slen && found_start == false {
        let c = s[start]
        if c == " " || c == "\t" || c == "\n" || c == "\r" {
            start = start + 1
        } else {
            found_start = true
        }
    }
    if found_start == false { return "" }
    // find last non-whitespace
    let mut end_pos = slen
    while end_pos > start {
        let ec = s[(end_pos - 1)]
        if ec == " " || ec == "\t" || ec == "\n" || ec == "\r" {
            end_pos = end_pos - 1
        } else {
            return rt_str_slice(s, start, end_pos)
        }
    }
    return rt_str_slice(s, start, end_pos)
}

// str_trim_start: remove leading whitespace
// STATUS: PURE
fn rt_str_trim_start(s) {
    if type_of(s) != "string" { return s }
    let slen = s.len()
    let mut i = 0
    while i < slen {
        let c = s[i]
        if c != " " && c != "\t" && c != "\n" && c != "\r" {
            return rt_str_slice(s, i, slen)
        }
        i = i + 1
    }
    return ""
}

// str_trim_end: remove trailing whitespace
// STATUS: PURE
fn rt_str_trim_end(s) {
    if type_of(s) != "string" { return s }
    let mut end_pos = s.len()
    while end_pos > 0 {
        let c = s[(end_pos - 1)]
        if c != " " && c != "\t" && c != "\n" && c != "\r" {
            return rt_str_slice(s, 0, end_pos)
        }
        end_pos = end_pos - 1
    }
    return ""
}

// str_replace: replace all occurrences of old with new_str
// STATUS: PURE
fn rt_str_replace(s, old_str, new_str) {
    if type_of(s) != "string" { return s }
    let slen = s.len()
    let olen = old_str.len()
    if olen == 0 { return s }
    let mut parts = []
    let mut start = 0
    let mut i = 0
    while i <= slen - olen {
        let mut found = true
        let mut j = 0
        while j < olen {
            if s[(i + j)] != old_str[j] {
                found = false
                j = olen
            }
            j = j + 1
        }
        if found {
            parts.push(rt_str_slice(s, start, i))
            parts.push(new_str)
            start = i + olen
            i = start
        } else {
            i = i + 1
        }
    }
    parts.push(rt_str_slice(s, start, slen))
    return parts.join("")
}

// str_to_upper: ASCII uppercase
// STATUS: PURE
fn rt_str_to_upper(s) {
    if type_of(s) != "string" { return s }
    let slen = s.len()
    let mut parts = []
    let mut i = 0
    while i < slen {
        let c = s[i]
        if c >= "a" && c <= "z" {
            // ASCII shift: a=97 z=122 A=65 Z=90, diff=32
            let code = char_code(c) - 32
            parts.push(from_char_code(code))
        } else {
            parts.push(to_string(c))
        }
        i = i + 1
    }
    return parts.join("")
}

// str_to_lower: ASCII lowercase
// STATUS: PURE
fn rt_str_to_lower(s) {
    if type_of(s) != "string" { return s }
    let slen = s.len()
    let mut parts = []
    let mut i = 0
    while i < slen {
        let c = s[i]
        if c >= "A" && c <= "Z" {
            let code = char_code(c) + 32
            parts.push(from_char_code(code))
        } else {
            parts.push(to_string(c))
        }
        i = i + 1
    }
    return parts.join("")
}

// str_repeat: repeat string n times
// STATUS: PURE
fn rt_str_repeat(s, n) {
    if type_of(s) != "string" { return "" }
    if n <= 0 { return "" }
    let mut parts = []
    let mut i = 0
    while i < n {
        parts.push(s)
        i = i + 1
    }
    return parts.join("")
}

// str_chars: split string into array of single characters
// STATUS: PURE
fn rt_str_chars(s) {
    if type_of(s) != "string" { return [] }
    let slen = s.len()
    let mut result = []
    let mut i = 0
    while i < slen {
        result.push(to_string(s[i]))
        i = i + 1
    }
    return result
}

// str_parse_int: parse string to integer
// STATUS: PURE
fn rt_str_parse_int(s) {
    if type_of(s) != "string" { return 0 }
    return parse_int(s)
}

// str_parse_float: parse string to float
// STATUS: PURE
fn rt_str_parse_float(s) {
    if type_of(s) != "string" { return 0.0 }
    return parse_float(s)
}

// ============================================================
// 2. Array Operations — PURE
// ============================================================

// array_len: return length of array
// STATUS: PURE
fn rt_array_len(arr) {
    if type_of(arr) != "array" { return 0 }
    return arr.len()
}

// array_push: append item to array (returns new array)
// STATUS: PURE
fn rt_array_push(arr, item) {
    return arr.push(item)
}

// array_pop: remove last element, return it
// STATUS: PURE
fn rt_array_pop(arr) {
    if type_of(arr) != "array" { return null }
    let n = arr.len()
    if n == 0 { return null }
    return arr[(n - 1)]
}

// index_get: get element at index (array) or key (map)
// STATUS: PURE
fn rt_index_get(container, key) {
    return container[key]
}

// index_set: set element at index (array) or key (map)
// STATUS: PURE
fn rt_index_set(container, key, val) {
    container[key] = val
    return container
}

// array_slice: slice [start, end) clamped
// STATUS: PURE
fn rt_array_slice(arr, start, end_idx) {
    if type_of(arr) != "array" { return [] }
    let n = arr.len()
    let mut a = start
    let mut b = end_idx
    if a < 0 { a = 0 }
    if b > n { b = n }
    if a > b { a = b }
    let mut result = []
    let mut i = a
    while i < b {
        result.push(arr[i])
        i = i + 1
    }
    return result
}

// array_reverse: reverse array
// STATUS: PURE
fn rt_array_reverse(arr) {
    if type_of(arr) != "array" { return [] }
    let n = arr.len()
    let mut result = []
    let mut i = n - 1
    while i >= 0 {
        result.push(arr[i])
        i = i - 1
    }
    return result
}

// array_contains: check if array contains item
// STATUS: PURE
fn rt_array_contains(arr, item) {
    if type_of(arr) != "array" { return false }
    let n = arr.len()
    let mut i = 0
    while i < n {
        if arr[i] == item { return true }
        i = i + 1
    }
    return false
}

// array_index_of: find first index of item, -1 if not found
// STATUS: PURE
fn rt_array_index_of(arr, item) {
    if type_of(arr) != "array" { return -1 }
    let n = arr.len()
    let mut i = 0
    while i < n {
        if arr[i] == item { return i }
        i = i + 1
    }
    return -1
}

// array_map: apply fn to each element
// STATUS: PURE
fn rt_array_map(arr, f) {
    if type_of(arr) != "array" { return [] }
    let n = arr.len()
    let mut result = []
    let mut i = 0
    while i < n {
        result.push(f(arr[i]))
        i = i + 1
    }
    return result
}

// array_filter: keep elements where fn returns true
// STATUS: PURE
fn rt_array_filter(arr, f) {
    if type_of(arr) != "array" { return [] }
    let n = arr.len()
    let mut result = []
    let mut i = 0
    while i < n {
        if f(arr[i]) { result.push(arr[i]) }
        i = i + 1
    }
    return result
}

// array_fold: left fold with accumulator
// STATUS: PURE
fn rt_array_fold(arr, init, f) {
    if type_of(arr) != "array" { return init }
    let n = arr.len()
    let mut acc = init
    let mut i = 0
    while i < n {
        acc = f(acc, arr[i])
        i = i + 1
    }
    return acc
}

// str_join: join array of strings with separator
// STATUS: PURE
fn rt_str_join(arr, sep) {
    if type_of(arr) != "array" { return "" }
    let n = arr.len()
    if n == 0 { return "" }
    let mut parts = []
    let mut i = 0
    while i < n {
        if i > 0 { parts.push(sep) }
        parts.push(to_string(arr[i]))
        i = i + 1
    }
    return parts.join("")
}

// ============================================================
// 3. Math Operations — FFI (thin wrappers around libm)
// ============================================================
// These MUST call libm via FFI. Pure hexa alternatives would be
// too slow or imprecise for production use.

// STATUS: FFI
fn rt_math_sqrt(x) { return __c_sqrt(to_float(x)) }
fn rt_math_pow(b, e) { return __c_pow(to_float(b), to_float(e)) }
fn rt_math_exp(x) { return __c_exp(to_float(x)) }
fn rt_math_log(x) { return __c_log(to_float(x)) }
fn rt_math_floor(x) { return __c_floor(to_float(x)) }
fn rt_math_ceil(x) { return __c_ceil(to_float(x)) }
fn rt_math_round(x) { return __c_round(to_float(x)) }
fn rt_math_abs(x) { return __c_fabs(to_float(x)) }
fn rt_math_tanh(x) { return __c_tanh(to_float(x)) }
fn rt_math_sin(x) { return __c_sin(to_float(x)) }
fn rt_math_cos(x) { return __c_cos(to_float(x)) }

// min/max: PURE (no libm needed)
fn rt_math_min(a, b) {
    let fa = to_float(a)
    let fb = to_float(b)
    if fa < fb { return fa }
    return fb
}

fn rt_math_max(a, b) {
    let fa = to_float(a)
    let fb = to_float(b)
    if fa > fb { return fa }
    return fb
}

// ============================================================
// 4. I/O Operations — HYBRID (hexa logic + libc FFI)
// ============================================================

// read_file: read entire file as string
// STATUS: HYBRID
fn rt_read_file(path) {
    // Delegate to builtin — interpreter already has this
    return read_file(path)
}

// write_file: write string to file
// STATUS: HYBRID
fn rt_write_file(path, content) {
    return write_file(path, content)
}

// write_bytes: write array of ints (0-255) as raw bytes
// STATUS: HYBRID
fn rt_write_bytes(path, arr) {
    return write_bytes(path, arr)
}

// read_file_bytes: read file as array of byte ints
// STATUS: HYBRID
fn rt_read_file_bytes(path) {
    return read_file_bytes(path)
}

// ============================================================
// 5. Exec — HYBRID (needs popen FFI)
// ============================================================

// exec: run shell command, return stdout as string
// STATUS: HYBRID
fn rt_exec(cmd) {
    if type_of(cmd) != "string" { return "" }
    return exec(cmd)
}

// exec_with_status: run shell command, return [stdout, exit_code]
// STATUS: HYBRID
fn rt_exec_with_status(cmd) {
    if type_of(cmd) != "string" { return ["", 127] }
    return exec_with_status(cmd)
}

// ============================================================
// 6. Memory — FFI (cannot avoid C for malloc/free)
// ============================================================

// STATUS: FFI (unavoidable)
fn rt_alloc_raw(size) { return __c_malloc(size) }
fn rt_free_raw(ptr) { __c_free(ptr) }

// ============================================================
// PORT STATUS SUMMARY
// ============================================================
// PURE (20 functions — no C dependency):
//   rt_str_len, rt_str_concat, rt_str_eq, rt_str_slice,
//   rt_str_contains, rt_str_starts_with, rt_str_ends_with,
//   rt_str_index_of, rt_str_split, rt_str_trim, rt_str_trim_start,
//   rt_str_trim_end, rt_str_replace, rt_str_to_upper, rt_str_to_lower,
//   rt_str_repeat, rt_str_chars, rt_str_parse_int, rt_str_parse_float,
//   rt_str_join
//
// PURE (12 functions — array ops):
//   rt_array_len, rt_array_push, rt_array_pop, rt_index_get,
//   rt_index_set, rt_array_slice, rt_array_reverse, rt_array_contains,
//   rt_array_index_of, rt_array_map, rt_array_filter, rt_array_fold
//
// PURE (2 functions — math, no libm needed):
//   rt_math_min, rt_math_max
//
// FFI (11 functions — thin libm wrappers):
//   rt_math_sqrt, rt_math_pow, rt_math_exp, rt_math_log,
//   rt_math_floor, rt_math_ceil, rt_math_round, rt_math_abs,
//   rt_math_tanh, rt_math_sin, rt_math_cos
//
// FFI (2 functions — unavoidable malloc/free):
//   rt_alloc_raw, rt_free_raw
//
// HYBRID (6 functions — delegate to interpreter builtins):
//   rt_read_file, rt_write_file, rt_write_bytes, rt_read_file_bytes,
//   rt_exec, rt_exec_with_status
//
// TOTAL: 53 functions
//   34 PURE (no C at all)
//   13 FFI  (thin libc/libm wrappers)
//    6 HYBRID (builtin delegation)
