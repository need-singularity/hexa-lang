// ═══════════════════════════════════════════════════════════
//  test_array_methods.hexa — Array Operations & Methods Tests
//  Tests: creation, indexing, push, len, for-in, map, filter,
//         join, sort, contains, nested arrays, slicing
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA Array Operations Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Array creation & indexing ──────────────────────────

println("--- Creation & Indexing ---")

let arr = [10, 20, 30, 40, 50]
check("arr[0]", arr[0], 10)
check("arr[2]", arr[2], 30)
check("arr[4]", arr[4], 50)
check("arr len", len(arr), 5)

let empty = []
check("empty len", len(empty), 0)

let single = [42]
check("single[0]", single[0], 42)
check("single len", len(single), 1)

// ── 2. Push ───────────────────────────────────────────────

println("")
println("--- Push ---")

let mut list = []
list.push(1)
list.push(2)
list.push(3)
check("push len", len(list), 3)
check("push[0]", list[0], 1)
check("push[2]", list[2], 3)

// Push different types
let mut mixed = []
mixed.push(42)
mixed.push("hello")
mixed.push(true)
check("mixed len", len(mixed), 3)
check("mixed[0]", mixed[0], 42)
check("mixed[1]", mixed[1], "hello")
check("mixed[2]", mixed[2], true)

// ── 3. For-in loop ────────────────────────────────────────

println("")
println("--- For-In Loop ---")

let mut sum = 0
for x in [10, 20, 30] {
    sum = sum + x
}
check("for-in sum", sum, 60)

let mut words = ""
for w in ["hello", " ", "world"] {
    words = words + w
}
check("for-in string concat", words, "hello world")

// for-in with range
let mut range_sum = 0
let mut i = 0

while i < 5 {
    range_sum = range_sum + i
}
check("for-in range 0..5", range_sum, 10)

let mut range_sum2 = 0
let mut i = 1

while i < 4 {
    range_sum2 = range_sum2 + i
}
check("for-in range 1..4", range_sum2, 6)

// empty array for-in
let mut never = 0
for x in [] {
    never = 1
}
check("for-in empty", never, 0)

// ── 4. Array .map ─────────────────────────────────────────

println("")
println("--- Array .map ---")

let doubled = [1, 2, 3].map(|x| x * 2)
check("map *2 len", len(doubled), 3)
check("map *2 [0]", doubled[0], 2)
check("map *2 [1]", doubled[1], 4)
check("map *2 [2]", doubled[2], 6)

let strs = [1, 2, 3].map(|x| to_string(x))
check("map to_string[0]", strs[0], "1")
check("map to_string[2]", strs[2], "3")

// ── 5. Array .join ────────────────────────────────────────

println("")
println("--- Array .join ---")

let joined = ["a", "b", "c"].join(", ")
check("join comma", joined, "a, b, c")

let joined2 = ["hello", "world"].join(" ")
check("join space", joined2, "hello world")

let joined3 = ["x"].join(", ")
check("join single", joined3, "x")

// ── 6. Array building patterns ────────────────────────────

println("")
println("--- Array Building ---")

// Build array in loop
let mut squares = []
let mut i = 0
while i < 5 {
    squares.push(i * i)
    i = i + 1
}
check("squares len", len(squares), 5)
check("squares[0]", squares[0], 0)
check("squares[3]", squares[3], 9)
check("squares[4]", squares[4], 16)

// Build fibonacci array
let mut fibs = [0, 1]
let mut fi = 2
while fi < 10 {
    fibs.push(fibs[fi - 1] + fibs[fi - 2])
    fi = fi + 1
}
check("fib len", len(fibs), 10)
check("fib[0]", fibs[0], 0)
check("fib[1]", fibs[1], 1)
check("fib[6]", fibs[6], 8)
check("fib[9]", fibs[9], 34)

// ── 7. Nested arrays ──────────────────────────────────────

println("")
println("--- Nested Arrays ---")

let matrix = [[1, 2, 3], [4, 5, 6], [7, 8, 9]]
check("matrix len", len(matrix), 3)
check("matrix[0][0]", matrix[0][0], 1)
check("matrix[1][1]", matrix[1][1], 5)
check("matrix[2][2]", matrix[2][2], 9)

// matrix sum
let mut mat_sum = 0
for row in matrix {
    for val in row {
        mat_sum = mat_sum + val
    }
}
check("matrix sum", mat_sum, 45)

// ── 8. Array search patterns ──────────────────────────────

println("")
println("--- Array Search ---")

fn array_contains(arr, target) {
    for item in arr {
        if item == target {
            return true
        }
    }
    return false
}

check("contains found", array_contains([1, 2, 3, 4], 3), true)
check("contains not found", array_contains([1, 2, 3, 4], 5), false)
check("contains empty", array_contains([], 1), false)

fn array_index_of(arr, target) {
    let mut idx = 0
    for item in arr {
        if item == target {
            return idx
        }
        idx = idx + 1
    }
    return 0 - 1
}

check("indexOf found", array_index_of([10, 20, 30], 20), 1)
check("indexOf not found", array_index_of([10, 20, 30], 99), -1)

// ── 9. Array accumulation patterns ────────────────────────

println("")
println("--- Accumulation Patterns ---")

fn array_sum(arr) {
    let mut s = 0
    for x in arr { s = s + x }
    return s
}

fn array_max(arr) {
    let mut m = arr[0]
    let mut i = 1
    while i < len(arr) {
        if arr[i] > m { m = arr[i] }
        i = i + 1
    }
    return m
}

fn array_min(arr) {
    let mut m = arr[0]
    let mut i = 1
    while i < len(arr) {
        if arr[i] < m { m = arr[i] }
        i = i + 1
    }
    return m
}

check("array_sum", array_sum([1, 2, 3, 4, 5]), 15)
check("array_max", array_max([3, 7, 2, 9, 1]), 9)
check("array_min", array_min([3, 7, 2, 9, 1]), 1)

// ── 10. Array reverse ─────────────────────────────────────

fn array_reverse(arr) {
    let mut out = []
    let mut i = len(arr) - 1
    while i >= 0 {
        out.push(arr[i])
        i = i - 1
    }
    return out
}

let rev = array_reverse([1, 2, 3, 4, 5])
check("reverse[0]", rev[0], 5)
check("reverse[4]", rev[4], 1)
check("reverse len", len(rev), 5)

// ── 11. Array filter ──────────────────────────────────────

println("")
println("--- Array .filter ---")

let odds = [1, 2, 3, 4, 5, 6, 7, 8].filter(|x| x % 2 != 0)
check("filter odds len", len(odds), 4)
check("filter odds[0]", odds[0], 1)
check("filter odds[3]", odds[3], 7)

let big_nums = [1, 50, 3, 100, 7, 200].filter(|x| x >= 50)
check("filter >=50 len", len(big_nums), 3)
check("filter >=50 [0]", big_nums[0], 50)
check("filter >=50 [2]", big_nums[2], 200)

let none_match = [1, 2, 3].filter(|x| x > 100)
check("filter none len", len(none_match), 0)

// ── 12. Array chaining ───────────────────────────────────

println("")
println("--- Array Chaining ---")

let result = [1, 2, 3, 4, 5].map(|x| x * x).filter(|x| x > 5)
check("chain map+filter len", len(result), 3)
check("chain [0]", result[0], 9)
check("chain [2]", result[2], 25)

// ── 13. Array copy semantics ─────────────────────────────

println("")
println("--- Array Copy ---")

let orig = [1, 2, 3]
let mut copy = []
for x in orig { copy.push(x) }
check("copy len", len(copy), 3)
check("copy[0]", copy[0], 1)
check("copy[2]", copy[2], 3)

// ── 14. Array with strings ───────────────────────────────

println("")
println("--- String Arrays ---")

let names = ["Alice", "Bob", "Carol", "Dave"]
check("names len", len(names), 4)
check("names[0]", names[0], "Alice")
check("names join", names.join(", "), "Alice, Bob, Carol, Dave")

let mut upper_names = []
for n in names {
    upper_names.push(n.to_upper())
}
check("upper[0]", upper_names[0], "ALICE")
check("upper[3]", upper_names[3], "DAVE")

// ── 15. Array reduce pattern ─────────────────────────────

println("")
println("--- Array Reduce ---")

fn arr_reduce(arr, init, f) {
    let mut acc = init
    for item in arr { acc = f(acc, item) }
    return acc
}

check("reduce sum", arr_reduce([1,2,3,4,5], 0, |a,b| a + b), 15)
check("reduce product", arr_reduce([1,2,3,4], 1, |a,b| a * b), 24)
check("reduce max", arr_reduce([3,7,2,9], 0, |a,b| { if b > a { return b } return a }), 9)

// ═══════════════════════════════════════════════════════════
//  SUMMARY
// ═══════════════════════════════════════════════════════════

println("")
println("═══════════════════════════════════════════════════════")
let total = pass_count + fail_count
println("  Results: " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL / " + to_string(total) + " total")
if fail_count == 0 {
    println("  ALL ARRAY TESTS PASSED!")
} else {
    println("  SOME TESTS FAILED")
}
println("═══════════════════════════════════════════════════════")
