// ═══════════════════════════════════════════════════════════════════
//  test_membership_defense.hexa — Membership Inference Defense (#283)
// ═══════════════════════════════════════════════════════════════════

import "ml/membership_defense.hexa"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs_(inp) { if inp < 0.0 { return 0.0 - inp } return inp }
fn approx_(a, b, eps) { return fabs_(a - b) < eps }

fn sum_vec(v) {
    let n = len(v)
    let mut s = 0.0
    for i in 0..n { s = s + v[i] }
    return s
}

fn max_vec(v) {
    let n = len(v)
    let mut m = v[0]
    for i in 1..n { if v[i] > m { m = v[i] } }
    return m
}

println("=== Membership Inference Defense (#283) ===")

// ── T1 softmax sums to 1 ────────────────────────────────────
let sm1 = md_softmax([1.0, 2.0, 3.0])
check("T1 softmax sums to 1", approx_(sum_vec(sm1), 1.0, 1.0e-6))

// ── T2 temp softmax T=1 ≈ softmax ──────────────────────────
let sm2 = md_temp_softmax([1.0, 2.0, 3.0], 1.0)
check("T2 T=1 equals softmax", approx_(sm2[0], sm1[0], 1.0e-6) && approx_(sm2[2], sm1[2], 1.0e-6))

// ── T3 high T flattens distribution ────────────────────────
let sm_hiT = md_temp_softmax([1.0, 2.0, 3.0], 100.0)
let max_hiT = max_vec(sm_hiT)
check("T3 high T flattens", max_hiT < max_vec(sm1))

// ── T4 very high T approaches uniform ──────────────────────
let K4 = 3
let uni_gap = fabs_(max_hiT - 1.0 / to_float(K4))
check("T4 high T ~ uniform", uni_gap < 0.05)

// ── T5 label smoothing sums to 1 ───────────────────────────
let ls5 = md_label_smooth(1, 4, 0.1)
check("T5 label smooth sums to 1", approx_(sum_vec(ls5), 1.0, 1.0e-6))

// ── T6 label smoothing assigns mass to non-target ──────────
check("T6 non-target > 0", ls5[0] > 0.0)
check("T6 target biggest", ls5[1] > ls5[0])

// ── T7 output gauss sums to 1 ──────────────────────────────
let p_in = [0.7, 0.2, 0.1]
let og7 = md_output_gauss(p_in, 0.05, 42)
check("T7 output_gauss sums to 1", approx_(sum_vec(og7), 1.0, 1.0e-4))

// ── T8 top-k masking flattens tail ─────────────────────────
let cm8 = md_confidence_mask([0.7, 0.15, 0.1, 0.05], 1)
check("T8 top-k sums to 1", approx_(sum_vec(cm8), 1.0, 1.0e-4))
check("T8 top-k reduces max", cm8[0] <= 0.7 + 1.0e-4)

// ── T9 mem_guard caps max ──────────────────────────────────
let mg9 = md_mem_guard([0.95, 0.03, 0.02], 0.8)
check("T9 max ≤ tau", max_vec(mg9) <= 0.8 + 1.0e-6)
check("T9 mg sums to 1", approx_(sum_vec(mg9), 1.0, 1.0e-6))

// ── T10 mem_guard passthrough when under tau ──────────────
let mg10 = md_mem_guard([0.6, 0.3, 0.1], 0.9)
check("T10 passthrough", approx_(mg10[0], 0.6, 1.0e-6))

// ── T11 attack_predict basic ───────────────────────────────
check("T11 member -> yes", md_attack_predict([0.95, 0.05], 0.8))
check("T11 low-conf -> no", md_attack_predict([0.55, 0.45], 0.8) == false)

// ── T12 attack accuracy drops with defense ────────────────
// Members (high conf), non-members (lower conf)
let Pm = [[0.95, 0.05], [0.92, 0.08], [0.97, 0.03]]
let Pn = [[0.6, 0.4], [0.65, 0.35], [0.55, 0.45]]
let acc_base = md_attack_accuracy(Pm, Pn, 0.8)
// apply mem_guard defense to members
let mut Pm_def = []
for i in 0..3 { Pm_def = Pm_def + [md_mem_guard(Pm[i], 0.7)] }
let acc_def = md_attack_accuracy(Pm_def, Pn, 0.8)
check("T12 attack acc base high", acc_base >= 0.8)
check("T12 defense lowers acc", acc_def < acc_base)

// ── T13 apply_defense dispatch ────────────────────────────
let def13 = md_apply_defense([0.9, 0.05, 0.05], "memguard", 0.7, 1)
check("T13 dispatch memguard", max_vec(def13) <= 0.7 + 1.0e-6)

// ── T14 apply_defense temp dispatch ────────────────────────
let def14 = md_apply_defense([0.8, 0.1, 0.1], "temp", 10.0, 1)
check("T14 dispatch temp flattens", max_vec(def14) < 0.8)

println("")
println("=== Membership Defense summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
