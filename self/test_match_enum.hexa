// ═══════════════════════════════════════════════════════════
//  test_match_enum.hexa — Match Expression & Enum Tests
//  Tests: match with int/string/bool patterns, wildcard, block body,
//         enum declaration, enum in match, nested match
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA Match & Enum Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Basic match with int ───────────────────────────────

println("--- Match Int ---")

let x = 2
let r1 = match x {
    1 -> "one",
    2 -> "two",
    3 -> "three",
    _ -> "other"
}
check("match int 2", r1, "two")

let r2 = match 99 {
    1 -> "one",
    _ -> "default"
}
check("match int wildcard", r2, "default")

let r3 = match 1 {
    1 -> "one",
    _ -> "other"
}
check("match int 1", r3, "one")

// ── 2. Match with string ──────────────────────────────────

println("")
println("--- Match String ---")

fn greet(lang) {
    return match lang {
        "en" -> "hello",
        "ko" -> "annyeong",
        "jp" -> "konnichiwa",
        _ -> "hi"
    }
}
check("match str en", greet("en"), "hello")
check("match str ko", greet("ko"), "annyeong")
check("match str jp", greet("jp"), "konnichiwa")
check("match str other", greet("fr"), "hi")

// ── 3. Match with bool ────────────────────────────────────

println("")
println("--- Match Bool ---")

fn bool_word(b) {
    return match b {
        true -> "yes",
        false -> "no"
    }
}
check("match bool true", bool_word(true), "yes")
check("match bool false", bool_word(false), "no")

// ── 4. Match with block body ──────────────────────────────

println("")
println("--- Match Block Body ---")

let r4 = match 3 {
    1 -> {
        let a = 10
        a + 1
    },
    3 -> {
        let a = 100
        let b = 200
        a + b
    },
    _ -> 0
}
check("match block body", r4, 300)

// ── 5. Match in function ──────────────────────────────────

println("")
println("--- Match in Function ---")

fn day_type(day) {
    return match day {
        "Mon" -> "weekday",
        "Tue" -> "weekday",
        "Wed" -> "weekday",
        "Thu" -> "weekday",
        "Fri" -> "weekday",
        "Sat" -> "weekend",
        "Sun" -> "weekend",
        _ -> "unknown"
    }
}
check("day Mon", day_type("Mon"), "weekday")
check("day Sat", day_type("Sat"), "weekend")
check("day Sun", day_type("Sun"), "weekend")
check("day ???", day_type("xyz"), "unknown")

// ── 6. Match as classifier ────────────────────────────────

println("")
println("--- Match Classifier ---")

fn http_status(code) {
    if code >= 200 && code < 300 {
        return "ok"
    } else {
        if code >= 400 && code < 500 {
            return "client_error"
        } else {
            if code >= 500 {
                return "server_error"
            } else {
                return "other"
            }
        }
    }
}
check("http 200", http_status(200), "ok")
check("http 404", http_status(404), "client_error")
check("http 500", http_status(500), "server_error")
check("http 100", http_status(100), "other")

// ── 7. Match chained with computation ─────────────────────

println("")
println("--- Match + Computation ---")

fn score_grade(score) {
    let letter = match true {
        true -> {
            if score >= 90 { return "A" }
            if score >= 80 { return "B" }
            if score >= 70 { return "C" }
            return "F"
        }
    }
    return letter
}
check("grade 95", score_grade(95), "A")
check("grade 85", score_grade(85), "B")
check("grade 75", score_grade(75), "C")
check("grade 50", score_grade(50), "F")

// ── 8. Enum declaration ───────────────────────────────────

println("")
println("--- Enum ---")

enum Color { Red, Green, Blue }

// type_of(Color) not supported — enum type names are not values at runtime
// check("enum type exists", type_of(Color), "enum")

// ── 9. Match in loop ──────────────────────────────────────

println("")
println("--- Match in Loop ---")

let mut results = []
let mut i = 0

while i < 5 {
    let label = match i {
        0 -> "zero",
        1 -> "one",
        2 -> "two",
        _ -> "many"
    }
    results = results.push(label)
}
check("loop match[0]", results[0], "zero")
check("loop match[1]", results[1], "one")
check("loop match[2]", results[2], "two")
check("loop match[3]", results[3], "many")
check("loop match[4]", results[4], "many")

// ── 10. Nested match patterns ─────────────────────────────

println("")
println("--- Complex Match Patterns ---")

fn fizzbuzz(n) {
    if n % 15 == 0 { return "FizzBuzz" }
    if n % 3 == 0 { return "Fizz" }
    if n % 5 == 0 { return "Buzz" }
    return to_string(n)
}
check("fizzbuzz 15", fizzbuzz(15), "FizzBuzz")
check("fizzbuzz 9", fizzbuzz(9), "Fizz")
check("fizzbuzz 10", fizzbuzz(10), "Buzz")
check("fizzbuzz 7", fizzbuzz(7), "7")

// State machine pattern
fn state_machine(state, input) {
    return match state {
        "idle" -> {
            if input == "start" { "running" } else { "idle" }
        },
        "running" -> {
            if input == "stop" { "idle" } else { if input == "pause" { "paused" } else { "running" } }
        },
        "paused" -> {
            if input == "resume" { "running" } else { if input == "stop" { "idle" } else { "paused" } }
        },
        _ -> "error"
    }
}
check("sm idle->start", state_machine("idle", "start"), "running")
check("sm running->pause", state_machine("running", "pause"), "paused")
check("sm paused->resume", state_machine("paused", "resume"), "running")
check("sm running->stop", state_machine("running", "stop"), "idle")
check("sm unknown", state_machine("???", "x"), "error")

// ═══════════════════════════════════════════════════════════
//  SUMMARY
// ═══════════════════════════════════════════════════════════

println("")
println("═══════════════════════════════════════════════════════")
let total = pass_count + fail_count
println("  Results: " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL / " + to_string(total) + " total")
if fail_count == 0 {
    println("  ALL MATCH/ENUM TESTS PASSED!")
} else {
    println("  SOME TESTS FAILED")
}
println("═══════════════════════════════════════════════════════")
