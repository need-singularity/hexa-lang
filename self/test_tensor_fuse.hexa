// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
//  test_tensor_fuse.hexa вЂ” ROI #81 verification.
//
//  Covers:
//    (1) empty chain (identity) on non-empty input
//    (2) empty input array on non-empty chain
//    (3) add в†’ mul в†’ relu   chain  (positive + negative inputs)
//    (4) add в†’ gelu в†’ scale chain  (non-linear + scale)
//    (5) mul в†’ tanh в†’ add chain
//    (6) relu в†’ sigmoid chain
//    (7) long chain of 6 ops (all op tags exercised)
//    (8) element-wise ORDER preserved вЂ” add(+1) then mul(2)  !=
//        mul(2) then add(+1)
//    (9) allocation accounting: naive = k+1, fused = 1
//   (10) single-op map helper consistent with 1-op chain
//
//  Numerical agreement between fused_chain and naive_chain is
//  asserted at tolerance 1e-5 for every elementwise position.
// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

use "ai_native/tensor_fuse"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

// Absolute value for float (no std::abs in interp).
fn fabs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

// Element-wise closeness within tolerance.
fn arrays_close(a, b, tol) {
    let la = len(a)
    let lb = len(b)
    if la != lb { return false }
    let mut i = 0
    while i < la {
        let d = fabs(a[i] - b[i])
        if d > tol { return false }
        i = i + 1
    }
    return true
}

println("=== @tensor_fuse tests ===")

let tol = 1.0e-5

// в”Ђв”Ђ (1) empty chain (identity) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
let x1 = [1.0, 2.0, -3.0, 4.5]
let empty_ops = []
let fused1 = fused_chain(x1, empty_ops)
let naive1 = naive_chain(x1, empty_ops)
check("empty chain: fused preserves values", arrays_close(fused1, x1, tol))
check("empty chain: naive preserves values", arrays_close(naive1, x1, tol))
check("empty chain: fused == naive",        arrays_close(fused1, naive1, tol))
check("empty chain: fused alloc == 1",      fused_alloc_count(empty_ops) == 1)
check("empty chain: naive alloc == 1 (k+1)", naive_alloc_count(empty_ops) == 1)

// в”Ђв”Ђ (2) empty input array в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
let x2 = []
let mut ops2 = []
ops2 = ops2.push(op_add_const(1.0))
ops2 = ops2.push(op_relu())
let fused2 = fused_chain(x2, ops2)
let naive2 = naive_chain(x2, ops2)
check("empty input: fused len == 0", len(fused2) == 0)
check("empty input: naive len == 0", len(naive2) == 0)
check("empty input: fused == naive", arrays_close(fused2, naive2, tol))

// в”Ђв”Ђ (3) add в†’ mul в†’ relu в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// x + 1.5  в†’  В· 2.0  в†’  relu
// For x=[-5, -0.5, 0.5, 3.0]: intermediates
//   +1.5   = [-3.5, 1.0, 2.0, 4.5]
//   *2.0   = [-7.0, 2.0, 4.0, 9.0]
//   relu   = [ 0.0, 2.0, 4.0, 9.0]
let x3 = [-5.0, -0.5, 0.5, 3.0]
let mut ops3 = []
ops3 = ops3.push(op_add_const(1.5))
ops3 = ops3.push(op_mul_const(2.0))
ops3 = ops3.push(op_relu())
let fused3 = fused_chain(x3, ops3)
let naive3 = naive_chain(x3, ops3)
let expect3 = [0.0, 2.0, 4.0, 9.0]
check("addв†’mulв†’relu: fused matches expected", arrays_close(fused3, expect3, tol))
check("addв†’mulв†’relu: naive matches expected", arrays_close(naive3, expect3, tol))
check("addв†’mulв†’relu: fused == naive",         arrays_close(fused3, naive3, tol))
check("addв†’mulв†’relu: naive alloc == 4",       naive_alloc_count(ops3) == 4)
check("addв†’mulв†’relu: fused alloc == 1",       fused_alloc_count(ops3) == 1)

// в”Ђв”Ђ (4) add в†’ gelu в†’ scale в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// Non-linear chain: only verify fused == naive at tolerance.
let x4 = [-2.0, -0.5, 0.0, 0.5, 1.5]
let mut ops4 = []
ops4 = ops4.push(op_add_const(0.25))
ops4 = ops4.push(op_gelu_approx())
ops4 = ops4.push(op_mul_const(1.5))
let fused4 = fused_chain(x4, ops4)
let naive4 = naive_chain(x4, ops4)
check("addв†’geluв†’scale: len preserved",   len(fused4) == len(x4))
check("addв†’geluв†’scale: fused == naive",  arrays_close(fused4, naive4, tol))

// в”Ђв”Ђ (5) mul в†’ tanh в†’ add в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
let x5 = [-3.0, -1.0, 0.0, 1.0, 3.0]
let mut ops5 = []
ops5 = ops5.push(op_mul_const(0.5))
ops5 = ops5.push(op_tanh_approx())
ops5 = ops5.push(op_add_const(1.0))
let fused5 = fused_chain(x5, ops5)
let naive5 = naive_chain(x5, ops5)
check("mulв†’tanhв†’add: fused == naive", arrays_close(fused5, naive5, tol))
// tanh is bounded to (-1,1), plus 1.0 shifts to (0, 2)
check("mulв†’tanhв†’add: all values in (0,2)",
      fused5[0] > 0.0 && fused5[0] < 2.0 &&
      fused5[4] > 0.0 && fused5[4] < 2.0)

// в”Ђв”Ђ (6) relu в†’ sigmoid в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
let x6 = [-10.0, -1.0, 0.0, 1.0, 10.0]
let mut ops6 = []
ops6 = ops6.push(op_relu())
ops6 = ops6.push(op_sigmoid_approx())
let fused6 = fused_chain(x6, ops6)
let naive6 = naive_chain(x6, ops6)
check("reluв†’sigmoid: fused == naive", arrays_close(fused6, naive6, tol))
// after reluв†’sigmoid, every negative input maps to sigmoid(0) = 0.5
check("reluв†’sigmoid: negatives land on 0.5", fabs(fused6[0] - 0.5) < tol && fabs(fused6[1] - 0.5) < tol)

// в”Ђв”Ђ (7) long chain of 6 ops (all tags exercised) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
let x7 = [-1.0, 0.0, 1.0]
let mut ops7 = []
ops7 = ops7.push(op_add_const(0.5))         // tag 0
ops7 = ops7.push(op_mul_const(2.0))         // tag 1
ops7 = ops7.push(op_relu())                 // tag 2
ops7 = ops7.push(op_gelu_approx())          // tag 3
ops7 = ops7.push(op_tanh_approx())          // tag 4
ops7 = ops7.push(op_sigmoid_approx())       // tag 5
let fused7 = fused_chain(x7, ops7)
let naive7 = naive_chain(x7, ops7)
check("6-op chain: len preserved",  len(fused7) == len(x7))
check("6-op chain: fused == naive", arrays_close(fused7, naive7, tol))
check("6-op chain: naive alloc == 7", naive_alloc_count(ops7) == 7)
check("6-op chain: fused alloc == 1", fused_alloc_count(ops7) == 1)

// в”Ђв”Ђ (8) order preservation в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// (x + 1) В· 2  vs  (x В· 2) + 1  must differ.
let x8 = [1.0, 2.0, 3.0]
let mut ops_ab = []
ops_ab = ops_ab.push(op_add_const(1.0))
ops_ab = ops_ab.push(op_mul_const(2.0))
let mut ops_ba = []
ops_ba = ops_ba.push(op_mul_const(2.0))
ops_ba = ops_ba.push(op_add_const(1.0))
let ab = fused_chain(x8, ops_ab)   // (x+1)*2 = [4,6,8]
let ba = fused_chain(x8, ops_ba)   // x*2+1   = [3,5,7]
check("order: (x+1)В·2 == [4,6,8]", arrays_close(ab, [4.0, 6.0, 8.0], tol))
check("order: (xВ·2)+1 == [3,5,7]", arrays_close(ba, [3.0, 5.0, 7.0], tol))
check("order: ab != ba",           arrays_close(ab, ba, tol) == false)

// в”Ђв”Ђ (9) allocation accounting (expanded) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
let mut big_ops = []
let mut bi = 0
while bi < 10 {
    big_ops = big_ops.push(op_add_const(0.1))
    bi = bi + 1
}
check("alloc: 10-op chain naive == 11", naive_alloc_count(big_ops) == 11)
check("alloc: 10-op chain fused == 1",  fused_alloc_count(big_ops) == 1)

// в”Ђв”Ђ (10) map_op 1-op consistency в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
let x10 = [1.0, 2.0, 3.0]
let mapped = map_op(x10, op_mul_const(3.0))
let mut ops_one = []
ops_one = ops_one.push(op_mul_const(3.0))
let chained = fused_chain(x10, ops_one)
check("map_op == fused(1 op)", arrays_close(mapped, chained, tol))
check("map_op correct value",  arrays_close(mapped, [3.0, 6.0, 9.0], tol))

println("")
println("=== summary ===")
println("  PASS: " + to_string(pass_count))
println("  FAIL: " + to_string(fail_count))
if fail_count == 0 {
    println("tensor_fuse: ALL GREEN")
} else {
    println("tensor_fuse: FAILURES detected")
}
