// ═══════════════════════════════════════════════════════════
//  test_tensor_fuse.hexa — ROI #81 verification.
//
//  Covers:
//    (1) empty chain (identity) on non-empty input
//    (2) empty input array on non-empty chain
//    (3) add → mul → relu   chain  (positive + negative inputs)
//    (4) add → gelu → scale chain  (non-linear + scale)
//    (5) mul → tanh → add chain
//    (6) relu → sigmoid chain
//    (7) long chain of 6 ops (all op tags exercised)
//    (8) element-wise ORDER preserved — add(+1) then mul(2)  !=
//        mul(2) then add(+1)
//    (9) allocation accounting: naive = k+1, fused = 1
//   (10) single-op map helper consistent with 1-op chain
//
//  Numerical agreement between fused_chain and naive_chain is
//  asserted at tolerance 1e-5 for every elementwise position.
// ═══════════════════════════════════════════════════════════

// -- inlined from self/ai_native/tensor_fuse.hexa --
// codegen import not wired for test files

// ═══════════════════════════════════════════════════════════
//  self/ai_native/tensor_fuse.hexa
//
//  @tensor_fuse — element-wise chain fusion.
//
//  Motivation: element-wise pipelines like
//      out = scale(relu(add_const(x, b)))
//  are commonly expressed as a sequence of `map(...)` calls over
//  a float tensor. The naive implementation materializes a fresh
//  array at every stage — O(N · (K+1)) allocation and 2·N·K
//  memory round-trips for a K-op chain of length N.
//
//  Fusion strategy:
//    Allocate ONE output array of length N and, for each element,
//    apply the full op chain in a register-local variable before
//    writing back. Net: 1 allocation, N · K pure ALU ops,
//    K memory round-trips eliminated.
//
//  Op encoding (no enum in hexa — we use a struct with a tag int):
//    tag 0 = add_const    (x := x + c)
//    tag 1 = mul_const    (x := x * c)       // aka "scale"
//    tag 2 = relu         (x := max(x, 0))
//    tag 3 = gelu_approx  (x := 0.5 · x · (1 + tanh(√(2/π)·(x + 0.044715·x³))))
//    tag 4 = tanh_approx  (x := tanh(x))
//    tag 5 = sigmoid_approx (x := 1 / (1 + exp(-x)), clamped)
//
//  Numerical contract:
//    fused_chain(x, ops) == naive_chain(x, ops)  within 1e-5
//    element-wise for any chain of the above ops, for finite inputs.
//
//  Allocation contract:
//    naive_chain: len(ops) + 1 arrays allocated
//    fused_chain: 1 array allocated (independent of len(ops))
// ═══════════════════════════════════════════════════════════

// ── Op struct + constructors ───────────────────────────────

pub struct Op {
    tag: int,
    c: float
}

pub fn op_add_const(c) {
    return Op { tag: 0, c: c }
}

pub fn op_mul_const(c) {
    return Op { tag: 1, c: c }
}

pub fn op_relu() {
    return Op { tag: 2, c: 0.0 }
}

pub fn op_gelu_approx() {
    return Op { tag: 3, c: 0.0 }
}

pub fn op_tanh_approx() {
    return Op { tag: 4, c: 0.0 }
}

pub fn op_sigmoid_approx() {
    return Op { tag: 5, c: 0.0 }
}

// ── pointwise helpers (kept private to the module) ─────────

// GELU (tanh approximation):
//   0.5 · x · (1 + tanh( sqrt(2/π) · (x + 0.044715 · x³) ))
// sqrt(2/π) ≈ 0.7978845608028654
fn gelu_pointwise(x) {
    let k = 0.7978845608028654
    let x3 = x * x * x
    let inner = k * (x + 0.044715 * x3)
    return 0.5 * x * (1.0 + tanh(inner))
}

// Sigmoid, numerically safe.
//   Clamp input to [-40, 40] to keep exp() finite under the
//   hexa float interpreter (exp(±40) ≈ 4e17 / 4e-18 — both
//   representable) then compute 1 / (1 + exp(-x)).
fn sigmoid_pointwise(x) {
    let mut c = x
    if c >  40.0 { c =  40.0 }
    if c < -40.0 { c = -40.0 }
    return 1.0 / (1.0 + exp(0.0 - c))
}

// Apply a single op to a scalar value.
fn apply_op(x, op) {
    let t = op.tag
    if t == 0 {
        return x + op.c
    } else if t == 1 {
        return x * op.c
    } else if t == 2 {
        if x < 0.0 { return 0.0 }
        return x
    } else if t == 3 {
        return gelu_pointwise(x)
    } else if t == 4 {
        return tanh(x)
    } else if t == 5 {
        return sigmoid_pointwise(x)
    }
    // unknown tag → identity (defensive)
    return x
}

// ── fused: single-loop, one allocation ─────────────────────

// Apply every op in `ops` to every element of `x` inside one
// sweep. Allocates exactly one output array of length len(x).
pub fn fused_chain(x, ops) {
    let n = len(x)
    let k = len(ops)
    let mut out = []
    let mut i = 0
    while i < n {
        let mut v = x[i]
        let mut j = 0
        while j < k {
            v = apply_op(v, ops[j])
            j = j + 1
        }
        out.push(v)
        i = i + 1
    }
    return out
}

// ── naive baseline: one array per op ───────────────────────

// Apply a single op across the whole array, producing a fresh
// array. Used by naive_chain; exported because tests want to
// verify the 1-op case independently as well.
pub fn map_op(x, op) {
    let n = len(x)
    let mut out = []
    let mut i = 0
    while i < n {
        out.push(apply_op(x[i], op))
        i = i + 1
    }
    return out
}

// Reference implementation: one fresh array allocation per op
// in the chain (plus the initial copy), for a total of
// len(ops)+1 allocations. Intentionally non-fused.
pub fn naive_chain(x, ops) {
    let k = len(ops)
    // initial copy so we never mutate the caller's array
    let mut cur = []
    let mut i0 = 0
    let n = len(x)
    while i0 < n {
        cur.push(x[i0])
        i0 = i0 + 1
    }
    let mut j = 0
    while j < k {
        cur = map_op(cur, ops[j])
        j = j + 1
    }
    return cur
}

// ── allocation accounting (for tests/benches) ──────────────

// Declared allocation count of naive_chain (for len(ops) = k,
// len(x) > 0): initial copy + one per op = k + 1.
pub fn naive_alloc_count(ops) {
    return len(ops) + 1
}

// Declared allocation count of fused_chain: always exactly 1.
pub fn fused_alloc_count(ops) {
    return 1
}


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

// Absolute value for float (no std::abs in interp).
fn fabs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

// Element-wise closeness within tolerance.
fn arrays_close(a, b, tol) {
    let la = len(a)
    let lb = len(b)
    if la != lb { return false }
    let mut i = 0
    while i < la {
        let d = fabs(a[i] - b[i])
        if d > tol { return false }
        i = i + 1
    }
    return true
}

println("=== @tensor_fuse tests ===")

let tol = 1.0e-5

// ── (1) empty chain (identity) ─────────────────────────────
let x1 = [1.0, 2.0, -3.0, 4.5]
let empty_ops = []
let fused1 = fused_chain(x1, empty_ops)
let naive1 = naive_chain(x1, empty_ops)
check("empty chain: fused preserves values", arrays_close(fused1, x1, tol))
check("empty chain: naive preserves values", arrays_close(naive1, x1, tol))
check("empty chain: fused == naive",        arrays_close(fused1, naive1, tol))
check("empty chain: fused alloc == 1",      fused_alloc_count(empty_ops) == 1)
check("empty chain: naive alloc == 1 (k+1)", naive_alloc_count(empty_ops) == 1)

// ── (2) empty input array ──────────────────────────────────
let x2 = []
let mut ops2 = []
ops2.push(op_add_const(1.0))
ops2.push(op_relu())
let fused2 = fused_chain(x2, ops2)
let naive2 = naive_chain(x2, ops2)
check("empty input: fused len == 0", len(fused2) == 0)
check("empty input: naive len == 0", len(naive2) == 0)
check("empty input: fused == naive", arrays_close(fused2, naive2, tol))

// ── (3) add → mul → relu ───────────────────────────────────
// x + 1.5  →  · 2.0  →  relu
// For x=[-5, -0.5, 0.5, 3.0]: intermediates
//   +1.5   = [-3.5, 1.0, 2.0, 4.5]
//   *2.0   = [-7.0, 2.0, 4.0, 9.0]
//   relu   = [ 0.0, 2.0, 4.0, 9.0]
let x3 = [-5.0, -0.5, 0.5, 3.0]
let mut ops3 = []
ops3.push(op_add_const(1.5))
ops3.push(op_mul_const(2.0))
ops3.push(op_relu())
let fused3 = fused_chain(x3, ops3)
let naive3 = naive_chain(x3, ops3)
let expect3 = [0.0, 2.0, 4.0, 9.0]
check("add→mul→relu: fused matches expected", arrays_close(fused3, expect3, tol))
check("add→mul→relu: naive matches expected", arrays_close(naive3, expect3, tol))
check("add→mul→relu: fused == naive",         arrays_close(fused3, naive3, tol))
check("add→mul→relu: naive alloc == 4",       naive_alloc_count(ops3) == 4)
check("add→mul→relu: fused alloc == 1",       fused_alloc_count(ops3) == 1)

// ── (4) add → gelu → scale ─────────────────────────────────
// Non-linear chain: only verify fused == naive at tolerance.
let x4 = [-2.0, -0.5, 0.0, 0.5, 1.5]
let mut ops4 = []
ops4.push(op_add_const(0.25))
ops4.push(op_gelu_approx())
ops4.push(op_mul_const(1.5))
let fused4 = fused_chain(x4, ops4)
let naive4 = naive_chain(x4, ops4)
check("add→gelu→scale: len preserved",   len(fused4) == len(x4))
check("add→gelu→scale: fused == naive",  arrays_close(fused4, naive4, tol))

// ── (5) mul → tanh → add ───────────────────────────────────
let x5 = [-3.0, -1.0, 0.0, 1.0, 3.0]
let mut ops5 = []
ops5.push(op_mul_const(0.5))
ops5.push(op_tanh_approx())
ops5.push(op_add_const(1.0))
let fused5 = fused_chain(x5, ops5)
let naive5 = naive_chain(x5, ops5)
check("mul→tanh→add: fused == naive", arrays_close(fused5, naive5, tol))
// tanh is bounded to (-1,1), plus 1.0 shifts to (0, 2)
check("mul→tanh→add: all values in (0,2)",
      fused5[0] > 0.0 && fused5[0] < 2.0 &&
      fused5[4] > 0.0 && fused5[4] < 2.0)

// ── (6) relu → sigmoid ─────────────────────────────────────
let x6 = [-10.0, -1.0, 0.0, 1.0, 10.0]
let mut ops6 = []
ops6.push(op_relu())
ops6.push(op_sigmoid_approx())
let fused6 = fused_chain(x6, ops6)
let naive6 = naive_chain(x6, ops6)
check("relu→sigmoid: fused == naive", arrays_close(fused6, naive6, tol))
// after relu→sigmoid, every negative input maps to sigmoid(0) = 0.5
check("relu→sigmoid: negatives land on 0.5", fabs(fused6[0] - 0.5) < tol && fabs(fused6[1] - 0.5) < tol)

// ── (7) long chain of 6 ops (all tags exercised) ───────────
let x7 = [-1.0, 0.0, 1.0]
let mut ops7 = []
ops7.push(op_add_const(0.5))         // tag 0
ops7.push(op_mul_const(2.0))         // tag 1
ops7.push(op_relu())                 // tag 2
ops7.push(op_gelu_approx())          // tag 3
ops7.push(op_tanh_approx())          // tag 4
ops7.push(op_sigmoid_approx())       // tag 5
let fused7 = fused_chain(x7, ops7)
let naive7 = naive_chain(x7, ops7)
check("6-op chain: len preserved",  len(fused7) == len(x7))
check("6-op chain: fused == naive", arrays_close(fused7, naive7, tol))
check("6-op chain: naive alloc == 7", naive_alloc_count(ops7) == 7)
check("6-op chain: fused alloc == 1", fused_alloc_count(ops7) == 1)

// ── (8) order preservation ─────────────────────────────────
// (x + 1) · 2  vs  (x · 2) + 1  must differ.
let x8 = [1.0, 2.0, 3.0]
let mut ops_ab = []
ops_ab.push(op_add_const(1.0))
ops_ab.push(op_mul_const(2.0))
let mut ops_ba = []
ops_ba.push(op_mul_const(2.0))
ops_ba.push(op_add_const(1.0))
let ab = fused_chain(x8, ops_ab)   // (x+1)*2 = [4,6,8]
let ba = fused_chain(x8, ops_ba)   // x*2+1   = [3,5,7]
check("order: (x+1)·2 == [4,6,8]", arrays_close(ab, [4.0, 6.0, 8.0], tol))
check("order: (x·2)+1 == [3,5,7]", arrays_close(ba, [3.0, 5.0, 7.0], tol))
check("order: ab != ba",           arrays_close(ab, ba, tol) == false)

// ── (9) allocation accounting (expanded) ───────────────────
let mut big_ops = []
let mut bi = 0
while bi < 10 {
    big_ops.push(op_add_const(0.1))
    bi = bi + 1
}
check("alloc: 10-op chain naive == 11", naive_alloc_count(big_ops) == 11)
check("alloc: 10-op chain fused == 1",  fused_alloc_count(big_ops) == 1)

// ── (10) map_op 1-op consistency ───────────────────────────
let x10 = [1.0, 2.0, 3.0]
let mapped = map_op(x10, op_mul_const(3.0))
let mut ops_one = []
ops_one.push(op_mul_const(3.0))
let chained = fused_chain(x10, ops_one)
check("map_op == fused(1 op)", arrays_close(mapped, chained, tol))
check("map_op correct value",  arrays_close(mapped, [3.0, 6.0, 9.0], tol))

println("")
println("=== summary ===")
println("  PASS: " + to_string(pass_count))
println("  FAIL: " + to_string(fail_count))
if fail_count == 0 {
    println("tensor_fuse: ALL GREEN")
} else {
    println("tensor_fuse: FAILURES detected")
}
