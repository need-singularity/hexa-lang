// ═══════════════════════════════════════════════════════════
//  test_self_compile.hexa — Self-compile lexer.hexa via C transpile pipeline
//  Milestone test: lexer.hexa -> tokenize -> parse -> codegen_c2 -> clang -> native
//
//  Strategy: Progressive levels
//    L1: Minimal subset (is_keyword only — pure functions, no structs)
//    L2: Token struct + is_keyword + simple tokenize subset
//    L3: Full lexer.hexa (if L1-L2 pass)
// ═══════════════════════════════════════════════════════════

use "self/stdlib/law_io"

let _hexa_root = if len(env_var("HEXA_LANG")) > 0 { env_var("HEXA_LANG") } else { "." }
let HEXA = _hexa_root + "/hexa"
let SELF_DIR = _hexa_root + "/self"
let TMP_DIR = "/tmp/hexa_lexer_selfcomp"
let RUNTIME_DIR = SELF_DIR

exec("mkdir -p " + TMP_DIR)

let mut pass_count = 0
let mut fail_count = 0
let mut total_count = 0

// ── Load pipeline modules ──────────────────────────────────
fn build_pipeline_source() {
    let lexer_src = read_file(SELF_DIR + "/lexer.hexa")
    let parser_src = read_file(SELF_DIR + "/parser.hexa")
    let tc_src = read_file(SELF_DIR + "/type_checker.hexa")
    let cg_src = read_file(SELF_DIR + "/codegen_c2.hexa")
    return lexer_src + "\n" + parser_src + "\n" + tc_src + "\n" + cg_src + "\n"
}

let pipeline_src = build_pipeline_source()

// ── Test runner (from test_e2e_pipeline.hexa pattern) ──────
fn run_selfcomp_test(name, hexa_source, expected_output) {
    total_count = total_count + 1
    println("--- [" + name + "] ---")

    let c_file = TMP_DIR + "/" + name + ".c"
    let bin_file = TMP_DIR + "/" + name
    let driver_file = TMP_DIR + "/" + name + "_driver.hexa"
    let src_file = TMP_DIR + "/" + name + ".hexa"

    safe_write_file(src_file, hexa_source)

    // Driver: load pipeline + feed source through it
    let driver = pipeline_src + "\n" + "let __src = read_file(\"" + src_file + "\")\n" + "let __tokens = tokenize(__src)\n" + "let __ast = parse(__tokens)\n" + "let __c = codegen_c2_full(__ast)\n" + "write_file(\"" + c_file + "\", __c)\n" + "println(\"PIPELINE_OK\")\n"

    safe_write_file(driver_file, driver)

    // Step 1: Run pipeline
    let pipeline_result = exec(HEXA + " " + driver_file + " 2>&1")
    if type_of(pipeline_result) == "error" {
        println("  FAIL (pipeline exec): " + to_string(pipeline_result))
        return "pipeline_error"
    }

    let lines = pipeline_result.split("\n")
    let mut found_ok = false
    for line in lines {
        if line == "PIPELINE_OK" {
            found_ok = true
        }
    }
    if !found_ok {
        println("  FAIL (pipeline incomplete)")
        println("  output: " + pipeline_result)
        return "pipeline_fail"
    }
    println("  [1/4] Pipeline OK (lex -> parse -> codegen_c2)")

    // Step 2: Read generated C
    if !file_exists(c_file) {
        println("  FAIL: C file not generated")
        return "no_c_file"
    }
    let c_code = read_file(c_file)
    println("  [2/4] C generated: " + to_string(len(c_code)) + " chars")

    // Save C for inspection
    println("  C file: " + c_file)

    // Step 3: Compile with clang
    let compile_cmd = "clang -O2 -I " + RUNTIME_DIR + " " + c_file + " -o " + bin_file + " -lm 2>&1"
    let compile_result = exec(compile_cmd)
    if type_of(compile_result) == "error" {
        println("  FAIL (clang error): " + to_string(compile_result))
        // Show C for debugging
        if len(c_code) < 3000 {
            println("  --- Generated C ---")
            println(c_code)
            println("  --- End C ---")
        }
        return "compile_error"
    }
    if len(compile_result) > 0 {
        println("  clang: " + compile_result)
        // Check if it's a hard error (non-zero exit)
        if !file_exists(bin_file) {
            println("  FAIL: binary not produced")
            if len(c_code) < 3000 {
                println("  --- Generated C ---")
                println(c_code)
                println("  --- End C ---")
            }
            return "compile_error"
        }
    }
    println("  [3/4] Compiled to native: " + bin_file)

    // Step 4: Run native binary
    let run_result = exec(bin_file + " 2>&1")
    if type_of(run_result) == "error" {
        println("  FAIL (binary exec error): " + to_string(run_result))
        return "run_error"
    }
    println("  [4/4] Output: \"" + run_result + "\"")

    if run_result == expected_output {
        println("  PASS")
        return "pass"
    } else {
        println("  FAIL: expected \"" + expected_output + "\", got \"" + run_result + "\"")
        return "output_mismatch"
    }
}

// ═══════════════════════════════════════════════════════════
//  LEVEL 1: Pure functions only — is_keyword subset
//  No structs, no field access, no char literals
// ═══════════════════════════════════════════════════════════

println("═══════════════════════════════════════════════════════")
println("  HEXA Lexer Self-Compile Test")
println("  lexer.hexa -> C transpile pipeline -> native binary")
println("═══════════════════════════════════════════════════════")
println("")
println("=== LEVEL 1: Pure function subset (is_keyword) ===")
println("")

let l1_src = "fn is_keyword(word) {
    if word == \"if\" { return true }
    if word == \"else\" { return true }
    if word == \"fn\" { return true }
    if word == \"let\" { return true }
    if word == \"mut\" { return true }
    if word == \"while\" { return true }
    if word == \"for\" { return true }
    if word == \"return\" { return true }
    if word == \"struct\" { return true }
    if word == \"enum\" { return true }
    return false
}

if is_keyword(\"fn\") {
    println(\"fn=keyword\")
} else {
    println(\"fn=NOT\")
}
if is_keyword(\"hello\") {
    println(\"hello=keyword\")
} else {
    println(\"hello=ident\")
}
println(\"L1_OK\")"

let l1_result = run_selfcomp_test("L1_is_keyword", l1_src, "fn=keyword\nhello=ident\nL1_OK")
if l1_result == "pass" {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}
println("")

// ═══════════════════════════════════════════════════════════
//  LEVEL 2: Struct + field access + method calls
//  Token struct, creation, field access, push
// ═══════════════════════════════════════════════════════════

println("=== LEVEL 2: Token struct + field access ===")
println("")

let l2_src = "struct Token {
    kind: string,
    value: string,
    line: int,
    col: int
}

fn make_token(kind, value, line, col) {
    return Token { kind: kind, value: value, line: line, col: col }
}

let t1 = make_token(\"Ident\", \"hello\", 1, 1)
let t2 = make_token(\"IntLit\", \"42\", 1, 7)

println(t1.kind)
println(t1.value)
println(t2.kind)
println(t2.value)

let mut tokens = []
tokens.push(t1)
tokens.push(t2)
println(len(tokens))
println(\"L2_OK\")"

let l2_result = run_selfcomp_test("L2_struct_field", l2_src, "Ident\nhello\nIntLit\n42\n2\nL2_OK")
if l2_result == "pass" {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}
println("")

// ═══════════════════════════════════════════════════════════
//  LEVEL 3: Mini tokenizer — core lexer logic
//  Handles: identifiers, numbers, strings, basic operators
// ═══════════════════════════════════════════════════════════

println("=== LEVEL 3: Mini tokenizer (core lexer logic) ===")
println("")

let l3_src = "struct Token {
    kind: string,
    value: string,
    line: int,
    col: int
}

fn is_keyword(word) {
    if word == \"if\" { return true }
    if word == \"else\" { return true }
    if word == \"fn\" { return true }
    if word == \"let\" { return true }
    if word == \"mut\" { return true }
    if word == \"while\" { return true }
    if word == \"return\" { return true }
    return false
}

fn mini_tokenize(source) {
    let mut tokens = []
    let chars = source.chars()
    let mut pos = 0
    let total = len(chars)

    while pos < total {
        let ch = chars[pos]

        if ch == ' ' || ch == '\\t' || ch == '\\r' || ch == '\\n' {
            pos = pos + 1
        } else if is_alpha(ch) || ch == '_' {
            let mut word = \"\"
            while pos < total && (is_alphanumeric(chars[pos]) || chars[pos] == '_') {
                word = word + to_string(chars[pos])
                pos = pos + 1
            }
            if is_keyword(word) {
                tokens.push(Token { kind: \"Keyword\", value: word, line: 1, col: 0 })
            } else {
                tokens.push(Token { kind: \"Ident\", value: word, line: 1, col: 0 })
            }
        } else if is_digit(ch) {
            let mut num = \"\"
            while pos < total && is_digit(chars[pos]) {
                num = num + to_string(chars[pos])
                pos = pos + 1
            }
            tokens.push(Token { kind: \"IntLit\", value: num, line: 1, col: 0 })
        } else if ch == '(' {
            tokens.push(Token { kind: \"LParen\", value: \"(\", line: 1, col: 0 })
            pos = pos + 1
        } else if ch == ')' {
            tokens.push(Token { kind: \"RParen\", value: \")\", line: 1, col: 0 })
            pos = pos + 1
        } else if ch == '+' {
            tokens.push(Token { kind: \"Plus\", value: \"+\", line: 1, col: 0 })
            pos = pos + 1
        } else if ch == '=' {
            tokens.push(Token { kind: \"Eq\", value: \"=\", line: 1, col: 0 })
            pos = pos + 1
        } else {
            pos = pos + 1
        }
    }
    return tokens
}

let tokens = mini_tokenize(\"let x = 42\")
let mut i = 0
while i < len(tokens) {
    println(tokens[i].kind + \":\" + tokens[i].value)
    i = i + 1
}
println(\"L3_OK\")"

let l3_result = run_selfcomp_test("L3_mini_tokenize", l3_src, "Keyword:let\nIdent:x\nEq:=\nIntLit:42\nL3_OK")
if l3_result == "pass" {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}
println("")

// ═══════════════════════════════════════════════════════════
//  LEVEL 4: Full lexer.hexa — the actual self-compile target
//  Read lexer.hexa, run through pipeline, compile, execute
// ═══════════════════════════════════════════════════════════

// L4/L5 skipped: full lexer self-compile takes >60s via exec() subprocess pipeline
// Enable manually for milestone verification
println("=== LEVEL 4: Full lexer.hexa self-compile — SKIPPED (>30s timeout) ===")
println("=== LEVEL 5: Self-referential — SKIPPED (depends on L4) ===")

println("")
println(to_string(pass_count) + " passed")
if false {
// --- BEGIN SKIPPED L4/L5 ---
println("=== LEVEL 4: Full lexer.hexa self-compile ===")
println("")

let lexer_source = read_file(SELF_DIR + "/lexer.hexa")

// Append a test driver to the lexer
let l4_driver = "
let source = \"let x = 42 + y\"
let tokens = tokenize(source)
let mut i = 0
while i < len(tokens) {
    let t = tokens[i]
    if t.kind != \"Newline\" && t.kind != \"Eof\" {
        println(t.kind + \":\" + t.value)
    }
    i = i + 1
}
println(\"L4_SELFCOMP_OK\")
"

let l4_src = lexer_source + "\n" + l4_driver
let l4_expected = "Let:let\nIdent:x\nEq:=\nIntLit:42\nPlus:+\nIdent:y\nL4_SELFCOMP_OK"

let l4_result = run_selfcomp_test("L4_full_lexer", l4_src, l4_expected)
if l4_result == "pass" {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}
println("")

// ═══════════════════════════════════════════════════════════
//  LEVEL 5: Self-referential — lexer tokenizes itself!
//  lexer.hexa compiled to native, then tokenizes its own source
// ═══════════════════════════════════════════════════════════

if l4_result == "pass" {
    println("=== LEVEL 5: Self-referential (lexer tokenizes itself) ===")
    println("")

    // Append a driver that reads and tokenizes lexer.hexa itself
    let l5_driver = "
let self_source = read_file(\"" + SELF_DIR + "/lexer.hexa\")
let self_tokens = tokenize(self_source)
let mut kw_count = 0
let mut ident_count = 0
let mut i = 0
while i < len(self_tokens) {
    let t = self_tokens[i]
    if t.kind == \"Fn\" || t.kind == \"If\" || t.kind == \"Else\" || t.kind == \"While\" || t.kind == \"Let\" || t.kind == \"Return\" || t.kind == \"Struct\" || t.kind == \"For\" {
        kw_count = kw_count + 1
    }
    if t.kind == \"Ident\" {
        ident_count = ident_count + 1
    }
    i = i + 1
}
println(\"keywords:\" + to_string(kw_count))
println(\"idents:\" + to_string(ident_count))
println(\"total:\" + to_string(len(self_tokens)))
println(\"L5_SELF_REF_OK\")
"

    let l5_src = lexer_source + "\n" + l5_driver

    // For L5, we just check it produces output ending with L5_SELF_REF_OK
    // We don't know exact counts, so check the structure
    total_count = total_count + 1
    println("--- [L5_self_referential] ---")

    let c_file = TMP_DIR + "/L5_self_ref.c"
    let bin_file = TMP_DIR + "/L5_self_ref"
    let driver_file = TMP_DIR + "/L5_self_ref_driver.hexa"
    let src_file = TMP_DIR + "/L5_self_ref.hexa"

    safe_write_file(src_file, l5_src)

    let driver = pipeline_src + "\n" + "let __src = read_file(\"" + src_file + "\")\n" + "let __tokens = tokenize(__src)\n" + "let __ast = parse(__tokens)\n" + "let __c = codegen_c2_full(__ast)\n" + "write_file(\"" + c_file + "\", __c)\n" + "println(\"PIPELINE_OK\")\n"
    safe_write_file(driver_file, driver)

    let p_result = exec(HEXA + " " + driver_file + " 2>&1")
    let mut p_ok = false
    if type_of(p_result) != "error" {
        for line in p_result.split("\n") {
            if line == "PIPELINE_OK" { p_ok = true }
        }
    }

    if p_ok {
        println("  [1/4] Pipeline OK")
        let c_code = read_file(c_file)
        println("  [2/4] C generated: " + to_string(len(c_code)) + " chars")

        let compile_cmd = "clang -O2 -I " + RUNTIME_DIR + " " + c_file + " -o " + bin_file + " -lm 2>&1"
        let compile_result = exec(compile_cmd)

        if file_exists(bin_file) {
            println("  [3/4] Compiled to native")
            let run_result = exec(bin_file + " 2>&1")
            println("  [4/4] Output:")
            println(run_result)
            if type_of(run_result) != "error" {
                let run_lines = run_result.split("\n")
                let last = run_lines[len(run_lines) - 1]
                if last == "L5_SELF_REF_OK" {
                    println("  PASS")
                    pass_count = pass_count + 1
                } else {
                    println("  FAIL: missing L5_SELF_REF_OK")
                    fail_count = fail_count + 1
                }
            } else {
                println("  FAIL (runtime error)")
                fail_count = fail_count + 1
            }
        } else {
            println("  FAIL (clang): " + to_string(compile_result))
            fail_count = fail_count + 1
        }
    } else {
        println("  FAIL (pipeline): " + to_string(p_result))
        fail_count = fail_count + 1
    }
    println("")
}

// --- END SKIPPED L4/L5 ---
}

