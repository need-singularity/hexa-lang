// ═══════════════════════════════════════════════════════════════════
//  test_dpo_variants.hexa — DPO Variants (IPO/KTO/ORPO) 검증
//
//  검증:
//    1. sigmoid 범위 [0, 1]
//    2. log_sigmoid 음수
//    3. IPO loss 대칭
//    4. IPO loss 최소점
//    5. KTO chosen loss
//    6. KTO rejected loss
//    7. ORPO log-odds
//    8. ORPO loss 양수
//    9. combined dispatch
//   10. DPO vs IPO 비교
//   11. preference accuracy
//   12. reward margin
//
//  실행: ./hexa self/test_dpo_variants.hexa
// ═══════════════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx(a, b, eps) { return fabs(a - b) < eps }

// ── inline helpers ──────────────────────────────────────────────

fn dv_exp(x) {
    let mut v = x
    if v > 20.0 { v = 20.0 }
    if v < -20.0 { v = -20.0 }
    let mut result = 1.0
    let mut term = 1.0
    let mut i = 1

    while i < 30 {
        term = term * v / to_float(i)
        result = result + term
    }
    if result < 0.0 { return 0.0 }
    return result
}

fn dv_log(x) {
    if x <= 0.0 { return -30.0 }
    let mut v = x
    let mut count = 0
    while v > 2.0 {
        v = v / 2.718281828
        count = count + 1
    }
    while v < 0.5 {
        v = v * 2.718281828
        count = count - 1
    }
    let d = v - 1.0
    let ln_v = d - d * d / 2.0 + d * d * d / 3.0 - d * d * d * d / 4.0
    return to_float(count) + ln_v
}

fn dv_zeros(n) {
    let mut v = []
    let mut _i = 0

    while _i < n { v = v + [0.0] }
    return v
}

fn dv_sigmoid(x) {
    if x > 20.0 { return 1.0 }
    if x < -20.0 { return 0.0 }
    return 1.0 / (1.0 + dv_exp(0.0 - x))
}

fn dv_log_sigmoid(x) {
    let neg_x = 0.0 - x
    if neg_x > 20.0 { return 0.0 - neg_x }
    if neg_x < -20.0 { return 0.0 }
    return 0.0 - dv_log(1.0 + dv_exp(neg_x))
}

fn dv_ipo_loss(log_ratio_w, log_ratio_l, tau) {
    let diff = log_ratio_w - log_ratio_l
    let target = 1.0 / (2.0 * tau)
    let gap = diff - target
    return gap * gap
}

fn dv_kto_loss_chosen(log_ratio, beta, kl_ref) {
    let x = beta * (log_ratio - kl_ref)
    return 1.0 - dv_sigmoid(x)
}

fn dv_kto_loss_rejected(log_ratio, beta, kl_ref) {
    let x = beta * (kl_ref - log_ratio)
    return 1.0 - dv_sigmoid(x)
}

fn dv_kto_loss(log_ratio_w, log_ratio_l, beta) {
    let kl_ref = (fabs(log_ratio_w) + fabs(log_ratio_l)) / 2.0
    let l_w = dv_kto_loss_chosen(log_ratio_w, beta, kl_ref)
    let l_l = dv_kto_loss_rejected(log_ratio_l, beta, kl_ref)
    return (l_w + l_l) / 2.0
}

fn dv_log_odds(log_p) {
    let p = dv_exp(log_p)
    let one_minus_p = 1.0 - p
    if one_minus_p < 1.0e-10 { return 30.0 }
    return log_p - dv_log(one_minus_p)
}

fn dv_orpo_loss(log_p_w, log_p_l, beta) {
    let log_odds_w = dv_log_odds(log_p_w)
    let log_odds_l = dv_log_odds(log_p_l)
    let log_odds_ratio = log_odds_w - log_odds_l
    let nll = 0.0 - log_p_w
    let orpo_penalty = 0.0 - dv_log_sigmoid(log_odds_ratio)
    return nll + beta * orpo_penalty
}

fn dv_combined_loss(log_ratio_w, log_ratio_l, log_p_w, log_p_l, method, beta) {
    if method == 0 {
        let tau = 1.0 / beta
        return dv_ipo_loss(log_ratio_w, log_ratio_l, tau)
    }
    if method == 1 { return dv_kto_loss(log_ratio_w, log_ratio_l, beta) }
    if method == 2 { return dv_orpo_loss(log_p_w, log_p_l, beta) }
    return 0.0
}

fn dv_dpo_loss(log_ratio_w, log_ratio_l, beta) {
    let logit = beta * (log_ratio_w - log_ratio_l)
    return 0.0 - dv_log_sigmoid(logit)
}

fn dv_ipo_grad_w(log_ratio_w, log_ratio_l, tau) {
    let diff = log_ratio_w - log_ratio_l
    let target = 1.0 / (2.0 * tau)
    return 2.0 * (diff - target)
}

fn dv_reward_margin(log_ratio_w, log_ratio_l, beta) {
    return beta * (log_ratio_w - log_ratio_l)
}

fn dv_preference_accuracy(log_ratio_w, log_ratio_l) {
    if log_ratio_w > log_ratio_l { return 1.0 }
    return 0.0
}

// ═══════════════════════════════════════════════════════════════════
//  Tests
// ═══════════════════════════════════════════════════════════════════

println("=== DPO Variants Tests ===")

// 1. Sigmoid range
check("sigmoid_pos", dv_sigmoid(5.0) > 0.99)
check("sigmoid_neg", dv_sigmoid(-5.0) < 0.01)
check("sigmoid_zero", approx(dv_sigmoid(0.0), 0.5, 0.01))

// 2. Log-sigmoid is negative
let ls = dv_log_sigmoid(1.0)
check("log_sigmoid_neg", ls < 0.0)
let ls0 = dv_log_sigmoid(0.0)
check("log_sigmoid_half", approx(ls0, dv_log(0.5), 0.1))

// 3. IPO loss is zero at target
let tau = 0.5
let target = 1.0 / (2.0 * tau)
let ipo0 = dv_ipo_loss(target + 0.0, 0.0, tau)
check("ipo_zero_at_target", approx(ipo0, 0.0, 0.001))

// 4. IPO loss symmetric around target
let ipo_p = dv_ipo_loss(target + 0.5, 0.0, tau)
let ipo_m = dv_ipo_loss(target - 0.5, 0.0, tau)
check("ipo_symmetric", approx(ipo_p, ipo_m, 0.001))

// 5. KTO chosen: large positive log-ratio -> small loss
let kto_w = dv_kto_loss_chosen(2.0, 0.1, 0.5)
check("kto_chosen_good", kto_w < 0.5)

// 6. KTO rejected: large positive log-ratio -> large loss
let kto_l = dv_kto_loss_rejected(2.0, 0.1, 0.5)
check("kto_rejected_bad", kto_l > 0.5)

// 7. ORPO log-odds
let lo = dv_log_odds(-1.0)
check("log_odds_neg_input", lo < 0.0)

// 8. ORPO loss is positive
let orpo = dv_orpo_loss(-0.5, -1.0, 0.1)
check("orpo_positive", orpo > 0.0)

// 9. Combined dispatch — IPO
let c0 = dv_combined_loss(1.0, 0.0, -0.5, -1.0, 0, 0.1)
check("combined_ipo", c0 > 0.0)

// 10. Combined dispatch — KTO
let c1 = dv_combined_loss(1.0, 0.0, -0.5, -1.0, 1, 0.1)
check("combined_kto", c1 > 0.0)

// 11. Combined dispatch — ORPO
let c2 = dv_combined_loss(1.0, 0.0, -0.5, -1.0, 2, 0.1)
check("combined_orpo", c2 > 0.0)

// 12. DPO loss positive when chosen preferred
let dpo = dv_dpo_loss(1.0, -1.0, 0.1)
check("dpo_chosen_preferred", dpo > 0.0)

// 13. IPO gradient sign
let grad = dv_ipo_grad_w(2.0, 0.0, 0.5)
check("ipo_grad_pos", grad > 0.0)

// 14. Reward margin
let margin = dv_reward_margin(1.0, -1.0, 0.5)
check("margin_positive", margin > 0.0)

// 15. Preference accuracy
check("acc_correct", approx(dv_preference_accuracy(1.0, -1.0), 1.0, 0.001))
check("acc_wrong", approx(dv_preference_accuracy(-1.0, 1.0), 0.0, 0.001))

// ── summary ──────────────────────────────────────────────────────
println("")
println("DPO Variants: " + str(pass_count) + " passed, " + str(fail_count) + " failed")
