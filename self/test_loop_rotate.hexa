// =====================================================================
//  test_loop_rotate.hexa -- ROI #42 Loop Rotation pass verification
//
//  Verifies that while-loops can be transformed to do-while form
//  (guard + body + loop) to reduce one branch per iteration.
//
//  Tests (>=12):
//    1. simple counting loop produces correct result after rotation
//    2. sum accumulation loop correctness
//    3. nested loop correctness
//    4. while with break-like early return
//    5. while with zero iterations (guard prevents entry)
//    6. factorial via while loop
//    7. power computation loop
//    8. string building loop
//    9. countdown loop
//   10. array sum loop
//   11. multiple sequential loops
//   12. loop with conditional body
//
//  Run: ./hexa test self/test_loop_rotate.hexa
// =====================================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn check_eq(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("=====================================================")
println("  Loop Rotation (ROI #42) Tests")
println("=====================================================")
println("")

// -- 1. Simple counting loop --
println("--- simple count ---")
fn count_to(n) {
    let mut i = 0
    let mut count = 0
    while i < n {
        count = count + 1
        i = i + 1
    }
    return count
}
check_eq("count_to(10)", count_to(10), 10)
check_eq("count_to(0)", count_to(0), 0)
check_eq("count_to(1)", count_to(1), 1)

// -- 2. Sum accumulation --
println("")
println("--- sum accumulation ---")
fn sum_to(n) {
    let mut i = 1
    let mut sum = 0
    while i <= n {
        sum = sum + i
        i = i + 1
    }
    return sum
}
check_eq("sum_to(10)", sum_to(10), 55)
check_eq("sum_to(100)", sum_to(100), 5050)
check_eq("sum_to(0)", sum_to(0), 0)

// -- 3. Nested loops --
println("")
println("--- nested loops ---")
fn nested_count(rows, cols) {
    let mut total = 0
    let mut r = 0
    while r < rows {
        let mut c = 0
        while c < cols {
            total = total + 1
            c = c + 1
        }
        r = r + 1
    }
    return total
}
check_eq("nested 3x4", nested_count(3, 4), 12)
check_eq("nested 5x5", nested_count(5, 5), 25)
check_eq("nested 0x10", nested_count(0, 10), 0)

// -- 4. Early return from loop body context --
println("")
println("--- early return ---")
fn find_first_ge(arr, target) {
    let mut i = 0
    while i < len(arr) {
        if arr[i] >= target { return arr[i] }
        i = i + 1
    }
    return -1
}
check_eq("find_first_ge [1,5,3,7] >=4", find_first_ge([1, 5, 3, 7], 4), 5)
check_eq("find_first_ge [1,2,3] >=10", find_first_ge([1, 2, 3], 10), -1)

// -- 5. Zero iterations --
println("")
println("--- zero iterations ---")
fn zero_iter_sum() {
    let mut sum = 0
    let mut i = 10
    while i < 5 {
        sum = sum + i
        i = i + 1
    }
    return sum
}
check_eq("zero iter sum", zero_iter_sum(), 0)

// -- 6. Factorial --
println("")
println("--- factorial ---")
fn fact_loop(n) {
    let mut result = 1
    let mut i = 2
    while i <= n {
        result = result * i
        i = i + 1
    }
    return result
}
check_eq("fact(1)", fact_loop(1), 1)
check_eq("fact(5)", fact_loop(5), 120)
check_eq("fact(10)", fact_loop(10), 3628800)

// -- 7. Power computation --
println("")
println("--- power ---")
fn power(base, exp) {
    let mut result = 1
    let mut i = 0
    while i < exp {
        result = result * base
        i = i + 1
    }
    return result
}
check_eq("2^10", power(2, 10), 1024)
check_eq("3^5", power(3, 5), 243)
check_eq("5^0", power(5, 0), 1)

// -- 8. String building loop --
println("")
println("--- string building ---")
fn repeat_str(s, n) {
    let mut result = ""
    let mut i = 0
    while i < n {
        result = result + s
        i = i + 1
    }
    return result
}
check_eq("repeat 'ab' 3", repeat_str("ab", 3), "ababab")
check_eq("repeat 'x' 0", repeat_str("x", 0), "")

// -- 9. Countdown loop --
println("")
println("--- countdown ---")
fn countdown_sum(start) {
    let mut sum = 0
    let mut i = start
    while i > 0 {
        sum = sum + i
        i = i - 1
    }
    return sum
}
check_eq("countdown 5", countdown_sum(5), 15)
check_eq("countdown 10", countdown_sum(10), 55)

// -- 10. Array sum --
println("")
println("--- array sum ---")
fn array_sum(arr) {
    let mut sum = 0
    let mut i = 0
    while i < len(arr) {
        sum = sum + arr[i]
        i = i + 1
    }
    return sum
}
check_eq("array_sum [1,2,3,4,5]", array_sum([1, 2, 3, 4, 5]), 15)
check_eq("array_sum []", array_sum([]), 0)

// -- 11. Multiple sequential loops --
println("")
println("--- sequential loops ---")
fn multi_loop(n) {
    let mut a = 0
    let mut i = 0
    while i < n {
        a = a + 1
        i = i + 1
    }
    let mut b = 0
    let mut j = 0
    while j < n {
        b = b + 2
        j = j + 1
    }
    return a + b
}
check_eq("multi_loop(5)", multi_loop(5), 15)

// -- 12. Loop with conditional body --
println("")
println("--- conditional body ---")
fn count_evens(n) {
    let mut count = 0
    let mut i = 0
    while i < n {
        if i % 2 == 0 {
            count = count + 1
        }
        i = i + 1
    }
    return count
}
check_eq("count_evens(10)", count_evens(10), 5)
check_eq("count_evens(7)", count_evens(7), 4)

// -- Summary --
println("")
println("=====================================================")
println("  Loop Rotation: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("=====================================================")
assert(fail_count == 0)
