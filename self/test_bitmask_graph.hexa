// ── Test 12: BFS shortest path distance ──
println("")
println("--- BFS shortest path ---")
fn bfs_dist(adj_from, adj_to, n, start, target) {
    let mut vis_mask = bit(start)
    let mut queue = [start]
    let mut dist = [0, 0, 0, 0, 0, 0, 0, 0]
    while len(queue) > 0 {
        let cur = queue[0]
        let mut new_queue = []
        let mut qi = 1
        while qi < len(queue) {
            new_queue.push(queue[qi])
            qi = qi + 1
        }
        queue = new_queue
        let mut ei = 0
        while ei < len(adj_from) {
            if adj_from[ei] == cur {
                let nb = adj_to[ei]
                if (vis_mask & bit(nb)) == 0 {
                    vis_mask = bitor(vis_mask, bit(nb))
                    dist[nb] = dist[cur] + 1
                    queue.push(nb)
                }
            }
            ei = ei + 1
        }
    }
    return dist[target]
}
check_eq("BFS dist 0->3", bfs_dist(g1_from, g1_to, g1_n, 0, 3), 2)
check_eq("BFS dist 0->1", bfs_dist(g1_from, g1_to, g1_n, 0, 1), 1)

// ── Test 13: DFS back edge detection ──
println("")
println("--- back edge ---")
fn has_back_edge(adj_from, adj_to, n, start) {
    let mut vis_mask = 0
    let mut stack = [start]
    let mut on_stack_mask = 0
    let mut found_back = false
    while len(stack) > 0 {
        let top = stack[len(stack) - 1]
        let mut new_stack = []
        let mut si = 0
        while si < len(stack) - 1 {
            new_stack.push(stack[si])
            si = si + 1
        }
        stack = new_stack
        if top < 0 {
            // sentinel: clear on_stack for node (-top - 1)
            let node = -top - 1
            on_stack_mask = on_stack_mask - bit(node)
        } else if (vis_mask & bit(top)) == 0 {
            vis_mask = bitor(vis_mask, bit(top))
            on_stack_mask = bitor(on_stack_mask, bit(top))
            // push sentinel to clear on_stack after children done
            stack.push(-top - 1)
            let mut ei = 0
            while ei < len(adj_from) {
                if adj_from[ei] == top {
                    let nb = adj_to[ei]
                    if (vis_mask & bit(nb)) != 0 {
                        if (on_stack_mask & bit(nb)) != 0 {
                            found_back = true
                        }
                    } else {
                        stack.push(nb)
                    }
                }
                ei = ei + 1
            }
        }
    }
    return found_back
}
check("back edge in cycle", has_back_edge(gc_from, gc_to, 4, 0))
check("no back edge in DAG", has_back_edge(g1_from, g1_to, g1_n, 0) == false)

