// ── Test 17: Bitmask clear via XOR ──
println("")
println("--- bitmask clear ---")
let cmask = 7
let cleared = cmask ^ bit(1)
check_eq("clear bit 1 via XOR", cleared, 5)
check("bit 0 still set", (cleared & 1) != 0)
check("bit 1 cleared", (cleared & 2) == 0)

// ── Test 18: popcount ──
println("")
println("--- popcount ---")
check_eq("popcount(0)", popcount(0), 0)
check_eq("popcount(1)", popcount(1), 1)
check_eq("popcount(7)", popcount(7), 3)
check_eq("popcount(255)", popcount(255), 8)
check_eq("popcount(15)", popcount(15), 4)

// ── Test 19: Bitmask union + intersection ──
println("")
println("--- bitmask union/intersection ---")
let a_set = bitor(bit(0), bit(2))
let b_set = bitor(bit(1), bit(2))
let union_ab = bitor(a_set, b_set)
check_eq("union popcount", popcount(union_ab), 3)
let inter_ab = a_set & b_set
check_eq("intersection popcount", popcount(inter_ab), 1)
check("intersection has bit 2", (inter_ab & bit(2)) != 0)

