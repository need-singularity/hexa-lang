// ── Test 22: BFS bitmask popcount check ──
println("")
println("--- bitmask popcount check ---")
fn bfs_count_visited(adj_from, adj_to, start) {
    let mut vis_mask = bit(start)
    let mut queue = [start]
    while len(queue) > 0 {
        let cur = queue[0]
        let mut new_queue = []
        let mut qi = 1
        while qi < len(queue) {
            new_queue.push(queue[qi])
            qi = qi + 1
        }
        queue = new_queue
        let mut ei = 0
        while ei < len(adj_from) {
            if adj_from[ei] == cur {
                let nb = adj_to[ei]
                if (vis_mask & bit(nb)) == 0 {
                    vis_mask = bitor(vis_mask, bit(nb))
                    queue.push(nb)
                }
            }
            ei = ei + 1
        }
    }
    return popcount(vis_mask)
}
check_eq("BFS popcount diamond", bfs_count_visited(g1_from, g1_to, 0), 4)
check_eq("BFS popcount 8-tree", bfs_count_visited(g8_from, g8_to, 0), 8)

// ── Test 23: DFS bitmask popcount check ──
println("")
println("--- DFS bitmask popcount ---")
fn dfs_count_visited(adj_from, adj_to, start) {
    let mut vis_mask = 0
    let mut stack = [start]
    while len(stack) > 0 {
        let top = stack[len(stack) - 1]
        let mut new_stack = []
        let mut si = 0
        while si < len(stack) - 1 {
            new_stack.push(stack[si])
            si = si + 1
        }
        stack = new_stack
        if (vis_mask & bit(top)) == 0 {
            vis_mask = bitor(vis_mask, bit(top))
            let mut ei = len(adj_from) - 1
            while ei >= 0 {
                if adj_from[ei] == top {
                    let nb = adj_to[ei]
                    if (vis_mask & bit(nb)) == 0 {
                        stack.push(nb)
                    }
                }
                ei = ei - 1
            }
        }
    }
    return popcount(vis_mask)
}
check_eq("DFS popcount diamond", dfs_count_visited(g1_from, g1_to, 0), 4)
check_eq("DFS popcount cycle", dfs_count_visited(gc_from, gc_to, 0), 4)

// ── Test 24: Bitmask boundary bits ──
println("")
println("--- boundary bits ---")
let mut bnd = bit(0)
check("bit 0 boundary", (bnd & 1) != 0)
let mut hi = bit(30)
check("bit 30 set", (hi & bit(30)) != 0)
check("bit 29 not set", (hi & bit(29)) == 0)

// ── Test 25: Connected components via bitmask BFS ──
println("")
println("--- connected components ---")
let gu_from = [0, 1, 2, 3]
let gu_to   = [1, 0, 3, 2]
fn count_components(adj_from, adj_to, n) {
    let mut global_vis = 0
    let mut comps = 0
    let mut v = 0
    while v < n {
        if (global_vis & bit(v)) == 0 {
            comps = comps + 1
            let mut vis_mask = bit(v)
            let mut queue = [v]
            while len(queue) > 0 {
                let cur = queue[0]
                let mut new_queue = []
                let mut qi = 1
                while qi < len(queue) {
                    new_queue.push(queue[qi])
                    qi = qi + 1
                }
                queue = new_queue
                let mut ei = 0
                while ei < len(adj_from) {
                    if adj_from[ei] == cur {
                        let nb = adj_to[ei]
                        if (vis_mask & bit(nb)) == 0 {
                            vis_mask = bitor(vis_mask, bit(nb))
                            queue.push(nb)
                        }
                    }
                    ei = ei + 1
                }
            }
            global_vis = bitor(global_vis, vis_mask)
        }
        v = v + 1
    }
    return comps
}
check_eq("2 components", count_components(gu_from, gu_to, 4), 2)
check_eq("1 component (K4)", count_components(gk_from, gk_to, 4), 1)

// ── Test 26: BFS level ordering ──
println("")
println("--- BFS level ordering ---")
let bfs_order = bfs_bitmask(g1_from, g1_to, g1_n, 0)
check_eq("BFS level: node 0 first", bfs_order[0], 0)
check_eq("BFS level: node 3 last", bfs_order[3], 3)

// ── Test 27: Bitmask XOR (symmetric difference) ──
println("")
println("--- bitmask XOR ---")
let x_set = bitor(bitor(bit(0), bit(1)), bit(3))
let y_set = bitor(bitor(bit(1), bit(2)), bit(3))
let xor_xy = x_set ^ y_set
check_eq("XOR popcount", popcount(xor_xy), 2)
check("XOR has bit 0", (xor_xy & bit(0)) != 0)
check("XOR has bit 2", (xor_xy & bit(2)) != 0)
check("XOR no bit 1", (xor_xy & bit(1)) == 0)

println("")
println("=====================================================")
println("  BFS/DFS Bitmask: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("=====================================================")
