let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn check_eq(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("=====================================================")
println("  BFS/DFS -> Bitmask Graph (ROI #60) Tests")
println("=====================================================")
println("")

// ── Bitmask helper functions ──
// HEXA does not have << or | operators, so we use arithmetic equivalents.

// bit(n) = 1 << n = 2^n
fn bit(n) {
    let mut r = 1
    let mut i = 0
    while i < n {
        r = r * 2
        i = i + 1
    }
    return r
}

// bitor(a, b) = a | b
fn bitor(a, b) {
    return a + b - (a & b)
}

// shr(x, n) = x >> n
fn shr(x, n) {
    return x / bit(n)
}

// popcount: count set bits
fn popcount(x) {
    let mut n = x
    let mut c = 0
    while n > 0 {
        c = c + (n & 1)
        n = shr(n, 1)
    }
    return c
}

// ── Array to string helper ──
fn arr_to_str(arr) {
    let mut s = "["
    let mut i = 0
    while i < len(arr) {
        if i > 0 { s = s + "," }
        s = s + to_string(arr[i])
        i = i + 1
    }
    return s + "]"
}

// ── Graph 1: 4-node diamond ──
//   0 -> 1, 0 -> 2, 1 -> 3, 2 -> 3
let g1_from = [0, 0, 1, 2]
let g1_to   = [1, 2, 3, 3]
let g1_n = 4

// ── BFS using array-based visited ──
fn bfs_array(adj_from, adj_to, n, start) {
    let mut visited = [false, false, false, false, false, false, false, false]
    let mut queue = [start]
    visited[start] = true
    let mut order = []
    while len(queue) > 0 {
        let cur = queue[0]
        let mut new_queue = []
        let mut qi = 1
        while qi < len(queue) {
            new_queue.push(queue[qi])
            qi = qi + 1
        }
        queue = new_queue
        order.push(cur)
        let mut ei = 0
        while ei < len(adj_from) {
            if adj_from[ei] == cur {
                let nb = adj_to[ei]
                if visited[nb] == false {
                    visited[nb] = true
                    queue.push(nb)
                }
            }
            ei = ei + 1
        }
    }
    return order
}

// ── BFS using bitmask visited ──
fn bfs_bitmask(adj_from, adj_to, n, start) {
    let mut vis_mask = bit(start)
    let mut queue = [start]
    let mut order = []
    while len(queue) > 0 {
        let cur = queue[0]
        let mut new_queue = []
        let mut qi = 1
        while qi < len(queue) {
            new_queue.push(queue[qi])
            qi = qi + 1
        }
        queue = new_queue
        order.push(cur)
        let mut ei = 0
        while ei < len(adj_from) {
            if adj_from[ei] == cur {
                let nb = adj_to[ei]
                if (vis_mask & bit(nb)) == 0 {
                    vis_mask = bitor(vis_mask, bit(nb))
                    queue.push(nb)
                }
            }
            ei = ei + 1
        }
    }
    return order
}

// ── DFS using array-based visited ──
fn dfs_array(adj_from, adj_to, n, start) {
    let mut visited = [false, false, false, false, false, false, false, false]
    let mut stack = [start]
    let mut order = []
    while len(stack) > 0 {
        let top = stack[len(stack) - 1]
        let mut new_stack = []
        let mut si = 0
        while si < len(stack) - 1 {
            new_stack.push(stack[si])
            si = si + 1
        }
        stack = new_stack
        if visited[top] == false {
            visited[top] = true
            order.push(top)
            let mut ei = len(adj_from) - 1
            while ei >= 0 {
                if adj_from[ei] == top {
                    let nb = adj_to[ei]
                    if visited[nb] == false {
                        stack.push(nb)
                    }
                }
                ei = ei - 1
            }
        }
    }
    return order
}

// ── DFS using bitmask visited ──
fn dfs_bitmask(adj_from, adj_to, n, start) {
    let mut vis_mask = 0
    let mut stack = [start]
    let mut order = []
    while len(stack) > 0 {
        let top = stack[len(stack) - 1]
        let mut new_stack = []
        let mut si = 0
        while si < len(stack) - 1 {
            new_stack.push(stack[si])
            si = si + 1
        }
        stack = new_stack
        if (vis_mask & bit(top)) == 0 {
            vis_mask = bitor(vis_mask, bit(top))
            order.push(top)
            let mut ei = len(adj_from) - 1
            while ei >= 0 {
                if adj_from[ei] == top {
                    let nb = adj_to[ei]
                    if (vis_mask & bit(nb)) == 0 {
                        stack.push(nb)
                    }
                }
                ei = ei - 1
            }
        }
    }
    return order
}

// ── Test 1: BFS array on 4-node diamond ──
println("--- BFS array ---")
let bfs1_arr = bfs_array(g1_from, g1_to, g1_n, 0)
check_eq("BFS array 4-node len", len(bfs1_arr), 4)
check_eq("BFS array 4-node start", bfs1_arr[0], 0)

// ── Test 2: BFS bitmask on 4-node diamond ──
