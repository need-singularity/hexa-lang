// self/edict_cli.hexa — hexa-native edict CLI
// usage:
//   hexa self/edict_cli.hexa               — 6 edict 요약 표
//   hexa self/edict_cli.hexa list          — 동일 (명시적)
//   hexa self/edict_cli.hexa show <id>     — 상세
//   hexa self/edict_cli.hexa check         — 전체 위반 리포트 (read-only)
//   hexa self/edict_cli.hexa check <file>  — 특정 파일만
//   hexa self/edict_cli.hexa install       — pre-commit 스탠자 설치 (safety net)
//
// 목적: CLAUDE.md 의존 축소. hexa 바이너리 자체가 edict 공표 + 검사 + 설치.
// SSOT: shared/hexa-lang/edict.json (인간+기계 공용 선언)

let _raw_args = args()
let mut cli_args = []
let mut _ai = 2
while _ai < len(_raw_args) {
    cli_args = cli_args.push(_raw_args[_ai])
    _ai = _ai + 1
}

// ─── 6 edict (edict.json 과 1:1) ─────────────────────────────
fn edict_rows() {
    return [
        ["1", "ai-native 24 @attr",              "warn",     "git-hook",    "AST scan — hot fn attr 누락 경고"],
        ["2", "ai-native 알고리즘",               "deferred", "-",           "semantic — 2026-10 까지 연기"],
        ["3", "@attr 네이밍",                    "unwired",  "git-hook",    "_naming 규칙 — check_naming_all"],
        ["4", "폴더명 (F4 generic_dir)",          "live",     "git-hook",    "utils/helpers/common/lib 차단"],
        ["5", "트리구조 (F5 loner + F6 parent)",  "unwired",  "git-hook",    "F5/F6 scan block 승격"],
        ["6", "파일명 (F1 _v + F2 stage + F3 _)", "live",     "git-hook",    "_v\\d+ / stage|phase / _old|_bak"]
    ]
}

fn _status_mark(s: string) -> string {
    if s == "live"     { return "✅" }
    if s == "warn"     { return "⚠" }
    if s == "unwired"  { return "❌" }
    if s == "deferred" { return "⏸" }
    return "?"
}

fn print_list() {
    println("── hexa-lang edict (6) ──────────────────────────")
    println("# | status | level     | name")
    println("──|────────|───────────|─────────────────────────────────────")
    let rows = edict_rows()
    for r in rows {
        let mark = _status_mark(r[2])
        let pad_status = r[2]
        let mut ps = pad_status
        while len(ps) < 8 { ps = ps + " " }
        let mut pl = r[3]
        while len(pl) < 9 { pl = pl + " " }
        println(r[0] + " | " + mark + " " + ps + "| " + pl + " | " + r[1])
    }
    println("")
    println("SSOT : shared/hexa-lang/edict.json")
    println("상세 : hexa self/edict_cli.hexa show <id>")
    println("검사 : hexa self/edict_cli.hexa check")
    println("설치 : hexa self/edict_cli.hexa install")
    println("")
    println("rollup : live 2 / warn 1 / unwired 2 / deferred 1")
    println("원칙   : low level 강제 — 새 세션 인지 없이도 위반 불가")
}

fn print_show(id: string) {
    let rows = edict_rows()
    for r in rows {
        if r[0] == id {
            println("── edict #" + id + " ──")
            println("  이름     : " + r[1])
            println("  상태     : " + r[2] + " " + _status_mark(r[2]))
            println("  레벨     : " + r[3])
            println("  동작     : " + r[4])
            println("")
            println("  SSOT     : shared/hexa-lang/edict.json")
            return
        }
    }
    eprintln("error: edict id 없음 — " + id)
    exit(1)
}

// ─── check: 기존 도구 다 돌림 (read-only) ─────────────────────
fn run_check(target: string) {
    let mut pwd = env("PWD")
    if pwd == "" { pwd = to_string(exec("pwd")).trim() }

    println("── edict check ─────────────────────────────────")
    let mut violations = 0

    // Rule 3 — @attr naming (check_naming_all 호출 시 위반 출력)
    println("")
    println("[3] @attr 네이밍 — _naming 규칙 검사")
    let naming_out = to_string(exec("cd '" + pwd + "' && hexa self/attrs/_registry.hexa 2>&1 | grep -E 'viol|fail|error' || echo '  (pass)'"))
    println(naming_out.trim())

    // Rule 4/5/6 — ai_native_scan
    println("")
    println("[4/5/6] 폴더/트리/파일명 — ai_native_scan")
    let scan_exists = to_string(exec("cd '" + pwd + "' && test -f scripts/ai_native_scan.hexa && echo y || echo n")).trim()
    if scan_exists == "y" {
        let scan_out = to_string(exec("cd '" + pwd + "' && hexa scripts/ai_native_scan.hexa 2>&1 | tail -20"))
        println(scan_out.trim())
    } else {
        println("  (skip — scripts/ai_native_scan.hexa 없음)")
    }

    // Rule 1 — ai-native 24 @attr (stub)
    println("")
    println("[1] ai-native 24 @attr — warn-only (scan 미구현)")

    println("")
    println("── 종료 ────────────────────────────────────────")
    if target != "" {
        println("target: " + target)
    }
}

// ─── install: pre-commit 스탠자 설치 ─────────────────────────
fn run_install() {
    let mut pwd = env("PWD")
    if pwd == "" { pwd = to_string(exec("pwd")).trim() }
    let hook_path = pwd + "/.git/hooks/pre-commit"

    let exists = to_string(exec("test -f '" + hook_path + "' && echo y || echo n")).trim()
    if exists != "y" {
        eprintln("error: " + hook_path + " 없음 — git repo 아님?")
        exit(1)
    }

    // 이미 edict 스탠자 있는지 검사
    let marker = to_string(exec("grep -c '@edict-stanza' '" + hook_path + "' 2>/dev/null || echo 0")).trim()
    if marker != "0" {
        println("already installed — '" + hook_path + "' 에 @edict-stanza 마커 존재")
        println("재설치 하려면 해당 블록 수동 삭제 후 재실행")
        exit(0)
    }

    // 3개 스탠자 append
    let stanza = "\n" +
        "# @edict-stanza — generated by self/edict_cli.hexa install (DO NOT EDIT)\n" +
        "# ── edict #3: @attr 네이밍 ────────────────────\n" +
        "EDICT_STAGED_HEXA=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null | grep '\\.hexa$' || true)\n" +
        "if [ -n \"$EDICT_STAGED_HEXA\" ] && [ -x \"./hexa\" ]; then\n" +
        "    EDICT_OUT=$(./hexa self/attrs/_registry.hexa 2>&1 | grep -E 'violation|fail' || true)\n" +
        "    if [ -n \"$EDICT_OUT\" ]; then\n" +
        "        echo \"🚫 edict#3 @attr 네이밍 위반\" >&2\n" +
        "        echo \"$EDICT_OUT\" >&2\n" +
        "        exit 1\n" +
        "    fi\n" +
        "fi\n" +
        "\n" +
        "# ── edict #5: 트리구조 (F5/F6) ─────────────────\n" +
        "if [ -x \"./hexa\" ] && [ -f \"scripts/ai_native_scan.hexa\" ]; then\n" +
        "    SCAN_F5F6=$(./hexa scripts/ai_native_scan.hexa 2>&1 | grep -E '^(F5|F6)' || true)\n" +
        "    if [ -n \"$SCAN_F5F6\" ]; then\n" +
        "        echo \"🚫 edict#5 트리구조 위반 (F5 loner / F6 parent-child)\" >&2\n" +
        "        echo \"$SCAN_F5F6\" >&2\n" +
        "        exit 1\n" +
        "    fi\n" +
        "fi\n" +
        "\n" +
        "# ── edict #1: ai-native 24 @attr (warn-only) ──\n" +
        "# (현 단계 warn 만 — block 승격은 Tier 2/3 semantic 분석 후)\n" +
        "# @edict-stanza-end\n"

    try {
        let existing = to_string(read_file(hook_path))
        write_file(hook_path, existing + stanza)
        exec("chmod +x '" + hook_path + "'")
        println("✅ installed — " + hook_path)
        println("   3 stanzas: edict#3 (attr naming), edict#5 (F5/F6), edict#1 (warn stub)")
        println("   제거: @edict-stanza ~ @edict-stanza-end 블록 수동 삭제")
    } catch e {
        eprintln("error: 쓰기 실패 " + hook_path)
        exit(1)
    }
}

// ─── dispatch ────────────────────────────────────────────────
if len(cli_args) == 0 {
    print_list()
    exit(0)
}

let sub = cli_args[0]

if sub == "list" {
    print_list()
    exit(0)
}

if sub == "show" {
    if len(cli_args) < 2 { eprintln("usage: show <id>"); exit(1) }
    print_show(cli_args[1])
    exit(0)
}

if sub == "check" {
    let target = if len(cli_args) >= 2 { cli_args[1] } else { "" }
    run_check(target)
    exit(0)
}

if sub == "install" {
    run_install()
    exit(0)
}

eprintln("usage:")
eprintln("  hexa self/edict_cli.hexa [list|show <id>|check [file]|install]")
exit(1)
