// test_map_pure.hexa — comprehensive tests for self/runtime/map_pure.hexa

// -- inlined from self/runtime/map_pure.hexa --
// codegen import not wired for test files

// ═══════════════════════════════════════════════════════════════════
//  self/runtime/map_pure.hexa — map/dict helpers as pure hexa
//
//  Replaces C runtime hexa_map_keys, hexa_map_values,
//  hexa_map_contains_key, hexa_map_remove, and adds higher-order
//  map operations (map_map, map_filter, merge, invert, etc.).
//
//  Uses surface builtins: keys(m), values(m), has_key(m, k), len().
//  Map literals use #{} syntax; access via m[k].
//
//  Public API:
//      map_keys_pure(m)              — array of keys
//      map_values_pure(m)            — array of values
//      map_entries_pure(m)           — array of [key, value] pairs
//      map_has_key_pure(m, k)        — bool
//      map_size_pure(m)              — count of entries
//      map_get_or_pure(m, k, def)    — value at k, or default
//      map_merge_pure(m1, m2)        — merged map (m2 wins on conflict)
//      map_map_pure(m, f)            — transform values via f(k, v)
//      map_filter_pure(m, pred)      — filter entries via pred(k, v)
//      map_from_entries_pure(entries) — build map from [k, v] pairs
//      map_invert_pure(m)            — swap keys and values
//      map_map_values_pure(m, f)     — transform values via f(v)
//      map_filter_keys_pure(m, pred) — filter by key predicate
//      map_filter_values_pure(m, pred) — filter by value predicate
//      map_any_pure(m, pred)         — any entry satisfies pred(k, v)
//      map_all_pure(m, pred)         — all entries satisfy pred(k, v)
//      map_count_pure(m, pred)       — count entries satisfying pred(k, v)
//      map_find_key_pure(m, pred)    — first key where pred(k, v) is true
//      map_fold_pure(m, init, f)     — fold over entries via f(acc, k, v)
//      map_select_keys_pure(m, ks)   — sub-map with only given keys
//      map_remove_keys_pure(m, ks)   — sub-map without given keys
//      map_update_pure(m, k, f, def) — update value at k via f(old), or set def
//      map_zip_pure(ks, vs)          — build map from parallel key/value arrays
//      map_group_by_pure(arr, f)     — group array elements by f(elem) -> key
//      map_eq_pure(a, b)             — structural equality
// ═══════════════════════════════════════════════════════════════════

// ── keys / values / entries ─────────────────────────────────────

@pure
pub fn map_keys_pure(m) {
    return keys(m)
}

@pure
pub fn map_values_pure(m) {
    let ks = keys(m)
    let mut out = []
    let n = len(ks)
    let mut i = 0
    while i < n {
        out.push(m[ks[i]])
        i = i + 1
    }
    return out
}

@pure
pub fn map_entries_pure(m) {
    let ks = keys(m)
    let mut out = []
    let n = len(ks)
    let mut i = 0
    while i < n {
        let k = ks[i]
        out.push([k, m[k]])
        i = i + 1
    }
    return out
}

// ── membership / size ───────────────────────────────────────────

@pure
pub fn map_has_key_pure(m, k) {
    return has_key(m, k)
}

@pure
pub fn map_size_pure(m) {
    return len(keys(m))
}

// ── get with default ────────────────────────────────────────────

@pure
pub fn map_get_or_pure(m, k, def) {
    if has_key(m, k) { return m[k] }
    return def
}

// ── merge ───────────────────────────────────────────────────────
// Returns a new map with all entries from m1, then all from m2.
// m2 values win on key collision.

@pure
pub fn map_merge_pure(m1, m2) {
    let mut out = #{}
    let ks1 = keys(m1)
    let n1 = len(ks1)
    let mut i = 0
    while i < n1 {
        let k = ks1[i]
        out[k] = m1[k]
        i = i + 1
    }
    let ks2 = keys(m2)
    let n2 = len(ks2)
    i = 0
    while i < n2 {
        let k = ks2[i]
        out[k] = m2[k]
        i = i + 1
    }
    return out
}

// ── map_map: transform values ───────────────────────────────────
// f(key, value) -> new_value

@pure
pub fn map_map_pure(m, f) {
    let mut out = #{}
    let ks = keys(m)
    let n = len(ks)
    let mut i = 0
    while i < n {
        let k = ks[i]
        out[k] = f(k, m[k])
        i = i + 1
    }
    return out
}

// ── map_map_values: transform values (value-only callback) ──────
// f(value) -> new_value

@pure
pub fn map_map_values_pure(m, f) {
    let mut out = #{}
    let ks = keys(m)
    let n = len(ks)
    let mut i = 0
    while i < n {
        let k = ks[i]
        out[k] = f(m[k])
        i = i + 1
    }
    return out
}

// ── filter ──────────────────────────────────────────────────────
// pred(key, value) -> bool

@pure
pub fn map_filter_pure(m, pred) {
    let mut out = #{}
    let ks = keys(m)
    let n = len(ks)
    let mut i = 0
    while i < n {
        let k = ks[i]
        let v = m[k]
        if pred(k, v) { out[k] = v }
        i = i + 1
    }
    return out
}

// ── filter by key only ──────────────────────────────────────────

@pure
pub fn map_filter_keys_pure(m, pred) {
    let mut out = #{}
    let ks = keys(m)
    let n = len(ks)
    let mut i = 0
    while i < n {
        let k = ks[i]
        if pred(k) { out[k] = m[k] }
        i = i + 1
    }
    return out
}

// ── filter by value only ────────────────────────────────────────

@pure
pub fn map_filter_values_pure(m, pred) {
    let mut out = #{}
    let ks = keys(m)
    let n = len(ks)
    let mut i = 0
    while i < n {
        let k = ks[i]
        let v = m[k]
        if pred(v) { out[k] = v }
        i = i + 1
    }
    return out
}

// ── from_entries: build map from [key, value] pair array ────────

@pure
pub fn map_from_entries_pure(entries) {
    let mut out = #{}
    let n = len(entries)
    let mut i = 0
    while i < n {
        let pair = entries[i]
        out[pair[0]] = pair[1]
        i = i + 1
    }
    return out
}

// ── invert: swap keys and values ────────────────────────────────
// If multiple keys map to the same value, the last one wins.

@pure
pub fn map_invert_pure(m) {
    let mut out = #{}
    let ks = keys(m)
    let n = len(ks)
    let mut i = 0
    while i < n {
        let k = ks[i]
        let v = m[k]
        out[to_string(v)] = k
        i = i + 1
    }
    return out
}

// ── any / all / count ───────────────────────────────────────────
// pred(key, value) -> bool

@pure
pub fn map_any_pure(m, pred) {
    let ks = keys(m)
    let n = len(ks)
    let mut i = 0
    while i < n {
        let k = ks[i]
        if pred(k, m[k]) { return true }
        i = i + 1
    }
    return false
}

@pure
pub fn map_all_pure(m, pred) {
    let ks = keys(m)
    let n = len(ks)
    let mut i = 0
    while i < n {
        let k = ks[i]
        if !pred(k, m[k]) { return false }
        i = i + 1
    }
    return true
}

@pure
pub fn map_count_pure(m, pred) {
    let mut c = 0
    let ks = keys(m)
    let n = len(ks)
    let mut i = 0
    while i < n {
        let k = ks[i]
        if pred(k, m[k]) { c = c + 1 }
        i = i + 1
    }
    return c
}

// ── find_key: first key satisfying pred(k, v) ──────────────────

@pure
pub fn map_find_key_pure(m, pred) {
    let ks = keys(m)
    let n = len(ks)
    let mut i = 0
    while i < n {
        let k = ks[i]
        if pred(k, m[k]) { return k }
        i = i + 1
    }
    return void
}

// ── fold: reduce over entries ───────────────────────────────────
// f(accumulator, key, value) -> new_accumulator

@pure
pub fn map_fold_pure(m, init, f) {
    let mut acc = init
    let ks = keys(m)
    let n = len(ks)
    let mut i = 0
    while i < n {
        let k = ks[i]
        acc = f(acc, k, m[k])
        i = i + 1
    }
    return acc
}

// ── select_keys: sub-map with only given keys ───────────────────

@pure
pub fn map_select_keys_pure(m, wanted) {
    let mut out = #{}
    let n = len(wanted)
    let mut i = 0
    while i < n {
        let k = wanted[i]
        if has_key(m, k) { out[k] = m[k] }
        i = i + 1
    }
    return out
}

// ── remove_keys: sub-map without given keys ─────────────────────

@pure
pub fn map_remove_keys_pure(m, unwanted) {
    // Build a set from unwanted for O(n+m) instead of O(n*m)
    let mut skip = #{}
    let nu = len(unwanted)
    let mut i = 0
    while i < nu {
        skip[unwanted[i]] = true
        i = i + 1
    }
    let mut out = #{}
    let ks = keys(m)
    let n = len(ks)
    i = 0
    while i < n {
        let k = ks[i]
        if !has_key(skip, k) { out[k] = m[k] }
        i = i + 1
    }
    return out
}

// ── update: update a single key via transform function ──────────
// If key exists: out[k] = f(m[k]). If not: out[k] = def.

@pure
pub fn map_update_pure(m, k, f, def) {
    let mut out = #{}
    let ks = keys(m)
    let n = len(ks)
    let mut i = 0
    while i < n {
        let key = ks[i]
        out[key] = m[key]
        i = i + 1
    }
    if has_key(m, k) {
        out[k] = f(m[k])
    } else {
        out[k] = def
    }
    return out
}

// ── zip: build map from parallel key and value arrays ───────────
// Shorter array determines length.

@pure
pub fn map_zip_pure(ks_arr, vs_arr) {
    let mut out = #{}
    let nk = len(ks_arr)
    let nv = len(vs_arr)
    let n = if nk < nv { nk } else { nv }
    let mut i = 0
    while i < n {
        out[ks_arr[i]] = vs_arr[i]
        i = i + 1
    }
    return out
}

// ── group_by: group array elements by classifier function ───────
// f(element) -> key. Returns map of key -> [elements].

@pure
pub fn map_group_by_pure(arr, f) {
    let mut out = #{}
    let n = len(arr)
    let mut i = 0
    while i < n {
        let elem = arr[i]
        let k = f(elem)
        if has_key(out, k) {
            out[k] = out[k].push(elem)
        } else {
            let init = []
            out[k] = init.push(elem)
        }
        i = i + 1
    }
    return out
}

// ── eq: structural map equality ─────────────────────────────────
// Both must have the same keys and equal values at each key.

@pure
pub fn map_eq_pure(a, b) {
    let ka = keys(a)
    let kb = keys(b)
    if len(ka) != len(kb) { return false }
    let n = len(ka)
    let mut i = 0
    while i < n {
        let k = ka[i]
        if !has_key(b, k) { return false }
        if a[k] != b[k] { return false }
        i = i + 1
    }
    return true
}


// -- end inlined --

let mut pass = 0
let mut fail = 0

fn check(name, cond) {
    if cond { pass = pass + 1 } else {
        fail = fail + 1
        println("[FAIL] " + name)
    }
}

fn eq(name, a, b) {
    let both_void = type_of(a) == "void" && type_of(b) == "void"
    if both_void || a == b { pass = pass + 1 } else {
        fail = fail + 1
        println("[FAIL] " + name + " got " + to_string(a) + " want " + to_string(b))
    }
}

println("=== map_pure test suite ===")

// ────────────────────────────────────────────────────────────
// 1. map_keys_pure
// ────────────────────────────────────────────────────────────
let m1 = #{"a": 1, "b": 2, "c": 3}
let ks1 = map_keys_pure(m1)
eq("keys length", len(ks1), 3)
// keys order not guaranteed, check membership
check("keys has a", has_key(m1, "a"))
check("keys has b", has_key(m1, "b"))
check("keys has c", has_key(m1, "c"))
// empty map
eq("keys empty", len(map_keys_pure(#{})), 0)

// ────────────────────────────────────────────────────────────
// 2. map_values_pure
// ────────────────────────────────────────────────────────────
let vs1 = map_values_pure(m1)
eq("values length", len(vs1), 3)
// empty
eq("values empty", len(map_values_pure(#{})), 0)

// ────────────────────────────────────────────────────────────
// 3. map_entries_pure
// ────────────────────────────────────────────────────────────
let ents = map_entries_pure(m1)
eq("entries length", len(ents), 3)
// each entry is [key, value] pair of length 2
eq("entry pair len", len(ents[0]), 2)
// rebuild from entries should equal original
let rebuilt = map_from_entries_pure(ents)
check("entries round-trip", map_eq_pure(rebuilt, m1))
// empty
eq("entries empty", len(map_entries_pure(#{})), 0)

// ────────────────────────────────────────────────────────────
// 4. map_has_key_pure
// ────────────────────────────────────────────────────────────
check("has_key a", map_has_key_pure(m1, "a"))
check("has_key z false", !map_has_key_pure(m1, "z"))
check("has_key empty", !map_has_key_pure(#{}, "x"))

// ────────────────────────────────────────────────────────────
// 5. map_size_pure
// ────────────────────────────────────────────────────────────
eq("size 3", map_size_pure(m1), 3)
eq("size 0", map_size_pure(#{}), 0)
eq("size 1", map_size_pure(#{"x": 99}), 1)

// ────────────────────────────────────────────────────────────
// 6. map_get_or_pure
// ────────────────────────────────────────────────────────────
eq("get_or hit", map_get_or_pure(m1, "b", -1), 2)
eq("get_or miss", map_get_or_pure(m1, "z", -1), -1)
eq("get_or empty", map_get_or_pure(#{}, "a", 42), 42)

// ────────────────────────────────────────────────────────────
// 7. map_merge_pure
// ────────────────────────────────────────────────────────────
let left = #{"a": 1, "b": 2}
let right = #{"b": 99, "c": 3}
let merged = map_merge_pure(left, right)
eq("merge size", map_size_pure(merged), 3)
eq("merge a", merged["a"], 1)
eq("merge b wins", merged["b"], 99)
eq("merge c", merged["c"], 3)
// merge with empty
check("merge left empty", map_eq_pure(map_merge_pure(#{}, right), right))
check("merge right empty", map_eq_pure(map_merge_pure(left, #{}), left))

// ────────────────────────────────────────────────────────────
// 8. map_map_pure (f(k, v) -> new_value)
// ────────────────────────────────────────────────────────────
let doubled = map_map_pure(#{"x": 1, "y": 2}, fn(k, v) { return v * 2 })
eq("map x", doubled["x"], 2)
eq("map y", doubled["y"], 4)
eq("map size", map_size_pure(doubled), 2)
// empty
eq("map empty", map_size_pure(map_map_pure(#{}, fn(k, v) { return v })), 0)

// ────────────────────────────────────────────────────────────
// 9. map_filter_pure (pred(k, v) -> bool)
// ────────────────────────────────────────────────────────────
let nums = #{"a": 1, "b": 2, "c": 3, "d": 4}
let evens = map_filter_pure(nums, fn(k, v) { return v % 2 == 0 })
eq("filter size", map_size_pure(evens), 2)
eq("filter b", evens["b"], 2)
eq("filter d", evens["d"], 4)
check("filter a gone", !map_has_key_pure(evens, "a"))
// filter none
eq("filter none", map_size_pure(map_filter_pure(nums, fn(k, v) { return false })), 0)
// filter all
eq("filter all", map_size_pure(map_filter_pure(nums, fn(k, v) { return true })), 4)

// ────────────────────────────────────────────────────────────
// 10. map_from_entries_pure
// ────────────────────────────────────────────────────────────
let fe = map_from_entries_pure([["x", 10], ["y", 20]])
eq("from_entries size", map_size_pure(fe), 2)
eq("from_entries x", fe["x"], 10)
eq("from_entries y", fe["y"], 20)
// empty
eq("from_entries empty", map_size_pure(map_from_entries_pure([])), 0)
// duplicate key — last wins
let dup = map_from_entries_pure([["a", 1], ["a", 2]])
eq("from_entries dup", dup["a"], 2)

// ────────────────────────────────────────────────────────────
// 11. map_invert_pure
// ────────────────────────────────────────────────────────────
let inv = map_invert_pure(#{"x": 1, "y": 2})
eq("invert size", map_size_pure(inv), 2)
eq("invert 1->x", inv["1"], "x")
eq("invert 2->y", inv["2"], "y")
// empty
eq("invert empty", map_size_pure(map_invert_pure(#{})), 0)

// ────────────────────────────────────────────────────────────
// 12. map_map_values_pure (f(v) -> new_value)
// ────────────────────────────────────────────────────────────
let mv = map_map_values_pure(#{"a": 10, "b": 20}, fn(v) { return v + 5 })
eq("map_values a", mv["a"], 15)
eq("map_values b", mv["b"], 25)
eq("map_values size", map_size_pure(mv), 2)

// ────────────────────────────────────────────────────────────
// 13. map_filter_keys_pure (pred(k) -> bool)
// ────────────────────────────────────────────────────────────
let fk = map_filter_keys_pure(#{"apple": 1, "banana": 2, "avocado": 3}, fn(k) { return k[0] == "a" })
eq("filter_keys size", map_size_pure(fk), 2)
check("filter_keys apple", map_has_key_pure(fk, "apple"))
check("filter_keys avocado", map_has_key_pure(fk, "avocado"))
check("filter_keys banana gone", !map_has_key_pure(fk, "banana"))

// ────────────────────────────────────────────────────────────
// 14. map_filter_values_pure (pred(v) -> bool)
// ────────────────────────────────────────────────────────────
let fv = map_filter_values_pure(#{"a": 10, "b": 3, "c": 7}, fn(v) { return v > 5 })
eq("filter_values size", map_size_pure(fv), 2)
check("filter_values a", map_has_key_pure(fv, "a"))
check("filter_values c", map_has_key_pure(fv, "c"))
check("filter_values b gone", !map_has_key_pure(fv, "b"))

// ────────────────────────────────────────────────────────────
// 15. map_any_pure
// ────────────────────────────────────────────────────────────
check("any true", map_any_pure(nums, fn(k, v) { return v > 3 }))
check("any false", !map_any_pure(nums, fn(k, v) { return v > 100 }))
check("any empty", !map_any_pure(#{}, fn(k, v) { return true }))

// ────────────────────────────────────────────────────────────
// 16. map_all_pure
// ────────────────────────────────────────────────────────────
check("all true", map_all_pure(nums, fn(k, v) { return v > 0 }))
check("all false", !map_all_pure(nums, fn(k, v) { return v > 2 }))
check("all empty", map_all_pure(#{}, fn(k, v) { return false }))

// ────────────────────────────────────────────────────────────
// 17. map_count_pure
// ────────────────────────────────────────────────────────────
eq("count >2", map_count_pure(nums, fn(k, v) { return v > 2 }), 2)
eq("count all", map_count_pure(nums, fn(k, v) { return true }), 4)
eq("count none", map_count_pure(nums, fn(k, v) { return false }), 0)
eq("count empty", map_count_pure(#{}, fn(k, v) { return true }), 0)

// ────────────────────────────────────────────────────────────
// 18. map_find_key_pure
// ────────────────────────────────────────────────────────────
let fk2 = map_find_key_pure(nums, fn(k, v) { return v == 3 })
eq("find_key 3", fk2, "c")
let fk3 = map_find_key_pure(nums, fn(k, v) { return v == 999 })
eq("find_key miss", fk3, void)
eq("find_key empty", map_find_key_pure(#{}, fn(k, v) { return true }), void)

// ────────────────────────────────────────────────────────────
// 19. map_fold_pure
// ────────────────────────────────────────────────────────────
let sum = map_fold_pure(nums, 0, fn(acc, k, v) { return acc + v })
eq("fold sum", sum, 10)
// fold on empty
eq("fold empty", map_fold_pure(#{}, 42, fn(acc, k, v) { return acc + v }), 42)
// fold concat keys
let m_small = #{"x": 1, "y": 2}
let key_count = map_fold_pure(m_small, 0, fn(acc, k, v) { return acc + 1 })
eq("fold count", key_count, 2)

// ────────────────────────────────────────────────────────────
// 20. map_select_keys_pure
// ────────────────────────────────────────────────────────────
let sel = map_select_keys_pure(nums, ["a", "c"])
eq("select size", map_size_pure(sel), 2)
eq("select a", sel["a"], 1)
eq("select c", sel["c"], 3)
check("select b gone", !map_has_key_pure(sel, "b"))
// select non-existent key silently ignored
let sel2 = map_select_keys_pure(nums, ["a", "zzz"])
eq("select partial", map_size_pure(sel2), 1)
// select empty keys
eq("select empty ks", map_size_pure(map_select_keys_pure(nums, [])), 0)

// ────────────────────────────────────────────────────────────
// 21. map_remove_keys_pure
// ────────────────────────────────────────────────────────────
let rem = map_remove_keys_pure(nums, ["b", "d"])
eq("remove size", map_size_pure(rem), 2)
eq("remove a", rem["a"], 1)
eq("remove c", rem["c"], 3)
check("remove b gone", !map_has_key_pure(rem, "b"))
check("remove d gone", !map_has_key_pure(rem, "d"))
// remove non-existent key
let rem2 = map_remove_keys_pure(nums, ["zzz"])
eq("remove non-existent", map_size_pure(rem2), 4)
// remove all
eq("remove all", map_size_pure(map_remove_keys_pure(nums, ["a", "b", "c", "d"])), 0)

// ────────────────────────────────────────────────────────────
// 22. map_update_pure
// ────────────────────────────────────────────────────────────
let upd1 = map_update_pure(#{"a": 10, "b": 20}, "a", fn(v) { return v + 5 }, 0)
eq("update hit a", upd1["a"], 15)
eq("update keep b", upd1["b"], 20)
// update miss
let upd2 = map_update_pure(#{"a": 10}, "z", fn(v) { return v + 1 }, 99)
eq("update miss z", upd2["z"], 99)
eq("update keep a", upd2["a"], 10)

// ────────────────────────────────────────────────────────────
// 23. map_zip_pure
// ────────────────────────────────────────────────────────────
let zipped = map_zip_pure(["a", "b", "c"], [1, 2, 3])
eq("zip size", map_size_pure(zipped), 3)
eq("zip a", zipped["a"], 1)
eq("zip b", zipped["b"], 2)
eq("zip c", zipped["c"], 3)
// unequal lengths — shorter wins
let zshort = map_zip_pure(["a", "b"], [1, 2, 3])
eq("zip short keys", map_size_pure(zshort), 2)
let zshort2 = map_zip_pure(["a", "b", "c"], [1])
eq("zip short vals", map_size_pure(zshort2), 1)
// empty
eq("zip empty", map_size_pure(map_zip_pure([], [])), 0)

// ────────────────────────────────────────────────────────────
// 24. map_group_by_pure
// ────────────────────────────────────────────────────────────
let words = ["cat", "car", "dog", "cow", "ant"]
let grouped = map_group_by_pure(words, fn(w) { return w[0] })
eq("group c len", len(grouped["c"]), 3)
eq("group d len", len(grouped["d"]), 1)
eq("group a len", len(grouped["a"]), 1)
eq("group size", map_size_pure(grouped), 3)
// group empty
eq("group empty", map_size_pure(map_group_by_pure([], fn(x) { return x })), 0)

// ────────────────────────────────────────────────────────────
// 25. map_eq_pure
// ────────────────────────────────────────────────────────────
check("eq same", map_eq_pure(#{"a": 1, "b": 2}, #{"a": 1, "b": 2}))
check("eq diff val", !map_eq_pure(#{"a": 1}, #{"a": 2}))
check("eq diff key", !map_eq_pure(#{"a": 1}, #{"b": 1}))
check("eq diff size", !map_eq_pure(#{"a": 1, "b": 2}, #{"a": 1}))
check("eq empty", map_eq_pure(#{}, #{}))
check("eq one empty", !map_eq_pure(#{"a": 1}, #{}))

// ────────────────────────────────────────────────────────────
// 26. edge case combos
// ────────────────────────────────────────────────────────────
// merge then filter
let mf = map_filter_pure(map_merge_pure(#{"a": 1}, #{"b": 2, "c": 3}), fn(k, v) { return v > 1 })
eq("merge+filter size", map_size_pure(mf), 2)
check("merge+filter b", map_has_key_pure(mf, "b"))
check("merge+filter c", map_has_key_pure(mf, "c"))

// invert then invert (round-trip for string->string map)
let strmap = #{"hello": "world", "foo": "bar"}
let inv2 = map_invert_pure(map_invert_pure(strmap))
check("invert round-trip", map_eq_pure(inv2, strmap))

// fold to build sum of select_keys
let partial_sum = map_fold_pure(map_select_keys_pure(nums, ["a", "d"]), 0, fn(acc, k, v) { return acc + v })
eq("select+fold sum", partial_sum, 5)

// update chained
let u1 = map_update_pure(#{"x": 0}, "x", fn(v) { return v + 1 }, 0)
let u2 = map_update_pure(u1, "x", fn(v) { return v + 1 }, 0)
let u3 = map_update_pure(u2, "x", fn(v) { return v + 1 }, 0)
eq("update chain", u3["x"], 3)

// group_by + map_map_values (count per group)
let g = map_group_by_pure([1, 2, 3, 4, 5, 6], fn(x) { return to_string(x % 2) })
let counts = map_map_values_pure(g, fn(v) { return len(v) })
eq("group+count 0", counts["0"], 3)
eq("group+count 1", counts["1"], 3)

println("===========================================================")
println("  Results: " + to_string(pass) + " passed, " + to_string(fail) + " failed")
println("===========================================================")
if fail == 0 { println("ALL PASS") } else { println("SOME FAIL") }
