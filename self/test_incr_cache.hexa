// self/test_incr_cache.hexa — ROI#177 incremental compile cache 테스트
//
// 시나리오:
//   1) 가짜 파일 2개를 2회씩 처리 → 첫 회는 miss, 둘째 회는 hit
//   2) source 변경 시 자동 invalidation (다른 key → miss)
//   3) hit_ratio / stats 검증
//
// 단독 실행을 위해 incr_cache 함수 인라인.

// ── inlined from self/incr_cache.hexa ─────────────────────────────

let INCR_FNV_OFFSET_32 = 2166136261
let INCR_FNV_PRIME_32  = 16777619
let INCR_FNV_MOD_32    = 4294967296

fn incr_hash_source(s) {
    if type_of(s) != "string" { return INCR_FNV_OFFSET_32 }
    let mut h = INCR_FNV_OFFSET_32
    let mut i = 0
    let n = len(s)
    while i < n {
        let b = ord(s.substring(i, i + 1))
        h = h ^ b
        h = (h * INCR_FNV_PRIME_32) % INCR_FNV_MOD_32
        i = i + 1
    }
    h
}

fn incr_cache_key(path, source) {
    let hp = incr_hash_source(path)
    let hs = incr_hash_source(source)
    to_string(hp) + ":" + to_string(hs)
}

fn incr_cache_new() {
    #{
        "entries": #{},
        "hits":    0,
        "misses":  0,
    }
}

fn incr_derive_artifact(path, key) {
    let mut last_slash = 0 - 1
    let mut i = 0
    let n = len(path)
    while i < n {
        if path.substring(i, i + 1) == "/" { last_slash = i }
        i = i + 1
    }
    let base = if last_slash >= 0 { path.substring(last_slash + 1, n) } else { path }
    let strip = if len(base) > 5 && base.substring(len(base) - 5, len(base)) == ".hexa" {
        base.substring(0, len(base) - 5)
    } else {
        base
    }
    let short = if len(key) > 8 { key.substring(0, 8) } else { key }
    "build/" + strip + "." + short + ".o"
}

fn incr_compile_or_skip(cache, path, source) {
    let key = incr_cache_key(path, source)
    let entries = cache["entries"]

    if entries.contains_key(key) {
        let e = entries[key]
        let mut c2 = cache
        c2["hits"] = cache["hits"] + 1
        return #{
            "artifact": e["artifact"],
            "cache":    c2,
            "skipped":  true,
            "key":      key,
        }
    }

    let artifact = incr_derive_artifact(path, key)
    let mut new_entries = entries
    new_entries[key] = #{
        "artifact":    artifact,
        "path":        path,
        "source_hash": incr_hash_source(source),
    }
    let mut c2 = cache
    c2["entries"] = new_entries
    c2["misses"] = cache["misses"] + 1
    return #{
        "artifact": artifact,
        "cache":    c2,
        "skipped":  false,
        "key":      key,
    }
}

fn incr_cache_hit_ratio(cache) {
    let h = cache["hits"]
    let m = cache["misses"]
    let t = h + m
    if t <= 0 { return 0 }
    (h * 100) / t
}

// ── end inlined ───────────────────────────────────────────────────

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  incr_cache.hexa — ROI#177 test runner")
println("═══════════════════════════════════════════════════════")

// ── 1. hash 결정성 ──────────────────────────────────────────
println("")
println("--- hash determinism ---")
check("same source → same hash",
      incr_hash_source("let x = 1") == incr_hash_source("let x = 1"),
      true)
check("diff source → diff hash",
      incr_hash_source("let x = 1") != incr_hash_source("let x = 2"),
      true)

// ── 2. cache key ────────────────────────────────────────────
println("")
println("--- cache key ---")
let k_a = incr_cache_key("a.hexa", "src1")
let k_b = incr_cache_key("b.hexa", "src1")
let k_a2 = incr_cache_key("a.hexa", "src1")
check("same (path,src) → same key", k_a == k_a2, true)
check("diff path → diff key", k_a != k_b, true)
let k_a_mut = incr_cache_key("a.hexa", "src1-changed")
check("diff source → diff key", k_a != k_a_mut, true)

// ── 3. 가짜 파일 2회 처리 (scaffold 요구) ────────────────────
println("")
println("--- fake files, 2 passes each ---")

let src_foo = "fn foo() { return 1 }"
let src_bar = "fn bar() { return 2 }"

let mut cache = incr_cache_new()
check("initial hits",   cache["hits"],   0)
check("initial misses", cache["misses"], 0)

// Pass 1: foo (miss)
let r1 = incr_compile_or_skip(cache, "foo.hexa", src_foo)
cache = r1["cache"]
check("pass1 foo: skipped", r1["skipped"], false)
check("pass1 foo: artifact non-empty", len(r1["artifact"]) > 0, true)
check("pass1 foo: misses=1", cache["misses"], 1)

// Pass 1: bar (miss)
let r2 = incr_compile_or_skip(cache, "bar.hexa", src_bar)
cache = r2["cache"]
check("pass1 bar: skipped", r2["skipped"], false)
check("pass1 bar: misses=2", cache["misses"], 2)
check("pass1 bar: hits=0",   cache["hits"],   0)

// Pass 2: foo (hit — same source)
let r3 = incr_compile_or_skip(cache, "foo.hexa", src_foo)
cache = r3["cache"]
check("pass2 foo: skipped=true", r3["skipped"], true)
check("pass2 foo: artifact matches pass1",
      r3["artifact"] == r1["artifact"], true)
check("pass2 foo: hits=1", cache["hits"], 1)

// Pass 2: bar (hit)
let r4 = incr_compile_or_skip(cache, "bar.hexa", src_bar)
cache = r4["cache"]
check("pass2 bar: skipped=true", r4["skipped"], true)
check("pass2 bar: hits=2", cache["hits"], 2)
check("pass2 bar: misses stays 2", cache["misses"], 2)

// ── 4. invalidation via source change ────────────────────────
println("")
println("--- invalidation on source change ---")
let src_foo_v2 = "fn foo() { return 42 }"
let r5 = incr_compile_or_skip(cache, "foo.hexa", src_foo_v2)
cache = r5["cache"]
check("changed foo: skipped=false", r5["skipped"], false)
check("changed foo: misses=3", cache["misses"], 3)
check("changed foo: artifact differs",
      r5["artifact"] != r1["artifact"], true)

// 변경 후 재호출은 다시 hit
let r6 = incr_compile_or_skip(cache, "foo.hexa", src_foo_v2)
cache = r6["cache"]
check("re-hit changed foo: skipped=true", r6["skipped"], true)
check("re-hit changed foo: hits=3", cache["hits"], 3)

// ── 5. hit ratio ─────────────────────────────────────────────
println("")
println("--- hit ratio ---")
// hits=3, misses=3 → 50%
check("hit ratio = 50%", incr_cache_hit_ratio(cache), 50)

// ── 6. empty cache ratio ─────────────────────────────────────
let empty = incr_cache_new()
check("empty ratio = 0", incr_cache_hit_ratio(empty), 0)

// ── 7. artifact 경로 포맷 ────────────────────────────────────
println("")
println("--- artifact path format ---")
let ap = incr_derive_artifact("foo.hexa", "12345678abcdef")
check("artifact starts with build/", ap.substring(0, 6), "build/")
check("artifact ends with .o",
      ap.substring(len(ap) - 2, len(ap)), ".o")

// ── Summary ──────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, "
        + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    println("FAIL")
    exit(1)
}
println("ALL PASS")
