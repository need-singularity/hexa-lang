// self/ast.hexa — HEXA AST ported from src/ast.rs
// Abstract Syntax Tree types for the HEXA language.

// ── AI-native Attribute ─────────────────────────────────

struct Attribute {
    kind: string,
    args: string   // serialized key:expr pairs
}

@pure
fn attribute_new(kind: string) -> Attribute {
    return Attribute { kind: kind, args: "" }
}

@pure
fn attribute_with_args(kind: string, args: string) -> Attribute {
    return Attribute { kind: kind, args: args }
}

@pure
fn has_attr(attrs: [string], check: string) -> bool {
    for i in 0..len(attrs) {
        if attrs[i] == check {
            return true
        }
    }
    return false
}

// ── Expressions ─────────────────────────────────────────
// Expr is represented as a struct with a `kind` tag string.
// Fields not relevant for a given kind are left as defaults.

struct Expr {
    kind: string,       // "int_lit", "float_lit", "bool_lit", "string_lit", "char_lit",
                        // "ident", "binary", "unary", "call", "lambda", "array", "tuple",
                        // "field", "index", "if", "match", "block", "range",
                        // "struct_init", "map_lit", "enum_path", "wildcard",
                        // "array_pattern", "own", "move", "borrow", "await",
                        // "macro_invoc", "comptime", "handle_with", "effect_call",
                        // "resume", "dyn_cast", "yield", "template", "try_catch"
    int_val: int,
    float_val: float,
    bool_val: bool,
    str_val: string,
    name: string,
    op: string,
    left: string,       // serialized child expr
    right: string,      // serialized child expr
    args: string,       // serialized argument list
    body: string,       // serialized block
    else_body: string,  // serialized else block
    arms: string,       // serialized match arms
    inclusive: bool      // for range: ..=
}

fn expr_int(val: int) -> Expr {
    return Expr { kind: "int_lit", int_val: val, float_val: 0.0, bool_val: false,
        str_val: "", name: "", op: "", left: "", right: "", args: "",
        body: "", else_body: "", arms: "", inclusive: false }
}

fn expr_float(val: float) -> Expr {
    return Expr { kind: "float_lit", int_val: 0, float_val: val, bool_val: false,
        str_val: "", name: "", op: "", left: "", right: "", args: "",
        body: "", else_body: "", arms: "", inclusive: false }
}

fn expr_bool(val: bool) -> Expr {
    return Expr { kind: "bool_lit", int_val: 0, float_val: 0.0, bool_val: val,
        str_val: "", name: "", op: "", left: "", right: "", args: "",
        body: "", else_body: "", arms: "", inclusive: false }
}

fn expr_string(val: string) -> Expr {
    return Expr { kind: "string_lit", int_val: 0, float_val: 0.0, bool_val: false,
        str_val: val, name: "", op: "", left: "", right: "", args: "",
        body: "", else_body: "", arms: "", inclusive: false }
}

fn expr_ident(name: string) -> Expr {
    return Expr { kind: "ident", int_val: 0, float_val: 0.0, bool_val: false,
        str_val: "", name: name, op: "", left: "", right: "", args: "",
        body: "", else_body: "", arms: "", inclusive: false }
}

fn expr_wildcard() -> Expr {
    return Expr { kind: "wildcard", int_val: 0, float_val: 0.0, bool_val: false,
        str_val: "", name: "", op: "", left: "", right: "", args: "",
        body: "", else_body: "", arms: "", inclusive: false }
}

// ── Template nodes ──────────────────────────────────────

struct TemplateNode {
    kind: string,       // "element", "text", "for", "if", "match", "verify", "invariant"
    tag: string,
    attrs: string,      // serialized attrs
    children: string,   // serialized children
    expr: string,       // serialized expression
    var_name: string,
    then_children: string,
    else_children: string
}

struct TemplateAttr {
    key: string,
    value: string       // serialized expr
}

// ── Select / Timeout ────────────────────────────────────

struct SelectArm {
    receiver: string,   // serialized expr
    binding: string,
    body: string        // serialized block
}

struct TimeoutArm {
    duration_ms: string, // serialized expr
    body: string         // serialized block
}

// ── Binary Operators (J2=24) ────────────────────────────
// BinOp: 22 binary operators (24 total - 2 unary-only: ! ~)

let BINOP_ADD = "add"
let BINOP_SUB = "sub"
let BINOP_MUL = "mul"
let BINOP_DIV = "div"
let BINOP_REM = "rem"
let BINOP_POW = "pow"
let BINOP_EQ = "eq"
let BINOP_NE = "ne"
let BINOP_LT = "lt"
let BINOP_GT = "gt"
let BINOP_LE = "le"
let BINOP_GE = "ge"
let BINOP_AND = "and"
let BINOP_OR = "or"
let BINOP_XOR = "xor"
let BINOP_BITAND = "bitand"
let BINOP_BITOR = "bitor"
let BINOP_BITXOR = "bitxor"
let BINOP_ASSIGN = "assign"
let BINOP_DECL_ASSIGN = "decl_assign"
let BINOP_RANGE = "range"
let BINOP_ARROW = "arrow"

// ── Unary Operators ─────────────────────────────────────

let UNARYOP_NEG = "neg"
let UNARYOP_NOT = "not"
let UNARYOP_BITNOT = "bitnot"

// ── Statements ──────────────────────────────────────────
// Stmt is represented as a struct with a `kind` tag string.

struct Stmt {
    kind: string,       // "let", "let_tuple", "const", "static", "assign", "expr",
                        // "return", "fn_decl", "struct_decl", "enum_decl", "trait_decl",
                        // "impl_block", "for", "while", "loop", "proof", "proof_block",
                        // "assert", "intent", "verify", "mod", "use", "try_catch",
                        // "throw", "spawn", "spawn_named", "scope", "drop",
                        // "async_fn_decl", "select", "macro_def", "derive_decl",
                        // "generate", "optimize", "comptime_fn", "effect_decl",
                        // "consciousness_block", "evolve_fn", "type_alias",
                        // "atomic_let", "panic", "theorem", "break", "continue", "extern"
    name: string,
    type_name: string,
    value: string,      // serialized expr or body
    visibility: string, // "private", "module", "crate", "public"
    params: string,     // serialized params
    body: string,       // serialized block
    else_body: string,
    fields: string,
    variants: string,
    methods: string,
    arms: string,
    target: string,
    trait_name: string,
    iter_expr: string,
    ret_type: string,
    attrs: string       // serialized attributes
}

// ── Function Declaration ────────────────────────────────

struct FnDecl {
    name: string,
    type_params: string,    // serialized type params
    params: string,         // serialized params
    ret_type: string,
    where_clauses: string,  // serialized where clauses
    precondition: string,   // serialized expr
    postcondition: string,  // serialized expr
    body: string,           // serialized block
    visibility: string,
    is_pure: bool,
    attrs: string,          // serialized attributes
    annotations: string     // serialized @cli/@flag/@doc/@schema/@gate/@memo (kind|raw;...)
}

struct Param {
    name: string,
    typ: string     // "" for untyped
}

struct TypeParam {
    name: string,
    bound: string   // "" for unbounded
}

struct WhereClause {
    type_name: string,
    bound: string
}

// ── Struct Declaration ──────────────────────────────────

struct StructDecl {
    name: string,
    type_params: string,
    fields: string,         // serialized [(name, type, visibility)]
    visibility: string,
    attrs: string
}

// ── Enum Declaration ────────────────────────────────────

struct EnumDecl {
    name: string,
    variants: string,   // serialized [(name, optional_types)]
    visibility: string
}

// ── Trait / Impl ────────────────────────────────────────

struct TraitDecl {
    name: string,
    methods: string,    // serialized [FnDecl]
    visibility: string
}

struct ImplBlock {
    trait_name: string, // "" if no trait
    target: string,
    methods: string     // serialized [FnDecl]
}

// ── Match Arm ───────────────────────────────────────────

struct MatchArm {
    pattern: string,    // serialized expr
    guard_expr: string, // serialized expr or ""  (field renamed: `guard` is a reserved keyword — P51)
    body: string        // serialized block
}

// ── Algebraic Effects ───────────────────────────────────

struct EffectDecl {
    name: string,
    type_params: string,
    operations: string  // serialized [EffectOp]
}

struct EffectOp {
    name: string,
    params: string,     // serialized [Param]
    return_type: string
}

struct EffectHandler {
    effect_name: string,   // renamed: `effect` is reserved (P51)
    op: string,
    params: string,        // serialized param names
    body: string           // serialized block
}

// ── Extern FFI ──────────────────────────────────────────

struct ExternFnDecl {
    name: string,
    params: string,     // serialized [ExternParam]
    ret_type: string,
    link_lib: string    // "" if none
}

struct ExternParam {
    name: string,
    typ: string
}

// ── Generate Target ─────────────────────────────────────

struct GenerateTarget {
    kind: string,       // "fn" or "expr"
    name: string,
    params: string,
    ret_type: string,
    description: string,
    type_hint: string
}

// ── Macro Types ─────────────────────────────────────────

struct MacroDef {
    name: string,
    rules: string       // serialized [MacroRule]
}

struct MacroRule {
    pattern: string,    // serialized pattern tokens
    body: string        // serialized body tokens
}

struct MacroInvocation {
    name: string,
    tokens: string      // serialized lit tokens
}

// ── Proof Block ─────────────────────────────────────────

struct ProofBlockStmt {
    kind: string,       // "forall", "exists", "assert", "check_law", "invariant"
    var: string,
    typ: string,
    condition: string,  // serialized expr
    conclusion: string, // serialized expr
    law_number: int
}

// ── Visibility (tau=4 levels) ───────────────────────────

let VIS_PRIVATE = "private"
let VIS_MODULE  = "module"
let VIS_CRATE   = "crate"
let VIS_PUBLIC  = "public"
