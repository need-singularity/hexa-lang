// -- inlined from self/ml/bitnet_b158.hexa --
// codegen import not wired for test files

// ===================================================================
//  bitnet_b158.hexa — BitNet b1.58 (ternary {-1, 0, +1} 1.58-bit train)
//
//  ML roadmap #217.
//
//  Reference: Ma et al., "The Era of 1-bit LLMs: All Large Language
//  Models are in 1.58 Bits" (2024).
//
//  Where the original BitNet (#1, see ml/bitnet.hexa) uses absmean
//  thresholding to map weights to {-1, 0, +1} via dead-zone clipping,
//  BitNet b1.58 instead uses absmean SCALING + ROUNDING:
//
//      scale         = mean(|W|) + eps
//      W_q[i]        = round(clip(W[i] / scale, -1, +1))   ∈ {-1, 0, +1}
//      W_dequant[i]  = scale * W_q[i]
//
//  Activations are quantized to int8 with absmax scaling per token.
//
//  Forward path (linear layer):
//      y = scale * (W_q · x_q) * activation_scale
//
//  Training uses the straight-through estimator (STE): the gradient
//  flows through the round() / clip() as if they were the identity.
//  A continuous "shadow" weight matrix is updated via SGD, then re-
//  quantized for the next forward pass.
//
//  Effective bit-width:
//      log2(3) ≈ 1.58 bits per weight (information-theoretic minimum
//      for a ternary alphabet). With 5 trits packed per byte (3^5 =
//      243 < 256) the practical storage cost is ~1.6 bits/weight.
//
//  Public API (prefix b158_):
//
//  Math helpers:
//    b158_abs(x)                       -> float
//    b158_max(a, b)                    -> numeric
//    b158_min(a, b)                    -> numeric
//    b158_clip(x, lo, hi)              -> numeric
//    b158_round_ternary(x)             -> int     (-1, 0, +1)
//    b158_round_int(x)                 -> int
//
//  Quantization core:
//    b158_absmean(w, n)                -> float                   (scale)
//    b158_quantize_weight(w, n)        -> B158Tensor
//    b158_dequantize(q, scale, n)      -> [float]
//    b158_activation_quantize(x, n, nbits) -> B158ActTensor      (int8)
//    b158_activation_dequantize(at)    -> [float]
//
//  Linear / inference:
//    b158_matmul(W_q, W_scale, x, rows, cols) -> [float]
//    b158_layer_forward(w_q, w_scale, x, rows, cols) -> [float]
//
//  Training:
//    b158_straight_through_gradient(grad_q, w, scale, n) -> [float]
//    b158_train_step(w, grads, lr, n)                    -> [float]
//
//  Memory accounting:
//    b158_param_bytes(n)               -> int                  (1.58→2 bit)
//    b158_compression_ratio(fp32_bytes, b158_bytes) -> float
//
//  Pure .hexa — no FFI, no Rust, no extern.
// ===================================================================

// ── Result structs ──────────────────────────────────────────────

struct B158Tensor {
    // Ternary codes in {-1, 0, +1}, length n.
    q: array,
    // Absmean scale (gamma) — multiply q by scale to recover float.
    scale: float,
    // Element count.
    n: int
}

struct B158ActTensor {
    // int8 codes (-127..127), length n.
    q: array,
    // Per-tensor absmax scale.
    scale: float,
    // Element count.
    n: int,
    // Quantization bit width (typically 8).
    nbits: int
}

// ===================================================================
//  Math helpers — prefixed b158_ to avoid collision with bitnet.hexa
// ===================================================================

fn b158_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn b158_max(a, b) {
    if a >= b { return a }
    return b
}

fn b158_min(a, b) {
    if a <= b { return a }
    return b
}

fn b158_clip(x, lo, hi) {
    if x < lo { return lo }
    if x > hi { return hi }
    return x
}

// Round-to-nearest-int (banker-free): 0.4→0, 0.6→1, -0.6→-1.
fn b158_round_int(x) {
    if x >= 0.0 { return to_int(x + 0.5) }
    return to_int(x - 0.5)
}

// Round to ternary {-1, 0, +1} after clipping into [-1, +1].
fn b158_round_ternary(x) {
    let c = b158_clip(x, -1.0, 1.0)
    let r = b158_round_int(c)
    if r > 1 { return 1 }
    if r < 0 - 1 { return 0 - 1 }
    return r
}

// ===================================================================
//  Absmean — scale = (1/n) * sum(|w_i|), with epsilon floor.
// ===================================================================
fn b158_absmean(w, n) {
    if n == 0 { return 0.0 }
    let mut acc = 0.0
    let mut i = 0
    while i < n {
        acc = acc + b158_abs(w[i])
        i = i + 1
    }
    return acc / to_float(n)
}

// ===================================================================
//  b158_quantize_weight(w, n) -> B158Tensor
//
//  scale  = mean(|w|)
//  q[i]   = round(clip(w[i]/scale, -1, +1))      ∈ {-1, 0, +1}
//
//  When scale == 0 (all zero input) the quantized tensor is all zero
//  with scale 0; that round-trips correctly through dequantize.
// ===================================================================
fn b158_quantize_weight(w, n) {
    let scale = b158_absmean(w, n)
    let mut qdata = []
    let mut i = 0
    if scale <= 0.0 {
        while i < n {
            qdata = qdata + [0]
            i = i + 1
        }
        return B158Tensor {
            q: qdata,
            scale: 0.0,
            n: n
        }
    }
    let inv = 1.0 / scale
    while i < n {
        let scaled = w[i] * inv
        qdata = qdata + [b158_round_ternary(scaled)]
        i = i + 1
    }
    return B158Tensor {
        q: qdata,
        scale: scale,
        n: n
    }
}

// ===================================================================
//  b158_dequantize(q, scale, n) -> [float]
//
//  w_hat[i] = scale * q[i]
//
//  Accepts either a raw ternary array `q` or a B158Tensor (the latter
//  via the `_tensor` helper below). For the array form the caller must
//  pass scale + n explicitly.
// ===================================================================
fn b158_dequantize(q, scale, n) {
    let mut out = []
    let mut i = 0
    while i < n {
        out = out + [scale * to_float(q[i])]
        i = i + 1
    }
    return out
}

fn b158_dequantize_tensor(bt) {
    return b158_dequantize(bt.q, bt.scale, bt.n)
}

// ===================================================================
//  b158_activation_quantize(x, n, nbits) -> B158ActTensor
//
//  Symmetric int-N absmax quantization (default N=8). Activations are
//  scaled to fit in [-(2^(nbits-1)-1), +(2^(nbits-1)-1)] then rounded.
// ===================================================================
fn b158_activation_quantize(x, n, nbits) {
    if n == 0 {
        return B158ActTensor {
            q: [],
            scale: 0.0,
            n: 0,
            nbits: nbits
        }
    }
    // qmax = 2^(nbits-1) - 1   (e.g. 127 for nbits=8)
    let mut qmax = 1
    let mut k = 1
    while k < nbits {
        qmax = qmax * 2
        k = k + 1
    }
    qmax = qmax - 1
    let qmax_f = to_float(qmax)

    // absmax
    let mut amax = 0.0
    let mut i = 0
    while i < n {
        let a = b158_abs(x[i])
        if a > amax { amax = a }
        i = i + 1
    }
    if amax <= 0.0 {
        let mut zeros = []
        let mut j = 0
        while j < n {
            zeros = zeros + [0]
            j = j + 1
        }
        return B158ActTensor {
            q: zeros,
            scale: 0.0,
            n: n,
            nbits: nbits
        }
    }
    let scale = amax / qmax_f
    let inv = qmax_f / amax
    let mut qdata = []
    let mut t = 0
    while t < n {
        let raw = x[t] * inv
        let mut q = b158_round_int(raw)
        if q > qmax { q = qmax }
        if q < 0 - qmax { q = 0 - qmax }
        qdata = qdata + [q]
        t = t + 1
    }
    return B158ActTensor {
        q: qdata,
        scale: scale,
        n: n,
        nbits: nbits
    }
}

fn b158_activation_dequantize(at) {
    let mut out = []
    let mut i = 0
    while i < at.n {
        out = out + [to_float(at.q[i]) * at.scale]
        i = i + 1
    }
    return out
}

// ===================================================================
//  b158_matmul(W_q, W_scale, x, rows, cols) -> [float]
//
//  W : [rows, cols] flattened row-major, ternary in {-1, 0, +1}
//  x : [cols]
//  y : [rows]
//
//  Because q ∈ {-1, 0, +1}, the inner product collapses to sign +
//  add — no float multiplies on weights. The single multiply is by
//  the global per-tensor `W_scale`.
// ===================================================================
fn b158_matmul(W_q, W_scale, x, rows, cols) {
    let mut out = []
    let mut r = 0
    while r < rows {
        let mut acc = 0.0
        let mut c = 0
        while c < cols {
            let q = W_q[r * cols + c]
            if q == 1 {
                acc = acc + x[c]
            } else {
                if q == 0 - 1 {
                    acc = acc - x[c]
                }
            }
            c = c + 1
        }
        out = out + [acc * W_scale]
        r = r + 1
    }
    return out
}

// ===================================================================
//  b158_layer_forward(w_q, w_scale, x, rows, cols) -> [float]
//
//  Convenience wrapper: same as b158_matmul, exposed as the public
//  forward op for a single linear layer.
// ===================================================================
fn b158_layer_forward(w_q, w_scale, x, rows, cols) {
    return b158_matmul(w_q, w_scale, x, rows, cols)
}

// ===================================================================
//  b158_straight_through_gradient(grad_q, w, scale, n) -> [float]
//
//  Straight-through estimator: dL/dw ≈ dL/dq when |w/scale| <= 1.
//  Outside the clip region the gradient is killed to zero so the
//  shadow weight cannot drift unboundedly.
// ===================================================================
fn b158_straight_through_gradient(grad_q, w, scale, n) {
    let mut grad_w = []
    let mut i = 0
    let s = scale
    while i < n {
        if s <= 0.0 {
            grad_w = grad_w + [grad_q[i]]
        } else {
            let r = w[i] / s
            if r > 1.0 {
                grad_w = grad_w + [0.0]
            } else {
                if r < 0.0 - 1.0 {
                    grad_w = grad_w + [0.0]
                } else {
                    grad_w = grad_w + [grad_q[i]]
                }
            }
        }
        i = i + 1
    }
    return grad_w
}

// ===================================================================
//  b158_train_step(w, grads, lr, n) -> [float]
//
//  Single SGD step on the continuous shadow weights:
//      w_new[i] = w[i] - lr * grads[i]
//  Caller re-runs b158_quantize_weight() before the next forward.
// ===================================================================
fn b158_train_step(w, grads, lr, n) {
    let mut out = []
    let mut i = 0
    while i < n {
        out = out + [w[i] - lr * grads[i]]
        i = i + 1
    }
    return out
}

// ===================================================================
//  b158_param_bytes(n) -> int
//
//  Practical packed storage cost. The information-theoretic minimum
//  is log2(3) ≈ 1.58 bits / weight, but no real ISA can address
//  fractional bits. With 5 trits packed per byte (3^5 = 243 < 256)
//  the cost is ceil(n/5) bytes ≈ n * 1.6 / 8 = n * 0.2.
//
//  We round up so a tensor of length n always reports at least 1
//  byte to avoid downstream division-by-zero in compression-ratio
//  computations.
// ===================================================================
fn b158_param_bytes(n) {
    if n <= 0 { return 1 }
    let bytes = (n + 4) / 5
    if bytes <= 0 { return 1 }
    return bytes
}

// ===================================================================
//  b158_compression_ratio(fp32_bytes, b158_bytes) -> float
//
//  fp32_bytes / b158_bytes — how many times smaller the b1.58 form is.
//  Defensive guard against b158_bytes <= 0.
// ===================================================================
fn b158_compression_ratio(fp32_bytes, b158_bytes) {
    if b158_bytes <= 0 { return 0.0 }
    return to_float(fp32_bytes) / to_float(b158_bytes)
}

// ===================================================================
//  b158_param_count helper for layered models.
// ===================================================================
fn b158_param_count(rows, cols) {
    return rows * cols
}


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check(idx, name, cond) {
    if cond {
        println("[PASS] #" + str(idx) + " " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] #" + str(idx) + " " + name)
        fail_count = fail_count + 1
    }
}

fn t_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn t_approx(a, b, eps) {
    return t_abs(a - b) < eps
}

println("=== BitNet b1.58 Tests ===")

// ===================================================================
//  #1-#9 Math helpers
// ===================================================================

check(1, "b158_abs positive", b158_abs(3.5) == 3.5)
check(2, "b158_abs negative", b158_abs(-3.5) == 3.5)
check(3, "b158_max picks larger", b158_max(2.0, 7.0) == 7.0)
check(4, "b158_min picks smaller", b158_min(2.0, 7.0) == 2.0)
check(5, "b158_clip in-range", b158_clip(0.5, -1.0, 1.0) == 0.5)
check(6, "b158_clip below", b158_clip(-2.0, -1.0, 1.0) == -1.0)
check(7, "b158_clip above", b158_clip(2.0, -1.0, 1.0) == 1.0)
check(8, "b158_round_int 2.7 -> 3", b158_round_int(2.7) == 3)
check(9, "b158_round_int -2.7 -> -3", b158_round_int(-2.7) == -3)

// ===================================================================
//  #10-#14 Round ternary
// ===================================================================

check(10, "b158_round_ternary 0.4 -> 0", b158_round_ternary(0.4) == 0)
check(11, "b158_round_ternary 0.6 -> 1", b158_round_ternary(0.6) == 1)
check(12, "b158_round_ternary -0.6 -> -1", b158_round_ternary(-0.6) == -1)
check(13, "b158_round_ternary clip above (2.0 -> 1)", b158_round_ternary(2.0) == 1)
check(14, "b158_round_ternary clip below (-2.0 -> -1)", b158_round_ternary(-2.0) == -1)

// ===================================================================
//  #15-#17 Absmean
// ===================================================================

let w_basic = [0.2, -0.4, 0.6, -0.8]
let am_basic = b158_absmean(w_basic, 4)
// (0.2+0.4+0.6+0.8)/4 = 0.5
check(15, "b158_absmean basic (0.5)", t_approx(am_basic, 0.5, 0.0001))

let w_signed = [-1.0, -2.0, -3.0, -4.0]
let am_signed = b158_absmean(w_signed, 4)
check(16, "b158_absmean non-negative", am_signed >= 0.0 && t_approx(am_signed, 2.5, 0.0001))

let w_zero = [0.0, 0.0, 0.0, 0.0]
check(17, "b158_absmean zero input = 0", b158_absmean(w_zero, 4) == 0.0)

// ===================================================================
//  #18-#21 Quantize weight
// ===================================================================

let w_q = [0.1, 0.9, -0.3, -0.7, 0.5, 0.0, 1.0, -1.0]
let bt = b158_quantize_weight(w_q, 8)

let mut q_in_set = true
let mut i = 0

while i < 8 {
    let v = bt.q[i]
    if v != -1 {
        if v != 0 {
            if v != 1 { q_in_set = false }
        }
    }
}
check(18, "b158_quantize_weight q in {-1, 0, +1}", q_in_set)
check(19, "b158_quantize_weight tensor n=8", bt.n == 8)
check(20, "b158_quantize_weight scale > 0", bt.scale > 0.0)

let bt_zero = b158_quantize_weight(w_zero, 4)
let mut all_zero = true
let mut i = 0

while i < 4 {
    if bt_zero.q[i] != 0 { all_zero = false }
}
check(21, "b158_quantize_weight zero input -> all zero", all_zero && bt_zero.scale == 0.0)

// ===================================================================
//  #22-#23 Dequantize
// ===================================================================

// Sign of dequantized value should match the original (when nonzero
// in the quantized form). We test with a strongly-signed input where
// every entry is well clear of the rounding boundary.
let w_signs = [2.0, -3.0, 4.0, -5.0]
let bt_signs = b158_quantize_weight(w_signs, 4)
let dq_signs = b158_dequantize(bt_signs.q, bt_signs.scale, 4)
let mut signs_ok = true
let mut i = 0

while i < 4 {
    let orig = w_signs[i]
    let deq = dq_signs[i]
    if orig > 0.0 {
        if deq < 0.0 { signs_ok = false }
    }
    if orig < 0.0 {
        if deq > 0.0 { signs_ok = false }
    }
}
check(22, "b158_dequantize sign matches original", signs_ok)
check(23, "b158_dequantize length", len(dq_signs) == 4)

// ===================================================================
//  #24-#27 Activation quantize / dequantize
// ===================================================================

let act = [0.5, -1.5, 2.0, -2.0, 0.25, -0.75, 1.25, -0.5]
let aq = b158_activation_quantize(act, 8, 8)
// All codes must lie in [-127, +127] for nbits=8.
let mut act_bounded = true
let mut i = 0

while i < 8 {
    let v = aq.q[i]
    if v > 127 { act_bounded = false }
    if v < -127 { act_bounded = false }
}
check(24, "b158_activation_quantize bounded by nbits", act_bounded)
check(25, "b158_activation_quantize length", aq.n == 8 && len(aq.q) == 8)

let act_zero = [0.0, 0.0, 0.0, 0.0]
let aq_zero = b158_activation_quantize(act_zero, 4, 8)
let mut aq_all_zero = true
let mut i = 0

while i < 4 {
    if aq_zero.q[i] != 0 { aq_all_zero = false }
}
check(26, "b158_activation_quantize zero input -> zero codes", aq_all_zero && aq_zero.scale == 0.0)

// Round-trip should be close to the original under int8 (8 bits ~ 0.78%).
let dq_act = b158_activation_dequantize(aq)
let mut max_act_err = 0.0
let mut i = 0

while i < 8 {
    let e = t_abs(act[i] - dq_act[i])
    if e > max_act_err { max_act_err = e }
}
check(27, "b158_activation_dequantize roundtrip near (<= 0.05)", max_act_err < 0.05)

// ===================================================================
//  #28-#30 Matmul
// ===================================================================

// Identity check: q = I (3x3), scale = 1.0  ->  y = x
let I_q = [1, 0, 0, 0, 1, 0, 0, 0, 1]
let x_id = [0.5, -1.5, 2.25]
let y_id = b158_matmul(I_q, 1.0, x_id, 3, 3)
let mut id_ok = true
let mut i = 0

while i < 3 {
    if t_abs(y_id[i] - x_id[i]) > 0.0001 { id_ok = false }
}
check(28, "b158_matmul identity (q=I, scale=1) = x", id_ok)

// Shape: y is length rows.
let W_q2 = [1, -1, 0, 1, 1, -1, 0, 0, 1, -1, 1, 0]   // 4 rows x 3 cols
let x2 = [1.0, 2.0, 3.0]
let y2 = b158_matmul(W_q2, 0.5, x2, 4, 3)
check(29, "b158_matmul shape correctness", len(y2) == 4)

// Zero weights -> zero output (q all zero, scale arbitrary).
let W_zero = [0, 0, 0, 0, 0, 0]
let y_zero = b158_matmul(W_zero, 1.5, [1.0, -2.0, 3.0], 2, 3)
let mut yz_ok = true
let mut i = 0

while i < 2 {
    if y_zero[i] != 0.0 { yz_ok = false }
}
check(30, "b158_matmul zero weights -> zero output", yz_ok)

// ===================================================================
//  #31-#32 Layer forward
// ===================================================================

let y_layer = b158_layer_forward(W_q2, 0.5, x2, 4, 3)
check(31, "b158_layer_forward shape", len(y_layer) == 4)

let mut layer_eq = true
let mut i = 0

while i < 4 {
    if t_abs(y_layer[i] - y2[i]) > 1.0e-9 { layer_eq = false }
}
check(32, "b158_layer_forward equals matmul", layer_eq)

// ===================================================================
//  #33-#34 STE gradient
// ===================================================================

// In-clip region: |w / scale| <= 1  ->  grad_w = grad_q (passthrough).
let w_in = [0.1, -0.2, 0.3, -0.4]
let g_in = [1.0, 2.0, 3.0, 4.0]
let scale_in = 0.5   // |w/scale| in {0.2, 0.4, 0.6, 0.8} all <= 1
let grad_w_in = b158_straight_through_gradient(g_in, w_in, scale_in, 4)
let mut ste_pass_ok = true
let mut i = 0

while i < 4 {
    if grad_w_in[i] != g_in[i] { ste_pass_ok = false }
}
check(33, "STE passthrough in clip region", ste_pass_ok)

// Out-of-clip region: |w / scale| > 1  ->  grad_w = 0.
let w_out = [2.0, -3.0, 4.0, -5.0]
let g_out = [0.5, 0.5, 0.5, 0.5]
let scale_out = 1.0
let grad_w_out = b158_straight_through_gradient(g_out, w_out, scale_out, 4)
let mut ste_zero_ok = true
let mut i = 0

while i < 4 {
    if grad_w_out[i] != 0.0 { ste_zero_ok = false }
}
check(34, "STE zero outside clip region", ste_zero_ok)

// ===================================================================
//  #35 Train step descent
// ===================================================================

// w_new = w - lr * grad. With grad > 0 the new value is strictly less.
let w_pre = [1.0, 2.0, 3.0, 4.0]
let g_pre = [0.1, 0.2, 0.3, 0.4]
let lr = 0.5
let w_post = b158_train_step(w_pre, g_pre, lr, 4)
let mut step_ok = true
let mut i = 0

while i < 4 {
    let expected = w_pre[i] - lr * g_pre[i]
    if t_abs(w_post[i] - expected) > 1.0e-9 { step_ok = false }
    if w_post[i] >= w_pre[i] { step_ok = false }
}
check(35, "b158_train_step descent direction", step_ok)

// ===================================================================
//  #36 Param bytes ~ n/5
// ===================================================================

// 1.58 bits/param packed at 5 trits per byte → ceil(n/5) bytes.
// For n = 1000 we expect 200 bytes (each trit costs ~1.6 bits).
let pb = b158_param_bytes(1000)
check(36, "b158_param_bytes(1000) = 200", pb == 200)

// ===================================================================
//  #37 Compression ratio > 10x vs fp32
// ===================================================================

// fp32: 4 bytes/param. b1.58 packed: ~0.2 bytes/param (n/5).
// ratio ≈ 4 / 0.2 = 20x.
let fp32_bytes = 1000 * 4
let b158_bytes = b158_param_bytes(1000)
let ratio = b158_compression_ratio(fp32_bytes, b158_bytes)
check(37, "b158_compression_ratio > 10x", ratio > 10.0)

// ===================================================================
//  #38 Param count helper
// ===================================================================

check(38, "b158_param_count(8, 16) = 128", b158_param_count(8, 16) == 128)

// ── summary ─────────────────────────────────────────────────────
println("")
println("=== BitNet b1.58 test summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
