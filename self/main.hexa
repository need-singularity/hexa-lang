            // av[3] = subcmd (dump | dump-meta), av[4] = file
            let mut cv_args = [av[3], av[4]]
            let mut cvi = 5
            while cvi < len(av) {
                cv_args.push(av[cvi])
                cvi = cvi + 1
            }
            cmd_run(cv_script, cv_args)
