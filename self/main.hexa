                    // install_dir 에 없고 cwd 에도 없으면 $HEXA_LANG 시도.
                    let hl = env_var("HEXA_LANG")
                    if len(hl) > 0 {
                        let hl_path = hl + "/self/test_runner.hexa"
                        if file_exists(hl_path) { test_script = hl_path }
                    }
                }
            }
            let mut test_args = []
            let mut ti = 3
            while ti < len(av) {
                test_args.push(av[ti])
                ti = ti + 1
            }
            cmd_run(test_script, test_args)
        }
    } else if sub == "init" {
        // scaffold <dir>/project.hexa via tool/init_project.hexa
        // check/convergence 와 같은 패턴: install_dir 로 절대경로 해석 후 cmd_run 위임.
        if len(av) < 4 {
            println("error: 'init' requires <target-dir>")
