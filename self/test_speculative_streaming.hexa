// -- inlined from self/ml/speculative_streaming.hexa --
// codegen import not wired for test files

// ═══════════════════════════════════════════════════════════════════
//  self/ml/speculative_streaming.hexa — Speculative Streaming (#216)
//
//  HEXA-LANG ML #216 — Stream-based speculative decoding.
//  Instead of the classic "propose-K, verify-K, accept-some" cycle,
//  we maintain a RING of K parallel draft streams that continuously
//  generate ahead while the verifier catches up. Accepted tokens
//  slide the ring forward; rejected tokens invalidate specific
//  streams so they can be re-seeded without blocking the verifier.
//
//  Conceptually:
//
//    stream_0: [t0, t1, t2, t3]      (depth=4, conf=0.82)
//    stream_1: [t0, t1, t2', t3']    (depth=4, conf=0.77)   <-- diverged
//    stream_2: [t0, t1, t2'', ...]   (depth=3, conf=0.91)
//    stream_3: [t0, t1, t2, t3, t4]  (depth=5, conf=0.65)   <-- deepest
//
//  The verifier picks the highest-confidence stream for its next
//  verification batch, and slides the ring by the accepted prefix
//  length after each verification round.
//
//  API (all prefixed `specs_`):
//    specs_create_stream(max_depth, vocab)                -> dict
//    specs_create_ring(k, max_depth, vocab)               -> [dict]
//    specs_advance_stream(stream, draft_fn, vocab)        -> dict
//    specs_verify_tokens(stream, verified, n_verified)    -> int
//    specs_invalidate_stream(stream)                      -> dict
//    specs_select_best_stream(ring, k)                    -> int
//    specs_slide_ring(ring, k, accepted_prefix)           -> [dict]
//    specs_stream_length(stream)                          -> int
//    specs_confidence_product(stream, depth)              -> float
//    specs_merge_common_prefix(ring, k)                   -> int
//    specs_reset_ring(ring, k)                            -> [dict]
//    specs_generate(draft_fn, verifier_fn, prefix,
//                   n_new, k, max_depth, vocab)           -> [int]
//
//  Stream layout (dict):
//    tokens       : [int]    drafted tokens, len <= max_depth
//    confidences  : [float]  per-token draft confidence in (0,1]
//    valid        : int      1 = active, 0 = invalidated
//    depth        : int      current length of tokens
//    max_depth    : int      fixed capacity
//    vocab        : int      vocab size (for clamping)
//
//  Rules: HX4 SELF-HOST FIRST, HX5 AI-native, P1 no semicolons,
//         P4 native collections. @pure on math helpers only —
//         NEVER @hot on functions that mutate dict fields
//         (see feedback_hot_attr_dict_mutation.md).
// ═══════════════════════════════════════════════════════════════════

// ── math helpers ─────────────────────────────────────────────────
@pure
fn _specs_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

@pure
fn _specs_min_int(a, b) {
    if a < b { return a }
    return b
}

@pure
fn _specs_max_int(a, b) {
    if a > b { return a }
    return b
}

// Tail-hash style confidence: deterministic, in (0.0, 1.0].
// Uses the token id and position so deeper draft tokens decay.
@pure
fn _specs_token_conf(token, pos) {
    let mut h = (token + 1) * 2654435761 + (pos + 7) * 1315423911
    h = h % 997
    if h < 0 { h = 0 - h }
    // map to (0.5, 1.0] so the product doesn't vanish too fast in tests
    let f = 0.5 + to_float(h) / 1994.0
    return f
}

// ── factory ──────────────────────────────────────────────────────
// Create an empty stream with capacity max_depth.
@pure
fn specs_create_stream(max_depth, vocab) {
    return #{
        "tokens": [],
        "confidences": [],
        "valid": 1,
        "depth": 0,
        "max_depth": max_depth,
        "vocab": vocab
    }
}

// Create a ring of K parallel streams. Each stream starts empty.
@pure
fn specs_create_ring(k, max_depth, vocab) {
    let mut ring = []
    let mut i = 0
    while i < k {
        ring = ring + [specs_create_stream(max_depth, vocab)]
        i = i + 1
    }
    return ring
}

// ── stream advance ───────────────────────────────────────────────
// Extend stream by 1 drafted token. Calls draft_fn(tokens_so_far)
// which should return an int in [0, vocab). If the stream is full
// or invalidated, the call is a no-op.
fn specs_advance_stream(stream, draft_fn, vocab) {
    let mut s = stream
    if s["valid"] == 0 { return s }
    if s["depth"] >= s["max_depth"] { return s }
    let cur_tokens = s["tokens"]
    let raw = draft_fn(cur_tokens)
    // Clamp to [0, vocab)
    let mut tok = raw % vocab
    if tok < 0 { tok = tok + vocab }
    let pos = s["depth"]
    let conf = _specs_token_conf(tok, pos)
    s["tokens"] = cur_tokens + [tok]
    s["confidences"] = s["confidences"] + [conf]
    s["depth"] = pos + 1
    return s
}

// ── verification ─────────────────────────────────────────────────
// Compare the first n_verified drafted tokens against verified[].
// Returns the count of matching tokens from position 0 until the
// first mismatch. A stream is *not* invalidated here — the caller
// decides, based on the returned number, whether to slide or
// invalidate.
@pure
fn specs_verify_tokens(stream, verified, n_verified) {
    let drafted = stream["tokens"]
    let cap = _specs_min_int(len(drafted), n_verified)
    let mut accepted = 0
    let mut i = 0
    let mut stop = 0
    while i < cap {
        if stop == 0 {
            if drafted[i] == verified[i] {
                accepted = accepted + 1
            } else {
                stop = 1
            }
        }
        i = i + 1
    }
    return accepted
}

// Mark a stream as invalidated. Tokens and confidences preserved
// so callers can still inspect the previous draft, but `valid=0`.
@pure
fn specs_invalidate_stream(stream) {
    let mut s = stream
    s["valid"] = 0
    return s
}

// ── ring scheduling ──────────────────────────────────────────────
// Pick the index of the highest-confidence valid stream. Scored by
// sum of log-ish confidences (we use the raw product since probs
// are ≥0.5, which keeps arithmetic simple and monotone). Ties
// resolved by smallest index. Returns -1 if all streams invalid.
@pure
fn specs_select_best_stream(ring, k) {
    let mut best_idx = -1
    let mut best_score = -1.0
    let mut i = 0
    while i < k {
        let s = ring[i]
        if s["valid"] == 1 {
            let score = specs_confidence_product(s, s["depth"])
            if score > best_score {
                best_score = score
                best_idx = i
            }
        }
        i = i + 1
    }
    return best_idx
}

// Slide every stream forward by `accepted_prefix` tokens:
// drop the first N tokens/confidences from each, shrink depth,
// and keep `valid` as-is. Empty-after-slide streams stay valid
// but depth=0 so they can be advanced again.
@pure
fn specs_slide_ring(ring, k, accepted_prefix) {
    let mut out = []
    let mut i = 0
    while i < k {
        let s = ring[i]
        let d = s["depth"]
        let take = _specs_min_int(accepted_prefix, d)
        let mut new_tokens = []
        let mut new_confs = []
        let mut j = take
        while j < d {
            new_tokens = new_tokens + [s["tokens"][j]]
            new_confs = new_confs + [s["confidences"][j]]
            j = j + 1
        }
        let mut ns = s
        ns["tokens"] = new_tokens
        ns["confidences"] = new_confs
        ns["depth"] = d - take
        out = out + [ns]
        i = i + 1
    }
    return out
}

// ── stream introspection ─────────────────────────────────────────
@pure
fn specs_stream_length(stream) {
    return stream["depth"]
}

// Product of per-token confidences for the first `depth` tokens.
// Empty stream => 1.0. Result is in (0.0, 1.0] for confs in (0,1].
@pure
fn specs_confidence_product(stream, depth) {
    let d = _specs_min_int(depth, stream["depth"])
    let confs = stream["confidences"]
    let mut prod = 1.0
    let mut i = 0
    while i < d {
        prod = prod * confs[i]
        i = i + 1
    }
    return prod
}

// ── common-prefix merge ──────────────────────────────────────────
// Scan every valid stream in the ring and return the length of the
// longest common prefix that all valid streams share. If there are
// no valid streams returns 0.
@pure
fn specs_merge_common_prefix(ring, k) {
    // find first valid stream as pivot
    let mut pivot = -1
    let mut i = 0
    while i < k {
        if ring[i]["valid"] == 1 { pivot = i i = k } else { i = i + 1 }
    }
    if pivot < 0 { return 0 }
    let pivot_s = ring[pivot]
    let pivot_tokens = pivot_s["tokens"]
    let pivot_depth = pivot_s["depth"]
    // walk positions 0..pivot_depth and check agreement
    let mut common = 0
    let mut p = 0
    let mut halted = 0
    while p < pivot_depth {
        if halted == 0 {
            let pt = pivot_tokens[p]
            let mut agree = 1
            let mut q = 0
            while q < k {
                let sq = ring[q]
                if sq["valid"] == 1 {
                    if sq["depth"] <= p {
                        agree = 0
                    } else {
                        if sq["tokens"][p] != pt {
                            agree = 0
                        }
                    }
                }
                q = q + 1
            }
            if agree == 1 {
                common = common + 1
            } else {
                halted = 1
            }
        }
        p = p + 1
    }
    return common
}

// ── ring reset ───────────────────────────────────────────────────
// Clear every stream in the ring: tokens=[], depth=0, valid=1.
// Preserves max_depth and vocab.
@pure
fn specs_reset_ring(ring, k) {
    let mut out = []
    let mut i = 0
    while i < k {
        let s = ring[i]
        let md = s["max_depth"]
        let vo = s["vocab"]
        out = out + [specs_create_stream(md, vo)]
        i = i + 1
    }
    return out
}

// ── full generate loop ───────────────────────────────────────────
// Continuously draft into every stream, verify the best one,
// slide the ring, repeat. Returns the full extended sequence
// (prefix + n_new generated tokens).
//
//   draft_fn(ctx)         -> int     proposes next token given ctx
//   verifier_fn(ctx, n)   -> [int]   emits n "golden" tokens
//
// Uses a guard bound so no step can loop forever.
fn specs_generate(draft_fn, verifier_fn, prefix, n_new, k, max_depth, vocab) {
    let mut cur = []
    let mut i = 0
    while i < len(prefix) {
        cur = cur + [prefix[i]]
        i = i + 1
    }
    if n_new <= 0 { return cur }
    let mut ring = specs_create_ring(k, max_depth, vocab)
    let mut produced = 0
    let mut guard = 0
    let hard_limit = n_new * 8 + 32
    while produced < n_new {
        if guard >= hard_limit {
            // Safety hatch: force verifier-only progress for remaining tokens.
            let need = n_new - produced
            let forced = verifier_fn(cur, need)
            let mut f = 0
            while f < len(forced) {
                if produced < n_new {
                    cur = cur + [forced[f]]
                    produced = produced + 1
                }
                f = f + 1
            }
            produced = n_new
        } else {
            // 1. Advance every valid stream by 1.
            let mut r2 = []
            let mut si = 0
            while si < k {
                let s = ring[si]
                let s2 = specs_advance_stream(s, draft_fn, vocab)
                r2 = r2 + [s2]
                si = si + 1
            }
            ring = r2

            // 2. Select the best stream and verify its drafted tokens.
            let best = specs_select_best_stream(ring, k)
            if best < 0 {
                ring = specs_reset_ring(ring, k)
                guard = guard + 1
            } else {
                let bs = ring[best]
                let depth = bs["depth"]
                if depth == 0 {
                    guard = guard + 1
                } else {
                    let verified = verifier_fn(cur, depth)
                    let n_acc = specs_verify_tokens(bs, verified, len(verified))
                    // 3. Commit accepted tokens (at least 1 to guarantee progress).
                    let commit = if n_acc > 0 { n_acc } else { 1 }
                    let remain = n_new - produced
                    let take = _specs_min_int(commit, remain)
                    let drafted = bs["tokens"]
                    let mut c = 0
                    while c < take {
                        if c < n_acc {
                            cur = cur + [drafted[c]]
                        } else {
                            cur = cur + [verified[c]]
                        }
                        c = c + 1
                    }
                    produced = produced + take
                    // 4. Slide ring by take (never by more than slide_by).
                    ring = specs_slide_ring(ring, k, take)
                    // 5. Invalidate streams that diverged at position n_acc.
                    if n_acc < len(verified) {
                        let mut vi = 0
                        while vi < k {
                            let sv = ring[vi]
                            if sv["valid"] == 1 {
                                if sv["depth"] > 0 {
                                    // If its first surviving token disagrees with the
                                    // next verified token, invalidate.
                                    // (cheap heuristic — keeps the ring fresh.)
                                    let nxt = sv["tokens"][0]
                                    if n_acc < len(verified) {
                                        if nxt != verified[n_acc] {
                                            ring[vi] = specs_invalidate_stream(sv)
                                        }
                                    }
                                }
                            }
                            vi = vi + 1
                        }
                    }
                    // 6. If all invalidated, reset.
                    let any_best = specs_select_best_stream(ring, k)
                    if any_best < 0 {
                        ring = specs_reset_ring(ring, k)
                    }
                    guard = guard + 1
                }
            }
        }
    }
    return cur
}


// -- end inlined --

fn fabs_s(x) { if x < 0.0 { return 0.0 - x } return x }

let mut pass = 0
let mut fail = 0
fn check(n, name, cond) {
    if cond {
        println("[PASS] #" + to_string(n) + " " + name)
        pass = pass + 1
    } else {
        println("[FAIL] #" + to_string(n) + " " + name)
        fail = fail + 1
    }
}

println("=== Speculative Streaming test suite (#216) ===")

let VOCAB = 16
let DEPTH = 4
let K_RING = 3

// ─── #1-#2 create_stream ──────────────────────────────────────
let s0 = specs_create_stream(DEPTH, VOCAB)
check(1, "create_stream fields",
    s0["max_depth"] == DEPTH && s0["vocab"] == VOCAB && s0["valid"] == 1)
check(2, "create_stream depth=0", s0["depth"] == 0 && len(s0["tokens"]) == 0)

// ─── #3-#4 create_ring ────────────────────────────────────────
let ring0 = specs_create_ring(K_RING, DEPTH, VOCAB)
check(3, "create_ring k=3", len(ring0) == K_RING)
let mut all_valid = true
let mut i = 0

while i < K_RING { if ring0[i]["valid"] != 1 { all_valid = false } }
check(4, "create_ring streams valid", all_valid)

// ─── #5-#7 advance_stream ─────────────────────────────────────
fn draft_simple(ctx) { return len(ctx) + 5 }

let s1 = specs_advance_stream(s0, draft_simple, VOCAB)
check(5, "advance_stream depth=1", s1["depth"] == 1)
check(6, "advance_stream token in [0,vocab)", s1["tokens"][0] >= 0 && s1["tokens"][0] < VOCAB)
check(7, "advance_stream confidence > 0", s1["confidences"][0] > 0.0)

// ─── #8-#9 advance no-op cases ────────────────────────────────
let s_inv = specs_invalidate_stream(s1)
let s_inv2 = specs_advance_stream(s_inv, draft_simple, VOCAB)
check(8, "advance invalidated -> no-op", s_inv2["depth"] == s1["depth"])

// Fill to max depth
let mut s_full = s0
let mut _i = 0

while _i < DEPTH { s_full = specs_advance_stream(s_full, draft_simple, VOCAB) }
let s_full2 = specs_advance_stream(s_full, draft_simple, VOCAB)
check(9, "advance at max_depth -> no-op", s_full2["depth"] == DEPTH)

// ─── #10-#13 verify_tokens ────────────────────────────────────
let drafted_toks = s_full["tokens"]
let n_acc_all = specs_verify_tokens(s_full, drafted_toks, len(drafted_toks))
check(10, "verify all match", n_acc_all == DEPTH)

let mut bad = []
let mut i = 0

while i < DEPTH { bad = bad + [drafted_toks[i]] }
bad[1] = drafted_toks[1] + 1
let n_acc_partial = specs_verify_tokens(s_full, bad, len(bad))
check(11, "verify partial match", n_acc_partial == 1)

let wrong = [999, 998, 997, 996]
let n_acc_none = specs_verify_tokens(s_full, wrong, 4)
check(12, "verify no match", n_acc_none == 0)

let n_acc_empty = specs_verify_tokens(s0, [], 0)
check(13, "verify empty stream = 0", n_acc_empty == 0)

// ─── #14-#15 invalidate_stream ────────────────────────────────
let inv = specs_invalidate_stream(s_full)
check(14, "invalidate valid->0", inv["valid"] == 0)
check(15, "invalidate preserves tokens", len(inv["tokens"]) == DEPTH)

// ─── #16-#17 select_best_stream ───────────────────────────────
// Build ring with one valid full stream
// s_full has depth>0 (valid), s0 is invalidated. Only s_full should be picked.
let s_inv_sel = specs_invalidate_stream(specs_create_stream(DEPTH, VOCAB))
let ring_sel = [s_full, s_inv_sel, s_inv_sel]
let best_idx = specs_select_best_stream(ring_sel, 3)
check(16, "select_best picks valid", best_idx == 0)

let ring_inv = [specs_invalidate_stream(s0), specs_invalidate_stream(s0)]
let best_inv = specs_select_best_stream(ring_inv, 2)
check(17, "select_best all invalid -> -1", best_inv == -1)

// ─── #18-#19 slide_ring ──────────────────────────────────────
let ring_full = [s_full, s_full, s_full]
let slid = specs_slide_ring(ring_full, 3, 2)
check(18, "slide_ring removes prefix", slid[0]["depth"] == DEPTH - 2)
check(19, "slide_ring depth decreases", slid[1]["depth"] < DEPTH)

// ─── #20-#21 stream_length / confidence ───────────────────────
check(20, "stream_length == depth", specs_stream_length(s_full) == DEPTH)

let cp_empty = specs_confidence_product(s0, 0)
check(21, "confidence_product empty = 1.0", fabs_s(cp_empty - 1.0) < 1.0e-9)

let cp = specs_confidence_product(s_full, DEPTH)
check(22, "confidence_product non-empty > 0", cp > 0.0)
check(23, "confidence_product <= 1.0", cp <= 1.0 + 1.0e-9)

// ─── #24-#26 merge_common_prefix ──────────────────────────────
let ring_same = [s_full, s_full, s_full]
let common_same = specs_merge_common_prefix(ring_same, 3)
check(24, "merge_common_prefix identical streams", common_same == DEPTH)

// Build two streams with different token sequences manually
let s_mA = #{ "tokens": [1, 2, 3, 4], "confidences": [0.9, 0.9, 0.9, 0.9], "valid": 1, "depth": 4, "max_depth": DEPTH, "vocab": VOCAB }
let s_mB = #{ "tokens": [1, 2, 9, 9], "confidences": [0.9, 0.9, 0.9, 0.9], "valid": 1, "depth": 4, "max_depth": DEPTH, "vocab": VOCAB }
let ring_mix = [s_mA, s_mB]
let common_mix = specs_merge_common_prefix(ring_mix, 2)
// Tokens match at pos 0,1 but differ at pos 2
check(25, "merge_common_prefix diverge at pos 2", common_mix == 2)

let ring_nv = [specs_invalidate_stream(s0)]
check(26, "merge_common_prefix no valid = 0", specs_merge_common_prefix(ring_nv, 1) == 0)

// ─── #27-#28 reset_ring ──────────────────────────────────────
let ring_res = specs_reset_ring(ring_full, 3)
let mut all_zero_d = true
let mut all_valid_r = true
let mut i = 0

while i < 3 {
    if ring_res[i]["depth"] != 0 { all_zero_d = false }
    if ring_res[i]["valid"] != 1 { all_valid_r = false }
}
check(27, "reset_ring all depth=0", all_zero_d)
check(28, "reset_ring all valid=1", all_valid_r)

// ─── #29-#31 generate ─────────────────────────────────────────
fn draft_gen(ctx) { return (len(ctx) * 7 + 3) % VOCAB }
fn verifier_gen(ctx, n) {
    let mut out = []
    let mut i = 0
    while i < n {
        out = out + [(len(ctx) * 7 + 3 + i) % VOCAB]
        i = i + 1
    }
    return out
}

let prefix = [1, 2, 3]
let result = specs_generate(draft_gen, verifier_gen, prefix, 5, 3, 4, VOCAB)
check(29, "generate extends prefix", len(result) >= len(prefix))
check(30, "generate length = prefix + n_new", len(result) == 8)
let mut prefix_ok = true
let mut i = 0

while i < 3 { if result[i] != prefix[i] { prefix_ok = false } }
check(31, "generate preserves prefix", prefix_ok)

// ─── #32 advance multiple steps ──────────────────────────────
let mut s_multi = s0
let mut _i = 0

while _i < 3 { s_multi = specs_advance_stream(s_multi, draft_simple, VOCAB) }
check(32, "advance multiple steps depth=3", s_multi["depth"] == 3 && len(s_multi["tokens"]) == 3)

// ─── #33 select_best prefers deeper confident stream ──────────
let mut s_deep = s0
let mut _i = 0

while _i < 4 { s_deep = specs_advance_stream(s_deep, draft_simple, VOCAB) }
let mut s_shallow = s0
s_shallow = specs_advance_stream(s_shallow, draft_simple, VOCAB)
let ring_pref = [s_shallow, s_deep]
let pref_best = specs_select_best_stream(ring_pref, 2)
check(33, "select_best prefers deeper confident", pref_best >= 0)

// ─── #34 slide then advance ──────────────────────────────────
let ring_sa = [s_full]
let slid_sa = specs_slide_ring(ring_sa, 1, 1)
let adv_sa = specs_advance_stream(slid_sa[0], draft_simple, VOCAB)
check(34, "slide then advance works", adv_sa["depth"] == DEPTH - 1 + 1)

// ─── #35 confidence deterministic ─────────────────────────────
let s_a = specs_advance_stream(s0, draft_simple, VOCAB)
let s_b = specs_advance_stream(s0, draft_simple, VOCAB)
check(35, "confidence deterministic", fabs_s(s_a["confidences"][0] - s_b["confidences"][0]) < 1.0e-12)

println("")
println("=== Speculative Streaming test summary ===")
println("PASS: " + to_string(pass))
println("FAIL: " + to_string(fail))
println("TOTAL: " + to_string(pass + fail))
