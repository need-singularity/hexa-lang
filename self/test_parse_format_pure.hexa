// ═══════════════════════════════════════════════════════════════════
//  test_parse_format_pure.hexa — coverage for parse_format_pure.hexa
//
//  Covers: parse_int_base_pure, parse_hex_pure, parse_bin_pure,
//          hex_str_upper_pure, zfill_pure
//
//  Pitfalls honored: P1 no semicolons, P15 let mut, P29 push rebind,
//  P39 no 0b literals, P50 no bit-shift operators.
// ═══════════════════════════════════════════════════════════════════

// ── INLINED from runtime/parse_format_pure.hexa ──

@pure
fn _pf_digit_val(ch) {
    if type_of(ch) != "string" { return -1 }
    if len(ch) == 0 { return -1 }
    let o = ord(ch.substring(0, 1))
    if o >= 48 && o <= 57  { return o - 48 }
    if o >= 97 && o <= 122 { return o - 97 + 10 }
    if o >= 65 && o <= 90  { return o - 65 + 10 }
    -1
}

@pure
pub fn parse_int_base_pure(s, base) {
    if type_of(s) != "string" { return 0 }
    if type_of(base) != "int"  { return 0 }
    if base < 2 || base > 36   { return 0 }
    let n = len(s)
    if n == 0 { return 0 }
    let mut i = 0
    while i < n {
        let ch = s.substring(i, i + 1)
        if ch == " " || ch == "\t" || ch == "\n" || ch == "\r" {
            i = i + 1
        } else {
            break
        }
    }
    if i >= n { return 0 }
    let mut sign = 1
    let ch0 = s.substring(i, i + 1)
    if ch0 == "+" {
        i = i + 1
    } else if ch0 == "-" {
        sign = 0 - 1
        i = i + 1
    }
    let mut val = 0
    let mut consumed = false
    while i < n {
        let digit = _pf_digit_val(s.substring(i, i + 1))
        if digit < 0     { break }
        if digit >= base { break }
        val = val * base + digit
        consumed = true
        i = i + 1
    }
    if consumed == false { return 0 }
    val * sign
}

@pure
pub fn parse_hex_pure(s) {
    if type_of(s) != "string" { return 0 }
    let n = len(s)
    if n == 0 { return 0 }
    let mut i = 0
    while i < n {
        let ch = s.substring(i, i + 1)
        if ch == " " || ch == "\t" || ch == "\n" || ch == "\r" {
            i = i + 1
        } else {
            break
        }
    }
    if i >= n { return 0 }
    let mut sign = 1
    let ch0 = s.substring(i, i + 1)
    if ch0 == "+" {
        i = i + 1
    } else if ch0 == "-" {
        sign = 0 - 1
        i = i + 1
    }
    if i + 1 < n {
        let p0 = s.substring(i, i + 1)
        let p1 = s.substring(i + 1, i + 2)
        if p0 == "0" && (p1 == "x" || p1 == "X") {
            i = i + 2
        }
    }
    let mut val = 0
    let mut consumed = false
    while i < n {
        let digit = _pf_digit_val(s.substring(i, i + 1))
        if digit < 0   { break }
        if digit >= 16 { break }
        val = val * 16 + digit
        consumed = true
        i = i + 1
    }
    if consumed == false { return 0 }
    val * sign
}

@pure
pub fn parse_bin_pure(s) {
    if type_of(s) != "string" { return 0 }
    let n = len(s)
    if n == 0 { return 0 }
    let mut i = 0
    while i < n {
        let ch = s.substring(i, i + 1)
        if ch == " " || ch == "\t" || ch == "\n" || ch == "\r" {
            i = i + 1
        } else {
            break
        }
    }
    if i >= n { return 0 }
    let mut sign = 1
    let ch0 = s.substring(i, i + 1)
    if ch0 == "+" {
        i = i + 1
    } else if ch0 == "-" {
        sign = 0 - 1
        i = i + 1
    }
    if i + 1 < n {
        let p0 = s.substring(i, i + 1)
        let p1 = s.substring(i + 1, i + 2)
        if p0 == "0" && (p1 == "b" || p1 == "B") {
            i = i + 2
        }
    }
    let mut val = 0
    let mut consumed = false
    while i < n {
        let ch = s.substring(i, i + 1)
        let o = ord(ch)
        if o == 48 {
            val = val * 2
            consumed = true
            i = i + 1
        } else if o == 49 {
            val = val * 2 + 1
            consumed = true
            i = i + 1
        } else {
            break
        }
    }
    if consumed == false { return 0 }
    val * sign
}

@pure
pub fn hex_str_upper_pure(n) {
    if type_of(n) != "int" { return "0" }
    if n == 0 { return "0" }
    let digits = "0123456789ABCDEF"
    let mut v = n
    let mut neg = false
    if v < 0 {
        neg = true
        v = 0 - v
    }
    let mut parts = []
    while v > 0 {
        let d = v % 16
        parts.push(digits.substring(d, d + 1))
        v = v / 16
    }
    let plen = len(parts)
    let mut rev = []
    let mut i = plen - 1
    while i >= 0 {
        rev.push(parts[i])
        i = i - 1
    }
    if neg { return "-" + rev.join("") }
    rev.join("")
}

@pure
pub fn zfill_pure(n, width) {
    if type_of(width) != "int" { return to_string(n) }
    let mut neg = false
    let mut v = 0
    if type_of(n) == "int" {
        v = n
        if v < 0 {
            neg = true
            v = 0 - v
        }
    }
    let digits = "0123456789"
    let mut body = ""
    if v == 0 {
        body = "0"
    } else {
        let mut parts = []
        let mut vv = v
        while vv > 0 {
            let d = vv % 10
            parts.push(digits.substring(d, d + 1))
            vv = vv / 10
        }
        let plen = len(parts)
        let mut i = plen - 1
        let mut rev = []
        while i >= 0 {
            rev.push(parts[i])
            i = i - 1
        }
        body = rev.join("")
    }
    let mut digit_width = width
    if neg { digit_width = width - 1 }
    if digit_width < 0 { digit_width = 0 }
    let blen = len(body)
    if blen >= digit_width {
        if neg { return "-" + body }
        return body
    }
    let missing = digit_width - blen
    let mut zeros = []
    let mut k = 0
    while k < missing {
        zeros.push("0")
        k = k + 1
    }
    let pad = zeros.join("")
    if neg { return "-" + pad + body }
    pad + body
}

// ── end inlined ──

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  Pure-Hexa parse/format extension tests")
println("═══════════════════════════════════════════════════════")

// ── parse_int_base_pure ─────────────────────────────────
println("--- parse_int_base_pure ---")
check("base 10 42",       parse_int_base_pure("42", 10),      42)
check("base 10 -7",       parse_int_base_pure("-7", 10),      -7)
check("base 2 '1010'",    parse_int_base_pure("1010", 2),     10)
check("base 2 '11111111'",parse_int_base_pure("11111111", 2), 255)
check("base 8 '777'",     parse_int_base_pure("777", 8),      511)
check("base 16 'ff'",     parse_int_base_pure("ff", 16),      255)
check("base 16 'DEAD'",   parse_int_base_pure("DEAD", 16),    57005)
check("base 36 'Z'",      parse_int_base_pure("Z", 36),       35)
check("base 36 'zz'",     parse_int_base_pure("zz", 36),      1295)
check("base 10 empty",    parse_int_base_pure("", 10),        0)
check("base 10 garbage",  parse_int_base_pure("xyz", 10),     0)
check("base 2 invalid",   parse_int_base_pure("102", 2),      2) // stops at '2'
check("base invalid 1",   parse_int_base_pure("42", 1),       0)
check("base invalid 37",  parse_int_base_pure("42", 37),      0)
check("base ws + sign",   parse_int_base_pure("  -ff", 16),   -255)

// ── parse_hex_pure ──────────────────────────────────────
println("--- parse_hex_pure ---")
check("hex '0x1F'",       parse_hex_pure("0x1F"),   31)
check("hex bare '1f'",    parse_hex_pure("1f"),     31)
check("hex '0X10'",       parse_hex_pure("0X10"),   16)
check("hex '-0xA'",       parse_hex_pure("-0xA"),   -10)
check("hex bare '-ff'",   parse_hex_pure("-ff"),    -255)
check("hex '  0xABC'",    parse_hex_pure("  0xABC"),2748)
check("hex empty",        parse_hex_pure(""),       0)
check("hex garbage",      parse_hex_pure("xyz"),    0)

// ── parse_bin_pure ──────────────────────────────────────
println("--- parse_bin_pure ---")
check("bin '0b101'",      parse_bin_pure("0b101"),  5)
check("bin bare '101'",   parse_bin_pure("101"),    5)
check("bin '0B1111'",     parse_bin_pure("0B1111"), 15)
check("bin '-1010'",      parse_bin_pure("-1010"),  -10)
check("bin '  0b11'",     parse_bin_pure("  0b11"), 3)
check("bin stops at '2'", parse_bin_pure("1012"),   5)
check("bin empty",        parse_bin_pure(""),       0)
check("bin garbage",      parse_bin_pure("xyz"),    0)

// ── hex_str_upper_pure ──────────────────────────────────
println("--- hex_str_upper_pure ---")
check("hex_up 0",         hex_str_upper_pure(0),    "0")
check("hex_up 15",        hex_str_upper_pure(15),   "F")
check("hex_up 31",        hex_str_upper_pure(31),   "1F")
check("hex_up 255",       hex_str_upper_pure(255),  "FF")
check("hex_up 2748",      hex_str_upper_pure(2748), "ABC")
check("hex_up 65535",     hex_str_upper_pure(65535),"FFFF")
check("hex_up -16",       hex_str_upper_pure(-16),  "-10")
check("hex_up non-int",   hex_str_upper_pure("x"),  "0")

// ── zfill_pure ──────────────────────────────────────────
println("--- zfill_pure ---")
check("zfill(7,3)",       zfill_pure(7, 3),         "007")
check("zfill(0,4)",       zfill_pure(0, 4),         "0000")
check("zfill(123,5)",     zfill_pure(123, 5),       "00123")
check("zfill(1234,2)",    zfill_pure(1234, 2),      "1234") // no truncation
check("zfill(-7,3)",      zfill_pure(-7, 3),        "-07")
check("zfill(-1,4)",      zfill_pure(-1, 4),        "-001")
check("zfill(42,0)",      zfill_pure(42, 0),        "42")

// Round-trip: parse → format → parse.
println("--- round-trips ---")
check("rt hex 255",       parse_hex_pure(hex_str_upper_pure(255)),   255)
check("rt base16 upper",  parse_int_base_pure(hex_str_upper_pure(12345), 16), 12345)
check("rt zfill 7",       parse_int_base_pure(zfill_pure(7, 5), 10), 7)

println("")
println("═══════════════════════════════════════════════════════")
println("  " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
if fail_count == 0 {
    println("  ALL PASS")
} else {
    println("  FAILURES")
}
println("═══════════════════════════════════════════════════════")
