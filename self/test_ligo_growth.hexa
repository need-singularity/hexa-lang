// ===================================================================
//  test_ligo_growth.hexa — LiGO Growth (#346) tests
//
//  Verifies:
//    1.  ligo_zeros produces correct length
//    2.  ligo_eye is identity
//    3.  ligo_matmul identity property
//    4.  ligo_matvec identity property
//    5.  Width operator identity block
//    6.  Width operator correct shape (D x d)
//    7.  Depth operator row sums = 1.0
//    8.  Depth operator first/last rows correct
//    9.  Grow vector preserves first d elements
//   10.  Grow matrix with identity operators = original
//   11.  Layer forward arithmetic
//   12.  Width growth preserves model dimension
//   13.  Depth growth preserves model dimension
//   14.  Full growth produces correct dimensions
//   15.  Function preservation: width-only growth error is small
//   16.  Function preservation: depth-only growth error is small
//   17.  Growth ratio computation
//   18.  Width operator verification
//   19.  Depth operator verification
//   20.  Grow model end-to-end: dimensions check
//
//  Run: ./hexa self/test_ligo_growth.hexa
// ===================================================================

import "ml/ligo_growth.hexa"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(v) {
    if v < 0.0 { return 0.0 - v }
    return v
}
fn approx(a, b, eps) { return fabs(a - b) < eps }

println("===================================================================")
println("  LiGO Growth (#346) Test Suite")
println("===================================================================")

// ── Test 1: ligo_zeros
let z4 = ligo_zeros(4)
check("zeros length 4", len(z4) == 4)
check("zeros all zero", z4[0] == 0.0)

// ── Test 2: ligo_eye
let I3 = ligo_eye(3)
check("eye(3) diagonal", I3[0] == 1.0)
check("eye(3) off-diag", I3[1] == 0.0)
check("eye(3) [1,1]", I3[4] == 1.0)
check("eye(3) [2,2]", I3[8] == 1.0)

// ── Test 3: matmul with identity
let A = [1.0, 2.0, 3.0, 4.0]
let I2 = ligo_eye(2)
let R = ligo_matmul(A, I2, 2, 2, 2)
check("matmul A@I = A [0,0]", approx(R[0], 1.0, 1.0e-9))
check("matmul A@I = A [0,1]", approx(R[1], 2.0, 1.0e-9))
check("matmul A@I = A [1,0]", approx(R[2], 3.0, 1.0e-9))
check("matmul A@I = A [1,1]", approx(R[3], 4.0, 1.0e-9))

// ── Test 4: matvec with identity
let x2 = [5.0, 7.0]
let y2 = ligo_matvec(I2, x2, 2, 2)
check("matvec I@x = x [0]", approx(y2[0], 5.0, 1.0e-9))
check("matvec I@x = x [1]", approx(y2[1], 7.0, 1.0e-9))

// ── Test 5: width operator identity block
let d = 3
let D = 5
let G_w = ligo_width_operator(d, D, 42)
check("G_width[0,0]=1", approx(G_w[0 * d + 0], 1.0, 1.0e-9))
check("G_width[1,1]=1", approx(G_w[1 * d + 1], 1.0, 1.0e-9))
check("G_width[2,2]=1", approx(G_w[2 * d + 2], 1.0, 1.0e-9))
check("G_width[0,1]=0", approx(G_w[0 * d + 1], 0.0, 1.0e-9))

// ── Test 6: width operator shape
check("G_width length = D*d", len(G_w) == D * d)

// ── Test 7: depth operator row sums
let L = 3
let Lp = 5
let G_d = ligo_depth_operator(L, Lp)
let mut depth_rows_ok = true
let mut i = 0

while i < Lp {
    let mut row_sum = 0.0
    let mut j = 0

    while j < L {
        row_sum = row_sum + G_d[i * L + j]
    }
    if fabs(row_sum - 1.0) > 1.0e-9 {
        depth_rows_ok = false
    }
}
check("depth operator rows sum to 1", depth_rows_ok)

// ── Test 8: depth operator first/last
check("depth[0] maps to layer 0", approx(G_d[0 * L + 0], 1.0, 1.0e-9))
check("depth[last] maps to layer L-1", approx(G_d[(Lp - 1) * L + (L - 1)], 1.0, 1.0e-9))

// ── Test 9: grow vector preserves first d elements
let v_small = [1.0, 2.0, 3.0]
let v_grown = ligo_grow_vector(v_small, G_w, D, d)
check("grown vec length = D", len(v_grown) == D)
check("grown vec[0] preserved", approx(v_grown[0], 1.0, 1.0e-9))
check("grown vec[1] preserved", approx(v_grown[1], 2.0, 1.0e-9))
check("grown vec[2] preserved", approx(v_grown[2], 3.0, 1.0e-9))

// ── Test 10: grow matrix with identity operators = original
// Build diagonal matrix explicitly to avoid COW pitfalls
let mut W_diag = ligo_zeros(9)
W_diag[0] = 1.0
W_diag[4] = 2.0
W_diag[8] = 3.0
let I3a = ligo_eye(3)
let I3b = ligo_eye(3)
let W_id = ligo_grow_matrix(W_diag, I3a, I3b, 3, 3, 3, 3)
check("grow W with I preserves [0,0]", approx(W_id[0], 1.0, 1.0e-9))
check("grow W with I preserves [1,1]", approx(W_id[4], 2.0, 1.0e-9))
check("grow W with I preserves [2,2]", approx(W_id[8], 3.0, 1.0e-9))

// ── Test 11: layer forward
let layer1 = ligo_make_layer([1.0, 0.0, 0.0, 1.0], [0.5, -0.5], 2, 2)
let y_layer = ligo_layer_forward(layer1, [3.0, 4.0])
check("layer forward [0]", approx(y_layer[0], 3.5, 1.0e-9))
check("layer forward [1]", approx(y_layer[1], 3.5, 1.0e-9))

// ── Test 12: create and width-grow model
let small = ligo_create_small_model(3, 2, 100)
check("small model d=3", small["d"] == 3)
check("small model L=2", small["L"] == 2)

let wide = ligo_grow_width(small, 5, 42)
check("wide model d=5", wide["d"] == 5)
check("wide model L=2", wide["L"] == 2)
check("wide layer[0] in_dim=5", wide["layers"][0]["in_dim"] == 5)
check("wide layer[0] out_dim=5", wide["layers"][0]["out_dim"] == 5)

// ── Test 13: depth-grow model
let deep = ligo_grow_depth(small, 4)
check("deep model d=3", deep["d"] == 3)
check("deep model L=4", deep["L"] == 4)
check("deep has 4 layers", len(deep["layers"]) == 4)

// ── Test 14: full growth
let big = ligo_grow_model(small, 5, 4, 42)
check("big model d=5", big["d"] == 5)
check("big model L=4", big["L"] == 4)

// ── Test 15: function preservation (width only)
// With identity block in G_width, the first d outputs should
// be close to the small model outputs.
let mut test_inputs = []
let mut i = 0

while i < 4 {
    let mut inp = []
    let mut j = 0

    while j < 3 {
        inp = inp + [ligo_hash(200 + i, j) * 2.0]
    }
    test_inputs = test_inputs + [inp]
}
let wide2 = ligo_grow_width(small, 5, 42)
let fp_err_w = ligo_function_preservation_error(small, wide2, test_inputs)
check("width growth func preservation err < 0.1", fp_err_w < 0.1)

// ── Test 16: function preservation (depth only)
// Depth growth with interpolation should closely match.
let deep2 = ligo_grow_depth(small, 4)
let fp_err_d = ligo_function_preservation_error(small, deep2, test_inputs)
check("depth growth func preservation err < 0.5", fp_err_d < 0.5)

// ── Test 17: growth ratio
let ratio = ligo_growth_ratio(small, big)
// small: 2*(3*3+3)=24, big: 4*(5*5+5)=120, ratio=5.0
check("growth ratio = 5.0", approx(ratio, 5.0, 1.0e-9))

// ── Test 18: width operator verification
let wok = ligo_verify_width_operator(3, 5, 42)
check("width operator identity block verified", wok)

// ── Test 19: depth operator verification
let dok = ligo_verify_depth_operator(3, 5)
check("depth operator row-sum verified", dok)

// ── Test 20: grow model end-to-end forward
let x_big = [0.5, 0.3, 0.1, 0.0, 0.0]
let y_big = ligo_model_forward(big, x_big)
check("big model forward length = 5", len(y_big) == 5)

// ===================================================================
println("")
println("pass=" + to_string(pass_count) + " fail=" + to_string(fail_count))
if fail_count == 0 {
    println("ALL PASS")
} else {
    println("FAILED")
}
println(to_string(pass_count) + " passed")
