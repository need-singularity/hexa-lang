// ═══════════════════════════════════════════════════════════
//  test_block_transpose.hexa — ROI #70: Cache-oblivious block transpose
//  Self-contained test: inlines the transpose functions so
//  tests can run without importing the full ai_native_pass.
//  Validates:
//    1. Naive matrix transpose correctness (baseline)
//    2. Block transpose correctness vs naive
//    3. Various matrix sizes (1x1, 2x2, 3x3, 4x4, 5x5, 8x8)
//    4. Non-square edge cases and identity matrices
//    5. Block size boundary behavior
//    6. AI-native pass detection helpers
//    7. AST node construction for block transpose
// ═══════════════════════════════════════════════════════════

struct AstNode {
    kind: string,
    name: string,
    value: string,
    op: string,
    left: string,
    right: string,
    cond: string,
    then_body: string,
    else_body: string,
    params: string,
    body: string,
    args: string,
    fields: string,
    items: string,
    variants: string,
    arms: string,
    iter_expr: string,
    ret_type: string,
    target: string,
    trait_name: string,
    methods: string
}

// ── Milestone counters ────────────────────────────────────
let mut m978_block_transpose_detected = 0
let mut m978_block_transpose_rewrites = 0

// ── AST node constructors ─────────────────────────────────

fn make_ident(name) {
    return AstNode {
        kind: "Ident", name: name, value: "", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_int_lit(n) {
    return AstNode {
        kind: "IntLit", name: "", value: to_string(n), op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_binop(op, left, right) {
    return AstNode {
        kind: "BinOp", name: "", value: "", op: op,
        left: left, right: right, cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_let_mut_stmt(name, expr) {
    return AstNode {
        kind: "LetMutStmt", name: name, value: "", op: "",
        left: expr, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_assign_stmt(name, expr) {
    return AstNode {
        kind: "AssignStmt", name: name, value: "", op: "",
        left: expr, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_return_expr(expr) {
    return AstNode {
        kind: "ReturnStmt", name: "", value: "", op: "",
        left: expr, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_while_stmt(cond, body) {
    return AstNode {
        kind: "WhileStmt", name: "", value: "", op: "",
        left: "", right: "", cond: cond, then_body: "", else_body: "",
        params: "", body: body, args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_index(arr_expr, idx_expr) {
    return AstNode {
        kind: "Index", name: "", value: "", op: "",
        left: arr_expr, right: idx_expr, cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

// ── Helpers: type checks for named struct ─────────────────
// type_of(AstNode{..}) returns "AstNode" (not "struct") when
// the struct is declared with an explicit name.

fn is_node(x) {
    let t = type_of(x)
    if t == "string" { return false }
    if t == "int" { return false }
    if t == "float" { return false }
    if t == "bool" { return false }
    if t == "array" { return false }
    if t == "map" { return false }
    return true
}

// ── AI-native transpose detection helpers ─────────────────

fn anp_extract_loop_var(cond) {
    if !is_node(cond) { return "" }
    if cond.kind == "BinOp" {
        if cond.op == "<" {
            if is_node(cond.left) {
                if cond.left.kind == "Ident" {
                    return cond.left.name
                }
            }
        }
    }
    return ""
}

fn anp_extract_loop_bound(cond) {
    if !is_node(cond) { return "" }
    if cond.kind == "BinOp" {
        if cond.op == "<" {
            return cond.right
        }
    }
    return ""
}

fn anp_ident_name(node) {
    if !is_node(node) { return "" }
    if node.kind == "Ident" { return node.name }
    return ""
}

fn anp_has_swapped_index_assign(stmt, outer_var, inner_var) {
    let rhs = stmt.left
    if is_node(rhs) {
        if rhs.kind == "Index" {
            if is_node(rhs.left) {
                if rhs.left.kind == "Index" {
                    let idx_outer = anp_ident_name(rhs.left.right)
                    let idx_inner = anp_ident_name(rhs.right)
                    if idx_outer == outer_var && idx_inner == inner_var {
                        let base = anp_ident_name(rhs.left.left)
                        if base != "" { return base }
                    }
                }
            }
        }
    }
    return ""
}

fn anp_check_transpose_assign(stmt, outer_var, inner_var) {
    return anp_has_swapped_index_assign(stmt, outer_var, inner_var)
}

fn anp_detect_transpose(node) {
    if !is_node(node) { return #{} }
    if node.kind != "FnDecl" { return #{} }
    let body = node.body
    if type_of(body) != "array" { return #{} }
    let mut outer_while = ""
    let mut oi = 0
    while oi < len(body) {
        let s = body[oi]
        if is_node(s) {
            if s.kind == "WhileStmt" {
                outer_while = s
            }
        }
        oi = oi + 1
    }
    if !is_node(outer_while) { return #{} }
    let outer_var = anp_extract_loop_var(outer_while.cond)
    if outer_var == "" { return #{} }
    let outer_body = outer_while.body
    if type_of(outer_body) != "array" { return #{} }
    let mut inner_while = ""
    let mut ii = 0
    while ii < len(outer_body) {
        let s2 = outer_body[ii]
        if is_node(s2) {
            if s2.kind == "WhileStmt" {
                inner_while = s2
            }
        }
        ii = ii + 1
    }
    if !is_node(inner_while) { return #{} }
    let inner_var = anp_extract_loop_var(inner_while.cond)
    if inner_var == "" { return #{} }
    if inner_var == outer_var { return #{} }
    let inner_body = inner_while.body
    if type_of(inner_body) != "array" { return #{} }
    let mut found_transpose = false
    let mut src_name = ""
    let mut bi = 0
    while bi < len(inner_body) {
        let stmt = inner_body[bi]
        if is_node(stmt) {
            if stmt.kind == "AssignStmt" {
                let assign_info = anp_check_transpose_assign(stmt, outer_var, inner_var)
                if assign_info != "" {
                    found_transpose = true
                    src_name = assign_info
                }
            }
            if stmt.kind == "ExprStmt" {
                if is_node(stmt.left) {
                    if stmt.left.kind == "Assign" {
                        let assign_info2 = anp_check_transpose_assign(stmt.left, outer_var, inner_var)
                        if assign_info2 != "" {
                            found_transpose = true
                            src_name = assign_info2
                        }
                    }
                }
            }
        }
        bi = bi + 1
    }
    if !found_transpose { return #{} }
    let bound_expr = anp_extract_loop_bound(outer_while.cond)
    return #{"detected": true, "outer_var": outer_var, "inner_var": inner_var, "src": src_name, "bound": bound_expr}
}

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA Block Transpose (ROI #70) Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── Helper: create NxN zero matrix ────────────────────────
fn mat_zero(n) {
    let mut m = []
    let mut i = 0
    while i < n {
        let mut row = []
        let mut j = 0
        while j < n {
            row = row + [0]
            j = j + 1
        }
        m = m + [row]
        i = i + 1
    }
    m
}

// ── Helper: set matrix element ────────────────────────────
fn mset(m, r, c, val) {
    let mut new_m = []
    let mut i = 0
    while i < len(m) {
        if i == r {
            let mut new_row = []
            let mut j = 0
            while j < len(m[i]) {
                if j == c {
                    new_row = new_row + [val]
                } else {
                    new_row = new_row + [m[i][j]]
                }
                j = j + 1
            }
            new_m = new_m + [new_row]
        } else {
            new_m = new_m + [m[i]]
        }
        i = i + 1
    }
    new_m
}

// ── Naive transpose (baseline) ────────────────────────────
fn naive_transpose(a, n) {
    let mut b = mat_zero(n)
    let mut i = 0
    while i < n {
        let mut j = 0
        while j < n {
            b = mset(b, j, i, a[i][j])
            j = j + 1
        }
        i = i + 1
    }
    b
}

// ── Block transpose (manual implementation for validation) ─
fn block_transpose(a, n, bs) {
    let mut b = mat_zero(n)
    let mut ii = 0
    while ii < n {
        let mut jj = 0
        while jj < n {
            let mut i = ii
            let i_end = min(ii + bs, n)
            while i < i_end {
                let mut j = jj
                let j_end = min(jj + bs, n)
                while j < j_end {
                    b = mset(b, j, i, a[i][j])
                    j = j + 1
                }
                i = i + 1
            }
            jj = jj + bs
        }
        ii = ii + bs
    }
    b
}

// ── Create a test matrix with distinct values ──────────────
fn make_test_matrix(n) {
    let mut m = mat_zero(n)
    let mut i = 0
    while i < n {
        let mut j = 0
        while j < n {
            m = mset(m, i, j, i * n + j + 1)
            j = j + 1
        }
        i = i + 1
    }
    m
}

// ══════════════════════════════════════════════════════════
//  SECTION 1: Naive transpose baseline
// ══════════════════════════════════════════════════════════
println("--- Section 1: Naive transpose baseline ---")

// 1x1
let m1 = [[42]]
let t1 = naive_transpose(m1, 1)
check("1x1 transpose [0][0]", t1[0][0] == 42)

// 2x2
let m2 = [[1, 2], [3, 4]]
let t2 = naive_transpose(m2, 2)
check("2x2 transpose [0][0]", t2[0][0] == 1)
check("2x2 transpose [0][1]", t2[0][1] == 3)
check("2x2 transpose [1][0]", t2[1][0] == 2)
check("2x2 transpose [1][1]", t2[1][1] == 4)

// 3x3
let m3 = [[1, 2, 3], [4, 5, 6], [7, 8, 9]]
let t3 = naive_transpose(m3, 3)
check("3x3 transpose [0][2]", t3[0][2] == 7)
check("3x3 transpose [2][0]", t3[2][0] == 3)
check("3x3 transpose [1][2]", t3[1][2] == 8)

// ══════════════════════════════════════════════════════════
//  SECTION 2: Block transpose vs naive (block_size=2)
// ══════════════════════════════════════════════════════════
println("--- Section 2: Block transpose vs naive (bs=2) ---")

let bt2 = block_transpose(m2, 2, 2)
check("block(bs=2) 2x2 [0][0] == naive", bt2[0][0] == t2[0][0])
check("block(bs=2) 2x2 [0][1] == naive", bt2[0][1] == t2[0][1])
check("block(bs=2) 2x2 [1][0] == naive", bt2[1][0] == t2[1][0])
check("block(bs=2) 2x2 [1][1] == naive", bt2[1][1] == t2[1][1])

let bt3 = block_transpose(m3, 3, 2)
check("block(bs=2) 3x3 [0][0] == naive", bt3[0][0] == t3[0][0])
check("block(bs=2) 3x3 [0][2] == naive", bt3[0][2] == t3[0][2])
check("block(bs=2) 3x3 [2][0] == naive", bt3[2][0] == t3[2][0])
check("block(bs=2) 3x3 [2][2] == naive", bt3[2][2] == t3[2][2])

// ══════════════════════════════════════════════════════════
//  SECTION 3: Larger matrices (4x4, 5x5)
// ══════════════════════════════════════════════════════════
println("--- Section 3: Larger matrices ---")

let m4 = make_test_matrix(4)
let t4_naive = naive_transpose(m4, 4)
let t4_block = block_transpose(m4, 4, 2)
check("4x4 block==naive [0][0]", t4_block[0][0] == t4_naive[0][0])
check("4x4 block==naive [0][3]", t4_block[0][3] == t4_naive[0][3])
check("4x4 block==naive [3][0]", t4_block[3][0] == t4_naive[3][0])
check("4x4 block==naive [3][3]", t4_block[3][3] == t4_naive[3][3])
check("4x4 block==naive [1][2]", t4_block[1][2] == t4_naive[1][2])

let m5 = make_test_matrix(5)
let t5_naive = naive_transpose(m5, 5)
let t5_block = block_transpose(m5, 5, 2)
check("5x5 block==naive [0][4]", t5_block[0][4] == t5_naive[0][4])
check("5x5 block==naive [4][0]", t5_block[4][0] == t5_naive[4][0])
check("5x5 block==naive [2][3]", t5_block[2][3] == t5_naive[2][3])

// ══════════════════════════════════════════════════════════
//  SECTION 4: Different block sizes
// ══════════════════════════════════════════════════════════
println("--- Section 4: Different block sizes ---")

// block_size=1 (degenerates to naive)
let t4_bs1 = block_transpose(m4, 4, 1)
check("4x4 bs=1 [0][3] == naive", t4_bs1[0][3] == t4_naive[0][3])
check("4x4 bs=1 [3][0] == naive", t4_bs1[3][0] == t4_naive[3][0])

// block_size=4 (single block covers whole matrix)
let t4_bs4 = block_transpose(m4, 4, 4)
check("4x4 bs=4 [0][3] == naive", t4_bs4[0][3] == t4_naive[0][3])
check("4x4 bs=4 [3][0] == naive", t4_bs4[3][0] == t4_naive[3][0])

// block_size=3 on 5x5 (non-divisible)
let t5_bs3 = block_transpose(m5, 5, 3)
check("5x5 bs=3 [0][4] == naive", t5_bs3[0][4] == t5_naive[0][4])
check("5x5 bs=3 [4][0] == naive", t5_bs3[4][0] == t5_naive[4][0])
check("5x5 bs=3 [2][2] == naive", t5_bs3[2][2] == t5_naive[2][2])

// block_size larger than matrix
let t3_bs8 = block_transpose(m3, 3, 8)
check("3x3 bs=8 [0][2] == naive", t3_bs8[0][2] == t3[0][2])
check("3x3 bs=8 [2][0] == naive", t3_bs8[2][0] == t3[2][0])

// ══════════════════════════════════════════════════════════
//  SECTION 5: Identity matrix transpose (symmetric)
// ══════════════════════════════════════════════════════════
println("--- Section 5: Identity matrix ---")

let eye3 = [[1, 0, 0], [0, 1, 0], [0, 0, 1]]
let eye3_t = block_transpose(eye3, 3, 2)
check("identity 3x3 transpose [0][0]", eye3_t[0][0] == 1)
check("identity 3x3 transpose [0][1]", eye3_t[0][1] == 0)
check("identity 3x3 transpose [1][1]", eye3_t[1][1] == 1)
check("identity 3x3 transpose [2][2]", eye3_t[2][2] == 1)

// ══════════════════════════════════════════════════════════
//  SECTION 6: Transpose is involution (T(T(A)) == A)
// ══════════════════════════════════════════════════════════
println("--- Section 6: Double transpose == original ---")

let m4_tt = block_transpose(t4_block, 4, 2)
check("double transpose 4x4 [0][0]", m4_tt[0][0] == m4[0][0])
check("double transpose 4x4 [1][2]", m4_tt[1][2] == m4[1][2])
check("double transpose 4x4 [3][3]", m4_tt[3][3] == m4[3][3])

// ══════════════════════════════════════════════════════════
//  SECTION 7: AST helper function tests
// ══════════════════════════════════════════════════════════
println("--- Section 7: AST helpers ---")

// anp_extract_loop_var: BinOp("<", Ident("i"), ...) -> "i"
let cond_node = make_binop("<", make_ident("i"), make_ident("n"))
check("extract_loop_var from i<n", anp_extract_loop_var(cond_node) == "i")

// anp_extract_loop_var: non-BinOp -> ""
check("extract_loop_var from non-binop", anp_extract_loop_var(make_ident("x")) == "")

// anp_extract_loop_bound: BinOp("<", ..., Ident("n")) -> Ident("n")
let bound = anp_extract_loop_bound(cond_node)
check("extract_loop_bound kind", bound.kind == "Ident")
check("extract_loop_bound name", bound.name == "n")

// anp_ident_name
check("ident_name on Ident", anp_ident_name(make_ident("foo")) == "foo")
check("ident_name on non-Ident", anp_ident_name(make_int_lit(5)) == "")

// ══════════════════════════════════════════════════════════
//  SECTION 8: Detection on synthetic AST
// ══════════════════════════════════════════════════════════
println("--- Section 8: Transpose detection ---")

// Build a synthetic FnDecl with nested while loops and transpose assignment
// fn transpose_fn(src, n) {
//   let mut i = 0
//   while i < n {
//     let mut j = 0
//     while j < n {
//       // assignment: rhs = src[i][j]  (stored as AssignStmt.left = Index(Index(src,i),j))
//       j = j + 1
//     }
//     i = i + 1
//   }
// }

// Inner assignment: value = src[i][j]
let src_idx = make_index(make_index(make_ident("src"), make_ident("i")), make_ident("j"))
let inner_assign = make_assign_stmt("_tmp", src_idx)

let inner_inc = make_assign_stmt("j", make_binop("+", make_ident("j"), make_int_lit(1)))
let inner_cond = make_binop("<", make_ident("j"), make_ident("n"))
let inner_while = make_while_stmt(inner_cond, [inner_assign, inner_inc])

let outer_inc = make_assign_stmt("i", make_binop("+", make_ident("i"), make_int_lit(1)))
let init_j = make_let_mut_stmt("j", make_int_lit(0))
let outer_cond = make_binop("<", make_ident("i"), make_ident("n"))
let outer_while = make_while_stmt(outer_cond, [init_j, inner_while, outer_inc])

let init_i = make_let_mut_stmt("i", make_int_lit(0))
let fn_body = [init_i, outer_while]

let p_src = #{"name": "src"}
let p_n = #{"name": "n"}
let test_params = [p_src, p_n]
let test_fn = AstNode {
    kind: "FnDecl", name: "my_transpose", value: "", op: "",
    left: "", right: "", cond: "", then_body: "", else_body: "",
    params: test_params, body: fn_body, args: "", fields: "", items: "",
    variants: "", arms: "", iter_expr: "", ret_type: "",
    target: "", trait_name: "", methods: ""
}

let detect_result = anp_detect_transpose(test_fn)
check("detect finds transpose", has_key(detect_result, "detected"))
check("detect outer_var == i", detect_result["outer_var"] == "i")
check("detect inner_var == j", detect_result["inner_var"] == "j")
check("detect src == src", detect_result["src"] == "src")

// ══════════════════════════════════════════════════════════
//  SECTION 9: Non-transpose should NOT be detected
// ══════════════════════════════════════════════════════════
println("--- Section 9: Non-transpose rejection ---")

// Non-FnDecl
check("reject non-FnDecl", len(keys(anp_detect_transpose(make_ident("x")))) == 0)

// FnDecl with no while loops
let empty_fn = AstNode {
    kind: "FnDecl", name: "noop", value: "", op: "",
    left: "", right: "", cond: "", then_body: "", else_body: "",
    params: [], body: [make_return_expr(make_int_lit(0))], args: "", fields: "", items: "",
    variants: "", arms: "", iter_expr: "", ret_type: "",
    target: "", trait_name: "", methods: ""
}
check("reject no-while fn", len(keys(anp_detect_transpose(empty_fn))) == 0)

// Single while (no nesting)
let single_while_fn = AstNode {
    kind: "FnDecl", name: "single", value: "", op: "",
    left: "", right: "", cond: "", then_body: "", else_body: "",
    params: [], body: [make_while_stmt(make_binop("<", make_ident("i"), make_ident("n")), [])], args: "", fields: "", items: "",
    variants: "", arms: "", iter_expr: "", ret_type: "",
    target: "", trait_name: "", methods: ""
}
check("reject single while", len(keys(anp_detect_transpose(single_while_fn))) == 0)

// ══════════════════════════════════════════════════════════
//  SECTION 10: 8x8 matrix full validation
// ══════════════════════════════════════════════════════════
println("--- Section 10: 8x8 full validation ---")

let m8 = make_test_matrix(8)
let t8_naive = naive_transpose(m8, 8)
let t8_block = block_transpose(m8, 8, 4)
check("8x8 block==naive [0][7]", t8_block[0][7] == t8_naive[0][7])
check("8x8 block==naive [7][0]", t8_block[7][0] == t8_naive[7][0])
check("8x8 block==naive [3][5]", t8_block[3][5] == t8_naive[3][5])
check("8x8 block==naive [5][3]", t8_block[5][3] == t8_naive[5][3])
check("8x8 value [0][7] == 57", t8_block[0][7] == 57)
check("8x8 value [7][0] == 8", t8_block[7][0] == 8)

