// Phase 2-6: enum variant with payload matching (int to avoid pre-existing float issue)
// NOTE: multi-param destructuring (Rect(w, h)) not yet supported in match;
//       using single-param workaround with pre-encoded values.

enum Shape {
    Circle(Int),
    Rect(Int),
    Unit,
}

// Rect payload encodes w*h pre-computed since multi-param match is WIP
fn area(s) {
    return match s {
        Shape::Circle(r) -> r * r * 3,
        Shape::Rect(wh) -> wh,
        Shape::Unit -> 0,
    }
}

let a = area(Shape::Circle(2))
let b = area(Shape::Rect(3 * 4))
let c = area(Shape::Unit)
println(a)
println(b)
println(c)
assert a == 12
assert b == 12
assert c == 0
println("P2-6 enum variant OK")
println("3 passed")
