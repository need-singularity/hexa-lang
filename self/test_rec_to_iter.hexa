// ═══════════════════════════════════════════════════════════
//  test_rec_to_iter.hexa — General Recursion->Iteration Tests
//  M976: Extends M25 tail-call to handle non-tail recursion:
//  - Accumulator recursion: n * f(n-1) -> while loop
//  - Tree traversal detection
//  - Divide-and-conquer detection
//  Tests verify algorithm correctness for the recursive patterns
//  that M976 would transform in the compiler pipeline.
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA Recursion->Iteration Transformation Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Accumulator recursion: factorial ──────────────────

println("--- Accumulator: factorial ---")

// Pattern: n * factorial(n-1) — M976 rewrites to while loop
// decreases n — structural
fn factorial(n) {
    if n <= 1 { return 1 }
    return n * factorial(n - 1)
}

check("factorial(0)", factorial(0), 1)
check("factorial(1)", factorial(1), 1)
check("factorial(5)", factorial(5), 120)
check("factorial(7)", factorial(7), 5040)
check("factorial(10)", factorial(10), 3628800)

// ── 2. Accumulator recursion: sum ────────────────────────

println("")
println("--- Accumulator: sum ---")

// decreases n — structural
fn rec_sum(n) {
    if n <= 0 { return 0 }
    return n + rec_sum(n - 1)
}

check("rec_sum(0)", rec_sum(0), 0)
check("rec_sum(5)", rec_sum(5), 15)
check("rec_sum(10)", rec_sum(10), 55)
check("rec_sum(100)", rec_sum(100), 5050)

// ── 3. Branching recursion: fibonacci (detection only) ───

println("")
println("--- Branching: fibonacci (detection) ---")

// TWO self-calls: fib(n-1) + fib(n-2) — M976 detects as candidate
// decreases n — structural
fn fib(n) {
    if n <= 1 { return n }
    return fib(n - 1) + fib(n - 2)
}

check("fib(0)", fib(0), 0)
check("fib(1)", fib(1), 1)
check("fib(5)", fib(5), 5)
check("fib(10)", fib(10), 55)

// ── 4. Already tail-recursive (handled by M25, not M976) ─

println("")
println("--- Tail-recursive (M25 territory) ---")

// decreases n — structural
fn tail_sum(n, acc) {
    if n <= 0 { return acc }
    return tail_sum(n - 1, acc + n)
}

check("tail_sum(0,0)", tail_sum(0, 0), 0)
check("tail_sum(5,0)", tail_sum(5, 0), 15)
check("tail_sum(10,0)", tail_sum(10, 0), 55)

// ── 5. Non-recursive function (no transform needed) ──────

println("")
println("--- Non-recursive (no transform) ---")

fn iterative_sum(n) {
    let mut acc = 0
    let mut i = 1
    while i <= n {
        acc = acc + i
        i = i + 1
    }
    return acc
}

check("iterative_sum(0)", iterative_sum(0), 0)
check("iterative_sum(5)", iterative_sum(5), 15)
check("iterative_sum(100)", iterative_sum(100), 5050)

// ── 6. Power function (accumulator pattern) ──────────────

println("")
println("--- Accumulator: power ---")

// decreases base — structural
fn rec_power(base, exp) {
    if exp <= 0 { return 1 }
    return base * rec_power(base, exp - 1)
}

check("rec_power(2,0)", rec_power(2, 0), 1)
check("rec_power(2,3)", rec_power(2, 3), 8)
check("rec_power(3,4)", rec_power(3, 4), 81)
check("rec_power(10,3)", rec_power(10, 3), 1000)

// ── 7. Subtraction recursion ─────────────────────────────

println("")
println("--- Subtraction recursion ---")

// decreases n — structural
fn count_down(n) {
    if n <= 0 { return 0 }
    return 1 + count_down(n - 1)
}

check("count_down(0)", count_down(0), 0)
check("count_down(5)", count_down(5), 5)
check("count_down(20)", count_down(20), 20)

// ── 8. Deep recursion safety ─────────────────────────────

println("")
println("--- Deep recursion safety ---")

// decreases n — structural
fn deep_add(n) {
    if n <= 0 { return 0 }
    return 1 + deep_add(n - 1)
}

check("deep_add(100)", deep_add(100), 100)
check("deep_add(500)", deep_add(500), 500)

// ── 9. Multiple base cases ──────────────────────────────

println("")
println("--- Multiple base cases ---")

// decreases n — structural
fn triangular(n) {
    if n <= 0 { return 0 }
    return n + triangular(n - 1)
}

check("triangular(1)", triangular(1), 1)
check("triangular(5)", triangular(5), 15)
check("triangular(10)", triangular(10), 55)

// ── 10. Iterative equivalence check ─────────────────────

println("")
println("--- Iterative equivalence ---")

fn iter_factorial(n) {
    let mut result = 1
    let mut i = 2
    while i <= n {
        result = result * i
        i = i + 1
    }
    return result
}

// Verify recursive and iterative produce same results
check("fact recursive==iterative 5", factorial(5) == iter_factorial(5), true)
check("fact recursive==iterative 7", factorial(7) == iter_factorial(7), true)
check("fact recursive==iterative 10", factorial(10) == iter_factorial(10), true)

// ── Summary ──────────────────────────────────────────────

println("")
println("═══════════════════════════════════════════════════════")
println("  Recursion->Iteration Tests: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")
if fail_count > 0 {
    println("SOME TESTS FAILED")
}
