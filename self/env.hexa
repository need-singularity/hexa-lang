// self/env.hexa — HEXA ENV ported from src/env.rs
// Runtime environment: scoped variable bindings, ownership tracking, builtins.

// ── Value kinds ─────────────────────────────────────────
// Values are represented as tagged structs (kind + payload fields).

struct Value {
    kind: string,       // "int", "float", "bool", "char", "str", "byte", "void",
                        // "array", "tuple", "fn", "builtin_fn", "struct", "lambda",
                        // "map", "error", "enum_variant", "intent", "sender",
                        // "receiver", "future", "set", "effect_request",
                        // "trait_object", "atomic", "pointer", "bigint", "tensor"
    int_val: int,
    float_val: float,
    bool_val: bool,
    str_val: string,
    name: string,       // for fn/builtin/struct/enum
    fields: string,     // serialized map for struct/map/intent
    items: string,      // serialized array for array/tuple
    params: string,     // for fn/lambda
    body: string,       // for fn/lambda
    captured: string,   // for lambda captured env
    variant: string,    // for enum_variant
    data: string        // for enum_variant data / error message
}

fn value_int(n: int) -> Value {
    return Value { kind: "int", int_val: n, float_val: 0.0, bool_val: false,
        str_val: "", name: "", fields: "", items: "", params: "", body: "",
        captured: "", variant: "", data: "" }
}

fn value_float(n: float) -> Value {
    return Value { kind: "float", int_val: 0, float_val: n, bool_val: false,
        str_val: "", name: "", fields: "", items: "", params: "", body: "",
        captured: "", variant: "", data: "" }
}

fn value_bool(b: bool) -> Value {
    return Value { kind: "bool", int_val: 0, float_val: 0.0, bool_val: b,
        str_val: "", name: "", fields: "", items: "", params: "", body: "",
        captured: "", variant: "", data: "" }
}

fn value_str(s: string) -> Value {
    return Value { kind: "str", int_val: 0, float_val: 0.0, bool_val: false,
        str_val: s, name: "", fields: "", items: "", params: "", body: "",
        captured: "", variant: "", data: "" }
}

fn value_void() -> Value {
    return Value { kind: "void", int_val: 0, float_val: 0.0, bool_val: false,
        str_val: "", name: "", fields: "", items: "", params: "", body: "",
        captured: "", variant: "", data: "" }
}

fn value_error(msg: string) -> Value {
    return Value { kind: "error", int_val: 0, float_val: 0.0, bool_val: false,
        str_val: "", name: "", fields: "", items: "", params: "", body: "",
        captured: "", variant: "", data: msg }
}

fn value_builtin(name: string) -> Value {
    return Value { kind: "builtin_fn", int_val: 0, float_val: 0.0, bool_val: false,
        str_val: "", name: name, fields: "", items: "", params: "", body: "",
        captured: "", variant: "", data: "" }
}

fn value_is_value_type(v: Value) -> bool {
    return v.kind == "int" || v.kind == "float" || v.kind == "bool" ||
           v.kind == "char" || v.kind == "byte" || v.kind == "void"
}

fn value_display(v: Value) -> string {
    match v.kind {
        "int"       => to_string(v.int_val)
        "float"     => to_string(v.float_val)
        "bool"      => to_string(v.bool_val)
        "str"       => v.str_val
        "void"      => "void"
        "error"     => "Error(" + v.data + ")"
        "builtin_fn" => "<builtin " + v.name + ">"
        _           => "<" + v.kind + ">"
    }
}

// ── TensorData ──────────────────────────────────────────

struct TensorData {
    shape: [int],
    data: [float]
}

// ── Ownership State ─────────────────────────────────────

let OWN_NORMAL   = "normal"
let OWN_OWNED    = "owned"
let OWN_MOVED    = "moved"
let OWN_BORROWED = "borrowed"
let OWN_DROPPED  = "dropped"

// ── Environment ─────────────────────────────────────────
// Flat variable stack with scope boundary tracking.
// Builtins stored separately for O(1) lookup.

struct EnvEntry {
    name: string,
    value: Value
}

struct OwnerEntry {
    name: string,
    state: string   // one of OWN_* constants
}

struct Env {
    vars: [EnvEntry],
    scope_starts: [int],
    ownership: [OwnerEntry],
    constants: [string],
    statics: [EnvEntry],
    builtins: [EnvEntry],
    ownership_count: int
}

fn env_new() -> Env {
    let env = Env {
        vars: [],
        scope_starts: [0],
        ownership: [],
        constants: [],
        statics: [],
        builtins: [],
        ownership_count: 0
    }

    // Register core builtins
    let builtin_names = [
        "print", "println", "len", "type_of", "sigma", "phi", "tau", "gcd",
        "bigint", "read_file", "write_file", "file_exists", "delete_file",
        "append_file", "keys", "values", "has_key", "to_string", "to_int",
        "to_float", "try_float", "is_numeric", "join", "split", "trim",
        "trim_start", "trim_end", "starts_with", "ends_with", "contains",
        "replace", "to_upper", "to_lower", "abs", "min", "max", "floor",
        "ceil", "round", "sqrt", "pow", "log", "log2", "log10", "exp", "ln",
        "sin", "cos", "tan", "asin", "acos", "atan", "atan2", "format",
        "args", "env_var", "exit", "clock", "Some", "Ok", "Err", "channel",
        "is_alpha", "is_digit", "is_alphanumeric", "is_whitespace",
        "random", "random_int", "sleep", "print_err", "json_parse",
        "json_stringify", "http_get", "http_post", "http_serve",
        "net_listen", "net_accept", "net_connect", "net_read", "net_read_n",
        "net_set_timeout", "net_write",
        "net_close", "Set", "now", "timestamp", "elapsed",
        "base64_encode", "base64_decode", "hex_encode", "hex_decode",
        "laws", "meta_laws", "consciousness_vector", "phi_predict",
        "psi_coupling", "psi_balance", "psi_steps", "psi_entropy",
        "psi_frustration", "consciousness_max_cells", "consciousness_decoder_dim",
        "consciousness_phi", "hexad_modules", "hexad_right", "hexad_left",
        "tension_link", "sopfr", "mem_stats", "mem_region", "arena_reset",
        "mem_budget", "nexus_scan", "nexus_verify", "nexus_omega",
        "nexus_lenses", "nexus_consensus", "nexus_n6_check",
        "str", "cstring", "from_cstring", "ptr_null", "ptr_addr", "deref",
        "env", "exec", "evolve_gen", "sigmoid", "tanh_", "relu", "softmax",
        "cosine_sim", "run_tests", "run_benchmarks", "matmul", "transpose",
        "normalize", "cross_entropy", "argmax", "zeros", "ones", "randn",
        "arange", "ema", "clip", "sum", "mean", "hadamard",
        "map_arr", "filter_arr", "reduce", "zip_arr", "enumerate_arr",
        "flatten", "slice", "sgd_step", "adam_step", "numerical_grad",
        "warmup_lr", "cosine_lr", "phase_lr", "batch_matvec", "batch_norm",
        "grad_accumulate", "layer_norm", "dropout", "embedding", "attention",
        "gru_cell", "gelu", "silu", "sinusoidal_pe", "multi_head_attention",
        "topk", "sample_token", "mse_loss", "conv1d", "max_pool1d",
        "kv_cache_append", "attention_cached", "save_array", "load_array",
        "quantize_int8", "dequantize_int8", "beam_search_step",
        "grad_clip_norm", "xavier_init", "kaiming_init",
        "curiosity_reward", "dialogue_reward", "combined_reward",
        "magnitude_prune", "sparsity", "tensor", "tensor_zeros", "tensor_fill",
        "input", "readline", "read_stdin", "input_all",
        "load_weights_bin", "mmap_weights", "to_char", "repeat_kv",
        "dot", "matvec", "mat_add", "mat_add_inplace",
        "matmul_into", "rms_norm", "rope", "rope_inplace",
        "weight_dict", "exec_with_status",
        // TUI-PRIM L1 (kick T1.A 2026-04-27_hexa-native-tui-implementation-plan)
        "term_raw_enter", "term_raw_restore",
        "term_winsize_rows", "term_winsize_cols",
        "term_poll_stdin", "term_read_byte", "term_write_str",
        "term_install_sigwinch", "term_sigwinch_pending",
        "term_install_sigint", "term_sigint_pending",
        "term_isatty_stdin", "term_isatty_stdout",
        "term_getppid",
        // PTY harness builtins (commit 43bec17b + this wiring)
        "term_pty_spawn_sh", "term_fd_read", "term_fd_write",
        "term_fd_close", "term_fd_poll", "term_pty_reap"
    ]

    let i = 0
    while i < len(builtin_names) {
        env.builtins = env.builtins + [EnvEntry { name: builtin_names[i], value: value_builtin(builtin_names[i]) }]
        i = i + 1
    }

    return env
}

fn env_push_scope(env: Env) -> Env {
    env.scope_starts = env.scope_starts + [len(env.vars)]
    return env
}

fn env_pop_scope(env: Env) -> Env {
    if len(env.scope_starts) > 0 {
        let start = env.scope_starts[len(env.scope_starts) - 1]
        // Truncate vars to scope start
        let new_vars = []
        let i = 0
        while i < start {
            new_vars = new_vars + [env.vars[i]]
            i = i + 1
        }
        env.vars = new_vars
        // Pop scope marker
        let new_starts = []
        i = 0
        while i < len(env.scope_starts) - 1 {
            new_starts = new_starts + [env.scope_starts[i]]
            i = i + 1
        }
        env.scope_starts = new_starts
    }
    return env
}

fn env_define(env: Env, name: string, val: Value) -> Env {
    env.vars = env.vars + [EnvEntry { name: name, value: val }]
    return env
}

fn env_get(env: Env, name: string) -> Value {
    // Search user vars in reverse (most recent first)
    let i = len(env.vars) - 1
    while i >= 0 {
        if env.vars[i].name == name {
            return env.vars[i].value
        }
        i = i - 1
    }
    // O(1)-style builtin lookup
    i = 0
    while i < len(env.builtins) {
        if env.builtins[i].name == name {
            return env.builtins[i].value
        }
        i = i + 1
    }
    // Static globals
    i = 0
    while i < len(env.statics) {
        if env.statics[i].name == name {
            return env.statics[i].value
        }
        i = i + 1
    }
    return value_void()  // sentinel: not found
}

fn env_set(env: Env, name: string, val: Value) -> bool {
    let i = len(env.vars) - 1
    while i >= 0 {
        if env.vars[i].name == name {
            env.vars[i] = EnvEntry { name: name, value: val }
            return true
        }
        i = i - 1
    }
    // Static fallback
    i = 0
    while i < len(env.statics) {
        if env.statics[i].name == name {
            env.statics[i] = EnvEntry { name: name, value: val }
            return true
        }
        i = i + 1
    }
    return false
}

fn env_scope_depth(env: Env) -> int {
    return len(env.scope_starts)
}

fn env_known_names(env: Env) -> [string] {
    let names = []
    let i = 0
    while i < len(env.vars) {
        names = names + [env.vars[i].name]
        i = i + 1
    }
    i = 0
    while i < len(env.builtins) {
        names = names + [env.builtins[i].name]
        i = i + 1
    }
    return names
}

fn env_define_const(env: Env, name: string, val: Value) -> Env {
    env.constants = env.constants + [name]
    env.vars = env.vars + [EnvEntry { name: name, value: val }]
    return env
}

fn env_is_constant(env: Env, name: string) -> bool {
    let i = 0
    while i < len(env.constants) {
        if env.constants[i] == name {
            return true
        }
        i = i + 1
    }
    return false
}

fn env_define_static(env: Env, name: string, val: Value) -> Env {
    env.statics = env.statics + [EnvEntry { name: name, value: val }]
    return env
}

fn env_set_ownership(env: Env, name: string, state: string) -> Env {
    env.ownership = env.ownership + [OwnerEntry { name: name, state: state }]
    env.ownership_count = env.ownership_count + 1
    return env
}

fn env_get_ownership(env: Env, name: string) -> string {
    if env.ownership_count == 0 {
        return OWN_NORMAL
    }
    let i = len(env.ownership) - 1
    while i >= 0 {
        if env.ownership[i].name == name {
            return env.ownership[i].state
        }
        i = i - 1
    }
    return OWN_NORMAL
}
