// self/std_math.hexa — HEXA MATH ported from src/std_math.rs
//
// Provides:
//   math_pi()              — pi constant
//   math_e()               — e constant
//   math_phi()             — golden ratio
//   math_abs(x)            — absolute value
//   math_sqrt(x)           — square root
//   math_pow(x, n)         — x^n
//   math_log(x)            — natural log
//   math_sin(x)            — sine
//   math_cos(x)            — cosine
//   math_floor(x)          — floor
//   math_ceil(x)           — ceiling
//   math_round(x)          — round to nearest
//   math_min(a, b)         — minimum
//   math_max(a, b)         — maximum
//   math_gcd(a, b)         — greatest common divisor
//   matrix_new(rows, cols) — create zero matrix
//   matrix_set(m, r, c, v) — set element
//   matrix_get(m, r, c)    — get element
//   matrix_mul(a, b)       — matrix multiplication
//   matrix_det(m)          — determinant (up to 4x4)

// -- Constants --

fn math_pi() -> float {
    return 3.141592653589793
}

fn math_e() -> float {
    return 2.718281828459045
}

fn math_phi() -> float {
    return 1.618033988749895
}

// -- Single-argument math --

fn math_abs(x) {
    if x < 0 { return 0 - x }
    return x
}

fn math_sqrt(x) -> float {
    // Newton's method
    if x < 0.0 { return 0.0 }
    if x == 0.0 { return 0.0 }
    let guess = x / 2.0
    let i = 0
    while i < 50 {
        let next = (guess + x / guess) / 2.0
        if math_abs(next - guess) < 0.0000000001 { return next }
        guess = next
        i = i + 1
    }
    return guess
}

fn math_pow(x, n) -> float {
    if n == 0 { return 1.0 }
    if n == 1 { return x }
    // integer exponent fast path
    let result = 1.0
    let base = x
    let exp = n
    if exp < 0 {
        base = 1.0 / base
        exp = 0 - exp
    }
    while exp > 0 {
        if exp % 2 == 1 { result = result * base }
        base = base * base
        exp = exp / 2
    }
    return result
}

fn math_log(x) -> float {
    // Natural log via series expansion (for x > 0)
    if x <= 0.0 { return 0.0 }
    // Reduce: find k such that x = 2^k * m, 0.5 <= m < 1
    let k = 0
    let m = x
    while m >= 2.0 { m = m / 2.0; k = k + 1 }
    while m < 0.5 { m = m * 2.0; k = k - 1 }
    // log(x) = k*log(2) + log(m), use series for log(m) near 1
    let t = (m - 1.0) / (m + 1.0)
    let t2 = t * t
    let sum = t
    let term = t
    let i = 1
    while i < 40 {
        term = term * t2
        sum = sum + term / (2 * i + 1)
        i = i + 1
    }
    return k * 0.6931471805599453 + 2.0 * sum
}

fn math_sin(x) -> float {
    // Taylor series
    let pi = 3.141592653589793
    // Normalize x to [-pi, pi]
    let v = x
    while v > pi { v = v - 2.0 * pi }
    while v < 0.0 - pi { v = v + 2.0 * pi }
    let term = v
    let sum = v
    let i = 1
    while i < 20 {
        term = 0.0 - term * v * v / ((2 * i) * (2 * i + 1))
        sum = sum + term
        i = i + 1
    }
    return sum
}

fn math_cos(x) -> float {
    let pi = 3.141592653589793
    return math_sin(x + pi / 2.0)
}

fn math_floor(x) -> int {
    let n = x
    if n >= 0 { return n }
    if n == x { return n }
    return n - 1
}

fn math_ceil(x) -> int {
    let n = x
    if n >= 0 {
        if n == x { return n }
        return n + 1
    }
    return n
}

fn math_round(x) -> int {
    return math_floor(x + 0.5)
}

fn math_min(a, b) {
    if a <= b { return a }
    return b
}

fn math_max(a, b) {
    if a >= b { return a }
    return b
}

fn math_gcd(a, b) -> int {
    let x = math_abs(a)
    let y = math_abs(b)
    while y != 0 {
        let t = y
        y = x % y
        x = t
    }
    return x
}

// -- Matrix (stored as array of arrays) --

fn matrix_new(rows, cols) -> [float] {
    let matrix = []
    let r = 0
    while r < rows {
        let row = []
        let c = 0
        while c < cols {
            row = array_push(row, 0.0)
            c = c + 1
        }
        matrix = array_push(matrix, row)
        r = r + 1
    }
    return matrix
}

fn matrix_set(m, r, c, val) {
    if r < 0 { return m }
    if r >= len(m) { return m }
    let row = m[r]
    if c < 0 { return m }
    if c >= len(row) { return m }
    row[c] = val
    m[r] = row
    return m
}

fn matrix_get(m, r, c) {
    if r < 0 { return 0.0 }
    if r >= len(m) { return 0.0 }
    let row = m[r]
    if c < 0 { return 0.0 }
    if c >= len(row) { return 0.0 }
    return row[c]
}

fn matrix_mul(a, b) {
    let a_rows = len(a)
    if a_rows == 0 { return [] }
    let a_cols = len(a[0])
    let b_rows = len(b)
    let b_cols = len(b[0])
    if a_cols != b_rows { return [] }

    let result = matrix_new(a_rows, b_cols)
    let i = 0
    while i < a_rows {
        let j = 0
        while j < b_cols {
            let sum = 0.0
            let k = 0
            while k < a_cols {
                sum = sum + a[i][k] * b[k][j]
                k = k + 1
            }
            result = matrix_set(result, i, j, sum)
            j = j + 1
        }
        i = i + 1
    }
    return result
}

fn matrix_det(m) -> float {
    let n = len(m)
    if n == 0 { return 1.0 }
    if n == 1 { return m[0][0] }
    if n == 2 { return m[0][0] * m[1][1] - m[0][1] * m[1][0] }

    let result = 0.0
    let j = 0
    while j < n {
        let sub = matrix_submatrix(m, 0, j)
        let sign = 1.0
        if j % 2 == 1 { sign = -1.0 }
        result = result + sign * m[0][j] * matrix_det(sub)
        j = j + 1
    }
    return result
}

fn matrix_submatrix(m, skip_row, skip_col) {
    let n = len(m)
    let sub = []
    let i = 0
    while i < n {
        if i != skip_row {
            let row = []
            let j = 0
            while j < n {
                if j != skip_col {
                    row = array_push(row, m[i][j])
                }
                j = j + 1
            }
            sub = array_push(sub, row)
        }
        i = i + 1
    }
    return sub
}
