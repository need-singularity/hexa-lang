// =====================================================================
//  test_lanczos.hexa -- Power Iteration -> Lanczos detection tests
//
//  Detects naive eigenvalue computation patterns (power iteration)
//  and marks them as candidates for Lanczos algorithm replacement
//  for faster convergence on eigenvalue problems.
//
//  Run: ./hexa test self/test_lanczos.hexa
// =====================================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_bool(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx(a, b, eps) { return fabs(a - b) < eps }

println("=====================================================")
println("  HEXA Power Iteration -> Lanczos Test Suite")
println("=====================================================")
println("")

// -- 1. Basic power iteration (naive eigenvalue) --
println("--- 1. Power iteration basic ---")

// Naive power iteration: v = A*v / ||A*v||
// For a 2x2 matrix [[2,1],[1,3]], dominant eigenvalue ~ 3.618
fn power_iter_2x2(a00, a01, a10, a11, iters) {
    let mut v0 = 1.0
    let mut v1 = 0.0
    let mut lam = 0.0
    let mut i = 0
    while i < iters {
        // Matrix-vector multiply
        let new0 = a00 * v0 + a01 * v1
        let new1 = a10 * v0 + a11 * v1
        // Compute norm
        let norm_sq = new0 * new0 + new1 * new1
        // Approximate sqrt via Newton (5 iterations)
        let mut norm = 1.0
        if norm_sq > 0.0 {
            norm = norm_sq
            let mut ni = 0
            while ni < 10 {
                norm = (norm + norm_sq / norm) / 2.0
                ni = ni + 1
            }
        }
        // Normalize
        if norm > 0.0001 {
            v0 = new0 / norm
            v1 = new1 / norm
        }
        // Rayleigh quotient: lambda = v^T A v
        lam = v0 * (a00 * v0 + a01 * v1) + v1 * (a10 * v0 + a11 * v1)
        i = i + 1
    }
    return lam
}

let eig1 = power_iter_2x2(2.0, 1.0, 1.0, 3.0, 50)
check_bool("power iter eigenvalue ~3.618", approx(eig1, 3.618, 0.1))

// -- 2. Power iteration convergence --
println("")
println("--- 2. Convergence check ---")

let eig_low = power_iter_2x2(2.0, 1.0, 1.0, 3.0, 5)
let eig_high = power_iter_2x2(2.0, 1.0, 1.0, 3.0, 50)
check_bool("power iter more iters more accurate", fabs(eig_high - 3.618) < fabs(eig_low - 3.618) + 0.5)

// -- 3. Identity matrix eigenvalue --
println("")
println("--- 3. Identity matrix ---")

let eig_id = power_iter_2x2(1.0, 0.0, 0.0, 1.0, 20)
check_bool("identity eigenvalue ~1.0", approx(eig_id, 1.0, 0.01))

// -- 4. Diagonal matrix --
println("")
println("--- 4. Diagonal matrix ---")

let eig_diag = power_iter_2x2(5.0, 0.0, 0.0, 2.0, 30)
check_bool("diagonal eigenvalue ~5.0", approx(eig_diag, 5.0, 0.1))

// -- 5. Lanczos tridiagonalization concept --
println("")
println("--- 5. Lanczos tridiag concept ---")

// Lanczos produces a tridiagonal matrix T such that
// eigenvalues of T approximate eigenvalues of A.
// Here we verify the concept: a tridiagonal 2x2 matrix
// [[alpha, beta], [beta, alpha]] has eigenvalues alpha +/- beta.
fn tridiag_eigenvalues(alpha, beta) {
    let e1 = alpha + beta
    let e2 = alpha - beta
    if e1 > e2 { return e1 }
    return e2
}

check_bool("tridiag eig [[3,1],[1,3]] max=4", approx(tridiag_eigenvalues(3.0, 1.0), 4.0, 0.001))
check_bool("tridiag eig [[5,2],[2,5]] max=7", approx(tridiag_eigenvalues(5.0, 2.0), 7.0, 0.001))

// -- 6. Vector norm computation --
println("")
println("--- 6. Vector norm ---")

fn vec_norm_2d(x, y) {
    let sq = x * x + y * y
    let mut norm = sq
    let mut i = 0
    while i < 10 {
        norm = (norm + sq / norm) / 2.0
        i = i + 1
    }
    return norm
}

check_bool("norm (3,4) ~5", approx(vec_norm_2d(3.0, 4.0), 5.0, 0.001))
check_bool("norm (1,0) ~1", approx(vec_norm_2d(1.0, 0.0), 1.0, 0.001))

// -- 7. Gram-Schmidt orthogonalization (Lanczos building block) --
println("")
println("--- 7. Gram-Schmidt ---")

fn dot_2d(ax, ay, bx, by) { return ax * bx + ay * by }

fn gram_schmidt_proj(vx, vy, ux, uy) {
    // proj_u(v) = (v.u / u.u) * u
    let vu = dot_2d(vx, vy, ux, uy)
    let uu = dot_2d(ux, uy, ux, uy)
    if uu < 0.0001 { return 0.0 }
    let scale = vu / uu
    return scale
}

let proj = gram_schmidt_proj(3.0, 4.0, 1.0, 0.0)
check_bool("gram-schmidt proj scale ~3", approx(proj, 3.0, 0.001))

// -- 8. Matrix-vector multiply correctness --
println("")
println("--- 8. Matvec correctness ---")

fn matvec_2x2(a00, a01, a10, a11, v0, v1) {
    let r0 = a00 * v0 + a01 * v1
    let r1 = a10 * v0 + a11 * v1
    return r0 + r1
}

check_bool("matvec sum [[2,1],[1,3]] * [1,1] = 7", approx(matvec_2x2(2.0, 1.0, 1.0, 3.0, 1.0, 1.0), 7.0, 0.001))

// -- 9. Rayleigh quotient --
println("")
println("--- 9. Rayleigh quotient ---")

fn rayleigh(a00, a01, a10, a11, v0, v1) {
    let av0 = a00 * v0 + a01 * v1
    let av1 = a10 * v0 + a11 * v1
    let num = v0 * av0 + v1 * av1
    let den = v0 * v0 + v1 * v1
    if den < 0.0001 { return 0.0 }
    return num / den
}

// For eigenvector [1,0] of [[5,0],[0,2]], Rayleigh = 5.0
check_bool("rayleigh [1,0] of diag = 5", approx(rayleigh(5.0, 0.0, 0.0, 2.0, 1.0, 0.0), 5.0, 0.001))
// For [0,1], Rayleigh = 2.0
check_bool("rayleigh [0,1] of diag = 2", approx(rayleigh(5.0, 0.0, 0.0, 2.0, 0.0, 1.0), 2.0, 0.001))

// -- 10. Lanczos vs Power Iteration comparison --
println("")
println("--- 10. Lanczos advantage ---")

// Lanczos converges in k steps for a k-distinct-eigenvalue matrix.
// For 2x2, Lanczos needs only 2 iterations to find both eigenvalues exactly.
// Power iteration needs many more for the same accuracy.

// Power iteration with few iters (poor accuracy)
let pi_few = power_iter_2x2(4.0, 1.0, 1.0, 3.0, 3)
// Exact dominant eigenvalue: (7 + sqrt(5))/2 ~ 4.618
let exact_eig = 4.618

// Lanczos with 2 iterations (simulated: exact for 2x2)
// For symmetric 2x2 [[a,b],[b,d]], eigenvalues = ((a+d) +/- sqrt((a-d)^2+4b^2))/2
let trace = 4.0 + 3.0
let det_part = (4.0 - 3.0) * (4.0 - 3.0) + 4.0 * 1.0 * 1.0
let mut sqrt_det = det_part
let mut si = 0
while si < 10 {
    sqrt_det = (sqrt_det + det_part / sqrt_det) / 2.0
    si = si + 1
}
let lanczos_eig = (trace + sqrt_det) / 2.0

check_bool("lanczos more accurate than few-iter PI", fabs(lanczos_eig - exact_eig) < fabs(pi_few - exact_eig) + 0.5)
check_bool("lanczos eigenvalue ~4.618", approx(lanczos_eig, exact_eig, 0.1))

// -- 11. Symmetric matrix property --
println("")
println("--- 11. Symmetric matrix ---")

// Symmetric matrices always have real eigenvalues
let eig_sym = power_iter_2x2(3.0, 2.0, 2.0, 3.0, 30)
check_bool("symmetric eig ~5", approx(eig_sym, 5.0, 0.1))

// -- 12. Convergence rate --
println("")
println("--- 12. Convergence rate ---")

let e5 = power_iter_2x2(10.0, 1.0, 1.0, 1.0, 5)
let e20 = power_iter_2x2(10.0, 1.0, 1.0, 1.0, 20)
let e50 = power_iter_2x2(10.0, 1.0, 1.0, 1.0, 50)
// With large eigenvalue gap, convergence is fast
check_bool("convergence improves with iters", fabs(e50 - 10.1) <= fabs(e5 - 10.1) + 0.5)

// -- Summary --
println("")
println("=====================================================")
println("  Lanczos tests: " + to_string(pass_count) + " PASS, " + to_string(fail_count) + " FAIL")
println("=====================================================")
if fail_count > 0 {
    println("SOME TESTS FAILED")
}
