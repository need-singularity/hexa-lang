// ═══════════════════════════════════════════════════════════
//  test_ir_phase2.hexa — Phase2 IR Pipeline Tests
//
//  Validates three new features through the self-hosting pipeline:
//    1. Match expressions — pattern matching with value production
//    2. Enum types — tagged variants with match dispatch
//    3. Try/catch — error handling with recovery
//
//  Tests both runtime behavior (interpreter) and codegen output
//  (verifying the C backend produces correct strings).
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  Phase2 IR Test — Match + Enum + Try/Catch")
println("═══════════════════════════════════════════════════════")
println("")

// ═══════════════════════════════════════════════════════════
//  Section 1: Match Expressions (value-producing)
// ═══════════════════════════════════════════════════════════

println("--- 1. Match Expressions ---")

// 1a: Match on integers
fn classify_num(n) {
    return match n {
        0 ->"zero",
        1 ->"one",
        2 ->"two",
        _ ->"many"
    }
}
check("1a match int 0", classify_num(0), "zero")
check("1b match int 1", classify_num(1), "one")
check("1c match int 2", classify_num(2), "two")
check("1d match int wildcard", classify_num(99), "many")

// 1b: Match producing numeric values
// decreases n — structural
fn fib_match(n) {
    return match n {
        0 ->0,
        1 ->1,
        _ ->fib_match(n - 1) + fib_match(n - 2)
    }
}
check("1e fib(0)", fib_match(0), 0)
check("1f fib(1)", fib_match(1), 1)
check("1g fib(5)", fib_match(5), 5)
check("1h fib(8)", fib_match(8), 21)

// 1c: Match on strings
fn greet(lang) {
    return match lang {
        "en" ->"hello",
        "ko" ->"annyeong",
        "jp" ->"konnichiwa",
        _ ->"hi"
    }
}
check("1i match str en", greet("en"), "hello")
check("1j match str ko", greet("ko"), "annyeong")
check("1k match str default", greet("fr"), "hi")

// 1d: Match on booleans
fn bool_to_str(b) {
    return match b {
        true ->"yes",
        false ->"no"
    }
}
check("1l match bool true", bool_to_str(true), "yes")
check("1m match bool false", bool_to_str(false), "no")

// 1e: Nested match
fn nested_match(x, y) {
    let outer = match x {
        0 ->100,
        _ ->200
    }
    let inner = match y {
        0 ->10,
        _ ->20
    }
    return outer + inner
}
check("1n nested match 0,0", nested_match(0, 0), 110)
check("1o nested match 0,1", nested_match(0, 1), 120)
check("1p nested match 1,0", nested_match(1, 0), 210)
check("1q nested match 1,1", nested_match(1, 1), 220)

// ═══════════════════════════════════════════════════════════
//  Section 2: Enum Types
// ═══════════════════════════════════════════════════════════

println("")
println("--- 2. Enum Types ---")

// 2a: Simple enum declaration and variant usage
enum Color {
    Red,
    Green,
    Blue
}

check("2a enum Red", Color::Red, Color::Red)
check("2b enum variant identity", to_string(Color::Red) != to_string(Color::Blue), true)

// 2b: Match on enum variants
fn color_name(c) {
    return match c {
        Color::Red ->"red",
        Color::Green ->"green",
        Color::Blue ->"blue",
        _ ->"unknown"
    }
}
check("2c match enum Red", color_name(Color::Red), "red")
check("2d match enum Green", color_name(Color::Green), "green")
check("2e match enum Blue", color_name(Color::Blue), "blue")

// 2c: Enum in computation
enum Direction {
    North,
    South,
    East,
    West
}

fn dir_dx(d) {
    return match d {
        Direction::East ->1,
        Direction::West ->-1,
        _ ->0
    }
}
fn dir_dy(d) {
    return match d {
        Direction::North ->1,
        Direction::South ->-1,
        _ ->0
    }
}
check("2f dir East dx", dir_dx(Direction::East), 1)
check("2g dir West dx", dir_dx(Direction::West), -1)
check("2h dir North dx", dir_dx(Direction::North), 0)
check("2i dir North dy", dir_dy(Direction::North), 1)
check("2j dir South dy", dir_dy(Direction::South), -1)
check("2k dir East dy", dir_dy(Direction::East), 0)

// 2d: Enum used in loops and collections
fn count_reds(colors) {
    let mut count = 0
    let mut i = 0
    while i < len(colors) {
        let c = colors[i]
        let val = match c {
            Color::Red ->1,
            _ ->0
        }
        count = count + val
        i = i + 1
    }
    return count
}
let palette = [Color::Red, Color::Blue, Color::Red, Color::Green, Color::Red]
check("2l count reds", count_reds(palette), 3)

// 2e: Enum-based state machine step
enum State {
    Idle,
    Running,
    Done,
    Error
}

fn next_state(s) {
    return match s {
        State::Idle ->State::Running,
        State::Running ->State::Done,
        _ ->State::Error
    }
}
check("2m state Idle→Running", next_state(State::Idle), State::Running)
check("2n state Running→Done", next_state(State::Running), State::Done)
check("2o state Done→Error", next_state(State::Done), State::Error)

// ═══════════════════════════════════════════════════════════
//  Section 3: Try/Catch Error Handling
// ═══════════════════════════════════════════════════════════

println("")
println("--- 3. Try/Catch ---")

// 3a: Basic try/catch with throw
fn safe_divide(a, b) {
    if b == 0 {
        throw "division by zero"
    }
    return a / b
}

let mut result = 0
try {
    result = safe_divide(10, 2)
} catch e {
    result = -1
}
check("3a try no throw", result, 5)

let mut result2 = 0
try {
    result2 = safe_divide(10, 0)
} catch e {
    result2 = -1
}
check("3b try with throw", result2, -1)

// 3c: Nested try/catch
fn risky_nested(x) {
    let mut outer_result = 0
    try {
        if x < 0 {
            throw "negative"
        }
        let mut inner_result = 0
        try {
            if x == 0 {
                throw "zero"
            }
            inner_result = x * 10
        } catch e {
            inner_result = -1
        }
        outer_result = inner_result
    } catch e {
        outer_result = -999
    }
    return outer_result
}
check("3c nested positive", risky_nested(5), 50)
check("3d nested zero", risky_nested(0), -1)
check("3e nested negative", risky_nested(-1), -999)

// 3f: Try/catch in loop
fn sum_safe(vals) {
    let mut total = 0
    let mut i = 0
    while i < len(vals) {
        try {
            let v = vals[i]
            if v < 0 {
                throw "negative value"
            }
            total = total + v
        } catch e {
            // skip negative values
        }
        i = i + 1
    }
    return total
}
check("3f try in loop", sum_safe([1, 2, -3, 4, -5, 6]), 13)

// 3g: Error recovery with default
// 3g: Try/catch propagation across function calls
fn might_fail(x) {
    if x == 0 {
        throw "fail"
    }
    return x * x
}

fn safe_square(x) {
    let mut result = -1
    try {
        result = might_fail(x)
    } catch e {
        result = 0
    }
    return result
}
check("3g safe square 5", safe_square(5), 25)
check("3h safe square 0", safe_square(0), 0)

// ═══════════════════════════════════════════════════════════
//  Section 4: Combined — Match + Enum + Try/Catch
// ═══════════════════════════════════════════════════════════

println("")
println("--- 4. Combined Features ---")

// 4a: Match on enum inside try/catch
enum OpCode {
    Add,
    Sub,
    Mul,
    Div
}

fn safe_calc(op, a, b) {
    let mut result = 0
    try {
        result = match op {
            OpCode::Add ->a + b,
            OpCode::Sub ->a - b,
            OpCode::Mul ->a * b,
            OpCode::Div ->safe_divide(a, b),
            _ ->0
        }
    } catch e {
        result = -9999
    }
    return result
}
check("4a calc add", safe_calc(OpCode::Add, 10, 3), 13)
check("4b calc sub", safe_calc(OpCode::Sub, 10, 3), 7)
check("4c calc mul", safe_calc(OpCode::Mul, 10, 3), 30)
check("4d calc div", safe_calc(OpCode::Div, 10, 2), 5)
check("4e calc div/0", safe_calc(OpCode::Div, 10, 0), -9999)

// 4f: Enum state machine with error handling
enum Result {
    Ok,
    Err
}

fn process_step(state, input) {
    let mut outcome = Result::Err
    try {
        if input < 0 {
            throw "bad input"
        }
        outcome = match state {
            State::Idle ->Result::Ok,
            State::Running ->Result::Ok,
            _ ->Result::Err
        }
    } catch e {
        outcome = Result::Err
    }
    return outcome
}
check("4f process Idle+valid", process_step(State::Idle, 1), Result::Ok)
check("4g process Running+valid", process_step(State::Running, 1), Result::Ok)
check("4h process Done+valid", process_step(State::Done, 1), Result::Err)
check("4i process Idle+invalid", process_step(State::Idle, -1), Result::Err)

// 4j: Match with complex arm bodies
fn categorize(x) {
    return match true {
        (x > 100) ->"big",
        (x > 10) ->"medium",
        (x > 0) ->"small",
        _ ->"non-positive"
    }
}
check("4j categorize 200", categorize(200), "big")
check("4k categorize 50", categorize(50), "medium")
check("4l categorize 5", categorize(5), "small")
check("4m categorize -1", categorize(-1), "non-positive")

// ═══════════════════════════════════════════════════════════
//  Summary
// ═══════════════════════════════════════════════════════════

println("")
println("═══════════════════════════════════════════════════════")
println("  Phase2 IR Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    println("FAIL")
} else {
    println("ALL PASS")
}
