// ═══════════════════════════════════════════════════════════════
//  test_kan.hexa — Kolmogorov-Arnold Network verification (#194 + #328)
//
//  Tests (44):
//    T1  kan_abs positive
//    T2  kan_abs negative
//    T3  kan_zeros length + all zero
//    T4  kan_max_f picks larger
//    T5  kan_min_f picks smaller
//    T6  kan_clamp in-range passthrough
//    T7  kan_clamp low saturation
//    T8  kan_clamp high saturation
//    T9  kan_lcg_next deterministic
//    T10 kan_lcg_float in [-1,1]
//    T11 kan_uniform_knots total count
//    T12 kan_uniform_knots monotonic
//    T13 kan_uniform_knots boundary repeats
//    T14 kan_bspline_basis partition of unity
//    T15 kan_bspline_basis non-negative
//    T16 kan_bspline_eval smooth bounded
//    T17 kan_init_coeffs length == n_basis
//    T18 kan_init_coeffs small magnitude
//    T19 kan_create_layer structure
//    T20 kan_create_layer edge count = in*out*n_basis
//    T21 kan_layer_forward output length == out_dim
//    T22 kan_create_network correct layer count
//    T23 kan_forward shape propagation
//    T24 kan_forward chaining non-trivial
//    T25 kan_param_count > 0
//    T26 kan_param_count matches manual calculation
//    T27 kan_regularization >= 0
//    T28 kan_regularization scales with lambda
//    T29 kan_prune_edge zeroes specific edge
//    T30 kan_prune_edge leaves other edges intact
//    T31 kan_edge_magnitudes non-negative
//    T32 kan_edge_magnitudes correct length
//    T33 kan_auto_prune removes small edges
//    T34 kan_mse_loss >= 0
//    T35 kan_mse_loss zero on identical
//    T36 kan_train_step changes params
//    T37 kan_ls_solve identity system
//    T38 kan_ls_solve overdetermined system
//    T39 kan_grid_extend_layer increases n_basis
//    T40 kan_grid_extend_layer preserves dims
//    T41 kan_grid_extend_layer approximates old spline
//    T42 kan_grid_extend whole network structure
//    T43 kan_grid_extend forward still works
//    T44 kan_grid_extend no-op when new <= old
//
//  Run: ./hexa self/test_kan.hexa
// ═══════════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx(a, b, eps) { return fabs(a - b) < eps }

// ═══════════════════════════════════════════════════════════════
//  Inlined KAN implementation (copied from self/ml/kan.hexa)
// ═══════════════════════════════════════════════════════════════

fn kan_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn kan_zeros(n) {
    let mut v = []
    for _i in 0..n { v = v + [0.0] }
    return v
}

fn kan_max_f(a, b) {
    if a > b { return a }
    return b
}

fn kan_min_f(a, b) {
    if a < b { return a }
    return b
}

fn kan_clamp(x, lo, hi) {
    if x < lo { return lo }
    if x > hi { return hi }
    return x
}

fn kan_lcg_next(seed) {
    return (seed * 1103515245 + 12345) % 2147483647
}

fn kan_lcg_float(seed) {
    return (to_float(seed % 2000) - 1000.0) / 1000.0
}

@pure
fn kan_uniform_knots(lo, hi, n_internal, degree) {
    let n_total = n_internal + 2 * (degree + 1)
    let mut knots = kan_zeros(n_total)

    for i in 0..(degree + 1) {
        knots[i] = lo
    }

    if n_internal > 0 {
        let step = (hi - lo) / to_float(n_internal + 1)
        for i in 0..n_internal {
            knots[degree + 1 + i] = lo + step * to_float(i + 1)
        }
    }

    for i in 0..(degree + 1) {
        knots[degree + 1 + n_internal + i] = hi
    }

    return knots
}

@pure
fn kan_bspline_basis(x, knots, n_knots, degree, i) {
    if degree == 0 {
        if i == n_knots - 2 {
            if x >= knots[i] {
                if x <= knots[i + 1] { return 1.0 }
            }
            return 0.0
        }
        if x >= knots[i] {
            if x < knots[i + 1] { return 1.0 }
        }
        return 0.0
    }

    let mut result = 0.0

    let denom1 = knots[i + degree] - knots[i]
    if kan_abs(denom1) > 1.0e-12 {
        let b1 = kan_bspline_basis(x, knots, n_knots, degree - 1, i)
        result = result + (x - knots[i]) / denom1 * b1
    }

    let denom2 = knots[i + degree + 1] - knots[i + 1]
    if kan_abs(denom2) > 1.0e-12 {
        let b2 = kan_bspline_basis(x, knots, n_knots, degree - 1, i + 1)
        result = result + (knots[i + degree + 1] - x) / denom2 * b2
    }

    return result
}

@pure
fn kan_bspline_eval(x, coeffs, knots, n_knots, degree, n_basis) {
    let mut result = 0.0
    for i in 0..n_basis {
        let b = kan_bspline_basis(x, knots, n_knots, degree, i)
        result = result + coeffs[i] * b
    }
    return result
}

fn kan_init_coeffs(n_basis) {
    let mut coeffs = kan_zeros(n_basis)
    let scale = 0.1 / to_float(n_basis)
    let mut seed = n_basis * 7 + 42
    for i in 0..n_basis {
        seed = kan_lcg_next(seed)
        coeffs[i] = kan_lcg_float(seed) * scale
    }
    return coeffs
}

fn kan_create_layer(in_dim, out_dim, n_basis, degree) {
    let n_internal = n_basis - degree - 1
    let safe_internal = kan_max_f(to_float(n_internal), 0.0)

    let knots = kan_uniform_knots(-1.0, 1.0, to_int(safe_internal), degree)

    let n_edges = out_dim * in_dim
    let total_coeffs = n_edges * n_basis
    let mut coeffs_flat = kan_zeros(total_coeffs)
    let scale = 0.1 / to_float(n_basis)
    let mut seed = in_dim * 31 + out_dim * 17 + n_basis * 7 + 42
    for idx in 0..total_coeffs {
        seed = kan_lcg_next(seed)
        coeffs_flat[idx] = kan_lcg_float(seed) * scale
    }

    return [coeffs_flat, knots, in_dim, out_dim, n_basis, degree]
}

@hot
@pure
fn kan_layer_forward(layer, input, in_dim) {
    let coeffs_flat = layer[0]
    let knots = layer[1]
    let l_in_dim = to_int(layer[2])
    let l_out_dim = to_int(layer[3])
    let n_basis = to_int(layer[4])
    let degree = to_int(layer[5])
    let n_knots = len(knots)

    let mut output = kan_zeros(l_out_dim)

    for out_i in 0..l_out_dim {
        let mut sum_val = 0.0
        for in_j in 0..l_in_dim {
            let base = (out_i * l_in_dim + in_j) * n_basis
            let mut edge_coeffs = kan_zeros(n_basis)
            for k in 0..n_basis {
                edge_coeffs[k] = coeffs_flat[base + k]
            }
            let x_val = kan_clamp(input[in_j], -1.0, 1.0)
            let phi = kan_bspline_eval(x_val, edge_coeffs, knots, n_knots, degree, n_basis)
            sum_val = sum_val + phi
        }
        output[out_i] = sum_val
    }

    return output
}

fn kan_create_network(layer_dims, n_basis, degree) {
    let n_layers = len(layer_dims) - 1
    let mut layers = []
    for i in 0..n_layers {
        let in_d = layer_dims[i]
        let out_d = layer_dims[i + 1]
        let layer = kan_create_layer(in_d, out_d, n_basis, degree)
        layers = layers + [layer]
    }
    return layers
}

@hot
fn kan_forward(network, input) {
    let n_layers = len(network)
    let mut act = input
    for i in 0..n_layers {
        let layer = network[i]
        let in_d = to_int(layer[2])
        act = kan_layer_forward(layer, act, in_d)
    }
    return act
}

@pure
fn kan_param_count(network) {
    let n_layers = len(network)
    let mut total = 0
    for i in 0..n_layers {
        let layer = network[i]
        total = total + len(layer[0])
    }
    return total
}

@pure
fn kan_regularization(network, lambda_l1) {
    let n_layers = len(network)
    let mut total = 0.0
    for i in 0..n_layers {
        let coeffs = network[i][0]
        let nc = len(coeffs)
        for j in 0..nc {
            total = total + kan_abs(coeffs[j])
        }
    }
    return lambda_l1 * total
}

fn kan_prune_edge(network, layer_idx, in_idx, out_idx) {
    let n_layers = len(network)
    let mut new_net = []
    for i in 0..n_layers {
        if i == layer_idx {
            let layer = network[i]
            let coeffs = layer[0]
            let l_in_dim = to_int(layer[2])
            let n_basis = to_int(layer[4])
            let base = (out_idx * l_in_dim + in_idx) * n_basis

            let nc = len(coeffs)
            let mut new_coeffs = kan_zeros(nc)
            for j in 0..nc {
                if j >= base {
                    if j < base + n_basis {
                        new_coeffs[j] = 0.0
                    } else {
                        new_coeffs[j] = coeffs[j]
                    }
                } else {
                    new_coeffs[j] = coeffs[j]
                }
            }
            new_net = new_net + [[new_coeffs, layer[1], layer[2], layer[3], layer[4], layer[5]]]
        } else {
            new_net = new_net + [network[i]]
        }
    }
    return new_net
}

fn kan_mse_loss(output, target) {
    let n = len(output)
    if n == 0 { return 0.0 }
    let mut total = 0.0
    for i in 0..n {
        let d = output[i] - target[i]
        total = total + d * d
    }
    return total / to_float(n)
}

@hot
fn kan_train_step(network, input, target, lr) {
    let eps = 1.0e-4
    let n_layers = len(network)

    let pred = kan_forward(network, input)
    let loss0 = kan_mse_loss(pred, target)

    let mut new_net = []
    for li in 0..n_layers {
        let layer = network[li]
        let coeffs = layer[0]
        let nc = len(coeffs)
        let mut new_coeffs = kan_zeros(nc)
        for ci in 0..nc {
            new_coeffs[ci] = coeffs[ci]
        }

        for ci in 0..nc {
            let old_val = new_coeffs[ci]
            new_coeffs[ci] = old_val + eps

            let mut tmp_net = []
            for li2 in 0..n_layers {
                if li2 == li {
                    tmp_net = tmp_net + [[new_coeffs, layer[1], layer[2], layer[3], layer[4], layer[5]]]
                } else {
                    tmp_net = tmp_net + [network[li2]]
                }
            }

            let pred_p = kan_forward(tmp_net, input)
            let loss_p = kan_mse_loss(pred_p, target)
            let grad = (loss_p - loss0) / eps

            new_coeffs[ci] = old_val - lr * grad
        }

        new_net = new_net + [[new_coeffs, layer[1], layer[2], layer[3], layer[4], layer[5]]]
    }

    return new_net
}

@pure
fn kan_edge_magnitudes(layer) {
    let coeffs = layer[0]
    let l_in_dim = to_int(layer[2])
    let l_out_dim = to_int(layer[3])
    let n_basis = to_int(layer[4])
    let n_edges = l_out_dim * l_in_dim

    let mut mags = kan_zeros(n_edges)
    for e in 0..n_edges {
        let base = e * n_basis
        let mut mag = 0.0
        for k in 0..n_basis {
            mag = mag + kan_abs(coeffs[base + k])
        }
        mags[e] = mag
    }
    return mags
}

fn kan_auto_prune(network, threshold) {
    let n_layers = len(network)
    let mut new_net = []
    for li in 0..n_layers {
        let layer = network[li]
        let mags = kan_edge_magnitudes(layer)
        let l_in_dim = to_int(layer[2])
        let l_out_dim = to_int(layer[3])
        let n_basis = to_int(layer[4])

        let mut pruned_net = new_net + [layer]
        let mut cur_net = pruned_net
        for out_i in 0..l_out_dim {
            for in_j in 0..l_in_dim {
                let edge_idx = out_i * l_in_dim + in_j
                if mags[edge_idx] < threshold {
                    let last_idx = len(cur_net) - 1
                    let cur_layer = cur_net[last_idx]
                    let coeffs = cur_layer[0]
                    let base = (out_i * l_in_dim + in_j) * n_basis
                    let nc = len(coeffs)
                    let mut nc2 = kan_zeros(nc)
                    for ci in 0..nc {
                        if ci >= base {
                            if ci < base + n_basis {
                                nc2[ci] = 0.0
                            } else {
                                nc2[ci] = coeffs[ci]
                            }
                        } else {
                            nc2[ci] = coeffs[ci]
                        }
                    }
                    let mut rebuilt = []
                    for ri in 0..last_idx {
                        rebuilt = rebuilt + [cur_net[ri]]
                    }
                    rebuilt = rebuilt + [[nc2, cur_layer[1], cur_layer[2], cur_layer[3], cur_layer[4], cur_layer[5]]]
                    cur_net = rebuilt
                }
            }
        }
        new_net = cur_net
    }
    return new_net
}

// ═══════════════════════════════════════════════════════════════
//  Test suite
// ═══════════════════════════════════════════════════════════════

// T1: kan_abs positive
check("T1 kan_abs positive", approx(kan_abs(3.5), 3.5, 1.0e-9))

// T2: kan_abs negative
check("T2 kan_abs negative", approx(kan_abs(-2.0), 2.0, 1.0e-9))

// T3: kan_zeros length + all zero
let z5 = kan_zeros(5)
let mut z_ok = (len(z5) == 5)
for i in 0..5 {
    if z5[i] != 0.0 { z_ok = false }
}
check("T3 kan_zeros length + all zero", z_ok)

// T4: kan_max_f picks larger
check("T4 kan_max_f", approx(kan_max_f(1.5, 2.5), 2.5, 1.0e-9))

// T5: kan_min_f picks smaller
check("T5 kan_min_f", approx(kan_min_f(1.5, 2.5), 1.5, 1.0e-9))

// T6: kan_clamp in-range passthrough
check("T6 kan_clamp passthrough", approx(kan_clamp(0.5, -1.0, 1.0), 0.5, 1.0e-9))

// T7: kan_clamp low saturation
check("T7 kan_clamp low", approx(kan_clamp(-2.0, -1.0, 1.0), -1.0, 1.0e-9))

// T8: kan_clamp high saturation
check("T8 kan_clamp high", approx(kan_clamp(2.0, -1.0, 1.0), 1.0, 1.0e-9))

// T9: kan_lcg_next deterministic
let s1 = kan_lcg_next(42)
let s2 = kan_lcg_next(42)
check("T9 kan_lcg_next deterministic", s1 == s2)

// T10: kan_lcg_float in [-1,1]
let mut lcg_ok = true
let mut ss = 17
for _i in 0..50 {
    ss = kan_lcg_next(ss)
    let f = kan_lcg_float(ss)
    if f < -1.0 { lcg_ok = false }
    if f > 1.0 { lcg_ok = false }
}
check("T10 kan_lcg_float in [-1,1]", lcg_ok)

// T11: kan_uniform_knots total count
// count = n_internal + 2*(degree+1)
let k1 = kan_uniform_knots(-1.0, 1.0, 3, 2)
check("T11 kan_uniform_knots count", len(k1) == 3 + 2 * (2 + 1))

// T12: kan_uniform_knots monotonic
let mut mono = true
for i in 0..(len(k1) - 1) {
    if k1[i] > k1[i + 1] { mono = false }
}
check("T12 kan_uniform_knots monotonic", mono)

// T13: kan_uniform_knots boundary repeats
// First (degree+1) knots == lo, last (degree+1) knots == hi
let mut bnd_ok = true
for i in 0..3 {
    if !approx(k1[i], -1.0, 1.0e-9) { bnd_ok = false }
}
let nk = len(k1)
for i in 0..3 {
    if !approx(k1[nk - 1 - i], 1.0, 1.0e-9) { bnd_ok = false }
}
check("T13 kan_uniform_knots boundary repeats", bnd_ok)

// T14: kan_bspline_basis partition of unity
// For clamped B-spline of degree d with n_basis = n_internal + d + 1,
// sum_i B_{i,d}(x) ≈ 1 for x inside the valid interval [knots[d], knots[n_knots-d-1]]
let deg_pu = 2
let n_int_pu = 3
let n_basis_pu = n_int_pu + deg_pu + 1
let knots_pu = kan_uniform_knots(-1.0, 1.0, n_int_pu, deg_pu)
let nk_pu = len(knots_pu)
let mut pu_ok = true
let test_xs = [-0.9, -0.5, 0.0, 0.3, 0.8]
for tx_i in 0..5 {
    let x_pu = test_xs[tx_i]
    let mut s_pu = 0.0
    for i in 0..n_basis_pu {
        s_pu = s_pu + kan_bspline_basis(x_pu, knots_pu, nk_pu, deg_pu, i)
    }
    if !approx(s_pu, 1.0, 1.0e-6) { pu_ok = false }
}
check("T14 kan_bspline_basis partition of unity", pu_ok)

// T15: kan_bspline_basis non-negative
let mut nn_ok = true
let xs_nn = [-0.9, -0.4, 0.0, 0.4, 0.9]
for xi in 0..5 {
    for i in 0..n_basis_pu {
        let b = kan_bspline_basis(xs_nn[xi], knots_pu, nk_pu, deg_pu, i)
        if b < 0.0 - 1.0e-9 { nn_ok = false }
    }
}
check("T15 kan_bspline_basis non-negative", nn_ok)

// T16: kan_bspline_eval smooth bounded
// With init coeffs of scale ~ 0.1/n_basis, output should be small (< 1)
let coeffs_eval = kan_init_coeffs(n_basis_pu)
let mut eval_ok = true
for xi in 0..5 {
    let v = kan_bspline_eval(xs_nn[xi], coeffs_eval, knots_pu, nk_pu, deg_pu, n_basis_pu)
    if fabs(v) > 1.0 { eval_ok = false }
}
check("T16 kan_bspline_eval bounded", eval_ok)

// T17: kan_init_coeffs length == n_basis
let c6 = kan_init_coeffs(6)
check("T17 kan_init_coeffs length", len(c6) == 6)

// T18: kan_init_coeffs small magnitude
// scale = 0.1/n_basis, values in [-scale, scale], max |coeffs| < 0.1
let mut small_ok = true
for i in 0..6 {
    if fabs(c6[i]) > 0.1 { small_ok = false }
}
check("T18 kan_init_coeffs small", small_ok)

// T19: kan_create_layer structure
// layer = [coeffs_flat, knots, in_dim, out_dim, n_basis, degree]
let lay = kan_create_layer(2, 3, 5, 2)
check("T19 kan_create_layer structure", len(lay) == 6 && to_int(lay[2]) == 2 && to_int(lay[3]) == 3 && to_int(lay[4]) == 5 && to_int(lay[5]) == 2)

// T20: kan_create_layer coeffs length = in_dim * out_dim * n_basis
check("T20 kan_create_layer edge count", len(lay[0]) == 2 * 3 * 5)

// T21: kan_layer_forward output length == out_dim
let input1 = [0.3, -0.5]
let out1 = kan_layer_forward(lay, input1, 2)
check("T21 kan_layer_forward output len", len(out1) == 3)

// T22: kan_create_network correct layer count
// layer_dims [2,4,3,1] -> 3 layers
let net_dims = [2, 4, 3, 1]
let net = kan_create_network(net_dims, 5, 2)
check("T22 kan_create_network n_layers", len(net) == 3)

// T23: kan_forward shape propagation
let net_in = [0.2, -0.4]
let net_out = kan_forward(net, net_in)
check("T23 kan_forward output len = 1", len(net_out) == 1)

// T24: kan_forward intermediate chaining non-trivial (different inputs → different outputs)
let out_a = kan_forward(net, [0.1, 0.2])
let out_b = kan_forward(net, [-0.5, 0.7])
check("T24 kan_forward non-trivial chaining", !approx(out_a[0], out_b[0], 1.0e-12))

// T25: kan_param_count > 0
let pc = kan_param_count(net)
check("T25 kan_param_count > 0", pc > 0)

// T26: kan_param_count matches manual calculation
// layers: [2,4,3,1], n_basis=5
// layer0: 2*4*5 = 40
// layer1: 4*3*5 = 60
// layer2: 3*1*5 = 15
// total = 115
let expected_pc = 2 * 4 * 5 + 4 * 3 * 5 + 3 * 1 * 5
check("T26 kan_param_count manual", pc == expected_pc)

// T27: kan_regularization >= 0
let reg1 = kan_regularization(net, 0.01)
check("T27 kan_regularization >= 0", reg1 >= 0.0)

// T28: kan_regularization scales with lambda
// reg(lambda=0.02) == 2 * reg(lambda=0.01)
let reg2 = kan_regularization(net, 0.02)
check("T28 kan_regularization scales", approx(reg2, 2.0 * reg1, 1.0e-9))

// T29: kan_prune_edge zeroes specific edge
// Prune edge (in_idx=1, out_idx=2) in layer 0 (which is 2->4)
// After prune, coeffs at base = (2*2 + 1)*5 = 25..30 should be zero
let net_p = kan_prune_edge(net, 0, 1, 2)
let pruned_layer0 = net_p[0]
let pruned_coeffs = pruned_layer0[0]
let base_pruned = (2 * 2 + 1) * 5
let mut pe_ok = true
for k in 0..5 {
    if pruned_coeffs[base_pruned + k] != 0.0 { pe_ok = false }
}
check("T29 kan_prune_edge zeroes target", pe_ok)

// T30: kan_prune_edge leaves other edges intact
// Check edge (0,0) in layer 0 is still non-zero (original values at base=0)
let orig_coeffs = net[0][0]
let mut intact_ok = true
for k in 0..5 {
    if pruned_coeffs[k] != orig_coeffs[k] { intact_ok = false }
}
check("T30 kan_prune_edge leaves other intact", intact_ok)

// T31: kan_edge_magnitudes non-negative
let mags = kan_edge_magnitudes(net[0])
let mut mg_nn = true
for i in 0..len(mags) {
    if mags[i] < 0.0 { mg_nn = false }
}
check("T31 kan_edge_magnitudes non-negative", mg_nn)

// T32: kan_edge_magnitudes correct length
// layer 0 is 2->4 → 8 edges
check("T32 kan_edge_magnitudes len", len(mags) == 2 * 4)

// T33: kan_auto_prune removes small edges
// Use very large threshold so everything gets pruned
let net_pruned_all = kan_auto_prune(net, 100.0)
let mags_after = kan_edge_magnitudes(net_pruned_all[0])
let mut all_zero = true
for i in 0..len(mags_after) {
    if mags_after[i] > 1.0e-12 { all_zero = false }
}
check("T33 kan_auto_prune large threshold zeros all", all_zero)

// T34: kan_mse_loss >= 0
let l1 = kan_mse_loss([0.3, -0.2], [0.1, 0.0])
check("T34 kan_mse_loss >= 0", l1 >= 0.0)

// T35: kan_mse_loss zero on identical
let l_same = kan_mse_loss([0.5, 0.3], [0.5, 0.3])
check("T35 kan_mse_loss zero on identical", approx(l_same, 0.0, 1.0e-12))

// T36: kan_train_step changes params (use small network for speed)
// Use a tiny network [2,2,1] with n_basis=3, degree=1 so finite diff is cheap
let small_dims = [2, 2, 1]
let small_net = kan_create_network(small_dims, 3, 1)
let tr_input = [0.3, -0.4]
let tr_target = [1.0]
let updated = kan_train_step(small_net, tr_input, tr_target, 0.01)
let orig_c0 = small_net[0][0]
let new_c0 = updated[0][0]
let mut changed = false
for i in 0..len(orig_c0) {
    if !approx(orig_c0[i], new_c0[i], 1.0e-12) { changed = true }
}
check("T36 kan_train_step changes params", changed)

// ═══════════════════════════════════════════════════════════════
//  Grid Extension Tests (#328)
// ═══════════════════════════════════════════════════════════════

// ── Inlined grid extension code ──

@pure
fn kan_ls_solve(a_mat, b_vec, rows, cols) {
    let mut ata = []
    for i in 0..cols {
        let mut row = kan_zeros(cols)
        for j in 0..cols {
            let mut s = 0.0
            for k in 0..rows {
                s = s + a_mat[k * cols + i] * a_mat[k * cols + j]
            }
            row[j] = s
        }
        ata = ata + [row]
    }

    let mut atb = kan_zeros(cols)
    for i in 0..cols {
        let mut s = 0.0
        for k in 0..rows {
            s = s + a_mat[k * cols + i] * b_vec[k]
        }
        atb[i] = s
    }

    for col in 0..cols {
        let mut best_row = col
        let mut best_val = kan_abs(ata[col][col])
        for r in (col + 1)..cols {
            let v = kan_abs(ata[r][col])
            if v > best_val {
                best_val = v
                best_row = r
            }
        }

        if best_row != col {
            let tmp_row = ata[col]
            ata[col] = ata[best_row]
            ata[best_row] = tmp_row
            let tmp_b = atb[col]
            atb[col] = atb[best_row]
            atb[best_row] = tmp_b
        }

        if kan_abs(ata[col][col]) < 1.0e-12 {
            continue
        }

        for r in (col + 1)..cols {
            let factor = ata[r][col] / ata[col][col]
            for c in col..cols {
                ata[r][c] = ata[r][c] - factor * ata[col][c]
            }
            atb[r] = atb[r] - factor * atb[col]
        }
    }

    let mut x = kan_zeros(cols)
    let mut ci = cols - 1
    for _step in 0..cols {
        if kan_abs(ata[ci][ci]) > 1.0e-12 {
            let mut s = atb[ci]
            for j in (ci + 1)..cols {
                s = s - ata[ci][j] * x[j]
            }
            x[ci] = s / ata[ci][ci]
        }
        if ci == 0 {
            break
        }
        ci = ci - 1
    }

    return x
}

@pure
fn kan_refit_edge_coeffs(old_coeffs, old_knots, old_n_knots, old_degree, old_n_basis, new_knots, new_n_knots, new_degree, new_n_basis, sample_pts) {
    let n_pts = len(sample_pts)

    let mut old_vals = kan_zeros(n_pts)
    for p in 0..n_pts {
        let x = kan_clamp(sample_pts[p], -1.0, 1.0)
        old_vals[p] = kan_bspline_eval(x, old_coeffs, old_knots, old_n_knots, old_degree, old_n_basis)
    }

    let mut basis_mat = kan_zeros(n_pts * new_n_basis)
    for p in 0..n_pts {
        let x = kan_clamp(sample_pts[p], -1.0, 1.0)
        for b in 0..new_n_basis {
            basis_mat[p * new_n_basis + b] = kan_bspline_basis(x, new_knots, new_n_knots, new_degree, b)
        }
    }

    let new_coeffs = kan_ls_solve(basis_mat, old_vals, n_pts, new_n_basis)
    return new_coeffs
}

fn kan_grid_extend_layer(layer, new_n_basis, sample_pts) {
    let old_coeffs_flat = layer[0]
    let old_knots = layer[1]
    let l_in_dim = to_int(layer[2])
    let l_out_dim = to_int(layer[3])
    let old_n_basis = to_int(layer[4])
    let degree = to_int(layer[5])
    let old_n_knots = len(old_knots)

    if new_n_basis <= old_n_basis {
        return layer
    }

    let new_n_internal = new_n_basis - degree - 1
    let safe_new_internal = to_int(kan_max_f(to_float(new_n_internal), 0.0))
    let new_knots = kan_uniform_knots(-1.0, 1.0, safe_new_internal, degree)
    let new_n_knots = len(new_knots)

    let n_edges = l_out_dim * l_in_dim
    let new_total = n_edges * new_n_basis
    let mut new_coeffs_flat = kan_zeros(new_total)

    for e in 0..n_edges {
        let old_base = e * old_n_basis
        let mut old_edge_coeffs = kan_zeros(old_n_basis)
        for k in 0..old_n_basis {
            old_edge_coeffs[k] = old_coeffs_flat[old_base + k]
        }

        let new_edge_coeffs = kan_refit_edge_coeffs(
            old_edge_coeffs, old_knots, old_n_knots, degree, old_n_basis,
            new_knots, new_n_knots, degree, new_n_basis, sample_pts
        )

        let new_base = e * new_n_basis
        for k in 0..new_n_basis {
            new_coeffs_flat[new_base + k] = new_edge_coeffs[k]
        }
    }

    return [new_coeffs_flat, new_knots, l_in_dim, l_out_dim, new_n_basis, degree]
}

fn kan_grid_extend(network, new_n_basis, sample_pts) {
    let n_layers = len(network)
    let mut new_net = []
    for i in 0..n_layers {
        let extended = kan_grid_extend_layer(network[i], new_n_basis, sample_pts)
        new_net = new_net + [extended]
    }
    return new_net
}

// ── Sample points for grid extension tests ──
let ge_sample_pts = [-0.95, -0.8, -0.6, -0.4, -0.2, 0.0, 0.2, 0.4, 0.6, 0.8, 0.95]

// T37: kan_ls_solve identity system
// Solve I @ x = b => x = b
// A = [[1,0],[0,1]] flat = [1,0,0,1], b = [3, 7]
let ls_a = [1.0, 0.0, 0.0, 1.0]
let ls_b = [3.0, 7.0]
let ls_x = kan_ls_solve(ls_a, ls_b, 2, 2)
check("T37 kan_ls_solve identity", approx(ls_x[0], 3.0, 1.0e-6) && approx(ls_x[1], 7.0, 1.0e-6))

// T38: kan_ls_solve overdetermined system
// A = [[1,1],[1,2],[1,3]], b = [2,3,4] => best fit x = [1, 1]
let ls_od_a = [1.0, 1.0, 1.0, 2.0, 1.0, 3.0]
let ls_od_b = [2.0, 3.0, 4.0]
let ls_od_x = kan_ls_solve(ls_od_a, ls_od_b, 3, 2)
check("T38 kan_ls_solve overdetermined", approx(ls_od_x[0], 1.0, 1.0e-4) && approx(ls_od_x[1], 1.0, 1.0e-4))

// T39: kan_grid_extend_layer increases n_basis
// Create a layer with n_basis=4, extend to 7
let ge_layer = kan_create_layer(2, 2, 4, 2)
let ge_ext = kan_grid_extend_layer(ge_layer, 7, ge_sample_pts)
check("T39 grid_extend_layer n_basis increased", to_int(ge_ext[4]) == 7)

// T40: kan_grid_extend_layer preserves dims
check("T40 grid_extend_layer preserves dims",
    to_int(ge_ext[2]) == 2 && to_int(ge_ext[3]) == 2 && to_int(ge_ext[5]) == 2)

// T41: kan_grid_extend_layer approximates old spline
// Evaluate old and new spline at multiple points and check they match closely
let old_coeffs_e0 = []
let ge_old_coeffs = ge_layer[0]
let ge_old_knots = ge_layer[1]
let ge_old_n_knots = len(ge_old_knots)
let ge_old_nb = to_int(ge_layer[4])
let ge_deg = to_int(ge_layer[5])

let ge_new_coeffs = ge_ext[0]
let ge_new_knots = ge_ext[1]
let ge_new_n_knots = len(ge_new_knots)
let ge_new_nb = to_int(ge_ext[4])

// Check edge 0 approximation at test points
let mut ge_approx_ok = true
let ge_test_xs = [-0.7, -0.3, 0.0, 0.3, 0.7]
for ti in 0..5 {
    let x_t = ge_test_xs[ti]
    // Old edge 0: coeffs [0..old_nb)
    let mut old_ec = kan_zeros(ge_old_nb)
    for k in 0..ge_old_nb { old_ec[k] = ge_old_coeffs[k] }
    let old_v = kan_bspline_eval(x_t, old_ec, ge_old_knots, ge_old_n_knots, ge_deg, ge_old_nb)

    // New edge 0: coeffs [0..new_nb)
    let mut new_ec = kan_zeros(ge_new_nb)
    for k in 0..ge_new_nb { new_ec[k] = ge_new_coeffs[k] }
    let new_v = kan_bspline_eval(x_t, new_ec, ge_new_knots, ge_new_n_knots, ge_deg, ge_new_nb)

    if fabs(old_v - new_v) > 0.05 { ge_approx_ok = false }
}
check("T41 grid_extend approximates old spline", ge_approx_ok)

// T42: kan_grid_extend whole network structure
let ge_net = kan_create_network([2, 3, 1], 4, 2)
let ge_net_ext = kan_grid_extend(ge_net, 7, ge_sample_pts)
check("T42 grid_extend network structure",
    len(ge_net_ext) == 2 && to_int(ge_net_ext[0][4]) == 7 && to_int(ge_net_ext[1][4]) == 7)

// T43: kan_grid_extend forward still works
let ge_in = [0.3, -0.2]
let ge_out = kan_forward(ge_net_ext, ge_in)
check("T43 grid_extend forward works", len(ge_out) == 1)

// T44: kan_grid_extend no-op when new <= old
let ge_noop = kan_grid_extend_layer(ge_layer, 3, ge_sample_pts)
check("T44 grid_extend no-op when new<=old", to_int(ge_noop[4]) == 4 && len(ge_noop[0]) == len(ge_layer[0]))

