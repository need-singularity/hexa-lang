// ═══════════════════════════════════════════════════════════════════
//  test_mem2reg.hexa — #35 phi-node mem2reg
//
//  Verifies that the mem2reg pass correctly identifies let mut
//  variables that are never reassigned and can be promoted to let.
//  Also tests that variables that ARE reassigned remain as let mut.
//
//  Tests:
//    1. let mut never reassigned → safe to be let (result still correct)
//    2. let mut reassigned in loop → must stay mut
//    3. let mut used as accumulator → must stay mut
//    4. Multiple variables: mix of promotable and non-promotable
//    5. let mut with conditional assignment → stays mut
//    6. let mut initialized once, read multiple times → promotable
//    7. Nested scope: inner let mut never reassigned
//    8. Function with only let (no mut) → unchanged
//    9. Empty body → unchanged
//   10. Single let mut with complex init expression
//   11. let mut array never reassigned → promotable
//   12. Multiple promotable vars in same function
//
//  Run: ./hexa test self/test_mem2reg.hexa
// ═══════════════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA #35 phi-node mem2reg Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. let mut never reassigned (promotable) ────────────────
fn promotable_simple() {
    let mut x = 42
    return x
}
check("#35-01 promotable simple", promotable_simple(), 42)

// ── 2. let mut reassigned in loop (not promotable) ──────────
fn loop_accumulator(n) {
    let mut sum = 0
    let mut i = 0
    while i < n {
        sum = sum + i
        i = i + 1
    }
    return sum
}
check("#35-02 loop accumulator", loop_accumulator(5), 10)

// ── 3. let mut as counter ───────────────────────────────────
fn counter_fn() {
    let mut c = 0
    c = c + 1
    c = c + 1
    c = c + 1
    return c
}
check("#35-03 counter", counter_fn(), 3)

// ── 4. Mix of promotable and non-promotable ─────────────────
fn mixed_vars() {
    let mut a = 10    // promotable (never reassigned)
    let mut b = 20    // not promotable (reassigned below)
    b = b + a
    return a + b
}
check("#35-04 mixed vars", mixed_vars(), 40)

// ── 5. let mut with complex expression init ─────────────────
fn complex_init() {
    let mut val = 3 * 7 + 1
    return val
}
check("#35-05 complex init", complex_init(), 22)

// ── 6. Multiple promotable vars ─────────────────────────────
fn multi_promotable() {
    let mut a = 1
    let mut b = 2
    let mut c = 3
    return a + b + c
}
check("#35-06 multi promotable", multi_promotable(), 6)

// ── 7. let mut initialized once, read many times ────────────
fn read_many() {
    let mut x = 100
    let a = x + 1
    let b = x + 2
    let c = x + 3
    return a + b + c
}
check("#35-07 read many", read_many(), 306)

// ── 8. Function with only immutable let ─────────────────────
fn only_let() {
    let x = 5
    let y = 10
    return x + y
}
check("#35-08 only let", only_let(), 15)

// ── 9. Accumulator pattern (must preserve mutability) ───────
fn product_acc(n) {
    let mut result = 1
    let mut i = 1
    while i <= n {
        result = result * i
        i = i + 1
    }
    return result
}
check("#35-09 product accumulator", product_acc(5), 120)

// ── 10. let mut with function call init ─────────────────────
fn helper_val() { return 99 }
fn call_init() {
    let mut v = helper_val()
    return v
}
check("#35-10 call init", call_init(), 99)

// ── 11. Nested arithmetic with promotable ───────────────────
fn nested_arith() {
    let mut x = 2
    let mut y = 3
    return x * y + x - y
}
check("#35-11 nested arith", nested_arith(), 5)

// ── 12. Large promotable set ────────────────────────────────
fn many_locals() {
    let mut a = 1
    let mut b = 2
    let mut c = 3
    let mut d = 4
    let mut e = 5
    return a + b + c + d + e
}
check("#35-12 many locals", many_locals(), 15)

// ── Summary ─────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  mem2reg: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")
if fail_count > 0 {
    println("FAIL")
}
