// self/dream.hexa — HEXA DREAM ported from src/dream.rs
// Dream Mode — Evolutionary code exploration and optimization.
// Generates mutations, evaluates fitness, evolves code through tournament selection.

// ── Mutation kinds ──────────────────────────────────────

let MUT_SWAP_OPERATOR      = "swap_operator"
let MUT_CHANGE_CONSTANT    = "change_constant"
let MUT_REORDER_STATEMENTS = "reorder_statements"
let MUT_INLINE_FUNCTION    = "inline_function"
let MUT_ADD_CACHING        = "add_caching"
let MUT_SIMPLIFY_EXPR      = "simplify_expression"

// ── Mutation ────────────────────────────────────────────

struct Mutation {
    kind: string,
    line: int,
    original: string,
    mutated: string
}

fn mutation_display(m: Mutation) -> string {
    return m.kind + " at line " + to_string(m.line) + ": \"" + m.original + "\" -> \"" + m.mutated + "\""
}

// ── Discovery ───────────────────────────────────────────

struct Discovery {
    description: string,
    improvement_pct: float,
    mutation: Mutation,
    generation: int,
    before_fitness: float,
    after_fitness: float
}

fn discovery_display(d: Discovery) -> string {
    return "[gen " + to_string(d.generation) + "] " + d.description +
           ": +" + to_string(d.improvement_pct) + "% fitness (" +
           to_string(d.before_fitness) + " -> " + to_string(d.after_fitness) + ")"
}

// ── Fitness ─────────────────────────────────────────────

struct Fitness {
    correct: bool,
    time_secs: float,
    code_lines: int,
    output: string,
    score: float
}

// ── Dream configuration ─────────────────────────────────

struct DreamConfig {
    generations: int,
    mutations_per_gen: int,
    verbose: bool,
    anima_bridge: bool
}

fn dream_config_default() -> DreamConfig {
    return DreamConfig {
        generations: 100,
        mutations_per_gen: 10,
        verbose: false,
        anima_bridge: false
    }
}

// ── Dream engine ────────────────────────────────────────

struct DreamEngine {
    source: string,
    original_source: string,
    baseline_fitness: float,
    best_fitness: float,
    generation: int,
    discoveries: [Discovery],
    config: DreamConfig,
    rng_state: int,
    baseline_output: string,
    fn_names: [string],
    fn_bodies: [string]     // parallel array: fn_bodies[i] is body of fn_names[i]
}

fn dream_engine_new(source: string, config: DreamConfig) -> DreamEngine {
    // Simple hash for RNG seed
    let h = 14695981039346656037  // FNV offset basis (truncated)
    let i = 0
    while i < len(source) {
        h = h + to_int(source[i])
        h = h * 1099511628211
        i = i + 1
    }
    if h == 0 { h = 1 }

    let fn_names = []
    let fn_bodies = []
    // Extract function names and bodies
    let lines = split(source, "\n")
    i = 0
    while i < len(lines) {
        let line = trim(lines[i])
        if starts_with(line, "fn ") {
            let paren_pos = -1
            let j = 0
            while j < len(line) {
                if line[j] == "(" {
                    paren_pos = j
                    break
                }
                j = j + 1
            }
            if paren_pos > 3 {
                let name = trim(slice(line, 3, paren_pos))
                let body_lines = []
                let depth = 0
                let started = false
                let k = i
                while k < len(lines) {
                    let kline = lines[k]
                    let c = 0
                    while c < len(kline) {
                        if kline[c] == "{" { depth = depth + 1; started = true }
                        if kline[c] == "}" { depth = depth - 1 }
                        c = c + 1
                    }
                    if started {
                        if k > i {
                            let bline = trim(kline)
                            if bline != "}" {
                                if bline != "" {
                                    body_lines = body_lines + [bline]
                                }
                            }
                        }
                    }
                    if started {
                        if depth == 0 { break }
                    }
                    k = k + 1
                }
                fn_names = fn_names + [name]
                fn_bodies = fn_bodies + [join(body_lines, "\n")]
            }
        }
        i = i + 1
    }

    return DreamEngine {
        source: source,
        original_source: source,
        baseline_fitness: 0.0,
        best_fitness: 0.0,
        generation: 0,
        discoveries: [],
        config: config,
        rng_state: h,
        baseline_output: "",
        fn_names: fn_names,
        fn_bodies: fn_bodies
    }
}

// ── RNG ─────────────────────────────────────────────────

fn dream_rand(engine: DreamEngine) -> DreamEngine {
    let x = engine.rng_state
    x = x ^ (x * 8192)       // x ^= x << 13 (approx)
    x = x ^ (x / 128)        // x ^= x >> 7 (approx)
    x = x ^ (x * 131072)     // x ^= x << 17 (approx)
    engine.rng_state = x
    return engine
}

fn dream_rand_range(engine: DreamEngine, lo: int, hi: int) -> int {
    if hi <= lo { return lo }
    let x = engine.rng_state
    if x < 0 { x = -x }
    return x % (hi - lo) + lo
}

// ── Mutation generators ─────────────────────────────────

fn dream_mutate_swap_operator(source: string, lines: [string], rng: int) -> Mutation {
    // Try to swap an arithmetic operator on a random line
    let ops_from = [" + ", " - ", " * ", " / ", " > ", " < ", " >= ", " <= "]
    let ops_to   = [" - ", " + ", " / ", " * ", " >= ", " <= ", " > ", " < "]

    let line_count = len(lines)
    let attempts = 0
    while attempts < line_count {
        let line_idx = abs(rng + attempts) % line_count
        let line = lines[line_idx]
        let j = 0
        while j < len(ops_from) {
            if contains(line, ops_from[j]) {
                let new_line = replace(line, ops_from[j], ops_to[j])
                return Mutation {
                    kind: MUT_SWAP_OPERATOR,
                    line: line_idx + 1,
                    original: line,
                    mutated: new_line
                }
            }
            j = j + 1
        }
        attempts = attempts + 1
    }

    return Mutation { kind: MUT_SWAP_OPERATOR, line: 0,
        original: "(no applicable target)", mutated: "(unchanged)" }
}

fn dream_mutate_simplify(source: string, lines: [string], rng: int) -> Mutation {
    let patterns = [" * 1", " + 0", " - 0", "1 * ", "0 + "]
    let replacements = ["", "", "", "", ""]

    let line_count = len(lines)
    let attempts = 0
    while attempts < line_count {
        let line_idx = abs(rng + attempts) % line_count
        let line = lines[line_idx]
        let j = 0
        while j < len(patterns) {
            if contains(line, patterns[j]) {
                let new_line = replace(line, patterns[j], replacements[j])
                return Mutation {
                    kind: MUT_SIMPLIFY_EXPR,
                    line: line_idx + 1,
                    original: line,
                    mutated: new_line
                }
            }
            j = j + 1
        }
        attempts = attempts + 1
    }

    return Mutation { kind: MUT_SIMPLIFY_EXPR, line: 0,
        original: "(no applicable target)", mutated: "(unchanged)" }
}

fn dream_mutate_reorder(lines: [string], rng: int) -> Mutation {
    if len(lines) < 2 {
        return Mutation { kind: MUT_REORDER_STATEMENTS, line: 0,
            original: "(too few lines)", mutated: "(unchanged)" }
    }

    let line_count = len(lines)
    let attempts = 0
    while attempts < line_count {
        let idx = abs(rng + attempts) % (line_count - 1)
        let a = trim(lines[idx])
        let b = trim(lines[idx + 1])
        if a != "" {
            if b != "" {
                if !starts_with(a, "fn ") {
                    if !starts_with(b, "fn ") {
                        if !starts_with(a, "}") {
                            if !starts_with(b, "}") {
                                return Mutation {
                                    kind: MUT_REORDER_STATEMENTS,
                                    line: idx + 1,
                                    original: a + " | " + b,
                                    mutated: b + " | " + a
                                }
                            }
                        }
                    }
                }
            }
        }
        attempts = attempts + 1
    }

    return Mutation { kind: MUT_REORDER_STATEMENTS, line: 0,
        original: "(no swappable pair)", mutated: "(unchanged)" }
}

// ── Dream report ────────────────────────────────────────

struct DreamReport {
    original_source: string,
    final_source: string,
    generations: int,
    discoveries: [Discovery],
    baseline_fitness: float,
    final_fitness: float,
    elapsed_secs: float,
    total_mutations_tried: int,
    ouroboros_ticks: int
}

fn dream_report_display(report: DreamReport) -> string {
    let out = "=== HEXA Dream Report ===\n"
    out = out + "Generations:      " + to_string(report.generations) + "\n"
    out = out + "Mutations tried:  " + to_string(report.total_mutations_tried) + "\n"
    out = out + "Discoveries:      " + to_string(len(report.discoveries)) + "\n"
    out = out + "Baseline fitness: " + to_string(report.baseline_fitness) + "\n"
    out = out + "Final fitness:    " + to_string(report.final_fitness) + "\n"

    let improvement = 0.0
    if report.baseline_fitness > 0.0 {
        improvement = (report.final_fitness - report.baseline_fitness) / report.baseline_fitness * 100.0
    }
    out = out + "Improvement:      " + to_string(improvement) + "%\n"
    out = out + "Time:             " + to_string(report.elapsed_secs) + "s\n"
    out = out + "Ouroboros ticks:  " + to_string(report.ouroboros_ticks) + " (every n=6 gens)\n"

    if len(report.discoveries) == 0 {
        out = out + "\nNo beneficial mutations found — the code is already optimal\n"
        out = out + "for the current fitness function.\n"
    } else {
        out = out + "\n--- Discoveries ---\n"
        let i = 0
        while i < len(report.discoveries) {
            out = out + "  " + to_string(i + 1) + ". " + discovery_display(report.discoveries[i]) + "\n"
            i = i + 1
        }
    }

    out = out + "\nDream complete.\n"
    return out
}
