// ===================================================================
//  test_rag_pipeline.hexa — RAG Pipeline Test Suite (SSOT id=58)
//
//  Covers:
//    T1  create_pipeline: zero size, zero stats
//    T2  add_chunk: size increments, get_chunk returns text/meta
//    T3  duplicate id rejected (no-op)
//    T4  add_document splits into multiple chunks
//    T5  update_chunk overwrites text
//    T6  delete_chunk removes entry and preserves others
//    T7  retrieve top-k returns the right chunk for a query
//    T8  retrieve top-k limits to store size
//    T9  retrieve increments retrieval counter
//    T10 build_prompt contains query + context + "Question"
//    T11 prompt templates vary (default / concise / detailed)
//    T12 cache miss on first query, hit on second (identical query)
//    T13 cache LRU eviction at capacity
//    T14 rag_query_with_hook generates via "first_ctx" tag
//    T15 rag_stats tracks hits/misses/retrievals
//    T16 rag_clear_cache empties LRU but keeps chunks
//    T17 rag_reset_stats zeros counters
//    T18 delete nonexistent id is a no-op
//    T19 update nonexistent id is a no-op
//
//  Run: ./hexa self/test_rag_pipeline.hexa
// ===================================================================

import "ml/rag_pipeline.hexa"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

println("===================================================================")
println("  RAG Pipeline Test Suite (SSOT id=58)")
println("===================================================================")

// ===================================================================
//  T1: create_pipeline
// ===================================================================
let p0 = create_pipeline(16, 4, 0.9)
let s0 = rag_stats(p0)
check("T1 create_pipeline size=0", rag_size(p0) == 0)
check("T1 create_pipeline hits=0 misses=0", s0[0] == 0 && s0[1] == 0)

// ===================================================================
//  T2: add_chunk
// ===================================================================
let p1 = rag_add_chunk(p0, "c1", "hello world from hexa", "topic=greeting")
check("T2 add_chunk size=1", rag_size(p1) == 1)
let got = rag_get_chunk(p1, "c1")
check("T2 get_chunk text", got[0] == "hello world from hexa")
check("T2 get_chunk meta", got[1] == "topic=greeting")

// ===================================================================
//  T3: duplicate id rejected
// ===================================================================
let p1b = rag_add_chunk(p1, "c1", "different text", "topic=other")
check("T3 duplicate id no-op", rag_size(p1b) == 1)
let got_same = rag_get_chunk(p1b, "c1")
check("T3 duplicate keeps original text", got_same[0] == "hello world from hexa")

// ===================================================================
//  T4: add_document splits into chunks
// ===================================================================
let p_doc = create_pipeline(16, 4, 0.9)
// 24 chars / chunk_size 8 => 3 chunks
let p_doc1 = rag_add_document(p_doc, "docA", "abcdefghijklmnopqrstuvwx", "src=test", 8)
check("T4 add_document 3 chunks", rag_size(p_doc1) == 3)
let chunk0 = rag_get_chunk(p_doc1, "docA#0")
check("T4 chunk#0 text", chunk0[0] == "abcdefgh")
let chunk2 = rag_get_chunk(p_doc1, "docA#2")
check("T4 chunk#2 text", chunk2[0] == "qrstuvwx")

// ===================================================================
//  T5: update_chunk
// ===================================================================
let p_up = rag_update_chunk(p1, "c1", "new text content", "topic=updated")
let got_up = rag_get_chunk(p_up, "c1")
check("T5 update_chunk text", got_up[0] == "new text content")
check("T5 update_chunk meta", got_up[1] == "topic=updated")
check("T5 update_chunk size unchanged", rag_size(p_up) == 1)

// ===================================================================
//  T6: delete_chunk
// ===================================================================
let p_del0 = rag_add_chunk(p0, "a", "alpha", "m=a")
let p_del1 = rag_add_chunk(p_del0, "b", "beta", "m=b")
let p_del2 = rag_add_chunk(p_del1, "c", "gamma", "m=c")
let p_del3 = rag_delete_chunk(p_del2, "b")
check("T6 delete_chunk size 3->2", rag_size(p_del3) == 2)
let got_a = rag_get_chunk(p_del3, "a")
let got_b = rag_get_chunk(p_del3, "b")
let got_c = rag_get_chunk(p_del3, "c")
check("T6 delete keeps a", got_a[0] == "alpha")
check("T6 delete removes b", len(got_b) == 0)
check("T6 delete keeps c", got_c[0] == "gamma")

// ===================================================================
//  T7: retrieve top-k returns relevant chunk
// ===================================================================
let p_r0 = create_pipeline(32, 4, 0.9)
let p_r1 = rag_add_chunk(p_r0, "ml", "machine learning neural networks training", "topic=ml")
let p_r2 = rag_add_chunk(p_r1, "cook", "chocolate cake recipe baking", "topic=cook")
let p_r3 = rag_add_chunk(p_r2, "math", "linear algebra matrix calculus", "topic=math")
let r_out = rag_retrieve(p_r3, "machine learning neural networks training", 1)
let r_list = r_out[0]
let p_r4 = r_out[1]
check("T7 retrieve top-1 returns 1 result", len(r_list) == 1)
check("T7 retrieve top-1 picks ml", r_list[0][0] == "ml")

// ===================================================================
//  T8: retrieve top-k clamped to store size
// ===================================================================
let r_big = rag_retrieve(p_r4, "anything", 99)
let big_list = r_big[0]
let p_r5 = r_big[1]
check("T8 top_k > n returns n results", len(big_list) == 3)

// ===================================================================
//  T9: retrieval counter increments
// ===================================================================
let stats_r = rag_stats(p_r5)
check("T9 retrievals = 2", stats_r[4] == 2)

// ===================================================================
//  T10: build_prompt with default template
// ===================================================================
let prompt_def = rag_build_prompt("what is ML?", r_list, "default")
check("T10 default prompt has Context", prompt_def.index_of("Context:") >= 0)
check("T10 default prompt has Question", prompt_def.index_of("Question:") >= 0)
check("T10 default prompt has Answer", prompt_def.index_of("Answer:") >= 0)
check("T10 default prompt has query text", prompt_def.index_of("what is ML?") >= 0)

// ===================================================================
//  T11: prompt templates differ
// ===================================================================
let prompt_concise = rag_build_prompt("q", r_list, "concise")
let prompt_detailed = rag_build_prompt("q", r_list, "detailed")
check("T11 concise has Briefly", prompt_concise.index_of("Briefly") >= 0)
check("T11 detailed has detailed", prompt_detailed.index_of("detailed") >= 0)
check("T11 detailed differs from default", prompt_detailed != prompt_def)

// ===================================================================
//  T12: cache miss then hit
// ===================================================================
let p_c0 = create_pipeline(32, 4, 0.9)
let p_c1 = rag_add_chunk(p_c0, "d1", "alpha beta gamma", "m=1")
// First query: miss (empty cache)
let q1 = rag_query_with_hook(p_c1, "alpha beta gamma", 1, "default", "first_ctx")
let ans1 = q1[0]
let hit1 = q1[3]
let p_c2 = q1[5]
check("T12 first query cache miss", hit1 == false)
check("T12 first query returns ctx text", ans1 == "alpha beta gamma")
// Second query with identical text: hit
let q2 = rag_query_with_hook(p_c2, "alpha beta gamma", 1, "default", "first_ctx")
let hit2 = q2[3]
let ans2 = q2[0]
let p_c3 = q2[5]
check("T12 second query cache hit", hit2 == true)
check("T12 second query returns cached answer", ans2 == "alpha beta gamma")

// ===================================================================
//  T13: cache LRU eviction at capacity
// ===================================================================
let p_l0 = create_pipeline(32, 2, 0.85)
let p_l1 = rag_add_chunk(p_l0, "x1", "first distinct chunk alpha", "")
let p_l2 = rag_add_chunk(p_l1, "x2", "second distinct chunk beta", "")
let p_l3 = rag_add_chunk(p_l2, "x3", "third distinct chunk gamma", "")
// Populate cache with 3 queries under capacity=2 → 1 should be evicted
let l_q1 = rag_query_with_hook(p_l3, "first distinct chunk alpha", 1, "default", "first_ctx")
let p_l4 = l_q1[5]
let l_q2 = rag_query_with_hook(p_l4, "second distinct chunk beta", 1, "default", "first_ctx")
let p_l5 = l_q2[5]
let l_q3 = rag_query_with_hook(p_l5, "third distinct chunk gamma", 1, "default", "first_ctx")
let p_l6 = l_q3[5]
// cache capacity is 2 → at most 2 entries cached. Size = 3 chunks.
check("T13 chunks still 3 after many queries", rag_size(p_l6) == 3)
check("T13 cache capacity <= 2", len(p_l6.cache_queries) <= 2)

// ===================================================================
//  T14: generator hook "first_ctx"
// ===================================================================
let p_h0 = create_pipeline(32, 4, 0.9)
let p_h1 = rag_add_chunk(p_h0, "fc", "specific context body text", "")
let h_q = rag_query_with_hook(p_h1, "specific context body text", 1, "default", "first_ctx")
let h_ans = h_q[0]
check("T14 first_ctx hook returns chunk text", h_ans == "specific context body text")

// Test "echo" hook
let e_q = rag_query_with_hook(p_h1, "specific context body text", 1, "default", "echo")
let e_ans = e_q[0]
check("T14 echo hook returns prompt", e_ans.index_of("Question:") >= 0)

// ===================================================================
//  T15: rag_stats tracks hits/misses/retrievals
// ===================================================================
let p_s0 = create_pipeline(32, 4, 0.9)
let p_s1 = rag_add_chunk(p_s0, "s1", "stat test chunk one", "")
let p_s2 = rag_add_chunk(p_s1, "s2", "stat test chunk two", "")
// miss + retrieve
let sq1 = rag_query_with_hook(p_s2, "stat test chunk one", 1, "default", "first_ctx")
let p_s3 = sq1[5]
// hit on same query
let sq2 = rag_query_with_hook(p_s3, "stat test chunk one", 1, "default", "first_ctx")
let p_s4 = sq2[5]
let stats_final = rag_stats(p_s4)
check("T15 stats hits=1", stats_final[0] == 1)
check("T15 stats misses=1", stats_final[1] == 1)
check("T15 stats hit_rate=0.5", stats_final[2] > 0.49 && stats_final[2] < 0.51)
check("T15 stats chunk_count=2", stats_final[3] == 2)
check("T15 stats retrievals=2", stats_final[4] == 2)

// ===================================================================
//  T16: clear_cache empties LRU but keeps chunks
// ===================================================================
let p_cc = rag_clear_cache(p_s4)
check("T16 clear_cache: chunks kept", rag_size(p_cc) == 2)
check("T16 clear_cache: cache queries empty", len(p_cc.cache_queries) == 0)
check("T16 clear_cache: hits preserved", p_cc.hits == 1)

// ===================================================================
//  T17: reset_stats zeros counters
// ===================================================================
let p_rs = rag_reset_stats(p_s4)
let rs_stats = rag_stats(p_rs)
check("T17 reset_stats hits=0", rs_stats[0] == 0)
check("T17 reset_stats misses=0", rs_stats[1] == 0)
check("T17 reset_stats retrievals=0", rs_stats[4] == 0)
check("T17 reset_stats chunks preserved", rs_stats[3] == 2)

// ===================================================================
//  T18: delete nonexistent id is a no-op
// ===================================================================
let p_nx = rag_delete_chunk(p_s4, "nope_no_such_id")
check("T18 delete missing no-op size", rag_size(p_nx) == rag_size(p_s4))

// ===================================================================
//  T19: update nonexistent id is a no-op
// ===================================================================
let p_ux = rag_update_chunk(p_s4, "nope_no_such_id", "x", "y")
check("T19 update missing no-op size", rag_size(p_ux) == rag_size(p_s4))

// ===================================================================
//  Summary
// ===================================================================
println("")
println("pass=" + to_string(pass_count) + " fail=" + to_string(fail_count))
if fail_count == 0 {
    println("ALL PASS")
} else {
    println("FAILED")
}
println(to_string(pass_count) + " passed")
