// ═══════════════════════════════════════════════════════════
//  self/test_self_parse.hexa — Phase2 Self-Hosting E2E Test
//  Verifies: self-lexer tokenize, self-parser parse, self-interpreter interpret
//  Pipeline: source string -> tokenize() -> parse() -> interpret()
//  Minimum 30 assertions covering tokenization, AST structure, evaluation
// ═══════════════════════════════════════════════════════════

// -- inlined from self/lexer.hexa --
// codegen import not wired for test files

// self/lexer.hexa — HEXA lexer written in HEXA (Stage 1 of self-hosting)
// Tokenizes HEXA source code into the same token sequence as the Rust lexer.

struct Token {
    kind: string,
    value: string,
    line: int,
    col: int
}

// Check if a word is one of the 56 HEXA keywords (sigma*tau+sopfr+3) + import alias
fn is_keyword(word) {
    if word == "if" { return true }
    if word == "else" { return true }
    if word == "match" { return true }
    if word == "for" { return true }
    if word == "while" { return true }
    if word == "loop" { return true }
    if word == "type" { return true }
    if word == "struct" { return true }
    if word == "enum" { return true }
    if word == "trait" { return true }
    if word == "impl" { return true }
    if word == "fn" { return true }
    if word == "return" { return true }
    if word == "yield" { return true }
    if word == "async" { return true }
    if word == "await" { return true }
    if word == "let" { return true }
    if word == "mut" { return true }
    if word == "const" { return true }
    if word == "static" { return true }
    if word == "mod" { return true }
    if word == "use" { return true }
    if word == "import" { return true }
    if word == "pub" { return true }
    if word == "crate" { return true }
    if word == "own" { return true }
    if word == "borrow" { return true }
    if word == "move" { return true }
    if word == "drop" { return true }
    if word == "spawn" { return true }
    if word == "channel" { return true }
    if word == "select" { return true }
    if word == "atomic" { return true }
    if word == "effect" { return true }
    if word == "handle" { return true }
    if word == "resume" { return true }
    if word == "pure" { return true }
    if word == "proof" { return true }
    if word == "assert" { return true }
    if word == "invariant" { return true }
    if word == "theorem" { return true }
    if word == "macro" { return true }
    if word == "derive" { return true }
    if word == "where" { return true }
    if word == "comptime" { return true }
    if word == "try" { return true }
    if word == "catch" { return true }
    if word == "throw" { return true }
    if word == "panic" { return true }
    if word == "recover" { return true }
    if word == "intent" { return true }
    if word == "generate" { return true }
    if word == "verify" { return true }
    if word == "optimize" { return true }
    if word == "extern" { return true }
    if word == "break" { return true }
    if word == "continue" { return true }
    if word == "dyn" { return true }
    if word == "scope" { return true }
    if word == "in" { return true }
    if word == "do" { return true }
    if word == "defer" { return true }
    if word == "typeof" { return true }
    if word == "guard" { return true }
    if word == "with" { return true }
    if word == "as" { return true }
    return false
}

// Get the keyword kind for a word (returns "Ident" if not a keyword)
fn keyword_kind(word) {
    if word == "true" { return "BoolLit" }
    if word == "false" { return "BoolLit" }
    if word == "import" { return "Use" }
    if is_keyword(word) {
        // Capitalize first letter for kind name
        let first = to_string(word.chars()[0]).to_upper()
        let mut rest_parts = []
        let chars = word.chars()
        let mut i = 1
        while i < len(chars) {
            rest_parts = rest_parts.push(to_string(chars[i]))
            i = i + 1
        }
        return first + join(rest_parts, "")
    }
    return "Ident"
}

// Check if character is valid identifier start (alpha or _)
@pure
fn is_ident_start(ch) {
    if is_alpha(ch) { return true }
    if ch == '_' { return true }
    return false
}

// Check if character is valid identifier continuation (alphanumeric or _)
@pure
fn is_ident_char(ch) {
    if is_alphanumeric(ch) { return true }
    if ch == '_' { return true }
    return false
}

// Check if character is a hex digit (0-9, a-f, A-F)
fn is_hex_digit(ch) {
    if is_digit(ch) { return true }
    if ch == 'a' || ch == 'b' || ch == 'c' || ch == 'd' || ch == 'e' || ch == 'f' { return true }
    if ch == 'A' || ch == 'B' || ch == 'C' || ch == 'D' || ch == 'E' || ch == 'F' { return true }
    return false
}

// Main tokenizer function
@compile_trace
fn tokenize(source) {
    let mut tokens = []
    let chars = source.chars()
    let mut pos = 0
    let mut line = 1
    let mut col = 1
    let total = len(chars)
    let mut paren_depth = 0

    while pos < total {
        let ch = chars[pos]

        // Skip whitespace (not newlines)
        if ch == ' ' || ch == '\t' || ch == '\r' {
            pos = pos + 1
            col = col + 1
            // Continue to next iteration
        } else if ch == '\n' {
            // Newline token — suppressed inside () and []
            if paren_depth == 0 {
                tokens = tokens.push(Token { kind: "Newline", value: "\n", line: line, col: col })
            }
            pos = pos + 1
            line = line + 1
            col = 1
        } else if ch == '/' && pos + 1 < total && chars[pos + 1] == '/' {
            // Line comment — skip until newline
            pos = pos + 2
            col = col + 2
            while pos < total && chars[pos] != '\n' {
                pos = pos + 1
                col = col + 1
            }
        } else if ch == '/' && pos + 1 < total && chars[pos + 1] == '*' {
            // Block comment (supports nesting)
            pos = pos + 2
            col = col + 2
            let mut depth = 1
            while depth > 0 && pos < total {
                if pos + 1 < total && chars[pos] == '/' && chars[pos + 1] == '*' {
                    depth = depth + 1
                    pos = pos + 2
                    col = col + 2
                } else if pos + 1 < total && chars[pos] == '*' && chars[pos + 1] == '/' {
                    depth = depth - 1
                    pos = pos + 2
                    col = col + 2
                } else if chars[pos] == '\n' {
                    pos = pos + 1
                    line = line + 1
                    col = 1
                } else {
                    pos = pos + 1
                    col = col + 1
                }
            }
        } else if is_ident_start(ch) {
            // Identifier or keyword
            let start_col = col
            let mut word_parts = []
            while pos < total && is_ident_char(chars[pos]) {
                word_parts = word_parts.push(to_string(chars[pos]))
                pos = pos + 1
                col = col + 1
            }
            let word = join(word_parts, "")
            let kind = keyword_kind(word)
            tokens = tokens.push(Token { kind: kind, value: word, line: line, col: start_col })
        } else if is_digit(ch) {
            // Number literal — integer, float, or hex (0x)
            // Underscore separators: 1_000_000 -> 1000000, 0xFF_FF -> 0xFFFF
            // Rules: _ only between digits, no leading/trailing _, no consecutive __
            let start_col = col
            let mut num_parts = []
            let mut is_float = false
            let mut is_hex = false

            // Check for hex prefix 0x / 0X
            if ch == '0' && pos + 1 < total && (chars[pos + 1] == 'x' || chars[pos + 1] == 'X') {
                is_hex = true
                num_parts = num_parts.push("0x")
                pos = pos + 2
                col = col + 2
                // Collect hex digits; accept _ only between hex digits (lookahead)
                while pos < total && is_hex_digit(chars[pos]) {
                    num_parts = num_parts.push(to_string(chars[pos]))
                    pos = pos + 1
                    col = col + 1
                    // After a hex digit, consume a single _ if followed by another hex digit
                    if pos < total && chars[pos] == '_' {
                        if pos + 1 < total && is_hex_digit(chars[pos + 1]) {
                            // Valid separator — skip _ and let loop consume next digit
                            pos = pos + 1
                            col = col + 1
                        }
                        // else: trailing _ or __ — stop; _ left for next token
                    }
                }
            } else {
                // Decimal integer part: collect digits; accept _ only between digits
                while pos < total && is_digit(chars[pos]) {
                    num_parts = num_parts.push(to_string(chars[pos]))
                    pos = pos + 1
                    col = col + 1
                    // After a digit, consume a single _ if followed by another digit
                    if pos < total && chars[pos] == '_' {
                        if pos + 1 < total && is_digit(chars[pos + 1]) {
                            pos = pos + 1
                            col = col + 1
                        }
                    }
                }
                // Check for decimal point (not range ..)
                if pos < total && chars[pos] == '.' {
                    if pos + 1 < total && is_digit(chars[pos + 1]) {
                        // It's a float: consume . and fractional digits
                        is_float = true
                        num_parts = num_parts.push(".")
                        pos = pos + 1
                        col = col + 1
                        while pos < total && is_digit(chars[pos]) {
                            num_parts = num_parts.push(to_string(chars[pos]))
                            pos = pos + 1
                            col = col + 1
                            // After a digit, consume a single _ if followed by another digit
                            if pos < total && chars[pos] == '_' {
                                if pos + 1 < total && is_digit(chars[pos + 1]) {
                                    pos = pos + 1
                                    col = col + 1
                                }
                            }
                        }
                    }
                }
                // Scientific notation: e/E [+-]? digits (1e10, 1e-5, 1.5e+3)
                // Lookahead: only consume `e` if followed by optional sign + digit,
                // otherwise leave `e` for identifier lexer (e.g. `1err` — unlikely but safe).
                if pos < total && (chars[pos] == 'e' || chars[pos] == 'E') {
                    let mut ep = pos + 1
                    if ep < total && (chars[ep] == '+' || chars[ep] == '-') { ep = ep + 1 }
                    if ep < total && is_digit(chars[ep]) {
                        is_float = true
                        num_parts = num_parts.push(to_string(chars[pos]))
                        pos = pos + 1
                        col = col + 1
                        if pos < total && (chars[pos] == '+' || chars[pos] == '-') {
                            num_parts = num_parts.push(to_string(chars[pos]))
                            pos = pos + 1
                            col = col + 1
                        }
                        while pos < total && is_digit(chars[pos]) {
                            num_parts = num_parts.push(to_string(chars[pos]))
                            pos = pos + 1
                            col = col + 1
                        }
                    }
                }
            }
            let num_str = join(num_parts, "")
            if is_float {
                tokens = tokens.push(Token { kind: "FloatLit", value: num_str, line: line, col: start_col })
            } else {
                tokens = tokens.push(Token { kind: "IntLit", value: num_str, line: line, col: start_col })
            }
        } else if ch == '"' {
            // String literal — check for triple-quote """
            let start_col = col
            if pos + 2 < total && chars[pos + 1] == '"' && chars[pos + 2] == '"' {
                // Triple-quoted multiline string
                pos = pos + 3
                col = col + 3
                // Skip optional leading newline after opening """
                if pos < total && chars[pos] == '\n' {
                    pos = pos + 1
                    line = line + 1
                    col = 1
                } else if pos < total && chars[pos] == '\r' && pos + 1 < total && chars[pos + 1] == '\n' {
                    pos = pos + 2
                    line = line + 1
                    col = 1
                }
                let mut ts_parts = []
                let mut ts_done = false
                while pos < total && !ts_done {
                    if pos + 2 < total && chars[pos] == '"' && chars[pos + 1] == '"' && chars[pos + 2] == '"' {
                        ts_done = true
                        pos = pos + 3
                        col = col + 3
                    } else {
                        let tc = chars[pos]
                        ts_parts = ts_parts.push(to_string(tc))
                        pos = pos + 1
                        if tc == '\n' {
                            line = line + 1
                            col = 1
                        } else {
                            col = col + 1
                        }
                    }
                }
                let ts = join(ts_parts, "")
                tokens = tokens.push(Token { kind: "StringLit", value: ts, line: line, col: start_col })
            } else {
                // Regular string literal
                pos = pos + 1
                col = col + 1
                let mut s_parts = []
                let mut done = false
                while pos < total && !done {
                    let c = chars[pos]
                    if c == '"' {
                        done = true
                        pos = pos + 1
                        col = col + 1
                    } else if c == '\\' {
                        pos = pos + 1
                        col = col + 1
                        if pos < total {
                            let esc = chars[pos]
                            if esc == 'n' { s_parts = s_parts.push("\n") }
                            else if esc == 't' { s_parts = s_parts.push("\t") }
                            else if esc == 'r' { s_parts = s_parts.push("\r") }
                            else if esc == '\\' { s_parts = s_parts.push("\\") }
                            else if esc == '"' { s_parts = s_parts.push("\"") }
                            else if esc == '0' { s_parts = s_parts.push("\0") }
                            else { s_parts = s_parts.push(to_string(esc)) }
                            pos = pos + 1
                            col = col + 1
                        }
                    } else {
                        s_parts = s_parts.push(to_string(c))
                        pos = pos + 1
                        if c == '\n' {
                            line = line + 1
                            col = 1
                        } else {
                            col = col + 1
                        }
                    }
                }
                let s = join(s_parts, "")
                tokens = tokens.push(Token { kind: "StringLit", value: s, line: line, col: start_col })
            }
        } else if ch == '\'' {
            let start_col = col
            // Check for label: 'ident where ident is >=2 chars or followed by ':'
            // Labels: 'outer  (used with labeled break/continue)
            // Char literals: 'x' or '\n'
            let mut is_label = false
            if pos + 1 < total && is_ident_start(chars[pos + 1]) {
                // Peek ahead to see if this is a multi-char ident (label) or char lit
                let mut peek_pos = pos + 1
                while peek_pos < total && is_ident_char(chars[peek_pos]) {
                    peek_pos = peek_pos + 1
                }
                let ident_len = peek_pos - pos - 1
                if ident_len > 1 {
                    // Multi-char ident after ' → label (e.g. 'outer)
                    is_label = true
                } else if peek_pos < total && chars[peek_pos] != '\'' {
                    // Single-char ident NOT followed by closing ' → label
                    is_label = true
                }
            }
            if is_label {
                // Label token: 'identifier
                pos = pos + 1  // skip '
                col = col + 1
                let mut label_parts = []
                while pos < total && is_ident_char(chars[pos]) {
                    label_parts = label_parts.push(to_string(chars[pos]))
                    pos = pos + 1
                    col = col + 1
                }
                let label_name = join(label_parts, "")
                tokens = tokens.push(Token { kind: "Label", value: label_name, line: line, col: start_col })
            } else {
                // Char literal
                pos = pos + 1
                col = col + 1
                let mut ch_val = ""
                if pos < total && chars[pos] == '\\' {
                    pos = pos + 1
                    col = col + 1
                    if pos < total {
                        let esc = chars[pos]
                        if esc == 'n' { ch_val = "\n" }
                        else if esc == 't' { ch_val = "\t" }
                        else if esc == 'r' { ch_val = "\r" }
                        else if esc == '\\' { ch_val = "\\" }
                        else if esc == '\'' { ch_val = "'" }
                        else if esc == '0' { ch_val = "\0" }
                        else { ch_val = to_string(esc) }
                        pos = pos + 1
                        col = col + 1
                    }
                } else if pos < total {
                    ch_val = to_string(chars[pos])
                    pos = pos + 1
                    col = col + 1
                }
                // Consume closing quote
                if pos < total && chars[pos] == '\'' {
                    pos = pos + 1
                    col = col + 1
                }
                tokens = tokens.push(Token { kind: "CharLit", value: ch_val, line: line, col: start_col })
            }
        } else {
            // Operators and delimiters
            let start_col = col
            if ch == '+' {
                if pos + 1 < total && chars[pos + 1] == '=' {
                    tokens = tokens.push(Token { kind: "PlusEq", value: "+=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens = tokens.push(Token { kind: "Plus", value: "+", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '-' {
                if pos + 1 < total && chars[pos + 1] == '>' {
                    tokens = tokens.push(Token { kind: "Arrow", value: "->", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else if pos + 1 < total && chars[pos + 1] == '=' {
                    tokens = tokens.push(Token { kind: "MinusEq", value: "-=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens = tokens.push(Token { kind: "Minus", value: "-", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '*' {
                if pos + 1 < total && chars[pos + 1] == '*' {
                    tokens = tokens.push(Token { kind: "Power", value: "**", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else if pos + 1 < total && chars[pos + 1] == '=' {
                    tokens = tokens.push(Token { kind: "StarEq", value: "*=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens = tokens.push(Token { kind: "Star", value: "*", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '/' {
                if pos + 1 < total && chars[pos + 1] == '=' {
                    tokens = tokens.push(Token { kind: "SlashEq", value: "/=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens = tokens.push(Token { kind: "Slash", value: "/", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '%' {
                if pos + 1 < total && chars[pos + 1] == '=' {
                    tokens = tokens.push(Token { kind: "PercentEq", value: "%=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens = tokens.push(Token { kind: "Percent", value: "%", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '=' {
                if pos + 1 < total && chars[pos + 1] == '=' {
                    tokens = tokens.push(Token { kind: "EqEq", value: "==", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else if pos + 1 < total && chars[pos + 1] == '>' {
                    tokens = tokens.push(Token { kind: "FatArrow", value: "=>", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens = tokens.push(Token { kind: "Eq", value: "=", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '!' {
                if pos + 1 < total && chars[pos + 1] == '=' {
                    tokens = tokens.push(Token { kind: "NotEq", value: "!=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens = tokens.push(Token { kind: "Not", value: "!", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '<' {
                if pos + 1 < total && chars[pos + 1] == '=' {
                    tokens = tokens.push(Token { kind: "LtEq", value: "<=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else if pos + 1 < total && chars[pos + 1] == '<' {
                    tokens = tokens.push(Token { kind: "Shl", value: "<<", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens = tokens.push(Token { kind: "Lt", value: "<", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '>' {
                if pos + 1 < total && chars[pos + 1] == '=' {
                    tokens = tokens.push(Token { kind: "GtEq", value: ">=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else if pos + 1 < total && chars[pos + 1] == '>' {
                    tokens = tokens.push(Token { kind: "Shr", value: ">>", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens = tokens.push(Token { kind: "Gt", value: ">", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '&' {
                if pos + 1 < total && chars[pos + 1] == '&' {
                    if pos + 2 < total && chars[pos + 2] == '=' {
                        tokens = tokens.push(Token { kind: "AndAssign", value: "&&=", line: line, col: start_col })
                        pos = pos + 3
                        col = col + 3
                    } else {
                        tokens = tokens.push(Token { kind: "And", value: "&&", line: line, col: start_col })
                        pos = pos + 2
                        col = col + 2
                    }
                } else {
                    tokens = tokens.push(Token { kind: "BitAnd", value: "&", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '|' {
                if pos + 1 < total && chars[pos + 1] == '|' {
                    if pos + 2 < total && chars[pos + 2] == '=' {
                        tokens = tokens.push(Token { kind: "OrAssign", value: "||=", line: line, col: start_col })
                        pos = pos + 3
                        col = col + 3
                    } else {
                        tokens = tokens.push(Token { kind: "Or", value: "||", line: line, col: start_col })
                        pos = pos + 2
                        col = col + 2
                    }
                } else {
                    tokens = tokens.push(Token { kind: "BitOr", value: "|", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '^' {
                if pos + 1 < total && chars[pos + 1] == '^' {
                    tokens = tokens.push(Token { kind: "Xor", value: "^^", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens = tokens.push(Token { kind: "BitXor", value: "^", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '~' {
                tokens = tokens.push(Token { kind: "BitNot", value: "~", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == '?' {
                if pos + 1 < total && chars[pos + 1] == '?' {
                    tokens = tokens.push(Token { kind: "NullCoal", value: "??", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens = tokens.push(Token { kind: "Question", value: "?", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '@' {
                // AI-native attribute marker (M0)
                tokens = tokens.push(Token { kind: "At", value: "@", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == ':' {
                if pos + 1 < total && chars[pos + 1] == '=' {
                    tokens = tokens.push(Token { kind: "ColonEq", value: ":=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else if pos + 1 < total && chars[pos + 1] == ':' {
                    tokens = tokens.push(Token { kind: "ColonColon", value: "::", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens = tokens.push(Token { kind: "Colon", value: ":", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '.' {
                if pos + 2 < total && chars[pos + 1] == '.' && chars[pos + 2] == '.' {
                    // G8: spread operator `...` — must check 3 dots before 2-dot range
                    tokens = tokens.push(Token { kind: "DotDotDot", value: "...", line: line, col: start_col })
                    pos = pos + 3
                    col = col + 3
                } else if pos + 1 < total && chars[pos + 1] == '.' {
                    if pos + 2 < total && chars[pos + 2] == '=' {
                        tokens = tokens.push(Token { kind: "DotDotEq", value: "..=", line: line, col: start_col })
                        pos = pos + 3
                        col = col + 3
                    } else {
                        tokens = tokens.push(Token { kind: "DotDot", value: "..", line: line, col: start_col })
                        pos = pos + 2
                        col = col + 2
                    }
                } else {
                    tokens = tokens.push(Token { kind: "Dot", value: ".", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '(' {
                tokens = tokens.push(Token { kind: "LParen", value: "(", line: line, col: start_col })
                paren_depth = paren_depth + 1
                pos = pos + 1
                col = col + 1
            } else if ch == ')' {
                tokens = tokens.push(Token { kind: "RParen", value: ")", line: line, col: start_col })
                if paren_depth > 0 { paren_depth = paren_depth - 1 }
                pos = pos + 1
                col = col + 1
            } else if ch == '{' {
                tokens = tokens.push(Token { kind: "LBrace", value: "{", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == '}' {
                tokens = tokens.push(Token { kind: "RBrace", value: "}", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == '[' {
                tokens = tokens.push(Token { kind: "LBracket", value: "[", line: line, col: start_col })
                paren_depth = paren_depth + 1
                pos = pos + 1
                col = col + 1
            } else if ch == ']' {
                tokens = tokens.push(Token { kind: "RBracket", value: "]", line: line, col: start_col })
                if paren_depth > 0 { paren_depth = paren_depth - 1 }
                pos = pos + 1
                col = col + 1
            } else if ch == ',' {
                tokens = tokens.push(Token { kind: "Comma", value: ",", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == ';' {
                tokens = tokens.push(Token { kind: "Semicolon", value: ";", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == '?' {
                // Optional chaining: ?.
                if pos + 1 < total && chars[pos + 1] == '.' {
                    tokens = tokens.push(Token { kind: "QuestionDot", value: "?.", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens = tokens.push(Token { kind: "Question", value: "?", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '@' {
                // Attribute token: @name
                pos = pos + 1
                col = col + 1
                let mut attr_parts = []
                while pos < total && is_ident_char(chars[pos]) {
                    attr_parts = attr_parts.push(to_string(chars[pos]))
                    pos = pos + 1
                    col = col + 1
                }
                let attr_name = join(attr_parts, "")
                tokens = tokens.push(Token { kind: "Attribute", value: attr_name, line: line, col: start_col })
            } else if ch == '?' {
                if pos + 1 < total && chars[pos + 1] == '?' {
                    if pos + 2 < total && chars[pos + 2] == '=' {
                        tokens = tokens.push(Token { kind: "NullCoalescingAssign", value: "??=", line: line, col: start_col })
                        pos = pos + 3
                        col = col + 3
                    } else {
                        tokens = tokens.push(Token { kind: "NullCoalescing", value: "??", line: line, col: start_col })
                        pos = pos + 2
                        col = col + 2
                    }
                } else {
                    tokens = tokens.push(Token { kind: "Question", value: "?", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '#' {
                // Map literal: #{...}
                if pos + 1 < total && chars[pos + 1] == '{' {
                    tokens = tokens.push(Token { kind: "HashLBrace", value: "#{", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    // Standalone # — skip
                    pos = pos + 1
                    col = col + 1
                }
            } else {
                // Unknown character — skip
                pos = pos + 1
                col = col + 1
            }
        }
    }

    // Add EOF token
    tokens = tokens.push(Token { kind: "Eof", value: "", line: line, col: col })
    return tokens
}

// Count tokens by kind
fn count_kind(tokens, kind) {
    let mut count = 0
    for t in tokens {
        if t.kind == kind {
            count = count + 1
        }
    }
    return count
}


// -- end inlined --

let _hexa_root = if len(env_var("HEXA_LANG")) > 0 { env_var("HEXA_LANG") } else { "." }
let HEXA = _hexa_root + "/hexa"
let SELF_DIR = _hexa_root + "/self"
let TMP_DIR = "/tmp/hexa_self_parse_test"

exec("mkdir -p " + TMP_DIR)

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        pass_count = pass_count + 1
        println("  PASS: " + name)
    } else {
        fail_count = fail_count + 1
        println("  FAIL: " + name)
    }
}

// ═══════════════════════════════════════════════════════════
//  PART A: Direct Lexer Tests (self/lexer.hexa imported)
// ═══════════════════════════════════════════════════════════

println("=== Part A: Self-Lexer Tokenization ===")
println("")

// --- A1: Basic let statement ---
println("[A1] let x = 42")
let a1 = tokenize("let x = 42")
check("A1.1 token count == 5", len(a1) == 5)
check("A1.2 first token kind is Let", a1[0].kind == "Let")
check("A1.3 second token is Ident 'x'", a1[1].kind == "Ident" && a1[1].value == "x")
check("A1.4 third token is Eq", a1[2].kind == "Eq")
check("A1.5 fourth token is IntLit '42'", a1[3].kind == "IntLit" && a1[3].value == "42")
check("A1.6 fifth token is Eof", a1[4].kind == "Eof")
check("A1.7 line tracking is 1", a1[0].line == 1)

// --- A2: Function declaration ---
println("")
println("[A2] fn add(a, b) { return a + b }")
let a2 = tokenize("fn add(a, b) { return a + b }")
check("A2.1 first token is Fn", a2[0].kind == "Fn")
check("A2.2 second token is Ident 'add'", a2[1].kind == "Ident" && a2[1].value == "add")
check("A2.3 LParen present", a2[2].kind == "LParen")
check("A2.4 params a,b with comma", a2[3].kind == "Ident" && a2[3].value == "a")
check("A2.5 comma separator", a2[4].kind == "Comma")
check("A2.6 param b", a2[5].kind == "Ident" && a2[5].value == "b")
check("A2.7 RParen", a2[6].kind == "RParen")
check("A2.8 LBrace", a2[7].kind == "LBrace")
check("A2.9 return keyword", a2[8].kind == "Return")

// --- A3: Operators and precedence tokens ---
println("")
println("[A3] Operators: == != >= <= && ||")
let a3 = tokenize("x == y != z >= w <= v && u || t")
check("A3.1 EqEq operator", a3[1].kind == "EqEq")
check("A3.2 NotEq operator", a3[3].kind == "NotEq")
check("A3.3 GtEq operator", a3[5].kind == "GtEq")
check("A3.4 LtEq operator", a3[7].kind == "LtEq")
check("A3.5 And operator", a3[9].kind == "And")
check("A3.6 Or operator", a3[11].kind == "Or")

// --- A4: String literal ---
println("")
println("[A4] String literal")
let a4 = tokenize("let s = \"hello world\"")
check("A4.1 StringLit token", a4[3].kind == "StringLit")
check("A4.2 StringLit value", a4[3].value == "hello world")

// --- A5: Keywords ---
println("")
println("[A5] Keyword classification")
let a5 = tokenize("struct enum trait impl match while for if else")
check("A5.1 struct keyword", a5[0].kind == "Struct")
check("A5.2 enum keyword", a5[1].kind == "Enum")
check("A5.3 trait keyword", a5[2].kind == "Trait")
check("A5.4 impl keyword", a5[3].kind == "Impl")
check("A5.5 match keyword", a5[4].kind == "Match")
check("A5.6 while keyword", a5[5].kind == "While")
check("A5.7 for keyword", a5[6].kind == "For")

// --- A6: Float literal ---
println("")
println("[A6] Float literal")
let a6 = tokenize("let pi = 3.14")
check("A6.1 FloatLit token", a6[3].kind == "FloatLit")
check("A6.2 FloatLit value", a6[3].value == "3.14")

// --- A7: Multiline tokenization ---
println("")
println("[A7] Multiline: line tracking")
let a7 = tokenize("let x = 1\nlet y = 2\nlet z = 3")
let a7_newlines = count_kind(a7, "Newline")
check("A7.1 newline tokens present", a7_newlines == 2)
// Find second let token - should be on line 2
let mut a7_second_let_line = 0
let mut a7_i = 0
let mut a7_let_count = 0
while a7_i < len(a7) {
    if a7[a7_i].kind == "Let" {
        a7_let_count = a7_let_count + 1
        if a7_let_count == 2 {
            a7_second_let_line = a7[a7_i].line
        }
    }
    a7_i = a7_i + 1
}
check("A7.2 second let is on line 2", a7_second_let_line == 2)

// --- A8: Bool literals ---
println("")
println("[A8] Bool literals")
let a8 = tokenize("true false")
check("A8.1 true is BoolLit", a8[0].kind == "BoolLit" && a8[0].value == "true")
check("A8.2 false is BoolLit", a8[1].kind == "BoolLit" && a8[1].value == "false")

// --- A9: Comments are skipped ---
println("")
println("[A9] Comments")
let a9 = tokenize("let x = 1 // this is a comment\nlet y = 2")
// Comment should be skipped; we should have tokens for both let statements
let a9_lets = count_kind(a9, "Let")
check("A9.1 comments skipped, two lets found", a9_lets == 2)

// --- A10: Range and dot ---
println("")
println("[A10] Dot/DotDot/Arrow operators")
let a10a = tokenize("0..10")
check("A10.1 DotDot range", a10a[1].kind == "DotDot")
let a10b = tokenize("x.y")
check("A10.2 Dot field access", a10b[1].kind == "Dot")
let a10c = tokenize("fn f() -> int")
// find Arrow
let mut a10_has_arrow = false
let mut a10_j = 0
while a10_j < len(a10c) {
    if a10c[a10_j].kind == "Arrow" { a10_has_arrow = true }
    a10_j = a10_j + 1
}
check("A10.3 Arrow token", a10_has_arrow)

// --- A11: Attribute (@ produces At token, name is separate Ident) ---
println("")
println("[A11] Attribute @memoize")
let a11 = tokenize("@memoize\nfn fib(n) { n }")
check("A11.1 At token", a11[0].kind == "At")
check("A11.2 Ident 'memoize' follows @", a11[1].kind == "Ident" && a11[1].value == "memoize")

// --- A12: Char literal ---
println("")
println("[A12] Char literal")
let a12 = tokenize("let c = 'a'")
check("A12.1 CharLit kind", a12[3].kind == "CharLit")
check("A12.2 CharLit value", a12[3].value == "a")

// --- A13: Array / Brackets ---
println("")
println("[A13] Brackets")
let a13 = tokenize("[1, 2, 3]")
check("A13.1 LBracket", a13[0].kind == "LBracket")
check("A13.2 RBracket", a13[len(a13) - 2].kind == "RBracket")

println("")
println("--- Part A Summary ---")
println("  Passed: " + to_string(pass_count))
println("  Failed: " + to_string(fail_count))
let part_a_pass = pass_count
let part_a_fail = fail_count

// ═══════════════════════════════════════════════════════════
//  PART B: Self-Parser AST + Self-Interpreter (subprocess)
//  We load parser.hexa source, build a driver, run via exec()
// ═══════════════════════════════════════════════════════════

println("")
println("=== Part B: Self-Parser AST + Self-Interpreter (subprocess) ===")
println("")

// Load self-hosting pipeline sources
let parser_src = read_file(SELF_DIR + "/parser.hexa")
let interp_src = read_file(SELF_DIR + "/interpreter.hexa")

println("Loaded: parser.hexa (" + to_string(len(parser_src)) + " chars), interpreter.hexa (" + to_string(len(interp_src)) + " chars)")
println("")

// Helper: run a driver that uses parser.hexa's inline lexer + parser
// Returns the stdout of the driver
fn run_parser_driver(driver_code) {
    let combined = parser_src + "\n" + driver_code + "\n"
    let driver_file = TMP_DIR + "/driver_parse.hexa"
    write_file(driver_file, combined)
    let result = exec(HEXA + " " + driver_file + " 2>&1")
    return result
}

// Helper: run a driver that uses parser + interpreter
fn run_full_driver(driver_code) {
    let combined = parser_src + "\n" + interp_src + "\n" + driver_code + "\n"
    let driver_file = TMP_DIR + "/driver_full.hexa"
    write_file(driver_file, combined)
    let result = exec(HEXA + " " + driver_file + " 2>&1")
    return result
}

// B1: Parse let statement, check AST kind
println("[B1] Parse let x = 42 -> AST")
let b1_code = "let toks = tokenize(\"let x = 42\")\nlet ast = parse(toks)\nif ast[0].kind == \"LetStmt\" { println(\"B1_OK\") } else { println(\"B1_FAIL:\" + ast[0].kind) }"
let b1_out = run_parser_driver(b1_code)
check("B1.1 LetStmt AST kind", contains(b1_out, "B1_OK"))

// B2: Parse fn decl, check name and params
println("[B2] Parse fn add(a, b)")
let b2_code = "let toks = tokenize(\"fn add(a, b) {\\n  return a + b\\n}\")\nlet ast = parse(toks)\nif ast[0].kind == \"FnDecl\" && ast[0].name == \"add\" && len(ast[0].params) == 2 { println(\"B2_OK\") } else { println(\"B2_FAIL\") }"
let b2_out = run_parser_driver(b2_code)
check("B2.1 FnDecl name+params", contains(b2_out, "B2_OK"))

// B3: Parse struct, check fields
println("[B3] Parse struct Point { x: int, y: int }")
let b3_code = "let toks = tokenize(\"struct Point {\\n  x: int,\\n  y: int\\n}\")\nlet ast = parse(toks)\nif ast[0].kind == \"StructDecl\" && ast[0].name == \"Point\" && len(ast[0].fields) == 2 { println(\"B3_OK\") } else { println(\"B3_FAIL:\" + ast[0].kind + \" fields:\" + to_string(len(ast[0].fields))) }"
let b3_out = run_parser_driver(b3_code)
check("B3.1 StructDecl name+fields", contains(b3_out, "B3_OK"))

// B4: Parse if/else expression
println("[B4] Parse if/else")
let b4_code = "let toks = tokenize(\"if x > 0 { x } else { 0 }\")\nlet ast = parse(toks)\nlet stmt = ast[0]\nif stmt.kind == \"ExprStmt\" { println(\"B4_OK\") } else { println(\"B4_FAIL:\" + stmt.kind) }"
let b4_out = run_parser_driver(b4_code)
check("B4.1 if/else parses as ExprStmt", contains(b4_out, "B4_OK"))

// B5: Parse for loop
println("[B5] Parse for i in arr { ... }")
let b5_code = "let toks = tokenize(\"for i in arr {\\n  println(i)\\n}\")\nlet ast = parse(toks)\nif ast[0].kind == \"ForStmt\" && ast[0].name == \"i\" { println(\"B5_OK\") } else { println(\"B5_FAIL:\" + ast[0].kind) }"
let b5_out = run_parser_driver(b5_code)
check("B5.1 ForStmt with iter var", contains(b5_out, "B5_OK"))

// B6: Parse while loop
println("[B6] Parse while n > 0 { ... }")
let b6_code = "let toks = tokenize(\"while n > 0 {\\n  n = n - 1\\n}\")\nlet ast = parse(toks)\nif ast[0].kind == \"WhileStmt\" { println(\"B6_OK\") } else { println(\"B6_FAIL:\" + ast[0].kind) }"
let b6_out = run_parser_driver(b6_code)
check("B6.1 WhileStmt", contains(b6_out, "B6_OK"))

// B7: Parse match
println("[B7] Parse match expr")
let b7_code = "let toks = tokenize(\"match x {\\n  1 => println(1)\\n  2 => println(2)\\n}\")\nlet ast = parse(toks)\nif ast[0].kind == \"MatchStmt\" || ast[0].kind == \"ExprStmt\" { println(\"B7_OK\") } else { println(\"B7_FAIL:\" + ast[0].kind) }"
let b7_out = run_parser_driver(b7_code)
check("B7.1 match statement parsed", contains(b7_out, "B7_OK"))

// B8: Parse enum
println("[B8] Parse enum Color { Red, Green, Blue }")
let b8_code = "let toks = tokenize(\"enum Color {\\n  Red,\\n  Green,\\n  Blue\\n}\")\nlet ast = parse(toks)\nif ast[0].kind == \"EnumDecl\" && ast[0].name == \"Color\" { println(\"B8_OK\") } else { println(\"B8_FAIL:\" + ast[0].kind) }"
let b8_out = run_parser_driver(b8_code)
check("B8.1 EnumDecl", contains(b8_out, "B8_OK"))

// B9: Parse multiple statements
println("[B9] Parse multiple statements")
let b9_code = "let toks = tokenize(\"let x = 1\\nlet y = 2\\nlet z = x + y\")\nlet ast = parse(toks)\nif len(ast) == 3 { println(\"B9_OK\") } else { println(\"B9_FAIL:\" + to_string(len(ast))) }"
let b9_out = run_parser_driver(b9_code)
check("B9.1 three statements parsed", contains(b9_out, "B9_OK"))

// B10: Parse binary expression precedence
println("[B10] Parse 1 + 2 * 3 precedence")
let b10_code = "let toks = tokenize(\"1 + 2 * 3\")\nlet ast = parse(toks)\nlet expr = ast[0]\nif expr.kind == \"ExprStmt\" { println(\"B10_OK\") } else { println(\"B10_FAIL:\" + expr.kind) }"
let b10_out = run_parser_driver(b10_code)
check("B10.1 BinOp expression parsed", contains(b10_out, "B10_OK"))

// ═══════════════════════════════════════════════════════════
//  PART C: Self-Interpreter Evaluation (full pipeline)
// ═══════════════════════════════════════════════════════════

println("")
println("=== Part C: Self-Interpreter Evaluation ===")
println("")

// C1: interpret let + println
println("[C1] let x = 42 + 8; println(x)")
let c1_code = "let toks = tokenize(\"let x = 42 + 8\\nprintln(x)\")\nlet ast = parse(toks)\ninterpret(ast)\nprintln(\"C1_DONE\")"
let c1_out = run_full_driver(c1_code)
check("C1.1 interpret outputs 50", contains(c1_out, "50"))
check("C1.2 interpret completes", contains(c1_out, "C1_DONE"))

// C2: fn def + call
println("[C2] fn add(a, b) + call")
let c2_code = "let toks = tokenize(\"fn add(a, b) {\\n  return a + b\\n}\\nprintln(add(10, 20))\")\nlet ast = parse(toks)\ninterpret(ast)\nprintln(\"C2_DONE\")"
let c2_out = run_full_driver(c2_code)
check("C2.1 fn call returns 30", contains(c2_out, "30"))
check("C2.2 fn call completes", contains(c2_out, "C2_DONE"))

// C3: while loop
println("[C3] while loop sum")
let c3_code = "let src = \"let mut n = 5\\nlet mut sum = 0\\nwhile n > 0 {\\n  sum = sum + n\\n  n = n - 1\\n}\\nprintln(sum)\"\nlet toks = tokenize(src)\nlet ast = parse(toks)\ninterpret(ast)\nprintln(\"C3_DONE\")"
let c3_out = run_full_driver(c3_code)
check("C3.1 while loop sum == 15", contains(c3_out, "15"))

// C4: recursive fibonacci
println("[C4] recursive fib(10)")
let c4_code = "let src = \"fn fib(n) {\\n  if n <= 1 { return n }\\n  return fib(n - 1) + fib(n - 2)\\n}\\nprintln(fib(10))\"\nlet toks = tokenize(src)\nlet ast = parse(toks)\ninterpret(ast)\nprintln(\"C4_DONE\")"
let c4_out = run_full_driver(c4_code)
check("C4.1 fib(10) == 55", contains(c4_out, "55"))

// C5: for loop with array
println("[C5] for loop over array")
let c5_code = "let src = \"let mut total = 0\\nfor i in [1, 2, 3, 4, 5] {\\n  total = total + i\\n}\\nprintln(total)\"\nlet toks = tokenize(src)\nlet ast = parse(toks)\ninterpret(ast)\nprintln(\"C5_DONE\")"
let c5_out = run_full_driver(c5_code)
check("C5.1 for loop sum == 15", contains(c5_out, "15"))

