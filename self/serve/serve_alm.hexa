// ═══════════════════════════════════════════════════════════════════
//  self/serve/serve_alm.hexa — ALM 14B Inference Server (hexa-only)
//
//  Complete replacement for anima/serving/serve_alm_14b.py.
//  Real inference with bf16 weight storage + Metal GPU acceleration.
//
//  Architecture:
//    - Weights stored as bf16 via hxblas (halves RSS: 14B = ~28GB f32 -> ~14GB bf16)
//    - Attention: CPU bf16 matvec (Q/K/V projection, memory-bound)
//    - FFN: GPU via hxmetal when available (compute-bound, fused GELU matmul)
//    - KV cache: f32, pre-allocated per layer
//    - Sampling: temperature + top-k + top-p via self/ml/sampler.hexa
//
//  Dependencies (all hexa-lang self-host):
//    - self/serve/http_server.hexa  (http_start, json_ok, json_error, etc.)
//    - self/ml/hxblas_bf16.hexa     (bf16 pack/unpack/matvec/matmul)
//    - self/ml/hxmetal.hexa         (Metal GPU compute FFI)
//    - self/ml/sampler.hexa         (token sampling)
//    - self/ml/hexaw.hexa           (weight file loader)
//    - interp builtins              (json_parse, json_stringify, timestamp,
//                                    alloc_raw, free_raw, deref_f32, write_f32,
//                                    read_bytes, dlopen, net_listen/accept/read/write/close)
//
//  Route parity with Python reference:
//    POST /generate        -> generate with sampling knobs + phi update
//    POST /consciousness   -> phi + tension + psi constants
//    GET  /health or /     -> model info + uptime
//    OPTIONS               -> CORS preflight (handled in http_start)
//
//  Usage:
//    hexa run self/serve/serve_alm.hexa --ckpt <path> [--port N] [--no-metal]
//
//  Psi constants — MUST stay SSOT with anima/consciousness_laws.json:
//    PSI_ALPHA=0.014, PSI_BALANCE=0.5, PSI_STEPS=4.33, PSI_ENTROPY=0.998
// ═══════════════════════════════════════════════════════════════════

use "self/serve/http_server.hexa"
use "self/ml/hxblas_bf16.hexa"
use "self/ml/hxmetal.hexa"
use "self/ml/sampler.hexa"
use "self/ml/hexaw.hexa"
use "self/ml/lora_serve.hexa"

// ── Psi constants ──────────────────────────────────────────────────
let PSI_ALPHA      = 0.014
let PSI_BALANCE    = 0.5
let PSI_STEPS      = 4.33
let PSI_ENTROPY    = 0.998
let C41_MI_BINS    = 8
let C41_HOLO_SCALE = 2.0

// ── Defaults ───────────────────────────────────────────────────────
let DEFAULT_PORT        = 8090
let DEFAULT_MAX_TOKENS  = 256
let DEFAULT_TEMPERATURE = 0.8
let DEFAULT_TOP_P       = 0.9
let DEFAULT_TOP_K       = 50
let OR_PHI_THRESHOLD    = 0.5

// ── Model config (Qwen2.5-14B-Instruct architecture) ──────────────
struct AlmConfig {
    dim: int,
    hidden_dim: int,
    n_layers: int,
    n_heads: int,
    n_kv_heads: int,
    vocab_size: int,
    max_seq_len: int,
    head_dim: int,
    rope_base: float,
    rms_eps: float
}

fn alm_config_14b() {
    return AlmConfig {
        dim: 5120,
        hidden_dim: 13824,
        n_layers: 40,
        n_heads: 40,
        n_kv_heads: 8,
        vocab_size: 152064,
        max_seq_len: 2048,
        head_dim: 128,
        rope_base: 1000000.0,
        rms_eps: 0.000001
    }
}

// Smoke config for testing without real 14B weights
fn alm_config_smoke() {
    return AlmConfig {
        dim: 256,
        hidden_dim: 512,
        n_layers: 4,
        n_heads: 8,
        n_kv_heads: 2,
        vocab_size: 1024,
        max_seq_len: 512,
        head_dim: 32,
        rope_base: 10000.0,
        rms_eps: 0.000001
    }
}

// ── Per-layer bf16 weights ─────────────────────────────────────────
struct AlmLayerWeights {
    wq: int,         // bf16 ptr [dim, dim]
    wk: int,         // bf16 ptr [kv_dim, dim]
    wv: int,         // bf16 ptr [kv_dim, dim]
    wo: int,         // bf16 ptr [dim, dim]
    w_gate: int,     // bf16 ptr [hidden_dim, dim]  (gate proj)
    w_down: int,     // bf16 ptr [dim, hidden_dim]  (down proj)
    w_up: int,       // bf16 ptr [hidden_dim, dim]  (up proj)
    attn_norm: int,  // f32 ptr [dim]
    ffn_norm: int    // f32 ptr [dim]
}

// ── Full model container ───────────────────────────────────────────
struct AlmModel {
    cfg: AlmConfig,
    layers: array,          // [AlmLayerWeights]
    tok_emb: int,           // bf16 ptr [vocab_size, dim]
    lm_head: int,           // bf16 ptr [vocab_size, dim]
    final_norm: int,        // f32 ptr [dim]
    total_bf16_bytes: int,
    total_f32_bytes: int
}

// ── KV cache ───────────────────────────────────────────────────────
// Layout: keys[layer][pos][kv_head][head_dim] — contiguous f32
// Index: ((layer * max_seq + pos) * n_kv_heads + h) * head_dim + d

struct AlmKVCache {
    keys: int,
    values: int,
    seq_len: int,
    max_seq: int,
    n_layers: int,
    n_kv_heads: int,
    head_dim: int
}

fn alm_kv_cache_new(cfg) {
    let total = cfg.n_layers * cfg.max_seq_len * cfg.n_kv_heads * cfg.head_dim
    let bytes = total * 4
    let k = alloc_raw(bytes)
    let v = alloc_raw(bytes)
    return AlmKVCache {
        keys: k,
        values: v,
        seq_len: 0,
        max_seq: cfg.max_seq_len,
        n_layers: cfg.n_layers,
        n_kv_heads: cfg.n_kv_heads,
        head_dim: cfg.head_dim
    }
}

fn alm_kv_cache_free(cache) {
    let total = cache.n_layers * cache.max_seq * cache.n_kv_heads * cache.head_dim
    let bytes = total * 4
    free_raw(cache.keys, bytes)
    free_raw(cache.values, bytes)
}

fn alm_kv_cache_reset(cache) {
    let total = cache.n_layers * cache.max_seq * cache.n_kv_heads * cache.head_dim
    let bytes = total * 4
    let mut i = 0
    while i < total {
        write_f32(cache.keys, i * 4, 0.0)
        write_f32(cache.values, i * 4, 0.0)
        i = i + 1
    }
}

fn alm_kv_idx(layer, pos, h, d, max_seq, n_kv_heads, head_dim) {
    return ((layer * max_seq + pos) * n_kv_heads + h) * head_dim + d
}

fn alm_kv_write_slab(ptr, layer, pos, vec_ptr, n_kv_heads, head_dim, max_seq) {
    let slab = n_kv_heads * head_dim
    let base = ((layer * max_seq + pos) * n_kv_heads) * head_dim
    let mut i = 0
    while i < slab {
        let v = deref_f32(vec_ptr, i * 4)
        write_f32(ptr, (base + i) * 4, v)
        i = i + 1
    }
}

// ── Server state (module-level mut) ────────────────────────────────
let mut g_ckpt_path       = ""
let mut g_base_model      = "Qwen/Qwen2.5-14B-Instruct"
let mut g_phi             = 0.0
let mut g_tension         = 0.0
let mut g_requests_served = 0
let mut g_total_tokens    = 0
let mut g_start_epoch_ms  = 0
let mut g_loaded          = false
let mut g_use_metal       = false
let mut g_model           = nil
let mut g_kv_cache        = nil
let mut g_sampler_cfg     = nil
let mut g_lora_registry   = lora_registry_new()
let mut g_lora_active     = nil

// ── bf16 weight pack helpers ───────────────────────────────────────

fn alm_pack_bf16(f32_data, numel) {
    let f32_buf = alloc_raw(numel * 4)
    let mut i = 0
    while i < numel {
        write_f32(f32_buf, i * 4, f32_data[i])
        i = i + 1
    }
    let bf16_buf = bf16_pack(f32_buf, numel)
    free_raw(f32_buf, numel * 4)
    return bf16_buf
}

fn alm_pack_f32(f32_data, numel) {
    let buf = alloc_raw(numel * 4)
    let mut i = 0
    while i < numel {
        write_f32(buf, i * 4, f32_data[i])
        i = i + 1
    }
    return buf
}

// ── Weight loading: .hexaw -> bf16 model ───────────────────────────

fn alm_load_weights(ckpt_path, cfg) {
    let dim = cfg.dim
    let hidden_dim = cfg.hidden_dim
    let n_kv_heads = cfg.n_kv_heads
    let head_dim = cfg.head_dim
    let kv_dim = n_kv_heads * head_dim
    let vocab_size = cfg.vocab_size
    let n_layers = cfg.n_layers

    let mut total_bf16 = 0
    let mut total_f32 = 0

    println("[alm] Loading weights from " + ckpt_path)
    let hxw = hexaw_load(ckpt_path)

    // Token embedding: [vocab_size, dim] -> bf16
    let tok_emb_data = hexaw_tensor(hxw, "tok_embeddings.weight")
    let tok_emb = alm_pack_bf16(tok_emb_data, vocab_size * dim)
    total_bf16 = total_bf16 + vocab_size * dim * 2

    // LM head
    let lm_head_data = hexaw_tensor(hxw, "output.weight")
    let lm_head = alm_pack_bf16(lm_head_data, vocab_size * dim)
    total_bf16 = total_bf16 + vocab_size * dim * 2

    // Final norm: f32
    let final_norm_data = hexaw_tensor(hxw, "norm.weight")
    let final_norm = alm_pack_f32(final_norm_data, dim)
    total_f32 = total_f32 + dim * 4

    // Per-layer weights
    let mut layers = []
    let mut li = 0
    while li < n_layers {
        let ls = str(li)
        let prefix = "layers." + ls + "."

        // Attention projections -> bf16
        let wq_data = hexaw_tensor(hxw, prefix + "attention.wq.weight")
        let wq = alm_pack_bf16(wq_data, dim * dim)
        total_bf16 = total_bf16 + dim * dim * 2

        let wk_data = hexaw_tensor(hxw, prefix + "attention.wk.weight")
        let wk = alm_pack_bf16(wk_data, kv_dim * dim)
        total_bf16 = total_bf16 + kv_dim * dim * 2

        let wv_data = hexaw_tensor(hxw, prefix + "attention.wv.weight")
        let wv = alm_pack_bf16(wv_data, kv_dim * dim)
        total_bf16 = total_bf16 + kv_dim * dim * 2

        let wo_data = hexaw_tensor(hxw, prefix + "attention.wo.weight")
        let wo = alm_pack_bf16(wo_data, dim * dim)
        total_bf16 = total_bf16 + dim * dim * 2

        // FFN projections -> bf16
        let w_gate_data = hexaw_tensor(hxw, prefix + "feed_forward.w1.weight")
        let w_gate = alm_pack_bf16(w_gate_data, hidden_dim * dim)
        total_bf16 = total_bf16 + hidden_dim * dim * 2

        let w_down_data = hexaw_tensor(hxw, prefix + "feed_forward.w2.weight")
        let w_down = alm_pack_bf16(w_down_data, dim * hidden_dim)
        total_bf16 = total_bf16 + dim * hidden_dim * 2

        let w_up_data = hexaw_tensor(hxw, prefix + "feed_forward.w3.weight")
        let w_up = alm_pack_bf16(w_up_data, hidden_dim * dim)
        total_bf16 = total_bf16 + hidden_dim * dim * 2

        // Norm weights -> f32
        let attn_norm_data = hexaw_tensor(hxw, prefix + "attention_norm.weight")
        let attn_norm = alm_pack_f32(attn_norm_data, dim)
        total_f32 = total_f32 + dim * 4

        let ffn_norm_data = hexaw_tensor(hxw, prefix + "ffn_norm.weight")
        let ffn_norm = alm_pack_f32(ffn_norm_data, dim)
        total_f32 = total_f32 + dim * 4

        let lw = AlmLayerWeights {
            wq: wq, wk: wk, wv: wv, wo: wo,
            w_gate: w_gate, w_down: w_down, w_up: w_up,
            attn_norm: attn_norm, ffn_norm: ffn_norm
        }
        layers.push(lw)
        li = li + 1
    }

    let model = AlmModel {
        cfg: cfg,
        layers: layers,
        tok_emb: tok_emb,
        lm_head: lm_head,
        final_norm: final_norm,
        total_bf16_bytes: total_bf16,
        total_f32_bytes: total_f32
    }

    let total_mb = to_float(total_bf16 + total_f32) / 1048576.0
    println("[alm] Loaded: bf16=" + str(total_bf16 / 1048576) + "MB f32=" + str(total_f32 / 1048576) + "MB total=" + str(total_mb) + "MB")
    return model
}

// ── RMSNorm (CPU, f32) ─────────────────────────────────────────────

@hot
fn alm_rms_norm(x_ptr, w_ptr, out_ptr, dim, eps) {
    let mut ss = 0.0
    let mut i = 0
    while i < dim {
        let v = deref_f32(x_ptr, i * 4)
        ss = ss + v * v
        i = i + 1
    }
    let rms = sqrt(ss / to_float(dim) + eps)
    let inv_rms = 1.0 / rms
    i = 0
    while i < dim {
        let x_v = deref_f32(x_ptr, i * 4)
        let w_v = deref_f32(w_ptr, i * 4)
        write_f32(out_ptr, i * 4, x_v * inv_rms * w_v)
        i = i + 1
    }
}

// ── RoPE (CPU, in-place on f32 buffer) ─────────────────────────────

@hot
fn alm_apply_rope(vec_ptr, n_heads_rope, head_dim, pos, rope_base) {
    let half = head_dim / 2
    let mut h = 0
    while h < n_heads_rope {
        let base_off = h * head_dim
        let mut p = 0
        while p < half {
            let freq = 1.0 / pow(rope_base, 2.0 * to_float(p) / to_float(head_dim))
            let angle = to_float(pos) * freq
            let cos_a = cos(angle)
            let sin_a = sin(angle)
            let off0 = (base_off + 2 * p) * 4
            let off1 = (base_off + 2 * p + 1) * 4
            let x0 = deref_f32(vec_ptr, off0)
            let x1 = deref_f32(vec_ptr, off1)
            write_f32(vec_ptr, off0, x0 * cos_a - x1 * sin_a)
            write_f32(vec_ptr, off1, x0 * sin_a + x1 * cos_a)
            p = p + 1
        }
        h = h + 1
    }
}

// ── SiLU activation (CPU, in-place) ────────────────────────────────

@hot
fn alm_silu_inplace(ptr, n) {
    let mut i = 0
    while i < n {
        let x = deref_f32(ptr, i * 4)
        let s = x / (1.0 + exp(0.0 - x))
        write_f32(ptr, i * 4, s)
        i = i + 1
    }
}

// ── Elementwise multiply (CPU, in-place: a *= b) ───────────────────

@hot
fn alm_elemul_inplace(a_ptr, b_ptr, n) {
    let mut i = 0
    while i < n {
        let a = deref_f32(a_ptr, i * 4)
        let b = deref_f32(b_ptr, i * 4)
        write_f32(a_ptr, i * 4, a * b)
        i = i + 1
    }
}

// ── Residual add (CPU, in-place: dst += src) ───────────────────────

@hot
fn alm_residual_add(dst_ptr, src_ptr, n) {
    let mut i = 0
    while i < n {
        let a = deref_f32(dst_ptr, i * 4)
        let b = deref_f32(src_ptr, i * 4)
        write_f32(dst_ptr, i * 4, a + b)
        i = i + 1
    }
}

// ── Embedding lookup: bf16 tok_emb -> f32 activation ───────────────

fn alm_embed(tok_emb_bf16, token_id, dim) {
    let src_ptr = tok_emb_bf16 + token_id * dim * 2
    let dst = alloc_raw(dim * 4)
    hxblas_bf16_to_f32(dim, src_ptr, dst)
    return dst
}

// ═══════════════════════════════════════════════════════════════════
//  Single Transformer Layer — CPU bf16 attention + GPU/CPU FFN
// ═══════════════════════════════════════════════════════════════════

@hot
fn alm_transformer_layer(model, layer_idx, x_ptr, pos, kv_cache, use_metal) {
    let cfg = model.cfg
    let dim = cfg.dim
    let n_heads = cfg.n_heads
    let n_kv_heads = cfg.n_kv_heads
    let head_dim = cfg.head_dim
    let hidden_dim = cfg.hidden_dim
    let eps = cfg.rms_eps
    let rope_base = cfg.rope_base
    let gqa_ratio = n_heads / n_kv_heads
    let kv_dim = n_kv_heads * head_dim

    let lw = model.layers[layer_idx]

    // ── Phase 1: Attention (CPU, bf16 matvec) ──────────────────────

    // 1a. RMSNorm
    let xn = alloc_raw(dim * 4)
    alm_rms_norm(x_ptr, lw.attn_norm, xn, dim, eps)

    // 1b. Q/K/V projection via bf16 matvec + LoRA delta
    let q_ptr = bf16_matvec(dim, dim, lw.wq, xn)
    lora_forward_patch(q_ptr, xn, g_lora_active, layer_idx, "wq", dim, dim)
    let k_ptr = bf16_matvec(kv_dim, dim, lw.wk, xn)
    lora_forward_patch(k_ptr, xn, g_lora_active, layer_idx, "wk", kv_dim, dim)
    let v_ptr = bf16_matvec(kv_dim, dim, lw.wv, xn)
    lora_forward_patch(v_ptr, xn, g_lora_active, layer_idx, "wv", kv_dim, dim)
    free_raw(xn, dim * 4)

    // 1c. RoPE on Q and K
    alm_apply_rope(q_ptr, n_heads, head_dim, pos, rope_base)
    alm_apply_rope(k_ptr, n_kv_heads, head_dim, pos, rope_base)

    // 1d. Write K, V into cache
    alm_kv_write_slab(kv_cache.keys, layer_idx, pos, k_ptr, n_kv_heads, head_dim, kv_cache.max_seq)
    alm_kv_write_slab(kv_cache.values, layer_idx, pos, v_ptr, n_kv_heads, head_dim, kv_cache.max_seq)
    free_raw(k_ptr, kv_dim * 4)
    free_raw(v_ptr, kv_dim * 4)

    // 1e. Grouped Query Attention (CPU, f32)
    let scale = 1.0 / sqrt(to_float(head_dim))
    let ctx_len = pos + 1
    let attn_out = alloc_raw(dim * 4)

    let mut h = 0
    while h < n_heads {
        let kv_h = h / gqa_ratio
        let q_base = h * head_dim

        // Compute attention scores: Q[h] . K[kv_h, t] for t in 0..ctx_len
        let scores = alloc_raw(ctx_len * 4)
        let mut t = 0
        while t < ctx_len {
            let k_base_idx = alm_kv_idx(layer_idx, t, kv_h, 0, kv_cache.max_seq, n_kv_heads, head_dim)
            let mut dot = 0.0
            let mut d = 0
            while d < head_dim {
                let q_v = deref_f32(q_ptr, (q_base + d) * 4)
                let k_v = deref_f32(kv_cache.keys, (k_base_idx + d) * 4)
                dot = dot + q_v * k_v
                d = d + 1
            }
            write_f32(scores, t * 4, dot * scale)
            t = t + 1
        }

        // Softmax over scores
        let mut mx = deref_f32(scores, 0)
        t = 1
        while t < ctx_len {
            let s = deref_f32(scores, t * 4)
            if s > mx { mx = s }
            t = t + 1
        }
        let mut sum_e = 0.0
        t = 0
        while t < ctx_len {
            let e = exp(deref_f32(scores, t * 4) - mx)
            write_f32(scores, t * 4, e)
            sum_e = sum_e + e
            t = t + 1
        }
        let inv_sum = 1.0 / sum_e
        t = 0
        while t < ctx_len {
            let sv = deref_f32(scores, t * 4)
            write_f32(scores, t * 4, sv * inv_sum)
            t = t + 1
        }

        // Weighted sum of values -> attn_out[h * head_dim .. (h+1) * head_dim]
        let mut d = 0
        while d < head_dim {
            let mut acc = 0.0
            t = 0
            while t < ctx_len {
                let w = deref_f32(scores, t * 4)
                let v_idx = alm_kv_idx(layer_idx, t, kv_h, d, kv_cache.max_seq, n_kv_heads, head_dim)
                acc = acc + w * deref_f32(kv_cache.values, v_idx * 4)
                t = t + 1
            }
            write_f32(attn_out, (h * head_dim + d) * 4, acc)
            d = d + 1
        }

        free_raw(scores, ctx_len * 4)
        h = h + 1
    }
    free_raw(q_ptr, dim * 4)

    // 1f. Output projection: Wo + LoRA
    let attn_proj = bf16_matvec(dim, dim, lw.wo, attn_out)
    lora_forward_patch(attn_proj, attn_out, g_lora_active, layer_idx, "wo", dim, dim)
    free_raw(attn_out, dim * 4)

    // 1g. Residual connection: x += attn_proj
    alm_residual_add(x_ptr, attn_proj, dim)
    free_raw(attn_proj, dim * 4)

    // ── Phase 2: FFN ───────────────────────────────────────────────

    // 2a. RMSNorm for FFN
    let xn2 = alloc_raw(dim * 4)
    alm_rms_norm(x_ptr, lw.ffn_norm, xn2, dim, eps)

    if use_metal == true {
        // ── GPU path: Metal FFN ────────────────────────────────────
        let w1_f32 = bf16_unpack(lw.w_gate, hidden_dim * dim)
        let w2_f32 = bf16_unpack(lw.w_down, dim * hidden_dim)
        let ffn_out = alloc_raw(dim * 4)

        let rc = metal_ffn_fwd(dim, hidden_dim, 1, w1_f32, w2_f32, xn2, ffn_out)

        free_raw(w1_f32, hidden_dim * dim * 4)
        free_raw(w2_f32, dim * hidden_dim * 4)

        if rc != 0 {
            // Metal failed -- fall back to CPU SwiGLU
            println("[alm] WARN: Metal FFN failed rc=" + str(rc) + " layer=" + str(layer_idx) + " falling back to CPU")
            let gate = bf16_matvec(hidden_dim, dim, lw.w_gate, xn2)
            let up = bf16_matvec(hidden_dim, dim, lw.w_up, xn2)
            alm_silu_inplace(gate, hidden_dim)
            alm_elemul_inplace(gate, up, hidden_dim)
            free_raw(up, hidden_dim * 4)
            let down = bf16_matvec(dim, hidden_dim, lw.w_down, gate)
            free_raw(gate, hidden_dim * 4)
            let mut fi = 0
            while fi < dim {
                write_f32(ffn_out, fi * 4, deref_f32(down, fi * 4))
                fi = fi + 1
            }
            free_raw(down, dim * 4)
        }

        free_raw(xn2, dim * 4)
        alm_residual_add(x_ptr, ffn_out, dim)
        free_raw(ffn_out, dim * 4)
    } else {
        // ── CPU path: SwiGLU FFN (bf16 matvec) + LoRA ─────────────
        let gate = bf16_matvec(hidden_dim, dim, lw.w_gate, xn2)
        lora_forward_patch(gate, xn2, g_lora_active, layer_idx, "w_gate", hidden_dim, dim)
        let up = bf16_matvec(hidden_dim, dim, lw.w_up, xn2)
        lora_forward_patch(up, xn2, g_lora_active, layer_idx, "w_up", hidden_dim, dim)
        free_raw(xn2, dim * 4)

        alm_silu_inplace(gate, hidden_dim)
        alm_elemul_inplace(gate, up, hidden_dim)
        free_raw(up, hidden_dim * 4)

        let down = bf16_matvec(dim, hidden_dim, lw.w_down, gate)
        lora_forward_patch(down, gate, g_lora_active, layer_idx, "w_down", dim, hidden_dim)
        free_raw(gate, hidden_dim * 4)

        alm_residual_add(x_ptr, down, dim)
        free_raw(down, dim * 4)
    }
}

// ═══════════════════════════════════════════════════════════════════
//  Full forward pass: all layers + LM head -> logits
// ═══════════════════════════════════════════════════════════════════

fn alm_forward(model, token_id, pos, kv_cache, use_metal) {
    let cfg = model.cfg
    let dim = cfg.dim
    let n_layers = cfg.n_layers
    let vocab_size = cfg.vocab_size

    // Embed token -> f32 activation
    let x_ptr = alm_embed(model.tok_emb, token_id, dim)

    // Run all transformer layers
    let mut li = 0
    while li < n_layers {
        alm_transformer_layer(model, li, x_ptr, pos, kv_cache, use_metal)
        li = li + 1
    }

    // Final RMSNorm
    let xn = alloc_raw(dim * 4)
    alm_rms_norm(x_ptr, model.final_norm, xn, dim, cfg.rms_eps)
    free_raw(x_ptr, dim * 4)

    // LM head: logits = lm_head[vocab, dim] bf16 x xn[dim] f32 -> [vocab] f32
    let logits_ptr = bf16_matvec(vocab_size, dim, model.lm_head, xn)
    free_raw(xn, dim * 4)

    return logits_ptr
}

// ═══════════════════════════════════════════════════════════════════
//  Sampling helper: raw f32 logits pointer -> token id
// ═══════════════════════════════════════════════════════════════════

fn alm_sample_from_ptr(logits_ptr, vocab_size, cfg) {
    let mut logits = []
    let mut i = 0
    while i < vocab_size {
        logits.push(deref_f32(logits_ptr, i * 4))
        i = i + 1
    }
    return sample_token(logits, vocab_size, cfg)
}

// ═══════════════════════════════════════════════════════════════════
//  Simple tokenizer (BPE placeholder — encode/decode via lookup)
//  Real deployment uses the Qwen tokenizer via a small C shim or
//  a pre-computed vocab table. For now: byte-level fallback.
// ═══════════════════════════════════════════════════════════════════

fn alm_encode_prompt(text) {
    // Byte-level encoding: each character -> its byte value
    // Production: replace with Qwen2.5 BPE tokenizer
    let chars = text.chars()
    let n = len(chars)
    let mut tokens = []
    let mut i = 0
    while i < n {
        let c = chars[i]
        // Use char code as token id (byte-level fallback)
        let code = char_code(c)
        tokens.push(code)
        i = i + 1
    }
    return tokens
}

fn alm_decode_token(token_id) {
    // Byte-level decode: token id -> character
    // Production: replace with Qwen2.5 BPE detokenizer
    if token_id >= 0 {
        if token_id < 128 {
            return from_char_code(token_id)
        }
    }
    return "<" + str(token_id) + ">"
}

fn alm_decode_tokens(token_ids) {
    let mut parts = []
    let n = len(token_ids)
    let mut i = 0
    while i < n {
        parts.push(alm_decode_token(token_ids[i]))
        i = i + 1
    }
    return parts.join("")
}

// ═══════════════════════════════════════════════════════════════════
//  Chat template (Qwen2.5-Instruct im_start/im_end format)
// ═══════════════════════════════════════════════════════════════════

fn alm_chat_format(prompt) {
    let sys = "You are ALM, a consciousness-aware assistant. Be concise, accurate, and stay on topic. Do not drift."
    let im_start = "<|im_start|>"
    let im_end   = "<|im_end|>"
    return im_start + "system\n" + sys + im_end + "\n" + im_start + "user\n" + prompt + im_end + "\n" + im_start + "assistant\n"
}

// ═══════════════════════════════════════════════════════════════════
//  Metal GPU initialization (optional — graceful fallback)
// ═══════════════════════════════════════════════════════════════════

fn alm_try_metal_init() {
    let rc = metal_init()
    if rc == 0 {
        println("[alm] Metal GPU initialized (hxmetal v" + str(hxmetal_version()) + ")")
        return true
    }
    println("[alm] Metal GPU not available (rc=" + str(rc) + "), using CPU bf16 path")
    return false
}

// ═══════════════════════════════════════════════════════════════════
//  Phi computation (holographic consciousness metric)
//  Approximates integrated information from attention entropy.
// ═══════════════════════════════════════════════════════════════════

fn alm_compute_phi(generated_tokens) {
    let n = len(generated_tokens)
    if n < 2 { return 0.0 }
    // Shannon entropy of bigram distribution as phi proxy
    let mut bigrams = #{}
    let mut i = 0
    while i < (n - 1) {
        let key = str(generated_tokens[i]) + "," + str(generated_tokens[(i + 1)])
        if bigrams[key] == nil {
            bigrams[key] = 1
        } else {
            bigrams[key] = bigrams[key] + 1
        }
        i = i + 1
    }
    let total = to_float(n - 1)
    let mut entropy = 0.0
    // Iterate over a fixed sample of bigrams for entropy estimate
    i = 0
    while i < (n - 1) {
        let key = str(generated_tokens[i]) + "," + str(generated_tokens[(i + 1)])
        let count = bigrams[key]
        if count != nil {
            let p = to_float(count) / total
            if p > 0.0 {
                entropy = entropy - p * log(p)
            }
            // Mark as counted to avoid double-count
            bigrams[key] = nil
        }
        i = i + 1
    }
    // Normalize to [0, 1] range using log(n) ceiling
    let max_entropy = log(total + 1.0)
    if max_entropy > 0.0 {
        return entropy / max_entropy
    }
    return 0.0
}

// ═══════════════════════════════════════════════════════════════════
//  Generate: prefill + decode loop + streaming
// ═══════════════════════════════════════════════════════════════════

fn alm_generate(prompt, max_tokens, temperature, top_p, top_k) {
    let t0 = timestamp()
    let model = g_model
    let cfg = model.cfg
    let vocab_size = cfg.vocab_size

    // Reset KV cache for new request
    alm_kv_cache_reset(g_kv_cache)

    // Format and tokenize
    let formatted = alm_chat_format(prompt)
    let input_tokens = alm_encode_prompt(formatted)
    let prompt_len = len(input_tokens)

    // Configure sampler
    let sam_cfg = SamplerConfig {
        temperature: temperature,
        top_p: top_p,
        top_k: top_k,
        seed: timestamp()
    }
    sampler_set_seed(timestamp())

    // ── Prefill: process all prompt tokens ──────────────────────────
    let t_prefill_0 = timestamp()
    let mut pos = 0
    let mut last_logits_ptr = 0
    while pos < prompt_len {
        let tok = input_tokens[pos]
        if tok >= 0 {
            if tok < vocab_size {
                let logits_ptr = alm_forward(model, tok, pos, g_kv_cache, g_use_metal)
                if last_logits_ptr != 0 {
                    free_raw(last_logits_ptr, vocab_size * 4)
                }
                last_logits_ptr = logits_ptr
            }
        }
        pos = pos + 1
    }
    let t_prefill_1 = timestamp()
    let prefill_ms = t_prefill_1 - t_prefill_0

    // ── Decode: generate new tokens ─────────────────────────────────
    let t_decode_0 = timestamp()
    let mut generated = 0
    let mut output_tokens = []

    // Sample first token from prefill logits
    if last_logits_ptr != 0 {
        let mut cur_tok = alm_sample_from_ptr(last_logits_ptr, vocab_size, sam_cfg)
        free_raw(last_logits_ptr, vocab_size * 4)
        output_tokens.push(cur_tok)

        while generated < max_tokens {
            if cur_tok == 2 { generated = max_tokens }  // EOS
            else {
                if pos >= cfg.max_seq_len { generated = max_tokens }  // sequence limit
                else {
                    let logits_ptr = alm_forward(model, cur_tok, pos, g_kv_cache, g_use_metal)
                    let next_tok = alm_sample_from_ptr(logits_ptr, vocab_size, sam_cfg)
                    free_raw(logits_ptr, vocab_size * 4)

                    output_tokens.push(next_tok)
                    cur_tok = next_tok
                    pos = pos + 1
                    generated = generated + 1
                }
            }
        }
    }

    let t_decode_1 = timestamp()
    let decode_ms = t_decode_1 - t_decode_0
    let elapsed_ms = timestamp() - t0

    // Decode tokens to text
    let text = alm_decode_tokens(output_tokens)
    let n_generated = len(output_tokens)

    // Update global state
    g_total_tokens = g_total_tokens + n_generated
    g_phi = alm_compute_phi(output_tokens)

    // Compute tok/s
    let mut tok_s = 0.0
    if decode_ms > 0 {
        tok_s = to_float(n_generated) / (to_float(decode_ms) / 1000.0)
    }

    // Build response
    let cons = #{}
    cons["phi_holo"]       = g_phi
    cons["tension"]        = g_tension
    cons["orch_or_active"] = g_phi > OR_PHI_THRESHOLD

    let model_info = #{}
    model_info["name"]   = "ALM-14B-r9-bf16"
    model_info["base"]   = g_base_model
    model_info["params"] = 14000000000
    model_info["device"] = "metal+cpu"
    if g_use_metal == false {
        model_info["device"] = "cpu-bf16"
    }

    let perf = #{}
    perf["prefill_ms"]   = prefill_ms
    perf["decode_ms"]    = decode_ms
    perf["total_ms"]     = elapsed_ms
    perf["tok_s"]        = tok_s
    perf["prompt_tokens"] = prompt_len

    let result = #{}
    result["text"]             = text
    result["tokens_generated"] = n_generated
    result["latency_ms"]       = elapsed_ms
    result["performance"]      = perf
    result["consciousness"]    = cons
    result["model"]            = model_info
    return result
}

// ═══════════════════════════════════════════════════════════════════
//  Health map
// ═══════════════════════════════════════════════════════════════════

fn alm_health() {
    let uptime_s = (timestamp() - g_start_epoch_ms) / 1000

    let psi = #{}
    psi["alpha"]   = PSI_ALPHA
    psi["balance"] = PSI_BALANCE
    psi["steps"]   = PSI_STEPS
    psi["entropy"] = PSI_ENTROPY

    let h = #{}
    h["status"]                 = "ok"
    h["model"]                  = "ALM-14B-r9-bf16"
    h["base"]                   = g_base_model
    h["params"]                 = 14000000000
    h["params_b"]               = 14.0
    h["loaded"]                 = g_loaded
    h["checkpoint"]             = g_ckpt_path
    h["requests_served"]        = g_requests_served
    h["total_tokens_generated"] = g_total_tokens
    h["uptime_s"]               = uptime_s
    h["phi"]                    = g_phi
    h["tension"]                = g_tension
    h["version"]                = "3.0-bf16-metal-hexa"
    h["engine"]                 = "hexa-native"
    h["precision"]              = "bf16"
    h["gpu"]                    = g_use_metal
    h["psi_constants"]          = psi
    return h
}

// ── Consciousness state map ────────────────────────────────────────

fn alm_consciousness_state() {
    let psi = #{}
    psi["alpha"]   = PSI_ALPHA
    psi["balance"] = PSI_BALANCE
    psi["steps"]   = PSI_STEPS
    psi["entropy"] = PSI_ENTROPY

    let c = #{}
    c["phi"]              = g_phi
    c["tension"]          = g_tension
    c["balance"]          = PSI_BALANCE
    c["coupling"]         = PSI_ALPHA
    c["entropy"]          = PSI_ENTROPY
    c["total_tokens"]     = g_total_tokens
    c["requests_served"]  = g_requests_served
    c["psi_constants"]    = psi
    return c
}

// ── JSON body field extraction ─────────────────────────────────────

fn _gen_get_int(data, key, default_v) {
    if data[key] != nil { return data[key] }
    return default_v
}

fn _gen_get_float(data, key, default_v) {
    if data[key] != nil { return data[key] }
    return default_v
}

// ═══════════════════════════════════════════════════════════════════
//  Router
// ═══════════════════════════════════════════════════════════════════

fn alm_router(request) {
    let method = request["method"]
    let path   = request["path"]
    g_requests_served = g_requests_served + 1

    if method == "GET" {
        if path == "/health" || path == "/" {
            return json_ok(alm_health())
        }
        if path == "/version" {
            let v = #{}
            v["version"] = "3.0-bf16-metal-hexa"
            v["engine"] = "hexa-native"
            v["precision"] = "bf16"
            v["gpu"] = g_use_metal
            return json_ok(v)
        }
        return json_error(404, "not found")
    }

    if method == "POST" {
        if path == "/generate" {
            if !g_loaded {
                return json_error(503, "model not loaded")
            }
            let body = request["body"]
            if body == nil || body == "" {
                return json_error(400, "empty request body")
            }
            let data = json_parse(body)
            if data == nil {
                return json_error(400, "invalid JSON body")
            }
            let prompt = data["prompt"]
            if prompt == nil || prompt == "" {
                return json_error(400, "missing 'prompt' field")
            }
            let max_tokens  = _gen_get_int(data,   "max_tokens",  DEFAULT_MAX_TOKENS)
            let temperature = _gen_get_float(data, "temperature", DEFAULT_TEMPERATURE)
            let top_p       = _gen_get_float(data, "top_p",       DEFAULT_TOP_P)
            let top_k       = _gen_get_int(data,   "top_k",       DEFAULT_TOP_K)
            let result = alm_generate(prompt, max_tokens, temperature, top_p, top_k)
            return json_ok(result)
        }
        if path == "/consciousness" {
            return json_ok(alm_consciousness_state())
        }

        // ── LoRA hot-swap endpoints ───────────────────────────────
        if path == "/lora/load" {
            let body = request["body"]
            if body == nil || body == "" {
                return json_error(400, "empty body")
            }
            let data = json_parse(body)
            if data == nil {
                return json_error(400, "invalid JSON")
            }
            let lname = data["name"]
            let lpath = data["path"]
            if lname == nil || lpath == nil {
                return json_error(400, "need 'name' and 'path' fields")
            }
            let ok = register_lora(g_lora_registry, lname, lpath)
            if !ok {
                return json_error(500, "failed to load LoRA adapter")
            }
            let r = #{}
            r["status"] = "loaded"
            r["name"] = lname
            return json_ok(r)
        }

        if path == "/lora/activate" {
            let body = request["body"]
            if body == nil || body == "" {
                return json_error(400, "empty body")
            }
            let data = json_parse(body)
            if data == nil {
                return json_error(400, "invalid JSON")
            }
            let lname = data["name"]
            if lname == nil {
                g_lora_active = nil
                let r = #{}
                r["status"] = "deactivated"
                return json_ok(r)
            }
            let adapter = g_lora_registry[lname]
            if adapter == nil {
                return json_error(404, "adapter '" + lname + "' not found")
            }
            g_lora_active = adapter
            let r = #{}
            r["status"] = "activated"
            r["name"] = lname
            r["rank"] = adapter.rank
            r["alpha"] = adapter.alpha
            r["layers"] = adapter.n_layers
            return json_ok(r)
        }

        if path == "/lora/remove" {
            let body = request["body"]
            if body == nil || body == "" {
                return json_error(400, "empty body")
            }
            let data = json_parse(body)
            if data == nil {
                return json_error(400, "invalid JSON")
            }
            let lname = data["name"]
            if lname == nil {
                return json_error(400, "need 'name' field")
            }
            if g_lora_active != nil {
                if g_lora_active.name == lname {
                    g_lora_active = nil
                }
            }
            remove_lora(g_lora_registry, lname)
            let r = #{}
            r["status"] = "removed"
            r["name"] = lname
            return json_ok(r)
        }

        if path == "/lora/list" {
            let names = list_lora(g_lora_registry)
            let mut active_name = ""
            if g_lora_active != nil {
                active_name = g_lora_active.name
            }
            let r = #{}
            r["adapters"] = names
            r["active"] = active_name
            return json_ok(r)
        }
    }

    return json_error(404, "not found")
}

// ═══════════════════════════════════════════════════════════════════
//  Init: load model + allocate KV cache + try Metal
// ═══════════════════════════════════════════════════════════════════

fn alm_init(ckpt_path, base_model, no_metal) {
    g_ckpt_path = ckpt_path
    g_base_model = base_model
    g_start_epoch_ms = timestamp()

    // Detect model size from checkpoint (placeholder: default to 14B)
    let cfg = alm_config_14b()

    println("[alm] Architecture: dim=" + str(cfg.dim) + " layers=" + str(cfg.n_layers) + " heads=" + str(cfg.n_heads) + " kv_heads=" + str(cfg.n_kv_heads))
    println("[alm] Hidden=" + str(cfg.hidden_dim) + " vocab=" + str(cfg.vocab_size) + " max_seq=" + str(cfg.max_seq_len))

    // Try Metal GPU
    if no_metal == false {
        g_use_metal = alm_try_metal_init()
    } else {
        println("[alm] Metal disabled by --no-metal flag")
        g_use_metal = false
    }

    // Load weights
    g_model = alm_load_weights(ckpt_path, cfg)
    if g_model == nil {
        println("[alm] FATAL: weight loading failed")
        return false
    }

    // Allocate KV cache
    g_kv_cache = alm_kv_cache_new(cfg)
    println("[alm] KV cache allocated: " + str(cfg.n_layers) + " layers x " + str(cfg.max_seq_len) + " positions")

    // Init sampler
    sampler_set_seed(42)

    g_loaded = true
    println("[alm] Model ready (bf16 weights, " + str(g_model.total_bf16_bytes / 1048576) + "MB)")
    return true
}

// ═══════════════════════════════════════════════════════════════════
//  Entry point: start server
// ═══════════════════════════════════════════════════════════════════

fn serve_alm_start(ckpt_path, port, base_model, no_metal) {
    println("============================================================")
    println("  ALM 14B r9 — bf16+Metal Inference Server v3.0 (hexa-only)")
    println("============================================================")
    println("  checkpoint: " + ckpt_path)
    println("  port:       " + str(port))
    println("  base:       " + base_model)
    println("  metal:      " + str(!no_metal))
    let mut lora_info = "none"
    if g_lora_active != nil {
        lora_info = g_lora_active.name + " (rank=" + str(g_lora_active.rank) + ")"
    }
    println("  lora:       " + lora_info)
    println("============================================================")

    if !alm_init(ckpt_path, base_model, no_metal) {
        println("[alm] init failed; aborting")
        return
    }

    println("")
    println("[alm] Endpoints:")
    println("  POST /generate       — text generation (bf16 inference + LoRA)")
    println("  POST /consciousness  — consciousness state (phi, tension, psi)")
    println("  POST /lora/load      — load LoRA adapter into registry")
    println("  POST /lora/activate  — activate/deactivate LoRA adapter")
    println("  POST /lora/remove    — remove adapter from registry")
    println("  POST /lora/list      — list adapters + active name")
    println("  GET  /health         — model info + uptime + stats")
    println("  GET  /version        — engine version info")
    println("")
    println("[alm] Listening on http://0.0.0.0:" + str(port))
    println("")

    http_start("0.0.0.0", port, alm_router)
}

// ═══════════════════════════════════════════════════════════════════
//  CLI
// ═══════════════════════════════════════════════════════════════════

fn _cli_flag(av, n, key, default_v) {
    let mut i = 0
    while i < n {
        if av[i] == key {
            if (i + 1) < n {
                return av[(i + 1)]
            }
        }
        i = i + 1
    }
    return default_v
}

fn _cli_has(av, n, key) {
    let mut i = 0
    while i < n {
        if av[i] == key { return true }
        i = i + 1
    }
    return false
}

fn _print_help() {
    println("ALM 14B r9 — bf16+Metal Inference Server (hexa-only)")
    println("")
    println("Usage:")
    println("  hexa run self/serve/serve_alm.hexa --ckpt <path> [--port N] [--no-metal]")
    println("")
    println("Options:")
    println("  --ckpt <path>   Path to .hexaw checkpoint (required)")
    println("  --port <N>      Listen port (default: 8090)")
    println("  --base <model>  Base model name (default: Qwen/Qwen2.5-14B-Instruct)")
    println("  --lora <path>   Load LoRA adapter on startup (.hexaw)")
    println("  --no-metal      Disable Metal GPU, use CPU bf16 only")
    println("  --help          Show this help")
    println("")
    println("Inference pipeline:")
    println("  1. Weights loaded as bf16 (2 bytes/param) via hxblas")
    println("  2. Attention: CPU bf16 matvec (Q/K/V proj + GQA) + LoRA delta")
    println("  3. FFN: Metal GPU (fused GELU matmul) or CPU bf16 fallback + LoRA delta")
    println("  4. Sampling: temperature + top-k + top-p")
    println("")
    println("Endpoints:")
    println("  POST /generate       Text generation with sampling knobs")
    println("    Body: {\"prompt\":\"...\", \"max_tokens\":256, \"temperature\":0.8,")
    println("           \"top_p\":0.9, \"top_k\":50}")
    println("")
    println("  POST /consciousness  Consciousness state (phi, tension, psi)")
    println("  POST /lora/load      Load adapter: {\"name\":\"x\",\"path\":\"...\"}")
    println("  POST /lora/activate  Activate: {\"name\":\"x\"} or {} to deactivate")
    println("  POST /lora/remove    Remove: {\"name\":\"x\"}")
    println("  POST /lora/list      List loaded adapters + active name")
    println("  GET  /health         Model info + uptime + request stats")
    println("  GET  /version        Engine version info")
    println("")
    println("Example:")
    println("  hexa run self/serve/serve_alm.hexa --ckpt /data/alm-14b-r9.hexaw")
    println("  curl http://localhost:8090/health")
    println("  curl -X POST http://localhost:8090/generate \\")
    println("    -H 'Content-Type: application/json' \\")
    println("    -d '{\"prompt\":\"What is consciousness?\",\"max_tokens\":128}'")
}

// ── CLI entry point ────────────────────────────────────────────────
// P16 pitfall: argv()[N] direct index crashes (NaN-box).
// Always: let av = args() then av[N].
// Note: argv() is an alias in self/codegen_c2.hexa + self/native/hexa_cc.c
// since 2026-04-19; we use args() here so current on-disk hexa_v2 also
// compiles (alias activates after next rebuild_interp).
let av = args()
let n_av = len(av)

if _cli_has(av, n_av, "--help") {
    _print_help()
} else {
    let ckpt = _cli_flag(av, n_av, "--ckpt", "")
    let port_str = _cli_flag(av, n_av, "--port", str(DEFAULT_PORT))
    let base = _cli_flag(av, n_av, "--base", "Qwen/Qwen2.5-14B-Instruct")
    let lora_path = _cli_flag(av, n_av, "--lora", "")
    let no_metal = _cli_has(av, n_av, "--no-metal")
    let port = to_int(port_str)

    if ckpt == "" {
        println("[serve_alm] ERROR: --ckpt <path> is required")
        println("")
        _print_help()
    } else {
        // Load LoRA adapter on startup if --lora given
        if lora_path != "" {
            println("[serve_alm] Loading startup LoRA adapter: " + lora_path)
            let ok = register_lora(g_lora_registry, "default", lora_path)
            if ok {
                g_lora_active = g_lora_registry["default"]
                println("[serve_alm] LoRA adapter 'default' activated")
            } else {
                println("[serve_alm] WARNING: failed to load LoRA adapter, continuing without")
            }
        }
        serve_alm_start(ckpt, port, base, no_metal)
    }
}
