// ===================================================================
//  self/serve/http_server.hexa — Minimal HTTP/1.1 Server in Pure HEXA
//
//  Uses net_listen / net_accept / net_read / net_write / net_close
//  builtins for full control over HTTP response format.
//
//  Exports:
//    http_start(host, port, router_fn)
//      router_fn(request) -> response map
//      request  = #{method, path, headers, body, query}
//      response = #{status, content_type, body, headers}
// ===================================================================

// ===================================================================
//  Parse raw HTTP request string into a map
// ===================================================================
fn parse_request(raw) {
    let mut method = "GET"
    let mut path = "/"
    let mut query = ""
    let mut body = ""
    let mut headers = #{}

    // Split header block from body on double CRLF
    let parts = raw.split("\r\n\r\n")
    let header_block = parts[0]
    if len(parts) > 1 {
        body = parts[1]
    }

    // Split header lines
    let lines = header_block.split("\r\n")
    if len(lines) > 0 {
        // Request line: "METHOD /path HTTP/1.1"
        let req_parts = lines[0].split(" ")
        if len(req_parts) >= 2 {
            method = req_parts[0]
            let full_path = req_parts[1]
            // Split path and query string
            let qidx = full_path.index_of("?")
            if qidx >= 0 {
                path = full_path.substring(0, qidx)
                query = full_path.substring(qidx + 1, len(full_path))
            } else {
                path = full_path
            }
        }
    }

    // Parse headers
    let mut i = 1
    while i < len(lines) {
        let line = lines[i]
        let colon = line.index_of(":")
        if colon > 0 {
            let key = line.substring(0, colon).trim().to_lower()
            let val = line.substring(colon + 1, len(line)).trim()
            headers[key] = val
        }
        i = i + 1
    }

    let result = #{}
    result["method"] = method
    result["path"] = path
    result["query"] = query
    result["body"] = body
    result["headers"] = headers
    return result
}

// ===================================================================
//  Parse query string "key=val&key2=val2" into map
// ===================================================================
fn parse_query(qs) {
    let result = #{}
    if len(qs) == 0 { return result }
    let pairs = qs.split("&")
    let mut i = 0
    while i < len(pairs) {
        let kv = pairs[i].split("=")
        if len(kv) >= 2 {
            result[kv[0]] = kv[1]
        } else {
            if len(kv) == 1 {
                result[kv[0]] = ""
            }
        }
        i = i + 1
    }
    return result
}

// ===================================================================
//  Build HTTP response string from response map
//  response map: #{status, content_type, body}
//  Optional: headers (map of extra headers)
// ===================================================================
fn build_response(resp) {
    let status = 200
    let mut status_code = 200
    let mut status_text = "OK"
    let mut content_type = "application/json"
    let mut body = ""
    let mut extra_headers = #{}

    // Read fields from response map
    if resp["status"] != nil {
        status_code = resp["status"]
    }
    if status_code == 200 { status_text = "OK" }
    if status_code == 201 { status_text = "Created" }
    if status_code == 204 { status_text = "No Content" }
    if status_code == 400 { status_text = "Bad Request" }
    if status_code == 404 { status_text = "Not Found" }
    if status_code == 405 { status_text = "Method Not Allowed" }
    if status_code == 500 { status_text = "Internal Server Error" }

    if resp["content_type"] != nil {
        content_type = resp["content_type"]
    }
    if resp["body"] != nil {
        body = resp["body"]
    }
    if resp["headers"] != nil {
        extra_headers = resp["headers"]
    }

    let mut header_str = "HTTP/1.1 " + str(status_code) + " " + status_text + "\r\n"
    header_str = header_str + "Content-Type: " + content_type + "\r\n"
    header_str = header_str + "Content-Length: " + str(len(body)) + "\r\n"
    header_str = header_str + "Connection: close\r\n"
    header_str = header_str + "Access-Control-Allow-Origin: *\r\n"
    header_str = header_str + "Access-Control-Allow-Methods: GET, POST, OPTIONS\r\n"
    header_str = header_str + "Access-Control-Allow-Headers: Content-Type\r\n"

    // Append extra headers
    // (skip for now — map iteration not trivially available)

    header_str = header_str + "\r\n"
    return header_str + body
}

// ===================================================================
//  JSON helpers
// ===================================================================
fn json_ok(data) {
    let resp = #{}
    resp["status"] = 200
    resp["content_type"] = "application/json"
    resp["body"] = json_stringify(data)
    return resp
}

fn json_error(status, message) {
    let err = #{}
    err["error"] = message
    let resp = #{}
    resp["status"] = status
    resp["content_type"] = "application/json"
    resp["body"] = json_stringify(err)
    return resp
}

fn text_ok(body) {
    let resp = #{}
    resp["status"] = 200
    resp["content_type"] = "text/plain"
    resp["body"] = body
    return resp
}

// ===================================================================
//  SSE (Server-Sent Events) response builder
//  Returns a response with text/event-stream content type.
//  The body should be pre-formatted SSE data.
// ===================================================================
fn sse_response(body) {
    let resp = #{}
    resp["status"] = 200
    resp["content_type"] = "text/event-stream"
    resp["body"] = body
    return resp
}

fn sse_event(data) {
    return "data: " + data + "\n\n"
}

fn sse_done() {
    return "data: [DONE]\n\n"
}

// ===================================================================
//  Main server loop
//  router_fn(request) -> response map
// ===================================================================
fn http_start(host, port, router_fn) {
    let addr = host + ":" + str(port)
    println("[http] Starting server on " + addr)
    let listener = net_listen(addr)
    println("[http] Listening on http://" + addr)

    let mut running = true
    while running {
        let conn = net_accept(listener)
        let raw = net_read(conn)

        if len(raw) > 0 {
            let request = parse_request(raw)

            // Handle OPTIONS preflight
            if request["method"] == "OPTIONS" {
                let resp = #{}
                resp["status"] = 204
                resp["content_type"] = "text/plain"
                resp["body"] = ""
                let http_resp = build_response(resp)
                net_write(conn, http_resp)
            } else {
                // Route the request
                let response = router_fn(request)

                // Check for shutdown sentinel
                if response["__stop__"] == true {
                    running = false
                } else {
                    let http_resp = build_response(response)
                    net_write(conn, http_resp)
                }
            }
        }

        net_close(conn)
    }

    println("[http] Server stopped")
}
