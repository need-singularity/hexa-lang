// ===================================================================
//  test_paged_attention_v2.hexa -- Paged Attention v2 (#297)
//
//  10+ tests covering:
//    1. pa_init manager creation
//    2. pa_alloc_block / pa_free_block
//    3. pa_write_kv / pa_read_kv round-trip
//    4. pa_create_sequence
//    5. pa_append_token (single + multi-block)
//    6. pa_attention correctness (single token)
//    7. pa_attention correctness (multi token softmax)
//    8. pa_cow_fork (shared blocks, ref_count)
//    9. pa_cow_fork + append (COW isolation)
//   10. pa_usage statistics
//   11. Exhaust blocks -> alloc returns -1
//   12. Multi-sequence independence
//
//  Run: ./hexa self/test_paged_attention_v2.hexa
// ===================================================================

import "ml/paged_attention_v2.hexa"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn approx(a, b, eps) {
    return fabs(a - b) < eps
}

println("===================================================================")
println("  Paged Attention v2 (#297) Test Suite")
println("===================================================================")

// -- T1: pa_init creates manager with correct state -----------------
let mgr0 = pa_init(4, 2, 8)
check("T1 D_head", mgr0["D_head"] == 4)
check("T1 block_size", mgr0["block_size"] == 2)
check("T1 max_blocks", mgr0["max_blocks"] == 8)
check("T1 free_list len", len(mgr0["free_list"]) == 8)

// -- T2: pa_alloc_block / pa_free_block ----------------------------
let res1 = pa_alloc_block(mgr0)
let mgr1 = res1[0]
let bid1 = res1[1]
check("T2 alloc: block_id >= 0", bid1 >= 0)
check("T2 alloc: free=7", len(mgr1["free_list"]) == 7)
check("T2 alloc: ref_count=1", mgr1["ref_count"][bid1] == 1)

let mgr1b = pa_free_block(mgr1, bid1)
check("T2 free: free=8", len(mgr1b["free_list"]) == 8)
check("T2 free: ref_count=0", mgr1b["ref_count"][bid1] == 0)

// -- T3: pa_write_kv / pa_read_kv round-trip -----------------------
let res2 = pa_alloc_block(mgr0)
let mgr2 = res2[0]
let bid2 = res2[1]
let k_in = [1.0, 2.0, 3.0, 4.0]
let v_in = [10.0, 20.0, 30.0, 40.0]
let mgr2w = pa_write_kv(mgr2, bid2, 0, k_in, v_in)
let kv_out = pa_read_kv(mgr2w, bid2, 0)
let k_out = kv_out[0]
let v_out = kv_out[1]
check("T3 read key[0]", approx(k_out[0], 1.0, 1.0e-9))
check("T3 read key[3]", approx(k_out[3], 4.0, 1.0e-9))
check("T3 read val[0]", approx(v_out[0], 10.0, 1.0e-9))
check("T3 read val[3]", approx(v_out[3], 40.0, 1.0e-9))

// -- T4: pa_create_sequence ----------------------------------------
let mgr3 = pa_create_sequence(mgr0, 0)
let seq0 = mgr3["sequences"]["0"]
check("T4 seq blocks empty", len(seq0["blocks"]) == 0)
check("T4 seq n_tokens=0", seq0["n_tokens"] == 0)

// -- T5: pa_append_token (single token, auto-alloc block) ----------
let mgr4 = pa_create_sequence(mgr0, 1)
let k1 = [1.0, 0.0, 0.0, 0.0]
let v1 = [5.0, 3.0, 1.0, 0.0]
let mgr4a = pa_append_token(mgr4, 1, k1, v1)
let seq1 = mgr4a["sequences"]["1"]
check("T5 append: n_tokens=1", seq1["n_tokens"] == 1)
check("T5 append: 1 block allocated", len(seq1["blocks"]) == 1)
// verify data via read
let phys5 = seq1["blocks"][0]
let kv5 = pa_read_kv(mgr4a, phys5, 0)
check("T5 append: key correct", approx(kv5[0][0], 1.0, 1.0e-9))
check("T5 append: val correct", approx(kv5[1][0], 5.0, 1.0e-9))

// -- T6: pa_attention single token (output = value) ----------------
let mgr5 = pa_init(2, 4, 8)
let mgr5a = pa_create_sequence(mgr5, 0)
let mgr5b = pa_append_token(mgr5a, 0, [1.0, 0.0], [7.0, 3.0])
let query6 = [1.0, 0.0]
let out6 = pa_attention(mgr5b, 0, query6)
// single token -> output = value
check("T6 attn single: dim0", approx(out6[0], 7.0, 1.0e-5))
check("T6 attn single: dim1", approx(out6[1], 3.0, 1.0e-5))

// -- T7: pa_attention multi-token softmax correctness --------------
// D_head=2, block_size=4, 2 tokens
// K0=[1,0] V0=[5,3], K1=[0,1] V1=[1,7], Q=[1,0]
let mgr6 = pa_init(2, 4, 8)
let mgr6a = pa_create_sequence(mgr6, 0)
let mgr6b = pa_append_token(mgr6a, 0, [1.0, 0.0], [5.0, 3.0])
let mgr6c = pa_append_token(mgr6b, 0, [0.0, 1.0], [1.0, 7.0])
let out7 = pa_attention(mgr6c, 0, [1.0, 0.0])
// Q=[1,0] . K0=[1,0] = 1.0, Q=[1,0] . K1=[0,1] = 0.0
// scale = 1/sqrt(2)
// score0 = 1/sqrt(2), score1 = 0
let sc0 = 1.0 / pa2_sqrt(2.0)
let sc1 = 0.0
let e0 = pa2_exp(sc0)
let e1 = pa2_exp(sc1)
let w0 = e0 / (e0 + e1)
let w1 = e1 / (e0 + e1)
let exp0 = w0 * 5.0 + w1 * 1.0
let exp1 = w0 * 3.0 + w1 * 7.0
check("T7 attn multi: dim0", approx(out7[0], exp0, 1.0e-4))
check("T7 attn multi: dim1", approx(out7[1], exp1, 1.0e-4))

// -- T8: pa_cow_fork shares blocks and increments ref_count --------
let mgr7 = pa_init(2, 4, 8)
let mgr7a = pa_create_sequence(mgr7, 0)
let mgr7b = pa_append_token(mgr7a, 0, [1.0, 0.0], [5.0, 3.0])
let mgr7c = pa_append_token(mgr7b, 0, [0.0, 1.0], [1.0, 7.0])
let mgr7d = pa_cow_fork(mgr7c, 0, 1)
let seq_src = mgr7d["sequences"]["0"]
let seq_dst = mgr7d["sequences"]["1"]
check("T8 fork: dst n_tokens == src", seq_dst["n_tokens"] == seq_src["n_tokens"])
check("T8 fork: dst blocks == src blocks", len(seq_dst["blocks"]) == len(seq_src["blocks"]))
// shared block should have ref_count == 2
let shared_bid = seq_src["blocks"][0]
check("T8 fork: ref_count=2", mgr7d["ref_count"][shared_bid] == 2)

// -- T9: COW isolation -- append to fork triggers private copy -----
// After fork, appending to dst should not affect src's data
let mgr8 = pa_append_token(mgr7d, 1, [1.0, 1.0], [9.0, 9.0])
// src seq 0 should still have 2 tokens
let src_after = mgr8["sequences"]["0"]
let dst_after = mgr8["sequences"]["1"]
check("T9 cow: src still 2 tokens", src_after["n_tokens"] == 2)
check("T9 cow: dst now 3 tokens", dst_after["n_tokens"] == 3)
// src attention should be unchanged
let out_src = pa_attention(mgr8, 0, [1.0, 0.0])
check("T9 cow: src attn unchanged dim0", approx(out_src[0], exp0, 1.0e-4))
check("T9 cow: src attn unchanged dim1", approx(out_src[1], exp1, 1.0e-4))

// -- T10: pa_usage statistics --------------------------------------
let mgr9 = pa_init(2, 4, 8)
let u0 = pa_usage(mgr9)
check("T10 usage: total=8", u0["total"] == 8)
check("T10 usage: used=0", u0["used"] == 0)
check("T10 usage: free=8", u0["free"] == 8)
let mgr9a = pa_create_sequence(mgr9, 0)
let mgr9b = pa_append_token(mgr9a, 0, [1.0, 0.0], [1.0, 0.0])
let u1 = pa_usage(mgr9b)
check("T10 usage: used=1 after append", u1["used"] == 1)
check("T10 usage: free=7 after append", u1["free"] == 7)

// -- T11: exhaust blocks -> alloc returns -1 -----------------------
let mgr10 = pa_init(2, 2, 2)
let r10a = pa_alloc_block(mgr10)
let r10b = pa_alloc_block(r10a[0])
let r10c = pa_alloc_block(r10b[0])
check("T11 exhaust: 3rd alloc returns -1", r10c[1] == -1)

// -- T12: multi-sequence independence ------------------------------
let mgr11 = pa_init(2, 4, 16)
let mgr11a = pa_create_sequence(mgr11, 10)
let mgr11b = pa_create_sequence(mgr11a, 20)
let mgr11c = pa_append_token(mgr11b, 10, [1.0, 0.0], [100.0, 0.0])
let mgr11d = pa_append_token(mgr11c, 20, [0.0, 1.0], [0.0, 200.0])
let out_s10 = pa_attention(mgr11d, 10, [1.0, 0.0])
let out_s20 = pa_attention(mgr11d, 20, [0.0, 1.0])
check("T12 multi-seq: seq10 dim0=100", approx(out_s10[0], 100.0, 1.0e-5))
check("T12 multi-seq: seq20 dim1=200", approx(out_s20[1], 200.0, 1.0e-5))
// sequences use different blocks
let s10_blks = mgr11d["sequences"]["10"]["blocks"]
let s20_blks = mgr11d["sequences"]["20"]["blocks"]
check("T12 multi-seq: different blocks", s10_blks[0] != s20_blks[0])

// -- T13: multi-block spanning (block_size=2, 3 tokens) ------------
let mgr12 = pa_init(2, 2, 8)
let mgr12a = pa_create_sequence(mgr12, 0)
let mgr12b = pa_append_token(mgr12a, 0, [1.0, 0.0], [1.0, 0.0])
let mgr12c = pa_append_token(mgr12b, 0, [0.0, 1.0], [0.0, 1.0])
let mgr12d = pa_append_token(mgr12c, 0, [1.0, 1.0], [0.5, 0.5])
let seq12 = mgr12d["sequences"]["0"]
check("T13 multi-block: 2 blocks used", len(seq12["blocks"]) == 2)
check("T13 multi-block: 3 tokens", seq12["n_tokens"] == 3)
// attention should work across blocks
let out13 = pa_attention(mgr12d, 0, [1.0, 1.0])
// Q=[1,1] . K0=[1,0]=1, K1=[0,1]=1, K2=[1,1]=2 -> scale 1/sqrt(2)
let s13_0 = 1.0 / pa2_sqrt(2.0)
let s13_1 = 1.0 / pa2_sqrt(2.0)
let s13_2 = 2.0 / pa2_sqrt(2.0)
let e13_0 = pa2_exp(s13_0)
let e13_1 = pa2_exp(s13_1)
let e13_2 = pa2_exp(s13_2)
let tot13 = e13_0 + e13_1 + e13_2
let exp13_0 = e13_0 * 1.0 / tot13 + e13_1 * 0.0 / tot13 + e13_2 * 0.5 / tot13
let exp13_1 = e13_0 * 0.0 / tot13 + e13_1 * 1.0 / tot13 + e13_2 * 0.5 / tot13
check("T13 multi-block attn: dim0", approx(out13[0], exp13_0, 1.0e-4))
check("T13 multi-block attn: dim1", approx(out13[1], exp13_1, 1.0e-4))

// ===================================================================
println("")
println("=== Paged Attention v2 (#297) summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
if fail_count == 0 {
    println("ALL PASS")
} else {
    println("SOME TESTS FAILED")
}
