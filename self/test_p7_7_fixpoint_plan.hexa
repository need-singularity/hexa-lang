#!hexa lax
// self/test_p7_7_fixpoint_plan.hexa — ROI #153 P7-7 fixpoint closure design doc
//
// HX11 AI-native self-format: design lives as hexa literal strings so that
// @doc / @readme passes can diff/lint without touching filesystem markdown.
// This file is NOT a unit test — running it prints the rendered plan so it
// stays parse-clean under default-strict lint and machine-addressable.
//
// Cross-refs (plain text, no external fetch):
//   - docs/plans/roi_143_p7_7_fixpoint.md              (ROI #143 deep plan)
//   - scripts/verify_fixpoint.hexa                     (whole-compiler 3x gate)
//   - scripts/p7_7_fixpoint_check.hexa                 (this ROI's harness)
//   - project_selfhost_p5.md                           (v2==v3 precedent)
//   - project_hexa_v2_circular_rebuild_20260417.md     (BLOCKER #152)
//   - feedback_seed_freeze.md                          (stage0 rebuild ban)

fn p7_7_plan_section(name) {
    // Cheap dispatch — each section returns a hexa literal string.
    if name == "gate"      { return _sec_gate() }
    if name == "artefacts" { return _sec_artefacts() }
    if name == "drift"     { return _sec_drift_classes() }
    if name == "blockers"  { return _sec_blockers() }
    if name == "harness"   { return _sec_harness_contract() }
    if name == "closure"   { return _sec_closure_criteria() }
    return ""
}

fn _sec_gate() {
    return "P7-7 FIXPOINT GATE\n"
        + "==================\n"
        + "  SHA256(hexa_v3) == SHA256(hexa_v4)  =>  CLOSED\n"
        + "  hexa_v2 (seed) -> hexa_v3 (first self-emit) may differ; tolerated.\n"
        + "  hexa_v3 -> hexa_v4 must be bitwise identical.\n"
        + "\n"
        + "This ROI (#153) follows P5 precedent which closed v2==v3 on 2026-04-10.\n"
        + "P7-7 extends the gate one cycle further so the native-emitted compiler\n"
        + "is proven a fixed point of itself (not just of the Rust-seeded stage0).\n"
}

fn _sec_artefacts() {
    return "ARTEFACTS\n"
        + "---------\n"
        + "  seed     : build/hexa_stage0       (HX8 frozen; do NOT rebuild)\n"
        + "  src      : self/hexa_full.hexa     (17,273 LOC compiler SSOT)\n"
        + "  hexa_v2  : build/hexa_fix1         (seed compiles src, legacy clang path)\n"
        + "  hexa_v3  : build/hexa_fix2         (hexa_v2 compiles src, native path)\n"
        + "  hexa_v4  : build/hexa_fix3         (hexa_v3 compiles src, native path)\n"
        + "  log      : shared/hexa-lang/fixpoint_log.json\n"
        + "  report   : build/p7_7_fixpoint_report.json  (harness output)\n"
}

fn _sec_drift_classes() {
    return "DRIFT CLASSES (byte-diff sources to neutralise)\n"
        + "-----------------------------------------------\n"
        + "  D1 symbol-table ordering    : HashMap iter non-determinism\n"
        + "  D2 string-literal pool      : insertion-order dependent\n"
        + "  D3 Mach-O LC_BUILD_VERSION  : wall-clock timestamp leak\n"
        + "  D4 ELF build-id             : nondeterministic SHA of input set\n"
        + "  D5 relocation offsets       : depend on emission order\n"
        + "  D6 codesign ad-hoc field    : per-host variance on Mac\n"
        + "  D7 peephole->fixup ordering : if reorder, BL/ADR deltas drift\n"
        + "  D8 IC-slot regen (BLOCKER)  : codegen_c2 _ic_def_parts aliasing\n"
        + "                                see project_hexa_v2_circular_rebuild_20260417.md\n"
}

fn _sec_blockers() {
    return "ACTIVE BLOCKERS\n"
        + "---------------\n"
        + "  B1 [BLOCKS #153] hexa_v2 circular rebuild regression\n"
        + "     rebuild_stage0.hexa triggers IC-slot collapse; 5.6M corrupt lines.\n"
        + "     Tracked: ROI #152; RESOLVED upstream at fcf275f4 per codegen_c2.hexa\n"
        + "     counter-driven regen, but stage0 on-disk binary is stale (frozen).\n"
        + "     Closure path: ROI #152 lands a fresh stage0, THEN this harness\n"
        + "     can flip from scaffold to live-gate mode (harness_live=1).\n"
        + "\n"
        + "  B2 HX8 seed freeze: do not run FORCE=1 rebuild_stage0.hexa.\n"
        + "     Memory feedback_seed_freeze.md, project_hexa_v2_circular_rebuild*.\n"
        + "\n"
        + "  B3 IR coverage gaps in native_build.hexa for hexa_full scale:\n"
        + "     StringLit, ArrayLit, MapLit, Field, Index, Match, TryCatch.\n"
        + "     See docs/plans/roi_143_p7_7_fixpoint.md Phase B.\n"
}

fn _sec_harness_contract() {
    return "HARNESS CONTRACT (scripts/p7_7_fixpoint_check.hexa)\n"
        + "----------------------------------------------------\n"
        + "  Modes:\n"
        + "    scaffold  — default; reports state, no compile. Safe under seed-freeze.\n"
        + "    live      — runs 3x compile chain (requires #152 fix landed).\n"
        + "                Gated by --live flag + absence of HEXA_SEED_FROZEN=1.\n"
        + "\n"
        + "  Exit codes:\n"
        + "    0  converged (v3==v4) OR scaffold report OK\n"
        + "    1  missing artefact\n"
        + "    2  compile failure during chain\n"
        + "    3  divergence detected (v3 != v4)\n"
        + "    4  IC-slot corruption detected in emitted .c (legacy path)\n"
        + "    5  blocker active, live mode refused\n"
        + "\n"
        + "  Report JSON keys:\n"
        + "    mode, ts, seed_sha, v2_sha, v3_sha, v4_sha, converged,\n"
        + "    ic_slot_drift_count, diff_first_offset, blockers_active[]\n"
}

fn _sec_closure_criteria() {
    return "CLOSURE CRITERIA\n"
        + "----------------\n"
        + "  C1 ROI #152 IC-slot fix lands in a fresh build/hexa_stage0 binary.\n"
        + "  C2 docs/plans/roi_143_p7_7_fixpoint.md Phase B completes (AST coverage).\n"
        + "  C3 Determinism audit patches D3-D7 above.\n"
        + "  C4 harness live mode returns exit 0 with converged=1 three runs in a row.\n"
        + "  C5 shared/hexa-lang/fixpoint_log.json gets a convergence row.\n"
        + "  C6 shared/hexa/state.json breakthrough entry appended.\n"
        + "  C7 Rename (HX10): hexa_v2 -> hexa, hexa_stage0 -> hexa. Separate commit.\n"
}

fn main() {
    let sections = ["gate", "artefacts", "drift", "blockers", "harness", "closure"]
    let mut i = 0
    while i < len(sections) {
        println(p7_7_plan_section(sections[i]))
        i = i + 1
    }
    println("[p7_7_plan] design doc render OK — ROI #153 scaffold")
}

main()
