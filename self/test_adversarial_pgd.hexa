// ═══════════════════════════════════════════════════════════════════
//  self/ml/adversarial_pgd.hexa — Adversarial Training PGD (#267)
//
//  FGSM / PGD attacks + adversarial training loop.
//
//  Model: linear multiclass with softmax + cross-entropy loss.
//      logits[k] = Σ_j W[k,j] * x[j]
//      p[k]      = softmax(logits)[k]
//      L         = -log p[y]
//
//  Gradient w.r.t. x:
//      ∇_x L = (p - onehot(y))^T · W
//
//  FGSM one-step:
//      x_adv = x + ε · sign(∇_x L)
//
//  PGD K-step with uniform init in ε-ball (L∞):
//      δ_0   ∼ U(-ε, ε)^D
//      δ_t+1 = Proj_{||δ||_∞ ≤ ε}( δ_t + α · sign(∇_δ L(f(x+δ), y)) )
//
//  Adversarial training: generate PGD examples, then SGD step on
//  the adversarial loss.
//
//  API:
//    apgd_softmax(logits)              -> [float]
//    apgd_ce_loss(W, x, y)             -> float
//    apgd_grad_input(W, x, y)          -> [float]
//    apgd_grad_weights(W, x, y)        -> [[float]]
//    apgd_sign(v)                      -> [float]
//    apgd_fgsm(W, x, y, eps)           -> [float]
//    apgd_pgd(W, x, y, eps, alpha, steps, seed) -> [float]
//    apgd_adv_train_step(W, X, Y, eps, alpha, steps, lr, seed) -> [[float]]
//    apgd_predict(W, x)                -> int
//    apgd_accuracy(W, X, Y)            -> float
//
//  AI-NATIVE attrs:
//    @pure  — deterministic numerics
//    @hot   — training loop
// ═══════════════════════════════════════════════════════════════════

fn apgd_abs(inp) { if inp < 0.0 { return 0.0 - inp } return inp }

fn apgd_exp(inp) {
    let mut v = inp
    if v > 20.0 { v = 20.0 }
    if v < -20.0 { v = -20.0 }
    let mut result = 1.0
    let mut term = 1.0
    let mut i = 1
    while i < 30 {
        term = term * v / to_float(i)
        result = result + term
        i = i + 1
    }
    if result < 0.0 { return 0.0 }
    return result
}

fn apgd_log(inp) {
    if inp <= 0.0 { return -30.0 }
    let mut v = inp
    let mut count = 0
    while v > 2.0 {
        v = v / 2.718281828
        count = count + 1
    }
    while v < 0.5 {
        v = v * 2.718281828
        count = count - 1
    }
    let d = v - 1.0
    let ln_v = d - d * d / 2.0 + d * d * d / 3.0 - d * d * d * d / 4.0
    return to_float(count) + ln_v
}

fn apgd_zeros_f(n) {
    let mut v = []
    let mut _i = 0
    while _i < n {
    return v
        _i = _i + 1
}

fn apgd_zeros_2d(rows, cols) {
    let mut v = []
    let mut _r = 0
    while _r < rows {
        let mut row = []
        for _c in 0..cols { row = row + [0.0] }
        v = v + [row]
        _r = _r + 1
    }
    return v
}

fn apgd_lcg(state) {
    return (state * 1103515245 + 12345) % 2147483648
}

fn apgd_uniform(state) {
    let s = apgd_lcg(state)
    return [to_float(s) / 2147483648.0, to_float(s)]
}

// ═══════════════════════════════════════════════════════════════════
//  Softmax
// ═══════════════════════════════════════════════════════════════════
@pure
fn apgd_softmax(logits) {
    let K = len(logits)
    let mut mx = logits[0]
    let mut k = 1
    while k < K {
    let mut out = apgd_zeros_f(K)
    let mut sum = 0.0
    for k in 0..K {
        let e = apgd_exp(logits[k] - mx)
        out[k] = e
        sum = sum + e
    }
    if sum <= 0.0 { sum = 1.0e-12 }
    for k in 0..K { out[k] = out[k] / sum }
    return out
        k = k + 1
}

// ═══════════════════════════════════════════════════════════════════
//  Linear forward
// ═══════════════════════════════════════════════════════════════════
@pure
fn apgd_logits(W, inp) {
    let K = len(W)
    let D = len(inp)
    let mut out = apgd_zeros_f(K)
    let mut k = 0
    while k < K {
        let mut s = 0.0
        for j in 0..D { s = s + W[k][j] * inp[j] }
        out[k] = s
        k = k + 1
    }
    return out
}

@pure
fn apgd_predict(W, inp) {
    let logits = apgd_logits(W, inp)
    let K = len(logits)
    let mut best = logits[0]
    let mut idx = 0
    let mut k = 1
    while k < K {
        if logits[k] > best {
            best = logits[k]
            idx = k
        }
        k = k + 1
    }
    return idx
}

// ═══════════════════════════════════════════════════════════════════
//  Cross-entropy loss
// ═══════════════════════════════════════════════════════════════════
@pure
fn apgd_ce_loss(W, inp, y) {
    let logits = apgd_logits(W, inp)
    let p = apgd_softmax(logits)
    let mut py = p[y]
    if py < 1.0e-12 { py = 1.0e-12 }
    return 0.0 - apgd_log(py)
}

// ═══════════════════════════════════════════════════════════════════
//  Gradient w.r.t. input:  ∇_x L = (p - onehot(y))^T · W
// ═══════════════════════════════════════════════════════════════════
@pure
fn apgd_grad_input(W, inp, y) {
    let K = len(W)
    let D = len(inp)
    let logits = apgd_logits(W, inp)
    let p = apgd_softmax(logits)
    let mut grad = apgd_zeros_f(D)
    let mut j = 0
    while j < D {
        let mut s = 0.0
        for k in 0..K {
            let mut diff = p[k]
            if k == y { diff = diff - 1.0 }
            s = s + diff * W[k][j]
        }
        grad[j] = s
        j = j + 1
    }
    return grad
}

// ═══════════════════════════════════════════════════════════════════
//  Gradient w.r.t. W:  ∇_W L[k,j] = (p[k] - [k==y]) * x[j]
// ═══════════════════════════════════════════════════════════════════
@pure
fn apgd_grad_weights(W, inp, y) {
    let K = len(W)
    let D = len(inp)
    let logits = apgd_logits(W, inp)
    let p = apgd_softmax(logits)
    let mut gW = apgd_zeros_2d(K, D)
    let mut k = 0
    while k < K {
        let mut diff = p[k]
        if k == y { diff = diff - 1.0 }
        for j in 0..D {
            gW[k][j] = diff * inp[j]
        }
        k = k + 1
    }
    return gW
}

// ═══════════════════════════════════════════════════════════════════
//  sign()
// ═══════════════════════════════════════════════════════════════════
@pure
fn apgd_sign(vec) {
    let D = len(vec)
    let mut out = apgd_zeros_f(D)
    let mut j = 0
    while j < D {
        if vec[j] > 0.0 { out[j] = 1.0 }
        else {
            if vec[j] < 0.0 { out[j] = -1.0 }
            else { out[j] = 0.0 }
        }
        j = j + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════════
//  FGSM one-step attack
// ═══════════════════════════════════════════════════════════════════
@pure
fn apgd_fgsm(W, inp, y, eps) {
    let D = len(inp)
    let grad = apgd_grad_input(W, inp, y)
    let sgn = apgd_sign(grad)
    let mut adv = apgd_zeros_f(D)
    let mut j = 0
    while j < D {
    return adv
        j = j + 1
}

// ═══════════════════════════════════════════════════════════════════
//  L∞ projection onto ε-ball centered at x_ref
// ═══════════════════════════════════════════════════════════════════
@pure
fn apgd_proj_linf(adv, x_ref, eps) {
    let D = len(adv)
    let mut out = apgd_zeros_f(D)
    let mut j = 0
    while j < D {
        let lo = x_ref[j] - eps
        let hi = x_ref[j] + eps
        let mut v = adv[j]
        if v < lo { v = lo }
        if v > hi { v = hi }
        out[j] = v
        j = j + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════════
//  PGD K-step attack (uniform init inside ε-ball)
// ═══════════════════════════════════════════════════════════════════
@hot
fn apgd_pgd(W, inp, y, eps, alpha, steps, seed) {
    let D = len(inp)
    let mut state = seed
    if state <= 0 { state = 1 }
    // init delta ~ U(-eps, eps)
    let mut adv = apgd_zeros_f(D)
    let mut j = 0
    while j < D {
        let u = apgd_uniform(state)
        state = int(u[1])
        if state <= 0 { state = 1 }
        let delta = (u[0] * 2.0 - 1.0) * eps
        adv[j] = inp[j] + delta
        j = j + 1
    }
    let mut t = 0
    while t < steps {
        let grad = apgd_grad_input(W, adv, y)
        let sgn = apgd_sign(grad)
        let mut updated = apgd_zeros_f(D)
        let mut j = 0
        while j < D {
        adv = apgd_proj_linf(updated, inp, eps)
        t = t + 1
            j = j + 1
    }
    return adv
}

// ═══════════════════════════════════════════════════════════════════
//  Adversarial training step
// ═══════════════════════════════════════════════════════════════════
@hot
fn apgd_adv_train_step(W, X, Y, eps, alpha, steps, lr, seed) {
    let N = len(X)
    let K = len(W)
    let D = len(X[0])
    let mut gW = apgd_zeros_2d(K, D)
    let mut state = seed
    if state <= 0 { state = 1 }
    let mut i = 0
    while i < N {
        let adv = apgd_pgd(W, X[i], Y[i], eps, alpha, steps, state)
        state = state + 7919
        if state <= 0 { state = 1 }
        let gi = apgd_grad_weights(W, adv, Y[i])
        for k in 0..K {
            for j in 0..D { gW[k][j] = gW[k][j] + gi[k][j] }
        }
        i = i + 1
    }
    let inv_n = 1.0 / to_float(N)
    let mut W_new = apgd_zeros_2d(K, D)
    let mut k = 0
    while k < K {
        for j in 0..D {
            W_new[k][j] = W[k][j] - lr * gW[k][j] * inv_n
        }
        k = k + 1
    }
    return W_new
}

// ═══════════════════════════════════════════════════════════════════
//  Accuracy
// ═══════════════════════════════════════════════════════════════════
@pure
fn apgd_accuracy(W, X, Y) {
    let N = len(X)
    if N == 0 { return 0.0 }
    let mut correct = 0
    let mut i = 0
    while i < N {
        let pred = apgd_predict(W, X[i])
        if pred == Y[i] { correct = correct + 1 }
        i = i + 1
    }
    return to_float(correct) / to_float(N)
}


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs_(inp) { if inp < 0.0 { return 0.0 - inp } return inp }
fn approx_(a, b, eps) { return fabs_(a - b) < eps }

println("=== Adversarial Training PGD (#267) ===")

// ── separable 2-class dataset ──────────────────────────────────
let W0 = [
    [2.0, 0.0],
    [0.0, 2.0]
]

// ── T1 softmax sums to 1 ───────────────────────────────────────
let s1 = apgd_softmax([1.0, 2.0, 3.0])
let mut sum1 = 0.0
let mut i = 0

while i < 3 { sum1 = sum1 + s1[i] }
check("T1 softmax sums to 1", approx_(sum1, 1.0, 1.0e-4))

// ── T2 softmax monotone ────────────────────────────────────────
check("T2 softmax monotone", s1[2] > s1[1] && s1[1] > s1[0])

// ── T3 CE loss on correct prediction is small ─────────────────
let loss_ok = apgd_ce_loss(W0, [1.0, 0.0], 0)
let loss_bad = apgd_ce_loss(W0, [0.0, 1.0], 0)
check("T3 ce_loss ok < bad", loss_ok < loss_bad)

// ── T4 predict picks argmax ────────────────────────────────────
check("T4 predict(1,0)=0", apgd_predict(W0, [1.0, 0.0]) == 0)
check("T4 predict(0,1)=1", apgd_predict(W0, [0.0, 1.0]) == 1)

// ── T5 grad_input has correct dimension ────────────────────────
let gi5 = apgd_grad_input(W0, [1.0, 0.0], 0)
check("T5 grad_input len=D", len(gi5) == 2)

// ── T6 grad_weights shape ──────────────────────────────────────
let gw6 = apgd_grad_weights(W0, [1.0, 0.0], 0)
check("T6 grad_weights shape", len(gw6) == 2 && len(gw6[0]) == 2)

// ── T7 sign() on positive/negative/zero ────────────────────────
let sg7 = apgd_sign([0.5, -1.2, 0.0])
check("T7 sign +", sg7[0] == 1.0)
check("T7 sign -", sg7[1] == -1.0)
check("T7 sign 0", sg7[2] == 0.0)

// ── T8 FGSM moves in adversarial direction ─────────────────────
let x8 = [0.9, 0.1]
let adv8 = apgd_fgsm(W0, x8, 0, 0.1)
// After perturbation, class-0 score should drop
let logits_clean = apgd_logits(W0, x8)
let logits_adv   = apgd_logits(W0, adv8)
let margin_clean = logits_clean[0] - logits_clean[1]
let margin_adv   = logits_adv[0] - logits_adv[1]
check("T8 FGSM shrinks margin", margin_adv < margin_clean)

// ── T9 FGSM respects ε-budget ─────────────────────────────────
let mut max_delta = 0.0
let mut j = 0

while j < 2 {
    let d = fabs_(adv8[j] - x8[j])
    if d > max_delta { max_delta = d }
}
check("T9 FGSM |delta|_inf <= eps", max_delta <= 0.1 + 1.0e-6)

// ── T10 PGD stays inside ε-ball ───────────────────────────────
let x10 = [0.9, 0.1]
let adv10 = apgd_pgd(W0, x10, 0, 0.15, 0.05, 10, 42)
let mut max_delta10 = 0.0
let mut j = 0

while j < 2 {
    let d = fabs_(adv10[j] - x10[j])
    if d > max_delta10 { max_delta10 = d }
}
check("T10 PGD |delta|_inf <= eps", max_delta10 <= 0.15 + 1.0e-6)

// ── T11 PGD increases loss ────────────────────────────────────
let loss_clean = apgd_ce_loss(W0, x10, 0)
let loss_pgd   = apgd_ce_loss(W0, adv10, 0)
check("T11 PGD raises loss", loss_pgd > loss_clean)

// ── T12 adversarial training step returns shape-consistent W ──
let X12 = [[1.0, 0.1], [0.9, 0.2], [0.1, 1.0], [0.2, 0.9]]
let Y12 = [0, 0, 1, 1]
let W1 = apgd_adv_train_step(W0, X12, Y12, 0.1, 0.03, 5, 0.05, 7)
check("T12 W_new shape", len(W1) == 2 && len(W1[0]) == 2)

// ── T13 clean accuracy remains high after one adv step ────────
let acc_clean = apgd_accuracy(W0, X12, Y12)
check("T13 base model separates", acc_clean >= 0.75)

// ── T14 PGD is stronger than FGSM in loss ─────────────────────
let adv_fgsm = apgd_fgsm(W0, x10, 0, 0.15)
let loss_fgsm_adv = apgd_ce_loss(W0, adv_fgsm, 0)
let loss_pgd_adv  = apgd_ce_loss(W0, adv10, 0)
check("T14 PGD ≥ FGSM loss", loss_pgd_adv >= loss_fgsm_adv - 1.0e-6)

println("")
println("=== Adversarial Training PGD summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
