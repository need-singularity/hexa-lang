// ═══════════════════════════════════════════════════════════════════
//  test_adversarial_pgd.hexa — Adversarial Training PGD (#267)
// ═══════════════════════════════════════════════════════════════════

import "ml/adversarial_pgd.hexa"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs_(inp) { if inp < 0.0 { return 0.0 - inp } return inp }
fn approx_(a, b, eps) { return fabs_(a - b) < eps }

println("=== Adversarial Training PGD (#267) ===")

// ── separable 2-class dataset ──────────────────────────────────
let W0 = [
    [2.0, 0.0],
    [0.0, 2.0]
]

// ── T1 softmax sums to 1 ───────────────────────────────────────
let s1 = apgd_softmax([1.0, 2.0, 3.0])
let mut sum1 = 0.0
let mut i = 0

while i < 3 { sum1 = sum1 + s1[i] }
check("T1 softmax sums to 1", approx_(sum1, 1.0, 1.0e-4))

// ── T2 softmax monotone ────────────────────────────────────────
check("T2 softmax monotone", s1[2] > s1[1] && s1[1] > s1[0])

// ── T3 CE loss on correct prediction is small ─────────────────
let loss_ok = apgd_ce_loss(W0, [1.0, 0.0], 0)
let loss_bad = apgd_ce_loss(W0, [0.0, 1.0], 0)
check("T3 ce_loss ok < bad", loss_ok < loss_bad)

// ── T4 predict picks argmax ────────────────────────────────────
check("T4 predict(1,0)=0", apgd_predict(W0, [1.0, 0.0]) == 0)
check("T4 predict(0,1)=1", apgd_predict(W0, [0.0, 1.0]) == 1)

// ── T5 grad_input has correct dimension ────────────────────────
let gi5 = apgd_grad_input(W0, [1.0, 0.0], 0)
check("T5 grad_input len=D", len(gi5) == 2)

// ── T6 grad_weights shape ──────────────────────────────────────
let gw6 = apgd_grad_weights(W0, [1.0, 0.0], 0)
check("T6 grad_weights shape", len(gw6) == 2 && len(gw6[0]) == 2)

// ── T7 sign() on positive/negative/zero ────────────────────────
let sg7 = apgd_sign([0.5, -1.2, 0.0])
check("T7 sign +", sg7[0] == 1.0)
check("T7 sign -", sg7[1] == -1.0)
check("T7 sign 0", sg7[2] == 0.0)

// ── T8 FGSM moves in adversarial direction ─────────────────────
let x8 = [0.9, 0.1]
let adv8 = apgd_fgsm(W0, x8, 0, 0.1)
// After perturbation, class-0 score should drop
let logits_clean = apgd_logits(W0, x8)
let logits_adv   = apgd_logits(W0, adv8)
let margin_clean = logits_clean[0] - logits_clean[1]
let margin_adv   = logits_adv[0] - logits_adv[1]
check("T8 FGSM shrinks margin", margin_adv < margin_clean)

// ── T9 FGSM respects ε-budget ─────────────────────────────────
let mut max_delta = 0.0
let mut j = 0

while j < 2 {
    let d = fabs_(adv8[j] - x8[j])
    if d > max_delta { max_delta = d }
}
check("T9 FGSM |delta|_inf <= eps", max_delta <= 0.1 + 1.0e-6)

// ── T10 PGD stays inside ε-ball ───────────────────────────────
let x10 = [0.9, 0.1]
let adv10 = apgd_pgd(W0, x10, 0, 0.15, 0.05, 10, 42)
let mut max_delta10 = 0.0
let mut j = 0

while j < 2 {
    let d = fabs_(adv10[j] - x10[j])
    if d > max_delta10 { max_delta10 = d }
}
check("T10 PGD |delta|_inf <= eps", max_delta10 <= 0.15 + 1.0e-6)

// ── T11 PGD increases loss ────────────────────────────────────
let loss_clean = apgd_ce_loss(W0, x10, 0)
let loss_pgd   = apgd_ce_loss(W0, adv10, 0)
check("T11 PGD raises loss", loss_pgd > loss_clean)

// ── T12 adversarial training step returns shape-consistent W ──
let X12 = [[1.0, 0.1], [0.9, 0.2], [0.1, 1.0], [0.2, 0.9]]
let Y12 = [0, 0, 1, 1]
let W1 = apgd_adv_train_step(W0, X12, Y12, 0.1, 0.03, 5, 0.05, 7)
check("T12 W_new shape", len(W1) == 2 && len(W1[0]) == 2)

// ── T13 clean accuracy remains high after one adv step ────────
let acc_clean = apgd_accuracy(W0, X12, Y12)
check("T13 base model separates", acc_clean >= 0.75)

// ── T14 PGD is stronger than FGSM in loss ─────────────────────
let adv_fgsm = apgd_fgsm(W0, x10, 0, 0.15)
let loss_fgsm_adv = apgd_ce_loss(W0, adv_fgsm, 0)
let loss_pgd_adv  = apgd_ce_loss(W0, adv10, 0)
check("T14 PGD ≥ FGSM loss", loss_pgd_adv >= loss_fgsm_adv - 1.0e-6)

println("")
println("=== Adversarial Training PGD summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
