// ===============================================================
//  self/test_approximate.hexa -- @approximate attribute tests
//  ROI #159 — Newton sqrt + Taylor exp, approximate attr
// ===============================================================
//
// NOTE: interp interpreter does NOT resolve `use "..."` at runtime
// (same as test_speculative_decode.hexa). We therefore INLINE the
// core approximate algorithms here, mirroring
// self/attrs/_own/approximate.hexa. SSOT for the attr impl +
// registry wiring stays in attrs/_own/approximate.hexa; this test
// locks the numerical algorithm.
//
// libm ref:
//   sqrt(100)=10           ± 1e-5
//   sqrt(2)=1.41421356     ± 1e-5
//   exp(0)=1               exact
//   exp(1)=2.71828         ± 1e-3
//   exp(-1)=0.36788        ± 1e-3
//
// Run: ./hexa run self/test_approximate.hexa

let mut pass_count = 0
let mut fail_count = 0

fn _abs_f(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

// ─── INLINED ALGORITHMS (mirror self/attrs/_own/approximate.hexa) ───

// Newton-Raphson sqrt — 6 iter default (mirrors attrs/_own/approximate.hexa)
fn approximate_newton_sqrt(n) {
    if n <= 0.0 { return 0.0 }
    let mut x = n / 2.0
    if x < 1.0 { x = 1.0 }
    let mut i = 0
    while i < 6 {
        x = 0.5 * (x + n / x)
        i = i + 1
    }
    return x
}

fn approximate_newton_sqrt_iter(n, iters) {
    if n <= 0.0 { return 0.0 }
    let mut x = n / 2.0
    if x < 1.0 { x = 1.0 }
    let mut i = 0
    while i < iters {
        x = 0.5 * (x + n / x)
        i = i + 1
    }
    return x
}

fn _approx_floor(x) {
    let i = to_int(x)
    let ir = to_float(i)
    if x < 0.0 && ir != x { return ir - 1.0 }
    return ir
}

fn _taylor_exp_small(x, terms) {
    let mut result = 1.0
    let mut term = 1.0
    let mut i = 1
    while i < terms {
        term = term * x / to_float(i)
        result = result + term
        i = i + 1
    }
    return result
}

fn approximate_taylor_exp(x) {
    if _abs_f(x) < 0.5 {
        return _taylor_exp_small(x, 10)
    }
    let kf = _approx_floor(x)
    let r  = x - kf
    let e_const = 2.718281828459045
    let e_inv   = 0.36787944117144233
    let k_int = to_int(kf)
    let mut e_pow = 1.0
    if k_int > 0 {
        let mut i = 0
        while i < k_int {
            e_pow = e_pow * e_const
            i = i + 1
        }
    } else if k_int < 0 {
        let mut i = 0
        let n = 0 - k_int
        while i < n {
            e_pow = e_pow * e_inv
            i = i + 1
        }
    }
    let e_r = _taylor_exp_small(r, 10)
    return e_pow * e_r
}

// ─── test helpers ───

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " expected=" + to_string(expected) + " got=" + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_close(name, actual, expected, tol) {
    let d = _abs_f(actual - expected)
    if d <= tol {
        println("[PASS] " + name + " diff=" + to_string(d))
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " actual=" + to_string(actual) + " expected=" + to_string(expected) + " diff=" + to_string(d) + " tol=" + to_string(tol))
        fail_count = fail_count + 1
    }
}

fn check_bool(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

println("===============================================================")
println("  HEXA @approximate (ROI #159) — Newton sqrt / Taylor exp")
println("===============================================================")

// ─── Section 1: Newton sqrt ──────────────────────────────────────
println("--- Section 1: approximate_newton_sqrt (6 iter Newton) ---")

check_close("sqrt(100)=10",    approximate_newton_sqrt(100.0), 10.0,           1e-5)
check_close("sqrt(2)=1.41421", approximate_newton_sqrt(2.0),   1.41421356,     1e-5)
check_close("sqrt(1)=1",       approximate_newton_sqrt(1.0),   1.0,            1e-5)
check_close("sqrt(4)=2",       approximate_newton_sqrt(4.0),   2.0,            1e-5)
check_close("sqrt(25)=5",      approximate_newton_sqrt(25.0),  5.0,            1e-5)
check_close("sqrt(9)=3",       approximate_newton_sqrt(9.0),   3.0,            1e-5)
check_close("sqrt(16)=4",      approximate_newton_sqrt(16.0),  4.0,            1e-5)

// edge cases
check("sqrt(0) exact 0",           approximate_newton_sqrt(0.0),  0.0)
check("sqrt(-1) defensive 0",      approximate_newton_sqrt(-1.0), 0.0)

// libm cross-check (loop 1..30)
let mut sq_ok = true
let mut max_err = 0.0
let mut si = 1
while si <= 30 {
    let x = to_float(si)
    let approx = approximate_newton_sqrt(x)
    let exact = sqrt(x)
    let d = _abs_f(approx - exact)
    if d > max_err { max_err = d }
    if d > 1e-5 { sq_ok = false }
    si = si + 1
}
check_bool("sqrt 1..30 max_err <= 1e-5 (" + to_string(max_err) + ")", sq_ok)

// parameterized iter (8 iter → 더 tight)
check_close("sqrt(2) iter=8 <= 1e-10",
    approximate_newton_sqrt_iter(2.0, 8),
    1.4142135623730951, 1e-10)

println("")

// ─── Section 2: Taylor exp ───────────────────────────────────────
println("--- Section 2: approximate_taylor_exp (10 terms + range-reduce) ---")
// (approximate_newton_sqrt_iter already covers parameterized iter path)


check_close("exp(0)=1",           approximate_taylor_exp(0.0),   1.0,           1e-9)
check_close("exp(1)=2.71828",     approximate_taylor_exp(1.0),   2.71828,       1e-3)
check_close("exp(-1)=0.36788",    approximate_taylor_exp(-1.0),  0.36788,       1e-3)
check_close("exp(0.5)=1.64872",   approximate_taylor_exp(0.5),   1.6487212707,  1e-3)
check_close("exp(-0.5)=0.60653",  approximate_taylor_exp(-0.5),  0.6065306597,  1e-3)
check_close("exp(2)=7.38906",     approximate_taylor_exp(2.0),   7.389056099,   1e-2)
check_close("exp(-2)=0.13534",    approximate_taylor_exp(-2.0),  0.1353352832,  1e-2)
check_close("exp(0.1)=1.10517",   approximate_taylor_exp(0.1),   1.10517091808, 1e-3)

println("")

// ─── Summary ─────────────────────────────────────────────────────
println("===============================================================")
println("  @approximate total: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("===============================================================")

if fail_count > 0 { exit(1) }
