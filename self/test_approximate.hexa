// ===============================================================
//  test_approximate.hexa -- @approximate attribute tests
//  M974: Newton/Taylor approximation injection
//  ROI id=6, P2, effect 2x
// ===============================================================

// ── Runtime approximate builtins ──
// These are the HEXA-level implementations that the M974 AST rewrite
// redirects to. Defined here so the test is self-contained.

fn __approx_sqrt(s) {
    // Newton's method: x_{n+1} = (x_n + S/x_n) / 2
    if s <= 0.0 { return 0.0 }
    let mut guess = s / 2.0
    if guess == 0.0 { guess = 1.0 }
    let mut iter = 0
    while iter < 20 {
        let next = (guess + s / guess) / 2.0
        let mut diff = next - guess
        if diff < 0.0 { diff = 0.0 - diff }
        guess = next
        if diff < 1e-10 { iter = 20 }
        iter = iter + 1
    }
    return guess
}

fn __approx_exp(x) {
    // Taylor series: e^x = 1 + x + x^2/2! + x^3/3! + ...
    let mut result = 1.0
    let mut term = 1.0
    let mut n = 1
    while n <= 20 {
        term = term * x / to_float(n)
        result = result + term
        let mut abs_term = term
        if abs_term < 0.0 { abs_term = 0.0 - abs_term }
        if abs_term < 1e-15 { n = 21 }
        n = n + 1
    }
    return result
}

fn __approx_sin(x) {
    // Taylor series: sin(x) = x - x^3/3! + x^5/5! - ...
    let mut result = 0.0
    let mut term = x
    let mut n = 1
    let mut sign = 1.0
    while n <= 21 {
        result = result + sign * term
        term = term * x * x / to_float(2 * n) / to_float(2 * n + 1)
        sign = 0.0 - sign
        n = n + 1
    }
    return result
}

fn __approx_cos(x) {
    // Taylor series: cos(x) = 1 - x^2/2! + x^4/4! - ...
    let mut result = 0.0
    let mut term = 1.0
    let mut n = 0
    let mut sign = 1.0
    while n <= 20 {
        result = result + sign * term
        term = term * x * x / to_float(2 * n + 1) / to_float(2 * n + 2)
        sign = 0.0 - sign
        n = n + 1
    }
    return result
}

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_approx(name, actual, expected, tolerance) {
    let diff = actual - expected
    if diff < 0.0 { diff = 0.0 - diff }
    if diff < tolerance {
        println("[PASS] " + name + " (diff=" + to_string(diff) + ")")
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " expected: " + to_string(expected) + ", got: " + to_string(actual) + " (diff=" + to_string(diff) + ")")
        fail_count = fail_count + 1
    }
}

println("===============================================================")
println("  HEXA @approximate Tests -- Newton/Taylor Approximation")
println("===============================================================")
println("")

// ================================================================
//  SECTION 1: __approx_sqrt -- Newton's method
// ================================================================

println("--- Section 1: __approx_sqrt (Newton's method) ---")

// Basic sqrt values
check_approx("sqrt(4.0)", __approx_sqrt(4.0), 2.0, 0.0001)
check_approx("sqrt(9.0)", __approx_sqrt(9.0), 3.0, 0.0001)
check_approx("sqrt(16.0)", __approx_sqrt(16.0), 4.0, 0.0001)
check_approx("sqrt(25.0)", __approx_sqrt(25.0), 5.0, 0.0001)
check_approx("sqrt(2.0)", __approx_sqrt(2.0), 1.41421356, 0.0001)
check_approx("sqrt(1.0)", __approx_sqrt(1.0), 1.0, 0.0001)
check_approx("sqrt(0.5)", __approx_sqrt(0.5), 0.70710678, 0.0001)
check_approx("sqrt(100.0)", __approx_sqrt(100.0), 10.0, 0.0001)

// Edge case: zero
check("sqrt(0.0)", __approx_sqrt(0.0), 0.0)

// Compare with builtin sqrt for accuracy
let mut sq_ok = true
let mut si = 1
while si <= 20 {
    let x = to_float(si)
    let approx = __approx_sqrt(x)
    let exact = sqrt(x)
    let diff = approx - exact
    if diff < 0.0 { diff = 0.0 - diff }
    if diff > 0.001 { sq_ok = false }
    si = si + 1
}
check("sqrt accuracy 1..20", sq_ok, true)

println("")

// ================================================================
//  SECTION 2: __approx_exp -- Taylor series
// ================================================================

println("--- Section 2: __approx_exp (Taylor series) ---")

check_approx("exp(0.0)", __approx_exp(0.0), 1.0, 0.0001)
check_approx("exp(1.0)", __approx_exp(1.0), 2.71828182, 0.001)
check_approx("exp(-1.0)", __approx_exp(-1.0), 0.36787944, 0.001)
check_approx("exp(2.0)", __approx_exp(2.0), 7.38905609, 0.01)
check_approx("exp(0.5)", __approx_exp(0.5), 1.64872127, 0.001)

println("")

// ================================================================
//  SECTION 3: __approx_sin -- Taylor series
// ================================================================

println("--- Section 3: __approx_sin (Taylor series) ---")

check_approx("sin(0.0)", __approx_sin(0.0), 0.0, 0.0001)
check_approx("sin(1.0)", __approx_sin(1.0), 0.84147098, 0.001)
check_approx("sin(-1.0)", __approx_sin(-1.0), -0.84147098, 0.001)
check_approx("sin(0.5)", __approx_sin(0.5), 0.47942553, 0.001)

// sin(pi) ~ 0
check_approx("sin(pi)", __approx_sin(3.14159265), 0.0, 0.001)

println("")

// ================================================================
//  SECTION 4: __approx_cos -- Taylor series
// ================================================================

println("--- Section 4: __approx_cos (Taylor series) ---")

check_approx("cos(0.0)", __approx_cos(0.0), 1.0, 0.0001)
check_approx("cos(1.0)", __approx_cos(1.0), 0.54030230, 0.001)
check_approx("cos(-1.0)", __approx_cos(-1.0), 0.54030230, 0.001)

// cos(pi) ~ -1
check_approx("cos(pi)", __approx_cos(3.14159265), -1.0, 0.001)

// sin^2 + cos^2 = 1 identity
let mut identity_ok = true
let mut ii = 0
while ii < 10 {
    let x = to_float(ii) * 0.5
    let s = __approx_sin(x)
    let c = __approx_cos(x)
    let sum = s * s + c * c
    let d = sum - 1.0
    if d < 0.0 { d = 0.0 - d }
    if d > 0.01 { identity_ok = false }
    ii = ii + 1
}
check("sin^2+cos^2=1 identity (0..5)", identity_ok, true)

println("")

// ================================================================
//  SECTION 5: precision parameter extraction
// ================================================================

println("--- Section 5: @approximate usage in annotated fn ---")

// An @approximate annotated function that uses sqrt
@approximate fn fast_distance(x, y) {
    return sqrt(x * x + y * y)
}

// The function should still produce correct results
// (M974 rewrites sqrt -> __approx_sqrt at compile time)
let d1 = fast_distance(3.0, 4.0)
check_approx("fast_distance(3,4)", d1, 5.0, 0.01)

let d2 = fast_distance(0.0, 0.0)
check_approx("fast_distance(0,0)", d2, 0.0, 0.01)

let d3 = fast_distance(1.0, 0.0)
check_approx("fast_distance(1,0)", d3, 1.0, 0.01)

// @approximate with exp
@approximate fn fast_sigmoid(x) {
    return 1.0 / (1.0 + exp(0.0 - x))
}

let s1 = fast_sigmoid(0.0)
check_approx("fast_sigmoid(0)", s1, 0.5, 0.01)

// For large positive x, sigmoid -> 1
let s2 = fast_sigmoid(5.0)
check_approx("fast_sigmoid(5) ~1", s2, 0.99330, 0.01)

// For large negative x, sigmoid -> 0
let s3 = fast_sigmoid(-5.0)
check_approx("fast_sigmoid(-5) ~0", s3, 0.00669, 0.01)

println("")

// ================================================================
//  SUMMARY
// ================================================================

println("===============================================================")
println("  @approximate total: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("===============================================================")

if fail_count > 0 {
    println("SOME TESTS FAILED")
}
