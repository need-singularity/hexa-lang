// ===================================================================
//  test_gradient_accumulation.hexa — Gradient Accumulation Tests
//
//  Validates:
//    1. create_accumulator initialization
//    2. accumulate adds gradients
//    3. should_step returns false before N steps
//    4. should_step returns true at N steps
//    5. get_accumulated returns averaged gradients
//    6. reset zeroes the buffer
//    7. effective_batch_size calculation
//    8. Multi-round accumulation
//    9. Gradient sync timing
//   10. Step counter tracking
//
//  Execution: ./hexa self/test_gradient_accumulation.hexa
//  Minimum 8 check() statements.
// ===================================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

// ===================================================================
//  Inline module (self-contained test)
// ===================================================================

struct GradAccumulator {
    accumulation_steps: int,
    current_step: int,
    accumulated_grads: array,
    total_steps_done: int,
    num_optimizer_steps: int,
    is_initialized: bool
}

fn create_accumulator(steps) {
    if steps < 1 {
        return GradAccumulator {
            accumulation_steps: 1,
            current_step: 0,
            accumulated_grads: [],
            total_steps_done: 0,
            num_optimizer_steps: 0,
            is_initialized: false
        }
    }
    return GradAccumulator {
        accumulation_steps: steps,
        current_step: 0,
        accumulated_grads: [],
        total_steps_done: 0,
        num_optimizer_steps: 0,
        is_initialized: false
    }
}

fn accumulate(acc, grad) {
    let n = len(grad)
    if !acc.is_initialized {
        let mut init_grads = []
        let mut i = 0
        while i < n {
            init_grads = init_grads + [grad[i]]
            i = i + 1
        }
        return GradAccumulator {
            accumulation_steps: acc.accumulation_steps,
            current_step: 1,
            accumulated_grads: init_grads,
            total_steps_done: acc.total_steps_done + 1,
            num_optimizer_steps: acc.num_optimizer_steps,
            is_initialized: true
        }
    }
    let an = len(acc.accumulated_grads)
    let mut new_grads = []
    let mut i = 0
    while i < an {
        let gi = i % n
        new_grads = new_grads + [acc.accumulated_grads[i] + grad[gi]]
        i = i + 1
    }
    return GradAccumulator {
        accumulation_steps: acc.accumulation_steps,
        current_step: acc.current_step + 1,
        accumulated_grads: new_grads,
        total_steps_done: acc.total_steps_done + 1,
        num_optimizer_steps: acc.num_optimizer_steps,
        is_initialized: true
    }
}

fn should_step(acc) {
    return acc.current_step >= acc.accumulation_steps
}

fn get_accumulated(acc) {
    let n = len(acc.accumulated_grads)
    let divisor = to_float(acc.accumulation_steps)
    let mut out = []
    let mut i = 0
    while i < n {
        out = out + [acc.accumulated_grads[i] / divisor]
        i = i + 1
    }
    return out
}

fn reset(acc) {
    let n = len(acc.accumulated_grads)
    let mut zeros = []
    let mut i = 0
    while i < n {
        zeros = zeros + [0.0]
        i = i + 1
    }
    return GradAccumulator {
        accumulation_steps: acc.accumulation_steps,
        current_step: 0,
        accumulated_grads: zeros,
        total_steps_done: acc.total_steps_done,
        num_optimizer_steps: acc.num_optimizer_steps + 1,
        is_initialized: true
    }
}

fn effective_batch_size(micro_batch, accumulation_steps) {
    return micro_batch * accumulation_steps
}

fn should_sync(acc) {
    return should_step(acc)
}

// ===================================================================
//  TESTS
// ===================================================================

println("===================================================")
println("  Gradient Accumulation Test Suite")
println("===================================================")

// -- 1. create_accumulator --
println("")
println("=== Creation ===")
let acc0 = create_accumulator(4)
check("create: accumulation_steps set", acc0.accumulation_steps == 4)
check("create: current_step is 0", acc0.current_step == 0)
check("create: not initialized", acc0.is_initialized == false)

// -- 2. accumulate adds gradients --
println("")
println("=== Accumulation ===")
let g1 = [1.0, 2.0, 3.0]
let acc1 = accumulate(acc0, g1)
check("accumulate: step incremented to 1", acc1.current_step == 1)
check("accumulate: is_initialized", acc1.is_initialized == true)
check("accumulate: grads stored", fabs(acc1.accumulated_grads[0] - 1.0) < 0.001)

// Accumulate second gradient
let g2 = [0.5, 1.0, 1.5]
let acc2 = accumulate(acc1, g2)
check("accumulate: step incremented to 2", acc2.current_step == 2)
check("accumulate: grads summed", fabs(acc2.accumulated_grads[0] - 1.5) < 0.001)
check("accumulate: grads[1] summed", fabs(acc2.accumulated_grads[1] - 3.0) < 0.001)

// -- 3. should_step: false before N --
println("")
println("=== Step Check ===")
check("should_step: false at step 2 of 4", should_step(acc2) == false)

// -- 4. should_step: true at N --
let g3 = [0.2, 0.3, 0.4]
let acc3 = accumulate(acc2, g3)
let g4 = [0.3, 0.7, 0.1]
let acc4 = accumulate(acc3, g4)
check("should_step: true at step 4 of 4", should_step(acc4) == true)

// -- 5. get_accumulated: averaged --
println("")
println("=== Get Accumulated ===")
let avg = get_accumulated(acc4)
// Sum: 1.0+0.5+0.2+0.3 = 2.0, avg = 2.0/4 = 0.5
check("get_accumulated: avg[0] = sum/4", fabs(avg[0] - 0.5) < 0.001)
// Sum: 2.0+1.0+0.3+0.7 = 4.0, avg = 4.0/4 = 1.0
check("get_accumulated: avg[1] = sum/4", fabs(avg[1] - 1.0) < 0.001)

// -- 6. reset zeroes buffer --
println("")
println("=== Reset ===")
let acc5 = reset(acc4)
check("reset: current_step is 0", acc5.current_step == 0)
check("reset: grads zeroed", fabs(acc5.accumulated_grads[0]) < 0.001)
check("reset: optimizer_steps incremented", acc5.num_optimizer_steps == 1)

// -- 7. effective_batch_size --
println("")
println("=== Effective Batch Size ===")
let ebs = effective_batch_size(8, 4)
check("effective_batch_size: 8*4=32", ebs == 32)

let ebs2 = effective_batch_size(16, 8)
check("effective_batch_size: 16*8=128", ebs2 == 128)

// -- 8. Multi-round accumulation --
println("")
println("=== Multi-Round ===")
let mut ma = create_accumulator(2)
// Round 1
let mg1 = [1.0, 1.0]
ma = accumulate(ma, mg1)
ma = accumulate(ma, mg1)
check("round1: should_step true", should_step(ma) == true)
let mr1 = get_accumulated(ma)
check("round1: averaged correctly", fabs(mr1[0] - 1.0) < 0.001)

ma = reset(ma)
check("round1: reset done", ma.current_step == 0)

// Round 2
let mg2 = [2.0, 3.0]
ma = accumulate(ma, mg2)
ma = accumulate(ma, mg2)
let mr2 = get_accumulated(ma)
check("round2: averaged correctly", fabs(mr2[0] - 2.0) < 0.001)

// -- 9. Gradient sync timing --
println("")
println("=== Sync Timing ===")
let sa = create_accumulator(3)
let sa1 = accumulate(sa, [1.0])
check("sync: no sync at step 1", should_sync(sa1) == false)
let sa2 = accumulate(sa1, [1.0])
check("sync: no sync at step 2", should_sync(sa2) == false)
let sa3 = accumulate(sa2, [1.0])
check("sync: sync at step 3", should_sync(sa3) == true)

// -- 10. Step counter tracking --
println("")
println("=== Counter Tracking ===")
check("total_steps: tracks all micro-batches", acc4.total_steps_done == 4)
let acc_r = reset(acc4)
let acc_new = accumulate(acc_r, [1.0, 2.0, 3.0])
check("total_steps: preserved across reset", acc_new.total_steps_done == 5)

// ===================================================================
//  Summary
// ===================================================================
println("")
println("=== Gradient Accumulation Tests Summary ===")
println("pass=" + str(pass_count) + " fail=" + str(fail_count))
if fail_count == 0 {
    println("ALL PASS")
} else {
    println("FAILED")
}
println(str(pass_count) + " passed")
