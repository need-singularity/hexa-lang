// ═══════════════════════════════════════════════════════════════════
//  test_math_pure.hexa — Tests for self/runtime/math_pure.hexa
//  Covers: abs_pure, null_coal_pure, sign_pure, min_pure, max_pure,
//          clamp_pure, neg_pure
// ═══════════════════════════════════════════════════════════════════

use "runtime/math_pure"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  Pure-Hexa Math Operations Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. abs_pure ─────────────────────────────────────────────

println("--- abs_pure ---")

check("abs int positive", abs_pure(5), 5)
check("abs int negative", abs_pure(-5), 5)
check("abs int zero", abs_pure(0), 0)
check("abs int large", abs_pure(-1000000), 1000000)
check("abs int one", abs_pure(-1), 1)
check("abs float positive", abs_pure(3.14), 3.14)
check("abs float negative", abs_pure(-3.14), 3.14)
check("abs float zero", abs_pure(0.0), 0.0)
check("abs float small", abs_pure(-0.001), 0.001)
check("abs string passthrough", abs_pure("hello"), "hello")
check("abs void passthrough", abs_pure(nil), nil)

// ── 2. null_coal_pure ───────────────────────────────────────

println("")
println("--- null_coal_pure ---")

check("null_coal void → b", null_coal_pure(nil, "fallback"), "fallback")
check("null_coal void → int", null_coal_pure(nil, 42), 42)
check("null_coal empty str → b", null_coal_pure("", "default"), "default")
check("null_coal string keeps a", null_coal_pure("hello", "default"), "hello")
check("null_coal int keeps a", null_coal_pure(7, 99), 7)
check("null_coal zero keeps a", null_coal_pure(0, 99), 0)
check("null_coal false keeps a", null_coal_pure(false, true), false)
check("null_coal float keeps a", null_coal_pure(3.14, 0.0), 3.14)
check("null_coal void → void", null_coal_pure(nil, nil), nil)
check("null_coal empty → empty", null_coal_pure("", ""), "")

// ── 3. sign_pure ────────────────────────────────────────────

println("")
println("--- sign_pure ---")

check("sign int positive", sign_pure(5), 1)
check("sign int negative", sign_pure(-5), -1)
check("sign int zero", sign_pure(0), 0)
check("sign int one", sign_pure(1), 1)
check("sign int neg one", sign_pure(-1), -1)
check("sign float positive", sign_pure(3.14), 1.0)
check("sign float negative", sign_pure(-3.14), -1.0)
check("sign float zero", sign_pure(0.0), 0.0)
check("sign string → 0", sign_pure("x"), 0)
check("sign void → 0", sign_pure(nil), 0)

// ── 4. min_pure ─────────────────────────────────────────────

println("")
println("--- min_pure ---")

check("min int a<b", min_pure(3, 5), 3)
check("min int a>b", min_pure(5, 3), 3)
check("min int equal", min_pure(4, 4), 4)
check("min int negatives", min_pure(-5, -3), -5)
check("min int mixed signs", min_pure(-1, 1), -1)
check("min float a<b", min_pure(1.5, 2.5), 1.5)
check("min float a>b", min_pure(2.5, 1.5), 1.5)
check("min float zeros", min_pure(0.0, 0.0), 0.0)
check("min int zero", min_pure(0, 5), 0)
check("min string passthrough", min_pure("x", 5), "x")
check("min rhs string passthrough", min_pure(5, "x"), 5)

// ── 5. max_pure ─────────────────────────────────────────────

println("")
println("--- max_pure ---")

check("max int a<b", max_pure(3, 5), 5)
check("max int a>b", max_pure(5, 3), 5)
check("max int equal", max_pure(4, 4), 4)
check("max int negatives", max_pure(-5, -3), -3)
check("max int mixed signs", max_pure(-1, 1), 1)
check("max float a<b", max_pure(1.5, 2.5), 2.5)
check("max float a>b", max_pure(2.5, 1.5), 2.5)
check("max float zeros", max_pure(0.0, 0.0), 0.0)
check("max int zero", max_pure(0, 5), 5)
check("max string passthrough", max_pure("x", 5), "x")
check("max rhs string passthrough", max_pure(5, "x"), 5)

// ── 6. clamp_pure ───────────────────────────────────────────

println("")
println("--- clamp_pure ---")

check("clamp inside range", clamp_pure(5, 0, 10), 5)
check("clamp below lo", clamp_pure(-3, 0, 10), 0)
check("clamp above hi", clamp_pure(15, 0, 10), 10)
check("clamp at lo", clamp_pure(0, 0, 10), 0)
check("clamp at hi", clamp_pure(10, 0, 10), 10)
check("clamp negative range", clamp_pure(-5, -10, -1), -5)
check("clamp below neg range", clamp_pure(-20, -10, -1), -10)
check("clamp above neg range", clamp_pure(5, -10, -1), -1)
check("clamp float inside", clamp_pure(1.5, 0.0, 2.0), 1.5)
check("clamp float below", clamp_pure(-0.5, 0.0, 2.0), 0.0)
check("clamp float above", clamp_pure(3.0, 0.0, 2.0), 2.0)
check("clamp inverted range", clamp_pure(5, 10, 0), 10)

// ── 7. neg_pure ─────────────────────────────────────────────

println("")
println("--- neg_pure ---")

check("neg int positive", neg_pure(5), -5)
check("neg int negative", neg_pure(-5), 5)
check("neg int zero", neg_pure(0), 0)
check("neg int one", neg_pure(1), -1)
check("neg float positive", neg_pure(3.14), -3.14)
check("neg float negative", neg_pure(-3.14), 3.14)
check("neg float zero", neg_pure(0.0), 0.0)
check("neg string passthrough", neg_pure("hi"), "hi")
check("neg void passthrough", neg_pure(nil), nil)
check("neg double neg", neg_pure(neg_pure(7)), 7)

// ── Summary ─────────────────────────────────────────────────

println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    println("FAIL")
    exit(1)
}
println("ALL PASS")
