// ═══════════════════════════════════════════════════════════════════
//  test_mcts.hexa — Monte Carlo Tree Search Reasoning Tests
//
//  Exercises self/ml/mcts.hexa (ML #71).
//
//  Coverage (≥ 12 checks):
//     T01 mcts_new_tree: root is node 0
//     T02 mcts_new_tree: untried actions copied
//     T03 mcts_ucb1: unvisited child gets infinite priority
//     T04 mcts_ucb1: visited child Q = value/visits
//     T05 mcts_ln: monotonic and matches known anchor
//     T06 mcts_expand: child count grows
//     T07 mcts_expand: parent untried shrinks by one
//     T08 mcts_rollout: reward is a sensible float
//     T09 mcts_backprop: visits propagate to root
//     T10 mcts_iter: single iter keeps tree consistent
//     T11 mcts_run: chain world — best action = right (1)
//     T12 mcts_best_child: returns a real child id
//     T13 ttt_winner: row / col / diag detection
//     T14 ttt_step: player swaps 1 <-> 2
//     T15 mcts_run: tic-tac-toe — O blocks immediate loss
//
//  Run: ./hexa self/test_mcts.hexa
// ═══════════════════════════════════════════════════════════════════

import "ml/mcts.hexa"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn tfabs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

println("=====================================================")
println("  MCTS Reasoning Test Suite (ML #71)")
println("=====================================================")

// ─── T01 mcts_new_tree: root is node 0 ────────────────────────────
mcts_set_seed(42)
mcts_set_env("chain")
mcts_new_tree(chain_start(), chain_legal(chain_start()), 1)
let root1 = mcts_get(0)
check("T01 new_tree root id == 0", root1["id"] == 0 && root1["parent"] == -1)

// ─── T02 new_tree: untried populated ──────────────────────────────
check("T02 new_tree untried == legal actions", len(root1["untried"]) == 2)

// ─── T03 ucb1: unvisited child = infinite priority ────────────────
let fake_unvis = mcts_new_node(1, 0, 0, 0, 1, [], false)
let prio_unvis = mcts_ucb1(fake_unvis, 10.0, 1.41)
check("T03 ucb1 unvisited child >> 0", prio_unvis > 1000.0)

// ─── T04 ucb1: Q = value/visits basic check ───────────────────────
let mut fake_vis = mcts_new_node(2, 0, 0, 0, 1, [], false)
fake_vis["visits"] = 4.0
fake_vis["value"] = 2.0
let prio_vis = mcts_ucb1(fake_vis, 16.0, 0.0)  // c=0 isolates Q
check("T04 ucb1 Q term == value/visits", tfabs(prio_vis - 0.5) < 0.000001)

// ─── T05 ln: anchor + monotonic ───────────────────────────────────
let ln4 = mcts_ln(4.0)
let ln8 = mcts_ln(8.0)
let t05a = tfabs(ln4 - 1.3862943611) < 0.02
let t05b = ln8 > ln4
check("T05 ln monotonic + accurate", t05a && t05b)

// ─── T06 expand grows children ────────────────────────────────────
mcts_set_seed(7)
mcts_set_env("chain")
mcts_new_tree(chain_start(), chain_legal(chain_start()), 1)
let before_children = len(mcts_get(0)["children"])
mcts_expand(0)
let after_children = len(mcts_get(0)["children"])
check("T06 expand grows child list", after_children == before_children + 1)

// ─── T07 expand drains untried ────────────────────────────────────
let after_untried = len(mcts_get(0)["untried"])
check("T07 expand drains untried by 1", after_untried == 1)

// ─── T08 rollout: chain world returns a finite reward ────────────
mcts_set_seed(17)
mcts_set_env("chain")
mcts_new_tree(chain_start(), chain_legal(chain_start()), 1)
let reward_any = mcts_rollout(0, 32)
let r_ok = reward_any >= 0.0 && reward_any <= 1.0
check("T08 rollout reward in [0,1]", r_ok)

// ─── T09 backprop: visits propagate to root ───────────────────────
mcts_set_seed(23)
mcts_set_env("chain")
mcts_new_tree(chain_start(), chain_legal(chain_start()), 1)
let child_id9 = mcts_expand(0)
mcts_backprop(child_id9, 1.0)
let root_visits = mcts_get(0)["visits"]
let child_visits = mcts_get(child_id9)["visits"]
let t9_ok = tfabs(root_visits - 1.0) < 0.000001 && tfabs(child_visits - 1.0) < 0.000001
check("T09 backprop root/child visits", t9_ok)

// ─── T10 one full iter keeps tree valid ───────────────────────────
mcts_set_seed(31)
mcts_set_env("chain")
mcts_new_tree(chain_start(), chain_legal(chain_start()), 1)
mcts_iter(32, 1.41)
let t10 = mcts_node_count() >= 2 && mcts_get(0)["visits"] >= 1.0
check("T10 mcts_iter grows tree + backs up", t10)

// ─── T11 mcts_run: chain world — best action = right (1) ──────────
mcts_set_seed(2026)
mcts_set_env("chain")
mcts_new_tree(chain_start(), chain_legal(chain_start()), 1)
mcts_run(400, 32, 1.41)
let best_a = mcts_best_action(0)
check("T11 chain best_action == right (1)", best_a == 1)

// ─── T12 mcts_best_child returns a real child ────────────────────
let best_id = mcts_best_child(0)
let root6 = mcts_get(0)
let mut found = false
let mut i12 = 0
while i12 < len(root6["children"]) {
    if root6["children"][i12] == best_id { found = true }
    i12 = i12 + 1
}
check("T12 best_child is in root.children", best_id >= 0 && found)

// ─── T13 ttt_winner: row / col / diag ─────────────────────────────
let win_row = [1, 1, 1, 0, 0, 0, 0, 0, 0]
let win_col = [2, 0, 0, 2, 0, 0, 2, 0, 0]
let win_dia = [1, 0, 0, 0, 1, 0, 0, 0, 1]
let no_win  = [1, 2, 1, 2, 1, 2, 2, 1, 2]
let t13 = ttt_winner(win_row) == 1 && ttt_winner(win_col) == 2 && ttt_winner(win_dia) == 1 && ttt_winner(no_win) == 0
check("T13 ttt_winner row/col/diag", t13)

// ─── T14 ttt_step swaps player ────────────────────────────────────
let empty_board = ttt_start()
let after1 = ttt_step(empty_board, 4, 1)
let t14_board_ok = after1[0][4] == 1
let t14_player_ok = after1[1] == 2
check("T14 ttt_step swaps player + places mark", t14_board_ok && t14_player_ok)

// ─── T15 tic-tac-toe blocking: O must block X's immediate win ─────
// Board:
//   X X .      positions: 0 1 2
//   . O .                 3 4 5
//   . . .                 6 7 8
// Player to move = O (2). Correct move is position 2 (block row 0).
let block_board = [1, 1, 0, 0, 2, 0, 0, 0, 0]
mcts_set_seed(2027)
mcts_set_env("ttt")
mcts_new_tree(block_board, ttt_legal(block_board), 2)
mcts_run(600, 16, 1.41)
let block_action = mcts_best_action(0)
check("T15 tic-tac-toe block: O plays 2", block_action == 2)

// ─── summary ──────────────────────────────────────────────────────
println("=====================================================")
println("  Pass: " + to_string(pass_count) + " / Fail: " + to_string(fail_count))
println("=====================================================")
if fail_count == 0 {
    println("  ALL TESTS PASSED")
} else {
    println("  SOME TESTS FAILED")
}
