//   same pattern as test_bitops_pure.hexa / test_char_pure.hexa.)
// ═══════════════════════════════════════════════════════════════════

// ── INLINED from self/runtime/cipher_mini_pure.hexa ──

@pure
fn _from_code(code) {
    if type_of(code) != "int" { return "" }
    if code < 0 { return "" }
    if code > 126 { return "" }
    if code >= 32 {
        let printable = " !\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_`abcdefghijklmnopqrstuvwxyz{|}~"
        let idx = code - 32
        return printable.substring(idx, idx + 1)
    }
    if code == 9 { return "\t" }
    if code == 10 { return "\n" }
    if code == 13 { return "\r" }
    ""
}

@pure
fn _shift_byte(c, n) {
    if c >= 65 {
        if c <= 90 {
            let k = ((n % 26) + 26) % 26
            return ((c - 65 + k) % 26) + 65
        }
    }
    if c >= 97 {
        if c <= 122 {
            let k = ((n % 26) + 26) % 26
            return ((c - 97 + k) % 26) + 97
        }
    }
    c
}

fn xor_cipher_pure(text, key) {
    if type_of(text) != "string" { return text }
    if type_of(key) != "string" { return text }
    let n = len(text)
    let k = len(key)
    if k == 0 { return text }
    let mut parts = []
    let mut i = 0
    while i < n {
        let tb = ord(text.substring(i, i + 1))
        let kb = ord(key.substring(i % k, (i % k) + 1))
        let xb = tb ^ kb
        parts = parts.push(_from_code(xb))
        i = i + 1
    }
    parts.join("")
}

fn caesar_shift_pure(text, n) {
    if type_of(text) != "string" { return text }
    if type_of(n) != "int" { return text }
    let sz = len(text)
    let mut parts = []
    let mut i = 0
    while i < sz {
        let b = ord(text.substring(i, i + 1))
        let sb = _shift_byte(b, n)
        parts = parts.push(_from_code(sb))
        i = i + 1
    }
    parts.join("")
}

fn rot13_pure(text) {
    caesar_shift_pure(text, 13)
}

fn atbash_pure(text) {
    if type_of(text) != "string" { return text }
    let sz = len(text)
    let mut parts = []
    let mut i = 0
    while i < sz {
        let b = ord(text.substring(i, i + 1))
        let mut out = b
        if b >= 65 {
            if b <= 90 {
                out = 155 - b
            }
        }
        if b >= 97 {
            if b <= 122 {
                out = 219 - b
            }
        }
        parts = parts.push(_from_code(out))
        i = i + 1
    }
    parts.join("")
}

fn vigenere_encode_pure(text, key) {
    if type_of(text) != "string" { return text }
    if type_of(key) != "string" { return text }
    let kn = len(key)
    if kn == 0 { return text }

    let mut key_shifts = []
    let mut ki = 0
    while ki < kn {
        let kb = ord(key.substring(ki, ki + 1))
        if kb >= 65 {
            if kb <= 90 {
                key_shifts = key_shifts.push(kb - 65)
            }
        }
        if kb >= 97 {
            if kb <= 122 {
                key_shifts = key_shifts.push(kb - 97)
            }
        }
        ki = ki + 1
    }
    let ks = len(key_shifts)
    if ks == 0 { return text }

    let sz = len(text)
    let mut parts = []
    let mut i = 0
    let mut kcur = 0
    while i < sz {
        let b = ord(text.substring(i, i + 1))
        let is_upper = (b >= 65 && b <= 90)
        let is_lower = (b >= 97 && b <= 122)
        if is_upper || is_lower {
            let shift = key_shifts[kcur % ks]
            let sb = _shift_byte(b, shift)
            parts = parts.push(_from_code(sb))
            kcur = kcur + 1
        } else {
            parts = parts.push(_from_code(b))
        }
        i = i + 1
    }
    parts.join("")
}

// ── END inlined ────────────────────────────────────────────────────

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  Pure-Hexa Cipher Mini Tests (toy/educational only)")
println("═══════════════════════════════════════════════════════")
println("")

// ── rot13_pure ─────────────────────────────────────────────────────
println("--- rot13_pure ---")
check("rot13 Hello",         rot13_pure("Hello"),         "Uryyb")
check("rot13 Uryyb back",    rot13_pure("Uryyb"),         "Hello")
check("rot13 HEXA",          rot13_pure("HEXA"),          "URKN")
check("rot13 abc",           rot13_pure("abc"),           "nop")
check("rot13 nop",           rot13_pure("nop"),           "abc")
check("rot13 roundtrip test",rot13_pure(rot13_pure("test")),       "test")
check("rot13 punct/digits",  rot13_pure("Hi, 123!"),      "Uv, 123!")
check("rot13 empty",         rot13_pure(""),              "")

// ── caesar_shift_pure ─────────────────────────────────────────────
println("")
println("--- caesar_shift_pure ---")
check("caesar abc +3",       caesar_shift_pure("abc", 3),         "def")
check("caesar xyz +3 wrap",  caesar_shift_pure("xyz", 3),         "abc")
check("caesar XYZ +3 wrap",  caesar_shift_pure("XYZ", 3),         "ABC")
check("caesar abc -3 wrap",  caesar_shift_pure("abc", -3),        "xyz")
check("caesar n=0 identity", caesar_shift_pure("Hello, World!", 0), "Hello, World!")
check("caesar n=26 identity",caesar_shift_pure("Hello", 26),      "Hello")
check("caesar n=52 identity",caesar_shift_pure("Hello", 52),      "Hello")
check("caesar +13 == rot13", caesar_shift_pure("Hello", 13),      "Uryyb")

// ── atbash_pure ───────────────────────────────────────────────────
println("")
println("--- atbash_pure ---")
check("atbash a",            atbash_pure("a"),            "z")
check("atbash z",            atbash_pure("z"),            "a")
check("atbash b",            atbash_pure("b"),            "y")
check("atbash A",            atbash_pure("A"),            "Z")
check("atbash Z",            atbash_pure("Z"),            "A")
check("atbash Hello",        atbash_pure("Hello"),        "Svool")
check("atbash roundtrip",    atbash_pure(atbash_pure("AtBash 123!")), "AtBash 123!")

// ── xor_cipher_pure ───────────────────────────────────────────────
// Inputs crafted so XOR stays in printable-ASCII range [32..126]
// (H=72 ^ SP=32 = h=104; i=105 ^ SP=32 = I=73; A=65 ^ !=33 = `=96).
println("")
println("--- xor_cipher_pure ---")
check("xor Hi ^ SP",         xor_cipher_pure("Hi", "  "),         "hI")
check("xor hI ^ SP back",    xor_cipher_pure("hI", "  "),         "Hi")
check("xor A ^ !",           xor_cipher_pure("A", "!"),           "`")
check("xor roundtrip Hi",    xor_cipher_pure(xor_cipher_pure("Hi", "  "), "  "), "Hi")
check("xor empty key noop",  xor_cipher_pure("abc", ""),          "abc")
check("xor empty text",      xor_cipher_pure("", "key"),          "")
check("xor same==same -> 0s",xor_cipher_pure("A", "A"),           "")

// ── vigenere_encode_pure ──────────────────────────────────────────
// Classical textbook pair: ATTACKATDAWN / LEMON -> LXFOPVEFRNHR.
println("")
println("--- vigenere_encode_pure ---")
check("vigenere ATTACKATDAWN/LEMON", vigenere_encode_pure("ATTACKATDAWN", "LEMON"), "LXFOPVEFRNHR")
check("vigenere key==AAA noop",      vigenere_encode_pure("HELLO", "AAA"),          "HELLO")
check("vigenere lowercase preserve", vigenere_encode_pure("hello", "abc"),          "hfnlp")
check("vigenere punct skipped",      vigenere_encode_pure("Hi, World!", "KEY"),     "Rm, Uyvjn!")
check("vigenere empty key noop",     vigenere_encode_pure("HELLO", ""),             "HELLO")
check("vigenere empty text",         vigenere_encode_pure("", "KEY"),               "")

println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    println("FAIL")
    exit(1)
}
println("ALL PASS")
