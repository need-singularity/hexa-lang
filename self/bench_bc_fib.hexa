// self/bench_bc_fib.hexa — rt#36-D canonical benchmark #1
//
// fib(30) recursive — dominated by function call dispatch and
// integer arithmetic. Compares tree-walk interpreter (hexa run)
// against bytecode VM (hexa run --vm) after rt#36-E #1 landed
// the AST→bytecode bridge.
//
// Target: --vm ≥ 2× faster than tree-walk on this workload.
//
// VM-compat requirements (HX3 pitfall notes):
//   - `fn main()` entry (T49 auto-call landed).
//   - `print(int)` NOT `println(str(int))` — `str()` builtin
//     currently emits "CALL: cannot resolve target proto" in
//     bc_vm which then spins (rt#36-E #3 gap).
//   - Single line of output. No decorative header/footer.
//   - fib(30) = 832040 — fixed expected value for diff.
//
// Run:
//   hexa run self/bench_bc_fib.hexa           # tree-walk
//   hexa run self/bench_bc_fib.hexa --vm      # bytecode VM
//
// Both must print exactly `832040` on stdout.

fn fib(n) {
    if n < 2 { return n }
    return fib(n - 1) + fib(n - 2)
}

fn main() {
    print(fib(30))
}
