// test_filter_early_exit.hexa — ROI #136 rewrite semantic equivalence
//
// Verifies that the short-circuit find-first loop produced by
// ai_native_pass.hexa's apply_filter_first_pass is semantically
// equivalent to the .filter(p).first() / .any(p) / .filter(p).len > 0
// source forms for representative inputs.
//
// The rewrite itself is an AST-level transformation inside the
// ai-native pass; we can't easily invoke the pass standalone from
// a test file. Instead we assert behavioral equivalence: we hand-code
// both the pre-rewrite (materializing) form and the post-rewrite
// (find-first) form and check they agree on the same input.
//
// Run: ./hexa self/test_filter_early_exit.hexa
//
// HX12 strict-compliant — no L1/L2/L3/L4 violations.

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

// Predicate used across all three patterns.
// Threshold chosen as 10 (allowed numeric literal outside compare context).
fn is_big(x) {
    let threshold = 10
    return x > threshold
}

// ── Pre-rewrite form A: arr.filter(p).first()
// Materializes the full filtered array then peeks index 0.
fn filter_first_materialized(arr) {
    let mut filtered = []
    let mut i = 0
    let n = len(arr)
    while i < n {
        let e = arr[i]
        if is_big(e) {
            filtered = filtered.push(e)
        }
        i = i + 1
    }
    if len(filtered) > 0 {
        return filtered[0]
    }
    return -1
}

// ── Post-rewrite form A: find-first loop with early exit
fn filter_first_rewritten(arr) {
    let mut found = -1
    let mut done = false
    let mut i = 0
    let n = len(arr)
    while i < n && !done {
        let e = arr[i]
        if is_big(e) {
            found = e
            done = true
        }
        i = i + 1
    }
    return found
}

// ── Pre-rewrite form B: arr.any(p)
fn any_materialized(arr) {
    let mut filtered = []
    let mut i = 0
    let n = len(arr)
    while i < n {
        let e = arr[i]
        if is_big(e) {
            filtered = filtered.push(e)
        }
        i = i + 1
    }
    return len(filtered) > 0
}

// ── Post-rewrite form B: find-first, bool result
fn any_rewritten(arr) {
    let mut found = false
    let mut done = false
    let mut i = 0
    let n = len(arr)
    while i < n && !done {
        let e = arr[i]
        if is_big(e) {
            found = true
            done = true
        }
        i = i + 1
    }
    return found
}

// ── Pre-rewrite form C: arr.filter(p).len > 0
fn filter_len_gt_zero_materialized(arr) {
    let mut filtered = []
    let mut i = 0
    let n = len(arr)
    while i < n {
        let e = arr[i]
        if is_big(e) {
            filtered = filtered.push(e)
        }
        i = i + 1
    }
    return len(filtered) > 0
}

// ── Post-rewrite form C: identical shape to any_rewritten
fn filter_len_gt_zero_rewritten(arr) {
    let mut found = false
    let mut done = false
    let mut i = 0
    let n = len(arr)
    while i < n && !done {
        let e = arr[i]
        if is_big(e) {
            found = true
            done = true
        }
        i = i + 1
    }
    return found
}

// ── Test inputs cover: empty, no-match, single-match, multi-match
let empty_arr = []
let no_match = [1, 2, 3, 4, 5]
let one_match = [1, 2, 99, 4, 5]
let multi_match = [50, 60, 70]

// ══════════════════════════════════════════════════════════════
//  T1 — filter(p).first() equivalence (3 inputs)
// ══════════════════════════════════════════════════════════════
let t1a = filter_first_materialized(empty_arr) == filter_first_rewritten(empty_arr)
let t1b = filter_first_materialized(no_match) == filter_first_rewritten(no_match)
let t1c = filter_first_materialized(one_match) == filter_first_rewritten(one_match)
let t1d = filter_first_materialized(multi_match) == filter_first_rewritten(multi_match)
// multi_match must yield FIRST matching elem (50), not any match
let first_expected = 50
let t1e = filter_first_rewritten(multi_match) == first_expected
check("T1 filter(p).first() equivalence + first-wins", t1a && t1b && t1c && t1d && t1e)

// ══════════════════════════════════════════════════════════════
//  T2 — any(p) equivalence (3 inputs)
// ══════════════════════════════════════════════════════════════
let t2a = any_materialized(empty_arr) == any_rewritten(empty_arr)
let t2b = any_materialized(no_match) == any_rewritten(no_match)
let t2c = any_materialized(one_match) == any_rewritten(one_match)
let t2d = any_materialized(multi_match) == any_rewritten(multi_match)
let t2e = any_rewritten(empty_arr) == false
let t2f = any_rewritten(one_match) == true
check("T2 any(p) equivalence + boolean correctness", t2a && t2b && t2c && t2d && t2e && t2f)

// ══════════════════════════════════════════════════════════════
//  T3 — filter(p).len > 0 equivalence (3 inputs)
// ══════════════════════════════════════════════════════════════
let t3a = filter_len_gt_zero_materialized(empty_arr) == filter_len_gt_zero_rewritten(empty_arr)
let t3b = filter_len_gt_zero_materialized(no_match) == filter_len_gt_zero_rewritten(no_match)
let t3c = filter_len_gt_zero_materialized(one_match) == filter_len_gt_zero_rewritten(one_match)
let t3d = filter_len_gt_zero_materialized(multi_match) == filter_len_gt_zero_rewritten(multi_match)
let t3e = filter_len_gt_zero_rewritten(no_match) == false
let t3f = filter_len_gt_zero_rewritten(one_match) == true
check("T3 filter(p).len > 0 equivalence + boolean correctness", t3a && t3b && t3c && t3d && t3e && t3f)

println("")
println("=== test_filter_early_exit summary ===")
println("PASS: " + to_string(pass_count))
println("FAIL: " + to_string(fail_count))
println("TOTAL: " + to_string(pass_count + fail_count))
