// self/work_stealing.hexa — HEXA work-stealing scheduler ported from src/work_stealing.rs
// Implements an M:N threading model where M green threads are multiplexed
// onto N OS threads. Each worker thread has a local deque; when it runs
// out of work it steals from other workers' deques.

// ── Work item ──────────────────────────────────────────────────

struct WorkItem {
    id: int,
    body: [string],
    bindings: [Binding],
    captured_env: [Binding],
    name: string
}

struct Binding {
    name: string,
    value: string
}

// ── Per-worker deque ───────────────────────────────────────────
// A thread-safe double-ended queue for work items.
// The owning worker pushes/pops from the back (LIFO for locality).
// Stealers take from the front (FIFO for fairness).

struct WorkerDeque {
    items: [WorkItem]
}

fn worker_deque_new() -> WorkerDeque {
    return WorkerDeque { items: [] }
}

fn worker_deque_push(self: WorkerDeque, item: WorkItem) {
    self.items.push(item)
}

fn worker_deque_pop(self: WorkerDeque) -> WorkItem {
    // Pop from back (LIFO)
    if self.items.length() == 0 {
        return WorkItem { id: -1, body: [], bindings: [], captured_env: [], name: "" }
    }
    return self.items.pop()
}

fn worker_deque_steal(self: WorkerDeque) -> WorkItem {
    // Steal from front (FIFO)
    if self.items.length() == 0 {
        return WorkItem { id: -1, body: [], bindings: [], captured_env: [], name: "" }
    }
    let first = self.items[0]
    let mut new_items = []
    let i = 1
    while i < self.items.length() {
        new_items.push(self.items[i])
        i = i + 1
    }
    self.items = new_items
    return first
}

fn worker_deque_len(self: WorkerDeque) -> int {
    return self.items.length()
}

fn worker_deque_is_empty(self: WorkerDeque) -> bool {
    return self.items.length() == 0
}

// ── Work-stealing scheduler ────────────────────────────────────

struct WorkStealingScheduler {
    deques: [WorkerDeque],
    num_workers: int,
    next_id: int,
    shutdown: bool,
    started: bool,
    tasks_completed: int,
    steals_performed: int
}

fn work_stealing_scheduler_new(n: int) -> WorkStealingScheduler {
    let num = n
    if num < 1 { num = 1 }
    let mut deques = []
    let i = 0
    while i < num {
        deques.push(worker_deque_new())
        i = i + 1
    }
    return WorkStealingScheduler {
        deques: deques,
        num_workers: num,
        next_id: 1,
        shutdown: false,
        started: false,
        tasks_completed: 0,
        steals_performed: 0
    }
}

fn scheduler_next_task_id(self: WorkStealingScheduler) -> int {
    let id = self.next_id
    self.next_id = self.next_id + 1
    return id
}

fn scheduler_submit(self: WorkStealingScheduler, item: WorkItem) {
    // Find the worker with the fewest items
    let min_idx = 0
    let min_len = 999999999
    let i = 0
    while i < self.deques.length() {
        let len = worker_deque_len(self.deques[i])
        if len < min_len {
            min_len = len
            min_idx = i
        }
        i = i + 1
    }
    worker_deque_push(self.deques[min_idx], item)
}

fn scheduler_start(self: WorkStealingScheduler) {
    if self.started { return }
    self.started = true
    // In full impl, spawn OS worker threads
}

fn scheduler_shutdown(self: WorkStealingScheduler) {
    self.shutdown = true
    // In full impl, join worker threads
}

// ── Scheduler stats ────────────────────────────────────────────

struct SchedulerStats {
    num_workers: int,
    tasks_completed: int,
    steals_performed: int,
    queue_sizes: [int]
}

fn scheduler_stats(self: WorkStealingScheduler) -> SchedulerStats {
    let mut sizes = []
    for deque in self.deques {
        sizes.push(worker_deque_len(deque))
    }
    return SchedulerStats {
        num_workers: self.num_workers,
        tasks_completed: self.tasks_completed,
        steals_performed: self.steals_performed,
        queue_sizes: sizes
    }
}

// ── Worker loop (single-threaded simulation) ───────────────────

fn worker_loop_step(scheduler: WorkStealingScheduler, worker_idx: int) -> bool {
    if scheduler.shutdown { return false }

    // Try to pop from own deque
    let item = worker_deque_pop(scheduler.deques[worker_idx])
    if item.id != -1 {
        // Execute work item (in full impl, run interpreter)
        scheduler.tasks_completed = scheduler.tasks_completed + 1
        return true
    }

    // Try to steal from other workers
    let i = 0
    while i < scheduler.deques.length() {
        if i != worker_idx {
            let stolen = worker_deque_steal(scheduler.deques[i])
            if stolen.id != -1 {
                scheduler.steals_performed = scheduler.steals_performed + 1
                scheduler.tasks_completed = scheduler.tasks_completed + 1
                return true
            }
        }
        i = i + 1
    }

    return false
}
