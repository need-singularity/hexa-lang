// ═══════════════════════════════════════════════════════════════════════
//  self/stdlib/stdin.hexa — pure-hexa stdin line reader
//
//  PURPOSE
//      Unblock JSONL stream consumers (fake-pi-rpc.mjs, MCP servers,
//      JSON-RPC dispatchers) that need line-by-line stdin parsing
//      from hexa land. Until now `exec()` only spawned children with
//      no parent-stdin read path, and `input()` conflated EOF with
//      empty-line. This module wraps existing runtime primitives
//      (`read_stdin()` slurp + `input()` per-line) and exposes:
//
//          read_lines()          → array<string>   slurp all → split
//          for_each_line(cb)     → ()              streaming via input()
//          read_line()           → string|()       one line, () on EOF
//
//      newline handling: \n delimiter, trailing \r stripped (CRLF safe).
//      trailing newline (POSIX text-file convention) → no phantom empty
//      line. backpressure: read_lines slurps whole stream so caller must
//      use for_each_line for unbounded streams.
//
//      hive blocker: state/blockers/goal_hexa_native_stdin_line_reader.hexa
//      cross-repo: hexa-lang sibling repo per memory project_cross_repo_*
//
//  USAGE
//      use "self/stdlib/stdin"
//      let lines = read_lines()
//      let i = 0
//      while i < len(lines) { println(lines[i]); i = i + 1 }
//
//      # streaming (large stdin):
//      use "self/stdlib/stdin"
//      for_each_line(fn(line) { println("got: " + line) })
//
//      # single line + EOF detect (returns void on EOF):
//      use "self/stdlib/stdin"
//      let line = read_line()
//      if line == () { println("EOF") } else { println("line=" + line) }
//
//  CAVEAT (read_line / for_each_line)
//      runtime `input()` returns "" on both EOF and empty-line; we cannot
//      distinguish without a runtime patch. As a best-effort heuristic
//      this module treats empty-line as continuation when the previous
//      line was non-empty, and as EOF only after two consecutive empties.
//      For strict-EOF semantics use read_lines() (slurp mode is exact).
// ═══════════════════════════════════════════════════════════════════════

// Strip a single trailing \r (CRLF on \n-split → leftover \r on the line).
fn _strip_cr(s) {
    let n = len(s)
    if n == 0 { return s }
    if s.ends_with("\r") { return s.substring(0, n - 1) }
    return s
}

// read_lines() — slurp entire stdin to EOF, return as array of lines.
// CRLF and LF both supported. Trailing newline is consumed (no empty
// final element). Memory: O(size_of_stdin) — non-streaming.
pub fn read_lines() {
    let blob = read_stdin()
    if len(blob) == 0 { return [] }
    // Drop trailing \n (or \r\n) so split doesn't yield phantom "" line.
    let n = len(blob)
    let trimmed = if blob.ends_with("\n") { blob.substring(0, n - 1) } else { blob }
    let m = len(trimmed)
    let trimmed2 = if m > 0 {
        if trimmed.ends_with("\r") { trimmed.substring(0, m - 1) } else { trimmed }
    } else { trimmed }
    if len(trimmed2) == 0 { return [""] }
    let raw = trimmed2.split("\n")
    let mut out = []
    let mut i = 0
    while i < len(raw) {
        out.push(_strip_cr(raw[i]))
        i = i + 1
    }
    return out
}

// for_each_line(cb) — streaming alt: invoke cb per line via input().
// Uses heuristic-EOF (two consecutive empty lines OR slurp-detected
// empty input). Suitable for line-delimited JSONL streams where empty
// payload lines are not expected.
pub fn for_each_line(cb) {
    let mut prev_empty = false
    while true {
        let line = input("")
        if line == "" {
            if prev_empty { return () }
            prev_empty = true
            // emit empty line conservatively (caller may treat as data)
            cb(line)
        } else {
            prev_empty = false
            cb(_strip_cr(line))
        }
    }
}

// read_line() — read one line; returns () (void) on EOF, else string.
// Uses input() — empty-line cannot be distinguished from EOF in single
// call mode. Caller wanting exact semantics should use read_lines().
pub fn read_line() {
    let line = input("")
    if line == "" { return () }
    return _strip_cr(line)
}

// ───────────────────────────────────────────────────────────
// Selftest. Activated only when invoked with --selftest-stdin
// (or --selftest while THIS file is the entry script). Imports
// from other modules must NOT consume stdin — gate is mandatory.
// Run:
//   echo -e "alpha\nbeta\ngamma" | hexa run self/stdlib/stdin.hexa --selftest-stdin
// ───────────────────────────────────────────────────────────
fn _selftest_stdin() -> i64 {
    println("[stdin selftest] start")
    let lines = read_lines()
    println("[stdin selftest] count=" + to_string(len(lines)))
    let mut i = 0
    while i < len(lines) {
        println("[stdin selftest] line[" + to_string(i) + "]=" + lines[i])
        i = i + 1
    }
    if len(lines) != 3 { eprintln("FAIL count"); return 1 }
    if lines[0] != "alpha" { eprintln("FAIL [0]"); return 1 }
    if lines[1] != "beta"  { eprintln("FAIL [1]"); return 1 }
    if lines[2] != "gamma" { eprintln("FAIL [2]"); return 1 }
    println("stdin selftest: 4/4 PASS")
    return 0
}

let _stdin_args = args()
let mut _stdin_selftest_flag = false
let mut _stdin_i = 0
while _stdin_i < len(_stdin_args) {
    if _stdin_args[_stdin_i] == "--selftest-stdin" { _stdin_selftest_flag = true }
    if _stdin_args[_stdin_i] == "--selftest" {
        let mut _stdin_j = 0
        while _stdin_j < len(_stdin_args) {
            if _stdin_args[_stdin_j].ends_with("/stdlib/stdin.hexa") { _stdin_selftest_flag = true }
            _stdin_j = _stdin_j + 1
        }
    }
    _stdin_i = _stdin_i + 1
}
if _stdin_selftest_flag {
    exit(_selftest_stdin())
}
