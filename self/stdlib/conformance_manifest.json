{
  "schema": "hexa-lang/self/stdlib/conformance_manifest/1",
  "purpose": "Catalog of stdlib + runtime-builtin symbols guaranteed to exist across hexa runtime modes. Closes upstream gap #6 (docs/hexa_url_complete_support_upstream_spec_2026_05_05.ai.md section 2.5).",
  "last_updated": "2026-05-05",
  "runtime_modes": {
    "interp": {
      "description": "Default `hexa run X.hexa` — AST evaluation by hexa.real (interpreter mode).",
      "binary": "/Users/ghost/.hx/packages/hexa/hexa -> hexa.real (Mach-O arm64 on darwin)",
      "detection": "default; resolver route=local or route=darwin-bypass; argv contains a .hexa file path"
    },
    "aot": {
      "description": "AOT-compiled binary produced by `hexa build` — runs without the interpreter loop.",
      "binary": "user-built ELF/Mach-O via codegen_c / codegen_native",
      "detection": "argv[0] is a non-.hexa native binary; HEXA_AOT=1 or absence of interpreter banner"
    },
    "darwin-bypass": {
      "description": "Resolver short-circuits to bare hexa.real on macOS (~/.hx/.darwin-bypass-eligible marker present, or @resolver-bypass annotation, or metadata-only argv).",
      "binary": "/Users/ghost/core/hexa-lang/hexa.real (Mach-O arm64)",
      "detection": "stderr contains `hexa-resolver: route=darwin-bypass`"
    },
    "docker-routed": {
      "description": "Resolver routes execution through a Linux container (mac_safe_landing).",
      "binary": "hexa-runner:latest container internal binary (Linux ELF)",
      "detection": "stderr contains `hexa-resolver: route=docker`"
    }
  },
  "categories": {
    "core": "Type conversion, length, type introspection — required by every hexa program.",
    "io": "Stdout/stderr emit + process termination.",
    "json": "JSON parse + stringify primitives the resolver itself depends on.",
    "env": "Environment variable + working-directory access.",
    "fs": "File-system read primitives (read-only — write APIs are stdlib wrappers).",
    "exec": "External-process execution.",
    "math": "Numeric helpers (abs/min/max).",
    "string_methods": "Method calls on string values (substring/split/replace/trim).",
    "array_methods": "Method calls on array values (push/keys for maps).",
    "stdlib_json": "self/stdlib/json.hexa exports — wrappers over runtime json_parse/json_stringify.",
    "stdlib_string": "self/stdlib/string.hexa exports — pure-hexa string utilities.",
    "stdlib_array": "self/stdlib/array.hexa exports — pure-hexa array utilities.",
    "stdlib_map": "self/stdlib/map.hexa exports — pure-hexa map utilities."
  },
  "symbols": [
    {"name": "to_string",       "kind": "builtin",  "category": "core",           "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "to_string(7) == \"7\""},
    {"name": "to_int",          "kind": "builtin",  "category": "core",           "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "to_int(\"8\") == 8"},
    {"name": "to_float",        "kind": "builtin",  "category": "core",           "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "to_float(\"1.5\") == 1.5"},
    {"name": "type_of",         "kind": "builtin",  "category": "core",           "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "type_of(1) == \"int\""},
    {"name": "len",             "kind": "builtin",  "category": "core",           "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "len(\"abc\") == 3"},

    {"name": "println",         "kind": "builtin",  "category": "io",             "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "side-effect; observed via stdout"},
    {"name": "eprintln",        "kind": "builtin",  "category": "io",             "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "side-effect; observed via stderr"},
    {"name": "print",           "kind": "builtin",  "category": "io",             "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "side-effect; no newline"},
    {"name": "exit",            "kind": "builtin",  "category": "io",             "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "process termination; gap #5 caveats apply for void-fn AOT"},

    {"name": "json_parse",      "kind": "builtin",  "category": "json",           "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "len(json_parse(\"[1]\")) == 1"},
    {"name": "json_stringify",  "kind": "builtin",  "category": "json",           "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "json_stringify([1]) == \"[1]\""},

    {"name": "env_get",         "kind": "builtin",  "category": "env",            "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "len(env_get(\"PATH\")) > 0"},

    {"name": "read_file",       "kind": "builtin",  "category": "fs",             "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "len(read_file(<readable path>)) > 0"},
    {"name": "file_exists",     "kind": "builtin",  "category": "fs",             "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "type_of(file_exists(\"/x\")) == \"bool\"; semantic stability tracked separately"},

    {"name": "exec",            "kind": "builtin",  "category": "exec",           "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "exec(\"printf x\") == \"x\""},

    {"name": "abs",             "kind": "builtin",  "category": "math",           "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "abs(-1) == 1"},
    {"name": "min",             "kind": "builtin",  "category": "math",           "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "min(1,2) == 1"},
    {"name": "max",             "kind": "builtin",  "category": "math",           "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "max(1,2) == 2"},

    {"name": "string.substring",   "kind": "method",  "category": "string_methods", "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "\"Hello\".substring(0,3) == \"Hel\"; gap #2 (slice/substring drift) tracked separately"},
    {"name": "string.split",       "kind": "method",  "category": "string_methods", "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "len(\"a b\".split(\" \")) == 2"},
    {"name": "string.replace",     "kind": "method",  "category": "string_methods", "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "\"abc\".replace(\"b\",\"X\") == \"aXc\""},
    {"name": "string.trim",        "kind": "method",  "category": "string_methods", "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "\"  x  \".trim() == \"x\""},

    {"name": "array.push",         "kind": "method",  "category": "array_methods",  "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "arr.push(v) appends in place"},
    {"name": "map.keys",           "kind": "method",  "category": "array_methods",  "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "len(json_parse(\"{\\\"a\\\":1}\").keys()) == 1"},
    {"name": "map.values",         "kind": "method",  "category": "array_methods",  "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "json_parse(\"{\\\"a\\\":1}\").values()[0] == 1"},

    {"name": "json_parse_safe",         "kind": "stdlib_fn", "category": "stdlib_json",  "module": "self/stdlib/json", "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "json_parse_safe(\"[1]\")[0] == true",
     "drift_note": "Per gap #6 the symbol is reported MISSING in the AOT bypass path used by hive-resource shim. Reproduces only when the consumer's resolver does not resolve `use \"self/stdlib/json\"`. Conformance test verifies presence on the route this test runs in."},
    {"name": "json_parse_or_throw",     "kind": "stdlib_fn", "category": "stdlib_json",  "module": "self/stdlib/json", "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "json_parse_or_throw(\"[1]\")[0] == 1"},
    {"name": "json_stringify_pretty",   "kind": "stdlib_fn", "category": "stdlib_json",  "module": "self/stdlib/json", "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "json_stringify_pretty([1]) == \"[1]\""},
    {"name": "json_stringify_value",    "kind": "stdlib_fn", "category": "stdlib_json",  "module": "self/stdlib/json", "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "json_stringify_value([1]) == \"[1]\""},
    {"name": "json_dump_pretty",        "kind": "stdlib_fn", "category": "stdlib_json",  "module": "self/stdlib/json", "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "len(json_dump_pretty([1,2], 2)) > 0"},
    {"name": "json_object_set",         "kind": "stdlib_fn", "category": "stdlib_json",  "module": "self/stdlib/json", "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "len(json_object_set(json_parse(\"{}\"), \"k\", 1).keys()) == 1"},
    {"name": "json_array_push",         "kind": "stdlib_fn", "category": "stdlib_json",  "module": "self/stdlib/json", "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "len(json_array_push([], 1)) == 1"},

    {"name": "str_trim",                "kind": "stdlib_fn", "category": "stdlib_string", "module": "stdlib/string",      "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "str_trim(\"  x  \") == \"x\""},
    {"name": "str_starts_with",         "kind": "stdlib_fn", "category": "stdlib_string", "module": "stdlib/string",      "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "str_starts_with(\"abc\", \"ab\") == true"},
    {"name": "str_ends_with",           "kind": "stdlib_fn", "category": "stdlib_string", "module": "stdlib/string",      "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "str_ends_with(\"abc\", \"bc\") == true"},
    {"name": "str_contains",            "kind": "stdlib_fn", "category": "stdlib_string", "module": "stdlib/string",      "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "str_contains(\"abc\", \"b\") == true"},
    {"name": "str_index_of",            "kind": "stdlib_fn", "category": "stdlib_string", "module": "stdlib/string",      "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "str_index_of(\"abc\", \"b\") == 1"},
    {"name": "str_to_upper",            "kind": "stdlib_fn", "category": "stdlib_string", "module": "stdlib/string",      "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "str_to_upper(\"abc\") == \"ABC\""},
    {"name": "str_to_lower",            "kind": "stdlib_fn", "category": "stdlib_string", "module": "stdlib/string",      "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "str_to_lower(\"ABC\") == \"abc\""},
    {"name": "str_repeat",              "kind": "stdlib_fn", "category": "stdlib_string", "module": "stdlib/string",      "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "str_repeat(\"a\", 3) == \"aaa\""},

    {"name": "array_reverse",           "kind": "stdlib_fn", "category": "stdlib_array",  "module": "stdlib/array",       "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "array_reverse([1,2,3])[0] == 3"},
    {"name": "array_contains",          "kind": "stdlib_fn", "category": "stdlib_array",  "module": "stdlib/array",       "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "array_contains([1,2,3], 2) == true"},
    {"name": "array_index_of",          "kind": "stdlib_fn", "category": "stdlib_array",  "module": "stdlib/array",       "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "array_index_of([1,2,3], 2) == 1"},
    {"name": "array_sum",               "kind": "stdlib_fn", "category": "stdlib_array",  "module": "stdlib/array",       "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "array_sum([1,2,3]) == 6"},
    {"name": "array_max",               "kind": "stdlib_fn", "category": "stdlib_array",  "module": "stdlib/array",       "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "array_max([1,3,2]) == 3"},
    {"name": "array_min",               "kind": "stdlib_fn", "category": "stdlib_array",  "module": "stdlib/array",       "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "array_min([3,1,2]) == 1"},

    {"name": "map_size",                "kind": "stdlib_fn", "category": "stdlib_map",    "module": "stdlib/map",         "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "map_size(json_parse(\"{\\\"a\\\":1}\")) == 1"},
    {"name": "map_contains_key",        "kind": "stdlib_fn", "category": "stdlib_map",    "module": "stdlib/map",         "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "map_contains_key(json_parse(\"{\\\"a\\\":1}\"), \"a\") == true"},
    {"name": "map_get_or",              "kind": "stdlib_fn", "category": "stdlib_map",    "module": "stdlib/map",         "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "map_get_or(json_parse(\"{}\"), \"k\", 9) == 9"},
    {"name": "map_keys",                "kind": "stdlib_fn", "category": "stdlib_map",    "module": "stdlib/map",         "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "len(map_keys(json_parse(\"{\\\"a\\\":1}\"))) == 1"},
    {"name": "map_values",              "kind": "stdlib_fn", "category": "stdlib_map",    "module": "stdlib/map",         "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "len(map_values(json_parse(\"{\\\"a\\\":1}\"))) == 1"},
    {"name": "map_is_empty",            "kind": "stdlib_fn", "category": "stdlib_map",    "module": "stdlib/map",         "runtime_modes": ["interp", "aot", "darwin-bypass", "docker-routed"], "probe": "map_is_empty(json_parse(\"{}\")) == true"}
  ],
  "divergences_observed": [
    {
      "symbol": "json_parse_safe",
      "missing_in": ["aot via hive-resource darwin-bypass shim (per Agent B 2026-05-04 report)"],
      "present_in": ["interp via ~/.hx/bin/hexa local route", "docker-routed"],
      "remediation": "Conformance assertion fails loud with sentinel `__STDLIB_PARITY__ FAIL missing=json_parse_safe`. Permanent fix tracked under upstream gap #6 (resolver-order parity)."
    },
    {
      "symbol": "string.slice",
      "intentionally_omitted_from_manifest": true,
      "rationale": "Per gap #2, slice/substring semantics drift across runtimes. Manifest locks `substring` only; `slice` use is discouraged until aliased."
    },
    {
      "symbol": "file_exists",
      "stability_caveat": "Returns false for paths that exist via `read_file` — Mach-O bypass build appears to gate on a stat() variant that disagrees with read(2). Listed in manifest because the symbol is callable in every mode, but its truth value is NOT asserted — only its callability and bool return type."
    },
    {
      "symbol": "exit",
      "stability_caveat": "Per gap #5, exit() from void-returning fn does not propagate to shell $? in AOT runtime. Manifest lists symbol as present; actual exit-code propagation is a separate conformance not asserted here."
    },
    {
      "symbol": "current_time_ms / now_ms",
      "intentionally_omitted_from_manifest": true,
      "rationale": "Probed and confirmed UNDEFINED in this runtime. Not promised across modes."
    }
  ]
}
