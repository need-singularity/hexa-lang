// ═══════════════════════════════════════════════════════════════════════
//  self/stdlib/term_screen.hexa — alt screen / clear / scroll region
//
//  PURPOSE
//      Screen-level operations on top of term_ansi: enter/leave
//      alternate screen buffer (preserves shell history on TUI exit),
//      clear regions, define scroll region (DECSTBM), scroll within
//      region. hive packages/tui/src/tui.ts uses these for the
//      full-screen mode toggle and panel-scroll subsystem.
//
//  EXPORTS
//      screen_alt_enter()                 -> string  // ESC [?1049h
//      screen_alt_leave()                 -> string  // ESC [?1049l
//      screen_clear()                     -> string  // 2J + home
//      screen_clear_to_end()              -> string  // J
//      screen_clear_to_start()            -> string  // 1J
//      screen_set_scroll_region(top, bot) -> string  // CSI top;bot r
//      screen_reset_scroll_region()       -> string  // CSI r
//      screen_scroll_up(n)                -> string  // CSI <n> S
//      screen_scroll_down(n)              -> string  // CSI <n> T
//      screen_save_state()                -> string  // pre-TUI prelude
//      screen_restore_state()             -> string  // post-TUI postlude
//
//  CAVEATS
//      * screen_save_state bundles: alt_enter + cursor_save + clear.
//        screen_restore_state bundles: cursor_restore + alt_leave.
//        Both are designed to be idempotent against each other when
//        emitted in matched pairs.
//      * Scroll region is 1-based, inclusive on both ends.
//        top must be >= 1, bot must be > top, else returns "" (noop).
//
//  USAGE
//      use "self/stdlib/term_screen"
//      print(screen_save_state())     // entering TUI
//      // ... draw ...
//      print(screen_restore_state())  // exiting TUI
//
//  --selftest:
//      hexa run self/stdlib/term_screen.hexa --selftest
//        → __TERM_SCREEN_SELFTEST__ <PASS|FAIL> n=<N> fail=<M>
// ═══════════════════════════════════════════════════════════════════════

use "self/stdlib/term_ansi"

pub fn screen_alt_enter() -> string { return ansi_alt_screen_on() }
pub fn screen_alt_leave() -> string { return ansi_alt_screen_off() }

pub fn screen_clear() -> string {
    return ansi_clear_screen() + ansi_move_to(1, 1)
}

pub fn screen_clear_to_end() -> string { return ansi_clear_to_eos() }
pub fn screen_clear_to_start() -> string { return ansi_clear_to_bos() }

pub fn screen_set_scroll_region(top: i64, bot: i64) -> string {
    if top < 1 { return "" }
    if bot <= top { return "" }
    return ansi_csi() + to_string(top) + ";" + to_string(bot) + "r"
}

pub fn screen_reset_scroll_region() -> string {
    return ansi_csi() + "r"
}

pub fn screen_scroll_up(n: i64) -> string {
    if n <= 0 { return "" }
    return ansi_csi() + to_string(n) + "S"
}

pub fn screen_scroll_down(n: i64) -> string {
    if n <= 0 { return "" }
    return ansi_csi() + to_string(n) + "T"
}

pub fn screen_save_state() -> string {
    return ansi_alt_screen_on() + ansi_save_cursor() + ansi_clear_screen() + ansi_move_to(1, 1)
}

pub fn screen_restore_state() -> string {
    return ansi_restore_cursor() + ansi_alt_screen_off()
}

// ── --selftest ─────────────────────────────────────────────────────
fn _tscreen_selftest() {
    let mut fail = 0
    let mut n = 0
    let esc = ansi_esc()

    n = n + 1
    if screen_alt_enter() != esc + "[?1049h" { eprintln("FAIL 1"); fail = fail + 1 }
    n = n + 1
    if screen_alt_leave() != esc + "[?1049l" { eprintln("FAIL 2"); fail = fail + 1 }

    n = n + 1
    if screen_clear() != esc + "[2J" + esc + "[1;1H" { eprintln("FAIL 3 got=" + screen_clear()); fail = fail + 1 }

    n = n + 1
    if screen_clear_to_end() != esc + "[J" { eprintln("FAIL 4"); fail = fail + 1 }
    n = n + 1
    if screen_clear_to_start() != esc + "[1J" { eprintln("FAIL 5"); fail = fail + 1 }

    n = n + 1
    if screen_set_scroll_region(2, 24) != esc + "[2;24r" { eprintln("FAIL 6"); fail = fail + 1 }

    n = n + 1
    if screen_set_scroll_region(0, 5) != "" { eprintln("FAIL 7 (top<1)"); fail = fail + 1 }
    n = n + 1
    if screen_set_scroll_region(5, 5) != "" { eprintln("FAIL 8 (bot<=top)"); fail = fail + 1 }

    n = n + 1
    if screen_reset_scroll_region() != esc + "[r" { eprintln("FAIL 9"); fail = fail + 1 }

    n = n + 1
    if screen_scroll_up(3) != esc + "[3S" { eprintln("FAIL 10"); fail = fail + 1 }
    n = n + 1
    if screen_scroll_down(0) != "" { eprintln("FAIL 11"); fail = fail + 1 }

    n = n + 1
    let save = screen_save_state()
    let want = esc + "[?1049h" + esc + "7" + esc + "[2J" + esc + "[1;1H"
    if save != want { eprintln("FAIL 12 got=" + save); fail = fail + 1 }

    n = n + 1
    let rest = screen_restore_state()
    let want2 = esc + "8" + esc + "[?1049l"
    if rest != want2 { eprintln("FAIL 13 got=" + rest); fail = fail + 1 }

    if fail == 0 {
        println("__TERM_SCREEN_SELFTEST__ PASS n=" + to_string(n) + " fail=0")
    } else {
        println("__TERM_SCREEN_SELFTEST__ FAIL n=" + to_string(n) + " fail=" + to_string(fail))
    }
}

let _tscr_argv = args()
let mut _tscr_st = false
let mut _tscr_ai = 0
while _tscr_ai < len(_tscr_argv) {
    if _tscr_argv[_tscr_ai] == "--selftest-term-screen" { _tscr_st = true }
    if _tscr_argv[_tscr_ai] == "--selftest" {
        let mut _tscr_aj = 0
        while _tscr_aj < len(_tscr_argv) {
            if _tscr_argv[_tscr_aj].ends_with("/stdlib/term_screen.hexa") { _tscr_st = true }
            _tscr_aj = _tscr_aj + 1
        }
    }
    _tscr_ai = _tscr_ai + 1
}
if _tscr_st {
    _tscreen_selftest()
}
