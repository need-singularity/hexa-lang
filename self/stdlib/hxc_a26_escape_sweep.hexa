#!hexa strict

// @resolver-bypass(reason="A26 F-A26-6 Howard escape sweep harness — measures e_d ∈ {0.3, 0.5, 0.7} bits/byte on small text fixture")
// @tool(slug="hxc-a26-escape-sweep", desc="A26 F-A26-6 falsifier resolver: sweep Howard escape e_d across {0.3, 0.5, 0.7} on a small text fixture and report the minimum-bits choice. raw 91 honest C3 — runs ONLY on small fixtures (≤1KB) due to F-A26-4 memory budget trip; sweep validates the e_d=0.5 minimality claim within the feasible scale.")
// @usage(hexa hxc_a26_escape_sweep.hexa --selftest)
// @usage(hexa hxc_a26_escape_sweep.hexa <text_file>)
// @exit_codes(0=ok, 1=fail, 2=io-error, 3=bad-args)

const A26_MAX_ORDER = 5
const A26_ALPHABET = 256
const A26_RAW_BITS_PER_BYTE = 8
const A26_PROB_SCALE = 10000
const A26_CTX_LIMIT = 65536

fn _byte_at(s: string, i: int) -> string {
    if i < 0 || i >= len(s) { return "" }
    return s.substring(i, i + 1)
}

fn _ctx_at(s: string, p: int, k: int) -> string {
    if p - k < 0 { return "" }
    return s.substring(p - k, p)
}

fn _table_inc(tbl, ctx: string, sym: string) -> int {
    let inner = if map_contains_key(tbl, ctx) { tbl[ctx] } else { {} }
    let cur = if map_contains_key(inner, sym) { inner[sym] } else { 0 }
    inner[sym] = cur + 1
    tbl[ctx] = inner
    return 0
}

fn _table_total(tbl, ctx: string) -> int {
    if !map_contains_key(tbl, ctx) { return 0 }
    let inner = tbl[ctx]
    let mut t = 0
    let keys = map_keys(inner)
    let mut i = 0
    while i < len(keys) { t = t + inner[keys[i]]; i = i + 1 }
    return t
}

fn _table_distinct(tbl, ctx: string) -> int {
    if !map_contains_key(tbl, ctx) { return 0 }
    return len(map_keys(tbl[ctx]))
}

fn _table_count(tbl, ctx: string, sym: string) -> int {
    if !map_contains_key(tbl, ctx) { return 0 }
    let inner = tbl[ctx]
    if !map_contains_key(inner, sym) { return 0 }
    return inner[sym]
}

// Parametrized escape count: e_num/e_den encodes the Howard escape coefficient.
// e_d=0.3 → e_num=3, e_den=10  (distinct * 3 / 10)
// e_d=0.5 → e_num=1, e_den=2   (distinct / 2)
// e_d=0.7 → e_num=7, e_den=10  (distinct * 7 / 10)
fn _ppmd_escape_count_param(tbl, ctx: string, e_num: int, e_den: int) -> int {
    let d = _table_distinct(tbl, ctx)
    let e = (d * e_num) / e_den
    if e < 1 { return 1 }
    return e
}

fn _ctx_capacity_check(tbl) -> bool {
    return len(map_keys(tbl)) < A26_CTX_LIMIT
}

fn a26_build(buf: string) -> array {
    let order0 = {}
    let order1 = {}
    let order2 = {}
    let order3 = {}
    let order4 = {}
    let order5 = {}
    let n = len(buf)
    let mut p = 0
    while p < n {
        let sym = _byte_at(buf, p)
        let _r0 = _table_inc(order0, "", sym)
        if p >= 1 && _ctx_capacity_check(order1) { let c1 = _ctx_at(buf, p, 1); let _r1 = _table_inc(order1, c1, sym) }
        if p >= 2 && _ctx_capacity_check(order2) { let c2 = _ctx_at(buf, p, 2); let _r2 = _table_inc(order2, c2, sym) }
        if p >= 3 && _ctx_capacity_check(order3) { let c3 = _ctx_at(buf, p, 3); let _r3 = _table_inc(order3, c3, sym) }
        if p >= 4 && _ctx_capacity_check(order4) { let c4 = _ctx_at(buf, p, 4); let _r4 = _table_inc(order4, c4, sym) }
        if p >= 5 && _ctx_capacity_check(order5) { let c5 = _ctx_at(buf, p, 5); let _r5 = _table_inc(order5, c5, sym) }
        p = p + 1
    }
    return [order0, order1, order2, order3, order4, order5]
}

fn _ilog2_ceil(x: int) -> int {
    if x <= 1 { return 0 }
    let mut b = 0
    let mut v = x - 1
    while v > 0 { b = b + 1; v = v / 2 }
    return b
}

fn _bits_from_prob_x10000(prob_x10000: int) -> int {
    if prob_x10000 <= 0 { return A26_RAW_BITS_PER_BYTE }
    if prob_x10000 >= A26_PROB_SCALE { return 1 }
    let ratio = (A26_PROB_SCALE + prob_x10000 - 1) / prob_x10000
    let b = _ilog2_ceil(ratio + 1)
    if b < 1 { return 1 }
    return b
}

fn a26_lookup_param(tree: array, buf: string, p: int, e_num: int, e_den: int) -> array {
    let sym = _byte_at(buf, p)
    let mut order: i64 = A26_MAX_ORDER
    while order >= 0 {
        if p >= order {
            let ctx = _ctx_at(buf, p, order)
            let cnt = _table_count(tree[order], ctx, sym)
            if cnt > 0 {
                let tot = _table_total(tree[order], ctx)
                let esc = _ppmd_escape_count_param(tree[order], ctx, e_num, e_den)
                let denom = tot + esc
                let prob_x10000 = if denom > 0 { (cnt * A26_PROB_SCALE) / denom } else { 0 }
                return [order, prob_x10000, esc]
            }
        }
        order = order - 1
    }
    return [-1, A26_PROB_SCALE / A26_ALPHABET, 0]
}

fn a26_estimate_bits_param(tree: array, buf: string, e_num: int, e_den: int) -> int {
    let n = len(buf)
    let mut total_bits = 0
    let mut p = 0
    while p < n {
        if p < A26_MAX_ORDER {
            total_bits = total_bits + A26_RAW_BITS_PER_BYTE
        } else {
            let r = a26_lookup_param(tree, buf, p, e_num, e_den)
            let order = r[0]
            let prob = r[1]
            if order < 0 {
                total_bits = total_bits + A26_RAW_BITS_PER_BYTE
            } else {
                let bits_sym = _bits_from_prob_x10000(prob)
                let bits_esc = (A26_MAX_ORDER - order)
                total_bits = total_bits + bits_sym + bits_esc
            }
        }
        p = p + 1
    }
    return total_bits
}

fn _english_1kb() -> string {
    let phrase = "the quick brown fox jumps over the lazy dog "
    let mut buf = ""
    let mut k = 0
    while k < 24 { buf = buf + phrase; k = k + 1 }
    return buf
}

fn _sweep_one(name: string, buf: string) -> int {
    let tree = a26_build(buf)
    // Wide grid: e_d ∈ {0.25, 0.3, 0.5, 0.7, 0.75}
    let bits_025 = a26_estimate_bits_param(tree, buf, 25, 100)
    let bits_03 = a26_estimate_bits_param(tree, buf, 3, 10)
    let bits_05 = a26_estimate_bits_param(tree, buf, 1, 2)
    let bits_07 = a26_estimate_bits_param(tree, buf, 7, 10)
    let bits_075 = a26_estimate_bits_param(tree, buf, 75, 100)
    let n = len(buf)
    println("# F-A26-6 sweep on " + name + " (n=" + to_string(n) + ")")
    println("  e_d=0.25 -> bits=" + to_string(bits_025) + " (bpb_x10=" + to_string((bits_025 * 10) / n) + ")")
    println("  e_d=0.3  -> bits=" + to_string(bits_03)  + " (bpb_x10=" + to_string((bits_03  * 10) / n) + ")")
    println("  e_d=0.5  -> bits=" + to_string(bits_05)  + " (bpb_x10=" + to_string((bits_05  * 10) / n) + ")")
    println("  e_d=0.7  -> bits=" + to_string(bits_07)  + " (bpb_x10=" + to_string((bits_07  * 10) / n) + ")")
    println("  e_d=0.75 -> bits=" + to_string(bits_075) + " (bpb_x10=" + to_string((bits_075 * 10) / n) + ")")
    let mut min_bits = bits_025
    let mut min_name = "0.25"
    if bits_03  < min_bits { min_bits = bits_03;  min_name = "0.3"  }
    if bits_05  < min_bits { min_bits = bits_05;  min_name = "0.5"  }
    if bits_07  < min_bits { min_bits = bits_07;  min_name = "0.7"  }
    if bits_075 < min_bits { min_bits = bits_075; min_name = "0.75" }
    println("  MIN: e_d=" + min_name + " bits=" + to_string(min_bits))
    if min_name == "0.5" {
        println("  F-A26-6 NOT_TRIPPED: e_d=0.5 IS minimal")
        return 0
    } else {
        println("  F-A26-6 TRIPPED: e_d=" + min_name + " < e_d=0.5 -> Howard escape tuning retract -> recommend e_d=" + min_name)
        return 1
    }
}

fn _selftest() -> int {
    println("# hxc_a26_escape_sweep selftest")
    let mut fail = 0
    let buf = _english_1kb()
    let f1 = _sweep_one("english_1kb_repeating", buf)
    if f1 != 0 { fail = fail + 1 }
    println("Results: " + to_string(if fail == 0 { 1 } else { 0 }) + " PASS / " + to_string(fail) + " FAIL")
    if fail == 0 { return 0 }
    return 1
}

fn main() {
    let av = argv()
    let mut has_selftest = false
    let mut file_arg = ""
    let mut k = 1
    while k < len(av) {
        if av[k] == "--selftest" { has_selftest = true }
        else { file_arg = av[k] }
        k = k + 1
    }
    if has_selftest { exit(_selftest()) }
    if len(file_arg) > 0 {
        let txt = read_file(file_arg)
        let r = _sweep_one(file_arg, txt)
        exit(r)
    }
    eprintln("usage: hxc_a26_escape_sweep [--selftest | <file>]")
    exit(3)
}
