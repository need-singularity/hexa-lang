// self/stdlib/argv_skip.hexa — cross-runtime argv prefix skip
//
// PURPOSE
//   Hexa's args() builtin returns a runtime-shaped prefix that differs by
//   binary (R4 BUG#2-class root cause, 2026-04-27):
//     - Mac stage0          → [binary, binary, ...real_args]
//     - Linux hexa_real     → [binary, "run", script.hexa, ...real_args]
//   The legacy idiom `let mut _ai = 2` skipped the Mac shape only — on
//   Linux it leaked script.hexa into cli[0], producing path-leak bugs
//   (e.g. mkfifo /tmp/subagent-relay-/path/script.hexa-.fifo) and broken
//   CLI parsing across the hive tool surface.
//
// CONTRACT
//   skip_invocation_prefix(raw) returns the index of the FIRST real CLI arg.
//   For Mac stage0 args() shape returns 2.
//   For Linux hexa_real args() shape returns 3.
//   Idempotent: passing an already-skipped tail returns 0.
//
// USAGE
//   use "self/stdlib/argv_skip"
//   let _raw_args = args()
//   let mut cli = []
//   let mut _ai = skip_invocation_prefix(_raw_args)
//   while _ai < len(_raw_args) {
//       cli.push(_raw_args[_ai])
//       _ai = _ai + 1
//   }
//
// REFERENCES
//   /Users/ghost/core/nexus/.raw-audit  (BUG#2 incident 2026-04-27)
//   /Users/ghost/core/hive/tool/subagent_dispatch.hexa  (canonical inline fix, lines 507-538)

// _argv_basename — extract the last "/"-segment of a path string.
// Inline (no import of path.hexa) to avoid cyclic stdlib deps.
// Empty string yields "". Trailing "/" trimmed.
fn _argv_basename(p) {
    if len(p) == 0 { return "" }
    let segs = p.split("/")
    let mut k = len(segs) - 1
    // Skip empty trailing segments (e.g., "/a/b/")
    while k > 0 {
        if len(segs[k]) == 0 {
            k = k - 1
        } else {
            break
        }
    }
    return segs[k]
}

// _is_interp_binary — robust prefix-match on a basename.
// Covers all build/ variants: hexa, hexa_real, hexa_interp,
// hexa_interp_linux_arm64, hexa_interp_t31_arena_off,
// hexa_interp_variant_a, hexa_interp_safe_2150, hexa_stage0,
// hexa.real, hexa.real.new_async, hexa.known_good, hexa.linux,
// hexa_v2_linux, exe, etc. Also retains the legacy 6-pattern
// ends_with fallback for regression safety.
// raw 91 honest C3: starts_with("hexa") admits any future binary
// whose basename begins with "hexa" (e.g., random `hexa_clone_test`)
// — false-positive risk accepted as the trade-off for robust coverage.
fn _is_interp_binary(a) {
    let b = _argv_basename(a)
    if len(b) > 0 {
        if b.starts_with("hexa") { return true }
        if b == "exe" { return true }
    }
    // Legacy fallback (backward-compat, regression guard)
    if a.ends_with("/hexa") { return true }
    if a.ends_with("/hexa_real") { return true }
    if a.ends_with("/exe") { return true }
    if a.ends_with("/hexa_interp") { return true }
    if a.ends_with("/hexa_interp.real") { return true }
    if a.ends_with("/hexa.real") { return true }
    return false
}

pub fn skip_invocation_prefix(raw: array) -> i64 {
    let mut i: i64 = 0
    // Skip leading interpreter binary path(s). Mac duplicates the binary path;
    // Linux has it once. Robust pattern (2026-04-30, raw 91 honest C3):
    // basename starts_with("hexa") OR basename == "exe" — covers all
    // /Users/ghost/core/hexa-lang/build/hexa_interp_* variants without
    // an exhaustive ends_with whitelist. Legacy 6-pattern ends_with
    // fallback retained inside _is_interp_binary for regression safety.
    // NOTE: Use nested `if` rather than `&&` short-circuit — Linux hexa runtime
    //       does NOT short-circuit `&&`, so `i < len && raw[i]…` evaluates both
    //       sides and crashes with `index N out of bounds` when raw is empty.
    while i < len(raw) {
        let a = raw[i]
        if _is_interp_binary(a) {
            i = i + 1
        } else {
            break
        }
    }
    // Optionally skip "run" subcommand (Linux runtime pattern).
    if i < len(raw) {
        if raw[i] == "run" {
            i = i + 1
        }
    }
    // Optionally skip ONE .hexa script path (the script being invoked, Linux pattern).
    if i < len(raw) {
        if raw[i].ends_with(".hexa") {
            i = i + 1
        }
    }
    return i
}
