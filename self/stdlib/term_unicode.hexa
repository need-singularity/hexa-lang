// ═══════════════════════════════════════════════════════════════════════
//  self/stdlib/term_unicode.hexa — wcwidth / east-asian width / graphemes
//
//  PURPOSE
//      Calculate the COLUMN WIDTH of a code-point or string when
//      rendered in a monospace terminal. hive packages/tui/src/utils.ts
//      depends on `get-east-asian-width` npm package and Intl.Segmenter
//      for ~250 LoC of width logic. This module ports the core
//      width tables (sufficient for the common case) into pure hexa.
//
//  EXPORTS
//      cp_width(cp: i64) -> i64
//        Returns 0 (zero-width / control), 1 (narrow), 2 (wide),
//        or -1 (control char that should be filtered).
//      char_width_at(s: string, idx: i64) -> [width, next_idx]
//        Decodes one UTF-8 code point at idx, returns its width plus
//        the byte index of the next code point. -1 on bad UTF-8.
//      text_width(s: string) -> i64
//        Sum of cp_width over all code points. Skips zero-width
//        joiners and combining marks. Returns -1 on bad UTF-8.
//      is_combining(cp) -> bool
//        Per Unicode general category Mn/Mc/Me (subset).
//      is_east_asian_wide(cp) -> bool
//        Per UAX #11. Subset suitable for CJK + emoji block.
//
//  CAVEATS (raw 91 honest C3)
//      * Width tables are SUBSETS — covers Latin + CJK + common
//        emoji + private-use ranges. Edge cases (Mongolian,
//        Tifinagh, recent emoji additions) may misreport. For
//        pixel-perfect output, terminal-side width queries (DSR)
//        would be needed; runtime cost prohibitive for hot path.
//      * Grapheme clustering (extended grapheme break per UAX#29)
//        is ONLY partially implemented: combining marks fold into
//        their base. ZWJ sequences (e.g. family emoji "👨‍👩‍👧‍👦") and
//        regional indicators (flags) are NOT joined — caller using
//        these should layer hive's own segmenter atop this module.
//
//  RAW 159 UPSTREAM GAP
//      Native UTF-8 codepoint iterator + general-category lookup
//      in hexa runtime would replace this module's hand-rolled
//      decoder. Tracked under raw 159.
//
//  USAGE
//      use "self/stdlib/term_unicode"
//      let w = text_width("hello 한국")    // 6 + 4 = 10
//      let r = char_width_at("ab", 0)
//
//  --selftest:
//      hexa run self/stdlib/term_unicode.hexa --selftest
//        → __TERM_UNICODE_SELFTEST__ <PASS|FAIL> n=<N> fail=<M>
// ═══════════════════════════════════════════════════════════════════════

// ── UTF-8 byte → codepoint decoder ────────────────────────────────
// Returns [cp, byte_len] or [-1, -1] on error.
fn _u8_decode(s: string, idx: i64) -> array {
    let n = len(s)
    if idx < 0 || idx >= n { return [-1, -1] }
    let b0 = char_code(s.substring(idx, idx + 1))
    if b0 < 128 {
        return [b0, 1]
    }
    if b0 < 192 {
        // Continuation byte at start → invalid.
        return [-1, -1]
    }
    if b0 < 224 {
        if idx + 2 > n { return [-1, -1] }
        let b1 = char_code(s.substring(idx + 1, idx + 2))
        if b1 < 128 || b1 >= 192 { return [-1, -1] }
        let cp = ((b0 - 192) * 64) + (b1 - 128)
        return [cp, 2]
    }
    if b0 < 240 {
        if idx + 3 > n { return [-1, -1] }
        let b1 = char_code(s.substring(idx + 1, idx + 2))
        let b2 = char_code(s.substring(idx + 2, idx + 3))
        if b1 < 128 || b1 >= 192 { return [-1, -1] }
        if b2 < 128 || b2 >= 192 { return [-1, -1] }
        let cp = ((b0 - 224) * 4096) + ((b1 - 128) * 64) + (b2 - 128)
        return [cp, 3]
    }
    if b0 < 248 {
        if idx + 4 > n { return [-1, -1] }
        let b1 = char_code(s.substring(idx + 1, idx + 2))
        let b2 = char_code(s.substring(idx + 2, idx + 3))
        let b3 = char_code(s.substring(idx + 3, idx + 3 + 1))
        if b1 < 128 || b1 >= 192 { return [-1, -1] }
        if b2 < 128 || b2 >= 192 { return [-1, -1] }
        if b3 < 128 || b3 >= 192 { return [-1, -1] }
        let cp = ((b0 - 240) * 262144) + ((b1 - 128) * 4096) + ((b2 - 128) * 64) + (b3 - 128)
        return [cp, 4]
    }
    return [-1, -1]
}

// ── Combining marks (Mn/Mc/Me) — common subset ────────────────────
pub fn is_combining(cp: i64) -> bool {
    // Combining Diacritical Marks
    if cp >= 768 && cp <= 879 { return true }
    // Hebrew points
    if cp >= 1425 && cp <= 1469 { return true }
    if cp == 1471 { return true }
    if cp >= 1473 && cp <= 1474 { return true }
    if cp >= 1476 && cp <= 1477 { return true }
    // Arabic marks
    if cp >= 1552 && cp <= 1562 { return true }
    if cp >= 1611 && cp <= 1631 { return true }
    if cp == 1648 { return true }
    if cp >= 1750 && cp <= 1756 { return true }
    if cp >= 1759 && cp <= 1764 { return true }
    if cp >= 1767 && cp <= 1768 { return true }
    if cp >= 1770 && cp <= 1773 { return true }
    // Devanagari
    if cp >= 2304 && cp <= 2306 { return true }
    if cp == 2362 { return true }
    if cp == 2364 { return true }
    if cp >= 2369 && cp <= 2376 { return true }
    if cp == 2381 { return true }
    if cp >= 2385 && cp <= 2391 { return true }
    if cp == 2402 { return true }
    if cp == 2403 { return true }
    // Variation selectors
    if cp >= 65024 && cp <= 65039 { return true }
    // Combining Half Marks
    if cp >= 65056 && cp <= 65071 { return true }
    // Variation Selectors Supplement
    if cp >= 917760 && cp <= 917999 { return true }
    // Zero-width joiner / non-joiner / formatters
    if cp == 8203 { return true }   // ZWSP
    if cp == 8204 { return true }   // ZWNJ
    if cp == 8205 { return true }   // ZWJ
    if cp == 8288 { return true }   // WORD JOINER
    return false
}

// ── East Asian Wide / Fullwidth (UAX #11 subset) ──────────────────
pub fn is_east_asian_wide(cp: i64) -> bool {
    // Hangul Jamo
    if cp >= 0x1100 && cp <= 0x115F { return true }
    // CJK Unified Ideographs Extension A
    if cp >= 0x2E80 && cp <= 0x303E { return true }
    if cp >= 0x3041 && cp <= 0x33FF { return true }   // Hiragana/Katakana/CJK
    if cp >= 0x3400 && cp <= 0x4DBF { return true }   // Ext A
    if cp >= 0x4E00 && cp <= 0x9FFF { return true }   // Unified
    if cp >= 0xA000 && cp <= 0xA4CF { return true }   // Yi
    if cp >= 0xAC00 && cp <= 0xD7A3 { return true }   // Hangul Syllables
    if cp >= 0xF900 && cp <= 0xFAFF { return true }   // Compatibility Ideographs
    if cp >= 0xFE30 && cp <= 0xFE4F { return true }   // CJK Compat Forms
    if cp >= 0xFF00 && cp <= 0xFF60 { return true }   // Fullwidth Forms
    if cp >= 0xFFE0 && cp <= 0xFFE6 { return true }   // Fullwidth Signs
    // Emoji blocks (subset; conservative)
    if cp >= 0x1F300 && cp <= 0x1F64F { return true }
    if cp >= 0x1F680 && cp <= 0x1F6FF { return true }
    if cp >= 0x1F900 && cp <= 0x1F9FF { return true }
    if cp >= 0x1FA70 && cp <= 0x1FAFF { return true }
    // CJK Ext B/C/D/E/F
    if cp >= 0x20000 && cp <= 0x2FFFD { return true }
    if cp >= 0x30000 && cp <= 0x3FFFD { return true }
    return false
}

// cp_width: monospace cell width.
pub fn cp_width(cp: i64) -> i64 {
    if cp < 0 { return -1 }
    // C0 controls (excluding TAB which terminals expand) and DEL
    if cp < 32 { return -1 }
    if cp == 127 { return -1 }
    // C1 controls
    if cp >= 128 && cp < 160 { return -1 }
    if is_combining(cp) { return 0 }
    if is_east_asian_wide(cp) { return 2 }
    return 1
}

pub fn char_width_at(s: string, idx: i64) -> array {
    let r = _u8_decode(s, idx)
    if r[0] < 0 { return [-1, -1] }
    let w = cp_width(r[0])
    return [w, idx + r[1]]
}

pub fn text_width(s: string) -> i64 {
    let n = len(s)
    let mut total = 0
    let mut i = 0
    while i < n {
        let r = _u8_decode(s, i)
        if r[0] < 0 { return -1 }
        let w = cp_width(r[0])
        if w >= 0 { total = total + w }
        // w == -1 (control): skip silently — caller can pre-filter
        // if they want strict mode.
        i = i + r[1]
    }
    return total
}

// ── --selftest ─────────────────────────────────────────────────────
fn _tuni_selftest() {
    let mut fail = 0
    let mut n = 0

    // 1. ASCII
    n = n + 1
    if cp_width(65) != 1 { eprintln("FAIL 1"); fail = fail + 1 }

    // 2. Control char → -1
    n = n + 1
    if cp_width(7) != -1 { eprintln("FAIL 2"); fail = fail + 1 }

    // 3. Combining (U+0301)
    n = n + 1
    if cp_width(0x301) != 0 { eprintln("FAIL 3"); fail = fail + 1 }

    // 4. Wide CJK (U+4E2D '中')
    n = n + 1
    if cp_width(0x4E2D) != 2 { eprintln("FAIL 4"); fail = fail + 1 }

    // 5. Wide Hangul (U+AC00 '가')
    n = n + 1
    if cp_width(0xAC00) != 2 { eprintln("FAIL 5"); fail = fail + 1 }

    // 6. Wide emoji (U+1F600)
    n = n + 1
    if cp_width(0x1F600) != 2 { eprintln("FAIL 6"); fail = fail + 1 }

    // 7. ZWJ → 0
    n = n + 1
    if cp_width(0x200D) != 0 { eprintln("FAIL 7"); fail = fail + 1 }

    // 8. text_width ASCII
    n = n + 1
    if text_width("hello") != 5 { eprintln("FAIL 8 got=" + to_string(text_width("hello"))); fail = fail + 1 }

    // 9. text_width with CJK
    n = n + 1
    let s9 = "한국"   // 2 hangul syllables, each width 2 → total 4
    if text_width(s9) != 4 { eprintln("FAIL 9 got=" + to_string(text_width(s9))); fail = fail + 1 }

    // 10. text_width mixed
    n = n + 1
    let s10 = "hi 한"   // h(1)+i(1)+ (1)+한(2) = 5
    if text_width(s10) != 5 { eprintln("FAIL 10 got=" + to_string(text_width(s10))); fail = fail + 1 }

    // 11. text_width empty
    n = n + 1
    if text_width("") != 0 { eprintln("FAIL 11"); fail = fail + 1 }

    // 12. _u8_decode boundary on 'a'
    n = n + 1
    let d12 = _u8_decode("a", 0)
    if d12[0] != 97 || d12[1] != 1 { eprintln("FAIL 12"); fail = fail + 1 }

    // 13. _u8_decode 2-byte ('é' = U+00E9; literal string is UTF-8 0xC3 0xA9)
    n = n + 1
    let s_e = "é"
    let d13 = _u8_decode(s_e, 0)
    if d13[0] != 0xE9 || d13[1] != 2 { eprintln("FAIL 13 got cp=" + to_string(d13[0]) + " len=" + to_string(d13[1])); fail = fail + 1 }

    // 14. _u8_decode 3-byte CJK ('中' = U+4E2D; literal is UTF-8 0xE4 0xB8 0xAD)
    n = n + 1
    let s_cn = "中"
    let d14 = _u8_decode(s_cn, 0)
    if d14[0] != 0x4E2D || d14[1] != 3 { eprintln("FAIL 14 got cp=" + to_string(d14[0])); fail = fail + 1 }

    // 15. _u8_decode bad byte (use from_char_code(0xFF) which produces UTF-8
    //     of cp 0xFF = 0xC3 0xBF — actually a VALID 2-byte sequence for U+00FF.
    //     Use from_char_code values that, when concatenated, fail validation.
    //     Build raw via a literal known to start with a continuation byte:
    //     U+0080 encodes as 0xC2 0x80; using s_e=0xC3 0xA9 then taking
    //     substring(1, 2) gives just continuation 0xA9. Decoding that as
    //     start should fail (b0 in 128..192 → continuation at start).
    n = n + 1
    let s_bad = "é"
    let d15 = _u8_decode(s_bad, 1)
    if d15[0] != -1 { eprintln("FAIL 15 got=" + to_string(d15[0])); fail = fail + 1 }

    // 16. char_width_at
    n = n + 1
    let r16 = char_width_at("a", 0)
    if r16[0] != 1 || r16[1] != 1 { eprintln("FAIL 16"); fail = fail + 1 }

    // 17. is_combining sanity
    n = n + 1
    if !is_combining(0x301) { eprintln("FAIL 17a"); fail = fail + 1 }
    n = n + 1
    if is_combining(65) { eprintln("FAIL 17b"); fail = fail + 1 }

    // 18. is_east_asian_wide sanity
    n = n + 1
    if !is_east_asian_wide(0x4E2D) { eprintln("FAIL 18a"); fail = fail + 1 }
    n = n + 1
    if is_east_asian_wide(65) { eprintln("FAIL 18b"); fail = fail + 1 }

    if fail == 0 {
        println("__TERM_UNICODE_SELFTEST__ PASS n=" + to_string(n) + " fail=0")
    } else {
        println("__TERM_UNICODE_SELFTEST__ FAIL n=" + to_string(n) + " fail=" + to_string(fail))
    }
}

let _tun_argv = args()
let mut _tun_st = false
let mut _tun_ai = 0
while _tun_ai < len(_tun_argv) {
    if _tun_argv[_tun_ai] == "--selftest-term-unicode" { _tun_st = true }
    if _tun_argv[_tun_ai] == "--selftest" {
        let mut _tun_aj = 0
        while _tun_aj < len(_tun_argv) {
            if _tun_argv[_tun_aj].ends_with("/stdlib/term_unicode.hexa") { _tun_st = true }
            _tun_aj = _tun_aj + 1
        }
    }
    _tun_ai = _tun_ai + 1
}
if _tun_st {
    _tuni_selftest()
}
