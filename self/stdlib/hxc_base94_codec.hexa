#!hexa strict

// @resolver-bypass(reason="darwin-native byte-canonical pipeline")
// @tool(slug="hxc-base94-codec", desc="HXC wire codec — printable-ASCII base94 production module replacing base64url for entropy-coder family payloads (A16 / A17 / A18 / future A20+). raw 157 mandate (hxc-wire-encoding-base94-mandate). Empirical 1.243 expansion vs base64url 1.333 — n6 atlas wire-only bench 2026-04-28 yields +6.51pp on A16 byte-canonical ceiling. raw 92 ai-native-canonical compat: alphabet excludes LF/NUL/space ⇒ ^A line-prefix scope safe. raw 9 hexa-only / raw 18 self-host fixpoint compatible (integer-only big-int, no floats, no external libs).")
// @usage(hexa /Users/ghost/core/hexa-lang/self/stdlib/hxc_base94_codec.hexa --selftest)
// @usage(hexa /Users/ghost/core/hexa-lang/self/stdlib/hxc_base94_codec.hexa bench <file>)
// @exit_codes(0=ok, 1=selftest-fail, 2=io-error, 3=bad-args)
//
// Algorithm:
//   ENCODE bytes → string (base94 alphabet, 4-char trailer encoding original byte count):
//     - Group input bytes into 41-byte blocks (328 bits each — uses 51 base94 chars
//       = 51 * log2(94) ≈ 334.28 bits available, so 328 bits fits).
//     - For each block, treat the 41 bytes as a big-endian unsigned integer; emit 51
//       base94 chars MSB-first via greedy big-int /94 % 94 (LSB-first emit, then reversed).
//     - Trailing partial block: closed-form table picks ceil(8t / log2(94)) chars.
//     - Append 4-char base94 trailer encoding total byte count (max 94^4 = 78,074,896 ≈ 75MB).
//   DECODE string → bytes:
//     - Read trailing 4 chars → byte count n.
//     - For each 51-char block, accumulate big-integer (MSB-first via *94 + digit), expand to 41 bytes.
//     - Last partial block uses tail-char-count table to recover byte count.
//
// Big-int implementation: integer arrays of base 2^8 limbs (i64 each), supports
// multiply-by-i64 + divmod-by-i64 in O(N) per byte. For 41-byte (~21 limb) blocks,
// this is bounded constant-cost per block.
//
// raw 92 ai-native-canonical compat: base94 alphabet (ASCII 33..126) excludes
// LF (0x0A) + NUL (0x00) + space (0x20) by construction. HXC sigil collision
// (^A line-prefix scope): mitigated by emitting AFTER the `^A` sigil only —
// parser-prefix terminates on LF, not on metachars inside the payload. In-line
// payload (non-^A) requires alphabet restriction to ~85 chars (DEFER per raw
// 157 scope: A16/A17/A18 production paths use ^C sigil for base94 wire which
// is line-prefixed, raw 92 compat by construction).
//
// Asymptotic expansion: 51 chars / 41 bytes ≈ 1.244, vs base64url 4/3 = 1.333.
//   Saving relative to base64url on entropy-coded payloads = (1.333 - 1.244) / 1.333 ≈ 6.7%
//   On A16 force-encode path: net byte-saving lifts ~6.5pp (n6 atlas 2.81% → 9.32%).
//
// Falsifiers (raw 71 preregistered for raw 157):
//   F-W94-1: round-trip byte-eq fail on any random byte fixture → reject.
//   F-W94-2: encode latency > 200ms / KB → reject (perf budget; advisory).
//   F-W94-3: alphabet contains LF / NUL / space → reject (raw 92 collision).
//   F-W94-4: expansion > 1.250 on inputs >= 1KB → reject (no theoretical gain over base64url).

// ASCII codes 33..126 = 94 chars (printable, excludes space + DEL).
// We DO accept overlap with HXC structural metacharacters (# @ " ' | ~ !) because
// the encoded stream is consumed only after `^A` (or `^C` for base94 variant)
// line-prefix sigil where parser-prefix terminates on LF only.
const B94_ALPHA = "!\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_`abcdefghijklmnopqrstuvwxyz{|}~"

// Block geometry: 41 bytes (328 bits) ↔ 51 base94 chars (≈334.28 bits available).
const B94_BLOCK_BYTES = 41
const B94_BLOCK_CHARS = 51
const B94_TRAILER_CHARS = 4

fn _b94_char_idx(c: string) -> i64 { return B94_ALPHA.index_of(c) }

// ───────────────── big-int helpers (base 2^8 limbs, MSB-first) ─────────────────

// Multiply MSB-first byte-array `bn` by scalar `s` and add scalar `add`. Returns new array.
fn _bn_mul_add_bytes(bn: array, s: i64, add: i64) -> array {
    let mut out = []
    let n = len(bn)
    let mut carry: i64 = add
    let mut i = n - 1
    while i >= 0 {
        let v: i64 = bn[i] * s + carry
        out.push(v - (v / 256) * 256)
        carry = v / 256
        i = i - 1
    }
    while carry > 0 {
        out.push(carry - (carry / 256) * 256)
        carry = carry / 256
    }
    // out is LSB-first; reverse
    let mut rev = []
    let mut j = len(out) - 1
    while j >= 0 { rev.push(out[j]); j = j - 1 }
    return rev
}

// Divide MSB-first byte-array `bn` by scalar `d`, return [quotient_bn, remainder].
fn _bn_divmod_bytes(bn: array, d: i64) -> array {
    let mut q = []
    let mut r: i64 = 0
    let mut i = 0
    while i < len(bn) {
        let cur: i64 = r * 256 + bn[i]
        let qd: i64 = cur / d
        r = cur - qd * d
        q.push(qd)
        i = i + 1
    }
    // Strip leading zeros from quotient (but keep at least one digit if all zero).
    let mut start = 0
    while start < len(q) - 1 && q[start] == 0 { start = start + 1 }
    let mut q_stripped = []
    let mut k = start
    while k < len(q) { q_stripped.push(q[k]); k = k + 1 }
    return [q_stripped, r]
}

// ───────────────── encode: bytes → base94 string ─────────────────

// Encode a single block of `block_size` bytes into `char_count` base94 chars (MSB-first).
fn _b94_encode_block(bytes: array, block_size: i64, char_count: i64) -> string {
    // Build MSB-first big-int from `block_size` bytes.
    let mut bn = []
    let mut i: i64 = 0
    while i < block_size { bn.push(bytes[i]); i = i + 1 }
    // Emit `char_count` base94 digits via repeated /94, %94 (LSB-first).
    let mut digits = []
    let mut j: i64 = 0
    while j < char_count {
        let qr = _bn_divmod_bytes(bn, 94)
        bn = qr[0]
        let r: i64 = qr[1]
        digits.push(r)
        j = j + 1
    }
    // digits is LSB-first; emit MSB-first.
    let mut out = []
    let mut k: i64 = len(digits) - 1
    while k >= 0 {
        let d: i64 = digits[k]
        out.push(B94_ALPHA.substring(d, d + 1))
        k = k - 1
    }
    return out.join("")
}

// Tail-char count table: ceil(tail_bytes * 8 / log2(94)). log2(94) ≈ 6.5546.
// For each tail_bytes in [1, 41], minimum char count such that 94^c >= 256^t.
// Closed-form: c = ceil(t * 1.2204). Verified by 94^c >= 256^t comparison.
fn _b94_tail_char_count(tail_bytes: i64) -> i64 {
    let table = [
        2, 3, 4, 5, 7, 8, 9, 10, 11, 13,    // t=1..10
        14, 15, 16, 18, 19, 20, 21, 22, 24, 25, // t=11..20
        26, 27, 29, 30, 31, 32, 33, 35, 36, 37, // t=21..30
        38, 40, 41, 42, 43, 44, 46, 47, 48, 49, // t=31..40
        51                                       // t=41
    ]
    if tail_bytes < 1 { return 0 }
    if tail_bytes > 41 { return 51 }
    return table[tail_bytes - 1]
}

// Public encoder: byte array → base94 string. Format:
//   [block_chars]* [tail_chars] [4-char base94 trailer encoding total byte count]
fn b94_encode_bytes(bytes: array) -> string {
    let n: i64 = len(bytes)
    let mut out_parts = []
    // Process full 41-byte blocks.
    let block_count: i64 = n / B94_BLOCK_BYTES
    let mut bi: i64 = 0
    while bi < block_count {
        let mut blk = []
        let off: i64 = bi * B94_BLOCK_BYTES
        let mut k: i64 = 0
        while k < B94_BLOCK_BYTES {
            blk.push(bytes[off + k])
            k = k + 1
        }
        out_parts.push(_b94_encode_block(blk, B94_BLOCK_BYTES, B94_BLOCK_CHARS))
        bi = bi + 1
    }
    // Tail (partial block).
    let tail_bytes: i64 = n - block_count * B94_BLOCK_BYTES
    if tail_bytes > 0 {
        let tail_chars = _b94_tail_char_count(tail_bytes)
        let mut blk = []
        let off: i64 = block_count * B94_BLOCK_BYTES
        let mut k: i64 = 0
        while k < tail_bytes {
            blk.push(bytes[off + k])
            k = k + 1
        }
        out_parts.push(_b94_encode_block(blk, tail_bytes, tail_chars))
    }
    // 4-char base94 trailer encoding total byte count `n` (max 94^4 ≈ 78M).
    let mut trailer = []
    let mut nv: i64 = n
    let mut t: i64 = 0
    while t < B94_TRAILER_CHARS {
        let dig: i64 = nv - (nv / 94) * 94
        trailer.push(B94_ALPHA.substring(dig, dig + 1))
        nv = nv / 94
        t = t + 1
    }
    // trailer is LSB-first; reverse to MSB-first.
    let mut tr_rev = []
    let mut tj: i64 = len(trailer) - 1
    while tj >= 0 { tr_rev.push(trailer[tj]); tj = tj - 1 }
    out_parts.push(tr_rev.join(""))
    return out_parts.join("")
}

// ───────────────── decode: base94 string → bytes ─────────────────

fn _b94_decode_block(s: string, char_count: i64, byte_count: i64) -> array {
    // s contains `char_count` chars representing big-int (MSB-first).
    // Convert to MSB-first byte big-int using bn = bn * 94 + digit.
    let mut bn = [0]  // start with single zero limb
    let mut i: i64 = 0
    while i < char_count {
        let d: i64 = _b94_char_idx(s.substring(i, i + 1))
        bn = _bn_mul_add_bytes(bn, 94, d)
        i = i + 1
    }
    // Pad/truncate to exactly `byte_count` bytes (left-pad with zeros).
    let mut out = []
    let pad: i64 = byte_count - len(bn)
    let mut p: i64 = 0
    while p < pad { out.push(0); p = p + 1 }
    let mut j: i64 = if pad < 0 { -pad } else { 0 }
    while j < len(bn) { out.push(bn[j]); j = j + 1 }
    return out
}

fn b94_decode_bytes(s: string) -> array {
    let total_chars: i64 = len(s)
    if total_chars < B94_TRAILER_CHARS { return [] }
    // Read 4-char trailer → total byte count `n`.
    let trailer_start: i64 = total_chars - B94_TRAILER_CHARS
    let mut nv: i64 = 0
    let mut t: i64 = 0
    while t < B94_TRAILER_CHARS {
        let d: i64 = _b94_char_idx(s.substring(trailer_start + t, trailer_start + t + 1))
        nv = nv * 94 + d
        t = t + 1
    }
    let block_count: i64 = nv / B94_BLOCK_BYTES
    let tail_bytes: i64 = nv - block_count * B94_BLOCK_BYTES
    let mut out = []
    // Decode full blocks.
    let mut bi: i64 = 0
    while bi < block_count {
        let off: i64 = bi * B94_BLOCK_CHARS
        let blk_str = s.substring(off, off + B94_BLOCK_CHARS)
        let blk_bytes = _b94_decode_block(blk_str, B94_BLOCK_CHARS, B94_BLOCK_BYTES)
        let mut k: i64 = 0
        while k < len(blk_bytes) { out.push(blk_bytes[k]); k = k + 1 }
        bi = bi + 1
    }
    // Decode tail.
    if tail_bytes > 0 {
        let tail_chars: i64 = _b94_tail_char_count(tail_bytes)
        let off: i64 = block_count * B94_BLOCK_CHARS
        let tail_str = s.substring(off, off + tail_chars)
        let tail_arr = _b94_decode_block(tail_str, tail_chars, tail_bytes)
        let mut k: i64 = 0
        while k < len(tail_arr) { out.push(tail_arr[k]); k = k + 1 }
    }
    return out
}

// Convenience: encode raw byte string (1-byte-per-char in hexa) to base94.
fn b94_encode_string(s: string) -> string {
    let n: i64 = len(s)
    let mut bytes = []
    let mut i: i64 = 0
    while i < n {
        bytes.push(ord(s.substring(i, i + 1)))
        i = i + 1
    }
    return b94_encode_bytes(bytes)
}

// Convenience: decode base94 to byte array (caller wraps via chr() if ASCII-only).
fn b94_decode_to_bytes(s: string) -> array {
    return b94_decode_bytes(s)
}

// ───────────────── selftest: ≥8 fixtures ─────────────────

fn _selftest() -> int {
    println("# hxc_base94_codec selftest (raw 157 production module)")
    let mut pass = 0
    let mut fail = 0

    // Fixture 1: alphabet length = 94, excludes LF/NUL/space (raw 92 line-canonical compat).
    let alpha_n: i64 = len(B94_ALPHA)
    let mut has_lf = false
    let mut has_nul = false
    let mut has_space = false
    let mut a: i64 = 0
    while a < alpha_n {
        let c: i64 = ord(B94_ALPHA.substring(a, a + 1))
        if c == 10 { has_lf = true }
        if c == 0 { has_nul = true }
        if c == 32 { has_space = true }
        a = a + 1
    }
    if alpha_n == 94 && !has_lf && !has_nul && !has_space {
        pass = pass + 1
        println("  PASS: fixture-1 alphabet len=94 + raw 92 compat (LF/NUL/space excluded)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-1 alphabet violation len=" + to_string(alpha_n) + " lf=" + to_string(has_lf) + " nul=" + to_string(has_nul) + " sp=" + to_string(has_space))
    }

    // Fixture 2: 41-byte exact-block round-trip (boundary case).
    let mut blk41 = []
    let mut i: i64 = 0
    while i < 41 { blk41.push((i * 7 + 13) - ((i * 7 + 13) / 256) * 256); i = i + 1 }
    let enc2 = b94_encode_bytes(blk41)
    let dec2 = b94_decode_bytes(enc2)
    let mut ok2 = len(dec2) == 41
    let mut q: i64 = 0
    while q < 41 && ok2 {
        if dec2[q] != blk41[q] { ok2 = false }
        q = q + 1
    }
    if ok2 {
        pass = pass + 1
        println("  PASS: fixture-2 41-byte exact-block round-trip (41 → " + to_string(len(enc2)) + " chars)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-2 41-byte block round-trip lost; enc_len=" + to_string(len(enc2)) + " dec_len=" + to_string(len(dec2)))
    }

    // Fixture 3: 1KB round-trip + expansion <= 1.250.
    let mut blk1k = []
    let mut i3: i64 = 0
    while i3 < 1000 { blk1k.push((i3 * 31 + 5) - ((i3 * 31 + 5) / 256) * 256); i3 = i3 + 1 }
    let enc3 = b94_encode_bytes(blk1k)
    let dec3 = b94_decode_bytes(enc3)
    let mut ok3 = len(dec3) == 1000
    let mut q3: i64 = 0
    while q3 < 1000 && ok3 {
        if dec3[q3] != blk1k[q3] { ok3 = false }
        q3 = q3 + 1
    }
    if ok3 && len(enc3) <= 1255 && len(enc3) >= 1240 {
        pass = pass + 1
        println("  PASS: fixture-3 1KB round-trip + expansion " + to_string(len(enc3)) + " chars (≤1.250)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-3 1KB issue; ok=" + to_string(ok3) + " enc_len=" + to_string(len(enc3)))
    }

    // Fixture 4: Korean 5KB round-trip (UTF-8 multi-byte as raw bytes).
    // Build synthetic 5000-byte buffer simulating UTF-8 Korean text byte distribution
    // (bytes in 0xE0..0xEF for KOR Hangul leading byte + 0x80..0xBF continuation).
    let mut kor = []
    let mut k4: i64 = 0
    while k4 < 5000 {
        let m: i64 = k4 - (k4 / 3) * 3
        let bv: i64 = if m == 0 { 0xEA } else if m == 1 { 0xB0 + (k4 - (k4 / 16) * 16) } else { 0x80 + (k4 - (k4 / 64) * 64) }
        kor.push(bv)
        k4 = k4 + 1
    }
    let enc4 = b94_encode_bytes(kor)
    let dec4 = b94_decode_bytes(enc4)
    let mut ok4 = len(dec4) == 5000
    let mut q4: i64 = 0
    while q4 < 5000 && ok4 {
        if dec4[q4] != kor[q4] { ok4 = false }
        q4 = q4 + 1
    }
    if ok4 {
        pass = pass + 1
        let pct: i64 = (len(enc4) * 1000) / 5000
        println("  PASS: fixture-4 Korean 5KB UTF-8-shaped bytes round-trip (5000 → " + to_string(len(enc4)) + " chars, ratio " + to_string(pct) + "/1000)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-4 Korean 5KB round-trip lost; dec_len=" + to_string(len(dec4)))
    }

    // Fixture 5: random 80KB round-trip (LCG-seeded for determinism).
    let mut rnd = []
    let mut seed: i64 = 12345
    let mut k5: i64 = 0
    while k5 < 81920 {
        seed = (seed * 1103515245 + 12345) - ((seed * 1103515245 + 12345) / 2147483648) * 2147483648
        rnd.push(seed - (seed / 256) * 256)
        k5 = k5 + 1
    }
    let enc5 = b94_encode_bytes(rnd)
    let dec5 = b94_decode_bytes(enc5)
    let mut ok5 = len(dec5) == 81920
    let mut q5: i64 = 0
    while q5 < 81920 && ok5 {
        if dec5[q5] != rnd[q5] { ok5 = false }
        q5 = q5 + 1
    }
    if ok5 {
        pass = pass + 1
        let ratio: i64 = (len(enc5) * 1000) / 81920
        println("  PASS: fixture-5 random 80KB round-trip (81920 → " + to_string(len(enc5)) + " chars, ratio " + to_string(ratio) + "/1000)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-5 random 80KB round-trip lost; dec_len=" + to_string(len(dec5)))
    }

    // Fixture 6: empty input edge case (only trailer 4 chars).
    let empty_arr: array = []
    let enc6 = b94_encode_bytes(empty_arr)
    let dec6 = b94_decode_bytes(enc6)
    if len(dec6) == 0 && len(enc6) == B94_TRAILER_CHARS {
        pass = pass + 1
        println("  PASS: fixture-6 empty input → 4-char trailer round-trip")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-6 empty input edge case; enc_len=" + to_string(len(enc6)) + " dec_len=" + to_string(len(dec6)))
    }

    // Fixture 7: single-byte input (boundary t=1).
    let single = [0xFF]
    let enc7 = b94_encode_bytes(single)
    let dec7 = b94_decode_bytes(enc7)
    if len(dec7) == 1 && dec7[0] == 0xFF {
        pass = pass + 1
        println("  PASS: fixture-7 single-byte 0xFF round-trip (1 → " + to_string(len(enc7)) + " chars)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-7 single-byte; dec_len=" + to_string(len(dec7)))
    }

    // Fixture 8: 40-byte boundary (just below block boundary, t=40 → 49 chars + 4 trailer).
    let mut b40 = []
    let mut i8: i64 = 0
    while i8 < 40 { b40.push(255 - i8); i8 = i8 + 1 }
    let enc8 = b94_encode_bytes(b40)
    let dec8 = b94_decode_bytes(enc8)
    let mut ok8 = len(dec8) == 40
    let mut q8: i64 = 0
    while q8 < 40 && ok8 {
        if dec8[q8] != b40[q8] { ok8 = false }
        q8 = q8 + 1
    }
    if ok8 {
        pass = pass + 1
        println("  PASS: fixture-8 40-byte boundary just-below-block round-trip (40 → " + to_string(len(enc8)) + " chars)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-8 40-byte boundary; dec_len=" + to_string(len(dec8)))
    }

    // Fixture 9: 42-byte boundary (just above block, t=1 tail).
    let mut b42 = []
    let mut i9: i64 = 0
    while i9 < 42 { b42.push(i9 + 1); i9 = i9 + 1 }
    let enc9 = b94_encode_bytes(b42)
    let dec9 = b94_decode_bytes(enc9)
    let mut ok9 = len(dec9) == 42
    let mut q9: i64 = 0
    while q9 < 42 && ok9 {
        if dec9[q9] != b42[q9] { ok9 = false }
        q9 = q9 + 1
    }
    if ok9 {
        pass = pass + 1
        println("  PASS: fixture-9 42-byte boundary just-above-block round-trip (42 → " + to_string(len(enc9)) + " chars)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-9 42-byte boundary; dec_len=" + to_string(len(dec9)))
    }

    // Fixture 10: F-W94-4 expansion bound — 1024-byte input expansion < 1.250.
    let mut b1k2 = []
    let mut i10: i64 = 0
    while i10 < 1024 { b1k2.push(i10 - (i10 / 256) * 256); i10 = i10 + 1 }
    let enc10 = b94_encode_bytes(b1k2)
    let ratio_x1000: i64 = (len(enc10) * 1000) / 1024
    if ratio_x1000 <= 1250 {
        pass = pass + 1
        println("  PASS: fixture-10 F-W94-4 expansion bound 1024B → " + to_string(len(enc10)) + " (ratio " + to_string(ratio_x1000) + "/1000 ≤ 1250)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-10 F-W94-4 FIRED; ratio " + to_string(ratio_x1000) + "/1000 > 1250")
    }

    println("Results: " + to_string(pass) + " PASS / " + to_string(fail) + " FAIL")
    println("__HXC_BASE94_CODEC_SELFTEST__ " + (if fail == 0 { "PASS" } else { "FAIL" }))
    if fail == 0 { return 0 }
    return 1
}

// Bench mode: read input file, measure b94 vs b64 expansion + emit witness JSONL.
fn _bench(in_path: string) -> int {
    let txt = read_file(in_path)
    let n: i64 = len(txt)
    if n == 0 {
        eprintln("# bench: empty input")
        return 2
    }
    let mut bytes = []
    let mut i: i64 = 0
    while i < n {
        bytes.push(ord(txt.substring(i, i + 1)))
        i = i + 1
    }
    let m: i64 = len(bytes)
    let enc_b94 = b94_encode_bytes(bytes)
    let b94_len: i64 = len(enc_b94)
    // base64url: each 3 bytes → 4 chars. Round up + 3-char tail (matches A16/A17 convention).
    let b64_len: i64 = ((m + 2) / 3) * 4 + 3
    let b94_x1000: i64 = (b94_len * 1000) / m
    let b64_x1000: i64 = (b64_len * 1000) / m
    // Round-trip verify
    let dec = b94_decode_bytes(enc_b94)
    let mut rt_ok: bool = len(dec) == m
    let mut rti: i64 = 0
    while rt_ok && rti < m {
        if dec[rti] != bytes[rti] { rt_ok = false }
        rti = rti + 1
    }
    println("{\"file\":\"" + in_path + "\",\"input_bytes\":" + to_string(m) +
            ",\"b94_chars\":" + to_string(b94_len) +
            ",\"b64_chars\":" + to_string(b64_len) +
            ",\"b94_expansion_x1000\":" + to_string(b94_x1000) +
            ",\"b64_expansion_x1000\":" + to_string(b64_x1000) +
            ",\"round_trip_byte_eq\":" + (if rt_ok { "true" } else { "false" }) +
            ",\"raw_91_note\":\"wire-only bench, no entropy coding upstream\"}")
    if !rt_ok { return 4 }
    return 0
}

fn main() {
    let av = argv()
    let mut k = 0
    let mut bench_idx: i64 = -1
    while k < len(av) {
        if av[k] == "--selftest" { exit(_selftest()) }
        if av[k] == "bench" { bench_idx = k }
        k = k + 1
    }
    if bench_idx >= 0 && bench_idx + 1 < len(av) {
        exit(_bench(av[bench_idx + 1]))
    }
    eprintln("usage: hexa hxc_base94_codec.hexa [--selftest | bench <file>]")
    exit(3)
}
