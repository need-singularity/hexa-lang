// self/stdlib/json.hexa — Safe JSON parse/stringify wrappers.
//
// Resolves part of hive blocker `goal_hexa_native_fs_stdlib` and is the
// upstream-of-truth for the cross-sister python3-removal initiative
// (papers tool/zenodo_publish.hexa + tool/osf_publish.hexa, 2026-04-28).
//
// CONTRACT (stdlib-json v2 / 2026-04-28)
//   The hexa runtime exposes `json_parse` + `json_stringify` builtins.
//   This module wraps them with a status-bearing API.
//
// Pure hexa (raw 9): zero exec(), zero external libs — delegates to
// runtime builtins for the actual parsing.
//
// raw 91 (no_silent_errors) HONEST DISCLOSURES — see docs/stdlib_json_rfc_2026_04_28.md
//   L1. The runtime `json_parse` builtin is NOT total over arbitrary
//       string input. For many malformed inputs it raises a hard
//       runtime error (e.g. `to_int: not an integer: "..."`) that
//       cannot be caught by stdlib code (no try/catch in current
//       runtime — see RFC stdlib_json_rfc §3.2). Therefore
//       json_parse_safe is "safe" only insofar as the input crosses
//       the runtime's well-formed gate. CALLERS PARSING UNTRUSTED
//       INPUT MUST PRE-VALIDATE shape upstream until RFC §4 lands a
//       runtime-level catch.
//   L2. `json_parse("")` returns int 0 (not void), so the wrapper
//       treats len-0 input as a parse failure to keep the documented
//       "[false, ...] on error" contract.
//   L3. The runtime accepts trailing commas in objects/arrays (lax
//       mode) — strict-JSON callers must reject upstream.
//   L4. Number precision: integers up to 10^18 round-trip; full
//       IEEE-754 / arbitrary-precision is NOT guaranteed.
//
// raw 91 (no_silent_errors):
//   - json_parse_safe returns [ok, value] tuple — caller MUST check ok.
//   - json_parse_or_throw raises (eprintln + exit 1) on bad input.
//   - json_stringify is total (never fails on hexa-native types).
//
// raw 159 (hexa-lang-upstream-proposal-mandate):
//   This module is the upstream-of-truth for hive's + papers' + n6's
//   json ops. Sister repos `use "self/stdlib/json"` and never
//   re-implement these.
//
// --selftest mode:
//   hexa run self/stdlib/json.hexa --selftest
//     → emits __JSON_SELFTEST__ <PASS|FAIL> n=<N> fail=<M>
//
// Exports:
//   json_parse_safe(text: string) -> [bool, value]
//       Returns [true, parsed] on success, [false, void] on error.
//       Subject to L1 (runtime crash on some malformed inputs).
//   json_parse_or_throw(text: string) -> value
//       Returns parsed value or eprintln + exit 1 on bad input.
//   json_stringify_pretty(v) -> string
//       Mirror of builtin json_stringify (for naming symmetry).

// ── json_parse_safe ─────────────────────────────────────────
// Parse `text` as JSON. Returns a 2-element array:
//   [true, value]  on success
//   [false, void]  on parse error
//
// Caller pattern:
//   let r = json_parse_safe(buf)
//   if !r[0] { eprintln("bad json"); exit(1) }
//   let v = r[1]
fn json_parse_safe(text) {
    let s = to_string(text)
    // L2: runtime returns int 0 (not void) for empty input, and
    // raises a hard error (uncatchable from stdlib) for many other
    // malformed inputs. Pre-screen empty here to honour the
    // documented [false, void] error contract for that case.
    if len(s) == 0 {
        return [false, void]
    }
    let parsed = json_parse(s)
    let t = type_of(parsed)
    // The builtin returns "void" type on some failures. "null" is a
    // valid JSON token that also parses to void — disambiguate.
    if t == "void" {
        if s.trim() == "null" {
            return [true, parsed]
        }
        return [false, parsed]
    }
    return [true, parsed]
}

// ── json_parse_or_throw ─────────────────────────────────────
// Parse and on failure: log to stderr + exit 1.
// Use when invalid JSON is a programmer error (config files, etc.).
fn json_parse_or_throw(text) {
    let r = json_parse_safe(text)
    if !r[0] {
        eprintln("json_parse: invalid JSON input (len=" + to_string(len(to_string(text))) + ")")
        exit(1)
    }
    return r[1]
}

// ── json_stringify_pretty ───────────────────────────────────
// Naming alias for symmetry with json_parse_safe. Delegates to
// the runtime builtin which is total over hexa-native types.
fn json_stringify_pretty(v) {
    return json_stringify(v)
}

// ── --selftest ──────────────────────────────────────────────
fn _json_selftest() {
    let mut fail = 0
    let mut n = 0

    // 1. parse simple object
    n = n + 1
    let r1 = json_parse_safe("{\"a\":1,\"b\":\"hi\"}")
    if !r1[0] {
        eprintln("FAIL 1 simple object parse")
        fail = fail + 1
    } else {
        let v = r1[1]
        if to_string(v.a) != "1" || to_string(v.b) != "hi" {
            eprintln("FAIL 1b values: a=" + to_string(v.a) + " b=" + to_string(v.b))
            fail = fail + 1
        }
    }

    // 2. parse array
    n = n + 1
    let r2 = json_parse_safe("[1,2,3]")
    if !r2[0] {
        eprintln("FAIL 2 array parse")
        fail = fail + 1
    } else {
        let v = r2[1]
        if len(v) != 3 || to_string(v[0]) != "1" {
            eprintln("FAIL 2b array contents")
            fail = fail + 1
        }
    }

    // 3. parse invalid bare-text -> SKIPPED (raw-91 L1 disclosure)
    //    The runtime hard-errors with `to_int: not an integer: "..."`
    //    for many malformed inputs (e.g. "not valid json", "{a", "a")
    //    which is uncatchable from stdlib. RFC stdlib_json_rfc §4
    //    proposes a runtime-level catch; until that lands, this case
    //    is a documented limit, not a stdlib defect.
    //    n is NOT incremented — selftest counts only enforced cases.

    // 4. parse empty string -> failure (covered by L2 short-circuit)
    n = n + 1
    let r4 = json_parse_safe("")
    if r4[0] {
        eprintln("FAIL 4 empty should fail")
        fail = fail + 1
    }

    // 5. parse "null" -> success (valid JSON)
    n = n + 1
    let r5 = json_parse_safe("null")
    if !r5[0] {
        eprintln("FAIL 5 'null' should parse")
        fail = fail + 1
    }

    // 6. stringify roundtrip
    n = n + 1
    let r6 = json_parse_safe("{\"x\":42}")
    if r6[0] {
        let back = json_stringify_pretty(r6[1])
        // Round-trip: parse-stringify-parse should re-produce the
        // same logical value.
        let r6b = json_parse_safe(back)
        if !r6b[0] {
            eprintln("FAIL 6 roundtrip parse failed: " + back)
            fail = fail + 1
        } else {
            if to_string(r6b[1].x) != "42" {
                eprintln("FAIL 6b roundtrip value drift")
                fail = fail + 1
            }
        }
    }

    // 7. parse nested
    n = n + 1
    let r7 = json_parse_safe("{\"outer\":{\"inner\":[1,2]}}")
    if !r7[0] {
        eprintln("FAIL 7 nested parse")
        fail = fail + 1
    } else {
        let v = r7[1]
        if len(v.outer.inner) != 2 {
            eprintln("FAIL 7b nested shape")
            fail = fail + 1
        }
    }

    // 8. stringify a literal value
    n = n + 1
    let s = json_stringify_pretty(42)
    if s != "42" {
        eprintln("FAIL 8 stringify int: " + s)
        fail = fail + 1
    }

    // 9. cross-sister manifest shape (papers tool/zenodo_publish.hexa
    //    pattern: parse {"papers":[{"id":..,"title":..,"keywords":[..]}]}
    //    and access nested array of strings).
    n = n + 1
    let r9 = json_parse_safe("{\"papers\":[{\"id\":\"p1\",\"title\":\"T\",\"keywords\":[\"a\",\"b\"]}]}")
    if !r9[0] {
        eprintln("FAIL 9 manifest-shape parse")
        fail = fail + 1
    } else {
        let v = r9[1]
        if len(v.papers) != 1 || to_string(v.papers[0].id) != "p1" {
            eprintln("FAIL 9b manifest shape access")
            fail = fail + 1
        }
        if len(v.papers[0].keywords) != 2 {
            eprintln("FAIL 9c keywords array len")
            fail = fail + 1
        }
    }

    // 10. unicode escape (papers titles often contain accented chars).
    n = n + 1
    let r10 = json_parse_safe("{\"name\":\"caf\\u00e9\"}")
    if !r10[0] {
        eprintln("FAIL 10 unicode parse")
        fail = fail + 1
    } else {
        if to_string(r10[1].name) != "café" {
            eprintln("FAIL 10b unicode value: " + to_string(r10[1].name))
            fail = fail + 1
        }
    }

    // 11. large integer round-trip (raw 91 L4 boundary check).
    n = n + 1
    let r11 = json_parse_safe("{\"big\":1000000000000000000}")
    if !r11[0] {
        eprintln("FAIL 11 large int parse")
        fail = fail + 1
    } else {
        if to_string(r11[1].big) != "1000000000000000000" {
            eprintln("FAIL 11b large int drift: " + to_string(r11[1].big))
            fail = fail + 1
        }
    }

    if fail == 0 {
        println("__JSON_SELFTEST__ PASS n=" + to_string(n) + " fail=0")
    } else {
        println("__JSON_SELFTEST__ FAIL n=" + to_string(n) + " fail=" + to_string(fail))
    }
}

let _json_argv = args()
let mut _json_selftest_flag = false
let mut _json_ai = 0
while _json_ai < len(_json_argv) {
    if _json_argv[_json_ai] == "--selftest-json" { _json_selftest_flag = true }
    if _json_argv[_json_ai] == "--selftest" { _json_selftest_flag = true }
    _json_ai = _json_ai + 1
}
if _json_selftest_flag {
    _json_selftest()
}
