// @usage(hexa /Users/ghost/core/hexa-lang/self/stdlib/hxc_a33_cross_repo_dict.hexa --selftest)
// @usage(hexa /Users/ghost/core/hexa-lang/self/stdlib/hxc_a33_cross_repo_dict.hexa encode <in> <out>)
// @usage(hexa /Users/ghost/core/hexa-lang/self/stdlib/hxc_a33_cross_repo_dict.hexa decode <in> <out>)
// @exit_codes(0=ok, 1=selftest-fail, 2=io-error, 3=bad-args, 4=decode-mismatch)
//
// First-tick scope (raw 91 honest C3 STRICT):
//
