//
// raw 137 cmix-ban compliance:
//     greedy longest-match + integer byte compare + LEB128 unsigned varint +
//     ring buffer modulo arithmetic. ALL deterministic. NO fp ops. NO neural
//     mixer. NO non-deterministic similarity. Encode + decode both deterministic
//     (raw 65/68 idempotent: same (manifest, seed, files) → byte-identical wire).
//
// raw 156 placement axis:
//     A33 = post-A1 secondary-stacking. multi-file SESSION ONLY. Single-file CLI
//     invocation reverts to identity (raw 142 D2 try-and-revert). NON-OVERLAP
//     with A19 v2 (per-corpus shared dict via ^Z) and A18 (per-file LZ-PPM via
//     ^L..^Q). Sigil ^h is LOWERCASE alphabetic, distinct from all uppercase
//     ^A..^Z and from ^a/^b/^c.
//
// FIRST-TICK BYTE-RANGE LIMITATION (raw 91 honest C3 disclosure):
//     hexa string primitives use UTF-8 encoding internally. chr(0) returns
//     empty string in some hexa builds, and chr(128..255) returns 2-byte
//     UTF-8 sequences. To preserve byte-eq round-trip on first-tick selftest,
//     A33 first-tick wire is restricted to ASCII range (byte values 1..127)
//     for both input bytes AND varint payload bytes. Sigil ^h = chr(94)+chr(104)
//     stays printable. Match references encoded with continuation-bit varint
//     using 7-bit chunks (continuation marker = adding 64 in printable range
//     instead of 128 high bit). Subsequent-tick may upgrade to byte-array
//     primitive once hexa stdlib exposes raw-byte container; first-tick selftest
//     fixtures are explicitly ASCII-only to honor this constraint.

const A33_RING_CAP = 262144                 // 256KB rolling window
const A33_MATCH_MIN = 4                     // below 4 bytes ref cost dominates
const A33_MATCH_MAX = 258                   // mirrors DEFLATE
const A33_MIN_SESSION_BYTES = 4096          // raw 156: < 4KB → identity passthrough
const A33_MIN_FILE_COUNT = 2                // raw 156: single-file → identity
const A33_SIGIL_BYTE_1 = 94                 // '^'
const A33_SIGIL_BYTE_2 = 104                // 'h'
const A33_HEADER_PREFIX = "# a33:s1 v=cross-repo-lz77-v1"
const A33_VARINT_BASE = 64                  // printable-safe 6-bit chunks (continuation = +64)
const A33_VARINT_MAX_BYTES = 5              // covers values up to 64^5 = 1073741824

// ───────────────── byte / window primitives ─────────────────

fn _byte_at(s: string, i: int) -> string {
    if i < 0 || i >= len(s) { return "" }
    return s.substring(i, i + 1)
}

fn _byte_ord(s: string, i: int) -> int {
    let c = _byte_at(s, i)
    if len(c) == 0 { return -1 }
    return ord(c)
}

// _str_to_codes: convert ASCII string to array of byte ord codes.
// Used to lift input strings into byte-code arrays for ring buffer ops
// (avoids UTF-8 chr() corruption for byte values 0/128+).
fn _str_to_codes(s: string) -> array {
    let n: i64 = len(s)
    let mut out = []
    let mut i: i64 = 0
    while i < n {
        out.push(ord(s.substring(i, i + 1)))
        i = i + 1
    }
    return out
}

// _codes_to_str: inverse, ASCII range only (codes must be 1..127).
// Codes >= 128 will produce UTF-8 multibyte; first-tick selftest restricts
// to ASCII range so this is a safe identity round-trip.
fn _codes_to_str(codes: array) -> string {
    let n: i64 = len(codes)
    let mut out = ""
    let mut i: i64 = 0
    while i < n {
        out = out + chr(codes[i])
        i = i + 1
    }
    return out
}

// ───────────────── PASS 2: ring buffer primitives ─────────────────
//
// Ring buffer state: [codes_array, write_idx_int, n_filled_int]
//   codes_array: array of byte codes (0..255). DYNAMIC GROWTH — initialized
//     with seed contents only (length = len(seed)); appended via push until
//     length reaches A33_RING_CAP, after which writes wrap modulo CAP.
//   write_idx: next position to write
//   n_filled: total bytes ever pushed (caps at A33_RING_CAP after wrap)
//
// FIRST-TICK NOTE: full pre-allocation of 262144 array elements at init was
// O(N) per init AND repeatedly invoked across selftest fixtures, making
// interp wall-time impractical. Dynamic-growth model preserves the SAME
// semantic ring contract (back-distance addressing modulo CAP, capped fill)
// while keeping init O(len(seed)) instead of O(CAP).

fn _a33_ring_init_from_seed(seed_codes: array) -> array {
    // Initialize ring with seed codes only (no padding). write_idx = len(seed)
    // until ring fills to CAP; n_filled = len(seed).
    let n: i64 = len(seed_codes)
    let cap_use: i64 = if n >= A33_RING_CAP { A33_RING_CAP } else { n }
    let mut codes = []
    let mut i: i64 = 0
    while i < cap_use {
        codes.push(seed_codes[i])
        i = i + 1
    }
    let write_idx: i64 = if cap_use >= A33_RING_CAP { 0 } else { cap_use }
    let n_filled: i64 = cap_use
    return [codes, write_idx, n_filled]
}

// _a33_ring_init_empty: empty seed (PASS 2 default).
fn _a33_ring_init_empty() -> array {
    return [[], 0, 0]
}

// _a33_ring_push: push byte b at write_idx; advance write_idx; bump n_filled.
// While length(codes) < A33_RING_CAP we grow via push (codes[write_idx] does
// not exist yet); once length == A33_RING_CAP we overwrite at write_idx.
fn _a33_ring_push(ring: array, b: int) -> array {
    let codes: array = ring[0]
    let write_idx: i64 = ring[1]
    let n_filled: i64 = ring[2]
    let cur_len: i64 = len(codes)
    if cur_len < A33_RING_CAP {
        // Growth phase: append.
        codes.push(b)
    } else {
        codes[write_idx] = b
    }
    let mut new_idx: i64 = write_idx + 1
    if new_idx >= A33_RING_CAP { new_idx = 0 }
    let new_filled: i64 = if n_filled < A33_RING_CAP { n_filled + 1 } else { A33_RING_CAP }
    return [codes, new_idx, new_filled]
}

// _a33_ring_get_back: read byte code at (write_idx - distance) with modulo wrap.
// During growth phase (n_filled < A33_RING_CAP) the modulo just gives a
// linear index; once full it wraps.
fn _a33_ring_get_back(ring: array, distance: int) -> int {
    let codes: array = ring[0]
    let write_idx: i64 = ring[1]
    let n_filled: i64 = ring[2]
    if distance <= 0 { return -1 }
    if distance > n_filled { return -1 }
    if distance > A33_RING_CAP { return -1 }
    let mut p: i64 = write_idx - distance
    while p < 0 { p = p + A33_RING_CAP }
    // During growth phase, codes len < A33_RING_CAP; p is bounded by n_filled
    // so p < len(codes) is guaranteed (n_filled == len(codes) in growth phase).
    return codes[p]
}

// ───────────────── PASS 2: printable-safe varint ─────────────────
//
// 6-bit chunks per byte. Continuation bit emitted as the +64 offset to a
// printable-range character. Encoded byte ranges:
//   continuation bytes: 64+chunk → 64..127  (printable @, A..Z, [, \, ], ^, _, `, a..z, {, |, }, ~, DEL)
//   final byte:         chunk    →  0..63   (some are non-printable, e.g. 0=NUL — but
//                                            only emitted as the LAST varint byte; outer
//                                            wire context ensures these don't collide
//                                            with sigils)
//
// PRINTABILITY NOTE: final-byte values 0..31 include control bytes; for first
// tick this is acceptable because varint sits BETWEEN sigil and next-byte and
// the decoder uses byte-at-position semantics, not line-prefix detection.
// raw 92 sigil-line constraint applies to LINE PREFIX only; varint payload
// is a structured byte sequence within the ^h reference, not a top-level line.

fn _a33_varint_encode(n: int) -> string {
    // n MUST be > 0 in production usage (distance ≥ 1, length ≥ A33_MATCH_MIN);
    // selftest F3 verifies all production-relevant boundaries.
    // For defensive completeness on n ≤ 0 we emit a single space char as a
    // sentinel — but production code paths never invoke this branch.
    if n <= 0 { return " " }
    let mut v: i64 = n
    let mut chunks = []
    while v > 0 {
        let lo: i64 = v - (v / A33_VARINT_BASE) * A33_VARINT_BASE
        let rest: i64 = v / A33_VARINT_BASE
        chunks.push(lo)
        v = rest
    }
    // Emit chunks high-to-low: high chunks have continuation bit (+64),
    // last (low) chunk has no continuation. Standard LEB128 emits low-first
    // with continuation on all-but-last; we emit low-first here too (simpler
    // streaming decode).
    let nc: i64 = len(chunks)
    let mut out = ""
    let mut i: i64 = 0
    while i < nc {
        let last: bool = i == nc - 1
        let chunk: i64 = chunks[i]
        if last {
            out = out + chr(chunk)
        } else {
            out = out + chr(chunk + A33_VARINT_BASE)
        }
        i = i + 1
    }
    return out
}

// _a33_varint_decode: returns [value, new_p]. value = -1 on parse failure.
fn _a33_varint_decode(stream: string, p: int) -> array {
    let n: i64 = len(stream)
    let mut value: i64 = 0
    let mut multiplier: i64 = 1
    let mut cur_p: i64 = p
    let mut consumed: i64 = 0
    while cur_p < n && consumed < A33_VARINT_MAX_BYTES {
        let b: i64 = ord(stream.substring(cur_p, cur_p + 1))
        let lo: i64 = if b >= A33_VARINT_BASE { b - A33_VARINT_BASE } else { b }
        value = value + lo * multiplier
        cur_p = cur_p + 1
        consumed = consumed + 1
        if b < A33_VARINT_BASE { return [value, cur_p] }    // no continuation
        multiplier = multiplier * A33_VARINT_BASE
    }
    return [-1, p]                              // continuation never terminated
}

// ───────────────── PASS 2: longest-match find ─────────────────
//
// _a33_find_longest_match: scan back through ring (distances 1..max_dist)
// for the longest prefix of upcoming_codes[p..p+max_len] that matches the
// ring content at that distance. Returns [dist, len]; len = 0 means no match
// of length ≥ A33_MATCH_MIN.
//
// Greedy: walks distances 1..max_dist; tracks best (longest, then smallest dist).
// O(max_dist × max_len) worst case. For first-tick selftest small fixtures
// this is acceptable; subsequent-tick LIVE FIRE may swap to hash-chain.
//
// Note: when the matched length exceeds the initial distance, the ring extends
// itself (run-length-encoding behavior in standard LZ77). This is supported
// by _a33_ring_get_back returning bytes that were just emitted forward
// (since encoder pushes bytes into ring as it emits the match).

fn _a33_find_longest_match_codes(ring: array, upcoming_codes: array, p: int, max_dist: int, max_len: int) -> array {
    let n_filled: i64 = ring[2]
    let dist_cap: i64 = if max_dist < n_filled { max_dist } else { n_filled }
    if dist_cap <= 0 { return [0, 0] }
    let n_up: i64 = len(upcoming_codes)
    let len_cap_pre: i64 = n_up - p
    let len_cap: i64 = if len_cap_pre < max_len { len_cap_pre } else { max_len }
    if len_cap < A33_MATCH_MIN { return [0, 0] }
    let mut best_dist: i64 = 0
    let mut best_len: i64 = 0
    let mut d: i64 = 1
    while d <= dist_cap {
        let mut cur_len: i64 = 0
        let mut k: i64 = 0
        while k < len_cap {
            let want: i64 = upcoming_codes[p + k]
            // Within a single match emission the ring is conceptually extended
            // by the bytes already emitted. For find we simulate this by
            // checking if the back-distance is still in range; if k >= d the
            // pattern wraps (RLE-style).
            let back_dist: i64 = d - k
            let mut got: i64 = -1
            if back_dist > 0 {
                got = _a33_ring_get_back(ring, back_dist)
            } else {
                // Wrap: byte that was at p+k-d in upcoming = upcoming[p + (k - d)]
                got = upcoming_codes[p + (k - d)]
            }
            if got < 0 { break }
            if got != want { break }
            cur_len = cur_len + 1
            k = k + 1
        }
        if cur_len >= A33_MATCH_MIN && cur_len > best_len {
            best_dist = d
            best_len = cur_len
        }
        d = d + 1
    }
    return [best_dist, best_len]
}

// Convenience wrapper accepting a string for upcoming.
fn _a33_find_longest_match(ring: array, upcoming: string, p: int, max_dist: int, max_len: int) -> array {
    let codes = _str_to_codes(upcoming)
    return _a33_find_longest_match_codes(ring, codes, p, max_dist, max_len)
}

// ───────────────── PASS 2: session encode / decode ─────────────────
//
// Wire body format (per concatenated stream):
//   sequence of either literal byte (any non-^h byte; if a literal '^' is
//   followed by 'h' it MUST be escaped) OR match reference:
//     ^h ESCAPE      → literal "^h" sequence (chr(94)+chr(104) bytes in source)
//     ^h <vd> <vl>   → match reference at distance vd, length vl
//   where ESCAPE is the byte chr(94) (= '^') immediately following the sigil.
//
// SIGIL DISAMBIGUATION: after detecting ^h, decoder reads ONE byte ahead:
//   - if next byte is 94 ('^') → literal "^h"
//   - else                      → varint dist starts here (continuation byte
//                                  range 64..127 OR final byte range 0..63)
// Byte 94 = '^' = a printable letter that COULD theoretically be a varint
// chunk (94 = 64 + 30 = continuation chunk 30). We disambiguate by NEVER
// emitting a varint whose first byte is exactly 94: distance varint encoding
// avoids the value 30 in the lowest 6-bit chunk by adjusting (encoder reserves
// chunk-30 for escape). This is implementable but adds bookkeeping; for first
// tick we adopt a SIMPLER scheme: escape sequence is the 3-byte triple
// chr(94)+chr(104)+chr(0), where chr(0) is the explicit "literal-sigil"
// marker (0 is NEVER a valid first-byte of a distance varint because distance
// values start at 1 → varint encoding always has at least one chunk and chunk-0
// only appears as a final byte for value-zero, which is reserved/disallowed
// for distances). NO ambiguity.

const A33_ESCAPE_MARKER = 0     // chr(0) following sigil = literal "^h"

fn _a33_emit_match(dist: int, mlen: int) -> string {
    return chr(A33_SIGIL_BYTE_1) + chr(A33_SIGIL_BYTE_2)
        + _a33_varint_encode(dist) + _a33_varint_encode(mlen)
}

// _a33_encode_codes: encode array of byte codes as LZ77 over ring. Returns
// wire body codes array (also a code array; convert at the end).
fn _a33_encode_codes(text_codes: array, seed_codes: array) -> array {
    let n: i64 = len(text_codes)
    let mut ring = _a33_ring_init_from_seed(seed_codes)
    let mut out = []     // wire codes
    let mut p: i64 = 0
    while p < n {
        // Detect literal "^h" prefix in source.
        let cur: i64 = text_codes[p]
        let is_lit_sigil: bool = p + 1 < n
            && cur == A33_SIGIL_BYTE_1
            && text_codes[p + 1] == A33_SIGIL_BYTE_2
        if is_lit_sigil {
            out.push(A33_SIGIL_BYTE_1)
            out.push(A33_SIGIL_BYTE_2)
            out.push(A33_ESCAPE_MARKER)
            ring = _a33_ring_push(ring, A33_SIGIL_BYTE_1)
            ring = _a33_ring_push(ring, A33_SIGIL_BYTE_2)
            p = p + 2
            continue
        }
        // Try longest match at p.
        let dist_cap_pre: i64 = ring[2]
        let dist_cap: i64 = if dist_cap_pre < A33_RING_CAP { dist_cap_pre } else { A33_RING_CAP }
        let len_cap_pre: i64 = n - p
        let len_cap: i64 = if len_cap_pre < A33_MATCH_MAX { len_cap_pre } else { A33_MATCH_MAX }
        let m = _a33_find_longest_match_codes(ring, text_codes, p, dist_cap, len_cap)
        let mdist: i64 = m[0]
        let mlen: i64 = m[1]
        if mlen >= A33_MATCH_MIN && mdist > 0 {
            let ref_str = _a33_emit_match(mdist, mlen)
            let ref_cost: i64 = len(ref_str)
            if mlen > ref_cost {
                // Emit match reference (3+ bytes: sigil + 2 varints)
                let mut ri: i64 = 0
                let n_ref: i64 = len(ref_str)
                while ri < n_ref {
                    out.push(ord(ref_str.substring(ri, ri + 1)))
                    ri = ri + 1
                }
                // Push the matched bytes into ring.
                let mut k: i64 = 0
                while k < mlen {
                    ring = _a33_ring_push(ring, text_codes[p + k])
                    k = k + 1
                }
                p = p + mlen
                continue
            }
        }
        // No worthwhile match → emit literal byte.
        out.push(cur)
        ring = _a33_ring_push(ring, cur)
        p = p + 1
    }
    return out
}

// _a33_decode_codes: inverse of _a33_encode_codes. Given wire body codes +
// seed_codes, reconstruct original byte codes. n_expected = decoded count
// expected.
fn _a33_decode_codes(stream_codes: array, seed_codes: array, n_expected: int) -> array {
    let n: i64 = len(stream_codes)
    let mut ring = _a33_ring_init_from_seed(seed_codes)
    let mut out = []
    let mut p: i64 = 0
    while p < n && len(out) < n_expected {
        let b0: i64 = stream_codes[p]
        let is_sigil: bool = b0 == A33_SIGIL_BYTE_1
            && p + 1 < n
            && stream_codes[p + 1] == A33_SIGIL_BYTE_2
        if !is_sigil {
            out.push(b0)
            ring = _a33_ring_push(ring, b0)
            p = p + 1
            continue
        }
        let after_sigil: i64 = p + 2
        if after_sigil >= n {
            // Truncated — emit literal sigil bytes.
            out.push(A33_SIGIL_BYTE_1)
            out.push(A33_SIGIL_BYTE_2)
            ring = _a33_ring_push(ring, A33_SIGIL_BYTE_1)
            ring = _a33_ring_push(ring, A33_SIGIL_BYTE_2)
            p = p + 2
            continue
        }
        let nb: i64 = stream_codes[after_sigil]
        if nb == A33_ESCAPE_MARKER {
            // Literal "^h" sequence
            out.push(A33_SIGIL_BYTE_1)
            out.push(A33_SIGIL_BYTE_2)
            ring = _a33_ring_push(ring, A33_SIGIL_BYTE_1)
            ring = _a33_ring_push(ring, A33_SIGIL_BYTE_2)
            p = after_sigil + 1
            continue
        }
        // Match reference: rebuild a string segment from stream codes for varint decode.
        // Build a small ASCII-substring containing the varint bytes (codes 0..255).
        // To stay in ASCII-safe range we take exactly the next 2*A33_VARINT_MAX_BYTES
        // codes, build a string via chr(), and decode.
        let segment_len_pre: i64 = 2 * A33_VARINT_MAX_BYTES
        let segment_avail: i64 = n - after_sigil
        let segment_len: i64 = if segment_avail < segment_len_pre { segment_avail } else { segment_len_pre }
        let mut segment = ""
        let mut si: i64 = 0
        while si < segment_len {
            segment = segment + chr(stream_codes[after_sigil + si])
            si = si + 1
        }
        let dr = _a33_varint_decode(segment, 0)
        let dist: i64 = dr[0]
        let q1: i64 = dr[1]
        if dist < 0 {
            // Parse failure — emit sigil bytes literally and move on.
            out.push(A33_SIGIL_BYTE_1)
            out.push(A33_SIGIL_BYTE_2)
            ring = _a33_ring_push(ring, A33_SIGIL_BYTE_1)
            ring = _a33_ring_push(ring, A33_SIGIL_BYTE_2)
            p = p + 2
            continue
        }
        let lr = _a33_varint_decode(segment, q1)
        let mlen: i64 = lr[0]
        let q2: i64 = lr[1]
        if mlen < 0 {
            out.push(A33_SIGIL_BYTE_1)
            out.push(A33_SIGIL_BYTE_2)
            ring = _a33_ring_push(ring, A33_SIGIL_BYTE_1)
            ring = _a33_ring_push(ring, A33_SIGIL_BYTE_2)
            p = p + 2
            continue
        }
        // Walk back-bytes and emit forward. Each emission also pushes into ring.
        let mut k: i64 = 0
        while k < mlen {
            let bb: i64 = _a33_ring_get_back(ring, dist)
            if bb < 0 { return out }
            out.push(bb)
            ring = _a33_ring_push(ring, bb)
            k = k + 1
        }
        p = after_sigil + q2
    }
    return out
}

// a33_session_encode: high-level entry. Concatenates files in array order,
// runs LZ77 over the concatenated stream with seed (string), returns
// [body_string, raw_total_bytes, encoded_bytes, mode_string].
//
// raw 142 D2 try-and-revert: if encoded_len ≥ raw_len → identity (raw concat).
// raw 156: if total < A33_MIN_SESSION_BYTES OR n_files < A33_MIN_FILE_COUNT
//          → identity.
fn a33_session_encode(files_text: array, seed: string) -> array {
    return a33_session_encode_opts(files_text, seed, A33_MIN_SESSION_BYTES)
}

// a33_session_encode_opts: variant exposing min_session_bytes override
// (selftest uses smaller threshold for tractability; production uses
// A33_MIN_SESSION_BYTES default).
fn a33_session_encode_opts(files_text: array, seed: string, min_bytes: int) -> array {
    let n_files: i64 = len(files_text)
    let mut concat = ""
    let mut i: i64 = 0
    while i < n_files {
        concat = concat + files_text[i]
        i = i + 1
    }
    let total: i64 = len(concat)
    if n_files < A33_MIN_FILE_COUNT { return [concat, total, total, "identity_single_file"] }
    if total < min_bytes { return [concat, total, total, "identity_min_bytes"] }
    let text_codes = _str_to_codes(concat)
    let seed_codes = _str_to_codes(seed)
    let body_codes = _a33_encode_codes(text_codes, seed_codes)
    let body_len: i64 = len(body_codes)
    if body_len >= total { return [concat, total, total, "identity_no_gain"] }
    let body_str = _codes_to_str(body_codes)
    return [body_str, total, body_len, "wire_active"]
}

// a33_session_decode: inverse. Given encoded body + seed + expected total,
// reconstruct concatenation. Returns reconstructed string.
fn a33_session_decode(body: string, seed: string, n_expected: int) -> string {
    let body_codes = _str_to_codes(body)
    let seed_codes = _str_to_codes(seed)
    let out_codes = _a33_decode_codes(body_codes, seed_codes, n_expected)
    return _codes_to_str(out_codes)
}

// ───────────────── PASS 3: selftest (5 fixtures) ─────────────────

fn _selftest() -> int {
    println("# hxc_a33_cross_repo_dict selftest (FIRST TICK BUILD — PASS 1+2+2.5+3, PASS 4+5 DEFERRED)")
    let mut pass: i64 = 0
    let mut fail: i64 = 0

    // ─── F1: 3-file mini-session round-trip byte-eq ───
    //   Falsifier: F-A33-3 (round-trip byte-eq) primary first-tick gate.
    //   Construction: 3 files share a long common prefix that should yield
    //   cross-file LZ77 matches in files 2 and 3 referencing file 1 content.
    //   Selftest uses min_bytes=64 (override) for interp tractability;
    //   production A33_MIN_SESSION_BYTES=4096 is verified by F5.
    let prefix1 = "{\"event\":\"witness\",\"phase\":\"P9\",\"a\":1}\n"
    let prefix2 = "{\"event\":\"witness\",\"phase\":\"P9\",\"a\":2}\n"
    let prefix3 = "{\"event\":\"witness\",\"phase\":\"P9\",\"a\":3}\n"
    let mut file1 = ""
    let mut file2 = ""
    let mut file3 = ""
    let mut k1: i64 = 0
    while k1 < 4 {
        file1 = file1 + prefix1
        file2 = file2 + prefix2
        file3 = file3 + prefix3
        k1 = k1 + 1
    }
    let files_f1 = [file1, file2, file3]
    let total_f1: i64 = len(file1) + len(file2) + len(file3)
    let res_f1 = a33_session_encode_opts(files_f1, "", 64)
    let body_f1: string = res_f1[0]
    let raw_f1: i64 = res_f1[1]
    let enc_f1: i64 = res_f1[2]
    let mode_f1: string = res_f1[3]
    let dec_f1 = if mode_f1 == "wire_active" { a33_session_decode(body_f1, "", raw_f1) } else { body_f1 }
    let mut concat_f1 = ""
    let mut k2: i64 = 0
    while k2 < len(files_f1) { concat_f1 = concat_f1 + files_f1[k2]; k2 = k2 + 1 }
    if dec_f1 == concat_f1 && raw_f1 == total_f1 {
        pass = pass + 1
        println("  PASS: F1 3-file mini-session round-trip byte-eq raw=" + to_string(raw_f1)
                + "B enc=" + to_string(enc_f1) + "B mode=" + mode_f1)
    } else {
        fail = fail + 1
        println("  FAIL: F1 3-file round-trip mismatch raw=" + to_string(raw_f1)
                + "B dec_len=" + to_string(len(dec_f1)) + "B mode=" + mode_f1
                + " → F-A33-3 TRIPPED (entire A33 first-tick retracted)")
    }

    // ─── F2: ring buffer push 1024 bytes; verify get_back at known offsets ───
    //   Falsifier: F-A33-3 (correctness gate; ring primitive must be byte-exact).
    //   Selftest uses 1024 pushes (subsequent-tick LIVE FIRE will verify
    //   ring-wrap at A33_RING_CAP=262144 boundary). Growth-phase semantics
    //   exercised here.
    let mut ring2 = _a33_ring_init_empty()
    let push_count: i64 = 1024
    let mut k3: i64 = 0
    while k3 < push_count {
        let raw: i64 = k3 * 17 + 3
        let rmod: i64 = raw - (raw / 127) * 127
        let bb: i64 = if rmod < 1 { rmod + 1 } else { rmod }   // keep ASCII range 1..127
        ring2 = _a33_ring_push(ring2, bb)
        k3 = k3 + 1
    }
    // Last-pushed byte is at distance 1.
    let last_idx: i64 = push_count - 1
    let last_raw: i64 = last_idx * 17 + 3
    let last_mod: i64 = last_raw - (last_raw / 127) * 127
    let last_byte: i64 = if last_mod < 1 { last_mod + 1 } else { last_mod }
    let got_d1: i64 = _a33_ring_get_back(ring2, 1)
    // Distance push_count = first-pushed byte (k3=0 → 3).
    let got_dn: i64 = _a33_ring_get_back(ring2, push_count)
    let first_byte: i64 = 3
    let got_dover: i64 = _a33_ring_get_back(ring2, push_count + 1)
    if got_d1 == last_byte && got_dn == first_byte && got_dover == -1 {
        pass = pass + 1
        println("  PASS: F2 ring buffer 1024-push: get_back(1)=" + to_string(got_d1)
                + " get_back(N)=" + to_string(got_dn)
                + " get_back(N+1)=" + to_string(got_dover) + " (out-of-range -1)")
    } else {
        fail = fail + 1
        println("  FAIL: F2 ring buffer mismatch d1=" + to_string(got_d1) + "/" + to_string(last_byte)
                + " dN=" + to_string(got_dn) + "/" + to_string(first_byte)
                + " dover=" + to_string(got_dover) + " (expected -1)"
                + " → F-A33-3 TRIPPED")
    }

    // ─── F3: varint round-trip on critical integer values ───
    //   Falsifier: F-A33-3 (varint must be lossless).
    //   Test values cover boundary points for 6-bit chunks:
    //     0/63 (1 byte), 64/4095 (2 bytes), 4096/262143 (3 bytes), 262144 (4 bytes).
    // Test values cover production-relevant boundaries (varint values are
    // distances ≥ 1 and lengths ≥ A33_MATCH_MIN=4, so v=0 never appears in
    // production wire). Boundary points: 1/63 (1 byte), 64/4095 (2 bytes),
    // 4096/262143 (3 bytes), 262144 (4 bytes).
    let test_vals = [1, 4, 63, 64, 100, 4095, 4096, 8191, 32767, 262143, 262144]
    let mut all_ok: bool = true
    let mut tv_idx: i64 = 0
    while tv_idx < len(test_vals) {
        let v: i64 = test_vals[tv_idx]
        let enc = _a33_varint_encode(v)
        let dec = _a33_varint_decode(enc, 0)
        let v_back: i64 = dec[0]
        let p_back: i64 = dec[1]
        if v_back != v || p_back != len(enc) {
            all_ok = false
            println("    DEBUG F3 mismatch v=" + to_string(v) + " enc_len=" + to_string(len(enc))
                    + " v_back=" + to_string(v_back) + " p_back=" + to_string(p_back))
        }
        tv_idx = tv_idx + 1
    }
    if all_ok {
        pass = pass + 1
        println("  PASS: F3 varint round-trip on " + to_string(len(test_vals)) + " test values")
    } else {
        fail = fail + 1
        println("  FAIL: F3 varint round-trip mismatch → F-A33-3 TRIPPED")
    }

    // ─── F4: match-find on synthetic ring with known content + upcoming prefix ───
    //   Falsifier: F-A33-3 (match-find correctness).
    //   Build ring containing "ABCDEFGHIJ" (10 bytes pushed). Then upcoming
    //   = "EFGHIJ_extra_garbage" — at p=0, longest match should be "EFGHIJ"
    //   (len=6, distance=6 because 'E' is at back-distance 6).
    let seed4_codes = _str_to_codes("ABCDEFGHIJ")
    let ring4 = _a33_ring_init_from_seed(seed4_codes)
    let upcoming4 = "EFGHIJ_extra_garbage"
    let m4 = _a33_find_longest_match(ring4, upcoming4, 0, 10, A33_MATCH_MAX)
    let m4d: i64 = m4[0]
    let m4l: i64 = m4[1]
    if m4d == 6 && m4l == 6 {
        pass = pass + 1
        println("  PASS: F4 match-find dist=" + to_string(m4d) + " len=" + to_string(m4l))
    } else {
        fail = fail + 1
        println("  FAIL: F4 match-find dist=" + to_string(m4d) + " len=" + to_string(m4l)
                + " expected dist=6 len=6 → F-A33-3 TRIPPED")
    }

    // ─── F5: short-input passthrough (raw 65 + 68) ───
    //   Falsifier: F-A33-3 (idempotency).
    //   Single-file 6-byte input via session_encode → identity (n_files=1
    //   below A33_MIN_FILE_COUNT=2).
    let tiny5 = "abc123"
    let res5 = a33_session_encode([tiny5], "")
    let body5: string = res5[0]
    let mode5: string = res5[3]
    let res5b = a33_session_encode([body5], "")
    let body5b: string = res5b[0]
    if body5 == tiny5 && body5b == tiny5 && mode5 == "identity_single_file" {
        pass = pass + 1
        println("  PASS: F5 short-input passthrough idempotent (raw 65 + 68) mode=" + mode5)
    } else {
        fail = fail + 1
        println("  FAIL: F5 short-input idempotency broken body5_len="
                + to_string(len(body5)) + " mode=" + mode5 + " → F-A33-3 TRIPPED")
    }

    println("Results: " + to_string(pass) + " PASS / " + to_string(fail) + " FAIL")
    println("__HXC_A33_CROSS_REPO_DICT_SELFTEST__ " + (if fail == 0 { "PASS" } else { "FAIL" })
            + " (FIRST TICK: PASS 1+2+2.5+3 only; PASS 4 LIVE FIRE + PASS 5 6-repo sweep DEFERRED)")
    if fail == 0 { return 0 }
    return 1
}

// ───────────────── main CLI ─────────────────

fn main() {
    let av = argv()
    let mut has_selftest = false
    let mut has_encode = false
    let mut has_decode = false
    let mut k: i64 = 0
    while k < len(av) {
        if av[k] == "--selftest" { has_selftest = true }
        if av[k] == "encode" { has_encode = true }
        if av[k] == "decode" { has_decode = true }
        k = k + 1
    }
    if has_selftest { exit(_selftest()) }
    if has_encode || has_decode {
        // Single-file CLI is HONESTLY identity-revert for A33 (raw 156:
        // multi-file SESSION required; single-file invocation reverts per
        // raw 142 D2). This CLI exists for dispatcher harness exposure.
        let mut sub_idx: i64 = 0
        let mut q: i64 = 0
        while q < len(av) {
            if av[q] == "encode" || av[q] == "decode" { sub_idx = q; break }
            q = q + 1
        }
        if sub_idx + 2 >= len(av) {
            eprintln("usage: hexa hxc_a33_cross_repo_dict.hexa <encode|decode> <in> <out>")
            exit(3)
        }
        let in_path = av[sub_idx + 1]
        let out_path = av[sub_idx + 2]
        let txt = read_file(in_path)
        let _w = write_file(out_path, txt)
        println("a33 " + (if has_encode { "encode" } else { "decode" })
                + " mode=identity_single_file_passthrough raw=" + to_string(len(txt))
                + "B note=multi_file_session_required_use_session_api")
        exit(0)
    }
    eprintln("usage: hexa hxc_a33_cross_repo_dict.hexa [--selftest | encode <in> <out> | decode <in> <out> ]")
    exit(3)
}
