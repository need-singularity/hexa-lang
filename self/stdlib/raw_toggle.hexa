// self/stdlib/raw_toggle.hexa — RAW/OWN selectable raw on/off toggle SSOT reader.
//
// Origin: hive 7-bucket closure cycle α (2026-04-30 partial closure deferred land).
// Spec source: hive/packages/coding-agent/hexa/cli_mvp.hexa lines 1771-1923
//   (_raw_toggles_root / _raw_toggles_state_path / _raw_toggles_audit_path /
//    _raw_toggles_load_map / _raw_toggles_effective / _raw_toggles_persist).
//
// Cross-repo: 5 sister repos (hive / nexus / anima / hexa-lang / airgenome /
// n6-architecture) — raw 47 cross-repo universal mandate. Single SSOT reader,
// no per-repo duplication.
//
// SSOT location:
//   <repo>/state/raw_toggles/state.json — current toggle states
//   <repo>/state/raw_toggles/audit.jsonl — append-only audit ledger (raw 77)
//   $HIVE_RAW_TOGGLES_HOME — env override for test isolation
//
// raw 12 silent-error-ban: load failures return empty map (default-on per
// caller's catalog defaultOn).
//
// raw 195 r33: writes via tmp+rename (atomic) — caller must NOT direct-write
// state.json (M5 lint enforces).
//
// Exports:
//   raw_toggle_root() -> string                              — repo root walk-up
//   raw_toggle_state_path() -> string                        — state.json full path
//   raw_toggle_audit_path() -> string                        — audit.jsonl full path
//   raw_toggle_load_map() -> any                             — slug→bool map
//   raw_toggle_effective(slug, default_on) -> bool           — memoized lookup
//   raw_toggle_map_refresh() -> int                          — invalidate cache
//   raw_toggle_persist(slug, enabled, default_on) -> int     — atomic upsert + audit
//
// --selftest:
//   hexa run self/stdlib/raw_toggle.hexa --selftest
//     → emits __RAW_TOGGLE_SELFTEST__ <PASS|FAIL> n=<N>

let mut _raw_toggle_root_cache = ""
let mut _raw_toggle_map_cached = false
let mut _raw_toggle_map = #{}

fn raw_toggle_root() -> string {
    if len(_raw_toggle_root_cache) > 0 { return _raw_toggle_root_cache }
    let override_home = exec("printf %s \"$HIVE_RAW_TOGGLES_HOME\" 2>/dev/null").trim()
    if len(override_home) > 0 {
        let _md_o = exec("mkdir -p '" + override_home + "/state/raw_toggles' 2>&1").trim()
        _raw_toggle_root_cache = override_home + "/state/raw_toggles"
        return _raw_toggle_root_cache
    }
    let pwd = exec("pwd").trim()
    let mut probe = pwd
    let mut safety = 0
    while safety < 12 {
        let _check = exec("test -d '" + probe + "/state/raw_toggles' && echo y || echo n").trim()
        if _check == "y" {
            _raw_toggle_root_cache = probe + "/state/raw_toggles"
            return _raw_toggle_root_cache
        }
        let _check2 = exec("test -d '" + probe + "/.git' && echo y || echo n").trim()
        if _check2 == "y" {
            let _md = exec("mkdir -p '" + probe + "/state/raw_toggles' 2>&1").trim()
            _raw_toggle_root_cache = probe + "/state/raw_toggles"
            return _raw_toggle_root_cache
        }
        let parent = exec("dirname '" + probe + "'").trim()
        if parent == probe || parent == "/" { safety = 100; continue }
        probe = parent
        safety = safety + 1
    }
    let _md_f = exec("mkdir -p /tmp/raw_toggle_fallback/state/raw_toggles 2>&1").trim()
    _raw_toggle_root_cache = "/tmp/raw_toggle_fallback/state/raw_toggles"
    return _raw_toggle_root_cache
}

fn raw_toggle_state_path() -> string {
    return raw_toggle_root() + "/state.json"
}

fn raw_toggle_audit_path() -> string {
    return raw_toggle_root() + "/audit.jsonl"
}

// Lightweight rows[] extractor — avoids json_parse_safe dependency
// (not available in all hexa runtime modes — docker subset).
// Scans body for `"slug":"X"..."enabled":true|false` patterns.
fn raw_toggle_load_map() -> any {
    let path = raw_toggle_state_path()
    let _exists = exec("test -f '" + path + "' && echo y || echo n").trim()
    if _exists != "y" { return #{} }
    let body = exec("cat '" + path + "' 2>/dev/null")
    if len(body) == 0 { return #{} }
    let mut out = #{}
    // Use grep -oE to extract row pairs deterministically.
    let _scan = exec("grep -oE '\"slug\":\"[^\"]+\"[^}]*\"enabled\":(true|false)' '" + path + "' 2>/dev/null").trim()
    if len(_scan) == 0 { return #{} }
    let lines = _scan.split("\n")
    let mut i = 0
    while i < len(lines) {
        let line = to_string(lines[i])
        let s_start = line.index_of("\"slug\":\"")
        if s_start >= 0 {
            let s_after = line.substring(s_start + 8, len(line))
            let s_end = s_after.index_of("\"")
            if s_end > 0 {
                let slug = s_after.substring(0, s_end)
                let e_idx = line.index_of("\"enabled\":")
                if e_idx > 0 {
                    let e_after = line.substring(e_idx + 10, len(line))
                    if e_after.starts_with("true") { out[slug] = true }
                    if e_after.starts_with("false") { out[slug] = false }
                }
            }
        }
        i = i + 1
    }
    return out
}

fn raw_toggle_effective(slug: string, default_on: bool) -> bool {
    if !_raw_toggle_map_cached {
        _raw_toggle_map = raw_toggle_load_map()
        _raw_toggle_map_cached = true
    }
    if has_key(_raw_toggle_map, slug) {
        let v = _raw_toggle_map[slug]
        if type_of(v) == "bool" { return v }
    }
    return default_on
}

fn raw_toggle_map_refresh() -> int {
    _raw_toggle_map = raw_toggle_load_map()
    _raw_toggle_map_cached = true
    return 0
}

// Persist a flip — reuse map-extract + manual rebuild rows[] string.
// Avoids json_stringify dependency for runtime-mode subset compat.
fn raw_toggle_persist(slug: string, enabled: bool, default_on: bool) -> int {
    let path = raw_toggle_state_path()
    let audit_path = raw_toggle_audit_path()
    let cur_map = raw_toggle_load_map()
    let mut new_map = cur_map
    new_map[slug] = enabled
    let ts = utc_iso_now()
    // Build rows[] JSON string manually (preserves slug/enabled/ts/default_on).
    let mut rows_json = ""
    let _slugs = keys(new_map)
    let mut i = 0
    while i < len(_slugs) {
        let _sl = to_string(_slugs[i])
        let _v = new_map[_sl]
        let mut _v_str = "false"
        if _v { _v_str = "true" }
        let mut _def_str = "false"
        if default_on { _def_str = "true" }
        let _row = "{\"raw_id\":0,\"slug\":\"" + _sl + "\",\"enabled\":" + _v_str + ",\"ts\":\"" + ts + "\",\"actor\":\"user-via-cli\",\"default_on\":" + _def_str + "}"
        if i > 0 { rows_json = rows_json + "," }
        rows_json = rows_json + _row
        i = i + 1
    }
    let body_out = "{\"schema\":\"raw_toggles.state_v1\",\"schema_ref\":\"raw 202 + raw 77\",\"rows\":[" + rows_json + "]}"
    let tmp = path + ".tmp.$$"
    let _w = exec("printf '%s' '" + body_out.replace("'", "'\\''") + "' > '" + tmp + "' 2>/dev/null && mv '" + tmp + "' '" + path + "' 2>/dev/null")
    let mut enabled_str = "false"
    if enabled { enabled_str = "true" }
    let mut def_str = "false"
    if default_on { def_str = "true" }
    let audit_line = "{\"ts\":\"" + ts + "\",\"slug\":\"" + slug + "\",\"enabled\":" + enabled_str + ",\"actor\":\"user-via-cli\",\"default_on\":" + def_str + "}"
    let _aw = exec("printf '%s\\n' '" + audit_line.replace("'", "'\\''") + "' >> '" + audit_path + "' 2>/dev/null")
    return 0
}

// ─── --selftest mode ────────────────────────────────────────────
let _av = args()
let mut _selftest = false
let mut _ai = 0
while _ai < len(_av) {
    if to_string(_av[_ai]) == "--selftest" { _selftest = true }
    _ai = _ai + 1
}

if _selftest {
    let _test_dir = "/tmp/raw_toggle_selftest_" + to_string(time_now())
    let _md = exec("mkdir -p '" + _test_dir + "/state/raw_toggles' 2>&1").trim()
    let _setenv = setenv("HIVE_RAW_TOGGLES_HOME", _test_dir)
    _raw_toggle_root_cache = ""
    _raw_toggle_map_cached = false

    let mut _fail = 0
    let mut _n = 0

    // T1: empty load returns empty map
    _n = _n + 1
    let _m1 = raw_toggle_load_map()
    if len(keys(_m1)) != 0 { _fail = _fail + 1; eprintln("[T1] empty load expected #{}, got non-empty") }

    // T2: persist + load round-trip
    _n = _n + 1
    let _r1 = raw_toggle_persist("raw.test_slug", false, true)
    raw_toggle_map_refresh()
    let _eff1 = raw_toggle_effective("raw.test_slug", true)
    if _eff1 != false { _fail = _fail + 1; eprintln("[T2] expected false after persist(false), got true") }

    // T3: default_on fallback
    _n = _n + 1
    let _eff2 = raw_toggle_effective("raw.unknown_slug", true)
    if _eff2 != true { _fail = _fail + 1; eprintln("[T3] expected default_on=true fallback") }

    // T4: persist update existing row
    _n = _n + 1
    let _r2 = raw_toggle_persist("raw.test_slug", true, true)
    raw_toggle_map_refresh()
    let _eff3 = raw_toggle_effective("raw.test_slug", false)
    if _eff3 != true { _fail = _fail + 1; eprintln("[T4] expected true after persist(true), got false") }

    let _cleanup = exec("rm -rf '" + _test_dir + "' 2>&1").trim()

    let _verdict = if _fail == 0 { "PASS" } else { "FAIL" }
    println("__RAW_TOGGLE_SELFTEST__ " + _verdict + " n=" + to_string(_n) + " fail=" + to_string(_fail))
    if _fail > 0 { exit(1) }
    exit(0)
}
