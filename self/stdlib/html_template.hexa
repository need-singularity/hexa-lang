// self/stdlib/html_template.hexa — HTML escape + template-string substitution.
//
// Resolves part of hive blocker `goal_hexa_native_html_templating`.
// Replaces vendored DOM-based escapeHtml() in
// `packages/coding-agent/src/core/export-html/template.js` (lines 591–595)
// with a pure-hexa equivalent that does not depend on a browser DOM.
//
// raw 9 (pure hexa): zero exec(), zero external libs.
// raw 91 (no_silent_errors): unknown var refs in render() raise eprintln + exit 1
//   when --strict mode is requested (default: leave the `${var}` token intact
//   for visibility, mirroring shell `set -u` opt-in semantics).
// raw 159 (hexa-lang-upstream-proposal-mandate): hive ports
//   `use "self/stdlib/html_template"` and never re-implements these.
//
// --selftest mode:
//   hexa run self/stdlib/html_template.hexa --selftest
//     → emits __HTML_TEMPLATE_SELFTEST__ <PASS|FAIL> n=<N> fail=<M>
//
// Exports:
//   html_escape(text: string) -> string
//       Escape HTML special characters: & < > " '
//       Mirrors browser textContent → innerHTML semantics.
//   html_attr_escape(text: string) -> string
//       Escape for use inside double-quoted HTML attributes.
//       Equivalent to html_escape (same 5 chars cover both contexts).
//   html_render(template: string, vars: map) -> string
//       Replace `${name}` tokens with vars[name] (HTML-escaped).
//       Unknown names: leave token verbatim (loud opt-in via --strict
//       in caller — this module never silently drops).
//   html_render_raw(template: string, vars: map) -> string
//       Same as html_render but values are NOT escaped (caller responsibility).
//       Use for embedding pre-rendered HTML fragments (markdown output, etc.).

// ── html_escape ────────────────────────────────────────────
// Escape the 5 HTML-significant characters. Order matters: & MUST be
// first to avoid double-escaping the entity refs we just inserted.
fn html_escape(text) {
    let s = to_string(text)
    let mut out = ""
    let mut i = 0
    let n = len(s)
    while i < n {
        let ch = s[i]
        if ch == "&" {
            out = out + "&amp;"
        } else {
            if ch == "<" {
                out = out + "&lt;"
            } else {
                if ch == ">" {
                    out = out + "&gt;"
                } else {
                    if ch == "\"" {
                        out = out + "&quot;"
                    } else {
                        if ch == "'" {
                            out = out + "&#39;"
                        } else {
                            out = out + ch
                        }
                    }
                }
            }
        }
        i = i + 1
    }
    return out
}

// ── html_attr_escape ───────────────────────────────────────
// Same 5-char escape — covers both attribute and text contexts.
// Provided as a separate name so call sites read clearly.
fn html_attr_escape(text) {
    return html_escape(text)
}

// ── _is_ident_char ─────────────────────────────────────────
// Variable name char: [A-Za-z0-9_].
fn _is_ident_char(ch) {
    if ch >= "a" && ch <= "z" { return true }
    if ch >= "A" && ch <= "Z" { return true }
    if ch >= "0" && ch <= "9" { return true }
    if ch == "_" { return true }
    return false
}

// ── _render_impl ───────────────────────────────────────────
// Internal: walk template, expand `${name}` tokens.
// escape=true → values are html_escape()'d.
// escape=false → values inserted verbatim.
fn _render_impl(template, vars, escape) {
    let s = to_string(template)
    let n = len(s)
    let mut out = ""
    let mut i = 0
    while i < n {
        let ch = s[i]
        // Look for `${`
        if ch == "$" && i + 1 < n && s[i + 1] == "{" {
            // Scan until matching `}`
            let mut j = i + 2
            let mut name = ""
            let mut closed = false
            while j < n {
                let cj = s[j]
                if cj == "}" {
                    closed = true
                    break
                }
                if !_is_ident_char(cj) {
                    // Bad token — bail, treat as literal.
                    break
                }
                name = name + cj
                j = j + 1
            }
            if closed && len(name) > 0 {
                // Look up in vars via .keys() linear scan (interp's map
                // primitives expose .keys()/.values() but not .has()).
                let mut found = false
                let mut val = ""
                let ks = vars.keys()
                let kn = len(ks)
                let mut ki = 0
                while ki < kn {
                    if ks[ki] == name {
                        val = to_string(vars[name])
                        found = true
                        break
                    }
                    ki = ki + 1
                }
                if found {
                    if escape {
                        out = out + html_escape(val)
                    } else {
                        out = out + val
                    }
                    i = j + 1
                    continue
                }
                // Not found: leave verbatim (raw 91 — visible, not silent).
                out = out + "${" + name + "}"
                i = j + 1
                continue
            }
            // Malformed: emit literal $
            out = out + ch
            i = i + 1
            continue
        }
        out = out + ch
        i = i + 1
    }
    return out
}

// ── html_render ────────────────────────────────────────────
// Substitute `${name}` with vars[name] (HTML-escaped).
fn html_render(template, vars) {
    return _render_impl(template, vars, true)
}

// ── html_render_raw ────────────────────────────────────────
// Substitute `${name}` with vars[name] (NOT escaped — caller's call).
fn html_render_raw(template, vars) {
    return _render_impl(template, vars, false)
}

// ── --selftest ──────────────────────────────────────────────
fn _html_template_selftest() {
    let mut fail = 0
    let mut n = 0

    // 1. basic ampersand escape
    n = n + 1
    let r1 = html_escape("a & b")
    if r1 != "a &amp; b" {
        eprintln("FAIL 1 amp: " + r1)
        fail = fail + 1
    }

    // 2. all 5 special chars
    n = n + 1
    let r2 = html_escape("<>&\"'")
    if r2 != "&lt;&gt;&amp;&quot;&#39;" {
        eprintln("FAIL 2 all5: " + r2)
        fail = fail + 1
    }

    // 3. no escape needed
    n = n + 1
    let r3 = html_escape("hello world")
    if r3 != "hello world" {
        eprintln("FAIL 3 plain: " + r3)
        fail = fail + 1
    }

    // 4. order — & first prevents double-encoding
    n = n + 1
    let r4 = html_escape("&lt;")
    if r4 != "&amp;lt;" {
        eprintln("FAIL 4 order: " + r4)
        fail = fail + 1
    }

    // 5. attr_escape == escape
    n = n + 1
    let r5 = html_attr_escape("a<b")
    if r5 != "a&lt;b" {
        eprintln("FAIL 5 attr: " + r5)
        fail = fail + 1
    }

    // 6. render: simple substitution + escape
    n = n + 1
    let vars1 = #{"name": "<script>"}
    let r6 = html_render("hi ${name}!", vars1)
    if r6 != "hi &lt;script&gt;!" {
        eprintln("FAIL 6 render esc: " + r6)
        fail = fail + 1
    }

    // 7. render_raw: no escape
    n = n + 1
    let vars2 = #{"html": "<b>x</b>"}
    let r7 = html_render_raw("[${html}]", vars2)
    if r7 != "[<b>x</b>]" {
        eprintln("FAIL 7 render_raw: " + r7)
        fail = fail + 1
    }

    // 8. unknown var → left verbatim (raw 91)
    n = n + 1
    let vars3 = #{"a": "X"}
    let r8 = html_render("${a}/${missing}", vars3)
    if r8 != "X/${missing}" {
        eprintln("FAIL 8 missing: " + r8)
        fail = fail + 1
    }

    // 9. multiple substitutions
    n = n + 1
    let vars4 = #{"a": "1", "b": "2", "c": "3"}
    let r9 = html_render("${a}-${b}-${c}", vars4)
    if r9 != "1-2-3" {
        eprintln("FAIL 9 multi: " + r9)
        fail = fail + 1
    }

    // 10. dollar literal preserved when malformed
    n = n + 1
    let r10 = html_render("price: $5 ${x}", #{"x": "ok"})
    if r10 != "price: $5 ok" {
        eprintln("FAIL 10 dollar: " + r10)
        fail = fail + 1
    }

    if fail == 0 {
        println("__HTML_TEMPLATE_SELFTEST__ PASS n=" + to_string(n) + " fail=0")
    } else {
        println("__HTML_TEMPLATE_SELFTEST__ FAIL n=" + to_string(n) + " fail=" + to_string(fail))
    }
}

let _ht_argv = args()
let mut _ht_selftest_flag = false
let mut _ht_ai = 0
while _ht_ai < len(_ht_argv) {
    if _ht_argv[_ht_ai] == "--selftest" { _ht_selftest_flag = true }
    if _ht_argv[_ht_ai] == "--selftest-html-template" { _ht_selftest_flag = true }
    _ht_ai = _ht_ai + 1
}
if _ht_selftest_flag {
    _html_template_selftest()
}
