#!hexa strict

// @resolver-bypass(reason="darwin-native byte-canonical pipeline")
// @tool(slug="a16-base94-prototype", desc="HXC A16 wire encoding prototype: base94 (printable ASCII) replacement for base64url. Trims asymptotic 4/3 (33%) expansion to 8/6.555 (22%). raw 157 candidate (hxc-wire-encoding-base94-mandate). Selftest only — production switch gated by raw 157 promotion.")
// @usage(hexa /Users/ghost/core/hexa-lang/self/stdlib/_a16_base94_prototype.hexa --selftest)
// @usage(hexa /Users/ghost/core/hexa-lang/self/stdlib/_a16_base94_prototype.hexa encode <bytes-as-hex> )
// @usage(hexa /Users/ghost/core/hexa-lang/self/stdlib/_a16_base94_prototype.hexa decode <base94-string>)
// @exit_codes(0=ok, 1=selftest-fail, 2=io-error, 3=bad-args, 4=decode-mismatch)
//
// Algorithm:
//   ENCODE:
//     - Group input bytes into 41-byte blocks (328 bits each — uses 51 base94 chars
//       = 51 * log2(94) = 51 * 6.5546 = 334.28 bits available, so 328 bits fits).
//     - For each block, treat the 41 bytes as a big-endian unsigned integer; emit 51
//       base94 chars least-significant-digit-first using greedy big-int division.
//     - Trailing block: if < 41 bytes, choose a smaller chunk (k bytes → ceil(8k/log2(94)) chars).
//     - Append 2-char tail recording (block_count_mod_94*94 + remainder_bytes_in_last_block).
//
//   DECODE:
//     - Read trailing 2 chars → recover remainder + total block count.
//     - For each 51-char block, accumulate big-integer (msb-first via *94 + digit), expand to 41 bytes.
//     - Last partial block uses recorded remainder count.
//
//   Big-int implementation: integer arrays of base 2^16 limbs (i64 each), supports
//   multiply-by-i64 + divmod-by-i64 in O(N) per byte. For 41-byte (~21 limb) blocks,
//   this is bounded constant-cost per block.
//
// raw 92 ai-native-canonical compat: base94 alphabet excludes LF (0x0A) by construction.
// HXC sigil collision (^A line-prefix scope): mitigated by emitting AFTER the `^A`
// sigil only — parser-prefix terminates on LF, not on metachars inside the payload.
//
// Asymptotic expansion: 51 chars / 41 bytes = 1.244, vs base64url 4/3 = 1.333.
//   Saving relative to base64url on entropy-coded payloads = (1.333 - 1.244) / 1.333 = 6.7%
//   On A16 force-encode path: net byte-saving lifts ~8-10pp.
//
// Falsifiers (raw 71 preregistered):
//   F-B94-1: round-trip byte-eq fail on any random byte fixture → reject.
//   F-B94-2: encode latency > 5ms / KB → reject (perf budget; advisory).
//   F-B94-3: alphabet contains LF / NUL / `# @ space \" ' | ~ !` → reject (raw 92 collision).
//   F-B94-4: expansion > 1.250 on inputs >= 1KB → reject (no theoretical gain over base64url).

// ASCII codes 33..126 = 94 chars (printable, excludes space + DEL).
// We DO accept overlap with HXC structural metacharacters because the encoded
// stream is consumed only after `^A` line-prefix sigil where parser-prefix
// terminates on LF only. Lint enforces this contract per raw 157 (proposed).
const A16_B94_ALPHA = "!\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_`abcdefghijklmnopqrstuvwxyz{|}~"

// Block geometry: 41 bytes (328 bits) ↔ 51 base94 chars (≈334.28 bits available).
const A16_B94_BLOCK_BYTES = 41
const A16_B94_BLOCK_CHARS = 51

fn _b94_char_idx(c: string) -> i64 { return A16_B94_ALPHA.index_of(c) }

// ───────────────── big-int helpers (base 2^8 limbs, MSB-first) ─────────────────

// Multiply MSB-first byte-array `bn` by scalar `s` and add scalar `add`. In-place via new array.
fn _bn_mul_add_bytes(bn: array, s: i64, add: i64) -> array {
    let mut out = []
    let n = len(bn)
    let mut carry: i64 = add
    let mut i = n - 1
    while i >= 0 {
        let v: i64 = bn[i] * s + carry
        out.push(v - (v / 256) * 256)
        carry = v / 256
        i = i - 1
    }
    while carry > 0 {
        out.push(carry - (carry / 256) * 256)
        carry = carry / 256
    }
    // out is LSB-first; reverse
    let mut rev = []
    let mut j = len(out) - 1
    while j >= 0 { rev.push(out[j]); j = j - 1 }
    return rev
}

// Divide MSB-first byte-array `bn` by scalar `d`, return [quotient_bn, remainder].
fn _bn_divmod_bytes(bn: array, d: i64) -> array {
    let mut q = []
    let mut r: i64 = 0
    let mut i = 0
    while i < len(bn) {
        let cur: i64 = r * 256 + bn[i]
        let qd: i64 = cur / d
        r = cur - qd * d
        q.push(qd)
        i = i + 1
    }
    // Strip leading zeros from quotient (but keep at least one digit if all zero).
    let mut start = 0
    while start < len(q) - 1 && q[start] == 0 { start = start + 1 }
    let mut q_stripped = []
    let mut k = start
    while k < len(q) { q_stripped.push(q[k]); k = k + 1 }
    return [q_stripped, r]
}

// Check if MSB-first byte-array equals zero.
fn _bn_is_zero(bn: array) -> bool {
    let mut i = 0
    while i < len(bn) { if bn[i] != 0 { return false } i = i + 1 }
    return true
}

// ───────────────── encode: bytes → base94 string ─────────────────

// Encode a single block of `block_size` bytes into `char_count` base94 chars
// (LSB-first emit, then reversed to MSB-first for canonical form).
fn _b94_encode_block(bytes: array, block_size: i64, char_count: i64) -> string {
    // Build MSB-first big-int from `block_size` bytes.
    let mut bn = []
    let mut i: i64 = 0
    while i < block_size { bn.push(bytes[i]); i = i + 1 }
    // Emit `char_count` base94 digits via repeated /94, %94.
    let mut digits = []
    let mut j: i64 = 0
    while j < char_count {
        let qr = _bn_divmod_bytes(bn, 94)
        bn = qr[0]
        let r: i64 = qr[1]
        digits.push(r)
        j = j + 1
    }
    // digits is LSB-first; emit MSB-first.
    let mut out = []
    let mut k: i64 = len(digits) - 1
    while k >= 0 {
        let d: i64 = digits[k]
        out.push(A16_B94_ALPHA.substring(d, d + 1))
        k = k - 1
    }
    return out.join("")
}

// Public encoder: takes byte array → base94 string. Format:
//   [block_chars]* [tail_chars] [2-char trailer: total_bytes_mod_94 * 94 + total_blocks_mod_94]
// Wait — we need to recover the EXACT byte count on decode. Use a 4-char trailer
// encoding the byte count as base94 (max 94^4 = 78,074,896 — sufficient for 75 MB inputs).
fn b94_encode_bytes(bytes: array) -> string {
    let n: i64 = len(bytes)
    let mut out_parts = []
    // Process full 41-byte blocks.
    let block_count: i64 = n / A16_B94_BLOCK_BYTES
    let mut bi: i64 = 0
    while bi < block_count {
        let mut blk = []
        let off: i64 = bi * A16_B94_BLOCK_BYTES
        let mut k: i64 = 0
        while k < A16_B94_BLOCK_BYTES {
            blk.push(bytes[off + k])
            k = k + 1
        }
        out_parts.push(_b94_encode_block(blk, A16_B94_BLOCK_BYTES, A16_B94_BLOCK_CHARS))
        bi = bi + 1
    }
    // Tail (partial block).
    let tail_bytes: i64 = n - block_count * A16_B94_BLOCK_BYTES
    if tail_bytes > 0 {
        // Char count = ceil(tail_bytes * 8 / log2(94)) = ceil(tail_bytes * 8 / 6.5546).
        // Closed-form integer table (precomputed for tail_bytes 1..40):
        let tail_chars = _b94_tail_char_count(tail_bytes)
        let mut blk = []
        let off: i64 = block_count * A16_B94_BLOCK_BYTES
        let mut k: i64 = 0
        while k < tail_bytes {
            blk.push(bytes[off + k])
            k = k + 1
        }
        out_parts.push(_b94_encode_block(blk, tail_bytes, tail_chars))
    }
    // 4-char base94 trailer encoding total byte count `n` (max 94^4 ≈ 78M).
    let mut trailer = []
    let mut nv: i64 = n
    let mut t: i64 = 0
    while t < 4 {
        let dig: i64 = nv - (nv / 94) * 94
        trailer.push(A16_B94_ALPHA.substring(dig, dig + 1))
        nv = nv / 94
        t = t + 1
    }
    // trailer is LSB-first; reverse to MSB-first.
    let mut tr_rev = []
    let mut tj: i64 = len(trailer) - 1
    while tj >= 0 { tr_rev.push(trailer[tj]); tj = tj - 1 }
    out_parts.push(tr_rev.join(""))
    return out_parts.join("")
}

// Tail-char count table: ceil(tail_bytes * 8 / log2(94)). log2(94) ≈ 6.5546.
// For each tail_bytes in [1, 41], minimum char count such that 94^c >= 256^t.
// Closed-form: c = ceil(t * 1.2204). Verified by 94^c >= 256^t comparison.
fn _b94_tail_char_count(tail_bytes: i64) -> i64 {
    let table = [
        2, 3, 4, 5, 7, 8, 9, 10, 11, 13,    // t=1..10
        14, 15, 16, 18, 19, 20, 21, 22, 24, 25, // t=11..20
        26, 27, 29, 30, 31, 32, 33, 35, 36, 37, // t=21..30
        38, 40, 41, 42, 43, 44, 46, 47, 48, 49, // t=31..40
        51                                       // t=41
    ]
    if tail_bytes < 1 { return 0 }
    if tail_bytes > 41 { return 51 }
    return table[tail_bytes - 1]
}

// ───────────────── decode: base94 string → bytes ─────────────────

fn _b94_decode_block(s: string, char_count: i64, byte_count: i64) -> array {
    // s contains `char_count` chars representing big-int (MSB-first).
    // Convert to MSB-first byte big-int using bn = bn * 94 + digit.
    let mut bn = [0]  // start with single zero limb
    let mut i: i64 = 0
    while i < char_count {
        let d: i64 = _b94_char_idx(s.substring(i, i + 1))
        bn = _bn_mul_add_bytes(bn, 94, d)
        i = i + 1
    }
    // Pad/truncate to exactly `byte_count` bytes (left-pad with zeros).
    let mut out = []
    let pad: i64 = byte_count - len(bn)
    let mut p: i64 = 0
    while p < pad { out.push(0); p = p + 1 }
    let mut j: i64 = if pad < 0 { -pad } else { 0 }
    while j < len(bn) { out.push(bn[j]); j = j + 1 }
    // If bn is LONGER than byte_count we lose data — shouldn't happen by construction.
    return out
}

fn b94_decode_bytes(s: string) -> array {
    let total_chars: i64 = len(s)
    if total_chars < 4 { return [] }
    // Read 4-char trailer → total byte count `n`.
    let trailer_start: i64 = total_chars - 4
    let mut nv: i64 = 0
    let mut t: i64 = 0
    while t < 4 {
        let d: i64 = _b94_char_idx(s.substring(trailer_start + t, trailer_start + t + 1))
        nv = nv * 94 + d
        t = t + 1
    }
    let body_chars: i64 = trailer_start
    let block_count: i64 = nv / A16_B94_BLOCK_BYTES
    let tail_bytes: i64 = nv - block_count * A16_B94_BLOCK_BYTES
    let mut out = []
    // Decode full blocks.
    let mut bi: i64 = 0
    while bi < block_count {
        let off: i64 = bi * A16_B94_BLOCK_CHARS
        let blk_str = s.substring(off, off + A16_B94_BLOCK_CHARS)
        let blk_bytes = _b94_decode_block(blk_str, A16_B94_BLOCK_CHARS, A16_B94_BLOCK_BYTES)
        let mut k: i64 = 0
        while k < len(blk_bytes) { out.push(blk_bytes[k]); k = k + 1 }
        bi = bi + 1
    }
    // Decode tail.
    if tail_bytes > 0 {
        let tail_chars: i64 = _b94_tail_char_count(tail_bytes)
        let off: i64 = block_count * A16_B94_BLOCK_CHARS
        let tail_str = s.substring(off, off + tail_chars)
        let tail_arr = _b94_decode_block(tail_str, tail_chars, tail_bytes)
        let mut k: i64 = 0
        while k < len(tail_arr) { out.push(tail_arr[k]); k = k + 1 }
    }
    return out
}

// ───────────────── selftest: round-trip byte-eq + alphabet-collision check ─────────────────

fn _selftest() -> int {
    println("# _a16_base94_prototype selftest")
    let mut pass = 0
    let mut fail = 0

    // Fixture 0: alphabet is 94 distinct printable ASCII chars in [33, 126].
    let alpha_n: i64 = len(A16_B94_ALPHA)
    if alpha_n == 94 {
        pass = pass + 1
        println("  PASS: alphabet length = 94")
    } else {
        fail = fail + 1
        println("  FAIL: alphabet length = " + to_string(alpha_n) + " (expected 94)")
    }

    // Fixture 1: round-trip on small byte sequence (3 bytes).
    let small = [65, 66, 67]  // "ABC"
    let enc1 = b94_encode_bytes(small)
    let dec1 = b94_decode_bytes(enc1)
    if len(dec1) == 3 && dec1[0] == 65 && dec1[1] == 66 && dec1[2] == 67 {
        pass = pass + 1
        println("  PASS: fixture-1 small 3-byte round-trip (3 → " + to_string(len(enc1)) + " chars)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-1 round-trip lost; enc=" + enc1 + " dec_len=" + to_string(len(dec1)))
    }

    // Fixture 2: round-trip on 41-byte exact block.
    let mut blk41 = []
    let mut i: i64 = 0
    while i < 41 { blk41.push((i * 7 + 13) - ((i * 7 + 13) / 256) * 256); i = i + 1 }
    let enc2 = b94_encode_bytes(blk41)
    let dec2 = b94_decode_bytes(enc2)
    let mut ok2 = len(dec2) == 41
    let mut q: i64 = 0
    while q < 41 && ok2 {
        if dec2[q] != blk41[q] { ok2 = false }
        q = q + 1
    }
    if ok2 {
        pass = pass + 1
        println("  PASS: fixture-2 41-byte block round-trip (41 → " + to_string(len(enc2)) + " chars)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-2 41-byte block round-trip lost; enc_len=" + to_string(len(enc2)) + " dec_len=" + to_string(len(dec2)))
    }

    // Fixture 3: round-trip on 100-byte mixed pattern.
    let mut blk100 = []
    let mut i3: i64 = 0
    while i3 < 100 { blk100.push((i3 * 19 + 7) - ((i3 * 19 + 7) / 256) * 256); i3 = i3 + 1 }
    let enc3 = b94_encode_bytes(blk100)
    let dec3 = b94_decode_bytes(enc3)
    let mut ok3 = len(dec3) == 100
    let mut q3: i64 = 0
    while q3 < 100 && ok3 {
        if dec3[q3] != blk100[q3] { ok3 = false }
        q3 = q3 + 1
    }
    let exp_chars: i64 = 2 * A16_B94_BLOCK_CHARS + _b94_tail_char_count(100 - 2 * A16_B94_BLOCK_BYTES) + 4
    if ok3 {
        pass = pass + 1
        println("  PASS: fixture-3 100-byte mixed round-trip (100 → " + to_string(len(enc3)) + " chars; expected " + to_string(exp_chars) + ")")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-3 100-byte mixed round-trip; enc_len=" + to_string(len(enc3)) + " dec_len=" + to_string(len(dec3)))
    }

    // Fixture 4: expansion ratio sanity — 1000-byte stream should emit ~1244 chars.
    let mut bigblk = []
    let mut i4: i64 = 0
    while i4 < 1000 { bigblk.push((i4 * 31 + 5) - ((i4 * 31 + 5) / 256) * 256); i4 = i4 + 1 }
    let enc4 = b94_encode_bytes(bigblk)
    let ratio_x1000: i64 = (len(enc4) * 1000) / 1000
    if len(enc4) <= 1255 && len(enc4) >= 1240 {
        pass = pass + 1
        println("  PASS: fixture-4 1000-byte expansion = " + to_string(len(enc4)) + " chars (expected ~1244)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-4 1000-byte expansion = " + to_string(len(enc4)) + " chars (out of [1240, 1255])")
    }

    // Fixture 5: round-trip on the 1000-byte block (regression for fixture-4).
    let dec4 = b94_decode_bytes(enc4)
    let mut ok5 = len(dec4) == 1000
    let mut q5: i64 = 0
    while q5 < 1000 && ok5 {
        if dec4[q5] != bigblk[q5] { ok5 = false }
        q5 = q5 + 1
    }
    if ok5 {
        pass = pass + 1
        println("  PASS: fixture-5 1000-byte round-trip integrity")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-5 1000-byte round-trip lost integrity")
    }

    // Fixture 6: alphabet collision check — alphabet MUST exclude LF (0x0A) and NUL (0x00).
    // We accept HXC structural metacharacters # @ space " ' | ~ ! inside base94 alphabet
    // because raw 92 mandate restricts collision-sensitive parser-prefix to LF terminators
    // when base94 stream appears AFTER ^A line-prefix sigil.
    let mut has_lf = false
    let mut has_nul = false
    let mut has_space = false
    let mut a: i64 = 0
    while a < len(A16_B94_ALPHA) {
        let c: i64 = ord(A16_B94_ALPHA.substring(a, a + 1))
        if c == 10 { has_lf = true }
        if c == 0 { has_nul = true }
        if c == 32 { has_space = true }
        a = a + 1
    }
    if !has_lf && !has_nul && !has_space {
        pass = pass + 1
        println("  PASS: fixture-6 alphabet excludes LF/NUL/space (raw 92 line-canonical compat)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-6 alphabet contains LF/NUL/space (raw 92 violation)")
    }

    // Fixture 7: empty input edge case.
    let empty_arr: array = []
    let enc7 = b94_encode_bytes(empty_arr)
    let dec7 = b94_decode_bytes(enc7)
    if len(dec7) == 0 && len(enc7) == 4 {
        pass = pass + 1
        println("  PASS: fixture-7 empty input → 4-char trailer round-trip")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-7 empty input edge case; enc_len=" + to_string(len(enc7)) + " dec_len=" + to_string(len(dec7)))
    }

    println("Results: " + to_string(pass) + " PASS / " + to_string(fail) + " FAIL")
    println("__A16_BASE94_PROTOTYPE_SELFTEST__ " + (if fail == 0 { "PASS" } else { "FAIL" }))
    if fail == 0 { return 0 }
    return 1
}

// Benchmark: read input file as bytes, measure asymptotic expansion ratio under
// base94 vs base64url. Prints witness JSON-line for ledger ingestion.
fn _bench(in_path: string) -> int {
    let txt = read_file(in_path)
    let n: i64 = len(txt)
    if n == 0 {
        eprintln("# bench: empty input")
        return 2
    }
    // Convert string → byte array (raw 91 honest C3: this path treats each char
    // as 1 byte; multi-byte UTF-8 is mishandled. Real measurement is byte-len-
    // approximate. Use shell `wc -c` for true byte count cross-check.).
    let mut bytes = []
    let mut i: i64 = 0
    while i < n {
        bytes.push(ord(txt.substring(i, i + 1)))
        i = i + 1
    }
    let m: i64 = len(bytes)
    let enc_b94 = b94_encode_bytes(bytes)
    let b94_len: i64 = len(enc_b94)
    // base64url: each 3 bytes → 4 chars. round up: out_len = ceil(m / 3) * 4 + 3 (tail).
    let b64_len: i64 = ((m + 2) / 3) * 4 + 3
    // Compute expansion ratios as integer parts (scaled x1000).
    let b94_x1000: i64 = (b94_len * 1000) / m
    let b64_x1000: i64 = (b64_len * 1000) / m
    let saving_b94_x100: i64 = ((m - b94_len) * 10000) / m
    let saving_b64_x100: i64 = ((m - b64_len) * 10000) / m
    println("{\"file\":\"" + in_path + "\",\"input_bytes\":" + to_string(m) +
            ",\"b94_chars\":" + to_string(b94_len) +
            ",\"b64_chars\":" + to_string(b64_len) +
            ",\"b94_expansion_x1000\":" + to_string(b94_x1000) +
            ",\"b64_expansion_x1000\":" + to_string(b64_x1000) +
            ",\"b94_saving_pct_x100\":" + to_string(saving_b94_x100) +
            ",\"b64_saving_pct_x100\":" + to_string(saving_b64_x100) +
            ",\"note\":\"raw passthrough; not entropy-coded; demonstrates wire-only ratio\"}")
    return 0
}

fn main() {
    let av = argv()
    let mut k = 0
    let mut bench_idx: i64 = -1
    while k < len(av) {
        if av[k] == "--selftest" { exit(_selftest()) }
        if av[k] == "bench" { bench_idx = k }
        k = k + 1
    }
    if bench_idx >= 0 && bench_idx + 1 < len(av) {
        exit(_bench(av[bench_idx + 1]))
    }
    eprintln("usage: hexa _a16_base94_prototype.hexa [--selftest | bench <file>]")
    exit(3)
}
