// self/stdlib/proc.hexa — popen_lines / popen_lines_with_status wrappers
//
// @module(slug="stdlib-proc", desc="line-oriented subprocess stdout capture")
// @usage(use "self/stdlib/proc"; for line in popen_lines("git log --oneline") { ... })
//
// RFC-001 (P0 BLOCKER) — popen_lines() / process_spawn() streaming subprocess
//   proposals/rfc_001_popen_lines.md
//
// raw#9 hexa-only-strict — wrapper over existing exec_with_status() builtin.
//   No C runtime change, no self-host fixpoint risk (raw#18). Cost: collects
//   entire stdout before splitting (NOT true incremental streaming).
//
// raw#10 honest C3 (concrete-clear-conservative): this implementation
//   FULLY CAPTURES the subprocess stdout into a single buffer and THEN
//   splits on '\n'. It is a strict superset of `exec(cmd) + manual split`
//   ergonomics. The RFC-001 streaming-iterator form (per-line emit while
//   subprocess is still alive) is NOT implemented here; that requires a
//   new C builtin (process_spawn + Process handle + stdout.read_line),
//   tracked as a separate cycle. See RFC-001 "Falsifier" — the streaming
//   sub-second-latency requirement is NOT satisfied by this wrapper.
//
// raw#159 hexa-lang upstream-proposal-mandate — anima-eeg gap-1 ergonomic
//   close: hexa scripts can `for line in popen_lines(...)` instead of the
//   `let body = exec(...); for line in split(body, "\n")` boilerplate.
//
// Exports:
//   popen_lines(cmd: string) -> [string]
//     run cmd via /bin/sh -c, capture stdout, return lines split on '\n'.
//     Trailing empty line (from typical `\n`-terminated shell output) is
//     stripped so `popen_lines("echo a\necho b")` returns ["a","b"], not
//     ["a","b",""]. exit code is dropped.
//
//   popen_lines_with_status(cmd: string) -> [any]
//     same but returns [lines: [string], rc: int]. Mirrors the
//     exec_with_status builtin shape.

// ── popen_lines_with_status ──────────────────────────────────────
//
// Returns [[lines...], rc]. The lines array is the stdout split on '\n'
// with the conventional trailing empty element stripped. The rc is the
// child's WEXITSTATUS (already extracted by exec_with_status).
//
// Rationale for stripping trailing empty: shell commands almost always
// terminate output with a final '\n'. Naive split("a\nb\n", "\n") yields
// ["a","b",""] — the trailing "" is an artifact of the terminator, not
// a real empty line emitted by the program. Programs that genuinely
// emit a blank final line are vanishingly rare in shell-pipeline use
// cases (find / grep / git log / ls). Callers needing the raw trailing
// element can drop down to exec_with_status + split themselves.
fn popen_lines_with_status(cmd: string) -> [any] {
    let result = exec_with_status(cmd)
    let body = to_string(result[0])
    let rc = result[1]
    let parts = split(body, "\n")
    // Strip exactly one trailing empty element (the '\n' terminator
    // artifact). Do NOT loop — preserving deliberate intra-output blank
    // lines is the correct default for line-oriented tools.
    let n = len(parts)
    if n > 0 && parts[n - 1] == "" {
        let mut trimmed = []
        let mut i = 0
        while i < n - 1 {
            trimmed.push(parts[i])
            i = i + 1
        }
        return [trimmed, rc]
    }
    return [parts, rc]
}

// ── popen_lines ───────────────────────────────────────────────────
//
// Convenience: drop the rc, return only the lines array. Use this when
// you only care about the output (find / grep / ls / git log style).
// For commands where rc matters (`test -f`, `command -v`), prefer
// popen_lines_with_status.
fn popen_lines(cmd: string) -> [string] {
    let pair = popen_lines_with_status(cmd)
    let lines = pair[0]
    return lines
}

// ── synchronous stdin-pipe + JSON bridge (P0 — qmirror substrate) ──
//
// Source: anima/docs/hexa_lang_attr_review_for_qmirror_2026_05_03.md §5.1, §5.2
//
// PROBLEM (qmirror engine_aer ↔ aer_runner.py)
//   Hexa's builtin `exec(cmd)` is synchronous popen but provides NO
//   stdin pipe. To send a QASM3 string (or any payload >256B) to a
//   python subprocess today the caller must hand-build a heredoc inside
//   the shell string — `exec("python3 ... <<'EOF'\n" + qasm + "\nEOF")`
//   — which (a) blows past macOS ARG_MAX (~256KB) on big circuits,
//   (b) requires escaping every single quote / dollar sign in payload,
//   (c) leaks the payload into `ps` output (security smell).
//
// FIX (additive, no runtime.c change)
//   1. proc_run_with_stdin(cmd, stdin_str) — spill stdin_str to a temp
//      file, exec `cmd < tmpfile`, unlink tmp. Capacity = filesystem.
//   2. proc_run_json_bridge(cmd, payload) — json_stringify payload,
//      pipe via #1, json_parse stdout. Returns hexa map. On parse
//      failure returns {"ok": 0, "error": "..."} — Result-style stays
//      compatible with nexus convention (`ok: int + message: str`).
//
// Breaking risk: 0. Both functions are new symbols; popen_lines /
// popen_lines_with_status / _selftest_main untouched.
//
// Caveats (raw#91):
//   · Temp-file write is not atomic against concurrent invokers; the
//     nonce uses now_epoch + len(stdin_str) which collides only if two
//     calls in the same wall-clock second happen with identical-length
//     payloads. For nexus single-threaded sampler/engine flow this is
//     adequate; a future C-level `popen3` builtin can supplant.
//   · stdout is captured via `2>&1` — caller cannot distinguish stderr
//     from stdout. Acceptable for JSON-bridge contract (python helpers
//     write JSON to stdout, log to stderr, but the bridge expects stdout
//     to BE the JSON; mixing is the helper's bug, not the wrapper's).
//   · Returns the entire output as a single string — no streaming.
//     Same trade-off as the existing `exec()` builtin.

// _proc_bridge_now_epoch — local helper (avoid name collision with the
// other stdlib/proc.hexa supervised-spawn module's _now_epoch).
fn _proc_bridge_now_epoch() -> int {
    return to_int(to_string(exec("date +%s")).trim())
}

// proc_run_with_stdin(cmd, stdin_str) -> string
//
// Run `cmd` synchronously with `stdin_str` piped on STDIN. Returns
// stdout (merged with stderr via `2>&1`).
//
// Implementation: spill stdin_str to /tmp/hexa_proc_stdin_<nonce>.txt,
// exec `cmd < tmpfile`, unlink tmp. Sidesteps ARG_MAX + shell escaping.
fn proc_run_with_stdin(cmd: string, stdin_str: string) -> string {
    let nonce = to_string(_proc_bridge_now_epoch()) + "_" + to_string(len(stdin_str))
    let tmp = "/tmp/hexa_proc_stdin_" + nonce + ".txt"
    write_file(tmp, stdin_str)
    let out = to_string(exec(cmd + " < '" + tmp + "' 2>&1"))
    let _drop = exec("rm -f '" + tmp + "'")
    return out
}

// proc_run_json_bridge(cmd, payload) -> map
//
// Serialize `payload` (any hexa value json_stringify accepts) to JSON,
// pipe to `cmd` via proc_run_with_stdin, parse stdout as JSON. Returns
// the parsed map.
//
// Error contract (parse failure or non-map result):
//   {"ok": 0, "error": "bridge: <reason>; got <head-of-stdout>"}
// Caller can gate on `result["ok"] == 0` without crashing on missing
// keys — has_key + index, the json_object_get_int idiom.
//
// On success the returned map is whatever the python helper emitted;
// the wrapper does NOT inject `ok: 1` (helpers commonly include their
// own ok / status field already).
fn proc_run_json_bridge(cmd: string, payload) {
    let stdin_str = json_stringify(payload)
    let stdout = proc_run_with_stdin(cmd, stdin_str)
    // Pre-flight: locate the LAST JSON object in stdout. Some hexa
    // wrappers prepend `[GATE]`-style log lines before the python
    // helper's actual JSON output, and the runtime json_parse panics
    // with "to_int: not an integer" on bare-text strings returned
    // from exec() (exec-output tag-vs-fresh-string runtime quirk).
    // We slice to the last `{...}` substring before parsing — common
    // contract: helper writes JSON last, log lines first.
    let head_len = if len(stdout) < 200 { len(stdout) } else { 200 }
    let head = stdout.substring(0, head_len)
    let last_open = stdout.last_index_of("{")
    let last_close = stdout.last_index_of("}")
    if last_open < 0 || last_close < 0 || last_close < last_open {
        let err = json_parse("{}")
        err["ok"] = 0
        err["error"] = "bridge: stdout has no JSON object; got " + head
        return err
    }
    let candidate = stdout.substring(last_open, last_close + 1)
    let parsed = json_parse(candidate)
    if type_of(parsed) != "map" {
        let err = json_parse("{}")
        err["ok"] = 0
        err["error"] = "bridge: stdout was not JSON map; got " + head
        return err
    }
    return parsed
}

// ── --selftest dispatcher ─────────────────────────────────────────
//
// `hexa run self/stdlib/proc.hexa --selftest` exercises the synthetic
// cases from RFC-001:
//   1. multi-line: echo a; echo b; echo c → ["a","b","c"]
//   2. empty:      true                   → []
//   3. single:     echo only              → ["only"]
//   4. status:     false                  → ([], rc!=0)
//   5. ordering:   printf "x\ny\nz\n"     → ["x","y","z"]
//
// Emits __PROC_SELFTEST__ <PASS|FAIL> n=<N> fail=<M> for harness pickup.
fn _selftest_main() {
    let mut n = 0
    let mut fail = 0

    // Case 1: three-line output
    n = n + 1
    let r1 = popen_lines("echo a; echo b; echo c")
    if len(r1) != 3 || r1[0] != "a" || r1[1] != "b" || r1[2] != "c" {
        fail = fail + 1
        eprintln("[proc.selftest] FAIL case1: " + to_string(r1))
    }

    // Case 2: no output
    n = n + 1
    let r2 = popen_lines("true")
    if len(r2) != 0 {
        fail = fail + 1
        eprintln("[proc.selftest] FAIL case2: expected [], got " + to_string(r2))
    }

    // Case 3: single line
    n = n + 1
    let r3 = popen_lines("echo only")
    if len(r3) != 1 || r3[0] != "only" {
        fail = fail + 1
        eprintln("[proc.selftest] FAIL case3: " + to_string(r3))
    }

    // Case 4: status return, non-zero rc
    n = n + 1
    let r4 = popen_lines_with_status("false")
    let r4_lines = r4[0]
    let r4_rc = r4[1]
    if len(r4_lines) != 0 || r4_rc == 0 {
        fail = fail + 1
        eprintln("[proc.selftest] FAIL case4: lines=" + to_string(r4_lines) + " rc=" + to_string(r4_rc))
    }

    // Case 5: ordering preserved through printf
    n = n + 1
    let r5 = popen_lines("printf 'x\\ny\\nz\\n'")
    if len(r5) != 3 || r5[0] != "x" || r5[1] != "y" || r5[2] != "z" {
        fail = fail + 1
        eprintln("[proc.selftest] FAIL case5: " + to_string(r5))
    }

    let status = if fail == 0 { "PASS" } else { "FAIL" }
    println("__PROC_SELFTEST__ " + status + " n=" + to_string(n) + " fail=" + to_string(fail))
    if fail != 0 { exit(1) }
}

// argv-tail dispatch — only run selftest when explicitly requested so the
// module remains import-safe (`use "self/stdlib/proc"` does not execute
// any side-effect on import). Scans the full argv because args() prefix
// shape varies by runtime (Mac: [bin, bin, ...]; Linux: [bin, "run",
// script.hexa, ...]) — see self/stdlib/argv_skip.hexa for the rationale.
let __proc_args = args()
let mut __proc_selftest = false
let mut __proc_i = 0
while __proc_i < len(__proc_args) {
    if __proc_args[__proc_i] == "--selftest" {
        __proc_selftest = true
        break
    }
    __proc_i = __proc_i + 1
}
if __proc_selftest {
    _selftest_main()
}
