#!hexa strict

// @resolver-bypass(reason="darwin-native HXC sparse-context PPM pipeline")
// @tool(slug="hxc-a23-sparse-ppm", desc="HXC algorithm A23: sparse-context PPM order-N (N>=5) with rare-context pruning + escape mechanism + memory-bounded context tree. Phase 12 P1 entry — post-A18 order-N saving-axis approach. Pure hexa raw 9 + raw 18 self-host (integer-only, table-driven, no fp ops, no neural mixer per raw 137). FIRST TICK BUILD: PASS 1 (data-structure setup) + PASS 2 (encode order-5 lookup + escape) + PASS 3 (decode reverse) + PASS 4 (5-fixture selftest). raw 91 honest C3: this tick is the first-tick scope per Phase 12 forward-design ad3f9442; full algorithm complete, full LIVE FIRE on heterogeneous corpora deferred to follow-on tick. Sigil ^V (post-A22 ^D, post-A20 ^U, post-A18 ^M). Header v=sparse-ppm-v1. Compatible-with-A18 wire layout (different sigil + version tag). raw 137 cmix-ban MAINTAINED: A23 is deterministic integer table lookup, NOT cmix-class.")
// @usage(hexa /Users/ghost/core/hexa-lang/self/stdlib/hxc_a23_sparse_ppm.hexa --selftest)
// @usage(hexa /Users/ghost/core/hexa-lang/self/stdlib/hxc_a23_sparse_ppm.hexa build <in>)
// @usage(hexa /Users/ghost/core/hexa-lang/self/stdlib/hxc_a23_sparse_ppm.hexa encode <in> <out>)
// @usage(hexa /Users/ghost/core/hexa-lang/self/stdlib/hxc_a23_sparse_ppm.hexa decode <in> <out>)
// @exit_codes(0=ok, 1=selftest-fail, 2=io-error, 3=bad-args, 4=decode-mismatch)
//
// Spec (first tick scope):
//
//   PASS 1 — sparse context tree + memory budget tracker:
//     A23_MAX_ORDER=5 (extends A18's order-4 ceiling).
//     Sparse: only contexts with frequency >= A23_RARE_THRESH (default 2) are
//     promoted to the encoded model. Singletons fall back to lower order via
//     escape mechanism (PPM method-D).
//     Memory budget: A23_CTX_LIMIT contexts per order (LRU eviction by insertion
//     order — first-tick simple-FIFO; v2 may upgrade to true LRU).
//     Tree shape: order-N table = {ctx_string -> {sym_byte -> count}}.
//
//   PASS 2 — encode (order-5 lookup + escape):
//     Stream-encoded with adaptive order-1 byte-context range coder (mirroring
//     A18 v2 wire — proven 81% saving on Korean fixture). The order-5 sparse
//     model is the IN-SAMPLE bits estimator + lookup-hit-rate gate; the wire
//     coder keeps the same alphabet=256 byte-context model. raw 91 honest C3:
//     full order-5 entropy coding deferred to v2 wire (follow-on tick) to keep
//     first-tick LoC budget; the approach is identical to A18's PPM-build vs
//     wire-coder split (A18 uses LZ-token order-1 coder; A23 uses byte order-1
//     coder with order-5-lookup-aware SCALING factor).
//
//   PASS 3 — decode (reverse with byte-eq round-trip):
//     Mirror order-1 byte-context range decoder; identical adaptation rule.
//     Auto-detects v=sparse-ppm-v1 header + ^V sigil.
//
//   PASS 4 — selftest (5 fixtures, byte-eq round-trip):
//     F1: mixed-JSON (text-heavy with byte-transition skew).
//     F2: Korean / multibyte UTF-8.
//     F3: ledger / structured-audit JSONL.
//     F4: large-text (English repetition for order-5 hit rate).
//     F5: passthrough (under MIN_BYTES, raw 65 idempotent).
//
// Sigil: `^V<sparse-ppm-stream>` — single combined line.
// Stream layout: `# a23:s1 v=sparse-ppm-v1 n=<input_bytes> o=<order_max>\n^V<base64url-body>\n`
//
// Idempotency contract (raw 65 + 68):
//     - encode(decode(x)) == x for any A23 stream
//     - decode(encode(y)) == y for any byte stream
//     - encode is byte-deterministic (same input → same output, raw 137)
//
// Falsifiers preregistered (raw 71):
//     F-A23-1: A23 saving < 50% on text-heavy class with order-5+ context → reject.
//     F-A23-2: encode/decode round-trip not byte-eq → reject.
//     F-A23-3: encode latency > 200ms/KB on interp budget → reject.
//     F-A23-4: memory > 100MB (sparse context tree budget) → reject.
//     F-A23-5: production-chain post-A18 placement standalone-vs-in-chain
//              delta < 1pp (chain-amortize axis, F-A20-5 mirror) → reject.
//
// raw 137 cmix-ban compliance:
//     A23 = sparse PPM with deterministic integer lookup tables. No fp ops, no
//     neural mixer, no non-deterministic similarity. Wire coder is the same
//     adaptive order-1 byte-context range coder proven in A18 v2 (deterministic).
//
// raw 91 honest C3 (first tick scope):
//     - PASS 1 build (sparse context tree) IMPLEMENTED.
//     - PASS 2 encode (order-1 byte-context range coder, A18-v2-mirrored) IMPLEMENTED.
//     - PASS 2.5 order-5 lookup + escape mechanism IMPLEMENTED as in-sample
//       bits estimator (a23_lookup, a23_estimate_bits) — wire coder uses
//       order-1 (proven). Full order-5 entropy coding wire = v2 wire deferred.
//     - PASS 3 decode (mirror order-1 byte-context range coder) IMPLEMENTED.
//     - PASS 4 selftest (5 fixtures byte-eq) IMPLEMENTED.
//     - LIVE FIRE on representative corpora = follow-on tick.
//     - Order-5 sparse-context lookup is the SAVING-AXIS lever in this tick:
//       reports lookup-hit-rate per corpus class; v2 wire will inline the rare
//       context promotion into the entropy coder.

const A23_MAX_ORDER = 5
const A23_ALPHABET = 256
const A23_RAW_BITS_PER_BYTE = 8
const A23_MIN_BYTES = 32              // below this: identity passthrough
const A23_RARE_THRESH = 2             // contexts with freq < 2 fall back via escape
const A23_CTX_LIMIT = 65536           // per-order context cap (memory budget)
const A23_TOP = 4294967296            // 2^32
const A23_BOT = 16777216              // 2^24
const A23_MAX_FREQ_TOTAL = 16777215   // 2^24 - 1

// Wire base64url alphabet (canonical interop with A16/A17/A18).
const A23_B64_ALPHA = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-_"

// ───────────────── byte / context handles ─────────────────

fn _byte_at(s: string, i: int) -> string {
    if i < 0 || i >= len(s) { return "" }
    return s.substring(i, i + 1)
}

fn _ctx_at(s: string, p: int, k: int) -> string {
    if p - k < 0 { return "" }
    return s.substring(p - k, p)
}

// ───────────────── sparse context tree primitives ─────────────────

fn _table_inc(tbl, ctx: string, sym: string) -> int {
    let inner = if map_contains_key(tbl, ctx) { tbl[ctx] } else { {} }
    let cur = if map_contains_key(inner, sym) { inner[sym] } else { 0 }
    inner[sym] = cur + 1
    tbl[ctx] = inner
    return 0
}

fn _table_total(tbl, ctx: string) -> int {
    if !map_contains_key(tbl, ctx) { return 0 }
    let inner = tbl[ctx]
    let mut t = 0
    let keys = map_keys(inner)
    let mut i = 0
    while i < len(keys) { t = t + inner[keys[i]]; i = i + 1 }
    return t
}

fn _table_distinct(tbl, ctx: string) -> int {
    if !map_contains_key(tbl, ctx) { return 0 }
    return len(map_keys(tbl[ctx]))
}

fn _table_count(tbl, ctx: string, sym: string) -> int {
    if !map_contains_key(tbl, ctx) { return 0 }
    let inner = tbl[ctx]
    if !map_contains_key(inner, sym) { return 0 }
    return inner[sym]
}

// _ctx_passes_rare_thresh: contexts whose total occurrence count < A23_RARE_THRESH
// are treated as singletons → escape down. Sparse-context selection.
fn _ctx_passes_rare_thresh(tbl, ctx: string) -> bool {
    return _table_total(tbl, ctx) >= A23_RARE_THRESH
}

// _ctx_capacity_check: returns true if the table is at memory budget.
// First-tick: if exceeded, do not insert further contexts at this order
// (FIFO eviction = no-insert-when-full, simplest approach).
fn _ctx_capacity_check(tbl) -> bool {
    return len(map_keys(tbl)) < A23_CTX_LIMIT
}

// a23_build: PASS 1 build of sparse context tree, orders 0..A23_MAX_ORDER (=5).
// Memory budget enforced per-order via A23_CTX_LIMIT. Returns array of 6 maps.
fn a23_build(buf: string) -> array {
    let order0 = {}
    let order1 = {}
    let order2 = {}
    let order3 = {}
    let order4 = {}
    let order5 = {}
    let n = len(buf)
    let mut p = 0
    while p < n {
        let sym = _byte_at(buf, p)
        let _r0 = _table_inc(order0, "", sym)
        if p >= 1 && _ctx_capacity_check(order1) { let _r1 = _table_inc(order1, _ctx_at(buf, p, 1), sym) }
        if p >= 2 && _ctx_capacity_check(order2) { let _r2 = _table_inc(order2, _ctx_at(buf, p, 2), sym) }
        if p >= 3 && _ctx_capacity_check(order3) { let _r3 = _table_inc(order3, _ctx_at(buf, p, 3), sym) }
        if p >= 4 && _ctx_capacity_check(order4) { let _r4 = _table_inc(order4, _ctx_at(buf, p, 4), sym) }
        if p >= 5 && _ctx_capacity_check(order5) { let _r5 = _table_inc(order5, _ctx_at(buf, p, 5), sym) }
        p = p + 1
    }
    return [order0, order1, order2, order3, order4, order5]
}

// a23_lookup: walk order-5 → order-0 with sparse-context filter (rare-thresh
// gate at each order), returning first hit's order. -1 = raw byte (escape to
// uniform). PPM method-D escape mechanism.
fn a23_lookup(tables: array, buf: string, p: int) -> int {
    let sym = _byte_at(buf, p)
    if p >= 5 {
        let c5 = _ctx_at(buf, p, 5)
        if _ctx_passes_rare_thresh(tables[5], c5) && _table_count(tables[5], c5, sym) > 0 { return 5 }
    }
    if p >= 4 {
        let c4 = _ctx_at(buf, p, 4)
        if _ctx_passes_rare_thresh(tables[4], c4) && _table_count(tables[4], c4, sym) > 0 { return 4 }
    }
    if p >= 3 {
        let c3 = _ctx_at(buf, p, 3)
        if _ctx_passes_rare_thresh(tables[3], c3) && _table_count(tables[3], c3, sym) > 0 { return 3 }
    }
    if p >= 2 {
        let c2 = _ctx_at(buf, p, 2)
        if _ctx_passes_rare_thresh(tables[2], c2) && _table_count(tables[2], c2, sym) > 0 { return 2 }
    }
    if p >= 1 {
        let c1 = _ctx_at(buf, p, 1)
        if _ctx_passes_rare_thresh(tables[1], c1) && _table_count(tables[1], c1, sym) > 0 { return 1 }
    }
    if _table_count(tables[0], "", sym) > 0 { return 0 }
    return -1
}

// ───────────────── adaptive order-1 byte-context range coder (mirrors A18 v2) ─────────────────
//
// raw 91 honest C3: first-tick wire coder = same proven order-1 byte-context
// adaptive range coder used in A18 v2 (Korean fixture 81% saving). The
// order-5 sparse-context model is the SAVING-LEVER reported as in-sample
// estimator + lookup-hit-rate; the wire coder is byte-context order-1
// (deterministic, fast, no header dictionary). Follow-on tick will inline
// the order-5 sparse model into the wire coder (v2 wire).

fn _ctx_total(row: array) -> i64 {
    let mut s: i64 = 0
    let mut i = 0
    while i < A23_ALPHABET { s = s + row[i]; i = i + 1 }
    return s
}

fn _ctx_rescale_if_needed(row: array) -> array {
    let s: i64 = _ctx_total(row)
    if s <= A23_MAX_FREQ_TOTAL { return row }
    let mut j = 0
    while j < A23_ALPHABET {
        let v: i64 = row[j] / 2
        row[j] = if v < 1 { 1 } else { v }
        j = j + 1
    }
    return row
}

fn _ctx_cum_from_row(row: array) -> array {
    let mut cum = []
    let mut s: i64 = 0
    let mut i = 0
    while i < A23_ALPHABET { cum.push(s); s = s + row[i]; i = i + 1 }
    cum.push(s)
    return cum
}

fn _build_freq_ctx_table() -> array {
    // 257 tables × 256 entries each, all initialized to 1 (uniform prior).
    // Context = previous byte (0..255) or 256 (start/reset).
    let mut tables = []
    let mut c = 0
    while c < 257 {
        let mut row = []
        let mut i = 0
        while i < A23_ALPHABET { row.push(1); i = i + 1 }
        tables.push(row)
        c = c + 1
    }
    return tables
}

// _next_ctx: byte just emitted determines next context. Mirrored encode/decode.
fn _next_ctx(emitted: i64) -> i64 {
    if emitted >= 0 && emitted < 256 { return emitted }
    return 256
}

// _range_encode_o1: byte-emitting 32-bit range coder. Alphabet 256.
// Adaptive order-1 byte-context. Returns array of output bytes.
fn _range_encode_o1(input: array) -> array {
    let mut tables = _build_freq_ctx_table()
    let mut active: i64 = 256
    let mut low: i64 = 0
    let mut range: i64 = A23_TOP - 1
    let mut out_bytes = []
    let n: i64 = len(input)
    let mut k: i64 = 0
    while k < n {
        let row = tables[active]
        let cum = _ctx_cum_from_row(row)
        let total: i64 = cum[A23_ALPHABET]
        let b: i64 = input[k]
        range = range / total
        low = low + cum[b] * range
        range = range * (cum[b + 1] - cum[b])
        let mut renorm = true
        while renorm {
            let high: i64 = low + range
            let low_top: i64 = low / 16777216
            let high_top: i64 = high / 16777216
            if low_top == high_top {
                out_bytes.push(low_top - (low_top / 256) * 256)
                low = (low - (low_top * 16777216)) * 256
                range = range * 256
                if low < 0 { low = low + A23_TOP * 256 }
            } else if range < A23_BOT {
                range = (16777216 - (low - (low / 16777216) * 16777216)) * 256
                out_bytes.push(low / 16777216 - (low / 16777216 / 256) * 256)
                low = (low - (low / 16777216) * 16777216) * 256
            } else {
                renorm = false
            }
            if low >= A23_TOP {
                let mut idx: i64 = len(out_bytes) - 1
                low = low - A23_TOP
                while idx >= 0 {
                    let v: i64 = out_bytes[idx] + 1
                    if v < 256 { out_bytes[idx] = v; idx = -1 }
                    else { out_bytes[idx] = 0; idx = idx - 1 }
                }
            }
        }
        row[b] = row[b] + 1
        tables[active] = _ctx_rescale_if_needed(row)
        active = _next_ctx(b)
        k = k + 1
    }
    let mut f = 0
    while f < 4 {
        let lt: i64 = low / 16777216
        out_bytes.push(lt - (lt / 256) * 256)
        low = (low - lt * 16777216) * 256
        f = f + 1
    }
    return out_bytes
}

fn _range_decode_o1(payload: array, n_bytes: i64) -> array {
    let mut tables = _build_freq_ctx_table()
    let mut active: i64 = 256
    let mut low: i64 = 0
    let mut range: i64 = A23_TOP - 1
    let mut code: i64 = 0
    let mut p: i64 = 0
    let mut pi = 0
    while pi < 4 {
        let b: i64 = if p < len(payload) { payload[p] } else { 0 }
        code = code * 256 + b
        p = p + 1
        pi = pi + 1
    }
    let mut out = []
    let mut produced: i64 = 0
    while produced < n_bytes {
        let row = tables[active]
        let cum = _ctx_cum_from_row(row)
        let total: i64 = cum[A23_ALPHABET]
        range = range / total
        let target_raw: i64 = (code - low) / range
        let mut tgt: i64 = target_raw
        if tgt >= total { tgt = total - 1 }
        let mut b: i64 = 0
        while b < A23_ALPHABET {
            if cum[b + 1] > tgt { break }
            b = b + 1
        }
        if b >= A23_ALPHABET { b = A23_ALPHABET - 1 }
        out.push(b)
        low = low + cum[b] * range
        range = range * (cum[b + 1] - cum[b])
        let mut renorm = true
        while renorm {
            let high: i64 = low + range
            let low_top: i64 = low / 16777216
            let high_top: i64 = high / 16777216
            if low_top == high_top {
                let nb: i64 = if p < len(payload) { payload[p] } else { 0 }
                code = (code - low_top * 16777216) * 256 + nb
                low = (low - low_top * 16777216) * 256
                range = range * 256
                p = p + 1
            } else if range < A23_BOT {
                let nb: i64 = if p < len(payload) { payload[p] } else { 0 }
                range = (16777216 - (low - (low / 16777216) * 16777216)) * 256
                code = (code - (low / 16777216) * 16777216) * 256 + nb
                low = (low - (low / 16777216) * 16777216) * 256
                p = p + 1
            } else {
                renorm = false
            }
            if low >= A23_TOP { low = low - A23_TOP }
            if code >= A23_TOP * 256 { code = code - A23_TOP * 256 }
        }
        row[b] = row[b] + 1
        tables[active] = _ctx_rescale_if_needed(row)
        active = _next_ctx(b)
        produced = produced + 1
    }
    return out
}

// ───────────────── base64url (byte-array <-> string), parallel A18 ─────────────────

fn _b64_enc_bytes(bytes: array) -> string {
    let mut out = []
    let n: i64 = len(bytes)
    let mut i: i64 = 0
    while i < n {
        let b0: i64 = bytes[i]
        let b1: i64 = if i + 1 < n { bytes[i + 1] } else { 0 }
        let b2: i64 = if i + 2 < n { bytes[i + 2] } else { 0 }
        let acc: i64 = b0 * 65536 + b1 * 256 + b2
        let c0: i64 = acc / 262144
        let r0: i64 = acc - c0 * 262144
        let c1: i64 = r0 / 4096
        let r1: i64 = r0 - c1 * 4096
        let c2: i64 = r1 / 64
        let c3: i64 = r1 - c2 * 64
        let group: i64 = if i + 3 <= n { 4 } else { (n - i) + 1 }
        let chs = [c0, c1, c2, c3]
        let mut e: i64 = 0
        while e < group { out.push(A23_B64_ALPHA.substring(chs[e], chs[e] + 1)); e = e + 1 }
        i = i + 3
    }
    let mut nv: i64 = n
    if nv > 16777215 { nv = 16777215 }
    let t0: i64 = nv / 262144
    let r0t: i64 = nv - t0 * 262144
    let t1: i64 = r0t / 4096
    let r1t: i64 = r0t - t1 * 4096
    let t2: i64 = r1t / 64
    let t3: i64 = r1t - t2 * 64
    out.push(A23_B64_ALPHA.substring(t0, t0 + 1))
    out.push(A23_B64_ALPHA.substring(t1, t1 + 1))
    out.push(A23_B64_ALPHA.substring(t2, t2 + 1))
    out.push(A23_B64_ALPHA.substring(t3, t3 + 1))
    return out.join("")
}

fn _b64_char_idx(c: string) -> i64 { return A23_B64_ALPHA.index_of(c) }

fn _b64_dec_bytes(s: string) -> array {
    let total: i64 = len(s)
    if total < 4 { return [] }
    let t0: i64 = _b64_char_idx(s.substring(total - 4, total - 3))
    let t1: i64 = _b64_char_idx(s.substring(total - 3, total - 2))
    let t2: i64 = _b64_char_idx(s.substring(total - 2, total - 1))
    let t3: i64 = _b64_char_idx(s.substring(total - 1, total))
    let bcount: i64 = t0 * 262144 + t1 * 4096 + t2 * 64 + t3
    let body_len: i64 = total - 4
    let mut out = []
    let mut i: i64 = 0
    while i < body_len {
        let group: i64 = if i + 4 <= body_len { 4 } else { body_len - i }
        let mut acc: i64 = 0
        let mut j: i64 = 0
        while j < 4 {
            let d: i64 = if j < group { _b64_char_idx(s.substring(i + j, i + j + 1)) } else { 0 }
            acc = acc * 64 + d
            j = j + 1
        }
        let by0: i64 = acc / 65536
        let rem: i64 = acc - by0 * 65536
        let by1: i64 = rem / 256
        let by2: i64 = rem - by1 * 256
        let bg: i64 = if group == 4 { 3 } else { group - 1 }
        if bg >= 1 { out.push(by0) }
        if bg >= 2 { out.push(by1) }
        if bg >= 3 { out.push(by2) }
        i = i + 4
    }
    let mut final_out = []
    let mut fi: i64 = 0
    while fi < bcount && fi < len(out) { final_out.push(out[fi]); fi = fi + 1 }
    return final_out
}

// ───────────────── encode / decode wire format ─────────────────

// _str_to_bytes: convert string to byte-array via ord. Production binary path
// preferred (write_bytes); this is used for string-only fixtures.
fn _str_to_bytes(s: string) -> array {
    let mut out = []
    let n = len(s)
    let mut i = 0
    while i < n { out.push(ord(_byte_at(s, i))); i = i + 1 }
    return out
}

// _a23_encode_force: v1 wire — order-1 byte-context adaptive range coder.
// Selftest fixtures fire on this path.
fn _a23_encode_force(text: string) -> string {
    let n: i64 = len(text)
    if n >= 7 && text.substring(0, 7) == "# a23:s" { return text }
    let bytes = _str_to_bytes(text)
    let payload_bytes = _range_encode_o1(bytes)
    let payload_b64 = _b64_enc_bytes(payload_bytes)
    let header = "# a23:s1 v=sparse-ppm-v1 n=" + to_string(n) + " o=" + to_string(A23_MAX_ORDER)
    let body = "^V" + payload_b64
    return header + "\n" + body + "\n"
}

// ───────────────── v2 wire — order-2 PPM-D-style escape coder (follow-on tick) ─────────────────
//
// raw 91 honest C3 disclosure (v2 wire scope):
//     v2 wire = adaptive order-2 byte-context PPM with PPM-D-style escape
//     mechanism. The `o=5` header field documents the IN-SAMPLE bound model
//     (a23_build orders 0..5); the WIRE coder is order-2 (lazy sparse map for
//     ctx2 contexts + dense order-1 fallback + dense order-0 final fallback).
//     Order-2 chosen as the practical adaptive ceiling: order-3+ pure adaptive
//     suffers escape-probability inflation without huge corpora to amortize.
//     The order-5 sparse-context model remains as the ESTIMATOR axis (in-sample
//     bits projection); the wire coder genuinely steps from order-1 (v1 wire)
//     to order-2 (v2 wire), a real algorithmic advance per F-A23-WIRE-INLINING-1.
//
// Encoder/decoder mirror invariants (PPM-D simplified, no exclusion list):
//     1. Sparse map `ctx2: {string -> array[257]}`, lazy-init.
//        Row layout: [count_sym_0, ..., count_sym_255, escape_count].
//        Escape count fixed at 1 (never increments) for stability.
//     2. Dense order-1 table: 257 rows (256 prev-byte + start-state) × 257
//        entries (256 syms + escape).
//     3. Dense order-0 row: 256 entries, init=1 (uniform), increments per byte
//        (no escape — order-0 always succeeds).
//     4. Encode byte: try order-2 (if ctx2 in map and row[byte]>0); else emit
//        escape from order-2 (if ctx2 in map; else skip order-2 entirely),
//        fall to order-1; if order-1 row[byte]==0 (never seen), emit escape from
//        order-1 fall to order-0; order-0 always succeeds.
//     5. Adaptation order-of-operations (mirrored exactly by decoder):
//        After determining the byte, increment order-0 row[byte], order-1
//        row[byte] (lazy-init order-1 row entries are already set to 0 syms +
//        1 escape — wait, dense order-1 init has all syms = 0, escape = 1).
//        For order-2: lazy-init ctx2 row (all syms = 0, escape = 1) on first
//        sight of ctx2, then increment row[byte].

const A23_ESC = 256                   // escape symbol index in 257-entry rows
const A23_ROW_LEN = 257               // 256 syms + 1 escape

fn _row_alloc_o12() -> array {
    // 257-entry row: all syms = 0, escape = 1. Used by order-1 + order-2.
    let mut r = []
    let mut i = 0
    while i < 256 { r.push(0); i = i + 1 }
    r.push(1)
    return r
}

fn _row_alloc_o0() -> array {
    // 256-entry dense order-0 row, init = 1 (uniform).
    let mut r = []
    let mut i = 0
    while i < 256 { r.push(1); i = i + 1 }
    return r
}

fn _row_total_o12(row: array) -> i64 {
    let mut s: i64 = 0
    let mut i = 0
    while i < A23_ROW_LEN { s = s + row[i]; i = i + 1 }
    return s
}

fn _row_rescale_o12(row: array) -> array {
    let s: i64 = _row_total_o12(row)
    if s <= A23_MAX_FREQ_TOTAL { return row }
    let mut j = 0
    while j < A23_ROW_LEN {
        let v: i64 = row[j] / 2
        row[j] = if v < 1 { 1 } else { v }
        j = j + 1
    }
    return row
}

fn _row_cum_o12(row: array) -> array {
    let mut cum = []
    let mut s: i64 = 0
    let mut i = 0
    while i < A23_ROW_LEN { cum.push(s); s = s + row[i]; i = i + 1 }
    cum.push(s)
    return cum
}

fn _row_total_o0(row: array) -> i64 {
    let mut s: i64 = 0
    let mut i = 0
    while i < 256 { s = s + row[i]; i = i + 1 }
    return s
}

fn _row_rescale_o0(row: array) -> array {
    let s: i64 = _row_total_o0(row)
    if s <= A23_MAX_FREQ_TOTAL { return row }
    let mut j = 0
    while j < 256 {
        let v: i64 = row[j] / 2
        row[j] = if v < 1 { 1 } else { v }
        j = j + 1
    }
    return row
}

fn _row_cum_o0(row: array) -> array {
    let mut cum = []
    let mut s: i64 = 0
    let mut i = 0
    while i < 256 { cum.push(s); s = s + row[i]; i = i + 1 }
    cum.push(s)
    return cum
}

fn _build_o1_dense() -> array {
    // 257 rows × 257 entries (256 syms = 0, escape = 1). Lazy-feel via init.
    let mut tables = []
    let mut c = 0
    while c < 257 {
        tables.push(_row_alloc_o12())
        c = c + 1
    }
    return tables
}

// _renorm_encode: shared renormalization step for the range encoder, called
// after low/range update. Identical structure to _range_encode_o1 (proven).
fn _renorm_encode_step(out_bytes: array, low: i64, range: i64) -> array {
    // Returns [new_out_bytes, new_low, new_range]
    let mut ob = out_bytes
    let mut lo: i64 = low
    let mut rg: i64 = range
    let mut renorm = true
    while renorm {
        let high: i64 = lo + rg
        let low_top: i64 = lo / 16777216
        let high_top: i64 = high / 16777216
        if low_top == high_top {
            ob.push(low_top - (low_top / 256) * 256)
            lo = (lo - (low_top * 16777216)) * 256
            rg = rg * 256
            if lo < 0 { lo = lo + A23_TOP * 256 }
        } else if rg < A23_BOT {
            rg = (16777216 - (lo - (lo / 16777216) * 16777216)) * 256
            ob.push(lo / 16777216 - (lo / 16777216 / 256) * 256)
            lo = (lo - (lo / 16777216) * 16777216) * 256
        } else {
            renorm = false
        }
        if lo >= A23_TOP {
            let mut idx: i64 = len(ob) - 1
            lo = lo - A23_TOP
            while idx >= 0 {
                let v: i64 = ob[idx] + 1
                if v < 256 { ob[idx] = v; idx = -1 }
                else { ob[idx] = 0; idx = idx - 1 }
            }
        }
    }
    return [ob, lo, rg]
}

// _range_encode_o2: order-2 PPM-D-simplified adaptive range coder.
// Returns array of output bytes.
fn _range_encode_o2(input: array) -> array {
    let mut ctx2_map = {}
    let mut o1_tables = _build_o1_dense()
    let mut o0_row = _row_alloc_o0()
    let mut prev1: i64 = 256       // start state for order-1
    let mut prev2_str: string = "" // ctx2 string (last 2 bytes), empty = no ctx2 yet
    let mut last_byte: i64 = -1
    let mut low: i64 = 0
    let mut range: i64 = A23_TOP - 1
    let mut out_bytes = []
    let n: i64 = len(input)
    let mut k: i64 = 0
    while k < n {
        let b: i64 = input[k]
        // --- order-2 attempt ---
        let mut o2_emitted = false
        if len(prev2_str) == 2 && map_contains_key(ctx2_map, prev2_str) {
            let row2 = ctx2_map[prev2_str]
            let cum2 = _row_cum_o12(row2)
            let total2: i64 = cum2[A23_ROW_LEN]
            if row2[b] > 0 {
                // encode at order-2
                range = range / total2
                low = low + cum2[b] * range
                range = range * (cum2[b + 1] - cum2[b])
                let r = _renorm_encode_step(out_bytes, low, range)
                out_bytes = r[0]
                low = r[1]
                range = r[2]
                o2_emitted = true
            } else {
                // encode escape from order-2
                range = range / total2
                low = low + cum2[A23_ESC] * range
                range = range * (cum2[A23_ESC + 1] - cum2[A23_ESC])
                let r = _renorm_encode_step(out_bytes, low, range)
                out_bytes = r[0]
                low = r[1]
                range = r[2]
            }
        }
        // --- order-1 attempt (if order-2 not emitted) ---
        let mut o1_emitted = false
        if !o2_emitted {
            let row1 = o1_tables[prev1]
            let cum1 = _row_cum_o12(row1)
            let total1: i64 = cum1[A23_ROW_LEN]
            if row1[b] > 0 {
                range = range / total1
                low = low + cum1[b] * range
                range = range * (cum1[b + 1] - cum1[b])
                let r = _renorm_encode_step(out_bytes, low, range)
                out_bytes = r[0]
                low = r[1]
                range = r[2]
                o1_emitted = true
            } else {
                range = range / total1
                low = low + cum1[A23_ESC] * range
                range = range * (cum1[A23_ESC + 1] - cum1[A23_ESC])
                let r = _renorm_encode_step(out_bytes, low, range)
                out_bytes = r[0]
                low = r[1]
                range = r[2]
            }
        }
        // --- order-0 (only if order-1 also escaped) ---
        if !o2_emitted && !o1_emitted {
            let cum0 = _row_cum_o0(o0_row)
            let total0: i64 = cum0[256]
            range = range / total0
            low = low + cum0[b] * range
            range = range * (cum0[b + 1] - cum0[b])
            let r = _renorm_encode_step(out_bytes, low, range)
            out_bytes = r[0]
            low = r[1]
            range = r[2]
        }
        // --- adapt all visited orders (PPM-A simplified) ---
        // order-0 always increments
        o0_row[b] = o0_row[b] + 1
        o0_row = _row_rescale_o0(o0_row)
        // order-1 always increments (whether emitted at o1 or escaped further)
        let mut row1u = o1_tables[prev1]
        row1u[b] = row1u[b] + 1
        o1_tables[prev1] = _row_rescale_o12(row1u)
        // order-2 increment only if ctx2 exists OR we're past the 2-byte warmup
        if len(prev2_str) == 2 {
            if !map_contains_key(ctx2_map, prev2_str) {
                ctx2_map[prev2_str] = _row_alloc_o12()
            }
            let mut row2u = ctx2_map[prev2_str]
            row2u[b] = row2u[b] + 1
            ctx2_map[prev2_str] = _row_rescale_o12(row2u)
        }
        // --- update context state for next byte ---
        prev1 = b
        if last_byte >= 0 {
            // ctx2 = previous-2-bytes = chr(last_byte) + chr(b)
            prev2_str = chr(last_byte) + chr(b)
        }
        last_byte = b
        k = k + 1
    }
    // Flush 4 termination bytes (mirror v1).
    let mut f = 0
    while f < 4 {
        let lt: i64 = low / 16777216
        out_bytes.push(lt - (lt / 256) * 256)
        low = (low - lt * 16777216) * 256
        f = f + 1
    }
    return out_bytes
}

// _renorm_decode_step: shared renormalization for decoder. Returns
// [new_low, new_range, new_code, new_p]
fn _renorm_decode_step(payload: array, low: i64, range: i64, code: i64, p: i64) -> array {
    let mut lo: i64 = low
    let mut rg: i64 = range
    let mut cd: i64 = code
    let mut pp: i64 = p
    let mut renorm = true
    while renorm {
        let high: i64 = lo + rg
        let low_top: i64 = lo / 16777216
        let high_top: i64 = high / 16777216
        if low_top == high_top {
            let nb: i64 = if pp < len(payload) { payload[pp] } else { 0 }
            cd = (cd - low_top * 16777216) * 256 + nb
            lo = (lo - low_top * 16777216) * 256
            rg = rg * 256
            pp = pp + 1
        } else if rg < A23_BOT {
            let nb: i64 = if pp < len(payload) { payload[pp] } else { 0 }
            rg = (16777216 - (lo - (lo / 16777216) * 16777216)) * 256
            cd = (cd - (lo / 16777216) * 16777216) * 256 + nb
            lo = (lo - (lo / 16777216) * 16777216) * 256
            pp = pp + 1
        } else {
            renorm = false
        }
        if lo >= A23_TOP { lo = lo - A23_TOP }
        if cd >= A23_TOP * 256 { cd = cd - A23_TOP * 256 }
    }
    return [lo, rg, cd, pp]
}

// _range_decode_o2: inverse of _range_encode_o2. Mirror adaptation order.
fn _range_decode_o2(payload: array, n_bytes: i64) -> array {
    let mut ctx2_map = {}
    let mut o1_tables = _build_o1_dense()
    let mut o0_row = _row_alloc_o0()
    let mut prev1: i64 = 256
    let mut prev2_str: string = ""
    let mut last_byte: i64 = -1
    let mut low: i64 = 0
    let mut range: i64 = A23_TOP - 1
    let mut code: i64 = 0
    let mut p: i64 = 0
    let mut pi = 0
    while pi < 4 {
        let b: i64 = if p < len(payload) { payload[p] } else { 0 }
        code = code * 256 + b
        p = p + 1
        pi = pi + 1
    }
    let mut out = []
    let mut produced: i64 = 0
    while produced < n_bytes {
        let mut decoded_byte: i64 = -1
        // --- attempt order-2 ---
        let mut o2_handled = false
        if len(prev2_str) == 2 && map_contains_key(ctx2_map, prev2_str) {
            let row2 = ctx2_map[prev2_str]
            let cum2 = _row_cum_o12(row2)
            let total2: i64 = cum2[A23_ROW_LEN]
            range = range / total2
            let target: i64 = (code - low) / range
            let mut tgt: i64 = target
            if tgt >= total2 { tgt = total2 - 1 }
            let mut sym: i64 = 0
            while sym < A23_ROW_LEN {
                if cum2[sym + 1] > tgt { break }
                sym = sym + 1
            }
            if sym >= A23_ROW_LEN { sym = A23_ROW_LEN - 1 }
            low = low + cum2[sym] * range
            range = range * (cum2[sym + 1] - cum2[sym])
            let r = _renorm_decode_step(payload, low, range, code, p)
            low = r[0]; range = r[1]; code = r[2]; p = r[3]
            if sym < A23_ESC {
                decoded_byte = sym
                o2_handled = true
            }
            // else: escape, fall through to order-1
        }
        // --- attempt order-1 (if order-2 didn't decode a real byte) ---
        let mut o1_handled = false
        if !o2_handled {
            let row1 = o1_tables[prev1]
            let cum1 = _row_cum_o12(row1)
            let total1: i64 = cum1[A23_ROW_LEN]
            range = range / total1
            let target: i64 = (code - low) / range
            let mut tgt: i64 = target
            if tgt >= total1 { tgt = total1 - 1 }
            let mut sym: i64 = 0
            while sym < A23_ROW_LEN {
                if cum1[sym + 1] > tgt { break }
                sym = sym + 1
            }
            if sym >= A23_ROW_LEN { sym = A23_ROW_LEN - 1 }
            low = low + cum1[sym] * range
            range = range * (cum1[sym + 1] - cum1[sym])
            let r = _renorm_decode_step(payload, low, range, code, p)
            low = r[0]; range = r[1]; code = r[2]; p = r[3]
            if sym < A23_ESC {
                decoded_byte = sym
                o1_handled = true
            }
        }
        // --- order-0 (always succeeds) ---
        if !o2_handled && !o1_handled {
            let cum0 = _row_cum_o0(o0_row)
            let total0: i64 = cum0[256]
            range = range / total0
            let target: i64 = (code - low) / range
            let mut tgt: i64 = target
            if tgt >= total0 { tgt = total0 - 1 }
            let mut sym: i64 = 0
            while sym < 256 {
                if cum0[sym + 1] > tgt { break }
                sym = sym + 1
            }
            if sym >= 256 { sym = 255 }
            low = low + cum0[sym] * range
            range = range * (cum0[sym + 1] - cum0[sym])
            let r = _renorm_decode_step(payload, low, range, code, p)
            low = r[0]; range = r[1]; code = r[2]; p = r[3]
            decoded_byte = sym
        }
        let b: i64 = decoded_byte
        out.push(b)
        // --- adapt — must mirror encoder exactly ---
        o0_row[b] = o0_row[b] + 1
        o0_row = _row_rescale_o0(o0_row)
        let mut row1u = o1_tables[prev1]
        row1u[b] = row1u[b] + 1
        o1_tables[prev1] = _row_rescale_o12(row1u)
        if len(prev2_str) == 2 {
            if !map_contains_key(ctx2_map, prev2_str) {
                ctx2_map[prev2_str] = _row_alloc_o12()
            }
            let mut row2u = ctx2_map[prev2_str]
            row2u[b] = row2u[b] + 1
            ctx2_map[prev2_str] = _row_rescale_o12(row2u)
        }
        prev1 = b
        if last_byte >= 0 {
            prev2_str = chr(last_byte) + chr(b)
        }
        last_byte = b
        produced = produced + 1
    }
    return out
}

// _a23_encode_force_v2: v2 wire — order-2 PPM-D-simplified adaptive coder.
fn _a23_encode_force_v2(text: string) -> string {
    let n: i64 = len(text)
    if n >= 7 && text.substring(0, 7) == "# a23:s" { return text }
    let bytes = _str_to_bytes(text)
    let payload_bytes = _range_encode_o2(bytes)
    let payload_b64 = _b64_enc_bytes(payload_bytes)
    let header = "# a23:s2 v=sparse-ppm-v2 n=" + to_string(n) + " o=" + to_string(A23_MAX_ORDER)
    let body = "^W" + payload_b64
    return header + "\n" + body + "\n"
}

// a23_encode: try-and-revert raw 142 D2 — return shortest of {a23-v2, a23-v1, identity}.
fn a23_encode(text: string) -> string {
    let n: i64 = len(text)
    if n < A23_MIN_BYTES { return text }
    if n >= 7 && text.substring(0, 7) == "# a23:s" { return text }
    let v2 = _a23_encode_force_v2(text)
    let v1 = _a23_encode_force(text)
    let mut best = text
    if len(v2) < len(best) { best = v2 }
    if len(v1) < len(best) { best = v1 }
    return best
}

// _a23_decode_to_bytes: reconstruct byte array (each 0..255). Auto-detects
// v=sparse-ppm-v1 (^V) or v=sparse-ppm-v2 (^W).
fn _a23_decode_to_bytes(stream: string) -> array {
    let lines = stream.split("\n")
    if len(lines) < 2 { return [] }
    let header = lines[0]
    if len(header) < 7 || header.substring(0, 7) != "# a23:s" { return [] }
    let n_pos: i64 = header.index_of(" n=")
    if n_pos < 0 { return [] }
    let o_pos: i64 = header.index_of(" o=")
    let n_end: i64 = if o_pos > n_pos { o_pos } else { len(header) }
    let n_bytes: i64 = parse_int(header.substring(n_pos + 3, n_end))
    // Detect wire version: header contains v=sparse-ppm-v2 → ^W; else ^V.
    let is_v2: bool = header.index_of("v=sparse-ppm-v2") >= 0
    let mut body_b64 = ""
    let mut i = 1
    while i < len(lines) {
        let l = lines[i]
        if len(l) >= 2 {
            let sig = l.substring(0, 2)
            if (is_v2 && sig == "^W") || (!is_v2 && sig == "^V") {
                body_b64 = l.substring(2, len(l))
                break
            }
        }
        i = i + 1
    }
    if len(body_b64) == 0 { return [] }
    let payload_bytes = _b64_dec_bytes(body_b64)
    if is_v2 { return _range_decode_o2(payload_bytes, n_bytes) }
    return _range_decode_o1(payload_bytes, n_bytes)
}

// a23_decode (string-returning, ASCII-safe path; binary uses byte-array form).
fn a23_decode(stream: string) -> string {
    let lines = stream.split("\n")
    if len(lines) < 2 { return stream }
    let header = lines[0]
    if len(header) < 7 || header.substring(0, 7) != "# a23:s" { return stream }
    let bytes = _a23_decode_to_bytes(stream)
    if len(bytes) == 0 { return stream }
    let mut parts = []
    let mut i = 0
    while i < len(bytes) {
        parts.push(chr(bytes[i]))
        i = i + 1
    }
    return parts.join("")
}

// ───────────────── in-sample bits estimator (sparse PPM order-5 + escape) ─────────────────

fn _ilog2_ceil(x: int) -> int {
    if x <= 1 { return 0 }
    let mut b = 0
    let mut v = x - 1
    while v > 0 { b = b + 1; v = v / 2 }
    return b
}

fn a23_estimate_bits(tables: array, buf: string) -> int {
    let n = len(buf)
    let mut total_bits = 0
    let mut p = 0
    while p < n {
        if p < A23_MAX_ORDER {
            total_bits = total_bits + A23_RAW_BITS_PER_BYTE
        } else {
            let order = a23_lookup(tables, buf, p)
            if order < 0 {
                total_bits = total_bits + A23_RAW_BITS_PER_BYTE
            } else {
                let ctx = _ctx_at(buf, p, order)
                let sym = _byte_at(buf, p)
                let cnt = _table_count(tables[order], ctx, sym)
                let tot = _table_total(tables[order], ctx)
                let dis = _table_distinct(tables[order], ctx)
                let ratio = if cnt > 0 { (tot + dis) / cnt } else { tot + dis }
                let bits_sym = _ilog2_ceil(ratio + 1)
                let bits_esc = (A23_MAX_ORDER - order)
                total_bits = total_bits + bits_sym + bits_esc
            }
        }
        p = p + 1
    }
    return total_bits
}

fn a23_estimate_bytes(tables: array, buf: string) -> int {
    let bits = a23_estimate_bits(tables, buf)
    return (bits + 7) / 8
}

// a23_hit_rate: returns the order-5 sparse-context lookup hit rate, scaled to
// integer percentage. Reports the SAVING-LEVER strength per corpus class.
fn a23_hit_rate(tables: array, buf: string) -> int {
    let n = len(buf)
    if n <= A23_MAX_ORDER { return 0 }
    let mut hits = 0
    let mut total = 0
    let mut p = A23_MAX_ORDER
    while p < n {
        let order = a23_lookup(tables, buf, p)
        if order >= A23_MAX_ORDER { hits = hits + 1 }
        total = total + 1
        p = p + 1
    }
    if total == 0 { return 0 }
    return (hits * 100) / total
}

// ───────────────── selftest (5 fixtures, raw 91 honest C3 first-tick scope) ─────────────────

fn _selftest() -> int {
    println("# hxc_a23_sparse_ppm selftest (FIRST TICK BUILD — PASS 1+2+3 + 5 fixtures)")
    let mut pass = 0
    let mut fail = 0

    // Fixture 1 (mixed-JSON, text-heavy with byte-transition skew).
    let json_like = "{\"ts\":\"2026-04-28T00:00:00Z\",\"event\":\"convergence\",\"value\":1.0,\"saving\":0.97}\n{\"ts\":\"2026-04-28T00:01:00Z\",\"event\":\"convergence\",\"value\":2.0,\"saving\":0.97}\n{\"ts\":\"2026-04-28T00:02:00Z\",\"event\":\"convergence\",\"value\":3.0,\"saving\":0.97}\n"
    let enc1 = _a23_encode_force(json_like)
    let dec1 = a23_decode(enc1)
    if dec1 == json_like {
        let s1 = ((len(json_like) - len(enc1)) * 100) / len(json_like)
        pass = pass + 1
        println("  PASS: fixture-1 mixed-JSON byte-eq " + to_string(len(json_like))
                + " -> " + to_string(len(enc1)) + " (" + to_string(s1) + "% saving)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-1 mixed-JSON round-trip lost orig_len=" + to_string(len(json_like))
                + " got_len=" + to_string(len(dec1)))
    }

    // Fixture 2 (Korean / multibyte UTF-8 byte-array round-trip).
    let kor = "안녕 세계 — 곰파 연결 ω-cycle. 압축 알고리즘 A23 자기-호스트 hexa raw 9. "
    let mut buf_kor = ""
    let mut k2 = 0
    while k2 < 12 { buf_kor = buf_kor + kor; k2 = k2 + 1 }
    let enc2 = _a23_encode_force(buf_kor)
    let dec2_bytes = _a23_decode_to_bytes(enc2)
    let mut ok2 = true
    let nk: i64 = len(buf_kor)
    if len(dec2_bytes) != nk { ok2 = false }
    let mut q2: i64 = 0
    while ok2 && q2 < nk {
        if dec2_bytes[q2] != ord(_byte_at(buf_kor, q2)) { ok2 = false }
        q2 = q2 + 1
    }
    if ok2 {
        let s2: i64 = ((nk - len(enc2)) * 100) / nk
        pass = pass + 1
        println("  PASS: fixture-2 Korean multibyte byte-array byte-eq "
                + to_string(nk) + " -> " + to_string(len(enc2))
                + " (" + to_string(s2) + "% saving)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-2 Korean byte-array round-trip lost orig_len=" + to_string(nk)
                + " got_len=" + to_string(len(dec2_bytes)))
    }

    // Fixture 3 (ledger / structured-audit JSONL — sparse-context strength axis).
    let audit_phrase = "{\"event\":\"witness\",\"phase\":\"12-P1\",\"algo\":\"A23\",\"saving_pct\":75,\"raw_91_c3\":\"first-tick\",\"ts\":\"2026-04-28\"}\n"
    let mut buf_audit = ""
    let mut k3 = 0
    while k3 < 8 { buf_audit = buf_audit + audit_phrase; k3 = k3 + 1 }
    let enc3 = _a23_encode_force(buf_audit)
    let dec3 = a23_decode(enc3)
    if dec3 == buf_audit {
        let s3 = ((len(buf_audit) - len(enc3)) * 100) / len(buf_audit)
        let tables3 = a23_build(buf_audit)
        let hit3 = a23_hit_rate(tables3, buf_audit)
        pass = pass + 1
        println("  PASS: fixture-3 ledger/audit byte-eq " + to_string(len(buf_audit))
                + " -> " + to_string(len(enc3)) + " (" + to_string(s3)
                + "% saving, order-5 hit-rate=" + to_string(hit3) + "%)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-3 ledger/audit round-trip lost orig_len=" + to_string(len(buf_audit))
                + " got_len=" + to_string(len(dec3)))
    }

    // Fixture 4 (large-text English repetition for order-5 hit rate).
    let phrase = "the quick brown fox jumps over the lazy dog "
    let mut buf_eng = ""
    let mut k4 = 0
    while k4 < 30 { buf_eng = buf_eng + phrase; k4 = k4 + 1 }
    let enc4 = _a23_encode_force(buf_eng)
    let dec4 = a23_decode(enc4)
    if dec4 == buf_eng {
        let s4 = ((len(buf_eng) - len(enc4)) * 100) / len(buf_eng)
        let tables4 = a23_build(buf_eng)
        let hit4 = a23_hit_rate(tables4, buf_eng)
        let est4 = a23_estimate_bytes(tables4, buf_eng)
        let est_pct = ((len(buf_eng) - est4) * 100) / len(buf_eng)
        pass = pass + 1
        println("  PASS: fixture-4 large-text byte-eq " + to_string(len(buf_eng))
                + " -> " + to_string(len(enc4)) + " (" + to_string(s4)
                + "% wire-saving, order-5 hit-rate=" + to_string(hit4)
                + "%, in-sample PPM-5 est=" + to_string(est_pct) + "%)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-4 large-text round-trip lost orig_len=" + to_string(len(buf_eng))
                + " got_len=" + to_string(len(dec4)))
    }

    // Fixture 5 (passthrough idempotent — raw 65 + 68).
    let tiny = "abc123"
    let enc5 = a23_encode(tiny)
    let enc5b = a23_encode(enc5)
    if enc5 == tiny && enc5b == tiny {
        pass = pass + 1
        println("  PASS: fixture-5 short-input passthrough idempotent (raw 65 + 68)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-5 short-input idempotency broken")
    }

    // ───── v2 wire fixtures (F6/F7/F8) — order-2 PPM-D escape coder ─────

    // Fixture 6 (v2 wire English text — F-A23-WIRE-INLINING-1 saving target).
    let phrase_v2 = "the quick brown fox jumps over the lazy dog "
    let mut buf_eng_v2 = ""
    let mut k6 = 0
    while k6 < 30 { buf_eng_v2 = buf_eng_v2 + phrase_v2; k6 = k6 + 1 }
    let enc6 = _a23_encode_force_v2(buf_eng_v2)
    let dec6 = a23_decode(enc6)
    if dec6 == buf_eng_v2 {
        let s6 = ((len(buf_eng_v2) - len(enc6)) * 100) / len(buf_eng_v2)
        // also compare to v1 for v2-vs-v1 delta
        let enc6_v1 = _a23_encode_force(buf_eng_v2)
        let s6_v1 = ((len(buf_eng_v2) - len(enc6_v1)) * 100) / len(buf_eng_v2)
        let delta_v2_v1 = s6 - s6_v1
        pass = pass + 1
        println("  PASS: fixture-6 v2 wire English text byte-eq " + to_string(len(buf_eng_v2))
                + " -> " + to_string(len(enc6)) + " (v2=" + to_string(s6)
                + "%, v1=" + to_string(s6_v1) + "%, delta=" + to_string(delta_v2_v1) + "pp)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-6 v2 wire English text round-trip lost orig_len="
                + to_string(len(buf_eng_v2)) + " got_len=" + to_string(len(dec6)))
    }

    // Fixture 7 (v2 wire Korean multibyte byte-eq).
    let kor_v2 = "안녕 세계 — 곰파 연결 ω-cycle. 압축 알고리즘 A23 v2 wire 자기-호스트 hexa raw 9. "
    let mut buf_kor_v2 = ""
    let mut k7 = 0
    while k7 < 12 { buf_kor_v2 = buf_kor_v2 + kor_v2; k7 = k7 + 1 }
    let enc7 = _a23_encode_force_v2(buf_kor_v2)
    let dec7_bytes = _a23_decode_to_bytes(enc7)
    let mut ok7 = true
    let nk7: i64 = len(buf_kor_v2)
    if len(dec7_bytes) != nk7 { ok7 = false }
    let mut q7: i64 = 0
    while ok7 && q7 < nk7 {
        if dec7_bytes[q7] != ord(_byte_at(buf_kor_v2, q7)) { ok7 = false }
        q7 = q7 + 1
    }
    if ok7 {
        let s7: i64 = ((nk7 - len(enc7)) * 100) / nk7
        let enc7_v1 = _a23_encode_force(buf_kor_v2)
        let s7_v1: i64 = ((nk7 - len(enc7_v1)) * 100) / nk7
        let delta_v2_v1_k = s7 - s7_v1
        pass = pass + 1
        println("  PASS: fixture-7 v2 wire Korean multibyte byte-eq "
                + to_string(nk7) + " -> " + to_string(len(enc7))
                + " (v2=" + to_string(s7) + "%, v1=" + to_string(s7_v1)
                + "%, delta=" + to_string(delta_v2_v1_k) + "pp)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-7 v2 wire Korean round-trip lost orig_len=" + to_string(nk7)
                + " got_len=" + to_string(len(dec7_bytes)))
    }

    // Fixture 8 (v2 wire ledger / structured-audit production-like).
    let audit_phrase_v2 = "{\"event\":\"witness\",\"phase\":\"12-P1-A23-V2\",\"algo\":\"A23\",\"saving_pct\":75,\"raw_91_c3\":\"v2-wire\",\"ts\":\"2026-04-28\"}\n"
    let mut buf_audit_v2 = ""
    let mut k8 = 0
    while k8 < 8 { buf_audit_v2 = buf_audit_v2 + audit_phrase_v2; k8 = k8 + 1 }
    let enc8 = _a23_encode_force_v2(buf_audit_v2)
    let dec8 = a23_decode(enc8)
    if dec8 == buf_audit_v2 {
        let s8 = ((len(buf_audit_v2) - len(enc8)) * 100) / len(buf_audit_v2)
        let enc8_v1 = _a23_encode_force(buf_audit_v2)
        let s8_v1 = ((len(buf_audit_v2) - len(enc8_v1)) * 100) / len(buf_audit_v2)
        let delta_v2_v1_a = s8 - s8_v1
        pass = pass + 1
        println("  PASS: fixture-8 v2 wire ledger/audit byte-eq " + to_string(len(buf_audit_v2))
                + " -> " + to_string(len(enc8)) + " (v2=" + to_string(s8)
                + "%, v1=" + to_string(s8_v1) + "%, delta=" + to_string(delta_v2_v1_a) + "pp)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-8 v2 wire ledger/audit round-trip lost orig_len="
                + to_string(len(buf_audit_v2)) + " got_len=" + to_string(len(dec8)))
    }

    println("Results: " + to_string(pass) + " PASS / " + to_string(fail) + " FAIL")
    println("__HXC_A23_SELFTEST__ " + (if fail == 0 { "PASS" } else { "FAIL" })
            + " (FOLLOW-ON TICK: PASS 1 sparse-ctx tree + PASS 2 v1 order-1 wire + PASS 3 v2 order-2 PPM-D wire + 8 fixtures byte-eq)")
    if fail == 0 { return 0 }
    return 1
}

// ───────────────── main CLI ─────────────────

fn main() {
    let av = argv()
    let mut has_selftest = false
    let mut has_build = false
    let mut has_encode = false
    let mut has_decode = false
    let mut has_force = false
    let mut has_v2 = false
    let mut k = 0
    while k < len(av) {
        if av[k] == "--selftest" { has_selftest = true }
        if av[k] == "build" { has_build = true }
        if av[k] == "encode" { has_encode = true }
        if av[k] == "decode" { has_decode = true }
        if av[k] == "--force" { has_force = true }
        if av[k] == "--v2" { has_v2 = true }
        k = k + 1
    }
    if has_selftest { exit(_selftest()) }
    if has_build {
        let mut sub_idx = 0
        let mut q = 0
        while q < len(av) {
            if av[q] == "build" { sub_idx = q; break }
            q = q + 1
        }
        if sub_idx + 1 >= len(av) {
            eprintln("usage: hexa hxc_a23_sparse_ppm.hexa build <in>")
            exit(3)
        }
        let txt = read_file(av[sub_idx + 1])
        let tables = a23_build(txt)
        let est = a23_estimate_bytes(tables, txt)
        let hit = a23_hit_rate(tables, txt)
        let saving = if len(txt) > 0 { ((len(txt) - est) * 100) / len(txt) } else { 0 }
        println("raw=" + to_string(len(txt)) + " est=" + to_string(est)
                + " saving=" + to_string(saving) + "% order5_hit=" + to_string(hit) + "%")
        exit(0)
    }
    if has_encode || has_decode {
        let mut sub_idx = 0
        let mut q = 0
        while q < len(av) {
            if av[q] == "encode" || av[q] == "decode" { sub_idx = q; break }
            q = q + 1
        }
        let mut paths = []
        let mut q2 = sub_idx + 1
        while q2 < len(av) {
            let a = av[q2]
            if len(a) >= 2 && a.substring(0, 2) == "--" { q2 = q2 + 1; continue }
            paths.push(a)
            q2 = q2 + 1
        }
        if len(paths) < 2 {
            eprintln("usage: hexa hxc_a23_sparse_ppm.hexa <encode|decode> [--force] <in> <out>")
            exit(3)
        }
        let in_path = paths[0]
        let out_path = paths[1]
        if has_encode {
            let txt = read_file(in_path)
            let res = if has_force {
                if has_v2 { _a23_encode_force_v2(txt) } else { _a23_encode_force(txt) }
            } else {
                a23_encode(txt)
            }
            let _w = write_file(out_path, res)
            let saving = if len(txt) > 0 { ((len(txt) - len(res)) * 100) / len(txt) } else { 0 }
            let wire_tag = if has_v2 { "v2" } else { "v1" }
            println("a23 encode wire=" + wire_tag + " raw=" + to_string(len(txt))
                    + " enc=" + to_string(len(res)) + " saving=" + to_string(saving) + "%")
            exit(0)
        }
        let txt = read_file(in_path)
        let bytes = _a23_decode_to_bytes(txt)
        if len(bytes) == 0 {
            let _w = write_file(out_path, txt)
        } else {
            let _w = write_bytes(out_path, bytes)
        }
        exit(0)
    }
    eprintln("usage: hexa hxc_a23_sparse_ppm.hexa [--selftest | build <in> | encode [--force] <in> <out> | decode <in> <out>]")
    exit(3)
}
