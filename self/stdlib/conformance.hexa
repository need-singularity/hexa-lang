// self/stdlib/conformance.hexa — Stdlib parity assertion.
//
// Closes hexa-lang upstream gap #6 (docs/hexa_url_complete_support_upstream_spec_2026_05_05.ai.md §2.5):
// "AOT runtime in darwin-bypass path lacks symbols the docker-routed
//  runtime has. Coverage drift between runtime variants is silent."
//
// CONTRACT
//   This module is loaded by every program that wants startup-time
//   verification that the runtime exposes every symbol declared in
//   `self/stdlib/conformance_manifest.json` for the active runtime mode.
//
// USAGE
//   use "self/stdlib/conformance"
//   fn main() {
//       conformance_assert_or_die()
//       // ... rest of program ...
//   }
//
// On success: emits no output (silent pass — keeps stdout clean for
// downstream sentinel-based parsers per gap #4).
// On failure: emits to stderr exactly one line:
//   __STDLIB_PARITY__ FAIL missing=<symbol>
// then exits with code 7. The exit code is informational only — gap #5
// (void-fn AOT exit non-propagation) means callers MUST also parse the
// sentinel line, not trust $?.
//
// raw 91 (no_silent_errors):
//   Every probe is exercised with safe args and observed for the
//   expected return value or side-effect. A symbol that is callable but
//   returns the wrong value still counts as PRESENT for parity (gap #6
//   is about absence, not correctness — semantic stability is gaps #2/#5).
//
// raw 9 (pure-hexa):
//   Zero exec(). All probes hit either a runtime builtin or a stdlib
//   wrapper directly.

use "stdlib/json"
use "stdlib/string"
use "stdlib/array"
use "stdlib/map"

// ── Active runtime mode detection ────────────────────────────
// Resolver banners go to STDERR; we cannot read them from the running
// program. We detect mode via env vars + binary self-introspection.
//
// Returns one of: "interp", "aot", "darwin-bypass", "docker-routed".
// "interp" is the default — the discriminator is the absence of any
// AOT or docker marker, plus the fact that hexa.real evaluates AST.
fn conformance_active_mode() -> string {
    let aot = env_get("HEXA_AOT")
    if len(aot) > 0 && aot != "0" {
        return "aot"
    }
    // Docker container marker — set by the resolver when entering the
    // mac_safe_landing route. Inside the container HEXA_RESOLVER_NO_REROUTE
    // is also set so we read that too.
    let in_docker = env_get("HEXA_IN_DOCKER")
    if len(in_docker) > 0 && in_docker != "0" {
        return "docker-routed"
    }
    // Darwin-bypass marker file. The resolver stamps this on first
    // successful bypass; the program inherits the env when re-entered
    // bypass-style.
    let bypass_env = env_get("HEXA_RESOLVER_NO_REROUTE")
    if len(bypass_env) > 0 && bypass_env != "0" {
        return "darwin-bypass"
    }
    return "interp"
}

// ── Per-symbol probes ────────────────────────────────────────
// Each probe returns the symbol name on FAILURE, or the empty string
// on SUCCESS. We chain probes via `_first_failing(probes)` which short-
// circuits on the first miss. The names returned must match the
// manifest exactly.

fn _probe_to_string() -> string {
    if to_string(7) == "7" { return "" }
    return "to_string"
}
fn _probe_to_int() -> string {
    if to_int("8") == 8 { return "" }
    return "to_int"
}
fn _probe_to_float() -> string {
    if to_float("1.5") == 1.5 { return "" }
    return "to_float"
}
fn _probe_type_of() -> string {
    if type_of(1) == "int" { return "" }
    return "type_of"
}
fn _probe_len() -> string {
    if len("abc") == 3 { return "" }
    return "len"
}
fn _probe_println() -> string {
    // println is unobservable from inside the program; we trust call
    // success (no exception) as proof of presence.
    print("")
    println("")
    return ""
}
fn _probe_eprintln() -> string {
    // Same rationale as println — call must not throw.
    eprintln("")
    return ""
}
fn _probe_json_parse() -> string {
    let v = json_parse("[1]")
    if len(v) == 1 { return "" }
    return "json_parse"
}
fn _probe_json_stringify() -> string {
    if json_stringify([1]) == "[1]" { return "" }
    return "json_stringify"
}
fn _probe_env_get() -> string {
    let p = env_get("PATH")
    if len(p) > 0 { return "" }
    return "env_get"
}
fn _probe_read_file() -> string {
    let s = read_file("/Users/ghost/core/hexa-lang/self/stdlib/README.md")
    if len(s) > 5 { return "" }
    return "read_file"
}
fn _probe_file_exists() -> string {
    // Per manifest: only assert callability + bool return — not truth.
    let r = file_exists("/Users/ghost")
    if type_of(r) == "bool" { return "" }
    return "file_exists"
}
fn _probe_exec() -> string {
    if exec("printf x") == "x" { return "" }
    return "exec"
}
fn _probe_abs() -> string { if abs(-1) == 1 { return "" } return "abs" }
fn _probe_min() -> string { if min(1,2) == 1 { return "" } return "min" }
fn _probe_max() -> string { if max(1,2) == 2 { return "" } return "max" }

fn _probe_string_substring() -> string {
    if "Hello".substring(0, 3) == "Hel" { return "" }
    return "string.substring"
}
fn _probe_string_split() -> string {
    if len("a b".split(" ")) == 2 { return "" }
    return "string.split"
}
fn _probe_string_replace() -> string {
    if "abc".replace("b", "X") == "aXc" { return "" }
    return "string.replace"
}
fn _probe_string_trim() -> string {
    if "  x  ".trim() == "x" { return "" }
    return "string.trim"
}
fn _probe_array_push() -> string {
    let mut a = []
    a.push(1)
    if len(a) == 1 { return "" }
    return "array.push"
}
fn _probe_map_keys() -> string {
    let m = json_parse("{\"a\":1}")
    if len(m.keys()) == 1 { return "" }
    return "map.keys"
}
fn _probe_map_values() -> string {
    let m = json_parse("{\"a\":1}")
    let vs = m.values()
    if len(vs) == 1 { return "" }
    return "map.values"
}

fn _probe_json_parse_safe() -> string {
    let r = json_parse_safe("[1]")
    if r[0] { return "" }
    return "json_parse_safe"
}
fn _probe_json_parse_or_throw() -> string {
    let v = json_parse_or_throw("[1]")
    if len(v) == 1 { return "" }
    return "json_parse_or_throw"
}
fn _probe_json_stringify_pretty() -> string {
    if json_stringify_pretty([1]) == "[1]" { return "" }
    return "json_stringify_pretty"
}
fn _probe_json_stringify_value() -> string {
    if json_stringify_value([1]) == "[1]" { return "" }
    return "json_stringify_value"
}
fn _probe_json_dump_pretty() -> string {
    if len(json_dump_pretty([1, 2], 2)) > 0 { return "" }
    return "json_dump_pretty"
}
fn _probe_json_object_set() -> string {
    let m = json_parse("{}")
    let m2 = json_object_set(m, "k", 1)
    if len(m2.keys()) == 1 { return "" }
    return "json_object_set"
}
fn _probe_json_array_push() -> string {
    let a = json_array_push([], 1)
    if len(a) == 1 { return "" }
    return "json_array_push"
}

fn _probe_str_trim() -> string {
    if str_trim("  x  ") == "x" { return "" }
    return "str_trim"
}
fn _probe_str_starts_with() -> string {
    if str_starts_with("abc", "ab") { return "" }
    return "str_starts_with"
}
fn _probe_str_ends_with() -> string {
    if str_ends_with("abc", "bc") { return "" }
    return "str_ends_with"
}
fn _probe_str_contains() -> string {
    if str_contains("abc", "b") { return "" }
    return "str_contains"
}
fn _probe_str_index_of() -> string {
    if str_index_of("abc", "b") == 1 { return "" }
    return "str_index_of"
}
fn _probe_str_to_upper() -> string {
    if str_to_upper("abc") == "ABC" { return "" }
    return "str_to_upper"
}
fn _probe_str_to_lower() -> string {
    if str_to_lower("ABC") == "abc" { return "" }
    return "str_to_lower"
}
fn _probe_str_repeat() -> string {
    if str_repeat("a", 3) == "aaa" { return "" }
    return "str_repeat"
}

fn _probe_array_reverse() -> string {
    let r = array_reverse([1, 2, 3])
    if r[0] == 3 { return "" }
    return "array_reverse"
}
fn _probe_array_contains() -> string {
    if array_contains([1, 2, 3], 2) { return "" }
    return "array_contains"
}
fn _probe_array_index_of() -> string {
    if array_index_of([1, 2, 3], 2) == 1 { return "" }
    return "array_index_of"
}
fn _probe_array_sum() -> string {
    if array_sum([1, 2, 3]) == 6 { return "" }
    return "array_sum"
}
fn _probe_array_max() -> string {
    if array_max([1, 3, 2]) == 3 { return "" }
    return "array_max"
}
fn _probe_array_min() -> string {
    if array_min([3, 1, 2]) == 1 { return "" }
    return "array_min"
}

fn _probe_map_size() -> string {
    let m = json_parse("{\"a\":1}")
    if map_size(m) == 1 { return "" }
    return "map_size"
}
fn _probe_map_contains_key() -> string {
    let m = json_parse("{\"a\":1}")
    if map_contains_key(m, "a") { return "" }
    return "map_contains_key"
}
fn _probe_map_get_or() -> string {
    let m = json_parse("{}")
    if map_get_or(m, "k", 9) == 9 { return "" }
    return "map_get_or"
}
fn _probe_map_keys_fn() -> string {
    let m = json_parse("{\"a\":1}")
    if len(map_keys(m)) == 1 { return "" }
    return "map_keys"
}
fn _probe_map_values_fn() -> string {
    let m = json_parse("{\"a\":1}")
    if len(map_values(m)) == 1 { return "" }
    return "map_values"
}
fn _probe_map_is_empty() -> string {
    let m = json_parse("{}")
    if map_is_empty(m) { return "" }
    return "map_is_empty"
}

// ── Public API ────────────────────────────────────────────────

// conformance_run() -> [missing, total]
//   Runs every probe in order. Stops at the first failure and returns
//   [<symbol_name>, <total_probes>]. On full pass returns ["", N].
pub fn conformance_run() {
    let mut total = 0
    let mut miss = ""

    total = total + 1; if miss == "" { miss = _probe_to_string() }
    total = total + 1; if miss == "" { miss = _probe_to_int() }
    total = total + 1; if miss == "" { miss = _probe_to_float() }
    total = total + 1; if miss == "" { miss = _probe_type_of() }
    total = total + 1; if miss == "" { miss = _probe_len() }
    total = total + 1; if miss == "" { miss = _probe_println() }
    total = total + 1; if miss == "" { miss = _probe_eprintln() }
    total = total + 1; if miss == "" { miss = _probe_json_parse() }
    total = total + 1; if miss == "" { miss = _probe_json_stringify() }
    total = total + 1; if miss == "" { miss = _probe_env_get() }
    total = total + 1; if miss == "" { miss = _probe_read_file() }
    total = total + 1; if miss == "" { miss = _probe_file_exists() }
    total = total + 1; if miss == "" { miss = _probe_exec() }
    total = total + 1; if miss == "" { miss = _probe_abs() }
    total = total + 1; if miss == "" { miss = _probe_min() }
    total = total + 1; if miss == "" { miss = _probe_max() }

    total = total + 1; if miss == "" { miss = _probe_string_substring() }
    total = total + 1; if miss == "" { miss = _probe_string_split() }
    total = total + 1; if miss == "" { miss = _probe_string_replace() }
    total = total + 1; if miss == "" { miss = _probe_string_trim() }
    total = total + 1; if miss == "" { miss = _probe_array_push() }
    total = total + 1; if miss == "" { miss = _probe_map_keys() }
    total = total + 1; if miss == "" { miss = _probe_map_values() }

    total = total + 1; if miss == "" { miss = _probe_json_parse_safe() }
    total = total + 1; if miss == "" { miss = _probe_json_parse_or_throw() }
    total = total + 1; if miss == "" { miss = _probe_json_stringify_pretty() }
    total = total + 1; if miss == "" { miss = _probe_json_stringify_value() }
    total = total + 1; if miss == "" { miss = _probe_json_dump_pretty() }
    total = total + 1; if miss == "" { miss = _probe_json_object_set() }
    total = total + 1; if miss == "" { miss = _probe_json_array_push() }

    total = total + 1; if miss == "" { miss = _probe_str_trim() }
    total = total + 1; if miss == "" { miss = _probe_str_starts_with() }
    total = total + 1; if miss == "" { miss = _probe_str_ends_with() }
    total = total + 1; if miss == "" { miss = _probe_str_contains() }
    total = total + 1; if miss == "" { miss = _probe_str_index_of() }
    total = total + 1; if miss == "" { miss = _probe_str_to_upper() }
    total = total + 1; if miss == "" { miss = _probe_str_to_lower() }
    total = total + 1; if miss == "" { miss = _probe_str_repeat() }

    total = total + 1; if miss == "" { miss = _probe_array_reverse() }
    total = total + 1; if miss == "" { miss = _probe_array_contains() }
    total = total + 1; if miss == "" { miss = _probe_array_index_of() }
    total = total + 1; if miss == "" { miss = _probe_array_sum() }
    total = total + 1; if miss == "" { miss = _probe_array_max() }
    total = total + 1; if miss == "" { miss = _probe_array_min() }

    total = total + 1; if miss == "" { miss = _probe_map_size() }
    total = total + 1; if miss == "" { miss = _probe_map_contains_key() }
    total = total + 1; if miss == "" { miss = _probe_map_get_or() }
    total = total + 1; if miss == "" { miss = _probe_map_keys_fn() }
    total = total + 1; if miss == "" { miss = _probe_map_values_fn() }
    total = total + 1; if miss == "" { miss = _probe_map_is_empty() }

    return [miss, total]
}

// Startup-time fail-loud assertion.
// On miss: emit __STDLIB_PARITY__ FAIL missing=<symbol> to stderr +
// exit(7). On pass: silent return (no stdout/stderr).
pub fn conformance_assert_or_die() {
    let r = conformance_run()
    let miss = r[0]
    if miss != "" {
        eprintln("__STDLIB_PARITY__ FAIL missing=" + miss + " mode=" + conformance_active_mode())
        exit(7)
    }
    return
}
