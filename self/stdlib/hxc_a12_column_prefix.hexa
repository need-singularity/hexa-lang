#!hexa strict

// @resolver-bypass(reason="darwin-native byte-canonical pipeline")
// @tool(slug="hxc-a12-column-prefix", desc="HXC algorithm A12: column-prefix dictionary. Detects per-column shared N-char prefixes (≥8 chars, ≥80% rows) — typical case: ISO-8601 ts columns share `YYYY-MM-DDTHH` window. Dictionary-encodes prefix as 1-byte symbol, emits suffix verbatim. Pure-hexa, raw 9 hexa-only. Targets aot_cache_gc.jsonl ts column 70%→77% gap.")
// @usage(hexa $HOME/core/hexa-lang/self/stdlib/hxc_a12_column_prefix.hexa --selftest)
// @usage(hexa $HOME/core/hexa-lang/self/stdlib/hxc_a12_column_prefix.hexa encode <hxc.in> <hxc.out>)
// @usage(hexa $HOME/core/hexa-lang/self/stdlib/hxc_a12_column_prefix.hexa decode <hxc.in> <hxc.out>)
// @exit_codes(0=ok, 1=selftest-fail, 2=io-error, 3=bad-args, 4=decode-mismatch)
//
// Algorithm spec:
//   PASS 1 (detect):
//     For each column c across all rows:
//       Find the longest prefix length L (8 ≤ L ≤ 32) such that ≥80% of rows
//       in column c share the first L chars. (L=0 if no shared prefix exists.)
//     Columns with L > 0 → eligible for prefix dict encoding.
//     Bound: max 8 prefix-eligible columns per schema; max 16 distinct prefixes per column
//     (1-byte symbol space limit, header overhead amortization gate).
//
//   PASS 2 (per-row encode):
//     For each value v in eligible column c with detected prefix p:
//       If v starts with p → emit `^Xsuffix` where ^X is 1-byte symbol from dict.
//       Else → emit verbatim (raw 91 honest C3 — no false-positive replacement).
//
//   Header format: `# col-prefix:<col_id> <symbol>=<prefix>` per column per prefix.
//   Symbol-prefix sigil: `^` (matches A8 convention, raw 65 + 68 idempotent
//   composability — A8 cat-symbols have no ambiguity with A12 prefix-symbols
//   because A12 marker is `^P<X>` triple-byte while A8 is `^<X>` double-byte).
//
// Idempotency contract (raw 65 + 68):
//   - encode(decode(x)) == x for any A12 stream
//   - decode(encode(y)) == y for any HXC v1 stream
//   - encode(encode(y)) byte-equal encode(y) when no detection (singleton).
//
// Falsifiers (raw 71 contract):
//   F-A12-1: saving < 0.05 byte-eq on synthetic ts-column fixture → reject.
//   F-A12-2: encode/decode round-trip not byte-eq → reject.
//   F-A12-3: false-positive replacement (verbatim cell starting with `^P` in raw
//     input gets misinterpreted as A12 symbol) → reject. Mitigation: verbatim cells
//     starting with `^P` get escape `^P^` prefix to disambiguate.

// @attr(complexity="O(N*L) detect + O(N) encode per column", memory="O(D)" where D=distinct-prefix-count)

const A12_MIN_ROWS = 16
const A12_MIN_PREFIX_LEN = 8
const A12_MAX_PREFIX_LEN = 32
const A12_THRESHOLD_X100 = 80  // 80% rows must share prefix
const A12_MAX_COLS = 8
const A12_MAX_DICT_PER_COL = 16
const A12_SYMBOL_ALPHABET = "ABCDEFGHIJKLMNOP"  // 16 chars, dense block uppercase

// ───────────────────── helpers ─────────────────────

fn _common_prefix_len(a: string, b: string) -> int {
    let mut i = 0
    let la = len(a)
    let lb = len(b)
    let lim = if la < lb { la } else { lb }
    while i < lim {
        if a.substring(i, i + 1) != b.substring(i, i + 1) { break }
        i = i + 1
    }
    return i
}

fn _split_top_level_pipes(s: string) -> array {
    let mut segs = []
    let mut depth_brace = 0
    let mut depth_bracket = 0
    let mut in_str = false
    let mut esc = false
    let mut start = 0
    let mut i = 0
    while i < len(s) {
        let c = s.substring(i, i + 1)
        if esc { esc = false; i = i + 1; continue }
        if in_str {
            if c == "\\" { esc = true }
            else if c == "\"" { in_str = false }
        } else {
            if c == "\"" { in_str = true }
            else if c == "{" { depth_brace = depth_brace + 1 }
            else if c == "}" { depth_brace = depth_brace - 1 }
            else if c == "[" { depth_bracket = depth_bracket + 1 }
            else if c == "]" { depth_bracket = depth_bracket - 1 }
            else if c == "|" && depth_brace == 0 && depth_bracket == 0 {
                segs.push(s.substring(start, i))
                start = i + 1
            }
        }
        i = i + 1
    }
    if start <= len(s) { segs.push(s.substring(start, len(s))) }
    return segs
}

// ───────────────────── detect prefix per column ─────────────────────

// Phase 8 P2: multi-prefix-per-column extension.
// Returns array of [col_id, prefix_string] entries — multiple entries per col_id allowed
// when top-K prefixes at the same length combine to ≥THRESHOLD% coverage.
// Each prefix gets its own symbol; encode chooses best-matching prefix per row.
fn _detect_prefix_columns(rows: array) -> array {
    let mut out = []
    if len(rows) < A12_MIN_ROWS { return out }
    let first_cols = _split_top_level_pipes(rows[0])
    let n_cols = len(first_cols)
    let mut col_id = 0
    let mut col_count = 0
    while col_id < n_cols && col_count < A12_MAX_COLS {
        let mut vals = []
        let mut r = 0
        while r < len(rows) {
            let parts = _split_top_level_pipes(rows[r])
            if col_id < len(parts) { vals.push(parts[col_id]) }
            r = r + 1
        }
        if len(vals) < A12_MIN_ROWS { col_id = col_id + 1; continue }

        // Phase 8 P2 multi-prefix scan: try LONGEST p_len first.
        // At each p_len, find top-K most frequent prefixes whose combined coverage
        // ≥THRESHOLD% — that p_len wins. K bounded by A12_MAX_DICT_PER_COL.
        let mut best_p_len = 0
        let mut best_prefixes = []
        let mut best_coverage = 0
        let mut p_len = A12_MAX_PREFIX_LEN
        while p_len >= A12_MIN_PREFIX_LEN {
            let mut prefixes = []
            let mut counts = []
            let mut v = 0
            while v < len(vals) {
                let val = vals[v]
                if len(val) >= p_len {
                    let prefix = val.substring(0, p_len)
                    let mut found = -1
                    let mut k = 0
                    while k < len(prefixes) {
                        if prefixes[k] == prefix { found = k; break }
                        k = k + 1
                    }
                    if found >= 0 {
                        counts[found] = counts[found] + 1
                    } else {
                        prefixes.push(prefix)
                        counts.push(1)
                    }
                }
                v = v + 1
            }
            // Sort prefixes by count desc, take top-K
            let mut top_prefixes = []
            let mut covered = 0
            let mut k_count = 0
            while k_count < A12_MAX_DICT_PER_COL && len(prefixes) > 0 {
                let mut max_idx = -1
                let mut max_cnt = 0
                let mut k = 0
                while k < len(prefixes) {
                    if counts[k] > max_cnt { max_cnt = counts[k]; max_idx = k }
                    k = k + 1
                }
                if max_idx < 0 { break }
                if max_cnt == 0 { break }
                top_prefixes.push(prefixes[max_idx])
                covered = covered + max_cnt
                counts[max_idx] = 0  // mark consumed
                k_count = k_count + 1
            }
            let coverage_x100 = (covered * 100) / len(vals)
            // Phase 8 P2: net savings calc INCLUDES dict header overhead.
            //   covered_bytes_saved = covered * (p_len - 3)  // per-row save: p_len chars → 3-byte symbol
            //   header_overhead = K_prefixes * (~25 byte_format + p_len)
            //   net = covered_bytes_saved - header_overhead
            // Threshold gate: coverage ≥80% AND net savings > 0.
            if coverage_x100 >= A12_THRESHOLD_X100 {
                let saved_per_row = if p_len > 3 { p_len - 3 } else { 0 }
                let total_saved = covered * saved_per_row
                let header_overhead = len(top_prefixes) * (25 + p_len)
                let net_savings = total_saved - header_overhead
                let best_total = best_coverage * (if best_p_len > 3 { best_p_len - 3 } else { 0 })
                let best_header = len(best_prefixes) * (25 + best_p_len)
                let best_net = best_total - best_header
                if net_savings > best_net && net_savings > 0 {
                    best_p_len = p_len
                    best_prefixes = top_prefixes
                    best_coverage = covered
                }
            }
            p_len = p_len - 1
        }
        // Emit all detected prefixes for this column
        let mut bp = 0
        while bp < len(best_prefixes) {
            out.push([to_string(col_id), best_prefixes[bp]])
            bp = bp + 1
        }
        if len(best_prefixes) > 0 { col_count = col_count + 1 }
        col_id = col_id + 1
    }
    return out
}

// ───────────────────── encode / decode ─────────────────────

// Phase 8 P1 helper: replace prefix in a column-value with token `^P<sym>suffix`.
// Disambiguation: cell starting with `^P` literal gets escape `^P^` prefix.
fn _replace_prefix(val: string, prefix: string, sym: string) -> string {
    let pl = len(prefix)
    let vl = len(val)
    if vl >= pl && val.substring(0, pl) == prefix {
        return "^P" + sym + val.substring(pl, vl)
    }
    // Disambiguation: cell that naturally starts with `^P` needs escape
    if vl >= 2 && val.substring(0, 2) == "^P" {
        return "^P^" + val
    }
    return val
}

fn _restore_prefix(val: string, prefix_map: array) -> string {
    // prefix_map: array of [col_id, prefix, sym] (we only get sym here, lookup by sym)
    // val format: `^P<sym>suffix` OR `^P^<orig>` OR verbatim
    if len(val) < 3 { return val }
    if val.substring(0, 2) != "^P" { return val }
    if val.substring(0, 3) == "^P^" {
        return val.substring(3, len(val))  // strip escape
    }
    let sym = val.substring(2, 3)
    let mut k = 0
    while k < len(prefix_map) {
        if prefix_map[k][2] == sym {
            return prefix_map[k][1] + val.substring(3, len(val))
        }
        k = k + 1
    }
    return val
}

fn a12_encode(v1_text: string) -> string {
    let lines = v1_text.split("\n")
    // Group rows by schema (lines starting with `@<schema>`)
    let mut schema_rows = []
    let mut schema_keys = []
    let mut header_lines = []
    let mut i = 0
    while i < len(lines) {
        let l = lines[i]
        if len(l) >= 9 && l.substring(0, 9) == "# schema:" {
            header_lines.push(l)
            schema_keys.push(l)
            schema_rows.push([])
        } else if len(l) >= 1 && l.substring(0, 1) == "@" {
            if len(schema_rows) > 0 {
                let last_idx = len(schema_rows) - 1
                let body_start = l.find(" ")
                let body = if body_start > 0 { l.substring(body_start + 1, len(l)) } else { "" }
                schema_rows[last_idx].push(body)
            } else {
                header_lines.push(l)
            }
        } else if len(l) > 0 {
            header_lines.push(l)
        }
        i = i + 1
    }

    let mut out = []
    let mut h = 0
    while h < len(header_lines) {
        out.push(header_lines[h])
        h = h + 1
    }

    let mut s = 0
    while s < len(schema_rows) {
        let rows = schema_rows[s]
        let detected = _detect_prefix_columns(rows)
        // Emit dict declarations + build sym table — bound to alphabet length (16).
        let mut d = 0
        while d < len(detected) && d < len(A12_SYMBOL_ALPHABET) {
            let col_id = detected[d][0]
            let prefix = detected[d][1]
            let symbol = A12_SYMBOL_ALPHABET.substring(d, d + 1)
            out.push("# col-prefix:s" + to_string(s + 1) + " " + col_id + " " + symbol + "=" + prefix)
            detected[d].push(symbol)
            d = d + 1
        }
        // Truncate detected to assigned-symbol entries only
        while len(detected) > d {
            detected.pop()
        }
        // Phase 8 P2: per-row encoding picks BEST matching prefix from multi-prefix dict.
        let mut r = 0
        while r < len(rows) {
            let parts = _split_top_level_pipes(rows[r])
            let mut new_parts = []
            let mut p = 0
            while p < len(parts) {
                let mut val = parts[p]
                // Find best matching detected entry: longest prefix that val starts with
                let mut best_match = -1
                let mut best_match_len = 0
                let mut dd = 0
                while dd < len(detected) {
                    if parse_int(detected[dd][0]) == p {
                        let pref = detected[dd][1]
                        let pl = len(pref)
                        if len(val) >= pl && val.substring(0, pl) == pref && pl > best_match_len {
                            best_match = dd
                            best_match_len = pl
                        }
                    }
                    dd = dd + 1
                }
                if best_match >= 0 {
                    val = _replace_prefix(val, detected[best_match][1], detected[best_match][2])
                } else {
                    // Disambiguation only — column has prefix dict but this row doesn't match
                    if len(val) >= 2 && val.substring(0, 2) == "^P" {
                        val = "^P^" + val
                    }
                }
                new_parts.push(val)
                p = p + 1
            }
            out.push("@s" + to_string(s + 1) + " " + new_parts.join("|"))
            r = r + 1
        }
        s = s + 1
    }
    return out.join("\n") + "\n"
}

fn a12_decode(v2_text: string) -> string {
    // Inverse: parse `# col-prefix:` headers into per-schema dict, restore prefix in cells.
    let lines = v2_text.split("\n")
    // schema_dicts: array of array of [col_id, prefix, sym]
    let mut schema_dicts = []
    let mut current_schema = -1
    let mut out = []
    let mut i = 0
    while i < len(lines) {
        let l = lines[i]
        if len(l) >= 9 && l.substring(0, 9) == "# schema:" {
            schema_dicts.push([])
            current_schema = len(schema_dicts) - 1
            out.push(l)
        } else if len(l) >= 14 && l.substring(0, 14) == "# col-prefix:s" {
            // Parse: `# col-prefix:s<N> <col_id> <sym>=<prefix>`
            // Find schema number
            let after = l.substring(14, len(l)).trim()
            let sp1 = after.find(" ")
            if sp1 > 0 {
                let s_num = parse_int(after.substring(0, sp1)) - 1
                let rest = after.substring(sp1 + 1, len(after))
                let sp2 = rest.find(" ")
                if sp2 > 0 {
                    let col_id = rest.substring(0, sp2)
                    let sym_pref = rest.substring(sp2 + 1, len(rest))
                    let eq = sym_pref.find("=")
                    if eq > 0 {
                        let sym = sym_pref.substring(0, eq)
                        let prefix = sym_pref.substring(eq + 1, len(sym_pref))
                        if s_num >= 0 && s_num < len(schema_dicts) {
                            schema_dicts[s_num].push([col_id, prefix, sym])
                        }
                    }
                }
            }
            // Skip emission (dict header is consumed by decoder)
        } else if len(l) >= 1 && l.substring(0, 1) == "@" {
            // Determine schema from `@s<N>`
            let body_start = l.find(" ")
            let head = if body_start > 0 { l.substring(0, body_start) } else { l }
            let body = if body_start > 0 { l.substring(body_start + 1, len(l)) } else { "" }
            let s_num = if len(head) > 2 { parse_int(head.substring(2, len(head))) - 1 } else { 0 }
            if s_num < 0 || s_num >= len(schema_dicts) {
                out.push(l)
                i = i + 1
                continue
            }
            let dict = schema_dicts[s_num]
            let parts = _split_top_level_pipes(body)
            let mut new_parts = []
            let mut p = 0
            while p < len(parts) {
                new_parts.push(_restore_prefix(parts[p], dict))
                p = p + 1
            }
            out.push(head + " " + new_parts.join("|"))
        } else if len(l) > 0 {
            // Symmetric to encoder: skip empty lines (encoder filters via len > 0 gate).
            out.push(l)
        }
        i = i + 1
    }
    return out.join("\n") + "\n"
}

// ───────────────────── selftest ─────────────────────

fn _selftest() -> int {
    println("# hxc_a12_column_prefix selftest")
    let mut pass = 0
    let mut fail = 0

    // Fixture: 20 rows, ts column with shared `2026-04-25T14` prefix
    let mut fixture_rows = []
    let mut i = 0
    while i < 20 {
        let mn = if i < 10 { "0" + to_string(i) } else { to_string(i) }
        fixture_rows.push("@s1 \"2026-04-25T14:" + mn + ":00Z\"|" + to_string(i) + "|true")
        i = i + 1
    }
    let fixture = "# schema:s1 ts col_int col_bool\n" + fixture_rows.join("\n") + "\n"

    let encoded = a12_encode(fixture)
    let decoded = a12_decode(encoded)

    // Test 1: dict header emitted
    let lines = encoded.split("\n")
    let mut has_dict = false
    let mut k = 0
    while k < len(lines) {
        if len(lines[k]) >= 14 && lines[k].substring(0, 14) == "# col-prefix:s" { has_dict = true; break }
        k = k + 1
    }
    if has_dict { pass = pass + 1; println("  PASS: detect emits dict header") } else { fail = fail + 1; println("  FAIL: no dict header") }

    // Test 2: decode strips dict + identity body
    let decoded_lines = decoded.split("\n")
    let mut decode_ok = true
    let mut dk = 0
    while dk < len(decoded_lines) {
        if len(decoded_lines[dk]) >= 14 && decoded_lines[dk].substring(0, 14) == "# col-prefix:s" { decode_ok = false; break }
        dk = dk + 1
    }
    if decode_ok { pass = pass + 1; println("  PASS: decode strips dict") } else { fail = fail + 1; println("  FAIL: dict survived decode") }

    // Test 3: round-trip body length preserved (PROVISIONAL — body unchanged in scaffold)
    let fixture_data_only = fixture
    let decoded_normalized = decoded.replace("@s1", "@s1")  // normalize markers
    if len(decoded_normalized) >= len(fixture_data_only) - 50 {
        pass = pass + 1
        println("  PASS: round-trip preserves body bytes (scaffold-tier)")
    } else {
        fail = fail + 1
        println("  FAIL: round-trip lost body bytes")
    }

    // Test 4: detect respects MIN_ROWS
    let small_fixture = "# schema:s1 ts col_int\n@s1 \"2026-04-25T14:00:00Z\"|0\n"
    let small_encoded = a12_encode(small_fixture)
    let small_lines = small_encoded.split("\n")
    let mut small_has_dict = false
    let mut sk = 0
    while sk < len(small_lines) {
        if len(small_lines[sk]) >= 14 && small_lines[sk].substring(0, 14) == "# col-prefix:s" { small_has_dict = true; break }
        sk = sk + 1
    }
    if !small_has_dict { pass = pass + 1; println("  PASS: small fixture (1 row) skipped (MIN_ROWS=16)") } else { fail = fail + 1; println("  FAIL: small fixture incorrectly emitted dict") }

    // Test 5: Phase 8 P1 — body replacement actually shrinks bytes
    let nb = len(fixture)
    let hb = len(encoded)
    if hb < nb {
        pass = pass + 1
        println("  PASS: P1 body replacement saves bytes " + to_string(nb) + " -> " + to_string(hb))
    } else {
        fail = fail + 1
        println("  FAIL: P1 body replacement did not save bytes " + to_string(nb) + " -> " + to_string(hb))
    }

    // Test 6: Phase 8 P1 — round-trip byte-eq (encode → decode == original)
    let encoded_p1 = a12_encode(fixture)
    let decoded_p1 = a12_decode(encoded_p1)
    if decoded_p1 == fixture {
        pass = pass + 1
        println("  PASS: P1 round-trip byte-eq")
    } else {
        fail = fail + 1
        println("  FAIL: P1 round-trip lost bytes")
        println("    expected len=" + to_string(len(fixture)))
        println("    got      len=" + to_string(len(decoded_p1)))
    }

    // Test 7: Phase 8 P1 — disambiguation (cells starting with ^P get escaped)
    let amb_fixture = "# schema:s1 ts text\n"
    let mut amb_rows = []
    let mut a = 0
    while a < 16 {
        let mn = if a < 10 { "0" + to_string(a) } else { to_string(a) }
        amb_rows.push("@s1 \"2026-04-25T14:" + mn + ":00Z\"|^Pliteral")
        a = a + 1
    }
    let amb_full = amb_fixture + amb_rows.join("\n") + "\n"
    let amb_encoded = a12_encode(amb_full)
    let amb_decoded = a12_decode(amb_encoded)
    if amb_decoded == amb_full {
        pass = pass + 1
        println("  PASS: P1 disambiguation escape preserves ^P-literal cells")
    } else {
        fail = fail + 1
        println("  FAIL: P1 disambiguation broken")
    }

    println("Results: " + to_string(pass) + " PASS / " + to_string(fail) + " FAIL")
    println("__HXC_A12_SELFTEST__ " + (if fail == 0 { "PASS" } else { "FAIL" }))
    if fail == 0 { return 0 }
    return 1
}

// ───────────────────── main ─────────────────────

fn _shell_escape(s: string) -> string {
    let mut parts = []
    parts.push("'")
    let mut i = 0
    while i < len(s) {
        let c = s.substring(i, i + 1)
        if c == "'" { parts.push("'\\''") } else { parts.push(c) }
        i = i + 1
    }
    parts.push("'")
    return parts.join("")
}

fn _read_file(p: string) -> string {
    // Phase 8 P5: native read_file() via rt_read_file.
    return read_file(p)
}
fn _write_file(p: string, c: string) -> int {
    // Phase 8 P5: native write_file() — heredoc fails for content > shell ARG_MAX.
    let _r = write_file(p, c)
    return 0
}

fn main() {
    let av = argv()
    let mut start = len(av)
    let mut i = 0
    while i < len(av) {
        if len(av[i]) >= 2 && av[i].substring(0, 2) == "--" { start = i; break }
        i = i + 1
    }
    let mut flags = []
    let mut j = start
    while j < len(av) { flags.push(av[j]); j = j + 1 }

    let mut has_selftest = false
    let mut has_encode = false
    let mut has_decode = false
    let mut k = 0
    while k < len(av) {
        if av[k] == "--selftest" { has_selftest = true }
        if av[k] == "encode" { has_encode = true }
        if av[k] == "decode" { has_decode = true }
        k = k + 1
    }

    if has_selftest { exit(_selftest()) }

    if has_encode || has_decode {
        // find positional args after subcommand
        let mut sub_idx = 0
        let mut q = 0
        while q < len(av) {
            if av[q] == "encode" || av[q] == "decode" { sub_idx = q; break }
            q = q + 1
        }
        if sub_idx + 2 >= len(av) {
            eprintln("usage: hexa hxc_a12_column_prefix.hexa <encode|decode> <in> <out>")
            exit(3)
        }
        let in_path = av[sub_idx + 1]
        let out_path = av[sub_idx + 2]
        let txt = _read_file(in_path)
        let res = if has_encode { a12_encode(txt) } else { a12_decode(txt) }
        let _w = _write_file(out_path, res)
        exit(0)
    }

    eprintln("usage: hexa hxc_a12_column_prefix.hexa [--selftest | encode <in> <out> | decode <in> <out>]")
    exit(3)
}
