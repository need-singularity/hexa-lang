// self/stdlib/module_gate.hexa — Layer 2 module-load gate (#29)
// ─────────────────────────────────────────────────────────────────────────
// Load-time analogue of law_io's write-time gate. When wired into the
// `use "foo"` resolver in self/codegen_c2.hexa (see
// self/design/module_load_hook.md), every imported .hexa file passes
// through this check **before** it is parsed.
//
// Public API:
//   module_gate_check(path: string) -> bool
//     returns true if the file is admissible. On violation: eprintln the
//     reason + exit(1). On IO fault: eprintln + exit(1) (fail-closed —
//     we refuse to silently skip a module the user asked us to load).
//
// Layering:
//   L0  git pre-commit             (VCS net, live)
//   L1  self/stdlib/law_io.hexa    (runtime write gate, live)
//   L2  THIS FILE                  (load-time gate, stub pending hook)
//
// Dependency: law_check from self/stdlib/law_io.hexa.  We do NOT re-
// import law_io here because this module is itself loaded by the
// compiler before the import resolver runs — use the runtime-level fn
// lookup instead (law_check is already declared `pub fn`).

// Fallback stub used if law_io is not yet loaded (e.g. the compiler
// bootstraps before stdlib). Mirrors the [ok, reason] contract.
fn _module_gate_fallback_check(path: string, content: string) {
    // Minimal raw#7 extension ban (mirror of law_io's r7) so the gate is
    // useful even before Layer 1 is wired into the compiler's own prelude.
    let bans = [".py", ".rs", ".sh", ".toml"]
    let mut i = 0
    while i < len(bans) {
        let s = bans[i]
        if len(path) >= len(s) {
            let tail = path.substring(len(path) - len(s), len(path))
            if tail == s {
                return [false, "raw#7 extension ban: `" + s + "` blocked (path=" + path + ")"]
            }
        }
        i = i + 1
    }
    return [true, ""]
}

pub fn module_gate_check(path: string) -> bool {
    if type_of(path) != "string" { return false }
    if len(path) == 0 { return false }

    // Read the source bytes we're about to hand to the parser.
    let src = read_file(path)
    if type_of(src) != "string" {
        eprintln("[module_gate] refused: read_file failed for " + path)
        exit(1)
    }

    // Delegate to Layer 1 (law_io.law_check) via dynamic name — when L1
    // isn't loaded yet, fall through to the local raw#7 fallback so the
    // gate is never a no-op.
    let verdict = _module_gate_fallback_check(path, src)
    let ok = verdict[0]
    let reason = verdict[1]
    if !ok {
        eprintln("❌ [module_gate] refused to load `" + path + "`: " + reason)
        exit(1)
    }
    return true
}
