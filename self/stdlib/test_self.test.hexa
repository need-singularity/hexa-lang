// self/stdlib/test_self.test.hexa — framework eats own dogfood (raw 18).
//
// Uses self/stdlib/test + self/stdlib/expect to verify the framework's
// describe/it/expect/mock/snapshot exports work AS A USER WOULD CALL THEM.
// This is the self-host fixpoint check (raw 18): if this file's output
// summary is `__TEST_RUNNER_RESULT__ PASS`, the framework is consistent
// under its own observation lens.
//
// Discovery target: hexa run self/stdlib/test_runner.hexa --discover self/stdlib
//   ↳ runner picks up this file (matches *.test.hexa), runs it, reads the
//     last __TEST_RUNNER_RESULT__ line, aggregates.

use "self/stdlib/test"
use "self/stdlib/expect"
use "self/stdlib/test_mock"
use "self/stdlib/test_snapshot"

// ─── inner test bodies (no closures over local state) ────────────────
// The interp doesn't honor closures over local lets reliably from a
// nested fn body, so each test fn is a top-level fn that reads from
// well-defined globals or only does pure arithmetic. This mirrors how
// hive *.test.hexa ports will be authored — each `it()` body is a
// top-level fn referenced by name.

fn _self_t_arithmetic() {
    assert_eq(1 + 1, 2)
    assert_eq(2 * 3, 6)
}

fn _self_t_string_contains() {
    assert_contains("hello world", "world")
    assert_contains("a/b/c.test.hexa", ".test.hexa")
}

fn _self_t_array_deep_eq() {
    assert_deep_eq([1, 2, 3], [1, 2, 3])
    assert_deep_eq([[1], [2, 3]], [[1], [2, 3]])
}

fn _self_t_defined() {
    assert_defined(42)
    assert_defined("text")
    assert_defined([])
}

fn _self_t_chained_form() {
    let m = expect(7)
    to_be(m, 7)
    to_equal(expect([1, 2]), [1, 2])
}

// ─── mock spy roundtrip ──────────────────────────────────────────────
fn _self_t_mock_roundtrip() {
    mock_clear_all()
    let id = mock_new("spy")
    mock_record(id, [1, 2, 3])
    mock_record(id, ["x"])
    assert_eq(mock_call_count(id), 2)
    if !mock_was_called_with(id, [1, 2, 3]) {
        test_record_failure("mock_was_called_with positive failed")
    }
    mock_set_return(id, 99)
    assert_eq(mock_get_return(id), 99)
}

// ─── snapshot roundtrip ──────────────────────────────────────────────
fn _self_t_snapshot_roundtrip() {
    let pid = to_string(exec("echo $$")).trim()
    let snap_path = "/tmp/_hexa_self_dogfood_" + pid + ".snap"
    let _ = exec("rm -f " + snap_path)
    // First run: writes
    to_match_snapshot_in(snap_path, "case_a", "expected-value")
    // Second run: matches read-back — should NOT record failure
    to_match_snapshot_in(snap_path, "case_a", "expected-value")
    let _ = exec("rm -f " + snap_path)
}

// ─── describe groups ─────────────────────────────────────────────────
fn _self_describe_basic() {
    it("arithmetic", _self_t_arithmetic)
    it("string contains", _self_t_string_contains)
    it("array deep equal", _self_t_array_deep_eq)
    it("defined-ness", _self_t_defined)
    it("chained matcher form", _self_t_chained_form)
}

fn _self_describe_mock() {
    it("mock roundtrip", _self_t_mock_roundtrip)
}

fn _self_describe_snapshot() {
    it("snapshot roundtrip", _self_t_snapshot_roundtrip)
}

// ─── nested describe ─────────────────────────────────────────────────
fn _self_describe_nested_inner() {
    it("inner case", _self_t_arithmetic)
}

fn _self_describe_nested_outer() {
    describe("inner", _self_describe_nested_inner)
}

// ─── entry ───────────────────────────────────────────────────────────
test_clear()

describe("framework basics", _self_describe_basic)
describe("framework mock", _self_describe_mock)
describe("framework snapshot", _self_describe_snapshot)
describe("framework nested describe", _self_describe_nested_outer)

// Final summary line — runner picks this up.
test_summary()
