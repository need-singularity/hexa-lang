// self/stdlib/bytes.hexa — byte/uint conversions (P1 — qmirror per-shot perf)
//
// @module(slug="self-stdlib-bytes", desc="byte-array <-> integer + hex helpers")
// @usage(use "self/stdlib/bytes"; let u = bytes_to_uint64(qrng_bytes, 0))
//
// Source: anima/docs/hexa_lang_attr_review_for_qmirror_2026_05_03.md §5.5
//
// Mirror of stdlib/bytes.hexa — same API, kept here for resolver-order
// safety with sister-repos using the `self/stdlib/...` import path. P0
// proc bridge follows the same dual-copy convention.
//
// PROBLEM: qmirror sampler does `exec("printf '%d' 0x" + pair)` per byte
// (50K shots × 8B → 400K forks). Pure-arithmetic fold eliminates the
// fork cost.
//
// FIX (additive, no runtime.c change):
//   1. bytes_to_uint64(b, offset) -> int   (big-endian)
//   2. bytes_to_uint64_le(b, offset) -> int
//   3. bytes_to_uint32(b, offset) -> int
//   4. int_from_hex(s) -> int
//   5. hex_encode_bytes(b) -> string  (NOT runtime hex_encode — int-array input)
//   6. uint64_to_unit_float(u) -> float
//
// Breaking risk: 0. New module, all new symbols.
//
// Caveats (raw#91): byte values outside 0..255 silently wrong · only low
// 53 bits used in unit_float (mantissa fit) · pure-hexa arithmetic loops,
// no SIMD (KB-scale conversions should profile and possibly move to a
// future C builtin).
//
// raw#9 hexa-only-strict: pure hexa, zero exec(), zero new C builtin.

fn bytes_to_uint64(b, offset: int) -> int {
    if offset < 0 { return 0 }
    if type_of(b) != "array" { return 0 }
    if offset + 8 > len(b) { return 0 }
    let mut u = 0
    let mut i = 0
    while i < 8 {
        u = u * 256 + b[offset + i]
        i = i + 1
    }
    return u
}

fn bytes_to_uint64_le(b, offset: int) -> int {
    if offset < 0 { return 0 }
    if type_of(b) != "array" { return 0 }
    if offset + 8 > len(b) { return 0 }
    let mut u = 0
    let mut i = 7
    while i >= 0 {
        u = u * 256 + b[offset + i]
        i = i - 1
    }
    return u
}

fn bytes_to_uint32(b, offset: int) -> int {
    if offset < 0 { return 0 }
    if type_of(b) != "array" { return 0 }
    if offset + 4 > len(b) { return 0 }
    let mut u = 0
    let mut i = 0
    while i < 4 {
        u = u * 256 + b[offset + i]
        i = i + 1
    }
    return u
}

fn int_from_hex(s: string) -> int {
    if len(s) == 0 { return 0 }
    let mut t = s.trim()
    if len(t) >= 2 && t.substring(0, 2) == "0x" {
        t = t.substring(2, len(t))
    }
    if len(t) >= 2 && t.substring(0, 2) == "0X" {
        t = t.substring(2, len(t))
    }
    if len(t) == 0 { return 0 }
    let mut acc = 0
    let mut i = 0
    while i < len(t) {
        let ch = t.substring(i, i + 1)
        let d = _bytes_hex_digit(ch)
        if d < 0 { return 0 }
        acc = acc * 16 + d
        i = i + 1
    }
    return acc
}

fn _bytes_hex_digit(ch: string) -> int {
    if ch == "0" { return 0 }
    if ch == "1" { return 1 }
    if ch == "2" { return 2 }
    if ch == "3" { return 3 }
    if ch == "4" { return 4 }
    if ch == "5" { return 5 }
    if ch == "6" { return 6 }
    if ch == "7" { return 7 }
    if ch == "8" { return 8 }
    if ch == "9" { return 9 }
    if ch == "a" || ch == "A" { return 10 }
    if ch == "b" || ch == "B" { return 11 }
    if ch == "c" || ch == "C" { return 12 }
    if ch == "d" || ch == "D" { return 13 }
    if ch == "e" || ch == "E" { return 14 }
    if ch == "f" || ch == "F" { return 15 }
    return -1
}

fn hex_encode_bytes(b) -> string {
    if type_of(b) != "array" { return "" }
    let table = "0123456789abcdef"
    let mut s = ""
    let mut i = 0
    while i < len(b) {
        let v = b[i]
        let hi = (v / 16) % 16
        let lo = v % 16
        s = s + table.substring(hi, hi + 1) + table.substring(lo, lo + 1)
        i = i + 1
    }
    return s
}

fn uint64_to_unit_float(u: int) -> float {
    let denom = 9007199254740992.0  // 2^53
    let masked = u % 9007199254740992
    return to_float(masked) / denom
}

// ═══════════════════════════════════════════════════════════════════════════
//  CHUNKED FILE I/O — interpreter-safe byte processing primitives
//
//  WHY (interp memory model)
//    The hexa interpreter represents `[int]` byte arrays as a HexaArr of
//    boxed HexaVal values (~16 B per element minimum, plus realloc growth
//    and arena bookkeeping — empirically ~120 B per byte at 1 MiB sizes).
//    Holding a 1 MiB payload as a single int-array therefore peaks RSS at
//    ~120 MiB inside the interpreter — which is enough to trip the docker
//    `mac_safe_landing` 4 GiB cap once the surrounding test ALSO holds
//    int-arrays in scope. F-SAFETENSORS-1 caps the default payload at
//    32 KiB; F-SQLITE rewrote bulk inserts as 1000-row LIMIT/OFFSET
//    chunks for the same reason.
//
//    Native AOT packs to true bytes and is unaffected. These helpers
//    exist so pure-interp producers can stream bounded chunks instead of
//    materializing a single boxed mega-array.
//
//  RECOMMENDED CEILING
//    bytes_interp_chunk_default() = 65536 (64 KiB)
//      · ~7.5 MiB RSS at peak — fits inside any sandbox cap
//      · matches the read_bytes_at / write_bytes_append fast region
//      · 16x the F-SAFETENSORS-1 default 32 KiB and 64x the F-SQLITE
//        per-row tier — both already proven workable
//    Larger chunks ARE supported (cap is per-call, not per-process) but
//    trade RSS linearly. Tune downward if the surrounding script holds
//    many other int-arrays simultaneously.
//
//  PRIMITIVES (all build on streaming runtime builtins:
//              read_bytes_at / write_bytes_append / file_size / write_bytes)
//    bytes_interp_chunk_default()              -> 65536
//    bytes_iter_file_chunked(path, n, cb)      — call cb(off, chunk) per chunk
//    bytes_copy_file_chunked(src, dst, n)      — bounded-RSS file copy
//    bytes_fold_file_chunked(path, n, init, fold) — fold over chunks
//    bytes_count_byte_in_file(path, b, n)      — count occurrences of byte b
//
//  raw#9 hexa-only-strict: pure hexa, zero exec(), zero new C builtin.
// ═══════════════════════════════════════════════════════════════════════════

fn bytes_interp_chunk_default() -> int {
    return 65536
}

fn bytes_iter_file_chunked(path: string, chunk_size: int, cb) -> int {
    if chunk_size <= 0 { return 0 }
    let total = file_size(path)
    if total <= 0 { return 0 }
    let mut off = 0
    while off < total {
        let want = chunk_size
        let remaining = total - off
        let take = if remaining < want { remaining } else { want }
        let chunk = read_bytes_at(path, off, take)
        let got = len(chunk)
        if got == 0 { return off }
        cb(off, chunk)
        off = off + got
        if got < take { return off }
    }
    return off
}

fn bytes_copy_file_chunked(src: string, dst: string, chunk_size: int) -> int {
    if chunk_size <= 0 { return 0 }
    let total = file_size(src)
    if total <= 0 { return 0 }
    write_bytes(dst, [])
    let mut off = 0
    while off < total {
        let want = chunk_size
        let remaining = total - off
        let take = if remaining < want { remaining } else { want }
        let chunk = read_bytes_at(src, off, take)
        let got = len(chunk)
        if got == 0 { return off }
        write_bytes_append(dst, chunk)
        off = off + got
        if got < take { return off }
    }
    return off
}

fn bytes_fold_file_chunked(path: string, chunk_size: int, init, fold) {
    if chunk_size <= 0 { return init }
    let total = file_size(path)
    if total <= 0 { return init }
    let mut acc = init
    let mut off = 0
    while off < total {
        let want = chunk_size
        let remaining = total - off
        let take = if remaining < want { remaining } else { want }
        let chunk = read_bytes_at(path, off, take)
        let got = len(chunk)
        if got == 0 { return acc }
        acc = fold(acc, off, chunk)
        off = off + got
        if got < take { return acc }
    }
    return acc
}

fn bytes_count_byte_in_file(path: string, target: int, n: int) -> int {
    if target < 0 { return 0 }
    if target > 255 { return 0 }
    let chunk_size = if n <= 0 { bytes_interp_chunk_default() } else { n }
    let t = target & 0xFF
    return bytes_fold_file_chunked(path, chunk_size, 0, fn(acc, _off, c) {
        let mut z = acc
        let mut i = 0
        let m = len(c)
        while i < m {
            if (c[i] & 0xFF) == t { z = z + 1 }
            i = i + 1
        }
        return z
    })
}
