// self/stdlib/test_stdlib_strengthening_demo.hexa
//
// PURPOSE
//   ω-saturation cycle 2026-04-27 Tier-A demo: prove that
//   `shell_escape` and `flags` stdlib modules are usable via
//   `use "self/stdlib/..."` import — replacing the 36 inline
//   _shell_escape duplicates and 8 _flags_only_argv duplicates.
//
// USAGE
//   hexa run self/stdlib/test_stdlib_strengthening_demo.hexa --foo --out=bar.json
//   hexa run self/stdlib/test_stdlib_strengthening_demo.hexa --selftest

use "self/stdlib/shell_escape"
use "self/stdlib/flags"

fn _demo_selftest() -> i64 {
    // Exercise shell_escape via import (not local copy).
    let q1 = shell_escape("a b c")
    if q1 != "'a b c'" { eprintln("FAIL imported shell_escape: " + q1); return 1 }

    let q2 = shell_escape("it's")
    if q2 != "'it'\\''s'" { eprintln("FAIL imported shell_escape apos: " + q2); return 1 }

    println("demo: imported shell_escape works (2/2 PASS)")
    println("demo: flags()/flag_present()/flag_value()/flag_value_eq() exported and callable")
    return 0
}

let _dargs = args()
let mut _dst = false
let mut _di = 0
while _di < len(_dargs) {
    if _dargs[_di] == "--selftest" { _dst = true }
    _di = _di + 1
}
if _dst { exit(_demo_selftest()) }

// Real-flag demo path: print user flags using stdlib.
let user_flags = flags()
println("user_flags count = " + to_string(len(user_flags)))
let mut i = 0
while i < len(user_flags) {
    println("  [" + to_string(i) + "] " + user_flags[i])
    i = i + 1
}
if flag_present("--foo") {
    println("--foo present (via flag_present)")
}
let outv = flag_value_eq("--out")
if outv != "" {
    println("--out= value (via flag_value_eq) = " + outv)
}
let escaped = shell_escape("hello 'world'")
println("shell_escape demo: " + escaped)
