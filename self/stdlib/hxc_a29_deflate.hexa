#!hexa strict

// @resolver-bypass(reason="darwin-native HXC DEFLATE LZ77+canonical-Huffman pipeline")
// @tool(slug="hxc-a29-deflate", desc="HXC algorithm A29: DEFLATE-class lossless coder = LZ77 (A18 v1 tokenizer reuse, MAX_MATCH=258 RFC 1951) + canonical Huffman entropy coder over literal/length+distance alphabets. Phase 13 P0 entry — post-A25 v2 76.24% ceiling-advance PRIMARY recommendation per a875c76c design doc §3.1. Pure hexa raw 9 + raw 18 self-host (integer-only Huffman tree build via in-place priority queue, no fp ops). raw 137 cmix-ban MAINTAINED (deterministic prefix codes, NOT neural mixer). FIRST TICK BUILD: PASS 1 (LZ77 tokenize) + PASS 2 (frequency build) + PASS 2.5 (canonical Huffman code-length assignment) + PASS 3 (encode/decode wire ^a sigil) + PASS 4 DEFERRED (LIVE FIRE next-tick per A23 first-tick pattern). raw 91 honest C3 STRICT: this tick scope is FIRST TICK ONLY — selftest 5/5 byte-eq round-trip + AOT-ready, NO LIVE FIRE deployment / NO catalog promotion / NO 6-repo sweep this turn. Sigil ^a (lowercase, raw 92 sigil-line compliant; disjoint from existing ^A..^Z uppercase set). Header v=deflate-v1.")
// @usage(hexa /Users/ghost/core/hexa-lang/self/stdlib/hxc_a29_deflate.hexa --selftest)
// @usage(hexa /Users/ghost/core/hexa-lang/self/stdlib/hxc_a29_deflate.hexa encode <in> <out>)
// @usage(hexa /Users/ghost/core/hexa-lang/self/stdlib/hxc_a29_deflate.hexa decode <in> <out>)
// @exit_codes(0=ok, 1=selftest-fail, 2=io-error, 3=bad-args, 4=decode-mismatch)
//
// Spec (first tick scope, refines design doc §3.1):
//
//   PASS 1 — LZ77 tokenize (A18 v1 logic reuse):
//     A29_MAX_MATCH=258 (RFC 1951 §3.2.5), A29_MIN_MATCH=3, A29_WINDOW=32768.
//     Produce flat token stream of mixed alphabet:
//        literal byte (0..255)         → emit literal-symbol b
//        match (len 3..258, dist 1..32768) → emit length-symbol (256 + len-3) and
//                                            two distance bytes (d_hi, d_lo).
//     Single combined alphabet of 514 symbols (0..255 literals, 256..513 length).
//     Distance codes are emitted as raw 16-bit (split 8+8) NOT Huffman-coded in
//     v1 wire (RFC 1951 transmits a separate distance Huffman tree; first-tick
//     v1 uses raw 16-bit for distances — matches A18's existing detokenize path,
//     preserves byte-eq, simplifies bookkeeping). Distance Huffman = v2 wire
//     deferred to follow-on tick (raw 91 honest C3).
//
//   PASS 2 — frequency build:
//     Single forward pass over token stream, count occurrences of each of
//     A29_TOKEN_ALPHABET=514 symbols. Build leaf list of (sym, freq) pairs for
//     all symbols with freq > 0.
//
//   PASS 2.5 — canonical Huffman code-length assignment:
//     Standard Huffman tree build via in-place priority queue (sort-by-freq
//     loop, integer-only). Walk tree to obtain code length per symbol.
//     Length-limited to A29_MAX_CODE_LEN=15 (RFC 1951 cap; in practice text
//     corpora produce max 13-14 bit codes — first-tick uses simple iterative
//     re-balance if any code exceeds 15).
//     Canonical encoding (RFC 1951 §3.2.2):
//       - sort symbols by (code_length, sym_index)
//       - assign codes in ascending order, starting from 0 for shortest length
//       - codes are integer values; bit-string is left-padded to code_length bits
//     The canonical layout means decoder needs only the code-length sequence,
//     NOT the tree shape.
//
//   PASS 3 — encode/decode wire (^a sigil):
//     Header: `# a29:s1 v=deflate-v1 n=<input_bytes> t=<n_tokens>`
//     Body line: `^a<base64url-of-bitstream>`
//     Bitstream layout:
//       (1) 514 × 4-bit code-length entries packed = 2056 bits = 257 bytes
//           (each entry holds code length 0..15; 0 = symbol absent)
//       (2) Huffman-coded tokens, one symbol at a time, MSB-first bit packing
//       (3) For length tokens (256..513), additional 16 raw bits for distance
//           (d_hi byte then d_lo byte, packed MSB-first)
//       (4) Final byte zero-padded to byte boundary
//     Decoder reads code-length table, rebuilds canonical codes (deterministic),
//     decodes Huffman symbols by traversing a code-length-indexed lookup, and
//     reads raw 16 bits after each length token.
//
//   PASS 4 — DEFERRED:
//     LIVE FIRE on 5MB stratified text-heavy / mixed corpora deferred to
//     follow-on tick per A23 first-tick pattern. raw 91 honest C3: NO measured
//     class-lift claims this turn.
//
//   Selftest (5 fixtures, byte-eq round-trip):
//     F1: English text (DEFLATE primary target — high-frequency space/lowercase
//         entropy lever).
//     F2: JSON / structured (mixed class).
//     F3: Korean / multibyte UTF-8 (byte-array round-trip).
//     F4: mixed prose (English + punctuation + numbers).
//     F5: passthrough (under MIN_BYTES, raw 65 idempotent).
//
// Idempotency contract (raw 65 + 68):
//     - encode(decode(x)) == x for any A29 stream
//     - decode(encode(y)) == y for any byte stream
//     - encode is byte-deterministic (same input → same output, raw 137)
//
// raw 142 D2 try-and-revert:
//     a29_encode returns shortest of {force-encoded, identity}. If encoded
//     output is longer than raw input (worst-case for tiny / high-entropy
//     inputs), identity is returned. Decoder treats non-A29-prefixed input as
//     identity passthrough.
//
// raw 156 algorithm-placement-orthogonality:
//     A29 placement axis = post-A1 secondary-stacking (A29 reuses A18 v1 LZ77
//     tokenizer + adds canonical Huffman entropy coder over the literal/length
//     stream). NOT orthogonal to A18; A29 SUBSUMES A18 v1 wire path. Deployment
//     option (b) per design doc §3.1: A25 dispatcher routes text-heavy + mixed
//     classes to A29; A18 v2 retained for json-heavy (94.38% saturated). This
//     decision is for FOLLOW-ON tick — first tick is build-only.
//
// Falsifiers preregistered (raw 71, per design doc §3.1 / §6):
//     F-A29-1: text-heavy class lift < +5pp on 5MB stratified → reject A29
//     F-A29-2: mixed class lift < +3pp on 5MB stratified → reject A29 mixed
//     F-A29-3: round-trip byte-eq fails on any class → reject (raw 65/68)
//     F-A29-4: encode latency > 200ms / 1KB hexa interp → reject (raw 42 perf)
//     F-A29-5: aggregate < 78.65% MEASURED on 6-repo sweep → reject raw 137 v8
//     F-A29-6: DEFLATE+A18 chain regression > 1pp vs DEFLATE-only → reject chain
//
// raw 137 cmix-ban compliance:
//     A29 = canonical Huffman = deterministic prefix codes computed from
//     integer frequency counts via integer-only priority queue. No fp ops, no
//     neural mixer, no training corpus, no on-line learning beyond per-file
//     frequency analysis. Output is bit-for-bit reproducible.
//
// raw 91 honest C3 (first tick scope):
//     - PASS 1 LZ77 tokenize IMPLEMENTED.
//     - PASS 2 frequency build IMPLEMENTED.
//     - PASS 2.5 canonical Huffman code-length assignment IMPLEMENTED.
//     - PASS 3 encode/decode wire (^a sigil, base64url body) IMPLEMENTED.
//     - PASS 4 LIVE FIRE production deferred to follow-on tick.
//     - Distance Huffman coding deferred (v1 wire uses raw 16-bit distance);
//       v2 wire = follow-on tick.
//     - Length-limited Huffman (cap=15 bits) uses iterative re-balance with
//       worst-case 256 iterations; production-grade is package-merge algorithm
//       (Larmore-Hirschberg 1990) deferred to follow-on tick.

const A29_MIN_MATCH = 3
const A29_MAX_MATCH = 258                  // RFC 1951 §3.2.5
const A29_WINDOW_BITS = 15
const A29_WINDOW_SIZE = 32768              // 1 << 15
const A29_HASH_SIZE = 16384                // 2^14 hash slots
const A29_MAX_CHAIN = 32                   // hash-chain walk bound (latency cap)
const A29_MIN_BYTES = 32                   // below this: identity passthrough
const A29_TOKEN_ALPHABET = 514             // 0..255 literals, 256..513 length codes
const A29_LIT_MAX = 256                    // tokens [0..255] are literal bytes
const A29_LEN_BASE = 256
const A29_LEN_COUNT = 256                  // 256 length codes (len = 3 + code)
const A29_MAX_CODE_LEN = 15                // RFC 1951 cap

// Wire base64url alphabet (canonical interop with A16/A17/A18/A23).
const A29_B64_ALPHA = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-_"

// ───────────────── byte-at primitive ─────────────────

fn _byte_at(s: string, i: int) -> string {
    if i < 0 || i >= len(s) { return "" }
    return s.substring(i, i + 1)
}

// ───────────────── PASS 1 — LZ77 tokenizer (A18 v1 logic reuse) ─────────────────

// _hash3: integer hash of 3 bytes at position p in s, modulo A29_HASH_SIZE.
fn _hash3(s: string, p: int) -> int {
    if p + 3 > len(s) { return 0 }
    let b0: i64 = ord(s.substring(p, p + 1))
    let b1: i64 = ord(s.substring(p + 1, p + 2))
    let b2: i64 = ord(s.substring(p + 2, p + 3))
    let h: i64 = ((b0 * 31 + b1) * 31 + b2)
    let m: i64 = h - (h / A29_HASH_SIZE) * A29_HASH_SIZE
    if m < 0 { return m + A29_HASH_SIZE }
    return m
}

// a29_lz_match: hash-chain LZ77 match search with 32KB window.
// Returns [length, distance]. Inserts current position into hash chain.
fn a29_lz_match(buf: string, p: int, hash_head: array, hash_prev) -> array {
    let n = len(buf)
    if p + A29_MIN_MATCH > n {
        return [0, 0]
    }
    let h: i64 = _hash3(buf, p)
    let lo: i64 = if p > A29_WINDOW_SIZE { p - A29_WINDOW_SIZE } else { 0 }
    let mut best_len: i64 = 0
    let mut best_dist: i64 = 0
    let mut q: i64 = hash_head[h]
    let mut hops: i64 = 0
    let p_byte0 = _byte_at(buf, p)
    while q >= lo && hops < A29_MAX_CHAIN && q < p {
        // First-byte filter cuts most chain steps cheaply.
        if _byte_at(buf, q) == p_byte0 {
            let mut m: i64 = 0
            let max_m: i64 = if n - p < A29_MAX_MATCH { n - p } else { A29_MAX_MATCH }
            while m < max_m && q + m < p && _byte_at(buf, q + m) == _byte_at(buf, p + m) {
                m = m + 1
            }
            if m >= A29_MIN_MATCH && m > best_len {
                best_len = m
                best_dist = p - q
                if m >= A29_MAX_MATCH { break }
            }
        }
        let qkey = to_string(q)
        let nq: i64 = if map_contains_key(hash_prev, qkey) { hash_prev[qkey] } else { -1 }
        q = nq
        hops = hops + 1
    }
    // Insert p into chain BEFORE returning.
    let prev_head: i64 = hash_head[h]
    hash_prev[to_string(p)] = prev_head
    hash_head[h] = p
    return [best_len, best_dist]
}

// a29_lz_tokenize: emit array of integer tokens. Encoding scheme:
//   literal byte b:           [ b ]                       (range 0..255)
//   match (len, dist):        [ 256 + (len-3), d_hi, d_lo ]  (len 3..258, dist 1..32768)
fn a29_lz_tokenize(buf: string) -> array {
    let n = len(buf)
    let mut tokens = []
    let mut hash_head = []
    let mut hi = 0
    while hi < A29_HASH_SIZE { hash_head.push(-1); hi = hi + 1 }
    let hash_prev = {}
    let mut p = 0
    while p < n {
        if p + A29_MIN_MATCH <= n {
            let m = a29_lz_match(buf, p, hash_head, hash_prev)
            let mlen: i64 = m[0]
            let mdist: i64 = m[1]
            if mlen >= A29_MIN_MATCH {
                tokens.push(256 + (mlen - A29_MIN_MATCH))
                tokens.push(mdist / 256)
                tokens.push(mdist - (mdist / 256) * 256)
                let mut sp: i64 = p + 1
                let stop: i64 = p + mlen
                while sp < stop {
                    if sp + 3 <= n {
                        let h2: i64 = _hash3(buf, sp)
                        let prev2: i64 = hash_head[h2]
                        hash_prev[to_string(sp)] = prev2
                        hash_head[h2] = sp
                    }
                    sp = sp + 1
                }
                p = p + mlen
                continue
            }
        }
        let b: i64 = ord(_byte_at(buf, p))
        tokens.push(b)
        p = p + 1
    }
    return tokens
}

// a29_lz_detokenize: reconstruct byte array from token stream. Mirrors A18's
// a18_lz_detokenize. Each match token consumes 3 array slots; literal 1 slot.
// Distance bytes (d_hi, d_lo) are packed in the token stream in raw 16-bit form.
fn a29_lz_detokenize(tokens: array) -> array {
    let mut out = []
    let mut i: i64 = 0
    let n: i64 = len(tokens)
    while i < n {
        let t: i64 = tokens[i]
        if t < 256 {
            out.push(t)
            i = i + 1
        } else {
            let mlen: i64 = (t - 256) + A29_MIN_MATCH
            let dh: i64 = if i + 1 < n { tokens[i + 1] } else { 0 }
            let dl: i64 = if i + 2 < n { tokens[i + 2] } else { 0 }
            let mdist: i64 = dh * 256 + dl
            let start: i64 = len(out) - mdist
            let mut k: i64 = 0
            while k < mlen {
                let src: i64 = start + k
                let bv: i64 = if src >= 0 && src < len(out) { out[src] } else { 0 }
                out.push(bv)
                k = k + 1
            }
            i = i + 3
        }
    }
    return out
}

// ───────────────── PASS 2 — frequency build ─────────────────

// a29_freq_build: count occurrences of each of A29_TOKEN_ALPHABET symbols
// across the LZ token stream. Distance bytes (d_hi, d_lo positions) are NOT
// counted into the Huffman frequency table — they are emitted raw 16-bit in
// the wire (PASS 3). Returns 514-entry int array.
fn a29_freq_build(tokens: array) -> array {
    let mut freq = []
    let mut i: i64 = 0
    while i < A29_TOKEN_ALPHABET { freq.push(0); i = i + 1 }
    let n: i64 = len(tokens)
    let mut p: i64 = 0
    while p < n {
        let t: i64 = tokens[p]
        if t < 256 {
            freq[t] = freq[t] + 1
            p = p + 1
        } else {
            // Length symbol; skip the 2 distance bytes (raw 16-bit, NOT
            // Huffman-coded in v1 wire).
            freq[t] = freq[t] + 1
            p = p + 3
        }
    }
    return freq
}

// ───────────────── PASS 2.5 — canonical Huffman code-length assignment ─────────────────

// Heap representation: state = [storage_array, live_size_array].
// storage_array is overprovisioned; live_size_array[0] tracks the logical
// size. We avoid array.pop() because hexa's pop returns the last element but
// does NOT shrink the array (verified empirically; selftest segfaults if
// pop()-shrink is assumed). Instead we maintain explicit live_size and shift
// entries within the storage.

// _heap_push: insert (freq, node_id) preserving ascending order on (freq, id).
fn _heap_push(state, freq: int, node_id: int) {
    let storage = state[0]
    let size_arr = state[1]
    let n: i64 = size_arr[0]
    // Find insertion index.
    let mut i: i64 = 0
    while i < n {
        let entry = storage[i]
        let ef: i64 = entry[0]
        if ef > freq { break }
        if ef == freq {
            let en: i64 = entry[1]
            if en > node_id { break }
        }
        i = i + 1
    }
    // Shift right [i..n) → [i+1..n+1).
    let new_n: i64 = n + 1
    if new_n > len(storage) {
        // Grow storage by appending dummy entries.
        let need: i64 = new_n - len(storage)
        let mut g: i64 = 0
        while g < need { storage.push([0, 0]); g = g + 1 }
    }
    let mut j: i64 = n
    while j > i {
        storage[j] = storage[j - 1]
        j = j - 1
    }
    storage[i] = [freq, node_id]
    size_arr[0] = new_n
}

// _heap_pop: remove and return [freq, node_id] at index 0 (min). Shifts left.
fn _heap_pop(state) -> array {
    let storage = state[0]
    let size_arr = state[1]
    let n: i64 = size_arr[0]
    if n == 0 { return [0, -1] }
    let head = storage[0]
    let mut i: i64 = 1
    while i < n {
        storage[i - 1] = storage[i]
        i = i + 1
    }
    size_arr[0] = n - 1
    return head
}

fn _heap_size(state) -> int {
    return state[1][0]
}

// a29_build_code_lengths: build canonical Huffman code-length table from
// frequency array. Returns 514-entry int array of code lengths (0 = symbol
// absent; 1..15 = code length in bits).
//
// Algorithm (integer-only Huffman):
//   1. Collect leaves with freq > 0.
//   2. Edge case: 0 or 1 leaf → assign length 1 to one leaf if exists.
//   3. Build Huffman tree via min-heap; track parent + depth.
//   4. Compute leaf depth = code length.
//   5. Length-limit to A29_MAX_CODE_LEN: iteratively redistribute deepest
//      leaves upward (simple cap; production uses package-merge).
fn a29_build_code_lengths(freq: array) -> array {
    let mut lengths = []
    let mut a: i64 = 0
    while a < A29_TOKEN_ALPHABET { lengths.push(0); a = a + 1 }

    // Collect leaves.
    let mut leaves = []
    let mut s: i64 = 0
    while s < A29_TOKEN_ALPHABET {
        if freq[s] > 0 { leaves.push(s) }
        s = s + 1
    }
    let n_leaves: i64 = len(leaves)

    // Edge cases.
    if n_leaves == 0 {
        return lengths
    }
    if n_leaves == 1 {
        lengths[leaves[0]] = 1
        return lengths
    }

    // Initialize heap: each leaf is a node with id = its symbol index.
    // Internal nodes get ids >= A29_TOKEN_ALPHABET.
    // parent[node_id] = parent_node_id.
    let mut parent = {}
    let heap_state = [[], [0]]   // [storage, [live_size]]
    let mut k: i64 = 0
    while k < n_leaves {
        let sym: i64 = leaves[k]
        _heap_push(heap_state, freq[sym], sym)
        k = k + 1
    }
    let mut next_id: i64 = A29_TOKEN_ALPHABET

    // Build tree.
    while _heap_size(heap_state) >= 2 {
        let a_entry = _heap_pop(heap_state)
        let b_entry = _heap_pop(heap_state)
        let af: i64 = a_entry[0]
        let an: i64 = a_entry[1]
        let bf: i64 = b_entry[0]
        let bn: i64 = b_entry[1]
        let new_id: i64 = next_id
        next_id = next_id + 1
        parent[to_string(an)] = new_id
        parent[to_string(bn)] = new_id
        _heap_push(heap_state, af + bf, new_id)
    }

    // Root = sole remaining heap entry.
    let root_entry = _heap_pop(heap_state)
    let root_id: i64 = root_entry[1]

    // Compute depth of each leaf by walking parent map up to root.
    let mut q: i64 = 0
    while q < n_leaves {
        let sym: i64 = leaves[q]
        let mut depth: i64 = 0
        let mut cur: i64 = sym
        while cur != root_id && depth < 64 {
            let key = to_string(cur)
            if !map_contains_key(parent, key) { break }
            cur = parent[key]
            depth = depth + 1
        }
        if depth == 0 { depth = 1 }   // single-leaf safeguard (already handled above)
        lengths[sym] = depth
        q = q + 1
    }

    // Length-limit: if any code > A29_MAX_CODE_LEN, redistribute by capping
    // to MAX and incrementing some shorter codes (Kraft inequality fix).
    // First-tick simple algorithm (worst-case OK on 514 alphabet):
    //   while exists L > MAX:
    //     pick deepest leaf and shortest leaf; cap deep at MAX, increment
    //     short by 1. Repeat. Bounded iterations.
    let mut iter: i64 = 0
    while iter < 1024 {
        let mut max_len: i64 = 0
        let mut max_sym: i64 = -1
        let mut s2: i64 = 0
        while s2 < A29_TOKEN_ALPHABET {
            if lengths[s2] > max_len { max_len = lengths[s2]; max_sym = s2 }
            s2 = s2 + 1
        }
        if max_len <= A29_MAX_CODE_LEN { break }
        // Find shortest non-zero leaf to absorb a bit.
        let mut min_len: i64 = 999
        let mut min_sym: i64 = -1
        let mut s3: i64 = 0
        while s3 < A29_TOKEN_ALPHABET {
            if lengths[s3] > 0 && lengths[s3] < min_len { min_len = lengths[s3]; min_sym = s3 }
            s3 = s3 + 1
        }
        if min_sym < 0 || max_sym < 0 { break }
        if min_len >= A29_MAX_CODE_LEN { break }
        lengths[max_sym] = max_len - 1
        lengths[min_sym] = min_len + 1
        iter = iter + 1
    }

    return lengths
}

// a29_canonical_codes: from code-length sequence, produce canonical Huffman
// codes per RFC 1951 §3.2.2. Returns 514-entry int array of code values
// (left-aligned to length bits; 0 if length == 0).
fn a29_canonical_codes(lengths: array) -> array {
    let mut codes = []
    let mut a: i64 = 0
    while a < A29_TOKEN_ALPHABET { codes.push(0); a = a + 1 }

    // Step 1: count number of codes for each code length.
    let mut bl_count = []
    let mut i: i64 = 0
    while i <= A29_MAX_CODE_LEN { bl_count.push(0); i = i + 1 }
    let mut s: i64 = 0
    while s < A29_TOKEN_ALPHABET {
        let L: i64 = lengths[s]
        if L > 0 && L <= A29_MAX_CODE_LEN { bl_count[L] = bl_count[L] + 1 }
        s = s + 1
    }

    // Step 2: find numerical value of smallest code for each length.
    let mut next_code = []
    let mut j: i64 = 0
    while j <= A29_MAX_CODE_LEN { next_code.push(0); j = j + 1 }
    let mut code_val: i64 = 0
    let mut bits: i64 = 1
    while bits <= A29_MAX_CODE_LEN {
        code_val = (code_val + bl_count[bits - 1]) * 2
        next_code[bits] = code_val
        bits = bits + 1
    }

    // Step 3: assign codes to symbols in symbol-index order (canonical).
    let mut s2: i64 = 0
    while s2 < A29_TOKEN_ALPHABET {
        let L: i64 = lengths[s2]
        if L > 0 {
            codes[s2] = next_code[L]
            next_code[L] = next_code[L] + 1
        }
        s2 = s2 + 1
    }
    return codes
}

// ───────────────── PASS 3 — bitstream pack / unpack ─────────────────

// _bits_push: append `nbits` low bits of `val` (MSB-first within each byte)
// into the bit-buffer. bit_buf is [bytes_array, current_byte, bit_pos] mutated
// in place.
fn _bits_push(state, val: int, nbits: int) {
    let mut k: i64 = nbits - 1
    while k >= 0 {
        let bit: i64 = (val / _pow2(k)) - ((val / _pow2(k + 1)) * 2)
        let cur: i64 = state[1]
        let pos: i64 = state[2]
        let new_byte: i64 = cur * 2 + bit
        if pos == 7 {
            state[0].push(new_byte)
            state[1] = 0
            state[2] = 0
        } else {
            state[1] = new_byte
            state[2] = pos + 1
        }
        k = k - 1
    }
}

// _bits_flush: zero-pad the trailing partial byte (if any) and return the
// finalized byte array.
fn _bits_flush(state) -> array {
    if state[2] > 0 {
        let cur: i64 = state[1]
        let pos: i64 = state[2]
        // Left-shift the partial byte to MSB-align the written bits.
        let final_byte: i64 = cur * _pow2(8 - pos)
        state[0].push(final_byte)
        state[1] = 0
        state[2] = 0
    }
    return state[0]
}

fn _pow2(n: int) -> int {
    let mut v: i64 = 1
    let mut k: i64 = 0
    while k < n { v = v * 2; k = k + 1 }
    return v
}

// _bits_read: read `nbits` MSB-first from byte stream starting at bit-pos
// state [bytes, byte_idx, bit_idx]. Returns int value; mutates state.
fn _bits_read(state, nbits: int) -> int {
    let mut val: i64 = 0
    let mut k: i64 = 0
    while k < nbits {
        let bytes = state[0]
        let bi: i64 = state[1]
        let pi: i64 = state[2]
        if bi >= len(bytes) { return val }
        let b: i64 = bytes[bi]
        // Extract bit pi from b (MSB first → bit at position 7-pi).
        let shift: i64 = 7 - pi
        let bit: i64 = (b / _pow2(shift)) - ((b / _pow2(shift + 1)) * 2)
        val = val * 2 + bit
        if pi == 7 {
            state[1] = bi + 1
            state[2] = 0
        } else {
            state[2] = pi + 1
        }
        k = k + 1
    }
    return val
}

// ───────────────── b64url codec (interop with A18/A23) ─────────────────

fn _b64_enc_bytes(bytes: array) -> string {
    let mut out = []
    let n: i64 = len(bytes)
    let mut i: i64 = 0
    while i < n {
        let b0: i64 = bytes[i]
        let b1: i64 = if i + 1 < n { bytes[i + 1] } else { 0 }
        let b2: i64 = if i + 2 < n { bytes[i + 2] } else { 0 }
        let acc: i64 = b0 * 65536 + b1 * 256 + b2
        let c0: i64 = acc / 262144
        let r0: i64 = acc - c0 * 262144
        let c1: i64 = r0 / 4096
        let r1: i64 = r0 - c1 * 4096
        let c2: i64 = r1 / 64
        let c3: i64 = r1 - c2 * 64
        let group: i64 = if i + 3 <= n { 4 } else { (n - i) + 1 }
        let chs = [c0, c1, c2, c3]
        let mut e: i64 = 0
        while e < group { out.push(A29_B64_ALPHA.substring(chs[e], chs[e] + 1)); e = e + 1 }
        i = i + 3
    }
    // tail u24 byte count
    let mut nv: i64 = n
    if nv > 16777215 { nv = 16777215 }
    let t0: i64 = nv / 262144
    let r0t: i64 = nv - t0 * 262144
    let t1: i64 = r0t / 4096
    let r1t: i64 = r0t - t1 * 4096
    let t2: i64 = r1t / 64
    let t3: i64 = r1t - t2 * 64
    out.push(A29_B64_ALPHA.substring(t0, t0 + 1))
    out.push(A29_B64_ALPHA.substring(t1, t1 + 1))
    out.push(A29_B64_ALPHA.substring(t2, t2 + 1))
    out.push(A29_B64_ALPHA.substring(t3, t3 + 1))
    return out.join("")
}

fn _b64_char_idx(c: string) -> i64 { return A29_B64_ALPHA.index_of(c) }

fn _b64_dec_bytes(s: string) -> array {
    let total: i64 = len(s)
    if total < 4 { return [] }
    let t0: i64 = _b64_char_idx(s.substring(total - 4, total - 3))
    let t1: i64 = _b64_char_idx(s.substring(total - 3, total - 2))
    let t2: i64 = _b64_char_idx(s.substring(total - 2, total - 1))
    let t3: i64 = _b64_char_idx(s.substring(total - 1, total))
    let bcount: i64 = t0 * 262144 + t1 * 4096 + t2 * 64 + t3
    let body_len: i64 = total - 4
    let mut out = []
    let mut i: i64 = 0
    while i < body_len {
        let group: i64 = if i + 4 <= body_len { 4 } else { body_len - i }
        let mut acc: i64 = 0
        let mut j: i64 = 0
        while j < 4 {
            let d: i64 = if j < group { _b64_char_idx(s.substring(i + j, i + j + 1)) } else { 0 }
            acc = acc * 64 + d
            j = j + 1
        }
        let by0: i64 = acc / 65536
        let rem: i64 = acc - by0 * 65536
        let by1: i64 = rem / 256
        let by2: i64 = rem - by1 * 256
        let bg: i64 = if group == 4 { 3 } else { group - 1 }
        if bg >= 1 { out.push(by0) }
        if bg >= 2 { out.push(by1) }
        if bg >= 3 { out.push(by2) }
        i = i + 4
    }
    let mut final_out = []
    let mut fi: i64 = 0
    while fi < bcount && fi < len(out) { final_out.push(out[fi]); fi = fi + 1 }
    return final_out
}

// ───────────────── encode / decode wire ─────────────────

// _a29_encode_force: v1 wire — LZ77 + canonical Huffman over literal/length
// alphabet (514 symbols). Distance bytes raw 16-bit. Body sigil ^a.
fn _a29_encode_force(text: string) -> string {
    let n: i64 = len(text)
    if n >= 7 && text.substring(0, 7) == "# a29:s" { return text }

    // PASS 1: LZ77 tokenize.
    let tokens = a29_lz_tokenize(text)
    // n_huff_tokens = count of Huffman-coded symbols (literals + length codes,
    // excluding the 2 raw-16-bit distance bytes that follow each length code).
    let n_arr: i64 = len(tokens)
    let mut n_huff_tokens: i64 = 0
    let mut np: i64 = 0
    while np < n_arr {
        let tt: i64 = tokens[np]
        if tt < 256 { n_huff_tokens = n_huff_tokens + 1; np = np + 1 }
        else { n_huff_tokens = n_huff_tokens + 1; np = np + 3 }
    }

    // PASS 2: frequency build.
    let freq = a29_freq_build(tokens)

    // PASS 2.5: canonical Huffman code-length assignment + canonical codes.
    let lengths = a29_build_code_lengths(freq)
    let codes = a29_canonical_codes(lengths)

    // PASS 3: bit-pack header (code-length table) + Huffman-coded tokens +
    //         raw 16-bit distances.
    let bit_state = [[], 0, 0]   // [bytes, current_byte, bit_pos]

    // (1) Write 514 × 4-bit code-length entries.
    let mut s: i64 = 0
    while s < A29_TOKEN_ALPHABET {
        _bits_push(bit_state, lengths[s], 4)
        s = s + 1
    }

    // (2) Huffman-coded tokens. For length tokens (256..513), additionally
    //     emit 16 raw bits for distance.
    let mut p: i64 = 0
    while p < n_arr {
        let t: i64 = tokens[p]
        let L: i64 = lengths[t]
        let C: i64 = codes[t]
        _bits_push(bit_state, C, L)
        if t >= 256 {
            let dh: i64 = if p + 1 < n_arr { tokens[p + 1] } else { 0 }
            let dl: i64 = if p + 2 < n_arr { tokens[p + 2] } else { 0 }
            _bits_push(bit_state, dh, 8)
            _bits_push(bit_state, dl, 8)
            p = p + 3
        } else {
            p = p + 1
        }
    }

    // (3) Flush trailing bits.
    let payload_bytes = _bits_flush(bit_state)
    let payload_b64 = _b64_enc_bytes(payload_bytes)
    let header = "# a29:s1 v=deflate-v1 n=" + to_string(n) + " t=" + to_string(n_huff_tokens)
    let body = "^a" + payload_b64
    return header + "\n" + body + "\n"
}

// a29_encode: try-and-revert raw 142 D2 — return shortest of {force-encoded,
// identity}. If encoded > raw, return identity.
fn a29_encode(text: string) -> string {
    let n: i64 = len(text)
    if n < A29_MIN_BYTES { return text }
    if n >= 7 && text.substring(0, 7) == "# a29:s" { return text }
    let v1 = _a29_encode_force(text)
    if len(v1) < len(text) { return v1 }
    return text
}

// _a29_decode_to_bytes: reconstruct byte array (each 0..255). Auto-detects
// v=deflate-v1 (^a sigil). Non-A29 input returns [] (caller treats as identity
// passthrough).
fn _a29_decode_to_bytes(stream: string) -> array {
    let lines = stream.split("\n")
    if len(lines) < 2 { return [] }
    let header = lines[0]
    if len(header) < 7 || header.substring(0, 7) != "# a29:s" { return [] }
    let n_pos: i64 = header.index_of(" n=")
    let t_pos: i64 = header.index_of(" t=")
    if n_pos < 0 || t_pos < 0 { return [] }
    let _n_bytes: i64 = parse_int(header.substring(n_pos + 3, t_pos))
    let n_tokens: i64 = parse_int(header.substring(t_pos + 3, len(header)))

    // Find ^a body line.
    let mut body_b64 = ""
    let mut i = 1
    while i < len(lines) {
        let l = lines[i]
        if len(l) >= 2 && l.substring(0, 2) == "^a" {
            body_b64 = l.substring(2, len(l))
            break
        }
        i = i + 1
    }
    if len(body_b64) == 0 { return [] }
    let payload_bytes = _b64_dec_bytes(body_b64)

    // Read code-length table (514 × 4 bits).
    let read_state = [payload_bytes, 0, 0]
    let mut lengths = []
    let mut s: i64 = 0
    while s < A29_TOKEN_ALPHABET {
        let L: i64 = _bits_read(read_state, 4)
        lengths.push(L)
        s = s + 1
    }

    // Rebuild canonical codes (deterministic).
    let codes = a29_canonical_codes(lengths)

    // Build (code_len, code_val) → symbol lookup. Two parallel arrays:
    //   sym_by_code[L] = sorted-by-code-value list of (code_val, sym).
    // For decode, iterate L=1..15: extend reading window, search for match.
    // Because canonical codes are dense within each length, use direct
    // computation per RFC 1951: maintain `next_code[L]` ranges.
    // Simpler approach: for each length L, build an array indexed by
    // (code_val - first_code[L]) → sym.
    let mut bl_count = []
    let mut i2: i64 = 0
    while i2 <= A29_MAX_CODE_LEN { bl_count.push(0); i2 = i2 + 1 }
    let mut s2: i64 = 0
    while s2 < A29_TOKEN_ALPHABET {
        let L: i64 = lengths[s2]
        if L > 0 && L <= A29_MAX_CODE_LEN { bl_count[L] = bl_count[L] + 1 }
        s2 = s2 + 1
    }
    let mut first_code = []
    let mut j2: i64 = 0
    while j2 <= A29_MAX_CODE_LEN { first_code.push(0); j2 = j2 + 1 }
    let mut code_val: i64 = 0
    let mut bits: i64 = 1
    while bits <= A29_MAX_CODE_LEN {
        code_val = (code_val + bl_count[bits - 1]) * 2
        first_code[bits] = code_val
        bits = bits + 1
    }

    // sym_by_idx[L][k] = symbol for the k-th canonical code of length L.
    let mut sym_by_idx = []
    let mut a3: i64 = 0
    while a3 <= A29_MAX_CODE_LEN { sym_by_idx.push([]); a3 = a3 + 1 }
    let mut s3: i64 = 0
    while s3 < A29_TOKEN_ALPHABET {
        let L: i64 = lengths[s3]
        if L > 0 && L <= A29_MAX_CODE_LEN { sym_by_idx[L].push(s3) }
        s3 = s3 + 1
    }

    // Decode tokens.
    let mut tokens = []
    let mut decoded: i64 = 0
    while decoded < n_tokens {
        // Read bits, attempt match at increasing code lengths.
        let mut acc: i64 = 0
        let mut found_sym: i64 = -1
        let mut L: i64 = 1
        while L <= A29_MAX_CODE_LEN {
            let bit: i64 = _bits_read(read_state, 1)
            acc = acc * 2 + bit
            if bl_count[L] > 0 {
                let fc: i64 = first_code[L]
                if acc >= fc && acc < fc + bl_count[L] {
                    let idx: i64 = acc - fc
                    found_sym = sym_by_idx[L][idx]
                    break
                }
            }
            L = L + 1
        }
        if found_sym < 0 {
            // Decode failure — bail with what we have (raw 65 byte-eq will
            // catch this, raising selftest failure).
            break
        }
        tokens.push(found_sym)
        if found_sym >= 256 {
            let dh: i64 = _bits_read(read_state, 8)
            let dl: i64 = _bits_read(read_state, 8)
            tokens.push(dh)
            tokens.push(dl)
        }
        decoded = decoded + 1
    }

    return a29_lz_detokenize(tokens)
}

// a29_decode (string-returning, ASCII-safe path; binary uses byte-array form).
fn a29_decode(stream: string) -> string {
    let lines = stream.split("\n")
    if len(lines) < 2 { return stream }
    let header = lines[0]
    if len(header) < 7 || header.substring(0, 7) != "# a29:s" { return stream }
    let bytes = _a29_decode_to_bytes(stream)
    if len(bytes) == 0 { return stream }
    let mut parts = []
    let mut i = 0
    while i < len(bytes) {
        parts.push(chr(bytes[i]))
        i = i + 1
    }
    return parts.join("")
}

// ───────────────── PASS 4 — selftest (5 fixtures byte-eq round-trip) ─────────────────

fn _selftest() -> int {
    let mut pass: i64 = 0
    let mut fail: i64 = 0
    println("# hxc_a29_deflate selftest (FIRST TICK BUILD — PASS 1+2+2.5+3 + 5 fixtures)")

    // Fixture 1: English text (DEFLATE primary target).
    let phrase = "the quick brown fox jumps over the lazy dog "
    let mut buf_eng = ""
    let mut k1 = 0
    while k1 < 30 { buf_eng = buf_eng + phrase; k1 = k1 + 1 }
    let enc1 = _a29_encode_force(buf_eng)
    let dec1 = a29_decode(enc1)
    if dec1 == buf_eng {
        let s1 = ((len(buf_eng) - len(enc1)) * 100) / len(buf_eng)
        pass = pass + 1
        println("  PASS: fixture-1 English text byte-eq " + to_string(len(buf_eng))
                + " -> " + to_string(len(enc1)) + " (" + to_string(s1) + "% wire-saving)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-1 English text round-trip lost orig_len=" + to_string(len(buf_eng))
                + " got_len=" + to_string(len(dec1)))
    }

    // Fixture 2: JSON / structured (mixed class).
    let json_phrase = "{\"event\":\"witness\",\"phase\":\"13-P0\",\"algo\":\"A29\",\"saving_pct\":0,\"raw_91_c3\":\"first-tick\",\"ts\":\"2026-04-28\"}\n"
    let mut buf_json = ""
    let mut k2 = 0
    while k2 < 8 { buf_json = buf_json + json_phrase; k2 = k2 + 1 }
    let enc2 = _a29_encode_force(buf_json)
    let dec2 = a29_decode(enc2)
    if dec2 == buf_json {
        let s2 = ((len(buf_json) - len(enc2)) * 100) / len(buf_json)
        pass = pass + 1
        println("  PASS: fixture-2 JSON byte-eq " + to_string(len(buf_json))
                + " -> " + to_string(len(enc2)) + " (" + to_string(s2) + "% wire-saving)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-2 JSON round-trip lost orig_len=" + to_string(len(buf_json))
                + " got_len=" + to_string(len(dec2)))
    }

    // Fixture 3: Korean / multibyte UTF-8 (byte-array round-trip).
    let kor = "안녕 세계 — A29 DEFLATE 첫 tick 자기-호스트 hexa raw 9. 압축 + 캐노니컬 허프만. "
    let mut buf_kor = ""
    let mut k3 = 0
    while k3 < 12 { buf_kor = buf_kor + kor; k3 = k3 + 1 }
    let enc3 = _a29_encode_force(buf_kor)
    let dec3_bytes = _a29_decode_to_bytes(enc3)
    let mut ok3 = true
    let nk3: i64 = len(buf_kor)
    if len(dec3_bytes) != nk3 { ok3 = false }
    let mut q3: i64 = 0
    while ok3 && q3 < nk3 {
        if dec3_bytes[q3] != ord(_byte_at(buf_kor, q3)) { ok3 = false }
        q3 = q3 + 1
    }
    if ok3 {
        let s3: i64 = ((nk3 - len(enc3)) * 100) / nk3
        pass = pass + 1
        println("  PASS: fixture-3 Korean multibyte byte-array byte-eq "
                + to_string(nk3) + " -> " + to_string(len(enc3))
                + " (" + to_string(s3) + "% wire-saving)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-3 Korean round-trip lost orig_len=" + to_string(nk3)
                + " got_len=" + to_string(len(dec3_bytes)))
    }

    // Fixture 4: mixed prose (English + punctuation + numbers + UTF-8 em-dash).
    // Uses byte-array round-trip (string-returning a29_decode collapses high
    // bytes via chr() codepoint encoding; binary correctness is via
    // _a29_decode_to_bytes per A23 fixture-2 pattern).
    let prose = "In 2026, Claude wrote a self-hosted compressor — 514 symbols, 32KB window, MAX_MATCH=258. The result: byte-eq round-trip on every fixture. RFC 1951 canonical Huffman, integer-only. "
    let mut buf_prose = ""
    let mut k4 = 0
    while k4 < 8 { buf_prose = buf_prose + prose; k4 = k4 + 1 }
    let enc4 = _a29_encode_force(buf_prose)
    let dec4_bytes = _a29_decode_to_bytes(enc4)
    let mut ok4 = true
    let np4: i64 = len(buf_prose)
    if len(dec4_bytes) != np4 { ok4 = false }
    let mut q4: i64 = 0
    while ok4 && q4 < np4 {
        if dec4_bytes[q4] != ord(_byte_at(buf_prose, q4)) { ok4 = false }
        q4 = q4 + 1
    }
    if ok4 {
        let s4: i64 = ((np4 - len(enc4)) * 100) / np4
        pass = pass + 1
        println("  PASS: fixture-4 mixed prose byte-array byte-eq " + to_string(np4)
                + " -> " + to_string(len(enc4)) + " (" + to_string(s4) + "% wire-saving)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-4 mixed prose round-trip lost orig_len=" + to_string(np4)
                + " got_len=" + to_string(len(dec4_bytes)))
    }

    // Fixture 5: passthrough idempotent — raw 65 + 68.
    let tiny = "abc123"
    let enc5 = a29_encode(tiny)
    let enc5b = a29_encode(enc5)
    if enc5 == tiny && enc5b == tiny {
        pass = pass + 1
        println("  PASS: fixture-5 short-input passthrough idempotent (raw 65 + 68)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-5 short-input idempotency broken")
    }

    println("Results: " + to_string(pass) + " PASS / " + to_string(fail) + " FAIL")
    println("__HXC_A29_SELFTEST__ " + (if fail == 0 { "PASS" } else { "FAIL" })
            + " (FIRST TICK: PASS 1 LZ77 + PASS 2 freq + PASS 2.5 canonical Huffman + PASS 3 wire ^a + 5 fixtures byte-eq; PASS 4 LIVE FIRE deferred)")
    if fail == 0 { return 0 }
    return 1
}

// ───────────────── main CLI ─────────────────

fn main() {
    let av = argv()
    let mut has_selftest = false
    let mut has_encode = false
    let mut has_decode = false
    let mut has_force = false
    let mut k = 0
    while k < len(av) {
        if av[k] == "--selftest" { has_selftest = true }
        if av[k] == "encode" { has_encode = true }
        if av[k] == "decode" { has_decode = true }
        if av[k] == "--force" { has_force = true }
        k = k + 1
    }
    if has_selftest { exit(_selftest()) }
    if has_encode || has_decode {
        let mut sub_idx = 0
        let mut q = 0
        while q < len(av) {
            if av[q] == "encode" || av[q] == "decode" { sub_idx = q; break }
            q = q + 1
        }
        let mut paths = []
        let mut q2 = sub_idx + 1
        while q2 < len(av) {
            let a = av[q2]
            if len(a) >= 2 && a.substring(0, 2) == "--" { q2 = q2 + 1; continue }
            paths.push(a)
            q2 = q2 + 1
        }
        if len(paths) < 2 {
            eprintln("usage: hexa hxc_a29_deflate.hexa <encode|decode> [--force] <in> <out>")
            exit(3)
        }
        let in_path = paths[0]
        let out_path = paths[1]
        if has_encode {
            let txt = read_file(in_path)
            let res = if has_force { _a29_encode_force(txt) } else { a29_encode(txt) }
            let _w = write_file(out_path, res)
            let saving = if len(txt) > 0 { ((len(txt) - len(res)) * 100) / len(txt) } else { 0 }
            println("a29 encode raw=" + to_string(len(txt))
                    + " enc=" + to_string(len(res)) + " saving=" + to_string(saving) + "%")
            exit(0)
        }
        let txt = read_file(in_path)
        let bytes = _a29_decode_to_bytes(txt)
        if len(bytes) == 0 {
            let _w = write_file(out_path, txt)
        } else {
            let _w = write_bytes(out_path, bytes)
        }
        exit(0)
    }
    eprintln("usage: hexa hxc_a29_deflate.hexa [--selftest | encode [--force] <in> <out> | decode <in> <out>]")
    exit(3)
}
