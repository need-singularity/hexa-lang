// ═══════════════════════════════════════════════════════════════════════
//  self/stdlib/term_focus.hexa — focus/blur events (CSI I / O)
//
//  PURPOSE
//      Many terminals emit ESC [I when window gains focus and ESC [O
//      when it loses focus, IF "focusin" tracking is enabled via
//      DECSET 1004 (CSI ?1004h). hive packages/tui needs this to
//      pause cursor blink when window unfocused, mute progress bar,
//      etc. term_input already DECODES these events; this module
//      gates the enable/disable + provides a small classifier.
//
//  EXPORTS
//      focus_enable_seq()                 -> string  // ESC [?1004h
//      focus_disable_seq()                -> string  // ESC [?1004l
//      focus_is_event(buf, off)           -> string
//        Inspects buf[off..off+3]. Returns "focus_in" iff bytes are
//        ESC [ I; "focus_out" iff ESC [ O; "" otherwise.
//
//  CAVEATS
//      * Not all terminals support DECSET 1004 (legacy xterm, some
//        Windows consoles). Enable-seq is harmless on unsupported
//        terminals; events simply never arrive.
//      * focus_is_event is a length-3 lookahead; caller advances by
//        3 bytes on a hit. For full event decode, prefer
//        term_input.decode_input which handles all CSI events.
//
//  USAGE
//      use "self/stdlib/term_focus"
//      print(focus_enable_seq())
//      // ... in input loop:
//      let kind = focus_is_event(buf, 0)
//      if kind == "focus_in" { on_focus_in() }
//
//  --selftest:
//      hexa run self/stdlib/term_focus.hexa --selftest
//        → __TERM_FOCUS_SELFTEST__ <PASS|FAIL> n=<N> fail=<M>
// ═══════════════════════════════════════════════════════════════════════

fn _tf_esc() -> string { return from_char_code(27) }

pub fn focus_enable_seq() -> string {
    return _tf_esc() + "[?1004h"
}

pub fn focus_disable_seq() -> string {
    return _tf_esc() + "[?1004l"
}

pub fn focus_is_event(buf: string, off: i64) -> string {
    let n = len(buf)
    if off < 0 || off + 3 > n { return "" }
    let s = buf.substring(off, off + 3)
    let esc = _tf_esc()
    if s == esc + "[I" { return "focus_in" }
    if s == esc + "[O" { return "focus_out" }
    return ""
}

// ── --selftest ─────────────────────────────────────────────────────
fn _tfocus_selftest() {
    let mut fail = 0
    let mut n = 0
    let esc = _tf_esc()

    n = n + 1
    if focus_enable_seq() != esc + "[?1004h" { eprintln("FAIL 1"); fail = fail + 1 }
    n = n + 1
    if focus_disable_seq() != esc + "[?1004l" { eprintln("FAIL 2"); fail = fail + 1 }

    n = n + 1
    if focus_is_event(esc + "[I", 0) != "focus_in" { eprintln("FAIL 3"); fail = fail + 1 }
    n = n + 1
    if focus_is_event(esc + "[O", 0) != "focus_out" { eprintln("FAIL 4"); fail = fail + 1 }

    n = n + 1
    if focus_is_event("xx" + esc + "[I", 2) != "focus_in" { eprintln("FAIL 5 (offset)"); fail = fail + 1 }

    n = n + 1
    if focus_is_event(esc + "[A", 0) != "" { eprintln("FAIL 6 (arrow not focus)"); fail = fail + 1 }

    n = n + 1
    if focus_is_event("", 0) != "" { eprintln("FAIL 7 (empty)"); fail = fail + 1 }
    n = n + 1
    if focus_is_event("a", 0) != "" { eprintln("FAIL 8 (too short)"); fail = fail + 1 }
    n = n + 1
    if focus_is_event(esc + "[I", -1) != "" { eprintln("FAIL 9 (neg off)"); fail = fail + 1 }

    if fail == 0 {
        println("__TERM_FOCUS_SELFTEST__ PASS n=" + to_string(n) + " fail=0")
    } else {
        println("__TERM_FOCUS_SELFTEST__ FAIL n=" + to_string(n) + " fail=" + to_string(fail))
    }
}

let _tfoc_argv = args()
let mut _tfoc_st = false
let mut _tfoc_ai = 0
while _tfoc_ai < len(_tfoc_argv) {
    if _tfoc_argv[_tfoc_ai] == "--selftest-term-focus" { _tfoc_st = true }
    if _tfoc_argv[_tfoc_ai] == "--selftest" {
        let mut _tfoc_aj = 0
        while _tfoc_aj < len(_tfoc_argv) {
            if _tfoc_argv[_tfoc_aj].ends_with("/stdlib/term_focus.hexa") { _tfoc_st = true }
            _tfoc_aj = _tfoc_aj + 1
        }
    }
    _tfoc_ai = _tfoc_ai + 1
}
if _tfoc_st {
    _tfocus_selftest()
}
