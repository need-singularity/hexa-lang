// ═══════════════════════════════════════════════════════════════════════
//  self/stdlib/term_box.hexa — box-drawing glyphs + frame builders
//
//  PURPOSE
//      Unicode box-drawing primitives + ready-made horizontal/vertical
//      rules and full-frame rectangles. Used by hive packages/tui
//      autocomplete-popup, status-line dividers, and panel borders.
//      Three styles: "single", "double", "round". Pure-string output.
//
//  EXPORTS
//      box_glyph(style, kind)        -> string
//        style: "single"/"double"/"round"
//        kind:  "h"/"v"/"tl"/"tr"/"bl"/"br"/"cross"/"t_t"/"t_b"/"t_l"/"t_r"
//      box_h_line(style, width)      -> string
//      box_v_line(style, height)     -> string  (newline-joined)
//      box_frame(style, w, h)        -> string  (top/bot/sides; no fill)
//      box_frame_lines(style, w, h)  -> array<string>  (line-by-line)
//      box_titled_top(style, w, t)   -> string  (top edge w/ centered title)
//
//  GLYPH TABLE
//      single:  ─ │ ┌ ┐ └ ┘ ┼ ┬ ┴ ├ ┤
//      double:  ═ ║ ╔ ╗ ╚ ╝ ╬ ╦ ╩ ╠ ╣
//      round :  ─ │ ╭ ╮ ╰ ╯ ┼ ┬ ┴ ├ ┤   (single H/V + rounded corners)
//
//  CAVEATS
//      * Width is in COLUMNS (visual cells), not bytes. Each glyph
//        is exactly 1 column. Caller using titled_top with multibyte
//        title should use term_unicode.text_width to verify it fits.
//      * Round style is identical to single except for corners.
//
//  USAGE
//      use "self/stdlib/term_box"
//      print(box_h_line("single", 20))
//      let lines = box_frame_lines("double", 30, 5)
//
//  --selftest:
//      hexa run self/stdlib/term_box.hexa --selftest
//        → __TERM_BOX_SELFTEST__ <PASS|FAIL> n=<N> fail=<M>
// ═══════════════════════════════════════════════════════════════════════

fn _box_lookup(style: string, kind: string) -> string {
    if style == "single" {
        if kind == "h" { return "─" }
        if kind == "v" { return "│" }
        if kind == "tl" { return "┌" }
        if kind == "tr" { return "┐" }
        if kind == "bl" { return "└" }
        if kind == "br" { return "┘" }
        if kind == "cross" { return "┼" }
        if kind == "t_t" { return "┬" }
        if kind == "t_b" { return "┴" }
        if kind == "t_l" { return "├" }
        if kind == "t_r" { return "┤" }
    } else if style == "double" {
        if kind == "h" { return "═" }
        if kind == "v" { return "║" }
        if kind == "tl" { return "╔" }
        if kind == "tr" { return "╗" }
        if kind == "bl" { return "╚" }
        if kind == "br" { return "╝" }
        if kind == "cross" { return "╬" }
        if kind == "t_t" { return "╦" }
        if kind == "t_b" { return "╩" }
        if kind == "t_l" { return "╠" }
        if kind == "t_r" { return "╣" }
    } else if style == "round" {
        if kind == "h" { return "─" }
        if kind == "v" { return "│" }
        if kind == "tl" { return "╭" }
        if kind == "tr" { return "╮" }
        if kind == "bl" { return "╰" }
        if kind == "br" { return "╯" }
        if kind == "cross" { return "┼" }
        if kind == "t_t" { return "┬" }
        if kind == "t_b" { return "┴" }
        if kind == "t_l" { return "├" }
        if kind == "t_r" { return "┤" }
    }
    return ""
}

pub fn box_glyph(style: string, kind: string) -> string {
    return _box_lookup(style, kind)
}

pub fn box_h_line(style: string, width: i64) -> string {
    if width <= 0 { return "" }
    let g = _box_lookup(style, "h")
    if len(g) == 0 { return "" }
    let mut out = ""
    let mut i = 0
    while i < width {
        out = out + g
        i = i + 1
    }
    return out
}

pub fn box_v_line(style: string, height: i64) -> string {
    if height <= 0 { return "" }
    let g = _box_lookup(style, "v")
    if len(g) == 0 { return "" }
    let mut out = ""
    let mut i = 0
    while i < height {
        out = out + g
        if i + 1 < height { out = out + "\n" }
        i = i + 1
    }
    return out
}

// box_frame_lines: returns an array<string> of `h` lines composing
// a w-wide × h-tall frame. Caller joins with "\n" or emits with
// explicit cursor positioning.
pub fn box_frame_lines(style: string, w: i64, h: i64) -> array {
    let mut out = []
    if w < 2 || h < 2 { return out }
    let tl = _box_lookup(style, "tl")
    let tr = _box_lookup(style, "tr")
    let bl = _box_lookup(style, "bl")
    let br = _box_lookup(style, "br")
    let v = _box_lookup(style, "v")
    let h_g = _box_lookup(style, "h")
    if len(tl) == 0 { return out }
    let mut hs = ""
    let mut i = 0
    while i < w - 2 { hs = hs + h_g; i = i + 1 }
    out.push(tl + hs + tr)
    let mut middle_pad = ""
    let mut k = 0
    while k < w - 2 { middle_pad = middle_pad + " "; k = k + 1 }
    let mut j = 0
    while j < h - 2 {
        out.push(v + middle_pad + v)
        j = j + 1
    }
    out.push(bl + hs + br)
    return out
}

pub fn box_frame(style: string, w: i64, h: i64) -> string {
    let lines = box_frame_lines(style, w, h)
    let mut out = ""
    let mut i = 0
    while i < len(lines) {
        out = out + lines[i]
        if i + 1 < len(lines) { out = out + "\n" }
        i = i + 1
    }
    return out
}

// box_titled_top: a horizontal top edge with the given title centered
// (or left-aligned if title is wider than the slot). Title uses raw
// chars — caller should pre-compute width with term_unicode.
pub fn box_titled_top(style: string, w: i64, title: string) -> string {
    if w < 2 { return "" }
    let tl = _box_lookup(style, "tl")
    let tr = _box_lookup(style, "tr")
    let h_g = _box_lookup(style, "h")
    if len(tl) == 0 { return "" }
    let inner = w - 2
    // Approximate width of title in cells = len(title) for ASCII.
    // True width caller-precomputed; we accept the literal title here.
    let t = " " + title + " "
    let tlen = len(t)
    if tlen >= inner {
        // Truncate title to fit; keep " " padding on at least one side.
        return tl + h_g + tr
    }
    let left = (inner - tlen) / 2
    let right = inner - tlen - left
    let mut hl = ""
    let mut i = 0
    while i < left { hl = hl + h_g; i = i + 1 }
    let mut hr = ""
    let mut j = 0
    while j < right { hr = hr + h_g; j = j + 1 }
    return tl + hl + t + hr + tr
}

// ── --selftest ─────────────────────────────────────────────────────
fn _tbox_selftest() {
    let mut fail = 0
    let mut n = 0

    n = n + 1
    if box_glyph("single", "h") != "─" { eprintln("FAIL 1"); fail = fail + 1 }
    n = n + 1
    if box_glyph("double", "tl") != "╔" { eprintln("FAIL 2"); fail = fail + 1 }
    n = n + 1
    if box_glyph("round", "tl") != "╭" { eprintln("FAIL 3"); fail = fail + 1 }
    n = n + 1
    if box_glyph("bogus", "h") != "" { eprintln("FAIL 4"); fail = fail + 1 }

    n = n + 1
    if box_h_line("single", 3) != "───" { eprintln("FAIL 5"); fail = fail + 1 }
    n = n + 1
    if box_h_line("double", 0) != "" { eprintln("FAIL 6"); fail = fail + 1 }

    n = n + 1
    let v = box_v_line("single", 3)
    if v != "│\n│\n│" { eprintln("FAIL 7 got=" + v); fail = fail + 1 }

    n = n + 1
    let frame = box_frame_lines("single", 4, 3)
    if len(frame) != 3 { eprintln("FAIL 8a count=" + to_string(len(frame))); fail = fail + 1 }
    n = n + 1
    if frame[0] != "┌──┐" { eprintln("FAIL 8b got=" + frame[0]); fail = fail + 1 }
    n = n + 1
    if frame[1] != "│  │" { eprintln("FAIL 8c got=" + frame[1]); fail = fail + 1 }
    n = n + 1
    if frame[2] != "└──┘" { eprintln("FAIL 8d got=" + frame[2]); fail = fail + 1 }

    n = n + 1
    let dframe = box_frame_lines("double", 4, 3)
    if dframe[0] != "╔══╗" { eprintln("FAIL 9 got=" + dframe[0]); fail = fail + 1 }

    n = n + 1
    let rframe = box_frame_lines("round", 4, 3)
    if rframe[0] != "╭──╮" { eprintln("FAIL 10 got=" + rframe[0]); fail = fail + 1 }

    n = n + 1
    if box_frame("single", 3, 2) != "┌─┐\n└─┘" { eprintln("FAIL 11"); fail = fail + 1 }

    n = n + 1
    let titled = box_titled_top("single", 12, "Hi")
    // inner=10; t=" Hi "=4; left=3; right=3 → "┌─── Hi ───┐"
    if titled != "┌─── Hi ───┐" { eprintln("FAIL 12 got=" + titled); fail = fail + 1 }

    n = n + 1
    if box_frame_lines("single", 1, 5) == [] {
        // empty — w<2 → []. Confirm with type check.
        // OK
    } else {
        eprintln("FAIL 13: should reject w<2"); fail = fail + 1
    }

    if fail == 0 {
        println("__TERM_BOX_SELFTEST__ PASS n=" + to_string(n) + " fail=0")
    } else {
        println("__TERM_BOX_SELFTEST__ FAIL n=" + to_string(n) + " fail=" + to_string(fail))
    }
}

let _tbox_argv = args()
let mut _tbox_st = false
let mut _tbox_ai = 0
while _tbox_ai < len(_tbox_argv) {
    if _tbox_argv[_tbox_ai] == "--selftest-term-box" { _tbox_st = true }
    if _tbox_argv[_tbox_ai] == "--selftest" {
        let mut _tbox_aj = 0
        while _tbox_aj < len(_tbox_argv) {
            if _tbox_argv[_tbox_aj].ends_with("/stdlib/term_box.hexa") { _tbox_st = true }
            _tbox_aj = _tbox_aj + 1
        }
    }
    _tbox_ai = _tbox_ai + 1
}
if _tbox_st {
    _tbox_selftest()
}
