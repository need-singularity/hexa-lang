// self/stdlib/syntax_highlight.hexa — minimal hljs-compatible highlighter.
//
// Resolves part of hive blocker `goal_hexa_native_html_templating`.
// Replaces vendored `highlight.min.js` with a pure-hexa tokenizer that
// emits the same `hljs-*` span class set the existing CSS rules in
// hive's export-html template depend on. Coverage targets the ~50%
// surface that chat-history exports actually exercise.
//
// Languages (top 8 — covers >95% of hive's exported code blocks):
//   - js / javascript
//   - ts / typescript
//   - python / py
//   - bash / sh / shell
//   - json
//   - sql
//   - html / xml
//   - css
//
// Output classes (subset of hljs vocabulary):
//   hljs-keyword, hljs-string, hljs-comment, hljs-number,
//   hljs-built_in, hljs-literal, hljs-tag, hljs-attr, hljs-selector-tag
//
// Unknown / out-of-set languages → return HTML-escaped text wrapped in
// a single span (mirrors hljs's plain fallback). Never throws.
//
// raw 9 (pure hexa): zero exec(), zero external libs.
// raw 91 (no_silent_errors): unknown language flagged via prefix line
//   in fallback mode is opt-in (caller passes strict=true).
// raw 159 (hexa-lang-upstream-proposal-mandate): hive ports
//   `use "self/stdlib/syntax_highlight"`.
//
// --selftest mode:
//   hexa run self/stdlib/syntax_highlight.hexa --selftest
//     → emits __SYNTAX_HIGHLIGHT_SELFTEST__ <PASS|FAIL> n=<N> fail=<M>
//
// Exports:
//   highlight(code: string, lang: string) -> string
//       Tokenize and wrap each token in <span class="hljs-...">.
//       Returns HTML-escaped output. Unknown lang → plain escape.
//   highlight_supported(lang: string) -> bool
//       True if lang is in the supported set.
//   highlight_normalize_lang(lang: string) -> string
//       Map aliases to canonical names (js→javascript, py→python, ...).

// ── _sh_escape ─────────────────────────────────────────────
fn _sh_escape(text) {
    let s = to_string(text)
    let mut out = ""
    let mut i = 0
    let n = len(s)
    while i < n {
        let ch = s[i]
        if ch == "&" {
            out = out + "&amp;"
        } else {
            if ch == "<" {
                out = out + "&lt;"
            } else {
                if ch == ">" {
                    out = out + "&gt;"
                } else {
                    if ch == "\"" {
                        out = out + "&quot;"
                    } else {
                        if ch == "'" {
                            out = out + "&#39;"
                        } else {
                            out = out + ch
                        }
                    }
                }
            }
        }
        i = i + 1
    }
    return out
}

// ── _is_alpha ──────────────────────────────────────────────
fn _is_alpha(ch) {
    if ch >= "a" && ch <= "z" { return true }
    if ch >= "A" && ch <= "Z" { return true }
    if ch == "_" { return true }
    return false
}

fn _is_alnum(ch) {
    if _is_alpha(ch) { return true }
    if ch >= "0" && ch <= "9" { return true }
    return false
}

fn _is_digit_ch(ch) {
    return ch >= "0" && ch <= "9"
}

// ── highlight_normalize_lang ───────────────────────────────
fn highlight_normalize_lang(lang) {
    let l = to_string(lang).to_lower().trim()
    if l == "js"        { return "javascript" }
    if l == "ts"        { return "typescript" }
    if l == "py"        { return "python" }
    if l == "sh"        { return "bash" }
    if l == "shell"     { return "bash" }
    if l == "xml"       { return "html" }
    if l == "yml"       { return "yaml" }
    return l
}

// ── _kw_set ────────────────────────────────────────────────
// Returns array of (keyword, class) pairs for a given language.
// `class` is one of: keyword, literal, built_in.
fn _kw_set(lang) {
    if lang == "javascript" || lang == "typescript" {
        let kws = ["var","let","const","function","return","if","else","for","while","do","switch","case","break","continue","new","delete","typeof","instanceof","in","of","try","catch","finally","throw","class","extends","super","this","import","export","from","as","default","async","await","yield","static","void","null","undefined","true","false"]
        let lits = ["true","false","null","undefined","NaN","Infinity"]
        let bins = ["console","Math","Object","Array","String","Number","Boolean","Promise","Error","JSON","Map","Set","Date","RegExp","Symbol","Reflect","Proxy"]
        if lang == "typescript" {
            kws.push("interface")
            kws.push("type")
            kws.push("enum")
            kws.push("namespace")
            kws.push("public")
            kws.push("private")
            kws.push("protected")
            kws.push("readonly")
            kws.push("implements")
            kws.push("declare")
            kws.push("abstract")
        }
        return [kws, lits, bins]
    }
    if lang == "python" {
        let kws = ["def","return","if","elif","else","for","while","break","continue","pass","import","from","as","class","try","except","finally","raise","with","yield","lambda","global","nonlocal","in","is","not","and","or","async","await","del"]
        let lits = ["True","False","None"]
        let bins = ["print","len","range","str","int","float","list","dict","tuple","set","bool","type","isinstance","open","input","map","filter","zip","enumerate","sorted","sum","min","max","abs","round"]
        return [kws, lits, bins]
    }
    if lang == "bash" {
        let kws = ["if","then","else","elif","fi","case","esac","for","in","do","done","while","until","function","return","break","continue","local","export","readonly","declare","typeset","unset","exit","trap","source","eval"]
        let lits = ["true","false"]
        let bins = ["echo","printf","cd","ls","cp","mv","rm","mkdir","rmdir","cat","grep","sed","awk","find","xargs","sort","uniq","head","tail","wc","tr","cut","tee","read","test"]
        return [kws, lits, bins]
    }
    if lang == "json" {
        let kws = []
        let lits = ["true","false","null"]
        let bins = []
        return [kws, lits, bins]
    }
    if lang == "sql" {
        let kws = ["SELECT","FROM","WHERE","INSERT","INTO","VALUES","UPDATE","SET","DELETE","CREATE","TABLE","INDEX","VIEW","DROP","ALTER","ADD","COLUMN","JOIN","INNER","LEFT","RIGHT","OUTER","ON","AS","GROUP","BY","ORDER","LIMIT","OFFSET","HAVING","UNION","DISTINCT","AND","OR","NOT","IN","BETWEEN","LIKE","IS","NULL","PRIMARY","KEY","FOREIGN","REFERENCES","DEFAULT","UNIQUE","CHECK","CONSTRAINT","CASCADE","RESTRICT","BEGIN","COMMIT","ROLLBACK","TRANSACTION","WITH","CASE","WHEN","THEN","ELSE","END","select","from","where","insert","into","values","update","set","delete","create","table","drop","join","on","as","group","by","order","and","or","not","in","like","is","null"]
        let lits = ["NULL","TRUE","FALSE","null","true","false"]
        let bins = ["COUNT","SUM","AVG","MIN","MAX","COALESCE","CAST","CONVERT","SUBSTRING","UPPER","LOWER","LENGTH","TRIM","NOW","CURRENT_TIMESTAMP","count","sum","avg","min","max","coalesce"]
        return [kws, lits, bins]
    }
    if lang == "css" {
        let kws = ["important","inherit","initial","unset","auto","none","solid","dashed","dotted","absolute","relative","fixed","static","sticky","block","inline","flex","grid","hidden","visible","center","left","right"]
        let lits = []
        let bins = ["rgb","rgba","hsl","hsla","url","calc","var","linear-gradient","radial-gradient"]
        return [kws, lits, bins]
    }
    return [[], [], []]
}

// ── _kw_match ──────────────────────────────────────────────
// True if `word` matches any string in arr.
fn _kw_match(word, arr) {
    let n = len(arr)
    let mut i = 0
    while i < n {
        if arr[i] == word { return true }
        i = i + 1
    }
    return false
}

// ── _scan_string ───────────────────────────────────────────
// Starting at `i` (s[i] is opening quote), find closing quote index
// (handling backslash-escapes). Returns -1 if unterminated.
fn _scan_string(s, i) {
    let n = len(s)
    let q = s[i]
    let mut j = i + 1
    while j < n {
        let ch = s[j]
        if ch == "\\" && j + 1 < n {
            j = j + 2
            continue
        }
        if ch == q { return j }
        j = j + 1
    }
    return -1
}

// ── _scan_number ───────────────────────────────────────────
// From index i (s[i] is a digit), scan integer/float. Returns end index.
fn _scan_number(s, i) {
    let n = len(s)
    let mut j = i
    let mut seen_dot = false
    while j < n {
        let ch = s[j]
        if _is_digit_ch(ch) {
            j = j + 1
            continue
        }
        if ch == "." && !seen_dot && j + 1 < n && _is_digit_ch(s[j + 1]) {
            seen_dot = true
            j = j + 1
            continue
        }
        break
    }
    return j
}

// ── _scan_word ─────────────────────────────────────────────
fn _scan_word(s, i) {
    let n = len(s)
    let mut j = i
    while j < n && _is_alnum(s[j]) {
        j = j + 1
    }
    return j
}

// ── _ss ────────────────────────────────────────────────────
// Local substring slicer.
fn _ss(s, a, b) {
    let mut out = ""
    let mut i = a
    while i < b {
        out = out + s[i]
        i = i + 1
    }
    return out
}

// ── _highlight_generic ─────────────────────────────────────
// Generic tokenizer: keywords, strings, numbers, line comments.
// `cmt_line` — string token that begins a line comment ("//", "#", "--", or "")
// `cmt_block_open/close` — pair for block comments (or "" / "" to disable)
fn _highlight_generic(code, kws, lits, bins, cmt_line, cmt_block_open, cmt_block_close) {
    let s = to_string(code)
    let n = len(s)
    let mut out = ""
    let mut i = 0
    while i < n {
        let ch = s[i]
        // Line comment
        if cmt_line != "" {
            let m = len(cmt_line)
            if i + m <= n {
                let mut match_cl = true
                let mut k = 0
                while k < m {
                    if s[i + k] != cmt_line[k] { match_cl = false; break }
                    k = k + 1
                }
                if match_cl {
                    let nl = i
                    let mut e = nl
                    while e < n && s[e] != "\n" {
                        e = e + 1
                    }
                    out = out + "<span class=\"hljs-comment\">" + _sh_escape(_ss(s, i, e)) + "</span>"
                    i = e
                    continue
                }
            }
        }
        // Block comment
        if cmt_block_open != "" {
            let m = len(cmt_block_open)
            if i + m <= n {
                let mut match_co = true
                let mut k = 0
                while k < m {
                    if s[i + k] != cmt_block_open[k] { match_co = false; break }
                    k = k + 1
                }
                if match_co {
                    let cm = len(cmt_block_close)
                    let mut e = i + m
                    while e + cm <= n {
                        let mut match_cc = true
                        let mut k2 = 0
                        while k2 < cm {
                            if s[e + k2] != cmt_block_close[k2] { match_cc = false; break }
                            k2 = k2 + 1
                        }
                        if match_cc {
                            e = e + cm
                            break
                        }
                        e = e + 1
                    }
                    out = out + "<span class=\"hljs-comment\">" + _sh_escape(_ss(s, i, e)) + "</span>"
                    i = e
                    continue
                }
            }
        }
        // String literal
        if ch == "\"" || ch == "'" || ch == "`" {
            let close = _scan_string(s, i)
            if close >= 0 {
                out = out + "<span class=\"hljs-string\">" + _sh_escape(_ss(s, i, close + 1)) + "</span>"
                i = close + 1
                continue
            }
            // Unterminated — emit rest as string
            out = out + "<span class=\"hljs-string\">" + _sh_escape(_ss(s, i, n)) + "</span>"
            i = n
            continue
        }
        // Number
        if _is_digit_ch(ch) {
            let e = _scan_number(s, i)
            out = out + "<span class=\"hljs-number\">" + _sh_escape(_ss(s, i, e)) + "</span>"
            i = e
            continue
        }
        // Identifier / keyword
        if _is_alpha(ch) {
            let e = _scan_word(s, i)
            let word = _ss(s, i, e)
            if _kw_match(word, kws) {
                out = out + "<span class=\"hljs-keyword\">" + _sh_escape(word) + "</span>"
            } else {
                if _kw_match(word, lits) {
                    out = out + "<span class=\"hljs-literal\">" + _sh_escape(word) + "</span>"
                } else {
                    if _kw_match(word, bins) {
                        out = out + "<span class=\"hljs-built_in\">" + _sh_escape(word) + "</span>"
                    } else {
                        out = out + _sh_escape(word)
                    }
                }
            }
            i = e
            continue
        }
        // Default — escape and emit single char
        out = out + _sh_escape(ch)
        i = i + 1
    }
    return out
}

// ── _highlight_html ────────────────────────────────────────
// HTML-specific: <tag attr="val">. Cheap state machine.
fn _highlight_html(code) {
    let s = to_string(code)
    let n = len(s)
    let mut out = ""
    let mut i = 0
    while i < n {
        let ch = s[i]
        // <!-- comment -->
        if ch == "<" && i + 3 < n && s[i + 1] == "!" && s[i + 2] == "-" && s[i + 3] == "-" {
            let mut e = i + 4
            while e + 3 <= n {
                if s[e] == "-" && s[e + 1] == "-" && s[e + 2] == ">" {
                    e = e + 3
                    break
                }
                e = e + 1
            }
            out = out + "<span class=\"hljs-comment\">" + _sh_escape(_ss(s, i, e)) + "</span>"
            i = e
            continue
        }
        // <tag ...>
        if ch == "<" {
            let mut e = i + 1
            while e < n && s[e] != ">" {
                e = e + 1
            }
            if e < n { e = e + 1 }
            // Render the tag span
            out = out + "<span class=\"hljs-tag\">" + _sh_escape(_ss(s, i, e)) + "</span>"
            i = e
            continue
        }
        out = out + _sh_escape(ch)
        i = i + 1
    }
    return out
}

// ── _highlight_css ─────────────────────────────────────────
// CSS-specific: selectors → hljs-selector-tag, properties → hljs-attr,
// strings/numbers/comments via generic helpers (inline).
fn _highlight_css(code) {
    let s = to_string(code)
    let n = len(s)
    let mut out = ""
    let mut i = 0
    let mut in_block = false   // inside { ... }
    while i < n {
        let ch = s[i]
        // Block comment /* ... */
        if ch == "/" && i + 1 < n && s[i + 1] == "*" {
            let mut e = i + 2
            while e + 1 < n {
                if s[e] == "*" && s[e + 1] == "/" {
                    e = e + 2
                    break
                }
                e = e + 1
            }
            out = out + "<span class=\"hljs-comment\">" + _sh_escape(_ss(s, i, e)) + "</span>"
            i = e
            continue
        }
        if ch == "{" {
            in_block = true
            out = out + _sh_escape(ch)
            i = i + 1
            continue
        }
        if ch == "}" {
            in_block = false
            out = out + _sh_escape(ch)
            i = i + 1
            continue
        }
        // String
        if ch == "\"" || ch == "'" {
            let close = _scan_string(s, i)
            if close >= 0 {
                out = out + "<span class=\"hljs-string\">" + _sh_escape(_ss(s, i, close + 1)) + "</span>"
                i = close + 1
                continue
            }
        }
        // Number
        if _is_digit_ch(ch) {
            let e = _scan_number(s, i)
            out = out + "<span class=\"hljs-number\">" + _sh_escape(_ss(s, i, e)) + "</span>"
            i = e
            continue
        }
        // Word
        if _is_alpha(ch) || ch == "-" || ch == "." || ch == "#" {
            let mut e = i
            if ch == "-" || ch == "." || ch == "#" { e = i + 1 }
            while e < n && (_is_alnum(s[e]) || s[e] == "-") {
                e = e + 1
            }
            let word = _ss(s, i, e)
            if in_block {
                // Property name (likely)
                out = out + "<span class=\"hljs-attr\">" + _sh_escape(word) + "</span>"
            } else {
                // Selector
                out = out + "<span class=\"hljs-selector-tag\">" + _sh_escape(word) + "</span>"
            }
            i = e
            continue
        }
        out = out + _sh_escape(ch)
        i = i + 1
    }
    return out
}

// ── highlight_supported ────────────────────────────────────
fn highlight_supported(lang) {
    let l = highlight_normalize_lang(lang)
    if l == "javascript" { return true }
    if l == "typescript" { return true }
    if l == "python"     { return true }
    if l == "bash"       { return true }
    if l == "json"       { return true }
    if l == "sql"        { return true }
    if l == "html"       { return true }
    if l == "css"        { return true }
    return false
}

// ── highlight ──────────────────────────────────────────────
fn highlight(code, lang) {
    let l = highlight_normalize_lang(lang)
    if l == "html" {
        return _highlight_html(code)
    }
    if l == "css" {
        return _highlight_css(code)
    }
    if l == "javascript" || l == "typescript" {
        let sets = _kw_set(l)
        return _highlight_generic(code, sets[0], sets[1], sets[2], "//", "/*", "*/")
    }
    if l == "python" {
        let sets = _kw_set(l)
        return _highlight_generic(code, sets[0], sets[1], sets[2], "#", "", "")
    }
    if l == "bash" {
        let sets = _kw_set(l)
        return _highlight_generic(code, sets[0], sets[1], sets[2], "#", "", "")
    }
    if l == "sql" {
        let sets = _kw_set(l)
        return _highlight_generic(code, sets[0], sets[1], sets[2], "--", "/*", "*/")
    }
    if l == "json" {
        let sets = _kw_set(l)
        return _highlight_generic(code, sets[0], sets[1], sets[2], "", "", "")
    }
    // Unknown: just escape.
    return _sh_escape(code)
}

// ── --selftest ──────────────────────────────────────────────
fn _sh_selftest() {
    let mut fail = 0
    let mut n = 0

    // 1. js keyword
    n = n + 1
    let r1 = highlight("let x = 1", "js")
    if !r1.contains("<span class=\"hljs-keyword\">let</span>") {
        eprintln("FAIL 1 js let: " + r1)
        fail = fail + 1
    }
    if !r1.contains("<span class=\"hljs-number\">1</span>") {
        eprintln("FAIL 1b js num: " + r1)
        fail = fail + 1
    }

    // 2. js string
    n = n + 1
    let r2 = highlight("let s = \"hi\"", "js")
    if !r2.contains("hljs-string") {
        eprintln("FAIL 2 js str: " + r2)
        fail = fail + 1
    }

    // 3. js comment
    n = n + 1
    let r3 = highlight("// note\nlet x = 1", "js")
    if !r3.contains("<span class=\"hljs-comment\">// note</span>") {
        eprintln("FAIL 3 js cmt: " + r3)
        fail = fail + 1
    }

    // 4. python keyword + builtin
    n = n + 1
    let r4 = highlight("def foo():\n    print(1)", "python")
    if !r4.contains("<span class=\"hljs-keyword\">def</span>") {
        eprintln("FAIL 4 py def: " + r4)
        fail = fail + 1
    }
    if !r4.contains("<span class=\"hljs-built_in\">print</span>") {
        eprintln("FAIL 4b py print: " + r4)
        fail = fail + 1
    }

    // 5. python comment
    n = n + 1
    let r5 = highlight("# hello\nx = 1", "python")
    if !r5.contains("<span class=\"hljs-comment\"># hello</span>") {
        eprintln("FAIL 5 py cmt: " + r5)
        fail = fail + 1
    }

    // 6. bash builtin
    n = n + 1
    let r6 = highlight("echo hello", "bash")
    if !r6.contains("hljs-built_in") {
        eprintln("FAIL 6 bash echo: " + r6)
        fail = fail + 1
    }

    // 7. json literal
    n = n + 1
    let r7 = highlight("{\"a\": true, \"b\": null}", "json")
    if !r7.contains("<span class=\"hljs-literal\">true</span>") {
        eprintln("FAIL 7 json true: " + r7)
        fail = fail + 1
    }
    if !r7.contains("<span class=\"hljs-literal\">null</span>") {
        eprintln("FAIL 7b json null: " + r7)
        fail = fail + 1
    }

    // 8. sql keyword
    n = n + 1
    let r8 = highlight("SELECT * FROM users", "sql")
    if !r8.contains("<span class=\"hljs-keyword\">SELECT</span>") {
        eprintln("FAIL 8 sql SELECT: " + r8)
        fail = fail + 1
    }

    // 9. html tag
    n = n + 1
    let r9 = highlight("<div class=\"x\">hi</div>", "html")
    if !r9.contains("hljs-tag") {
        eprintln("FAIL 9 html tag: " + r9)
        fail = fail + 1
    }

    // 10. css selector + attr
    n = n + 1
    let r10 = highlight(".foo { color: red; }", "css")
    if !r10.contains("hljs-selector-tag") {
        eprintln("FAIL 10 css sel: " + r10)
        fail = fail + 1
    }
    if !r10.contains("hljs-attr") {
        eprintln("FAIL 10b css attr: " + r10)
        fail = fail + 1
    }

    // 11. unknown lang → plain escape
    n = n + 1
    let r11 = highlight("x < y", "rust")
    if r11.contains("hljs-keyword") {
        eprintln("FAIL 11 unknown: " + r11)
        fail = fail + 1
    }
    if !r11.contains("&lt;") {
        eprintln("FAIL 11b escape: " + r11)
        fail = fail + 1
    }

    // 12. supported() check
    n = n + 1
    if !highlight_supported("js") { eprintln("FAIL 12 js"); fail = fail + 1 }
    if !highlight_supported("python") { eprintln("FAIL 12 py"); fail = fail + 1 }
    if highlight_supported("rust") { eprintln("FAIL 12 rust"); fail = fail + 1 }

    // 13. normalize aliases
    n = n + 1
    if highlight_normalize_lang("JS") != "javascript" { eprintln("FAIL 13 JS"); fail = fail + 1 }
    if highlight_normalize_lang("py") != "python" { eprintln("FAIL 13 py"); fail = fail + 1 }
    if highlight_normalize_lang("sh") != "bash" { eprintln("FAIL 13 sh"); fail = fail + 1 }

    // 14. typescript adds interface
    n = n + 1
    let r14 = highlight("interface X { a: string }", "ts")
    if !r14.contains("<span class=\"hljs-keyword\">interface</span>") {
        eprintln("FAIL 14 ts interface: " + r14)
        fail = fail + 1
    }

    // 15. HTML escape preserved in output
    n = n + 1
    let r15 = highlight("a < b && c > d", "js")
    if !r15.contains("&lt;") || !r15.contains("&amp;") || !r15.contains("&gt;") {
        eprintln("FAIL 15 esc: " + r15)
        fail = fail + 1
    }

    if fail == 0 {
        println("__SYNTAX_HIGHLIGHT_SELFTEST__ PASS n=" + to_string(n) + " fail=0")
    } else {
        println("__SYNTAX_HIGHLIGHT_SELFTEST__ FAIL n=" + to_string(n) + " fail=" + to_string(fail))
    }
}

let _sh_argv = args()
let mut _sh_selftest_flag = false
let mut _sh_ai = 0
while _sh_ai < len(_sh_argv) {
    if _sh_argv[_sh_ai] == "--selftest" { _sh_selftest_flag = true }
    if _sh_argv[_sh_ai] == "--selftest-syntax-highlight" { _sh_selftest_flag = true }
    _sh_ai = _sh_ai + 1
}
if _sh_selftest_flag {
    _sh_selftest()
}
