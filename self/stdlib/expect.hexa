// self/stdlib/expect.hexa — vitest-parity expect/matcher API.
//
// Pairs with self/stdlib/test.hexa. Provides the assertion surface that
// hive's archived `*.test.archive.txt` files use most heavily:
//   .toBe(x), .toEqual(x), .toContain(x), .toThrow(), .toBeDefined(),
//   .toMatch(re).
//
// raw 9  (pure-hexa):     external libs = 0. Builtins only.
// raw 18 (self-host fixpoint): zero new builtins.
// raw 91 (no_silent_errors): every assert that fails calls
//   test_record_failure(msg) on test.hexa — the runner's verdict line is
//   never silent. Bare expect() (outside it()) eprintln+exit(1).
// raw 159 (hexa-lang-upstream-proposal-mandate): hive's *.test.hexa ports
//   `use "self/stdlib/expect"` and never re-implement matchers.
//
// ── Why two API surfaces (chained + flat) ────────────────────────────
// The current hexa interp does NOT support method-style invocation on
// arbitrary user-defined map values (`expect(x).to_be(y)` → `to_be` is
// not bound on a record). We therefore expose:
//
//   1. CHAINED form via free fns that take a `matcher` record:
//        let m = expect(actual)
//        to_be(m, expected)
//        to_equal(m, expected)
//        to_contain(m, needle)
//        to_throw(m)              // needs body fn — see G1
//        to_be_defined(m)
//        to_match(m, pattern)
//
//   2. FLAT form (one call per assertion) for ergonomic ports:
//        assert_eq(actual, expected)        — maps to .toBe
//        assert_deep_eq(actual, expected)   — maps to .toEqual
//        assert_contains(haystack, needle)  — maps to .toContain
//        assert_defined(value)              — maps to .toBeDefined
//        assert_matches(s, pattern)         — maps to .toMatch
//        assert_throws(body_fn)             — maps to .toThrow
//
// Both record the failure via test.hexa's test_record_failure(msg) so
// the runner picks them up uniformly.
//
// ── Known gaps (raw 91 honest) ───────────────────────────────────────
//   G1. `.toThrow()` requires the runtime to support catchable errors;
//       on this interp many failures eprintln+exit. We approximate via
//       `assert_throws(body_fn)` which scans for a sentinel side-effect
//       written by the body to a known global var (`_expect_throw_flag`).
//       Bodies that intend to "throw" should set _expect_throw_flag = true
//       before returning. This is the honest contract until the runtime
//       lands try/catch (RFC stdlib_json_rfc §4 family).
//   G2. `.not.toBe(x)` chained negation is NOT exposed because we cannot
//       attach a `.not` field with bound matchers. Use `not_to_be()` etc.
//   G3. `.toMatch(regex)` uses substring match (not full regex) because
//       hexa stdlib has no regex builtin. Documented limit.
//   G4. `.toBeCloseTo(num, digits)` for floats — NOT implemented; hive
//       archives don't currently use it. Stub-marker only.
//
// ── --selftest ────────────────────────────────────────────────────────
//   hexa run self/stdlib/expect.hexa --selftest
//     → emits __EXPECT_SELFTEST__ <PASS|FAIL> n=<N> fail=<M>

use "self/stdlib/test"

// ─── matcher constructor ─────────────────────────────────────────────
// Returns a 1-element array [actual] — keeps the API future-compatible
// with `[actual, NOT_FLAG]` style negation. Records are stored as arrays
// because the interp's struct/record support varies across paths.
fn expect(actual) {
    return [actual]
}

// ─── helpers ─────────────────────────────────────────────────────────
fn _expect_format(v) {
    let t = type_of(v)
    if t == "string" { return "\"" + to_string(v) + "\"" }
    return to_string(v)
}

// Deep equality for hexa-native nested structures (arrays, primitive
// values, strings). Falls back to `==` when both sides are scalars.
// raw 91: documented limit — does NOT recurse into map/object fields
// generically (would need keys() iteration which this interp exposes
// inconsistently). Most hive archive uses are array/scalar deep-eq.
// decreases a — structural
fn _expect_deep_eq(a, b) {
    let ta = type_of(a)
    let tb = type_of(b)
    if ta != tb { return false }
    if ta == "array" {
        if len(a) != len(b) { return false }
        let mut i = 0
        while i < len(a) {
            if !_expect_deep_eq(a[i], b[i]) { return false }
            i = i + 1
        }
        return true
    }
    return a == b
}

// ─── chained-form matchers ───────────────────────────────────────────
fn to_be(m, expected) {
    let actual = m[0]
    if actual == expected {
        return true
    }
    let msg = "expected " + _expect_format(expected) + " got " + _expect_format(actual)
    test_record_failure(msg)
    return false
}

fn not_to_be(m, expected) {
    let actual = m[0]
    if actual != expected {
        return true
    }
    let msg = "expected NOT " + _expect_format(expected) + " but values matched"
    test_record_failure(msg)
    return false
}

fn to_equal(m, expected) {
    let actual = m[0]
    if _expect_deep_eq(actual, expected) {
        return true
    }
    let msg = "deep-eq failed: expected " + _expect_format(expected)
        + " got " + _expect_format(actual)
    test_record_failure(msg)
    return false
}

fn to_contain(m, needle) {
    let actual = m[0]
    let ta = type_of(actual)
    if ta == "string" {
        if actual.contains(to_string(needle)) {
            return true
        }
        test_record_failure("string did not contain " + _expect_format(needle))
        return false
    }
    if ta == "array" {
        let mut i = 0
        while i < len(actual) {
            if actual[i] == needle { return true }
            i = i + 1
        }
        test_record_failure("array did not contain " + _expect_format(needle))
        return false
    }
    test_record_failure("to_contain: unsupported type " + ta)
    return false
}

fn to_be_defined(m) {
    let actual = m[0]
    let ta = type_of(actual)
    if ta == "void" {
        test_record_failure("expected defined value, got void")
        return false
    }
    return true
}

fn to_be_undefined(m) {
    let actual = m[0]
    let ta = type_of(actual)
    if ta != "void" {
        test_record_failure("expected void, got " + ta + " " + _expect_format(actual))
        return false
    }
    return true
}

// G3: substring match only (no regex builtin).
fn to_match(m, pattern) {
    let actual = m[0]
    let s = to_string(actual)
    if s.contains(to_string(pattern)) {
        return true
    }
    test_record_failure("string \"" + s + "\" did not match pattern \"" + to_string(pattern) + "\"")
    return false
}

// G1: see docblock. body_fn must set _expect_throw_flag = true if it
// "throws". Without runtime try/catch, this is the only honest contract.
let mut _expect_throw_flag = false

fn to_throw(m) {
    // chained form variant — m is unused (kept for API symmetry); the
    // user must invoke a wrapped body separately. Prefer assert_throws.
    if _expect_throw_flag {
        _expect_throw_flag = false
        return true
    }
    test_record_failure("expected fn to throw — _expect_throw_flag was not set")
    return false
}

// ─── flat-form (single-call) matchers ────────────────────────────────
// More ergonomic for direct port of `expect(x).toBe(y)` lines.
fn assert_eq(actual, expected) {
    return to_be([actual], expected)
}

fn assert_deep_eq(actual, expected) {
    return to_equal([actual], expected)
}

fn assert_contains(haystack, needle) {
    return to_contain([haystack], needle)
}

fn assert_defined(v) {
    return to_be_defined([v])
}

fn assert_matches(s, pattern) {
    return to_match([s], pattern)
}

// G1: invokes body_fn() and checks _expect_throw_flag.
fn assert_throws(body_fn) {
    _expect_throw_flag = false
    body_fn()
    if _expect_throw_flag {
        _expect_throw_flag = false
        return true
    }
    test_record_failure("expected body_fn to throw — flag not set")
    return false
}

// External hook so user code can mark a "throw" without depending on the
// internal var name.
fn expect_throw_flag_set() {
    _expect_throw_flag = true
}

// ─── --selftest ──────────────────────────────────────────────────────
fn _expect_synth_thrower() {
    expect_throw_flag_set()
}

fn _expect_synth_nonthrower() {
    // does nothing — flag stays false
}

fn _expect_selftest() {
    test_clear()
    let mut fail = 0
    let mut n = 0

    // 1. assert_eq pass
    n = n + 1
    if !assert_eq(1 + 1, 2) {
        eprintln("FAIL 1 assert_eq(2,2)")
        fail = fail + 1
    }

    // 2. assert_eq fail records
    n = n + 1
    test_clear()
    let _it_dummy_name = "_dummy"
    // simulate inside-it scope by directly inspecting failure recording
    assert_eq(1, 2)
    let fr = test_results()
    // No it() wrapper so the failure was stored in _test_current_failure
    // but never flushed to results. Verify it's in current_failure via
    // test_record_failure path — call it() to flush.
    if len(fr) != 0 {
        eprintln("FAIL 2a unexpected pre-it() rows: " + to_string(len(fr)))
        fail = fail + 1
    }

    // 3. assert_deep_eq array
    n = n + 1
    if !assert_deep_eq([1, 2, 3], [1, 2, 3]) {
        eprintln("FAIL 3 deep_eq array equal")
        fail = fail + 1
    }

    // 4. assert_deep_eq nested
    n = n + 1
    if !assert_deep_eq([[1, 2], [3, 4]], [[1, 2], [3, 4]]) {
        eprintln("FAIL 4 deep_eq nested")
        fail = fail + 1
    }

    // 5. assert_deep_eq mismatch returns false
    n = n + 1
    test_clear()
    if assert_deep_eq([1, 2], [1, 3]) {
        eprintln("FAIL 5 deep_eq mismatch should be false")
        fail = fail + 1
    }

    // 6. assert_contains string
    n = n + 1
    test_clear()
    if !assert_contains("hello world", "world") {
        eprintln("FAIL 6 contains string")
        fail = fail + 1
    }

    // 7. assert_contains array
    n = n + 1
    if !assert_contains([1, 2, 3], 2) {
        eprintln("FAIL 7 contains array")
        fail = fail + 1
    }

    // 8. assert_contains negative
    n = n + 1
    test_clear()
    if assert_contains("foo", "bar") {
        eprintln("FAIL 8 contains negative")
        fail = fail + 1
    }

    // 9. assert_defined positive
    n = n + 1
    test_clear()
    if !assert_defined(42) {
        eprintln("FAIL 9 defined int")
        fail = fail + 1
    }
    n = n + 1
    if !assert_defined("hi") {
        eprintln("FAIL 10 defined string")
        fail = fail + 1
    }

    // 10. assert_matches substring (G3)
    n = n + 1
    test_clear()
    if !assert_matches("/path/to/file.ts", "file.ts") {
        eprintln("FAIL 11 matches substring")
        fail = fail + 1
    }

    // 11. chained form: to_be / to_equal
    n = n + 1
    test_clear()
    let m = expect(7)
    if !to_be(m, 7) {
        eprintln("FAIL 12 chained to_be")
        fail = fail + 1
    }

    // 12. assert_throws with synthetic thrower
    n = n + 1
    test_clear()
    if !assert_throws(_expect_synth_thrower) {
        eprintln("FAIL 13 assert_throws expected true")
        fail = fail + 1
    }

    // 13. assert_throws with non-thrower returns false
    n = n + 1
    test_clear()
    if assert_throws(_expect_synth_nonthrower) {
        eprintln("FAIL 14 non-thrower should not pass throws check")
        fail = fail + 1
    }

    // 14. not_to_be positive
    n = n + 1
    test_clear()
    if !not_to_be(expect(1), 2) {
        eprintln("FAIL 15 not_to_be")
        fail = fail + 1
    }

    if fail == 0 {
        println("__EXPECT_SELFTEST__ PASS n=" + to_string(n) + " fail=0")
    } else {
        println("__EXPECT_SELFTEST__ FAIL n=" + to_string(n) + " fail=" + to_string(fail))
    }
}

let _expect_argv = args()
let mut _expect_selftest_flag = false
let mut _expect_ai = 0
while _expect_ai < len(_expect_argv) {
    if _expect_argv[_expect_ai] == "--selftest" { _expect_selftest_flag = true }
    if _expect_argv[_expect_ai] == "--selftest-expect" { _expect_selftest_flag = true }
    _expect_ai = _expect_ai + 1
}
if _expect_selftest_flag {
    _expect_selftest()
}
