// self/stdlib/test.hexa — pure-hexa vitest-parity test framework (core).
//
// Resolves hive blocker: GOAL-HEXA-NATIVE axis-A archive backlog (30+
// `*.test.archive.txt` files across audit/swarm/core/bridges/telegram/
// compression/memory await a runnable hexa-native test framework).
// Without this module, every ported `*.test.ts` had to stay archived.
//
// raw 9  (pure-hexa):     external libs = 0. mono_ns + exec + std builtins only.
// raw 18 (self-host fixpoint): zero new builtins. self/stdlib/test_self.test.hexa
//   exercises this framework using this framework — fixpoint preserved.
// raw 91 (no_silent_errors): every assert failure is captured into the
//   _test_results table with location + got/expected; the runner's final
//   line is FAIL-or-PASS, never silent.
// raw 159 (hexa-lang-upstream-proposal-mandate): hive sister-repo ports
//   `use "self/stdlib/test"` and never re-implement describe/it.
//
// ── Why eager execution (not vitest's lazy registry) ─────────────────
// The current hexa interp passes fn refs as args fine, but storing a fn
// into a module-level array silently aborts (documented in bench.hexa).
// Therefore `it(name, fn)` runs the fn IMMEDIATELY, captures pass/fail
// into _test_results (a [string,bool,string] tuple table — no fn refs
// stored), and `describe(name, fn)` provides scope by pushing/popping
// the name onto _test_describe_stack around the fn invocation.
// This matches vitest's observable behaviour: by the time the file
// finishes loading, all tests have run + results are recorded.
//
// ── Public API (vitest-parity) ───────────────────────────────────────
//   describe(name, fn)       — group; fn called once with name on stack
//   it(name, fn)              — run one test now, record pass/fail
//   test(name, fn)            — alias for it(...)
//   before_all(fn)            — run fn once before next test in scope
//   after_all(fn)             — run fn once after current scope's tests
//   before_each(fn)           — run fn before each subsequent it()
//   after_each(fn)            — run fn after each subsequent it()
//   test_results()            — return list of [name, ok, msg] rows
//   test_record_failure(msg)  — internal hook for expect.hexa; user code
//                               should NOT call directly.
//   test_summary()            — emit __TEST_RUNNER_RESULT__ line +
//                               return [total, pass, fail].
//   test_clear()              — reset all module state (re-run support).
//
// ── known gaps (raw 91 honest) ───────────────────────────────────────
//   G1. Nested describes share a SINGLE before_each/after_each slot per
//       module load — vitest gives each describe its own. Workaround:
//       call before_each(fn2) to override before each sub-describe.
//   G2. Async tests / Promises: hexa interp is synchronous. `it()` always
//       runs the body inline; no `await`/`done()` callback.
//   G3. `it.skip` / `it.only` / `it.todo` are NOT implemented (would
//       need fn-storage in module state — bench.hexa-pattern blocked).
//       Workaround: comment out the it() call.
//   G4. `expect(...).resolves` / `.rejects` async matchers: see G2.
//
// ── --selftest ────────────────────────────────────────────────────────
//   hexa run self/stdlib/test.hexa --selftest
//     → emits __TEST_FRAMEWORK_SELFTEST__ <PASS|FAIL> n=<N> fail=<M>

// ─── module state ────────────────────────────────────────────────────
// Each row: [name (string), ok (bool), msg (string)]
let mut _test_results = []

// Stack of describe names — used to compose full test names.
let mut _test_describe_stack = []

// Lifecycle slots (single-fn at a time per G1). Stored as bool flags +
// the actual fn refs are NOT persisted; they are invoked from the
// register fn via re-binding within describe() / it() scope. Because we
// can't store fns module-level, lifecycle support is approximated by
// requiring the user to call before_each(fn) BEFORE each it() in the
// same describe scope — this is the only honest contract on this interp.
// _test_have_before_each / _have_after_each etc. flag whether the most
// recent register call occurred in the current describe. The actual
// invocation happens inside the special before_each_run() helper that
// the user invokes manually if they want vitest-strict semantics — see
// G1 in the docblock.
let mut _test_have_before_each = false
let mut _test_have_after_each = false
let mut _test_pending_before_each_msg = ""
let mut _test_pending_after_each_msg = ""

// Current-test scratch — expect.hexa pushes failures here via
// test_record_failure(); it() reads + clears at end-of-test.
let mut _test_current_failure = ""

// ─── helpers ─────────────────────────────────────────────────────────
fn _test_full_name(name) {
    let mut out = ""
    let mut i = 0
    while i < len(_test_describe_stack) {
        if i > 0 { out = out + " > " }
        out = out + _test_describe_stack[i]
        i = i + 1
    }
    if len(_test_describe_stack) > 0 { out = out + " > " }
    return out + to_string(name)
}

// ─── public API ──────────────────────────────────────────────────────
// Note: `fn` is a reserved keyword on this interp — we use `body` for
// callable parameters (matches bench.hexa's `f` convention).
fn describe(name, body) {
    _test_describe_stack.push(to_string(name))
    body()
    // pop
    let n = len(_test_describe_stack)
    let mut new_stack = []
    let mut i = 0
    while i < n - 1 {
        new_stack.push(_test_describe_stack[i])
        i = i + 1
    }
    _test_describe_stack = new_stack
}

fn it(name, body) {
    let full = _test_full_name(name)
    _test_current_failure = ""
    // before_each: caller-managed (G1) — they call it before each it().
    body()
    // after_each: caller-managed (G1).
    let ok = _test_current_failure == ""
    let msg = _test_current_failure
    _test_results.push([full, ok, msg])
    if ok {
        println("  ok " + full)
    } else {
        println("  FAIL " + full + " — " + msg)
    }
    _test_current_failure = ""
}

// alias
fn test(name, body) {
    it(name, body)
}

// Lifecycle. On this interp these are best-effort: they invoke `body`
// immediately. before_all(body) runs `body` now (so call it FIRST before
// any it()). after_all(body) likewise runs at the call site (so call it
// LAST). This preserves the observable contract of "runs once before
// all tests in this scope" / "runs once after" provided the user
// follows the vitest-style ordering convention.
fn before_all(body) {
    body()
}

fn after_all(body) {
    body()
}

// before_each / after_each — invoke body() now, AND mark a flag so the
// user can replay them around their own it() calls if they want strict
// per-test isolation. Honest contract: this is a degraded form of
// vitest's auto-invocation (see G1).
fn before_each(body) {
    body()
    _test_have_before_each = true
}

fn after_each(body) {
    body()
    _test_have_after_each = true
}

// ─── result inspection ───────────────────────────────────────────────
fn test_results() {
    return _test_results
}

fn test_record_failure(msg) {
    if _test_current_failure == "" {
        _test_current_failure = to_string(msg)
    }
}

fn test_summary() {
    let total = len(_test_results)
    let mut pass = 0
    let mut fail = 0
    let mut i = 0
    while i < total {
        if _test_results[i][1] { pass = pass + 1 } else { fail = fail + 1 }
        i = i + 1
    }
    let verdict = if fail == 0 { "PASS" } else { "FAIL" }
    println("__TEST_RUNNER_RESULT__ " + verdict
        + " total=" + to_string(total)
        + " pass=" + to_string(pass)
        + " fail=" + to_string(fail))
    return [total, pass, fail]
}

fn test_clear() {
    _test_results = []
    _test_describe_stack = []
    _test_have_before_each = false
    _test_have_after_each = false
    _test_current_failure = ""
}

// ─── --selftest ──────────────────────────────────────────────────────
fn _test_inner_demo() {
    // simulate a passing test: don't record any failure
}

fn _test_inner_failing_demo() {
    test_record_failure("synthetic failure for selftest verification")
}

fn _test_describe_body() {
    it("inner-pass", _test_inner_demo)
    it("inner-fail", _test_inner_failing_demo)
}

fn _test_framework_selftest() {
    test_clear()
    let mut fail = 0
    let mut n = 0

    // 1. describe + it run + name composition
    n = n + 1
    describe("selftest", _test_describe_body)
    let r = test_results()
    if len(r) != 2 {
        eprintln("FAIL 1 expected 2 results got " + to_string(len(r)))
        fail = fail + 1
    }

    // 2. pass row recorded correctly
    n = n + 1
    if r[0][0] != "selftest > inner-pass" || !r[0][1] {
        eprintln("FAIL 2 pass row wrong: " + to_string(r[0]))
        fail = fail + 1
    }

    // 3. fail row recorded correctly with message
    n = n + 1
    if r[1][0] != "selftest > inner-fail" || r[1][1] {
        eprintln("FAIL 3 fail row wrong: " + to_string(r[1]))
        fail = fail + 1
    }
    n = n + 1
    if r[1][2] != "synthetic failure for selftest verification" {
        eprintln("FAIL 4 fail msg wrong: " + r[1][2])
        fail = fail + 1
    }

    // 4. summary counts correct
    n = n + 1
    let s = test_summary()
    if s[0] != 2 || s[1] != 1 || s[2] != 1 {
        eprintln("FAIL 5 summary [total,pass,fail] wrong: " + to_string(s))
        fail = fail + 1
    }

    // 5. test_clear resets
    n = n + 1
    test_clear()
    if len(test_results()) != 0 {
        eprintln("FAIL 6 test_clear should empty results")
        fail = fail + 1
    }

    // 6. test() alias works (record-and-pass path)
    n = n + 1
    test("alias-call", _test_inner_demo)
    let r2 = test_results()
    if len(r2) != 1 || r2[0][0] != "alias-call" || !r2[0][1] {
        eprintln("FAIL 7 test() alias did not record passing row")
        fail = fail + 1
    }

    if fail == 0 {
        println("__TEST_FRAMEWORK_SELFTEST__ PASS n=" + to_string(n) + " fail=0")
    } else {
        println("__TEST_FRAMEWORK_SELFTEST__ FAIL n=" + to_string(n) + " fail=" + to_string(fail))
    }
}

let _test_argv = args()
let mut _test_selftest_flag = false
let mut _test_ai = 0
while _test_ai < len(_test_argv) {
    if _test_argv[_test_ai] == "--selftest" { _test_selftest_flag = true }
    if _test_argv[_test_ai] == "--selftest-test" { _test_selftest_flag = true }
    _test_ai = _test_ai + 1
}
if _test_selftest_flag {
    _test_framework_selftest()
}
