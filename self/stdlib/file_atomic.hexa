// self/stdlib/file_atomic.hexa — atomic file primitives for hexa.
//
// Closes hexa-lang upstream gap #9 enumerated in
//   docs/hexa_url_complete_support_upstream_spec_2026_05_05.ai.md §2.9
// Without these primitives, the path-patch handler that replaces
// `chflags uchg` sealing (per resource.016 — "no chflags uchg") had
// to compose `cp` + `chmod` via shell, which is racy (a concurrent
// reader can see partial state mid-copy) and loses permissions on
// cross-FS moves.
//
// SCOPE
//   file_atomic_replace(target, source) -> [ok, error]
//     Atomically replaces target with the file at source via
//     rename(2) (`mv` shells out — POSIX requires rename(2) atomic on
//     same filesystem). Preserves target's mode via stat-then-chmod
//     after the rename. Owner is preserved automatically by the
//     kernel when running as root; for non-root callers the new
//     file inherits the caller's uid (documented limitation).
//
//   file_sha256(path) -> [ok, sha_hex]
//     Computes SHA-256 by shelling out to `shasum -a 256` (macOS)
//     or `sha256sum` (linux fallback). Stable across runtime modes
//     because the computation is performed by an external tool —
//     same input → same hex digest. Verified by self/test/file_sha256.hexa.
//
//   file_set_executable(path, mode) -> [ok, error]
//     `chmod` with default 0755. Wraps the common path-patch case.
//
//   file_atomic_write(path, content) -> [ok, error]
//     Writes content to a temp file in the SAME parent directory as
//     `path`, fsyncs (best-effort via shell), then renames over
//     `path`. Mid-write readers never observe partial content because
//     rename(2) is atomic on a single filesystem.
//
// ATOMIC-RENAME CONSTRAINT
//   rename(2) is atomic ONLY when source and target reside on the
//   same filesystem. Cross-filesystem renames degrade to copy+unlink
//   — racy. file_atomic_write places the temp file in the target's
//   parent dir to guarantee same-FS by construction. file_atomic_replace
//   trusts the caller to stage `source` on the same FS (typically the
//   target's parent dir as well). When the caller violates this we
//   detect non-zero exit from `mv` and surface ok=false; we do NOT
//   silently fall back to cp+rm (raw 91: no_silent_errors).
//
// RETURN-VALUE CONVENTION
//   `[ok, msg]` array-tuple — same shape as `json_parse_safe(s) -> [bool, value]`
//   in the gap doc. ok is bool; msg is empty on success or a short
//   diagnostic on failure. Callers destructure as
//     let r = file_atomic_replace(t, s)
//     if !r[0] { eprintln("replace failed: " + r[1]); exit(1) }
//
// SHELL FALLBACK STRATEGY
//   The hexa runtime currently exposes no rename(2)-bound builtin,
//   so we shell to `mv`. `mv` on macOS/linux delegates to rename(2)
//   for same-FS moves. Quoting via self/stdlib/shell_escape.hexa
//   is mandatory — every path is single-quoted, no exception.
//
// raw 91 (no_silent_errors)
//   Every shell branch checks the post-condition (target exists +
//   sha matches expected on replace, or chmod actually applied for
//   set_executable). On verify-fail we return ok=false with a hint.

use "self/stdlib/shell_escape"

// ── _fa_basename ─────────────────────────────────────────────
// Returns the basename of `p` (POSIX `basename`). Used to derive
// a temp filename adjacent to a target path.
fn _fa_basename(p: string) -> string {
    let mut i = len(p) - 1
    while i >= 0 {
        if p.substring(i, i + 1) == "/" {
            return p.substring(i + 1, len(p))
        }
        i = i - 1
    }
    return p
}

// ── _fa_dirname ──────────────────────────────────────────────
// Returns the parent dir of `p` (POSIX `dirname`). For a
// non-slashed name returns ".".
fn _fa_dirname(p: string) -> string {
    let mut i = len(p) - 1
    while i >= 0 {
        if p.substring(i, i + 1) == "/" {
            if i == 0 { return "/" }
            return p.substring(0, i)
        }
        i = i - 1
    }
    return "."
}

// ── _fa_pid ──────────────────────────────────────────────────
// Cheap process-id token for temp-file uniqueness. Falls back
// to the unix epoch milliseconds if $$ is unavailable.
fn _fa_pid() -> string {
    let pid = to_string(exec("echo $$")).trim()
    if pid == "" {
        return to_string(exec("date +%s%N 2>/dev/null || date +%s")).trim()
    }
    return pid
}

// ── _fa_exists ───────────────────────────────────────────────
// Local existence probe (avoids cross-stdlib dep on fs.hexa to
// keep file_atomic minimal — the path-patch handler is invoked
// at restore boundaries where module-loader budget matters).
fn _fa_exists(path: string) -> bool {
    let p = shell_escape(path)
    let r = to_string(exec("test -e " + p + " && echo 1 || echo 0")).trim()
    return r == "1"
}

// ── _fa_get_mode ─────────────────────────────────────────────
// Reads the octal mode bits of `path` as a string (e.g. "0755").
// Returns "" on stat failure. macOS uses `stat -f %Lp` which
// reports lower 4 octal digits with leading zero; linux uses
// `stat -c %a` which reports without leading zero — we
// normalize to a 4-char "0NNN" string so chmod re-application
// is unambiguous.
fn _fa_get_mode(path: string) -> string {
    let p = shell_escape(path)
    // try macOS, then linux.
    let raw = to_string(exec("stat -f %Lp " + p + " 2>/dev/null || stat -c %a " + p + " 2>/dev/null")).trim()
    if raw == "" { return "" }
    // pad to 4 digits.
    if len(raw) == 3 { return "0" + raw }
    if len(raw) == 4 { return raw }
    if len(raw) == 2 { return "00" + raw }
    if len(raw) == 1 { return "000" + raw }
    return raw
}

// ── _fa_run_quiet ────────────────────────────────────────────
// Run a shell command, suppress its stdout/stderr, return the
// exit code as int.
fn _fa_run_quiet(cmd: string) -> int {
    let rc = exec(cmd + " >/dev/null 2>&1; echo $?")
    let s = to_string(rc).trim()
    return to_int(s)
}

// ═════════════════════════════════════════════════════════════
//  Public surface
// ═════════════════════════════════════════════════════════════

// ── file_sha256 ──────────────────────────────────────────────
// Compute SHA-256 of `path` content. Returns [ok, sha_hex].
// Output sha_hex is the lowercase 64-char hex digest, matching
// `shasum -a 256 <path>` first column EXACTLY.
//
// Stability guarantee (per gap 6, stdlib parity across runtime
// modes): the sha is computed by an external `shasum`/`sha256sum`
// tool present on every supported host (macOS, ubu1, ubu2). The
// digest does not depend on hexa-lang runtime mode.
//
// On missing file or shell error, returns [false, ""].
pub fn file_sha256(path: string) -> array {
    if !_fa_exists(path) {
        return [false, ""]
    }
    let p = shell_escape(path)
    // macOS ships `shasum`; linux ships `sha256sum` (and usually
    // both). Try macOS form first, fall back to linux.
    let raw = to_string(exec("shasum -a 256 " + p + " 2>/dev/null || sha256sum " + p + " 2>/dev/null")).trim()
    if raw == "" {
        return [false, ""]
    }
    // Output shape: "<64-hex>  <path>" — split on whitespace and
    // take field 1.
    let mut i = 0
    let n = len(raw)
    let mut sha = ""
    while i < n {
        let c = raw.substring(i, i + 1)
        if c == " " || c == "\t" {
            sha = raw.substring(0, i)
            break
        }
        i = i + 1
    }
    if sha == "" { sha = raw }
    if len(sha) != 64 {
        return [false, ""]
    }
    return [true, sha]
}

// ── file_set_executable ──────────────────────────────────────
// chmod `path` to `mode_octal` (string like "0755", "0700").
// Default mode applied when caller passes empty string is "0755".
// Returns [ok, error]. raw 91: post-verifies the new mode via
// stat readback.
pub fn file_set_executable(path: string, mode_octal: string) -> array {
    if !_fa_exists(path) {
        return [false, "missing: " + path]
    }
    let mut m = mode_octal
    if m == "" { m = "0755" }
    let p = shell_escape(path)
    let me = shell_escape(m)
    let rc = _fa_run_quiet("chmod " + me + " " + p)
    if rc != 0 {
        return [false, "chmod rc=" + to_string(rc)]
    }
    let after = _fa_get_mode(path)
    // Normalize: chmod 755 sets 0755; both "755" and "0755" are
    // accepted as equivalent here.
    let mut want_normalized = m
    if len(want_normalized) == 3 { want_normalized = "0" + want_normalized }
    if after != want_normalized {
        return [false, "verify fail: got " + after + " want " + want_normalized]
    }
    return [true, ""]
}

// ── file_atomic_write ────────────────────────────────────────
// Atomically write `content` to `path`. Mid-write readers either
// see the OLD file (or no file, if first-write) or the NEW file —
// never partial bytes. Implementation: write to a temp file in
// the SAME parent directory as `path`, then rename(2) over `path`.
// Same-FS by construction → rename(2) is atomic.
//
// Permissions on the new file: caller's umask applies (typically
// 0644). To preserve a specific mode after write, pair with
// file_set_executable() or file_atomic_replace() (which picks up
// the target's pre-existing mode).
//
// Returns [ok, error].
pub fn file_atomic_write(path: string, content: string) -> array {
    let parent = _fa_dirname(path)
    let base = _fa_basename(path)
    let pid = _fa_pid()
    // Embed the basename so debugging tmp leaks is easy; embed
    // the pid so concurrent writers don't collide.
    let tmp = parent + "/." + base + ".faw." + pid + ".tmp"
    // Write content via runtime builtin (write_file truncates +
    // creates). If the runtime cannot write, fail loud.
    write_file(tmp, content)
    if !_fa_exists(tmp) {
        return [false, "tmp write failed: " + tmp]
    }
    // Best-effort fsync via `sync` to flush kernel buffers before
    // rename. Not strictly required for atomicity (rename itself
    // is atomic) but recommended for crash-durability.
    let _ = exec("sync 2>/dev/null")
    let q_tmp = shell_escape(tmp)
    let q_path = shell_escape(path)
    let rc = _fa_run_quiet("mv -f " + q_tmp + " " + q_path)
    if rc != 0 {
        // Cleanup the orphan temp; surface error.
        let _ = exec("rm -f " + q_tmp + " 2>/dev/null")
        return [false, "mv rc=" + to_string(rc)]
    }
    if !_fa_exists(path) {
        return [false, "post-mv missing: " + path]
    }
    return [true, ""]
}

// ── file_atomic_replace ──────────────────────────────────────
// Atomically replace `target_path` with `source_path`, preserving
// target's pre-existing mode (and owner if running as root).
//
// Sequence:
//   1. stat target → capture original mode.
//   2. mv -f source → target  (rename(2), atomic same-FS).
//   3. chmod <captured_mode> target.
//   4. verify via stat readback.
//
// Caller responsibility: `source_path` must reside on the same
// filesystem as `target_path` (typically: stage source in the
// target's parent dir). On cross-FS, `mv` falls back to copy+rm
// which is NOT atomic — we still return ok=true if the final
// verify passes, but the in-between window is observable. The
// docstring marks this as a known limitation; callers that need
// strict atomicity must stage same-FS.
//
// Owner preservation: rename(2) preserves the inode for same-FS
// renames, so owner/group/xattrs follow automatically. For
// cross-FS (the copy+rm fallback), `mv` adopts the caller's uid,
// which for non-root means owner change. Documented as known
// limitation.
//
// Returns [ok, error].
pub fn file_atomic_replace(target_path: string, source_path: string) -> array {
    if !_fa_exists(source_path) {
        return [false, "source missing: " + source_path]
    }
    // Capture target's original mode — empty string if target is
    // first-time-create. We only re-apply mode when we had one.
    let orig_mode = _fa_get_mode(target_path)
    let q_src = shell_escape(source_path)
    let q_tgt = shell_escape(target_path)
    let rc = _fa_run_quiet("mv -f " + q_src + " " + q_tgt)
    if rc != 0 {
        return [false, "mv rc=" + to_string(rc)]
    }
    if !_fa_exists(target_path) {
        return [false, "post-mv missing: " + target_path]
    }
    // Re-apply mode if we captured one.
    if orig_mode != "" {
        let r = file_set_executable(target_path, orig_mode)
        if !r[0] {
            return [false, "mode reapply: " + to_string(r[1])]
        }
    }
    return [true, ""]
}

// ═════════════════════════════════════════════════════════════
//  --selftest-file-atomic mode
//
//  Comprehensive in-runtime conformance test. Same pattern as
//  self/stdlib/fs.hexa: stage a scratch dir, exercise every
//  exported primitive, emit a single-line sentinel.
//
//  Run with:
//    hexa run self/stdlib/file_atomic.hexa --selftest-file-atomic
//
//  Sentinel:
//    __FILE_ATOMIC_SELFTEST__ <PASS|FAIL> n=<total> fail=<failed>
//
//  This selftest lives in the stdlib file (rather than self/test/)
//  because the current module loader silences `use "self/stdlib/..."`
//  imports from files under self/test/ — see gap #6 in the upstream
//  spec. A thin sentinel-emitting wrapper still lives at
//  self/test/file_{sha256,atomic_write,atomic_replace}.hexa for
//  external verification scripts that grep the sentinel.
// ═════════════════════════════════════════════════════════════

fn _fa_selftest() {
    let pid = _fa_pid()
    let scratch = "/tmp/_hexa_file_atomic_selftest_" + pid
    let _ = exec("rm -rf " + shell_escape(scratch))
    let _ = exec("mkdir -p " + shell_escape(scratch))
    let mut fail = 0
    let mut n = 0

    // ── file_sha256 contract ────────────────────────────────
    let p1 = scratch + "/blob_a.bin"
    let p2 = scratch + "/blob_b.bin"
    let p_missing = scratch + "/never_existed.bin"
    write_file(p1, "the quick brown fox jumps over the lazy dog\n")
    write_file(p2, "DIFFERENT-CONTENT-FOR-COLLISION-CHECK\n")

    // T1: basic shape (64 hex chars).
    n = n + 1
    let s1 = file_sha256(p1)
    if !s1[0] { eprintln("FAIL T1 sha256 not ok"); fail = fail + 1 }
    if len(s1[1]) != 64 { eprintln("FAIL T1 sha256 len != 64"); fail = fail + 1 }

    // T2: stability across 3 calls.
    n = n + 1
    let s1b = file_sha256(p1)
    let s1c = file_sha256(p1)
    if s1b[1] != s1[1] || s1c[1] != s1[1] {
        eprintln("FAIL T2 sha unstable across calls")
        fail = fail + 1
    }

    // T3: matches `shasum -a 256` first column.
    n = n + 1
    let raw = to_string(exec("shasum -a 256 " + shell_escape(p1) + " 2>/dev/null || sha256sum " + shell_escape(p1) + " 2>/dev/null")).trim()
    let parts = raw.split(" ")
    let want = parts[0]
    if s1[1] != want {
        eprintln("FAIL T3 sha mismatch shasum: lib=" + s1[1] + " shell=" + want)
        fail = fail + 1
    }

    // T4: different content -> different digest.
    n = n + 1
    let s2 = file_sha256(p2)
    if s1[1] == s2[1] {
        eprintln("FAIL T4 collision unexpected")
        fail = fail + 1
    }

    // T5: missing path -> ok=false, sha empty.
    n = n + 1
    let sm = file_sha256(p_missing)
    if sm[0] || sm[1] != "" {
        eprintln("FAIL T5 missing returned non-empty")
        fail = fail + 1
    }

    // ── file_atomic_write contract ──────────────────────────
    let cfg = scratch + "/cfg.txt"
    let content_a = "alpha-payload-r1\n"
    let content_b = "beta-payload-r2-longer\n"

    // T6: first write.
    n = n + 1
    let w1 = file_atomic_write(cfg, content_a)
    if !w1[0] {
        eprintln("FAIL T6 first_write: " + to_string(w1[1]))
        fail = fail + 1
    }
    let read_a = read_file(cfg)
    if read_a != content_a {
        eprintln("FAIL T6 content mismatch a")
        fail = fail + 1
    }

    // T7: re-write replaces atomically.
    n = n + 1
    let w2 = file_atomic_write(cfg, content_b)
    if !w2[0] {
        eprintln("FAIL T7 second_write: " + to_string(w2[1]))
        fail = fail + 1
    }
    let read_b = read_file(cfg)
    if read_b != content_b {
        eprintln("FAIL T7 content mismatch b")
        fail = fail + 1
    }

    // T8: no orphan temp files in scratch dir.
    n = n + 1
    let orphans = to_string(exec("ls -1A " + shell_escape(scratch) + " 2>/dev/null | grep '^\\.' | grep '\\.faw\\.' | wc -l")).trim()
    if to_int(orphans) != 0 {
        eprintln("FAIL T8 orphan temps: " + orphans)
        fail = fail + 1
    }

    // ── file_set_executable contract ────────────────────────
    // T9: chmod 0755 default applies.
    n = n + 1
    let exe_target = scratch + "/script"
    write_file(exe_target, "#!/bin/sh\necho hi\n")
    let chr = file_set_executable(exe_target, "")
    if !chr[0] {
        eprintln("FAIL T9 chmod default: " + to_string(chr[1]))
        fail = fail + 1
    }
    let mode_after = _fa_get_mode(exe_target)
    if mode_after != "0755" {
        eprintln("FAIL T9 mode want 0755 got " + mode_after)
        fail = fail + 1
    }

    // T10: chmod 0700 explicit.
    n = n + 1
    let chr2 = file_set_executable(exe_target, "0700")
    if !chr2[0] {
        eprintln("FAIL T10 chmod 0700: " + to_string(chr2[1]))
        fail = fail + 1
    }
    let mode_after2 = _fa_get_mode(exe_target)
    if mode_after2 != "0700" {
        eprintln("FAIL T10 mode want 0700 got " + mode_after2)
        fail = fail + 1
    }

    // ── file_atomic_replace contract ────────────────────────
    // T11: replace preserves mode + sha matches source-pre.
    n = n + 1
    let target = scratch + "/sealed_binary"
    let source = scratch + "/patched_replacement"
    write_file(target, "OLD-PAYLOAD-v1\n")
    let _ = exec("chmod 0755 " + shell_escape(target))
    write_file(source, "NEW-PATCHED-PAYLOAD-v2\n")

    let pre_target = file_sha256(target)
    let pre_source = file_sha256(source)
    if pre_target[1] == pre_source[1] {
        eprintln("FAIL T11 setup: target and source share sha (impossible)")
        fail = fail + 1
    }
    let pre_mode = _fa_get_mode(target)

    let rep = file_atomic_replace(target, source)
    if !rep[0] {
        eprintln("FAIL T11 replace: " + to_string(rep[1]))
        fail = fail + 1
    }
    let post_target = file_sha256(target)
    if post_target[1] != pre_source[1] {
        eprintln("FAIL T11 sha post-replace != source pre-replace")
        fail = fail + 1
    }
    let post_mode = _fa_get_mode(target)
    if post_mode != pre_mode {
        eprintln("FAIL T11 mode drift: pre=" + pre_mode + " post=" + post_mode)
        fail = fail + 1
    }
    // Source must be consumed by rename(2).
    let src_still = to_string(exec("test -e " + shell_escape(source) + " && echo 1 || echo 0")).trim()
    if src_still != "0" {
        eprintln("FAIL T11 source not consumed by rename(2)")
        fail = fail + 1
    }

    // T12: replace into a non-existent target (first-time create).
    n = n + 1
    let target2 = scratch + "/fresh_target"
    let source2 = scratch + "/fresh_source"
    write_file(source2, "fresh-payload\n")
    let rep2 = file_atomic_replace(target2, source2)
    if !rep2[0] {
        eprintln("FAIL T12 fresh create: " + to_string(rep2[1]))
        fail = fail + 1
    }
    let read2 = read_file(target2)
    if read2 != "fresh-payload\n" {
        eprintln("FAIL T12 content mismatch after first-time replace")
        fail = fail + 1
    }

    let _ = exec("rm -rf " + shell_escape(scratch))

    if fail == 0 {
        println("__FILE_ATOMIC_SELFTEST__ PASS n=" + to_string(n) + " fail=0")
    } else {
        println("__FILE_ATOMIC_SELFTEST__ FAIL n=" + to_string(n) + " fail=" + to_string(fail))
    }
}

let _fa_argv = args()
let mut _fa_selftest_flag = false
let mut _fa_ai = 0
while _fa_ai < len(_fa_argv) {
    if _fa_argv[_fa_ai] == "--selftest-file-atomic" { _fa_selftest_flag = true }
    if _fa_argv[_fa_ai] == "--selftest" {
        let mut _fa_aj = 0
        while _fa_aj < len(_fa_argv) {
            if _fa_argv[_fa_aj].ends_with("/stdlib/file_atomic.hexa") { _fa_selftest_flag = true }
            _fa_aj = _fa_aj + 1
        }
    }
    _fa_ai = _fa_ai + 1
}
if _fa_selftest_flag {
    _fa_selftest()
}
