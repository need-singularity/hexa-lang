// raw 137 cmix-ban compliance:
//     A24 v2 = bounded greedy frequency-saving n-gram rule synthesis with
//     integer-only counts, integer-only saving formula, deterministic insertion
//     sort, deterministic greedy rule-budget. NO fp ops. NO neural mixer. NO
//     non-deterministic similarity. Build pass + tokenization + estimator all
//     deterministic (raw 65/68 idempotent: same input → same rule set).
//
// CONCURRENT ORTHOGONALITY (3 concurrent agents in-flight):
//     - A26 v2 bounded (different agent, hxc_a26_v2_bounded.hexa, sigil ^Y).
//     - A19 cross-file dict (different agent, hxc_a19_cross_file_dict.hexa,
//       sigil ^Z).
//     - A25 type-aware (different agent, hxc_a25_type_aware.hexa).
//     This module stays in A24 v2 namespace ONLY. Sigil ^[ reserved post-A19
//     ^Z, post-A24 v1 ^X. Does NOT modify hxc_a24_grammar_induction.hexa
//     (v1 preserved unchanged), hxc_a26_v2_bounded.hexa, hxc_a19_cross_file_dict.hexa,
//     OR hxc_a25_type_aware.hexa.

const A24_V2_MIN_BYTES = 1024              // raise from v1 64 → 1024 (raw 142 D2)
const A24_V2_MAX_INPUT_BYTES = 65536       // hard cap; above this → identity revert
const A24_V2_MIN_FREQ = 4                  // rule promotion threshold (count >= this)
const A24_V2_MAX_RULES = 4096              // memory budget — absolute rule count cap
const A24_V2_RULES_PER_KB = 8              // rules-per-KB heuristic budget
const A24_V2_NGRAM_LENGTHS_COUNT = 2       // we track 2 ngram lengths: 3, 4 (v1 was 6)
const A24_V2_MAX_NGRAMS = 4096             // per-length frequency map cap (v1 was 65536)
const A24_V2_LATENCY_BUDGET_MS = 500       // hard wallclock cap per file (structural)
const A24_V2_RULE_MARKER = 254             // tokenized stream: 254 = follow rule_id
const A24_V2_RULE_ESCAPE = 255             // tokenized stream: 255 = literal next-byte
const A24_V2_ALPHABET = 256
const A24_V2_RAW_BITS_PER_BYTE = 8

// ───────────────── byte / string helpers ─────────────────

fn _byte_at_v2(s: string, i: int) -> string {
    if i < 0 || i >= len(s) { return "" }
    return s.substring(i, i + 1)
}

fn _str_to_bytes_v2(s: string) -> array {
    let mut out = []
    let n = len(s)
    let mut i = 0
    while i < n { out.push(ord(_byte_at_v2(s, i))); i = i + 1 }
    return out
}

// ───────────────── PASS 1: bounded n-gram frequency scan ─────────────────
//
// _scan_ngrams_v2: build {ngram_string → count} for given length L, capped
// at A24_V2_MAX_NGRAMS unique keys. Once cap is reached, NEW keys are
// dropped (existing keys still increment). This bounds K, which in turn
// bounds the O(K²) candidate sort cost. Same forward-sweep pattern as v1
// but with HARD K cap.

fn _scan_ngrams_v2(buf: string, L: int) -> any {
    let n = len(buf)
    let mut tbl = {}
    if n < L { return tbl }
    let limit = n - L
    let mut p = 0
    while p <= limit {
        let s = buf.substring(p, p + L)
        let cur = if map_contains_key(tbl, s) { tbl[s] } else { 0 }
        if cur > 0 || len(map_keys(tbl)) < A24_V2_MAX_NGRAMS {
            tbl[s] = cur + 1
        }
        p = p + 1
    }
    return tbl
}

// a24v2_scan_corpus: PASS 1 — collect bounded n-gram tables for L in {3, 4}.
// Returns array of 2 maps. Drops L={2,5,6,8} from v1 entirely.
fn a24v2_scan_corpus(buf: string) -> array {
    let n3 = _scan_ngrams_v2(buf, 3)
    let n4 = _scan_ngrams_v2(buf, 4)
    return [n3, n4]
}

// ───────────────── PASS 2: rule synthesis (bounded greedy frequency-saving) ─────────────────

// _candidate_saving_v2: bytes saved if we promote ngram to rule.
// Same model as v1: per_use = L - 3 (marker+id is 3 bytes); table_cost
// approximates (L+1)*0.7 for range-coder-amortized rule rhs storage.
// 75% realization haircut on count for first-tick conservatism.
fn _candidate_saving_v2(L: int, count: int) -> int {
    if count < A24_V2_MIN_FREQ { return 0 }
    if L <= 3 { return 0 }
    let per_use = L - 3
    let realized = (count * 3) / 4
    let table_cost = ((L + 1) * 7) / 10
    return realized * per_use - table_cost
}

// _collect_candidates_v2: walk 2 n-gram maps (lengths 3, 4), emit candidate
// array [rhs, count, saving, length] filtered by saving > 0 AND count ≥ MIN_FREQ.
fn _collect_candidates_v2(scans: array) -> array {
    let lengths = [3, 4]
    let mut cands = []
    let mut idx = 0
    while idx < A24_V2_NGRAM_LENGTHS_COUNT {
        let L = lengths[idx]
        let tbl = scans[idx]
        let keys = map_keys(tbl)
        let mut k = 0
        while k < len(keys) {
            let key = keys[k]
            let count = tbl[key]
            let saving = _candidate_saving_v2(L, count)
            if saving > 0 && count >= A24_V2_MIN_FREQ {
                cands.push([key, count, saving, L])
            }
            k = k + 1
        }
        idx = idx + 1
    }
    return cands
}

// _sort_cands_desc_v2: insertion sort by saving descending. Bounded by
// 2 lengths × A24_V2_MAX_NGRAMS = 8192 candidates worst-case before filter;
// after the saving > 0 filter the working set is much smaller.
fn _sort_cands_desc_v2(cands: array) -> array {
    let n = len(cands)
    let mut i = 1
    while i < n {
        let cur = cands[i]
        let mut j = i - 1
        while j >= 0 && cands[j][2] < cur[2] {
            cands[j + 1] = cands[j]
            j = j - 1
        }
        cands[j + 1] = cur
        i = i + 1
    }
    return cands
}

// _select_rules_v2: greedy non-overlapping rule selection. After sort by
// saving descending, scan top candidates, skip duplicates. Bounded by
// max_rules budget.
fn _select_rules_v2(sorted_cands: array, max_rules: int) -> array {
    let mut rules = []
    let mut i = 0
    let n = len(sorted_cands)
    while i < n && len(rules) < max_rules {
        let c = sorted_cands[i]
        let rhs = c[0]
        let mut keep = true
        let mut q = 0
        while q < len(rules) {
            if rules[q][0] == rhs { keep = false; break }
            q = q + 1
        }
        if keep { rules.push([rhs, c[1], c[2], c[3]]) }
        i = i + 1
    }
    return rules
}

// _rule_budget_v2: per-corpus-size budget for rule count. Caps at
// A24_V2_MAX_RULES (4096) but scales as A24_V2_RULES_PER_KB (8) per KB
// of input. Floor of 8 rules.
fn _rule_budget_v2(n: int) -> int {
    let kb = (n + 1023) / 1024
    let mut budget = A24_V2_RULES_PER_KB * kb
    if budget < 8 { budget = 8 }
    if budget > A24_V2_MAX_RULES { budget = A24_V2_MAX_RULES }
    return budget
}

// a24v2_synthesize_rules: PASS 2 — full bounded pipeline corpus → ranked
// rule list. Returns array of [rhs_string, count, saving, length].
fn a24v2_synthesize_rules(buf: string) -> array {
    let n = len(buf)
    if n < A24_V2_MIN_BYTES { return [] }
    if n > A24_V2_MAX_INPUT_BYTES { return [] }
    let scans = a24v2_scan_corpus(buf)
    let cands = _collect_candidates_v2(scans)
    let sorted = _sort_cands_desc_v2(cands)
    let budget = _rule_budget_v2(n)
    return _select_rules_v2(sorted, budget)
}

// a24v2_build: top-level alias for synthesize_rules (consistent v2 naming).
fn a24v2_build(buf: string) -> array {
    return a24v2_synthesize_rules(buf)
}

// ───────────────── PASS 2.5: tokenization (greedy longest-match + literal escape) ─────────────────

fn _build_rule_index_v2(rules: array) -> any {
    let mut index = {}
    let mut i = 0
    while i < len(rules) {
        let rhs = rules[i][0]
        if len(rhs) == 0 { i = i + 1; continue }
        let fb_str = _byte_at_v2(rhs, 0)
        let fb = ord(fb_str)
        let key = to_string(fb)
        let entry = [i, rhs, len(rhs)]
        if !map_contains_key(index, key) {
            index[key] = []
        }
        let mut bucket = index[key]
        bucket.push(entry)
        index[key] = bucket
        i = i + 1
    }
    let bucket_keys = map_keys(index)
    let mut bk = 0
    while bk < len(bucket_keys) {
        let k = bucket_keys[bk]
        let bucket = index[k]
        let bn = len(bucket)
        let mut x = 1
        while x < bn {
            let cur = bucket[x]
            let mut y = x - 1
            while y >= 0 && bucket[y][2] < cur[2] {
                bucket[y + 1] = bucket[y]
                y = y - 1
            }
            bucket[y + 1] = cur
            x = x + 1
        }
        index[k] = bucket
        bk = bk + 1
    }
    return index
}

fn _try_match_rule_v2(buf: string, p: int, index: any) -> array {
    let n = len(buf)
    if p >= n { return [-1, 0] }
    let fb = ord(_byte_at_v2(buf, p))
    let key = to_string(fb)
    if !map_contains_key(index, key) { return [-1, 0] }
    let bucket = index[key]
    let mut i = 0
    while i < len(bucket) {
        let entry = bucket[i]
        let rhs = entry[1]
        let L = entry[2]
        if p + L <= n && buf.substring(p, p + L) == rhs {
            return [entry[0], L]
        }
        i = i + 1
    }
    return [-1, 0]
}

fn _tokenize_v2(buf: string, rules: array) -> array {
    let index = _build_rule_index_v2(rules)
    let n = len(buf)
    let mut out = []
    let mut p = 0
    while p < n {
        let b = ord(_byte_at_v2(buf, p))
        if b == A24_V2_RULE_MARKER || b == A24_V2_RULE_ESCAPE {
            out.push(A24_V2_RULE_ESCAPE)
            out.push(b)
            p = p + 1
            continue
        }
        let m = _try_match_rule_v2(buf, p, index)
        let rule_id = m[0]
        let mlen = m[1]
        if rule_id >= 0 && mlen > 3 {
            out.push(A24_V2_RULE_MARKER)
            let hi = rule_id / 256
            let lo = rule_id - hi * 256
            out.push(hi)
            out.push(lo)
            p = p + mlen
        } else {
            out.push(b)
            p = p + 1
        }
    }
    return out
}

// a24v2_estimate_bytes: PASS 2.5 in-sample estimator. Returns
// post-tokenization byte count (the wire would also range-code it, but
// first-tick estimator stops here). Used by the bits/byte sanity floor
// fixture and the build CLI subcommand.
fn a24v2_estimate_bytes(buf: string, rules: array) -> int {
    if len(rules) == 0 { return len(buf) }
    let tokenized = _tokenize_v2(buf, rules)
    return len(tokenized)
}

fn a24v2_estimate_bits(buf: string, rules: array) -> int {
    let bytes_est = a24v2_estimate_bytes(buf, rules)
    return bytes_est * A24_V2_RAW_BITS_PER_BYTE
}

// a24v2_rule_density: returns (rule-replaced bytes / total bytes) * 100 —
// the fraction of input absorbed by grammar rules.
fn a24v2_rule_density(buf: string, rules: array) -> int {
    let n = len(buf)
    if n == 0 { return 0 }
    if len(rules) == 0 { return 0 }
    let tokenized = _tokenize_v2(buf, rules)
    let mut absorbed = 0
    let mut p = 0
    let nt = len(tokenized)
    while p < nt {
        let b = tokenized[p]
        if b == A24_V2_RULE_MARKER {
            if p + 2 >= nt { break }
            let hi = tokenized[p + 1]
            let lo = tokenized[p + 2]
            let rule_id = hi * 256 + lo
            if rule_id < 0 || rule_id >= len(rules) { break }
            absorbed = absorbed + len(rules[rule_id][0])
            p = p + 3
        } else if b == A24_V2_RULE_ESCAPE {
            p = p + 2
        } else {
            p = p + 1
        }
    }
    return (absorbed * 100) / n
}

// a24v2_encode / a24v2_decode: s2 mode = build-only estimator gated wire.
// Returns identity passthrough (subsequent-tick wire was deferred per first-tick
// honest C3). RETAINED for backward compat: callers that selected s2 stay
// on identity; first-tick winner-eligibility gated by s3 wire below.
fn a24v2_encode(text: string) -> string {
    let n = len(text)
    if n < A24_V2_MIN_BYTES { return text }
    if n > A24_V2_MAX_INPUT_BYTES { return text }
    return text
}

fn a24v2_decode(stream: string) -> string {
    return stream
}

// ═════════════════════════════════════════════════════════════════════════════
// PASS 3.5 — A24 v2 s3 WIRE encode/decode (post-a505ec43 honest C3 resolution)
// ═════════════════════════════════════════════════════════════════════════════
//
// a505ec43 finding: A24 v2 was BUILD-ONLY estimator (encode/decode wire absent).
// Therefore A24 v2 was NOT byte-eq composite winner-eligible (no wire stream
// to compete on with A18 / A25 / A29 wire pool). v3 wire ships the encode/decode
// pair so the dispatcher can route mixed-class files to A24 if the wire output
// beats identity on size.
//
// Wire format (header + base64url-of-payload body, sigil ^[):
//
//   Header line:    `# a24:s3 v=bounded-v3 n=<input_bytes> r=<n_rules>\n`
//   Body line:      `^[<base64url-of-payload>\n`
//
// Payload byte layout:
//   Section 1 — rule dictionary (variable size, ≤ 5×r bytes since L∈{3,4}):
//     For each rule i in [0..r):
//       byte[0]  = L (rule length, 3 or 4)
//       byte[1..L] = rhs raw bytes
//   Section 2 — tokenized stream (output of _tokenize_v2):
//     Bytes ∈ [0..255]. Marker=254 → next 2 bytes = (rule_id_hi, rule_id_lo).
//     Escape=255 → next 1 byte = literal byte ∈ {254,255}.
//
// Decoder reads back: parse header → n, r. b64-decode body. Read r rule entries.
// Stream-decode tokenized section.
//
// raw 142 D2 try-and-revert: a24v2_encode_v3 returns shortest of {wire_v3,
// identity}. If rule dictionary + tokenized + b64 + header overhead exceeds
// raw input bytes, identity wins.
//
// raw 137 cmix-ban: deterministic integer pack/unpack only. No fp ops.
// raw 65/68 idempotent: same input → same wire output (byte-identical).

// ─── b64url codec (interop with A18/A23/A29; NOT shared due to raw 18 self-host) ───

const A24_V2_B64_ALPHA = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-_"

fn _a24v2_b64_enc(bytes: array) -> string {
    let mut out = []
    let n: i64 = len(bytes)
    let mut i: i64 = 0
    while i < n {
        let b0: i64 = bytes[i]
        let b1: i64 = if i + 1 < n { bytes[i + 1] } else { 0 }
        let b2: i64 = if i + 2 < n { bytes[i + 2] } else { 0 }
        let acc: i64 = b0 * 65536 + b1 * 256 + b2
        let c0: i64 = acc / 262144
        let r0: i64 = acc - c0 * 262144
        let c1: i64 = r0 / 4096
        let r1: i64 = r0 - c1 * 4096
        let c2: i64 = r1 / 64
        let c3: i64 = r1 - c2 * 64
        let group: i64 = if i + 3 <= n { 4 } else { (n - i) + 1 }
        let chs = [c0, c1, c2, c3]
        let mut e: i64 = 0
        while e < group { out.push(A24_V2_B64_ALPHA.substring(chs[e], chs[e] + 1)); e = e + 1 }
        i = i + 3
    }
    // 4-char tail = u24 byte count (matches A29/A23 convention)
    let mut nv: i64 = n
    if nv > 16777215 { nv = 16777215 }
    let t0: i64 = nv / 262144
    let r0t: i64 = nv - t0 * 262144
    let t1: i64 = r0t / 4096
    let r1t: i64 = r0t - t1 * 4096
    let t2: i64 = r1t / 64
    let t3: i64 = r1t - t2 * 64
    out.push(A24_V2_B64_ALPHA.substring(t0, t0 + 1))
    out.push(A24_V2_B64_ALPHA.substring(t1, t1 + 1))
    out.push(A24_V2_B64_ALPHA.substring(t2, t2 + 1))
    out.push(A24_V2_B64_ALPHA.substring(t3, t3 + 1))
    return out.join("")
}

fn _a24v2_b64_char_idx(c: string) -> i64 { return A24_V2_B64_ALPHA.index_of(c) }

fn _a24v2_b64_dec(s: string) -> array {
    let total: i64 = len(s)
    if total < 4 { return [] }
    let t0: i64 = _a24v2_b64_char_idx(s.substring(total - 4, total - 3))
    let t1: i64 = _a24v2_b64_char_idx(s.substring(total - 3, total - 2))
    let t2: i64 = _a24v2_b64_char_idx(s.substring(total - 2, total - 1))
    let t3: i64 = _a24v2_b64_char_idx(s.substring(total - 1, total))
    let bcount: i64 = t0 * 262144 + t1 * 4096 + t2 * 64 + t3
    let body_len: i64 = total - 4
    let mut out = []
    let mut i: i64 = 0
    while i < body_len {
        let group: i64 = if i + 4 <= body_len { 4 } else { body_len - i }
        let mut acc: i64 = 0
        let mut j: i64 = 0
        while j < 4 {
            let d: i64 = if j < group { _a24v2_b64_char_idx(s.substring(i + j, i + j + 1)) } else { 0 }
            acc = acc * 64 + d
            j = j + 1
        }
        let by0: i64 = acc / 65536
        let rem: i64 = acc - by0 * 65536
        let by1: i64 = rem / 256
        let by2: i64 = rem - by1 * 256
        let bg: i64 = if group == 4 { 3 } else { group - 1 }
        if bg >= 1 { out.push(by0) }
        if bg >= 2 { out.push(by1) }
        if bg >= 3 { out.push(by2) }
        i = i + 4
    }
    let mut final_out = []
    let mut fi: i64 = 0
    while fi < bcount && fi < len(out) { final_out.push(out[fi]); fi = fi + 1 }
    return final_out
}

// ─── _a24v2_pack_payload: serialize rule dictionary + tokenized stream → byte array ───

fn _a24v2_pack_payload(rules: array, tokenized: array) -> array {
    let mut out = []
    let r: i64 = len(rules)
    // Section 1: rule dictionary. For each rule, write 1 byte L, then L raw rhs bytes.
    let mut i: i64 = 0
    while i < r {
        let rhs = rules[i][0]
        let L: i64 = len(rhs)
        out.push(L)
        let mut q: i64 = 0
        while q < L {
            out.push(ord(_byte_at_v2(rhs, q)))
            q = q + 1
        }
        i = i + 1
    }
    // Section 2: tokenized stream (already byte-array form from _tokenize_v2).
    let nt: i64 = len(tokenized)
    let mut j: i64 = 0
    while j < nt { out.push(tokenized[j]); j = j + 1 }
    return out
}

// ─── _a24v2_unpack_payload: parse dict + stream → reconstructed byte array ───

fn _a24v2_unpack_payload(payload: array, n_rules: i64) -> array {
    let mut p: i64 = 0
    let plen: i64 = len(payload)
    let mut rules_rhs = []
    let mut i: i64 = 0
    while i < n_rules {
        if p >= plen { return [] }
        let L: i64 = payload[p]
        p = p + 1
        if p + L > plen { return [] }
        let mut rhs_bytes = []
        let mut q: i64 = 0
        while q < L {
            rhs_bytes.push(payload[p + q])
            q = q + 1
        }
        rules_rhs.push(rhs_bytes)
        p = p + L
        i = i + 1
    }
    // Section 2: tokenized stream → reconstruct original bytes.
    let mut out = []
    while p < plen {
        let b: i64 = payload[p]
        if b == A24_V2_RULE_MARKER {
            if p + 2 >= plen { return [] }
            let hi: i64 = payload[p + 1]
            let lo: i64 = payload[p + 2]
            let rule_id: i64 = hi * 256 + lo
            if rule_id < 0 || rule_id >= n_rules { return [] }
            let rhs_bytes = rules_rhs[rule_id]
            let rL: i64 = len(rhs_bytes)
            let mut k: i64 = 0
            while k < rL { out.push(rhs_bytes[k]); k = k + 1 }
            p = p + 3
        } else if b == A24_V2_RULE_ESCAPE {
            if p + 1 >= plen { return [] }
            out.push(payload[p + 1])
            p = p + 2
        } else {
            out.push(b)
            p = p + 1
        }
    }
    return out
}

// ─── _a24v2_encode_v3_force: build rules + tokenize + pack → wire string ───

fn _a24v2_encode_v3_force(text: string) -> string {
    let n: i64 = len(text)
    if n >= 7 && text.substring(0, 7) == "# a24:s" { return text }
    let rules = a24v2_synthesize_rules(text)
    let tokenized = _tokenize_v2(text, rules)
    let payload = _a24v2_pack_payload(rules, tokenized)
    let payload_b64 = _a24v2_b64_enc(payload)
    let header = "# a24:s3 v=bounded-v3 n=" + to_string(n) + " r=" + to_string(len(rules))
    let body = "^[" + payload_b64
    return header + "\n" + body + "\n"
}

// a24v2_encode_v3: try-and-revert (raw 142 D2) — return shortest of {wire_v3, identity}.
// Below MIN_BYTES or above MAX_INPUT_BYTES → identity passthrough.
fn a24v2_encode_v3(text: string) -> string {
    let n: i64 = len(text)
    if n < A24_V2_MIN_BYTES { return text }
    if n > A24_V2_MAX_INPUT_BYTES { return text }
    if n >= 7 && text.substring(0, 7) == "# a24:s" { return text }
    let v3 = _a24v2_encode_v3_force(text)
    if len(v3) < n { return v3 }
    return text
}

// _a24v2_decode_v3_to_bytes: byte-array decode (preserves multibyte byte-eq).
// Auto-detects v=bounded-v3 (^[ sigil). Non-A24 input returns []
// (caller treats as identity passthrough).
fn _a24v2_decode_v3_to_bytes(stream: string) -> array {
    let lines = stream.split("\n")
    if len(lines) < 2 { return [] }
    let header = lines[0]
    if len(header) < 7 || header.substring(0, 7) != "# a24:s" { return [] }
    let n_pos: i64 = header.index_of(" n=")
    let r_pos: i64 = header.index_of(" r=")
    if n_pos < 0 || r_pos < 0 { return [] }
    let _n_bytes: i64 = parse_int(header.substring(n_pos + 3, r_pos))
    let n_rules: i64 = parse_int(header.substring(r_pos + 3, len(header)))

    // Find ^[ body line.
    let mut body_b64 = ""
    let mut i = 1
    while i < len(lines) {
        let l = lines[i]
        if len(l) >= 2 && l.substring(0, 2) == "^[" {
            body_b64 = l.substring(2, len(l))
            break
        }
        i = i + 1
    }
    if len(body_b64) == 0 { return [] }
    let payload = _a24v2_b64_dec(body_b64)
    return _a24v2_unpack_payload(payload, n_rules)
}

// a24v2_decode_v3: string-returning round-trip. ASCII-safe path uses chr()
// concat; for multibyte byte-eq verification, callers should use
// _a24v2_decode_v3_to_bytes.
fn a24v2_decode_v3(stream: string) -> string {
    let lines = stream.split("\n")
    if len(lines) < 2 { return stream }
    let header = lines[0]
    if len(header) < 7 || header.substring(0, 7) != "# a24:s" { return stream }
    let bytes = _a24v2_decode_v3_to_bytes(stream)
    if len(bytes) == 0 { return stream }
    let mut parts = []
    let mut i = 0
    while i < len(bytes) {
        parts.push(chr(bytes[i]))
        i = i + 1
    }
    return parts.join("")
}

// ───────────────── selftest (5 fixtures + 3 latency probes + 5 wire) ─────────────────

fn _english_4kb_v2() -> string {
    let phrase = "the quick brown fox jumps over the lazy dog "
    let mut buf = ""
    let mut k = 0
    while k < 96 { buf = buf + phrase; k = k + 1 }
    return buf
}

fn _english_32kb_v2() -> string {
    let phrase = "the quick brown fox jumps over the lazy dog "
    let mut buf = ""
    let mut k = 0
    while k < 768 { buf = buf + phrase; k = k + 1 }
    return buf
}

fn _english_70kb_v2() -> string {
    // ~70KB > A24_V2_MAX_INPUT_BYTES (64KB) — forces identity revert path.
    let phrase = "the quick brown fox jumps over the lazy dog "
    let mut buf = ""
    let mut k = 0
    while k < 1600 { buf = buf + phrase; k = k + 1 }
    return buf
}

fn _selftest_v2() -> int {
    println("# hxc_a24_v2_bounded selftest (FIRST TICK + WIRE — PASS 1+2+2.5+3 + 3 latency probes + PASS 3.5 5 wire round-trip)")
    let mut pass = 0
    let mut fail = 0

    // ─── Fixture 1: byte-eq mixed-JSON below MIN_BYTES (raw 142 D2 try-revert) ───
    //   234 B JSON < A24_V2_MIN_BYTES (1024) → identity passthrough invariant.
    //   Falsifier on fail: F-A24-V2-2 (entire v2 first-tick retracted).
    let json_234 = "{\"ts\":\"2026-04-28T00:00:00Z\",\"event\":\"convergence\",\"value\":1.0,\"saving\":0.97}\n{\"ts\":\"2026-04-28T00:01:00Z\",\"event\":\"convergence\",\"value\":2.0,\"saving\":0.97}\n{\"ts\":\"2026-04-28T00:02:00Z\",\"event\":\"convergence\",\"value\":3.0,\"saving\":0.97}\n"
    let enc1 = a24v2_encode(json_234)
    let dec1 = a24v2_decode(enc1)
    if dec1 == json_234 && len(json_234) == 234 && enc1 == json_234 {
        pass = pass + 1
        println("  PASS: fixture-1 byte-eq mixed-JSON 234 B (raw 142 D2 pre-gate honored — below MIN_BYTES=1024 → identity passthrough)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-1 byte-eq broken (got_len="
                + to_string(len(dec1)) + ", expected 234) → F-A24-V2-2 TRIPPED")
    }

    // ─── Fixture 2: byte-eq Korean multibyte (raw 137 byte-faithful) ───
    //   Korean multibyte string padded to >= 1KB to enter the bounded n-gram path.
    //   Round-trip preserves byte-identical output at the encode/decode boundary.
    //   Falsifier on fail: F-A24-V2-2.
    let kor = "안녕 세계 — 곰파 연결 ω-cycle. 압축 알고리즘 A24 v2 bounded n-gram. 자기-호스트 hexa raw 9. "
    let mut buf_kor = ""
    let mut k2 = 0
    while k2 < 16 { buf_kor = buf_kor + kor; k2 = k2 + 1 }
    let enc2 = a24v2_encode(buf_kor)
    let dec2 = a24v2_decode(enc2)
    let nk = len(buf_kor)
    let mut ok2 = true
    if dec2 != buf_kor { ok2 = false }
    // Verify raw byte equality (multibyte safety)
    let mut q2 = 0
    while ok2 && q2 < nk {
        if ord(_byte_at_v2(dec2, q2)) != ord(_byte_at_v2(buf_kor, q2)) { ok2 = false }
        q2 = q2 + 1
    }
    if ok2 && nk >= A24_V2_MIN_BYTES {
        pass = pass + 1
        println("  PASS: fixture-2 byte-eq Korean multibyte n=" + to_string(nk)
                + " B (raw 137 byte-faithful round-trip)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-2 Korean byte-eq broken nk=" + to_string(nk)
                + " ok=" + (if ok2 { "true" } else { "false" })
                + " → F-A24-V2-2 TRIPPED")
    }

    // ─── Fixture 3: byte-eq large-text 4KB-32KB (forces real bounded path) ───
    //   Inputs above MIN_BYTES and below MAX_INPUT_BYTES → bounded n-gram
    //   scan with K cap and sort cap exercised.
    let buf_4k = _english_4kb_v2()
    let buf_32k = _english_32kb_v2()
    let enc3a = a24v2_encode(buf_4k)
    let dec3a = a24v2_decode(enc3a)
    let enc3b = a24v2_encode(buf_32k)
    let dec3b = a24v2_decode(enc3b)
    if dec3a == buf_4k && dec3b == buf_32k && len(buf_4k) >= 4000 && len(buf_32k) >= 32000 {
        let rules3a = a24v2_synthesize_rules(buf_4k)
        let rules3b = a24v2_synthesize_rules(buf_32k)
        let dens3a = a24v2_rule_density(buf_4k, rules3a)
        let dens3b = a24v2_rule_density(buf_32k, rules3b)
        pass = pass + 1
        println("  PASS: fixture-3 byte-eq large-text 4KB n=" + to_string(len(buf_4k))
                + " (n_rules=" + to_string(len(rules3a)) + ", density=" + to_string(dens3a)
                + "%) + 32KB n=" + to_string(len(buf_32k))
                + " (n_rules=" + to_string(len(rules3b)) + ", density=" + to_string(dens3b)
                + "%) — bounded n-gram path exercised")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-3 large-text byte-eq broken (4k_len=" + to_string(len(dec3a))
                + " 32k_len=" + to_string(len(dec3b)) + ") → F-A24-V2-2 TRIPPED")
    }

    // ─── Fixture 4: PCFG escape unit test (rule-match + literal passthrough) ───
    //   Verify the tokenizer correctly identifies rule matches AND handles
    //   ASCII literal passthrough. Build a tiny rule set with one rule
    //   {"abcd" → rule_id 0} and tokenize "Xabcdabcd" — expect:
    //   [ord('X'), 254, 0, 0, 254, 0, 0]  (literal X, rule emit twice).
    //   This is the dual of v1's tokenization invariant — the rule_marker
    //   path is the saving lever. We avoid testing chr(254/255) escape
    //   directly because hexa string concatenation through chr(b≥128)
    //   triggers UTF-8 expansion (raw 137 byte-faithfulness contract uses
    //   byte arrays, not strings, for high-byte content).
    let mut tiny_rules = []
    tiny_rules.push(["abcd", 2, 1, 4])
    let s_in4 = "Xabcdabcd"
    let tok4 = _tokenize_v2(s_in4, tiny_rules)
    let mut ok4 = true
    // expected: ['X' = 88, 254, 0, 0, 254, 0, 0] = 7 tokens
    if len(tok4) != 7 { ok4 = false }
    if ok4 && (tok4[0] != 88 || tok4[1] != 254 || tok4[2] != 0 || tok4[3] != 0
               || tok4[4] != 254 || tok4[5] != 0 || tok4[6] != 0) { ok4 = false }
    if ok4 {
        pass = pass + 1
        println("  PASS: fixture-4 PCFG escape unit (rule-match emits [254, hi, lo]; literal passes through)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-4 PCFG escape unit broken (tok_len=" + to_string(len(tok4))
                + ") → F-A24-V2-2 TRIPPED")
    }

    // ─── Fixture 5: bits/byte sanity floor on 4KB English ───
    //   Estimator must NOT fabricate sub-1.0 bit/byte on small training
    //   samples (raw 91 honest C3). At 4KB English with bounded {3,4}-gram
    //   rules, expect bits/byte ≥ 1.0.
    let rules5 = a24v2_synthesize_rules(buf_4k)
    let bits5 = a24v2_estimate_bits(buf_4k, rules5)
    let n5 = len(buf_4k)
    let est_bpb_x10 = (bits5 * 10) / n5
    if bits5 >= n5 {
        pass = pass + 1
        println("  PASS: fixture-5 a24v2_estimate_bits=" + to_string(bits5)
                + " over n=" + to_string(n5) + " → " + to_string(est_bpb_x10 / 10)
                + "." + to_string(est_bpb_x10 - (est_bpb_x10 / 10) * 10)
                + " bit/byte (≥ 1.0 sanity floor honored, n_rules="
                + to_string(len(rules5)) + ")")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-5 a24v2_estimate_bits=" + to_string(bits5)
                + " < n=" + to_string(n5)
                + " → estimator fabricates sub-1.0 bit/byte → F-A24-V2-1 SIGNAL")
    }

    // ─── F-A24-V2-LAT-1: ≤500ms wallclock on 1KB English ───
    //   Structural proxy: 1KB input has ≤ 1024 starting positions per
    //   length × 2 lengths = 2048 ngram-insert ops + ≤ A24_V2_MAX_NGRAMS²
    //   sort ops = ≤ 16M total, well within 500ms budget. Verify path
    //   completes and returns bounded rule set (n_rules ≤ rule_budget).
    let phrase = "the quick brown fox jumps over the lazy dog "
    let mut buf_1k = ""
    let mut kk = 0
    while kk < 24 { buf_1k = buf_1k + phrase; kk = kk + 1 }
    // 24 × 44 = 1056 B (just over MIN_BYTES=1024)
    let n_1k = len(buf_1k)
    let rules_1k = a24v2_synthesize_rules(buf_1k)
    let budget_1k = _rule_budget_v2(n_1k)
    if n_1k >= A24_V2_MIN_BYTES && len(rules_1k) <= budget_1k && len(rules_1k) <= A24_V2_MAX_RULES {
        pass = pass + 1
        println("  PASS: F-A24-V2-LAT-1 1KB build completed, n=" + to_string(n_1k)
                + " B, n_rules=" + to_string(len(rules_1k))
                + " ≤ budget " + to_string(budget_1k)
                + " (bounded; v1 measured 1000ms+/KB at this scale)")
    } else {
        fail = fail + 1
        println("  FAIL: F-A24-V2-LAT-1 1KB build budget exceeded n_rules="
                + to_string(len(rules_1k)) + " > " + to_string(budget_1k)
                + " → F-A24-V2-3 TRIPPED")
    }

    // ─── F-A24-V2-LAT-2: ≤2s wallclock on 32KB JSON ───
    //   Structural proxy: 32KB input × 2 lengths × probe ≤ K cap. Verify
    //   completion and bounded n_rules.
    let json_phrase = "{\"ts\":\"2026-04-28T00:00:00Z\",\"event\":\"convergence\",\"value\":1.0,\"saving\":0.97}\n"
    let mut buf_32k_json = ""
    let mut kj = 0
    // 32KB JSON ~= 78 B/line × 420 lines = 32760 B (just over 32KB, well under 64KB cap)
    while kj < 420 { buf_32k_json = buf_32k_json + json_phrase; kj = kj + 1 }
    let n_32k = len(buf_32k_json)
    let rules_32k = a24v2_synthesize_rules(buf_32k_json)
    let budget_32k = _rule_budget_v2(n_32k)
    if n_32k >= 32000 && n_32k <= A24_V2_MAX_INPUT_BYTES && len(rules_32k) <= budget_32k && len(rules_32k) <= A24_V2_MAX_RULES {
        pass = pass + 1
        println("  PASS: F-A24-V2-LAT-2 32KB JSON build completed, n=" + to_string(n_32k)
                + " B, n_rules=" + to_string(len(rules_32k))
                + " ≤ budget " + to_string(budget_32k)
                + " (bounded; v1 measured 30s+ at this scale, 39KB JSON took 40+ seconds)")
    } else {
        fail = fail + 1
        println("  FAIL: F-A24-V2-LAT-2 32KB build budget exceeded n="
                + to_string(n_32k) + " n_rules=" + to_string(len(rules_32k))
                + " → F-A24-V2-3 TRIPPED")
    }

    // ─── F-A24-V2-LAT-3: identity revert above 64KB cap ───
    //   Structural verification that a24v2_encode honors the input-size
    //   hard cap and reverts to identity passthrough above 64KB. Also
    //   verifies a24v2_synthesize_rules returns empty rule set above cap.
    let buf_70k = _english_70kb_v2()
    let n_70k = len(buf_70k)
    let enc_70k = a24v2_encode(buf_70k)
    let rules_70k = a24v2_synthesize_rules(buf_70k)
    if n_70k > A24_V2_MAX_INPUT_BYTES && enc_70k == buf_70k && len(rules_70k) == 0 {
        pass = pass + 1
        println("  PASS: F-A24-V2-LAT-3 70KB > " + to_string(A24_V2_MAX_INPUT_BYTES)
                + " B cap → identity revert (n_rules=0, byte-eq passthrough verified)")
    } else {
        fail = fail + 1
        println("  FAIL: F-A24-V2-LAT-3 hard cap not honored n="
                + to_string(n_70k) + " enc_eq=" + (if enc_70k == buf_70k { "true" } else { "false" })
                + " n_rules=" + to_string(len(rules_70k))
                + " → F-A24-V2-3 TRIPPED")
    }

    // ═════════════════════════════════════════════════════════════════════════
    // PASS 3.5 — A24 v3 WIRE round-trip (5 fixtures)
    // ═════════════════════════════════════════════════════════════════════════

    // ─── F-A24-V3-WIRE-1: byte-eq round-trip 4KB English ───
    //   Force-encode 4KB English (well above MIN_BYTES, well below MAX_INPUT)
    //   via _a24v2_encode_v3_force, decode via _a24v2_decode_v3_to_bytes,
    //   verify byte-identical reconstruction.
    let w1_buf = buf_4k
    let w1_enc = _a24v2_encode_v3_force(w1_buf)
    let w1_dec_bytes = _a24v2_decode_v3_to_bytes(w1_enc)
    let mut w1_ok = true
    let w1_n: i64 = len(w1_buf)
    if len(w1_dec_bytes) != w1_n { w1_ok = false }
    let mut w1_q: i64 = 0
    while w1_ok && w1_q < w1_n {
        if w1_dec_bytes[w1_q] != ord(_byte_at_v2(w1_buf, w1_q)) { w1_ok = false }
        w1_q = w1_q + 1
    }
    let w1_saving = if w1_n > 0 { ((w1_n - len(w1_enc)) * 100) / w1_n } else { 0 }
    if w1_ok {
        pass = pass + 1
        println("  PASS: F-A24-V3-WIRE-1 4KB English byte-eq round-trip n="
                + to_string(w1_n) + " B → wire=" + to_string(len(w1_enc))
                + " B (saving=" + to_string(w1_saving) + "%)")
    } else {
        fail = fail + 1
        println("  FAIL: F-A24-V3-WIRE-1 4KB English byte-eq broken (got_len="
                + to_string(len(w1_dec_bytes)) + " expected " + to_string(w1_n)
                + ") → F-A24-V2-2 TRIPPED")
    }

    // ─── F-A24-V3-WIRE-2: byte-eq round-trip Korean multibyte ───
    //   Multibyte safety: high-byte content (UTF-8 Korean) must round-trip
    //   byte-identical via the byte-array decode path.
    let kor3 = "안녕 세계 — 곰파 연결 ω-cycle. 압축 알고리즘 A24 v2 wire ship. 자기-호스트 hexa raw 9. "
    let mut w2_buf = ""
    let mut w2k = 0
    while w2k < 16 { w2_buf = w2_buf + kor3; w2k = w2k + 1 }
    let w2_n: i64 = len(w2_buf)
    let w2_enc = _a24v2_encode_v3_force(w2_buf)
    let w2_dec_bytes = _a24v2_decode_v3_to_bytes(w2_enc)
    let mut w2_ok = true
    if len(w2_dec_bytes) != w2_n { w2_ok = false }
    let mut w2_q: i64 = 0
    while w2_ok && w2_q < w2_n {
        if w2_dec_bytes[w2_q] != ord(_byte_at_v2(w2_buf, w2_q)) { w2_ok = false }
        w2_q = w2_q + 1
    }
    if w2_ok {
        pass = pass + 1
        println("  PASS: F-A24-V3-WIRE-2 Korean multibyte byte-eq round-trip n="
                + to_string(w2_n) + " B → wire=" + to_string(len(w2_enc))
                + " B (raw 137 byte-faithful)")
    } else {
        fail = fail + 1
        println("  FAIL: F-A24-V3-WIRE-2 Korean multibyte byte-eq broken (got_len="
                + to_string(len(w2_dec_bytes)) + " expected " + to_string(w2_n)
                + ") → F-A24-V2-2 TRIPPED")
    }

    // ─── F-A24-V3-WIRE-3: byte-eq round-trip 32KB JSON ───
    //   Stress the rule dictionary on highly-repetitive JSON input near the
    //   max-input-bytes cap. Verify byte-identical reconstruction.
    let w3_buf = buf_32k_json
    let w3_n: i64 = len(w3_buf)
    let w3_enc = _a24v2_encode_v3_force(w3_buf)
    let w3_dec_bytes = _a24v2_decode_v3_to_bytes(w3_enc)
    let mut w3_ok = true
    if len(w3_dec_bytes) != w3_n { w3_ok = false }
    let mut w3_q: i64 = 0
    while w3_ok && w3_q < w3_n {
        if w3_dec_bytes[w3_q] != ord(_byte_at_v2(w3_buf, w3_q)) { w3_ok = false }
        w3_q = w3_q + 1
    }
    let w3_saving = if w3_n > 0 { ((w3_n - len(w3_enc)) * 100) / w3_n } else { 0 }
    if w3_ok {
        pass = pass + 1
        println("  PASS: F-A24-V3-WIRE-3 32KB JSON byte-eq round-trip n="
                + to_string(w3_n) + " B → wire=" + to_string(len(w3_enc))
                + " B (saving=" + to_string(w3_saving) + "%)")
    } else {
        fail = fail + 1
        println("  FAIL: F-A24-V3-WIRE-3 32KB JSON byte-eq broken (got_len="
                + to_string(len(w3_dec_bytes)) + " expected " + to_string(w3_n)
                + ") → F-A24-V2-2 TRIPPED")
    }

    // ─── F-A24-V3-WIRE-4: try-and-revert under MIN_BYTES → identity ───
    //   raw 142 D2 honored: 234B JSON < MIN_BYTES → a24v2_encode_v3 returns
    //   identity (NOT wire). Decode of pure identity returns input unchanged.
    let w4_input = "{\"ts\":\"2026-04-28T00:00:00Z\",\"event\":\"convergence\",\"value\":1.0,\"saving\":0.97}\n{\"ts\":\"2026-04-28T00:01:00Z\",\"event\":\"convergence\",\"value\":2.0,\"saving\":0.97}\n{\"ts\":\"2026-04-28T00:02:00Z\",\"event\":\"convergence\",\"value\":3.0,\"saving\":0.97}\n"
    let w4_enc = a24v2_encode_v3(w4_input)
    let w4_dec = a24v2_decode_v3(w4_enc)
    if w4_enc == w4_input && w4_dec == w4_input && len(w4_input) == 234 {
        pass = pass + 1
        println("  PASS: F-A24-V3-WIRE-4 234B JSON < MIN_BYTES=1024 → identity (raw 142 D2 try-revert honored)")
    } else {
        fail = fail + 1
        println("  FAIL: F-A24-V3-WIRE-4 try-revert pre-gate broken (enc_eq_in="
                + (if w4_enc == w4_input { "true" } else { "false" })
                + " dec_eq_in=" + (if w4_dec == w4_input { "true" } else { "false" })
                + ") → F-A24-V2-2 TRIPPED")
    }

    // ─── F-A24-V3-WIRE-5: a24v2_encode_v3 returns shortest of {wire, identity} ───
    //   For a worst-case input where the wire dictionary + tokenized stream
    //   would exceed identity, the try-revert clause must select identity.
    //   We synthesize a 1056B input with NO repeating substrings (random-ish
    //   prose) such that the rule dictionary overhead dominates → identity wins.
    //   Validation: a24v2_encode_v3 returns identity-equal-or-shorter; decode
    //   round-trip preserves bytes either way.
    let mut w5_buf = ""
    let mut w5k = 0
    // 56-char unique-ish phrase × 24 = 1344B; high entropy from numerals
    let w5_phrase = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123"
    while w5k < 24 { w5_buf = w5_buf + w5_phrase; w5k = w5k + 1 }
    let w5_n: i64 = len(w5_buf)
    let w5_enc = a24v2_encode_v3(w5_buf)
    let w5_v3 = _a24v2_encode_v3_force(w5_buf)
    // a24v2_encode_v3 returns whichever is shorter
    let w5_expected_shorter: i64 = if len(w5_v3) < w5_n { len(w5_v3) } else { w5_n }
    let mut w5_ok = true
    if len(w5_enc) != w5_expected_shorter { w5_ok = false }
    // Round-trip verification: decode whichever encode picked
    let w5_dec_bytes = _a24v2_decode_v3_to_bytes(w5_enc)
    if len(w5_dec_bytes) > 0 {
        // If wire was picked, decode bytes match input
        let mut w5q: i64 = 0
        while w5_ok && w5q < w5_n {
            if w5_dec_bytes[w5q] != ord(_byte_at_v2(w5_buf, w5q)) { w5_ok = false }
            w5q = w5q + 1
        }
    } else {
        // Identity path: enc == input
        if w5_enc != w5_buf { w5_ok = false }
    }
    if w5_ok {
        pass = pass + 1
        println("  PASS: F-A24-V3-WIRE-5 try-revert shortest wire=" + to_string(len(w5_v3))
                + " vs identity=" + to_string(w5_n) + " → picked "
                + to_string(len(w5_enc)) + " (raw 142 D2 shortest-of selection honored)")
    } else {
        fail = fail + 1
        println("  FAIL: F-A24-V3-WIRE-5 try-revert shortest selection broken (enc_len="
                + to_string(len(w5_enc)) + " v3_len=" + to_string(len(w5_v3))
                + " ident_len=" + to_string(w5_n) + ") → F-A24-V2-2 TRIPPED")
    }

    println("Results: " + to_string(pass) + " PASS / " + to_string(fail) + " FAIL")
    println("__HXC_A24_V2_SELFTEST__ " + (if fail == 0 { "PASS" } else { "FAIL" })
            + " (FIRST TICK + WIRE: PASS 1 bounded n-gram scan {3,4} + PASS 2 a24v2_build with K-cap 4096 + PASS 2.5 in-sample estimator + PASS 3 5-fixture + 3 latency probes + PASS 3.5 5 wire round-trip ^[ s3; LIVE FIRE deferred)")
    if fail == 0 { return 0 }
    return 1
}

// ───────────────── main CLI ─────────────────

fn main() {
    let av = argv()
    let mut has_selftest = false
    let mut has_build = false
    let mut k = 0
    while k < len(av) {
        if av[k] == "--selftest" { has_selftest = true }
        if av[k] == "build" { has_build = true }
        k = k + 1
    }
    if has_selftest { exit(_selftest_v2()) }
    if has_build {
        let mut sub_idx = 0
        let mut q = 0
        while q < len(av) {
            if av[q] == "build" { sub_idx = q; break }
            q = q + 1
        }
        if sub_idx + 1 >= len(av) {
            eprintln("usage: hexa hxc_a24_v2_bounded.hexa build <in>")
            exit(3)
        }
        let txt = read_file(av[sub_idx + 1])
        let rules = a24v2_synthesize_rules(txt)
        let est = a24v2_estimate_bytes(txt, rules)
        let dens = a24v2_rule_density(txt, rules)
        let saving = if len(txt) > 0 { ((len(txt) - est) * 100) / len(txt) } else { 0 }
        println("raw=" + to_string(len(txt)) + " est=" + to_string(est)
                + " saving=" + to_string(saving) + "% n_rules=" + to_string(len(rules))
                + " rule_density=" + to_string(dens) + "%")
        exit(0)
    }
    eprintln("usage: hexa hxc_a24_v2_bounded.hexa [--selftest | build <in>]")
    exit(3)
}
