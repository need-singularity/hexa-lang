#!hexa strict

// @resolver-bypass(reason="darwin-native HXC grammar-induction PCFG pipeline")
// @tool(slug="hxc-a24-grammar-induction", desc="HXC algorithm A24: corpus grammar induction (Stolcke-Omohundro 1994 PCFG-style) — frequent-substring → non-terminal rule synthesis + adaptive order-1 byte-context residual range coder. Phase 12 P2 entry — JSON-heavy class +5..+9pp projected. Pure hexa raw 9 + raw 18 self-host (integer-only, table-driven, no fp ops, no neural mixer per raw 137). FIRST TICK BUILD: PASS 1 (n-gram scan + rule synthesis) + PASS 2 (rule probability + encoder bytecode) + PASS 3 (decoder rule expansion) + PASS 4 (5-fixture selftest). raw 91 honest C3: this tick is the first-tick scope per Phase 12 forward-design ad3f9442 A24 spec; full Stolcke-Omohundro merge/split MDL search (Bayes posterior scoring) deferred to follow-on tick (this tick uses greedy frequency-driven non-terminal promotion, a proven first-pass approximation with deterministic results). Sigil ^X (post-A23 ^V/^W). Header v=grammar-pcfg-v1. raw 137 cmix-ban MAINTAINED: A24 = deterministic context-free-grammar with integer rule tables + range coder, NOT cmix-class neural mixer.")
// @usage(hexa /Users/ghost/core/hexa-lang/self/stdlib/hxc_a24_grammar_induction.hexa --selftest)
// @usage(hexa /Users/ghost/core/hexa-lang/self/stdlib/hxc_a24_grammar_induction.hexa build <in>)
// @usage(hexa /Users/ghost/core/hexa-lang/self/stdlib/hxc_a24_grammar_induction.hexa encode <in> <out>)
// @usage(hexa /Users/ghost/core/hexa-lang/self/stdlib/hxc_a24_grammar_induction.hexa decode <in> <out>)
// @exit_codes(0=ok, 1=selftest-fail, 2=io-error, 3=bad-args, 4=decode-mismatch)
//
// Spec (first tick scope — Stolcke-Omohundro 1994 PCFG induction):
//
//   PASS 1 — corpus scan + n-gram frequency:
//     For each substring length L in {2,3,4,5,6,8}, build frequency map
//     {ngram_string -> count}. Frequencies bounded by A24_MAX_NGRAM_PER_LEN.
//     Filter: count >= A24_MIN_FREQ (default 4) — rule promotion threshold.
//
//   PASS 2 — rule synthesis (greedy Stolcke-Omohundro proxy):
//     Score each candidate by saving = (count - 1) * (length - 1) bytes.
//     Greedy select top A24_MAX_RULES candidates (bounded). Each promoted
//     candidate becomes a non-terminal rule {rule_id -> rhs_bytes}.
//     Note: full Stolcke-Omohundro MDL search uses Bayes posterior over
//     grammar topology (merge/split with prior P(grammar)); first-tick
//     uses greedy frequency-saving proxy (deterministic, raw 137 compliant).
//
//   PASS 3 — probability assignment + encoder:
//     Greedy longest-match tokenization: scan input left-to-right, at each
//     position try rules sorted longest-first; if matched, emit non-terminal
//     marker (byte 254) + rule_id (1-2 bytes); else emit literal byte
//     (escaping 254 with 255).
//     Wire: rule table header + adaptive order-1 byte-context range coder
//     over the tokenized stream (alphabet 256, proven A18/A23 coder).
//     ML probabilities are implicit in the adaptive order-1 statistics
//     learned during encode (the rule ids cluster, raising context probs).
//
//   PASS 4 — decoder (rule expansion + residual reconstruction):
//     Mirror order-1 range decoder → tokenized stream → expand rules
//     (read 254 + rule_id → emit rhs; read 255 → emit literal); restore
//     escape(255) literals; reconstruct original bytes (byte-eq round-trip).
//
// Sigil: `^X<grammar-pcfg-stream>` — single combined line.
// Stream layout:
//     `# a24:s1 v=grammar-pcfg-v1 n=<input_bytes> g=<n_rules>\n^X<base64url-body>\n`
//   where body = b64url(rule_table_bytes ++ separator ++ payload_bytes).
//
// Idempotency contract (raw 65 + 68):
//     - encode(decode(x)) == x for any A24 stream
//     - decode(encode(y)) == y for any byte stream
//     - encode is byte-deterministic (same input → same output, raw 137)
//
// Falsifiers preregistered (raw 71):
//     F-A24-1: A24 saving < 70% on JSON-heavy class with rule-density > 0.5 → reject.
//     F-A24-2: encode/decode round-trip not byte-eq → reject.
//     F-A24-3: encode latency > 500ms/KB on interp budget → reject.
//     F-A24-4: memory > 200MB (rule table budget) → reject.
//     F-A24-5: production-chain post-A18+A23 placement standalone-vs-in-chain
//              delta < 1pp (chain-amortize axis, F-A23-5 mirror) → reject.
//
// raw 137 cmix-ban compliance:
//     A24 = deterministic context-free-grammar induction with integer rule
//     tables + adaptive order-1 byte-context range coder (proven A18/A23
//     lineage). No fp ops, no neural mixer, no non-deterministic similarity.
//     PCFG rule probabilities are integer counts (ML-estimate, deterministic).
//
// raw 91 honest C3 (first tick scope):
//     - PASS 1 n-gram scan IMPLEMENTED.
//     - PASS 2 greedy rule synthesis IMPLEMENTED (full Stolcke-Omohundro
//       MDL Bayes posterior search DEFERRED to follow-on tick; greedy
//       frequency-saving proxy is documented as scope-bounded).
//     - PASS 3 tokenized encoder + adaptive order-1 wire IMPLEMENTED.
//     - PASS 4 decoder + selftest 5 fixtures IMPLEMENTED.
//     - LIVE FIRE on representative corpora = follow-on tick.
//     - The grammar rules ARE the saving-axis lever in this tick: rule
//       density + per-corpus rule hit-rate reported as the in-sample bound.
//
// Author tick: Phase 12 P2 A24 first-tick build, Stolcke-Omohundro PCFG.

const A24_MIN_BYTES = 64               // below this: identity passthrough
const A24_MIN_FREQ = 4                 // rule promotion threshold (count >= this)
const A24_MAX_RULES = 4096             // memory budget — absolute rule count cap
const A24_RULES_PER_KB = 8             // rules-per-KB heuristic budget (saving-axis)
const A24_NGRAM_LENGTHS = 6            // we track 6 ngram lengths: 2,3,4,5,6,8
const A24_MAX_NGRAMS_PER_LEN = 65536   // per-length frequency map cap (memory bound)
const A24_RULE_MARKER = 254            // tokenized stream: 254 = follow rule_id
const A24_RULE_ESCAPE = 255            // tokenized stream: 255 = literal next-byte
const A24_ALPHABET = 256
const A24_RAW_BITS_PER_BYTE = 8
const A24_TOP = 4294967296             // 2^32
const A24_BOT = 16777216               // 2^24
const A24_MAX_FREQ_TOTAL = 16777215    // 2^24 - 1
const A24_RULE_ID_MIN = 0              // rule_id range [0, A24_MAX_RULES)

// Wire base64url alphabet (canonical interop with A16/A17/A18/A23).
const A24_B64_ALPHA = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-_"

// ───────────────── byte / string helpers ─────────────────

fn _byte_at(s: string, i: int) -> string {
    if i < 0 || i >= len(s) { return "" }
    return s.substring(i, i + 1)
}

fn _str_to_bytes(s: string) -> array {
    let mut out = []
    let n = len(s)
    let mut i = 0
    while i < n { out.push(ord(_byte_at(s, i))); i = i + 1 }
    return out
}

fn _bytes_to_str(b: array) -> string {
    let mut parts = []
    let mut i = 0
    while i < len(b) { parts.push(chr(b[i])); i = i + 1 }
    return parts.join("")
}

fn _bytes_eq(a: array, b: array) -> bool {
    if len(a) != len(b) { return false }
    let mut i = 0
    while i < len(a) {
        if a[i] != b[i] { return false }
        i = i + 1
    }
    return true
}

// ───────────────── PASS 1: n-gram frequency scan ─────────────────

// _scan_ngrams: build {ngram_string -> count} for given length L.
// Bounded by A24_MAX_NGRAMS_PER_LEN (no insert when full — FIFO-ish).
fn _scan_ngrams(buf: string, L: int) -> any {
    let n = len(buf)
    let mut tbl = {}
    if n < L { return tbl }
    let limit = n - L
    let mut p = 0
    while p <= limit {
        let s = buf.substring(p, p + L)
        let cur = if map_contains_key(tbl, s) { tbl[s] } else { 0 }
        if cur > 0 || len(map_keys(tbl)) < A24_MAX_NGRAMS_PER_LEN {
            tbl[s] = cur + 1
        }
        p = p + 1
    }
    return tbl
}

// a24_scan_corpus: PASS 1 — collect n-gram tables for L in {2,3,4,5,6,8}.
// Returns array of 6 maps.
fn a24_scan_corpus(buf: string) -> array {
    let n2 = _scan_ngrams(buf, 2)
    let n3 = _scan_ngrams(buf, 3)
    let n4 = _scan_ngrams(buf, 4)
    let n5 = _scan_ngrams(buf, 5)
    let n6 = _scan_ngrams(buf, 6)
    let n8 = _scan_ngrams(buf, 8)
    return [n2, n3, n4, n5, n6, n8]
}

// ───────────────── PASS 2: rule synthesis (greedy Stolcke-Omohundro proxy) ─────────────────

// _candidate_saving: estimated bytes saved if we promote ngram to rule.
// Saving model: each occurrence reduces L bytes to ~3 bytes (marker + rule_id_2bytes).
// Net saving per occurrence = L - 3; total saving = count * (L - 3) - (rule_table_overhead).
// Rule table overhead per rule = 1 (length varint) + L (rhs bytes) ≈ L+1, but the
// rule rhs goes through the range coder and compresses by ~30-50%, so the
// effective table cost is closer to (L+1) * 0.7. We use ((L+1) * 7) / 10 to
// stay deterministic-integer arithmetic per raw 137.
// Greedy non-overlap is approximate — a rule's count may overestimate post-
// tokenization usage if shorter rules absorb same bytes; we apply a 75%
// realization haircut on count for first-tick conservatism (raw 91 honest C3).
fn _candidate_saving(L: int, count: int) -> int {
    if count < A24_MIN_FREQ { return 0 }
    if L <= 3 { return 0 }     // marker+id is 3 bytes; only rules with L > 3 can save
    let per_use = L - 3
    let realized = (count * 3) / 4   // conservative tokenization realization haircut
    let table_cost = ((L + 1) * 7) / 10
    return realized * per_use - table_cost
}

// _collect_candidates: walk all 6 n-gram maps, emit array of [rhs, count, saving]
// sorted by saving descending. Filter: saving > 0 AND count >= A24_MIN_FREQ.
fn _collect_candidates(scans: array) -> array {
    let lengths = [2, 3, 4, 5, 6, 8]
    let mut cands = []
    let mut idx = 0
    while idx < A24_NGRAM_LENGTHS {
        let L = lengths[idx]
        let tbl = scans[idx]
        let keys = map_keys(tbl)
        let mut k = 0
        while k < len(keys) {
            let key = keys[k]
            let count = tbl[key]
            let saving = _candidate_saving(L, count)
            if saving > 0 && count >= A24_MIN_FREQ {
                cands.push([key, count, saving, L])
            }
            k = k + 1
        }
        idx = idx + 1
    }
    return cands
}

// _sort_cands_desc: in-place insertion sort by saving descending. O(n^2) but
// bounded by A24_NGRAM_LENGTHS * A24_MAX_NGRAMS_PER_LEN total candidates;
// after the saving > 0 filter the working set is much smaller.
fn _sort_cands_desc(cands: array) -> array {
    let n = len(cands)
    let mut i = 1
    while i < n {
        let cur = cands[i]
        let mut j = i - 1
        while j >= 0 && cands[j][2] < cur[2] {
            cands[j + 1] = cands[j]
            j = j - 1
        }
        cands[j + 1] = cur
        i = i + 1
    }
    return cands
}

// _select_rules: greedy non-overlapping rule selection. After sorting by saving
// descending, scan top candidates and skip those whose rhs is a substring of an
// already-promoted rule's rhs (de-duplication: longer rules absorb shorter
// frequent overlaps). Bounded by max_rules budget.
fn _select_rules(sorted_cands: array, max_rules: int) -> array {
    let mut rules = []
    let mut i = 0
    let n = len(sorted_cands)
    while i < n && len(rules) < max_rules {
        let c = sorted_cands[i]
        let rhs = c[0]
        let mut keep = true
        // Skip if an already-promoted rule equals this rhs (shouldn't happen post-scan
        // since each ngram length is distinct, but defensive).
        let mut q = 0
        while q < len(rules) {
            if rules[q][0] == rhs { keep = false; break }
            q = q + 1
        }
        if keep { rules.push([rhs, c[1], c[2], c[3]]) }
        i = i + 1
    }
    return rules
}

// _rule_budget: per-corpus-size budget for rule count. Caps at A24_MAX_RULES
// (4096) but scales as A24_RULES_PER_KB (8) per KB of input — prevents
// rule-table overhead exceeding savings on small inputs (raw 142 D2 try-revert
// safety). Floor of 8 rules for sub-KB inputs.
fn _rule_budget(n: int) -> int {
    let kb = (n + 1023) / 1024
    let mut budget = A24_RULES_PER_KB * kb
    if budget < 8 { budget = 8 }
    if budget > A24_MAX_RULES { budget = A24_MAX_RULES }
    return budget
}

// a24_synthesize_rules: PASS 2 — full pipeline corpus → ranked rule list.
// Returns array of [rhs_string, count, saving, length].
fn a24_synthesize_rules(buf: string) -> array {
    let scans = a24_scan_corpus(buf)
    let cands = _collect_candidates(scans)
    let sorted = _sort_cands_desc(cands)
    let budget = _rule_budget(len(buf))
    return _select_rules(sorted, budget)
}

// ───────────────── PASS 3: encoder (greedy longest-match + literal escape) ─────────────────
//
// Tokenized stream alphabet:
//   0..253 = literal byte (passes through if input byte == 254 or 255 we escape)
//   254 = RULE_MARKER, followed by 2 bytes rule_id (high, low)
//   255 = RULE_ESCAPE, followed by 1 byte literal (the literal is 254 or 255)
//
// To keep the decoder simple, when an input byte is 254 or 255 we always emit
// the escape sequence regardless of whether a rule could match.

// _build_rule_index: returns a map {first_byte_int -> array<[rule_id, rhs_string, length]>}
// sorted longest-first within each bucket. Greedy match starts at the first byte.
fn _build_rule_index(rules: array) -> any {
    let mut index = {}
    let mut i = 0
    while i < len(rules) {
        let rhs = rules[i][0]
        if len(rhs) == 0 { i = i + 1; continue }
        let fb_str = _byte_at(rhs, 0)
        let fb = ord(fb_str)
        let key = to_string(fb)
        let entry = [i, rhs, len(rhs)]
        if !map_contains_key(index, key) {
            index[key] = []
        }
        let mut bucket = index[key]
        bucket.push(entry)
        index[key] = bucket
        i = i + 1
    }
    // sort each bucket longest-first (insertion sort over small bucket sizes).
    let bucket_keys = map_keys(index)
    let mut bk = 0
    while bk < len(bucket_keys) {
        let k = bucket_keys[bk]
        let bucket = index[k]
        let bn = len(bucket)
        let mut x = 1
        while x < bn {
            let cur = bucket[x]
            let mut y = x - 1
            while y >= 0 && bucket[y][2] < cur[2] {
                bucket[y + 1] = bucket[y]
                y = y - 1
            }
            bucket[y + 1] = cur
            x = x + 1
        }
        index[k] = bucket
        bk = bk + 1
    }
    return index
}

// _try_match_rule: at position p of buf, return [rule_id, length] of the
// longest matching rule, or [-1, 0] if no match.
fn _try_match_rule(buf: string, p: int, index: any) -> array {
    let n = len(buf)
    if p >= n { return [-1, 0] }
    let fb = ord(_byte_at(buf, p))
    let key = to_string(fb)
    if !map_contains_key(index, key) { return [-1, 0] }
    let bucket = index[key]
    let mut i = 0
    while i < len(bucket) {
        let entry = bucket[i]
        let rhs = entry[1]
        let L = entry[2]
        if p + L <= n && buf.substring(p, p + L) == rhs {
            return [entry[0], L]
        }
        i = i + 1
    }
    return [-1, 0]
}

// _tokenize: walk buf, emit tokenized byte stream per the alphabet rules above.
fn _tokenize(buf: string, rules: array) -> array {
    let index = _build_rule_index(rules)
    let n = len(buf)
    let mut out = []
    let mut p = 0
    while p < n {
        let b = ord(_byte_at(buf, p))
        if b == A24_RULE_MARKER || b == A24_RULE_ESCAPE {
            // literal escape: emit 255 then the byte itself.
            out.push(A24_RULE_ESCAPE)
            out.push(b)
            p = p + 1
            continue
        }
        let m = _try_match_rule(buf, p, index)
        let rule_id = m[0]
        let mlen = m[1]
        if rule_id >= 0 && mlen > 3 {
            // rule emit: 254, hi-byte, lo-byte
            out.push(A24_RULE_MARKER)
            let hi = rule_id / 256
            let lo = rule_id - hi * 256
            out.push(hi)
            out.push(lo)
            p = p + mlen
        } else {
            out.push(b)
            p = p + 1
        }
    }
    return out
}

// _detokenize: inverse of _tokenize. Read tokenized byte stream, produce raw bytes.
fn _detokenize(stream: array, rules: array) -> array {
    let n = len(stream)
    let mut out = []
    let mut p = 0
    while p < n {
        let b = stream[p]
        if b == A24_RULE_MARKER {
            if p + 2 >= n { return [] }
            let hi = stream[p + 1]
            let lo = stream[p + 2]
            let rule_id = hi * 256 + lo
            if rule_id < 0 || rule_id >= len(rules) { return [] }
            let rhs = rules[rule_id][0]
            let rL = len(rhs)
            let mut q = 0
            while q < rL {
                out.push(ord(_byte_at(rhs, q)))
                q = q + 1
            }
            p = p + 3
            continue
        }
        if b == A24_RULE_ESCAPE {
            if p + 1 >= n { return [] }
            out.push(stream[p + 1])
            p = p + 2
            continue
        }
        out.push(b)
        p = p + 1
    }
    return out
}

// ───────────────── adaptive order-1 byte-context range coder (mirrors A18 v2 / A23 v1) ─────────────────

fn _ctx_total(row: array) -> i64 {
    let mut s: i64 = 0
    let mut i = 0
    while i < A24_ALPHABET { s = s + row[i]; i = i + 1 }
    return s
}

fn _ctx_rescale_if_needed(row: array) -> array {
    let s: i64 = _ctx_total(row)
    if s <= A24_MAX_FREQ_TOTAL { return row }
    let mut j = 0
    while j < A24_ALPHABET {
        let v: i64 = row[j] / 2
        row[j] = if v < 1 { 1 } else { v }
        j = j + 1
    }
    return row
}

fn _ctx_cum_from_row(row: array) -> array {
    let mut cum = []
    let mut s: i64 = 0
    let mut i = 0
    while i < A24_ALPHABET { cum.push(s); s = s + row[i]; i = i + 1 }
    cum.push(s)
    return cum
}

fn _build_freq_ctx_table() -> array {
    let mut tables = []
    let mut c = 0
    while c < 257 {
        let mut row = []
        let mut i = 0
        while i < A24_ALPHABET { row.push(1); i = i + 1 }
        tables.push(row)
        c = c + 1
    }
    return tables
}

fn _next_ctx(emitted: i64) -> i64 {
    if emitted >= 0 && emitted < 256 { return emitted }
    return 256
}

fn _range_encode_o1(input: array) -> array {
    let mut tables = _build_freq_ctx_table()
    let mut active: i64 = 256
    let mut low: i64 = 0
    let mut range: i64 = A24_TOP - 1
    let mut out_bytes = []
    let n: i64 = len(input)
    let mut k: i64 = 0
    while k < n {
        let row = tables[active]
        let cum = _ctx_cum_from_row(row)
        let total: i64 = cum[A24_ALPHABET]
        let b: i64 = input[k]
        range = range / total
        low = low + cum[b] * range
        range = range * (cum[b + 1] - cum[b])
        let mut renorm = true
        while renorm {
            let high: i64 = low + range
            let low_top: i64 = low / 16777216
            let high_top: i64 = high / 16777216
            if low_top == high_top {
                out_bytes.push(low_top - (low_top / 256) * 256)
                low = (low - (low_top * 16777216)) * 256
                range = range * 256
                if low < 0 { low = low + A24_TOP * 256 }
            } else if range < A24_BOT {
                range = (16777216 - (low - (low / 16777216) * 16777216)) * 256
                out_bytes.push(low / 16777216 - (low / 16777216 / 256) * 256)
                low = (low - (low / 16777216) * 16777216) * 256
            } else {
                renorm = false
            }
            if low >= A24_TOP {
                let mut idx: i64 = len(out_bytes) - 1
                low = low - A24_TOP
                while idx >= 0 {
                    let v: i64 = out_bytes[idx] + 1
                    if v < 256 { out_bytes[idx] = v; idx = -1 }
                    else { out_bytes[idx] = 0; idx = idx - 1 }
                }
            }
        }
        row[b] = row[b] + 1
        tables[active] = _ctx_rescale_if_needed(row)
        active = _next_ctx(b)
        k = k + 1
    }
    let mut f = 0
    while f < 4 {
        let lt: i64 = low / 16777216
        out_bytes.push(lt - (lt / 256) * 256)
        low = (low - lt * 16777216) * 256
        f = f + 1
    }
    return out_bytes
}

fn _range_decode_o1(payload: array, n_bytes: i64) -> array {
    let mut tables = _build_freq_ctx_table()
    let mut active: i64 = 256
    let mut low: i64 = 0
    let mut range: i64 = A24_TOP - 1
    let mut code: i64 = 0
    let mut p: i64 = 0
    let mut pi = 0
    while pi < 4 {
        let b: i64 = if p < len(payload) { payload[p] } else { 0 }
        code = code * 256 + b
        p = p + 1
        pi = pi + 1
    }
    let mut out = []
    let mut produced: i64 = 0
    while produced < n_bytes {
        let row = tables[active]
        let cum = _ctx_cum_from_row(row)
        let total: i64 = cum[A24_ALPHABET]
        range = range / total
        let target_raw: i64 = (code - low) / range
        let mut tgt: i64 = target_raw
        if tgt >= total { tgt = total - 1 }
        let mut b: i64 = 0
        while b < A24_ALPHABET {
            if cum[b + 1] > tgt { break }
            b = b + 1
        }
        if b >= A24_ALPHABET { b = A24_ALPHABET - 1 }
        out.push(b)
        low = low + cum[b] * range
        range = range * (cum[b + 1] - cum[b])
        let mut renorm = true
        while renorm {
            let high: i64 = low + range
            let low_top: i64 = low / 16777216
            let high_top: i64 = high / 16777216
            if low_top == high_top {
                let nb: i64 = if p < len(payload) { payload[p] } else { 0 }
                code = (code - low_top * 16777216) * 256 + nb
                low = (low - low_top * 16777216) * 256
                range = range * 256
                p = p + 1
            } else if range < A24_BOT {
                let nb: i64 = if p < len(payload) { payload[p] } else { 0 }
                range = (16777216 - (low - (low / 16777216) * 16777216)) * 256
                code = (code - (low / 16777216) * 16777216) * 256 + nb
                low = (low - (low / 16777216) * 16777216) * 256
                p = p + 1
            } else {
                renorm = false
            }
            if low >= A24_TOP { low = low - A24_TOP }
            if code >= A24_TOP * 256 { code = code - A24_TOP * 256 }
        }
        row[b] = row[b] + 1
        tables[active] = _ctx_rescale_if_needed(row)
        active = _next_ctx(b)
        produced = produced + 1
    }
    return out
}

// ───────────────── base64url (byte-array <-> string), parallel A23 ─────────────────

fn _b64_enc_bytes(bytes: array) -> string {
    let mut out = []
    let n: i64 = len(bytes)
    let mut i: i64 = 0
    while i < n {
        let b0: i64 = bytes[i]
        let b1: i64 = if i + 1 < n { bytes[i + 1] } else { 0 }
        let b2: i64 = if i + 2 < n { bytes[i + 2] } else { 0 }
        let acc: i64 = b0 * 65536 + b1 * 256 + b2
        let c0: i64 = acc / 262144
        let r0: i64 = acc - c0 * 262144
        let c1: i64 = r0 / 4096
        let r1: i64 = r0 - c1 * 4096
        let c2: i64 = r1 / 64
        let c3: i64 = r1 - c2 * 64
        let group: i64 = if i + 3 <= n { 4 } else { (n - i) + 1 }
        let chs = [c0, c1, c2, c3]
        let mut e: i64 = 0
        while e < group { out.push(A24_B64_ALPHA.substring(chs[e], chs[e] + 1)); e = e + 1 }
        i = i + 3
    }
    let mut nv: i64 = n
    if nv > 16777215 { nv = 16777215 }
    let t0: i64 = nv / 262144
    let r0t: i64 = nv - t0 * 262144
    let t1: i64 = r0t / 4096
    let r1t: i64 = r0t - t1 * 4096
    let t2: i64 = r1t / 64
    let t3: i64 = r1t - t2 * 64
    out.push(A24_B64_ALPHA.substring(t0, t0 + 1))
    out.push(A24_B64_ALPHA.substring(t1, t1 + 1))
    out.push(A24_B64_ALPHA.substring(t2, t2 + 1))
    out.push(A24_B64_ALPHA.substring(t3, t3 + 1))
    return out.join("")
}

fn _b64_char_idx(c: string) -> i64 { return A24_B64_ALPHA.index_of(c) }

fn _b64_dec_bytes(s: string) -> array {
    let total: i64 = len(s)
    if total < 4 { return [] }
    let t0: i64 = _b64_char_idx(s.substring(total - 4, total - 3))
    let t1: i64 = _b64_char_idx(s.substring(total - 3, total - 2))
    let t2: i64 = _b64_char_idx(s.substring(total - 2, total - 1))
    let t3: i64 = _b64_char_idx(s.substring(total - 1, total))
    let bcount: i64 = t0 * 262144 + t1 * 4096 + t2 * 64 + t3
    let body_len: i64 = total - 4
    let mut out = []
    let mut i: i64 = 0
    while i < body_len {
        let group: i64 = if i + 4 <= body_len { 4 } else { body_len - i }
        let mut acc: i64 = 0
        let mut j: i64 = 0
        while j < 4 {
            let d: i64 = if j < group { _b64_char_idx(s.substring(i + j, i + j + 1)) } else { 0 }
            acc = acc * 64 + d
            j = j + 1
        }
        let by0: i64 = acc / 65536
        let rem: i64 = acc - by0 * 65536
        let by1: i64 = rem / 256
        let by2: i64 = rem - by1 * 256
        let bg: i64 = if group == 4 { 3 } else { group - 1 }
        if bg >= 1 { out.push(by0) }
        if bg >= 2 { out.push(by1) }
        if bg >= 3 { out.push(by2) }
        i = i + 4
    }
    let mut final_out = []
    let mut fi: i64 = 0
    while fi < bcount && fi < len(out) { final_out.push(out[fi]); fi = fi + 1 }
    return final_out
}

// ───────────────── rule table serialization (deterministic, raw 137) ─────────────────
//
// Layout (byte-stream):
//   varint(n_rules)                      // 1-3 bytes
//   per rule (in order, rule_id implicit by position):
//       varint(rhs_length)               // 1-2 bytes
//       rhs_length raw bytes (rhs)

// _emit_varint: little-endian length-prefixed (1 byte if <128, else 2 bytes).
fn _emit_varint(n: int, out: array) -> array {
    if n < 128 {
        out.push(n)
        return out
    }
    if n < 16384 {
        let lo = n - (n / 128) * 128
        out.push(lo + 128)
        out.push(n / 128)
        return out
    }
    // 3-byte form
    let lo = n - (n / 128) * 128
    out.push(lo + 128)
    let mid = (n / 128) - ((n / 128) / 128) * 128
    out.push(mid + 128)
    out.push(n / 16384)
    return out
}

// _read_varint: reads varint starting at p, returns [value, new_p].
fn _read_varint(stream: array, p: int) -> array {
    if p >= len(stream) { return [0, p] }
    let b0 = stream[p]
    if b0 < 128 { return [b0, p + 1] }
    if p + 1 >= len(stream) { return [b0 - 128, p + 1] }
    let b1 = stream[p + 1]
    if b1 < 128 { return [(b0 - 128) + b1 * 128, p + 2] }
    if p + 2 >= len(stream) { return [(b0 - 128) + (b1 - 128) * 128, p + 2] }
    let b2 = stream[p + 2]
    return [(b0 - 128) + (b1 - 128) * 128 + b2 * 16384, p + 3]
}

fn _serialize_rule_table(rules: array) -> array {
    let mut out = []
    let nr = len(rules)
    out = _emit_varint(nr, out)
    let mut i = 0
    while i < nr {
        let rhs = rules[i][0]
        let L = len(rhs)
        out = _emit_varint(L, out)
        let mut k = 0
        while k < L {
            out.push(ord(_byte_at(rhs, k)))
            k = k + 1
        }
        i = i + 1
    }
    return out
}

fn _deserialize_rule_table(stream: array, p_start: int) -> array {
    // Returns [rules_bytes, new_p]. rules_bytes = array of [rhs_byte_array, length].
    // raw 137: byte-faithful (Korean/multibyte safe; chr(b>127) would round-trip
    // through UTF-8 expansion and corrupt bytes; we use raw byte arrays).
    let v0 = _read_varint(stream, p_start)
    let nr = v0[0]
    let mut p = v0[1]
    let mut rules_bytes = []
    let mut i = 0
    while i < nr {
        let v1 = _read_varint(stream, p)
        let L = v1[0]
        p = v1[1]
        let mut bytes = []
        let mut k = 0
        while k < L {
            if p >= len(stream) { return [[], p] }
            bytes.push(stream[p])
            p = p + 1
            k = k + 1
        }
        rules_bytes.push([bytes, L])
        i = i + 1
    }
    return [rules_bytes, p]
}

// ───────────────── encode / decode wire format ─────────────────

// _a24_encode_force: v1 wire — grammar-induced rule table + tokenized stream
// + adaptive order-1 byte-context range coder.
fn _a24_encode_force(text: string) -> string {
    let n: i64 = len(text)
    if n >= 7 && text.substring(0, 7) == "# a24:s" { return text }
    // PASS 1+2: synthesize rules from corpus
    let rules = a24_synthesize_rules(text)
    let n_rules = len(rules)
    // PASS 3: tokenize input
    let tokenized = _tokenize(text, rules)
    // Serialize rule table
    let rule_bytes = _serialize_rule_table(rules)
    // Concatenate rule_table_bytes + payload_bytes (tokenized).
    // We range-code the entire concatenation (rules then payload) so the
    // adaptive coder learns the rule-table byte distribution as warmup.
    let mut combined = []
    let mut i = 0
    while i < len(rule_bytes) { combined.push(rule_bytes[i]); i = i + 1 }
    let mut j = 0
    while j < len(tokenized) { combined.push(tokenized[j]); j = j + 1 }
    let payload_bytes = _range_encode_o1(combined)
    let payload_b64 = _b64_enc_bytes(payload_bytes)
    let header = "# a24:s1 v=grammar-pcfg-v1 n=" + to_string(n) + " g=" + to_string(n_rules)
    let body = "^X" + payload_b64
    return header + "\n" + body + "\n"
}

// a24_encode: try-and-revert raw 142 D2 — return shortest of {a24, identity}.
fn a24_encode(text: string) -> string {
    let n: i64 = len(text)
    if n < A24_MIN_BYTES { return text }
    if n >= 7 && text.substring(0, 7) == "# a24:s" { return text }
    let v1 = _a24_encode_force(text)
    if len(v1) < n { return v1 }
    return text
}

// _a24_decode_to_bytes: reconstruct byte array. Auto-detects v=grammar-pcfg-v1 (^X).
fn _a24_decode_to_bytes(stream: string) -> array {
    let lines = stream.split("\n")
    if len(lines) < 2 { return [] }
    let header = lines[0]
    if len(header) < 7 || header.substring(0, 7) != "# a24:s" { return [] }
    let n_pos: i64 = header.index_of(" n=")
    if n_pos < 0 { return [] }
    let g_pos: i64 = header.index_of(" g=")
    let n_end: i64 = if g_pos > n_pos { g_pos } else { len(header) }
    let n_bytes: i64 = parse_int(header.substring(n_pos + 3, n_end))
    let mut body_b64 = ""
    let mut i = 1
    while i < len(lines) {
        let l = lines[i]
        if len(l) >= 2 && l.substring(0, 2) == "^X" {
            body_b64 = l.substring(2, len(l))
            break
        }
        i = i + 1
    }
    if len(body_b64) == 0 { return [] }
    let payload_bytes = _b64_dec_bytes(body_b64)
    // We need to know the total byte count of (rule_table + tokenized) to pass
    // to _range_decode_o1. The tokenized length is variable; we recover it by
    // reading up to a generous upper bound and stopping at the final tokenized
    // stream length implied by reconstructing rule table + walking tokens.
    //
    // Strategy: the wire stores _range_encode_o1(rule_bytes ++ tokenized).
    // The decoder needs to know the total length. We re-encode the same rule
    // table structure: read rule_table from the decoded byte stream, then
    // continue decoding tokenized bytes until we've reconstructed n_bytes
    // raw bytes via _detokenize.
    //
    // Implementation: decode bytes one at a time (impractical for streaming).
    // Easier: decode max possible length; reconstruct rule table; detokenize
    // until n_bytes raw produced; trim. Since range coder needs n_bytes input
    // upfront, we estimate upper bound = original_n + rule_table_overhead.
    //
    // Upper bound estimate: tokenized length ≤ raw n_bytes (each rule
    // replacement reduces length). Rule-table size ≤ A24_MAX_RULES * ~10 bytes.
    // Conservative upper bound = n_bytes + 65536.
    let upper = n_bytes + 65536
    let combined = _range_decode_o1(payload_bytes, upper)
    // Read rule table from combined (byte-faithful — array of [byte_array, length]).
    let unpack = _deserialize_rule_table(combined, 0)
    let rules_bytes = unpack[0]
    let p_after_rules = unpack[1]
    // The tokenized stream starts at p_after_rules. We detokenize until we
    // have n_bytes raw output. We walk the tokenized portion explicitly so
    // we can stop precisely.
    let mut out = []
    let mut p = p_after_rules
    while p < len(combined) && len(out) < n_bytes {
        let b = combined[p]
        if b == A24_RULE_MARKER {
            if p + 2 >= len(combined) { return [] }
            let hi = combined[p + 1]
            let lo = combined[p + 2]
            let rule_id = hi * 256 + lo
            if rule_id < 0 || rule_id >= len(rules_bytes) { return [] }
            let rhs_pair = rules_bytes[rule_id]
            let rhs_arr = rhs_pair[0]
            let rL = rhs_pair[1]
            let mut q = 0
            while q < rL && len(out) < n_bytes {
                out.push(rhs_arr[q])
                q = q + 1
            }
            p = p + 3
            continue
        }
        if b == A24_RULE_ESCAPE {
            if p + 1 >= len(combined) { return [] }
            if len(out) < n_bytes { out.push(combined[p + 1]) }
            p = p + 2
            continue
        }
        out.push(b)
        p = p + 1
    }
    return out
}

fn a24_decode(stream: string) -> string {
    let lines = stream.split("\n")
    if len(lines) < 2 { return stream }
    let header = lines[0]
    if len(header) < 7 || header.substring(0, 7) != "# a24:s" { return stream }
    let bytes = _a24_decode_to_bytes(stream)
    if len(bytes) == 0 { return stream }
    return _bytes_to_str(bytes)
}

// ───────────────── in-sample bits estimator + rule-density measurement ─────────────────

fn _ilog2_ceil(x: int) -> int {
    if x <= 1 { return 0 }
    let mut b = 0
    let mut v = x - 1
    while v > 0 { b = b + 1; v = v / 2 }
    return b
}

// a24_estimate_bytes: in-sample lower-bound estimate. For each rule applied,
// ~3 bytes replace L bytes; for each literal, 8 bits. This is the
// pre-range-coder budget; the actual range coder shaves additional bits via
// adaptive context probabilities.
fn a24_estimate_bytes(buf: string, rules: array) -> int {
    let tokenized = _tokenize(buf, rules)
    return len(tokenized)
}

// a24_rule_density: returns (rule-replaced bytes / total bytes) * 100 — the
// fraction of input absorbed by grammar rules. Reports SAVING-LEVER strength.
fn a24_rule_density(buf: string, rules: array) -> int {
    let n = len(buf)
    if n == 0 { return 0 }
    let tokenized = _tokenize(buf, rules)
    // Each rule emit = 3 tokens (marker + 2 id bytes); each escape = 2 tokens.
    // Compute absorbed bytes = sum over rule emits of (rule_length).
    let mut absorbed = 0
    let mut p = 0
    let nt = len(tokenized)
    while p < nt {
        let b = tokenized[p]
        if b == A24_RULE_MARKER {
            if p + 2 >= nt { break }
            let hi = tokenized[p + 1]
            let lo = tokenized[p + 2]
            let rule_id = hi * 256 + lo
            if rule_id < 0 || rule_id >= len(rules) { break }
            absorbed = absorbed + len(rules[rule_id][0])
            p = p + 3
        } else if b == A24_RULE_ESCAPE {
            p = p + 2
        } else {
            p = p + 1
        }
    }
    return (absorbed * 100) / n
}

// ───────────────── selftest (5 fixtures, raw 91 honest C3 first-tick scope) ─────────────────

fn _selftest() -> int {
    println("# hxc_a24_grammar_induction selftest (FIRST TICK BUILD — PASS 1+2+3+4 + 5 fixtures)")
    let mut pass = 0
    let mut fail = 0

    // Fixture 1 (mixed-JSON, text-heavy with byte-transition skew).
    let json_phrase = "{\"ts\":\"2026-04-28T00:00:00Z\",\"event\":\"convergence\",\"value\":1.0,\"saving\":0.97}\n"
    let mut buf_json = ""
    let mut k1 = 0
    while k1 < 6 { buf_json = buf_json + json_phrase; k1 = k1 + 1 }
    let enc1 = _a24_encode_force(buf_json)
    let dec1 = a24_decode(enc1)
    if dec1 == buf_json {
        let s1 = ((len(buf_json) - len(enc1)) * 100) / len(buf_json)
        let rules1 = a24_synthesize_rules(buf_json)
        let dens1 = a24_rule_density(buf_json, rules1)
        pass = pass + 1
        println("  PASS: fixture-1 mixed-JSON byte-eq " + to_string(len(buf_json))
                + " -> " + to_string(len(enc1)) + " (" + to_string(s1)
                + "% saving, n_rules=" + to_string(len(rules1))
                + ", rule_density=" + to_string(dens1) + "%)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-1 mixed-JSON round-trip lost orig_len=" + to_string(len(buf_json))
                + " got_len=" + to_string(len(dec1)))
    }

    // Fixture 2 (Korean / multibyte UTF-8 byte-array round-trip).
    let kor = "안녕 세계 — 곰파 연결 ω-cycle. 압축 알고리즘 A24 자기-호스트 hexa raw 9. "
    let mut buf_kor = ""
    let mut k2 = 0
    while k2 < 12 { buf_kor = buf_kor + kor; k2 = k2 + 1 }
    let enc2 = _a24_encode_force(buf_kor)
    let dec2_bytes = _a24_decode_to_bytes(enc2)
    let mut ok2 = true
    let nk: i64 = len(buf_kor)
    if len(dec2_bytes) != nk { ok2 = false }
    let mut q2: i64 = 0
    while ok2 && q2 < nk {
        if dec2_bytes[q2] != ord(_byte_at(buf_kor, q2)) { ok2 = false }
        q2 = q2 + 1
    }
    if ok2 {
        let s2: i64 = ((nk - len(enc2)) * 100) / nk
        let rules2 = a24_synthesize_rules(buf_kor)
        let dens2 = a24_rule_density(buf_kor, rules2)
        pass = pass + 1
        println("  PASS: fixture-2 Korean multibyte byte-array byte-eq "
                + to_string(nk) + " -> " + to_string(len(enc2))
                + " (" + to_string(s2) + "% saving, n_rules=" + to_string(len(rules2))
                + ", rule_density=" + to_string(dens2) + "%)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-2 Korean byte-array round-trip lost orig_len=" + to_string(nk)
                + " got_len=" + to_string(len(dec2_bytes)))
    }

    // Fixture 3 (ledger/audit JSONL — rule-density saving-axis).
    let audit_phrase = "{\"event\":\"witness\",\"phase\":\"12-P2\",\"algo\":\"A24\",\"saving_pct\":75,\"raw_91_c3\":\"first-tick\",\"ts\":\"2026-04-28\"}\n"
    let mut buf_audit = ""
    let mut k3 = 0
    while k3 < 8 { buf_audit = buf_audit + audit_phrase; k3 = k3 + 1 }
    let enc3 = _a24_encode_force(buf_audit)
    let dec3 = a24_decode(enc3)
    if dec3 == buf_audit {
        let s3 = ((len(buf_audit) - len(enc3)) * 100) / len(buf_audit)
        let rules3 = a24_synthesize_rules(buf_audit)
        let dens3 = a24_rule_density(buf_audit, rules3)
        pass = pass + 1
        println("  PASS: fixture-3 ledger/audit byte-eq " + to_string(len(buf_audit))
                + " -> " + to_string(len(enc3)) + " (" + to_string(s3)
                + "% saving, n_rules=" + to_string(len(rules3))
                + ", rule_density=" + to_string(dens3) + "%)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-3 ledger/audit round-trip lost orig_len=" + to_string(len(buf_audit))
                + " got_len=" + to_string(len(dec3)))
    }

    // Fixture 4 (large-text English repetition for grammar-rule effect).
    let phrase = "the quick brown fox jumps over the lazy dog "
    let mut buf_eng = ""
    let mut k4 = 0
    while k4 < 30 { buf_eng = buf_eng + phrase; k4 = k4 + 1 }
    let enc4 = _a24_encode_force(buf_eng)
    let dec4 = a24_decode(enc4)
    if dec4 == buf_eng {
        let s4 = ((len(buf_eng) - len(enc4)) * 100) / len(buf_eng)
        let rules4 = a24_synthesize_rules(buf_eng)
        let dens4 = a24_rule_density(buf_eng, rules4)
        pass = pass + 1
        println("  PASS: fixture-4 large-text byte-eq " + to_string(len(buf_eng))
                + " -> " + to_string(len(enc4)) + " (" + to_string(s4)
                + "% wire-saving, n_rules=" + to_string(len(rules4))
                + ", rule_density=" + to_string(dens4) + "%)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-4 large-text round-trip lost orig_len=" + to_string(len(buf_eng))
                + " got_len=" + to_string(len(dec4)))
    }

    // Fixture 5 (passthrough idempotent — raw 65 + 68).
    let tiny = "abc123"
    let enc5 = a24_encode(tiny)
    let enc5b = a24_encode(enc5)
    if enc5 == tiny && enc5b == tiny {
        pass = pass + 1
        println("  PASS: fixture-5 short-input passthrough idempotent (raw 65 + 68)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-5 short-input idempotency broken")
    }

    println("Results: " + to_string(pass) + " PASS / " + to_string(fail) + " FAIL")
    println("__HXC_A24_SELFTEST__ " + (if fail == 0 { "PASS" } else { "FAIL" })
            + " (FIRST TICK: PASS 1 ngram + PASS 2 rule synthesis + PASS 3 tokenize+wire + PASS 4 decoder + 5 fixtures byte-eq)")
    if fail == 0 { return 0 }
    return 1
}

// ───────────────── main CLI ─────────────────

fn main() {
    let av = argv()
    let mut has_selftest = false
    let mut has_build = false
    let mut has_encode = false
    let mut has_decode = false
    let mut has_force = false
    let mut k = 0
    while k < len(av) {
        if av[k] == "--selftest" { has_selftest = true }
        if av[k] == "build" { has_build = true }
        if av[k] == "encode" { has_encode = true }
        if av[k] == "decode" { has_decode = true }
        if av[k] == "--force" { has_force = true }
        k = k + 1
    }
    if has_selftest { exit(_selftest()) }
    if has_build {
        let mut sub_idx = 0
        let mut q = 0
        while q < len(av) {
            if av[q] == "build" { sub_idx = q; break }
            q = q + 1
        }
        if sub_idx + 1 >= len(av) {
            eprintln("usage: hexa hxc_a24_grammar_induction.hexa build <in>")
            exit(3)
        }
        let txt = read_file(av[sub_idx + 1])
        let rules = a24_synthesize_rules(txt)
        let est = a24_estimate_bytes(txt, rules)
        let dens = a24_rule_density(txt, rules)
        let saving = if len(txt) > 0 { ((len(txt) - est) * 100) / len(txt) } else { 0 }
        println("raw=" + to_string(len(txt)) + " est=" + to_string(est)
                + " saving=" + to_string(saving) + "% n_rules=" + to_string(len(rules))
                + " rule_density=" + to_string(dens) + "%")
        exit(0)
    }
    if has_encode || has_decode {
        let mut sub_idx = 0
        let mut q = 0
        while q < len(av) {
            if av[q] == "encode" || av[q] == "decode" { sub_idx = q; break }
            q = q + 1
        }
        let mut paths = []
        let mut q2 = sub_idx + 1
        while q2 < len(av) {
            let a = av[q2]
            if len(a) >= 2 && a.substring(0, 2) == "--" { q2 = q2 + 1; continue }
            paths.push(a)
            q2 = q2 + 1
        }
        if len(paths) < 2 {
            eprintln("usage: hexa hxc_a24_grammar_induction.hexa <encode|decode> [--force] <in> <out>")
            exit(3)
        }
        let in_path = paths[0]
        let out_path = paths[1]
        if has_encode {
            let txt = read_file(in_path)
            let res = if has_force { _a24_encode_force(txt) } else { a24_encode(txt) }
            let _w = write_file(out_path, res)
            let saving = if len(txt) > 0 { ((len(txt) - len(res)) * 100) / len(txt) } else { 0 }
            println("a24 encode raw=" + to_string(len(txt)) + " enc=" + to_string(len(res))
                    + " saving=" + to_string(saving) + "%")
            exit(0)
        }
        let txt = read_file(in_path)
        let bytes = _a24_decode_to_bytes(txt)
        if len(bytes) == 0 {
            let _w = write_file(out_path, txt)
        } else {
            let _w = write_bytes(out_path, bytes)
        }
        exit(0)
    }
    eprintln("usage: hexa hxc_a24_grammar_induction.hexa [--selftest | build <in> | encode [--force] <in> <out> | decode <in> <out>]")
    exit(3)
}
