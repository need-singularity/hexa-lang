// self/stdlib/os.hexa — OS environment helpers for hexa.
//
// Resolves part of hive blocker `goal_hexa_native_fs_stdlib`.
// Provides node:os and process.env equivalents needed by
// `scripts/install-extensions.mjs` (homedir, getenv) and the rest
// of the hive .mjs surface. Pure hexa (raw 9 hexa-only): single
// exec() fallback for $HOME / `id -u -n`.
//
// raw 91 (no_silent_errors):
//   getenv() returns "" on missing instead of throwing — caller
//   distinguishes via `=="" && !env_has(name)`. homedir() falls
//   back to `/Users/<id -un>` (Mac) or `/home/<id -un>` (Linux)
//   if $HOME is unset, and ultimately to "/" with a stderr warn.
//
// raw 159 (hexa-lang-upstream-proposal-mandate):
//   This module is the upstream-of-truth for hive's os ops. hive
//   ports `use "self/stdlib/os"` and never re-implements these.
//
// --selftest mode:
//   hexa run self/stdlib/os.hexa --selftest
//     → emits __OS_SELFTEST__ <PASS|FAIL> n=<N> fail=<M>
//
// Exports:
//   os_homedir() -> string         // node:os.homedir
//   os_getenv(name: string) -> string  // node process.env[name] || ""

// ── os_getenv ───────────────────────────────────────────────
// Returns the value of env var `name`, or "" if unset.
// Implementation note: the hexa runtime exposes `env_var(name)` and
// `getenv(name)`; both return "" on missing. We name our wrapper
// `os_getenv` to avoid confusion with the runtime builtin and to
// match the os.* namespace convention.
fn os_getenv(name) {
    let s = to_string(name)
    if len(s) == 0 { return "" }
    // Prefer the runtime builtin (constant time, no fork).
    let v = env_var(s)
    return to_string(v)
}

// ── os_homedir ──────────────────────────────────────────────
// Returns the user's home directory. Mirrors node:os.homedir.
// Order of resolution (matches Node):
//   1. $HOME if set.
//   2. /Users/<username> on Darwin or /home/<username> on Linux.
//   3. "/" as a last-resort + stderr warn.
fn os_homedir() {
    let h = os_getenv("HOME")
    if len(h) > 0 { return h }
    // Fall back: derive from username + uname.
    let user = to_string(exec("id -u -n 2>/dev/null")).trim()
    if len(user) == 0 {
        eprintln("os_homedir: $HOME unset and `id -u -n` failed; returning /")
        return "/"
    }
    let kernel = to_string(exec("uname -s 2>/dev/null")).trim()
    if kernel == "Darwin" {
        return "/Users/" + user
    }
    return "/home/" + user
}

// ── --selftest ──────────────────────────────────────────────
fn _os_selftest() {
    let mut fail = 0
    let mut n = 0

    // 1. os_homedir is non-empty and absolute
    n = n + 1
    let home = os_homedir()
    if len(home) == 0 || home.substring(0, 1) != "/" {
        eprintln("FAIL 1 os_homedir not absolute: " + home)
        fail = fail + 1
    }

    // 2. os_getenv on a known var ($PATH always set under sh)
    n = n + 1
    let path_var = os_getenv("PATH")
    if len(path_var) == 0 {
        eprintln("FAIL 2 os_getenv(PATH) empty")
        fail = fail + 1
    }

    // 3. os_getenv on an unset var
    n = n + 1
    let bogus = os_getenv("__HEXA_OS_BOGUS_VAR_DOES_NOT_EXIST_XYZ__")
    if len(bogus) != 0 {
        eprintln("FAIL 3 os_getenv(bogus) should be empty: " + bogus)
        fail = fail + 1
    }

    // 4. os_getenv on empty name -> ""
    n = n + 1
    let empty_name = os_getenv("")
    if len(empty_name) != 0 {
        eprintln("FAIL 4 os_getenv('') should be empty: " + empty_name)
        fail = fail + 1
    }

    if fail == 0 {
        println("__OS_SELFTEST__ PASS n=" + to_string(n) + " fail=0")
    } else {
        println("__OS_SELFTEST__ FAIL n=" + to_string(n) + " fail=" + to_string(fail))
    }
}

let _os_argv = args()
let mut _os_selftest_flag = false
let mut _os_ai = 0
while _os_ai < len(_os_argv) {
    if _os_argv[_os_ai] == "--selftest-os" { _os_selftest_flag = true }
    if _os_argv[_os_ai] == "--selftest" { _os_selftest_flag = true }
    _os_ai = _os_ai + 1
}
if _os_selftest_flag {
    _os_selftest()
}
