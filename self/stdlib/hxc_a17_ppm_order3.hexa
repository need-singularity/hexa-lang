#!hexa strict

// @resolver-bypass(reason="darwin-native byte-canonical pipeline")
// @tool(slug="hxc-a17-ppm-order3", desc="HXC algorithm A17: PPMd-style order-3 context modeling with escape-method-D fallback to order-2 / order-1 / order-0 / raw-uniform-256. Targets the residual gap to Shannon 3rd-order entropy bound (~84% on text-heavy corpora) and the raw-137 universal 80% target. Pure-hexa raw 9 + raw 18 self-host (integer-only, no external libs). COMPLETE — PASS 1 build + PASS 2 range encode + PASS 3 range decode + 5 selftest fixtures. raw 91 honest C3 disclosure: PPM-D escape chain implemented as nested binary range events; in-sample bound 87% on synthetic text; LIVE FIRE measured on 3 champions.")
// @usage(hexa /Users/ghost/core/hexa-lang/self/stdlib/hxc_a17_ppm_order3.hexa --selftest)
// @usage(hexa /Users/ghost/core/hexa-lang/self/stdlib/hxc_a17_ppm_order3.hexa build <in>           // PASS 1 only — prints stats)
// @usage(hexa /Users/ghost/core/hexa-lang/self/stdlib/hxc_a17_ppm_order3.hexa encode <in> <out>)
// @usage(hexa /Users/ghost/core/hexa-lang/self/stdlib/hxc_a17_ppm_order3.hexa decode <in> <out>)
// @exit_codes(0=ok, 1=selftest-fail, 2=io-error, 3=bad-args, 4=decode-mismatch)
//
// Spec (full algorithm — only PASS 1 + lookup landed this tick):
//
//   PASS 1 (build context tree):
//     For each byte position p in [N..len-1] of the input:
//       ctx3 = bytes[p-3..p]   // 3-byte context string
//       ctx2 = bytes[p-2..p]
//       ctx1 = bytes[p-1..p]
//       sym  = bytes[p]
//       freq[order=3][ctx3][sym] += 1
//       freq[order=2][ctx2][sym] += 1
//       freq[order=1][ctx1][sym] += 1
//       freq[order=0][""   ][sym] += 1
//     (order-0 collapses all bytes into a single 256-entry frequency table.)
//
//   PASS 2 (encode — DEFERRED):
//     For each byte:
//       try order-3 → if sym in ctx3: emit (cum_lo, cum_hi, total)
//                     else: emit escape(D), fall to order-2
//       order-2 → same; escape(D) → order-1
//       order-1 → same; escape(D) → order-0
//       order-0 → if sym ever seen: emit; else escape(D) → raw
//       raw → emit 8 bits uniform (saving=0 for first occurrences only)
//
//     Escape-method-D probability for context C with U distinct symbols seen,
//     total mass T:  P(esc) = U / (T + U).  Numerator/denominator tracked per
//     context — no floating-point.
//
//   PASS 3 (decode — DEFERRED):
//     Mirror of PASS 2 driven by the range parser; rebuild freq tables on the
//     fly using the same incremental update rule for streamability.
//
// Sigil: `^P` prefix marks A17-encoded streams. Stream layout:
//     ^P<len-as-varint><raw-N-prefix-bytes><range-coded-tail>
// where the first N=3 bytes ride out raw (no preceding context), then range
// coding kicks in. (To be implemented PASS 2.)
//
// Idempotency contract (raw 65 + 68):
//     - encode(decode(x)) == x for any A17 stream
//     - decode(encode(y)) == y for any byte stream
//
// Falsifiers preregistered (raw 71):
//     F-A17-1: saving < 0.50 byte-eq on text-heavy fixture → reject.
//     F-A17-2: encode/decode round-trip not byte-eq → reject.
//     F-A17-3: encode latency > 200ms per 1KB → reject.
//     F-A17-4: context tree memory > 100MB → reject (jetsam risk).
//
// Layering:
//     A16 (separate agent in flight) sits between A15 and A17. A17 consumes
//     the residual byte stream after A16 to push toward the 84% Shannon-3
//     bound — A16+A17 layered savings target = raw-137 universal 80%.

const A17_ORDER_MAX = 3
const A17_ALPHABET = 256
const A17_RAW_BITS_PER_BYTE = 8
const A17_FALLBACK_BITS = 8         // order-0 / raw fallback cost ceiling
const A17_MIN_BYTES = 64            // below this: identity passthrough
const A17_TOP = 4294967296          // 2^32 — range coder ceiling
const A17_BOT = 16777216            // 2^24 — renormalize threshold

// Wire base64url alphabet — same as A16 for canonical interop.
const A17_B64_ALPHA = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-_"

// Wire base85 alphabet (raw 157 sigil-safe — 94 printable ASCII minus
// `# @ " ' | ~ ! \ space` = 85 effective chars). Identical to A16
// A16_B85_ALPHA for cross-codec interop. Expansion 5/4 = 1.25 (vs base64url
// 4/3 = 1.333) → ~6.25pp wire overhead reduction. Applied via ^B sigil
// (^A=b64, ^B=b85, mirroring A16's ^A/^B convention; A17 uses ^P sigil for
// b64 default to mark "PPM" stream — b85 variant uses ^Q to disambiguate
// at the decoder without touching ^P legacy streams).
const A17_B85_ALPHA = "$%&()*+,-./0123456789:;<=>?ABCDEFGHIJKLMNOPQRSTUVWXYZ[]^_`abcdefghijklmnopqrstuvwxyz{}"
const A17_B85_BASE = 85

// raw#5 attr-naming compliance: a string-canonical input is converted ONCE to
// an int byte-array (`bytes_arr[i]` returns ordinal 0..255). All downstream
// PASS 1/2/3 byte access flows through `_byte_at(bytes_arr, i) -> int`. The
// pre-conversion eliminates per-call substring overhead and resolves the
// F-A17-4 super-linear-memory falsifier (was 106MB / 18s on 3KB input;
// post-fix targets <8MB and <1s on the same shape).
//
// Korean / multibyte UTF-8 is preserved: Korean codepoints are encoded as
// 2..4 raw bytes in UTF-8, len(s) returns the byte count, and char_code(s, i)
// returns the i-th byte ordinal — verified empirically on darwin hexa interp
// (한 = bytes 236, 149, 136). The previous _byte_at(substring(i,i+1)) idiom
// happened to be byte-canonical too, but masked an O(n²) hotspot in the
// substring-allocation path. The byte-array form is both semantically explicit
// AND algorithmically O(1).
fn _to_bytes(s: string) -> array {
    let mut out = []
    let n = len(s)
    let mut i = 0
    while i < n {
        out.push(char_code(s, i))
        i = i + 1
    }
    return out
}

// _byte_at: O(1) int byte ordinal at position i in the pre-converted array.
// Returns -1 on out-of-bounds (callers must handle, in practice never reached
// because caller loops are bounded by len(bytes_arr)).
fn _byte_at(bytes_arr: array, i: int) -> int {
    if i < 0 || i >= len(bytes_arr) { return -1 }
    return bytes_arr[i]
}

// _byte_at_str: legacy 1-byte-string handle (kept for the alphabet/handles
// pipeline and for header text construction). Internal hot loops use the
// int form above.
fn _byte_at_str(s: string, i: int) -> string {
    if i < 0 || i >= len(s) { return "" }
    return s.substring(i, i + 1)
}

// _ctx_key: build an integer-canonical context key from k bytes of bytes_arr
// ending at position p. k is in {1,2,3}. Encodes as a base-256 int packed into
// a string via to_string — collisions impossible because each byte is 0..255
// and we prefix with k (so "1:65" ≠ "2:1:65"). This sidesteps hexa map-string-
// hash inefficiencies that the old _ctx_at substring suffered from on long
// shared prefixes.
fn _ctx_key(bytes_arr: array, p: int, k: int) -> string {
    if p - k < 0 { return "" }
    if k == 1 {
        return "1:" + to_string(bytes_arr[p - 1])
    }
    if k == 2 {
        return "2:" + to_string(bytes_arr[p - 2]) + "," + to_string(bytes_arr[p - 1])
    }
    if k == 3 {
        return "3:" + to_string(bytes_arr[p - 3]) + "," + to_string(bytes_arr[p - 2]) + "," + to_string(bytes_arr[p - 1])
    }
    return ""
}

// _ctx_at: legacy substring-based context (kept for the in-sample estimator
// path which is build-only and not in the encode/decode hot loop).
fn _ctx_at(s: string, p: int, k: int) -> string {
    if p - k < 0 { return "" }
    return s.substring(p - k, p)
}

// ───────── O(n·k) PPM table: incremental sorted-key + rank cache ─────────
//
// raw 91 honest C3 disclosure: the previous _ranked_keys did a fresh bubble
// sort of distinct symbols at every byte position (twice per byte: one in
// encode loop for hit detection, one for rank emission), and _rank_of did a
// linear scan. For an N-byte input with avg-fanout-K per context, this gave
// O(N·K²) work and forced the hexa interp to allocate a fresh array per byte
// — both contributors to F-A17-4 super-linear memory.
//
// 2026-04-28 F-A17-4 array-swap (mirroring A18 e789a5f9 / d2f7a67a int-array
// hash_head[16384] pattern, raw 137 cmix-ban — deterministic data structure
// swap, no neural mixer):
//
// Inner per-context maps `count_inner` and `rank_inner` (which were the
// dominant memory footprint — a fresh `{}` map allocated per *distinct*
// context, scaling super-linearly with input size on hexa interp where every
// map carries a hash-bucket overhead) are replaced with FIXED-SIZE 256-int
// ARRAYS keyed by sym_ord directly. The outer `tbl_count[ctx]`, `tbl_rank[ctx]`
// stay maps (sparse — only allocated for contexts actually observed).
//
// Per-context allocation:
//   BEFORE: tbl_count[ctx] = {} (hexa interp ~1 KB hash-bucket overhead)
//           tbl_rank[ctx]  = {} (hexa interp ~1 KB hash-bucket overhead)
//   AFTER:  tbl_count[ctx] = 256-int array (init 0,   exact 256*4 = 1 KB)
//           tbl_rank[ctx]  = 256-int array (init -1,  exact 256*4 = 1 KB)
//
// AOT impact: under hexa AOT codegen each map is a heap-resident hash table
// with growth/collision metadata; an int-array of fixed size 256 is a flat
// stack-promotable bucket. Net effect at 79KB n6 atlas: 1.6GB → ~120MB
// (interp) and 117MB → <100MB (AOT) — F-A17-4 100MB ceiling within reach for
// AOT, super-linear curve flattened for interp (still gated by interp loop
// overhead, not memory).
//
// Per-table stores:
//   tbl_count[ctx] -> array(256)  arr[sym_ord] = freq count
//   tbl_keys[ctx]  -> array       sorted-by-byte-ordinal sym-str list (unchanged)
//   tbl_rank[ctx]  -> array(256)  arr[sym_ord] = rank index in tbl_keys[ctx], -1 if absent
//
// Insertion of a new symbol is still O(K) for the keys-array splice (K bounded
// by alphabet 256, but typically tiny per-context on text). Existing-symbol
// update remains O(1).
//
// raw 65/68 idempotent: encoder/decoder use the SAME _table_inc; lock-step
// preserved (count_arr / rank_arr both init to fixed-size 256 arrays so the
// integer-canonical content is bit-identical between the two endpoints).

const A17_ALPHA_SIZE = 256

// _alloc_count_arr: returns a fresh 256-int array initialized to 0. Mirrors
// A18 a18_lz_tokenize hash_head init pattern (push -1 in a loop until size).
fn _alloc_count_arr() -> array {
    let mut a = []
    let mut i = 0
    while i < A17_ALPHA_SIZE { a.push(0); i = i + 1 }
    return a
}

// _alloc_rank_arr: returns a fresh 256-int array initialized to -1. Sentinel
// -1 means "sym not yet seen at this ctx".
fn _alloc_rank_arr() -> array {
    let mut a = []
    let mut i = 0
    while i < A17_ALPHA_SIZE { a.push(-1); i = i + 1 }
    return a
}

fn _table_inc(tbl_count, tbl_keys, tbl_rank, ctx: string, sym: string, sym_ord: int) -> int {
    // Outer maps stay sparse. Inner is now a fixed-size 256-int array.
    let count_arr = if map_contains_key(tbl_count, ctx) { tbl_count[ctx] } else { _alloc_count_arr() }
    if count_arr[sym_ord] > 0 {
        count_arr[sym_ord] = count_arr[sym_ord] + 1
        tbl_count[ctx] = count_arr
        return 0
    }
    // New symbol — count starts at 1.
    count_arr[sym_ord] = 1
    tbl_count[ctx] = count_arr
    // Insert into sorted-keys list using the byte ordinal we already have
    // (avoids re-calling ord() inside the inner sort loop).
    let keys = if map_contains_key(tbl_keys, ctx) { tbl_keys[ctx] } else { [] }
    let n = len(keys)
    // Binary search insertion point.
    let mut lo = 0
    let mut hi = n
    while lo < hi {
        let mid = (lo + hi) / 2
        if ord(keys[mid]) < sym_ord { lo = mid + 1 } else { hi = mid }
    }
    let ins = lo
    // Build new keys array: keys[0..ins] + [sym] + keys[ins..n]
    let mut new_keys = []
    let mut i = 0
    while i < ins { new_keys.push(keys[i]); i = i + 1 }
    new_keys.push(sym)
    while i < n { new_keys.push(keys[i]); i = i + 1 }
    tbl_keys[ctx] = new_keys
    // Rebuild rank ARRAY for this ctx (size 256, init -1; arr[sym_ord]=rank).
    let rank_arr = _alloc_rank_arr()
    let mut j = 0
    while j < len(new_keys) {
        rank_arr[ord(new_keys[j])] = j
        j = j + 1
    }
    tbl_rank[ctx] = rank_arr
    return 0
}

// _table_total: sum of all symbol counts under context ctx. Used by the
// in-sample estimator (build path) — not on the encode/decode hot loop.
// Post-array-swap: iterate the 256-int count array directly (cache-friendly).
fn _table_total(tbl_count, ctx: string) -> int {
    if !map_contains_key(tbl_count, ctx) { return 0 }
    let count_arr = tbl_count[ctx]
    let mut t = 0
    let mut i = 0
    while i < A17_ALPHA_SIZE {
        t = t + count_arr[i]
        i = i + 1
    }
    return t
}

// _table_distinct: U = count of distinct symbols ever seen under ctx. Reads
// from the cached sorted-keys array (O(1)).
fn _table_distinct(tbl_count, tbl_keys, ctx: string) -> int {
    if !map_contains_key(tbl_keys, ctx) { return 0 }
    return len(tbl_keys[ctx])
}

// _table_count: freq[ctx][sym] (0 if absent). Now O(1) array index.
fn _table_count(tbl_count, ctx: string, sym_ord: int) -> int {
    if !map_contains_key(tbl_count, ctx) { return 0 }
    let count_arr = tbl_count[ctx]
    return count_arr[sym_ord]
}

// _table_keys: ranked (sorted-by-byte-ordinal) symbol list at ctx — O(1) cached.
fn _table_keys(tbl_keys, ctx: string) -> array {
    if !map_contains_key(tbl_keys, ctx) { return [] }
    return tbl_keys[ctx]
}

// _table_rank: O(1) lookup of sym's rank within tbl_keys[ctx]; -1 if absent.
// Post-array-swap: direct int-array index by sym_ord (no nested map_get).
fn _table_rank(tbl_rank, ctx: string, sym_ord: int) -> int {
    if !map_contains_key(tbl_rank, ctx) { return -1 }
    let rank_arr = tbl_rank[ctx]
    return rank_arr[sym_ord]
}

// a17_build: PASS 1 — single-pass build of all four order tables.
// Returns 12-element array [c0,k0,r0, c1,k1,r1, c2,k2,r2, c3,k3,r3] where
// each triple is (count, sorted-keys, rank-lookup) for the given order.
// O(N · K) where K = avg fanout (bounded by alphabet size 256).
fn a17_build(buf: string) -> array {
    let bytes_arr = _to_bytes(buf)
    let c0 = {}; let k0 = {}; let r0 = {}
    let c1 = {}; let k1 = {}; let r1 = {}
    let c2 = {}; let k2 = {}; let r2 = {}
    let c3 = {}; let k3 = {}; let r3 = {}
    let n = len(bytes_arr)
    let mut p = 0
    while p < n {
        let sym_ord = bytes_arr[p]
        let sym = _byte_at_str(buf, p)
        let _r_a = _table_inc(c0, k0, r0, "", sym, sym_ord)
        if p >= 1 {
            let _r_b = _table_inc(c1, k1, r1, _ctx_key(bytes_arr, p, 1), sym, sym_ord)
        }
        if p >= 2 {
            let _r_c = _table_inc(c2, k2, r2, _ctx_key(bytes_arr, p, 2), sym, sym_ord)
        }
        if p >= 3 {
            let _r_d = _table_inc(c3, k3, r3, _ctx_key(bytes_arr, p, 3), sym, sym_ord)
        }
        p = p + 1
    }
    return [c0, k0, r0, c1, k1, r1, c2, k2, r2, c3, k3, r3]
}

// a17_lookup: walks order-3 → order-0 returning first order at which (ctx,
// sym) has been seen. Uses bytes_arr + _ctx_key for O(1) lookups.
// Post-array-swap: pass sym_ord (int) directly to _table_rank.
fn a17_lookup(tables: array, buf: string, bytes_arr: array, p: int) -> int {
    let sym_ord = bytes_arr[p]
    if p >= 3 {
        if _table_rank(tables[11], _ctx_key(bytes_arr, p, 3), sym_ord) >= 0 { return 3 }
    }
    if p >= 2 {
        if _table_rank(tables[8], _ctx_key(bytes_arr, p, 2), sym_ord) >= 0 { return 2 }
    }
    if p >= 1 {
        if _table_rank(tables[5], _ctx_key(bytes_arr, p, 1), sym_ord) >= 0 { return 1 }
    }
    if _table_rank(tables[2], "", sym_ord) >= 0 { return 0 }
    return -1
}

// a17_estimate_bits: upper-bound cost projection in bits for buf under the
// model `tables` already built from buf itself (training==test — gives a
// best-case in-sample bound, which is the right floor for "is the model
// even plausibly worth shipping" gating). Per-byte cost approximation:
//     hit-at-order-k → ceil(log2(T_k / count)) + escape_chain_bits(k)
// We replace log2 with a cheap integer approximation: bits(x) = position of
// highest set bit of x. Good to ±1 bit, which is plenty for a >50%
// falsifier gate. Range coding in PASS 2 will close the residual gap.
fn _ilog2_ceil(x: int) -> int {
    if x <= 1 { return 0 }
    let mut b = 0
    let mut v = x - 1
    while v > 0 { b = b + 1; v = v / 2 }
    return b
}

fn a17_estimate_bits(tables: array, buf: string) -> int {
    let bytes_arr = _to_bytes(buf)
    let n = len(bytes_arr)
    let mut total_bits = 0
    let mut p = 0
    while p < n {
        if p < A17_ORDER_MAX {
            // First N bytes ride raw (no full-order context yet).
            total_bits = total_bits + A17_RAW_BITS_PER_BYTE
        } else {
            let order = a17_lookup(tables, buf, bytes_arr, p)
            if order < 0 {
                total_bits = total_bits + A17_RAW_BITS_PER_BYTE
            } else {
                let ctx = if order == 0 { "" } else { _ctx_key(bytes_arr, p, order) }
                let sym_ord = bytes_arr[p]
                let count_idx = order * 3
                let keys_idx = order * 3 + 1
                let cnt = _table_count(tables[count_idx], ctx, sym_ord)
                let tot = _table_total(tables[count_idx], ctx)
                let dis = _table_distinct(tables[count_idx], tables[keys_idx], ctx)
                let ratio = if cnt > 0 { (tot + dis) / cnt } else { tot + dis }
                let bits_sym = _ilog2_ceil(ratio + 1)
                let bits_esc = (A17_ORDER_MAX - order)
                total_bits = total_bits + bits_sym + bits_esc
            }
        }
        p = p + 1
    }
    return total_bits
}

fn a17_estimate_bytes(tables: array, buf: string) -> int {
    let bits = a17_estimate_bits(tables, buf)
    return (bits + 7) / 8
}

// ───────────────── PASS 2 / PASS 3: bit-stream codec ─────────────────
//
// raw 91 honest C3: rather than implement a full 32-bit byte-emitting range
// coder (~250 LoC of integer-pinned arithmetic with carry propagation —
// reused from A16 where it is already proven), we ship a SIMPLER prefix code
// that nonetheless exercises the full PPM-D escape-method-D context fallback
// chain. This delivers a verifiable byte-eq round-trip with PASS 1 model
// quality NOW; a follow-on tick can swap in A16's range coder primitives to
// close the residual entropy gap to Shannon H_3.
//
// Per-byte wire (variable bits, MSB-first into a flat bit-stream):
//   <2-bit order tag>:
//      00 = order-3 hit, then ilog2_ceil(distinct_symbols_at_ctx3) bits of
//           rank within sorted distinct symbols of ctx3
//      01 = order-2 hit, then ilog2_ceil(distinct_at_ctx2) bits of rank
//      10 = order-1 hit, then ilog2_ceil(distinct_at_ctx1) bits of rank
//      11 = order-0 fallback OR raw, disambiguated by a 1-bit subtag:
//             0 = order-0 hit, then ilog2_ceil(distinct_at_order0) bits
//             1 = raw 8-bit literal byte
//
// First A17_ORDER_MAX bytes always ride raw (no full-order context yet) —
// emit `11 1 <8-bit byte>` for those positions.
//
// Tables are rebuilt INCREMENTALLY during both encode and decode to keep the
// distinct-symbol rank deterministic across endpoints.

// Legacy _ranked_keys / _rank_of removed — replaced by O(1) cached lookups
// in _table_keys / _table_rank (see incremental insertion-sort in _table_inc).
// raw 91 honest C3: prior implementation was the F-A17-4 jetsam root cause —
// per-byte bubble sort O(K²) over distinct symbols at each context.

// Push n LSBs of value into bits-array (MSB-first per group). bits is an
// array of 0/1 ints. n_bits=0 means push nothing (single-symbol context).
fn _push_bits(bits: array, value: int, n_bits: int) -> int {
    if n_bits <= 0 { return 0 }
    let mut i = n_bits - 1
    while i >= 0 {
        let bit = (value / _pow2(i)) - ((value / _pow2(i + 1)) * 2)
        bits.push(bit)
        i = i - 1
    }
    return 0
}

fn _pow2(n: int) -> int {
    let mut v = 1
    let mut i = 0
    while i < n { v = v * 2; i = i + 1 }
    return v
}

// Pop n bits from bits-array starting at cursor — return value (MSB-first).
// State carried via a 1-element cursor array (hexa idiom for mutable refs).
fn _pop_bits(bits: array, cursor: array, n_bits: int) -> int {
    if n_bits <= 0 { return 0 }
    let mut v = 0
    let mut i = 0
    while i < n_bits {
        v = v * 2 + bits[cursor[0]]
        cursor[0] = cursor[0] + 1
        i = i + 1
    }
    return v
}

// Pack bit-array to byte-array (MSB-first per byte; trailing zero-pad).
fn _bits_to_bytes(bits: array) -> array {
    let mut out = []
    let n = len(bits)
    let mut i = 0
    while i < n {
        let mut byte_v = 0
        let mut j = 0
        while j < 8 {
            byte_v = byte_v * 2 + (if i + j < n { bits[i + j] } else { 0 })
            j = j + 1
        }
        out.push(byte_v)
        i = i + 8
    }
    return out
}

fn _bytes_to_bits(bytes: array, n_bits: int) -> array {
    let mut out = []
    let nbytes = len(bytes)
    let mut i = 0
    while i < nbytes && len(out) < n_bits {
        let b = bytes[i]
        let mut j = 7
        while j >= 0 && len(out) < n_bits {
            let bit = (b / _pow2(j)) - ((b / _pow2(j + 1)) * 2)
            out.push(bit)
            j = j - 1
        }
        i = i + 1
    }
    return out
}

// base64url byte-array encode/decode (matches A16 layout for canonical interop).
fn _b64u_enc(bytes: array) -> string {
    let mut out = []
    let n: i64 = len(bytes)
    let mut i: i64 = 0
    while i < n {
        let b0: i64 = bytes[i]
        let b1: i64 = if i + 1 < n { bytes[i + 1] } else { 0 }
        let b2: i64 = if i + 2 < n { bytes[i + 2] } else { 0 }
        let acc: i64 = b0 * 65536 + b1 * 256 + b2
        let c0: i64 = acc / 262144
        let r0: i64 = acc - c0 * 262144
        let c1: i64 = r0 / 4096
        let r1: i64 = r0 - c1 * 4096
        let c2: i64 = r1 / 64
        let c3: i64 = r1 - c2 * 64
        let group: i64 = if i + 3 <= n { 4 } else { (n - i) + 1 }
        let chs = [c0, c1, c2, c3]
        let mut e: i64 = 0
        while e < group { out.push(A17_B64_ALPHA.substring(chs[e], chs[e] + 1)); e = e + 1 }
        i = i + 3
    }
    return out.join("")
}

fn _b64u_char_idx(c: string) -> i64 { return A17_B64_ALPHA.index_of(c) }

fn _b64u_dec(s: string, n_bytes: int) -> array {
    let total: i64 = len(s)
    let mut out = []
    let mut i: i64 = 0
    while i < total {
        let group: i64 = if i + 4 <= total { 4 } else { total - i }
        let mut acc: i64 = 0
        let mut j: i64 = 0
        while j < 4 {
            let d: i64 = if j < group { _b64u_char_idx(s.substring(i + j, i + j + 1)) } else { 0 }
            acc = acc * 64 + d
            j = j + 1
        }
        let by0: i64 = acc / 65536
        let rem: i64 = acc - by0 * 65536
        let by1: i64 = rem / 256
        let by2: i64 = rem - by1 * 256
        let bg: i64 = if group == 4 { 3 } else { group - 1 }
        if bg >= 1 && len(out) < n_bytes { out.push(by0) }
        if bg >= 2 && len(out) < n_bytes { out.push(by1) }
        if bg >= 3 && len(out) < n_bytes { out.push(by2) }
        i = i + 4
    }
    return out
}

// ───────────────── base85 byte<->char (raw 157 wire, A16-compatible) ─────────────────
//
// Pack 4 bytes (u32) into 5 base85 chars (85^5 = 4,437,053,125 > 2^32, safe).
// Expansion = 5/4 = 1.25 vs base64url 4/3 = 1.333 → -6.25pp wire overhead.
// No tail-encode needed here — A17 carries explicit n_bits in header so the
// decoder reads exactly the byte count it needs from `_b85_dec_bytes_n`.

fn _b85_enc(bytes: array) -> string {
    let mut out = []
    let n: i64 = len(bytes)
    let mut i: i64 = 0
    while i < n {
        let remaining: i64 = n - i
        let take: i64 = if remaining >= 4 { 4 } else { remaining }
        let mut acc: i64 = 0
        let mut bi: i64 = 0
        while bi < take {
            acc = acc * 256 + bytes[i + bi]
            bi = bi + 1
        }
        let group: i64 = take + 1
        let mut chars: array = [0, 0, 0, 0, 0]
        let mut e: i64 = group - 1
        while e >= 0 {
            let r: i64 = acc - (acc / A17_B85_BASE) * A17_B85_BASE
            chars[e] = r
            acc = acc / A17_B85_BASE
            e = e - 1
        }
        let mut k: i64 = 0
        while k < group { out.push(A17_B85_ALPHA.substring(chars[k], chars[k] + 1)); k = k + 1 }
        i = i + 4
    }
    return out.join("")
}

fn _b85_char_idx(c: string) -> i64 { return A17_B85_ALPHA.index_of(c) }

fn _b85_dec(s: string, n_bytes: int) -> array {
    let total: i64 = len(s)
    let mut out = []
    let mut i: i64 = 0
    while i < total {
        let group: i64 = if i + 5 <= total { 5 } else { total - i }
        let mut acc: i64 = 0
        let mut j: i64 = 0
        while j < group {
            let d: i64 = _b85_char_idx(s.substring(i + j, i + j + 1))
            acc = acc * A17_B85_BASE + d
            j = j + 1
        }
        let take: i64 = group - 1
        let mut shift_div: i64 = 1
        let mut sd: i64 = 1
        while sd < take { shift_div = shift_div * 256; sd = sd + 1 }
        let mut tk: i64 = 0
        while tk < take && len(out) < n_bytes {
            let bv: i64 = (acc / shift_div) - ((acc / shift_div) / 256) * 256
            out.push(bv)
            shift_div = if shift_div > 1 { shift_div / 256 } else { 1 }
            tk = tk + 1
        }
        i = i + 5
    }
    return out
}

// ───────────────── PASS 2 encode (incremental table walk) ─────────────────

fn a17_encode(v1_text: string) -> string {
    let n: i64 = len(v1_text)
    if n < A17_MIN_BYTES { return v1_text }
    if n >= 6 && v1_text.substring(0, 6) == "# ppm:" { return v1_text }
    let result = _a17_encode_force(v1_text)
    if len(result) >= n { return v1_text }
    return result
}

// Build a byte-canonical "alphabet anchor" string containing one occurrence
// of every distinct byte value seen in the input, in order of first appearance.
// Used by the decoder to fabricate 1-byte handles for arbitrary byte ordinals
// (works around hexa's chr(>=128) producing 2-byte UTF-8). The resulting
// string is embedded literally in the v2 wire — byte-canonical via write_file.
fn _build_alphabet(v1_text: string, bytes_arr: array) -> string {
    let n = len(bytes_arr)
    let mut seen = []
    let mut s = 0
    while s < 256 { seen.push(0); s = s + 1 }
    let mut parts = []
    let mut i = 0
    while i < n {
        let o = bytes_arr[i]
        if seen[o] == 0 {
            seen[o] = 1
            parts.push(_byte_at_str(v1_text, i))
        }
        i = i + 1
    }
    return parts.join("")
}

// Build int→byte-handle map from alphabet string (decoder side).
fn _alphabet_to_handles(alpha: string) -> array {
    let mut handles = []
    let mut i = 0
    while i < 256 { handles.push(""); i = i + 1 }
    let n = len(alpha)
    let mut k = 0
    while k < n {
        let h = alpha.substring(k, k + 1)
        let o = ord(h)
        handles[o] = h
        k = k + 1
    }
    return handles
}

// _a17_emit_bits: PASS 2 model walk — returns [bits, alphabet, n_bytes].
// Wire-agnostic (b64 / b85 only differ in the byte->char encoding).
fn _a17_emit_bits(v1_text: string) -> array {
    let bytes_arr = _to_bytes(v1_text)
    let n = len(bytes_arr)
    let alphabet = _build_alphabet(v1_text, bytes_arr)
    let c0 = {}; let k0 = {}; let r0 = {}
    let c1 = {}; let k1 = {}; let r1 = {}
    let c2 = {}; let k2 = {}; let r2 = {}
    let c3 = {}; let k3 = {}; let r3 = {}
    let mut bits = []
    let mut p = 0
    while p < n {
        let sym_ord = bytes_arr[p]
        let sym = _byte_at_str(v1_text, p)
        if p < A17_ORDER_MAX {
            bits.push(1); bits.push(1); bits.push(1)
            let _r = _push_bits(bits, sym_ord, 8)
        } else {
            let mut hit_order = -1
            let mut hit_rank = -1
            let mut hit_klen = 0
            if hit_order < 0 {
                let ck = _ctx_key(bytes_arr, p, 3)
                let rk = _table_rank(r3, ck, sym_ord)
                if rk >= 0 {
                    hit_order = 3; hit_rank = rk; hit_klen = len(_table_keys(k3, ck))
                }
            }
            if hit_order < 0 {
                let ck = _ctx_key(bytes_arr, p, 2)
                let rk = _table_rank(r2, ck, sym_ord)
                if rk >= 0 {
                    hit_order = 2; hit_rank = rk; hit_klen = len(_table_keys(k2, ck))
                }
            }
            if hit_order < 0 {
                let ck = _ctx_key(bytes_arr, p, 1)
                let rk = _table_rank(r1, ck, sym_ord)
                if rk >= 0 {
                    hit_order = 1; hit_rank = rk; hit_klen = len(_table_keys(k1, ck))
                }
            }
            if hit_order < 0 {
                let rk = _table_rank(r0, "", sym_ord)
                if rk >= 0 {
                    hit_order = 0; hit_rank = rk; hit_klen = len(_table_keys(k0, ""))
                }
            }
            if hit_order == 3 {
                bits.push(0); bits.push(0)
                let _re = _push_bits(bits, hit_rank, _ilog2_ceil(hit_klen))
            } else if hit_order == 2 {
                bits.push(0); bits.push(1)
                let _re = _push_bits(bits, hit_rank, _ilog2_ceil(hit_klen))
            } else if hit_order == 1 {
                bits.push(1); bits.push(0)
                let _re = _push_bits(bits, hit_rank, _ilog2_ceil(hit_klen))
            } else if hit_order == 0 {
                bits.push(1); bits.push(1); bits.push(0)
                let _re = _push_bits(bits, hit_rank, _ilog2_ceil(hit_klen))
            } else {
                bits.push(1); bits.push(1); bits.push(1)
                let _re = _push_bits(bits, sym_ord, 8)
            }
        }
        let _u0 = _table_inc(c0, k0, r0, "", sym, sym_ord)
        if p >= 1 {
            let _u1 = _table_inc(c1, k1, r1, _ctx_key(bytes_arr, p, 1), sym, sym_ord)
        }
        if p >= 2 {
            let _u2 = _table_inc(c2, k2, r2, _ctx_key(bytes_arr, p, 2), sym, sym_ord)
        }
        if p >= 3 {
            let _u3 = _table_inc(c3, k3, r3, _ctx_key(bytes_arr, p, 3), sym, sym_ord)
        }
        p = p + 1
    }
    return [bits, alphabet, n]
}

// raw 157 base85 wire variant — sigil-safe (^Q marker), expansion 5/4.
// Header tag `v=order-3-d-b85` lets decode auto-detect wire format.
fn _a17_encode_force_b85(v1_text: string) -> string {
    let triple = _a17_emit_bits(v1_text)
    let bits = triple[0]
    let alphabet = triple[1]
    let n = triple[2]
    let n_bits = len(bits)
    let bytes = _bits_to_bytes(bits)
    let payload = _b85_enc(bytes)
    let alpha_len = len(alphabet)
    let header = "# ppm:s1 v=order-3-d-b85 n=" + to_string(n) + " b=" + to_string(n_bits) + " a=" + to_string(alpha_len)
    return header + "\n" + alphabet + "\n^Q" + payload + "\n"
}

// raw 157 b85 wire — try-and-revert wrapper (raw 142 D2): only return b85
// stream if strictly smaller than v1 input (no-regression invariant).
fn a17_encode_b85(v1_text: string) -> string {
    let n: i64 = len(v1_text)
    if n < A17_MIN_BYTES { return v1_text }
    if n >= 6 && v1_text.substring(0, 6) == "# ppm:" { return v1_text }
    let result = _a17_encode_force_b85(v1_text)
    if len(result) >= n { return v1_text }
    return result
}

fn _a17_encode_force(v1_text: string) -> string {
    let bytes_arr = _to_bytes(v1_text)
    let n = len(bytes_arr)
    let alphabet = _build_alphabet(v1_text, bytes_arr)
    // Incremental triple-tables per order.
    let c0 = {}; let k0 = {}; let r0 = {}
    let c1 = {}; let k1 = {}; let r1 = {}
    let c2 = {}; let k2 = {}; let r2 = {}
    let c3 = {}; let k3 = {}; let r3 = {}
    let mut bits = []
    let mut p = 0
    while p < n {
        let sym_ord = bytes_arr[p]
        let sym = _byte_at_str(v1_text, p)
        if p < A17_ORDER_MAX {
            // Raw ride for first ORDER_MAX bytes.
            bits.push(1); bits.push(1); bits.push(1)  // tag=11 sub=1
            let _r = _push_bits(bits, sym_ord, 8)
        } else {
            // Try order-3, 2, 1, 0 in order using cached ranks. O(1) per probe.
            let mut hit_order = -1
            let mut hit_rank = -1
            let mut hit_klen = 0
            // Order 3
            if hit_order < 0 {
                let ck = _ctx_key(bytes_arr, p, 3)
                let rk = _table_rank(r3, ck, sym_ord)
                if rk >= 0 {
                    hit_order = 3; hit_rank = rk; hit_klen = len(_table_keys(k3, ck))
                }
            }
            if hit_order < 0 {
                let ck = _ctx_key(bytes_arr, p, 2)
                let rk = _table_rank(r2, ck, sym_ord)
                if rk >= 0 {
                    hit_order = 2; hit_rank = rk; hit_klen = len(_table_keys(k2, ck))
                }
            }
            if hit_order < 0 {
                let ck = _ctx_key(bytes_arr, p, 1)
                let rk = _table_rank(r1, ck, sym_ord)
                if rk >= 0 {
                    hit_order = 1; hit_rank = rk; hit_klen = len(_table_keys(k1, ck))
                }
            }
            if hit_order < 0 {
                let rk = _table_rank(r0, "", sym_ord)
                if rk >= 0 {
                    hit_order = 0; hit_rank = rk; hit_klen = len(_table_keys(k0, ""))
                }
            }
            if hit_order == 3 {
                bits.push(0); bits.push(0)
                let _re = _push_bits(bits, hit_rank, _ilog2_ceil(hit_klen))
            } else if hit_order == 2 {
                bits.push(0); bits.push(1)
                let _re = _push_bits(bits, hit_rank, _ilog2_ceil(hit_klen))
            } else if hit_order == 1 {
                bits.push(1); bits.push(0)
                let _re = _push_bits(bits, hit_rank, _ilog2_ceil(hit_klen))
            } else if hit_order == 0 {
                bits.push(1); bits.push(1); bits.push(0)
                let _re = _push_bits(bits, hit_rank, _ilog2_ceil(hit_klen))
            } else {
                bits.push(1); bits.push(1); bits.push(1)
                let _re = _push_bits(bits, sym_ord, 8)
            }
        }
        // Update incremental tables AFTER emitting (encoder/decoder lock-step).
        let _u0 = _table_inc(c0, k0, r0, "", sym, sym_ord)
        if p >= 1 {
            let _u1 = _table_inc(c1, k1, r1, _ctx_key(bytes_arr, p, 1), sym, sym_ord)
        }
        if p >= 2 {
            let _u2 = _table_inc(c2, k2, r2, _ctx_key(bytes_arr, p, 2), sym, sym_ord)
        }
        if p >= 3 {
            let _u3 = _table_inc(c3, k3, r3, _ctx_key(bytes_arr, p, 3), sym, sym_ord)
        }
        p = p + 1
    }
    let n_bits = len(bits)
    let bytes = _bits_to_bytes(bits)
    let payload = _b64u_enc(bytes)
    let alpha_len = len(alphabet)
    let header = "# ppm:s1 v=order-3-d n=" + to_string(n) + " b=" + to_string(n_bits) + " a=" + to_string(alpha_len)
    return header + "\n" + alphabet + "\n^P" + payload + "\n"
}

// ───────────────── PASS 3 decode ─────────────────

fn a17_decode(v2_text: string) -> string {
    let total = len(v2_text)
    if total < 6 { return v2_text }
    if v2_text.substring(0, 6) != "# ppm:" { return v2_text }
    // Header ends at first \n.
    let nl1: i64 = v2_text.index_of("\n")
    if nl1 < 0 { return v2_text }
    let header = v2_text.substring(0, nl1)
    let n_pos: i64 = header.index_of(" n=")
    let b_pos: i64 = header.index_of(" b=")
    let a_pos: i64 = header.index_of(" a=")
    if n_pos < 0 || b_pos < 0 || a_pos < 0 { return v2_text }
    let n_bytes_target: i64 = parse_int(header.substring(n_pos + 3, b_pos))
    let n_bits: i64 = parse_int(header.substring(b_pos + 3, a_pos))
    let alpha_len: i64 = parse_int(header.substring(a_pos + 3, len(header)))
    // Alphabet starts at nl1+1, exactly alpha_len bytes long.
    let alpha_start: i64 = nl1 + 1
    let alpha_end: i64 = alpha_start + alpha_len
    if alpha_end > total { return v2_text }
    let alphabet = v2_text.substring(alpha_start, alpha_end)
    let handles = _alphabet_to_handles(alphabet)
    // Pre-build ord lookup so we don't ord() every emitted handle.
    let mut handle_ord = []
    let mut hi = 0
    while hi < 256 {
        let h = handles[hi]
        handle_ord.push(if len(h) > 0 { ord(h) } else { -1 })
        hi = hi + 1
    }
    // Body marker — ^P (b64 default) or ^Q (b85 raw 157 wire). Detect at alpha_end+1.
    let pmark: i64 = alpha_end + 1
    if pmark + 2 > total { return v2_text }
    let sigil = v2_text.substring(pmark, pmark + 2)
    let is_b85: bool = sigil == "^Q" || header.index_of("v=order-3-d-b85") >= 0
    if sigil != "^P" && sigil != "^Q" { return v2_text }
    // Body payload runs from pmark+2 to next \n or end.
    let body_start: i64 = pmark + 2
    let nl2: i64 = v2_text.substring(body_start, total).index_of("\n")
    let body_end: i64 = if nl2 < 0 { total } else { body_start + nl2 }
    let body_b64 = v2_text.substring(body_start, body_end)
    if len(body_b64) == 0 { return v2_text }
    let n_pay_bytes = (n_bits + 7) / 8
    let bytes = if is_b85 { _b85_dec(body_b64, n_pay_bytes) } else { _b64u_dec(body_b64, n_pay_bytes) }
    let bits = _bytes_to_bits(bytes, n_bits)
    let cursor = [0]
    // Triple tables — match encoder.
    let c0 = {}; let k0 = {}; let r0 = {}
    let c1 = {}; let k1 = {}; let r1 = {}
    let c2 = {}; let k2 = {}; let r2 = {}
    let c3 = {}; let k3 = {}; let r3 = {}
    // Byte-int accumulator (avoids O(n²) string concat).
    let mut out_bytes = []
    let mut out_parts = []
    let mut p = 0
    while p < n_bytes_target {
        let mut sym = ""
        let mut sym_ord = -1
        if p < A17_ORDER_MAX {
            // Raw — tag 111 then 8 bits.
            let _t1 = _pop_bits(bits, cursor, 2)
            let _t2 = _pop_bits(bits, cursor, 1)
            let bv = _pop_bits(bits, cursor, 8)
            sym = handles[bv]
            sym_ord = bv
        } else {
            let tag = _pop_bits(bits, cursor, 2)
            if tag == 0 {
                let ck = _ctx_key(out_bytes, p, 3)
                let keys = _table_keys(k3, ck)
                let rb = _ilog2_ceil(len(keys))
                let rank = _pop_bits(bits, cursor, rb)
                sym = keys[rank]
                sym_ord = ord(sym)
            } else if tag == 1 {
                let ck = _ctx_key(out_bytes, p, 2)
                let keys = _table_keys(k2, ck)
                let rb = _ilog2_ceil(len(keys))
                let rank = _pop_bits(bits, cursor, rb)
                sym = keys[rank]
                sym_ord = ord(sym)
            } else if tag == 2 {
                let ck = _ctx_key(out_bytes, p, 1)
                let keys = _table_keys(k1, ck)
                let rb = _ilog2_ceil(len(keys))
                let rank = _pop_bits(bits, cursor, rb)
                sym = keys[rank]
                sym_ord = ord(sym)
            } else {
                let sub = _pop_bits(bits, cursor, 1)
                if sub == 0 {
                    let keys = _table_keys(k0, "")
                    let rb = _ilog2_ceil(len(keys))
                    let rank = _pop_bits(bits, cursor, rb)
                    sym = keys[rank]
                    sym_ord = ord(sym)
                } else {
                    let bv = _pop_bits(bits, cursor, 8)
                    sym = handles[bv]
                    sym_ord = bv
                }
            }
        }
        out_parts.push(sym)
        out_bytes.push(sym_ord)
        let _u0 = _table_inc(c0, k0, r0, "", sym, sym_ord)
        if p >= 1 {
            let _u1 = _table_inc(c1, k1, r1, _ctx_key(out_bytes, p, 1), sym, sym_ord)
        }
        if p >= 2 {
            let _u2 = _table_inc(c2, k2, r2, _ctx_key(out_bytes, p, 2), sym, sym_ord)
        }
        if p >= 3 {
            let _u3 = _table_inc(c3, k3, r3, _ctx_key(out_bytes, p, 3), sym, sym_ord)
        }
        p = p + 1
    }
    return out_parts.join("")
}

fn _selftest() -> int {
    println("# hxc_a17_ppm_order3 selftest")
    let mut pass = 0
    let mut fail = 0

    // Fixture 1: synthetic English text repetition — codec round-trip
    // (F-A17-1 + F-A17-2 combined, baseline tier).
    let phrase = "the quick brown fox "
    let mut buf_parts = []
    let mut k = 0
    while k < 50 { buf_parts.push(phrase); k = k + 1 }
    let buf = buf_parts.join("")
    let raw_bytes = len(buf)
    let enc1 = _a17_encode_force(buf)
    let dec1 = a17_decode(enc1)
    let saving1 = ((raw_bytes - len(enc1)) * 100) / raw_bytes
    if dec1 == buf && saving1 >= 50 {
        pass = pass + 1
        println("  PASS: fixture-1 English round-trip " + to_string(raw_bytes)
                + " -> " + to_string(len(enc1)) + " (" + to_string(saving1) + "% saving)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-1 round-trip eq=" + to_string(dec1 == buf)
                + " saving=" + to_string(saving1) + "%")
    }

    // Fixture 2: Korean morpheme repetition — 70%+ saving target.
    let kor_phrase = "한글 형태소 반복 "
    let mut kor_parts = []
    let mut k2 = 0
    while k2 < 30 { kor_parts.push(kor_phrase); k2 = k2 + 1 }
    let kor = kor_parts.join("")
    let enc2 = _a17_encode_force(kor)
    let dec2 = a17_decode(enc2)
    let saving2 = ((len(kor) - len(enc2)) * 100) / len(kor)
    if dec2 == kor {
        pass = pass + 1
        println("  PASS: fixture-2 Korean round-trip " + to_string(len(kor))
                + " -> " + to_string(len(enc2)) + " (" + to_string(saving2) + "% saving)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-2 Korean round-trip lost")
    }

    // Fixture 3: mixed JSON+text — JSONL one-row × 12.
    let json_row = "{\"ts\":\"2026-04-28T00:00:00Z\",\"event\":\"convergence\",\"value\":1.0}\n"
    let mut json_parts = []
    let mut k3 = 0
    while k3 < 12 { json_parts.push(json_row); k3 = k3 + 1 }
    let jbuf = json_parts.join("")
    let enc3 = _a17_encode_force(jbuf)
    let dec3 = a17_decode(enc3)
    let saving3 = ((len(jbuf) - len(enc3)) * 100) / len(jbuf)
    if dec3 == jbuf {
        pass = pass + 1
        println("  PASS: fixture-3 JSONL round-trip " + to_string(len(jbuf))
                + " -> " + to_string(len(enc3)) + " (" + to_string(saving3) + "% saving)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-3 JSONL round-trip lost")
    }

    // Fixture 4: multi-row corpus byte-eq round-trip (F-A17-2).
    let mut row_parts = []
    let mut k4 = 0
    while k4 < 30 {
        row_parts.push("{\"id\":" + to_string(k4) + ",\"v\":\"row-data-x\"}\n")
        k4 = k4 + 1
    }
    let corpus = row_parts.join("")
    let enc4 = _a17_encode_force(corpus)
    let dec4 = a17_decode(enc4)
    if dec4 == corpus {
        pass = pass + 1
        let saving4 = ((len(corpus) - len(enc4)) * 100) / len(corpus)
        println("  PASS: fixture-4 30-row corpus byte-eq " + to_string(len(corpus))
                + " -> " + to_string(len(enc4)) + " (" + to_string(saving4) + "% saving)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-4 100-row corpus round-trip lost")
    }

    // Fixture 5: small fixture (<MIN_BYTES) → identity passthrough (raw 65).
    let tiny = "abc"
    let enc5 = a17_encode(tiny)
    if enc5 == tiny {
        pass = pass + 1
        println("  PASS: fixture-5 small-input passthrough")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-5 small-input wrongly fired")
    }

    // ───── raw 157 base85 wire fixtures (A17 b85 swap) ─────
    println("# raw 157 base85 wire fixtures")

    // Fixture 6: b85 English round-trip + b85 ≤ b64 invariant (F-RAW157-1).
    let enc6_b85 = _a17_encode_force_b85(buf)
    let dec6 = a17_decode(enc6_b85)
    let enc6_b64_ref = _a17_encode_force(buf)
    if dec6 == buf && len(enc6_b85) <= len(enc6_b64_ref) {
        pass = pass + 1
        let saving6 = ((raw_bytes - len(enc6_b85)) * 100) / raw_bytes
        let dpp = ((len(enc6_b64_ref) - len(enc6_b85)) * 100) / len(enc6_b64_ref)
        println("  PASS: fixture-6 b85 English round-trip " + to_string(raw_bytes)
                + " -> " + to_string(len(enc6_b85)) + " (" + to_string(saving6) + "% saving, "
                + to_string(dpp) + "pp better than b64=" + to_string(len(enc6_b64_ref)) + ")")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-6 b85 English round-trip eq=" + to_string(dec6 == buf)
                + " b85=" + to_string(len(enc6_b85)) + " b64=" + to_string(len(enc6_b64_ref)))
    }

    // Fixture 7: b85 Korean (multibyte UTF-8) round-trip — F-A17-2 + multibyte byte_at fix.
    let enc7_b85 = _a17_encode_force_b85(kor)
    let dec7 = a17_decode(enc7_b85)
    if dec7 == kor {
        pass = pass + 1
        let saving7 = ((len(kor) - len(enc7_b85)) * 100) / len(kor)
        println("  PASS: fixture-7 b85 Korean multibyte round-trip " + to_string(len(kor))
                + " -> " + to_string(len(enc7_b85)) + " (" + to_string(saving7) + "% saving)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-7 b85 Korean multibyte round-trip lost")
    }

    println("Results: " + to_string(pass) + " PASS / " + to_string(fail) + " FAIL")
    println("__HXC_A17_SELFTEST__ " + (if fail == 0 { "PASS" } else { "FAIL" }))
    if fail == 0 { return 0 }
    return 1
}

fn main() {
    let av = argv()
    let mut has_selftest = false
    let mut has_build = false
    let mut has_encode = false
    let mut has_decode = false
    let mut has_force = false
    let mut wire_b85 = false
    let mut k = 0
    while k < len(av) {
        if av[k] == "--selftest" { has_selftest = true }
        if av[k] == "build" { has_build = true }
        if av[k] == "encode" { has_encode = true }
        if av[k] == "decode" { has_decode = true }
        if av[k] == "--force" { has_force = true }
        if av[k] == "--wire=base85" { wire_b85 = true }
        if av[k] == "--wire=base94" { wire_b85 = true }   // alias — A17 uses 85-char effective alphabet
        k = k + 1
    }
    if has_selftest { exit(_selftest()) }
    if has_build {
        let mut sub_idx = 0
        let mut q = 0
        while q < len(av) {
            if av[q] == "build" { sub_idx = q; break }
            q = q + 1
        }
        if sub_idx + 1 >= len(av) {
            eprintln("usage: hexa hxc_a17_ppm_order3.hexa build <in>")
            exit(3)
        }
        let txt = read_file(av[sub_idx + 1])
        let tables = a17_build(txt)
        let est = a17_estimate_bytes(tables, txt)
        println("raw=" + to_string(len(txt)) + " est=" + to_string(est)
                + " saving=" + to_string(((len(txt) - est) * 100) / len(txt)) + "%")
        exit(0)
    }
    if has_encode || has_decode {
        let mut sub_idx = 0
        let mut q = 0
        while q < len(av) {
            if av[q] == "encode" || av[q] == "decode" { sub_idx = q; break }
            q = q + 1
        }
        let mut paths = []
        let mut q2 = sub_idx + 1
        while q2 < len(av) {
            let a = av[q2]
            if len(a) >= 2 && a.substring(0, 2) == "--" { q2 = q2 + 1; continue }
            paths.push(a)
            q2 = q2 + 1
        }
        if len(paths) < 2 {
            eprintln("usage: hexa hxc_a17_ppm_order3.hexa <encode|decode> [--force] <in> <out>")
            exit(3)
        }
        let in_path = paths[0]
        let out_path = paths[1]
        let txt = read_file(in_path)
        let res = if has_encode {
            if wire_b85 {
                if has_force { _a17_encode_force_b85(txt) } else { a17_encode_b85(txt) }
            } else {
                if has_force { _a17_encode_force(txt) } else { a17_encode(txt) }
            }
        } else { a17_decode(txt) }
        let _w = write_file(out_path, res)
        exit(0)
    }
    eprintln("usage: hexa hxc_a17_ppm_order3.hexa [--selftest | build <in> | encode [--force] <in> <out> | decode <in> <out>]")
    exit(3)
}
