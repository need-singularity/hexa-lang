// self/stdlib/http.hexa — HTTP GET with custom headers (P1 — qmirror ANU)
//
// @module(slug="self-stdlib-http", desc="curl-based HTTP GET with header map support")
// @usage(use "self/stdlib/http"; let body = http_get_with_headers(url, #{"x-api-key": k}, 30))
//
// Source: anima/docs/hexa_lang_attr_review_for_qmirror_2026_05_03.md §5.4
//
// Mirror of stdlib/http.hexa — same API, kept here for resolver-order
// safety with sister-repos that import via the `self/stdlib/...` path
// (anthropic_sdk / openai_sdk / mcp_server convention). The P0 proc
// bridge follows the same dual-copy pattern.
//
// PROBLEM (qmirror entropy.hexa ↔ ANU REST API)
//   stdlib/net/http_client::http_get is body-only with no header support.
//   ANU quantum-RNG API requires `x-api-key: <key>`. Today qmirror.entropy
//   shells out raw curl per call — escape-fragile.
//
// FIX (additive, no runtime.c change)
//   1. http_get_with_headers(url, headers, timeout_sec) -> string
//   2. http_get_with_headers_status(url, headers, timeout_sec) -> map
//
// Breaking risk: 0. New module, new symbols.
//
// Caveats (raw#91): curl hard dep · header newline injection unchecked
// (callers pre-validate) · binary body unsafe (NUL truncation) · empty
// body indistinguishable from failure (use status variant for diagnostics).

fn _shell_escape(s: string) -> string {
    return "'" + s.replace("'", "'\\''") + "'"
}

fn _last_index_of(s: string, needle: string) -> int {
    let nlen = len(needle)
    let slen = len(s)
    if nlen == 0 { return -1 }
    if slen < nlen { return -1 }
    let mut i = slen - nlen
    while i >= 0 {
        if s.substring(i, i + nlen) == needle {
            return i
        }
        i = i - 1
    }
    return -1
}

fn _build_header_flags(headers) -> string {
    if type_of(headers) != "map" { return "" }
    let ks = dict_keys(headers)
    let mut out = ""
    let mut i = 0
    while i < len(ks) {
        let k = ks[i]
        let v = to_string(headers[k])
        out = out + " -H " + _shell_escape(k + ": " + v)
        i = i + 1
    }
    return out
}

// http_get_with_headers — body-only GET with header map.
// Returns "" on any failure (non-2xx, network error, curl missing).
fn http_get_with_headers(url: string, headers, timeout_sec: int) -> string {
    if len(url) == 0 { return "" }
    let t = if timeout_sec > 0 { timeout_sec } else { 30 }
    let hflags = _build_header_flags(headers)
    let cmd = "curl -sSL --fail --max-time " + to_string(t) + hflags + " " + _shell_escape(url) + " 2>/dev/null"
    let body = to_string(exec(cmd))
    return body
}

// http_get_with_headers_status — full {status, body, ok}.
fn http_get_with_headers_status(url: string, headers, timeout_sec: int) {
    let result = #{}
    result["status"] = 0
    result["body"] = ""
    result["ok"] = false

    if len(url) == 0 { return result }
    let t = if timeout_sec > 0 { timeout_sec } else { 30 }
    let hflags = _build_header_flags(headers)
    let cmd = "curl -sSL --max-time " + to_string(t) + hflags + " -w '\\n%{http_code}' " + _shell_escape(url) + " 2>/dev/null"
    let raw = to_string(exec(cmd))
    if len(raw) == 0 { return result }

    let nl = _last_index_of(raw, "\n")
    if nl < 0 { return result }
    let body = raw.substring(0, nl)
    let status_str = raw.substring(nl + 1, len(raw)).trim()
    let status = to_int(status_str)

    result["status"] = status
    result["body"] = body
    result["ok"] = status >= 200 && status < 300
    return result
}
