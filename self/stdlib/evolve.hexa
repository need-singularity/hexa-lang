// self/lib/evolve.hexa — @evolve AI-native self-evolution library
//
// Pure .hexa genetic algorithm / evolutionary optimization.
// The "singularity" attr: programs that optimize themselves.
//
// Gene = array of Float parameters within bounds.
// Population = array of genes.
// Bounds = array of [min, max] pairs (one per gene slot).
//
// API:
//   evolve_init(pop_size, gene_length, bounds)              → population
//   evolve_mutate(gene, rate, bounds)                       → mutated gene
//   evolve_crossover(parent1, parent2)                      → child gene
//   evolve_select(population, fitness_scores, t_size)       → winner gene
//   evolve_generation(population, fitness_fn, rate, bounds) → next population
//   evolve_run(config, fitness_fn)                          → best gene
//   self_optimize(fn, param_bounds, test_input)             → optimized params

// ═══════════════════════════════════════
// Helpers
// ═══════════════════════════════════════

fn evolve_rand_range(lo, hi) {
    // random() returns [0,1) float
    return lo + random(0, 1) * (hi - lo)
}

fn evolve_rand_int(lo, hi) {
    // inclusive [lo, hi]
    return lo + floor(random(0, 1) * (hi - lo + 1))
}

fn evolve_abs(x) {
    if x < 0 { return 0 - x }
    return x
}

fn evolve_copy_arr(a) {
    let mut out = []
    let mut i = 0
    while i < len(a) {
        out.push(a[i])
        i = i + 1
    }
    return out
}

// ═══════════════════════════════════════
// Gene representation + initialization
// ═══════════════════════════════════════

fn evolve_random_gene(gene_length, bounds) {
    // Create one random gene within bounds
    let mut gene = []
    let mut i = 0
    while i < gene_length {
        let lo = bounds[i][0]
        let hi = bounds[i][1]
        gene.push(evolve_rand_range(lo, hi))
        i = i + 1
    }
    return gene
}

fn evolve_init(pop_size, gene_length, bounds) {
    // Create initial random population
    let mut pop = []
    let mut i = 0
    while i < pop_size {
        pop.push(evolve_random_gene(gene_length, bounds))
        i = i + 1
    }
    return pop
}

// ═══════════════════════════════════════
// Fitness evaluation (user supplies fn)
// ═══════════════════════════════════════

fn evolve_eval_all(population, fitness_fn) {
    // Evaluate fitness for entire population → array of scores
    let mut scores = []
    let mut i = 0
    while i < len(population) {
        scores.push(fitness_fn(population[i]))
        i = i + 1
    }
    return scores
}

// ═══════════════════════════════════════
// Mutation: randomly perturb genes
// ═══════════════════════════════════════

fn evolve_mutate(gene, rate, bounds) {
    let mut out = []
    let mut i = 0
    while i < len(gene) {
        let val = gene[i]
        if random(0, 1) < rate {
            // Gaussian-ish mutation: add noise proportional to range
            let lo = bounds[i][0]
            let hi = bounds[i][1]
            let range = hi - lo
            // Box-Muller-lite: sum of 3 uniforms ~ approximate normal
            let noise = (random(0, 1) + random(0, 1) + random(0, 1) - 1.5) * range * 0.2
            let mut new_val = val + noise
            // clamp to bounds
            if new_val < lo { new_val = lo }
            if new_val > hi { new_val = hi }
            out.push(new_val)
        } else {
            out.push(val)
        }
        i = i + 1
    }
    return out
}

// ═══════════════════════════════════════
// Crossover: uniform crossover of two parents
// ═══════════════════════════════════════

fn evolve_crossover(parent1, parent2) {
    let mut child = []
    let mut i = 0
    while i < len(parent1) {
        if random(0, 1) < 0.5 {
            child.push(parent1[i])
        } else {
            child.push(parent2[i])
        }
        i = i + 1
    }
    return child
}

// Blend crossover (BLX-alpha) — interpolates between parents
fn evolve_crossover_blend(parent1, parent2, alpha) {
    let mut child = []
    let mut i = 0
    while i < len(parent1) {
        let lo = parent1[i]
        let hi = parent2[i]
        let mut mn = lo
        let mut mx = hi
        if mn > mx {
            let tmp = mn
            mn = mx
            mx = tmp
        }
        let d = mx - mn
        let new_lo = mn - alpha * d
        let new_hi = mx + alpha * d
        child.push(evolve_rand_range(new_lo, new_hi))
        i = i + 1
    }
    return child
}

// ═══════════════════════════════════════
// Selection: tournament selection
// ═══════════════════════════════════════

fn evolve_select(population, fitness_scores, tournament_size) {
    // Pick tournament_size random individuals, return the fittest
    let pop_size = len(population)
    let mut best_idx = evolve_rand_int(0, pop_size - 1)
    let mut best_fit = fitness_scores[best_idx]
    let mut t = 1
    while t < tournament_size {
        let idx = evolve_rand_int(0, pop_size - 1)
        if fitness_scores[idx] > best_fit {
            best_idx = idx
            best_fit = fitness_scores[idx]
        }
        t = t + 1
    }
    return evolve_copy_arr(population[best_idx])
}

// ═══════════════════════════════════════
// Find best in population
// ═══════════════════════════════════════

fn evolve_best(population, fitness_scores) {
    let mut best_idx = 0
    let mut best_fit = fitness_scores[0]
    let mut i = 1
    while i < len(population) {
        if fitness_scores[i] > best_fit {
            best_idx = i
            best_fit = fitness_scores[i]
        }
        i = i + 1
    }
    return evolve_copy_arr(population[best_idx])
}

fn evolve_best_fitness(fitness_scores) {
    let mut best = fitness_scores[0]
    let mut i = 1
    while i < len(fitness_scores) {
        if fitness_scores[i] > best {
            best = fitness_scores[i]
        }
        i = i + 1
    }
    return best
}

// ═══════════════════════════════════════
// Evolution: one generation step
// ═══════════════════════════════════════

fn evolve_generation(population, fitness_fn, mutation_rate, bounds) {
    let pop_size = len(population)
    let scores = evolve_eval_all(population, fitness_fn)

    // Elitism: keep the best individual
    let elite = evolve_best(population, scores)

    let mut next_gen = []
    next_gen.push(elite)

    let mut i = 1
    while i < pop_size {
        let p1 = evolve_select(population, scores, 3)
        let p2 = evolve_select(population, scores, 3)
        let child = evolve_crossover(p1, p2)
        let mutated = evolve_mutate(child, mutation_rate, bounds)
        next_gen.push(mutated)
        i = i + 1
    }
    return next_gen
}

// ═══════════════════════════════════════
// Evolution loop: full run
// ═══════════════════════════════════════

// config = [pop_size, gene_length, generations, mutation_rate]
// bounds = array of [min, max] per gene
// fitness_fn(gene) → Float (higher = better)

fn evolve_run(config, bounds, fitness_fn) {
    let pop_size = config[0]
    let gene_length = config[1]
    let generations = config[2]
    let mutation_rate = config[3]

    let mut pop = evolve_init(pop_size, gene_length, bounds)

    let mut gen = 0
    while gen < generations {
        pop = evolve_generation(pop, fitness_fn, mutation_rate, bounds)
        gen = gen + 1
    }

    let scores = evolve_eval_all(pop, fitness_fn)
    return evolve_best(pop, scores)
}

// Verbose version that prints progress
fn evolve_run_verbose(config, bounds, fitness_fn) {
    let pop_size = config[0]
    let gene_length = config[1]
    let generations = config[2]
    let mutation_rate = config[3]

    let mut pop = evolve_init(pop_size, gene_length, bounds)

    let mut gen = 0
    while gen < generations {
        let scores = evolve_eval_all(pop, fitness_fn)
        let best = evolve_best_fitness(scores)
        if gen % 10 == 0 {
            println("  gen " + to_string(gen) + " best_fitness=" + to_string(best))
        }
        pop = evolve_generation(pop, fitness_fn, mutation_rate, bounds)
        gen = gen + 1
    }

    let final_scores = evolve_eval_all(pop, fitness_fn)
    let winner = evolve_best(pop, final_scores)
    println("  gen " + to_string(generations) + " FINAL best_fitness=" + to_string(evolve_best_fitness(final_scores)))
    return winner
}

// ═══════════════════════════════════════
// Self-optimization: evolve parameters for a function
// ═══════════════════════════════════════

// Given a function that takes (params, input) → score,
// find the best params within param_bounds.
// test_inputs = array of inputs to test against (averaged).

fn self_optimize(eval_fn, param_bounds, test_inputs) {
    let gene_length = len(param_bounds)

    // Fitness = average score across all test inputs
    fn fitness(gene) {
        let mut total = 0.0
        let mut i = 0
        while i < len(test_inputs) {
            total = total + eval_fn(gene, test_inputs[i])
            i = i + 1
        }
        return total / len(test_inputs)
    }

    // config: pop=30, gene_length, generations=50, mutation_rate=0.3
    let config = [30, gene_length, 50, 0.3]
    return evolve_run(config, param_bounds, fitness)
}

// Lightweight self-optimize with custom config
fn self_optimize_ex(eval_fn, param_bounds, test_inputs, pop_size, generations) {
    let gene_length = len(param_bounds)

    fn fitness(gene) {
        let mut total = 0.0
        let mut i = 0
        while i < len(test_inputs) {
            total = total + eval_fn(gene, test_inputs[i])
            i = i + 1
        }
        return total / len(test_inputs)
    }

    let config = [pop_size, gene_length, generations, 0.25]
    return evolve_run(config, param_bounds, fitness)
}

// ═══════════════════════════════════════
// C4: Structural admissibility seal (raw 73 paradigm)
// ═══════════════════════════════════════
//
// raw 73 design-strategy-structural-admissibility-paradigm:
// derive @attr-set from semantic metadata via deterministic algebraic
// rules — no search, no fitness loop. closure proven by raw 68 byte-eq
// idempotence (same meta → same attrs across runs).
//
// fn_meta = array of [flag_name, bool_value] pairs:
//   ["pure", true], ["hot", false], ["has_loop", false],
//   ["has_io", false], ["is_const", false]
//
// Returns deterministic-order attr-name string array.

fn evolve_attr_meta_get(meta, key) {
    let mut i = 0
    while i < len(meta) {
        if meta[i][0] == key { return meta[i][1] }
        i = i + 1
    }
    return false
}

fn evolve_attr_seal(meta) {
    // Algebraic rules (raw 73 paradigm — no search):
    //   pure                       -> @const, @memoize, @pure
    //   pure ∧ hot                 -> +@hot, +@inline
    //   pure ∧ has_loop ∧ ¬has_io  -> +@simd, +@vectorize
    //   ¬pure                      -> [] (side-effect risk; opt-in only)
    let is_pure = evolve_attr_meta_get(meta, "pure")
    let is_hot = evolve_attr_meta_get(meta, "hot")
    let has_loop = evolve_attr_meta_get(meta, "has_loop")
    let has_io = evolve_attr_meta_get(meta, "has_io")

    let mut attrs = []
    if is_pure {
        attrs.push("@const")
        attrs.push("@memoize")
        attrs.push("@pure")
        if is_hot {
            attrs.push("@hot")
            attrs.push("@inline")
        }
        if has_loop {
            if !has_io {
                attrs.push("@simd")
                attrs.push("@vectorize")
            }
        }
    }
    return attrs
}

fn evolve_attr_seal_eq(a, b) {
    if len(a) != len(b) { return false }
    let mut i = 0
    while i < len(a) {
        if a[i] != b[i] { return false }
        i = i + 1
    }
    return true
}

fn evolve_attr_seal_idempotent(meta) {
    // raw 68 idempotence-witness: seal(meta) byte-eq across re-runs.
    let r1 = evolve_attr_seal(meta)
    let r2 = evolve_attr_seal(meta)
    return evolve_attr_seal_eq(r1, r2)
}
