// ═══════════════════════════════════════════════════════════
//  self/stdlib/env.hexa — environment-variable convenience layer
//
//  PURPOSE
//    `env(name)` returns "" when a variable is unset, so every
//    consumer hand-rolls one of:
//      let x = env("X"); if x.len() > 0 { ... }
//      let on = env("FLAG") == "1"
//      let n  = env("N"); let v = if n.len() > 0 { to_int(n) } else { 42 }
//    Across anima/qmirror/nexus there are 40+ duplicates of these
//    patterns. This file collapses them into 4 ergonomic helpers.
//
//  CONTRACT
//    env_or(name, default_val: string) -> string
//      Returns env(name) when non-empty, else default_val.
//      Pure passthrough on the empty-string sentinel.
//
//    env_int_or(name, default_val: i64) -> i64
//      Returns parsed env(name) when non-empty + parses cleanly,
//      else default_val. Negative integers supported via to_int.
//
//    env_bool(name) -> bool
//      True iff env(name) (lowercased) is one of:
//        "1" | "true" | "yes" | "on" | "y" | "t"
//      False on "0" | "false" | "no" | "off" | "n" | "f" | unset.
//      Mixed case ("True", "YES", "On") all accepted.
//
//    env_present(name) -> bool
//      True iff env(name) is non-empty (any value).
//
//  EVIDENCE (anima/qmirror duplication)
//    anima/training/watch_a2_fire_13b.hexa:151,166
//    anima/training/launch_alm_a2_tool.hexa:282
//    anima/training/launch_alm_a2_orch.hexa:345
//    anima/training/launch_alm_13b.hexa:377
//    anima/training/download_qwen72b.hexa:230
//    anima/training/alm_a1_preflight.hexa:232
//    anima/training/alm_70b_preflight.hexa:71
//    anima/training/nn_core.hexa:33
//    anima/mirror/qmirror/seed/pull.hexa (this commit cycle)
//    anima/mirror/qmirror/seed/pull_live.hexa (this commit cycle)
//    qmirror/cli/qmirror.hexa:34-35
//    ...and ~30 more in nexus/n6/, hexa-lang/self/.
//
//  RELATIONSHIP TO env() builtin
//    `env(name)` remains the canonical raw accessor — these helpers
//    are pure compositions on top of it. Use env() directly when you
//    need the unset/empty distinction; use these wrappers when you
//    have a default or a typed expectation.
// ═══════════════════════════════════════════════════════════

pub fn env_or(name: string, default_val: string) -> string {
    let v = env(name)
    if v.len() > 0 { return v }
    return default_val
}

// Pure digit check — to_int errors on non-numeric input, so we
// must validate the string shape before parsing.
fn _env_is_int_str(v: string) -> bool {
    if v.len() < 1 { return false }
    let mut i = 0
    if v.substring(0, 1) == "-" {
        if v.len() < 2 { return false }
        i = 1
    }
    while i < v.len() {
        let c = v.substring(i, i + 1)
        if c < "0" { return false }
        if c > "9" { return false }
        i = i + 1
    }
    return true
}

pub fn env_int_or(name: string, default_val: i64) -> i64 {
    let v = env(name)
    if v.len() < 1 { return default_val }
    if !_env_is_int_str(v) { return default_val }
    return to_int(v)
}

pub fn env_bool(name: string) -> bool {
    let v = env(name).to_lower()
    if v == "1" { return true }
    if v == "true" { return true }
    if v == "yes" { return true }
    if v == "on" { return true }
    if v == "y" { return true }
    if v == "t" { return true }
    return false
}

pub fn env_present(name: string) -> bool {
    return env(name).len() > 0
}

// ── Selftest ────────────────────────────────────────────────
//
// Selftest is constructed without depending on actual env state
// since real env varies by host. We exercise the pure-string
// helpers on synthetic inputs via private re-implementations
// that take an explicit value argument. The public env_* fns
// are exercised under the assumption that test cases set/unset
// the test variable beforehand — but we keep the host-touching
// path minimal (one round-trip) to stay robust.

fn _env_or_pure(value: string, default_val: string) -> string {
    if value.len() > 0 { return value }
    return default_val
}

fn _env_int_or_pure(value: string, default_val: i64) -> i64 {
    if value.len() < 1 { return default_val }
    if !_env_is_int_str(value) { return default_val }
    return to_int(value)
}

fn _env_bool_pure(value: string) -> bool {
    let v = value.to_lower()
    if v == "1" { return true }
    if v == "true" { return true }
    if v == "yes" { return true }
    if v == "on" { return true }
    if v == "y" { return true }
    if v == "t" { return true }
    return false
}

fn _env_selftest() -> i64 {
    // T1: env_or — empty -> default, non-empty -> value
    if _env_or_pure("",    "fallback") != "fallback" { eprintln("FAIL T1a"); return 1 }
    if _env_or_pure("set", "fallback") != "set"      { eprintln("FAIL T1b"); return 1 }

    // T2: env_int_or — empty -> default, valid -> parsed, junk -> default
    if _env_int_or_pure("",    42) != 42  { eprintln("FAIL T2a"); return 1 }
    if _env_int_or_pure("17",  42) != 17  { eprintln("FAIL T2b"); return 1 }
    if _env_int_or_pure("0",   42) != 0   { eprintln("FAIL T2c"); return 1 }
    if _env_int_or_pure("-3",  42) != 0 - 3   { eprintln("FAIL T2d"); return 1 }
    if _env_int_or_pure("abc", 42) != 42  { eprintln("FAIL T2e"); return 1 }

    // T3: env_bool — truthy variants
    if !_env_bool_pure("1")    { eprintln("FAIL T3a"); return 1 }
    if !_env_bool_pure("true") { eprintln("FAIL T3b"); return 1 }
    if !_env_bool_pure("YES")  { eprintln("FAIL T3c"); return 1 }
    if !_env_bool_pure("On")   { eprintln("FAIL T3d"); return 1 }
    if !_env_bool_pure("y")    { eprintln("FAIL T3e"); return 1 }
    if !_env_bool_pure("T")    { eprintln("FAIL T3f"); return 1 }

    // T4: env_bool — falsy variants
    if _env_bool_pure("")      { eprintln("FAIL T4a"); return 1 }
    if _env_bool_pure("0")     { eprintln("FAIL T4b"); return 1 }
    if _env_bool_pure("false") { eprintln("FAIL T4c"); return 1 }
    if _env_bool_pure("no")    { eprintln("FAIL T4d"); return 1 }
    if _env_bool_pure("off")   { eprintln("FAIL T4e"); return 1 }
    if _env_bool_pure("garbage") { eprintln("FAIL T4f"); return 1 }

    // T5: round-trip via env() — relies on env("PATH") existing
    //     on every reasonable host (POSIX guarantee).
    if !env_present("PATH") { eprintln("FAIL T5a — PATH unset?"); return 1 }
    if env_or("PATH", "MISSING") == "MISSING" { eprintln("FAIL T5b"); return 1 }

    // T6: env_or with absent var → default returned
    if env_or("__HEXA_UNSET_VAR_FOR_SELFTEST__", "default") != "default" {
        eprintln("FAIL T6"); return 1
    }
    if env_present("__HEXA_UNSET_VAR_FOR_SELFTEST__") {
        eprintln("FAIL T6b"); return 1
    }

    println("__ENV_SELFTEST__ PASS")
    return 0
}

// Run selftest only when invoked directly with --selftest, matching
// flags.hexa convention (so `use "self/stdlib/env"` consumers do not
// trigger the test harness).
let _env_args = args()
let mut _env_selftest_flag = false
let mut _env_i = 0
while _env_i < len(_env_args) {
    if _env_args[_env_i] == "--selftest" { _env_selftest_flag = true }
    if _env_args[_env_i].ends_with("/stdlib/env.hexa") {
        // Direct invocation — also run selftest if no other flags.
        let mut _env_j = _env_i + 1
        let mut _env_more = false
        while _env_j < len(_env_args) {
            if _env_args[_env_j].len() > 0 { _env_more = true }
            _env_j = _env_j + 1
        }
        if !_env_more { _env_selftest_flag = true }
    }
    _env_i = _env_i + 1
}
if _env_selftest_flag {
    exit(_env_selftest())
}
