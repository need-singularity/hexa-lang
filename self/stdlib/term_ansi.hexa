// ═══════════════════════════════════════════════════════════════════════
//  self/stdlib/term_ansi.hexa — ANSI/VT escape sequence emitters
//
//  PURPOSE
//      Pure-string ANSI escape builder. NO I/O — caller is responsible
//      for `print()` / `term_write()`. Centralizes the magic numbers
//      currently hard-coded across hive packages/tui/src as
//      "\x1b[…" literals (~95 occurrences in terminal.ts +
//      terminal-image.ts + tui.ts). Cross-repo invariant: every
//      future module that emits ANSI MUST import this module.
//
//  EXPORTS (composer family — all return strings)
//      ansi_esc()                  -> "\x1b"
//      ansi_csi()                  -> "\x1b["
//      ansi_osc()                  -> "\x1b]"
//      ansi_st()                   -> "\x1b\\"   // String Terminator
//      ansi_bel()                  -> "\x07"
//      ansi_sgr(code: i64)         -> "\x1b[<code>m"
//      ansi_sgr2(a, b)             -> "\x1b[<a>;<b>m"
//      ansi_clear_screen()         -> "\x1b[2J"
//      ansi_clear_line()           -> "\x1b[2K"
//      ansi_clear_to_eol()         -> "\x1b[K"
//      ansi_clear_to_eos()         -> "\x1b[J"
//      ansi_move_to(row, col)      -> "\x1b[<row>;<col>H" (1-based)
//      ansi_move_up(n)             -> "\x1b[<n>A"
//      ansi_move_down(n)           -> "\x1b[<n>B"
//      ansi_move_right(n)          -> "\x1b[<n>C"
//      ansi_move_left(n)           -> "\x1b[<n>D"
//      ansi_save_cursor()          -> "\x1b7"
//      ansi_restore_cursor()       -> "\x1b8"
//      ansi_hide_cursor()          -> "\x1b[?25l"
//      ansi_show_cursor()          -> "\x1b[?25h"
//      ansi_alt_screen_on()        -> "\x1b[?1049h"
//      ansi_alt_screen_off()       -> "\x1b[?1049l"
//      ansi_reset()                -> "\x1b[0m"
//      ansi_set_title(t: string)   -> "\x1b]0;<t>\x07"
//      ansi_strip(s: string)       -> string (visible-only)
//
//  CAVEATS
//      * ansi_strip is best-effort: handles CSI (\x1b[…<final>) and
//        OSC (\x1b]…BEL or ST). Does NOT handle DCS/PM/APC strings
//        (rare). SS2/SS3 single-char are stripped as 2-byte.
//      * Numeric args are bounded by call site; no clamping here.
//      * No color helpers — see term_style.hexa.
//
//  RAW 159 UPSTREAM GAP
//      ESC literal `\x1b` is not directly expressible in current
//      hexa string literal grammar without runtime support. We
//      construct it via from_char_code(27). When hexa adds \xNN
//      string escapes, replace _ESC_ definition for ~10x speedup.
//
//  USAGE
//      use "self/stdlib/term_ansi"
//      print(ansi_clear_screen() + ansi_move_to(1, 1))
//      print(ansi_sgr(31) + "red text" + ansi_reset())
//
//  --selftest:
//      hexa run self/stdlib/term_ansi.hexa --selftest
//        → __TERM_ANSI_SELFTEST__ <PASS|FAIL> n=<N> fail=<M>
// ═══════════════════════════════════════════════════════════════════════

// ── Core constants ────────────────────────────────────────────────
// ESC = 0x1b. BEL = 0x07. Built from char codes since hexa string
// literals don't currently support \xNN (raw 159 upstream gap).
fn _esc() -> string { return from_char_code(27) }
fn _bel_ch() -> string { return from_char_code(7) }
fn _bs_ch() -> string { return from_char_code(8) }

pub fn ansi_esc() -> string { return _esc() }
pub fn ansi_csi() -> string { return _esc() + "[" }
pub fn ansi_osc() -> string { return _esc() + "]" }
pub fn ansi_st() -> string { return _esc() + "\\" }
pub fn ansi_bel() -> string { return _bel_ch() }

// ── SGR (Select Graphic Rendition) ────────────────────────────────
pub fn ansi_sgr(code: i64) -> string {
    return ansi_csi() + to_string(code) + "m"
}
pub fn ansi_sgr2(a: i64, b: i64) -> string {
    return ansi_csi() + to_string(a) + ";" + to_string(b) + "m"
}
pub fn ansi_reset() -> string { return ansi_csi() + "0m" }

// ── Clear ─────────────────────────────────────────────────────────
pub fn ansi_clear_screen() -> string { return ansi_csi() + "2J" }
pub fn ansi_clear_line() -> string { return ansi_csi() + "2K" }
pub fn ansi_clear_to_eol() -> string { return ansi_csi() + "K" }
pub fn ansi_clear_to_eos() -> string { return ansi_csi() + "J" }
pub fn ansi_clear_to_bos() -> string { return ansi_csi() + "1J" }

// ── Cursor movement ───────────────────────────────────────────────
pub fn ansi_move_to(row: i64, col: i64) -> string {
    return ansi_csi() + to_string(row) + ";" + to_string(col) + "H"
}
pub fn ansi_move_up(n: i64) -> string {
    if n <= 0 { return "" }
    return ansi_csi() + to_string(n) + "A"
}
pub fn ansi_move_down(n: i64) -> string {
    if n <= 0 { return "" }
    return ansi_csi() + to_string(n) + "B"
}
pub fn ansi_move_right(n: i64) -> string {
    if n <= 0 { return "" }
    return ansi_csi() + to_string(n) + "C"
}
pub fn ansi_move_left(n: i64) -> string {
    if n <= 0 { return "" }
    return ansi_csi() + to_string(n) + "D"
}

// ── Cursor save/show/hide ─────────────────────────────────────────
pub fn ansi_save_cursor() -> string { return _esc() + "7" }
pub fn ansi_restore_cursor() -> string { return _esc() + "8" }
pub fn ansi_hide_cursor() -> string { return ansi_csi() + "?25l" }
pub fn ansi_show_cursor() -> string { return ansi_csi() + "?25h" }

// ── Alt screen ────────────────────────────────────────────────────
pub fn ansi_alt_screen_on() -> string { return ansi_csi() + "?1049h" }
pub fn ansi_alt_screen_off() -> string { return ansi_csi() + "?1049l" }

// ── Window title (OSC 0) ──────────────────────────────────────────
pub fn ansi_set_title(t: string) -> string {
    return ansi_osc() + "0;" + t + ansi_bel()
}

// ── ansi_strip — remove escape sequences for width calc ───────────
// Handles CSI (\x1b[…<final>), OSC (\x1b]…BEL or ST). Bare ESC
// followed by 1 char (SS2/SS3/etc) is consumed as 2-byte. Does NOT
// strip DCS/PM/APC strings (uncommon in TUI output).
pub fn ansi_strip(s: string) -> string {
    let n = len(s)
    if n == 0 { return s }
    let esc = _esc()
    let bel = _bel_ch()
    let mut out = ""
    let mut i = 0
    while i < n {
        let ch = s.substring(i, i + 1)
        if ch == esc {
            // Need next char to disambiguate.
            if i + 1 >= n { i = i + 1 } // bare ESC at end — drop
            else {
                let nx = s.substring(i + 1, i + 2)
                if nx == "[" {
                    // CSI: ESC [ params final-byte (0x40..0x7E)
                    i = i + 2
                    while i < n {
                        let c = s.substring(i, i + 1)
                        let cc = char_code(c)
                        if cc >= 64 && cc <= 126 { i = i + 1; break }
                        i = i + 1
                    }
                } else if nx == "]" {
                    // OSC: ESC ] params (BEL or ESC \) terminator
                    i = i + 2
                    while i < n {
                        let c = s.substring(i, i + 1)
                        if c == bel { i = i + 1; break }
                        if c == esc {
                            // Possible ST = ESC \
                            if i + 1 < n && s.substring(i + 1, i + 2) == "\\" {
                                i = i + 2
                                break
                            }
                            i = i + 1
                        } else {
                            i = i + 1
                        }
                    }
                } else {
                    // 2-byte sequence (SS2/SS3/=/>/7/8 etc): drop both
                    i = i + 2
                }
            }
        } else {
            out = out + ch
            i = i + 1
        }
    }
    return out
}

// ── --selftest ─────────────────────────────────────────────────────
fn _ansi_selftest() {
    let mut fail = 0
    let mut n = 0
    let esc = _esc()

    // 1. ansi_esc
    n = n + 1
    if ansi_esc() != esc { eprintln("FAIL 1"); fail = fail + 1 }

    // 2. ansi_csi
    n = n + 1
    if ansi_csi() != esc + "[" { eprintln("FAIL 2"); fail = fail + 1 }

    // 3. ansi_sgr
    n = n + 1
    if ansi_sgr(31) != esc + "[31m" { eprintln("FAIL 3 got=" + ansi_sgr(31)); fail = fail + 1 }

    // 4. ansi_sgr2
    n = n + 1
    if ansi_sgr2(1, 31) != esc + "[1;31m" { eprintln("FAIL 4"); fail = fail + 1 }

    // 5. clear ops
    n = n + 1
    if ansi_clear_screen() != esc + "[2J" { eprintln("FAIL 5a"); fail = fail + 1 }
    n = n + 1
    if ansi_clear_line() != esc + "[2K" { eprintln("FAIL 5b"); fail = fail + 1 }
    n = n + 1
    if ansi_clear_to_eol() != esc + "[K" { eprintln("FAIL 5c"); fail = fail + 1 }

    // 6. move
    n = n + 1
    if ansi_move_to(5, 10) != esc + "[5;10H" { eprintln("FAIL 6a"); fail = fail + 1 }
    n = n + 1
    if ansi_move_up(3) != esc + "[3A" { eprintln("FAIL 6b"); fail = fail + 1 }
    n = n + 1
    if ansi_move_down(0) != "" { eprintln("FAIL 6c (zero should noop)"); fail = fail + 1 }

    // 7. cursor
    n = n + 1
    if ansi_hide_cursor() != esc + "[?25l" { eprintln("FAIL 7a"); fail = fail + 1 }
    n = n + 1
    if ansi_show_cursor() != esc + "[?25h" { eprintln("FAIL 7b"); fail = fail + 1 }
    n = n + 1
    if ansi_save_cursor() != esc + "7" { eprintln("FAIL 7c"); fail = fail + 1 }

    // 8. alt screen
    n = n + 1
    if ansi_alt_screen_on() != esc + "[?1049h" { eprintln("FAIL 8a"); fail = fail + 1 }
    n = n + 1
    if ansi_alt_screen_off() != esc + "[?1049l" { eprintln("FAIL 8b"); fail = fail + 1 }

    // 9. set_title
    n = n + 1
    let title = ansi_set_title("hi")
    if title != esc + "]0;hi" + _bel_ch() { eprintln("FAIL 9"); fail = fail + 1 }

    // 10. ansi_strip — visible only
    n = n + 1
    let s = ansi_sgr(31) + "red" + ansi_reset() + " plain"
    if ansi_strip(s) != "red plain" { eprintln("FAIL 10 got=" + ansi_strip(s)); fail = fail + 1 }

    // 11. ansi_strip — OSC sequence
    n = n + 1
    let s2 = ansi_set_title("X") + "after"
    if ansi_strip(s2) != "after" { eprintln("FAIL 11 got=" + ansi_strip(s2)); fail = fail + 1 }

    // 12. ansi_strip — empty / no escape
    n = n + 1
    if ansi_strip("hello") != "hello" { eprintln("FAIL 12a"); fail = fail + 1 }
    n = n + 1
    if ansi_strip("") != "" { eprintln("FAIL 12b"); fail = fail + 1 }

    // 13. ansi_reset
    n = n + 1
    if ansi_reset() != esc + "[0m" { eprintln("FAIL 13"); fail = fail + 1 }

    if fail == 0 {
        println("__TERM_ANSI_SELFTEST__ PASS n=" + to_string(n) + " fail=0")
    } else {
        println("__TERM_ANSI_SELFTEST__ FAIL n=" + to_string(n) + " fail=" + to_string(fail))
    }
}

let _tansi_argv = args()
let mut _tansi_st = false
let mut _tansi_ai = 0
while _tansi_ai < len(_tansi_argv) {
    if _tansi_argv[_tansi_ai] == "--selftest-term-ansi" { _tansi_st = true }
    if _tansi_argv[_tansi_ai] == "--selftest" {
        let mut _tansi_aj = 0
        while _tansi_aj < len(_tansi_argv) {
            if _tansi_argv[_tansi_aj].ends_with("/stdlib/term_ansi.hexa") { _tansi_st = true }
            _tansi_aj = _tansi_aj + 1
        }
    }
    _tansi_ai = _tansi_ai + 1
}
if _tansi_st {
    _ansi_selftest()
}
