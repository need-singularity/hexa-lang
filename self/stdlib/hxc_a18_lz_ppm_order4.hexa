#!hexa strict

// @resolver-bypass(reason="darwin-native byte-canonical pipeline")
// @tool(slug="hxc-a18-lz-ppm-order4", desc="HXC algorithm A18: LZ77 sliding-window prefilter + PPMd-style order-4 context modeling. Layered on top of A17 (order-3 ceiling ~87%) targeting Shannon H_4 = 0.813 bit/byte → 90% asymptotic entropy rate. Pure hexa raw 9 + raw 18 self-host (integer-only, table-driven, no external libs, no neural mixer per raw 137). PARTIAL — first cron tick = design doc + struct skeleton + PPM order-4 PASS 1 build + 1 selftest fixture (~150 LoC). LZ match emission + range coder encode/decode + 5 selftests + LIVE FIRE deferred to follow-on ticks. raw 91 honest C3 disclosure: ~150 LoC of ~900 LoC final.")
// @usage(hexa /Users/ghost/core/hexa-lang/self/stdlib/hxc_a18_lz_ppm_order4.hexa --selftest)
// @usage(hexa /Users/ghost/core/hexa-lang/self/stdlib/hxc_a18_lz_ppm_order4.hexa build <in>)
// @exit_codes(0=ok, 1=selftest-fail, 2=io-error, 3=bad-args, 9=not-yet-implemented)
//
// Spec (full algorithm — only PASS 1 build + LZ struct + lookup landed this tick):
//
//   Stage 1 — LZ77 sliding-window prefilter (DEFERRED emission):
//     For each position p in [0..len-1]:
//       compute h = hash3(buf[p..p+3])
//       walk hash_prev[hash_head[h]] chain (bounded A18_MAX_CHAIN=32 hops):
//         find longest match m in [max(0, p-W), p) with len >= A18_MIN_MATCH (3)
//       if m: emit (offset, length); skip p forward by length
//       else: emit literal buf[p]; advance by 1
//       insert position p into hash_head[h]
//
//   Stage 2 — PPM order-4 (extends A17 order-0..order-3 to order-0..order-4):
//     For each literal byte from stage 1:
//       try order-4 → escape-D → order-3 → ... → order-0 → raw uniform
//     Escape-method-D unchanged from A17.
//
// Sigil: `^L<lz-stream>^P<ppm-residual>` — two-segment combined stream.
//
// Idempotency contract (raw 65 + 68):
//     - encode(decode(x)) == x for any A18 stream
//     - decode(encode(y)) == y for any byte stream
//
// Falsifiers preregistered (raw 71):
//     F-A18-1: saving < 0.85 on text-heavy fixture (90% target with margin) → reject.
//     F-A18-2: encode/decode round-trip not byte-eq → reject.
//     F-A18-3: encode latency > 500ms per 1KB (LZ + PPM combined) → reject.
//     F-A18-4: window memory > 100MB on 10MB input → reject.

const A18_ORDER_MAX = 4
const A18_ALPHABET = 256
const A18_RAW_BITS_PER_BYTE = 8
const A18_WINDOW_BITS = 15        // 32 KB sliding window (1 << 15)
const A18_WINDOW_SIZE = 32768
const A18_HASH_SIZE = 16384       // 2^14 hash slots
const A18_MIN_MATCH = 3           // LZ77 minimum match length
const A18_MAX_CHAIN = 32          // hash chain walk bound (F-A18-3 latency cap)

// _byte_at: 1-byte substring at position i (byte-canonical handle).
fn _byte_at(s: string, i: int) -> string {
    if i < 0 || i >= len(s) { return "" }
    return s.substring(i, i + 1)
}

// _ctx_at: k-byte context ending just before position p ("" if underflow).
fn _ctx_at(s: string, p: int, k: int) -> string {
    if p - k < 0 { return "" }
    return s.substring(p - k, p)
}

// _byte_ord: integer ordinal of a 1-byte string. Replaces ord() since hexa
// stdlib lacks it; we substring-compare against a 256-byte canonical table.
// For PASS 1 build we only need byte equality, which substring already gives.
// Hash of 3-byte string uses character-wise integer accumulation.
fn _hash3(s: string, p: int) -> int {
    if p + 3 > len(s) { return 0 }
    let b0 = s.substring(p, p + 1)
    let b1 = s.substring(p + 1, p + 2)
    let b2 = s.substring(p + 2, p + 3)
    // Pseudo-ord via length of accumulated string. Stable, integer-only,
    // collision-tolerant within 16K slot count.
    let mut h = 0
    let mut i = 0
    while i < len(b0) { h = (h * 31 + i + 1); i = i + 1 }
    let mut j = 0
    while j < len(b1) { h = (h * 31 + j + 7); j = j + 1 }
    let mut k = 0
    while k < len(b2) { h = (h * 31 + k + 13); k = k + 1 }
    // Collapse multi-byte fold: also incorporate substring identity hash via
    // length sum (proxy for ord). Good enough for chain bucketing; PASS 2
    // emission will replace this with a true byte-ord table.
    if h < 0 { h = -h }
    return h % A18_HASH_SIZE
}

// _table_inc / _total / _distinct / _count — same shape as A17, reused so
// A17 PPM stream remains forward-compatible (raw 65 + 68 invariant).
fn _table_inc(tbl, ctx: string, sym: string) -> int {
    let inner = if map_contains_key(tbl, ctx) { tbl[ctx] } else { {} }
    let cur = if map_contains_key(inner, sym) { inner[sym] } else { 0 }
    inner[sym] = cur + 1
    tbl[ctx] = inner
    return 0
}

fn _table_total(tbl, ctx: string) -> int {
    if !map_contains_key(tbl, ctx) { return 0 }
    let inner = tbl[ctx]
    let mut t = 0
    let keys = map_keys(inner)
    let mut i = 0
    while i < len(keys) { t = t + inner[keys[i]]; i = i + 1 }
    return t
}

fn _table_distinct(tbl, ctx: string) -> int {
    if !map_contains_key(tbl, ctx) { return 0 }
    return len(map_keys(tbl[ctx]))
}

fn _table_count(tbl, ctx: string, sym: string) -> int {
    if !map_contains_key(tbl, ctx) { return 0 }
    let inner = tbl[ctx]
    if !map_contains_key(inner, sym) { return 0 }
    return inner[sym]
}

// a18_build: PASS 1 build of all 5 PPM order tables (0..4). Returns array
// [order0, order1, order2, order3, order4]. LZ hash structures built lazily
// during encode (Stage 1) — not needed for PASS 1 model build.
fn a18_build(buf: string) -> array {
    let order0 = {}
    let order1 = {}
    let order2 = {}
    let order3 = {}
    let order4 = {}
    let n = len(buf)
    let mut p = 0
    while p < n {
        let sym = _byte_at(buf, p)
        let _r0 = _table_inc(order0, "", sym)
        if p >= 1 { let _r1 = _table_inc(order1, _ctx_at(buf, p, 1), sym) }
        if p >= 2 { let _r2 = _table_inc(order2, _ctx_at(buf, p, 2), sym) }
        if p >= 3 { let _r3 = _table_inc(order3, _ctx_at(buf, p, 3), sym) }
        if p >= 4 { let _r4 = _table_inc(order4, _ctx_at(buf, p, 4), sym) }
        p = p + 1
    }
    return [order0, order1, order2, order3, order4]
}

// a18_lookup: walk order-4 → order-0 returning first hit's order. -1 = raw.
fn a18_lookup(tables: array, buf: string, p: int) -> int {
    let sym = _byte_at(buf, p)
    if p >= 4 {
        let c4 = _ctx_at(buf, p, 4)
        if _table_count(tables[4], c4, sym) > 0 { return 4 }
    }
    if p >= 3 {
        let c3 = _ctx_at(buf, p, 3)
        if _table_count(tables[3], c3, sym) > 0 { return 3 }
    }
    if p >= 2 {
        let c2 = _ctx_at(buf, p, 2)
        if _table_count(tables[2], c2, sym) > 0 { return 2 }
    }
    if p >= 1 {
        let c1 = _ctx_at(buf, p, 1)
        if _table_count(tables[1], c1, sym) > 0 { return 1 }
    }
    if _table_count(tables[0], "", sym) > 0 { return 0 }
    return -1
}

// a18_lz_match_stub: STUB for Stage-1 LZ match search. Returns longest match
// length found within the window, or 0 if no match >= A18_MIN_MATCH. Greedy
// parsing only; lazy parsing deferred. PASS 2 emission DEFERRED.
fn a18_lz_match_stub(buf: string, p: int) -> int {
    let n = len(buf)
    if p + A18_MIN_MATCH > n { return 0 }
    let lo = if p > A18_WINDOW_SIZE { p - A18_WINDOW_SIZE } else { 0 }
    let mut best = 0
    let mut q = lo
    let mut hops = 0
    while q < p && hops < A18_MAX_CHAIN {
        // naive substring compare; PASS 2 replaces with hash-chain walk.
        let mut m = 0
        while p + m < n && q + m < p && _byte_at(buf, q + m) == _byte_at(buf, p + m) {
            m = m + 1
            if m >= 258 { break }
        }
        if m >= A18_MIN_MATCH && m > best { best = m }
        q = q + 1
        hops = hops + 1
    }
    return best
}

// _ilog2_ceil: integer log2 ceiling (same as A17, ±1 bit accuracy).
fn _ilog2_ceil(x: int) -> int {
    if x <= 1 { return 0 }
    let mut b = 0
    let mut v = x - 1
    while v > 0 { b = b + 1; v = v / 2 }
    return b
}

// a18_estimate_bits: in-sample bound combining LZ-saved bytes + PPM order-4
// residual cost. PASS 2 range coding closes the residual ±1 bit gap.
fn a18_estimate_bits(tables: array, buf: string) -> int {
    let n = len(buf)
    let mut total_bits = 0
    let mut p = 0
    while p < n {
        // Stage 1: LZ stub — credit a match if found (offset+length cost ~24 bits)
        let m = a18_lz_match_stub(buf, p)
        if m >= A18_MIN_MATCH {
            // approx LZ emission: ~24 bits for (offset, length) pair
            total_bits = total_bits + 24
            p = p + m
            continue
        }
        // Stage 2: PPM order-4 lookup for literal byte
        if p < A18_ORDER_MAX {
            total_bits = total_bits + A18_RAW_BITS_PER_BYTE
        } else {
            let order = a18_lookup(tables, buf, p)
            if order < 0 {
                total_bits = total_bits + A18_RAW_BITS_PER_BYTE
            } else {
                let ctx = _ctx_at(buf, p, order)
                let sym = _byte_at(buf, p)
                let cnt = _table_count(tables[order], ctx, sym)
                let tot = _table_total(tables[order], ctx)
                let dis = _table_distinct(tables[order], ctx)
                let ratio = if cnt > 0 { (tot + dis) / cnt } else { tot + dis }
                let bits_sym = _ilog2_ceil(ratio + 1)
                let bits_esc = (A18_ORDER_MAX - order)
                total_bits = total_bits + bits_sym + bits_esc
            }
        }
        p = p + 1
    }
    return total_bits
}

fn a18_estimate_bytes(tables: array, buf: string) -> int {
    let bits = a18_estimate_bits(tables, buf)
    return (bits + 7) / 8
}

fn _selftest() -> int {
    println("# hxc_a18_lz_ppm_order4 selftest (PARTIAL — first cron tick)")
    let mut pass = 0
    let mut fail = 0

    // Fixture: synthetic text repetition — long-range LZ + order-4 PPM should
    // saturate well past A17's 87% ceiling. ~50 cycles of 20-byte phrase.
    let phrase = "the quick brown fox "
    let mut buf = ""
    let mut k = 0
    while k < 50 { buf = buf + phrase; k = k + 1 }
    let raw_bytes = len(buf)

    let tables = a18_build(buf)

    // Test 1: order-4 table populated.
    let n4 = len(map_keys(tables[4]))
    if n4 > 0 { pass = pass + 1; println("  PASS: order-4 contexts seen = " + to_string(n4)) }
    else { fail = fail + 1; println("  FAIL: order-4 table empty") }

    // Test 2: lookup hits order-4 mid-stream.
    let lo = a18_lookup(tables, buf, 100)
    if lo == 4 { pass = pass + 1; println("  PASS: mid-stream lookup hit at order-4") }
    else { fail = fail + 1; println("  FAIL: lookup returned order=" + to_string(lo)) }

    // Test 3: LZ stub finds a long match on repetitive fixture.
    let m = a18_lz_match_stub(buf, 40)
    if m >= A18_MIN_MATCH { pass = pass + 1; println("  PASS: LZ match len=" + to_string(m) + " at p=40") }
    else { fail = fail + 1; println("  FAIL: LZ stub returned " + to_string(m)) }

    // Test 4: combined estimate projection >= 85% (F-A18-1 with 5pp dev margin).
    let est_bytes = a18_estimate_bytes(tables, buf)
    let saving_pct = ((raw_bytes - est_bytes) * 100) / raw_bytes
    if saving_pct >= 85 {
        pass = pass + 1
        println("  PASS: in-sample bound " + to_string(raw_bytes) + " -> "
                + to_string(est_bytes) + " B (" + to_string(saving_pct) + "% saving, target 90%)")
    } else {
        fail = fail + 1
        println("  FAIL: saving only " + to_string(saving_pct) + "% (want >=85)")
    }

    println("Results: " + to_string(pass) + " PASS / " + to_string(fail) + " FAIL")
    println("__HXC_A18_SELFTEST__ " + (if fail == 0 { "PASS" } else { "FAIL" })
            + " (PARTIAL: PASS 1 + LZ stub only; emission/decode deferred)")
    if fail == 0 { return 0 }
    return 1
}

fn main() {
    let av = argv()
    let mut has_selftest = false
    let mut has_build = false
    let mut k = 0
    while k < len(av) {
        if av[k] == "--selftest" { has_selftest = true }
        if av[k] == "build" { has_build = true }
        k = k + 1
    }
    if has_selftest { exit(_selftest()) }
    if has_build {
        let mut sub_idx = 0
        let mut q = 0
        while q < len(av) {
            if av[q] == "build" { sub_idx = q; break }
            q = q + 1
        }
        if sub_idx + 1 >= len(av) {
            eprintln("usage: hexa hxc_a18_lz_ppm_order4.hexa build <in>")
            exit(3)
        }
        let txt = read_file(av[sub_idx + 1])
        let tables = a18_build(txt)
        let est = a18_estimate_bytes(tables, txt)
        println("raw=" + to_string(len(txt)) + " est=" + to_string(est)
                + " saving=" + to_string(((len(txt) - est) * 100) / len(txt)) + "%")
        exit(0)
    }
    eprintln("# A18 encode/decode NOT YET IMPLEMENTED — first cron tick = PASS 1 + LZ stub only.")
    eprintln("usage: hexa hxc_a18_lz_ppm_order4.hexa [--selftest | build <in>]")
    exit(9)
}
