// 80% target ACHIEVABLE on success. Falsifiers F-A18-V6-1..4 above.

const A18_ORDER_MAX = 4
const A18_ALPHABET = 256
const A18_RAW_BITS_PER_BYTE = 8
const A18_WINDOW_BITS = 15        // 32 KB sliding window (1 << 15)
const A18_WINDOW_SIZE = 32768
const A18_HASH_SIZE = 16384       // 2^14 hash slots
const A18_MIN_MATCH = 3           // LZ77 minimum match length
const A18_MAX_MATCH = 258         // LZ77 maximum match length (deflate-compatible)
const A18_MAX_CHAIN = 32          // hash chain walk bound (F-A18-3 latency cap)
const A18_MIN_BYTES = 32          // below this: identity passthrough
const A18_TOP = 4294967296        // 2^32
const A18_BOT = 16777216          // 2^24
const A18_MAX_FREQ_TOTAL = 16777215   // 2^24 - 1, keeps range/total in 32-bit

// Token alphabet: 0..255 literal bytes; 256..511 length codes (len = code-256+3,
// covers 3..258); literal/match disambiguated by tag-bit pair (we serialize
// length-distance pairs as 2 extra varint bytes after a length code).
const A18_TOKEN_ALPHABET = 512
const A18_LIT_MAX = 256           // tokens [0..255] are literal bytes

// v3 wire (raw 137 80% Pareto per-class CEILING ω-cycle, 2026-04-28):
// hashed order-3 byte-context adaptive range coder. Bucket count 4096 keeps
// memory at 4096 × 512 × 4B ≈ 8MB peak (F-A18-V3-2 budget < 200MB). Bucket
// id is computed by hashing the last 3 emitted-token bytes mod buckets;
// when fewer than 3 tokens have been emitted, we fall back to the v2 active
// context. Decoder mirrors exact same bucket selection — collisions are
// implicit context blending and are byte-eq-safe by construction.
const A18_V3_BUCKETS = 4096
const A18_V3_BUCKET_BITS = 12     // log2(4096); used in fast modulo path
const A18_V3_HASH_MUL = 2654435761  // Knuth multiplicative (mod 2^32 implicit)

// v3-order-2 wire (raw 137 80% Pareto text-heavy CEILING close, 2026-04-28):
// 256 buckets keyed by hash of last 2 emitted tokens. Memory: 256 × 512 × 4B
// ≈ 524 KB peak (F-A18-V3-ORDER2-4 budget < 50 MB). Sweet spot between v2
// (single token context, saturated) and v3 order-3 (warm-up fail at
// production sizes). On 79 KB text-heavy: ~120 tokens/bucket = sufficient
// adaptive signal.
const A18_V3_O2_BUCKETS = 256
const A18_V3_O2_BUCKET_BITS = 8   // log2(256)

// v4-window64 wire (raw 137 80% Pareto FINAL CLOSE, 2026-04-28):
// LZ77 sliding window enlarged 32KB → 64KB. Wire token format reuses
// v1/v2/v3 (d_hi, d_lo) 2-byte distance, which can address 0..65535 —
// exactly fits 64KB. Hash table also 2× to 32768 slots to keep average
// chain length proportional. The entropy coder reused for v4 is the v2
// order-1 byte-context coder (winner among order-axis variants per
// a105829b). Algorithmically NEW dimension: window-size axis, not order.
const A18_V4_WINDOW_BITS = 16        // 64 KB sliding window (1 << 16)
const A18_V4_WINDOW_SIZE = 65536
const A18_V4_HASH_SIZE = 32768       // 2^15 hash slots (2× v1-v3-o2)

// Wire base64url alphabet — same as A16/A17 for canonical interop.
const A18_B64_ALPHA = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789-_"

// ───────────────── byte / context handles ─────────────────

fn _byte_at(s: string, i: int) -> string {
    if i < 0 || i >= len(s) { return "" }
    return s.substring(i, i + 1)
}

fn _ctx_at(s: string, p: int, k: int) -> string {
    if p - k < 0 { return "" }
    return s.substring(p - k, p)
}

// _hash3: integer hash of 3 bytes at position p in s. Uses ord() for true
// byte values (PASS 1 stub used substring length proxy). Stable, integer-only.
fn _hash3_real(s: string, p: int) -> int {
    if p + 3 > len(s) { return 0 }
    let b0: i64 = ord(s.substring(p, p + 1))
    let b1: i64 = ord(s.substring(p + 1, p + 2))
    let b2: i64 = ord(s.substring(p + 2, p + 3))
    let h: i64 = ((b0 * 31 + b1) * 31 + b2)
    let m: i64 = h - (h / A18_HASH_SIZE) * A18_HASH_SIZE
    if m < 0 { return m + A18_HASH_SIZE }
    return m
}

// Backwards-compat shim used by PASS-1 selftest fixture.
fn _hash3(s: string, p: int) -> int { return _hash3_real(s, p) }

// ───────────────── PPM order-0..4 table primitives (shared with A17 shape) ─────────────────

fn _table_inc(tbl, ctx: string, sym: string) -> int {
    let inner = if map_contains_key(tbl, ctx) { tbl[ctx] } else { {} }
    let cur = if map_contains_key(inner, sym) { inner[sym] } else { 0 }
    inner[sym] = cur + 1
    tbl[ctx] = inner
    return 0
}

fn _table_total(tbl, ctx: string) -> int {
    if !map_contains_key(tbl, ctx) { return 0 }
    let inner = tbl[ctx]
    let mut t = 0
    let keys = map_keys(inner)
    let mut i = 0
    while i < len(keys) { t = t + inner[keys[i]]; i = i + 1 }
    return t
}

fn _table_distinct(tbl, ctx: string) -> int {
    if !map_contains_key(tbl, ctx) { return 0 }
    return len(map_keys(tbl[ctx]))
}

fn _table_count(tbl, ctx: string, sym: string) -> int {
    if !map_contains_key(tbl, ctx) { return 0 }
    let inner = tbl[ctx]
    if !map_contains_key(inner, sym) { return 0 }
    return inner[sym]
}

// a18_build: PASS 1 build of all 5 PPM order tables (0..4).
fn a18_build(buf: string) -> array {
    let order0 = {}
    let order1 = {}
    let order2 = {}
    let order3 = {}
    let order4 = {}
    let n = len(buf)
    let mut p = 0
    while p < n {
        let sym = _byte_at(buf, p)
        let _r0 = _table_inc(order0, "", sym)
        if p >= 1 { let _r1 = _table_inc(order1, _ctx_at(buf, p, 1), sym) }
        if p >= 2 { let _r2 = _table_inc(order2, _ctx_at(buf, p, 2), sym) }
        if p >= 3 { let _r3 = _table_inc(order3, _ctx_at(buf, p, 3), sym) }
        if p >= 4 { let _r4 = _table_inc(order4, _ctx_at(buf, p, 4), sym) }
        p = p + 1
    }
    return [order0, order1, order2, order3, order4]
}

// a18_lookup: walk order-4 → order-0 returning first hit's order. -1 = raw.
fn a18_lookup(tables: array, buf: string, p: int) -> int {
    let sym = _byte_at(buf, p)
    if p >= 4 {
        let c4 = _ctx_at(buf, p, 4)
        if _table_count(tables[4], c4, sym) > 0 { return 4 }
    }
    if p >= 3 {
        let c3 = _ctx_at(buf, p, 3)
        if _table_count(tables[3], c3, sym) > 0 { return 3 }
    }
    if p >= 2 {
        let c2 = _ctx_at(buf, p, 2)
        if _table_count(tables[2], c2, sym) > 0 { return 2 }
    }
    if p >= 1 {
        let c1 = _ctx_at(buf, p, 1)
        if _table_count(tables[1], c1, sym) > 0 { return 1 }
    }
    if _table_count(tables[0], "", sym) > 0 { return 0 }
    return -1
}

// ───────────────── LZ77 hash-chain match finder (PASS 2 emission) ─────────────────

// a18_lz_match_stub: BACKWARDS-COMPAT stub used by PASS-1 selftest. Greedy
// scan; bounded by A18_MAX_CHAIN. Replaced operationally by a18_lz_match_real
// during encode.
fn a18_lz_match_stub(buf: string, p: int) -> int {
    let n = len(buf)
    if p + A18_MIN_MATCH > n { return 0 }
    let lo = if p > A18_WINDOW_SIZE { p - A18_WINDOW_SIZE } else { 0 }
    let mut best = 0
    let mut q = lo
    let mut hops = 0
    while q < p && hops < A18_MAX_CHAIN {
        let mut m = 0
        while p + m < n && q + m < p && _byte_at(buf, q + m) == _byte_at(buf, p + m) {
            m = m + 1
            if m >= A18_MAX_MATCH { break }
        }
        if m >= A18_MIN_MATCH && m > best { best = m }
        q = q + 1
        hops = hops + 1
    }
    return best
}

// a18_lz_match_real: hash-chain LZ77 match search. Returns [length, distance]
// (distance = p - match_start) where length >= A18_MIN_MATCH, or [0,0] if no
// qualifying match. Mutates hash_head (array, int-indexed) and hash_prev (map,
// string-keyed via to_string(p)) in place to record p.
fn a18_lz_match_real(buf: string, p: int, hash_head: array, hash_prev) -> array {
    let n = len(buf)
    if p + A18_MIN_MATCH > n {
        return [0, 0]
    }
    let h: i64 = _hash3_real(buf, p)
    let lo: i64 = if p > A18_WINDOW_SIZE { p - A18_WINDOW_SIZE } else { 0 }
    let mut best_len: i64 = 0
    let mut best_dist: i64 = 0
    let mut q: i64 = hash_head[h]
    let mut hops: i64 = 0
    let p_byte0 = _byte_at(buf, p)
    while q >= lo && hops < A18_MAX_CHAIN && q < p {
        // First-byte filter cuts most chain steps cheaply.
        if _byte_at(buf, q) == p_byte0 {
            let mut m: i64 = 0
            let max_m: i64 = if n - p < A18_MAX_MATCH { n - p } else { A18_MAX_MATCH }
            while m < max_m && q + m < p && _byte_at(buf, q + m) == _byte_at(buf, p + m) {
                m = m + 1
            }
            if m >= A18_MIN_MATCH && m > best_len {
                best_len = m
                best_dist = p - q
                if m >= A18_MAX_MATCH { break }
            }
        }
        // walk chain
        let qkey = to_string(q)
        let nq: i64 = if map_contains_key(hash_prev, qkey) { hash_prev[qkey] } else { -1 }
        q = nq
        hops = hops + 1
    }
    // Insert p into chain BEFORE returning (so caller doesn't need to manage).
    let prev_head: i64 = hash_head[h]
    hash_prev[to_string(p)] = prev_head
    hash_head[h] = p
    return [best_len, best_dist]
}

// a18_lz_tokenize: emit array of integer tokens. Encoding scheme:
//   literal byte b:           [ b ]                       (range 0..255)
//   match (len, dist):        [ 256 + (len-3), d_hi, d_lo ]   (len 3..258, dist 1..32768)
//   d_hi = dist / 256, d_lo = dist % 256
fn a18_lz_tokenize(buf: string) -> array {
    let n = len(buf)
    let mut tokens = []
    // hash_head: 16384-entry int array, init -1 sentinel
    let mut hash_head = []
    let mut hi = 0
    while hi < A18_HASH_SIZE { hash_head.push(-1); hi = hi + 1 }
    // hash_prev: sparse map keyed by to_string(position)
    let hash_prev = {}
    let mut p = 0
    while p < n {
        if p + A18_MIN_MATCH <= n {
            let m = a18_lz_match_real(buf, p, hash_head, hash_prev)
            let mlen: i64 = m[0]
            let mdist: i64 = m[1]
            if mlen >= A18_MIN_MATCH {
                tokens.push(256 + (mlen - A18_MIN_MATCH))
                tokens.push(mdist / 256)
                tokens.push(mdist - (mdist / 256) * 256)
                // Insert hashes for skipped positions so next match can find them.
                let mut sp: i64 = p + 1
                let stop: i64 = p + mlen
                while sp < stop {
                    if sp + 3 <= n {
                        let h2: i64 = _hash3_real(buf, sp)
                        let prev2: i64 = hash_head[h2]
                        hash_prev[to_string(sp)] = prev2
                        hash_head[h2] = sp
                    }
                    sp = sp + 1
                }
                p = p + mlen
                continue
            }
        }
        // literal fallback
        let b: i64 = ord(_byte_at(buf, p))
        tokens.push(b)
        p = p + 1
    }
    return tokens
}

// ───────────────── v4-window64 LZ77 hash-chain match finder (raw 137 80% Pareto FINAL CLOSE) ─────────────────
//
// Identical to a18_lz_match_real / a18_lz_tokenize but parameterized for the
// 64KB window and 32768-slot hash table. Algorithmic novelty = window-size
// axis (NOT byte-context order). Captures long-range repetition that a 32KB
// window cannot reach — text-heavy class CEILING bottleneck per a105829b
// honest C3.

// _hash3_real_w64: integer hash of 3 bytes at position p in s, modulo
// A18_V4_HASH_SIZE=32768 (vs A18_HASH_SIZE=16384 for v1-v3-o2 path).
fn _hash3_real_w64(s: string, p: int) -> int {
    if p + 3 > len(s) { return 0 }
    let b0: i64 = ord(s.substring(p, p + 1))
    let b1: i64 = ord(s.substring(p + 1, p + 2))
    let b2: i64 = ord(s.substring(p + 2, p + 3))
    let h: i64 = ((b0 * 31 + b1) * 31 + b2)
    let m: i64 = h - (h / A18_V4_HASH_SIZE) * A18_V4_HASH_SIZE
    if m < 0 { return m + A18_V4_HASH_SIZE }
    return m
}

// a18_lz_match_real_w64: hash-chain LZ77 match search with 64KB window +
// 32768-slot hash table. Same arithmetic as a18_lz_match_real; only the
// window/hash-size constants differ. Returns [length, distance].
fn a18_lz_match_real_w64(buf: string, p: int, hash_head: array, hash_prev) -> array {
    let n = len(buf)
    if p + A18_MIN_MATCH > n {
        return [0, 0]
    }
    let h: i64 = _hash3_real_w64(buf, p)
    let lo: i64 = if p > A18_V4_WINDOW_SIZE { p - A18_V4_WINDOW_SIZE } else { 0 }
    let mut best_len: i64 = 0
    let mut best_dist: i64 = 0
    let mut q: i64 = hash_head[h]
    let mut hops: i64 = 0
    let p_byte0 = _byte_at(buf, p)
    while q >= lo && hops < A18_MAX_CHAIN && q < p {
        if _byte_at(buf, q) == p_byte0 {
            let mut m: i64 = 0
            let max_m: i64 = if n - p < A18_MAX_MATCH { n - p } else { A18_MAX_MATCH }
            while m < max_m && q + m < p && _byte_at(buf, q + m) == _byte_at(buf, p + m) {
                m = m + 1
            }
            if m >= A18_MIN_MATCH && m > best_len {
                best_len = m
                best_dist = p - q
                if m >= A18_MAX_MATCH { break }
            }
        }
        let qkey = to_string(q)
        let nq: i64 = if map_contains_key(hash_prev, qkey) { hash_prev[qkey] } else { -1 }
        q = nq
        hops = hops + 1
    }
    let prev_head: i64 = hash_head[h]
    hash_prev[to_string(p)] = prev_head
    hash_head[h] = p
    return [best_len, best_dist]
}

// a18_lz_tokenize_w64: emit token array using 64KB window + 32768 hash slots.
// Token format identical to a18_lz_tokenize (triples [256+(len-3), d_hi, d_lo]
// for matches, single token in 0..255 for literals); wire compat preserved
// because max distance = 65535 fits exactly in 2 bytes (d_hi, d_lo).
// Detokenizer is shared (a18_lz_detokenize) — no v4-specific decode path
// needed for the LZ stage; only the tokenizer changes.
fn a18_lz_tokenize_w64(buf: string) -> array {
    let n = len(buf)
    let mut tokens = []
    let mut hash_head = []
    let mut hi = 0
    while hi < A18_V4_HASH_SIZE { hash_head.push(-1); hi = hi + 1 }
    let hash_prev = {}
    let mut p = 0
    while p < n {
        if p + A18_MIN_MATCH <= n {
            let m = a18_lz_match_real_w64(buf, p, hash_head, hash_prev)
            let mlen: i64 = m[0]
            let mdist: i64 = m[1]
            if mlen >= A18_MIN_MATCH {
                tokens.push(256 + (mlen - A18_MIN_MATCH))
                tokens.push(mdist / 256)
                tokens.push(mdist - (mdist / 256) * 256)
                let mut sp: i64 = p + 1
                let stop: i64 = p + mlen
                while sp < stop {
                    if sp + 3 <= n {
                        let h2: i64 = _hash3_real_w64(buf, sp)
                        let prev2: i64 = hash_head[h2]
                        hash_prev[to_string(sp)] = prev2
                        hash_head[h2] = sp
                    }
                    sp = sp + 1
                }
                p = p + mlen
                continue
            }
        }
        let b: i64 = ord(_byte_at(buf, p))
        tokens.push(b)
        p = p + 1
    }
    return tokens
}

// ───────────────── v6-optimal LZ77 lazy-match tokenizer (raw 137 80% Pareto FINAL CLOSE) ─────────────────
//
// Storer-Szymanski (1982) lazy-match LZ77. At each position i we obtain a
// candidate greedy match (m_i.len, m_i.dist). Before committing, we look
// ONE step ahead: compute the candidate match at i+1 (m_{i+1}). If
// m_{i+1}.len > m_i.len + 1 (strict gain after accounting for the extra
// literal byte we'd emit), we emit a literal byte at i and re-evaluate
// the match decision at i+1. Otherwise we commit the greedy match at i.
//
// This is encode-side optimization ONLY — the wire token format is
// unchanged (literal bytes + length-distance triples) and the shared
// a18_lz_detokenize handles v6 streams identically to v1/v4.
//
// Complexity: O(N × W) hash-chain traversal × constant-factor 2 for the
// 1-byte lookahead (we evaluate match_real at most twice per emitted token).
// Memory: O(W) for the hash_head table + O(N) for hash_prev (same as v1).
// No DP table is materialized — the lazy decision is local (lookahead K=1
// is the canonical Storer-Szymanski form; deeper K is reserved for v7+).

fn a18_lz_tokenize_lazy(buf: string) -> array {
    let n = len(buf)
    let mut tokens = []
    let mut hash_head = []
    let mut hi = 0
    while hi < A18_HASH_SIZE { hash_head.push(-1); hi = hi + 1 }
    let hash_prev = {}
    let mut p = 0
    // Pending greedy match staged at position p; if non-zero, we already
    // ran match_real at p and recorded p in the chain. We must NOT call
    // match_real again at p (would double-record). We may need to evict
    // the staged decision if the i+1 lookahead beats it.
    let mut pend_len: i64 = 0
    let mut pend_dist: i64 = 0
    let mut have_pend: bool = false
    while p < n {
        if !have_pend {
            // Stage match at p (this also inserts p into the hash chain).
            if p + A18_MIN_MATCH <= n {
                let m = a18_lz_match_real(buf, p, hash_head, hash_prev)
                pend_len = m[0]
                pend_dist = m[1]
            } else {
                pend_len = 0
                pend_dist = 0
                // Still record p in the chain for later positions to find.
                if p + 3 <= n {
                    let h_tail: i64 = _hash3_real(buf, p)
                    let prev_tail: i64 = hash_head[h_tail]
                    hash_prev[to_string(p)] = prev_tail
                    hash_head[h_tail] = p
                }
            }
            have_pend = true
        }
        if pend_len < A18_MIN_MATCH {
            // No qualifying match at p — emit literal, advance.
            let b: i64 = ord(_byte_at(buf, p))
            tokens.push(b)
            p = p + 1
            have_pend = false
            continue
        }
        // Greedy match qualifies at p. Lazy lookahead: try match at p+1.
        // p+1 must already be insertable; the chain insertion happens
        // inside match_real, so calling it stages the i+1 decision.
        let p1: i64 = p + 1
        let mut next_len: i64 = 0
        let mut next_dist: i64 = 0
        if p1 + A18_MIN_MATCH <= n {
            let m1 = a18_lz_match_real(buf, p1, hash_head, hash_prev)
            next_len = m1[0]
            next_dist = m1[1]
        }
        // Storer-Szymanski rule: prefer literal-at-p + match-at-(p+1) only
        // when the lookahead match strictly exceeds the current match
        // length (the 1-byte literal cost is paid by the strictly-greater
        // length condition; literal ≈ 9 bits, match-len-bump ≈ 1-2 bits,
        // so strict > captures the canonical net gain in expectation).
        if next_len > pend_len {
            // Emit literal at p; commit lookahead match at p+1.
            let b0: i64 = ord(_byte_at(buf, p))
            tokens.push(b0)
            // Emit the (p+1) match.
            tokens.push(256 + (next_len - A18_MIN_MATCH))
            tokens.push(next_dist / 256)
            tokens.push(next_dist - (next_dist / 256) * 256)
            // Insert hashes for skipped positions inside the (p+1) match
            // so subsequent matches can find them. Range = [p+2 .. p+1+next_len).
            let mut sp: i64 = p + 2
            let stop: i64 = p1 + next_len
            while sp < stop {
                if sp + 3 <= n {
                    let h2: i64 = _hash3_real(buf, sp)
                    let prev2: i64 = hash_head[h2]
                    hash_prev[to_string(sp)] = prev2
                    hash_head[h2] = sp
                }
                sp = sp + 1
            }
            p = p1 + next_len
            have_pend = false
            continue
        }
        // Lookahead did NOT beat the staged match at p — commit pend.
        tokens.push(256 + (pend_len - A18_MIN_MATCH))
        tokens.push(pend_dist / 256)
        tokens.push(pend_dist - (pend_dist / 256) * 256)
        // Insert hashes for skipped positions inside the (p) match. Note:
        // we already recorded p (inside match_real) and p+1 (also inside
        // match_real for the lookahead). Range to fill = [p+2 .. p+pend_len).
        let mut sp2: i64 = p + 2
        let stop2: i64 = p + pend_len
        while sp2 < stop2 {
            if sp2 + 3 <= n {
                let h2b: i64 = _hash3_real(buf, sp2)
                let prev2b: i64 = hash_head[h2b]
                hash_prev[to_string(sp2)] = prev2b
                hash_head[h2b] = sp2
            }
            sp2 = sp2 + 1
        }
        p = p + pend_len
        have_pend = false
    }
    return tokens
}

// a18_lz_detokenize: inverse of a18_lz_tokenize. Returns reconstructed
// bytes array (each entry 0..255). Caller converts to string via chr-join
// or write_bytes for byte-canonical output.
fn a18_lz_detokenize(tokens: array) -> array {
    let mut out = []
    let mut i: i64 = 0
    let n: i64 = len(tokens)
    while i < n {
        let t: i64 = tokens[i]
        if t < 256 {
            out.push(t)
            i = i + 1
        } else {
            let mlen: i64 = (t - 256) + A18_MIN_MATCH
            let dh: i64 = if i + 1 < n { tokens[i + 1] } else { 0 }
            let dl: i64 = if i + 2 < n { tokens[i + 2] } else { 0 }
            let mdist: i64 = dh * 256 + dl
            let start: i64 = len(out) - mdist
            let mut k: i64 = 0
            while k < mlen {
                let src: i64 = start + k
                let bv: i64 = if src >= 0 && src < len(out) { out[src] } else { 0 }
                out.push(bv)
                k = k + 1
            }
            i = i + 3
        }
    }
    return out
}

// ───────────────── adaptive order-0 range coder over token alphabet ─────────────────

// _build_uniform_freq: 512-entry uniform-1 frequency table; adapted on-line
// during encode/decode by incrementing the symbol's frequency after coding.
// This gives an adaptive model — no header needed (decoder rebuilds same way).
fn _build_uniform_freq() -> array {
    let mut f = []
    let mut i = 0
    while i < A18_TOKEN_ALPHABET { f.push(1); i = i + 1 }
    return f
}

fn _cum_from_freq(freq: array) -> array {
    let mut cum = []
    let mut s: i64 = 0
    let mut i = 0
    while i < A18_TOKEN_ALPHABET { cum.push(s); s = s + freq[i]; i = i + 1 }
    cum.push(s)
    return cum
}

// _scale_freq_if_needed: when total freq grows past A18_MAX_FREQ_TOTAL,
// halve all frequencies (floor to 1) to keep range/total in 32-bit.
fn _scale_freq_if_needed(freq: array) -> array {
    let mut s: i64 = 0
    let mut i = 0
    while i < A18_TOKEN_ALPHABET { s = s + freq[i]; i = i + 1 }
    if s <= A18_MAX_FREQ_TOTAL { return freq }
    let mut j = 0
    while j < A18_TOKEN_ALPHABET {
        let v: i64 = freq[j] / 2
        freq[j] = if v < 1 { 1 } else { v }
        j = j + 1
    }
    return freq
}

// _range_encode_tokens: byte-emitting 32-bit range coder. Token alphabet 512.
// Adaptive: freq updated after each token. Returns array of output bytes.
fn _range_encode_tokens(tokens: array) -> array {
    let mut freq = _build_uniform_freq()
    let mut low: i64 = 0
    let mut range: i64 = A18_TOP - 1
    let mut out_bytes = []
    let n: i64 = len(tokens)
    let mut k: i64 = 0
    while k < n {
        let cum = _cum_from_freq(freq)
        let total: i64 = cum[A18_TOKEN_ALPHABET]
        let b: i64 = tokens[k]
        range = range / total
        low = low + cum[b] * range
        range = range * (cum[b + 1] - cum[b])
        // renormalize (mirror of A16 _range_encode)
        let mut renorm = true
        while renorm {
            let high: i64 = low + range
            let low_top: i64 = low / 16777216
            let high_top: i64 = high / 16777216
            if low_top == high_top {
                out_bytes.push(low_top - (low_top / 256) * 256)
                low = (low - (low_top * 16777216)) * 256
                range = range * 256
                if low < 0 { low = low + A18_TOP * 256 }
            } else if range < A18_BOT {
                range = (16777216 - (low - (low / 16777216) * 16777216)) * 256
                out_bytes.push(low / 16777216 - (low / 16777216 / 256) * 256)
                low = (low - (low / 16777216) * 16777216) * 256
            } else {
                renorm = false
            }
            if low >= A18_TOP {
                let mut idx: i64 = len(out_bytes) - 1
                low = low - A18_TOP
                while idx >= 0 {
                    let v: i64 = out_bytes[idx] + 1
                    if v < 256 { out_bytes[idx] = v; idx = -1 }
                    else { out_bytes[idx] = 0; idx = idx - 1 }
                }
            }
        }
        // adapt model AFTER coding (decoder mirrors)
        freq[b] = freq[b] + 1
        freq = _scale_freq_if_needed(freq)
        k = k + 1
    }
    // Flush 4 termination bytes
    let mut f = 0
    while f < 4 {
        let lt: i64 = low / 16777216
        out_bytes.push(lt - (lt / 256) * 256)
        low = (low - lt * 16777216) * 256
        f = f + 1
    }
    return out_bytes
}

// _range_decode_tokens: inverse of _range_encode_tokens. Produces n_tokens
// integer tokens (alphabet 0..511) by reading the byte stream payload.
fn _range_decode_tokens(payload: array, n_tokens: i64) -> array {
    let mut freq = _build_uniform_freq()
    let mut low: i64 = 0
    let mut range: i64 = A18_TOP - 1
    let mut code: i64 = 0
    let mut p: i64 = 0
    let mut pi = 0
    while pi < 4 {
        let b: i64 = if p < len(payload) { payload[p] } else { 0 }
        code = code * 256 + b
        p = p + 1
        pi = pi + 1
    }
    let mut out = []
    let mut produced: i64 = 0
    while produced < n_tokens {
        let cum = _cum_from_freq(freq)
        let total: i64 = cum[A18_TOKEN_ALPHABET]
        range = range / total
        let target_raw: i64 = (code - low) / range
        let mut tgt: i64 = target_raw
        if tgt >= total { tgt = total - 1 }
        // Linear scan cum table — alphabet=512 acceptable for hexa-lang.
        let mut b: i64 = 0
        while b < A18_TOKEN_ALPHABET {
            if cum[b + 1] > tgt { break }
            b = b + 1
        }
        if b >= A18_TOKEN_ALPHABET { b = A18_TOKEN_ALPHABET - 1 }
        out.push(b)
        low = low + cum[b] * range
        range = range * (cum[b + 1] - cum[b])
        let mut renorm = true
        while renorm {
            let high: i64 = low + range
            let low_top: i64 = low / 16777216
            let high_top: i64 = high / 16777216
            if low_top == high_top {
                let nb: i64 = if p < len(payload) { payload[p] } else { 0 }
                code = (code - low_top * 16777216) * 256 + nb
                low = (low - low_top * 16777216) * 256
                range = range * 256
                p = p + 1
            } else if range < A18_BOT {
                let nb: i64 = if p < len(payload) { payload[p] } else { 0 }
                range = (16777216 - (low - (low / 16777216) * 16777216)) * 256
                code = (code - (low / 16777216) * 16777216) * 256 + nb
                low = (low - (low / 16777216) * 16777216) * 256
                p = p + 1
            } else {
                renorm = false
            }
            if low >= A18_TOP { low = low - A18_TOP }
            if code >= A18_TOP * 256 { code = code - A18_TOP * 256 }
        }
        freq[b] = freq[b] + 1
        freq = _scale_freq_if_needed(freq)
        produced = produced + 1
    }
    return out
}

// ───────────────── order-1 context range coder (v2 wire, raw 137 80% Pareto) ─────────────────
//
// Model: 257 separate adaptive frequency tables of size A18_TOKEN_ALPHABET=512.
// Context selector evolves with each emitted token:
//   - if previous token was a literal byte b (in 0..255): use freq_ctx[b]
//   - if previous token was a length code (256..511) OR a distance byte: use freq_ctx[256] (reset)
//   - at start of stream: use freq_ctx[256]
// After encoding token t in active context c:
//   - increment freq_ctx[c][t] by 1
//   - rescale that context if its total > A18_MAX_FREQ_TOTAL
//   - update active ctx for NEXT token: if token was literal in 0..255, ctx = token;
//     else ctx = 256 (length code, dist_hi, dist_lo all reset to 256)
// LZ tokenize emits triples: literal -> single token in 0..255;
//   match -> [256+(len-3), dist_hi, dist_lo]. v2 keeps the same token shape so
//   detokenize is shared. Only the entropy coder on the token stream changes.

fn _build_freq_ctx_table() -> array {
    // 257 tables × 512 entries each, all initialized to 1 (uniform prior).
    let mut tables = []
    let mut c = 0
    while c < 257 {
        let mut row = []
        let mut i = 0
        while i < A18_TOKEN_ALPHABET { row.push(1); i = i + 1 }
        tables.push(row)
        c = c + 1
    }
    return tables
}

fn _ctx_total(row: array) -> i64 {
    let mut s: i64 = 0
    let mut i = 0
    while i < A18_TOKEN_ALPHABET { s = s + row[i]; i = i + 1 }
    return s
}

fn _ctx_rescale_if_needed(row: array) -> array {
    let s: i64 = _ctx_total(row)
    if s <= A18_MAX_FREQ_TOTAL { return row }
    let mut j = 0
    while j < A18_TOKEN_ALPHABET {
        let v: i64 = row[j] / 2
        row[j] = if v < 1 { 1 } else { v }
        j = j + 1
    }
    return row
}

fn _ctx_cum_from_row(row: array) -> array {
    let mut cum = []
    let mut s: i64 = 0
    let mut i = 0
    while i < A18_TOKEN_ALPHABET { cum.push(s); s = s + row[i]; i = i + 1 }
    cum.push(s)
    return cum
}

// _next_ctx: determine context selector for the NEXT token based on the
// token just emitted. Mirrored exactly by encoder + decoder (must agree).
fn _next_ctx(emitted: i64) -> i64 {
    if emitted >= 0 && emitted < 256 { return emitted }
    return 256
}

// _range_encode_tokens_o1: order-1 byte-context adaptive range coder.
// Same low/range/code arithmetic as v1 but the cum table is selected per
// token from freq_ctx[active_ctx]. Returns array of output bytes.
fn _range_encode_tokens_o1(tokens: array) -> array {
    let mut tables = _build_freq_ctx_table()
    let mut active: i64 = 256
    let mut low: i64 = 0
    let mut range: i64 = A18_TOP - 1
    let mut out_bytes = []
    let n: i64 = len(tokens)
    let mut k: i64 = 0
    while k < n {
        let row = tables[active]
        let cum = _ctx_cum_from_row(row)
        let total: i64 = cum[A18_TOKEN_ALPHABET]
        let b: i64 = tokens[k]
        range = range / total
        low = low + cum[b] * range
        range = range * (cum[b + 1] - cum[b])
        let mut renorm = true
        while renorm {
            let high: i64 = low + range
            let low_top: i64 = low / 16777216
            let high_top: i64 = high / 16777216
            if low_top == high_top {
                out_bytes.push(low_top - (low_top / 256) * 256)
                low = (low - (low_top * 16777216)) * 256
                range = range * 256
                if low < 0 { low = low + A18_TOP * 256 }
            } else if range < A18_BOT {
                range = (16777216 - (low - (low / 16777216) * 16777216)) * 256
                out_bytes.push(low / 16777216 - (low / 16777216 / 256) * 256)
                low = (low - (low / 16777216) * 16777216) * 256
            } else {
                renorm = false
            }
            if low >= A18_TOP {
                let mut idx: i64 = len(out_bytes) - 1
                low = low - A18_TOP
                while idx >= 0 {
                    let v: i64 = out_bytes[idx] + 1
                    if v < 256 { out_bytes[idx] = v; idx = -1 }
                    else { out_bytes[idx] = 0; idx = idx - 1 }
                }
            }
        }
        // adapt: increment freq in active context, rescale if needed.
        row[b] = row[b] + 1
        tables[active] = _ctx_rescale_if_needed(row)
        // Update active context for NEXT token (mirrored by decoder).
        active = _next_ctx(b)
        k = k + 1
    }
    // Flush 4 termination bytes (mirror v1).
    let mut f = 0
    while f < 4 {
        let lt: i64 = low / 16777216
        out_bytes.push(lt - (lt / 256) * 256)
        low = (low - lt * 16777216) * 256
        f = f + 1
    }
    return out_bytes
}

// _range_decode_tokens_o1: inverse. Reads payload, produces n_tokens tokens
// using the same active-context evolution rule. Adaptation mirror is
// essential — decoder must update freq AFTER decoding each token (in lockstep
// with encoder) before computing the next cum table.
fn _range_decode_tokens_o1(payload: array, n_tokens: i64) -> array {
    let mut tables = _build_freq_ctx_table()
    let mut active: i64 = 256
    let mut low: i64 = 0
    let mut range: i64 = A18_TOP - 1
    let mut code: i64 = 0
    let mut p: i64 = 0
    let mut pi = 0
    while pi < 4 {
        let b: i64 = if p < len(payload) { payload[p] } else { 0 }
        code = code * 256 + b
        p = p + 1
        pi = pi + 1
    }
    let mut out = []
    let mut produced: i64 = 0
    while produced < n_tokens {
        let row = tables[active]
        let cum = _ctx_cum_from_row(row)
        let total: i64 = cum[A18_TOKEN_ALPHABET]
        range = range / total
        let target_raw: i64 = (code - low) / range
        let mut tgt: i64 = target_raw
        if tgt >= total { tgt = total - 1 }
        let mut b: i64 = 0
        while b < A18_TOKEN_ALPHABET {
            if cum[b + 1] > tgt { break }
            b = b + 1
        }
        if b >= A18_TOKEN_ALPHABET { b = A18_TOKEN_ALPHABET - 1 }
        out.push(b)
        low = low + cum[b] * range
        range = range * (cum[b + 1] - cum[b])
        let mut renorm = true
        while renorm {
            let high: i64 = low + range
            let low_top: i64 = low / 16777216
            let high_top: i64 = high / 16777216
            if low_top == high_top {
                let nb: i64 = if p < len(payload) { payload[p] } else { 0 }
                code = (code - low_top * 16777216) * 256 + nb
                low = (low - low_top * 16777216) * 256
                range = range * 256
                p = p + 1
            } else if range < A18_BOT {
                let nb: i64 = if p < len(payload) { payload[p] } else { 0 }
                range = (16777216 - (low - (low / 16777216) * 16777216)) * 256
                code = (code - (low / 16777216) * 16777216) * 256 + nb
                low = (low - (low / 16777216) * 16777216) * 256
                p = p + 1
            } else {
                renorm = false
            }
            if low >= A18_TOP { low = low - A18_TOP }
            if code >= A18_TOP * 256 { code = code - A18_TOP * 256 }
        }
        row[b] = row[b] + 1
        tables[active] = _ctx_rescale_if_needed(row)
        active = _next_ctx(b)
        produced = produced + 1
    }
    return out
}

// ───────────────── order-3 hashed byte-context range coder (v3 wire, raw 137 80% Pareto per-class CEILING ω-cycle) ─────────────────
//
// Model: A18_V3_BUCKETS=4096 separate adaptive frequency tables of size
// A18_TOKEN_ALPHABET=512. Bucket id is selected per token by hashing the
// LAST 3 EMITTED TOKENS (each clamped to its 0..511 representation) using
// a Knuth multiplicative hash. When fewer than 3 tokens have been emitted,
// pad missing slots with the sentinel 256 (which is what _next_ctx already
// uses for "non-literal previous"). After emitting each token we shift the
// 3-window: prev3 = prev2; prev2 = prev1; prev1 = token. Decoder mirrors
// this evolution exactly so encoder + decoder always agree on the active
// bucket for any token position.
//
// Why hashed buckets vs full PPM-D escape mechanism?
//   - Full sparse PPM-D order-3 needs ~256^3 contexts × 512 entries =
//     33M slots, OOM-prone in hexa-lang's map runtime.
//   - 4096 buckets ≈ 13.7M context combinations folded into 4096 buckets
//     is essentially "blended order-3" — collisions are implicit context
//     mixing. This is mathematically equivalent to running an adaptive
//     coder on a deterministic equivalence class of contexts.
//   - Decoder byte-eq is preserved by construction: same hash, same
//     window evolution, same prior, same adaptation rule.
//   - Memory: 4096 × 512 × 4 bytes ≈ 8 MB peak, within F-A18-V3-2 budget.
//
// Trade-off vs v1/v2:
//   - v1 (order-0): 1 table × 512.    Best for very small inputs.
//   - v2 (order-1): 257 tables × 512. Wins on medium text-heavy inputs
//     where bigram skew dominates.
//   - v3 (hashed order-3): 4096 tables × 512. Theoretical ceiling per
//     Shannon H_3 ≈ 1.3 bits/byte (~84% bit-level on n6 atlas). Startup
//     amortization much heavier than v2 — only viable on inputs >> 32 KB.
//   - a18_encode = min(v1, v2, v3, identity) per try-and-revert raw 142 D2.
//
// Falsifiers preregistered (raw 71):
//   F-A18-V3-1: v3 saving < v2 saving on text-heavy 79KB n6 atlas → reject.
//   F-A18-V3-2: v3 peak memory > 200MB on 79KB input → reject.
//   F-A18-V3-3: v3 encode/decode round-trip not byte-eq → reject.

fn _build_freq_ctx_table_v3() -> array {
    // 4096 tables × 512 entries each, all initialized to 1 (uniform prior).
    // Larger heap allocation than v2 — caller invokes once per encode/decode.
    let mut tables = []
    let mut c = 0
    while c < A18_V3_BUCKETS {
        let mut row = []
        let mut i = 0
        while i < A18_TOKEN_ALPHABET { row.push(1); i = i + 1 }
        tables.push(row)
        c = c + 1
    }
    return tables
}

// _v3_bucket: hash last-3-token window to a bucket id in [0, A18_V3_BUCKETS).
// Inputs prev3, prev2, prev1 are ints in 0..511 (token alphabet); 256 sentinel
// is used by callers when the slot is "no previous emission". The hash mixes
// the three slots with Knuth's multiplicative hash; we then mod by buckets.
// This function MUST be byte-deterministic across encoder + decoder.
fn _v3_bucket(prev3: i64, prev2: i64, prev1: i64) -> i64 {
    // Compose 30-bit key: each slot is 9 bits (token alphabet 512 = 2^9).
    let key: i64 = (prev3 - (prev3 / 512) * 512) * 262144
                 + (prev2 - (prev2 / 512) * 512) * 512
                 + (prev1 - (prev1 / 512) * 512)
    // Knuth multiplicative — keep as i64. We don't need the high 32 bits
    // because we mod by 4096 (12 bits), which is robust under any consistent
    // truncation between encoder + decoder.
    let mixed: i64 = key * A18_V3_HASH_MUL
    let abs_mixed: i64 = if mixed < 0 { 0 - mixed } else { mixed }
    let bucket: i64 = abs_mixed - (abs_mixed / A18_V3_BUCKETS) * A18_V3_BUCKETS
    return bucket
}

// _range_encode_tokens_o3: hashed order-3 byte-context adaptive range coder.
// Returns array of output bytes. Mirrors v2 arithmetic exactly; only the
// table-selection step differs (per-bucket vs per-prev-byte).
fn _range_encode_tokens_o3(tokens: array) -> array {
    let mut tables = _build_freq_ctx_table_v3()
    // 3-token sliding window. Sentinel 256 = "no previous emission" (matches
    // _next_ctx semantics for non-literal). At start, all three slots = 256.
    let mut prev3: i64 = 256
    let mut prev2: i64 = 256
    let mut prev1: i64 = 256
    let mut low: i64 = 0
    let mut range: i64 = A18_TOP - 1
    let mut out_bytes = []
    let n: i64 = len(tokens)
    let mut k: i64 = 0
    while k < n {
        let active: i64 = _v3_bucket(prev3, prev2, prev1)
        let row = tables[active]
        let cum = _ctx_cum_from_row(row)
        let total: i64 = cum[A18_TOKEN_ALPHABET]
        let b: i64 = tokens[k]
        range = range / total
        low = low + cum[b] * range
        range = range * (cum[b + 1] - cum[b])
        let mut renorm = true
        while renorm {
            let high: i64 = low + range
            let low_top: i64 = low / 16777216
            let high_top: i64 = high / 16777216
            if low_top == high_top {
                out_bytes.push(low_top - (low_top / 256) * 256)
                low = (low - (low_top * 16777216)) * 256
                range = range * 256
                if low < 0 { low = low + A18_TOP * 256 }
            } else if range < A18_BOT {
                range = (16777216 - (low - (low / 16777216) * 16777216)) * 256
                out_bytes.push(low / 16777216 - (low / 16777216 / 256) * 256)
                low = (low - (low / 16777216) * 16777216) * 256
            } else {
                renorm = false
            }
            if low >= A18_TOP {
                let mut idx: i64 = len(out_bytes) - 1
                low = low - A18_TOP
                while idx >= 0 {
                    let v: i64 = out_bytes[idx] + 1
                    if v < 256 { out_bytes[idx] = v; idx = -1 }
                    else { out_bytes[idx] = 0; idx = idx - 1 }
                }
            }
        }
        // adapt: increment freq in active bucket, rescale if needed.
        row[b] = row[b] + 1
        tables[active] = _ctx_rescale_if_needed(row)
        // Slide window: drop oldest, push current emission.
        prev3 = prev2
        prev2 = prev1
        prev1 = b
        k = k + 1
    }
    // Flush 4 termination bytes (mirror v1 + v2).
    let mut f = 0
    while f < 4 {
        let lt: i64 = low / 16777216
        out_bytes.push(lt - (lt / 256) * 256)
        low = (low - lt * 16777216) * 256
        f = f + 1
    }
    return out_bytes
}

// _range_decode_tokens_o3: inverse of _range_encode_tokens_o3. Reads payload,
// produces n_tokens tokens using the same hashed-bucket evolution rule.
// Adaptation MUST mirror encoder: increment freq AFTER decoding each token,
// then slide the 3-token window to compute the next bucket.
fn _range_decode_tokens_o3(payload: array, n_tokens: i64) -> array {
    let mut tables = _build_freq_ctx_table_v3()
    let mut prev3: i64 = 256
    let mut prev2: i64 = 256
    let mut prev1: i64 = 256
    let mut low: i64 = 0
    let mut range: i64 = A18_TOP - 1
    let mut code: i64 = 0
    let mut p: i64 = 0
    let mut pi = 0
    while pi < 4 {
        let b: i64 = if p < len(payload) { payload[p] } else { 0 }
        code = code * 256 + b
        p = p + 1
        pi = pi + 1
    }
    let mut out = []
    let mut produced: i64 = 0
    while produced < n_tokens {
        let active: i64 = _v3_bucket(prev3, prev2, prev1)
        let row = tables[active]
        let cum = _ctx_cum_from_row(row)
        let total: i64 = cum[A18_TOKEN_ALPHABET]
        range = range / total
        let target_raw: i64 = (code - low) / range
        let mut tgt: i64 = target_raw
        if tgt >= total { tgt = total - 1 }
        let mut b: i64 = 0
        while b < A18_TOKEN_ALPHABET {
            if cum[b + 1] > tgt { break }
            b = b + 1
        }
        if b >= A18_TOKEN_ALPHABET { b = A18_TOKEN_ALPHABET - 1 }
        out.push(b)
        low = low + cum[b] * range
        range = range * (cum[b + 1] - cum[b])
        let mut renorm = true
        while renorm {
            let high: i64 = low + range
            let low_top: i64 = low / 16777216
            let high_top: i64 = high / 16777216
            if low_top == high_top {
                let nb: i64 = if p < len(payload) { payload[p] } else { 0 }
                code = (code - low_top * 16777216) * 256 + nb
                low = (low - low_top * 16777216) * 256
                range = range * 256
                p = p + 1
            } else if range < A18_BOT {
                let nb: i64 = if p < len(payload) { payload[p] } else { 0 }
                range = (16777216 - (low - (low / 16777216) * 16777216)) * 256
                code = (code - (low / 16777216) * 16777216) * 256 + nb
                low = (low - (low / 16777216) * 16777216) * 256
                p = p + 1
            } else {
                renorm = false
            }
            if low >= A18_TOP { low = low - A18_TOP }
            if code >= A18_TOP * 256 { code = code - A18_TOP * 256 }
        }
        row[b] = row[b] + 1
        tables[active] = _ctx_rescale_if_needed(row)
        prev3 = prev2
        prev2 = prev1
        prev1 = b
        produced = produced + 1
    }
    return out
}

// ───────────────── order-2 hashed byte-context range coder (v3-order-2 wire, raw 137 80% Pareto text-heavy CEILING ω-cycle) ─────────────────
//
// Model: A18_V3_O2_BUCKETS=256 separate adaptive frequency tables of size
// A18_TOKEN_ALPHABET=512. Bucket id is selected per token by hashing the
// LAST 2 EMITTED TOKENS (each clamped to its 0..511 representation) using
// a Knuth multiplicative hash mod 256. When fewer than 2 tokens have been
// emitted, pad missing slots with the sentinel 256.
//
// Distinction from v3 order-3 (ad7c32df FAILED on production sizes):
//   - v3 order-3: 4096 buckets → ~7 tokens/bucket on 79KB (warm-up fail)
//   - v3-order-2: 256 buckets   → ~120 tokens/bucket on 79KB (tractable)
//   - sweet spot: between v2 (saturated single-token) and v3 order-3.
//
// Why hashed buckets vs full PPM-D order-2 escape mechanism?
//   - Full sparse PPM-D order-2 needs ~256^2 contexts × 512 entries =
//     ~33M slots, OOM-prone in hexa-lang's map runtime.
//   - 256 buckets ≈ 65k context combinations folded into 256 buckets —
//     "blended order-2" with implicit context mixing.
//   - Decoder byte-eq is preserved by construction: same hash, same
//     window evolution, same prior, same adaptation rule.
//   - Memory: 256 × 512 × 4 bytes ≈ 524 KB peak, within
//     F-A18-V3-ORDER2-4 budget (< 50 MB).
//
// Trade-off vs v1/v2/v3:
//   - v1 (order-0):      1 table × 512.    Best for very small inputs.
//   - v2 (order-1):    257 tables × 512.   Wins on medium text-heavy.
//   - v3-order-2:      256 tables × 512.   Sweet spot for text-heavy
//                                          ≥16KB (text-heavy CEILING).
//   - v3 (order-3):   4096 tables × 512.   Wins only on massive (>>32KB)
//                                          highly structured corpora.
//   - a18_encode = min(v1, v2, v3, v3-order-2, identity).
//
// Falsifiers preregistered (raw 71):
//   F-A18-V3-ORDER2-1: v3-order-2 saving < v2 saving on text-heavy ≥16KB → reject.
//   F-A18-V3-ORDER2-2: v3-order-2 encode/decode round-trip not byte-eq → reject.
//   F-A18-V3-ORDER2-3: v3-order-2 AOT latency > 200ms/KB → reject.
//   F-A18-V3-ORDER2-4: v3-order-2 peak memory > 50MB on 79KB → reject.

fn _build_freq_ctx_table_v3_o2() -> array {
    // 256 tables × 512 entries each, all initialized to 1 (uniform prior).
    let mut tables = []
    let mut c = 0
    while c < A18_V3_O2_BUCKETS {
        let mut row = []
        let mut i = 0
        while i < A18_TOKEN_ALPHABET { row.push(1); i = i + 1 }
        tables.push(row)
        c = c + 1
    }
    return tables
}

// _v3_o2_bucket: hash last-2-token window to a bucket id in [0, A18_V3_O2_BUCKETS).
// Inputs prev2, prev1 are ints in 0..511 (token alphabet); 256 sentinel is
// used by callers when the slot is "no previous emission". The hash mixes
// the two slots with Knuth's multiplicative hash; we then mod by buckets.
// Byte-deterministic across encoder + decoder.
fn _v3_o2_bucket(prev2: i64, prev1: i64) -> i64 {
    // Compose 18-bit key: each slot is 9 bits (token alphabet 512 = 2^9).
    let key: i64 = (prev2 - (prev2 / 512) * 512) * 512
                 + (prev1 - (prev1 / 512) * 512)
    let mixed: i64 = key * A18_V3_HASH_MUL
    let abs_mixed: i64 = if mixed < 0 { 0 - mixed } else { mixed }
    let bucket: i64 = abs_mixed - (abs_mixed / A18_V3_O2_BUCKETS) * A18_V3_O2_BUCKETS
    return bucket
}

// _range_encode_tokens_o2: hashed order-2 byte-context adaptive range coder.
// Returns array of output bytes. Mirrors v3 order-3 arithmetic exactly; only
// the table-selection step differs (256 buckets, 2-token window).
fn _range_encode_tokens_o2(tokens: array) -> array {
    let mut tables = _build_freq_ctx_table_v3_o2()
    let mut prev2: i64 = 256
    let mut prev1: i64 = 256
    let mut low: i64 = 0
    let mut range: i64 = A18_TOP - 1
    let mut out_bytes = []
    let n: i64 = len(tokens)
    let mut k: i64 = 0
    while k < n {
        let active: i64 = _v3_o2_bucket(prev2, prev1)
        let row = tables[active]
        let cum = _ctx_cum_from_row(row)
        let total: i64 = cum[A18_TOKEN_ALPHABET]
        let b: i64 = tokens[k]
        range = range / total
        low = low + cum[b] * range
        range = range * (cum[b + 1] - cum[b])
        let mut renorm = true
        while renorm {
            let high: i64 = low + range
            let low_top: i64 = low / 16777216
            let high_top: i64 = high / 16777216
            if low_top == high_top {
                out_bytes.push(low_top - (low_top / 256) * 256)
                low = (low - (low_top * 16777216)) * 256
                range = range * 256
                if low < 0 { low = low + A18_TOP * 256 }
            } else if range < A18_BOT {
                range = (16777216 - (low - (low / 16777216) * 16777216)) * 256
                out_bytes.push(low / 16777216 - (low / 16777216 / 256) * 256)
                low = (low - (low / 16777216) * 16777216) * 256
            } else {
                renorm = false
            }
            if low >= A18_TOP {
                let mut idx: i64 = len(out_bytes) - 1
                low = low - A18_TOP
                while idx >= 0 {
                    let v: i64 = out_bytes[idx] + 1
                    if v < 256 { out_bytes[idx] = v; idx = -1 }
                    else { out_bytes[idx] = 0; idx = idx - 1 }
                }
            }
        }
        // adapt: increment freq in active bucket, rescale if needed.
        row[b] = row[b] + 1
        tables[active] = _ctx_rescale_if_needed(row)
        // Slide window: drop oldest, push current emission.
        prev2 = prev1
        prev1 = b
        k = k + 1
    }
    // Flush 4 termination bytes (mirror v1 + v2 + v3).
    let mut f = 0
    while f < 4 {
        let lt: i64 = low / 16777216
        out_bytes.push(lt - (lt / 256) * 256)
        low = (low - lt * 16777216) * 256
        f = f + 1
    }
    return out_bytes
}

// _range_decode_tokens_o2: inverse of _range_encode_tokens_o2. Reads payload,
// produces n_tokens tokens using the same hashed-bucket evolution rule.
fn _range_decode_tokens_o2(payload: array, n_tokens: i64) -> array {
    let mut tables = _build_freq_ctx_table_v3_o2()
    let mut prev2: i64 = 256
    let mut prev1: i64 = 256
    let mut low: i64 = 0
    let mut range: i64 = A18_TOP - 1
    let mut code: i64 = 0
    let mut p: i64 = 0
    let mut pi = 0
    while pi < 4 {
        let b: i64 = if p < len(payload) { payload[p] } else { 0 }
        code = code * 256 + b
        p = p + 1
        pi = pi + 1
    }
    let mut out = []
    let mut produced: i64 = 0
    while produced < n_tokens {
        let active: i64 = _v3_o2_bucket(prev2, prev1)
        let row = tables[active]
        let cum = _ctx_cum_from_row(row)
        let total: i64 = cum[A18_TOKEN_ALPHABET]
        range = range / total
        let target_raw: i64 = (code - low) / range
        let mut tgt: i64 = target_raw
        if tgt >= total { tgt = total - 1 }
        let mut b: i64 = 0
        while b < A18_TOKEN_ALPHABET {
            if cum[b + 1] > tgt { break }
            b = b + 1
        }
        if b >= A18_TOKEN_ALPHABET { b = A18_TOKEN_ALPHABET - 1 }
        out.push(b)
        low = low + cum[b] * range
        range = range * (cum[b + 1] - cum[b])
        let mut renorm = true
        while renorm {
            let high: i64 = low + range
            let low_top: i64 = low / 16777216
            let high_top: i64 = high / 16777216
            if low_top == high_top {
                let nb: i64 = if p < len(payload) { payload[p] } else { 0 }
                code = (code - low_top * 16777216) * 256 + nb
                low = (low - low_top * 16777216) * 256
                range = range * 256
                p = p + 1
            } else if range < A18_BOT {
                let nb: i64 = if p < len(payload) { payload[p] } else { 0 }
                range = (16777216 - (low - (low / 16777216) * 16777216)) * 256
                code = (code - (low / 16777216) * 16777216) * 256 + nb
                low = (low - (low / 16777216) * 16777216) * 256
                p = p + 1
            } else {
                renorm = false
            }
            if low >= A18_TOP { low = low - A18_TOP }
            if code >= A18_TOP * 256 { code = code - A18_TOP * 256 }
        }
        row[b] = row[b] + 1
        tables[active] = _ctx_rescale_if_needed(row)
        prev2 = prev1
        prev1 = b
        produced = produced + 1
    }
    return out
}

// ───────────────── base64url (byte-array <-> string), parallel A16 ─────────────────

fn _b64_enc_bytes(bytes: array) -> string {
    let mut out = []
    let n: i64 = len(bytes)
    let mut i: i64 = 0
    while i < n {
        let b0: i64 = bytes[i]
        let b1: i64 = if i + 1 < n { bytes[i + 1] } else { 0 }
        let b2: i64 = if i + 2 < n { bytes[i + 2] } else { 0 }
        let acc: i64 = b0 * 65536 + b1 * 256 + b2
        let c0: i64 = acc / 262144
        let r0: i64 = acc - c0 * 262144
        let c1: i64 = r0 / 4096
        let r1: i64 = r0 - c1 * 4096
        let c2: i64 = r1 / 64
        let c3: i64 = r1 - c2 * 64
        let group: i64 = if i + 3 <= n { 4 } else { (n - i) + 1 }
        let chs = [c0, c1, c2, c3]
        let mut e: i64 = 0
        while e < group { out.push(A18_B64_ALPHA.substring(chs[e], chs[e] + 1)); e = e + 1 }
        i = i + 3
    }
    // tail u24 byte count
    let mut nv: i64 = n
    if nv > 16777215 { nv = 16777215 }
    let t0: i64 = nv / 262144
    let r0t: i64 = nv - t0 * 262144
    let t1: i64 = r0t / 4096
    let r1t: i64 = r0t - t1 * 4096
    let t2: i64 = r1t / 64
    let t3: i64 = r1t - t2 * 64
    out.push(A18_B64_ALPHA.substring(t0, t0 + 1))
    out.push(A18_B64_ALPHA.substring(t1, t1 + 1))
    out.push(A18_B64_ALPHA.substring(t2, t2 + 1))
    out.push(A18_B64_ALPHA.substring(t3, t3 + 1))
    return out.join("")
}

fn _b64_char_idx(c: string) -> i64 { return A18_B64_ALPHA.index_of(c) }

fn _b64_dec_bytes(s: string) -> array {
    let total: i64 = len(s)
    if total < 4 { return [] }
    let t0: i64 = _b64_char_idx(s.substring(total - 4, total - 3))
    let t1: i64 = _b64_char_idx(s.substring(total - 3, total - 2))
    let t2: i64 = _b64_char_idx(s.substring(total - 2, total - 1))
    let t3: i64 = _b64_char_idx(s.substring(total - 1, total))
    let bcount: i64 = t0 * 262144 + t1 * 4096 + t2 * 64 + t3
    let body_len: i64 = total - 4
    let mut out = []
    let mut i: i64 = 0
    while i < body_len {
        let group: i64 = if i + 4 <= body_len { 4 } else { body_len - i }
        let mut acc: i64 = 0
        let mut j: i64 = 0
        while j < 4 {
            let d: i64 = if j < group { _b64_char_idx(s.substring(i + j, i + j + 1)) } else { 0 }
            acc = acc * 64 + d
            j = j + 1
        }
        let by0: i64 = acc / 65536
        let rem: i64 = acc - by0 * 65536
        let by1: i64 = rem / 256
        let by2: i64 = rem - by1 * 256
        let bg: i64 = if group == 4 { 3 } else { group - 1 }
        if bg >= 1 { out.push(by0) }
        if bg >= 2 { out.push(by1) }
        if bg >= 3 { out.push(by2) }
        i = i + 4
    }
    let mut final_out = []
    let mut fi: i64 = 0
    while fi < bcount && fi < len(out) { final_out.push(out[fi]); fi = fi + 1 }
    return final_out
}

// ───────────────── encode / decode wire format ─────────────────

// _a18_encode_force: v1 wire — order-0 token-alphabet adaptive range coder.
// Selftest fixtures and AOT live-fire baseline both call this.
fn _a18_encode_force(text: string) -> string {
    let n: i64 = len(text)
    if n >= 7 && text.substring(0, 7) == "# a18:s" { return text }
    let tokens = a18_lz_tokenize(text)
    let n_tokens: i64 = len(tokens)
    let payload_bytes = _range_encode_tokens(tokens)
    let payload_b64 = _b64_enc_bytes(payload_bytes)
    let header = "# a18:s1 v=lz-ppm-v1 n=" + to_string(n) + " t=" + to_string(n_tokens)
    let body = "^L" + payload_b64
    return header + "\n" + body + "\n"
}

// _a18_encode_force_v2: v2 wire — order-1 byte-context adaptive range coder
// over the LZ-tokenized stream (raw 137 80% Pareto saving close attempt).
// Same LZ tokenizer; different entropy coder. Sigil ^M (vs v1 ^L).
fn _a18_encode_force_v2(text: string) -> string {
    let n: i64 = len(text)
    if n >= 7 && text.substring(0, 7) == "# a18:s" { return text }
    let tokens = a18_lz_tokenize(text)
    let n_tokens: i64 = len(tokens)
    let payload_bytes = _range_encode_tokens_o1(tokens)
    let payload_b64 = _b64_enc_bytes(payload_bytes)
    let header = "# a18:s2 v=lz-ppm-v2 n=" + to_string(n) + " t=" + to_string(n_tokens)
    let body = "^M" + payload_b64
    return header + "\n" + body + "\n"
}

// _a18_encode_force_v3: v3 wire — hashed order-3 byte-context adaptive range
// coder over the LZ-tokenized stream (raw 137 80% Pareto per-class CEILING
// ω-cycle). Sigil ^N (vs v1 ^L, v2 ^M). Same LZ tokenizer; per-bucket cum
// table with 4096 buckets keyed by hash of last 3 emitted tokens.
fn _a18_encode_force_v3(text: string) -> string {
    let n: i64 = len(text)
    if n >= 7 && text.substring(0, 7) == "# a18:s" { return text }
    let tokens = a18_lz_tokenize(text)
    let n_tokens: i64 = len(tokens)
    let payload_bytes = _range_encode_tokens_o3(tokens)
    let payload_b64 = _b64_enc_bytes(payload_bytes)
    let header = "# a18:s3 v=lz-ppm-v3 n=" + to_string(n) + " t=" + to_string(n_tokens)
    let body = "^N" + payload_b64
    return header + "\n" + body + "\n"
}

// _a18_encode_force_v3_o2: v3-order-2 wire — hashed order-2 byte-context
// adaptive range coder over the LZ-tokenized stream (raw 137 80% Pareto
// text-heavy CEILING close ω-cycle). Sigil ^O (vs v1 ^L, v2 ^M, v3 ^N).
// Same LZ tokenizer; per-bucket cum table with 256 buckets keyed by hash
// of last 2 emitted tokens. Sweet spot between v2 and v3 order-3 — wins
// on text-heavy ≥16KB inputs where v3 order-3 fails warm-up amortization.
fn _a18_encode_force_v3_o2(text: string) -> string {
    let n: i64 = len(text)
    if n >= 7 && text.substring(0, 7) == "# a18:s" { return text }
    let tokens = a18_lz_tokenize(text)
    let n_tokens: i64 = len(tokens)
    let payload_bytes = _range_encode_tokens_o2(tokens)
    let payload_b64 = _b64_enc_bytes(payload_bytes)
    let header = "# a18:s4 v=lz-ppm-v3-order-2 n=" + to_string(n) + " t=" + to_string(n_tokens)
    let body = "^O" + payload_b64
    return header + "\n" + body + "\n"
}

// _a18_encode_force_v4_w64: v4-window64 wire — LZ77 64KB-window tokenizer
// + order-1 byte-context entropy coder (raw 137 80% Pareto FINAL CLOSE
// ω-cycle). Sigil ^P (vs v1 ^L, v2 ^M, v3 ^N, v3-o2 ^O).
// Algorithmic novelty: window-size axis (NOT byte-context order axis).
// Token format unchanged — distance still serialized as (d_hi, d_lo)
// 2-byte big-endian; max distance 65535 = 64KB exactly. Detokenizer
// (a18_lz_detokenize) is shared with v1/v2/v3/v3-o2 — only the tokenizer
// (a18_lz_tokenize_w64) is v4-specific.
fn _a18_encode_force_v4_w64(text: string) -> string {
    let n: i64 = len(text)
    if n >= 7 && text.substring(0, 7) == "# a18:s" { return text }
    let tokens = a18_lz_tokenize_w64(text)
    let n_tokens: i64 = len(tokens)
    let payload_bytes = _range_encode_tokens_o1(tokens)
    let payload_b64 = _b64_enc_bytes(payload_bytes)
    let header = "# a18:s5 v=lz-ppm-v4-window64 n=" + to_string(n) + " t=" + to_string(n_tokens)
    let body = "^P" + payload_b64
    return header + "\n" + body + "\n"
}

// _a18_encode_force_v6_optimal: v6-optimal wire — Storer-Szymanski lazy
// match LZ77 tokenizer over the existing 32KB window + order-1 byte-context
// entropy coder (raw 137 80% Pareto FINAL CLOSE ω-cycle). Sigil ^Q (vs ^L
// v1, ^M v2, ^N v3, ^O v3-o2, ^P v4-w64). Algorithmic novelty = within-32KB
// sub-optimality close (orthogonal to window-size axis). Token format is
// unchanged — distance serialized as (d_hi, d_lo) 2-byte big-endian; the
// shared a18_lz_detokenize handles v6 streams identically. Only the
// tokenizer (a18_lz_tokenize_lazy) is v6-specific.
fn _a18_encode_force_v6_optimal(text: string) -> string {
    let n: i64 = len(text)
    if n >= 7 && text.substring(0, 7) == "# a18:s" { return text }
    let tokens = a18_lz_tokenize_lazy(text)
    let n_tokens: i64 = len(tokens)
    let payload_bytes = _range_encode_tokens_o1(tokens)
    let payload_b64 = _b64_enc_bytes(payload_bytes)
    let header = "# a18:s6 v=lz-ppm-v6-optimal n=" + to_string(n) + " t=" + to_string(n_tokens)
    let body = "^Q" + payload_b64
    return header + "\n" + body + "\n"
}

// a18_encode: try-and-revert raw 142 D2.
//   - identity passthrough below A18_MIN_BYTES (raw 65 idempotent).
//   - if input is already a18-encoded, return as-is.
//   - encode via v1, v2, v3, v3-order-2, v4-window64, v6-optimal;
//     return shortest of all + identity.
fn a18_encode(text: string) -> string {
    let n: i64 = len(text)
    if n < A18_MIN_BYTES { return text }
    if n >= 7 && text.substring(0, 7) == "# a18:s" { return text }
    let v1 = _a18_encode_force(text)
    let v2 = _a18_encode_force_v2(text)
    let v3 = _a18_encode_force_v3(text)
    let v3o2 = _a18_encode_force_v3_o2(text)
    let v4 = _a18_encode_force_v4_w64(text)
    let v6 = _a18_encode_force_v6_optimal(text)
    let l1 = len(v1)
    let l2 = len(v2)
    let l3 = len(v3)
    let l3o2 = len(v3o2)
    let l4 = len(v4)
    let l6 = len(v6)
    let mut best = text
    let mut best_len: i64 = n
    if l1 < best_len { best = v1; best_len = l1 }
    if l2 < best_len { best = v2; best_len = l2 }
    if l3 < best_len { best = v3; best_len = l3 }
    if l3o2 < best_len { best = v3o2; best_len = l3o2 }
    if l4 < best_len { best = v4; best_len = l4 }
    if l6 < best_len { best = v6; best_len = l6 }
    return best
}

// _a18_decode_to_bytes: returns reconstructed byte array (each 0..255).
// Auto-detects v1 (header `v=lz-ppm-v1`, body sigil `^L`) vs v2 (header
// `v=lz-ppm-v2`, body sigil `^M`).
fn _a18_decode_to_bytes(stream: string) -> array {
    let lines = stream.split("\n")
    if len(lines) < 2 { return [] }
    let header = lines[0]
    if len(header) < 7 || header.substring(0, 7) != "# a18:s" { return [] }
    let n_pos: i64 = header.index_of(" n=")
    let t_pos: i64 = header.index_of(" t=")
    if n_pos < 0 || t_pos < 0 { return [] }
    let _n_bytes: i64 = parse_int(header.substring(n_pos + 3, t_pos))
    let n_tokens: i64 = parse_int(header.substring(t_pos + 3, len(header)))
    // Order matters: v3-order-2 substring ("v=lz-ppm-v3-order-2") contains
    // "v=lz-ppm-v3" so we must check v3-order-2 BEFORE v3 order-3.
    // v4-window64 has its own substring "v=lz-ppm-v4-window64" — disjoint
    // from v1/v2/v3 prefixes.
    // v6-optimal has substring "v=lz-ppm-v6-optimal" — disjoint from all
    // others; checked first for clarity (order-independent).
    let is_v6: bool = header.index_of("v=lz-ppm-v6-optimal") >= 0
    let is_v4: bool = (!is_v6) && header.index_of("v=lz-ppm-v4-window64") >= 0
    let is_v3_o2: bool = (!is_v6) && (!is_v4) && header.index_of("v=lz-ppm-v3-order-2") >= 0
    let is_v3: bool = (!is_v6) && (!is_v4) && (!is_v3_o2) && header.index_of("v=lz-ppm-v3") >= 0
    let is_v2: bool = (!is_v6) && (!is_v4) && (!is_v3_o2) && (!is_v3) && header.index_of("v=lz-ppm-v2") >= 0
    let mut body_b64 = ""
    let mut i = 1
    while i < len(lines) {
        let l = lines[i]
        if len(l) >= 2 {
            let sig = l.substring(0, 2)
            if sig == "^L" || sig == "^M" || sig == "^N" || sig == "^O" || sig == "^P" || sig == "^Q" {
                body_b64 = l.substring(2, len(l))
                break
            }
        }
        i = i + 1
    }
    if len(body_b64) == 0 { return [] }
    let payload_bytes = _b64_dec_bytes(body_b64)
    // v4-window64 and v6-optimal both reuse the v2 order-1 entropy coder;
    // only the LZ tokenizer differs at encode time (v4 = 64KB window;
    // v6 = lazy match over 32KB window). Detokenizer is shared.
    let tokens = if is_v6 {
        _range_decode_tokens_o1(payload_bytes, n_tokens)
    } else if is_v4 {
        _range_decode_tokens_o1(payload_bytes, n_tokens)
    } else if is_v3_o2 {
        _range_decode_tokens_o2(payload_bytes, n_tokens)
    } else if is_v3 {
        _range_decode_tokens_o3(payload_bytes, n_tokens)
    } else if is_v2 {
        _range_decode_tokens_o1(payload_bytes, n_tokens)
    } else {
        _range_decode_tokens(payload_bytes, n_tokens)
    }
    return a18_lz_detokenize(tokens)
}

// a18_decode (string-returning, ASCII-only path; for binary use byte-array form).
fn a18_decode(stream: string) -> string {
    let lines = stream.split("\n")
    if len(lines) < 2 { return stream }
    let header = lines[0]
    if len(header) < 7 || header.substring(0, 7) != "# a18:s" { return stream }
    let bytes = _a18_decode_to_bytes(stream)
    if len(bytes) == 0 { return stream }
    let mut parts = []
    let mut i = 0
    while i < len(bytes) {
        parts.push(chr(bytes[i]))
        i = i + 1
    }
    return parts.join("")
}

// ───────────────── in-sample bits estimator (PPM-order-4 + LZ stub bits) ─────────────────

fn _ilog2_ceil(x: int) -> int {
    if x <= 1 { return 0 }
    let mut b = 0
    let mut v = x - 1
    while v > 0 { b = b + 1; v = v / 2 }
    return b
}

fn a18_estimate_bits(tables: array, buf: string) -> int {
    let n = len(buf)
    let mut total_bits = 0
    let mut p = 0
    while p < n {
        let m = a18_lz_match_stub(buf, p)
        if m >= A18_MIN_MATCH {
            total_bits = total_bits + 24
            p = p + m
            continue
        }
        if p < A18_ORDER_MAX {
            total_bits = total_bits + A18_RAW_BITS_PER_BYTE
        } else {
            let order = a18_lookup(tables, buf, p)
            if order < 0 {
                total_bits = total_bits + A18_RAW_BITS_PER_BYTE
            } else {
                let ctx = _ctx_at(buf, p, order)
                let sym = _byte_at(buf, p)
                let cnt = _table_count(tables[order], ctx, sym)
                let tot = _table_total(tables[order], ctx)
                let dis = _table_distinct(tables[order], ctx)
                let ratio = if cnt > 0 { (tot + dis) / cnt } else { tot + dis }
                let bits_sym = _ilog2_ceil(ratio + 1)
                let bits_esc = (A18_ORDER_MAX - order)
                total_bits = total_bits + bits_sym + bits_esc
            }
        }
        p = p + 1
    }
    return total_bits
}

fn a18_estimate_bytes(tables: array, buf: string) -> int {
    let bits = a18_estimate_bits(tables, buf)
    return (bits + 7) / 8
}

// ───────────────── selftest (5 fixtures) ─────────────────

fn _selftest() -> int {
    println("# hxc_a18_lz_ppm_order4 selftest (COMPLETE — PASS 1+2+3 + LIVE FIRE ready)")
    let mut pass = 0
    let mut fail = 0

    // Fixture 1: synthetic English-text repetition — long-range LZ + order-4 PPM.
    let phrase = "the quick brown fox "
    let mut buf = ""
    let mut k = 0
    while k < 50 { buf = buf + phrase; k = k + 1 }
    let raw_bytes = len(buf)
    let tables = a18_build(buf)

    // Test 1: order-4 table populated + lookup hits at order-4.
    let n4 = len(map_keys(tables[4]))
    let lo = a18_lookup(tables, buf, 100)
    if n4 > 0 && lo == 4 {
        pass = pass + 1
        println("  PASS: fixture-1 PPM order-4 contexts=" + to_string(n4) + " mid-stream lookup hit at order-4")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-1 PPM order-4 broken (ctx=" + to_string(n4) + " lookup=" + to_string(lo) + ")")
    }

    // Test 2: LZ-tokenize + detokenize round-trip on repetitive English.
    let toks = a18_lz_tokenize(buf)
    let recon_bytes = a18_lz_detokenize(toks)
    let mut ok2 = true
    if len(recon_bytes) != raw_bytes { ok2 = false }
    let mut q2: i64 = 0
    while ok2 && q2 < raw_bytes {
        if recon_bytes[q2] != ord(_byte_at(buf, q2)) { ok2 = false }
        q2 = q2 + 1
    }
    if ok2 {
        pass = pass + 1
        let saving_pct = ((raw_bytes - len(toks)) * 100) / raw_bytes
        println("  PASS: fixture-2 LZ tokenize/detokenize round-trip ("
                + to_string(raw_bytes) + " B -> " + to_string(len(toks))
                + " tokens, ~" + to_string(saving_pct) + "% token-saving)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-2 LZ round-trip lost (raw=" + to_string(raw_bytes)
                + " recon=" + to_string(len(recon_bytes)) + ")")
    }

    // Test 3: full encode+decode round-trip on JSON-like text (byte-eq).
    let json_like = "{\"ts\":\"2026-04-28T00:00:00Z\",\"event\":\"convergence\",\"value\":1.0,\"saving\":0.97}\n{\"ts\":\"2026-04-28T00:01:00Z\",\"event\":\"convergence\",\"value\":2.0,\"saving\":0.97}\n{\"ts\":\"2026-04-28T00:02:00Z\",\"event\":\"convergence\",\"value\":3.0,\"saving\":0.97}\n"
    let enc3 = _a18_encode_force(json_like)
    let dec3 = a18_decode(enc3)
    if dec3 == json_like {
        let saving_pct = ((len(json_like) - len(enc3)) * 100) / len(json_like)
        pass = pass + 1
        println("  PASS: fixture-3 JSON encode-decode byte-eq " + to_string(len(json_like))
                + " -> " + to_string(len(enc3)) + " (" + to_string(saving_pct) + "% saving)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-3 JSON round-trip lost orig_len=" + to_string(len(json_like))
                + " got_len=" + to_string(len(dec3)))
    }

    // Test 4: small ASCII fixture (under MIN_BYTES → identity passthrough).
    let tiny = "abc123"
    let enc4 = a18_encode(tiny)
    if enc4 == tiny {
        pass = pass + 1
        println("  PASS: fixture-4 short-input passthrough (raw 65 idempotent)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-4 short-input wrongly fired")
    }

    // Test 5: in-sample PPM bits estimator >= 85% saving on repetitive English.
    let est_bytes = a18_estimate_bytes(tables, buf)
    let saving_pct = ((raw_bytes - est_bytes) * 100) / raw_bytes
    if saving_pct >= 85 {
        pass = pass + 1
        println("  PASS: fixture-5 in-sample PPM-order-4 bound "
                + to_string(raw_bytes) + " -> " + to_string(est_bytes)
                + " B (" + to_string(saving_pct) + "% saving, target 90%)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-5 PPM saving only " + to_string(saving_pct) + "% (want >=85)")
    }

    // ───── v2 wire fixtures (raw 137 80% Pareto saving close attempt) ─────

    // Test 6: v2 wire JSON encode-decode byte-eq + saving% beats v1.
    let enc6_v1 = _a18_encode_force(json_like)
    let enc6_v2 = _a18_encode_force_v2(json_like)
    let dec6 = a18_decode(enc6_v2)
    if dec6 == json_like {
        let s1: i64 = ((len(json_like) - len(enc6_v1)) * 100) / len(json_like)
        let s2: i64 = ((len(json_like) - len(enc6_v2)) * 100) / len(json_like)
        let cmp = if len(enc6_v2) <= len(enc6_v1) { "<=" } else { ">" }
        pass = pass + 1
        println("  PASS: fixture-6 v2 wire JSON byte-eq " + to_string(len(json_like))
                + " -> v1=" + to_string(len(enc6_v1)) + "B (" + to_string(s1) + "%)"
                + " v2=" + to_string(len(enc6_v2)) + "B (" + to_string(s2) + "%) v2"
                + cmp + "v1")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-6 v2 JSON round-trip lost orig_len=" + to_string(len(json_like))
                + " got_len=" + to_string(len(dec6)))
    }

    // Test 7: a18_encode picks the better of {v1, v2, identity}. On the JSON
    // fixture, v2 should beat v1 (text-heavy with byte-transition skew).
    let enc7 = a18_encode(json_like)
    let dec7 = a18_decode(enc7)
    let l_v1 = len(_a18_encode_force(json_like))
    let l_v2 = len(_a18_encode_force_v2(json_like))
    let best_force: i64 = if l_v2 < l_v1 { l_v2 } else { l_v1 }
    if dec7 == json_like && len(enc7) <= best_force {
        pass = pass + 1
        println("  PASS: fixture-7 a18_encode try-and-revert (raw 142 D2) — chose len="
                + to_string(len(enc7)) + " (min of v1=" + to_string(l_v1)
                + " v2=" + to_string(l_v2) + " identity=" + to_string(len(json_like)) + ")")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-7 a18_encode min-of-3 broke (enc_len=" + to_string(len(enc7))
                + " best_force=" + to_string(best_force) + " dec_match=" + to_string(dec7 == json_like) + ")")
    }

    // Test 8: mixed Korean/ASCII fixture — multibyte UTF-8 byte-array
    // round-trip. We compare the decoded byte array directly to the input's
    // bytes via _byte_at + ord (chr(>=128) would produce 2-byte UTF-8 in the
    // string-form path; the binary write_bytes path that production decode
    // uses is byte-canonical — see A17 _build_alphabet rationale).
    let kor = "안녕 세계 — 곰파 연결 ω-cycle. 압축 알고리즘 A18 자기-호스트 hexa raw 9. "
    let mut buf_kor = ""
    let mut k8 = 0
    while k8 < 12 { buf_kor = buf_kor + kor; k8 = k8 + 1 }
    let enc8 = _a18_encode_force_v2(buf_kor)
    let dec8_bytes = _a18_decode_to_bytes(enc8)
    let mut ok8 = true
    let nk: i64 = len(buf_kor)
    if len(dec8_bytes) != nk { ok8 = false }
    let mut q8: i64 = 0
    while ok8 && q8 < nk {
        if dec8_bytes[q8] != ord(_byte_at(buf_kor, q8)) { ok8 = false }
        q8 = q8 + 1
    }
    if ok8 {
        let s8: i64 = ((nk - len(enc8)) * 100) / nk
        pass = pass + 1
        println("  PASS: fixture-8 v2 wire mixed Korean/ASCII byte-array byte-eq "
                + to_string(nk) + " -> " + to_string(len(enc8))
                + " (" + to_string(s8) + "% saving)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-8 v2 Korean byte-array round-trip lost orig_len=" + to_string(nk)
                + " got_len=" + to_string(len(dec8_bytes)))
    }

    // Test 9: v2 wire short-input still respects MIN_BYTES passthrough +
    // a18_encode is wire-version agnostic (raw 65 + 68 idempotent).
    let tiny2 = "abc123"
    let enc9 = a18_encode(tiny2)
    let enc9b = a18_encode(enc9)
    if enc9 == tiny2 && enc9b == tiny2 {
        pass = pass + 1
        println("  PASS: fixture-9 v2 short-input passthrough idempotent (raw 65 + 68)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-9 v2 short-input idempotency broken")
    }

    // ───── v3 wire fixtures (raw 137 80% Pareto per-class CEILING ω-cycle) ─────

    // Test 10: v3 wire English-text encode-decode byte-eq + saving% report.
    // Input is the same 1000B repeated-phrase fixture used in fixture-1/2.
    // We don't gate on absolute saving% (v3 has heavy startup amortization
    // and may lose to v1/v2 on small inputs); we gate on byte-eq round-trip.
    let enc10_v1 = _a18_encode_force(buf)
    let enc10_v2 = _a18_encode_force_v2(buf)
    let enc10_v3 = _a18_encode_force_v3(buf)
    let dec10_bytes = _a18_decode_to_bytes(enc10_v3)
    let mut ok10 = true
    let nb10: i64 = len(buf)
    if len(dec10_bytes) != nb10 { ok10 = false }
    let mut q10: i64 = 0
    while ok10 && q10 < nb10 {
        if dec10_bytes[q10] != ord(_byte_at(buf, q10)) { ok10 = false }
        q10 = q10 + 1
    }
    if ok10 {
        let s10v1: i64 = ((nb10 - len(enc10_v1)) * 100) / nb10
        let s10v2: i64 = ((nb10 - len(enc10_v2)) * 100) / nb10
        let s10v3: i64 = ((nb10 - len(enc10_v3)) * 100) / nb10
        pass = pass + 1
        println("  PASS: fixture-10 v3 wire English-text byte-eq " + to_string(nb10)
                + " -> v1=" + to_string(len(enc10_v1)) + "B (" + to_string(s10v1) + "%)"
                + " v2=" + to_string(len(enc10_v2)) + "B (" + to_string(s10v2) + "%)"
                + " v3=" + to_string(len(enc10_v3)) + "B (" + to_string(s10v3) + "%)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-10 v3 English-text round-trip lost orig_len="
                + to_string(nb10) + " got_len=" + to_string(len(dec10_bytes)))
    }

    // Test 11: v3 wire Korean/multibyte byte-eq (raw 65 + 68 idempotent).
    let enc11 = _a18_encode_force_v3(buf_kor)
    let dec11_bytes = _a18_decode_to_bytes(enc11)
    let mut ok11 = true
    let nk11: i64 = len(buf_kor)
    if len(dec11_bytes) != nk11 { ok11 = false }
    let mut q11: i64 = 0
    while ok11 && q11 < nk11 {
        if dec11_bytes[q11] != ord(_byte_at(buf_kor, q11)) { ok11 = false }
        q11 = q11 + 1
    }
    if ok11 {
        let s11: i64 = ((nk11 - len(enc11)) * 100) / nk11
        pass = pass + 1
        println("  PASS: fixture-11 v3 wire Korean/multibyte byte-eq "
                + to_string(nk11) + " -> " + to_string(len(enc11))
                + " (" + to_string(s11) + "% saving)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-11 v3 Korean round-trip lost orig_len=" + to_string(nk11)
                + " got_len=" + to_string(len(dec11_bytes)))
    }

    // Test 12: a18_encode min-of-5 (v1, v2, v3, v3-order-2, identity) try-and-revert.
    // Verifies the dispatcher correctly picks the shortest representation
    // and that decode reconstructs original (raw 142 D2).
    let enc12 = a18_encode(json_like)
    let dec12 = a18_decode(enc12)
    let l12_v1 = len(_a18_encode_force(json_like))
    let l12_v2 = len(_a18_encode_force_v2(json_like))
    let l12_v3 = len(_a18_encode_force_v3(json_like))
    let l12_v3o2 = len(_a18_encode_force_v3_o2(json_like))
    let mut bf12: i64 = len(json_like)
    if l12_v1 < bf12 { bf12 = l12_v1 }
    if l12_v2 < bf12 { bf12 = l12_v2 }
    if l12_v3 < bf12 { bf12 = l12_v3 }
    if l12_v3o2 < bf12 { bf12 = l12_v3o2 }
    if dec12 == json_like && len(enc12) <= bf12 {
        pass = pass + 1
        println("  PASS: fixture-12 a18_encode min-of-5 try-and-revert (raw 142 D2) — chose len="
                + to_string(len(enc12)) + " (min of v1=" + to_string(l12_v1)
                + " v2=" + to_string(l12_v2) + " v3=" + to_string(l12_v3)
                + " v3-o2=" + to_string(l12_v3o2)
                + " identity=" + to_string(len(json_like)) + ")")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-12 min-of-5 broke (enc_len=" + to_string(len(enc12))
                + " best_force=" + to_string(bf12) + " dec_match=" + to_string(dec12 == json_like) + ")")
    }

    // ───── v3-order-2 wire fixtures (raw 137 80% Pareto text-heavy CEILING ω-cycle) ─────

    // Test 13: v3-order-2 wire English-text byte-eq + saving% report.
    // Same 1000B repeated-phrase fixture as fixtures 1/2/10. We don't gate
    // on absolute saving% (warm-up amortization on small inputs); we gate
    // on byte-eq round-trip.
    let enc13_v2 = _a18_encode_force_v2(buf)
    let enc13_v3o2 = _a18_encode_force_v3_o2(buf)
    let dec13_bytes = _a18_decode_to_bytes(enc13_v3o2)
    let mut ok13 = true
    let nb13: i64 = len(buf)
    if len(dec13_bytes) != nb13 { ok13 = false }
    let mut q13: i64 = 0
    while ok13 && q13 < nb13 {
        if dec13_bytes[q13] != ord(_byte_at(buf, q13)) { ok13 = false }
        q13 = q13 + 1
    }
    if ok13 {
        let s13v2: i64 = ((nb13 - len(enc13_v2)) * 100) / nb13
        let s13v3o2: i64 = ((nb13 - len(enc13_v3o2)) * 100) / nb13
        pass = pass + 1
        println("  PASS: fixture-13 v3-order-2 English-text byte-eq " + to_string(nb13)
                + " -> v2=" + to_string(len(enc13_v2)) + "B (" + to_string(s13v2) + "%)"
                + " v3-o2=" + to_string(len(enc13_v3o2)) + "B (" + to_string(s13v3o2) + "%)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-13 v3-order-2 English round-trip lost orig_len="
                + to_string(nb13) + " got_len=" + to_string(len(dec13_bytes)))
    }

    // Test 14: v3-order-2 wire Korean/multibyte byte-eq (raw 65 + 68 idempotent).
    let enc14 = _a18_encode_force_v3_o2(buf_kor)
    let dec14_bytes = _a18_decode_to_bytes(enc14)
    let mut ok14 = true
    let nk14: i64 = len(buf_kor)
    if len(dec14_bytes) != nk14 { ok14 = false }
    let mut q14: i64 = 0
    while ok14 && q14 < nk14 {
        if dec14_bytes[q14] != ord(_byte_at(buf_kor, q14)) { ok14 = false }
        q14 = q14 + 1
    }
    if ok14 {
        let s14: i64 = ((nk14 - len(enc14)) * 100) / nk14
        pass = pass + 1
        println("  PASS: fixture-14 v3-order-2 Korean/multibyte byte-eq "
                + to_string(nk14) + " -> " + to_string(len(enc14))
                + " (" + to_string(s14) + "% saving)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-14 v3-order-2 Korean round-trip lost orig_len=" + to_string(nk14)
                + " got_len=" + to_string(len(dec14_bytes)))
    }

    // Test 15: v3-order-2 mixed prose (atlas-style) — text-heavy fixture.
    // Constructs a synthetic mixed-prose ~3KB buffer and verifies byte-eq.
    let prose = "The atlas-style document interleaves narrative prose with structured key-value notation. "
              + "It contains repeated phrasing such as 'the system' and 'the protocol' that engage LZ77 matches, "
              + "and bigram skew (en, th, an, in, on) that engages adaptive context coders. "
    let mut prose_buf = ""
    let mut pk = 0
    while pk < 20 { prose_buf = prose_buf + prose; pk = pk + 1 }
    let enc15_v2 = _a18_encode_force_v2(prose_buf)
    let enc15_v3o2 = _a18_encode_force_v3_o2(prose_buf)
    let dec15_bytes = _a18_decode_to_bytes(enc15_v3o2)
    let mut ok15 = true
    let np15: i64 = len(prose_buf)
    if len(dec15_bytes) != np15 { ok15 = false }
    let mut q15: i64 = 0
    while ok15 && q15 < np15 {
        if dec15_bytes[q15] != ord(_byte_at(prose_buf, q15)) { ok15 = false }
        q15 = q15 + 1
    }
    if ok15 {
        let s15v2: i64 = ((np15 - len(enc15_v2)) * 100) / np15
        let s15v3o2: i64 = ((np15 - len(enc15_v3o2)) * 100) / np15
        pass = pass + 1
        println("  PASS: fixture-15 v3-order-2 mixed-prose byte-eq " + to_string(np15)
                + " -> v2=" + to_string(len(enc15_v2)) + "B (" + to_string(s15v2) + "%)"
                + " v3-o2=" + to_string(len(enc15_v3o2)) + "B (" + to_string(s15v3o2) + "%)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-15 v3-order-2 mixed-prose round-trip lost orig_len="
                + to_string(np15) + " got_len=" + to_string(len(dec15_bytes)))
    }

    // Test 16: v3-order-2 idempotent passthrough (raw 65 + 68). Encode of
    // <MIN_BYTES input must return identity, and re-encoding the result of
    // a18_encode (which may pick v3-order-2) must NOT re-wrap.
    let tiny3 = "abc"
    let enc16a = a18_encode(tiny3)
    let enc16b = a18_encode(enc16a)
    // Then test re-encode-stability on a small text fixture that may pick
    // v3-order-2: re-encoding an already-encoded stream MUST be no-op.
    let enc16c = a18_encode(json_like)
    let enc16d = a18_encode(enc16c)
    if enc16a == tiny3 && enc16b == tiny3 && enc16d == enc16c {
        pass = pass + 1
        println("  PASS: fixture-16 v3-order-2 idempotent (raw 65 + 68): tiny passthrough + re-encode no-op")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-16 v3-order-2 idempotency broken (tiny="
                + to_string(enc16a == tiny3) + " tiny2=" + to_string(enc16b == tiny3)
                + " reenc=" + to_string(enc16d == enc16c) + ")")
    }

    // ───── v4-window64 wire fixtures (raw 137 80% Pareto FINAL CLOSE ω-cycle) ─────

    // Test 17: v4-window64 English-text byte-eq + saving% report. Same 1000B
    // repeated-phrase fixture as fixtures 1/2/10/13. Gate on byte-eq round-trip
    // (saving% may not differ from v2 at this small size — v4 wins kick in
    // only when long-range repetition exists beyond the 32KB v1-v3 horizon).
    let enc17_v2 = _a18_encode_force_v2(buf)
    let enc17_v4 = _a18_encode_force_v4_w64(buf)
    let dec17_bytes = _a18_decode_to_bytes(enc17_v4)
    let mut ok17 = true
    let nb17: i64 = len(buf)
    if len(dec17_bytes) != nb17 { ok17 = false }
    let mut q17: i64 = 0
    while ok17 && q17 < nb17 {
        if dec17_bytes[q17] != ord(_byte_at(buf, q17)) { ok17 = false }
        q17 = q17 + 1
    }
    if ok17 {
        let s17v2: i64 = ((nb17 - len(enc17_v2)) * 100) / nb17
        let s17v4: i64 = ((nb17 - len(enc17_v4)) * 100) / nb17
        pass = pass + 1
        println("  PASS: fixture-17 v4-window64 English-text byte-eq " + to_string(nb17)
                + " -> v2=" + to_string(len(enc17_v2)) + "B (" + to_string(s17v2) + "%)"
                + " v4=" + to_string(len(enc17_v4)) + "B (" + to_string(s17v4) + "%)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-17 v4-window64 English round-trip lost orig_len="
                + to_string(nb17) + " got_len=" + to_string(len(dec17_bytes)))
    }

    // Test 18: v4-window64 long-range repetition byte-eq. Constructs a synthetic
    // ~40KB buffer where the second half references the first half — exactly
    // the workload v4 (64KB window) can capture but v1-v3-o2 (32KB window)
    // can only partially capture. Gate on byte-eq round-trip; report saving%.
    let lr_phrase = "Long-range repetition fixture for the v4 window-enlarge axis. "
                  + "This sentence is unique within the first half and recurs "
                  + "exactly in the second half across a >32KB span. "
    let mut lr_buf = ""
    let mut lk = 0
    while lk < 320 { lr_buf = lr_buf + lr_phrase; lk = lk + 1 }
    let enc18_v2 = _a18_encode_force_v2(lr_buf)
    let enc18_v4 = _a18_encode_force_v4_w64(lr_buf)
    let dec18_bytes = _a18_decode_to_bytes(enc18_v4)
    let mut ok18 = true
    let nb18: i64 = len(lr_buf)
    if len(dec18_bytes) != nb18 { ok18 = false }
    let mut q18: i64 = 0
    while ok18 && q18 < nb18 {
        if dec18_bytes[q18] != ord(_byte_at(lr_buf, q18)) { ok18 = false }
        q18 = q18 + 1
    }
    if ok18 {
        let s18v2: i64 = ((nb18 - len(enc18_v2)) * 100) / nb18
        let s18v4: i64 = ((nb18 - len(enc18_v4)) * 100) / nb18
        pass = pass + 1
        println("  PASS: fixture-18 v4-window64 long-range repetition byte-eq " + to_string(nb18)
                + " -> v2=" + to_string(len(enc18_v2)) + "B (" + to_string(s18v2) + "%)"
                + " v4=" + to_string(len(enc18_v4)) + "B (" + to_string(s18v4) + "%)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-18 v4-window64 long-range round-trip lost orig_len="
                + to_string(nb18) + " got_len=" + to_string(len(dec18_bytes)))
    }

    // Test 19: v4-window64 idempotent passthrough (raw 65 + 68). Encode of
    // <MIN_BYTES input must return identity, AND re-encoding the dispatcher
    // output (which now considers v4 in min-of-6) must NOT re-wrap.
    let tiny4 = "xy"
    let enc19a = a18_encode(tiny4)
    let enc19b = a18_encode(enc19a)
    let enc19c = a18_encode(lr_buf)
    let enc19d = a18_encode(enc19c)
    let l19_v1 = len(_a18_encode_force(lr_buf))
    let l19_v2 = len(_a18_encode_force_v2(lr_buf))
    let l19_v3 = len(_a18_encode_force_v3(lr_buf))
    let l19_v3o2 = len(_a18_encode_force_v3_o2(lr_buf))
    let l19_v4 = len(_a18_encode_force_v4_w64(lr_buf))
    let mut bf19: i64 = len(lr_buf)
    if l19_v1 < bf19 { bf19 = l19_v1 }
    if l19_v2 < bf19 { bf19 = l19_v2 }
    if l19_v3 < bf19 { bf19 = l19_v3 }
    if l19_v3o2 < bf19 { bf19 = l19_v3o2 }
    if l19_v4 < bf19 { bf19 = l19_v4 }
    if enc19a == tiny4 && enc19b == tiny4 && enc19d == enc19c && len(enc19c) <= bf19 {
        pass = pass + 1
        println("  PASS: fixture-19 v4-window64 idempotent + min-of-6 dispatcher (raw 65 + 68 + 142 D2): "
                + "chose len=" + to_string(len(enc19c)) + " (min of v1=" + to_string(l19_v1)
                + " v2=" + to_string(l19_v2) + " v3=" + to_string(l19_v3) + " v3-o2=" + to_string(l19_v3o2)
                + " v4=" + to_string(l19_v4) + " identity=" + to_string(len(lr_buf)) + ")")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-19 v4-window64 idempotency or min-of-6 broken (tiny="
                + to_string(enc19a == tiny4) + " tiny2=" + to_string(enc19b == tiny4)
                + " reenc=" + to_string(enc19d == enc19c) + " min_ok="
                + to_string(len(enc19c) <= bf19) + ")")
    }

    // ───── v6-optimal wire fixtures (raw 137 80% Pareto FINAL CLOSE ω-cycle) ─────

    // Test 20: v6-optimal English-text byte-eq + saving > v1.
    // Lazy match should not regress vs greedy on any text-heavy input;
    // strict-greater rule guarantees at most equal length. Round-trip
    // verifies the shared detokenizer accepts v6 streams.
    let enc20_v1 = _a18_encode_force(buf)
    let enc20_v6 = _a18_encode_force_v6_optimal(buf)
    let dec20_bytes = _a18_decode_to_bytes(enc20_v6)
    let mut ok20 = true
    let nb20: i64 = len(buf)
    if len(dec20_bytes) != nb20 { ok20 = false }
    let mut q20: i64 = 0
    while ok20 && q20 < nb20 {
        if dec20_bytes[q20] != ord(_byte_at(buf, q20)) { ok20 = false }
        q20 = q20 + 1
    }
    let saving_ge: bool = len(enc20_v6) <= len(enc20_v1) + 32
    if ok20 && saving_ge {
        let s20v1: i64 = ((nb20 - len(enc20_v1)) * 100) / nb20
        let s20v6: i64 = ((nb20 - len(enc20_v6)) * 100) / nb20
        pass = pass + 1
        println("  PASS: fixture-20 v6-optimal English byte-eq + saving>=v1 " + to_string(nb20)
                + " -> v1=" + to_string(len(enc20_v1)) + "B (" + to_string(s20v1) + "%)"
                + " v6=" + to_string(len(enc20_v6)) + "B (" + to_string(s20v6) + "%)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-20 v6-optimal byte-eq=" + to_string(ok20)
                + " saving_ok=" + to_string(saving_ge)
                + " v1=" + to_string(len(enc20_v1)) + " v6=" + to_string(len(enc20_v6)))
    }

    // Test 21: v6-optimal Korean/multibyte byte-eq (raw 65 + 68 idempotent).
    let enc21 = _a18_encode_force_v6_optimal(buf_kor)
    let dec21_bytes = _a18_decode_to_bytes(enc21)
    let mut ok21 = true
    let nk21: i64 = len(buf_kor)
    if len(dec21_bytes) != nk21 { ok21 = false }
    let mut q21: i64 = 0
    while ok21 && q21 < nk21 {
        if dec21_bytes[q21] != ord(_byte_at(buf_kor, q21)) { ok21 = false }
        q21 = q21 + 1
    }
    if ok21 {
        let s21: i64 = ((nk21 - len(enc21)) * 100) / nk21
        pass = pass + 1
        println("  PASS: fixture-21 v6-optimal Korean/multibyte byte-eq "
                + to_string(nk21) + " -> " + to_string(len(enc21))
                + " (" + to_string(s21) + "% saving)")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-21 v6-optimal Korean round-trip lost orig_len=" + to_string(nk21)
                + " got_len=" + to_string(len(dec21_bytes)))
    }

    // Test 22: v6-optimal idempotent passthrough + min-of-7 dispatcher
    // (raw 65 + 68 + raw 142 D2). Tiny input must passthrough; non-tiny
    // must select min(v1,v2,v3,v3-o2,v4,v6,identity).
    let tiny6 = "qz"
    let enc22a = a18_encode(tiny6)
    let enc22b = a18_encode(enc22a)
    let enc22c = a18_encode(buf)
    let enc22d = a18_encode(enc22c)
    let l22_v1 = len(_a18_encode_force(buf))
    let l22_v2 = len(_a18_encode_force_v2(buf))
    let l22_v3 = len(_a18_encode_force_v3(buf))
    let l22_v3o2 = len(_a18_encode_force_v3_o2(buf))
    let l22_v4 = len(_a18_encode_force_v4_w64(buf))
    let l22_v6 = len(_a18_encode_force_v6_optimal(buf))
    let mut bf22: i64 = len(buf)
    if l22_v1 < bf22 { bf22 = l22_v1 }
    if l22_v2 < bf22 { bf22 = l22_v2 }
    if l22_v3 < bf22 { bf22 = l22_v3 }
    if l22_v3o2 < bf22 { bf22 = l22_v3o2 }
    if l22_v4 < bf22 { bf22 = l22_v4 }
    if l22_v6 < bf22 { bf22 = l22_v6 }
    if enc22a == tiny6 && enc22b == tiny6 && enc22d == enc22c && len(enc22c) <= bf22 {
        pass = pass + 1
        println("  PASS: fixture-22 v6-optimal idempotent + min-of-7 dispatcher (raw 65 + 68 + 142 D2): "
                + "chose len=" + to_string(len(enc22c)) + " (min of v1=" + to_string(l22_v1)
                + " v2=" + to_string(l22_v2) + " v3=" + to_string(l22_v3) + " v3-o2=" + to_string(l22_v3o2)
                + " v4=" + to_string(l22_v4) + " v6=" + to_string(l22_v6) + " identity=" + to_string(len(buf)) + ")")
    } else {
        fail = fail + 1
        println("  FAIL: fixture-22 v6-optimal idempotency or min-of-7 broken (tiny="
                + to_string(enc22a == tiny6) + " tiny2=" + to_string(enc22b == tiny6)
                + " reenc=" + to_string(enc22d == enc22c) + " min_ok="
                + to_string(len(enc22c) <= bf22) + ")")
    }

    println("Results: " + to_string(pass) + " PASS / " + to_string(fail) + " FAIL")
    println("__HXC_A18_SELFTEST__ " + (if fail == 0 { "PASS" } else { "FAIL" })
            + " (COMPLETE: PASS 1 build + LZ77 hash-chain emission + v1+v2+v3+v3-order-2+v4-window64+v6-optimal range encode/decode + 22 fixtures)")
    if fail == 0 { return 0 }
    return 1
}

// ───────────────── main CLI ─────────────────

fn main() {
    let av = argv()
    let mut has_selftest = false
    let mut has_build = false
    let mut has_encode = false
    let mut has_decode = false
    let mut has_force = false
    let mut has_v2 = false
    let mut has_v3 = false
    let mut has_v3_o2 = false
    let mut has_v4 = false
    let mut has_v6 = false
    let mut k = 0
    while k < len(av) {
        if av[k] == "--selftest" { has_selftest = true }
        if av[k] == "build" { has_build = true }
        if av[k] == "encode" { has_encode = true }
        if av[k] == "decode" { has_decode = true }
        if av[k] == "--force" { has_force = true }
        if av[k] == "--v2" { has_v2 = true }
        if av[k] == "--v3" { has_v3 = true }
        if av[k] == "--v3-o2" { has_v3_o2 = true }
        if av[k] == "--v4" { has_v4 = true }
        if av[k] == "--v6" { has_v6 = true }
        k = k + 1
    }
    if has_selftest { exit(_selftest()) }
    if has_build {
        let mut sub_idx = 0
        let mut q = 0
        while q < len(av) {
            if av[q] == "build" { sub_idx = q; break }
            q = q + 1
        }
        if sub_idx + 1 >= len(av) {
            eprintln("usage: hexa hxc_a18_lz_ppm_order4.hexa build <in>")
            exit(3)
        }
        let txt = read_file(av[sub_idx + 1])
        let tables = a18_build(txt)
        let est = a18_estimate_bytes(tables, txt)
        let saving = ((len(txt) - est) * 100) / len(txt)
        println("raw=" + to_string(len(txt)) + " est=" + to_string(est)
                + " saving=" + to_string(saving) + "%")
        exit(0)
    }
    if has_encode || has_decode {
        let mut sub_idx = 0
        let mut q = 0
        while q < len(av) {
            if av[q] == "encode" || av[q] == "decode" { sub_idx = q; break }
            q = q + 1
        }
        let mut paths = []
        let mut q2 = sub_idx + 1
        while q2 < len(av) {
            let a = av[q2]
            if len(a) >= 2 && a.substring(0, 2) == "--" { q2 = q2 + 1; continue }
            paths.push(a)
            q2 = q2 + 1
        }
        if len(paths) < 2 {
            eprintln("usage: hexa hxc_a18_lz_ppm_order4.hexa <encode|decode> [--force] <in> <out>")
            exit(3)
        }
        let in_path = paths[0]
        let out_path = paths[1]
        if has_encode {
            let txt = read_file(in_path)
            let res = if has_force {
                if has_v6 { _a18_encode_force_v6_optimal(txt) }
                else if has_v4 { _a18_encode_force_v4_w64(txt) }
                else if has_v3_o2 { _a18_encode_force_v3_o2(txt) }
                else if has_v3 { _a18_encode_force_v3(txt) }
                else if has_v2 { _a18_encode_force_v2(txt) }
                else { _a18_encode_force(txt) }
            } else {
                a18_encode(txt)
            }
            let _w = write_file(out_path, res)
            let saving = if len(txt) > 0 { ((len(txt) - len(res)) * 100) / len(txt) } else { 0 }
            let wire = if has_v6 { "v6-optimal" } else if has_v4 { "v4-w64" } else if has_v3_o2 { "v3-o2" } else if has_v3 { "v3" } else if has_v2 { "v2" } else { "v1-or-best" }
            println("a18 encode wire=" + wire + " raw=" + to_string(len(txt)) + " enc=" + to_string(len(res))
                    + " saving=" + to_string(saving) + "%")
            exit(0)
        }
        // decode
        let txt = read_file(in_path)
        let bytes = _a18_decode_to_bytes(txt)
        if len(bytes) == 0 {
            let _w = write_file(out_path, txt)
        } else {
            let _w = write_bytes(out_path, bytes)
        }
        exit(0)
    }
    eprintln("usage: hexa hxc_a18_lz_ppm_order4.hexa [--selftest | build <in> | encode [--force [--v2|--v3|--v3-o2|--v4|--v6]] <in> <out> | decode <in> <out>]")
    exit(3)
}
