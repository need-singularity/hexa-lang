// ═══════════════════════════════════════════════════════════════════════
//  self/stdlib/term.hexa — terminal capability detection (TTY/size/color)
//
//  PURPOSE
//      Pure-hexa terminal capability gateway. Resolves FRONTEND-2
//      blocker for hive `packages/tui` port: 63 .ts files in
//      packages/tui/src/ depend on stdout/stderr TTY-ness, terminal
//      dimensions (cols/rows), and color support tier (mono / 16 /
//      256 / truecolor). Until now, hexa stdlib only had `os_getenv`
//      and `exec()`; no first-class capability layer existed.
//
//  EXPORTS
//      term_is_tty()              -> bool      // stdout is a tty
//      term_stderr_is_tty()       -> bool      // stderr is a tty
//      term_size()                -> map       // { cols, rows }
//      term_columns()             -> i64       // shortcut, fallback 80
//      term_rows()                -> i64       // shortcut, fallback 24
//      term_color_tier()          -> string    // "none" | "16" | "256" | "truecolor"
//      term_supports_color()      -> bool      // tier != "none"
//      term_program()             -> string    // $TERM_PROGRAM or ""
//      term_term()                -> string    // $TERM
//
//  CAVEATS (raw 91 honest)
//      * isTTY detection uses `[ -t 1 ]` shell test via `exec()`. This
//        is correct but fork-per-call. Memoize in caller hot loops.
//      * size detection uses `stty size` (rows cols) → env COLUMNS/LINES
//        → fallback (24, 80). When stdin is not a TTY, `stty size`
//        prints to stderr and exits 1; we swallow and use env/fallback.
//      * color tier inference is heuristic: $COLORTERM=truecolor →
//        truecolor; $TERM contains "256" → 256; $TERM in {dumb, ""} →
//        none; else 16.
//
//  RAW 159 UPSTREAM GAP
//      A native ioctl(TIOCGWINSZ) / isatty(fd) syscall surface in
//      hexa runtime would replace fork-per-call. Tracked under raw
//      159 hexa-lang upstream proposal pattern. For now we ship the
//      shell-fallback impl; runtime can later swap _term_isatty_fd
//      and _term_winsize impls without changing this module's API.
//
//  USAGE
//      use "self/stdlib/term"
//      if term_is_tty() {
//          let cols = term_columns()
//          let tier = term_color_tier()
//          println("tty=" + to_string(cols) + " tier=" + tier)
//      }
//
//  --selftest:
//      hexa run self/stdlib/term.hexa --selftest
//        → __TERM_TERM_SELFTEST__ <PASS|FAIL> n=<N> fail=<M>
// ═══════════════════════════════════════════════════════════════════════

// Local getenv to avoid pulling in os.hexa's --selftest auto-fire
// (existing module's selftest fires on any --selftest in argv).
fn _term_getenv(name: string) -> string {
    if len(name) == 0 { return "" }
    return to_string(env_var(name))
}

// ── Internal: shell-based TTY check ────────────────────────────────
// Returns true iff fd N (1=stdout, 2=stderr) is a TTY.
fn _term_isatty_fd(fd: i64) -> bool {
    let cmd = "[ -t " + to_string(fd) + " ] && echo 1 || echo 0"
    let out = to_string(exec(cmd)).trim()
    return out == "1"
}

pub fn term_is_tty() -> bool {
    return _term_isatty_fd(1)
}

pub fn term_stderr_is_tty() -> bool {
    return _term_isatty_fd(2)
}

// ── term_size() — { cols, rows } ───────────────────────────────────
// Order: stty size → $COLUMNS/$LINES → (80, 24).
pub fn term_size() {
    let mut out = {}
    // Try stty (must run against /dev/tty if stdin is not a TTY).
    let raw = to_string(exec("(stty size </dev/tty) 2>/dev/null")).trim()
    if len(raw) > 0 {
        let parts = raw.split(" ")
        if len(parts) == 2 {
            // Cheap parse: digits only, otherwise reject.
            let r = _term_parse_int(parts[0])
            let c = _term_parse_int(parts[1])
            if r > 0 && c > 0 {
                out["cols"] = c
                out["rows"] = r
                return out
            }
        }
    }
    // Env fallback.
    let env_c = _term_parse_int(_term_getenv("COLUMNS"))
    let env_r = _term_parse_int(_term_getenv("LINES"))
    let cols = if env_c > 0 { env_c } else { 80 }
    let rows = if env_r > 0 { env_r } else { 24 }
    out["cols"] = cols
    out["rows"] = rows
    return out
}

pub fn term_columns() -> i64 {
    let s = term_size()
    return s["cols"]
}

pub fn term_rows() -> i64 {
    let s = term_size()
    return s["rows"]
}

// ── term_color_tier() — heuristic color capability ─────────────────
pub fn term_color_tier() -> string {
    let term = _term_getenv("TERM")
    if len(term) == 0 || term == "dumb" { return "none" }
    let colorterm = _term_getenv("COLORTERM")
    if colorterm == "truecolor" || colorterm == "24bit" {
        return "truecolor"
    }
    // $TERM containing "256" → 256-color.
    if term.contains("256") { return "256" }
    return "16"
}

pub fn term_supports_color() -> bool {
    return term_color_tier() != "none"
}

pub fn term_program() -> string {
    return _term_getenv("TERM_PROGRAM")
}

pub fn term_term() -> string {
    return _term_getenv("TERM")
}

// ── parse_int helper (defensive) ───────────────────────────────────
fn _term_parse_int(s: string) -> i64 {
    let t = s.trim()
    if len(t) == 0 { return 0 }
    let mut i = 0
    let mut acc = 0
    while i < len(t) {
        let ch = t.substring(i, i + 1)
        if ch == "0" { acc = acc * 10 + 0 }
        else if ch == "1" { acc = acc * 10 + 1 }
        else if ch == "2" { acc = acc * 10 + 2 }
        else if ch == "3" { acc = acc * 10 + 3 }
        else if ch == "4" { acc = acc * 10 + 4 }
        else if ch == "5" { acc = acc * 10 + 5 }
        else if ch == "6" { acc = acc * 10 + 6 }
        else if ch == "7" { acc = acc * 10 + 7 }
        else if ch == "8" { acc = acc * 10 + 8 }
        else if ch == "9" { acc = acc * 10 + 9 }
        else { return 0 }
        i = i + 1
    }
    return acc
}

// ── --selftest ─────────────────────────────────────────────────────
fn _term_selftest() {
    let mut fail = 0
    let mut n = 0

    // 1. term_is_tty() returns a bool (true or false; either is valid)
    n = n + 1
    let tty = term_is_tty()
    if tty != true && tty != false {
        eprintln("FAIL 1 term_is_tty not bool")
        fail = fail + 1
    }

    // 2. term_size() returns map with positive cols/rows
    n = n + 1
    let sz = term_size()
    if sz["cols"] <= 0 || sz["rows"] <= 0 {
        eprintln("FAIL 2 term_size cols/rows nonpos: " + to_string(sz["cols"]) + "/" + to_string(sz["rows"]))
        fail = fail + 1
    }

    // 3. term_columns() / term_rows() shortcuts agree with term_size()
    n = n + 1
    if term_columns() != sz["cols"] {
        eprintln("FAIL 3a columns mismatch")
        fail = fail + 1
    }
    n = n + 1
    if term_rows() != sz["rows"] {
        eprintln("FAIL 3b rows mismatch")
        fail = fail + 1
    }

    // 4. term_color_tier() in valid set
    n = n + 1
    let tier = term_color_tier()
    if tier != "none" && tier != "16" && tier != "256" && tier != "truecolor" {
        eprintln("FAIL 4 unknown tier: " + tier)
        fail = fail + 1
    }

    // 5. term_supports_color() consistent with tier
    n = n + 1
    let sc = term_supports_color()
    if (tier == "none" && sc) || (tier != "none" && !sc) {
        eprintln("FAIL 5 supports_color/tier mismatch")
        fail = fail + 1
    }

    // 6. _term_parse_int correctness
    n = n + 1
    if _term_parse_int("42") != 42 { eprintln("FAIL 6a"); fail = fail + 1 }
    n = n + 1
    if _term_parse_int("0") != 0 { eprintln("FAIL 6b"); fail = fail + 1 }
    n = n + 1
    if _term_parse_int("") != 0 { eprintln("FAIL 6c"); fail = fail + 1 }
    n = n + 1
    if _term_parse_int("abc") != 0 { eprintln("FAIL 6d"); fail = fail + 1 }
    n = n + 1
    if _term_parse_int("12abc") != 0 { eprintln("FAIL 6e"); fail = fail + 1 }
    n = n + 1
    if _term_parse_int(" 7 ") != 7 { eprintln("FAIL 6f"); fail = fail + 1 }

    if fail == 0 {
        println("__TERM_TERM_SELFTEST__ PASS n=" + to_string(n) + " fail=0")
    } else {
        println("__TERM_TERM_SELFTEST__ FAIL n=" + to_string(n) + " fail=" + to_string(fail))
    }
}

let _term_argv = args()
let mut _term_st = false
let mut _term_ai = 0
while _term_ai < len(_term_argv) {
    if _term_argv[_term_ai] == "--selftest-term" { _term_st = true }
    if _term_argv[_term_ai] == "--selftest" {
        let mut _term_aj = 0
        while _term_aj < len(_term_argv) {
            if _term_argv[_term_aj].ends_with("/stdlib/term.hexa") { _term_st = true }
            _term_aj = _term_aj + 1
        }
    }
    _term_ai = _term_ai + 1
}
if _term_st {
    _term_selftest()
}
