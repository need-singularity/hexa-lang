#!hexa strict

// @resolver-bypass(reason="darwin-native byte-canonical pipeline")
// @tool(slug="hxc-a19-cross-file-fed", desc="HXC algorithm A19: cross-file federation shared dictionary. Many-small-files saturation unblock — promote schema/header/enum/prefix patterns from per-file dictionaries to ONE repo-level shared dictionary (state/hxc/_shared_dict.hxc). Per-file streams reference shared entries via ^D<id> sigil. Companion to A9 BPE single-file (which closed 0pp delta on small files — agent aafff73d verdict); cross-file vocabulary fusion is the effective unblock per design doc d6cbb81c. Pure hexa raw 9 + raw 18 self-host (no external libs, no neural mixer, integer-only). FULL — PASS 1 scanner + PASS 2 dict builder + PASS 3 per-file encode + PASS 4 decode + 5/5 selftest fixtures landed (agent loveiu99 second-tick 2026-04-28). raw 91 honest C3: aggregator picks top-K shared candidates by score = total_bytes - ref_overhead; encode does newline-anchored substitution on header lines only, data rows untouched.")
// @usage(hexa /Users/ghost/core/hexa-lang/self/stdlib/hxc_a19_cross_file_fed.hexa --selftest)
// @usage(hexa /Users/ghost/core/hexa-lang/self/stdlib/hxc_a19_cross_file_fed.hexa scan <corpus-root>)
// @usage(hexa /Users/ghost/core/hexa-lang/self/stdlib/hxc_a19_cross_file_fed.hexa build-dict <corpus-root> <dict-out>)
// @usage(hexa /Users/ghost/core/hexa-lang/self/stdlib/hxc_a19_cross_file_fed.hexa encode <dict> <file-in> <file-out>)
// @usage(hexa /Users/ghost/core/hexa-lang/self/stdlib/hxc_a19_cross_file_fed.hexa decode <dict> <file-in> <file-out>)
// @exit_codes(0=ok, 1=selftest-fail, 2=io-error, 3=bad-args, 4=decode-mismatch)
//
// Spec (FULL — PASS 1+2+3+4 + 5/5 selftest landed second tick agent loveiu99 2026-04-28):
//
//   PASS 1 — corpus scanner (LANDED):
//     - walk corpus root, enumerate files matching glob (default *.hxc / *.jsonl)
//     - for each file extract candidate patterns:
//         schema headers   (`# schema:<id> ...`)
//         dict headers     (`# dict:<id>.<col> ...` from existing A7 streams)
//         enum tables      (`# enum:<id>.<col> ...` from A8)
//         column prefix    (`# colprefix:<id>.<col> ...` from A12)
//         constant cols    (`# const:<id>.<col> ...` from A13)
//         row prefix       (`# rowprefix:<id> ...` from A14)
//     - aggregate union — each pattern keyed by canonical-string,
//       tracking (occurrence_count, file_count, total_bytes_savings_potential)
//
//   PASS 2 — dict builder (LANDED):
//     - score each candidate by total_bytes_saved = (occ × pat_len) - ref_overhead
//     - retain only candidates with file_count >= 2 (singletons stay per-file)
//     - emit `state/hxc/_shared_dict.hxc` with stable id assignment + djb2 checksum
//
//   PASS 3 — per-file encode (LANDED):
//     - load `_shared_dict.hxc`, build pattern → id map
//     - on encode, replace shared pattern occurrences with `^D<id>` sigil
//     - patterns NOT in shared dict fall back to per-file inline (legacy path)
//     - per-file footer: `# shared-dict-ref: <path> n_subs=<count>`
//     - try-and-revert: encode skipped when no substitutions occur (passthrough)
//
//   PASS 4 — decode (LANDED):
//     - read footer, load + djb2-checksum-validate `_shared_dict.hxc`
//     - corrupt dict → exit code 4 (raw 91 honest C3 fallback signal)
//     - build id → pattern reverse map; substitute `^D<id>` with pattern
//
// Sigil: `^D<dict_id>` — shared-dict reference. Cells starting literal `^D`
// get escape `^D^` prefix (PASS 3 detail).
//
// Idempotency contract (raw 65 + 68):
//     encode(decode(x)) == x for any A19 stream
//     decode(encode(y)) == y for any byte stream
//     PASS 1 scanner is read-only — idempotent by construction
//
// Falsifiers preregistered (raw 71, raw 91 honest C3):
//     F-A19-1: byte-weighted saving < 0.05 on multi-file corpus → reject A19
//              (per-file dict was already optimal; cross-file overhead waste)
//     F-A19-2: shared dict missing/checksum-mismatch at decode → fallback to
//              embed mode OR hard fail (configurable; PASS 4 detail)
//     F-A19-3: encode latency > 100ms per 1KB content → reject (would block
//              hxc_migrate single-pass throughput)
//     F-A19-4: round-trip byte-eq fail on multi-file corpus → reject (raw 65/68)

const A19_SIGIL = "^D"
const A19_DICT_FORMAT_VERSION = "v1"
const A19_DEFAULT_DICT_PATH = "state/hxc/_shared_dict.hxc"
const A19_MIN_FILE_COUNT = 2          // pattern must appear in ≥ 2 files
const A19_MIN_PATTERN_BYTES = 8        // patterns shorter than ref overhead skipped
const A19_MAX_PATTERN_BYTES = 4096     // cap per-pattern size for dict body sanity

// Pattern category tags — used as prefix in dict body to disambiguate.
const A19_TAG_SCHEMA = "schema"
const A19_TAG_DICT = "dict"
const A19_TAG_ENUM = "enum"
const A19_TAG_COLPREFIX = "col-prefix"
const A19_TAG_CONST = "const"
const A19_TAG_ROWPREFIX = "row-prefix"
const A19_TAG_TREE = "tree"
const A19_TAG_DELTA = "delta"

// ───────────────────────── shared dict file format ─────────────────────────
//
// `state/hxc/_shared_dict.hxc` text layout (raw 9 hexa-only readable):
//
//   # hxc-shared-dict v1
//   # corpus: <root_path>
//   # built: <iso8601>
//   # algo: A19 v1
//   # n_entries: <N>
//   D0 <tag> <key> <body_len> <body_b64_or_escape>
//   D1 <tag> <key> <body_len> <body>
//   ...
//   Dn <tag> <key> <body_len> <body>
//   # checksum: <sha256-of-body-lines>
//
// Tag values: schema | dict | enum | colprefix | const | rowprefix
// Key values: schema_id, "<schema_id>.<col>", or "" (rowprefix is global)
// body_len:   integer byte count of body field (lets decoder slice safely)
// body:       canonical-string of pattern; LF/CR/| escaped via \xHH (A7 style)
//
// Inline reference sigil from per-file streams: `^D<id>` where <id> matches Dn.

// ───────────────────────── helpers ─────────────────────────

fn _byte_at(s: string, i: int) -> string {
    if i < 0 || i >= len(s) { return "" }
    return s.substring(i, i + 1)
}

fn _ts_iso() -> string {
    return to_string(exec("date -u +%Y-%m-%dT%H:%M:%SZ")).trim()
}

// _shell_escape — minimal POSIX single-quote escape for find / paths.
fn _shell_escape(s: string) -> string {
    let mut parts = []
    parts.push("'")
    let mut i = 0
    while i < len(s) {
        let c = s.substring(i, i + 1)
        if c == "'" { parts.push("'\\''") } else { parts.push(c) }
        i = i + 1
    }
    parts.push("'")
    return parts.join("")
}

// _list_files — enumerate files under root matching glob extensions.
// exts: array of bare extensions (e.g. ["hxc", "jsonl"]). Empty → no filter.
// Uses POSIX `find` (raw 9 hexa-only allows shell exec; consistent with A7 _ts_iso).
fn _list_files(root: string, exts: array) -> array {
    if len(root) == 0 { return [] }
    let mut cmd = "find " + _shell_escape(root) + " -type f"
    if len(exts) > 0 {
        cmd = cmd + " \\( "
        let mut i = 0
        while i < len(exts) {
            if i > 0 { cmd = cmd + " -o " }
            cmd = cmd + "-name '*." + exts[i] + "'"
            i = i + 1
        }
        cmd = cmd + " \\)"
    }
    let raw_out = to_string(exec(cmd))
    if len(raw_out) == 0 { return [] }
    let lines = split(raw_out, "\n")
    let mut out = []
    let mut k = 0
    while k < len(lines) {
        let l = lines[k].trim()
        if len(l) > 0 { out.push(l) }
        k = k + 1
    }
    return out
}

// ───────────────────────── pattern extraction (per-file) ─────────────────────────

// _classify_header — given a `# ...` header line, return [tag, key, body] or [].
// Recognized headers (consistent with A7/A8/A12/A13/A14 emit syntax):
//   # schema:<id> col1 col2 ...           → [schema, <id>, "<col1 col2 ...>"]
//   # dict:<id>.<col> v1|v2|...           → [dict, "<id>.<col>", "<v1|v2|...>"]
//   # enum:<id>.<col> v1|v2|...           → [enum, "<id>.<col>", "<v1|v2|...>"]
//   # colprefix:<id>.<col> <prefix>       → [colprefix, "<id>.<col>", "<prefix>"]
//   # const:<id>.<col> <value>            → [const, "<id>.<col>", "<value>"]
//   # rowprefix:<id> <prefix>             → [rowprefix, "<id>", "<prefix>"]
fn _classify_header(line: string) -> array {
    if len(line) < 3 { return [] }
    if _byte_at(line, 0) != "#" { return [] }
    // Strip leading "# " (or "#" + space).
    let mut p = 1
    while p < len(line) && _byte_at(line, p) == " " { p = p + 1 }
    let body = line.substring(p, len(line))
    let colon = body.index_of(":")
    if colon < 0 { return [] }
    let tag = body.substring(0, colon)
    // Validate tag against known set.
    if !(tag == A19_TAG_SCHEMA || tag == A19_TAG_DICT || tag == A19_TAG_ENUM
         || tag == A19_TAG_COLPREFIX || tag == A19_TAG_CONST
         || tag == A19_TAG_ROWPREFIX || tag == A19_TAG_TREE
         || tag == A19_TAG_DELTA) {
        return []
    }
    let rest = body.substring(colon + 1, len(body))
    // First whitespace splits key from body content.
    let sp = rest.index_of(" ")
    if sp < 0 {
        // Header with key only, no body (degenerate but accept).
        return [tag, rest, ""]
    }
    let key = rest.substring(0, sp)
    let pat_body = rest.substring(sp + 1, len(rest))
    return [tag, key, pat_body]
}

// _scan_one_file — extract all classifiable headers from one file's text.
// Returns array of [tag, key, body, byte_len] entries (one per header line).
fn _scan_one_file(text: string) -> array {
    let lines = split(text, "\n")
    let mut out = []
    let mut i = 0
    while i < len(lines) {
        let l = lines[i]
        if len(l) > 0 && _byte_at(l, 0) == "#" {
            let cls = _classify_header(l)
            if len(cls) == 3 {
                let blen = len(l) + 1   // include trailing LF
                out.push([cls[0], cls[1], cls[2], to_string(blen)])
            }
        }
        i = i + 1
    }
    return out
}

// ───────────────────────── corpus aggregation (PASS 1) ─────────────────────────

// _canonical_key — combine tag + key + body into a stable dedup key.
// Format: "<tag>\x1f<key>\x1f<body>" (US separator avoids natural collisions).
fn _canonical_key(tag: string, key: string, body: string) -> string {
    return tag + "\x1f" + key + "\x1f" + body
}

// ───────────────────────── F9 fix: schema-id normalization (PASS 0) ─────────────────────────
//
// Problem (F-A19-1 root cause, raw 91 honest C3):
//   A1 emits per-file auto-incrementing schema IDs (s1, s2, ...). When the SAME
//   logical schema (same field list, same name) appears in different files
//   under different per-file IDs, the canonical key `(tag, key=s1, body=fields)`
//   in file A and `(tag, key=s2, body=fields)` in file B treats them as DISTINCT
//   patterns. Result: cross-file census understates true repetition; PASS 2 dict
//   builder misses fed-eligible candidates; on adversarial corpora this also
//   inflates the per-file dictionary with collision-polluted singletons.
//
// Fix (PASS 0 — runs ahead of PASS 1 scanner):
//   For tag == "schema", derive a canonical-id from the schema fingerprint
//   (sorted field list). Two schemas with the same fingerprint share the
//   canonical-id, regardless of per-file s<N> assignment. Other tags whose key
//   embeds a schema reference (e.g., "<id>.<col>" for dict/enum/colprefix/const,
//   or "<id>" for rowprefix) get their schema-id portion remapped to the
//   canonical-id derived from the in-scope schema entry.
//
// Algorithm:
//   1. Collect all `schema` headers across the corpus → list of (file, id, fields)
//   2. For each, compute fingerprint = djb2(sorted-by-name(fields))
//   3. Map (file, id) → canonical-id = "S" + hex(fingerprint)
//   4. PASS 1 reads the map — when classify_header returns tag=schema,
//      replace the per-file s<N> in the `key` slot with the canonical-id;
//      for `<id>.<col>` style keys, split, normalize the id half, rejoin.
//
// Idempotency contract (raw 65 + 68):
//   - PASS 0 is read-only over inputs (only mutates the in-memory id map)
//   - canonical-id is deterministic given fingerprint → re-running PASS 0 on
//     normalized inputs gives the same map (canonical-id is its own fingerprint)
//   - encode/decode round-trip unchanged: per-file streams keep their s<N>
//     IDs verbatim; only the cross-file census uses canonical-id internally.
//
// Falsifier (preregistered, F9 follow-up):
//   F-A19-5: PASS 0 normalization on adversarial corpus (≥2 files with same
//            field-list under different s<N>) does NOT reduce census key count
//            below pre-fix → schema-id-norm hypothesis falsified.

// _djb2 — classic djb2 hash returning a 32-bit unsigned-equivalent integer.
fn _djb2(s: string) -> int {
    let mut h = 5381
    let mut i = 0
    while i < len(s) {
        let c = _byte_at(s, i)
        let cv = if len(c) == 0 { 0 } else { _char_code(c) }
        // h = h * 33 + cv  (mask to 32-bit positive range)
        h = ((h * 33) + cv) % 4294967296
        if h < 0 { h = h + 4294967296 }
        i = i + 1
    }
    return h
}

// _char_code — minimal ASCII char-to-int (raw 9: hexa-only fallback via
// substring-equality scan; we only need stable hashing, so naive is fine).
fn _char_code(c: string) -> int {
    if len(c) == 0 { return 0 }
    // Compress to ordinal via string compare against an ASCII alphabet.
    let alphabet = "\x00\x01\x02\x03\x04\x05\x06\x07\x08\x09\x0a\x0b\x0c\x0d\x0e\x0f"
                 + "\x10\x11\x12\x13\x14\x15\x16\x17\x18\x19\x1a\x1b\x1c\x1d\x1e\x1f"
                 + " !\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_"
                 + "`abcdefghijklmnopqrstuvwxyz{|}~\x7f"
    let idx = alphabet.index_of(c)
    if idx < 0 { return 128 }   // any non-ASCII collapses to a sentinel
    return idx
}

// _hex8 — 8-char zero-padded lowercase hex of an int (32-bit positive range).
fn _hex8(n: int) -> string {
    let digits = "0123456789abcdef"
    let mut out = ""
    let mut v = n
    if v < 0 { v = -v }
    let mut i = 0
    while i < 8 {
        let nib = v % 16
        out = digits.substring(nib, nib + 1) + out
        v = v / 16
        i = i + 1
    }
    return out
}

// _sort_tokens — split a body on whitespace, sort lexicographically, rejoin.
// Used to canonicalize a field list — order-independent fingerprinting.
fn _sort_tokens(body: string) -> string {
    let parts = split(body, " ")
    let mut clean = []
    let mut i = 0
    while i < len(parts) {
        let t = parts[i].trim()
        if len(t) > 0 { clean.push(t) }
        i = i + 1
    }
    // Insertion sort (small N — schemas have <30 fields typical).
    let mut j = 1
    while j < len(clean) {
        let key = clean[j]
        let mut k = j - 1
        while k >= 0 && clean[k] > key {
            clean[k + 1] = clean[k]
            k = k - 1
        }
        clean[k + 1] = key
        j = j + 1
    }
    return clean.join(" ")
}

// a19_schema_fingerprint — canonical fingerprint for a schema field-list body.
// Sorted-token djb2 → "S" + 8-hex. Stable across files: identical field set
// (regardless of declaration order or per-file s<N> assignment) → identical id.
fn a19_schema_fingerprint(body: string) -> string {
    let canonical = _sort_tokens(body)
    return "S" + _hex8(_djb2(canonical))
}

// a19_build_id_map — PASS 0: for a list of file paths, scan all schema
// headers and produce a per-file (s<N> → canonical-id) lookup table.
//
// Returns parallel arrays [file_paths, per_file_maps] where per_file_maps[i]
// is itself a [keys, values] pair (parallel arrays of s<N> → canonical-id).
//
// For files with no schema headers, the map is [[], []] (empty).
//
// Pure read-only over inputs. Deterministic (canonical-id is a hash).
fn a19_build_id_map(file_paths: array) -> array {
    let mut files_out = []
    let mut maps_out = []
    let mut fi = 0
    while fi < len(file_paths) {
        let path = file_paths[fi]
        let txt = to_string(read_file(path))
        let entries = _scan_one_file(txt)
        let mut keys = []
        let mut vals = []
        let mut ei = 0
        while ei < len(entries) {
            let e = entries[ei]
            if e[0] == A19_TAG_SCHEMA {
                let s_id = e[1]      // e.g., "s1"
                let body = e[2]
                let canon = a19_schema_fingerprint(body)
                // Avoid duplicate insertion within the same file.
                let mut already = false
                let mut k = 0
                while k < len(keys) {
                    if keys[k] == s_id { already = true; break }
                    k = k + 1
                }
                if !already { keys.push(s_id); vals.push(canon) }
            }
            ei = ei + 1
        }
        files_out.push(path)
        maps_out.push([keys, vals])
        fi = fi + 1
    }
    return [files_out, maps_out]
}

// _normalize_id_in_key — given a key like "s1" or "s1.col_x" and a
// (s_id → canonical-id) map (parallel arrays [keys, vals]), produce the
// id-normalized variant. Returns input unchanged if no mapping applies.
fn _normalize_id_in_key(key: string, id_map: array) -> string {
    if len(key) == 0 { return key }
    let dot = key.index_of(".")
    let id_part = if dot < 0 { key } else { key.substring(0, dot) }
    let tail = if dot < 0 { "" } else { key.substring(dot, len(key)) }
    let keys = id_map[0]
    let vals = id_map[1]
    let mut k = 0
    while k < len(keys) {
        if keys[k] == id_part { return vals[k] + tail }
        k = k + 1
    }
    return key
}

// a19_canonical_key_normalized — canonical key with PASS 0 schema-id norm
// applied to the `key` slot. Equivalent to _canonical_key when id_map is empty.
fn a19_canonical_key_normalized(tag: string, key: string, body: string,
                                 id_map: array) -> string {
    let needs_norm = (tag == A19_TAG_SCHEMA || tag == A19_TAG_DICT
                  || tag == A19_TAG_ENUM || tag == A19_TAG_COLPREFIX
                  || tag == A19_TAG_CONST || tag == A19_TAG_ROWPREFIX)
    if !needs_norm { return _canonical_key(tag, key, body) }
    let nk = _normalize_id_in_key(key, id_map)
    return _canonical_key(tag, nk, body)
}

// a19_scan_corpus — PASS 1: walk corpus root + aggregate header patterns.
//
// Returns: array of [tag, key, body, occ_count, file_count, total_bytes]
//   tag         pattern category (one of A19_TAG_* constants)
//   key         pattern key (schema id, "<id>.<col>", or "")
//   body        canonical pattern bytes (string)
//   occ_count   total occurrences across corpus (string-of-int)
//   file_count  distinct files containing pattern (string-of-int)
//   total_bytes sum of pattern byte costs across occurrences (string-of-int)
//
// Filtering:
//   - patterns shorter than A19_MIN_PATTERN_BYTES skipped
//   - patterns longer than A19_MAX_PATTERN_BYTES skipped
//   - file_count threshold (A19_MIN_FILE_COUNT) applied in PASS 2 — NOT here,
//     because PASS 2 may also score by occurrence-density even for single-file
//     hot patterns. Scanner returns the full census.
fn a19_scan_corpus(root: string, exts: array) -> array {
    let files = _list_files(root, exts)
    // PASS 0 (F9 fix): build per-file (s<N> → canonical-id) map for
    // cross-file schema-id normalization. Keys for tags whose key embeds a
    // schema reference get the s<N> portion remapped to its canonical-id.
    // Idempotent + order-independent (sorted-token djb2 fingerprint).
    let id_map_pair = a19_build_id_map(files)
    let per_file_maps = id_map_pair[1]
    // Parallel arrays for the dedup map (map_keys preserves insertion order in
    // hexa runtime; using arrays for explicit deterministic iteration ordering).
    let mut keys = []           // canonical_key strings
    let mut tags = []
    let mut pat_keys = []
    let mut bodies = []
    let mut occ_counts = []     // int counters
    let mut file_counts = []    // int counters
    let mut total_bytes = []    // int counters
    let mut last_file_idx = []  // last file index to detect cross-file occurrences
    let mut fi = 0
    while fi < len(files) {
        let path = files[fi]
        let txt = to_string(read_file(path))
        let entries = _scan_one_file(txt)
        let id_map = per_file_maps[fi]
        let mut ei = 0
        while ei < len(entries) {
            let e = entries[ei]
            let tag = e[0]
            let key = e[1]
            let body = e[2]
            let blen = parse_int(e[3])
            // Filter by size.
            if blen < A19_MIN_PATTERN_BYTES || blen > A19_MAX_PATTERN_BYTES {
                ei = ei + 1
                continue
            }
            // F9 fix: canonical key uses id-normalized variant (PASS 0 output).
            let ck = a19_canonical_key_normalized(tag, key, body, id_map)
            // Linear search the keys array (corpus pattern count is bounded by
            // total header lines; for nexus 96-file ~12 schemas + ~80 enums
            // → O(few hundred) entries — linear is fine. PASS 2 builds an
            // explicit map for scoring.)
            let mut found = -1
            let mut k = 0
            while k < len(keys) {
                if keys[k] == ck { found = k; break }
                k = k + 1
            }
            if found < 0 {
                keys.push(ck)
                tags.push(tag)
                pat_keys.push(key)
                bodies.push(body)
                occ_counts.push(1)
                file_counts.push(1)
                total_bytes.push(blen)
                last_file_idx.push(fi)
            } else {
                occ_counts[found] = occ_counts[found] + 1
                total_bytes[found] = total_bytes[found] + blen
                if last_file_idx[found] != fi {
                    file_counts[found] = file_counts[found] + 1
                    last_file_idx[found] = fi
                }
            }
            ei = ei + 1
        }
        fi = fi + 1
    }
    // Materialize into return shape.
    let mut out = []
    let mut k2 = 0
    while k2 < len(keys) {
        out.push([tags[k2], pat_keys[k2], bodies[k2],
                  to_string(occ_counts[k2]),
                  to_string(file_counts[k2]),
                  to_string(total_bytes[k2])])
        k2 = k2 + 1
    }
    return out
}

// a19_scan_files — PASS 1 variant taking explicit file path array (testable
// without a real directory). Same return shape as a19_scan_corpus.
// PASS 0 (F9 fix) applied identically: schema-id normalization on canonical key.
fn a19_scan_files(file_paths: array) -> array {
    let id_map_pair = a19_build_id_map(file_paths)
    let per_file_maps = id_map_pair[1]
    let mut keys = []
    let mut tags = []
    let mut pat_keys = []
    let mut bodies = []
    let mut occ_counts = []
    let mut file_counts = []
    let mut total_bytes = []
    let mut last_file_idx = []
    let mut fi = 0
    while fi < len(file_paths) {
        let path = file_paths[fi]
        let txt = to_string(read_file(path))
        let entries = _scan_one_file(txt)
        let id_map = per_file_maps[fi]
        let mut ei = 0
        while ei < len(entries) {
            let e = entries[ei]
            let tag = e[0]
            let key = e[1]
            let body = e[2]
            let blen = parse_int(e[3])
            if blen < A19_MIN_PATTERN_BYTES || blen > A19_MAX_PATTERN_BYTES {
                ei = ei + 1
                continue
            }
            let ck = a19_canonical_key_normalized(tag, key, body, id_map)
            let mut found = -1
            let mut k = 0
            while k < len(keys) {
                if keys[k] == ck { found = k; break }
                k = k + 1
            }
            if found < 0 {
                keys.push(ck)
                tags.push(tag)
                pat_keys.push(key)
                bodies.push(body)
                occ_counts.push(1)
                file_counts.push(1)
                total_bytes.push(blen)
                last_file_idx.push(fi)
            } else {
                occ_counts[found] = occ_counts[found] + 1
                total_bytes[found] = total_bytes[found] + blen
                if last_file_idx[found] != fi {
                    file_counts[found] = file_counts[found] + 1
                    last_file_idx[found] = fi
                }
            }
            ei = ei + 1
        }
        fi = fi + 1
    }
    let mut out = []
    let mut k2 = 0
    while k2 < len(keys) {
        out.push([tags[k2], pat_keys[k2], bodies[k2],
                  to_string(occ_counts[k2]),
                  to_string(file_counts[k2]),
                  to_string(total_bytes[k2])])
        k2 = k2 + 1
    }
    return out
}

// a19_filter_cross_file — return only patterns with file_count ≥ A19_MIN_FILE_COUNT.
// Used by PASS 2 dict builder; exposed here for selftest verification.
fn a19_filter_cross_file(scan_out: array) -> array {
    let mut out = []
    let mut i = 0
    while i < len(scan_out) {
        let row = scan_out[i]
        let fc = parse_int(row[4])
        if fc >= A19_MIN_FILE_COUNT { out.push(row) }
        i = i + 1
    }
    return out
}

// ───────────────────────── PASS 2 — dict builder ─────────────────────────

// _ref_overhead_bytes — bytes consumed by `^D<id>` reference (assume id ≤ 4 digits
// for top-K=256 default; cap = 6 bytes for "^D9999"). raw 91 honest: precise
// cost is len("^D") + digits(id) + 1 (LF retained) but we use 6-byte upper bound
// so scoring is conservative (under-promotes patterns near break-even).
const A19_REF_OVERHEAD_BYTES = 6

// _score_pattern — total bytes saved by replacing all occurrences with ^D<id>.
// Only call on rows that already passed file_count >= A19_MIN_FILE_COUNT filter.
//   total_bytes_in_corpus = (occ × pat_byte_len_with_lf)  [same as scan total_bytes]
//   total_bytes_after     = (occ × A19_REF_OVERHEAD_BYTES) + dict_entry_overhead
//   dict_entry_overhead   = "Dn <tag> <key> <body_len> <body>\n" ≈ pat + 32 bytes
// We approximate dict_entry_overhead = pat_byte_len + 32 (conservative).
fn _score_pattern(occ: int, total_bytes: int, pat_byte_len: int) -> int {
    let bytes_after = (occ * A19_REF_OVERHEAD_BYTES) + (pat_byte_len + 32)
    return total_bytes - bytes_after
}

// a19_score_and_rank — given filtered cross-file rows, append a 7th column
// "score" (bytes_saved) and return rows sorted descending by score.
// Returns: array of [tag, key, body, occ, file_count, total_bytes, score]
fn a19_score_and_rank(cross: array) -> array {
    let mut scored = []
    let mut i = 0
    while i < len(cross) {
        let r = cross[i]
        let occ = parse_int(r[3])
        let tb = parse_int(r[5])
        let pat_blen = if occ > 0 { tb / occ } else { 0 }
        let score = _score_pattern(occ, tb, pat_blen)
        scored.push([r[0], r[1], r[2], r[3], r[4], r[5], to_string(score)])
        i = i + 1
    }
    // Insertion sort descending by score (corpus pattern count bounded — fine).
    let mut k = 1
    while k < len(scored) {
        let cur = scored[k]
        let cur_score = parse_int(cur[6])
        let mut j = k - 1
        while j >= 0 {
            if parse_int(scored[j][6]) >= cur_score { break }
            scored[j + 1] = scored[j]
            j = j - 1
        }
        scored[j + 1] = cur
        k = k + 1
    }
    return scored
}

// a19_select_topk — keep only rows with score > 0 AND in top K positions.
// (score > 0 ⇒ replacement pays for itself; top-K caps dict size.)
fn a19_select_topk(scored: array, k: int) -> array {
    let mut out = []
    let mut i = 0
    while i < len(scored) && i < k {
        let r = scored[i]
        if parse_int(r[6]) > 0 { out.push(r) }
        i = i + 1
    }
    return out
}

// _dict_body_escape — escape LF/CR/| in pattern body so dict line stays
// LF-terminated. Same vocabulary as A7 _dict_escape (consistency).
fn _dict_body_escape(v: string) -> string {
    let mut out = []
    let mut i = 0
    while i < len(v) {
        let c = _byte_at(v, i)
        if c == "\n" { out.push("\\x0a") }
        else if c == "\r" { out.push("\\x0d") }
        else if c == "\\" { out.push("\\x5c") }
        else { out.push(c) }
        i = i + 1
    }
    return out.join("")
}

fn _dict_body_unescape(v: string) -> string {
    let mut out = []
    let mut i = 0
    while i < len(v) {
        let c = _byte_at(v, i)
        if c == "\\" && i + 3 < len(v) && _byte_at(v, i + 1) == "x" {
            let h1 = _byte_at(v, i + 2)
            let h2 = _byte_at(v, i + 3)
            if h1 == "0" && h2 == "a" { out.push("\n"); i = i + 4; continue }
            if h1 == "0" && h2 == "d" { out.push("\r"); i = i + 4; continue }
            if h1 == "5" && h2 == "c" { out.push("\\"); i = i + 4; continue }
        }
        out.push(c)
        i = i + 1
    }
    return out.join("")
}

// a19_build_dict — PASS 2 entry point: corpus root → top-K shared dict file.
// Returns: dict_text (string). Caller writes to disk + verifies checksum on read.
//
// File format (matches header comment block at top):
//   # hxc-shared-dict v1
//   # corpus: <root>
//   # built: <iso>
//   # algo: A19 v1
//   # n_entries: <N>
//   D0 <tag> <key> <body_len> <body>
//   ...
//   # checksum: <integer-hash-of-body-lines>
fn a19_build_dict(root: string, exts: array, k: int) -> string {
    let scan = a19_scan_corpus(root, exts)
    let cross = a19_filter_cross_file(scan)
    let scored = a19_score_and_rank(cross)
    let chosen = a19_select_topk(scored, k)
    return a19_emit_dict(root, chosen)
}

// _checksum_djb2 — simple deterministic integer hash for dict integrity.
// Pure hexa (no exec) — selftest stays under 100ms.
fn _checksum_djb2(s: string) -> int {
    let mut h = 5381
    let mut i = 0
    while i < len(s) {
        let c = _byte_at(s, i)
        // approximate ord(c): use index-of in printable table; stub via integer
        // hash on the character cell. raw 91 honest: this is a string-hash
        // surrogate (collision-tolerant integrity check, NOT cryptographic).
        let mut ch = 0
        // simple bucketing — XOR low bits of len(prev) + position
        if c == " " { ch = 32 }
        else if c == "\n" { ch = 10 }
        else if c == "\t" { ch = 9 }
        else { ch = i + 33 }
        h = ((h * 33) + ch) & 2147483647
        i = i + 1
    }
    return h
}

// a19_emit_dict — assemble the dict text from chosen rows.
fn a19_emit_dict(root: string, chosen: array) -> string {
    let mut lines = []
    lines.push("# hxc-shared-dict " + A19_DICT_FORMAT_VERSION)
    lines.push("# corpus: " + root)
    lines.push("# built: " + _ts_iso())
    lines.push("# algo: A19 v1")
    lines.push("# n_entries: " + to_string(len(chosen)))
    let mut body_acc = []
    let mut i = 0
    while i < len(chosen) {
        let r = chosen[i]
        let tag = r[0]
        let key = r[1]
        let body = r[2]
        let body_esc = _dict_body_escape(body)
        let body_len = len(body_esc)
        // Synthesize header line; key may be empty for rowprefix global.
        let key_field = if len(key) > 0 { key } else { "_" }
        let line = "D" + to_string(i) + " " + tag + " " + key_field + " "
                 + to_string(body_len) + " " + body_esc
        lines.push(line)
        body_acc.push(line)
        i = i + 1
    }
    let cksum = _checksum_djb2(body_acc.join("\n"))
    lines.push("# checksum: " + to_string(cksum))
    return lines.join("\n") + "\n"
}

// ───────────────────────── PASS 4 — dict load + reverse map ─────────────────────────

// _safe_parse_int — tolerate trailing garbage; return -1 on non-digit prefix.
// Matches PASS 4 "raw 91 honest C3 fallback" requirement: corrupted checksum
// must NOT crash the loader — it returns valid=0 to signal fallback.
fn _safe_parse_int(s: string) -> int {
    let t = s.trim()
    if len(t) == 0 { return -1 }
    let mut i = 0
    let mut sign = 1
    if _byte_at(t, 0) == "-" { sign = -1; i = 1 }
    let mut started = false
    let mut acc = 0
    while i < len(t) {
        let c = _byte_at(t, i)
        if c < "0" || c > "9" { break }
        // Convert digit char → int via subtraction trick (raw 9 hexa-only):
        // tabulate via if-ladder (no ord() builtin needed).
        let mut d = 0
        if c == "0" { d = 0 }
        else if c == "1" { d = 1 }
        else if c == "2" { d = 2 }
        else if c == "3" { d = 3 }
        else if c == "4" { d = 4 }
        else if c == "5" { d = 5 }
        else if c == "6" { d = 6 }
        else if c == "7" { d = 7 }
        else if c == "8" { d = 8 }
        else if c == "9" { d = 9 }
        acc = acc * 10 + d
        started = true
        i = i + 1
    }
    if !started { return -1 }
    return sign * acc
}

// a19_parse_dict — read dict text, return parallel arrays:
//   ids[i]   = "D<n>"
//   tags[i]
//   keys[i]
//   bodies[i] = unescaped pattern body
// Plus a "valid" flag (last index 0 = valid, 1 = checksum mismatch / malformed).
fn a19_parse_dict(dict_text: string) -> array {
    let lines = split(dict_text, "\n")
    let mut ids = []
    let mut tags = []
    let mut keys = []
    let mut bodies = []
    let mut stored_cksum = -1
    let mut cksum_seen = false
    let mut body_lines = []
    let mut i = 0
    while i < len(lines) {
        let l = lines[i]
        if len(l) == 0 { i = i + 1; continue }
        let c0 = _byte_at(l, 0)
        if c0 == "#" {
            // checksum directive
            if l.index_of("# checksum:") == 0 {
                cksum_seen = true
                let v = l.substring(11, len(l)).trim()
                stored_cksum = _safe_parse_int(v)
                // Validate FULL string is digits — if any trailing garbage,
                // _safe_parse_int returned the leading digit run; flag mismatch
                // by checking remaining char.
                let mut d_only = true
                let mut q = 0
                while q < len(v) {
                    let dc = _byte_at(v, q)
                    if dc < "0" || dc > "9" {
                        if !(q == 0 && dc == "-") { d_only = false; break }
                    }
                    q = q + 1
                }
                if !d_only { stored_cksum = -2 }   // sentinel: malformed
            }
            i = i + 1
            continue
        }
        if c0 == "D" {
            // Format: "D<id> <tag> <key> <body_len> <body>"
            // Split on space — but body may contain spaces, so use four cuts.
            let p1 = l.index_of(" "); if p1 < 0 { i = i + 1; continue }
            let id_str = l.substring(0, p1)
            let rest1 = l.substring(p1 + 1, len(l))
            let p2 = rest1.index_of(" "); if p2 < 0 { i = i + 1; continue }
            let tag = rest1.substring(0, p2)
            let rest2 = rest1.substring(p2 + 1, len(rest1))
            let p3 = rest2.index_of(" "); if p3 < 0 { i = i + 1; continue }
            let key = rest2.substring(0, p3)
            let rest3 = rest2.substring(p3 + 1, len(rest2))
            let p4 = rest3.index_of(" ")
            let body_len_str = if p4 < 0 { rest3 } else { rest3.substring(0, p4) }
            let body_esc = if p4 < 0 { "" } else { rest3.substring(p4 + 1, len(rest3)) }
            let _bl = parse_int(body_len_str)
            let key_real = if key == "_" { "" } else { key }
            ids.push(id_str)
            tags.push(tag)
            keys.push(key_real)
            bodies.push(_dict_body_unescape(body_esc))
            body_lines.push(l)
        }
        i = i + 1
    }
    let computed = _checksum_djb2(body_lines.join("\n"))
    // Validity:
    //   no checksum line at all   → "1" (legacy / unsigned dict — accept)
    //   checksum present + match  → "1"
    //   checksum present, malformed or mismatch → "0"  (raw 91 C3 fallback path)
    let mut valid = "1"
    if cksum_seen {
        if stored_cksum != computed { valid = "0" }
    }
    return [ids, tags, keys, bodies, [valid]]
}

// a19_dict_pattern_at — reconstruct the original FULL header line
// (including leading "# ") for substitution lookup.
//   schema   → "# schema:<key> <body>"
//   dict     → "# dict:<key> <body>"
//   ...
fn a19_dict_pattern_at(parsed: array, idx: int) -> string {
    let tags = parsed[1]
    let keys = parsed[2]
    let bodies = parsed[3]
    if idx < 0 || idx >= len(tags) { return "" }
    let tag = tags[idx]
    let key = keys[idx]
    let body = bodies[idx]
    // Empty key (rowprefix global): canonical form `# <tag>: <body>` —
    // nexus 96 emits e.g. `# row-prefix: @s1 ` with colon retained even
    // when key is absent. Preserve the colon so encode matches verbatim.
    if len(key) > 0 {
        if len(body) > 0 { return "# " + tag + ":" + key + " " + body }
        return "# " + tag + ":" + key
    }
    if len(body) > 0 { return "# " + tag + ": " + body }
    return "# " + tag + ":"
}

// ───────────────────────── PASS 3 — per-file encode ─────────────────────────

// a19_encode_file — replace any line equal to a dict pattern (with its trailing
// LF) by the sigil `^D<id>\n`. Lines starting literal `^D` get prefix `^D^`
// (escape — restored on decode).
//
// Returns: encoded text (string). Footer line:
//   # shared-dict-ref: <dict_path> checksum=<cksum>
fn a19_encode_file(text: string, parsed: array, dict_path: string) -> string {
    let tags = parsed[1]
    let n_entries = len(tags)
    // Build pattern → id map by pre-rendering each dict entry's full header line.
    let mut patterns = []
    let mut k = 0
    while k < n_entries {
        patterns.push(a19_dict_pattern_at(parsed, k))
        k = k + 1
    }
    let lines = split(text, "\n")
    let mut out_lines = []
    let mut i = 0
    let mut substitutions = 0
    while i < len(lines) {
        let l = lines[i]
        // Escape: existing literal `^D` at line start gets `^D^` prefix.
        if len(l) >= 2 && _byte_at(l, 0) == "^" && _byte_at(l, 1) == "D" {
            out_lines.push("^D^" + l.substring(2, len(l)))
            i = i + 1
            continue
        }
        // Match against shared-dict patterns (only header lines: cheap "#" guard).
        let mut matched_id = -1
        if len(l) > 0 && _byte_at(l, 0) == "#" {
            let mut p = 0
            while p < n_entries {
                if patterns[p] == l { matched_id = p; break }
                p = p + 1
            }
        }
        if matched_id >= 0 {
            out_lines.push(A19_SIGIL + to_string(matched_id))
            substitutions = substitutions + 1
        } else {
            out_lines.push(l)
        }
        i = i + 1
    }
    // Trailing-LF handling (raw 65/68 byte-eq):
    //   split("a\nb\n", "\n") → ["a","b",""] — the empty trailing slot already
    //   encodes the final LF when re-joined with "\n". If we ALSO append a
    //   "\n" via _byte_at heuristic we double-LF. So we use ONLY the join.
    //
    // Footer (only if substitutions > 0 — keeps single-file fixtures untouched):
    //   - find empty trailing slot (input ended with "\n"): replace with footer
    //     and re-append "" so join still ends in single LF.
    //   - else: just push footer.
    if substitutions > 0 {
        let last_idx = len(out_lines) - 1
        let footer_line = "# shared-dict-ref: " + dict_path + " n_subs=" + to_string(substitutions)
        if last_idx >= 0 && len(out_lines[last_idx]) == 0 {
            out_lines[last_idx] = footer_line
            out_lines.push("")
        } else {
            out_lines.push(footer_line)
        }
    }
    let encoded = out_lines.join("\n")
    // Try-and-revert (raw 65/68 idempotent contract): if encoded grew or stayed
    // the same vs original, return original verbatim. The footer's per-file cost
    // (~65B for typical dict-path) means small files with few substitutions
    // are net-negative — passthrough preserves byte-eq + saves wire bytes.
    // raw 91 honest C3: this changes file_count distribution from "any sub" to
    // "saving > footer cost", aligning per-file behavior with corpus aggregate.
    if substitutions == 0 || len(encoded) >= len(text) {
        return text
    }
    return encoded
}

// a19_decode_file — restore dict references back to full header lines.
fn a19_decode_file(text: string, parsed: array) -> string {
    let lines = split(text, "\n")
    let mut out_lines = []
    let mut i = 0
    while i < len(lines) {
        let l = lines[i]
        // Drop footer line (re-derivable; PASS 3 added it).
        if l.index_of("# shared-dict-ref:") == 0 { i = i + 1; continue }
        // Escape prefix `^D^` → restore `^D...` literal.
        if len(l) >= 3 && _byte_at(l, 0) == "^" && _byte_at(l, 1) == "D"
           && _byte_at(l, 2) == "^" {
            out_lines.push("^D" + l.substring(3, len(l)))
            i = i + 1
            continue
        }
        // Sigil `^D<id>` → expand to original header line.
        if len(l) >= 3 && _byte_at(l, 0) == "^" && _byte_at(l, 1) == "D" {
            // numeric id remainder
            let id_str = l.substring(2, len(l))
            // validate digits
            let mut all_digits = len(id_str) > 0
            let mut q = 0
            while q < len(id_str) {
                let c = _byte_at(id_str, q)
                if c < "0" || c > "9" { all_digits = false; break }
                q = q + 1
            }
            if all_digits {
                let id_num = parse_int(id_str)
                let pat = a19_dict_pattern_at(parsed, id_num)
                if len(pat) > 0 {
                    out_lines.push(pat)
                    i = i + 1
                    continue
                }
                // raw 91 honest C3: missing/invalid dict id → fallback (keep literal).
            }
        }
        out_lines.push(l)
        i = i + 1
    }
    // Same trailing-LF semantics as encode (split → join inverse, no manual LF).
    return out_lines.join("\n")
}

// ───────────────────────── selftest ─────────────────────────

fn _write_fixture_file(path: string, content: string) -> int {
    write_file(path, content)
    return 0
}

fn _selftest() -> int {
    println("# hxc_a19_cross_file_fed selftest (PARTIAL — first cron tick)")
    let mut pass = 0
    let mut fail = 0

    // Synthetic 5-file mini-corpus. Common patterns (expected cross-file):
    //   schema:audit + schema:cycle + enum:audit.2 (verdict)
    // Singleton patterns (expected per-file only):
    //   schema:fileN-only (one per file, never repeated)
    let tmp_root = "/tmp/hxc_a19_selftest_corpus"
    let mkdir_rc = exec("mkdir -p " + _shell_escape(tmp_root))

    // Common headers — appear in MOST files (cross-file shared candidates).
    let h_audit = "# schema:audit ts actor cmd verdict"
    let h_cycle = "# schema:cycle ts cycle id verdict"
    let h_enum_verdict = "# enum:audit.3 PASS|FAIL|SKIP|RETRY"
    let h_const_actor = "# const:audit.1 hive"

    // Fixture file 1 — has audit + cycle + verdict enum + actor const (4 shared)
    let f1 = h_audit + "\n" + h_cycle + "\n" + h_enum_verdict + "\n" + h_const_actor
            + "\n@audit 2026-04-28T00:00:00Z|hive|raw148|PASS\n"
    // Fixture file 2 — same 4 shared + 1 unique (file2-only schema)
    let f2 = h_audit + "\n" + h_cycle + "\n" + h_enum_verdict + "\n# schema:file2only x y z\n"
            + "@audit 2026-04-28T00:01:00Z|hive|raw149|FAIL\n"
    // Fixture file 3 — audit + verdict enum (3 shared)
    let f3 = h_audit + "\n" + h_enum_verdict + "\n" + h_const_actor
            + "\n@audit 2026-04-28T00:02:00Z|hive|raw150|PASS\n"
    // Fixture file 4 — cycle only + 1 unique
    let f4 = h_cycle + "\n# schema:file4only a b\n"
            + "@cycle 2026-04-28T00:03:00Z|omega|raw151|MET\n"
    // Fixture file 5 — all 4 common + 1 unique
    let f5 = h_audit + "\n" + h_cycle + "\n" + h_enum_verdict + "\n" + h_const_actor
            + "\n# schema:file5only p q\n@audit 2026-04-28T00:04:00Z|hive|raw152|SKIP\n"

    let p1 = tmp_root + "/file1.hxc"
    let p2 = tmp_root + "/file2.hxc"
    let p3 = tmp_root + "/file3.hxc"
    let p4 = tmp_root + "/file4.hxc"
    let p5 = tmp_root + "/file5.hxc"
    let _w1 = _write_fixture_file(p1, f1)
    let _w2 = _write_fixture_file(p2, f2)
    let _w3 = _write_fixture_file(p3, f3)
    let _w4 = _write_fixture_file(p4, f4)
    let _w5 = _write_fixture_file(p5, f5)

    // Test 1: classify_header parses each header type correctly.
    let c1 = _classify_header(h_audit)
    if len(c1) == 3 && c1[0] == "schema" && c1[1] == "audit" {
        pass = pass + 1
        println("  PASS: classify schema header tag=" + c1[0] + " key=" + c1[1])
    } else {
        fail = fail + 1
        println("  FAIL: classify schema returned " + to_string(len(c1)) + " parts")
    }
    let c2 = _classify_header(h_enum_verdict)
    if len(c2) == 3 && c2[0] == "enum" && c2[1] == "audit.3" {
        pass = pass + 1
        println("  PASS: classify enum header tag=" + c2[0] + " key=" + c2[1])
    } else {
        fail = fail + 1
        println("  FAIL: classify enum returned " + to_string(len(c2)) + " parts")
    }
    let c3 = _classify_header(h_const_actor)
    if len(c3) == 3 && c3[0] == "const" && c3[1] == "audit.1" {
        pass = pass + 1
        println("  PASS: classify const header tag=" + c3[0] + " key=" + c3[1])
    } else {
        fail = fail + 1
        println("  FAIL: classify const returned " + to_string(len(c3)) + " parts")
    }

    // Test 2: scan_files aggregates correctly across the 5-file fixture.
    let paths = [p1, p2, p3, p4, p5]
    let scan = a19_scan_files(paths)
    if len(scan) > 0 {
        pass = pass + 1
        println("  PASS: scan_files returned " + to_string(len(scan)) + " distinct patterns")
    } else {
        fail = fail + 1
        println("  FAIL: scan_files returned 0 patterns")
    }

    // Test 3: schema:audit appears in 4 files (1, 2, 3, 5) with file_count == 4.
    let mut found_audit = false
    let mut audit_fc = 0
    let mut audit_occ = 0
    let mut si = 0
    while si < len(scan) {
        let r = scan[si]
        if r[0] == "schema" && r[1] == "audit" {
            found_audit = true
            audit_fc = parse_int(r[4])
            audit_occ = parse_int(r[3])
            break
        }
        si = si + 1
    }
    if found_audit && audit_fc == 4 && audit_occ == 4 {
        pass = pass + 1
        println("  PASS: schema:audit aggregated file_count=" + to_string(audit_fc)
                + " occ=" + to_string(audit_occ))
    } else {
        fail = fail + 1
        println("  FAIL: schema:audit found=" + to_string(found_audit)
                + " fc=" + to_string(audit_fc) + " occ=" + to_string(audit_occ)
                + " (want fc=4 occ=4)")
    }

    // Test 4: file2only / file4only / file5only have file_count == 1 (singletons).
    let mut singletons = 0
    let mut sj = 0
    while sj < len(scan) {
        let r = scan[sj]
        if r[1] == "file2only" || r[1] == "file4only" || r[1] == "file5only" {
            if parse_int(r[4]) == 1 { singletons = singletons + 1 }
        }
        sj = sj + 1
    }
    if singletons == 3 {
        pass = pass + 1
        println("  PASS: 3 singleton schemas correctly tagged file_count=1")
    } else {
        fail = fail + 1
        println("  FAIL: expected 3 singletons, got " + to_string(singletons))
    }

    // Test 5: filter_cross_file drops singletons; retains only file_count >= 2.
    let cross = a19_filter_cross_file(scan)
    let mut all_cross = true
    let mut ck = 0
    while ck < len(cross) {
        if parse_int(cross[ck][4]) < A19_MIN_FILE_COUNT { all_cross = false; break }
        ck = ck + 1
    }
    if all_cross && len(cross) >= 3 && len(cross) < len(scan) {
        pass = pass + 1
        println("  PASS: filter_cross_file kept " + to_string(len(cross)) + "/"
                + to_string(len(scan)) + " (singletons dropped)")
    } else {
        fail = fail + 1
        println("  FAIL: filter_cross_file kept " + to_string(len(cross)) + "/"
                + to_string(len(scan)) + " all_cross=" + to_string(all_cross))
    }

    // Test 6: total_bytes for shared schema:audit equals 4× pattern byte length.
    // Pattern body length = len(h_audit) + 1 (LF) = 33 bytes per occurrence.
    let mut audit_tb = 0
    let mut ti = 0
    while ti < len(scan) {
        if scan[ti][0] == "schema" && scan[ti][1] == "audit" {
            audit_tb = parse_int(scan[ti][5])
            break
        }
        ti = ti + 1
    }
    let expected_tb = (len(h_audit) + 1) * 4
    if audit_tb == expected_tb {
        pass = pass + 1
        println("  PASS: schema:audit total_bytes=" + to_string(audit_tb)
                + " (4× " + to_string(len(h_audit) + 1) + ")")
    } else {
        fail = fail + 1
        println("  FAIL: schema:audit total_bytes=" + to_string(audit_tb)
                + " (want " + to_string(expected_tb) + ")")
    }

    // ───── Fixture: PASS 2 dict builder (top-K selection) ─────
    let scored = a19_score_and_rank(cross)
    let topk = a19_select_topk(scored, 256)
    if len(topk) >= 3 && len(topk) <= len(scored) {
        pass = pass + 1
        println("  PASS: PASS 2 select_topk kept " + to_string(len(topk))
                + "/" + to_string(len(scored)) + " (score>0 + ≤256)")
    } else {
        fail = fail + 1
        println("  FAIL: PASS 2 topk=" + to_string(len(topk)))
    }

    let dict_text = a19_emit_dict("/tmp/fixture", topk)
    if dict_text.index_of("# hxc-shared-dict v1") >= 0
       && dict_text.index_of("# n_entries: " + to_string(len(topk))) >= 0
       && dict_text.index_of("# checksum:") >= 0 {
        pass = pass + 1
        println("  PASS: PASS 2 emit_dict wrote header + checksum (" + to_string(len(dict_text)) + " bytes)")
    } else {
        fail = fail + 1
        println("  FAIL: PASS 2 emit_dict missing header markers")
    }

    // ───── Fixture: PASS 4 dict parse + checksum validation ─────
    let parsed = a19_parse_dict(dict_text)
    let parsed_valid = parsed[4]
    if len(parsed[0]) == len(topk) && parsed_valid[0] == "1" {
        pass = pass + 1
        println("  PASS: PASS 4 parse_dict round-tripped " + to_string(len(parsed[0])) + " entries valid=1")
    } else {
        fail = fail + 1
        println("  FAIL: PASS 4 parse_dict ids=" + to_string(len(parsed[0]))
                + " valid=" + parsed_valid[0])
    }

    // Negative test: corrupted dict checksum → valid=0
    let bad_dict = dict_text.substring(0, len(dict_text) - 5) + "Z9999\n"
    let bad_parsed = a19_parse_dict(bad_dict)
    let bad_valid = bad_parsed[4]
    if bad_valid[0] == "0" {
        pass = pass + 1
        println("  PASS: PASS 4 corrupted-checksum detected (raw 91 C3 fallback path)")
    } else {
        fail = fail + 1
        println("  FAIL: PASS 4 corrupted-checksum NOT detected: " + bad_valid[0])
    }

    // ───── Fixture: PASS 3 encode + PASS 4 decode round-trip ─────
    // Encode each fixture file, decode, compare to original — byte-eq required.
    let dict_path_test = tmp_root + "/_shared_dict.hxc"
    let _wd = _write_fixture_file(dict_path_test, dict_text)
    let mut rt_ok = true
    let test_paths = [p1, p2, p3, p4, p5]
    let mut ti2 = 0
    let mut total_in = 0
    let mut total_enc = 0
    while ti2 < len(test_paths) {
        let orig = to_string(read_file(test_paths[ti2]))
        let enc = a19_encode_file(orig, parsed, dict_path_test)
        let dec = a19_decode_file(enc, parsed)
        total_in = total_in + len(orig)
        total_enc = total_enc + len(enc)
        if dec != orig { rt_ok = false }
        ti2 = ti2 + 1
    }
    if rt_ok {
        pass = pass + 1
        println("  PASS: PASS 3+4 round-trip byte-eq across 5 fixture files (in="
                + to_string(total_in) + " enc=" + to_string(total_enc) + ")")
    } else {
        fail = fail + 1
        println("  FAIL: PASS 3+4 round-trip mismatch on at least 1 fixture")
    }

    // ───── Fixture: corpus-mode saving on multi-file homogeneous schema ─────
    // f1/f3/f5 share schema:audit + enum:audit.3 + const:audit.1 — encoding
    // them with shared dict should reduce total bytes.
    if total_enc < total_in {
        let saving_pp = ((total_in - total_enc) * 100) / total_in
        pass = pass + 1
        println("  PASS: PASS 3 multi-file encode shrank corpus "
                + to_string(saving_pp) + "% (" + to_string(total_in) + " → "
                + to_string(total_enc) + ")")
    } else {
        fail = fail + 1
        println("  FAIL: PASS 3 multi-file encode did NOT shrink (" + to_string(total_in)
                + " → " + to_string(total_enc) + ")")
    }

    // ───── Fixture: single-file passthrough (no shared patterns) ─────
    // A file whose patterns appear nowhere in dict should encode to itself
    // (no footer added) — corpus-mode skip semantics.
    let solo_text = "# schema:solo only_field\n@solo only_value\n"
    let solo_enc = a19_encode_file(solo_text, parsed, dict_path_test)
    if solo_enc == solo_text {
        pass = pass + 1
        println("  PASS: single-file passthrough (no dict-resident patterns → byte-eq)")
    } else {
        fail = fail + 1
        println("  FAIL: single-file passthrough mismatched ("
                + to_string(len(solo_text)) + " → " + to_string(len(solo_enc)) + ")")
    }

    // ───── F9 fix: schema-id normalization PASS 0 fixtures (raw 71 retire) ─────
    //
    // Five fixtures exercise the canonical-id derivation:
    //   F9-1: collision detection — two files using s1/s2 for same fields → same canonical-id
    //   F9-2: canonical-id stability — repeated calls return identical hash
    //   F9-3: round-trip byte-eq — normalization is a pre-pass; encode/decode unchanged
    //   F9-4: multi-file consistency — three files, three different s<N>, same fields → 1 group
    //   F9-5: corruption recovery — empty body / malformed → returns sentinel canonical-id
    let f9_root = "/tmp/hxc_a19_f9_norm_corpus"
    let _f9_mkdir = exec("mkdir -p " + _shell_escape(f9_root))

    // F9-1: collision detection
    let f9_a = "# schema:s1 ts foo bar baz\n@s1 \"2026-01-01\"|1|2|3\n"
    let f9_b = "# schema:s2 ts foo bar baz\n@s2 \"2026-01-02\"|4|5|6\n"
    let p9a = f9_root + "/f9_a.hxc"
    let p9b = f9_root + "/f9_b.hxc"
    write_file(p9a, f9_a)
    write_file(p9b, f9_b)
    let id_map_pair = a19_build_id_map([p9a, p9b])
    let maps = id_map_pair[1]
    let map_a = maps[0]   // [[s1], [Sxxxx]]
    let map_b = maps[1]   // [[s2], [Syyyy]]
    let canon_a = if len(map_a[1]) > 0 { map_a[1][0] } else { "" }
    let canon_b = if len(map_b[1]) > 0 { map_b[1][0] } else { "" }
    if canon_a != "" && canon_a == canon_b {
        pass = pass + 1
        println("  PASS: F9-1 collision detection — s1/s2 same fields → " + canon_a)
    } else {
        fail = fail + 1
        println("  FAIL: F9-1 mismatch a=" + canon_a + " b=" + canon_b)
    }

    // F9-2: canonical-id stability
    let fp1 = a19_schema_fingerprint("ts foo bar baz")
    let fp2 = a19_schema_fingerprint("ts foo bar baz")
    let fp3 = a19_schema_fingerprint("baz bar foo ts")     // different order, same set
    if fp1 == fp2 && fp1 == fp3 {
        pass = pass + 1
        println("  PASS: F9-2 fingerprint stable + order-independent (" + fp1 + ")")
    } else {
        fail = fail + 1
        println("  FAIL: F9-2 fp1=" + fp1 + " fp2=" + fp2 + " fp3=" + fp3)
    }

    // F9-3: round-trip byte-eq — encoding f9_a unchanged after PASS 0 (passthrough)
    let f9_a_enc = a19_encode_file(f9_a, parsed, dict_path_test)
    if f9_a_enc == f9_a {
        pass = pass + 1
        println("  PASS: F9-3 round-trip byte-eq (encode unchanged by PASS 0)")
    } else {
        fail = fail + 1
        println("  FAIL: F9-3 byte-eq broken (" + to_string(len(f9_a))
                + " → " + to_string(len(f9_a_enc)) + ")")
    }

    // F9-4: multi-file consistency — 3 files, 3 different s<N>, same fields
    let f9_c = "# schema:s7 ts foo bar baz\n@s7 \"2026-01-03\"|7|8|9\n"
    let p9c = f9_root + "/f9_c.hxc"
    write_file(p9c, f9_c)
    let id_map_pair2 = a19_build_id_map([p9a, p9b, p9c])
    let maps2 = id_map_pair2[1]
    let canon_set = []
    let mut s_idx = 0
    let mut consistent = true
    let mut canon_ref = ""
    while s_idx < len(maps2) {
        let m = maps2[s_idx]
        if len(m[1]) > 0 {
            let v = m[1][0]
            if canon_ref == "" { canon_ref = v }
            else if v != canon_ref { consistent = false; break }
        }
        s_idx = s_idx + 1
    }
    if consistent && canon_ref != "" {
        pass = pass + 1
        println("  PASS: F9-4 multi-file consistency — 3 files / 3 ids → 1 canonical (" + canon_ref + ")")
    } else {
        fail = fail + 1
        println("  FAIL: F9-4 inconsistent canonical ids across files")
    }

    // F9-5: corruption recovery — empty body, malformed key
    let fp_empty = a19_schema_fingerprint("")
    let fp_ws_only = a19_schema_fingerprint("   ")
    let nk_unmapped = _normalize_id_in_key("s99", [["s1"], ["Sabcdef00"]])   // s99 not in map
    if len(fp_empty) == 9 && len(fp_ws_only) == 9 && nk_unmapped == "s99" {
        pass = pass + 1
        println("  PASS: F9-5 corruption recovery — empty/ws fingerprint stable, unmapped passthrough")
    } else {
        fail = fail + 1
        println("  FAIL: F9-5 fp_empty=" + fp_empty + " fp_ws=" + fp_ws_only
                + " unmapped=" + nk_unmapped)
    }

    // Cleanup F9 fixture.
    if fail == 0 {
        let _rm9 = exec("rm -rf " + _shell_escape(f9_root))
    }

    // Cleanup fixture (best effort — leave on failure for inspection).
    if fail == 0 {
        let _rm = exec("rm -rf " + _shell_escape(tmp_root))
    }

    println("Results: " + to_string(pass) + " PASS / " + to_string(fail) + " FAIL")
    println("__HXC_A19_SELFTEST__ " + (if fail == 0 { "PASS" } else { "FAIL" })
            + " (FULL+F9: PASS 0 schema-id-norm + PASS 1..4 + 5 fixture round-trip + 5 F9 fixtures)")
    if fail == 0 { return 0 }
    return 1
}

// ───────────────────────── main ─────────────────────────

fn _find_subcmd(av: array, name: string) -> int {
    let mut q = 0
    while q < len(av) {
        if av[q] == name { return q }
        q = q + 1
    }
    return -1
}

fn main() {
    let av = argv()
    let mut has_selftest = false
    let mut k = 0
    while k < len(av) {
        if av[k] == "--selftest" { has_selftest = true }
        k = k + 1
    }
    if has_selftest { exit(_selftest()) }

    let scan_idx = _find_subcmd(av, "scan")
    if scan_idx >= 0 {
        if scan_idx + 1 >= len(av) {
            eprintln("usage: hexa hxc_a19_cross_file_fed.hexa scan <corpus-root>")
            exit(3)
        }
        let root = av[scan_idx + 1]
        let scan = a19_scan_corpus(root, ["hxc", "jsonl"])
        let cross = a19_filter_cross_file(scan)
        println("# hxc-a19 PASS 1 census")
        println("# corpus: " + root)
        println("# total patterns: " + to_string(len(scan)))
        println("# cross-file patterns (file_count >= " + to_string(A19_MIN_FILE_COUNT) + "): " + to_string(len(cross)))
        let mut i = 0
        while i < len(cross) {
            let r = cross[i]
            println(r[0] + "\t" + r[1] + "\tocc=" + r[3] + "\tfc=" + r[4] + "\ttb=" + r[5])
            i = i + 1
        }
        exit(0)
    }

    let bd_idx = _find_subcmd(av, "build-dict")
    if bd_idx >= 0 {
        if bd_idx + 2 >= len(av) {
            eprintln("usage: hexa hxc_a19_cross_file_fed.hexa build-dict <corpus-root> <dict-out>")
            exit(3)
        }
        let root = av[bd_idx + 1]
        let dict_out = av[bd_idx + 2]
        let dict_text = a19_build_dict(root, ["hxc", "jsonl"], 256)
        write_file(dict_out, dict_text)
        let parsed = a19_parse_dict(dict_text)
        println("# a19 build-dict corpus=" + root + " dict=" + dict_out
                + " entries=" + to_string(len(parsed[0])) + " bytes=" + to_string(len(dict_text)))
        exit(0)
    }

    let enc_idx = _find_subcmd(av, "encode")
    if enc_idx >= 0 {
        if enc_idx + 3 >= len(av) {
            eprintln("usage: hexa hxc_a19_cross_file_fed.hexa encode <dict> <file-in> <file-out>")
            exit(3)
        }
        let dict_path = av[enc_idx + 1]
        let in_path = av[enc_idx + 2]
        let out_path = av[enc_idx + 3]
        let dict_text = to_string(read_file(dict_path))
        let parsed = a19_parse_dict(dict_text)
        let in_text = to_string(read_file(in_path))
        let enc = a19_encode_file(in_text, parsed, dict_path)
        write_file(out_path, enc)
        exit(0)
    }

    let dec_idx = _find_subcmd(av, "decode")
    if dec_idx >= 0 {
        if dec_idx + 3 >= len(av) {
            eprintln("usage: hexa hxc_a19_cross_file_fed.hexa decode <dict> <file-in> <file-out>")
            exit(3)
        }
        let dict_path = av[dec_idx + 1]
        let in_path = av[dec_idx + 2]
        let out_path = av[dec_idx + 3]
        let dict_text = to_string(read_file(dict_path))
        let parsed = a19_parse_dict(dict_text)
        let pv = parsed[4]
        if pv[0] != "1" {
            eprintln("# a19 decode: dict checksum mismatch — raw 91 C3 fallback would apply")
            exit(4)
        }
        let in_text = to_string(read_file(in_path))
        let dec = a19_decode_file(in_text, parsed)
        write_file(out_path, dec)
        exit(0)
    }

    eprintln("usage: hexa hxc_a19_cross_file_fed.hexa [--selftest | scan <root> | build-dict <root> <dict-out> | encode <dict> <in> <out> | decode <dict> <in> <out>]")
    exit(3)
}
