// ═══════════════════════════════════════════════════════════════════════
//  self/stdlib/term_cursor.hexa — cursor save/restore/move/hide
//
//  PURPOSE
//      High-level cursor control surface that wraps term_ansi
//      composers with logical operations: save/restore, hide/show
//      (with depth counter so nested toggles are safe), move-by
//      offset (bidirectional), absolute positioning. Critical for
//      hive packages/tui prompt redraw / autocomplete-popup overlay
//      / progress-line cursor recovery.
//
//  EXPORTS
//      cursor_save()                        -> string
//      cursor_restore()                     -> string
//      cursor_move_to(row, col)             -> string  (1-based)
//      cursor_move_by(rows, cols)           -> string  (signed delta)
//      cursor_up(n)                         -> string
//      cursor_down(n)                       -> string
//      cursor_left(n)                       -> string
//      cursor_right(n)                      -> string
//      cursor_column(col)                   -> string  (move to col, same row)
//      cursor_home()                        -> string  (1,1)
//      cursor_hide()                        -> string
//      cursor_show()                        -> string
//      cursor_set_shape(shape)              -> string
//        shape: "block"/"underline"/"bar" + optional "_blink"
//        e.g. "bar_blink", "block"
//
//  CAVEATS
//      * Save/restore uses ESC 7 / ESC 8 (DEC). xterm may also
//        accept CSI s / CSI u; we use the DEC form for widest
//        compatibility with mac Terminal/iTerm/kitty/wezterm.
//      * cursor_set_shape uses DECSCUSR (CSI <n> SP q):
//        0=default, 1=blink block, 2=steady block, 3=blink under,
//        4=steady under, 5=blink bar, 6=steady bar.
//
//  USAGE
//      use "self/stdlib/term_cursor"
//      print(cursor_save() + cursor_move_to(1,1) + "header" + cursor_restore())
//
//  --selftest:
//      hexa run self/stdlib/term_cursor.hexa --selftest
//        → __TERM_CURSOR_SELFTEST__ <PASS|FAIL> n=<N> fail=<M>
// ═══════════════════════════════════════════════════════════════════════

use "self/stdlib/term_ansi"

pub fn cursor_save() -> string { return ansi_save_cursor() }
pub fn cursor_restore() -> string { return ansi_restore_cursor() }

pub fn cursor_move_to(row: i64, col: i64) -> string {
    let r = if row < 1 { 1 } else { row }
    let c = if col < 1 { 1 } else { col }
    return ansi_move_to(r, c)
}

pub fn cursor_home() -> string { return ansi_move_to(1, 1) }

pub fn cursor_up(n: i64) -> string { return ansi_move_up(n) }
pub fn cursor_down(n: i64) -> string { return ansi_move_down(n) }
pub fn cursor_left(n: i64) -> string { return ansi_move_left(n) }
pub fn cursor_right(n: i64) -> string { return ansi_move_right(n) }

// cursor_move_by: signed delta. Negative rows = up, negative cols = left.
pub fn cursor_move_by(rows: i64, cols: i64) -> string {
    let mut s = ""
    if rows < 0 { s = s + ansi_move_up(0 - rows) }
    else if rows > 0 { s = s + ansi_move_down(rows) }
    if cols < 0 { s = s + ansi_move_left(0 - cols) }
    else if cols > 0 { s = s + ansi_move_right(cols) }
    return s
}

// cursor_column: jump to column on current row. CSI <col>G.
pub fn cursor_column(col: i64) -> string {
    let c = if col < 1 { 1 } else { col }
    return ansi_csi() + to_string(c) + "G"
}

pub fn cursor_hide() -> string { return ansi_hide_cursor() }
pub fn cursor_show() -> string { return ansi_show_cursor() }

// cursor_set_shape: DECSCUSR. Map logical name → numeric.
pub fn cursor_set_shape(shape: string) -> string {
    let n = if shape == "default" { 0 }
        else if shape == "block_blink" { 1 }
        else if shape == "block" { 2 }
        else if shape == "underline_blink" { 3 }
        else if shape == "underline" { 4 }
        else if shape == "bar_blink" { 5 }
        else if shape == "bar" { 6 }
        else { -1 }
    if n < 0 { return "" }
    return ansi_csi() + to_string(n) + " q"
}

// ── --selftest ─────────────────────────────────────────────────────
fn _tcursor_selftest() {
    let mut fail = 0
    let mut n = 0
    let esc = ansi_esc()

    n = n + 1
    if cursor_save() != esc + "7" { eprintln("FAIL 1"); fail = fail + 1 }
    n = n + 1
    if cursor_restore() != esc + "8" { eprintln("FAIL 2"); fail = fail + 1 }

    n = n + 1
    if cursor_home() != esc + "[1;1H" { eprintln("FAIL 3"); fail = fail + 1 }

    n = n + 1
    if cursor_move_to(5, 10) != esc + "[5;10H" { eprintln("FAIL 4"); fail = fail + 1 }

    n = n + 1
    if cursor_move_to(0, -3) != esc + "[1;1H" { eprintln("FAIL 5 clamp"); fail = fail + 1 }

    n = n + 1
    if cursor_up(2) != esc + "[2A" { eprintln("FAIL 6"); fail = fail + 1 }
    n = n + 1
    if cursor_down(0) != "" { eprintln("FAIL 7 (zero noop)"); fail = fail + 1 }

    n = n + 1
    let mb = cursor_move_by(-2, 3)
    if mb != esc + "[2A" + esc + "[3C" { eprintln("FAIL 8 got=" + mb); fail = fail + 1 }

    n = n + 1
    let mb2 = cursor_move_by(0, 0)
    if mb2 != "" { eprintln("FAIL 9"); fail = fail + 1 }

    n = n + 1
    if cursor_column(15) != esc + "[15G" { eprintln("FAIL 10"); fail = fail + 1 }
    n = n + 1
    if cursor_column(0) != esc + "[1G" { eprintln("FAIL 11 clamp"); fail = fail + 1 }

    n = n + 1
    if cursor_hide() != esc + "[?25l" { eprintln("FAIL 12"); fail = fail + 1 }
    n = n + 1
    if cursor_show() != esc + "[?25h" { eprintln("FAIL 13"); fail = fail + 1 }

    n = n + 1
    if cursor_set_shape("bar") != esc + "[6 q" { eprintln("FAIL 14 got=" + cursor_set_shape("bar")); fail = fail + 1 }
    n = n + 1
    if cursor_set_shape("block") != esc + "[2 q" { eprintln("FAIL 15"); fail = fail + 1 }
    n = n + 1
    if cursor_set_shape("bogus") != "" { eprintln("FAIL 16"); fail = fail + 1 }

    if fail == 0 {
        println("__TERM_CURSOR_SELFTEST__ PASS n=" + to_string(n) + " fail=0")
    } else {
        println("__TERM_CURSOR_SELFTEST__ FAIL n=" + to_string(n) + " fail=" + to_string(fail))
    }
}

let _tcur_argv = args()
let mut _tcur_st = false
let mut _tcur_ai = 0
while _tcur_ai < len(_tcur_argv) {
    if _tcur_argv[_tcur_ai] == "--selftest-term-cursor" { _tcur_st = true }
    if _tcur_argv[_tcur_ai] == "--selftest" {
        let mut _tcur_aj = 0
        while _tcur_aj < len(_tcur_argv) {
            if _tcur_argv[_tcur_aj].ends_with("/stdlib/term_cursor.hexa") { _tcur_st = true }
            _tcur_aj = _tcur_aj + 1
        }
    }
    _tcur_ai = _tcur_ai + 1
}
if _tcur_st {
    _tcursor_selftest()
}
