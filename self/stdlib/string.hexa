// ═══════════════════════════════════════════════════════════
//  self/stdlib/string.hexa — HEXA-native string utilities (T4)
//
//  Migration proof-of-concept for T4 C→HEXA 이식.
//  Each fn here has a parallel C impl in runtime.c for backward
//  compat. Consumers choosing `use "stdlib/string"` get the HEXA
//  version — identical semantics, plain HEXA loop.
//
//  Policy: see docs/hexa-hot-path.md
//    - T4 함수는 training hot path 아님 (anima 무영향 약속)
//    - HEXA impl 은 `hexa build` 로 컴파일 시 일반 C 로 emit 되므로
//      성능 차이는 함수 call overhead 뿐 (~10ns per call)
//    - 안전 이행: runtime.c 의 C 버전 유지 → legacy 호출 보존
//
//  Proof gate: test_stdlib_string.hexa 통과 (하단 참조).
// ═══════════════════════════════════════════════════════════

// Trim ASCII whitespace from both ends.
// Matches runtime.c hexa_str_trim semantics — space, tab, newline, CR.
pub fn str_trim(s) {
    let n = len(s)
    let mut i = 0
    let mut front_done = false
    while i < n && !front_done {
        let c = s.substring(i, i + 1)
        if c == " " || c == "\t" || c == "\n" || c == "\r" {
            i = i + 1
        } else {
            front_done = true
        }
    }
    let mut j = n
    let mut back_done = false
    while j > i && !back_done {
        let c = s.substring(j - 1, j)
        if c == " " || c == "\t" || c == "\n" || c == "\r" {
            j = j - 1
        } else {
            back_done = true
        }
    }
    return s.substring(i, j)
}

// Trim only leading whitespace.
pub fn str_trim_start(s) {
    let n = len(s)
    let mut i = 0
    let mut done = false
    while i < n && !done {
        let c = s.substring(i, i + 1)
        if c == " " || c == "\t" || c == "\n" || c == "\r" {
            i = i + 1
        } else {
            done = true
        }
    }
    return s.substring(i, n)
}

// Trim only trailing whitespace.
pub fn str_trim_end(s) {
    let n = len(s)
    let mut j = n
    let mut done = false
    while j > 0 && !done {
        let c = s.substring(j - 1, j)
        if c == " " || c == "\t" || c == "\n" || c == "\r" {
            j = j - 1
        } else {
            done = true
        }
    }
    return s.substring(0, j)
}

// Repeat a string N times. N <= 0 → empty.
pub fn str_repeat(s, n) {
    if n <= 0 { return "" }
    let mut parts = []
    let mut i = 0
    while i < n {
        parts = parts.push(s)
        i = i + 1
    }
    return parts.join("")
}
