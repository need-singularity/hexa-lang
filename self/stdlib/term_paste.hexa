// ═══════════════════════════════════════════════════════════════════════
//  self/stdlib/term_paste.hexa — bracketed paste mode (CSI 200~/201~)
//
//  PURPOSE
//      Bracketed paste enables/disables the terminal's "wrap pasted
//      text in escape markers" feature. Without it, multiline paste
//      arrives interleaved with newline=Enter events, so a TUI that
//      handles Enter as "submit" will fire submit per pasted line.
//      With it, pastes arrive as ESC[200~ ... ESC[201~ blocks the
//      decoder identifies as a single atomic event.
//
//  EXPORTS
//      paste_enable_seq()                 -> string  // ESC [?2004h
//      paste_disable_seq()                -> string  // ESC [?2004l
//      paste_extract(buf: string)         -> array
//        If buf starts with paste_start AND contains paste_end,
//        returns [content, end_idx] where content is the text
//        between markers and end_idx is the byte index AFTER the
//        closing marker. Otherwise returns [].
//      paste_is_in_progress(buf)          -> bool
//        True iff buf contains an unterminated paste_start.
//
//  CAVEATS
//      * Caller still needs to PRINT the enable sequence on TUI
//        startup and disable on shutdown — this module only
//        composes strings.
//      * Bracketed paste requires terminal cooperation. If terminal
//        doesn't support it (e.g. legacy xterm < R299), enable is
//        a no-op and pastes will arrive line-by-line.
//      * paste_extract handles only the FIRST paste in buf; caller
//        loops if multiple pastes accumulated.
//
//  USAGE
//      use "self/stdlib/term_paste"
//      print(paste_enable_seq())
//      // ... in input loop:
//      if paste_is_in_progress(buf) {
//          let r = paste_extract(buf)
//          if len(r) == 2 { handle_paste(r[0]); buf = buf.substring(r[1], len(buf)) }
//      }
//
//  --selftest:
//      hexa run self/stdlib/term_paste.hexa --selftest
//        → __TERM_PASTE_SELFTEST__ <PASS|FAIL> n=<N> fail=<M>
// ═══════════════════════════════════════════════════════════════════════

fn _tp_esc() -> string { return from_char_code(27) }

fn _tp_start() -> string { return _tp_esc() + "[200~" }
fn _tp_end() -> string { return _tp_esc() + "[201~" }

pub fn paste_enable_seq() -> string {
    return _tp_esc() + "[?2004h"
}

pub fn paste_disable_seq() -> string {
    return _tp_esc() + "[?2004l"
}

pub fn paste_extract(buf: string) -> array {
    let s = _tp_start()
    let e = _tp_end()
    let n = len(buf)
    if n < len(s) { return [] }
    if buf.substring(0, len(s)) != s { return [] }
    // find e from len(s) onward
    let body_start = len(s)
    let mut i = body_start
    while i + len(e) <= n {
        if buf.substring(i, i + len(e)) == e {
            let content = buf.substring(body_start, i)
            return [content, i + len(e)]
        }
        i = i + 1
    }
    return []
}

pub fn paste_is_in_progress(buf: string) -> bool {
    let s = _tp_start()
    let e = _tp_end()
    let mut i = 0
    let mut depth = 0
    let n = len(buf)
    while i < n {
        if i + len(s) <= n && buf.substring(i, i + len(s)) == s {
            depth = depth + 1
            i = i + len(s)
        } else if i + len(e) <= n && buf.substring(i, i + len(e)) == e {
            if depth > 0 { depth = depth - 1 }
            i = i + len(e)
        } else {
            i = i + 1
        }
    }
    return depth > 0
}

// ── --selftest ─────────────────────────────────────────────────────
fn _tpaste_selftest() {
    let mut fail = 0
    let mut n = 0
    let esc = _tp_esc()

    n = n + 1
    if paste_enable_seq() != esc + "[?2004h" { eprintln("FAIL 1"); fail = fail + 1 }
    n = n + 1
    if paste_disable_seq() != esc + "[?2004l" { eprintln("FAIL 2"); fail = fail + 1 }

    // 3. extract — happy path
    n = n + 1
    let buf = esc + "[200~hello\nworld" + esc + "[201~tail"
    let r = paste_extract(buf)
    if len(r) != 2 { eprintln("FAIL 3a count=" + to_string(len(r))); fail = fail + 1 }
    if r[0] != "hello\nworld" { eprintln("FAIL 3b content=" + r[0]); fail = fail + 1 }

    // 4. extract — unterminated
    n = n + 1
    let buf2 = esc + "[200~partial"
    let r2 = paste_extract(buf2)
    if len(r2) != 0 { eprintln("FAIL 4"); fail = fail + 1 }

    // 5. extract — no leading marker
    n = n + 1
    let buf3 = "no marker"
    let r3 = paste_extract(buf3)
    if len(r3) != 0 { eprintln("FAIL 5"); fail = fail + 1 }

    // 6. is_in_progress — open
    n = n + 1
    if !paste_is_in_progress(esc + "[200~mid") { eprintln("FAIL 6"); fail = fail + 1 }

    // 7. is_in_progress — closed
    n = n + 1
    if paste_is_in_progress(esc + "[200~mid" + esc + "[201~") { eprintln("FAIL 7"); fail = fail + 1 }

    // 8. is_in_progress — none
    n = n + 1
    if paste_is_in_progress("plain text") { eprintln("FAIL 8"); fail = fail + 1 }

    // 9. extract — empty content
    n = n + 1
    let buf9 = esc + "[200~" + esc + "[201~"
    let r9 = paste_extract(buf9)
    if len(r9) != 2 || r9[0] != "" { eprintln("FAIL 9"); fail = fail + 1 }

    // 10. extract — end_idx points correctly
    n = n + 1
    let buf10 = esc + "[200~ab" + esc + "[201~XY"
    let r10 = paste_extract(buf10)
    let want_idx = len(esc + "[200~ab" + esc + "[201~")
    if r10[1] != want_idx { eprintln("FAIL 10 idx=" + to_string(r10[1])); fail = fail + 1 }

    if fail == 0 {
        println("__TERM_PASTE_SELFTEST__ PASS n=" + to_string(n) + " fail=0")
    } else {
        println("__TERM_PASTE_SELFTEST__ FAIL n=" + to_string(n) + " fail=" + to_string(fail))
    }
}

let _tpa_argv = args()
let mut _tpa_st = false
let mut _tpa_ai = 0
while _tpa_ai < len(_tpa_argv) {
    if _tpa_argv[_tpa_ai] == "--selftest-term-paste" { _tpa_st = true }
    if _tpa_argv[_tpa_ai] == "--selftest" {
        let mut _tpa_aj = 0
        while _tpa_aj < len(_tpa_argv) {
            if _tpa_argv[_tpa_aj].ends_with("/stdlib/term_paste.hexa") { _tpa_st = true }
            _tpa_aj = _tpa_aj + 1
        }
    }
    _tpa_ai = _tpa_ai + 1
}
if _tpa_st {
    _tpaste_selftest()
}
