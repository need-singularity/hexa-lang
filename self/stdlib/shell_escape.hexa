// ═══════════════════════════════════════════════════════════
//  self/stdlib/shell_escape.hexa — canonical POSIX shell escape
//
//  PURPOSE
//    Quote an arbitrary string for safe inclusion in a POSIX shell
//    command line (passed via `exec()`). Single-quoted form so that
//    no metacharacter is interpreted. Embedded `'` becomes `'\''`.
//
//  EVIDENCE / MOTIVATION
//    36+ tools across hive/anima/nexus reimplemented an identical
//    `_shell_escape` local helper because no canonical stdlib fn
//    existed. ω-cycle 2026-04-27 (raw 91 honest disclosure):
//    duplication count = 36, all bytewise identical (verified
//    `grep -A 10 "fn _shell_escape" | sort -u` yields ONE form).
//
//  CONTRACT
//    shell_escape(s: string) -> string
//      Pre:  s is any string (including empty / containing apos /
//            containing newline / containing $ ` \ ! etc.)
//      Post: returned string is single-quoted. exec("echo " + r)
//            emits exactly s + "\n".
//      Idempotency: shell_escape(shell_escape(x)) is safe (double-
//            escape — interior single quotes still neutralized).
//
//  REFERENCES
//    /Users/ghost/core/hive/tool/escalation_window_recovery.hexa
//    /Users/ghost/core/hive/tool/raw_taxonomy_lint.hexa
//    /Users/ghost/core/hive/tool/git_pre_commit.hexa
//    /Users/ghost/core/hive/tool/hxc_lint.hexa
//    (and 32 others — see `grep -l "fn _shell_escape" hive/tool`)
// ═══════════════════════════════════════════════════════════

pub fn shell_escape(s: string) -> string {
    let mut parts = []
    parts.push("'")
    let mut i = 0
    let n = len(s)
    // @triad: atomize — bounded counter — finite string scan
    while i < n {
        let c = s.substring(i, i + 1)
        if c == "'" {
            parts.push("'\\''")
        } else {
            parts.push(c)
        }
        i = i + 1
    }
    parts.push("'")
    return parts.join("")
}

// ── Selftest ────────────────────────────────────────────────
//
// Run with: hexa run self/stdlib/shell_escape.hexa --selftest
// All 9 cases must PASS for byte-equivalence with legacy
// _shell_escape implementations across 36 call-sites.

fn _se_selftest() -> i64 {
    // T1: empty string
    let t1 = shell_escape("")
    if t1 != "''" { eprintln("FAIL T1 empty: got " + t1); return 1 }

    // T2: simple alnum (no escape needed but quoted)
    let t2 = shell_escape("hello")
    if t2 != "'hello'" { eprintln("FAIL T2 simple: got " + t2); return 1 }

    // T3: single quote — canonical '\'' replacement
    let t3 = shell_escape("a'b")
    if t3 != "'a'\\''b'" { eprintln("FAIL T3 apos: got " + t3); return 1 }

    // T4: multiple single quotes
    let t4 = shell_escape("'''")
    if t4 != "''\\'''\\'''\\'''" { eprintln("FAIL T4 multi-apos: got " + t4); return 1 }

    // T5: spaces & path
    let t5 = shell_escape("/tmp/a b/c.txt")
    if t5 != "'/tmp/a b/c.txt'" { eprintln("FAIL T5 spaces: got " + t5); return 1 }

    // T6: dollar / backtick / backslash — must remain literal
    let t6 = shell_escape("$VAR `cmd` \\n")
    if t6 != "'$VAR `cmd` \\n'" { eprintln("FAIL T6 metachars: got " + t6); return 1 }

    // T7: newline preserved literally inside quotes
    let t7 = shell_escape("a\nb")
    if t7 != "'a\nb'" { eprintln("FAIL T7 newline: got " + t7); return 1 }

    // T8: idempotency — escaping twice still safe (no apos, no
    // injection). Double-escaped form must still be a valid
    // POSIX-quoted string.
    let raw = "x"
    let once = shell_escape(raw)
    let twice = shell_escape(once)
    // The double-escaped form must start and end with a quote.
    if twice.substring(0, 1) != "'" { eprintln("FAIL T8 idem-start"); return 1 }
    if twice.substring(len(twice) - 1, len(twice)) != "'" { eprintln("FAIL T8 idem-end"); return 1 }

    // T9: byte-equivalence with the legacy inline form found in
    // 36 tools (canonical reference: hive/tool/git_pre_commit.hexa).
    // We replicate that algorithm here and assert exact match.
    let ref_input = "it's a 'test' \"quoted\" $val"
    let ref_out = _se_legacy_reference(ref_input)
    let new_out = shell_escape(ref_input)
    if ref_out != new_out {
        eprintln("FAIL T9 byte-eq: legacy=" + ref_out + " new=" + new_out)
        return 1
    }

    println("shell_escape selftest: 9/9 PASS")
    return 0
}

// Legacy reference impl — bytewise copy of the form duplicated
// across 36 tools. Used for T9 byte-equivalence assertion only.
fn _se_legacy_reference(s: string) -> string {
    let mut parts = []
    parts.push("'")
    let mut i = 0
    while i < len(s) {
        let c = s.substring(i, i + 1)
        if c == "'" { parts.push("'\\''") } else { parts.push(c) }
        i = i + 1
    }
    parts.push("'")
    return parts.join("")
}

// CLI entry — only fire on --selftest-shell-escape to keep this
// module import-safe even when the host script also takes
// --selftest. (Module loader concatenates top-level statements,
// so a generic --selftest would collide.)
let _se_args = args()
let mut _se_selftest_flag = false
let mut _se_i = 0
while _se_i < len(_se_args) {
    if _se_args[_se_i] == "--selftest-shell-escape" { _se_selftest_flag = true }
    if _se_args[_se_i] == "--selftest" {
        // Only run when invoked directly (script path ends with shell_escape.hexa).
        let mut _se_j = 0
        while _se_j < len(_se_args) {
            if _se_args[_se_j].ends_with("/stdlib/shell_escape.hexa") { _se_selftest_flag = true }
            _se_j = _se_j + 1
        }
    }
    _se_i = _se_i + 1
}
if _se_selftest_flag {
    exit(_se_selftest())
}
