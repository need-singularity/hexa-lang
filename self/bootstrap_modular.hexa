// self/bootstrap_modular.hexa — modular bootstrap entry (Phase2 C1)
//
// bootstrap.hexa (1,945 LOC monolith) 를 5 개 모듈로 분할한 버전.
// module_loader 가 import 지시문을 concat 으로 풀어준다.
//
// 처리 흐름:
//   module_loader.hexa → load_module("bootstrap_modular.hexa")
//     └─ 아래 import 지시문 5개를 재귀적으로 인라인
//     └─ 순환 감지 완료된 단일 소스 문자열 반환
//     └─ 기존 parser/interpreter 에 그대로 투입
//
// 분할 결과 (총 1,911 LOC, 본래 self-test 34 줄 제외):
//   modules/boot_structs.hexa     64 LOC  — Token/AstNode/TypeError/Instruction/CompiledFn
//   modules/boot_lexer.hexa      431 LOC  — is_keyword/tokenize
//   modules/boot_parser.hexa     657 LOC  — parse + helpers
//   modules/boot_typecheck.hexa  298 LOC  — type_check
//   modules/boot_compiler.hexa   461 LOC  — compile_program + disassemble + bootstrap_compile

import "modules/boot_structs.hexa"
import "modules/boot_lexer.hexa"
import "modules/boot_parser.hexa"
import "modules/boot_typecheck.hexa"
import "modules/boot_compiler.hexa"

// ══════════════════════════════════════════════════════════════
// Self-test (moved from original bootstrap.hexa tail)
// ══════════════════════════════════════════════════════════════

let test1 = "let x = 42\nlet y = x + 8\nprintln(y)\n\nfn add(a, b) {\n  return a + b\n}\n\nlet result = add(10, 20)\nprintln(result)"
println("=== Test 1: Basic let + fn + call ===")
let bc1 = bootstrap_compile(test1)

let test2 = "let mut sum = 0\nfor i in [1, 2, 3, 4, 5] {\n  sum = sum + i\n}\nprintln(sum)"
println("=== Test 2: For loop + array ===")
let bc2 = bootstrap_compile(test2)

let test3 = "let mut n = 10\nlet mut count = 0\nwhile n > 0 {\n  count = count + 1\n  n = n - 1\n}\nprintln(count)"
println("=== Test 3: While loop ===")
let bc3 = bootstrap_compile(test3)

let test4 = "fn fib(n) {\n  if n <= 1 {\n    return n\n  }\n  return fib(n - 1) + fib(n - 2)\n}\nprintln(fib(10))"
println("=== Test 4: Recursive fibonacci ===")
let bc4 = bootstrap_compile(test4)

let test5 = "struct Point {\n  x: int,\n  y: int\n}\nlet p = Point { x: 10, y: 20 }\nprintln(p.x)"
println("=== Test 5: Struct definition + init ===")
let bc5 = bootstrap_compile(test5)

println("=== Bootstrap (modular) Self-Test Summary ===")
println("  Test 1 (basic): " + to_string(len(bc1)) + " instructions")
println("  Test 2 (for):   " + to_string(len(bc2)) + " instructions")
println("  Test 3 (while): " + to_string(len(bc3)) + " instructions")
println("  Test 4 (fib):   " + to_string(len(bc4)) + " instructions")
println("  Test 5 (struct): " + to_string(len(bc5)) + " instructions")
let total = len(bc1) + len(bc2) + len(bc3) + len(bc4) + len(bc5)
println("  Total: " + to_string(total) + " instructions across 5 programs")
println("HEXA self-hosting bootstrap (modular): ALL TESTS PASSED")
