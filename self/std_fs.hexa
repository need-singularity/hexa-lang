// self/std_fs.hexa — HEXA FS ported from src/std_fs.rs
//
// Provides:
//   fs_read(path)             — read file to string
//   fs_write(path, content)   — write string to file
//   fs_append(path, content)  — append to file
//   fs_exists(path)           — check if path exists
//   fs_remove(path)           — delete file
//   fs_mkdir(path)            — create directory (recursive)
//   fs_list(path)             — list directory entries
//   fs_copy(src, dst)         — copy file
//   fs_move(src, dst)         — rename/move
//   fs_metadata(path)         — size, modified, is_dir, is_file
//   fs_glob(pattern)          — simple glob matching
//   fs_watch(path, callback)  — polling-based file watcher

// All fs_* functions delegate to builtins in the runtime.
// This file provides the Hexa-level API signatures.

fn fs_read(path) -> string {
    return __builtin_fs_read(path)
}

fn fs_write(path, content) {
    __builtin_fs_write(path, content)
}

fn fs_append(path, content) {
    __builtin_fs_append(path, content)
}

fn fs_exists(path) -> bool {
    return __builtin_fs_exists(path)
}

fn fs_remove(path) {
    __builtin_fs_remove(path)
}

fn fs_mkdir(path) {
    __builtin_fs_mkdir(path)
}

fn fs_list(path) -> [string] {
    return __builtin_fs_list(path)
}

fn fs_copy(src, dst) {
    __builtin_fs_copy(src, dst)
}

fn fs_move(src, dst) {
    __builtin_fs_move(src, dst)
}

fn fs_metadata(path) {
    // Returns map: { size: int, is_dir: bool, is_file: bool, readonly: bool, modified: int, created: int }
    return __builtin_fs_metadata(path)
}

// -- Glob matching (pure Hexa) --

fn fs_glob(pattern) -> [string] {
    // Split pattern into directory and file pattern
    let dir = "."
    let file_pattern = pattern
    let last_slash = string_rfind(pattern, "/")
    if last_slash >= 0 {
        dir = string_slice(pattern, 0, last_slash)
        file_pattern = string_slice(pattern, last_slash + 1, len(pattern))
    }

    let entries = fs_list(dir)
    let result = []
    let i = 0
    while i < len(entries) {
        if glob_matches(file_pattern, entries[i]) {
            if dir == "." {
                result = array_push(result, entries[i])
            } else {
                result = array_push(result, dir + "/" + entries[i])
            }
        }
        i = i + 1
    }
    return result
}

fn glob_matches(pattern, text) -> bool {
    return glob_matches_inner(pattern, text, 0, 0)
}

// decreases pattern — structural
fn glob_matches_inner(pattern, text, pi, ti) -> bool {
    if pi >= len(pattern) {
        return ti >= len(text)
    }
    let ch = pattern[pi]
    if ch == "*" {
        // Try matching rest at every position
        let k = ti
        while k <= len(text) {
            if glob_matches_inner(pattern, text, pi + 1, k) {
                return true
            }
            k = k + 1
        }
        return false
    }
    if ch == "?" {
        if ti >= len(text) { return false }
        return glob_matches_inner(pattern, text, pi + 1, ti + 1)
    }
    // Literal
    if ti >= len(text) { return false }
    if ch != text[ti] { return false }
    return glob_matches_inner(pattern, text, pi + 1, ti + 1)
}

// -- File watcher (polling) --

fn fs_watch(path, callback) {
    let snapshot = fs_build_snapshot(path)
    while true {
        time_sleep(500)
        let current = fs_build_snapshot(path)

        // Detect new/modified
        let i = 0
        while i < len(current) {
            let name = current[i][0]
            let mtime = current[i][1]
            let old_mtime = fs_snapshot_get(snapshot, name)
            if old_mtime < 0 {
                let result = callback({ path: name, kind: "created" })
                if result == "__stop__" { return }
            } else {
                if old_mtime != mtime {
                    let result = callback({ path: name, kind: "modified" })
                    if result == "__stop__" { return }
                }
            }
            i = i + 1
        }

        // Detect deleted
        let j = 0
        while j < len(snapshot) {
            let name = snapshot[j][0]
            if fs_snapshot_get(current, name) < 0 {
                let result = callback({ path: name, kind: "deleted" })
                if result == "__stop__" { return }
            }
            j = j + 1
        }

        snapshot = current
    }
}

fn fs_build_snapshot(path) {
    // Returns array of [name, mtime] pairs
    let result = []
    if fs_exists(path) {
        let meta = fs_metadata(path)
        if meta.is_dir {
            let entries = fs_list(path)
            let i = 0
            while i < len(entries) {
                let child = path + "/" + entries[i]
                let cmeta = fs_metadata(child)
                result = array_push(result, [entries[i], cmeta.modified])
                i = i + 1
            }
        } else {
            result = array_push(result, [path, meta.modified])
        }
    }
    return result
}

fn fs_snapshot_get(snapshot, name) -> int {
    let i = 0
    while i < len(snapshot) {
        if snapshot[i][0] == name { return snapshot[i][1] }
        i = i + 1
    }
    return -1
}
