// ═══════════════════════════════════════════════════════════════════
//  test_rope.hexa — ROI #91 correctness suite for self/ai_native/rope.hexa
//
//  Coverage:
//    A. Precompute shape:  seq_len × (head_dim/2) for cos and sin
//    B. pos=0 identity:    cos=1, sin=0  → rope_apply is the identity
//    C. fused vs naive:    rope_apply == rope_apply_naive (tol 1e-5)
//       across multiple (head_dim, pos) combos
//    D. Rotary inverse:    rope_inverse(rope_apply(x)) ≈ x
//    E. head_dim sweep:    4 / 8 / 16 / 64
//    F. cos/sin bounds:    all table entries in [-1, 1]
//    G. op-count note:     precompute caches amortise sin/cos calls
// ═══════════════════════════════════════════════════════════════════

// ── inlined from self/ai_native/rope.hexa ──────────────────
// codegen_c2 import resolution not wired for test files

// ═══════════════════════════════════════════════════════════════════
//  self/ai_native/rope.hexa — AI-native ROI #91
//
//  @rope — Rotary Position Embedding (RoPE, Su et al. 2021). Modern
//  LLMs (LLaMA, Qwen, Mistral, DeepSeek) use RoPE instead of additive
//  positional embeddings because rotation composes well under dot
//  product: <R_m·q, R_n·k> depends only on (m-n), giving relative
//  position semantics for free.
//
//  Public API (interleaved / "LLaMA complex pair" layout):
//      rope_precompute(seq_len, head_dim, base)   -> {cos, sin}
//          • cos, sin : seq_len × (head_dim/2)  LUT tables
//      rope_apply(x, cos_cache, sin_cache, pos)   -> [float]
//          • applies the rotation at row `pos` to vector x
//          • x.length must equal head_dim and be even
//      rope_apply_naive(x, pos, head_dim, base)   -> [float]
//          • reference path: recomputes cos/sin every call
//      rope_inverse(x, cos_cache, sin_cache, pos) -> [float]
//          • -pos rotation: undoes rope_apply — rotary inverse
//
//  Layout choice — INTERLEAVED (complex-pair):
//      For i in 0..head_dim/2:
//          x'[2i]   = x[2i]·cos_i - x[2i+1]·sin_i
//          x'[2i+1] = x[2i]·sin_i + x[2i+1]·cos_i
//      This treats (x[2i], x[2i+1]) as Re,Im of a complex number and
//      rotates by angle θ_i = pos · base^(-2i/head_dim). Matches the
//      original RoPE paper and HuggingFace's `rotary_emb_interleaved`
//      convention. (HF LLaMA default is the half-split variant; we
//      picked interleaved for locality — adjacent pairs stay adjacent.)
//
//  Frequency table:
//      θ_i = pos · inv_freq_i,  where
//      inv_freq_i = base^(-2i/head_dim)  for i in 0..head_dim/2
//
//  HX3 pitfalls handled:
//      - no struct-literal inside `if` body → use map #{} return at tail
//      - slice precedence — no range slices on fp arrays here
//      - @attr pub fn  → avoided; plain @pure / @hot
//      - no `enum`       → not needed
//      - no bitwise ops  → only +-*/ with base/head_dim
//      - abs/fabs        → file-local fabs_rope
//
//  AI-native attrs:
//      @pure — math helpers, precompute
//      @hot  — rope_apply / rope_inverse (per-token hot-path)
// ═══════════════════════════════════════════════════════════════════

// ── numeric helpers ────────────────────────────────────────────────

// rope_fabs → abs_pure (math_pure.hexa)

// pow fallback is available as builtin; we re-wrap so the call site
// reads like rope_pow(base, exponent) and base=10000.0 stays obvious.
@pure
fn rope_pow(base, exponent) {
    return pow(base, exponent)
}

@pure
fn rope_cos(x) {
    return cos(x)
}

@pure
fn rope_sin(x) {
    return sin(x)
}

// ═══════════════════════════════════════════════════════════════════
//  rope_inv_freq(head_dim, base)
//
//  Builds the length head_dim/2 inverse-frequency vector:
//      inv_freq[i] = 1 / base^(2i/head_dim)
//
//  base=10000.0 gives LLaMA-compatible frequencies; larger base
//  compresses frequencies (YaRN / NTK-aware extensions scale base).
// ═══════════════════════════════════════════════════════════════════
@pure
fn rope_inv_freq(head_dim, base) {
    let half = head_dim / 2
    let mut freqs = []
    let hd_f = to_float(head_dim)
    for i in 0..half {
        let exponent = 2.0 * to_float(i) / hd_f
        let denom = rope_pow(base, exponent)
        freqs = freqs + [1.0 / denom]
    }
    return freqs
}

// ═══════════════════════════════════════════════════════════════════
//  rope_precompute(seq_len, head_dim, base)
//
//  Returns a map #{cos, sin} where each table is seq_len × (head_dim/2).
//  cos[pos][i] = cos(pos · inv_freq_i),  sin[pos][i] = sin(pos · inv_freq_i)
//
//  Cost: O(seq_len · head_dim/2) — amortised across all tokens that
//  share this position range (the whole batch, and across decoding
//  steps inside max_seq).
// ═══════════════════════════════════════════════════════════════════
@pure
fn rope_precompute(seq_len, head_dim, base) {
    let inv_freq = rope_inv_freq(head_dim, base)
    let half = len(inv_freq)

    let mut cos_cache = []
    let mut sin_cache = []
    for p in 0..seq_len {
        let pf = to_float(p)
        let mut cos_row = []
        let mut sin_row = []
        for i in 0..half {
            let angle = pf * inv_freq[i]
            cos_row = cos_row + [rope_cos(angle)]
            sin_row = sin_row + [rope_sin(angle)]
        }
        cos_cache = cos_cache + [cos_row]
        sin_cache = sin_cache + [sin_row]
    }

    return #{
        "cos": cos_cache,
        "sin": sin_cache
    }
}

// ═══════════════════════════════════════════════════════════════════
//  rope_apply(x, cos_cache, sin_cache, pos)
//
//  In-cache rotation at position `pos`, interleaved layout:
//      x'[2i]   = x[2i]·c - x[2i+1]·s
//      x'[2i+1] = x[2i]·s + x[2i+1]·c
//  where (c, s) = (cos_cache[pos][i], sin_cache[pos][i]).
//
//  Caller must ensure len(x) is even; odd head_dim is unsupported by
//  RoPE by construction.
// ═══════════════════════════════════════════════════════════════════
@hot
fn rope_apply(x, cos_cache, sin_cache, pos) {
    let d = len(x)
    let half = d / 2
    let cos_row = cos_cache[pos]
    let sin_row = sin_cache[pos]

    let mut out = []
    for _i in 0..d { out = out + [0.0] }

    for i in 0..half {
        let c = cos_row[i]
        let s = sin_row[i]
        let x0 = x[2 * i]
        let x1 = x[2 * i + 1]
        out[2 * i]     = x0 * c - x1 * s
        out[2 * i + 1] = x0 * s + x1 * c
    }
    return out
}

// ═══════════════════════════════════════════════════════════════════
//  rope_apply_naive(x, pos, head_dim, base)
//
//  Reference path: recompute cos/sin per call. Numerically identical
//  to rope_apply on the same (pos, head_dim, base). Used as a correctness
//  baseline — NOT a fair speed benchmark (both paths dominated by the
//  2 mul / 2 add per pair).
// ═══════════════════════════════════════════════════════════════════
@hot
fn rope_apply_naive(x, pos, head_dim, base) {
    let d = len(x)
    let half = d / 2
    let pf = to_float(pos)
    let hd_f = to_float(head_dim)

    let mut out = []
    for _i in 0..d { out = out + [0.0] }

    for i in 0..half {
        let exponent = 2.0 * to_float(i) / hd_f
        let inv_freq_i = 1.0 / rope_pow(base, exponent)
        let angle = pf * inv_freq_i
        let c = rope_cos(angle)
        let s = rope_sin(angle)
        let x0 = x[2 * i]
        let x1 = x[2 * i + 1]
        out[2 * i]     = x0 * c - x1 * s
        out[2 * i + 1] = x0 * s + x1 * c
    }
    return out
}

// ═══════════════════════════════════════════════════════════════════
//  rope_inverse(x, cos_cache, sin_cache, pos)
//
//  Applies the -pos rotation, which is the inverse of rope_apply at pos:
//      x'[2i]   =  x[2i]·c + x[2i+1]·s
//      x'[2i+1] = -x[2i]·s + x[2i+1]·c
//  equivalent to rotating by angle -θ.
//
//  Property: rope_inverse(rope_apply(x, cache, pos), cache, pos) ≈ x.
// ═══════════════════════════════════════════════════════════════════
@hot
fn rope_inverse(x, cos_cache, sin_cache, pos) {
    let d = len(x)
    let half = d / 2
    let cos_row = cos_cache[pos]
    let sin_row = sin_cache[pos]

    let mut out = []
    for _i in 0..d { out = out + [0.0] }

    for i in 0..half {
        let c = cos_row[i]
        let s = sin_row[i]
        let x0 = x[2 * i]
        let x1 = x[2 * i + 1]
        out[2 * i]     =  x0 * c + x1 * s
        out[2 * i + 1] = 0.0 - x0 * s + x1 * c
    }
    return out
}

// ═══════════════════════════════════════════════════════════════════
//  Shape helpers — tests query cache dimensions without poking the map.
// ═══════════════════════════════════════════════════════════════════
@pure
fn rope_cache_seq_len(cache) {
    return len(cache["cos"])
}

@pure
fn rope_cache_half_dim(cache) {
    let cos_t = cache["cos"]
    if len(cos_t) == 0 { return 0 }
    return len(cos_t[0])
}


// ── end inlined ──────────────────────────────────────────


let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs_t(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn vec_close(a, b, eps) {
    let n = len(a)
    if len(b) != n { return false }
    for i in 0..n {
        if fabs_t(a[i] - b[i]) > eps { return false }
    }
    return true
}

// deterministic pseudo-random LCG for reproducible inputs
fn lcg_step(state) {
    let a = 1103515245
    let c = 12345
    let m = 2147483648
    return (state * a + c) % m
}

fn rand_vec(n, seed) {
    let mut state = seed
    let mut v = []
    for _i in 0..n {
        state = lcg_step(state)
        let r = (state % 2000) * 0.001 - 1.0
        v = v + [r]
    }
    return v
}

// ══════════════════════════════════════════════════════════════════
println("═══════════════════════════════════════════════════════")
println("  ROI #91 RoPE (rotary position embedding) — correctness suite")
println("═══════════════════════════════════════════════════════")

let eps = 1.0e-5
let base = 10000.0

// ── Test A : precompute shape ─────────────────────────────────────
let seq_len_a = 16
let head_dim_a = 8
let cache_a = rope_precompute(seq_len_a, head_dim_a, base)

check("A1 cache has seq_len rows",     rope_cache_seq_len(cache_a) == seq_len_a)
check("A2 cache has head_dim/2 cols",  rope_cache_half_dim(cache_a) == head_dim_a / 2)

// direct map access sanity check
let cos_tab_a = cache_a["cos"]
let sin_tab_a = cache_a["sin"]
check("A3 cos_tab length",  len(cos_tab_a) == seq_len_a)
check("A4 sin_tab length",  len(sin_tab_a) == seq_len_a)
check("A5 cos row0 length", len(cos_tab_a[0]) == head_dim_a / 2)
check("A6 sin row0 length", len(sin_tab_a[0]) == head_dim_a / 2)

// ── Test B : pos=0 identity ───────────────────────────────────────
// pos=0 → angle=0 → (cos, sin) = (1, 0) → rope_apply returns x unchanged
let x_b = rand_vec(8, 42)
let y_b = rope_apply(x_b, cos_tab_a, sin_tab_a, 0)
check("B1 pos=0 identity (head_dim=8)", vec_close(x_b, y_b, eps))

// also check cos[0] == [1,1,..,1], sin[0] == [0,0,..,0]
let mut cos0_ok = true
let mut sin0_ok = true
for i in 0..(head_dim_a / 2) {
    if fabs_t(cos_tab_a[0][i] - 1.0) > eps { cos0_ok = false }
    if fabs_t(sin_tab_a[0][i] - 0.0) > eps { sin0_ok = false }
}
check("B2 cos[0] all 1",    cos0_ok)
check("B3 sin[0] all 0",    sin0_ok)

// ── Test C : fused vs naive (tol 1e-5) ────────────────────────────
// multiple (head_dim, pos) — precomputed cache must match per-call path
let dims_c = [4, 8, 16, 64]
let seq_len_c = 32
for di in 0..len(dims_c) {
    let hd = dims_c[di]
    let cache_c = rope_precompute(seq_len_c, hd, base)
    let cos_c = cache_c["cos"]
    let sin_c = cache_c["sin"]
    let positions = [0, 1, 7, 15, 31]
    for pi in 0..len(positions) {
        let pos = positions[pi]
        let xv = rand_vec(hd, 1000 + hd * 17 + pos)
        let y_fused = rope_apply(xv, cos_c, sin_c, pos)
        let y_naive = rope_apply_naive(xv, pos, hd, base)
        let name = "C fused==naive  hd=" + to_string(hd) + " pos=" + to_string(pos)
        check(name, vec_close(y_fused, y_naive, eps))
    }
}

// ── Test D : rotary inverse ───────────────────────────────────────
// rope_inverse(rope_apply(x, cache, pos), cache, pos) ≈ x
let dims_d = [4, 8, 16, 64]
let positions_d = [0, 1, 5, 13, 30]
let seq_len_d = 32
for di in 0..len(dims_d) {
    let hd = dims_d[di]
    let cache_d = rope_precompute(seq_len_d, hd, base)
    let cos_d = cache_d["cos"]
    let sin_d = cache_d["sin"]
    for pi in 0..len(positions_d) {
        let pos = positions_d[pi]
        let xv = rand_vec(hd, 5000 + hd * 13 + pos * 3)
        let y = rope_apply(xv, cos_d, sin_d, pos)
        let xr = rope_inverse(y, cos_d, sin_d, pos)
        let name = "D inverse∘apply=id hd=" + to_string(hd) + " pos=" + to_string(pos)
        check(name, vec_close(xr, xv, eps))
    }
}

// ── Test E : head_dim sweep sanity — rotation preserves norm ──────
// RoPE is unitary: |x| == |rope_apply(x)|. Small float drift allowed.
let dims_e = [4, 8, 16, 64]
for di in 0..len(dims_e) {
    let hd = dims_e[di]
    let cache_e = rope_precompute(16, hd, base)
    let cos_e = cache_e["cos"]
    let sin_e = cache_e["sin"]
    let xv = rand_vec(hd, 7777 + hd)
    let mut n_in = 0.0
    for i in 0..hd { n_in = n_in + xv[i] * xv[i] }
    let y = rope_apply(xv, cos_e, sin_e, 7)
    let mut n_out = 0.0
    for i in 0..hd { n_out = n_out + y[i] * y[i] }
    let name = "E norm preserved hd=" + to_string(hd)
    check(name, fabs_t(n_in - n_out) < 1.0e-4 * (n_in + 1.0))
}

// ── Test F : cos/sin bounded in [-1, 1] ───────────────────────────
let cache_f = rope_precompute(64, 32, base)
let cos_f = cache_f["cos"]
let sin_f = cache_f["sin"]
let mut f_bounded = true
for p in 0..64 {
    for i in 0..16 {
        if cos_f[p][i] >  1.000001 { f_bounded = false }
        if cos_f[p][i] < -1.000001 { f_bounded = false }
        if sin_f[p][i] >  1.000001 { f_bounded = false }
        if sin_f[p][i] < -1.000001 { f_bounded = false }
    }
}
check("F all cos/sin entries in [-1,1]", f_bounded)

// ── Test G : op-count — cache amortises sin/cos across calls ──────
// Apply the same cache to M different vectors at the same position:
// fused path reuses one (cos,sin) row; naive path redoes trig M times.
// Correctness equivalence suffices as "connection" here; we just
// reassert M independent vectors get matching results.
let hd_g = 32
let cache_g = rope_precompute(8, hd_g, base)
let cos_g = cache_g["cos"]
let sin_g = cache_g["sin"]
let pos_g = 3
let mut all_match = true
for k in 0..8 {
    let xv = rand_vec(hd_g, 900 + k * 31)
    let yf = rope_apply(xv, cos_g, sin_g, pos_g)
    let yn = rope_apply_naive(xv, pos_g, hd_g, base)
    if !vec_close(yf, yn, eps) { all_match = false }
}
check("G 8 vectors shared cache agree with naive", all_match)

// op-count bookkeeping (descriptive only — no assertion needed):
//   naive   : per call  -> head_dim/2 pow + head_dim/2 sin + head_dim/2 cos
//   fused   : precompute once, per call -> 0 pow + 0 sin + 0 cos
//   For M calls at the same pos range:
//     naive trig ops   = M · head_dim/2 · 2
//     fused trig ops   = seq_len · head_dim/2 · 2  (one-time)
//   Break-even at M == seq_len; for typical decode M >> seq_len so
//   fused wins asymptotically.
println("[INFO] op-count: naive=M*(hd/2)*2 sincos,  fused=seq_len*(hd/2)*2 sincos once")

// ══════════════════════════════════════════════════════════════════
println("")
println("pass=" + to_string(pass_count) + " fail=" + to_string(fail_count))
if fail_count == 0 {
    println("ALL PASS")
} else {
    println("FAILED")
}
println(to_string(pass_count) + " passed")
