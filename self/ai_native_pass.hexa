                        if lastK_d.kind == "ReturnStmt" { m686_fn_body_starts_let_ends_return = m686_fn_body_starts_let_ends_return + 1 }
                    }
                    if first_d.kind == "AssertStmt" {
                        if lastK_d.kind == "ReturnStmt" { m687_fn_body_starts_assert_ends_return = m687_fn_body_starts_assert_ends_return + 1 }
                    }
                    if first_d.kind == "WhileStmt" {
                        if lastK_d.kind == "ReturnStmt" { m688_fn_body_starts_while_ends_return = m688_fn_body_starts_while_ends_return + 1 }
                    }
                    if first_d.kind == "LetMutStmt" {
                        if lastK_d.kind == "ReturnStmt" { m689_fn_body_first_letmut_last_return = m689_fn_body_first_letmut_last_return + 1 }
                    }
                    let mut all_ast_d = true
                    let mut si_d = 0
                    while si_d < bln_d {
                        if node.body[si_d].kind != "AssertStmt" { all_ast_d = false }
                        si_d = si_d + 1
                    }
                    if all_ast_d { m690_fn_body_all_asserts = m690_fn_body_all_asserts + 1 }
                    let mut all_let_d = true
                    let mut all_ret_d = true
                    let mut all_ass_d = true
                    let mut all_exp_d = true
                    let mut ki_d = 0
                    while ki_d < bln_d {
                        let kk_d = node.body[ki_d].kind
                        if kk_d != "LetStmt" { all_let_d = false }
                        if kk_d != "ReturnStmt" { all_ret_d = false }
                        if kk_d != "AssignStmt" { all_ass_d = false }
                        if kk_d != "ExprStmt" { all_exp_d = false }
                        ki_d = ki_d + 1
                    }
                    if all_let_d { m691_fn_body_all_lets = m691_fn_body_all_lets + 1 }
                    if all_ret_d { m692_fn_body_all_returns = m692_fn_body_all_returns + 1 }
                    if all_ass_d { m693_fn_body_all_assigns = m693_fn_body_all_assigns + 1 }
                    if all_exp_d { m694_fn_body_all_exprstmts = m694_fn_body_all_exprstmts + 1 }
                    let mut uniq_cnt_d = 0
                    if all_let_d { uniq_cnt_d = 1 }
                    if all_ret_d { uniq_cnt_d = 1 }
                    if all_ass_d { uniq_cnt_d = 1 }
                    if all_exp_d { uniq_cnt_d = 1 }
                    if all_ast_d { uniq_cnt_d = 1 }
                    if uniq_cnt_d == 0 { m695_fn_body_mixed_kinds = m695_fn_body_mixed_kinds + 1 }
                    m696_fn_body_kind_count = m696_fn_body_kind_count + uniq_cnt_d
                    if first_d.kind == "LetMutStmt" { m697_fn_with_first_letmut = m697_fn_with_first_letmut + 1 }
                    m829_unique_kinds_per_fn = m829_unique_kinds_per_fn + uniq_cnt_d
                    if uniq_cnt_d == 1 { m830_total_uniformity_marker = m830_total_uniformity_marker + 1 }
                    if uniq_cnt_d >= 2 { m831_fn_with_2plus_kinds = m831_fn_with_2plus_kinds + 1 }
                    if uniq_cnt_d >= 3 { m832_fn_with_3plus_kinds = m832_fn_with_3plus_kinds + 1 }
                    if uniq_cnt_d > m833_max_unique_kinds_in_body { m833_max_unique_kinds_in_body = uniq_cnt_d }
                    if first_d.kind != "" { m834_total_distinct_first_kind_marker = m834_total_distinct_first_kind_marker + 1 }
                    if lastK_d.kind != "" { m835_total_distinct_last_kind_marker = m835_total_distinct_last_kind_marker + 1 }
                    m836_aggregate_growth = m836_aggregate_growth + bln_d
                    let last_d = lastK_d
                    if last_d.kind == "ReturnStmt" {
                        if type_of(last_d.left) != "string" {
                            m667_fn_returning_expr = m667_fn_returning_expr + 1
                            if last_d.left.kind == "IntLit" { m668_fn_returning_lit = m668_fn_returning_lit + 1 }
                            if last_d.left.kind == "Ident" { m669_fn_returning_ident = m669_fn_returning_ident + 1 }
                            if last_d.left.kind == "BinOp" { m670_fn_returning_binop = m670_fn_returning_binop + 1 }
                            if last_d.left.kind == "Call" { m671_fn_returning_call = m671_fn_returning_call + 1 }
                            if last_d.left.kind == "IntLit" { m815_total_const_lit_returns = m815_total_const_lit_returns + 1 }
                            if last_d.left.kind == "Call" { m816_total_call_returns = m816_total_call_returns + 1 }
                            if last_d.left.kind == "BinOp" { m817_total_binop_returns = m817_total_binop_returns + 1 }
                            if last_d.left.kind == "Ident" { m818_total_ident_returns = m818_total_ident_returns + 1 }
                            if last_d.left.kind == "BoolLit" { m819_total_bool_returns = m819_total_bool_returns + 1 }
                            if last_d.left.kind == "StringLit" { m820_total_string_returns = m820_total_string_returns + 1 }
                            if last_d.left.kind == "UnaryOp" { m821_total_unary_returns = m821_total_unary_returns + 1 }
                            if last_d.left.kind == "Index" { m822_total_index_returns = m822_total_index_returns + 1 }
                            if last_d.left.kind == "CharLit" { m823_total_charlit_returns = m823_total_charlit_returns + 1 }
                            let lk_d = last_d.left.kind
                            if lk_d != "IntLit" {
                                if lk_d != "Ident" {
                                    if lk_d != "BinOp" {
                                        if lk_d != "Call" {
                                            if lk_d != "BoolLit" {
                                                if lk_d != "StringLit" {
                                                    if lk_d != "UnaryOp" {
                                                        if lk_d != "Index" {
                                                            if lk_d != "CharLit" { m824_total_other_returns = m824_total_other_returns + 1 }
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        } else {
                            if bln_d > 1 { m672_fn_void_return_with_body = m672_fn_void_return_with_body + 1 }
                        }
                    }
                }
            }
            if type_of(node.params) == "array" {
                let pl2_d = len(node.params)
                if pl2_d == 0 { m546_zero_params_fn = m546_zero_params_fn + 1 }
                if pl2_d == 1 { m547_single_param_fn = m547_single_param_fn + 1 }
                if pl2_d >= 4 { m548_many_param_fn = m548_many_param_fn + 1 }
                if pl2_d == 0 {
                    if brets_d == 0 { m549_empty_params_zero_returns = m549_empty_params_zero_returns + 1 }
                }
                if node.value != "" {
                    if pl2_d == 1 { m550_attr_one_param = m550_attr_one_param + 1 }
                    if pl2_d == 2 { m551_attr_two_params = m551_attr_two_params + 1 }
                }
                if type_of(node.body) == "array" {
                    let bl3_d = len(node.body)
                    if bl3_d == 1 {
                        if brets_d == 1 {
                            if pl2_d >= 1 { m552_simple_getter = m552_simple_getter + 1 }
                        }
                    }
                    if bl3_d == 1 {
                        if bass_d == 1 { m553_simple_setter = m553_simple_setter + 1 }
                    }
                    if node.value != "" {
                        if attr_has(split_attrs_m0(node.value), "pure") {
                            if bl3_d == 1 { m556_single_stmt_pure = m556_single_stmt_pure + 1 }
                            if bl3_d == 1 {
                                if brets_d == 1 { m554_identity_pure = m554_identity_pure + 1 }
                            }
                            if bl3_d == 1 {
                                if bcalls_d == 1 { m555_wrapper_pure = m555_wrapper_pure + 1 }
                            }
                            if bl3_d <= 2 { m557_trivial_pure = m557_trivial_pure + 1 }
                        }
                    }
                }
            }
            if bbops_d == 0 { m418_zero_binop_fns = m418_zero_binop_fns + 1 }
            if bbops_d == 1 { m441_one_binop_fns = m441_one_binop_fns + 1 }
            if bbops_d == 2 { m455_two_binop_fns = m455_two_binop_fns + 1 }
            if bbops_d == 3 { m461_three_binop_fns = m461_three_binop_fns + 1 }
            if bbops_d == 4 { m464_four_binop_fns = m464_four_binop_fns + 1 }
            if bbops_d >= 5 { m467_heavy_binop_fns = m467_heavy_binop_fns + 1 }
            if bbops_d >= 10 { m470_very_heavy_binop_fns = m470_very_heavy_binop_fns + 1 }
            if bbops_d >= 3 { m731_fn_binop_3plus = m731_fn_binop_3plus + 1 }
            if bbops_d >= 5 { m732_fn_binop_5plus = m732_fn_binop_5plus + 1 }
            if bass_d >= 3 { m733_fn_assign_3plus = m733_fn_assign_3plus + 1 }
            if bass_d >= 5 { m734_fn_assign_5plus = m734_fn_assign_5plus + 1 }
            if brets_d >= 3 { m735_fn_return_3plus = m735_fn_return_3plus + 1 }
            if basts_d >= 3 { m736_fn_assert_3plus = m736_fn_assert_3plus + 1 }
            if bwhs_d >= 3 { m737_fn_while_3plus = m737_fn_while_3plus + 1 }
            if bexprs_d >= 3 { m738_fn_exprstmt_3plus = m738_fn_exprstmt_3plus + 1 }
            if blms_d >= 2 { m739_fn_letmut_2plus = m739_fn_letmut_2plus + 1 }
            if blms_d >= 3 { m740_fn_letmut_3plus = m740_fn_letmut_3plus + 1 }
            if blms_d >= 5 { m741_fn_letmut_5plus = m741_fn_letmut_5plus + 1 }
            let bints2_d = count_body_intlits(node.body)
            if bints2_d >= 3 { m742_fn_intlit_3plus = m742_fn_intlit_3plus + 1 }
            if bints2_d >= 5 { m743_fn_intlit_5plus = m743_fn_intlit_5plus + 1 }
            let bidents2_d = count_body_by_kind(node.body, "Ident")
            if bidents2_d >= 3 { m744_fn_ident_3plus = m744_fn_ident_3plus + 1 }
            if bidents2_d >= 5 { m745_fn_ident_5plus = m745_fn_ident_5plus + 1 }
            let bunas2_d = count_body_by_kind(node.body, "UnaryOp")
            if bunas2_d >= 2 { m746_fn_unary_2plus = m746_fn_unary_2plus + 1 }
            let bbools2_d = count_body_by_kind(node.body, "BoolLit")
            if bbools2_d >= 2 { m747_fn_boollit_2plus = m747_fn_boollit_2plus + 1 }
            let bstrs2_d = count_body_by_kind(node.body, "StringLit")
            if bstrs2_d >= 2 { m748_fn_stringlit_2plus = m748_fn_stringlit_2plus + 1 }
            if count_body_by_kind(node.body, "Index") > 0 { m749_fn_index_any = m749_fn_index_any + 1 }
            m750_milestone_750 = m750_milestone_750 + 1
            m751_total_blms_x_brets = m751_total_blms_x_brets + blms_d * brets_d
            m752_total_bcalls_x_blets = m752_total_bcalls_x_blets + bcalls_d * blets_d
            m753_total_bbops_x_bidents = m753_total_bbops_x_bidents + bbops_d * bidents2_d
            m754_total_brets_x_bass = m754_total_brets_x_bass + brets_d * bass_d
            m755_total_bwhs_x_basts = m755_total_bwhs_x_basts + bwhs_d * basts_d
            if type_of(node.params) == "array" {
                m756_total_param_x_attr = m756_total_param_x_attr + len(node.params) * len(split_attrs_m0(node.value))
                if type_of(node.body) == "array" {
                    m757_total_body_x_param = m757_total_body_x_param + len(node.body) * len(node.params)
                }
                let cplx3_d = bbops_d + bcalls_d + bwhs_d + brets_d
                m760_total_param_x_cplx = m760_total_param_x_cplx + len(node.params) * cplx3_d
                m761_total_attr_x_cplx = m761_total_attr_x_cplx + len(split_attrs_m0(node.value)) * cplx3_d
                m762_total_name_x_cplx = m762_total_name_x_cplx + len(node.name) * cplx3_d
            }
            if type_of(node.body) == "array" {
                m758_total_body_x_attr = m758_total_body_x_attr + len(node.body) * len(split_attrs_m0(node.value))
                m759_total_body_x_cplx = m759_total_body_x_cplx + len(node.body) * (bbops_d + bcalls_d + brets_d)
            }
            let bints_d = count_body_intlits(node.body)
            m353_total_intlits = m353_total_intlits + bints_d
            if bints_d > m405_max_body_intlits { m405_max_body_intlits = bints_d }
            if bints_d == 0 { m419_zero_intlit_fns = m419_zero_intlit_fns + 1 }
            if bints_d == 1 { m443_one_intlit_fns = m443_one_intlit_fns + 1 }
            if bints_d == 2 { m458_two_intlit_fns = m458_two_intlit_fns + 1 }
            if bints_d >= 5 { m474_heavy_intlit_fns = m474_heavy_intlit_fns + 1 }
            if bints_d >= 10 { m477_very_heavy_intlit_fns = m477_very_heavy_intlit_fns + 1 }
            let bbools_d = count_body_by_kind(node.body, "BoolLit")
            m354_total_boollits = m354_total_boollits + bbools_d
            if bbools_d > m414_max_body_boollits { m414_max_body_boollits = bbools_d }
            if bbools_d == 0 { m428_zero_boollit_fns = m428_zero_boollit_fns + 1 }
            if bbools_d == 1 { m450_one_boollit_fns = m450_one_boollit_fns + 1 }
            let bstrs_d = count_body_by_kind(node.body, "StringLit")
            m355_total_stringlits = m355_total_stringlits + bstrs_d
            if bstrs_d > m415_max_body_stringlits { m415_max_body_stringlits = bstrs_d }
            if bstrs_d == 0 { m429_zero_stringlit_fns = m429_zero_stringlit_fns + 1 }
            if bstrs_d == 1 { m451_one_stringlit_fns = m451_one_stringlit_fns + 1 }
            if count_body_by_kind(node.body, "Index") > 0 { m452_has_index_fns = m452_has_index_fns + 1 }
            let bidents_d = count_body_by_kind(node.body, "Ident")
            m356_total_idents = m356_total_idents + bidents_d
            if bidents_d > m406_max_body_idents { m406_max_body_idents = bidents_d }
            if bidents_d == 0 { m427_zero_ident_fns = m427_zero_ident_fns + 1 }
            if bidents_d == 1 { m442_one_ident_fns = m442_one_ident_fns + 1 }
            if bidents_d >= 5 { m475_heavy_ident_fns = m475_heavy_ident_fns + 1 }
            if bidents_d >= 10 { m478_very_heavy_ident_fns = m478_very_heavy_ident_fns + 1 }
            let bunas_d = count_body_by_kind(node.body, "UnaryOp")
            m357_total_unaryops = m357_total_unaryops + bunas_d
            if bunas_d > m416_max_body_unaryops { m416_max_body_unaryops = bunas_d }
            if bunas_d == 0 { m426_zero_unary_fns = m426_zero_unary_fns + 1 }
            if bunas_d == 1 { m449_one_unary_fns = m449_one_unary_fns + 1 }
            if bunas_d >= 3 { m476_heavy_unary_fns = m476_heavy_unary_fns + 1 }
            m358_total_indexes = m358_total_indexes + count_body_by_kind(node.body, "Index")
            m359_total_charlits = m359_total_charlits + count_body_by_kind(node.body, "CharLit")
            // M295/M296: const-return fn classification
            if body_is_const_return(node.body) {
                let s = node.body[0]
                let e = s.left
                if type_of(e) != "string" {
                    if e.kind == "BoolLit" { m295_bool_const_fns = m295_bool_const_fns + 1 }
                    if e.kind == "IntLit" { m296_int_const_fns = m296_int_const_fns + 1 }
                    if e.kind == "StringLit" { m297_string_const_fns = m297_string_const_fns + 1 }
                    if e.kind == "CharLit" { m298_char_const_fns = m298_char_const_fns + 1 }
                }
            }
            // M37/M84: stub → auto @pure (use fresh attrs from node.value)
            if body_is_const_return(node.body) {
                m37_stubs = m37_stubs + 1
                let fresh_attrs_stub = split_attrs_m0(node.value)
                if !attr_has(fresh_attrs_stub, "pure") && _has_av {
                    node = rewrite_fn_with_attrs(node, node.value + ",pure")
                    m84_stub_pure = m84_stub_pure + 1
                    println("[ai-native] fn " + node.name + " REWRITE: auto @pure (stub)")
                }
            }
            // M38: attr count histogram
            if an == 1 { m38_one = m38_one + 1 }
            if an == 2 { m38_two = m38_two + 1 }
            if an == 3 { m38_three = m38_three + 1 }
            if an >= 4 { m38_four_plus = m38_four_plus + 1 }
            // M64/M67: attrs sum + max per fn
            m64_total_attrs = m64_total_attrs + an
            if an > m67_max_attrs_per_fn { m67_max_attrs_per_fn = an }
            // M39: parameter stats
            let pn = len(node.params)
            m39_param_sum = m39_param_sum + pn
            if pn == 0 { m39_zero_arg = m39_zero_arg + 1 }
            if pn > m39_max_arity { m39_max_arity = pn }
            // M42: fn name hash accumulator
            m42_hash_sum = m42_hash_sum + str_hash(node.name)
            // M60: longest attr string
            let al = len(node.value.chars())
            if al > m60_longest_attrs { m60_longest_attrs = al }
            // M43/M44/M45: shape stats
            let bd = max_binop_depth_body(node.body)
            if bd > m43_max_binop_depth { m43_max_binop_depth = bd }
            count_lits_body(node.body)
            // M46: max name length
            let nl = len(node.name.chars())
            if nl > m46_max_name_len { m46_max_name_len = nl }
            // M49: min name length
            if m49_min_name_len == 0 || nl < m49_min_name_len {
                m49_min_name_len = nl
            }
            // M47: ident refs
            count_idents_body(node.body)
            // M48: return count
            m48_return_count = m48_return_count + count_returns_body(node.body)
            // M131/M133/M134: total + max + min node count
            let nc_here = count_nodes_body(node.body)
            m131_total_nodes = m131_total_nodes + nc_here
            if nc_here > m133_max_nodes_per_fn { m133_max_nodes_per_fn = nc_here }
            if m134_min_nodes_per_fn == 0 || nc_here < m134_min_nodes_per_fn {
                m134_min_nodes_per_fn = nc_here
            }
            // M100~M103: shape node counters
            count_shape_body(node.body)
            // M116: eliminate assert(true) stmts
            let before_elim = m116_assert_elim
            let trimmed = eliminate_trivial_asserts(node.body)
            if m116_assert_elim > before_elim {
                node = rewrite_fn_with_body(node, trimmed)
                println("[ai-native] fn " + node.name + " REWRITE: dropped " + to_string(m116_assert_elim - before_elim) + " trivial assert(s)")
            }
            // M104: const-folded assertion check (top-level only)
            let bnn = body_stmt_count(node.body)
            let mut ci = 0
            while ci < bnn {
                let s = node.body[ci]
                if s.kind == "AssertStmt" {
                    let e = s.left
                    if type_of(e) != "string" {
                        if e.kind == "BoolLit" && e.value == "true" {
                            m104_const_assert_true = m104_const_assert_true + 1
                        }
                        if e.kind == "BoolLit" && e.value == "false" {
                            m104_const_assert_false = m104_const_assert_false + 1
                            println("[ai-native] fn " + node.name + " WARN: assert false (unreachable)")
                        }
                    }
                }
                ci = ci + 1
            }
            // M105: @pure + @inline combo
            if attr_has(attrs, "pure") && attr_has(attrs, "inline") {
                m105_pure_inline_combo = m105_pure_inline_combo + 1
            }
            // M50/M51/M52: stmt kind aggregation
            count_stmt_kinds(node.body)
            // M13: track max while nesting
            let wd = while_depth(node.body)
            if wd > m13_max_while_depth { m13_max_while_depth = wd }
            // M14: bubble-sort heuristic — @optimize + nested while + let mut
            if attr_has(attrs, "optimize") && wd >= 2 && body_has_let_mut(node.body) {
                println("[ai-native] fn " + node.name + " CANDIDATE: bubble→merge")
                m14_bubble_candidates = m14_bubble_candidates + 1
            }
            // M957: bubble-sort strict detection — nested while + let mut + >=4 Index ops (a[j],a[j+1],swap)
            if wd >= 2 && body_has_let_mut(node.body) && count_body_by_kind(node.body, "Index") >= 4 {
                println("[ai-native] fn " + node.name + " DETECTED: bubble-sort (→ merge sort O(n log n))")
                m957_bubble_detected = m957_bubble_detected + 1
            }
            // M961: bubble-sort → merge-sort AST rewrite (requires @optimize + M957 detection)
            if attr_has(attrs, "optimize") && wd >= 2 && body_has_let_mut(node.body) && count_body_by_kind(node.body, "Index") >= 4 {
                let param_name = get_first_param_name(node)
                let ms_body = make_merge_sort_body(node.name, param_name)
                node = rewrite_fn_with_body(node, ms_body)
                m961_bubble_rewrites = m961_bubble_rewrites + 1
                println("[ai-native] fn " + node.name + " REWRITE: bubble→merge_sort")
            }
            // M958: linear search detection — single while + Index + return-in-while + no let mut swap
            if wd >= 1 && wd < 2 && !body_has_let_mut(node.body) && count_body_by_kind(node.body, "Index") >= 1 && body_has_return_in_while(node.body) {
                println("[ai-native] fn " + node.name + " DETECTED: linear-search (→ binary search O(log n) if sorted)")
                m958_linear_search_detected = m958_linear_search_detected + 1
            }
            // M959: tail-recursive detection — last stmt is Return(self-call), no @optimize required
            if is_tail_call(node.body, node.name) {
                println("[ai-native] fn " + node.name + " DETECTED: tail-recursive (→ while loop, O(1) stack)")
                m959_tail_recursive_detected = m959_tail_recursive_detected + 1
            }
            // M15: tail-call heuristic — @optimize + last stmt is Return(self_call)
            if attr_has(attrs, "optimize") && is_tail_call(node.body, node.name) {
                println("[ai-native] fn " + node.name + " CANDIDATE: tail→loop")
                m15_tail_call_candidates = m15_tail_call_candidates + 1
                // M25: if the body is EXACTLY a single tail-return, rewrite to while(true){}; return 0
                if is_simple_tail_only(node.body, node.name) {
                    let new_body = [make_while_true_empty(), make_return_zero()]
                    node = rewrite_fn_with_body(node, new_body)
                    m25_tail_rewrites = m25_tail_rewrites + 1
                    println("[ai-native] fn " + node.name + " REWRITE: tail→while(true)")
                }
            }
            // M16: Strassen heuristic — @optimize + while depth >= 3
            if attr_has(attrs, "optimize") && wd >= 3 {
                println("[ai-native] fn " + node.name + " CANDIDATE: matmul→Strassen")
                m16_strassen_candidates = m16_strassen_candidates + 1
            }
            // M481/M482: @fuse call-chain depth detection
            if attr_has(attrs, "fuse") {
                let chain = body_max_call_chain(node.body)
                if chain > m481_fuse_chain_max { m481_fuse_chain_max = chain }
                if chain >= 2 {
                    m482_fuse_candidates = m482_fuse_candidates + 1
                    println("[ai-native] fn " + node.name + " CANDIDATE: @fuse chain depth " + to_string(chain) + " (fuseable)")
                } else {
                    println("[ai-native] fn " + node.name + " NOTE: @fuse chain depth " + to_string(chain) + " (single call, no fusion needed)")
                }
                // M965: @fuse map/filter chain → single while-loop rewrite
                let before_mf = m965_mapfilter_fused
                let mf_body = fuse_mapfilter_body(node.body)
                let mf_count = m965_mapfilter_fused - before_mf
                if mf_count > 0 {
                    node = rewrite_fn_with_body(node, mf_body)
                    println("[ai-native] fn " + node.name + " REWRITE: @fuse map/filter chain → loop (" + to_string(mf_count) + " site(s))")
                }
                // M960: @fuse actual intermediate variable elimination — AST rewrite
                // Run fuse_intermediate_vars up to 4 times (fixpoint) to handle chains a→b→c→d
                let before_fuse = m960_fuse_rewrites
                let mut fuse_body = node.body
                let mut fuse_iter = 0
                while fuse_iter < 4 {
                    let prev_count = m960_fuse_rewrites
                    fuse_body = fuse_intermediate_vars(fuse_body)
                    if m960_fuse_rewrites == prev_count { fuse_iter = 4 }
                    fuse_iter = fuse_iter + 1
                }
                let fuse_count = m960_fuse_rewrites - before_fuse
                if fuse_count > 0 {
                    node = rewrite_fn_with_body(node, fuse_body)
                    println("[ai-native] fn " + node.name + " REWRITE: @fuse eliminated " + to_string(fuse_count) + " intermediate var(s)")
                }
            }
            // M962: @specialize — fn with params used in binop with int literal
            //   → monomorphization/const-prop opportunity. Requires >=1 param.
            if attr_has(attrs, "specialize") {
                let p_cnt = if type_of(node.params) == "array" { len(node.params) } else { 0 }
                if p_cnt == 0 {
                    println("[ai-native] fn " + node.name + " WARN: @specialize on zero-arg fn (no parameter to specialize)")
                    m962_specialize_violations = m962_specialize_violations + 1
                } else {
                    m962_specialize_ok = m962_specialize_ok + 1
                    let bops = count_binops_with_intlit(node.body)
                    if bops > 0 {
                        m962_specialize_candidates = m962_specialize_candidates + 1
                        println("[ai-native] fn " + node.name + " CANDIDATE: @specialize (" + to_string(bops) + " literal binop site(s), " + to_string(p_cnt) + " param(s))")
                    } else {
                        println("[ai-native] fn " + node.name + " NOTE: @specialize — no literal binop (low benefit)")
                    }
                }
            }
            // M963: @lazy — defer-eval safety. Requires zero-arg + @pure.
            if attr_has(attrs, "lazy") {
                let lp_cnt = if type_of(node.params) == "array" { len(node.params) } else { 0 }
                if lp_cnt != 0 {
                    println("[ai-native] fn " + node.name + " WARN: @lazy requires zero-arg (found " + to_string(lp_cnt) + ")")
                    m963_lazy_violations = m963_lazy_violations + 1
                } else if !attr_has(attrs, "pure") {
                    println("[ai-native] fn " + node.name + " WARN: @lazy requires @pure (unsafe defer-eval)")
                    m963_lazy_violations = m963_lazy_violations + 1
                } else {
                    m963_lazy_ok = m963_lazy_ok + 1
                    println("[ai-native] fn " + node.name + " OK: @lazy (defer-eval safe)")
                }
            }
            // M964: @reduce — fold/reduce accumulator detection.
            if attr_has(attrs, "reduce") {
                let add_acc = count_accumulators(node.body)
                let mul_acc = count_mul_accumulators(node.body)
                let total_acc = add_acc + mul_acc
                if total_acc == 0 {
                    println("[ai-native] fn " + node.name + " WARN: @reduce has no accumulator pattern (acc=acc+/*x)")
                    m964_reduce_violations = m964_reduce_violations + 1
                } else {
                    m964_reduce_ok = m964_reduce_ok + 1
                    m964_reduce_candidates = m964_reduce_candidates + total_acc
                    let kind = if add_acc > 0 && mul_acc > 0 { "sum+product" } else if add_acc > 0 { "sum" } else { "product" }
                    println("[ai-native] fn " + node.name + " CANDIDATE: @reduce " + kind + " (" + to_string(total_acc) + " accumulator(s) → parallel fold)")
                }
            }
            // M966: @cache — bounded memoize. Like @memoize but with LRU eviction.
            //   Requires >=1 param (cache key). Pure recommended.
            if attr_has(attrs, "cache") {
                let cache_pc = if type_of(node.params) == "array" { len(node.params) } else { 0 }
                if cache_pc >= 1 {
                    m966_cache_ok = m966_cache_ok + 1
                    println("[ai-native] fn " + node.name + " OK: @cache (" + to_string(cache_pc) + " param(s), LRU-eligible)")
                } else {
                    m966_cache_violations = m966_cache_violations + 1
                    println("[ai-native] fn " + node.name + " WARN: @cache requires >=1 param (no key)")
                }
            }
            // M967: @profile — call-count/timing measurement wrapper.
            //   Any fn qualifies. Wraps body with entry/exit instrumentation.
            if attr_has(attrs, "profile") {
                m967_profile_ok = m967_profile_ok + 1
                let prof_sz = body_stmt_count(node.body)
                println("[ai-native] fn " + node.name + " OK: @profile (body=" + to_string(prof_sz) + " stmts, instrumented)")
            }
            // M968: @autograd — automatic differentiation (forward mode).
            //   Requires >=1 numeric param. Body should contain arithmetic.
            if attr_has(attrs, "autograd") {
                let ag_pc = if type_of(node.params) == "array" { len(node.params) } else { 0 }
                if ag_pc >= 1 {
                    let ag_bops = count_binops_with_intlit(node.body)
                    m968_autograd_ok = m968_autograd_ok + 1
                    println("[ai-native] fn " + node.name + " OK: @autograd (" + to_string(ag_pc) + " param(s), " + to_string(ag_bops) + " arith site(s))")
                } else {
                    m968_autograd_violations = m968_autograd_violations + 1
                    println("[ai-native] fn " + node.name + " WARN: @autograd requires >=1 param")
                }
            }
            // M969: @quantize — int8/int4 quantization simulation.
            //   Requires >=1 param. Body should use numeric ops.
            if attr_has(attrs, "quantize") {
                let q_pc = if type_of(node.params) == "array" { len(node.params) } else { 0 }
                if q_pc >= 1 {
                    m969_quantize_ok = m969_quantize_ok + 1
                    println("[ai-native] fn " + node.name + " OK: @quantize (" + to_string(q_pc) + " param(s), quant-eligible)")
                } else {
                    m969_quantize_violations = m969_quantize_violations + 1
                    println("[ai-native] fn " + node.name + " WARN: @quantize requires >=1 param")
                }
            }
            // M970: @algebraic — commutative/associative reordering.
            //   Scans body for non-canonical commutative and unfoldable associative chains.
            if attr_has(attrs, "algebraic") {
                let alg_sites = count_algebraic_body(node.body)
                if alg_sites > 0 {
                    m970_algebraic_ok = m970_algebraic_ok + 1
                    m970_algebraic_candidates = m970_algebraic_candidates + alg_sites
                    println("[ai-native] fn " + node.name + " CANDIDATE: @algebraic " + to_string(alg_sites) + " reorderable site(s)")
                } else {
                    m970_algebraic_ok = m970_algebraic_ok + 1
                    println("[ai-native] fn " + node.name + " OK: @algebraic (already canonical)")
                }
            }
            // M971: @approximate — fast math approximation detection.
            //   Detects division, sqrt, pow, exp, log, trig calls.
            if attr_has(attrs, "approximate") {
                let apx_cnt = count_approx_body(node.body)
                if apx_cnt > 0 {
                    m971_approx_ok = m971_approx_ok + 1
                    m971_approx_candidates = m971_approx_candidates + apx_cnt
                    println("[ai-native] fn " + node.name + " CANDIDATE: @approximate " + to_string(apx_cnt) + " expensive math site(s)")
                } else {
                    m971_approx_violations = m971_approx_violations + 1
                    println("[ai-native] fn " + node.name + " WARN: @approximate — no expensive math ops found")
                }
            }
            // M972: @compact — SoA transform detection.
            //   Detects arr[i].field patterns (AoS → SoA candidate).
            if attr_has(attrs, "compact") {
                let cpt_cnt = count_compact_body(node.body)
                if cpt_cnt > 0 {
                    m972_compact_ok = m972_compact_ok + 1
                    m972_compact_candidates = m972_compact_candidates + cpt_cnt
                    println("[ai-native] fn " + node.name + " CANDIDATE: @compact " + to_string(cpt_cnt) + " AoS access(es) → SoA transform")
                } else {
                    m972_compact_ok = m972_compact_ok + 1
                    println("[ai-native] fn " + node.name + " OK: @compact (no AoS pattern detected)")
                }
            }
            // M973: @optimize sliding-window — DP lookback detection.
            //   Detects dp[i] = f(dp[i-1], dp[i-2]) patterns inside while loops.
            if attr_has(attrs, "optimize") {
                let sw_cnt = count_sliding_window_body(node.body)
                if sw_cnt > 0 {
                    m973_sliding_ok = m973_sliding_ok + 1
                    m973_sliding_candidates = m973_sliding_candidates + sw_cnt
                    println("[ai-native] fn " + node.name + " CANDIDATE: @optimize sliding-window " + to_string(sw_cnt) + " DP lookback(s) → O(1) memory")
                }
            }
            // M17/M23: recursive @optimize without @memoize → auto-inject
            if attr_has(attrs, "optimize") && is_rec && !attr_has(attrs, "memoize") {
                println("[ai-native] fn " + node.name + " REWRITE: auto-added @memoize")
                m17_dp_missed = m17_dp_missed + 1
                node = rewrite_fn_with_attrs(node, node.value + ",memoize")
                m23_auto_memoize = m23_auto_memoize + 1
            }
            // M250: constant propagation (run before simplify for compose)
            let before_cp = m250_const_prop
            let propagated_body = propagate_consts_body(node.body)
            if m250_const_prop > before_cp {
                node = rewrite_fn_with_body(node, propagated_body)
                println("[ai-native] fn " + node.name + " REWRITE: const-prop +" + to_string(m250_const_prop - before_cp))
            }
            // M259: copy propagation (let y = x → use x)
            let before_copy = m250_const_prop
            let copy_body = propagate_copies_body(node.body)
            // m250_const_prop counts substitutions; track delta
            let copy_delta = m250_const_prop - before_copy
            if copy_delta > 0 {
                m259_copy_prop = m259_copy_prop + copy_delta
                node = rewrite_fn_with_body(node, copy_body)
                println("[ai-native] fn " + node.name + " REWRITE: copy-prop +" + to_string(copy_delta))
            }
            // M294: infinite loop warning
            let inf = detect_infinite_loops(node.body)
            if inf > 0 {
                m294_infinite_loops = m294_infinite_loops + inf
                println("[ai-native] fn " + node.name + " WARN: " + to_string(inf) + " infinite loop(s)")
            }
            // M288: dead pure ExprStmt drop
            let before_de = m288_dead_exprs
            let de_body = drop_dead_exprs(node.body)
            if m288_dead_exprs > before_de {
                node = rewrite_fn_with_body(node, de_body)
                println("[ai-native] fn " + node.name + " REWRITE: drop dead-expr x" + to_string(m288_dead_exprs - before_de))
            }
            // M275: dead AssignStmt elimination
            let before_da = m275_dead_assigns
            let da_body = eliminate_dead_assigns(node.body)
            if m275_dead_assigns > before_da {
                node = rewrite_fn_with_body(node, da_body)
                println("[ai-native] fn " + node.name + " REWRITE: dead-assign drop x" + to_string(m275_dead_assigns - before_da))
            }
            // M274: while true { return X } → return X
            let before_w2r = m274_while_to_return
            let w2r_body = collapse_while_returns(node.body)
            if m274_while_to_return > before_w2r {
                node = rewrite_fn_with_body(node, w2r_body)
                println("[ai-native] fn " + node.name + " REWRITE: while(true)→return")
            }
            // M273: return forwarding (let x = e; return x → return e)
            let before_rf = m273_return_fwd
            let rf_body = forward_returns(node.body)
            if m273_return_fwd > before_rf {
                node = rewrite_fn_with_body(node, rf_body)
                println("[ai-native] fn " + node.name + " REWRITE: return forwarding")
            }
            // M272: self-assign elimination (before mut→let conversion)
            let before_sa = m272_self_assigns
            let sa_body = eliminate_self_assigns(node.body)
            if m272_self_assigns > before_sa {
                node = rewrite_fn_with_body(node, sa_body)
                println("[ai-native] fn " + node.name + " REWRITE: drop self-assign x" + to_string(m272_self_assigns - before_sa))
            }
            // M271: redundant mut → let conversion (before DSE)
            let before_mtl = m271_mut_to_let
            let mtl_body = convert_mut_to_let(node.body)
            if m271_mut_to_let > before_mtl {
                node = rewrite_fn_with_body(node, mtl_body)
                println("[ai-native] fn " + node.name + " REWRITE: mut→let " + to_string(m271_mut_to_let - before_mtl))
            }
            // M251: dead store elimination (after const prop makes lets dead)
            let before_ds = m251_dead_stores
            let dse_body = eliminate_dead_stores(node.body)
            if m251_dead_stores > before_ds {
                node = rewrite_fn_with_body(node, dse_body)
                println("[ai-native] fn " + node.name + " REWRITE: DSE dropped " + to_string(m251_dead_stores - before_ds) + " dead let(s)")
            }
            // M252: @contract → auto pre-assert injection (param0 != 0)
            let fresh_attrs_ct = split_attrs_m0(node.value)
            if attr_has(fresh_attrs_ct, "contract") && len(node.params) > 0 {
                let pname = node.params[0].name
                if !body_has_contract_assert(node.body, pname) {
                    let injected = inject_contract_assert(node.body, pname)
                    node = rewrite_fn_with_body(node, injected)
                    m252_contract_injects = m252_contract_injects + 1
                    println("[ai-native] fn " + node.name + " REWRITE: @contract assert " + pname + " != 0 prepended")
                }
            }
            // M30/M32/M33/M34/M35/M41: folding + dead loop elimination
            let before_alg = m30_algebraic
            let before_fold = m32_folds
            let before_cmp = m33_cmp_folds
            let before_un = m34_unary_folds
            let before_bool = m35_bool_folds
            let before_dead_loop = m41_dead_loops
            let simplified_body = simplify_body(node.body)
            if m30_algebraic > before_alg || m32_folds > before_fold || m33_cmp_folds > before_cmp || m34_unary_folds > before_un || m35_bool_folds > before_bool || m41_dead_loops > before_dead_loop {
                node = rewrite_fn_with_body(node, simplified_body)
                println("[ai-native] fn " + node.name + " REWRITE: simplify (+" + to_string(m30_algebraic - before_alg) + " alg, +" + to_string(m32_folds - before_fold) + " fold, +" + to_string(m33_cmp_folds - before_cmp) + " cmp, +" + to_string(m34_unary_folds - before_un) + " una)")
            }
            // M19/M24: unreachable code → detect + eliminate
            let unr = count_unreachable(node.body)
            if unr > 0 {
                println("[ai-native] fn " + node.name + " WARN: " + to_string(unr) + " unreachable stmt(s) after return")
                m19_unreachable = m19_unreachable + unr
                let cleaned = eliminate_dead(node.body)
                node = rewrite_fn_with_body(node, cleaned)
                m24_dce_fns = m24_dce_fns + 1
                m24_dce_stmts = m24_dce_stmts + unr
                println("[ai-native] fn " + node.name + " REWRITE: DCE dropped " + to_string(unr) + " stmt(s)")
            }
            // M20 already counted above (pre-rewrite)
            // M21: constant return
            if body_is_const_return(node.body) {
                println("[ai-native] fn " + node.name + " NOTE: constant-return, @pure/@memoize redundant")
                m21_const_return = m21_const_return + 1
            }
            // M12: track body size per primary group (first attr wins)
            if an > 0 {
                let primary_cat = classify_attr_m0(attrs[0])
                let sz2 = body_stmt_count(node.body)
                if primary_cat == "G1" { m12_g1_size = m12_g1_size + sz2 }
                if primary_cat == "G2" { m12_g2_size = m12_g2_size + sz2 }
                if primary_cat == "G3" { m12_g3_size = m12_g3_size + sz2 }
                if primary_cat == "G4" { m12_g4_size = m12_g4_size + sz2 }
            }
            // M10: @memoize score — +1 if recursive, +1 if also @pure
            if attr_has(attrs, "memoize") {
                let mut score = 0
                if is_rec { score = score + 1 }
                if attr_has(attrs, "pure") { score = score + 1 }
                m10_memoize_score_sum = m10_memoize_score_sum + score
                if score > m124_max_memoize_score { m124_max_memoize_score = score }
                println("[ai-native] fn " + node.name + " memoize-score=" + to_string(score))
                // M90: @memoize without @pure is potentially unsafe
                if !attr_has(attrs, "pure") {
                    m90_unsafe_memoize = m90_unsafe_memoize + 1
                    println("[ai-native] fn " + node.name + " WARN: @memoize without @pure (unsafe)")
                }
                // M91: ideal = pure + recursive + memoize
                if attr_has(attrs, "pure") && is_rec {
                    m91_ideal_memoize = m91_ideal_memoize + 1
                }
            }
            // M92/M93/M141: per-fn param stats
            let pcount2 = len(node.params)
            if pcount2 == 0 { m92_nullary = m92_nullary + 1 }
            if pcount2 > m93_max_params { m93_max_params = pcount2 }
            if pcount2 == 0 { m141_p0 = m141_p0 + 1 }
            if pcount2 == 1 { m141_p1 = m141_p1 + 1 }
            if pcount2 == 2 { m141_p2 = m141_p2 + 1 }
            if pcount2 >= 3 { m141_p3plus = m141_p3plus + 1 }
            // M146/M147: max + total param name length
            let mut pi = 0
            while pi < pcount2 {
                let pn_len = len(node.params[pi].name.chars())
                if pn_len > m146_max_param_name { m146_max_param_name = pn_len }
                m147_total_param_chars = m147_total_param_chars + pn_len
                pi = pi + 1
            }
            // M4: attr conflict (once per fn)
            let conflict = find_attr_conflict(attrs)
            if conflict != "" {
                println("[ai-native] fn " + node.name + " CONFLICT: " + conflict)
                m4_attr_conflicts = m4_attr_conflicts + 1
            }
            let mut j = 0
            while j < an {
                let attr = attrs[j]
                let cat = classify_attr_m0(attr)
                println("[ai-native] fn " + node.name + " @" + attr + " (" + cat + ")")
                // M1/M2: @pure → verify body recursively
                if attr == "pure" {
                    let reason = check_purity_m1(node.body)
                    if reason == "" {
                        println("  [pure] OK")
                        m1_pure_ok = m1_pure_ok + 1
                    } else {
                        println("  [pure] VIOLATION: " + reason)
                        m1_pure_violations = m1_pure_violations + 1
                    }
                }
                // M3: @inline → body size check
                if attr == "inline" {
                    let sz = body_stmt_count(node.body)
                    if sz <= inline_threshold {
                        println("  [inline] OK (" + to_string(sz) + " stmts)")
                        m3_inline_ok = m3_inline_ok + 1
                    } else {
                        println("  [inline] TOO BIG (" + to_string(sz) + " stmts > " + to_string(inline_threshold) + ")")
                        m3_inline_too_big = m3_inline_too_big + 1
                    }
                }
                // M5: @memoize — needs ≥1 param (cache key)
                if attr == "memoize" {
                    let pcount = 0
                    let pc = len(node.params)
                    if pc >= 1 {
                        println("  [memoize] OK (" + to_string(pc) + " param(s))")
                        m5_memoize_ok = m5_memoize_ok + 1
                    } else {
                        println("  [memoize] INELIGIBLE: zero-arg fn")
                        m5_memoize_bad = m5_memoize_bad + 1
                    }
                }
                // M963: @lazy — defer-eval safety (zero-arg + @pure required)
                // Thunk: evaluated once on first access, cached thereafter.
                // Safety: only deterministic (pure) zero-arg fns can be thunk-wrapped.
                if attr == "lazy" {
                    let lp = len(node.params)
                    let lazy_pure = attr_has(attrs, "pure")
                    if lp == 0 && lazy_pure {
                        println("  [lazy] OK (zero-arg + @pure, thunk-safe)")
                        m963_lazy_ok = m963_lazy_ok + 1
                    } else {
                        let mut why = ""
                        if lp != 0 { why = "non-zero-arg" }
                        if !lazy_pure {
                            if why == "" { why = "missing @pure" }
                            else { why = why + " + missing @pure" }
                        }
                        println("  [lazy] VIOLATION: " + why)
                        m963_lazy_violations = m963_lazy_violations + 1
                    }
                }
                // M966: @cache — bounded memoize check (inner loop)
                if attr == "cache" {
                    let cpc = len(node.params)
                    if cpc >= 1 {
                        println("  [cache] OK (" + to_string(cpc) + " param(s), LRU)")
                    } else {
                        println("  [cache] VIOLATION: zero-arg fn (no cache key)")
                    }
                }
                // M967: @profile — instrumentation check (inner loop)
                if attr == "profile" {
                    println("  [profile] OK (instrumented)")
                }
                // M968: @autograd — differentiation check (inner loop)
                if attr == "autograd" {
                    let agpc = len(node.params)
                    if agpc >= 1 {
                        println("  [autograd] OK (" + to_string(agpc) + " param(s), forward-mode)")
                    } else {
                        println("  [autograd] VIOLATION: zero-arg fn")
                    }
                }
                // M969: @quantize — quantization check (inner loop)
                if attr == "quantize" {
                    let qpc = len(node.params)
                    if qpc >= 1 {
                        println("  [quantize] OK (" + to_string(qpc) + " param(s), quant-sim)")
                    } else {
                        println("  [quantize] VIOLATION: zero-arg fn")
                    }
                }
                // M6: group distribution
                if cat == "G1" { m6_g1 = m6_g1 + 1 }
                if cat == "G2" { m6_g2 = m6_g2 + 1 }
                if cat == "G3" { m6_g3 = m6_g3 + 1 }
                if cat == "G4" { m6_g4 = m6_g4 + 1 }
                // M7: meta attrs
                if attr == "test" {
                    m7_test = m7_test + 1
                    if len(node.params) > 0 {
                        m86_test_bad = m86_test_bad + 1
                        println("[ai-native] fn " + node.name + " WARN: @test must be zero-arg")
                    }
                }
                if attr == "bench" {
                    m7_bench = m7_bench + 1
                    // M85: @bench requires zero-arg fn
                    if len(node.params) > 0 {
                        m85_bench_bad = m85_bench_bad + 1
                        println("[ai-native] fn " + node.name + " WARN: @bench must be zero-arg")
                    }
                }
                if attr == "deprecated" { m7_deprecated = m7_deprecated + 1 }
                // M62: core attr frequency
                if attr == "pure" { m62_pure_uses = m62_pure_uses + 1 }
                if attr == "inline" { m62_inline_uses = m62_inline_uses + 1 }
                if attr == "optimize" { m62_optimize_uses = m62_optimize_uses + 1 }
                if attr == "memoize" { m62_memoize_uses = m62_memoize_uses + 1 }
                // M63: diversity — add to set if new
                if !name_in_registry(attr, m63_attr_set) {
                    m63_attr_set = m63_attr_set.push(attr)
                }
                // M71/M72/M73: bounded value analysis
                if len(attr.chars()) > 8 && attr.substring(0, 8) == "bounded:" {
                    let bv = extract_bounded_value(attr)
                    if bv >= 0 {
                        m72_bounded_fns = m72_bounded_fns + 1
                        if bv > m71_bounded_max { m71_bounded_max = bv }
                        if bv > 1000 {
                            m71_bounded_huge = m71_bounded_huge + 1
                            println("[ai-native] fn " + node.name + " WARN: @bounded(" + to_string(bv) + ") exceeds 1000")
                        }
                        if bv <= 4 && bv > 0 {
                            m73_unrollable = m73_unrollable + 1
                            println("[ai-native] fn " + node.name + " TAG: unrollable (N=" + to_string(bv) + ")")
                        }
                    }
                }
                // M8: hardware attrs require a loop in body
                if attr == "parallel" || attr == "simd" || attr == "gpu" {
                    if body_has_loop(node.body) {
                        println("  [" + attr + "] OK (loop found)")
                        m8_hw_ok = m8_hw_ok + 1
                    } else {
                        println("  [" + attr + "] WARN: no loop in body")
                        m8_hw_no_loop = m8_hw_no_loop + 1
                    }
                }
                j = j + 1
            }
            seen = seen + 1
        }
        out = out.push(node)
        i = i + 1
    }
    // M53: second pass — count cross-annotated calls (registry now complete)
    let on = len(out)
    let mut oi = 0
    while oi < on {
        let nd = out[oi]
        if nd.kind == "FnDecl" && nd.value != "" {
            m53_cross_calls = m53_cross_calls + count_cross_calls_body(nd.body, m29_registry)
        }
        oi = oi + 1
    }
    // M253 pre-pass: collect inlinable fn signatures (stub + identity)
    let mut pi3 = 0
    while pi3 < on {
        let nd3 = out[pi3]
        if nd3.kind == "FnDecl" {
            // Const-return stub: body == [Return(literal)]
            if body_is_const_return(nd3.body) {
                m253_stub_names = m253_stub_names.push(nd3.name)
                m253_stub_lits = m253_stub_lits.push(nd3.body[0].left)
            } else {
                // Identity: 1 stmt, return param0
                if is_identity_fn(nd3.body, nd3.params) {
                    m253_id_names = m253_id_names.push(nd3.name)
                    m253_id_param0 = m253_id_param0.push(nd3.params[0].name)
                }
            }
        }
        pi3 = pi3 + 1
    }
    // M253 inline pass: rewrite all FnDecl bodies
    let mut out2 = []
    let mut pi4 = 0
    while pi4 < on {
        let nd4 = out[pi4]
        if nd4.kind == "FnDecl" {
            let before_in = m253_inlined_calls
            let new_body = inline_body(nd4.body)
            if m253_inlined_calls > before_in {
                out2 = out2.push(rewrite_fn_with_body(nd4, new_body))
                println("[ai-native] fn " + nd4.name + " REWRITE: inlined " + to_string(m253_inlined_calls - before_in) + " call(s)")
            } else {
                out2 = out2.push(nd4)
            }
        } else {
            out2 = out2.push(nd4)
        }
        pi4 = pi4 + 1
    }
    out = out2
    // ROI #42: loop rotation pass
    out = apply_loop_rotation(out)
    // ROI #43: @thread_local TLS promotion pass
    out = apply_thread_local_pass(out)
    // ROI #44: swiss table detection pass
    out = apply_swiss_table_pass(out)
    // ROI #45: @nonnull null check elimination pass
    out = apply_nonnull_pass(out)
    let mut cov_pct = 0
    if m6_total_fns > 0 {
        cov_pct = (m6_annotated_fns * 100) / m6_total_fns
    }
    println("[ai-native] pass complete — " + to_string(seen) + " annotated fn(s), pure " + to_string(m1_pure_ok) + "/" + to_string(m1_pure_violations) + ", inline " + to_string(m3_inline_ok) + "/" + to_string(m3_inline_too_big) + ", memoize " + to_string(m5_memoize_ok) + "/" + to_string(m5_memoize_bad) + ", conflicts " + to_string(m4_attr_conflicts))
    println("[ai-native] coverage " + to_string(m6_annotated_fns) + "/" + to_string(m6_total_fns) + " (" + to_string(cov_pct) + "%), G1=" + to_string(m6_g1) + " G2=" + to_string(m6_g2) + " G3=" + to_string(m6_g3) + " G4=" + to_string(m6_g4))
    println("[ai-native] meta test=" + to_string(m7_test) + " bench=" + to_string(m7_bench) + " deprecated=" + to_string(m7_deprecated))
    println("[ai-native] hw " + to_string(m8_hw_ok) + " ok / " + to_string(m8_hw_no_loop) + " no-loop")
    println("[ai-native] recursive " + to_string(m9_recursive) + ", calls " + to_string(m11_call_count) + ", memoize-score-sum " + to_string(m10_memoize_score_sum))
    println("[ai-native] body-size G1=" + to_string(m12_g1_size) + " G2=" + to_string(m12_g2_size) + " G3=" + to_string(m12_g3_size) + " G4=" + to_string(m12_g4_size) + ", max-while-depth " + to_string(m13_max_while_depth) + ", max-complexity " + to_string(m36_max_complexity))
    println("[ai-native] stubs " + to_string(m37_stubs) + ", attr-hist 1=" + to_string(m38_one) + " 2=" + to_string(m38_two) + " 3=" + to_string(m38_three) + " 4+=" + to_string(m38_four_plus) + ", params sum=" + to_string(m39_param_sum) + " zero-arg=" + to_string(m39_zero_arg) + " max-arity=" + to_string(m39_max_arity))
    println("[ai-native] bubble-candidates " + to_string(m14_bubble_candidates) + ", tail-call-candidates " + to_string(m15_tail_call_candidates) + ", strassen-candidates " + to_string(m16_strassen_candidates) + ", dp-missed " + to_string(m17_dp_missed))
    println("[ai-native] bubble-detected " + to_string(m957_bubble_detected) + ", linear-search-detected " + to_string(m958_linear_search_detected) + ", tail-rec-detected " + to_string(m959_tail_recursive_detected) + ", bubble-rewrites " + to_string(m961_bubble_rewrites))
    // M81: digest line — compact one-shot summary
    let total_rewrites = m22_rewrites + m23_auto_memoize + m24_dce_fns + m25_tail_rewrites + m26_attr_dedups + m27_attr_sorts + m30_algebraic + m32_folds + m33_cmp_folds + m34_unary_folds + m35_bool_folds + m41_dead_loops + m480_symbolic_rewrites + m960_fuse_rewrites + m961_bubble_rewrites + m965_mapfilter_fused
    println("[ai-native] DIGEST fns=" + to_string(m6_annotated_fns) + "/" + to_string(m6_total_fns) + " attrs=" + to_string(m64_total_attrs) + " diversity=" + to_string(len(m63_attr_set)) + " rewrites=" + to_string(total_rewrites) + " leaves=" + to_string(m54_leaf_count) + " identity=" + to_string(m74_identity_fns) + " wrapper=" + to_string(m75_wrapper_fns) + " stubs=" + to_string(m37_stubs) + " nodes=" + to_string(m131_total_nodes) + " max-cplx=" + to_string(m36_max_complexity))
    let m18_total_suggestions = m14_bubble_candidates + m15_tail_call_candidates + m16_strassen_candidates + m17_dp_missed + m3_inline_too_big + m5_memoize_bad + m8_hw_no_loop + m4_attr_conflicts + m1_pure_violations + m19_unreachable
    println("[ai-native] unreachable " + to_string(m19_unreachable) + ", empty-body " + to_string(m20_empty_body) + ", const-return " + to_string(m21_const_return) + ", rewrites " + to_string(m22_rewrites) + ", auto-memoize " + to_string(m23_auto_memoize) + ", dce " + to_string(m24_dce_stmts) + " stmt(s) in " + to_string(m24_dce_fns) + " fn(s), tail-rewrites " + to_string(m25_tail_rewrites))
    println("[ai-native] TOTAL actionable items: " + to_string(m18_total_suggestions))
    if m480_symbolic_rewrites > 0 {
        println("[ai-native] @symbolic strength-reduction: " + to_string(m480_symbolic_rewrites) + " rewrite(s)")
    }
    if m482_fuse_candidates > 0 {
        println("[ai-native] @fuse candidates: " + to_string(m482_fuse_candidates) + " fn(s), max chain depth " + to_string(m481_fuse_chain_max))
    }
    if m960_fuse_rewrites > 0 {
        println("[ai-native] @fuse intermediate elimination: " + to_string(m960_fuse_rewrites) + " var(s) inlined")
    }
    if m965_mapfilter_fused > 0 {
        println("[ai-native] @fuse map/filter → loop: " + to_string(m965_mapfilter_fused) + " chain(s) fused")
    }
    if m962_specialize_ok + m962_specialize_violations > 0 {
        println("[ai-native] @specialize: " + to_string(m962_specialize_ok) + " ok, " + to_string(m962_specialize_candidates) + " candidate(s), " + to_string(m962_specialize_violations) + " violation(s)")
    }
    if m963_lazy_ok + m963_lazy_violations > 0 {
        println("[ai-native] @lazy: " + to_string(m963_lazy_ok) + " ok, " + to_string(m963_lazy_violations) + " violation(s)")
    }
    if m964_reduce_ok + m964_reduce_violations > 0 {
        println("[ai-native] @reduce: " + to_string(m964_reduce_ok) + " ok, " + to_string(m964_reduce_candidates) + " accumulator site(s), " + to_string(m964_reduce_violations) + " violation(s)")
    }
    if m966_cache_ok + m966_cache_violations > 0 {
        println("[ai-native] @cache: " + to_string(m966_cache_ok) + " ok, " + to_string(m966_cache_violations) + " violation(s)")
    }
    if m967_profile_ok > 0 {
        println("[ai-native] @profile: " + to_string(m967_profile_ok) + " instrumented")
    }
    if m968_autograd_ok + m968_autograd_violations > 0 {
        println("[ai-native] @autograd: " + to_string(m968_autograd_ok) + " ok, " + to_string(m968_autograd_violations) + " violation(s)")
    }
    if m969_quantize_ok + m969_quantize_violations > 0 {
        println("[ai-native] @quantize: " + to_string(m969_quantize_ok) + " ok, " + to_string(m969_quantize_violations) + " violation(s)")
    }
    if m970_algebraic_ok > 0 {
        println("[ai-native] @algebraic: " + to_string(m970_algebraic_ok) + " fn(s), " + to_string(m970_algebraic_candidates) + " reorderable site(s)")
    }
    if m971_approx_ok + m971_approx_violations > 0 {
        println("[ai-native] @approximate: " + to_string(m971_approx_ok) + " ok, " + to_string(m971_approx_violations) + " violation(s), " + to_string(m971_approx_candidates) + " candidate(s)")
    }
    if m972_compact_ok + m972_compact_violations > 0 {
        println("[ai-native] @compact: " + to_string(m972_compact_ok) + " fn(s), " + to_string(m972_compact_candidates) + " AoS site(s)")
    }
    if m973_sliding_ok > 0 {
        println("[ai-native] @optimize sliding-window: " + to_string(m973_sliding_ok) + " fn(s), " + to_string(m973_sliding_candidates) + " DP lookback(s)")
    }
    if m974_loop_rotations > 0 {
        println("[ai-native] loop-rotation: " + to_string(m974_loop_rotations) + " while→do-while transform(s)")
    }
    if m975_thread_local_ok > 0 {
        println("[ai-native] @thread_local: " + to_string(m975_thread_local_ok) + " fn(s), " + to_string(m975_thread_local_vars) + " var(s) promoted")
    }
    if m976_swiss_table_rewrites > 0 {
        println("[ai-native] swiss-table: " + to_string(m976_swiss_table_rewrites) + " hash probe site(s) detected")
    }
    if m977_nonnull_ok > 0 {
        println("[ai-native] @nonnull: " + to_string(m977_nonnull_ok) + " fn(s), " + to_string(m977_nonnull_elim) + " null check(s) eliminated")
    }
    return out
}

// M28: fixpoint runner — call ai_native_pass until no rewrites occur
fn ai_native_fixpoint(ast) {
    let mut cur = ast
    let mut iter = 0
    let max_iters = 5
    m87_fixpoint_iters = 0
    m88_fixpoint_converged = false
    m89_fixpoint_total_rewrites = 0
    while iter < max_iters {
        let next = ai_native_pass(cur)
        m87_fixpoint_iters = m87_fixpoint_iters + 1
        let total_rewrites = m22_rewrites + m23_auto_memoize + m24_dce_fns + m25_tail_rewrites + m26_attr_dedups + m27_attr_sorts + m82_auto_inline + m83_wrapper_inline + m84_stub_pure + m116_assert_elim + m152_auto_pure_leaf + m153_trivial_inline + m250_const_prop + m251_dead_stores + m480_symbolic_rewrites
        m89_fixpoint_total_rewrites = m89_fixpoint_total_rewrites + total_rewrites
        if total_rewrites == 0 {
            m88_fixpoint_converged = true
            println("[ai-native] FIXPOINT reached after " + to_string(iter + 1) + " iter(s)")
            return next
        }
        cur = next
        iter = iter + 1
    }
    println("[ai-native] FIXPOINT max_iters hit (" + to_string(max_iters) + ")")
    return cur
}
