                return AstNode {
                    kind: "UnaryOp", name: "", value: "", op: "-",
                    left: inner_mul2, right: "", cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            }
        }
        // M266: (x/c) * c → x (assumes exact division)
        if type_of(l) != "string" && type_of(r) != "string" {
            if l.kind == "BinOp" && l.op == "/" && r.kind == "IntLit" {
                if type_of(l.right) != "string" && l.right.kind == "IntLit" {
                    if l.right.value == r.value && r.value != "0" {
                        m30_algebraic = m30_algebraic + 1
                        return l.left
                    }
                }
            }
        }
        // M120: IntLit * x → x * IntLit (commutative)
        if type_of(l) != "string" && type_of(r) != "string" {
            if l.kind == "IntLit" && r.kind != "IntLit" {
                m30_algebraic = m30_algebraic + 1
                return AstNode {
                    kind: "BinOp", name: "", value: "", op: "*",
                    left: r, right: l, cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            }
        }
        // M481b: @symbolic x * 2 → x + x (addition cheaper than mul)
        if type_of(r) != "string" && r.kind == "IntLit" && r.value == "2" {
            m481b_symbolic_mul2 = m481b_symbolic_mul2 + 1
            return AstNode {
                kind: "BinOp", name: "", value: "", op: "+",
                left: l, right: l, cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            }
        }
        // M480: @symbolic strength reduction — x * pow2 → x << log2(pow2)
        if type_of(r) != "string" && r.kind == "IntLit" {
            let rv = parse_int_str(r.value)
            if rv >= 2 && is_power_of_two(rv) {
                m480_symbolic_rewrites = m480_symbolic_rewrites + 1
                return AstNode {
                    kind: "BinOp", name: "", value: "", op: "<<",
                    left: l, right: make_int_lit(log2_of(rv)), cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            }
        }
    }
    // M114: x / 1 → x, 0 / x → 0
    if op == "/" {
        if is_int_one(r) {
            m30_algebraic = m30_algebraic + 1
            return l
        }
        if is_int_zero(l) {
            m30_algebraic = m30_algebraic + 1
            return AstNode {
                kind: "IntLit", name: "", value: "0", op: "",
                left: "", right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            }
        }
        // M115: x / x → 1 (assumes x != 0)
        if same_ident(l, r) {
            m30_algebraic = m30_algebraic + 1
            return make_int_lit(1)
        }
        // M265: (x*c) / c → x
        if type_of(l) != "string" && type_of(r) != "string" {
            if l.kind == "BinOp" && l.op == "*" && r.kind == "IntLit" {
                if type_of(l.right) != "string" && l.right.kind == "IntLit" {
                    if l.right.value == r.value && r.value != "0" {
                        m30_algebraic = m30_algebraic + 1
                        return l.left
                    }
                }
            }
        }
        // M480: @symbolic — x / pow2 → x >> log2(pow2)
        if type_of(r) != "string" && r.kind == "IntLit" {
            let rv_d = parse_int_str(r.value)
            if rv_d >= 2 && is_power_of_two(rv_d) {
                m480_symbolic_rewrites = m480_symbolic_rewrites + 1
                return AstNode {
                    kind: "BinOp", name: "", value: "", op: ">>",
                    left: l, right: make_int_lit(log2_of(rv_d)), cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            }
        }
    }
    // M480: @symbolic — x % pow2 → x & (pow2 - 1)
    if op == "%" {
        if type_of(r) != "string" && r.kind == "IntLit" {
            let rv_m = parse_int_str(r.value)
            if rv_m >= 2 && is_power_of_two(rv_m) {
                m480_symbolic_rewrites = m480_symbolic_rewrites + 1
                return AstNode {
                    kind: "BinOp", name: "", value: "", op: "&",
                    left: l, right: make_int_lit(rv_m - 1), cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            }
        }
    }
    if op == "&&" {
        if is_bool_false(l) {
            m35_bool_folds = m35_bool_folds + 1
            return l
        }
        if is_bool_false(r) {
            m35_bool_folds = m35_bool_folds + 1
            return r
        }
        if is_bool_true(l) {
            m35_bool_folds = m35_bool_folds + 1
            return r
        }
        if is_bool_true(r) {
            m35_bool_folds = m35_bool_folds + 1
            return l
        }
        // M108: x && x → x
        if same_ident(l, r) {
            m35_bool_folds = m35_bool_folds + 1
            return l
        }
        // M113: x && !x → false / !x && x → false
        if is_not_of(l, r) || is_not_of(r, l) {
            m35_bool_folds = m35_bool_folds + 1
            return make_bool_lit_from_bool(false)
        }
    }
    if op == "||" {
        if is_bool_true(l) {
            m35_bool_folds = m35_bool_folds + 1
            return l
        }
        if is_bool_true(r) {
            m35_bool_folds = m35_bool_folds + 1
            return r
        }
        if is_bool_false(l) {
            m35_bool_folds = m35_bool_folds + 1
            return r
        }
        if is_bool_false(r) {
            m35_bool_folds = m35_bool_folds + 1
            return l
        }
        // M109: x || x → x
        if same_ident(l, r) {
            m35_bool_folds = m35_bool_folds + 1
            return l
        }
        // M113: x || !x → true / !x || x → true
        if is_not_of(l, r) || is_not_of(r, l) {
            m35_bool_folds = m35_bool_folds + 1
            return make_bool_lit_from_bool(true)
        }
    }
    // M481c: @symbolic x ** 2 → x * x (power lowering)
    if op == "**" {
        if type_of(r) != "string" && r.kind == "IntLit" {
            // x ** 0 → 1
            if r.value == "0" {
                m481c_symbolic_pow2 = m481c_symbolic_pow2 + 1
                return make_int_lit(1)
            }
            // x ** 1 → x
            if r.value == "1" {
                m481c_symbolic_pow2 = m481c_symbolic_pow2 + 1
                return l
            }
            // x ** 2 → x * x
            if r.value == "2" {
                m481c_symbolic_pow2 = m481c_symbolic_pow2 + 1
                return AstNode {
                    kind: "BinOp", name: "", value: "", op: "*",
                    left: l, right: l, cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            }
        }
    }
    // Rebuild with simplified children
    return AstNode {
        kind: "BinOp", name: "", value: "", op: op,
        left: l, right: r, cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn simplify_body(body) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ReturnStmt" || k == "ExprStmt" || k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" {
            let new_e = simplify_expr(stmt.left)
            out = out.push(AstNode {
                kind: k, name: stmt.name, value: stmt.value, op: "",
                left: new_e, right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            })
        } else {
            if k == "AssignStmt" {
                let new_r = simplify_expr(stmt.right)
                out = out.push(AstNode {
                    kind: "AssignStmt", name: "", value: "", op: "",
                    left: stmt.left, right: new_r, cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                })
            } else {
                if k == "WhileStmt" {
                    let new_cond = simplify_expr(stmt.cond)
                    // M41: while(false) { ... } → drop entirely
                    if is_bool_false(new_cond) {
                        m41_dead_loops = m41_dead_loops + 1
                        // don't push anything
                    } else {
                        let new_body = simplify_body(stmt.body)
                        out = out.push(AstNode {
                            kind: "WhileStmt", name: "", value: "", op: "",
                            left: "", right: "", cond: new_cond, then_body: "", else_body: "",
                            params: "", body: new_body, args: "", fields: "", items: "",
                            variants: "", arms: "", iter_expr: "", ret_type: "",
                            target: "", trait_name: "", methods: ""
                        })
                    }
                } else {
                    out = out.push(stmt)
                }
            }
        }
        i = i + 1
    }
    return out
}

// ── M977/M978: strength reduction extensions (ROI id=13) ─────────────────────
// M977: additional small-constant strength reductions already covered by M480.
//       (x*2→x<<1, x/2→x>>1, x%2→x&1 are handled by M480 pow2 path.)
//       This counter tracks any extra small-constant reductions found.

// M978: loop index multiply → accumulate.
// Pattern: while (i < n) { ... use(i * stride) ... i = i + 1 }
//       → let mut __acc = 0; while (i < n) { ... use(__acc) ... __acc = __acc + stride; i = i + 1 }
// Detects: LetStmt/ConstStmt inside a WhileStmt body where init = BinOp("*", Ident(loop_var), IntLit(stride))
// and loop_var is the loop counter incremented by 1 each iteration.

// Find the loop counter name: a variable assigned `name = name + 1` in the body
fn find_loop_counter(body) {
    if type_of(body) != "array" { return "" }
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "AssignStmt" {
            let rhs = stmt.left
            if type_of(rhs) != "string" && rhs.kind == "BinOp" && rhs.op == "+" {
                if type_of(rhs.left) != "string" && rhs.left.kind == "Ident" {
                    if type_of(rhs.right) != "string" && rhs.right.kind == "IntLit" && rhs.right.value == "1" {
                        if rhs.left.name == stmt.name {
                            return stmt.name
                        }
                    }
                }
            }
        }
        i = i + 1
    }
    return ""
}

// Rewrite a WhileStmt body: replace `let x = counter * stride` with `let x = __acc`
// and add `__acc = __acc + stride` before the counter increment.
fn strength_reduce_loop_body(body) {
    if type_of(body) != "array" { return body }
    let counter_name = find_loop_counter(body)
    if counter_name == "" { return body }
    // Scan for LetStmt/ConstStmt where init = counter * IntLit
    let n = len(body)
    let mut targets = []  // [{idx, stride, var_name}]
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "LetStmt" || stmt.kind == "ConstStmt" {
            let init = stmt.left
            if type_of(init) != "string" && init.kind == "BinOp" && init.op == "*" {
                if type_of(init.left) != "string" && init.left.kind == "Ident" && init.left.name == counter_name {
                    if type_of(init.right) != "string" && init.right.kind == "IntLit" {
                        let stride_val = parse_int_str(init.right.value)
                        if stride_val >= 2 {
                            // Record target for rewriting
                            let rec = AstNode {
                                kind: "__StrideTarget", name: stmt.name, value: init.right.value, op: "",
                                left: "", right: "", cond: "", then_body: "", else_body: "",
                                params: "", body: "", args: "", fields: "", items: "",
                                variants: "", arms: "", iter_expr: "", ret_type: "",
                                target: "", trait_name: "", methods: ""
                            }
                            targets = targets.push(rec)
                        }
                    }
                }
                // Also handle stride * counter (commutative)
                if type_of(init.right) != "string" && init.right.kind == "Ident" && init.right.name == counter_name {
                    if type_of(init.left) != "string" && init.left.kind == "IntLit" {
                        let stride_val2 = parse_int_str(init.left.value)
                        if stride_val2 >= 2 {
                            let rec2 = AstNode {
                                kind: "__StrideTarget", name: stmt.name, value: init.left.value, op: "",
                                left: "", right: "", cond: "", then_body: "", else_body: "",
                                params: "", body: "", args: "", fields: "", items: "",
                                variants: "", arms: "", iter_expr: "", ret_type: "",
                                target: "", trait_name: "", methods: ""
                            }
                            targets = targets.push(rec2)
                        }
                    }
                }
            }
        }
        i = i + 1
    }
    if len(targets) == 0 { return body }
    // Rewrite: replace `let x = counter * stride` with `let x = __sr_acc_N`
    // and insert `__sr_acc_N = __sr_acc_N + stride` before counter increment
    let mut new_body = []
    let mut ti = 0
    let tn = len(targets)
    let mut si = 0
    while si < n {
        let stmt = body[si]
        // Check if this stmt is a target
        let mut matched = false
        let mut match_idx = 0
        let mut mj = 0
        while mj < tn {
            if targets[mj].name == stmt.name && (stmt.kind == "LetStmt" || stmt.kind == "ConstStmt") {
                let init_chk = stmt.left
                if type_of(init_chk) != "string" && init_chk.kind == "BinOp" && init_chk.op == "*" {
                    matched = true
                    match_idx = mj
                }
            }
            mj = mj + 1
        }
        if matched {
            // Replace: let x = __sr_acc_N
            let acc_name = "__sr_acc" + to_string(match_idx)
            new_body = new_body.push(make_let_stmt(stmt.name, make_ident(acc_name)))
            m978_loop_stride = m978_loop_stride + 1
        } else {
            // Before counter increment, insert accumulator updates
            if stmt.kind == "AssignStmt" && stmt.name == counter_name {
                let mut ak = 0
                while ak < tn {
                    let acc_n = "__sr_acc" + to_string(ak)
                    let stride_lit = make_int_lit(parse_int_str(targets[ak].value))
                    new_body = new_body.push(make_assign_stmt(acc_n, make_binop("+", make_ident(acc_n), stride_lit)))
                    ak = ak + 1
                }
            }
            new_body = new_body.push(stmt)
        }
        si = si + 1
    }
    return new_body
}

// Body-level pass: scan for WhileStmt and apply loop stride reduction
fn strength_reduce_body(body) {
    if type_of(body) != "array" { return body }
    let n = len(body)
    let mut out = []
    let mut pre_inits = []  // accumulator init stmts to prepend before while
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "WhileStmt" {
            // Check if loop body has stride targets
            let counter_name = find_loop_counter(stmt.body)
            if counter_name != "" {
                let before_stride = m978_loop_stride
                let new_loop_body = strength_reduce_loop_body(stmt.body)
                if m978_loop_stride > before_stride {
                    // Need to prepend accumulator init stmts before the while
                    // Scan targets to create init stmts
                    let bn = len(stmt.body)
                    let mut targets2 = []
                    let mut bi = 0
                    while bi < bn {
                        let bs = stmt.body[bi]
                        if bs.kind == "LetStmt" || bs.kind == "ConstStmt" {
                            let binit = bs.left
                            if type_of(binit) != "string" && binit.kind == "BinOp" && binit.op == "*" {
                                let mut is_stride = false
                                let mut stride_v = ""
                                if type_of(binit.left) != "string" && binit.left.kind == "Ident" && binit.left.name == counter_name {
                                    if type_of(binit.right) != "string" && binit.right.kind == "IntLit" {
                                        is_stride = true
                                        stride_v = binit.right.value
                                    }
                                }
                                if type_of(binit.right) != "string" && binit.right.kind == "Ident" && binit.right.name == counter_name {
                                    if type_of(binit.left) != "string" && binit.left.kind == "IntLit" {
                                        is_stride = true
                                        stride_v = binit.left.value
                                    }
                                }
                                if is_stride {
                                    targets2 = targets2.push(stride_v)
                                }
                            }
                        }
                        bi = bi + 1
                    }
                    // Emit accumulator inits
                    let mut ti = 0
                    while ti < len(targets2) {
                        let acc_n = "__sr_acc" + to_string(ti)
                        out = out.push(make_let_mut_stmt(acc_n, make_int_lit(0)))
                        ti = ti + 1
                    }
                    out = out.push(make_while_stmt(stmt.cond, new_loop_body))
                } else {
                    out = out.push(stmt)
                }
            } else {
                out = out.push(stmt)
            }
        } else {
            out = out.push(stmt)
        }
        i = i + 1
    }
    return out
}

// Canonical attr rank (lower = earlier). Integer comparison only.
fn attr_rank(name) {
    if name == "pure" { return 10 }
    if name == "inline" { return 20 }
    if name == "hot" { return 30 }
    if name == "cold" { return 31 }
    if name == "bounded" { return 40 }
    if name == "memoize" { return 50 }
    if name == "optimize" { return 60 }
    if name == "fuse" { return 70 }
    if name == "compact" { return 71 }
    if name == "lazy" { return 72 }
    if name == "cache" { return 73 }
    if name == "algebraic" { return 74 }
    if name == "parallel" { return 80 }
    if name == "simd" { return 81 }
    if name == "gpu" { return 82 }
    if name == "specialize" { return 83 }
    if name == "predict" { return 84 }
    if name == "symbolic" { return 90 }
    if name == "reduce" { return 91 }
    if name == "approximate" { return 92 }
    if name == "evolve" { return 93 }
    if name == "learn" { return 94 }
    if name == "contract" { return 95 }
    if name == "profile" { return 96 }
    if name == "speculative_decode" { return 85 }
    if name == "test" { return 200 }
    if name == "bench" { return 201 }
    if name == "deprecated" { return 202 }
    if name == "link" { return 203 }
    return 999
}

fn sort_attrs(attrs) {
    // Selection sort by rank — stable for equal ranks
    let n = len(attrs)
    let mut result = []
    let mut i = 0
    while i < n {
        result = result.push(attrs[i])
        i = i + 1
    }
    let mut k = 0
    while k < n {
        let mut min_idx = k
        let mut j = k + 1
        while j < n {
            if attr_rank(result[j]) < attr_rank(result[min_idx]) {
                min_idx = j
            }
            j = j + 1
        }
        if min_idx != k {
            // swap via rebuild
            let mut tmp = []
            let mut t = 0
            while t < n {
                if t == k { tmp = tmp.push(result[min_idx]) }
                else { if t == min_idx { tmp = tmp.push(result[k]) }
                       else { tmp = tmp.push(result[t]) } }
                t = t + 1
            }
            result = tmp
        }
        k = k + 1
    }
    return result
}

fn arrays_equal_str(a, b) {
    if len(a) != len(b) { return false }
    let n = len(a)
    let mut i = 0
    while i < n {
        if a[i] != b[i] { return false }
        i = i + 1
    }
    return true
}

fn dedup_attrs(attrs) {
    let mut seen = []
    let n = len(attrs)
    let mut i = 0
    while i < n {
        let a = attrs[i]
        let mut already = false
        let sn = len(seen)
        let mut j = 0
        while j < sn {
            if seen[j] == a { already = true }
            j = j + 1
        }
        if !already { seen = seen.push(a) }
        i = i + 1
    }
    return seen
}

fn join_attrs(attrs) {
    let n = len(attrs)
    if n == 0 { return "" }
    let mut out = attrs[0]
    let mut i = 1
    while i < n {
        out = out + "," + attrs[i]
        i = i + 1
    }
    return out
}

fn make_bool_lit(v) {
    return AstNode {
        kind: "BoolLit", name: "", value: v, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_while_true_empty() {
    return AstNode {
        kind: "WhileStmt", name: "", value: "", op: "",
        left: "", right: "", cond: make_bool_lit("true"), then_body: "", else_body: "",
        params: "", body: [], args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

// Simple tail-call: body is exactly [ReturnStmt(Call(Ident self, ...))]
fn is_simple_tail_only(body, self_name) {
    if type_of(body) != "array" { return false }
    if len(body) != 1 { return false }
    let s = body[0]
    if s.kind != "ReturnStmt" { return false }
    let e = s.left
    if type_of(e) == "string" { return false }
    if e.kind != "Call" { return false }
    let callee = e.left
    if type_of(callee) == "string" { return false }
    if callee.kind != "Ident" { return false }
    return callee.name == self_name
}

fn eliminate_dead(body) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let n = len(body)
    let mut i = 0
    let mut stopped = false
    while i < n {
        if !stopped {
            out = out.push(body[i])
            if body[i].kind == "ReturnStmt" { stopped = true }
            // M293: assert false also stops execution
            if body[i].kind == "AssertStmt" {
                let c = body[i].left
                if type_of(c) != "string" && c.kind == "BoolLit" && c.value == "false" {
                    stopped = true
                }
            }
        }
        i = i + 1
    }
    return out
}

fn rewrite_fn_with_attrs(fn_node, new_attrs) {
    return AstNode {
        kind: "FnDecl", name: fn_node.name, value: new_attrs, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: fn_node.params, body: fn_node.body, args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: fn_node.ret_type,
        target: "", trait_name: "", methods: ""
    }
}

fn make_return_zero() {
    let lit = AstNode {
        kind: "IntLit", name: "", value: "0", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
    return AstNode {
        kind: "ReturnStmt", name: "", value: "", op: "",
        left: lit, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn rewrite_fn_with_body(fn_node, new_body) {
    return AstNode {
        kind: "FnDecl", name: fn_node.name, value: fn_node.value, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: fn_node.params, body: new_body, args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: fn_node.ret_type,
        target: "", trait_name: "", methods: ""
    }
}

// ── M961 AST node constructors for merge-sort rewrite ──────────

fn make_ident(name) {
    return AstNode {
        kind: "Ident", name: name, value: "", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_call_node(callee_name, call_args) {
    return AstNode {
        kind: "Call", name: "", value: "", op: "",
        left: make_ident(callee_name), right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: call_args, fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_binop(op, left, right) {
    return AstNode {
        kind: "BinOp", name: "", value: "", op: op,
        left: left, right: right, cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_let_stmt(name, expr) {
    return AstNode {
        kind: "LetStmt", name: name, value: "", op: "",
        left: expr, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_let_mut_stmt(name, expr) {
    return AstNode {
        kind: "LetMutStmt", name: name, value: "", op: "",
        left: expr, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_assign_stmt(name, expr) {
    return AstNode {
        kind: "AssignStmt", name: name, value: "", op: "",
        left: expr, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_return_expr(expr) {
    return AstNode {
        kind: "ReturnStmt", name: "", value: "", op: "",
        left: expr, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_if_expr(cond, then_body, else_body) {
    return AstNode {
        kind: "IfExpr", name: "", value: "", op: "",
        left: "", right: "", cond: cond, then_body: then_body, else_body: else_body,
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_expr_stmt(expr) {
    return AstNode {
        kind: "ExprStmt", name: "", value: "", op: "",
        left: expr, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_while_stmt(cond, body) {
    return AstNode {
        kind: "WhileStmt", name: "", value: "", op: "",
        left: "", right: "", cond: cond, then_body: "", else_body: "",
        params: "", body: body, args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_index(arr_expr, idx_expr) {
    return AstNode {
        kind: "Index", name: "", value: "", op: "",
        left: arr_expr, right: idx_expr, cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_param(name) {
    return AstNode {
        kind: "Param", name: name, value: "", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_array_lit(items) {
    return AstNode {
        kind: "Array", name: "", value: "", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: items,
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

// Build <receiver>.<method_name>(<call_args...>) — parser shape:
//   Call { left: Field { name: method_name, left: receiver }, args: call_args }
fn make_method_call(receiver, method_name, call_args) {
    let field = AstNode {
        kind: "Field", name: method_name, value: "", op: "",
        left: receiver, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
    return AstNode {
        kind: "Call", name: "", value: "", op: "",
        left: field, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: call_args, fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

// ── M961: Build merge-sort replacement body ────────────────────
// Generates the body for a merge-sort function that replaces bubble sort.
// The rewrite produces:
//   fn <name>(arr) {
//     let n = len(arr)
//     if n <= 1 { return arr }
//     let mid = n / 2
//     let mut left = []
//     let mut i = 0
//     while i < mid { left = left.push(arr[i]); i = i + 1 }
//     let mut right = []
//     let mut j = mid
//     while j < n { right = right.push(arr[j]); j = j + 1 }
//     left = <name>(left)
//     right = <name>(right)
//     // merge
//     let mut result = []
//     let mut li = 0
//     let mut ri = 0
//     while li < len(left) && ri < len(right) {
//       if left[li] <= right[ri] { result = result.push(left[li]); li = li + 1 }
//       else { result = result.push(right[ri]); ri = ri + 1 }
//     }
//     while li < len(left) { result = result.push(left[li]); li = li + 1 }
//     while ri < len(right) { result = result.push(right[ri]); ri = ri + 1 }
//     return result
//   }

fn make_merge_sort_body(fn_name, param_name) {
    let arr = make_ident(param_name)
    let mut body = []

    // let n = len(arr)
    body = body.push(make_let_stmt("n", make_call_node("len", [arr])))

    // if n <= 1 { return arr }
    let early_ret = make_if_expr(
        make_binop("<=", make_ident("n"), make_int_lit(1)),
        [make_return_expr(make_ident(param_name))],
        []
    )
    body = body.push(make_expr_stmt(early_ret))

    // let mid = n / 2
    body = body.push(make_let_stmt("mid", make_binop("/", make_ident("n"), make_int_lit(2))))

    // let mut left = []
    body = body.push(make_let_mut_stmt("left", make_array_lit([])))
    // let mut i = 0
    body = body.push(make_let_mut_stmt("i", make_int_lit(0)))
    // while i < mid { left = left.push(arr[i]); i = i + 1 }
    let left_loop_body = [
        make_assign_stmt("left", make_method_call(make_ident("left"), "push", [make_index(arr, make_ident("i"))])),
        make_assign_stmt("i", make_binop("+", make_ident("i"), make_int_lit(1)))
    ]
    body = body.push(make_while_stmt(make_binop("<", make_ident("i"), make_ident("mid")), left_loop_body))

    // let mut right = []
    body = body.push(make_let_mut_stmt("right", make_array_lit([])))
    // let mut j = mid
    body = body.push(make_let_mut_stmt("j", make_ident("mid")))
    // while j < n { right = right.push(arr[j]); j = j + 1 }
    let right_loop_body = [
        make_assign_stmt("right", make_method_call(make_ident("right"), "push", [make_index(arr, make_ident("j"))])),
        make_assign_stmt("j", make_binop("+", make_ident("j"), make_int_lit(1)))
    ]
    body = body.push(make_while_stmt(make_binop("<", make_ident("j"), make_ident("n")), right_loop_body))

    // left = <fn_name>(left)
    body = body.push(make_assign_stmt("left", make_call_node(fn_name, [make_ident("left")])))
    // right = <fn_name>(right)
    body = body.push(make_assign_stmt("right", make_call_node(fn_name, [make_ident("right")])))

    // let mut result = []
    body = body.push(make_let_mut_stmt("result", make_array_lit([])))
    // let mut li = 0
    body = body.push(make_let_mut_stmt("li", make_int_lit(0)))
    // let mut ri = 0
    body = body.push(make_let_mut_stmt("ri", make_int_lit(0)))

    // while li < len(left) && ri < len(right) { ... }
    let merge_cond = make_binop("&&",
        make_binop("<", make_ident("li"), make_call_node("len", [make_ident("left")])),
        make_binop("<", make_ident("ri"), make_call_node("len", [make_ident("right")]))
    )
    let merge_if = make_if_expr(
        make_binop("<=", make_index(make_ident("left"), make_ident("li")), make_index(make_ident("right"), make_ident("ri"))),
        [
            make_assign_stmt("result", make_method_call(make_ident("result"), "push", [make_index(make_ident("left"), make_ident("li"))])),
            make_assign_stmt("li", make_binop("+", make_ident("li"), make_int_lit(1)))
        ],
        [
            make_assign_stmt("result", make_method_call(make_ident("result"), "push", [make_index(make_ident("right"), make_ident("ri"))])),
            make_assign_stmt("ri", make_binop("+", make_ident("ri"), make_int_lit(1)))
        ]
    )
    body = body.push(make_while_stmt(merge_cond, [make_expr_stmt(merge_if)]))

    // while li < len(left) { result = result.push(left[li]); li = li + 1 }
    let left_tail = [
        make_assign_stmt("result", make_method_call(make_ident("result"), "push", [make_index(make_ident("left"), make_ident("li"))])),
        make_assign_stmt("li", make_binop("+", make_ident("li"), make_int_lit(1)))
    ]
    body = body.push(make_while_stmt(make_binop("<", make_ident("li"), make_call_node("len", [make_ident("left")])), left_tail))

    // while ri < len(right) { result = result.push(right[ri]); ri = ri + 1 }
    let right_tail = [
        make_assign_stmt("result", make_method_call(make_ident("result"), "push", [make_index(make_ident("right"), make_ident("ri"))])),
        make_assign_stmt("ri", make_binop("+", make_ident("ri"), make_int_lit(1)))
    ]
    body = body.push(make_while_stmt(make_binop("<", make_ident("ri"), make_call_node("len", [make_ident("right")])), right_tail))

    // return result
    body = body.push(make_return_expr(make_ident("result")))

    return body
}

// ── M974: Build Strassen matmul replacement body ─────────────────
// Generates the body for a Strassen O(n^2.807) matrix multiplication.
// Threshold: n < 64 falls back to naive triple-loop O(n^3).
// The rewrite produces:
//   fn <name>(a, b) {
//     let n = len(a)
//     if n < 64 { return naive_matmul(a, b) }
//     // Strassen: partition into quadrants, 7 muls, recombine
//     return strassen_combine(...)
//   }
//
// Since full Strassen requires sub-matrix slicing which is complex
// in AST form, we emit a call to strassen_matmul_impl(a, b, n)
// which is a helper fn injected alongside.
fn make_strassen_body(fn_name, param_a, param_b) {
    let mut body = []
    let a = make_ident(param_a)
    let b = make_ident(param_b)

    // let n = len(a)
    body = body.push(make_let_stmt("n", make_call_node("len", [a])))

    // if n < 64 { return naive_matmul_inner(a, b, n) }
    let naive_call = make_call_node("__strassen_naive", [make_ident(param_a), make_ident(param_b), make_ident("n")])
    let early_ret = make_if_expr(
        make_binop("<", make_ident("n"), make_int_lit(64)),
        [make_return_expr(naive_call)],
        []
    )
    body = body.push(make_expr_stmt(early_ret))

    // let mid = n / 2
    body = body.push(make_let_stmt("mid", make_binop("/", make_ident("n"), make_int_lit(2))))

    // Partition: a11, a12, a21, a22, b11, b12, b21, b22
    body = body.push(make_let_stmt("a11", make_call_node("__strassen_sub", [make_ident(param_a), make_int_lit(0), make_int_lit(0), make_ident("mid")])))
    body = body.push(make_let_stmt("a12", make_call_node("__strassen_sub", [make_ident(param_a), make_int_lit(0), make_ident("mid"), make_ident("mid")])))
    body = body.push(make_let_stmt("a21", make_call_node("__strassen_sub", [make_ident(param_a), make_ident("mid"), make_int_lit(0), make_ident("mid")])))
    body = body.push(make_let_stmt("a22", make_call_node("__strassen_sub", [make_ident(param_a), make_ident("mid"), make_ident("mid"), make_ident("mid")])))
    body = body.push(make_let_stmt("b11", make_call_node("__strassen_sub", [make_ident(param_b), make_int_lit(0), make_int_lit(0), make_ident("mid")])))
    body = body.push(make_let_stmt("b12", make_call_node("__strassen_sub", [make_ident(param_b), make_int_lit(0), make_ident("mid"), make_ident("mid")])))
    body = body.push(make_let_stmt("b21", make_call_node("__strassen_sub", [make_ident(param_b), make_ident("mid"), make_int_lit(0), make_ident("mid")])))
    body = body.push(make_let_stmt("b22", make_call_node("__strassen_sub", [make_ident(param_b), make_ident("mid"), make_ident("mid"), make_ident("mid")])))

    // 7 Strassen multiplications (recursive calls)
    // m1 = strassen((a11+a22), (b11+b22))
    body = body.push(make_let_stmt("s_m1", make_call_node(fn_name, [make_call_node("__strassen_add", [make_ident("a11"), make_ident("a22")]), make_call_node("__strassen_add", [make_ident("b11"), make_ident("b22")])])))
    // m2 = strassen((a21+a22), b11)
    body = body.push(make_let_stmt("s_m2", make_call_node(fn_name, [make_call_node("__strassen_add", [make_ident("a21"), make_ident("a22")]), make_ident("b11")])))
    // m3 = strassen(a11, (b12-b22))
    body = body.push(make_let_stmt("s_m3", make_call_node(fn_name, [make_ident("a11"), make_call_node("__strassen_sub_mat", [make_ident("b12"), make_ident("b22")])])))
    // m4 = strassen(a22, (b21-b11))
    body = body.push(make_let_stmt("s_m4", make_call_node(fn_name, [make_ident("a22"), make_call_node("__strassen_sub_mat", [make_ident("b21"), make_ident("b11")])])))
    // m5 = strassen((a11+a12), b22)
    body = body.push(make_let_stmt("s_m5", make_call_node(fn_name, [make_call_node("__strassen_add", [make_ident("a11"), make_ident("a12")]), make_ident("b22")])))
    // m6 = strassen((a21-a11), (b11+b12))
    body = body.push(make_let_stmt("s_m6", make_call_node(fn_name, [make_call_node("__strassen_sub_mat", [make_ident("a21"), make_ident("a11")]), make_call_node("__strassen_add", [make_ident("b11"), make_ident("b12")])])))
    // m7 = strassen((a12-a22), (b21+b22))
    body = body.push(make_let_stmt("s_m7", make_call_node(fn_name, [make_call_node("__strassen_sub_mat", [make_ident("a12"), make_ident("a22")]), make_call_node("__strassen_add", [make_ident("b21"), make_ident("b22")])])))

    // Combine: c11 = m1+m4-m5+m7, c12 = m3+m5, c21 = m2+m4, c22 = m1-m2+m3+m6
    body = body.push(make_let_stmt("c11", make_call_node("__strassen_add", [make_call_node("__strassen_sub_mat", [make_call_node("__strassen_add", [make_ident("s_m1"), make_ident("s_m4")]), make_ident("s_m5")]), make_ident("s_m7")])))
    body = body.push(make_let_stmt("c12", make_call_node("__strassen_add", [make_ident("s_m3"), make_ident("s_m5")])))
    body = body.push(make_let_stmt("c21", make_call_node("__strassen_add", [make_ident("s_m2"), make_ident("s_m4")])))
    body = body.push(make_let_stmt("c22", make_call_node("__strassen_add", [make_call_node("__strassen_sub_mat", [make_call_node("__strassen_add", [make_ident("s_m1"), make_ident("s_m3")]), make_ident("s_m2")]), make_ident("s_m6")])))

    // return __strassen_join(c11, c12, c21, c22, mid)
    body = body.push(make_return_expr(make_call_node("__strassen_join", [make_ident("c11"), make_ident("c12"), make_ident("c21"), make_ident("c22"), make_ident("mid")])))

    return body
}

// Get second param name from FnDecl node (for matmul: fn mm(a, b))
fn get_second_param_name(fn_node) {
    if type_of(fn_node.params) != "array" { return "b" }
    if len(fn_node.params) < 2 { return "b" }
    return fn_node.params[1].name
}

// ── M975: @specialize — generate type-specialized clone body ─────
// Rewrites fn body to include an inline type-dispatch prologue:
// If the first arg's type matches an observed common type, jump to
// a specialized version with known-type assumptions.
// The AST rewrite inserts a type-check branch at the top of the fn body.
fn make_specialize_prologue(fn_node) {
    let mut body = []
    let params = fn_node.params
    if type_of(params) != "array" { return fn_node.body }
    if len(params) == 0 { return fn_node.body }
    let p0 = params[0].name

    // Insert: if type_of(<p0>) == "int" { <specialized fast path> }
    // The specialized path is a copy of the original body with
    // type checks elided (conceptual — the branch itself is the gain).
    // For now, we add a type-guard comment marker so downstream
    // passes (codegen, JIT) can emit monomorphic code.
    let type_check = make_binop("==",
        make_call_node("type_of", [make_ident(p0)]),
        make_string_lit("int")
    )
    // __spec_hit = 1 signals to the runtime/codegen that this is
    // a specialized path entry point
    let spec_marker = make_let_stmt("__spec_hit", make_int_lit(1))
    let spec_branch = make_if_expr(type_check, [spec_marker], [])
    body = body.push(make_expr_stmt(spec_branch))

    // Append original body
    let mut i = 0
    while i < len(fn_node.body) {
        body = body.push(fn_node.body[i])
        i = i + 1
    }
    return body
}

fn make_string_lit(s) {
    return AstNode {
        kind: "StringLit", name: "", value: s, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

// Extract first param name from FnDecl node
fn get_first_param_name(fn_node) {
    if type_of(fn_node.params) != "array" { return "arr" }
    if len(fn_node.params) < 1 { return "arr" }
    return fn_node.params[0].name
}

// Extract second param name from FnDecl node (for binary search: arr, target)
fn get_second_param_name(fn_node) {
    if type_of(fn_node.params) != "array" { return "target" }
    if len(fn_node.params) < 2 { return "target" }
    return fn_node.params[1].name
}

// ── M975: linear-search → binary-search AST rewrite ──────────
// Builds a binary search body that replaces the detected linear search.
// Precondition: the array parameter must be @sorted or statically verified sorted.
// Generated code:
//   fn search(arr, target) {
//     let mut lo = 0
//     let mut hi = len(arr) - 1
//     while lo <= hi {
//       let mid = lo + (hi - lo) / 2
//       if arr[mid] == target { return mid }
//       if arr[mid] < target { lo = mid + 1 } else { hi = mid - 1 }
//     }
//     return -1
//   }
fn make_binary_search_body(arr_param, target_param) {
    let arr = make_ident(arr_param)
    let target = make_ident(target_param)
    let mut body = []

    // let mut lo = 0
    body = body.push(make_let_mut_stmt("lo", make_int_lit(0)))

    // let mut hi = len(arr) - 1
    body = body.push(make_let_mut_stmt("hi", make_binop("-", make_call_node("len", [arr]), make_int_lit(1))))

    // while lo <= hi
    let mid_expr = make_binop("+", make_ident("lo"), make_binop("/", make_binop("-", make_ident("hi"), make_ident("lo")), make_int_lit(2)))
    // let mid = lo + (hi - lo) / 2
    let mid_let = make_let_stmt("mid", mid_expr)

    // if arr[mid] == target { return mid }
    let eq_check = make_if_expr(
        make_binop("==", make_index(make_ident(arr_param), make_ident("mid")), target),
        [make_return_expr(make_ident("mid"))],
        []
    )

    // if arr[mid] < target { lo = mid + 1 } else { hi = mid - 1 }
    let lt_check = make_if_expr(
        make_binop("<", make_index(make_ident(arr_param), make_ident("mid")), target),
        [make_assign_stmt("lo", make_binop("+", make_ident("mid"), make_int_lit(1)))],
        [make_assign_stmt("hi", make_binop("-", make_ident("mid"), make_int_lit(1)))]
    )

    let while_body = [mid_let, make_expr_stmt(eq_check), make_expr_stmt(lt_check)]
    body = body.push(make_while_stmt(make_binop("<=", make_ident("lo"), make_ident("hi")), while_body))

    // return -1
    let neg_one = make_binop("-", make_int_lit(0), make_int_lit(1))
    body = body.push(make_return_expr(neg_one))

    return body
}

// Check if fn has @sorted annotation (indicates array param is pre-sorted)
fn fn_has_sorted_attr(attrs) {
    return attr_has(attrs, "sorted")
}

// Heuristic: check if fn body returns an index (returns i or similar Ident, not
// an element value). Linear search pattern returns index, not arr[i].
fn body_returns_index_not_value(body) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "WhileStmt" {
            if body_returns_ident_in_block(stmt.body) { return true }
        }
        i = i + 1
    }
    return false
}

fn body_returns_ident_in_block(body) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "ReturnStmt" {
            if type_of(stmt.left) != "string" && stmt.left.kind == "Ident" { return true }
        }
        if stmt.kind == "IfStmt" {
            if body_returns_ident_in_block(stmt.body) { return true }
        }
        i = i + 1
    }
    return false
}

// ── M976: @algebraic closed-form series detection and rewrite ─────
// Detects loop-based summation patterns and rewrites to O(1) closed form.
//
// Pattern 1 — arithmetic series sum(1..n):
//   let mut s = 0; let mut i = 1; while i <= n { s = s + i; i = i + 1 } return s
//   → return n * (n + 1) / 2
//
// Pattern 2 — geometric series sum(a * r^0 + a * r^1 + ... + a * r^(n-1)):
//   let mut s = 0; let mut term = a; let mut i = 0
//   while i < n { s = s + term; term = term * r; i = i + 1 } return s
//   → return a * (r^n - 1) / (r - 1)   [when r != 1, else return a * n]
//
// Detects the pattern at AST level by checking:
//   (a) accumulator init to 0
//   (b) counter init to 0 or 1
//   (c) while body has acc = acc + <counter_expr>
//   (d) counter increments by 1

// Check if a stmt is `let mut <name> = <int_value>` and return {name, value}
fn extract_let_mut_int(stmt) {
    if stmt.kind != "LetMutStmt" { return "" }
    if type_of(stmt.left) == "string" { return "" }
    if stmt.left.kind != "IntLit" { return "" }
    return stmt.name + "=" + stmt.left.value
}

// Check if body has pattern: acc = acc + counter_var (simple additive accumulation)
fn is_acc_plus_counter(body, acc_name, counter_name) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "AssignStmt" && stmt.name == acc_name {
            if type_of(stmt.left) != "string" && stmt.left.kind == "BinOp" && stmt.left.op == "+" {
                let l = stmt.left.left
                let r = stmt.left.right
                if type_of(l) != "string" && l.kind == "Ident" && l.name == acc_name {
                    if type_of(r) != "string" && r.kind == "Ident" && r.name == counter_name {
                        return true
                    }
                }
            }
        }
        i = i + 1
    }
    return false
}

// Check if body has pattern: counter = counter + 1
fn has_counter_increment(body, counter_name) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "AssignStmt" && stmt.name == counter_name {
            if type_of(stmt.left) != "string" && stmt.left.kind == "BinOp" && stmt.left.op == "+" {
                let l = stmt.left.left
                let r = stmt.left.right
                if type_of(l) != "string" && l.kind == "Ident" && l.name == counter_name {
                    if type_of(r) != "string" && r.kind == "IntLit" && r.value == "1" {
                        return true
                    }
                }
            }
        }
        i = i + 1
    }
    return false
}

// Check if body has pattern: acc = acc + (counter * counter)  [sum of squares]
fn is_acc_plus_counter_squared(body, acc_name, counter_name) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "AssignStmt" && stmt.name == acc_name {
            if type_of(stmt.left) != "string" && stmt.left.kind == "BinOp" && stmt.left.op == "+" {
                let l = stmt.left.left
                let r = stmt.left.right
                if type_of(l) != "string" && l.kind == "Ident" && l.name == acc_name {
                    // r should be counter * counter
                    if type_of(r) != "string" && r.kind == "BinOp" && r.op == "*" {
                        if type_of(r.left) != "string" && r.left.kind == "Ident" && r.left.name == counter_name {
                            if type_of(r.right) != "string" && r.right.kind == "Ident" && r.right.name == counter_name {
                                return true
                            }
                        }
                    }
                }
            }
        }
        i = i + 1
    }
    return false
}

// Check if body has geometric pattern: acc = acc + term; term = term * <ratio>
fn is_geometric_pattern(body, acc_name) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    let mut has_acc_plus_term = false
    let mut term_name = ""
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "AssignStmt" && stmt.name == acc_name {
            if type_of(stmt.left) != "string" && stmt.left.kind == "BinOp" && stmt.left.op == "+" {
                let l = stmt.left.left
                let r = stmt.left.right
                if type_of(l) != "string" && l.kind == "Ident" && l.name == acc_name {
                    if type_of(r) != "string" && r.kind == "Ident" {
                        has_acc_plus_term = true
                        term_name = r.name
                    }
                }
            }
        }
        i = i + 1
    }
    if !has_acc_plus_term { return false }
    // Check: term = term * <something>
    let mut j = 0
    while j < n {
        let stmt2 = body[j]
        if stmt2.kind == "AssignStmt" && stmt2.name == term_name {
            if type_of(stmt2.left) != "string" && stmt2.left.kind == "BinOp" && stmt2.left.op == "*" {
                let l2 = stmt2.left.left
                if type_of(l2) != "string" && l2.kind == "Ident" && l2.name == term_name {
                    return true
                }
            }
        }
        j = j + 1
    }
    return false
}

// Extract the geometric ratio expression from term = term * <ratio>
fn get_geometric_ratio(body, acc_name) {
    // First find term name
    let n = len(body)
    let mut term_name = ""
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "AssignStmt" && stmt.name == acc_name {
            if type_of(stmt.left) != "string" && stmt.left.kind == "BinOp" && stmt.left.op == "+" {
                let r = stmt.left.right
                if type_of(r) != "string" && r.kind == "Ident" {
                    term_name = r.name
                }
            }
        }
        i = i + 1
    }
    // Now find ratio
    let mut j = 0
    while j < n {
        let stmt2 = body[j]
        if stmt2.kind == "AssignStmt" && stmt2.name == term_name {
            if type_of(stmt2.left) != "string" && stmt2.left.kind == "BinOp" && stmt2.left.op == "*" {
                let l2 = stmt2.left.left
                if type_of(l2) != "string" && l2.kind == "Ident" && l2.name == term_name {
                    return stmt2.left.right
                }
            }
        }
        j = j + 1
    }
    return ""
}

// Get term name from geometric pattern
fn get_geometric_term_name(body, acc_name) {
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "AssignStmt" && stmt.name == acc_name {
            if type_of(stmt.left) != "string" && stmt.left.kind == "BinOp" && stmt.left.op == "+" {
                let r = stmt.left.right
                if type_of(r) != "string" && r.kind == "Ident" {
                    return r.name
                }
            }
        }
        i = i + 1
    }
    return ""
}

// Get the while-loop limit variable/expr from: while counter < <limit>
// or: while counter <= <limit>
fn get_while_limit(body) {
    if type_of(body) != "array" { return "" }
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "WhileStmt" {
            if type_of(stmt.cond) != "string" && stmt.cond.kind == "BinOp" {
                return stmt.cond.right
            }
        }
        i = i + 1
    }
    return ""
}

// Get the while-loop comparison operator (<= or <)
fn get_while_op(body) {
    if type_of(body) != "array" { return "" }
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "WhileStmt" {
            if type_of(stmt.cond) != "string" && stmt.cond.kind == "BinOp" {
                return stmt.cond.op
            }
        }
        i = i + 1
    }
    return ""
}

// Detect arithmetic series: sum(start..limit) where acc += counter
// Returns "arithmetic" if pattern matches, "" otherwise
fn detect_series_pattern(fn_body) {
    if type_of(fn_body) != "array" { return "" }
    let n = len(fn_body)
    // Need at least: let mut acc = 0; let mut i = ...; while ...; return acc
    if n < 4 { return "" }

    // Find accumulator (first let mut with init=0)
    let mut acc_name = ""
    let mut counter_name = ""
    let mut fi = 0
    while fi < n {
        let info = extract_let_mut_int(fn_body[fi])
        if info != "" {
            // Parse "name=value"
            let mut eq_pos = 0
            let chars = info.chars()
            let clen = len(chars)
            let mut ci = 0
            while ci < clen {
                if to_string(chars[ci]) == "=" { eq_pos = ci }
                ci = ci + 1
            }
            // Extract name and value using substring logic
            let mut nm = ""
            let mut vi = 0
            while vi < eq_pos {
                nm = nm + to_string(chars[vi])
                vi = vi + 1
            }
            let mut vl = ""
            let mut vj = eq_pos + 1
            while vj < clen {
                vl = vl + to_string(chars[vj])
                vj = vj + 1
            }
            if acc_name == "" && vl == "0" {
                acc_name = nm
            } else {
                if counter_name == "" {
                    counter_name = nm
                }
            }
        }
        fi = fi + 1
    }
    if acc_name == "" || counter_name == "" { return "" }

    // Find while statement and check its body
    let mut wi = 0
    while wi < n {
        if fn_body[wi].kind == "WhileStmt" {
            let wbody = fn_body[wi].body
            if has_counter_increment(wbody, counter_name) {
                if is_acc_plus_counter(wbody, acc_name, counter_name) {
                    return "arithmetic"
                }
                if is_acc_plus_counter_squared(wbody, acc_name, counter_name) {
                    return "arithmetic_sq"
                }
                if is_geometric_pattern(wbody, acc_name) {
                    return "geometric"
                }
            }
        }
        wi = wi + 1
    }
    return ""
}

// Extract accumulator and counter names from fn body
fn get_series_acc_name(fn_body) {
    let n = len(fn_body)
    let mut fi = 0
    while fi < n {
        let info = extract_let_mut_int(fn_body[fi])
        if info != "" {
            let chars = info.chars()
            let clen = len(chars)
            let mut eq_pos = 0
            let mut ci = 0
            while ci < clen {
                if to_string(chars[ci]) == "=" { eq_pos = ci }
                ci = ci + 1
            }
            let mut nm = ""
            let mut vi = 0
            while vi < eq_pos {
                nm = nm + to_string(chars[vi])
                vi = vi + 1
            }
            let mut vl = ""
            let mut vj = eq_pos + 1
            while vj < clen {
                vl = vl + to_string(chars[vj])
                vj = vj + 1
            }
            if vl == "0" { return nm }
        }
        fi = fi + 1
    }
    return ""
}

fn get_series_counter_name(fn_body) {
    let n = len(fn_body)
    let mut acc_found = false
    let mut fi = 0
    while fi < n {
        let info = extract_let_mut_int(fn_body[fi])
        if info != "" {
            let chars = info.chars()
            let clen = len(chars)
            let mut eq_pos = 0
            let mut ci = 0
            while ci < clen {
                if to_string(chars[ci]) == "=" { eq_pos = ci }
                ci = ci + 1
            }
            let mut nm = ""
            let mut vi = 0
            while vi < eq_pos {
                nm = nm + to_string(chars[vi])
                vi = vi + 1
            }
            let mut vl = ""
            let mut vj = eq_pos + 1
            while vj < clen {
                vl = vl + to_string(chars[vj])
                vj = vj + 1
            }
            if !acc_found && vl == "0" {
                acc_found = true
            } else {
                if acc_found { return nm }
            }
        }
        fi = fi + 1
    }
    return ""
}

// Build closed-form body for arithmetic series: n * (n + 1) / 2
// Handles while i <= n (sum 1..n) and while i < n (sum 0..n-1)
fn make_arithmetic_closed_form(fn_body) {
    let limit = get_while_limit(fn_body)
    if type_of(limit) == "string" && limit == "" { return fn_body }
    let op = get_while_op(fn_body)
    let mut body = []
    if op == "<=" {
        // sum(1..n) = n * (n + 1) / 2
        let n_plus_1 = make_binop("+", limit, make_int_lit(1))
        let n_times = make_binop("*", limit, n_plus_1)
        let result = make_binop("/", n_times, make_int_lit(2))
        body = body.push(make_return_expr(result))
    } else {
        // sum(0..n-1) = n * (n - 1) / 2  (when counter starts at 0)
        // But we need to check counter start
        let counter_name = get_series_counter_name(fn_body)
        let mut counter_start = "0"
        let bn = len(fn_body)
        let mut bi = 0
        while bi < bn {
            let info = extract_let_mut_int(fn_body[bi])
            if info != "" {
                let chars = info.chars()
                let clen = len(chars)
                let mut eq_pos = 0
                let mut ci = 0
                while ci < clen {
                    if to_string(chars[ci]) == "=" { eq_pos = ci }
                    ci = ci + 1
                }
                let mut nm = ""
                let mut vi = 0
                while vi < eq_pos {
                    nm = nm + to_string(chars[vi])
                    vi = vi + 1
                }
                let mut vl = ""
                let mut vj = eq_pos + 1
                while vj < clen {
                    vl = vl + to_string(chars[vj])
                    vj = vj + 1
                }
                if nm == counter_name { counter_start = vl }
            }
            bi = bi + 1
        }
        if counter_start == "1" {
            // sum(1..n-1) = (n-1) * n / 2
            let n_minus_1 = make_binop("-", limit, make_int_lit(1))
            let prod = make_binop("*", n_minus_1, limit)
            let result = make_binop("/", prod, make_int_lit(2))
            body = body.push(make_return_expr(result))
        } else {
            // sum(0..n-1) = n * (n - 1) / 2
            let n_minus_1 = make_binop("-", limit, make_int_lit(1))
            let prod = make_binop("*", limit, n_minus_1)
            let result = make_binop("/", prod, make_int_lit(2))
            body = body.push(make_return_expr(result))
        }
    }
    return body
}

// Build closed-form body for sum of squares: n * (n + 1) * (2n + 1) / 6
fn make_arithmetic_sq_closed_form(fn_body) {
    let limit = get_while_limit(fn_body)
    if type_of(limit) == "string" && limit == "" { return fn_body }
    let mut body = []
    // n * (n + 1) * (2 * n + 1) / 6
    let n_plus_1 = make_binop("+", limit, make_int_lit(1))
    let two_n_plus_1 = make_binop("+", make_binop("*", make_int_lit(2), limit), make_int_lit(1))
    let prod = make_binop("*", make_binop("*", limit, n_plus_1), two_n_plus_1)
    let result = make_binop("/", prod, make_int_lit(6))
    body = body.push(make_return_expr(result))
    return body
}

// Build closed-form body for geometric series: a * (r^n - 1) / (r - 1)
// Since we don't have pow() built-in at AST level, we emit a small loop for r^n
// but fold the rest: if r == 1, return a * n
fn make_geometric_closed_form(fn_body) {
    let limit = get_while_limit(fn_body)
    if type_of(limit) == "string" && limit == "" { return fn_body }
    let acc_name = get_series_acc_name(fn_body)
    // Find the while stmt to get its body for geometric details
    let bn = len(fn_body)
    let mut wi = 0
    let mut wbody = []
    while wi < bn {
        if fn_body[wi].kind == "WhileStmt" { wbody = fn_body[wi].body }
        wi = wi + 1
    }
    let ratio_expr = get_geometric_ratio(wbody, acc_name)
    let term_name = get_geometric_term_name(wbody, acc_name)
    if type_of(ratio_expr) == "string" { return fn_body }

    // Find initial value of term
    let mut term_init = make_int_lit(1)
    let mut ti = 0
    while ti < bn {
        if fn_body[ti].kind == "LetMutStmt" && fn_body[ti].name == term_name {
            term_init = fn_body[ti].left
        }
        ti = ti + 1
    }

    let mut body = []
    // Compute r^n via loop (can't use pow at AST level)
    // let mut rn = 1; let mut ri = 0; while ri < n { rn = rn * r; ri = ri + 1 }
    body = body.push(make_let_mut_stmt("_rn", make_int_lit(1)))
    body = body.push(make_let_mut_stmt("_ri", make_int_lit(0)))
    let rn_loop_body = [
        make_assign_stmt("_rn", make_binop("*", make_ident("_rn"), ratio_expr)),
        make_assign_stmt("_ri", make_binop("+", make_ident("_ri"), make_int_lit(1)))
    ]
    body = body.push(make_while_stmt(make_binop("<", make_ident("_ri"), limit), rn_loop_body))

    // if r == 1 { return a * n } else { return a * (rn - 1) / (r - 1) }
    let r_eq_1 = make_if_expr(
        make_binop("==", ratio_expr, make_int_lit(1)),
        [make_return_expr(make_binop("*", term_init, limit))],
        [make_return_expr(make_binop("/", make_binop("*", term_init, make_binop("-", make_ident("_rn"), make_int_lit(1))), make_binop("-", ratio_expr, make_int_lit(1))))]
    )
    body = body.push(make_expr_stmt(r_eq_1))
    return body
}

fn is_literal_kind(k) {
    if k == "IntLit" { return true }
    if k == "FloatLit" { return true }
    if k == "BoolLit" { return true }
    if k == "StringLit" { return true }
    if k == "CharLit" { return true }
    // M292: Array literal also propagatable
    if k == "Array" { return true }
    return false
}

fn body_is_const_return(body) {
    if type_of(body) != "array" { return false }
    if len(body) != 1 { return false }
    let s = body[0]
    if s.kind != "ReturnStmt" { return false }
    let e = s.left
    if type_of(e) == "string" { return false }
    return is_literal_kind(e.kind)
}

fn count_unreachable(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    let mut hit = false
    while i < n {
        let stmt = body[i]
        if hit { c = c + 1 }
        if stmt.kind == "ReturnStmt" { hit = true }
        // M293: assert false also stops execution
        if stmt.kind == "AssertStmt" {
            let cc = stmt.left
            if type_of(cc) != "string" && cc.kind == "BoolLit" && cc.value == "false" {
                hit = true
            }
        }
        if stmt.kind == "WhileStmt" {
            c = c + count_unreachable(stmt.body)
        }
        i = i + 1
    }
    return c
}

fn is_tail_call(body, self_name) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    if n == 0 { return false }
    let last = body[n - 1]
    if last.kind != "ReturnStmt" { return false }
    return expr_calls_self(last.left, self_name)
}

fn body_has_let_mut(body) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    let mut i = 0
    while i < n {
        let k = body[i].kind
        if k == "LetMutStmt" { return true }
        if k == "WhileStmt" {
            if body_has_let_mut(body[i].body) { return true }
        }
        i = i + 1
    }
    return false
}

// M958 helper: body contains a ReturnStmt inside a WhileStmt (possibly nested in If)
fn body_has_return_in_while(body) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "WhileStmt" {
            if body_has_return_any(stmt.body) { return true }
        }
        i = i + 1
    }
    return false
}

fn body_has_return_any(body) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "ReturnStmt" { return true }
        if stmt.kind == "WhileStmt" {
            if body_has_return_any(stmt.body) { return true }
        }
        if stmt.kind == "IfStmt" {
            if body_has_return_any(stmt.body) { return true }
        }
        i = i + 1
    }
    return false
}

fn while_depth(body) {
    if type_of(body) != "array" { return 0 }
    let mut maxd = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "WhileStmt" {
            let sub = while_depth(stmt.body)
            let here = 1 + sub
            if here > maxd { maxd = here }
        }
        i = i + 1
    }
    return maxd
}

fn count_returns(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "ReturnStmt" { c = c + 1 }
        if stmt.kind == "WhileStmt" { c = c + count_returns(stmt.body) }
        i = i + 1
    }
    return c
}

fn count_assigns(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "AssignStmt" { c = c + 1 }
        if stmt.kind == "WhileStmt" { c = c + count_assigns(stmt.body) }
        i = i + 1
    }
    return c
}

fn count_lets(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "LetStmt" { c = c + 1 }
        if stmt.kind == "LetMutStmt" { c = c + 1 }
        if stmt.kind == "WhileStmt" { c = c + count_lets(stmt.body) }
        i = i + 1
    }
    return c
}

fn count_exprstmts(body) {
