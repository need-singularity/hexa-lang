fn is_bool_true(e) {
    if type_of(e) == "string" { return false }
    if e.kind != "BoolLit" { return false }
    return e.value == "true"
}

fn is_bool_false(e) {
    if type_of(e) == "string" { return false }
    if e.kind != "BoolLit" { return false }
    return e.value == "false"
}

fn make_bool_lit_from_bool(b) {
    let v = "false"
    if b { v = "true" }
    return AstNode {
        kind: "BoolLit", name: "", value: v, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn digit_val(c) {
    if c == "0" { return 0 }
    if c == "1" { return 1 }
    if c == "2" { return 2 }
    if c == "3" { return 3 }
    if c == "4" { return 4 }
    if c == "5" { return 5 }
    if c == "6" { return 6 }
    if c == "7" { return 7 }
    if c == "8" { return 8 }
    if c == "9" { return 9 }
    return -1
}

fn parse_int_str(s) {
    let chars = s.chars()
    let n = len(chars)
    if n == 0 { return -1 }
    let mut i = 0
    let mut result = 0
    let mut neg = false
    if to_string(chars[0]) == "-" {
        neg = true
        i = 1
    }
    while i < n {
        let d = digit_val(to_string(chars[i]))
        if d < 0 { return -1 }
        result = result * 10 + d
        i = i + 1
    }
    if neg { return 0 - result }
    return result
}

fn make_int_lit(n) {
    return AstNode {
        kind: "IntLit", name: "", value: to_string(n), op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn same_ident(a, b) {
    if type_of(a) == "string" { return false }
    if type_of(b) == "string" { return false }
    if a.kind != "Ident" { return false }
    if b.kind != "Ident" { return false }
    return a.name == b.name
}

// M113: complementary pair detection
fn is_not_of(not_expr, ident_expr) {
    if type_of(not_expr) == "string" { return false }
    if type_of(ident_expr) == "string" { return false }
    if not_expr.kind != "UnaryOp" { return false }
    if not_expr.op != "!" { return false }
    return same_ident(not_expr.left, ident_expr)
}

fn is_int_zero(e) {
    if type_of(e) == "string" { return false }
    if e.kind != "IntLit" { return false }
    return e.value == "0"
}

fn is_int_one(e) {
    if type_of(e) == "string" { return false }
    if e.kind != "IntLit" { return false }
    return e.value == "1"
}

fn simplify_expr(expr) {
    if type_of(expr) == "string" { return expr }
    // M286: Array literal constant index → element
    if expr.kind == "Index" {
        let arr = simplify_expr(expr.left)
        let idx = simplify_expr(expr.right)
        if type_of(arr) != "string" && type_of(idx) != "string" {
            if arr.kind == "Array" && idx.kind == "IntLit" {
                let iv = parse_int_str(idx.value)
                if iv >= 0 && iv < len(arr.items) {
                    m30_algebraic = m30_algebraic + 1
                    return arr.items[iv]
                }
            }
        }
        return AstNode {
            kind: "Index", name: "", value: "", op: "",
            left: arr, right: idx, cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    // M34: unary folding
    if expr.kind == "UnaryOp" {
        let inner = simplify_expr(expr.left)
        if expr.op == "!" && type_of(inner) != "string" {
            if inner.kind == "BoolLit" {
                m34_unary_folds = m34_unary_folds + 1
                let flipped = "true"
                if inner.value == "true" { flipped = "false" }
                return AstNode {
                    kind: "BoolLit", name: "", value: flipped, op: "",
                    left: "", right: "", cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            }
            // M110: !!x → x
            if inner.kind == "UnaryOp" && inner.op == "!" {
                m34_unary_folds = m34_unary_folds + 1
                return inner.left
            }
            // M117: !(a == b) → a != b, !(a != b) → a == b
            if inner.kind == "BinOp" && inner.op == "==" {
                m34_unary_folds = m34_unary_folds + 1
                return AstNode {
                    kind: "BinOp", name: "", value: "", op: "!=",
                    left: inner.left, right: inner.right, cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            }
            if inner.kind == "BinOp" && inner.op == "!=" {
                m34_unary_folds = m34_unary_folds + 1
                return AstNode {
                    kind: "BinOp", name: "", value: "", op: "==",
                    left: inner.left, right: inner.right, cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            }
            // M118: comparison De Morgan (4종)
            if inner.kind == "BinOp" {
                let mut flip = ""
                if inner.op == "<" { flip = ">=" }
                if inner.op == ">" { flip = "<=" }
                if inner.op == "<=" { flip = ">" }
                if inner.op == ">=" { flip = "<" }
                if flip != "" {
                    m34_unary_folds = m34_unary_folds + 1
                    return AstNode {
                        kind: "BinOp", name: "", value: "", op: flip,
                        left: inner.left, right: inner.right, cond: "", then_body: "", else_body: "",
                        params: "", body: "", args: "", fields: "", items: "",
                        variants: "", arms: "", iter_expr: "", ret_type: "",
                        target: "", trait_name: "", methods: ""
                    }
                }
            }
        }
        if expr.op == "-" && type_of(inner) != "string" {
            // Double negation: --x → x
            if inner.kind == "UnaryOp" && inner.op == "-" {
                m34_unary_folds = m34_unary_folds + 1
                return inner.left
            }
            // M268: -0 → 0
            if inner.kind == "IntLit" && inner.value == "0" {
                m34_unary_folds = m34_unary_folds + 1
                return make_int_lit(0)
            }
            // M276: -(a - b) → b - a
            if inner.kind == "BinOp" && inner.op == "-" {
                m34_unary_folds = m34_unary_folds + 1
                return AstNode {
                    kind: "BinOp", name: "", value: "", op: "-",
                    left: inner.right, right: inner.left, cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            }
            // -IntLit → IntLit with negated value
            if inner.kind == "IntLit" {
                let v = parse_int_str(inner.value)
                if v >= 0 {
                    m34_unary_folds = m34_unary_folds + 1
                    return make_int_lit(0 - v)
                }
            }
        }
        return AstNode {
            kind: "UnaryOp", name: "", value: "", op: expr.op,
            left: inner, right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    if expr.kind != "BinOp" { return expr }
    // Recursively simplify children first
    let l = simplify_expr(expr.left)
    let r = simplify_expr(expr.right)
    let op = expr.op
    // M32: constant folding when both sides are IntLit
    if type_of(l) != "string" && type_of(r) != "string" {
        if l.kind == "IntLit" && r.kind == "IntLit" {
            let lv = parse_int_str(l.value)
            let rv = parse_int_str(r.value)
            if lv >= 0 && rv >= 0 {
                if op == "+" {
                    m32_folds = m32_folds + 1
                    return make_int_lit(lv + rv)
                }
                if op == "-" {
                    m32_folds = m32_folds + 1
                    return make_int_lit(lv - rv)
                }
                if op == "*" {
                    m32_folds = m32_folds + 1
                    return make_int_lit(lv * rv)
                }
                if op == "/" && rv != 0 {
                    m32_folds = m32_folds + 1
                    return make_int_lit(lv / rv)
                }
                // M33: comparison folding
                if op == "==" {
                    m33_cmp_folds = m33_cmp_folds + 1
                    return make_bool_lit_from_bool(lv == rv)
                }
                if op == "!=" {
                    m33_cmp_folds = m33_cmp_folds + 1
                    return make_bool_lit_from_bool(lv != rv)
                }
                if op == "<" {
                    m33_cmp_folds = m33_cmp_folds + 1
                    return make_bool_lit_from_bool(lv < rv)
                }
                if op == ">" {
                    m33_cmp_folds = m33_cmp_folds + 1
                    return make_bool_lit_from_bool(lv > rv)
                }
                if op == "<=" {
                    m33_cmp_folds = m33_cmp_folds + 1
                    return make_bool_lit_from_bool(lv <= rv)
                }
                if op == ">=" {
                    m33_cmp_folds = m33_cmp_folds + 1
                    return make_bool_lit_from_bool(lv >= rv)
                }
            }
        }
    }
    if op == "+" {
        if is_int_zero(l) {
            m30_algebraic = m30_algebraic + 1
            return r
        }
        if is_int_zero(r) {
            m30_algebraic = m30_algebraic + 1
            return l
        }
        // M254: associative fold (x + c1) + c2 → x + (c1+c2)
        if type_of(l) != "string" && type_of(r) != "string" {
            if l.kind == "BinOp" && l.op == "+" && r.kind == "IntLit" {
                if type_of(l.right) != "string" && l.right.kind == "IntLit" {
                    let c1 = parse_int_str(l.right.value)
                    let c2 = parse_int_str(r.value)
                    if c1 >= 0 && c2 >= 0 {
                        m32_folds = m32_folds + 1
                        return AstNode {
                            kind: "BinOp", name: "", value: "", op: "+",
                            left: l.left, right: make_int_lit(c1 + c2), cond: "", then_body: "", else_body: "",
                            params: "", body: "", args: "", fields: "", items: "",
                            variants: "", arms: "", iter_expr: "", ret_type: "",
                            target: "", trait_name: "", methods: ""
                        }
                    }
                }
            }
            // M270: (a - b) + b → a
            if l.kind == "BinOp" && l.op == "-" {
                if same_ident(l.right, r) {
                    m30_algebraic = m30_algebraic + 1
                    return l.left
                }
            }
            // M258: (x - c1) + c2 where c2 >= c1 → x + (c2-c1)
            if l.kind == "BinOp" && l.op == "-" && r.kind == "IntLit" {
                if type_of(l.right) != "string" && l.right.kind == "IntLit" {
                    let c1 = parse_int_str(l.right.value)
                    let c2 = parse_int_str(r.value)
                    if c2 >= c1 && c1 >= 0 {
                        m32_folds = m32_folds + 1
                        return AstNode {
                            kind: "BinOp", name: "", value: "", op: "+",
                            left: l.left, right: make_int_lit(c2 - c1), cond: "", then_body: "", else_body: "",
                            params: "", body: "", args: "", fields: "", items: "",
                            variants: "", arms: "", iter_expr: "", ret_type: "",
                            target: "", trait_name: "", methods: ""
                        }
                    }
                }
            }
            // M262: (x*c) + x → x*(c+1)
            if l.kind == "BinOp" && l.op == "*" && r.kind == "Ident" {
                if same_ident(l.left, r) && type_of(l.right) != "string" && l.right.kind == "IntLit" {
                    let cv = parse_int_str(l.right.value)
                    if cv >= 0 {
                        m30_algebraic = m30_algebraic + 1
                        return AstNode {
                            kind: "BinOp", name: "", value: "", op: "*",
                            left: r, right: make_int_lit(cv + 1), cond: "", then_body: "", else_body: "",
                            params: "", body: "", args: "", fields: "", items: "",
                            variants: "", arms: "", iter_expr: "", ret_type: "",
                            target: "", trait_name: "", methods: ""
                        }
                    }
                }
            }
            // M263: x + (x*c) → x*(c+1) (대칭)
            if l.kind == "Ident" && r.kind == "BinOp" && r.op == "*" {
                if same_ident(l, r.left) && type_of(r.right) != "string" && r.right.kind == "IntLit" {
                    let cv2 = parse_int_str(r.right.value)
                    if cv2 >= 0 {
                        m30_algebraic = m30_algebraic + 1
                        return AstNode {
                            kind: "BinOp", name: "", value: "", op: "*",
                            left: l, right: make_int_lit(cv2 + 1), cond: "", then_body: "", else_body: "",
                            params: "", body: "", args: "", fields: "", items: "",
                            variants: "", arms: "", iter_expr: "", ret_type: "",
                            target: "", trait_name: "", methods: ""
                        }
                    }
                }
            }
            // M260: distributive factor x*a + x*b → x*(a+b)
            if l.kind == "BinOp" && l.op == "*" && r.kind == "BinOp" && r.op == "*" {
                if same_ident(l.left, r.left) {
                    m30_algebraic = m30_algebraic + 1
                    // Pre-fold combined right if both IntLit
                    let mut combined_r = AstNode {
                        kind: "BinOp", name: "", value: "", op: "+",
                        left: l.right, right: r.right, cond: "", then_body: "", else_body: "",
                        params: "", body: "", args: "", fields: "", items: "",
                        variants: "", arms: "", iter_expr: "", ret_type: "",
                        target: "", trait_name: "", methods: ""
                    }
                    if type_of(l.right) != "string" && type_of(r.right) != "string" {
                        if l.right.kind == "IntLit" && r.right.kind == "IntLit" {
                            let av = parse_int_str(l.right.value)
                            let bv = parse_int_str(r.right.value)
                            if av >= 0 && bv >= 0 {
                                combined_r = make_int_lit(av + bv)
                            }
                        }
                    }
                    return AstNode {
                        kind: "BinOp", name: "", value: "", op: "*",
                        left: l.left, right: combined_r, cond: "", then_body: "", else_body: "",
                        params: "", body: "", args: "", fields: "", items: "",
                        variants: "", arms: "", iter_expr: "", ret_type: "",
                        target: "", trait_name: "", methods: ""
                    }
                }
            }
        }
        // M279: a + (-b) → a - b, (-a) + b → b - a
        if type_of(l) != "string" && type_of(r) != "string" {
            if r.kind == "UnaryOp" && r.op == "-" {
                m30_algebraic = m30_algebraic + 1
                return AstNode {
                    kind: "BinOp", name: "", value: "", op: "-",
                    left: l, right: r.left, cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            }
            if l.kind == "UnaryOp" && l.op == "-" {
                m30_algebraic = m30_algebraic + 1
                return AstNode {
                    kind: "BinOp", name: "", value: "", op: "-",
                    left: r, right: l.left, cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            }
        }
        // M112: x + x → x * 2
        if same_ident(l, r) {
            m30_algebraic = m30_algebraic + 1
            return AstNode {
                kind: "BinOp", name: "", value: "", op: "*",
                left: l, right: make_int_lit(2), cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            }
        }
        // M119: IntLit + x → x + IntLit (commutative canonicalization)
        if type_of(l) != "string" && type_of(r) != "string" {
            if l.kind == "IntLit" && r.kind != "IntLit" {
                m30_algebraic = m30_algebraic + 1
                return AstNode {
                    kind: "BinOp", name: "", value: "", op: "+",
                    left: r, right: l, cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            }
        }
    }
    if op == "-" {
        if is_int_zero(r) {
            m30_algebraic = m30_algebraic + 1
            return l
        }
        // M280: a - (-b) → a + b (correct - branch)
        if type_of(r) != "string" && r.kind == "UnaryOp" && r.op == "-" {
            m30_algebraic = m30_algebraic + 1
            return AstNode {
                kind: "BinOp", name: "", value: "", op: "+",
                left: l, right: r.left, cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            }
        }
        // M281: (-a) - b → -(a + b)
        if type_of(l) != "string" && l.kind == "UnaryOp" && l.op == "-" {
            m30_algebraic = m30_algebraic + 1
            let inner_add = AstNode {
                kind: "BinOp", name: "", value: "", op: "+",
                left: l.left, right: r, cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            }
            return AstNode {
                kind: "UnaryOp", name: "", value: "", op: "-",
                left: inner_add, right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            }
        }
        // M256: (x - c1) - c2 → x - (c1+c2)
        if type_of(l) != "string" && type_of(r) != "string" {
            if l.kind == "BinOp" && l.op == "-" && r.kind == "IntLit" {
                if type_of(l.right) != "string" && l.right.kind == "IntLit" {
                    let c1 = parse_int_str(l.right.value)
                    let c2 = parse_int_str(r.value)
                    if c1 >= 0 && c2 >= 0 {
                        m32_folds = m32_folds + 1
                        return AstNode {
                            kind: "BinOp", name: "", value: "", op: "-",
                            left: l.left, right: make_int_lit(c1 + c2), cond: "", then_body: "", else_body: "",
                            params: "", body: "", args: "", fields: "", items: "",
                            variants: "", arms: "", iter_expr: "", ret_type: "",
                            target: "", trait_name: "", methods: ""
                        }
                    }
                }
            }
            // M257: (x + c1) - c2 where c1 >= c2 → x + (c1-c2)
            if l.kind == "BinOp" && l.op == "+" && r.kind == "IntLit" {
                if type_of(l.right) != "string" && l.right.kind == "IntLit" {
                    let c1 = parse_int_str(l.right.value)
                    let c2 = parse_int_str(r.value)
                    if c1 >= c2 && c2 >= 0 {
                        m32_folds = m32_folds + 1
                        return AstNode {
                            kind: "BinOp", name: "", value: "", op: "+",
                            left: l.left, right: make_int_lit(c1 - c2), cond: "", then_body: "", else_body: "",
                            params: "", body: "", args: "", fields: "", items: "",
                            variants: "", arms: "", iter_expr: "", ret_type: "",
                            target: "", trait_name: "", methods: ""
                        }
                    }
                }
            }
            // M282: (a + b) - (a + c) → b - c, (a + b) - (c + b) → a - c
            if l.kind == "BinOp" && l.op == "+" && r.kind == "BinOp" && r.op == "+" {
                if same_ident(l.left, r.left) {
                    m30_algebraic = m30_algebraic + 1
                    return AstNode {
                        kind: "BinOp", name: "", value: "", op: "-",
                        left: l.right, right: r.right, cond: "", then_body: "", else_body: "",
                        params: "", body: "", args: "", fields: "", items: "",
                        variants: "", arms: "", iter_expr: "", ret_type: "",
                        target: "", trait_name: "", methods: ""
                    }
                }
                if same_ident(l.right, r.right) {
                    m30_algebraic = m30_algebraic + 1
                    return AstNode {
                        kind: "BinOp", name: "", value: "", op: "-",
                        left: l.left, right: r.left, cond: "", then_body: "", else_body: "",
                        params: "", body: "", args: "", fields: "", items: "",
                        variants: "", arms: "", iter_expr: "", ret_type: "",
                        target: "", trait_name: "", methods: ""
                    }
                }
            }
            // M269: (a + b) - a → b, (a + b) - b → a
            if l.kind == "BinOp" && l.op == "+" {
                if same_ident(l.left, r) {
                    m30_algebraic = m30_algebraic + 1
                    return l.right
                }
                if same_ident(l.right, r) {
                    m30_algebraic = m30_algebraic + 1
                    return l.left
                }
            }
            // M264: (x*c) - x → x*(c-1) where c >= 1
            if l.kind == "BinOp" && l.op == "*" && r.kind == "Ident" {
                if same_ident(l.left, r) && type_of(l.right) != "string" && l.right.kind == "IntLit" {
                    let cv = parse_int_str(l.right.value)
                    if cv >= 1 {
                        m30_algebraic = m30_algebraic + 1
                        return AstNode {
                            kind: "BinOp", name: "", value: "", op: "*",
                            left: r, right: make_int_lit(cv - 1), cond: "", then_body: "", else_body: "",
                            params: "", body: "", args: "", fields: "", items: "",
                            variants: "", arms: "", iter_expr: "", ret_type: "",
                            target: "", trait_name: "", methods: ""
                        }
                    }
                }
            }
            // M261: distributive factor x*a - x*b → x*(a-b)
            if l.kind == "BinOp" && l.op == "*" && r.kind == "BinOp" && r.op == "*" {
                if same_ident(l.left, r.left) {
                    m30_algebraic = m30_algebraic + 1
                    let mut comb_r = AstNode {
                        kind: "BinOp", name: "", value: "", op: "-",
                        left: l.right, right: r.right, cond: "", then_body: "", else_body: "",
                        params: "", body: "", args: "", fields: "", items: "",
                        variants: "", arms: "", iter_expr: "", ret_type: "",
                        target: "", trait_name: "", methods: ""
                    }
                    if type_of(l.right) != "string" && type_of(r.right) != "string" {
                        if l.right.kind == "IntLit" && r.right.kind == "IntLit" {
                            let av = parse_int_str(l.right.value)
                            let bv = parse_int_str(r.right.value)
                            if av >= bv && bv >= 0 {
                                comb_r = make_int_lit(av - bv)
                            }
                        }
                    }
                    return AstNode {
                        kind: "BinOp", name: "", value: "", op: "*",
                        left: l.left, right: comb_r, cond: "", then_body: "", else_body: "",
                        params: "", body: "", args: "", fields: "", items: "",
                        variants: "", arms: "", iter_expr: "", ret_type: "",
                        target: "", trait_name: "", methods: ""
                    }
                }
            }
        }
        // M111: 0 - x → -x (UnaryOp)
        if is_int_zero(l) {
            m30_algebraic = m30_algebraic + 1
            return AstNode {
                kind: "UnaryOp", name: "", value: "", op: "-",
                left: r, right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            }
        }
        if same_ident(l, r) {
            m30_algebraic = m30_algebraic + 1
            return AstNode {
                kind: "IntLit", name: "", value: "0", op: "",
                left: "", right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            }
        }
    }
    // M106: x == x → true
    if op == "==" && same_ident(l, r) {
        m33_cmp_folds = m33_cmp_folds + 1
        return make_bool_lit_from_bool(true)
    }
    // M107: x != x → false
    if op == "!=" && same_ident(l, r) {
        m33_cmp_folds = m33_cmp_folds + 1
        return make_bool_lit_from_bool(false)
    }
    // M283: BoolLit == BoolLit / BoolLit != BoolLit
    if op == "==" && type_of(l) != "string" && type_of(r) != "string" {
        if l.kind == "BoolLit" && r.kind == "BoolLit" {
            m33_cmp_folds = m33_cmp_folds + 1
            return make_bool_lit_from_bool(l.value == r.value)
        }
        // M284: StringLit == StringLit
        if l.kind == "StringLit" && r.kind == "StringLit" {
            m33_cmp_folds = m33_cmp_folds + 1
            return make_bool_lit_from_bool(l.value == r.value)
        }
        // M285: CharLit == CharLit
        if l.kind == "CharLit" && r.kind == "CharLit" {
            m33_cmp_folds = m33_cmp_folds + 1
            return make_bool_lit_from_bool(l.value == r.value)
        }
        // M301: IntLit == x → x == IntLit (commutative)
        if l.kind == "IntLit" && r.kind != "IntLit" {
            m33_cmp_folds = m33_cmp_folds + 1
            return AstNode {
                kind: "BinOp", name: "", value: "", op: "==",
                left: r, right: l, cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            }
        }
    }
    if op == "!=" && type_of(l) != "string" && type_of(r) != "string" {
        if l.kind == "BoolLit" && r.kind == "BoolLit" {
            m33_cmp_folds = m33_cmp_folds + 1
            return make_bool_lit_from_bool(l.value != r.value)
        }
        if l.kind == "StringLit" && r.kind == "StringLit" {
            m33_cmp_folds = m33_cmp_folds + 1
            return make_bool_lit_from_bool(l.value != r.value)
        }
        if l.kind == "CharLit" && r.kind == "CharLit" {
            m33_cmp_folds = m33_cmp_folds + 1
            return make_bool_lit_from_bool(l.value != r.value)
        }
    }
    // M267: order self-compare
    if op == "<" && same_ident(l, r) {
        m33_cmp_folds = m33_cmp_folds + 1
        return make_bool_lit_from_bool(false)
    }
    if op == ">" && same_ident(l, r) {
        m33_cmp_folds = m33_cmp_folds + 1
        return make_bool_lit_from_bool(false)
    }
    if op == "<=" && same_ident(l, r) {
        m33_cmp_folds = m33_cmp_folds + 1
        return make_bool_lit_from_bool(true)
    }
    if op == ">=" && same_ident(l, r) {
        m33_cmp_folds = m33_cmp_folds + 1
        return make_bool_lit_from_bool(true)
    }
    // M121: boolean equality simplification
    if op == "==" {
        if is_bool_true(r) {
            m33_cmp_folds = m33_cmp_folds + 1
            return l
        }
        if is_bool_true(l) {
            m33_cmp_folds = m33_cmp_folds + 1
            return r
        }
        if is_bool_false(r) {
            m33_cmp_folds = m33_cmp_folds + 1
            return AstNode {
                kind: "UnaryOp", name: "", value: "", op: "!",
                left: l, right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            }
        }
        if is_bool_false(l) {
            m33_cmp_folds = m33_cmp_folds + 1
            return AstNode {
                kind: "UnaryOp", name: "", value: "", op: "!",
                left: r, right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            }
        }
    }
    if op == "!=" {
        if is_bool_false(r) {
            m33_cmp_folds = m33_cmp_folds + 1
            return l
        }
        if is_bool_false(l) {
            m33_cmp_folds = m33_cmp_folds + 1
            return r
        }
        if is_bool_true(r) {
            m33_cmp_folds = m33_cmp_folds + 1
            return AstNode {
                kind: "UnaryOp", name: "", value: "", op: "!",
                left: l, right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            }
        }
        if is_bool_true(l) {
            m33_cmp_folds = m33_cmp_folds + 1
            return AstNode {
                kind: "UnaryOp", name: "", value: "", op: "!",
                left: r, right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            }
        }
    }
    if op == "*" {
        if is_int_zero(l) || is_int_zero(r) {
            m30_algebraic = m30_algebraic + 1
            return AstNode {
                kind: "IntLit", name: "", value: "0", op: "",
                left: "", right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            }
        }
        if is_int_one(l) {
            m30_algebraic = m30_algebraic + 1
            return r
        }
        if is_int_one(r) {
            m30_algebraic = m30_algebraic + 1
            return l
        }
        // M255: associative fold (x * c1) * c2 → x * (c1*c2)
        if type_of(l) != "string" && type_of(r) != "string" {
            if l.kind == "BinOp" && l.op == "*" && r.kind == "IntLit" {
                if type_of(l.right) != "string" && l.right.kind == "IntLit" {
                    let c1 = parse_int_str(l.right.value)
                    let c2 = parse_int_str(r.value)
                    if c1 >= 0 && c2 >= 0 {
                        m32_folds = m32_folds + 1
                        return AstNode {
                            kind: "BinOp", name: "", value: "", op: "*",
                            left: l.left, right: make_int_lit(c1 * c2), cond: "", then_body: "", else_body: "",
                            params: "", body: "", args: "", fields: "", items: "",
                            variants: "", arms: "", iter_expr: "", ret_type: "",
                            target: "", trait_name: "", methods: ""
                        }
                    }
                }
            }
        }
        // M277: (-a) * (-b) → a * b
        if type_of(l) != "string" && type_of(r) != "string" {
            if l.kind == "UnaryOp" && l.op == "-" && r.kind == "UnaryOp" && r.op == "-" {
                m30_algebraic = m30_algebraic + 1
                return AstNode {
                    kind: "BinOp", name: "", value: "", op: "*",
                    left: l.left, right: r.left, cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            }
            // M278: (-a) * b → -(a * b), a * (-b) → -(a * b)
            if l.kind == "UnaryOp" && l.op == "-" {
                m30_algebraic = m30_algebraic + 1
                let inner_mul = AstNode {
                    kind: "BinOp", name: "", value: "", op: "*",
                    left: l.left, right: r, cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
                return AstNode {
                    kind: "UnaryOp", name: "", value: "", op: "-",
                    left: inner_mul, right: "", cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            }
            if r.kind == "UnaryOp" && r.op == "-" {
                m30_algebraic = m30_algebraic + 1
                let inner_mul2 = AstNode {
                    kind: "BinOp", name: "", value: "", op: "*",
                    left: l, right: r.left, cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
                return AstNode {
                    kind: "UnaryOp", name: "", value: "", op: "-",
                    left: inner_mul2, right: "", cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            }
        }
        // M266: (x/c) * c → x (assumes exact division)
        if type_of(l) != "string" && type_of(r) != "string" {
            if l.kind == "BinOp" && l.op == "/" && r.kind == "IntLit" {
                if type_of(l.right) != "string" && l.right.kind == "IntLit" {
                    if l.right.value == r.value && r.value != "0" {
                        m30_algebraic = m30_algebraic + 1
                        return l.left
                    }
                }
            }
        }
        // M120: IntLit * x → x * IntLit (commutative)
        if type_of(l) != "string" && type_of(r) != "string" {
            if l.kind == "IntLit" && r.kind != "IntLit" {
                m30_algebraic = m30_algebraic + 1
                return AstNode {
                    kind: "BinOp", name: "", value: "", op: "*",
                    left: r, right: l, cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            }
        }
    }
    // M114: x / 1 → x, 0 / x → 0
    if op == "/" {
        if is_int_one(r) {
            m30_algebraic = m30_algebraic + 1
            return l
        }
        if is_int_zero(l) {
            m30_algebraic = m30_algebraic + 1
            return AstNode {
                kind: "IntLit", name: "", value: "0", op: "",
                left: "", right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            }
        }
        // M115: x / x → 1 (assumes x != 0)
        if same_ident(l, r) {
            m30_algebraic = m30_algebraic + 1
            return make_int_lit(1)
        }
        // M265: (x*c) / c → x
        if type_of(l) != "string" && type_of(r) != "string" {
            if l.kind == "BinOp" && l.op == "*" && r.kind == "IntLit" {
                if type_of(l.right) != "string" && l.right.kind == "IntLit" {
                    if l.right.value == r.value && r.value != "0" {
                        m30_algebraic = m30_algebraic + 1
                        return l.left
                    }
                }
            }
        }
    }
    if op == "&&" {
        if is_bool_false(l) {
            m35_bool_folds = m35_bool_folds + 1
            return l
        }
        if is_bool_false(r) {
            m35_bool_folds = m35_bool_folds + 1
            return r
        }
        if is_bool_true(l) {
            m35_bool_folds = m35_bool_folds + 1
            return r
        }
        if is_bool_true(r) {
            m35_bool_folds = m35_bool_folds + 1
            return l
        }
        // M108: x && x → x
        if same_ident(l, r) {
            m35_bool_folds = m35_bool_folds + 1
            return l
        }
        // M113: x && !x → false / !x && x → false
        if is_not_of(l, r) || is_not_of(r, l) {
            m35_bool_folds = m35_bool_folds + 1
            return make_bool_lit_from_bool(false)
        }
    }
    if op == "||" {
        if is_bool_true(l) {
            m35_bool_folds = m35_bool_folds + 1
            return l
        }
        if is_bool_true(r) {
            m35_bool_folds = m35_bool_folds + 1
            return r
        }
        if is_bool_false(l) {
            m35_bool_folds = m35_bool_folds + 1
            return r
        }
        if is_bool_false(r) {
            m35_bool_folds = m35_bool_folds + 1
            return l
        }
        // M109: x || x → x
        if same_ident(l, r) {
            m35_bool_folds = m35_bool_folds + 1
            return l
        }
        // M113: x || !x → true / !x || x → true
        if is_not_of(l, r) || is_not_of(r, l) {
            m35_bool_folds = m35_bool_folds + 1
            return make_bool_lit_from_bool(true)
        }
    }
    // Rebuild with simplified children
    return AstNode {
        kind: "BinOp", name: "", value: "", op: op,
        left: l, right: r, cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn simplify_body(body) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ReturnStmt" || k == "ExprStmt" || k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" {
            let new_e = simplify_expr(stmt.left)
            out = out.push(AstNode {
                kind: k, name: stmt.name, value: stmt.value, op: "",
                left: new_e, right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            })
        } else {
            if k == "AssignStmt" {
                let new_r = simplify_expr(stmt.right)
                out = out.push(AstNode {
                    kind: "AssignStmt", name: "", value: "", op: "",
                    left: stmt.left, right: new_r, cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                })
            } else {
                if k == "WhileStmt" {
                    let new_cond = simplify_expr(stmt.cond)
                    // M41: while(false) { ... } → drop entirely
                    if is_bool_false(new_cond) {
                        m41_dead_loops = m41_dead_loops + 1
                        // don't push anything
                    } else {
                        let new_body = simplify_body(stmt.body)
                        out = out.push(AstNode {
                            kind: "WhileStmt", name: "", value: "", op: "",
                            left: "", right: "", cond: new_cond, then_body: "", else_body: "",
                            params: "", body: new_body, args: "", fields: "", items: "",
                            variants: "", arms: "", iter_expr: "", ret_type: "",
                            target: "", trait_name: "", methods: ""
                        })
                    }
                } else {
                    out = out.push(stmt)
                }
            }
        }
        i = i + 1
    }
    return out
}

// Canonical attr rank (lower = earlier). Integer comparison only.
fn attr_rank(name) {
    if name == "pure" { return 10 }
    if name == "inline" { return 20 }
    if name == "hot" { return 30 }
    if name == "cold" { return 31 }
    if name == "bounded" { return 40 }
    if name == "memoize" { return 50 }
    if name == "optimize" { return 60 }
    if name == "fuse" { return 70 }
    if name == "compact" { return 71 }
    if name == "lazy" { return 72 }
    if name == "cache" { return 73 }
    if name == "algebraic" { return 74 }
    if name == "parallel" { return 80 }
    if name == "simd" { return 81 }
    if name == "gpu" { return 82 }
    if name == "specialize" { return 83 }
    if name == "predict" { return 84 }
    if name == "symbolic" { return 90 }
    if name == "reduce" { return 91 }
    if name == "approximate" { return 92 }
    if name == "evolve" { return 93 }
    if name == "learn" { return 94 }
    if name == "contract" { return 95 }
    if name == "profile" { return 96 }
    if name == "test" { return 200 }
    if name == "bench" { return 201 }
    if name == "deprecated" { return 202 }
    if name == "link" { return 203 }
    return 999
}

fn sort_attrs(attrs) {
    // Selection sort by rank — stable for equal ranks
    let n = len(attrs)
    let mut result = []
    let mut i = 0
    while i < n {
        result = result.push(attrs[i])
        i = i + 1
    }
    let mut k = 0
    while k < n {
        let mut min_idx = k
        let mut j = k + 1
        while j < n {
            if attr_rank(result[j]) < attr_rank(result[min_idx]) {
                min_idx = j
            }
            j = j + 1
        }
        if min_idx != k {
            // swap via rebuild
            let mut tmp = []
            let mut t = 0
            while t < n {
                if t == k { tmp = tmp.push(result[min_idx]) }
                else { if t == min_idx { tmp = tmp.push(result[k]) }
                       else { tmp = tmp.push(result[t]) } }
                t = t + 1
            }
            result = tmp
        }
        k = k + 1
    }
    return result
}

fn arrays_equal_str(a, b) {
    if len(a) != len(b) { return false }
    let n = len(a)
    let mut i = 0
    while i < n {
        if a[i] != b[i] { return false }
        i = i + 1
    }
    return true
}

fn dedup_attrs(attrs) {
    let mut seen = []
    let n = len(attrs)
    let mut i = 0
    while i < n {
        let a = attrs[i]
        let mut already = false
        let sn = len(seen)
        let mut j = 0
        while j < sn {
            if seen[j] == a { already = true }
            j = j + 1
        }
        if !already { seen = seen.push(a) }
        i = i + 1
    }
    return seen
}

fn join_attrs(attrs) {
    let n = len(attrs)
    if n == 0 { return "" }
    let mut out = attrs[0]
    let mut i = 1
    while i < n {
        out = out + "," + attrs[i]
        i = i + 1
    }
    return out
}

fn make_bool_lit(v) {
    return AstNode {
        kind: "BoolLit", name: "", value: v, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_while_true_empty() {
    return AstNode {
        kind: "WhileStmt", name: "", value: "", op: "",
        left: "", right: "", cond: make_bool_lit("true"), then_body: "", else_body: "",
        params: "", body: [], args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

// Simple tail-call: body is exactly [ReturnStmt(Call(Ident self, ...))]
fn is_simple_tail_only(body, self_name) {
    if type_of(body) != "array" { return false }
    if len(body) != 1 { return false }
    let s = body[0]
    if s.kind != "ReturnStmt" { return false }
    let e = s.left
    if type_of(e) == "string" { return false }
    if e.kind != "Call" { return false }
    let callee = e.left
    if type_of(callee) == "string" { return false }
    if callee.kind != "Ident" { return false }
    return callee.name == self_name
}

fn eliminate_dead(body) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let n = len(body)
    let mut i = 0
    let mut stopped = false
    while i < n {
        if !stopped {
            out = out.push(body[i])
            if body[i].kind == "ReturnStmt" { stopped = true }
            // M293: assert false also stops execution
            if body[i].kind == "AssertStmt" {
                let c = body[i].left
                if type_of(c) != "string" && c.kind == "BoolLit" && c.value == "false" {
                    stopped = true
                }
            }
        }
        i = i + 1
    }
    return out
}

fn rewrite_fn_with_attrs(fn_node, new_attrs) {
    return AstNode {
        kind: "FnDecl", name: fn_node.name, value: new_attrs, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: fn_node.params, body: fn_node.body, args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: fn_node.ret_type,
        target: "", trait_name: "", methods: ""
    }
}

fn make_return_zero() {
    let lit = AstNode {
        kind: "IntLit", name: "", value: "0", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
    return AstNode {
        kind: "ReturnStmt", name: "", value: "", op: "",
        left: lit, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn rewrite_fn_with_body(fn_node, new_body) {
    return AstNode {
        kind: "FnDecl", name: fn_node.name, value: fn_node.value, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: fn_node.params, body: new_body, args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: fn_node.ret_type,
        target: "", trait_name: "", methods: ""
    }
}

fn is_literal_kind(k) {
    if k == "IntLit" { return true }
    if k == "FloatLit" { return true }
    if k == "BoolLit" { return true }
    if k == "StringLit" { return true }
    if k == "CharLit" { return true }
    // M292: Array literal also propagatable
    if k == "Array" { return true }
    return false
}

fn body_is_const_return(body) {
    if type_of(body) != "array" { return false }
    if len(body) != 1 { return false }
    let s = body[0]
    if s.kind != "ReturnStmt" { return false }
    let e = s.left
    if type_of(e) == "string" { return false }
    return is_literal_kind(e.kind)
}

fn count_unreachable(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    let mut hit = false
    while i < n {
        let stmt = body[i]
        if hit { c = c + 1 }
        if stmt.kind == "ReturnStmt" { hit = true }
        // M293: assert false also stops execution
        if stmt.kind == "AssertStmt" {
            let cc = stmt.left
            if type_of(cc) != "string" && cc.kind == "BoolLit" && cc.value == "false" {
                hit = true
            }
        }
        if stmt.kind == "WhileStmt" {
            c = c + count_unreachable(stmt.body)
        }
        i = i + 1
    }
    return c
}

fn is_tail_call(body, self_name) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    if n == 0 { return false }
    let last = body[n - 1]
    if last.kind != "ReturnStmt" { return false }
    return expr_calls_self(last.left, self_name)
}

fn body_has_let_mut(body) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    let mut i = 0
    while i < n {
        let k = body[i].kind
        if k == "LetMutStmt" { return true }
        if k == "WhileStmt" {
            if body_has_let_mut(body[i].body) { return true }
        }
        i = i + 1
    }
    return false
}

fn while_depth(body) {
    if type_of(body) != "array" { return 0 }
    let mut maxd = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "WhileStmt" {
            let sub = while_depth(stmt.body)
            let here = 1 + sub
            if here > maxd { maxd = here }
        }
        i = i + 1
    }
    return maxd
}

fn count_returns(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "ReturnStmt" { c = c + 1 }
        if stmt.kind == "WhileStmt" { c = c + count_returns(stmt.body) }
        i = i + 1
    }
    return c
}

fn count_assigns(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "AssignStmt" { c = c + 1 }
        if stmt.kind == "WhileStmt" { c = c + count_assigns(stmt.body) }
        i = i + 1
    }
    return c
}

fn count_lets(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "LetStmt" { c = c + 1 }
        if stmt.kind == "LetMutStmt" { c = c + 1 }
        if stmt.kind == "WhileStmt" { c = c + count_lets(stmt.body) }
        i = i + 1
    }
    return c
}

fn count_exprstmts(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "ExprStmt" { c = c + 1 }
        if stmt.kind == "WhileStmt" { c = c + count_exprstmts(stmt.body) }
        i = i + 1
    }
    return c
}

fn count_asserts(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "AssertStmt" { c = c + 1 }
        if stmt.kind == "WhileStmt" { c = c + count_asserts(stmt.body) }
        i = i + 1
    }
    return c
}

fn count_whiles(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "WhileStmt" {
            c = c + 1
            c = c + count_whiles(stmt.body)
        }
        i = i + 1
    }
    return c
}

fn count_expr_binops(expr) {
    if type_of(expr) == "string" { return 0 }
    let mut c = 0
    if expr.kind == "BinOp" {
        c = 1 + count_expr_binops(expr.left) + count_expr_binops(expr.right)
    }
    if expr.kind == "Call" {
        let args = expr.args
        if type_of(args) == "array" {
            let n = len(args)
            let mut i = 0
            while i < n {
                c = c + count_expr_binops(args[i])
                i = i + 1
            }
        }
    }
    return c
}

fn count_expr_calls_m352(expr) {
    if type_of(expr) == "string" { return 0 }
    let mut c = 0
    if expr.kind == "Call" {
        c = 1
        let args = expr.args
        if type_of(args) == "array" {
            let n = len(args)
            let mut i = 0
            while i < n {
                c = c + count_expr_calls_m352(args[i])
                i = i + 1
            }
        }
    }
    if expr.kind == "BinOp" {
        c = count_expr_calls_m352(expr.left) + count_expr_calls_m352(expr.right)
    }
    return c
}

fn count_expr_intlits(expr) {
    if type_of(expr) == "string" { return 0 }
    if expr.kind == "IntLit" { return 1 }
    if expr.kind == "BinOp" {
        return count_expr_intlits(expr.left) + count_expr_intlits(expr.right)
    }
    if expr.kind == "Call" {
        let mut c = 0
        let args = expr.args
        if type_of(args) == "array" {
            let n = len(args)
            let mut i = 0
            while i < n {
                c = c + count_expr_intlits(args[i])
                i = i + 1
            }
        }
        return c
    }
    return 0
}

fn count_body_binops(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "ReturnStmt" { c = c + count_expr_binops(stmt.left) }
        if stmt.kind == "LetStmt" { c = c + count_expr_binops(stmt.left) }
        if stmt.kind == "LetMutStmt" { c = c + count_expr_binops(stmt.left) }
        if stmt.kind == "AssignStmt" { c = c + count_expr_binops(stmt.left) + count_expr_binops(stmt.right) }
        if stmt.kind == "ExprStmt" { c = c + count_expr_binops(stmt.left) }
        if stmt.kind == "AssertStmt" { c = c + count_expr_binops(stmt.left) }
        if stmt.kind == "WhileStmt" {
            c = c + count_expr_binops(stmt.cond)
            c = c + count_body_binops(stmt.body)
        }
        i = i + 1
    }
    return c
}

fn count_body_calls_m352(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "ReturnStmt" { c = c + count_expr_calls_m352(stmt.left) }
        if stmt.kind == "LetStmt" { c = c + count_expr_calls_m352(stmt.left) }
        if stmt.kind == "LetMutStmt" { c = c + count_expr_calls_m352(stmt.left) }
        if stmt.kind == "AssignStmt" { c = c + count_expr_calls_m352(stmt.left) + count_expr_calls_m352(stmt.right) }
        if stmt.kind == "ExprStmt" { c = c + count_expr_calls_m352(stmt.left) }
        if stmt.kind == "AssertStmt" { c = c + count_expr_calls_m352(stmt.left) }
        if stmt.kind == "WhileStmt" {
            c = c + count_expr_calls_m352(stmt.cond)
            c = c + count_body_calls_m352(stmt.body)
        }
        i = i + 1
    }
    return c
}

fn count_expr_by_kind(expr, kind) {
    if type_of(expr) == "string" { return 0 }
    let mut c = 0
    if expr.kind == kind { c = 1 }
    if expr.kind == "BinOp" {
        c = c + count_expr_by_kind(expr.left, kind) + count_expr_by_kind(expr.right, kind)
    }
    if expr.kind == "Call" {
        let args = expr.args
        if type_of(args) == "array" {
            let n = len(args)
            let mut i = 0
            while i < n {
                c = c + count_expr_by_kind(args[i], kind)
                i = i + 1
            }
        }
    }
    return c
}

fn count_body_by_kind(body, kind) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "ReturnStmt" { c = c + count_expr_by_kind(stmt.left, kind) }
        if stmt.kind == "LetStmt" { c = c + count_expr_by_kind(stmt.left, kind) }
        if stmt.kind == "LetMutStmt" { c = c + count_expr_by_kind(stmt.left, kind) }
        if stmt.kind == "AssignStmt" { c = c + count_expr_by_kind(stmt.left, kind) + count_expr_by_kind(stmt.right, kind) }
        if stmt.kind == "ExprStmt" { c = c + count_expr_by_kind(stmt.left, kind) }
        if stmt.kind == "AssertStmt" { c = c + count_expr_by_kind(stmt.left, kind) }
        if stmt.kind == "WhileStmt" {
            c = c + count_expr_by_kind(stmt.cond, kind)
            c = c + count_body_by_kind(stmt.body, kind)
        }
        i = i + 1
    }
    return c
}

fn count_body_intlits(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "ReturnStmt" { c = c + count_expr_intlits(stmt.left) }
        if stmt.kind == "LetStmt" { c = c + count_expr_intlits(stmt.left) }
        if stmt.kind == "LetMutStmt" { c = c + count_expr_intlits(stmt.left) }
        if stmt.kind == "AssignStmt" { c = c + count_expr_intlits(stmt.left) + count_expr_intlits(stmt.right) }
        if stmt.kind == "ExprStmt" { c = c + count_expr_intlits(stmt.left) }
        if stmt.kind == "AssertStmt" { c = c + count_expr_intlits(stmt.left) }
        if stmt.kind == "WhileStmt" {
            c = c + count_expr_intlits(stmt.cond)
            c = c + count_body_intlits(stmt.body)
        }
        i = i + 1
    }
    return c
}

fn count_letmuts(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "LetMutStmt" { c = c + 1 }
        if stmt.kind == "WhileStmt" { c = c + count_letmuts(stmt.body) }
        i = i + 1
    }
    return c
}

fn count_void_returns(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "ReturnStmt" {
            if type_of(stmt.left) == "string" { c = c + 1 }
        }
        if stmt.kind == "WhileStmt" { c = c + count_void_returns(stmt.body) }
        i = i + 1
    }
    return c
}

fn expr_count_calls(expr) {
    if type_of(expr) == "string" { return 0 }
    let mut c = 0
    if expr.kind == "Call" {
        c = 1
        let args = expr.args
        if type_of(args) == "array" {
            let n = len(args)
            let mut i = 0
            while i < n {
                c = c + expr_count_calls(args[i])
                i = i + 1
            }
        }
    }
    if expr.kind == "BinOp" {
        c = c + expr_count_calls(expr.left)
        c = c + expr_count_calls(expr.right)
    }
    return c
}

fn stmts_count_calls(body) {
    if type_of(body) != "array" { return 0 }
    let mut total = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ExprStmt" || k == "ReturnStmt" || k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" {
            total = total + expr_count_calls(stmt.left)
        }
        if k == "AssignStmt" {
            total = total + expr_count_calls(stmt.right)
        }
        if k == "WhileStmt" {
            total = total + expr_count_calls(stmt.cond)
            total = total + stmts_count_calls(stmt.body)
        }
        i = i + 1
    }
    return total
}

fn expr_calls_self(expr, self_name) {
    if type_of(expr) == "string" { return false }
    let k = expr.kind
    if k == "Call" {
        let callee = expr.left
        if type_of(callee) != "string" {
            if callee.kind == "Ident" && callee.name == self_name {
                return true
            }
        }
        // recurse into args
        let args = expr.args
        if type_of(args) == "array" {
            let n = len(args)
            let mut i = 0
            while i < n {
                if expr_calls_self(args[i], self_name) { return true }
                i = i + 1
            }
        }
        return false
    }
    if k == "BinOp" {
        if expr_calls_self(expr.left, self_name) { return true }
        if expr_calls_self(expr.right, self_name) { return true }
    }
    return false
}

fn stmts_call_self(body, self_name) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ExprStmt" {
            if expr_calls_self(stmt.left, self_name) { return true }
        }
        if k == "ReturnStmt" {
            if expr_calls_self(stmt.left, self_name) { return true }
        }
        if k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" {
            if expr_calls_self(stmt.left, self_name) { return true }
        }
        if k == "AssignStmt" {
            if expr_calls_self(stmt.right, self_name) { return true }
        }
        if k == "WhileStmt" {
            if expr_calls_self(stmt.cond, self_name) { return true }
            if stmts_call_self(stmt.body, self_name) { return true }
        }
        i = i + 1
    }
    return false
}

fn body_has_loop(body) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    let mut i = 0
    while i < n {
        let k = body[i].kind
        if k == "WhileStmt" { return true }
        if k == "ForStmt" { return true }
        if k == "LoopStmt" { return true }
        i = i + 1
    }
    return false
}

// M3: body size — counts top-level statements only (simple heuristic).
// Inline threshold: 8 stmts. Over → "too big" diagnostic.
fn body_stmt_count(body) {
    if type_of(body) != "array" { return 0 }
    return len(body)
}

// M4: check a set of attrs for known conflicts.
// Returns reason string if conflict, else "".
fn attr_has(attrs, target) {
    let n = len(attrs)
    let mut i = 0
    while i < n {
        if attrs[i] == target { return true }
        i = i + 1
    }
    return false
}

fn find_attr_conflict(attrs) {
    if attr_has(attrs, "hot") && attr_has(attrs, "cold") {
        return "hot+cold"
    }
    if attr_has(attrs, "inline") && attr_has(attrs, "cold") {
        return "inline+cold"
    }
    if attr_has(attrs, "pure") && attr_has(attrs, "evolve") {
        return "pure+evolve"
    }
    return ""
}

