                    }
                }
            }
        }
        if stmt.kind == "WhileStmt" { c = c + count_div_accumulators(stmt.body) }
        i = i + 1
    }
    return c
}

// ── M970: @algebraic — count commutative reordering opportunities ──
// Detects: non-canonical commutative binops (IntLit on left of +/*),
// associative chains that can be reordered for constant folding.
fn count_commutative_sites(expr) {
    if type_of(expr) == "string" { return 0 }
    if expr.kind == "BinOp" {
        let mut c = count_commutative_sites(expr.left) + count_commutative_sites(expr.right)
        let op = expr.op
        // Non-canonical: literal on left of commutative op
        if op == "+" || op == "*" {
            if type_of(expr.left) != "string" && type_of(expr.right) != "string" {
                if expr.left.kind == "IntLit" && expr.right.kind != "IntLit" {
                    c = c + 1
                }
            }
        }
        // Associative chain: (a + b) + c or (a * b) * c with constants that can merge
        if op == "+" || op == "*" {
            if type_of(expr.left) != "string" && expr.left.kind == "BinOp" && expr.left.op == op {
                if type_of(expr.right) != "string" && expr.right.kind == "IntLit" {
                    if type_of(expr.left.right) != "string" && expr.left.right.kind == "IntLit" {
                        c = c + 1
                    }
                }
            }
        }
        return c
    }
    if expr.kind == "UnaryOp" { return count_commutative_sites(expr.left) }
    return 0
}

fn count_algebraic_body(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ReturnStmt" { c = c + count_commutative_sites(stmt.left) }
        if k == "LetStmt" || k == "LetMutStmt" { c = c + count_commutative_sites(stmt.left) }
        if k == "AssignStmt" { c = c + count_commutative_sites(stmt.right) }
        if k == "ExprStmt" { c = c + count_commutative_sites(stmt.left) }
        if k == "WhileStmt" {
            c = c + count_commutative_sites(stmt.cond)
            c = c + count_algebraic_body(stmt.body)
        }
        if k == "IfStmt" {
            c = c + count_commutative_sites(stmt.cond)
            c = c + count_algebraic_body(stmt.then_body)
            if type_of(stmt.else_body) == "array" { c = c + count_algebraic_body(stmt.else_body) }
        }
        i = i + 1
    }
    return c
}

// ── M971: @approximate — detect expensive math patterns ──
// Detects: division in loops (potential multiply-by-reciprocal),
// repeated same-denominator division, call to pow/sqrt/exp/log (approximable).
fn count_div_in_expr(expr) {
    if type_of(expr) == "string" { return 0 }
    if expr.kind == "BinOp" {
        let c = count_div_in_expr(expr.left) + count_div_in_expr(expr.right)
        if expr.op == "/" { return c + 1 }
        return c
    }
    if expr.kind == "UnaryOp" { return count_div_in_expr(expr.left) }
    if expr.kind == "Call" {
        if type_of(expr.left) != "string" && expr.left.kind == "Ident" {
            let cn = expr.left.name
            if cn == "sqrt" || cn == "pow" || cn == "exp" || cn == "log" || cn == "sin" || cn == "cos" || cn == "tan" {
                return 1
            }
        }
    }
    return 0
}

fn count_approx_body(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ReturnStmt" { c = c + count_div_in_expr(stmt.left) }
        if k == "LetStmt" || k == "LetMutStmt" { c = c + count_div_in_expr(stmt.left) }
        if k == "AssignStmt" { c = c + count_div_in_expr(stmt.right) }
        if k == "ExprStmt" { c = c + count_div_in_expr(stmt.left) }
        if k == "WhileStmt" {
            c = c + count_div_in_expr(stmt.cond)
            // Divisions inside loops are extra expensive → count double
            c = c + count_approx_body(stmt.body) * 2
        }
        if k == "IfStmt" {
            c = c + count_div_in_expr(stmt.cond)
            c = c + count_approx_body(stmt.then_body)
            if type_of(stmt.else_body) == "array" { c = c + count_approx_body(stmt.else_body) }
        }
        i = i + 1
    }
    return c
}

// ── M972: @compact — SoA detection ──
// Detects: field access on array-indexed struct (arr[i].field pattern)
// which indicates AoS that could be transformed to SoA.
fn count_field_on_index(expr) {
    if type_of(expr) == "string" { return 0 }
    // Pattern: expr.kind == "FieldAccess" && expr.left.kind == "Index"
    if expr.kind == "FieldAccess" {
        if type_of(expr.left) != "string" && expr.left.kind == "Index" {
            return 1
        }
        return count_field_on_index(expr.left)
    }
    if expr.kind == "BinOp" { return count_field_on_index(expr.left) + count_field_on_index(expr.right) }
    if expr.kind == "UnaryOp" { return count_field_on_index(expr.left) }
    if expr.kind == "Index" { return count_field_on_index(expr.left) + count_field_on_index(expr.right) }
    if expr.kind == "Call" {
        let mut c = 0
        if type_of(expr.args) == "array" {
            let an = len(expr.args)
            let mut ai = 0
            while ai < an {
                c = c + count_field_on_index(expr.args[ai])
                ai = ai + 1
            }
        }
        return c
    }
    return 0
}

fn count_compact_body(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ReturnStmt" { c = c + count_field_on_index(stmt.left) }
        if k == "LetStmt" || k == "LetMutStmt" { c = c + count_field_on_index(stmt.left) }
        if k == "AssignStmt" {
            c = c + count_field_on_index(stmt.left)
            c = c + count_field_on_index(stmt.right)
        }
        if k == "ExprStmt" { c = c + count_field_on_index(stmt.left) }
        if k == "WhileStmt" { c = c + count_compact_body(stmt.body) }
        if k == "IfStmt" {
            c = c + count_compact_body(stmt.then_body)
            if type_of(stmt.else_body) == "array" { c = c + count_compact_body(stmt.else_body) }
        }
        i = i + 1
    }
    return c
}

// ── M973: @optimize sliding-window — DP array lookback detection ──
// Detects: dp[i] = f(dp[i-1], dp[i-2]) pattern inside while loops.
// This means only the last K elements are needed → O(1) memory.
fn detect_dp_lookback(expr, arr_name) {
    // Checks if expr references arr_name[i - const]
    if type_of(expr) == "string" { return 0 }
    if expr.kind == "Index" {
        if type_of(expr.left) != "string" && expr.left.kind == "Ident" && expr.left.name == arr_name {
            if type_of(expr.right) != "string" && expr.right.kind == "BinOp" && expr.right.op == "-" {
                if type_of(expr.right.right) != "string" && expr.right.right.kind == "IntLit" {
                    return 1
                }
            }
        }
    }
    if expr.kind == "BinOp" {
        return detect_dp_lookback(expr.left, arr_name) + detect_dp_lookback(expr.right, arr_name)
    }
    if expr.kind == "UnaryOp" { return detect_dp_lookback(expr.left, arr_name) }
    if expr.kind == "Call" {
        let mut c = 0
        if type_of(expr.args) == "array" {
            let an = len(expr.args)
            let mut ai = 0
            while ai < an {
                c = c + detect_dp_lookback(expr.args[ai], arr_name)
                ai = ai + 1
            }
        }
        return c
    }
    return 0
}

// Scan while-loop body for: arr[i] = ... arr[i-k] ... pattern
fn count_sliding_window_body(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "WhileStmt" {
            // Look inside while for assignments to arr[i]
            if type_of(stmt.body) == "array" {
                let wn = len(stmt.body)
                let mut wi = 0
                while wi < wn {
                    let ws = stmt.body[wi]
                    if ws.kind == "AssignStmt" {
                        let lhs = ws.left
                        if type_of(lhs) != "string" && lhs.kind == "Index" {
                            if type_of(lhs.left) != "string" && lhs.left.kind == "Ident" {
                                let arr_nm = lhs.left.name
                                let lookbacks = detect_dp_lookback(ws.right, arr_nm)
                                if lookbacks > 0 {
                                    c = c + lookbacks
                                }
                            }
                        }
                    }
                    wi = wi + 1
                }
            }
        }
        i = i + 1
    }
    return c
}

// ── M974: @cow — detect shared-data mutation sites (copy-on-write candidates) ──
// Counts AssignStmt where LHS is Index or FieldAccess on a parameter/variable
// that could be shared. In COW semantics, the runtime defers copy until mutation.
fn count_cow_mutation_sites(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "AssignStmt" {
            let lhs = stmt.left
            if type_of(lhs) != "string" {
                // arr[i] = val  or  obj.field = val  → COW trigger
                if lhs.kind == "Index" || lhs.kind == "FieldAccess" {
                    c = c + 1
                }
            }
        }
        if k == "WhileStmt" { c = c + count_cow_mutation_sites(stmt.body) }
        if k == "IfStmt" {
            c = c + count_cow_mutation_sites(stmt.then_body)
            if type_of(stmt.else_body) == "array" { c = c + count_cow_mutation_sites(stmt.else_body) }
        }
        i = i + 1
    }
    return c
}

// ── M975: O(n^2) sort pattern detection ──
// Detect bubble/insertion/selection sort: nested while + swap pattern (>=4 Index ops)
// Also detects insertion sort: nested while + shift pattern
fn detect_quadratic_sort(body) {
    if type_of(body) != "array" { return false }
    let wd = while_depth(body)
    if wd < 2 { return false }
    let idx_count = count_body_by_kind(body, "Index")
    if idx_count < 4 { return false }
    // Must have let mut (for swap variable or shift)
    if !body_has_let_mut(body) { return false }
    return true
}

// Build introsort body as AST: partition + recursive calls + insertion sort fallback
fn make_introsort_body(fn_name, param_name) {
    let mut stmts = []
    // let n = len(arr)
    let len_call = make_call_node("len", [make_ident(param_name)])
    stmts = stmts.push(make_let_stmt("n", len_call))
    // if n <= 1 { return arr }
    let cond = make_binop("<=", make_ident("n"), make_int_lit(1))
    let ret_arr = AstNode {
        kind: "ReturnStmt", name: "", value: "", op: "",
        left: make_ident(param_name), right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
    let if_stmt = AstNode {
        kind: "IfStmt", name: "", value: "", op: "",
        left: "", right: "", cond: cond, then_body: [ret_arr], else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
    stmts = stmts.push(if_stmt)
    // Pivot = arr[n/2], partition, recurse
    // let pivot = arr[n / 2]
    let mid_expr = make_binop("/", make_ident("n"), make_int_lit(2))
    let pivot_idx = AstNode {
        kind: "Index", name: "", value: "", op: "",
        left: make_ident(param_name), right: mid_expr, cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
    stmts = stmts.push(make_let_stmt("pivot", pivot_idx))
    // Partition into left/right arrays + recursive calls + concat
    // let left = arr.filter(|x| x < pivot)
    // let right = arr.filter(|x| x > pivot)
    // let mid = arr.filter(|x| x == pivot)
    // return sort(left) + mid + sort(right)
    let sort_left = make_call_node(fn_name, [make_ident("__left")])
    let sort_right = make_call_node(fn_name, [make_ident("__right")])
    // Build: let __left = []; let __mid = []; let __right = []
    stmts = stmts.push(make_let_mut_stmt("__left", make_empty_array()))
    stmts = stmts.push(make_let_mut_stmt("__mid", make_empty_array()))
    stmts = stmts.push(make_let_mut_stmt("__right", make_empty_array()))
    // Partition loop: while __pi < n
    stmts = stmts.push(make_let_mut_stmt("__pi", make_int_lit(0)))
    let pi_cond = make_binop("<", make_ident("__pi"), make_ident("n"))
    let elem_idx = AstNode {
        kind: "Index", name: "", value: "", op: "",
        left: make_ident(param_name), right: make_ident("__pi"), cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
    let let_elem = make_let_stmt("__e", elem_idx)
    let push_left = make_assign_push("__left", "__e")
    let push_mid = make_assign_push("__mid", "__e")
    let push_right = make_assign_push("__right", "__e")
    let cmp_lt = make_binop("<", make_ident("__e"), make_ident("pivot"))
    let cmp_eq = make_binop("==", make_ident("__e"), make_ident("pivot"))
    // if __e < pivot { __left.push } else if __e == pivot { __mid.push } else { __right.push }
    let else_right = [push_right]
    let elif_mid = AstNode {
        kind: "IfStmt", name: "", value: "", op: "",
        left: "", right: "", cond: cmp_eq, then_body: [push_mid], else_body: else_right,
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
    let if_part = AstNode {
        kind: "IfStmt", name: "", value: "", op: "",
        left: "", right: "", cond: cmp_lt, then_body: [push_left], else_body: [elif_mid],
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
    let incr_pi = make_assign_incr("__pi")
    let loop_body = [let_elem, if_part, incr_pi]
    let part_loop = AstNode {
        kind: "WhileStmt", name: "", value: "", op: "",
        left: "", right: "", cond: pi_cond, then_body: "", else_body: "",
        params: "", body: loop_body, args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
    stmts = stmts.push(part_loop)
    // return sort(__left) + __mid + sort(__right)
    let sorted_l = make_let_stmt("__sl", sort_left)
    let sorted_r = make_let_stmt("__sr", sort_right)
    stmts = stmts.push(sorted_l)
    stmts = stmts.push(sorted_r)
    let concat1 = make_binop("+", make_ident("__sl"), make_ident("__mid"))
    let concat2 = make_binop("+", concat1, make_ident("__sr"))
    let ret_final = AstNode {
        kind: "ReturnStmt", name: "", value: "", op: "",
        left: concat2, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
    stmts = stmts.push(ret_final)
    return stmts
}

fn make_let_mut_stmt(name, expr) {
    return AstNode {
        kind: "LetMutStmt", name: name, value: "", op: "",
        left: expr, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_empty_array() {
    return AstNode {
        kind: "ArrayLit", name: "", value: "", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: [],
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_assign_push(arr_name, elem_name) {
    // arr_name = arr_name.push(elem_name) → AssignStmt
    let push_call = AstNode {
        kind: "MethodCall", name: "push", value: "", op: "",
        left: make_ident(arr_name), right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: [make_ident(elem_name)], fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
    return AstNode {
        kind: "AssignStmt", name: "", value: "", op: "",
        left: make_ident(arr_name), right: push_call, cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_assign_incr(name) {
    let incr = make_binop("+", make_ident(name), make_int_lit(1))
    return AstNode {
        kind: "AssignStmt", name: "", value: "", op: "",
        left: make_ident(name), right: incr, cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

// ── M976: branch merging — detect if/else with identical trailing stmts ──
// Scans body for IfStmt where the last statement of then_body and else_body
// are identical (same kind + same value/name). These can be hoisted out.
fn count_branch_merge_candidates(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "IfStmt" {
            if type_of(stmt.then_body) == "array" && type_of(stmt.else_body) == "array" {
                let tlen = len(stmt.then_body)
                let elen = len(stmt.else_body)
                if tlen > 0 && elen > 0 {
                    let last_then = stmt.then_body[tlen - 1]
                    let last_else = stmt.else_body[elen - 1]
                    if stmts_match(last_then, last_else) {
                        c = c + 1
                    }
                }
            }
            // recurse into branches
            c = c + count_branch_merge_candidates(stmt.then_body)
            if type_of(stmt.else_body) == "array" { c = c + count_branch_merge_candidates(stmt.else_body) }
        }
        if k == "WhileStmt" { c = c + count_branch_merge_candidates(stmt.body) }
        i = i + 1
    }
    return c
}

// Check if two stmts are structurally identical (kind + name + value match)
fn stmts_match(a, b) {
    if type_of(a) == "string" || type_of(b) == "string" { return false }
    if a.kind != b.kind { return false }
    if a.kind == "ReturnStmt" {
        return exprs_match(a.left, b.left)
    }
    if a.kind == "ExprStmt" {
        return exprs_match(a.left, b.left)
    }
    if a.kind == "AssignStmt" {
        return exprs_match(a.left, b.left) && exprs_match(a.right, b.right)
    }
    if a.kind == "LetStmt" || a.kind == "LetMutStmt" {
        if a.name != b.name { return false }
        return exprs_match(a.left, b.left)
    }
    return false
}

fn exprs_match(a, b) {
    if type_of(a) == "string" && type_of(b) == "string" { return a == b }
    if type_of(a) == "string" || type_of(b) == "string" { return false }
    if a.kind != b.kind { return false }
    if a.kind == "IntLit" || a.kind == "FloatLit" || a.kind == "BoolLit" || a.kind == "StringLit" || a.kind == "CharLit" {
        return a.value == b.value
    }
    if a.kind == "Ident" { return a.name == b.name }
    if a.kind == "BinOp" {
        if a.op != b.op { return false }
        return exprs_match(a.left, b.left) && exprs_match(a.right, b.right)
    }
    if a.kind == "UnaryOp" {
        if a.op != b.op { return false }
        return exprs_match(a.left, b.left)
    }
    if a.kind == "Call" {
        if !exprs_match(a.left, b.left) { return false }
        if type_of(a.args) != "array" || type_of(b.args) != "array" { return false }
        if len(a.args) != len(b.args) { return false }
        let mut ci = 0
        while ci < len(a.args) {
            if !exprs_match(a.args[ci], b.args[ci]) { return false }
            ci = ci + 1
        }
        return true
    }
    return false
}

// Apply branch merging: hoist identical trailing stmts out of if/else
fn apply_branch_merge(body) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "IfStmt" {
            if type_of(stmt.then_body) == "array" && type_of(stmt.else_body) == "array" {
                let tlen = len(stmt.then_body)
                let elen = len(stmt.else_body)
                if tlen > 0 && elen > 0 {
                    let last_then = stmt.then_body[tlen - 1]
                    let last_else = stmt.else_body[elen - 1]
                    if stmts_match(last_then, last_else) {
                        // Hoist: remove last from both, push if, then push hoisted stmt
                        let mut new_then = []
                        let mut ti = 0
                        while ti < tlen - 1 {
                            new_then = new_then.push(stmt.then_body[ti])
                            ti = ti + 1
                        }
                        let mut new_else = []
                        let mut ei = 0
                        while ei < elen - 1 {
                            new_else = new_else.push(stmt.else_body[ei])
                            ei = ei + 1
                        }
                        let new_if = AstNode {
                            kind: "IfStmt", name: stmt.name, value: stmt.value, op: stmt.op,
                            left: stmt.left, right: stmt.right, cond: stmt.cond,
                            then_body: new_then, else_body: new_else,
                            params: "", body: "", args: "", fields: "", items: "",
                            variants: "", arms: "", iter_expr: "", ret_type: "",
                            target: "", trait_name: "", methods: ""
                        }
                        out = out.push(new_if)
                        out = out.push(last_then)
                        m976_branch_merge_candidates = m976_branch_merge_candidates + 1
                        i = i + 1
                        // skip normal push
                        continue
                    }
                }
            }
        }
        out = out.push(stmt)
        i = i + 1
    }
    return out
}

// ── M977: @compact enum — count enum variants for tag bit compression ──
// Given an EnumDecl node, computes minimum bits needed for tag.
fn min_bits_for_count(count) {
    if count <= 1 { return 1 }
    let mut bits = 0
    let mut v = count - 1
    while v > 0 {
        bits = bits + 1
        v = v / 2
    }
    return bits
}

fn body_increments_name_m311(body, target) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    let mut i = 0
    while i < n {
        let s = body[i]
        if s.kind == "AssignStmt" {
            let lhs = s.left
            let rhs = s.right
            if type_of(lhs) != "string" && type_of(rhs) != "string" {
                if lhs.kind == "Ident" && lhs.name == target {
                    if rhs.kind == "BinOp" && rhs.op == "+" {
                        if type_of(rhs.left) != "string" && rhs.left.kind == "Ident" && rhs.left.name == target {
                            return true
                        }
                    }
                }
            }
        }
        i = i + 1
    }
    return false
}

