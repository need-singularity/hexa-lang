                    left: "", right: "", cond: stmt.cond, then_body: "", else_body: new_else,
                    params: "", body: new_then, args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                })
            }
