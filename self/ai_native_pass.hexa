fn count_for_loops(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "LetMutStmt" && i + 1 < n {
            let init = stmt.left
            if type_of(init) != "string" && init.kind == "IntLit" {
                let nxt = body[i + 1]
                if nxt.kind == "WhileStmt" {
                    let cond = nxt.cond
                    if type_of(cond) != "string" && cond.kind == "BinOp" {
                        if cond.op == "<" || cond.op == "<=" {
                            if type_of(cond.left) != "string" && cond.left.kind == "Ident" && cond.left.name == stmt.name {
                                if body_increments_name_m311(nxt.body, stmt.name) { c = c + 1 }
                            }
                        }
                    }
                }
            }
        }
        i = i + 1
    }
    return c
}

fn count_passthrough_calls_expr(expr) {
    if type_of(expr) == "string" { return 0 }
    let mut c = 0
    if expr.kind == "Call" {
        let args = expr.args
        if type_of(args) == "array" && len(args) == 1 {
            let a0 = args[0]
            if type_of(a0) != "string" && a0.kind == "Ident" { c = c + 1 }
        }
        if type_of(args) == "array" {
            let an = len(args)
            let mut ai = 0
            while ai < an {
                c = c + count_passthrough_calls_expr(args[ai])
                ai = ai + 1
            }
        }
    }
    if expr.kind == "BinOp" {
        c = c + count_passthrough_calls_expr(expr.left)
        c = c + count_passthrough_calls_expr(expr.right)
    }
    if expr.kind == "UnaryOp" { c = c + count_passthrough_calls_expr(expr.left) }
    return c
}

fn count_passthrough_calls_body(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ReturnStmt" || k == "ExprStmt" || k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" {
            c = c + count_passthrough_calls_expr(stmt.left)
        }
        if k == "AssignStmt" { c = c + count_passthrough_calls_expr(stmt.right) }
        if k == "WhileStmt" { c = c + count_passthrough_calls_body(stmt.body) }
        i = i + 1
    }
    return c
}

fn body_has_return(body) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    let mut i = 0
    while i < n {
        if body[i].kind == "ReturnStmt" { return true }
        if body[i].kind == "WhileStmt" {
            if body_has_return(body[i].body) { return true }
        }
        i = i + 1
    }
    return false
}

fn detect_infinite_loops(body) {
    if type_of(body) != "array" { return 0 }
    let mut count = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "WhileStmt" {
            let c = stmt.cond
            // Cond is Ident X, body doesn't modify X, body has no return → infinite
            if type_of(c) != "string" && c.kind == "Ident" {
                if !name_assigned_in_body(stmt.body, c.name) {
                    if !body_has_return(stmt.body) {
                        count = count + 1
                    }
                }
            }
            // Cond is BoolLit true, body has no return → infinite
            if type_of(c) != "string" && c.kind == "BoolLit" && c.value == "true" {
                if !body_has_return(stmt.body) { count = count + 1 }
            }
            count = count + detect_infinite_loops(stmt.body)
        }
        i = i + 1
    }
    return count
}

fn expr_has_call(expr) {
    if type_of(expr) == "string" { return false }
    let k = expr.kind
    if k == "Call" { return true }
    if k == "BinOp" {
        if expr_has_call(expr.left) { return true }
        if expr_has_call(expr.right) { return true }
    }
    if k == "UnaryOp" { return expr_has_call(expr.left) }
    if k == "Index" {
        if expr_has_call(expr.left) { return true }
        if expr_has_call(expr.right) { return true }
    }
    return false
}

fn drop_dead_exprs(body) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let mut skip = false
        if stmt.kind == "ExprStmt" {
            if !expr_has_call(stmt.left) {
                skip = true
                m288_dead_exprs = m288_dead_exprs + 1
            }
        }
        if !skip { out = out.push(stmt) }
        i = i + 1
    }
    return out
}

fn eliminate_dead_assigns(body) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let mut skip = false
        if stmt.kind == "AssignStmt" {
            let lhs = stmt.left
            if type_of(lhs) != "string" && lhs.kind == "Ident" {
                if !remaining_uses_name(body, i + 1, lhs.name) {
                    skip = true
                    m275_dead_assigns = m275_dead_assigns + 1
                }
            }
        }
        if !skip { out = out.push(stmt) }
        i = i + 1
    }
    return out
}

fn collapse_while_returns(body) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let mut replaced = false
        if stmt.kind == "WhileStmt" {
            let c = stmt.cond
            if type_of(c) != "string" && c.kind == "BoolLit" && c.value == "true" {
                let wb = stmt.body
                if type_of(wb) == "array" && len(wb) >= 1 {
                    if wb[0].kind == "ReturnStmt" {
                        out = out.push(wb[0])
                        replaced = true
                        m274_while_to_return = m274_while_to_return + 1
                    }
                }
            }
        }
        if !replaced { out = out.push(stmt) }
        i = i + 1
    }
    return out
}

fn count_uses_in_body(body, target) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ReturnStmt" || k == "ExprStmt" || k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" || k == "AssertStmt" {
            if expr_uses_name(stmt.left, target) { c = c + 1 }
        }
        if k == "AssignStmt" {
            if expr_uses_name(stmt.right, target) { c = c + 1 }
        }
        if k == "WhileStmt" {
            if expr_uses_name(stmt.cond, target) { c = c + 1 }
            c = c + count_uses_in_body(stmt.body, target)
        }
        i = i + 1
    }
    return c
}

fn forward_returns(body) {
    if type_of(body) != "array" { return body }
    let n = len(body)
    if n < 2 { return body }
    let last_idx = n - 1
    let last = body[last_idx]
    if last.kind != "ReturnStmt" { return body }
    let ret_e = last.left
    if type_of(ret_e) == "string" { return body }
    if ret_e.kind != "Ident" { return body }
    let target_name = ret_e.name
    let prev = body[last_idx - 1]
    // M273: LetStmt; M287: ConstStmt
    if prev.kind != "LetStmt" && prev.kind != "ConstStmt" { return body }
    if prev.name != target_name { return body }
    // Check single use
    if count_uses_in_body(body, target_name) != 1 { return body }
    // Rewrite: drop let, replace return with init
    let new_ret = AstNode {
        kind: "ReturnStmt", name: "", value: "", op: "",
        left: prev.left, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
    let mut out = []
    let mut i = 0
    while i < last_idx - 1 {
        out = out.push(body[i])
        i = i + 1
    }
    out = out.push(new_ret)
    m273_return_fwd = m273_return_fwd + 1
    return out
}

fn eliminate_self_assigns(body) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let mut skip = false
        if stmt.kind == "AssignStmt" {
            let lhs = stmt.left
            let rhs = stmt.right
            if type_of(lhs) != "string" && type_of(rhs) != "string" {
                if lhs.kind == "Ident" && rhs.kind == "Ident" && lhs.name == rhs.name {
                    skip = true
                    m272_self_assigns = m272_self_assigns + 1
                }
            }
        }
        if !skip { out = out.push(stmt) }
        i = i + 1
    }
    return out
}

fn name_assigned_in_body(body, target) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "AssignStmt" {
            let lhs = stmt.left
            if type_of(lhs) != "string" && lhs.kind == "Ident" && lhs.name == target {
                return true
            }
        }
        if stmt.kind == "WhileStmt" {
            if name_assigned_in_body(stmt.body, target) { return true }
        }
        i = i + 1
    }
    return false
}

fn convert_mut_to_let(body) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "LetMutStmt" && !name_assigned_in_body(body, stmt.name) {
            m271_mut_to_let = m271_mut_to_let + 1
            out = out.push(AstNode {
                kind: "LetStmt", name: stmt.name, value: stmt.value, op: "",
                left: stmt.left, right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            })
        } else {
            out = out.push(stmt)
        }
        i = i + 1
    }
    return out
}

fn propagate_copies_body(body) {
    if type_of(body) != "array" { return body }
    let mut copy_names = []   // alias name
    let mut copy_targets = [] // original Ident node
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "LetStmt" || k == "LetMutStmt" {
            let init = stmt.left
            if type_of(init) != "string" && init.kind == "Ident" {
                copy_names = copy_names.push(stmt.name)
                copy_targets = copy_targets.push(init)
            }
            out = out.push(stmt)
        } else {
            if k == "AssignStmt" {
                // Kill on reassign
                let lhs = stmt.left
                if type_of(lhs) != "string" && lhs.kind == "Ident" {
                    let cn = len(copy_names)
                    let mut nn = []
                    let mut nt = []
                    let mut j = 0
                    while j < cn {
                        if copy_names[j] != lhs.name {
                            nn = nn.push(copy_names[j])
                            nt = nt.push(copy_targets[j])
                        }
                        j = j + 1
                    }
                    copy_names = nn
                    copy_targets = nt
                }
                let new_r = propagate_expr(stmt.right, copy_names, copy_targets)
                out = out.push(AstNode {
                    kind: "AssignStmt", name: "", value: "", op: "",
                    left: stmt.left, right: new_r, cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                })
            } else {
                if k == "WhileStmt" {
                    copy_names = []
                    copy_targets = []
                    out = out.push(stmt)
                } else {
                    if k == "ReturnStmt" || k == "ExprStmt" || k == "ConstStmt" {
                        let new_e = propagate_expr(stmt.left, copy_names, copy_targets)
                        // Count copy substitutions separately by checking
                        out = out.push(AstNode {
                            kind: k, name: stmt.name, value: stmt.value, op: "",
                            left: new_e, right: "", cond: "", then_body: "", else_body: "",
                            params: "", body: "", args: "", fields: "", items: "",
                            variants: "", arms: "", iter_expr: "", ret_type: "",
                            target: "", trait_name: "", methods: ""
                        })
                    } else {
                        out = out.push(stmt)
                    }
                }
            }
        }
        i = i + 1
    }
    return out
}
// M252: @contract auto pre-assert injection
let mut m252_contract_injects = 0
// M253b: @contract compile-time provability — runtime check elimination
let mut m253b_contract_elims = 0
// M480: @symbolic strength reduction (x*pow2 → x<<N, x/pow2 → x>>N, x%pow2 → x&(N-1))
let mut m480_symbolic_rewrites = 0
// M481b: @symbolic x*2 → x+x rewrites
let mut m481b_symbolic_mul2 = 0
// M481c: @symbolic x**2 → x*x rewrites
let mut m481c_symbolic_pow2 = 0
// M481: @fuse call-chain depth (max nested Call depth per @fuse fn)
let mut m481_fuse_chain_max = 0
// M482: @fuse candidate count (fns with chain depth >= 2)
let mut m482_fuse_candidates = 0
// M960: @fuse actual intermediate variable elimination rewrites
let mut m960_fuse_rewrites = 0
// M965: @fuse map/filter chain → single-loop AST rewrites
let mut m965_mapfilter_fused = 0
// M974: @fuse map/filter/reduce chain → single-loop AST rewrites (ROI id=4)
let mut m974_reduce_fused = 0
// M975: constant folding — string concat folding (ROI id=5)
let mut m975_string_concat_folds = 0
// M976: constant folding — len() folding on literals (ROI id=5)
let mut m976_len_folds = 0
// M977: strength reduction — x/2→x>>1, x%2→x&1, x*2→x<<1 (ROI id=13)
let mut m977_strength_small = 0
// M978: strength reduction — loop index multiply → accumulate (ROI id=13)
let mut m978_loop_stride = 0
// M253: cross-fn inlining (const-return stubs + identity fns)
let mut m253_inlined_calls = 0
// Inlining tables (parallel arrays)
let mut m253_stub_names = []
let mut m253_stub_lits = []   // AstNode literal value
let mut m253_id_names = []
let mut m253_id_param0 = []   // first param name

// Inline a Call expression if matches a known stub or identity
fn inline_expr(expr) {
    if type_of(expr) == "string" { return expr }
    let k = expr.kind
    if k == "Call" {
        let callee = expr.left
        if type_of(callee) != "string" {
            if callee.kind == "Ident" {
                let cname = callee.name
                // Check stub table first
                let sn = len(m253_stub_names)
                let mut si = 0
                while si < sn {
                    if m253_stub_names[si] == cname {
                        m253_inlined_calls = m253_inlined_calls + 1
                        return m253_stub_lits[si]
                    }
                    si = si + 1
                }
                // Check identity table — replace with first arg
                let idn = len(m253_id_names)
                let mut ii = 0
                while ii < idn {
                    if m253_id_names[ii] == cname {
                        let args = expr.args
                        if type_of(args) == "array" && len(args) >= 1 {
                            m253_inlined_calls = m253_inlined_calls + 1
                            return inline_expr(args[0])
                        }
                    }
                    ii = ii + 1
                }
            }
        }
        // Recurse into args (other calls may inline)
        let args = expr.args
        let mut new_args = []
        if type_of(args) == "array" {
            let an = len(args)
            let mut ai = 0
            while ai < an {
                new_args = new_args.push(inline_expr(args[ai]))
                ai = ai + 1
            }
        }
        return AstNode {
            kind: "Call", name: "", value: "", op: "",
            left: expr.left, right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: new_args, fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    if k == "BinOp" {
        let nl = inline_expr(expr.left)
        let nr = inline_expr(expr.right)
        return AstNode {
            kind: "BinOp", name: "", value: "", op: expr.op,
            left: nl, right: nr, cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    if k == "UnaryOp" {
        let no = inline_expr(expr.left)
        return AstNode {
            kind: "UnaryOp", name: "", value: "", op: expr.op,
            left: no, right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    return expr
}

fn inline_body(body) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ReturnStmt" || k == "ExprStmt" || k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" {
            let new_e = inline_expr(stmt.left)
            out = out.push(AstNode {
                kind: k, name: stmt.name, value: stmt.value, op: "",
                left: new_e, right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            })
        } else {
            if k == "AssignStmt" {
                let new_r = inline_expr(stmt.right)
                out = out.push(AstNode {
                    kind: "AssignStmt", name: "", value: "", op: "",
                    left: stmt.left, right: new_r, cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                })
            } else {
                out = out.push(stmt)
            }
        }
        i = i + 1
    }
    return out
}

fn make_contract_assert(param_name) {
    // Build: assert param_name != 0
    let lhs = AstNode {
        kind: "Ident", name: param_name, value: "", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
    let zero = make_int_lit(0)
    let cond = AstNode {
        kind: "BinOp", name: "", value: "", op: "!=",
        left: lhs, right: zero, cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
    return AstNode {
        kind: "AssertStmt", name: "", value: "", op: "",
        left: cond, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

// Check if body already starts with our injected assert (idempotence)
fn body_has_contract_assert(body, param_name) {
    if type_of(body) != "array" { return false }
    if len(body) == 0 { return false }
    let s = body[0]
    if s.kind != "AssertStmt" { return false }
    let c = s.left
    if type_of(c) == "string" { return false }
    if c.kind != "BinOp" { return false }
    if c.op != "!=" { return false }
    if type_of(c.left) == "string" { return false }
    if c.left.kind != "Ident" { return false }
    return c.left.name == param_name
}

fn inject_contract_assert(body, param_name) {
    if body_has_contract_assert(body, param_name) { return body }
    let mut out = []
    out = out.push(make_contract_assert(param_name))
    if type_of(body) == "array" {
        let n = len(body)
        let mut i = 0
        while i < n {
            out = out.push(body[i])
            i = i + 1
        }
    }
    return out
}

// ── M253b: @contract compile-time provability ─────────────────────────
// Attempt to prove a ContractAssert condition is always true given
// compile-time information. If provable, the runtime assert is elided.
//
// Currently handles:
//   (a) Trivially-true conditions: BoolLit "true"
//   (b) Constant comparisons: IntLit op IntLit that evaluate to true
//   (c) Tautologies: x == x, x <= x, x >= x
//   (d) Implied by param type: (for future extension)
fn contract_cond_provably_true(cond) {
    if type_of(cond) == "string" { return false }
    // (a) literal true
    if cond.kind == "BoolLit" && cond.value == "true" { return true }
    // (b) constant int comparison
    if cond.kind == "BinOp" {
        let l = cond.left
        let r = cond.right
        if type_of(l) != "string" && type_of(r) != "string" {
            if l.kind == "IntLit" && r.kind == "IntLit" {
                let lv = parse_int_str(l.value)
                let rv = parse_int_str(r.value)
                let op = cond.op
                if op == ">" { return lv > rv }
                if op == ">=" { return lv >= rv }
                if op == "<" { return lv < rv }
                if op == "<=" { return lv <= rv }
                if op == "==" { return lv == rv }
                if op == "!=" { return lv != rv }
            }
            // (c) tautology: same ident on both sides
            if l.kind == "Ident" && r.kind == "Ident" && l.name == r.name {
                let op = cond.op
                if op == "==" || op == "<=" || op == ">=" { return true }
            }
        }
        // (d) && — both sides must be provably true
        if cond.op == "&&" {
            return contract_cond_provably_true(cond.left) && contract_cond_provably_true(cond.right)
        }
        // || — either side provably true suffices
        if cond.op == "||" {
            return contract_cond_provably_true(cond.left) || contract_cond_provably_true(cond.right)
        }
    }
    return false
}

// Eliminate provably-true ContractAssert nodes from a body.
// Returns [new_body, elim_count].
fn contract_elim_body(body) {
    if type_of(body) != "array" { return [body, 0] }
    let mut out = []
    let mut elims = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "ContractAssert" {
            if contract_cond_provably_true(stmt.left) {
                // Provably true — elide
                elims = elims + 1
            } else {
                out = out.push(stmt)
            }
        } else {
            if stmt.kind == "IfStmt" || stmt.kind == "IfExpr" {
                // Recurse into branches
                let then_r = contract_elim_body(stmt.then_body)
                let else_r = contract_elim_body(stmt.else_body)
                elims = elims + then_r[1] + else_r[1]
                out = out.push(AstNode {
                    kind: stmt.kind, name: stmt.name, value: stmt.value, op: stmt.op,
                    left: stmt.left, right: stmt.right, cond: stmt.cond,
                    then_body: then_r[0], else_body: else_r[0],
                    params: stmt.params, body: stmt.body, args: stmt.args, fields: stmt.fields, items: stmt.items,
                    variants: stmt.variants, arms: stmt.arms, iter_expr: stmt.iter_expr, ret_type: stmt.ret_type,
                    target: stmt.target, trait_name: stmt.trait_name, methods: stmt.methods
                })
            } else {
                out = out.push(stmt)
            }
        }
        i = i + 1
    }
    return [out, elims]
}

// Check if expression references an identifier by name (recursive)
fn expr_uses_name(expr, target) {
    if type_of(expr) == "string" { return false }
    let k = expr.kind
    if k == "Ident" { return expr.name == target }
    if k == "BinOp" {
        if expr_uses_name(expr.left, target) { return true }
        if expr_uses_name(expr.right, target) { return true }
        return false
    }
    if k == "UnaryOp" { return expr_uses_name(expr.left, target) }
    if k == "Call" {
        if expr_uses_name(expr.left, target) { return true }
        let args = expr.args
        if type_of(args) == "array" {
            let an = len(args)
            let mut ai = 0
            while ai < an {
                if expr_uses_name(args[ai], target) { return true }
                ai = ai + 1
            }
        }
        return false
    }
    return false
}

// Check if any stmt in remaining body references name
fn remaining_uses_name(body, from_idx, target) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    let mut i = from_idx
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ReturnStmt" || k == "ExprStmt" || k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" || k == "AssertStmt" {
            if expr_uses_name(stmt.left, target) { return true }
        }
        if k == "AssignStmt" {
            // LHS use = kill, skip; RHS use = true
            if expr_uses_name(stmt.right, target) { return true }
            if type_of(stmt.left) != "string" && stmt.left.kind == "Ident" && stmt.left.name == target {
                // Name is reassigned — original binding is dead if no prior use
                return false
            }
        }
        if k == "WhileStmt" {
            if expr_uses_name(stmt.cond, target) { return true }
            if remaining_uses_name(stmt.body, 0, target) { return true }
        }
        i = i + 1
    }
    return false
}

// Drop Let/LetMut stmts whose bound name is never used subsequently
fn eliminate_dead_stores(body) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        let mut keep = true
        if k == "LetStmt" || k == "LetMutStmt" {
            // Drop if name is never used later
            if !remaining_uses_name(body, i + 1, stmt.name) {
                keep = false
                m251_dead_stores = m251_dead_stores + 1
            }
        }
        if keep { out = out.push(stmt) }
        i = i + 1
    }
    return out
}

// Walk expression substituting Ident → literal when tracked
fn propagate_expr(expr, names, vals) {
    if type_of(expr) == "string" { return expr }
    let k = expr.kind
    if k == "Ident" {
        let n = len(names)
        let mut i = 0
        while i < n {
            if names[i] == expr.name {
                m250_const_prop = m250_const_prop + 1
                return vals[i]
            }
            i = i + 1
        }
        return expr
    }
    if k == "BinOp" {
        let nl = propagate_expr(expr.left, names, vals)
        let nr = propagate_expr(expr.right, names, vals)
        return AstNode {
            kind: "BinOp", name: "", value: "", op: expr.op,
            left: nl, right: nr, cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    if k == "UnaryOp" {
        let no = propagate_expr(expr.left, names, vals)
        return AstNode {
            kind: "UnaryOp", name: "", value: "", op: expr.op,
            left: no, right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    if k == "Call" {
        let args = expr.args
        let mut new_args = []
        if type_of(args) == "array" {
            let an = len(args)
            let mut ai = 0
            while ai < an {
                new_args = new_args.push(propagate_expr(args[ai], names, vals))
                ai = ai + 1
            }
        }
        return AstNode {
            kind: "Call", name: "", value: "", op: "",
            left: expr.left, right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: new_args, fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    return expr
}

// Forward pass: track immutable let bindings to literal values
fn propagate_consts_body(body) {
    if type_of(body) != "array" { return body }
    let mut names = []
    let mut vals = []
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "LetStmt" || k == "ConstStmt" {
            // M250/M291: Record (name, lit) if init is literal (Let/Const)
            let init = stmt.left
            if type_of(init) != "string" {
                if is_literal_kind(init.kind) {
                    names = names.push(stmt.name)
                    vals = vals.push(init)
                }
            }
            out = out.push(stmt)
        } else {
            if k == "LetMutStmt" {
                // M289: track let mut with literal init until killed
                let init2 = stmt.left
                if type_of(init2) != "string" && is_literal_kind(init2.kind) {
                    names = names.push(stmt.name)
                    vals = vals.push(init2)
                }
                out = out.push(stmt)
            } else {
                if k == "AssignStmt" {
                    // LHS modified — drop from consts
                    let lhs = stmt.left
                    if type_of(lhs) != "string" && lhs.kind == "Ident" {
                        let nn = len(names)
                        let mut nn_new = []
                        let mut vv_new = []
                        let mut j = 0
                        while j < nn {
                            if names[j] != lhs.name {
                                nn_new = nn_new.push(names[j])
                                vv_new = vv_new.push(vals[j])
                            }
                            j = j + 1
                        }
                        names = nn_new
                        vals = vv_new
                    }
                    // propagate RHS
                    let new_r = propagate_expr(stmt.right, names, vals)
                    out = out.push(AstNode {
                        kind: "AssignStmt", name: "", value: "", op: "",
                        left: stmt.left, right: new_r, cond: "", then_body: "", else_body: "",
                        params: "", body: "", args: "", fields: "", items: "",
                        variants: "", arms: "", iter_expr: "", ret_type: "",
                        target: "", trait_name: "", methods: ""
                    })
                } else {
                    if k == "WhileStmt" {
                        // Safety: clear consts at loop boundary
                        names = []
                        vals = []
                        out = out.push(stmt)
                    } else {
                        if k == "ReturnStmt" || k == "ExprStmt" || k == "ConstStmt" {
                            let new_e = propagate_expr(stmt.left, names, vals)
                            out = out.push(AstNode {
                                kind: k, name: stmt.name, value: stmt.value, op: "",
                                left: new_e, right: "", cond: "", then_body: "", else_body: "",
                                params: "", body: "", args: "", fields: "", items: "",
                                variants: "", arms: "", iter_expr: "", ret_type: "",
                                target: "", trait_name: "", methods: ""
                            })
                        } else {
                            out = out.push(stmt)
                        }
                    }
                }
            }
        }
        i = i + 1
    }
    return out
}
// M179: single-stmt fn count (any kind)
let mut m179_single_stmt = 0
// M141: param count histogram
let mut m141_p0 = 0
let mut m141_p1 = 0
let mut m141_p2 = 0
let mut m141_p3plus = 0
// M144/M145: complex fn count + high complexity warnings
let mut m144_complex_fns = 0
let mut m145_high_cplx_warn = 0
// M146: max param name length
let mut m146_max_param_name = 0
// M147: total param name chars
let mut m147_total_param_chars = 0

fn count_nodes_expr(expr) {
    if type_of(expr) == "string" { return 0 }
    let mut c = 1
    if expr.kind == "BinOp" {
        c = c + count_nodes_expr(expr.left)
        c = c + count_nodes_expr(expr.right)
    }
    if expr.kind == "UnaryOp" { c = c + count_nodes_expr(expr.left) }
    if expr.kind == "Call" {
        c = c + count_nodes_expr(expr.left)
        let args = expr.args
        if type_of(args) == "array" {
            let an4 = len(args)
            let mut qi = 0
            while qi < an4 {
                c = c + count_nodes_expr(args[qi])
                qi = qi + 1
            }
        }
    }
    return c
}

fn count_nodes_body(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        c = c + 1
        let stmt = body[i]
        let k = stmt.kind
        if k == "ReturnStmt" || k == "ExprStmt" || k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" || k == "AssertStmt" {
            c = c + count_nodes_expr(stmt.left)
        }
        if k == "AssignStmt" {
            c = c + count_nodes_expr(stmt.left)
            c = c + count_nodes_expr(stmt.right)
        }
        if k == "WhileStmt" {
            c = c + count_nodes_expr(stmt.cond)
            c = c + count_nodes_body(stmt.body)
        }
        i = i + 1
    }
    return c
}
// M124: max memoize score observed
let mut m124_max_memoize_score = 0
// M125: ideal helper = @pure + identity
let mut m125_ideal_helpers = 0
// M104: constant-folded assertions
let mut m104_const_assert_true = 0
let mut m104_const_assert_false = 0
// M116: assert(true) elimination
let mut m116_assert_elim = 0

fn eliminate_trivial_asserts(body) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let mut skip_it = false
        if stmt.kind == "AssertStmt" {
            let e = stmt.left
            if type_of(e) != "string" {
                if e.kind == "BoolLit" && e.value == "true" {
                    skip_it = true
                    m116_assert_elim = m116_assert_elim + 1
                }
            }
        }
        if !skip_it { out = out.push(stmt) }
        i = i + 1
    }
    return out
}
// M105: @pure + @inline combo
let mut m105_pure_inline_combo = 0

fn count_shape_expr(expr) {
    if type_of(expr) == "string" { return }
    let k = expr.kind
    if k == "Array" { m101_arrays = m101_arrays + 1 }
    if k == "Index" { m102_indexes = m102_indexes + 1 }
    if k == "Field" { m103_fields = m103_fields + 1 }
    if k == "BinOp" {
        m122_binops = m122_binops + 1
        // M127: track unique operator
        if !name_in_registry(expr.op, m127_op_set) {
            m127_op_set = m127_op_set.push(expr.op)
        }
        count_shape_expr(expr.left)
        count_shape_expr(expr.right)
    }
    if k == "UnaryOp" {
        m123_unaryops = m123_unaryops + 1
        if !name_in_registry(expr.op, m128_uop_set) {
            m128_uop_set = m128_uop_set.push(expr.op)
        }
        count_shape_expr(expr.left)
    }
    if k == "Call" {
        count_shape_expr(expr.left)
        let args = expr.args
        if type_of(args) == "array" {
            let an3 = len(args)
            if an3 > m171_max_call_args { m171_max_call_args = an3 }
            m172_total_call_args = m172_total_call_args + an3
            let mut ci = 0
            while ci < an3 {
                count_shape_expr(args[ci])
                ci = ci + 1
            }
        }
    }
    if k == "Index" { count_shape_expr(expr.left) }
    if k == "Field" { count_shape_expr(expr.left) }
}

fn count_shape_body(body) {
    if type_of(body) != "array" { return }
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "AssertStmt" { m100_asserts = m100_asserts + 1 }
        if k == "ReturnStmt" || k == "ExprStmt" || k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" || k == "AssertStmt" {
            count_shape_expr(stmt.left)
        }
        if k == "AssignStmt" {
            count_shape_expr(stmt.left)
            count_shape_expr(stmt.right)
        }
        if k == "WhileStmt" {
            count_shape_expr(stmt.cond)
            count_shape_body(stmt.body)
        }
        i = i + 1
    }
}

fn is_identity_fn(body, params) {
    if type_of(body) != "array" { return false }
    if len(body) != 1 { return false }
    if len(params) == 0 { return false }
    let s = body[0]
    if s.kind != "ReturnStmt" { return false }
    let e = s.left
    if type_of(e) == "string" { return false }
    if e.kind != "Ident" { return false }
    return e.name == params[0].name
}

fn is_trivial_wrapper(body, self_name) {
    if type_of(body) != "array" { return false }
    if len(body) != 1 { return false }
    let s = body[0]
    if s.kind != "ReturnStmt" { return false }
    let e = s.left
    if type_of(e) == "string" { return false }
    if e.kind != "Call" { return false }
    let callee = e.left
    if type_of(callee) == "string" { return false }
    if callee.kind != "Ident" { return false }
    return callee.name != self_name
}

fn extract_bounded_value(attr) {
    let chars = attr.chars()
    let n = len(chars)
    let mut i = 0
    let mut found_colon = false
    let mut num_str = ""
    while i < n {
        let c = to_string(chars[i])
        if found_colon { num_str = num_str + c }
        if c == ":" { found_colon = true }
        i = i + 1
    }
    if !found_colon { return -1 }
    return parse_int_str(num_str)
}

fn name_in_registry(name, registry) {
    let n = len(registry)
    let mut i = 0
    while i < n {
        if registry[i] == name { return true }
        i = i + 1
    }
    return false
}

fn count_cross_calls_expr(expr, registry) {
    if type_of(expr) == "string" { return 0 }
    let mut c = 0
    if expr.kind == "Call" {
        let callee = expr.left
        if type_of(callee) != "string" {
            if callee.kind == "Ident" {
                if name_in_registry(callee.name, registry) { c = c + 1 }
            }
        }
        let args = expr.args
        if type_of(args) == "array" {
            let an2 = len(args)
            let mut ai = 0
            while ai < an2 {
                c = c + count_cross_calls_expr(args[ai], registry)
                ai = ai + 1
            }
        }
    }
    if expr.kind == "BinOp" {
        c = c + count_cross_calls_expr(expr.left, registry)
        c = c + count_cross_calls_expr(expr.right, registry)
    }
    if expr.kind == "UnaryOp" {
        c = c + count_cross_calls_expr(expr.left, registry)
    }
    return c
}

fn count_cross_calls_body(body, registry) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ReturnStmt" || k == "ExprStmt" || k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" {
            c = c + count_cross_calls_expr(stmt.left, registry)
        }
        if k == "AssignStmt" {
            c = c + count_cross_calls_expr(stmt.right, registry)
        }
        if k == "WhileStmt" {
            c = c + count_cross_calls_expr(stmt.cond, registry)
            c = c + count_cross_calls_body(stmt.body, registry)
        }
        i = i + 1
    }
    return c
}

fn count_stmt_kinds(body) {
    if type_of(body) != "array" { return }
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "WhileStmt" {
            m50_while_count = m50_while_count + 1
            count_stmt_kinds(stmt.body)
        }
        if k == "LetStmt" || k == "LetMutStmt" { m51_let_count = m51_let_count + 1 }
        if k == "AssignStmt" { m52_assign_count = m52_assign_count + 1 }
        i = i + 1
    }
}

fn count_returns_body(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "ReturnStmt" { c = c + 1 }
        if stmt.kind == "WhileStmt" { c = c + count_returns_body(stmt.body) }
        i = i + 1
    }
    return c
}

fn count_idents_expr(expr) {
    if type_of(expr) == "string" { return }
    if expr.kind == "Ident" { m47_ident_refs = m47_ident_refs + 1 }
    if expr.kind == "BinOp" {
        count_idents_expr(expr.left)
        count_idents_expr(expr.right)
    }
    if expr.kind == "UnaryOp" { count_idents_expr(expr.left) }
    if expr.kind == "Call" {
        count_idents_expr(expr.left)
        let args = expr.args
        if type_of(args) == "array" {
            let n = len(args)
            let mut i = 0
            while i < n {
                count_idents_expr(args[i])
                i = i + 1
            }
        }
    }
}

fn count_idents_body(body) {
    if type_of(body) != "array" { return }
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ReturnStmt" || k == "ExprStmt" || k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" {
            count_idents_expr(stmt.left)
        }
        if k == "AssignStmt" {
            count_idents_expr(stmt.left)
            count_idents_expr(stmt.right)
        }
        if k == "WhileStmt" {
            count_idents_expr(stmt.cond)
            count_idents_body(stmt.body)
        }
        i = i + 1
    }
}

fn expr_binop_depth(expr) {
    if type_of(expr) == "string" { return 0 }
    if expr.kind != "BinOp" { return 0 }
    let ld = expr_binop_depth(expr.left)
    let rd = expr_binop_depth(expr.right)
    let mx = ld
    if rd > mx { mx = rd }
    return 1 + mx
}

fn count_lits_expr(expr) {
    if type_of(expr) == "string" { return }
    if expr.kind == "IntLit" { m44_int_lit_count = m44_int_lit_count + 1 }
    if expr.kind == "BoolLit" { m45_bool_lit_count = m45_bool_lit_count + 1 }
    if expr.kind == "StringLit" { m129_string_lits = m129_string_lits + 1 }
    if expr.kind == "CharLit" { m130_char_lits = m130_char_lits + 1 }
    if expr.kind == "BinOp" {
        count_lits_expr(expr.left)
        count_lits_expr(expr.right)
    }
    if expr.kind == "UnaryOp" {
        count_lits_expr(expr.left)
    }
    if expr.kind == "Call" {
        let args = expr.args
        if type_of(args) == "array" {
            let n = len(args)
            let mut i = 0
            while i < n {
                count_lits_expr(args[i])
                i = i + 1
            }
        }
    }
}

fn count_lits_body(body) {
    if type_of(body) != "array" { return }
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ReturnStmt" || k == "ExprStmt" || k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" {
            count_lits_expr(stmt.left)
        }
        if k == "AssignStmt" { count_lits_expr(stmt.right) }
        if k == "WhileStmt" {
            count_lits_expr(stmt.cond)
            count_lits_body(stmt.body)
        }
        i = i + 1
    }
}

fn max_binop_depth_body(body) {
    if type_of(body) != "array" { return 0 }
    let mut mx = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        let mut d = 0
        if k == "ReturnStmt" || k == "ExprStmt" || k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" {
            d = expr_binop_depth(stmt.left)
        }
        if k == "AssignStmt" { d = expr_binop_depth(stmt.right) }
        if k == "WhileStmt" {
            let dc = expr_binop_depth(stmt.cond)
            let db = max_binop_depth_body(stmt.body)
            if dc > d { d = dc }
            if db > d { d = db }
        }
        if d > mx { mx = d }
        i = i + 1
    }
    return mx
}

fn str_hash(s) {
    let chars = s.chars()
    let n = len(chars)
    let mut h = 0
    let mut i = 0
    while i < n {
        let c = to_string(chars[i])
        let d = digit_val(c)
        if d >= 0 {
            h = h * 31 + d
        } else {
            // Non-digit: use length contribution (cheap fallback)
            h = h * 31 + n
        }
        i = i + 1
    }
    return h
}
// M37: stub fns (body is just `return <literal>`)
let mut m37_stubs = 0
// M38: attr count histogram
let mut m38_one = 0
let mut m38_two = 0
let mut m38_three = 0
let mut m38_four_plus = 0
// M39: total params + zero-param fns + max arity
let mut m39_param_sum = 0
let mut m39_zero_arg = 0
let mut m39_max_arity = 0

fn is_bool_true(e) {
    if type_of(e) == "string" { return false }
    if e.kind != "BoolLit" { return false }
    return e.value == "true"
}

fn is_bool_false(e) {
    if type_of(e) == "string" { return false }
    if e.kind != "BoolLit" { return false }
    return e.value == "false"
}

fn make_bool_lit_from_bool(b) {
    let v = "false"
    if b { v = "true" }
    return AstNode {
        kind: "BoolLit", name: "", value: v, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn digit_val(c) {
    if c == "0" { return 0 }
    if c == "1" { return 1 }
    if c == "2" { return 2 }
    if c == "3" { return 3 }
    if c == "4" { return 4 }
    if c == "5" { return 5 }
    if c == "6" { return 6 }
    if c == "7" { return 7 }
    if c == "8" { return 8 }
    if c == "9" { return 9 }
    return -1
}

fn parse_int_str(s) {
    let chars = s.chars()
    let n = len(chars)
    if n == 0 { return -1 }
    let mut i = 0
    let mut result = 0
    let mut neg = false
    if to_string(chars[0]) == "-" {
        neg = true
        i = 1
    }
    while i < n {
        let d = digit_val(to_string(chars[i]))
        if d < 0 { return -1 }
        result = result * 10 + d
        i = i + 1
    }
    if neg { return 0 - result }
    return result
}

fn make_int_lit(n) {
    return AstNode {
        kind: "IntLit", name: "", value: to_string(n), op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn same_ident(a, b) {
    if type_of(a) == "string" { return false }
    if type_of(b) == "string" { return false }
    if a.kind != "Ident" { return false }
    if b.kind != "Ident" { return false }
    return a.name == b.name
}

// M113: complementary pair detection
fn is_not_of(not_expr, ident_expr) {
    if type_of(not_expr) == "string" { return false }
    if type_of(ident_expr) == "string" { return false }
    if not_expr.kind != "UnaryOp" { return false }
    if not_expr.op != "!" { return false }
    return same_ident(not_expr.left, ident_expr)
}

fn is_int_zero(e) {
    if type_of(e) == "string" { return false }
    if e.kind != "IntLit" { return false }
    return e.value == "0"
}

fn is_int_one(e) {
    if type_of(e) == "string" { return false }
    if e.kind != "IntLit" { return false }
    return e.value == "1"
}

// @symbolic helpers: power-of-two detection and log2
fn is_power_of_two(n) {
    if n < 2 { return false }
    let mut v = n
    while v > 1 {
        if v % 2 != 0 { return false }
        v = v / 2
    }
    return true
}

fn log2_of(n) {
    let mut v = n
    let mut r = 0
    while v > 1 {
        v = v / 2
        r = r + 1
    }
    return r
}

// @fuse helper: measure max nested Call depth in an expression
fn call_chain_depth(expr) {
    if type_of(expr) == "string" { return 0 }
    if expr.kind == "Call" {
        // depth = 1 + max depth of args (look at first arg for chain pattern)
        let callee_depth = call_chain_depth(expr.left)
        let mut max_arg = 0
        if type_of(expr.args) == "array" {
            let n = len(expr.args)
            let mut i = 0
            while i < n {
                let d = call_chain_depth(expr.args[i])
                if d > max_arg { max_arg = d }
                i = i + 1
            }
        }
        let inner = callee_depth
        if max_arg > inner { return 1 + max_arg }
        return 1 + inner
    }
    if expr.kind == "BinOp" {
        let ld = call_chain_depth(expr.left)
        let rd = call_chain_depth(expr.right)
        if ld > rd { return ld }
        return rd
    }
    if expr.kind == "UnaryOp" { return call_chain_depth(expr.left) }
    return 0
}

// @fuse: max call chain depth across all statements in a body
fn body_max_call_chain(body) {
    if type_of(body) != "array" { return 0 }
    let mut mx = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let mut d = 0
        if stmt.kind == "ReturnStmt" { d = call_chain_depth(stmt.left) }
        if stmt.kind == "ExprStmt" { d = call_chain_depth(stmt.left) }
        if stmt.kind == "LetStmt" { d = call_chain_depth(stmt.left) }
        if stmt.kind == "LetMutStmt" { d = call_chain_depth(stmt.left) }
        if stmt.kind == "AssignStmt" { d = call_chain_depth(stmt.left) }
        if stmt.kind == "WhileStmt" {
            let wd = body_max_call_chain(stmt.body)
            if wd > d { d = wd }
        }
        if d > mx { mx = d }
        i = i + 1
    }
    return mx
}

// ── M960: @fuse intermediate variable elimination (AST rewrite) ──────────────
// Pattern: let temp = expr1; <next stmt uses temp exactly once> → inline expr1
// Handles: (a) single intermediate elimination, (b) chain fusion a→b→c → a→c,
//          (c) map-filter fusion via repeated application of single-step elimination.

// Substitute all occurrences of Ident(target) with replacement expr inside an expression
fn substitute_in_expr(expr, target, replacement) {
    if type_of(expr) == "string" { return expr }
    let k = expr.kind
    if k == "Ident" {
        if expr.name == target { return replacement }
        return expr
    }
    if k == "BinOp" {
        let new_l = substitute_in_expr(expr.left, target, replacement)
        let new_r = substitute_in_expr(expr.right, target, replacement)
        return AstNode {
            kind: "BinOp", name: expr.name, value: expr.value, op: expr.op,
            left: new_l, right: new_r, cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    if k == "UnaryOp" {
        let new_l = substitute_in_expr(expr.left, target, replacement)
        return AstNode {
            kind: "UnaryOp", name: expr.name, value: expr.value, op: expr.op,
            left: new_l, right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    if k == "Call" {
        let new_callee = substitute_in_expr(expr.left, target, replacement)
        let mut new_args = []
        if type_of(expr.args) == "array" {
            let an = len(expr.args)
            let mut ai = 0
            while ai < an {
                new_args = new_args.push(substitute_in_expr(expr.args[ai], target, replacement))
                ai = ai + 1
            }
        }
        return AstNode {
            kind: "Call", name: expr.name, value: expr.value, op: "",
            left: new_callee, right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: new_args, fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    if k == "Index" {
        let new_l = substitute_in_expr(expr.left, target, replacement)
        let new_r = substitute_in_expr(expr.right, target, replacement)
        return AstNode {
            kind: "Index", name: expr.name, value: expr.value, op: "",
            left: new_l, right: new_r, cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    if k == "FieldAccess" {
        let new_l = substitute_in_expr(expr.left, target, replacement)
        return AstNode {
            kind: "FieldAccess", name: expr.name, value: expr.value, op: "",
            left: new_l, right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    // Literal / unknown — no substitution needed
    return expr
}

// Substitute target name in a single statement's expression(s), returning new stmt
fn substitute_in_stmt(stmt, target, replacement) {
    let k = stmt.kind
    if k == "ReturnStmt" {
        return AstNode {
            kind: "ReturnStmt", name: "", value: "", op: "",
            left: substitute_in_expr(stmt.left, target, replacement), right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    if k == "ExprStmt" {
        return AstNode {
            kind: "ExprStmt", name: "", value: "", op: "",
            left: substitute_in_expr(stmt.left, target, replacement), right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    if k == "LetStmt" || k == "ConstStmt" {
        return AstNode {
            kind: k, name: stmt.name, value: stmt.value, op: "",
            left: substitute_in_expr(stmt.left, target, replacement), right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    if k == "LetMutStmt" {
        return AstNode {
            kind: "LetMutStmt", name: stmt.name, value: stmt.value, op: "",
            left: substitute_in_expr(stmt.left, target, replacement), right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    if k == "AssertStmt" {
        return AstNode {
            kind: "AssertStmt", name: "", value: "", op: "",
            left: substitute_in_expr(stmt.left, target, replacement), right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    // AssignStmt, WhileStmt, etc. — don't fuse across control flow
    return stmt
}

// Count how many times Ident(target) appears in an expression (for single-use check)
fn count_uses_in_expr(expr, target) {
    if type_of(expr) == "string" { return 0 }
    let k = expr.kind
    if k == "Ident" {
        if expr.name == target { return 1 }
        return 0
    }
    if k == "BinOp" {
        return count_uses_in_expr(expr.left, target) + count_uses_in_expr(expr.right, target)
    }
    if k == "UnaryOp" { return count_uses_in_expr(expr.left, target) }
    if k == "Call" {
        let mut c = count_uses_in_expr(expr.left, target)
        if type_of(expr.args) == "array" {
            let an = len(expr.args)
            let mut ai = 0
            while ai < an {
                c = c + count_uses_in_expr(expr.args[ai], target)
                ai = ai + 1
            }
        }
        return c
    }
    if k == "Index" {
        return count_uses_in_expr(expr.left, target) + count_uses_in_expr(expr.right, target)
    }
    if k == "FieldAccess" { return count_uses_in_expr(expr.left, target) }
    return 0
}

// Get the expression from a statement (for use-count checking)
fn stmt_expr(stmt) {
    let k = stmt.kind
    if k == "ReturnStmt" || k == "ExprStmt" || k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" || k == "AssertStmt" {
        return stmt.left
    }
    return ""
}

// @fuse body rewrite: eliminate intermediate variables that are used exactly once
// in the immediately following statement. Runs one pass over the body; caller
// may invoke repeatedly (via fixpoint) for multi-step chain fusion (a→b→c → a→c).
fn fuse_intermediate_vars(body) {
    if type_of(body) != "array" { return body }
    let n = len(body)
    if n < 2 { return body }
    let mut out = []
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        // Only fuse immutable let bindings (LetStmt / ConstStmt)
        // — mutable bindings may be reassigned so substitution is unsafe
        if (k == "LetStmt" || k == "ConstStmt") && i + 1 < n {
            let bind_name = stmt.name
            let bind_expr = stmt.left
            // Safety: skip if the init expression itself is effectful (contains a call
            // that could have side effects). We approximate: all calls are "maybe effectful"
            // but we still fuse them — the semantics are preserved because the call happens
            // exactly once (single-use) and its position in evaluation order is the same
            // when inlined into the immediately next statement.
            let next = body[i + 1]
            let next_k = next.kind
            // The next statement must be a simple statement (not control flow)
            let next_ok = next_k == "ReturnStmt" || next_k == "ExprStmt" || next_k == "LetStmt" || next_k == "LetMutStmt" || next_k == "ConstStmt" || next_k == "AssertStmt"
            if next_ok {
                let next_e = stmt_expr(next)
                let uses_in_next = count_uses_in_expr(next_e, bind_name)
                // Check no further uses beyond the next stmt
                let remaining = remaining_uses_name(body, i + 2, bind_name)
                if uses_in_next == 1 && !remaining {
                    // Safe to inline: substitute bind_expr for bind_name in next stmt
                    let new_next = substitute_in_stmt(next, bind_name, bind_expr)
                    out = out.push(new_next)
                    m960_fuse_rewrites = m960_fuse_rewrites + 1
                    i = i + 2  // skip both the let and the original next
                } else {
                    out = out.push(stmt)
                    i = i + 1
                }
            } else {
                out = out.push(stmt)
                i = i + 1
            }
        } else {
            out = out.push(stmt)
            i = i + 1
        }
    }
    return out
}

// ── M965: @fuse map/filter chain → single while-loop AST rewrite ─────────────
// Pattern detection: Call{left:Field{name∈{"map","filter"}, left:inner}, args:[Lambda]}
// where inner is either another such chain call or a plain "source" expression.
// A chain qualifies when it has ≥2 consecutive map/filter ops and every stage
// uses a 1-param expression-bodied lambda (non-block).
//
// Rewrite target (inside a LetStmt `let result = <chain>`):
//   let mut result = []
//   let mut __fi = 0
//   let __fsrc = <source-expr>
//   while __fi < __fsrc.len() {
//       let __fx = __fsrc[__fi]
//       <nested: per op, either bind mapped value or wrap remainder in if>
//       __fi = __fi + 1
//   }
// This eliminates all intermediate arrays created by .map/.filter chains
// and replaces them with one allocation + one traversal.

fn is_map_filter_field(expr) {
    if type_of(expr) == "string" { return false }
    if expr.kind != "Field" { return false }
    let nm = expr.name
    if nm == "map" { return true }
    if nm == "filter" { return true }
    return false
}

fn is_expr_lambda_1arg(expr) {
    if type_of(expr) == "string" { return false }
    if expr.kind != "Lambda" { return false }
    if type_of(expr.params) != "array" { return false }
    if len(expr.params) != 1 { return false }
    // Body must be an expression node (AstNode), not a block (array of stmts)
    if type_of(expr.left) == "array" { return false }
    if type_of(expr.left) == "string" { return false }
    return true
}

// Measure chain length of map/filter ops starting at `expr`.
// Returns 0 if not a chain, else the number of consecutive map/filter calls.
fn mapfilter_chain_len(expr) {
    if type_of(expr) == "string" { return 0 }
    if expr.kind != "Call" { return 0 }
    if !is_map_filter_field(expr.left) { return 0 }
    // Must have exactly 1 arg, a 1-param expression lambda
    if type_of(expr.args) != "array" { return 0 }
    if len(expr.args) != 1 { return 0 }
    if !is_expr_lambda_1arg(expr.args[0]) { return 0 }
    let inner_len = mapfilter_chain_len(expr.left.left)
    return 1 + inner_len
}

// Collect ops from innermost to outermost as a flat array of
// AstNode records {kind:"Call", name:<"map"|"filter">, args:[lambda]}.
// Also returns the source (non-chain) expression via a two-element array [source, ops].
// We use two separate return paths since hexa fn returns 1 value; encode as an AstNode
// with items=ops and left=source using kind "__FuseChain".
fn collect_mapfilter_chain(expr) {
    let mut ops = []
    let mut cur = expr
    // Walk outermost→innermost, pushing ops; at the end reverse.
    while type_of(cur) != "string" && cur.kind == "Call" && is_map_filter_field(cur.left) {
        // Record {op_name, lambda}
        let rec = AstNode {
            kind: "__FuseOp", name: cur.left.name, value: "", op: "",
            left: cur.args[0], right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
        ops = ops.push(rec)
        cur = cur.left.left
    }
    // Reverse ops so index 0 is the innermost (first-applied)
    let mut rev = []
    let mut ri = len(ops) - 1
    while ri >= 0 {
        rev = rev.push(ops[ri])
        ri = ri - 1
    }
    return AstNode {
        kind: "__FuseChain", name: "", value: "", op: "",
        left: cur, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: rev,
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

// Build the inner loop body given an ops array and a starting expression (cur_expr)
// representing the currently-flowing value. Recurses over idx.
// Result: list of statements that, at the end, perform result = result.push(final).
fn build_fused_inner(ops, idx, cur_expr, result_name, counter) {
    let n = len(ops)
    if idx >= n {
        // Base: result = result.push(cur_expr)
        // Build Field{name:"push", left: Ident(result_name)}
        let push_field = AstNode {
            kind: "Field", name: "push", value: "", op: "",
            left: make_ident(result_name), right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
        let push_call = AstNode {
            kind: "Call", name: "", value: "", op: "",
            left: push_field, right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: [cur_expr], fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
        return [make_assign_stmt(result_name, push_call)]
    }
    let op = ops[idx]
    let op_name = op.name
    let lam = op.left
    let param = lam.params[0]
    let lam_body = lam.left
    // Substitute cur_expr for param in lam_body
    let applied = substitute_in_expr(lam_body, param, cur_expr)
    if op_name == "map" {
        // let __fmN = applied; recurse with Ident(__fmN)
        let var_name = "__fm" + to_string(counter) + "_" + to_string(idx)
        let bind = make_let_stmt(var_name, applied)
        let rest = build_fused_inner(ops, idx + 1, make_ident(var_name), result_name, counter)
        let mut out = [bind]
        let mut ri = 0
        let rn = len(rest)
        while ri < rn {
            out = out.push(rest[ri])
            ri = ri + 1
        }
        return out
    }
    // filter: if applied { recurse with cur_expr unchanged }
    let then_stmts = build_fused_inner(ops, idx + 1, cur_expr, result_name, counter)
    let if_node = make_if_expr(applied, then_stmts, [])
    return [make_expr_stmt(if_node)]
}

// Rewrite a single LetStmt/ConstStmt whose init is a map/filter chain into
// a sequence of statements implementing the fused loop. Returns the new list
// of statements (length >= 1). If not rewritable, returns empty array (caller
// falls back to original statement).
fn fuse_mapfilter_stmt(stmt, counter) {
    let k = stmt.kind
    if k != "LetStmt" && k != "ConstStmt" { return [] }
    let init = stmt.left
    let clen = mapfilter_chain_len(init)
    if clen < 2 { return [] }
    let chain = collect_mapfilter_chain(init)
    let src_expr = chain.left
    let ops = chain.items
    let result_name = stmt.name
    // Materialize source into a fresh let so we don't re-evaluate `.len()` etc.
    let src_name = "__fsrc" + to_string(counter)
    let idx_name = "__fi" + to_string(counter)
    let x_name = "__fx" + to_string(counter)
    // Statements to emit:
    //   let mut <result_name> = []
    //   let <src_name> = <src_expr>
    //   let mut <idx_name> = 0
    //   while <idx_name> < <src_name>.len() {
    //       let <x_name> = <src_name>[<idx_name>]
    //       <fused-body>
    //       <idx_name> = <idx_name> + 1
    //   }
    let init_result = make_let_mut_stmt(result_name, make_array_lit([]))
    let bind_src = make_let_stmt(src_name, src_expr)
    let init_idx = make_let_mut_stmt(idx_name, make_int_lit(0))
    // len call: src_name.len()
    let len_field = AstNode {
        kind: "Field", name: "len", value: "", op: "",
        left: make_ident(src_name), right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
    let len_call = AstNode {
        kind: "Call", name: "", value: "", op: "",
        left: len_field, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: [], fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
    let cond = make_binop("<", make_ident(idx_name), len_call)
    // Loop body
    let x_bind = make_let_stmt(x_name, make_index(make_ident(src_name), make_ident(idx_name)))
    let fused = build_fused_inner(ops, 0, make_ident(x_name), result_name, counter)
    let incr = make_assign_stmt(idx_name, make_binop("+", make_ident(idx_name), make_int_lit(1)))
    let mut loop_body = [x_bind]
    let mut fi = 0
    let fn_ = len(fused)
    while fi < fn_ {
        loop_body = loop_body.push(fused[fi])
        fi = fi + 1
    }
    loop_body = loop_body.push(incr)
    let while_s = make_while_stmt(cond, loop_body)
    return [init_result, bind_src, init_idx, while_s]
}

// Body-level pass: walk statements, and for each LetStmt whose init is a
// map/filter chain of length >= 2, splice in the fused-loop statements.
fn fuse_mapfilter_body(body) {
    if type_of(body) != "array" { return body }
    let n = len(body)
    let mut out = []
    let mut i = 0
    let mut counter = 0
    while i < n {
        let stmt = body[i]
        let replacement = fuse_mapfilter_stmt(stmt, counter)
        if type_of(replacement) == "array" && len(replacement) > 0 {
            let mut ri = 0
            let rn = len(replacement)
            while ri < rn {
                out = out.push(replacement[ri])
                ri = ri + 1
            }
            m965_mapfilter_fused = m965_mapfilter_fused + 1
            counter = counter + 1
        } else {
            out = out.push(stmt)
        }
        i = i + 1
    }
    return out
}

// ── M974: @fuse map/filter/reduce chain → single-loop AST rewrite ────────────
// Extends M965 to handle chains ending in reduce/fold/sum.
// Pattern: arr.map(f).filter(g).reduce(init, h) → single while-loop with acc.
// Also handles: arr.map(f).reduce(init, h) and arr.filter(g).reduce(init, h).

// Check if a Field node has name "reduce", "fold", or "sum"
fn is_reduce_field(expr) {
    if type_of(expr) == "string" { return false }
    if expr.kind != "Field" { return false }
    let nm = expr.name
    if nm == "reduce" { return true }
    if nm == "fold" { return true }
    if nm == "sum" { return true }
    return false
}

// Detect a map/filter chain ending in reduce/fold/sum.
// Returns chain length (map/filter ops) + 1 for the terminal reduce; 0 if not matching.
// Structure: Call{left:Field{name:"reduce",..., left: <map/filter chain>}, args:[init, lambda2]}
//   or for .sum(): Call{left:Field{name:"sum",..., left: <map/filter chain>}, args:[]}
fn reduce_chain_len(expr) {
    if type_of(expr) == "string" { return 0 }
    if expr.kind != "Call" { return 0 }
    if !is_reduce_field(expr.left) { return 0 }
    let inner = expr.left.left
    // The inner must be a map/filter chain of length >= 1 (or a plain source)
    let mf_len = mapfilter_chain_len(inner)
    if mf_len >= 1 { return mf_len + 1 }
    // Even without map/filter, a plain .reduce on a source is valid but not a "chain"
    return 0
}

// Build the fused inner body for a reduce chain: map/filter ops + terminal reduce.
// cur_expr: the current element variable flowing through the chain.
// acc_name: accumulator variable name.
// reduce_op: the terminal reduce AstNode (__FuseOp with name "reduce"/"fold"/"sum").
fn build_fused_reduce_inner(ops, idx, cur_expr, acc_name, reduce_op, counter) {
    let n = len(ops)
    if idx >= n {
        // Terminal: apply the reduce lambda (or += for sum)
        let rname = reduce_op.name
        if rname == "sum" {
            // acc = acc + cur_expr
            return [make_assign_stmt(acc_name, make_binop("+", make_ident(acc_name), cur_expr))]
        }
        // reduce/fold: lambda(acc, elem) → new acc
        let lam = reduce_op.left
        let acc_param = lam.params[0]
        let elem_param = lam.params[1]
        let lam_body = lam.left
        let step1 = substitute_in_expr(lam_body, acc_param, make_ident(acc_name))
        let step2 = substitute_in_expr(step1, elem_param, cur_expr)
        return [make_assign_stmt(acc_name, step2)]
    }
    let op = ops[idx]
    let op_name = op.name
    let lam = op.left
    let param = lam.params[0]
    let lam_body = lam.left
    let applied = substitute_in_expr(lam_body, param, cur_expr)
    if op_name == "map" {
        let var_name = "__frm" + to_string(counter) + "_" + to_string(idx)
        let bind = make_let_stmt(var_name, applied)
        let rest = build_fused_reduce_inner(ops, idx + 1, make_ident(var_name), acc_name, reduce_op, counter)
        let mut out = [bind]
        let mut ri = 0
        let rn = len(rest)
        while ri < rn {
            out = out.push(rest[ri])
            ri = ri + 1
        }
        return out
    }
    // filter: if applied { recurse with cur_expr unchanged }
    let then_stmts = build_fused_reduce_inner(ops, idx + 1, cur_expr, acc_name, reduce_op, counter)
    let if_node = make_if_expr(applied, then_stmts, [])
    return [make_expr_stmt(if_node)]
}

// Rewrite a LetStmt/ConstStmt whose init is a map/filter chain ending in reduce/fold/sum.
// Returns replacement statements or empty array if not rewritable.
fn fuse_reduce_stmt(stmt, counter) {
    let k = stmt.kind
    if k != "LetStmt" && k != "ConstStmt" && k != "LetMutStmt" { return [] }
    let init = stmt.left
    if type_of(init) == "string" { return [] }
    if init.kind != "Call" { return [] }
    if !is_reduce_field(init.left) { return [] }
    let reduce_name = init.left.name
    let inner_chain_expr = init.left.left
    let mf_len = mapfilter_chain_len(inner_chain_expr)
    if mf_len < 1 { return [] }
    // Collect the map/filter chain
    let chain = collect_mapfilter_chain(inner_chain_expr)
    let src_expr = chain.left
    let ops = chain.items
    // Determine init value and reduce lambda
    let mut reduce_init_expr = make_int_lit(0)
    let mut reduce_lam = ""
    if reduce_name == "sum" {
        // .sum() has no args, init = 0
        reduce_init_expr = make_int_lit(0)
    } else {
        // .reduce(init, lambda) or .fold(init, lambda)
        if type_of(init.args) != "array" { return [] }
        if len(init.args) < 2 { return [] }
        reduce_init_expr = init.args[0]
        reduce_lam = init.args[1]
        // Validate: lambda must have 2 params
        if type_of(reduce_lam) == "string" { return [] }
        if reduce_lam.kind != "Lambda" { return [] }
        if type_of(reduce_lam.params) != "array" { return [] }
        if len(reduce_lam.params) != 2 { return [] }
    }
    let result_name = stmt.name
    let src_name = "__frsrc" + to_string(counter)
    let idx_name = "__fri" + to_string(counter)
    let x_name = "__frx" + to_string(counter)
    let acc_name = "__fracc" + to_string(counter)
    // Build the reduce op record
    let reduce_rec = AstNode {
        kind: "__FuseOp", name: reduce_name, value: "", op: "",
        left: reduce_lam, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
    // Emit:
    //   let mut <acc_name> = <init_expr>
    //   let <src_name> = <src_expr>
    //   let mut <idx_name> = 0
    //   while <idx_name> < <src_name>.len() {
    //       let <x_name> = <src_name>[<idx_name>]
    //       <fused-body with map/filter leading to acc update>
    //       <idx_name> = <idx_name> + 1
    //   }
    //   let <result_name> = <acc_name>
    let init_acc = make_let_mut_stmt(acc_name, reduce_init_expr)
    let bind_src = make_let_stmt(src_name, src_expr)
    let init_idx = make_let_mut_stmt(idx_name, make_int_lit(0))
    // len call: src_name.len()
    let len_field = AstNode {
        kind: "Field", name: "len", value: "", op: "",
        left: make_ident(src_name), right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
    let len_call = AstNode {
        kind: "Call", name: "", value: "", op: "",
        left: len_field, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: [], fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
    let cond = make_binop("<", make_ident(idx_name), len_call)
    let x_bind = make_let_stmt(x_name, make_index(make_ident(src_name), make_ident(idx_name)))
    let fused = build_fused_reduce_inner(ops, 0, make_ident(x_name), acc_name, reduce_rec, counter)
    let incr = make_assign_stmt(idx_name, make_binop("+", make_ident(idx_name), make_int_lit(1)))
    let mut loop_body = [x_bind]
    let mut fi = 0
    let fn_ = len(fused)
    while fi < fn_ {
        loop_body = loop_body.push(fused[fi])
        fi = fi + 1
    }
    loop_body = loop_body.push(incr)
    let while_s = make_while_stmt(cond, loop_body)
    let bind_result = make_let_stmt(result_name, make_ident(acc_name))
    return [init_acc, bind_src, init_idx, while_s, bind_result]
}

// Body-level pass: walk statements and fuse reduce/fold/sum chains.
fn fuse_reduce_body(body) {
    if type_of(body) != "array" { return body }
    let n = len(body)
    let mut out = []
    let mut i = 0
    let mut counter = 0
    while i < n {
        let stmt = body[i]
        let replacement = fuse_reduce_stmt(stmt, counter)
        if type_of(replacement) == "array" && len(replacement) > 0 {
            let mut ri = 0
            let rn = len(replacement)
            while ri < rn {
                out = out.push(replacement[ri])
                ri = ri + 1
            }
            m974_reduce_fused = m974_reduce_fused + 1
            counter = counter + 1
        } else {
            out = out.push(stmt)
        }
        i = i + 1
    }
    return out
}

fn simplify_expr(expr) {
    if type_of(expr) == "string" { return expr }
    // M286: Array literal constant index → element
    if expr.kind == "Index" {
        let arr = simplify_expr(expr.left)
        let idx = simplify_expr(expr.right)
        if type_of(arr) != "string" && type_of(idx) != "string" {
            if arr.kind == "Array" && idx.kind == "IntLit" {
                let iv = parse_int_str(idx.value)
                if iv >= 0 && iv < len(arr.items) {
                    m30_algebraic = m30_algebraic + 1
                    return arr.items[iv]
                }
            }
        }
        return AstNode {
            kind: "Index", name: "", value: "", op: "",
            left: arr, right: idx, cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    // M976: len() constant folding — len("abc") → 3, len([1,2,3]) → 3
    if expr.kind == "Call" {
        let callee = expr.left
        if type_of(callee) != "string" && callee.kind == "Ident" && callee.name == "len" {
            if type_of(expr.args) == "array" && len(expr.args) == 1 {
                let arg = simplify_expr(expr.args[0])
                if type_of(arg) != "string" {
                    // len("literal") → string length
                    if arg.kind == "StringLit" {
                        m976_len_folds = m976_len_folds + 1
                        let slen = len(arg.value.chars())
                        return make_int_lit(slen)
                    }
                    // len([a, b, c]) → array literal length
                    if arg.kind == "Array" {
                        if type_of(arg.items) == "array" {
                            m976_len_folds = m976_len_folds + 1
                            return make_int_lit(len(arg.items))
                        }
                    }
                }
            }
        }
    }
    // M34: unary folding
    if expr.kind == "UnaryOp" {
        let inner = simplify_expr(expr.left)
        if expr.op == "!" && type_of(inner) != "string" {
            if inner.kind == "BoolLit" {
                m34_unary_folds = m34_unary_folds + 1
                let flipped = "true"
                if inner.value == "true" { flipped = "false" }
                return AstNode {
                    kind: "BoolLit", name: "", value: flipped, op: "",
                    left: "", right: "", cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            }
            // M110: !!x → x
            if inner.kind == "UnaryOp" && inner.op == "!" {
                m34_unary_folds = m34_unary_folds + 1
                return inner.left
            }
            // M117: !(a == b) → a != b, !(a != b) → a == b
            if inner.kind == "BinOp" && inner.op == "==" {
                m34_unary_folds = m34_unary_folds + 1
                return AstNode {
                    kind: "BinOp", name: "", value: "", op: "!=",
                    left: inner.left, right: inner.right, cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            }
            if inner.kind == "BinOp" && inner.op == "!=" {
                m34_unary_folds = m34_unary_folds + 1
                return AstNode {
                    kind: "BinOp", name: "", value: "", op: "==",
                    left: inner.left, right: inner.right, cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            }
            // M118: comparison De Morgan (4종)
            if inner.kind == "BinOp" {
                let mut flip = ""
                if inner.op == "<" { flip = ">=" }
                if inner.op == ">" { flip = "<=" }
                if inner.op == "<=" { flip = ">" }
                if inner.op == ">=" { flip = "<" }
                if flip != "" {
                    m34_unary_folds = m34_unary_folds + 1
                    return AstNode {
                        kind: "BinOp", name: "", value: "", op: flip,
                        left: inner.left, right: inner.right, cond: "", then_body: "", else_body: "",
                        params: "", body: "", args: "", fields: "", items: "",
                        variants: "", arms: "", iter_expr: "", ret_type: "",
                        target: "", trait_name: "", methods: ""
                    }
                }
            }
        }
        if expr.op == "-" && type_of(inner) != "string" {
            // Double negation: --x → x
            if inner.kind == "UnaryOp" && inner.op == "-" {
                m34_unary_folds = m34_unary_folds + 1
                return inner.left
            }
            // M268: -0 → 0
            if inner.kind == "IntLit" && inner.value == "0" {
                m34_unary_folds = m34_unary_folds + 1
                return make_int_lit(0)
            }
            // M276: -(a - b) → b - a
            if inner.kind == "BinOp" && inner.op == "-" {
                m34_unary_folds = m34_unary_folds + 1
                return AstNode {
                    kind: "BinOp", name: "", value: "", op: "-",
                    left: inner.right, right: inner.left, cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            }
            // -IntLit → IntLit with negated value
            if inner.kind == "IntLit" {
                let v = parse_int_str(inner.value)
                if v >= 0 {
                    m34_unary_folds = m34_unary_folds + 1
                    return make_int_lit(0 - v)
                }
            }
        }
        return AstNode {
            kind: "UnaryOp", name: "", value: "", op: expr.op,
            left: inner, right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    if expr.kind != "BinOp" { return expr }
    // Recursively simplify children first
    let l = simplify_expr(expr.left)
    let r = simplify_expr(expr.right)
    let op = expr.op
    // M32: constant folding when both sides are IntLit
    if type_of(l) != "string" && type_of(r) != "string" {
        if l.kind == "IntLit" && r.kind == "IntLit" {
            let lv = parse_int_str(l.value)
            let rv = parse_int_str(r.value)
            if lv >= 0 && rv >= 0 {
                if op == "+" {
                    m32_folds = m32_folds + 1
                    return make_int_lit(lv + rv)
                }
                if op == "-" {
                    m32_folds = m32_folds + 1
                    return make_int_lit(lv - rv)
                }
                if op == "*" {
                    m32_folds = m32_folds + 1
                    return make_int_lit(lv * rv)
                }
                if op == "/" && rv != 0 {
                    m32_folds = m32_folds + 1
                    return make_int_lit(lv / rv)
                }
                // M33: comparison folding
                if op == "==" {
                    m33_cmp_folds = m33_cmp_folds + 1
                    return make_bool_lit_from_bool(lv == rv)
                }
                if op == "!=" {
                    m33_cmp_folds = m33_cmp_folds + 1
                    return make_bool_lit_from_bool(lv != rv)
                }
                if op == "<" {
                    m33_cmp_folds = m33_cmp_folds + 1
                    return make_bool_lit_from_bool(lv < rv)
                }
                if op == ">" {
                    m33_cmp_folds = m33_cmp_folds + 1
                    return make_bool_lit_from_bool(lv > rv)
                }
                if op == "<=" {
                    m33_cmp_folds = m33_cmp_folds + 1
                    return make_bool_lit_from_bool(lv <= rv)
                }
                if op == ">=" {
                    m33_cmp_folds = m33_cmp_folds + 1
                    return make_bool_lit_from_bool(lv >= rv)
                }
            }
        }
    }
    if op == "+" {
        if is_int_zero(l) {
            m30_algebraic = m30_algebraic + 1
            return r
        }
        if is_int_zero(r) {
            m30_algebraic = m30_algebraic + 1
            return l
        }
        // M975: string concat folding — "a" + "b" → "ab"
        if type_of(l) != "string" && type_of(r) != "string" {
            if l.kind == "StringLit" && r.kind == "StringLit" {
                m975_string_concat_folds = m975_string_concat_folds + 1
                return AstNode {
                    kind: "StringLit", name: "", value: l.value + r.value, op: "",
                    left: "", right: "", cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            }
            // M975: ("a" + "b") + "c" → "abc" (associative string concat)
            if l.kind == "BinOp" && l.op == "+" && r.kind == "StringLit" {
                if type_of(l.right) != "string" && l.right.kind == "StringLit" {
                    m975_string_concat_folds = m975_string_concat_folds + 1
                    return AstNode {
                        kind: "BinOp", name: "", value: "", op: "+",
                        left: l.left, right: AstNode {
                            kind: "StringLit", name: "", value: l.right.value + r.value, op: "",
                            left: "", right: "", cond: "", then_body: "", else_body: "",
                            params: "", body: "", args: "", fields: "", items: "",
                            variants: "", arms: "", iter_expr: "", ret_type: "",
                            target: "", trait_name: "", methods: ""
                        }, cond: "", then_body: "", else_body: "",
                        params: "", body: "", args: "", fields: "", items: "",
                        variants: "", arms: "", iter_expr: "", ret_type: "",
                        target: "", trait_name: "", methods: ""
                    }
                }
            }
        }
        // M254: associative fold (x + c1) + c2 → x + (c1+c2)
        if type_of(l) != "string" && type_of(r) != "string" {
