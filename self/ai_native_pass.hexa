            }
            if nl_d > 10 { m368_long_name_fns = m368_long_name_fns + 1 }
            if count_whiles(node.body) > 0 { m369_fns_with_while = m369_fns_with_while + 1 }
            if count_asserts(node.body) > 0 { m370_fns_with_assert = m370_fns_with_assert + 1 }
            if count_letmuts(node.body) > 0 { m371_fns_with_letmut = m371_fns_with_letmut + 1 }
            if count_body_binops(node.body) > 0 { m372_fns_with_binop = m372_fns_with_binop + 1 }
            if count_body_calls_m352(node.body) > 0 { m373_fns_with_call = m373_fns_with_call + 1 }
            if count_lets(node.body) > 0 { m374_fns_with_let = m374_fns_with_let + 1 }
            if count_returns(node.body) > 0 { m375_fns_with_return = m375_fns_with_return + 1 }
            if count_assigns(node.body) > 0 { m376_fns_with_assign = m376_fns_with_assign + 1 }
            if count_exprstmts(node.body) > 0 { m377_fns_with_exprstmt = m377_fns_with_exprstmt + 1 }
            if count_body_intlits(node.body) > 0 { m378_fns_with_intlit = m378_fns_with_intlit + 1 }
            if count_body_by_kind(node.body, "BoolLit") > 0 { m379_fns_with_boollit = m379_fns_with_boollit + 1 }
            if count_body_by_kind(node.body, "StringLit") > 0 { m380_fns_with_stringlit = m380_fns_with_stringlit + 1 }
            if count_body_by_kind(node.body, "UnaryOp") > 0 { m381_fns_with_unaryop = m381_fns_with_unaryop + 1 }
            if count_body_by_kind(node.body, "Index") > 0 { m382_fns_with_index = m382_fns_with_index + 1 }
            if count_body_by_kind(node.body, "Ident") > 0 { m383_fns_with_ident = m383_fns_with_ident + 1 }
            let fresh_stats_d = split_attrs_m0(node.value)
            if type_of(fresh_stats_d) == "array" {
                let fa_d = len(fresh_stats_d)
                m331_total_attrs = m331_total_attrs + fa_d
                if attr_has(fresh_stats_d, "pure") {
                    m332_pure_fns = m332_pure_fns + 1
                    if attr_has(fresh_stats_d, "inline") { m384_pure_inline = m384_pure_inline + 1 }
                    if attr_has(fresh_stats_d, "memoize") { m385_pure_memoize = m385_pure_memoize + 1 }
                    if attr_has(fresh_stats_d, "hot") { m386_pure_hot = m386_pure_hot + 1 }
                    if attr_has(fresh_stats_d, "simd") { m387_pure_simd = m387_pure_simd + 1 }
                    if attr_has(fresh_stats_d, "parallel") { m388_pure_parallel = m388_pure_parallel + 1 }
                    if attr_has(fresh_stats_d, "specialize") { m389_pure_specialize = m389_pure_specialize + 1 }
                    if attr_has(fresh_stats_d, "contract") { m390_pure_contract = m390_pure_contract + 1 }
                    if attr_has(fresh_stats_d, "evolve") { m391_pure_evolve = m391_pure_evolve + 1 }
                    if attr_has(fresh_stats_d, "learn") { m392_pure_learn = m392_pure_learn + 1 }
                    if attr_has(fresh_stats_d, "fuse") { m393_pure_fuse = m393_pure_fuse + 1 }
                    if attr_has(fresh_stats_d, "bounded") { m394_pure_bounded = m394_pure_bounded + 1 }
                    if attr_has(fresh_stats_d, "optimize") { m395_pure_optimize = m395_pure_optimize + 1 }
                    if attr_has(fresh_stats_d, "inline") {
