    m39_max_arity = 0
    let inline_threshold = 8
    let mut out = []
    let n = len(ast)
    let mut i = 0
    while i < n {
        let mut node = ast[i]
        // M20 diagnostic captured BEFORE any M22 rewrite
        let was_empty = node.kind == "FnDecl" && node.value != "" && body_stmt_count(node.body) == 0
        if was_empty {
            println("[ai-native] fn " + node.name + " WARN: empty body with @attrs")
            m20_empty_body = m20_empty_body + 1
        }
        // M22: if annotated with empty body, rewrite to inject `return 0`
        if was_empty {
            let new_body = [make_return_zero()]
            node = rewrite_fn_with_body(node, new_body)
            m22_rewrites = m22_rewrites + 1
            println("[ai-native] fn " + node.name + " REWRITE: inserted `return 0`")
        }
        if node.kind == "FnDecl" {
            m6_total_fns = m6_total_fns + 1
        }
        if node.kind == "FnDecl" {
            let _has_av = node.value != ""
            if _has_av {
                m6_annotated_fns = m6_annotated_fns + 1
                // M29: register this fn name
                m29_registry = m29_registry.push(node.name)
            }
            let raw_attrs = split_attrs_m0(node.value)
            // M26: deduplicate attrs
            let deduped = dedup_attrs(raw_attrs)
            if len(deduped) < len(raw_attrs) {
                node = rewrite_fn_with_attrs(node, join_attrs(deduped))
                m26_attr_dedups = m26_attr_dedups + (len(raw_attrs) - len(deduped))
                println("[ai-native] fn " + node.name + " REWRITE: dedup attrs → " + join_attrs(deduped))
            }
            // M27: canonical alpha sort
            let sorted = sort_attrs(deduped)
            let attrs = sorted
            if !arrays_equal_str(deduped, sorted) {
                node = rewrite_fn_with_attrs(node, join_attrs(sorted))
                m27_attr_sorts = m27_attr_sorts + 1
                println("[ai-native] fn " + node.name + " REWRITE: sort attrs → " + join_attrs(sorted))
            }
            let an = len(attrs)
            // M9: pre-compute self-recursion once per fn
            let is_rec = stmts_call_self(node.body, node.name)
            if is_rec {
                m9_recursive = m9_recursive + 1
                println("[ai-native] fn " + node.name + " RECURSIVE")
            }
            // M11: accumulate call count for this annotated fn
            let calls_here = stmts_count_calls(node.body)
            m11_call_count = m11_call_count + calls_here
            // M54: leaf detection
            if calls_here == 0 { m54_leaf_count = m54_leaf_count + 1 }
            // M177/M179: single-stmt fn
            if body_stmt_count(node.body) == 1 {
                m179_single_stmt = m179_single_stmt + 1
                if node.body[0].kind == "ReturnStmt" {
                    m177_return_only = m177_return_only + 1
                }
            }
            // M151/M152: leaf fn missing @pure → auto inject (requires purity check)
            // Re-read fresh attrs from node.value (may have been updated by earlier rewrites)
            let fresh_attrs_leaf = split_attrs_m0(node.value)
            if calls_here == 0 && !attr_has(fresh_attrs_leaf, "pure") {
                m151_leaf_not_pure = m151_leaf_not_pure + 1
                // Only auto-inject if body is also syntactically pure
                let pur_reason = check_purity_m1(node.body)
                if pur_reason == "" && _has_av {
                    node = rewrite_fn_with_attrs(node, node.value + ",pure")
                    m152_auto_pure_leaf = m152_auto_pure_leaf + 1
                    println("[ai-native] fn " + node.name + " REWRITE: auto @pure (leaf + syntactically pure)")
                }
            }
            // M136/M153: trivial simple = no calls + no while + body ≤ 2 → auto @inline
            // Skip identity fns (handled by M82) and wrappers (handled by M83)
            if calls_here == 0 && while_depth(node.body) == 0 && body_stmt_count(node.body) <= 2 && !is_identity_fn(node.body, node.params) && !is_trivial_wrapper(node.body, node.name) {
                m136_trivial_fns = m136_trivial_fns + 1
                let fresh_attrs_triv = split_attrs_m0(node.value)
                if !attr_has(fresh_attrs_triv, "inline") && _has_av {
                    node = rewrite_fn_with_attrs(node, node.value + ",inline")
                    m153_trivial_inline = m153_trivial_inline + 1
                    println("[ai-native] fn " + node.name + " REWRITE: auto @inline (trivial)")
                }
            }
            // M74/M82/M125: identity fn → auto @inline + ideal helper
            if is_identity_fn(node.body, node.params) {
                m74_identity_fns = m74_identity_fns + 1
                let fresh_ai = split_attrs_m0(node.value)
                if !attr_has(fresh_ai, "inline") && _has_av {
                    node = rewrite_fn_with_attrs(node, node.value + ",inline")
                    m82_auto_inline = m82_auto_inline + 1
                    println("[ai-native] fn " + node.name + " REWRITE: auto @inline (identity)")
                }
                if attr_has(fresh_ai, "pure") {
                    m125_ideal_helpers = m125_ideal_helpers + 1
                }
            }
            // M75/M83: trivial wrapper → auto @inline
            if is_trivial_wrapper(node.body, node.name) {
                m75_wrapper_fns = m75_wrapper_fns + 1
                let fresh_wr = split_attrs_m0(node.value)
                if !attr_has(fresh_wr, "inline") && _has_av {
                    node = rewrite_fn_with_attrs(node, node.value + ",inline")
                    m83_wrapper_inline = m83_wrapper_inline + 1
                    println("[ai-native] fn " + node.name + " REWRITE: auto @inline (wrapper)")
                }
            }
            // M55/M56: per-fn max + total body size tracking
            let bs = body_stmt_count(node.body)
            if bs > m55_max_body_size { m55_max_body_size = bs }
            m56_total_body_size = m56_total_body_size + bs
            // M36: per-fn complexity score = body_size + calls*2 + while_depth*5
            let sz_here = body_stmt_count(node.body)
            let cplx = sz_here + calls_here * 2 + while_depth(node.body) * 5
            if cplx > m36_max_complexity { m36_max_complexity = cplx }
            // M144: complex fn (body > 5)
            if sz_here > 5 { m144_complex_fns = m144_complex_fns + 1 }
            // M145: high complexity warning (> 10)
            if cplx > 10 {
                m145_high_cplx_warn = m145_high_cplx_warn + 1
                println("[ai-native] fn " + node.name + " WARN: high complexity " + to_string(cplx))
            }
            println("[ai-native] fn " + node.name + " complexity=" + to_string(cplx))
            // M299: fully effect-free fn
            if body_is_effect_free(node.body) {
                m299_effect_free = m299_effect_free + 1
            }
            // M304~M316: pattern detection
            m304_underscore_bindings = m304_underscore_bindings + count_underscore_bindings(node.body)
            m305_increments = m305_increments + count_increments(node.body)
            m306_decrements = m306_decrements + count_decrements(node.body)
            m307_accumulators = m307_accumulators + count_accumulators(node.body)
            m308_mul_accumulators = m308_mul_accumulators + count_mul_accumulators(node.body)
            m309_sub_accumulators = m309_sub_accumulators + count_sub_accumulators(node.body)
            m310_div_accumulators = m310_div_accumulators + count_div_accumulators(node.body)
            m311_counter_loops = m311_counter_loops + count_counter_loops(node.body)
            m312_countdown_loops = m312_countdown_loops + count_countdown_loops(node.body)
            m313_sum_loops = m313_sum_loops + count_sum_loops(node.body)
            m314_product_loops = m314_product_loops + count_product_loops(node.body)
            m315_for_loops = m315_for_loops + count_for_loops(node.body)
            m316_passthrough_calls = m316_passthrough_calls + count_passthrough_calls_body(node.body)
            // M317: nested while depth max
            let nw_d = while_depth(node.body)
            if nw_d > m317_max_nested_while { m317_max_nested_while = nw_d }
            let brets_d = count_returns(node.body)
            m318_total_returns = m318_total_returns + brets_d
            if brets_d > m409_max_body_returns { m409_max_body_returns = brets_d }
            if brets_d == 0 { m422_zero_return_fns = m422_zero_return_fns + 1 }
            if brets_d == 1 { m438_one_return_fns = m438_one_return_fns + 1 }
            if brets_d == 2 { m456_two_return_fns = m456_two_return_fns + 1 }
            if brets_d >= 3 { m472_heavy_return_fns = m472_heavy_return_fns + 1 }
            let bass_d = count_assigns(node.body)
            m319_total_assigns = m319_total_assigns + bass_d
            if bass_d > m408_max_body_assigns { m408_max_body_assigns = bass_d }
            if bass_d == 0 { m421_zero_assign_fns = m421_zero_assign_fns + 1 }
            if bass_d == 1 { m444_one_assign_fns = m444_one_assign_fns + 1 }
            if bass_d == 2 { m457_two_assign_fns = m457_two_assign_fns + 1 }
            if bass_d >= 5 { m473_heavy_assign_fns = m473_heavy_assign_fns + 1 }
            let blets_d = count_lets(node.body)
            m320_total_lets = m320_total_lets + blets_d
            if blets_d > m407_max_body_lets { m407_max_body_lets = blets_d }
            if blets_d == 0 { m420_zero_let_fns = m420_zero_let_fns + 1 }
            if blets_d == 1 { m439_one_let_fns = m439_one_let_fns + 1 }
            if blets_d == 2 { m454_two_let_fns = m454_two_let_fns + 1 }
            if blets_d == 3 { m460_three_let_fns = m460_three_let_fns + 1 }
            if blets_d == 4 { m463_four_let_fns = m463_four_let_fns + 1 }
            if blets_d >= 5 { m466_heavy_let_fns = m466_heavy_let_fns + 1 }
            if blets_d >= 10 { m469_very_heavy_let_fns = m469_very_heavy_let_fns + 1 }
            if blets_d >= 3 { m729_fn_let_3plus = m729_fn_let_3plus + 1 }
            if blets_d >= 5 { m730_fn_let_5plus = m730_fn_let_5plus + 1 }
            let bexprs_d = count_exprstmts(node.body)
            m321_total_exprstmts = m321_total_exprstmts + bexprs_d
            if bexprs_d > m411_max_body_exprstmts { m411_max_body_exprstmts = bexprs_d }
            if bexprs_d == 0 { m425_zero_exprstmt_fns = m425_zero_exprstmt_fns + 1 }
            if bexprs_d == 1 { m448_one_exprstmt_fns = m448_one_exprstmt_fns + 1 }
            let basts_d = count_asserts(node.body)
            m322_total_asserts = m322_total_asserts + basts_d
            if basts_d > m412_max_body_asserts { m412_max_body_asserts = basts_d }
            if basts_d == 0 { m424_zero_assert_fns = m424_zero_assert_fns + 1 }
            if basts_d == 1 { m447_one_assert_fns = m447_one_assert_fns + 1 }
            let blms_d = count_letmuts(node.body)
            if blms_d > m413_max_body_letmuts { m413_max_body_letmuts = blms_d }
            if blms_d == 0 { m430_zero_letmut_fns = m430_zero_letmut_fns + 1 }
            if blms_d == 1 { m446_one_letmut_fns = m446_one_letmut_fns + 1 }
            m431_grand_fn_count = m431_grand_fn_count + 1
            let nname_d = len(node.name)
            if nname_d > 15 { m432_very_long_name_fns = m432_very_long_name_fns + 1 }
            if nname_d > 25 { m433_extra_long_name_fns = m433_extra_long_name_fns + 1 }
            if node.value != "" { m434_attr_fns = m434_attr_fns + 1 }
            if node.value == "" { m437_no_attr_fns = m437_no_attr_fns + 1 }
            if count_body_by_kind(node.body, "Index") == 0 { m435_zero_index_fns = m435_zero_index_fns + 1 }
            if count_body_by_kind(node.body, "CharLit") == 0 { m436_zero_charlit_fns = m436_zero_charlit_fns + 1 }
            let bwhs_d = count_whiles(node.body)
            m323_total_whiles = m323_total_whiles + bwhs_d
            if bwhs_d > m410_max_body_whiles { m410_max_body_whiles = bwhs_d }
            if bwhs_d == 0 { m423_zero_while_fns = m423_zero_while_fns + 1 }
            if bwhs_d == 1 { m445_one_while_fns = m445_one_while_fns + 1 }
            m324_void_returns = m324_void_returns + count_void_returns(node.body)
            m813_total_void_returns = m813_total_void_returns + count_void_returns(node.body)
            m814_total_value_returns = m814_total_value_returns + brets_d - count_void_returns(node.body)
            if type_of(node.body) == "array" {
                let bl_d = len(node.body)
                if bl_d == 1 { m325_single_stmt_fns = m325_single_stmt_fns + 1 }
                if bl_d > m326_max_body_stmts { m326_max_body_stmts = bl_d }
                m399_grand_total_stmts = m399_grand_total_stmts + bl_d
                if bl_d >= 2 {
                    if bl_d <= 5 { m363_small_body_fns = m363_small_body_fns + 1 }
                }
                if bl_d >= 6 {
                    if bl_d <= 15 { m364_medium_body_fns = m364_medium_body_fns + 1 }
                }
                if bl_d > 15 { m365_large_body_fns = m365_large_body_fns + 1 }
                if bl_d >= 10 { m471_heavy_body_fns = m471_heavy_body_fns + 1 }
                if bl_d >= 20 { m479_very_heavy_body_fns = m479_very_heavy_body_fns + 1 }
            }
            if type_of(node.params) == "array" {
                let pl_d = len(node.params)
                if pl_d == 0 { m327_zero_param_fns = m327_zero_param_fns + 1 }
                if pl_d > m328_max_arity { m328_max_arity = pl_d }
                m329_total_params = m329_total_params + pl_d
                if pl_d == 1 { m360_one_arg_fns = m360_one_arg_fns + 1 }
                if pl_d == 2 { m361_two_arg_fns = m361_two_arg_fns + 1 }
                if pl_d >= 3 { m362_multi_arg_fns = m362_multi_arg_fns + 1 }
            }
            let nl_d = len(node.name)
            if nl_d > m330_max_name_len { m330_max_name_len = nl_d }
            if nl_d <= 3 { m366_short_name_fns = m366_short_name_fns + 1 }
