fn body_increments_name_m311(body, target) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    let mut i = 0
    while i < n {
        let s = body[i]
        if s.kind == "AssignStmt" {
            let lhs = s.left
            let rhs = s.right
            if type_of(lhs) != "string" && type_of(rhs) != "string" {
                if lhs.kind == "Ident" && lhs.name == target {
                    if rhs.kind == "BinOp" && rhs.op == "+" {
                        if type_of(rhs.left) != "string" && rhs.left.kind == "Ident" && rhs.left.name == target {
                            return true
                        }
                    }
                }
            }
        }
        i = i + 1
    }
    return false
}

