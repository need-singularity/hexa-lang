let mut m975_thread_local_vars = 0
// M976: swiss table — hash table rewrite candidates
let mut m976_swiss_table_rewrites = 0
// M977: @nonnull — null check elimination count
let mut m977_nonnull_elim = 0
let mut m977_nonnull_ok = 0

fn body_is_effect_free(body) {
    if type_of(body) != "array" { return true }
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "AssignStmt" { return false }
        if k == "WhileStmt" { return false }
        if k == "ExprStmt" { return false }
        if k == "ReturnStmt" || k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" {
            if expr_has_call(stmt.left) { return false }
        }
        i = i + 1
    }
    return true
}

// ── M304~M316: pattern detection helpers ──────────────────────

fn count_underscore_bindings(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" {
            let nm = stmt.name
            if len(nm.chars()) > 0 && to_string(nm.chars()[0]) == "_" {
                c = c + 1
            }
        }
        if k == "WhileStmt" { c = c + count_underscore_bindings(stmt.body) }
        i = i + 1
    }
    return c
}

fn count_increments(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "AssignStmt" {
            let lhs = stmt.left
            let rhs = stmt.right
            if type_of(lhs) != "string" && type_of(rhs) != "string" {
                if lhs.kind == "Ident" && rhs.kind == "BinOp" && rhs.op == "+" {
                    if type_of(rhs.left) != "string" && rhs.left.kind == "Ident" && rhs.left.name == lhs.name {
                        if type_of(rhs.right) != "string" && rhs.right.kind == "IntLit" && rhs.right.value == "1" {
                            c = c + 1
                        }
                    }
                }
            }
        }
        if stmt.kind == "WhileStmt" { c = c + count_increments(stmt.body) }
        i = i + 1
    }
    return c
}

fn count_decrements(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "AssignStmt" {
            let lhs = stmt.left
            let rhs = stmt.right
            if type_of(lhs) != "string" && type_of(rhs) != "string" {
                if lhs.kind == "Ident" && rhs.kind == "BinOp" && rhs.op == "-" {
                    if type_of(rhs.left) != "string" && rhs.left.kind == "Ident" && rhs.left.name == lhs.name {
                        if type_of(rhs.right) != "string" && rhs.right.kind == "IntLit" && rhs.right.value == "1" {
                            c = c + 1
                        }
                    }
                }
            }
        }
        if stmt.kind == "WhileStmt" { c = c + count_decrements(stmt.body) }
        i = i + 1
    }
    return c
}

fn count_accumulators(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "AssignStmt" {
            let lhs = stmt.left
            let rhs = stmt.right
            if type_of(lhs) != "string" && type_of(rhs) != "string" {
                if lhs.kind == "Ident" && rhs.kind == "BinOp" && rhs.op == "+" {
                    if type_of(rhs.left) != "string" && rhs.left.kind == "Ident" && rhs.left.name == lhs.name {
                        c = c + 1
                    }
                }
            }
        }
        if stmt.kind == "WhileStmt" { c = c + count_accumulators(stmt.body) }
        i = i + 1
    }
    return c
}

// M962 helper: count BinOp nodes whose left or right is an IntLit, recursively.
fn expr_has_intlit_binop(e) {
    if type_of(e) == "string" { return 0 }
    if e.kind == "BinOp" {
        let mut c = 0
        if type_of(e.left) != "string" && e.left.kind == "IntLit" { c = c + 1 }
        else if type_of(e.right) != "string" && e.right.kind == "IntLit" { c = c + 1 }
        c = c + expr_has_intlit_binop(e.left) + expr_has_intlit_binop(e.right)
        return c
    }
    if e.kind == "UnaryOp" { return expr_has_intlit_binop(e.operand) }
    if e.kind == "Call" {
        if type_of(e.args) == "array" {
            let mut c = 0
            let mut i = 0
            while i < len(e.args) {
                c = c + expr_has_intlit_binop(e.args[i])
                i = i + 1
            }
            return c
        }
    }
    return 0
}

fn count_binops_with_intlit(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ReturnStmt" {
            if type_of(stmt.value) != "string" { c = c + expr_has_intlit_binop(stmt.value) }
        }
        if k == "LetStmt" || k == "LetMutStmt" {
            if type_of(stmt.value) != "string" { c = c + expr_has_intlit_binop(stmt.value) }
        }
        if k == "AssignStmt" {
            if type_of(stmt.right) != "string" { c = c + expr_has_intlit_binop(stmt.right) }
        }
        if k == "ExprStmt" {
            if type_of(stmt.value) != "string" { c = c + expr_has_intlit_binop(stmt.value) }
        }
        if k == "WhileStmt" { c = c + count_binops_with_intlit(stmt.body) }
        if k == "IfStmt" {
            c = c + count_binops_with_intlit(stmt.then_body)
            if type_of(stmt.else_body) == "array" { c = c + count_binops_with_intlit(stmt.else_body) }
        }
        i = i + 1
    }
    return c
}

