                if attr_has(fresh_stats_d, "evolve") { m402_total_semantic_attrs = m402_total_semantic_attrs + 1 }
                if attr_has(fresh_stats_d, "learn") { m402_total_semantic_attrs = m402_total_semantic_attrs + 1 }
                if attr_has(fresh_stats_d, "specialize") { m402_total_semantic_attrs = m402_total_semantic_attrs + 1 }
