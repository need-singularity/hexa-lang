// Inline @inline_always in a body
fn inline_always_body(body) {
fn count_iv_multiply_exprs(body, iv_name) {
    if type_of(body) != "array" { return 0 }
    let mut count = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if type_of(stmt) != "string" {
            count = count + count_iv_mul_in_expr(stmt, iv_name)
        }
        i = i + 1
    }
    return count
}

fn count_iv_mul_in_expr(node, iv_name) {
    if type_of(node) == "string" { return 0 }
    let mut c = 0
    if node.kind == "BinOp" && node.op == "*" {
        // Check if either side is the IV
        if type_of(node.left) != "string" && node.left.kind == "Ident" && node.left.name == iv_name {
            c = c + 1
        }
        if type_of(node.right) != "string" && node.right.kind == "Ident" && node.right.name == iv_name {
            c = c + 1
        }
    }
    // Recurse
    if node.kind == "BinOp" {
        c = c + count_iv_mul_in_expr(node.left, iv_name)
        c = c + count_iv_mul_in_expr(node.right, iv_name)
    }
    if node.kind == "Index" {
        c = c + count_iv_mul_in_expr(node.left, iv_name)
        c = c + count_iv_mul_in_expr(node.right, iv_name)
    }
    if node.kind == "Call" {
        if type_of(node.args) == "array" {
            let n = len(node.args)
            let mut j = 0
            while j < n {
                c = c + count_iv_mul_in_expr(node.args[j], iv_name)
                j = j + 1
            }
        }
    }
    if node.kind == "AssignStmt" {
        c = c + count_iv_mul_in_expr(node.right, iv_name)
    }
    if node.kind == "LetStmt" || node.kind == "LetMutStmt" {
        c = c + count_iv_mul_in_expr(node.left, iv_name)
    }
    if node.kind == "ReturnStmt" {
        c = c + count_iv_mul_in_expr(node.left, iv_name)
    }
    if node.kind == "ExprStmt" {
        c = c + count_iv_mul_in_expr(node.left, iv_name)
    }
    return c
}

fn iv_simplify_body(body) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ReturnStmt" || k == "ExprStmt" || k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" {
            let new_e = inline_always_expr(stmt.left)
            out = out.push(AstNode {
                kind: k, name: stmt.name, value: stmt.value, op: "",
                left: new_e, right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            })
        } else if k == "AssignStmt" {
            let new_r = inline_always_expr(stmt.right)
            out = out.push(AstNode {
                kind: "AssignStmt", name: "", value: "", op: "",
                left: stmt.left, right: new_r, cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            })
        } else if k == "WhileStmt" {
            let new_wb = inline_always_body(stmt.body)
            out = out.push(make_while_stmt(stmt.cond, new_wb))
        } else {
            out = out.push(stmt)
        }
        if type_of(stmt) != "string" && stmt.kind == "WhileStmt" {
            let loop_body = stmt.body
            if type_of(loop_body) == "array" {
                let iv_name = find_loop_iv(loop_body)
                if iv_name != "" && count_iv_multiply_exprs(loop_body, iv_name) > 0 {
                    // Rewrite: add __iv_step var and replace multiply with additive
                    let new_loop_body = rewrite_iv_body(loop_body, iv_name)
                    let new_while = AstNode {
                        kind: "WhileStmt",
                        cond: stmt.cond,
                        body: new_loop_body
                    }
                    // Prepend IV init: let mut __iv_<name> = 0
                    let iv_init = AstNode {
                        kind: "LetMutStmt",
                        name: "__iv_" + iv_name,
                        left: AstNode { kind: "IntLit", value: "0" }
                    }
                    out = out.push(iv_init)
                    out = out.push(new_while)
                    m976_iv_simplify = m976_iv_simplify + 1
                    i = i + 1
                    continue
                }
            }
        }
        out = out.push(stmt)
        i = i + 1
    }
    return out
}

