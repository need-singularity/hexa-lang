                m30_algebraic = m30_algebraic + 1
                return AstNode {
                    kind: "BinOp", name: "", value: "", op: "*",
                    left: l.left, right: r.left, cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            }
            // M278: (-a) * b → -(a * b), a * (-b) → -(a * b)
            if l.kind == "UnaryOp" && l.op == "-" {
                m30_algebraic = m30_algebraic + 1
                let inner_mul = AstNode {
                    kind: "BinOp", name: "", value: "", op: "*",
                    left: l.left, right: r, cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
                return AstNode {
                    kind: "UnaryOp", name: "", value: "", op: "-",
                    left: inner_mul, right: "", cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            }
            if r.kind == "UnaryOp" && r.op == "-" {
                m30_algebraic = m30_algebraic + 1
                let inner_mul2 = AstNode {
                    kind: "BinOp", name: "", value: "", op: "*",
                    left: l, right: r.left, cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
                return AstNode {
                    kind: "UnaryOp", name: "", value: "", op: "-",
                    left: inner_mul2, right: "", cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            }
        }
        // M266: (x/c) * c → x (assumes exact division)
        if type_of(l) != "string" && type_of(r) != "string" {
            if l.kind == "BinOp" && l.op == "/" && r.kind == "IntLit" {
                if type_of(l.right) != "string" && l.right.kind == "IntLit" {
                    if l.right.value == r.value && r.value != "0" {
                        m30_algebraic = m30_algebraic + 1
                        return l.left
                    }
                }
            }
        }
        // M120: IntLit * x → x * IntLit (commutative)
        if type_of(l) != "string" && type_of(r) != "string" {
            if l.kind == "IntLit" && r.kind != "IntLit" {
                m30_algebraic = m30_algebraic + 1
                return AstNode {
                    kind: "BinOp", name: "", value: "", op: "*",
                    left: r, right: l, cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            }
        }
        // M480: @symbolic strength reduction — x * pow2 → x << log2(pow2)
        if type_of(r) != "string" && r.kind == "IntLit" {
            let rv = parse_int_str(r.value)
            if rv >= 2 && is_power_of_two(rv) {
                m480_symbolic_rewrites = m480_symbolic_rewrites + 1
                return AstNode {
                    kind: "BinOp", name: "", value: "", op: "<<",
                    left: l, right: make_int_lit(log2_of(rv)), cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            }
        }
    }
    // M114: x / 1 → x, 0 / x → 0
    if op == "/" {
        if is_int_one(r) {
            m30_algebraic = m30_algebraic + 1
            return l
        }
        if is_int_zero(l) {
            m30_algebraic = m30_algebraic + 1
            return AstNode {
                kind: "IntLit", name: "", value: "0", op: "",
                left: "", right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            }
        }
        // M115: x / x → 1 (assumes x != 0)
        if same_ident(l, r) {
            m30_algebraic = m30_algebraic + 1
            return make_int_lit(1)
        }
        // M265: (x*c) / c → x
        if type_of(l) != "string" && type_of(r) != "string" {
            if l.kind == "BinOp" && l.op == "*" && r.kind == "IntLit" {
                if type_of(l.right) != "string" && l.right.kind == "IntLit" {
                    if l.right.value == r.value && r.value != "0" {
                        m30_algebraic = m30_algebraic + 1
                        return l.left
                    }
                }
            }
        }
        // M480: @symbolic — x / pow2 → x >> log2(pow2)
        if type_of(r) != "string" && r.kind == "IntLit" {
            let rv_d = parse_int_str(r.value)
            if rv_d >= 2 && is_power_of_two(rv_d) {
                m480_symbolic_rewrites = m480_symbolic_rewrites + 1
                return AstNode {
                    kind: "BinOp", name: "", value: "", op: ">>",
                    left: l, right: make_int_lit(log2_of(rv_d)), cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            }
        }
    }
    // M480: @symbolic — x % pow2 → x & (pow2 - 1)
    if op == "%" {
        if type_of(r) != "string" && r.kind == "IntLit" {
            let rv_m = parse_int_str(r.value)
            if rv_m >= 2 && is_power_of_two(rv_m) {
                m480_symbolic_rewrites = m480_symbolic_rewrites + 1
                return AstNode {
                    kind: "BinOp", name: "", value: "", op: "&",
                    left: l, right: make_int_lit(rv_m - 1), cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            }
        }
    }
    if op == "&&" {
        if is_bool_false(l) {
            m35_bool_folds = m35_bool_folds + 1
            return l
        }
        if is_bool_false(r) {
            m35_bool_folds = m35_bool_folds + 1
            return r
        }
        if is_bool_true(l) {
            m35_bool_folds = m35_bool_folds + 1
            return r
        }
        if is_bool_true(r) {
            m35_bool_folds = m35_bool_folds + 1
            return l
        }
        // M108: x && x → x
        if same_ident(l, r) {
            m35_bool_folds = m35_bool_folds + 1
            return l
        }
        // M113: x && !x → false / !x && x → false
        if is_not_of(l, r) || is_not_of(r, l) {
            m35_bool_folds = m35_bool_folds + 1
            return make_bool_lit_from_bool(false)
        }
    }
    if op == "||" {
        if is_bool_true(l) {
            m35_bool_folds = m35_bool_folds + 1
            return l
        }
        if is_bool_true(r) {
            m35_bool_folds = m35_bool_folds + 1
            return r
        }
        if is_bool_false(l) {
            m35_bool_folds = m35_bool_folds + 1
            return r
        }
        if is_bool_false(r) {
            m35_bool_folds = m35_bool_folds + 1
            return l
        }
        // M109: x || x → x
        if same_ident(l, r) {
            m35_bool_folds = m35_bool_folds + 1
            return l
        }
        // M113: x || !x → true / !x || x → true
        if is_not_of(l, r) || is_not_of(r, l) {
            m35_bool_folds = m35_bool_folds + 1
            return make_bool_lit_from_bool(true)
        }
    }
    // Rebuild with simplified children
    return AstNode {
        kind: "BinOp", name: "", value: "", op: op,
        left: l, right: r, cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn simplify_body(body) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ReturnStmt" || k == "ExprStmt" || k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" {
            let new_e = simplify_expr(stmt.left)
            out = out.push(AstNode {
                kind: k, name: stmt.name, value: stmt.value, op: "",
                left: new_e, right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            })
        } else {
            if k == "AssignStmt" {
                let new_r = simplify_expr(stmt.right)
                out = out.push(AstNode {
                    kind: "AssignStmt", name: "", value: "", op: "",
                    left: stmt.left, right: new_r, cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                })
            } else {
                if k == "WhileStmt" {
                    let new_cond = simplify_expr(stmt.cond)
                    // M41: while(false) { ... } → drop entirely
                    if is_bool_false(new_cond) {
                        m41_dead_loops = m41_dead_loops + 1
                        // don't push anything
                    } else {
                        let new_body = simplify_body(stmt.body)
                        out = out.push(AstNode {
                            kind: "WhileStmt", name: "", value: "", op: "",
                            left: "", right: "", cond: new_cond, then_body: "", else_body: "",
                            params: "", body: new_body, args: "", fields: "", items: "",
                            variants: "", arms: "", iter_expr: "", ret_type: "",
                            target: "", trait_name: "", methods: ""
                        })
                    }
                } else {
                    out = out.push(stmt)
                }
            }
        }
        i = i + 1
    }
    return out
}

// Canonical attr rank (lower = earlier). Integer comparison only.
fn attr_rank(name) {
    if name == "pure" { return 10 }
    if name == "inline" { return 20 }
    if name == "hot" { return 30 }
    if name == "cold" { return 31 }
    if name == "bounded" { return 40 }
    if name == "memoize" { return 50 }
    if name == "optimize" { return 60 }
    if name == "fuse" { return 70 }
    if name == "compact" { return 71 }
    if name == "lazy" { return 72 }
    if name == "cache" { return 73 }
    if name == "algebraic" { return 74 }
    if name == "parallel" { return 80 }
    if name == "simd" { return 81 }
    if name == "gpu" { return 82 }
    if name == "specialize" { return 83 }
    if name == "predict" { return 84 }
    if name == "symbolic" { return 90 }
    if name == "reduce" { return 91 }
    if name == "approximate" { return 92 }
    if name == "evolve" { return 93 }
    if name == "learn" { return 94 }
    if name == "contract" { return 95 }
    if name == "profile" { return 96 }
    if name == "speculative_decode" { return 85 }
    if name == "test" { return 200 }
    if name == "bench" { return 201 }
    if name == "deprecated" { return 202 }
    if name == "link" { return 203 }
    return 999
}

fn sort_attrs(attrs) {
    // Selection sort by rank — stable for equal ranks
    let n = len(attrs)
    let mut result = []
    let mut i = 0
    while i < n {
        result = result.push(attrs[i])
        i = i + 1
    }
    let mut k = 0
    while k < n {
        let mut min_idx = k
        let mut j = k + 1
        while j < n {
            if attr_rank(result[j]) < attr_rank(result[min_idx]) {
                min_idx = j
            }
            j = j + 1
        }
        if min_idx != k {
            // swap via rebuild
            let mut tmp = []
            let mut t = 0
            while t < n {
                if t == k { tmp = tmp.push(result[min_idx]) }
                else { if t == min_idx { tmp = tmp.push(result[k]) }
                       else { tmp = tmp.push(result[t]) } }
                t = t + 1
            }
            result = tmp
        }
        k = k + 1
    }
    return result
}

fn arrays_equal_str(a, b) {
    if len(a) != len(b) { return false }
    let n = len(a)
    let mut i = 0
    while i < n {
        if a[i] != b[i] { return false }
        i = i + 1
    }
    return true
}

fn dedup_attrs(attrs) {
    let mut seen = []
    let n = len(attrs)
    let mut i = 0
    while i < n {
        let a = attrs[i]
        let mut already = false
        let sn = len(seen)
        let mut j = 0
        while j < sn {
            if seen[j] == a { already = true }
            j = j + 1
        }
        if !already { seen = seen.push(a) }
        i = i + 1
    }
    return seen
}

fn join_attrs(attrs) {
    let n = len(attrs)
    if n == 0 { return "" }
    let mut out = attrs[0]
    let mut i = 1
    while i < n {
        out = out + "," + attrs[i]
        i = i + 1
    }
    return out
}

fn make_bool_lit(v) {
    return AstNode {
        kind: "BoolLit", name: "", value: v, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_while_true_empty() {
    return AstNode {
        kind: "WhileStmt", name: "", value: "", op: "",
        left: "", right: "", cond: make_bool_lit("true"), then_body: "", else_body: "",
        params: "", body: [], args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

// Simple tail-call: body is exactly [ReturnStmt(Call(Ident self, ...))]
fn is_simple_tail_only(body, self_name) {
    if type_of(body) != "array" { return false }
    if len(body) != 1 { return false }
    let s = body[0]
    if s.kind != "ReturnStmt" { return false }
    let e = s.left
    if type_of(e) == "string" { return false }
    if e.kind != "Call" { return false }
    let callee = e.left
    if type_of(callee) == "string" { return false }
    if callee.kind != "Ident" { return false }
    return callee.name == self_name
}

fn eliminate_dead(body) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let n = len(body)
    let mut i = 0
    let mut stopped = false
    while i < n {
        if !stopped {
            out = out.push(body[i])
            if body[i].kind == "ReturnStmt" { stopped = true }
            // M293: assert false also stops execution
            if body[i].kind == "AssertStmt" {
                let c = body[i].left
                if type_of(c) != "string" && c.kind == "BoolLit" && c.value == "false" {
                    stopped = true
                }
            }
        }
        i = i + 1
    }
    return out
}

fn rewrite_fn_with_attrs(fn_node, new_attrs) {
    return AstNode {
        kind: "FnDecl", name: fn_node.name, value: new_attrs, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: fn_node.params, body: fn_node.body, args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: fn_node.ret_type,
        target: "", trait_name: "", methods: ""
    }
}

