    if cond.kind == "BinOp" {
        let lv = ccp_eval_int(cond.left, names, vals)
        let rv = ccp_eval_int(cond.right, names, vals)
        if lv != "" && rv != "" {
            let li = parse_int_str(lv)
            let ri = parse_int_str(rv)
            let op = cond.op
            if op == "==" {
                m977_ccp_folds = m977_ccp_folds + 1
                if li == ri { return "true" } else { return "false" }
            }
            if op == "!=" {
                m977_ccp_folds = m977_ccp_folds + 1
                if li != ri { return "true" } else { return "false" }
            }
            if op == "<" {
                m977_ccp_folds = m977_ccp_folds + 1
                if li < ri { return "true" } else { return "false" }
            }
            if op == ">" {
                m977_ccp_folds = m977_ccp_folds + 1
                if li > ri { return "true" } else { return "false" }
            }
            if op == "<=" {
                m977_ccp_folds = m977_ccp_folds + 1
                if li <= ri { return "true" } else { return "false" }
            }
            if op == ">=" {
                m977_ccp_folds = m977_ccp_folds + 1
                if li >= ri { return "true" } else { return "false" }
            }
        }
    }
    // UnaryOp ! with known bool
    if cond.kind == "UnaryOp" && cond.op == "!" {
        let inner = ccp_resolve_cond(cond.left, names, vals)
        if inner == "true" {
            m977_ccp_folds = m977_ccp_folds + 1
            return "false"
        }
        if inner == "false" {
            m977_ccp_folds = m977_ccp_folds + 1
            return "true"
        }
// ── #49 Linked List → Array ────────────────────────────────────
// Detects sequential-access linked list patterns:
//   while node != nil { ... node = node.next }
// And marks them as candidates for Vec-based contiguous layout.
fn detect_linked_list_pattern(body) {
    if type_of(body) != "array" { return 0 }
    let mut count = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if type_of(stmt) != "string" && stmt.kind == "WhileStmt" {
            // Check for node.next traversal pattern
            let loop_body = stmt.body
            if type_of(loop_body) == "array" {
                let traversal_var = find_next_traversal(loop_body)
                if traversal_var != "" {
                    count = count + 1
                }
            }
        }
        i = i + 1
    }
    return count
}

fn find_next_traversal(body) {
    if type_of(body) != "array" { return "" }
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if type_of(stmt) != "string" && stmt.kind == "AssignStmt" {
            // pattern: x = x.next
            if type_of(stmt.right) != "string" && stmt.right.kind == "FieldAccess" {
                if stmt.right.field == "next" {
                    if type_of(stmt.right.left) != "string" && stmt.right.left.kind == "Ident" {
                        if stmt.right.left.name == stmt.name {
                            return stmt.name
                        }
                    }
                }
            }
        }
        i = i + 1
    }
    return ""
}

// Evaluate an expression to an integer string if constant
fn ccp_eval_int(expr, names, vals) {
    if type_of(expr) == "string" { return "" }
    if expr.kind == "IntLit" { return expr.value }
    if expr.kind == "Ident" {
        let n = len(names)
        let mut i = 0
        while i < n {
            if names[i] == expr.name {
                let v = vals[i]
                if type_of(v) != "string" && v.kind == "IntLit" {
                    return v.value
                }
            }
            i = i + 1
        }
    }
    return ""
fn list_to_array_body(body) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if type_of(stmt) != "string" && stmt.kind == "WhileStmt" {
            let loop_body = stmt.body
            if type_of(loop_body) == "array" {
                let traversal_var = find_next_traversal(loop_body)
                if traversal_var != "" {
                    // Rewrite: collect linked nodes into array first, then iterate
                    // 1. let mut __list_arr = []
                    // 2. let mut __cur = <init>; while __cur != nil { __list_arr.push(__cur); __cur = __cur.next }
                    // 3. for __item in __list_arr { <body without next-traversal> }
                    // For the pass, we mark + count; actual full rewrite at codegen time
                    m977_list_to_array = m977_list_to_array + 1
                    out = out.push(stmt)
                    i = i + 1
                    continue
                }
            }
        }
        out = out.push(stmt)
        i = i + 1
    }
    return out
}
