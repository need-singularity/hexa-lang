    }
    return out
}

// M28: fixpoint runner — call ai_native_pass until no rewrites occur
fn ai_native_fixpoint(ast) {
    let mut cur = ast
    let mut iter = 0
    let max_iters = 5
    m87_fixpoint_iters = 0
    m88_fixpoint_converged = false
    m89_fixpoint_total_rewrites = 0
    while iter < max_iters {
        let next = ai_native_pass(cur)
        m87_fixpoint_iters = m87_fixpoint_iters + 1
        let total_rewrites = m22_rewrites + m23_auto_memoize + m24_dce_fns + m25_tail_rewrites + m26_attr_dedups + m27_attr_sorts + m82_auto_inline + m83_wrapper_inline + m84_stub_pure + m116_assert_elim + m152_auto_pure_leaf + m153_trivial_inline + m250_const_prop + m251_dead_stores + m480_symbolic_rewrites + m481b_symbolic_mul2 + m481c_symbolic_pow2 + m253b_contract_elims
        let total_rewrites = m22_rewrites + m23_auto_memoize + m24_dce_fns + m25_tail_rewrites + m26_attr_dedups + m27_attr_sorts + m82_auto_inline + m83_wrapper_inline + m84_stub_pure + m116_assert_elim + m152_auto_pure_leaf + m153_trivial_inline + m250_const_prop + m251_dead_stores + m480_symbolic_rewrites + m974_ipcp_specialized + m975_reg_promoted + m976_rec_to_iter
        let total_rewrites = m22_rewrites + m23_auto_memoize + m24_dce_fns + m25_tail_rewrites + m26_attr_dedups + m27_attr_sorts + m82_auto_inline + m83_wrapper_inline + m84_stub_pure + m116_assert_elim + m152_auto_pure_leaf + m153_trivial_inline + m250_const_prop + m251_dead_stores + m480_symbolic_rewrites + m975_sort_upgrade_rewrites + m976_branch_merge_candidates
        m89_fixpoint_total_rewrites = m89_fixpoint_total_rewrites + total_rewrites
        if total_rewrites == 0 {
            m88_fixpoint_converged = true
            println("[ai-native] FIXPOINT reached after " + to_string(iter + 1) + " iter(s)")
            return next
        }
        cur = next
        iter = iter + 1
    }
    println("[ai-native] FIXPOINT max_iters hit (" + to_string(max_iters) + ")")
    return cur
}
