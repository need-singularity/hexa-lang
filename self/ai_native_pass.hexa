fn rewrite_iv_body(body, iv_name) {
    // Replace `iv * stride` with `__iv_name` and add `__iv_name = __iv_name + stride` before increment
    let mut out = []
    let n = len(body)
    let iv_var = "__iv_" + iv_name
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if type_of(stmt) != "string" && stmt.kind == "AssignStmt" && stmt.name == iv_name {
            // This is the IV increment (i = i + 1); add __iv increment before it
            // Extract stride from multiply contexts (default=1 for simplicity)
            let iv_inc = AstNode {
                kind: "AssignStmt",
                name: iv_var,
                right: AstNode {
                    kind: "BinOp",
                    op: "+",
                    left: AstNode { kind: "Ident", name: iv_var },
                    right: AstNode { kind: "IntLit", value: "1" }
                }
            }
            out = out.push(iv_inc)
            out = out.push(stmt)
        } else {
            out = out.push(stmt)
        }
        i = i + 1
    }
    return out
}

// Resolve a condition expression to "true"/"false"/""
fn ccp_resolve_cond(cond, names, vals) {
