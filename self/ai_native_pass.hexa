// ── M974: @approximate rewrite — inject Newton/Taylor approximation ──
// Rewrites sqrt(x) → Newton's method, exp(x)/sin(x)/cos(x) → Taylor series.
// Precision parameter from @approximate(precision=N) is extracted from attr string.
fn extract_approx_precision(attrs_str) {
    // Parse "approximate(precision=1e-6)" or "approximate:1e-6"
    let chars = attrs_str.chars()
    let n = len(chars)
    let mut i = 0
    let mut in_approx = false
    let mut num_str = ""
    // Look for "precision=" inside approximate(...)
    let full = to_string(attrs_str)
    if contains(full, "precision=") {
        let parts = full.split("precision=")
        if len(parts) >= 2 {
            let after = parts[1]
            let ac = after.chars()
            let mut ai = 0
            while ai < len(ac) {
                let ch = to_string(ac[ai])
                if ch == ")" || ch == "," { ai = len(ac) } else {
                    num_str = num_str + ch
                }
                ai = ai + 1
            }
            if num_str != "" { return num_str }
        }
    }
    return "1e-6"
}

// Rewrite: replace sqrt/exp/sin/cos calls with approximate versions.
// Returns rewritten body + increments m974_approx_rewrites.
fn rewrite_approx_expr(expr, precision_str) {
    if type_of(expr) == "string" { return expr }
    if expr.kind == "Call" {
        if type_of(expr.left) != "string" && expr.left.kind == "Ident" {
            let cn = expr.left.name
            // sqrt(x) → __approx_sqrt(x, precision)
            if cn == "sqrt" || cn == "exp" || cn == "sin" || cn == "cos" {
                let approx_name = "__approx_" + cn
                let mut new_args = []
                if type_of(expr.args) == "array" {
                    let mut ai = 0
                    while ai < len(expr.args) {
                        new_args = new_args.push(rewrite_approx_expr(expr.args[ai], precision_str))
                        ai = ai + 1
                    }
                }
                m974_approx_rewrites = m974_approx_rewrites + 1
                return make_call_node(approx_name, new_args)
            }
        }
        // Recurse into args
        let mut new_args = []
        if type_of(expr.args) == "array" {
            let mut ai = 0
            while ai < len(expr.args) {
                new_args = new_args.push(rewrite_approx_expr(expr.args[ai], precision_str))
// M974: Tail Call Optimization (TCO) — tail-position calls → jumps
