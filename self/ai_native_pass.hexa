// ═══════════════════════════════════════════════════════════════════
//  #34 Tail Call Optimization (TCO) — detect tail-position calls and
//  convert to while-loop with parameter reassignment (prevents stack overflow).
//  Handles: fn f(x) { ... return f(expr) } → fn f(x) { while true { ... x = expr; continue } }
// ═══════════════════════════════════════════════════════════════════

// Detect if the last statement in a body is a tail call to self_name,
// supporting if/else branches where both sides return self-call.
fn is_tail_position_call(body, self_name) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    if n == 0 { return false }
    let last = body[n - 1]
    if last.kind == "ReturnStmt" {
        return expr_calls_self(last.left, self_name)
    }
    // If the last stmt is an IfStmt, check both branches
    if last.kind == "IfStmt" {
        let then_ok = is_tail_position_call(last.body, self_name)
        let else_ok = is_tail_position_call(last.else_body, self_name)
        return then_ok && else_ok
    }
    return false
}

// Extract args from a Call node (self-call)
fn extract_call_args(expr) {
    if type_of(expr) == "string" { return [] }
    if expr.kind == "Call" {
        if type_of(expr.args) == "array" { return expr.args }
    }
    return []
}

// Build assignment statements: param_i = arg_i, for TCO rewrite
fn build_tco_assigns(params, args) {
    let mut out = []
    let n = len(params)
    let an = len(args)
    let mut i = 0
    while i < n {
        if i < an {
            // Assign param = new_arg via AssignStmt (left=Ident(param), right=arg)
            let lhs = make_ident(params[i].name)
            out = out.push(AstNode {
                kind: "AssignStmt", name: "", value: "", op: "",
                left: lhs, right: args[i], cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            })
        }
