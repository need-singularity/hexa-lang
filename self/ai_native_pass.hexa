// ── M961: Build merge-sort replacement body ────────────────────
// Generates the body for a merge-sort function that replaces bubble sort.
// The rewrite produces:
//   fn <name>(arr) {
//     let n = len(arr)
//     if n <= 1 { return arr }
//     let mid = n / 2
//     let mut left = []
//     let mut i = 0
//     while i < mid { left = left.push(arr[i]); i = i + 1 }
//     let mut right = []
//     let mut j = mid
//     while j < n { right = right.push(arr[j]); j = j + 1 }
//     left = <name>(left)
//     right = <name>(right)
//     // merge
//     let mut result = []
//     let mut li = 0
//     let mut ri = 0
//     while li < len(left) && ri < len(right) {
//       if left[li] <= right[ri] { result = result.push(left[li]); li = li + 1 }
//       else { result = result.push(right[ri]); ri = ri + 1 }
//     }
//     while li < len(left) { result = result.push(left[li]); li = li + 1 }
//     while ri < len(right) { result = result.push(right[ri]); ri = ri + 1 }
//     return result
//   }

fn make_merge_sort_body(fn_name, param_name) {
    let arr = make_ident(param_name)
    let mut body = []

    // let n = len(arr)
    body = body.push(make_let_stmt("n", make_call_node("len", [arr])))

    // if n <= 1 { return arr }
    let early_ret = make_if_expr(
        make_binop("<=", make_ident("n"), make_int_lit(1)),
        [make_return_expr(make_ident(param_name))],
        []
    )
    body = body.push(make_expr_stmt(early_ret))

    // let mid = n / 2
    body = body.push(make_let_stmt("mid", make_binop("/", make_ident("n"), make_int_lit(2))))

    // let mut left = []
    body = body.push(make_let_mut_stmt("left", make_array_lit([])))
    // let mut i = 0
    body = body.push(make_let_mut_stmt("i", make_int_lit(0)))
    // while i < mid { left = left.push(arr[i]); i = i + 1 }
    let left_loop_body = [
        make_assign_stmt("left", make_method_call(make_ident("left"), "push", [make_index(arr, make_ident("i"))])),
        make_assign_stmt("i", make_binop("+", make_ident("i"), make_int_lit(1)))
    ]
    body = body.push(make_while_stmt(make_binop("<", make_ident("i"), make_ident("mid")), left_loop_body))

    // let mut right = []
    body = body.push(make_let_mut_stmt("right", make_array_lit([])))
    // let mut j = mid
    body = body.push(make_let_mut_stmt("j", make_ident("mid")))
    // while j < n { right = right.push(arr[j]); j = j + 1 }
    let right_loop_body = [
        make_assign_stmt("right", make_method_call(make_ident("right"), "push", [make_index(arr, make_ident("j"))])),
        make_assign_stmt("j", make_binop("+", make_ident("j"), make_int_lit(1)))
    ]
    body = body.push(make_while_stmt(make_binop("<", make_ident("j"), make_ident("n")), right_loop_body))

    // left = <fn_name>(left)
    body = body.push(make_assign_stmt("left", make_call_node(fn_name, [make_ident("left")])))
    // right = <fn_name>(right)
    body = body.push(make_assign_stmt("right", make_call_node(fn_name, [make_ident("right")])))

    // let mut result = []
    body = body.push(make_let_mut_stmt("result", make_array_lit([])))
    // let mut li = 0
    body = body.push(make_let_mut_stmt("li", make_int_lit(0)))
    // let mut ri = 0
    body = body.push(make_let_mut_stmt("ri", make_int_lit(0)))

    // while li < len(left) && ri < len(right) { ... }
    let merge_cond = make_binop("&&",
        make_binop("<", make_ident("li"), make_call_node("len", [make_ident("left")])),
        make_binop("<", make_ident("ri"), make_call_node("len", [make_ident("right")]))
    )
    let merge_if = make_if_expr(
        make_binop("<=", make_index(make_ident("left"), make_ident("li")), make_index(make_ident("right"), make_ident("ri"))),
        [
            make_assign_stmt("result", make_method_call(make_ident("result"), "push", [make_index(make_ident("left"), make_ident("li"))])),
            make_assign_stmt("li", make_binop("+", make_ident("li"), make_int_lit(1)))
        ],
        [
            make_assign_stmt("result", make_method_call(make_ident("result"), "push", [make_index(make_ident("right"), make_ident("ri"))])),
            make_assign_stmt("ri", make_binop("+", make_ident("ri"), make_int_lit(1)))
        ]
    )
    body = body.push(make_while_stmt(merge_cond, [make_expr_stmt(merge_if)]))

    // while li < len(left) { result = result.push(left[li]); li = li + 1 }
    let left_tail = [
        make_assign_stmt("result", make_method_call(make_ident("result"), "push", [make_index(make_ident("left"), make_ident("li"))])),
        make_assign_stmt("li", make_binop("+", make_ident("li"), make_int_lit(1)))
    ]
    body = body.push(make_while_stmt(make_binop("<", make_ident("li"), make_call_node("len", [make_ident("left")])), left_tail))

    // while ri < len(right) { result = result.push(right[ri]); ri = ri + 1 }
    let right_tail = [
        make_assign_stmt("result", make_method_call(make_ident("result"), "push", [make_index(make_ident("right"), make_ident("ri"))])),
        make_assign_stmt("ri", make_binop("+", make_ident("ri"), make_int_lit(1)))
    ]
    body = body.push(make_while_stmt(make_binop("<", make_ident("ri"), make_call_node("len", [make_ident("right")])), right_tail))

    // return result
    body = body.push(make_return_expr(make_ident("result")))

    return body
}

// Extract first param name from FnDecl node
fn get_first_param_name(fn_node) {
    if type_of(fn_node.params) != "array" { return "arr" }
    if len(fn_node.params) < 1 { return "arr" }
    return fn_node.params[0].name
}

fn is_literal_kind(k) {
    if k == "IntLit" { return true }
    if k == "FloatLit" { return true }
    if k == "BoolLit" { return true }
    if k == "StringLit" { return true }
    if k == "CharLit" { return true }
    // M292: Array literal also propagatable
    if k == "Array" { return true }
    return false
}

fn body_is_const_return(body) {
    if type_of(body) != "array" { return false }
    if len(body) != 1 { return false }
    let s = body[0]
    if s.kind != "ReturnStmt" { return false }
    let e = s.left
    if type_of(e) == "string" { return false }
    return is_literal_kind(e.kind)
}

fn count_unreachable(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    let mut hit = false
    while i < n {
        let stmt = body[i]
        if hit { c = c + 1 }
        if stmt.kind == "ReturnStmt" { hit = true }
        // M293: assert false also stops execution
        if stmt.kind == "AssertStmt" {
            let cc = stmt.left
            if type_of(cc) != "string" && cc.kind == "BoolLit" && cc.value == "false" {
                hit = true
            }
        }
        if stmt.kind == "WhileStmt" {
            c = c + count_unreachable(stmt.body)
        }
        i = i + 1
    }
    return c
}

fn is_tail_call(body, self_name) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    if n == 0 { return false }
    let last = body[n - 1]
    if last.kind != "ReturnStmt" { return false }
    return expr_calls_self(last.left, self_name)
}

fn body_has_let_mut(body) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    let mut i = 0
    while i < n {
        let k = body[i].kind
        if k == "LetMutStmt" { return true }
        if k == "WhileStmt" {
            if body_has_let_mut(body[i].body) { return true }
        }
        i = i + 1
    }
    return false
}

// M958 helper: body contains a ReturnStmt inside a WhileStmt (possibly nested in If)
fn body_has_return_in_while(body) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "WhileStmt" {
            if body_has_return_any(stmt.body) { return true }
        }
        i = i + 1
    }
    return false
}

fn body_has_return_any(body) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "ReturnStmt" { return true }
        if stmt.kind == "WhileStmt" {
            if body_has_return_any(stmt.body) { return true }
        }
        if stmt.kind == "IfStmt" {
            if body_has_return_any(stmt.body) { return true }
        }
        i = i + 1
    }
    return false
}

fn while_depth(body) {
    if type_of(body) != "array" { return 0 }
    let mut maxd = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "WhileStmt" {
            let sub = while_depth(stmt.body)
            let here = 1 + sub
            if here > maxd { maxd = here }
        }
        i = i + 1
    }
    return maxd
}

fn count_returns(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "ReturnStmt" { c = c + 1 }
        if stmt.kind == "WhileStmt" { c = c + count_returns(stmt.body) }
        i = i + 1
    }
    return c
}

fn count_assigns(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "AssignStmt" { c = c + 1 }
        if stmt.kind == "WhileStmt" { c = c + count_assigns(stmt.body) }
        i = i + 1
    }
    return c
}

fn count_lets(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "LetStmt" { c = c + 1 }
        if stmt.kind == "LetMutStmt" { c = c + 1 }
        if stmt.kind == "WhileStmt" { c = c + count_lets(stmt.body) }
        i = i + 1
    }
    return c
}

fn count_exprstmts(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "ExprStmt" { c = c + 1 }
        if stmt.kind == "WhileStmt" { c = c + count_exprstmts(stmt.body) }
        i = i + 1
    }
    return c
}

fn count_asserts(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "AssertStmt" { c = c + 1 }
        if stmt.kind == "WhileStmt" { c = c + count_asserts(stmt.body) }
        i = i + 1
    }
    return c
}

fn count_whiles(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "WhileStmt" {
            c = c + 1
            c = c + count_whiles(stmt.body)
        }
        i = i + 1
    }
    return c
}

fn count_expr_binops(expr) {
    if type_of(expr) == "string" { return 0 }
    let mut c = 0
    if expr.kind == "BinOp" {
        c = 1 + count_expr_binops(expr.left) + count_expr_binops(expr.right)
    }
    if expr.kind == "Call" {
        let args = expr.args
        if type_of(args) == "array" {
            let n = len(args)
            let mut i = 0
            while i < n {
                c = c + count_expr_binops(args[i])
                i = i + 1
            }
        }
    }
    return c
}

fn count_expr_calls_m352(expr) {
    if type_of(expr) == "string" { return 0 }
    let mut c = 0
    if expr.kind == "Call" {
        c = 1
        let args = expr.args
        if type_of(args) == "array" {
            let n = len(args)
            let mut i = 0
            while i < n {
                c = c + count_expr_calls_m352(args[i])
                i = i + 1
            }
        }
    }
    if expr.kind == "BinOp" {
        c = count_expr_calls_m352(expr.left) + count_expr_calls_m352(expr.right)
    }
    return c
}

fn count_expr_intlits(expr) {
    if type_of(expr) == "string" { return 0 }
    if expr.kind == "IntLit" { return 1 }
    if expr.kind == "BinOp" {
        return count_expr_intlits(expr.left) + count_expr_intlits(expr.right)
    }
    if expr.kind == "Call" {
        let mut c = 0
        let args = expr.args
        if type_of(args) == "array" {
            let n = len(args)
            let mut i = 0
            while i < n {
                c = c + count_expr_intlits(args[i])
                i = i + 1
            }
        }
        return c
    }
    return 0
}

fn count_body_binops(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "ReturnStmt" { c = c + count_expr_binops(stmt.left) }
        if stmt.kind == "LetStmt" { c = c + count_expr_binops(stmt.left) }
        if stmt.kind == "LetMutStmt" { c = c + count_expr_binops(stmt.left) }
        if stmt.kind == "AssignStmt" { c = c + count_expr_binops(stmt.left) + count_expr_binops(stmt.right) }
        if stmt.kind == "ExprStmt" { c = c + count_expr_binops(stmt.left) }
        if stmt.kind == "AssertStmt" { c = c + count_expr_binops(stmt.left) }
        if stmt.kind == "WhileStmt" {
            c = c + count_expr_binops(stmt.cond)
            c = c + count_body_binops(stmt.body)
        }
        i = i + 1
    }
    return c
}

fn count_body_calls_m352(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "ReturnStmt" { c = c + count_expr_calls_m352(stmt.left) }
        if stmt.kind == "LetStmt" { c = c + count_expr_calls_m352(stmt.left) }
        if stmt.kind == "LetMutStmt" { c = c + count_expr_calls_m352(stmt.left) }
        if stmt.kind == "AssignStmt" { c = c + count_expr_calls_m352(stmt.left) + count_expr_calls_m352(stmt.right) }
        if stmt.kind == "ExprStmt" { c = c + count_expr_calls_m352(stmt.left) }
        if stmt.kind == "AssertStmt" { c = c + count_expr_calls_m352(stmt.left) }
        if stmt.kind == "WhileStmt" {
            c = c + count_expr_calls_m352(stmt.cond)
            c = c + count_body_calls_m352(stmt.body)
        }
        i = i + 1
    }
    return c
}

fn count_expr_by_kind(expr, kind) {
    if type_of(expr) == "string" { return 0 }
    let mut c = 0
    if expr.kind == kind { c = 1 }
    if expr.kind == "BinOp" {
        c = c + count_expr_by_kind(expr.left, kind) + count_expr_by_kind(expr.right, kind)
    }
    if expr.kind == "Call" {
        let args = expr.args
        if type_of(args) == "array" {
            let n = len(args)
            let mut i = 0
            while i < n {
                c = c + count_expr_by_kind(args[i], kind)
                i = i + 1
            }
        }
    }
    return c
}

fn count_body_by_kind(body, kind) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "ReturnStmt" { c = c + count_expr_by_kind(stmt.left, kind) }
        if stmt.kind == "LetStmt" { c = c + count_expr_by_kind(stmt.left, kind) }
        if stmt.kind == "LetMutStmt" { c = c + count_expr_by_kind(stmt.left, kind) }
        if stmt.kind == "AssignStmt" { c = c + count_expr_by_kind(stmt.left, kind) + count_expr_by_kind(stmt.right, kind) }
        if stmt.kind == "ExprStmt" { c = c + count_expr_by_kind(stmt.left, kind) }
        if stmt.kind == "AssertStmt" { c = c + count_expr_by_kind(stmt.left, kind) }
        if stmt.kind == "WhileStmt" {
            c = c + count_expr_by_kind(stmt.cond, kind)
            c = c + count_body_by_kind(stmt.body, kind)
        }
        i = i + 1
    }
    return c
}

fn count_body_intlits(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "ReturnStmt" { c = c + count_expr_intlits(stmt.left) }
        if stmt.kind == "LetStmt" { c = c + count_expr_intlits(stmt.left) }
        if stmt.kind == "LetMutStmt" { c = c + count_expr_intlits(stmt.left) }
        if stmt.kind == "AssignStmt" { c = c + count_expr_intlits(stmt.left) + count_expr_intlits(stmt.right) }
        if stmt.kind == "ExprStmt" { c = c + count_expr_intlits(stmt.left) }
        if stmt.kind == "AssertStmt" { c = c + count_expr_intlits(stmt.left) }
        if stmt.kind == "WhileStmt" {
            c = c + count_expr_intlits(stmt.cond)
            c = c + count_body_intlits(stmt.body)
        }
        i = i + 1
    }
    return c
}

fn count_letmuts(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "LetMutStmt" { c = c + 1 }
        if stmt.kind == "WhileStmt" { c = c + count_letmuts(stmt.body) }
        i = i + 1
    }
    return c
}

fn count_void_returns(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "ReturnStmt" {
            if type_of(stmt.left) == "string" { c = c + 1 }
        }
        if stmt.kind == "WhileStmt" { c = c + count_void_returns(stmt.body) }
        i = i + 1
    }
    return c
}

fn expr_count_calls(expr) {
    if type_of(expr) == "string" { return 0 }
    let mut c = 0
    if expr.kind == "Call" {
        c = 1
        let args = expr.args
        if type_of(args) == "array" {
            let n = len(args)
            let mut i = 0
            while i < n {
                c = c + expr_count_calls(args[i])
                i = i + 1
            }
        }
    }
    if expr.kind == "BinOp" {
        c = c + expr_count_calls(expr.left)
        c = c + expr_count_calls(expr.right)
    }
    return c
}

fn stmts_count_calls(body) {
    if type_of(body) != "array" { return 0 }
    let mut total = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ExprStmt" || k == "ReturnStmt" || k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" {
            total = total + expr_count_calls(stmt.left)
        }
        if k == "AssignStmt" {
            total = total + expr_count_calls(stmt.right)
        }
        if k == "WhileStmt" {
            total = total + expr_count_calls(stmt.cond)
            total = total + stmts_count_calls(stmt.body)
        }
        i = i + 1
    }
    return total
}

fn expr_calls_self(expr, self_name) {
    if type_of(expr) == "string" { return false }
    let k = expr.kind
    if k == "Call" {
        let callee = expr.left
        if type_of(callee) != "string" {
            if callee.kind == "Ident" && callee.name == self_name {
                return true
            }
        }
        // recurse into args
        let args = expr.args
        if type_of(args) == "array" {
            let n = len(args)
            let mut i = 0
            while i < n {
                if expr_calls_self(args[i], self_name) { return true }
                i = i + 1
            }
        }
        return false
    }
    if k == "BinOp" {
        if expr_calls_self(expr.left, self_name) { return true }
        if expr_calls_self(expr.right, self_name) { return true }
    }
    return false
}

fn stmts_call_self(body, self_name) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ExprStmt" {
            if expr_calls_self(stmt.left, self_name) { return true }
        }
        if k == "ReturnStmt" {
            if expr_calls_self(stmt.left, self_name) { return true }
        }
        if k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" {
            if expr_calls_self(stmt.left, self_name) { return true }
        }
        if k == "AssignStmt" {
            if expr_calls_self(stmt.right, self_name) { return true }
        }
        if k == "WhileStmt" {
            if expr_calls_self(stmt.cond, self_name) { return true }
            if stmts_call_self(stmt.body, self_name) { return true }
        }
        i = i + 1
    }
    return false
}

fn body_has_loop(body) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    let mut i = 0
    while i < n {
        let k = body[i].kind
        if k == "WhileStmt" { return true }
        if k == "ForStmt" { return true }
        if k == "LoopStmt" { return true }
        i = i + 1
    }
    return false
}

// M3: body size — counts top-level statements only (simple heuristic).
// Inline threshold: 8 stmts. Over → "too big" diagnostic.
fn body_stmt_count(body) {
    if type_of(body) != "array" { return 0 }
    return len(body)
}

// M4: check a set of attrs for known conflicts.
// Returns reason string if conflict, else "".
fn attr_has(attrs, target) {
    let n = len(attrs)
    let mut i = 0
    while i < n {
        if attrs[i] == target { return true }
        i = i + 1
    }
    return false
}

fn find_attr_conflict(attrs) {
    if attr_has(attrs, "hot") && attr_has(attrs, "cold") {
        return "hot+cold"
    }
    if attr_has(attrs, "inline") && attr_has(attrs, "cold") {
        return "inline+cold"
    }
    if attr_has(attrs, "pure") && attr_has(attrs, "evolve") {
        return "pure+evolve"
    }
    return ""
}

// ═══════════════════════════════════════════════════════════
//  ROI #42: Loop Rotation — while→do-while transform
//  Transforms `while cond { body }` into:
//    if cond { do { body } while cond }
//  This eliminates one branch per iteration and enables LICM.
//  Detection: WhileStmt with non-trivial body.
//  Rewrite: wraps in IfExpr guard + internal do-while.
// ═══════════════════════════════════════════════════════════

fn detect_loop_rotation_candidate(stmt) {
    // A WhileStmt whose condition is not a constant true/false literal
    // is a candidate for loop rotation.
    if stmt.kind != "WhileStmt" { return false }
    if type_of(stmt.body) != "array" { return false }
    if len(stmt.body) == 0 { return false }
    // Skip while(true) — infinite loops are not candidates
    if type_of(stmt.cond) != "string" {
        if stmt.cond.kind == "BoolLit" { return false }
    }
    return true
}

fn rotate_loop(stmt) {
    // Transform: while(cond) { body }
    // Into equivalent: if(cond) { body; while(cond) { body } }
    // This is the standard loop-rotation form: the first iteration
    // executes unconditionally after the guard, reducing branch count.
    let rotated_while = make_while_stmt(stmt.cond, stmt.body)
    let mut guarded_body = []
    let mut bi = 0
    while bi < len(stmt.body) {
        guarded_body = guarded_body.push(stmt.body[bi])
        bi = bi + 1
    }
    guarded_body = guarded_body.push(rotated_while)
    return make_if_expr(stmt.cond, guarded_body, [])
}

fn apply_loop_rotation_body(body) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if detect_loop_rotation_candidate(stmt) {
            m974_loop_rotations = m974_loop_rotations + 1
            out = out.push(rotate_loop(stmt))
        } else {
            out = out.push(stmt)
        }
        i = i + 1
    }
    return out
}

fn apply_loop_rotation(ast) {
    let mut out = []
    let n = len(ast)
    let mut i = 0
    while i < n {
        let node = ast[i]
        if node.kind == "FnDecl" {
            let new_body = apply_loop_rotation_body(node.body)
            if m974_loop_rotations > 0 {
                out = out.push(rewrite_fn_with_body(node, new_body))
            } else {
                out = out.push(node)
            }
        } else {
            out = out.push(node)
        }
        i = i + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════
//  ROI #43: @thread_local — TLS promotion pass
//  Detects variables annotated with @thread_local and validates
//  they are not shared across threads (no @parallel/@gpu usage).
//  Promotes validated vars to thread-local storage.
// ═══════════════════════════════════════════════════════════

fn check_thread_local_valid(fn_node, attrs) {
    // @thread_local is invalid if combined with @parallel or @gpu
    // because those attrs imply cross-thread sharing
    if attr_has(attrs, "parallel") { return false }
    if attr_has(attrs, "gpu") { return false }
    return true
}

fn count_let_mut_vars(body) {
    if type_of(body) != "array" { return 0 }
    let n = len(body)
    let mut count = 0
    let mut i = 0
    while i < n {
        if body[i].kind == "LetMutStmt" {
            count = count + 1
        }
        i = i + 1
    }
    return count
}

fn apply_thread_local_pass(ast) {
    let n = len(ast)
    let mut i = 0
    while i < n {
        let node = ast[i]
        if node.kind == "FnDecl" {
            let attrs = split_attrs_m0(node.value)
            if attr_has(attrs, "thread_local") {
                if check_thread_local_valid(node, attrs) {
                    m975_thread_local_ok = m975_thread_local_ok + 1
                    let var_count = count_let_mut_vars(node.body)
                    m975_thread_local_vars = m975_thread_local_vars + var_count
                    println("[ai-native] @thread_local fn " + node.name + ": " + to_string(var_count) + " var(s) promoted to TLS")
                } else {
                    println("[ai-native] @thread_local CONFLICT fn " + node.name + ": combined with @parallel/@gpu")
                }
            }
        }
        i = i + 1
    }
    return ast
}

// ═══════════════════════════════════════════════════════════
//  ROI #44: Swiss Table hash map rewrite
//  Detects naive linear-probing hash table patterns and marks
//  them for swiss-table style SIMD probing optimization.
//  Pattern: while loop with index probing + comparison chain.
// ═══════════════════════════════════════════════════════════

fn detect_hash_probe_pattern(body) {
    // Look for the pattern:
    //   let mut idx = hash(key) % capacity
    //   while table[idx] != empty {
    //       if table[idx].key == key { ... }
    //       idx = (idx + 1) % capacity
    //   }
    // We detect: WhileStmt containing Index + BinOp(%) + AssignStmt with +1
    if type_of(body) != "array" { return 0 }
    let n = len(body)
    let mut candidates = 0
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "WhileStmt" {
            if type_of(stmt.body) == "array" {
                let wb = stmt.body
                let wn = len(wb)
                let mut has_index = false
                let mut has_mod_assign = false
                let mut j = 0
                while j < wn {
                    let ws = wb[j]
                    if ws.kind == "ExprStmt" || ws.kind == "LetStmt" || ws.kind == "LetMutStmt" {
                        if type_of(ws.left) != "string" {
                            if ws.left.kind == "Index" {
                                has_index = true
                            }
                        }
                    }
                    if ws.kind == "AssignStmt" {
                        if type_of(ws.left) != "string" {
                            if ws.left.kind == "BinOp" {
                                if ws.left.op == "%" {
                                    has_mod_assign = true
                                }
                            }
                        }
                    }
                    j = j + 1
                }
                if has_index && has_mod_assign {
                    candidates = candidates + 1
                }
            }
        }
        i = i + 1
    }
    return candidates
}

fn apply_swiss_table_pass(ast) {
    let n = len(ast)
    let mut i = 0
    while i < n {
        let node = ast[i]
        if node.kind == "FnDecl" {
            let candidates = detect_hash_probe_pattern(node.body)
            if candidates > 0 {
                m976_swiss_table_rewrites = m976_swiss_table_rewrites + candidates
                println("[ai-native] swiss-table: fn " + node.name + " has " + to_string(candidates) + " hash probe site(s) → SIMD rewrite candidate")
            }
        }
        i = i + 1
    }
    return ast
}

// ═══════════════════════════════════════════════════════════
//  ROI #45: @nonnull — null check elimination
//  On functions annotated @nonnull, eliminate redundant null
//  checks (if x == nil / if x != nil) when the value is proven
//  non-null from prior assignments or parameter annotations.
// ═══════════════════════════════════════════════════════════

fn is_nil_check(stmt) {
    // Detect: if x == nil { ... } or if x != nil { ... }
    if stmt.kind != "IfExpr" { return false }
    if type_of(stmt.cond) == "string" { return false }
    if stmt.cond.kind != "BinOp" { return false }
    let op = stmt.cond.op
    if op != "==" && op != "!=" { return false }
    // Check if either side is nil/null literal
    if type_of(stmt.cond.right) != "string" {
        if stmt.cond.right.kind == "Ident" {
            if stmt.cond.right.name == "nil" { return true }
            if stmt.cond.right.name == "null" { return true }
        }
        if stmt.cond.right.kind == "NilLit" { return true }
    }
    if type_of(stmt.cond.left) != "string" {
        if stmt.cond.left.kind == "Ident" {
            if stmt.cond.left.name == "nil" { return true }
            if stmt.cond.left.name == "null" { return true }
        }
        if stmt.cond.left.kind == "NilLit" { return true }
    }
    return false
}

fn elim_null_checks_body(body) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if is_nil_check(stmt) {
            m977_nonnull_elim = m977_nonnull_elim + 1
            // For == nil check: entire branch is dead (value proven nonnull)
            // For != nil check: inline the then-body (always taken)
            if stmt.cond.op == "!=" {
                // The then-body is always taken — inline it
                if type_of(stmt.then_body) == "array" {
                    let mut ti = 0
                    while ti < len(stmt.then_body) {
                        out = out.push(stmt.then_body[ti])
                        ti = ti + 1
                    }
                }
            }
            // == nil check: skip entirely (dead branch)
        } else {
            out = out.push(stmt)
        }
        i = i + 1
    }
    return out
}

fn apply_nonnull_pass(ast) {
    let mut out = []
    let n = len(ast)
    let mut i = 0
    while i < n {
        let node = ast[i]
        if node.kind == "FnDecl" {
            let attrs = split_attrs_m0(node.value)
            if attr_has(attrs, "nonnull") {
                m977_nonnull_ok = m977_nonnull_ok + 1
                let before = m977_nonnull_elim
                let new_body = elim_null_checks_body(node.body)
                let elim_count = m977_nonnull_elim - before
                if elim_count > 0 {
                    println("[ai-native] @nonnull fn " + node.name + ": eliminated " + to_string(elim_count) + " null check(s)")
                    out = out.push(rewrite_fn_with_body(node, new_body))
                } else {
                    out = out.push(node)
                }
            } else {
                out = out.push(node)
            }
        } else {
            out = out.push(node)
        }
        i = i + 1
    }
    return out
}

