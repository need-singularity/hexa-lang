// ── #46 Jump Threading ─────────────────────────────────────────
// Detects conditional branch chains: if-else where branches lead to
// further trivial conditional jumps. Threads the jump directly to
// the final target, eliminating intermediate blocks.
//
// Pattern detected:
//   if cond1 { if cond2 { X } else { Y } } else { Y }
// Rewrites to:
//   if cond1 && cond2 { X } else { Y }
fn stmts_equal_shallow(a, b) {
    if type_of(a) != "array" || type_of(b) != "array" { return false }
    if len(a) != len(b) { return false }
    let n = len(a)
    let mut i = 0
    while i < n {
        if type_of(a[i]) == "string" || type_of(b[i]) == "string" { return false }
        if a[i].kind != b[i].kind { return false }
        // Shallow: match ReturnStmt with same literal, or ExprStmt same
        if a[i].kind == "ReturnStmt" {
            if type_of(a[i].left) != "string" && type_of(b[i].left) != "string" {
                if a[i].left.kind == "IntLit" && b[i].left.kind == "IntLit" {
                    if a[i].left.value != b[i].left.value { return false }
                } else if a[i].left.kind == "Ident" && b[i].left.kind == "Ident" {
                    if a[i].left.name != b[i].left.name { return false }
                } else if a[i].left.kind == "BoolLit" && b[i].left.kind == "BoolLit" {
                    if a[i].left.value != b[i].left.value { return false }
                } else {
                    return false
                }
            } else if type_of(a[i].left) != type_of(b[i].left) {
                return false
            }
        } else if a[i].kind == "AssignStmt" {
            if a[i].name != b[i].name { return false }
            if type_of(a[i].right) != "string" && type_of(b[i].right) != "string" {
                if a[i].right.kind == "IntLit" && b[i].right.kind == "IntLit" {
                    if a[i].right.value != b[i].right.value { return false }
                } else {
                    return false
                }
            } else {
                return false
            }
        } else {
            return false
        }
        i = i + 1
    }
    return true
}

fn jump_thread_body(body) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if type_of(stmt) != "string" && stmt.kind == "IfStmt" {
            // Check: outer if has else_body, and inner then_body has single IfStmt
            let then_b = stmt.body
            let else_b = stmt.else_body
            if type_of(then_b) == "array" && len(then_b) == 1 && type_of(else_b) == "array" {
                let inner = then_b[0]
                if type_of(inner) != "string" && inner.kind == "IfStmt" {
                    let inner_else = inner.else_body
                    if type_of(inner_else) == "array" && stmts_equal_shallow(inner_else, else_b) {
                        // Thread: if cond1 && cond2 { inner_then } else { shared_else }
                        let combined_cond = AstNode {
                            kind: "BinOp",
                            op: "&&",
                            left: stmt.cond,
                            right: inner.cond
                        }
                        let threaded = AstNode {
                            kind: "IfStmt",
                            cond: combined_cond,
                            body: inner.body,
                            else_body: else_b
                        }
                        out = out.push(threaded)
                        m974_jump_thread = m974_jump_thread + 1
                        i = i + 1
                        continue
                    }
                }
            }
        }
        out = out.push(stmt)
        i = i + 1
    }
    return out
}

// Rewrite a body with tail calls → assignments + continue (within while(true) wrapper).
// Returns the new while-body statements.
fn tco_rewrite_body(body, self_name, params) {
    if type_of(body) != "array" { return body }
    let n = len(body)
    if n == 0 { return body }
    let mut out = []
    let mut i = 0
    while i < n - 1 {
        out = out.push(body[i])
        i = i + 1
    }
    // Rewrite the last stmt
    let last = body[n - 1]
    if last.kind == "ReturnStmt" && expr_calls_self(last.left, self_name) {
        // return self(a1, a2, ...) → p1=a1; p2=a2; ... (continue implicit in while)
        let args = extract_call_args(last.left)
        let assigns = build_tco_assigns(params, args)
        let an = len(assigns)
        let mut ai = 0
        while ai < an {
            out = out.push(assigns[ai])
            ai = ai + 1
        }
    } else if last.kind == "IfStmt" {
        // Rewrite both branches
        let new_then = tco_rewrite_body(last.body, self_name, params)
        let new_else = tco_rewrite_body(last.else_body, self_name, params)
        out = out.push(AstNode {
            kind: "IfStmt", name: "", value: "", op: "",
            left: "", right: "", cond: last.cond, then_body: "", else_body: "",
            params: "", body: new_then, args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        })
        // Attach else_body
        let last_out = out[len(out) - 1]
        out = []
        let mut oi = 0
        while oi < len(out) - 1 {
            out = out.push(out[oi])
            oi = oi + 1
        }
        out = out.push(AstNode {
            kind: "IfStmt", name: "", value: "", op: "",
            left: "", right: "", cond: last.cond, then_body: "", else_body: new_else,
            params: "", body: new_then, args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        })
    } else {
        out = out.push(last)
    }
    return out
}

// Full TCO pass for a single FnDecl — returns rewritten body or original.
fn tco_pass_fn(fn_node) {
    if !is_tail_position_call(fn_node.body, fn_node.name) { return fn_node }
    // Build: while(true) { <rewritten body> }
    let new_while_body = tco_rewrite_body(fn_node.body, fn_node.name, fn_node.params)
    let loop_node = make_while_stmt(make_bool_lit("true"), new_while_body)
    let new_body = [loop_node]
    m974_tco_rewrites = m974_tco_rewrites + 1
    println("[ai-native] fn " + fn_node.name + " REWRITE: TCO tail→while(true)")
    return rewrite_fn_with_body(fn_node, new_body)
}

// ═══════════════════════════════════════════════════════════════════
//  #35 phi-node mem2reg — promote stack variables (let mut) to SSA.
//  Detect let mut vars that are assigned once then only read → promote
//  to let (immutable). Also track vars assigned in branches → phi-node
//  candidate. This is a simplified mem2reg that catches the common case.
// ═══════════════════════════════════════════════════════════════════

// Count how many times a variable name appears as AssignStmt target in body
fn count_var_assigns(body, varname) {
    if type_of(body) != "array" { return 0 }
    let n = len(body)
    let mut c = 0
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "AssignStmt" {
            if type_of(stmt.left) != "string" && stmt.left.kind == "Ident" {
                if stmt.left.name == varname { c = c + 1 }
            }
        }
        if stmt.kind == "WhileStmt" {
            c = c + count_var_assigns(stmt.body, varname)
        }
        if stmt.kind == "IfStmt" {
            c = c + count_var_assigns(stmt.body, varname)
            if type_of(stmt.else_body) == "array" {
                c = c + count_var_assigns(stmt.else_body, varname)
            }
        }
        i = i + 1
    }
    return c
}

// Check if a var is read (as Ident) in an expression
fn expr_reads_var(expr, varname) {
    if type_of(expr) == "string" { return false }
    if expr.kind == "Ident" { return expr.name == varname }
    if expr.kind == "BinOp" {
        return expr_reads_var(expr.left, varname) || expr_reads_var(expr.right, varname)
    }
    if expr.kind == "UnaryOp" { return expr_reads_var(expr.left, varname) }
    if expr.kind == "Call" {
        if type_of(expr.args) == "array" {
            let n = len(expr.args)
            let mut i = 0
            while i < n {
                if expr_reads_var(expr.args[i], varname) { return true }
                i = i + 1
            }
        }
    }
    if expr.kind == "Index" {
        return expr_reads_var(expr.left, varname) || expr_reads_var(expr.right, varname)
    }
    return false
}

// mem2reg pass: promote let mut with 0 reassignments → let
fn mem2reg_pass_body(body) {
    if type_of(body) != "array" { return body }
    let n = len(body)
    // First pass: collect let mut names with 0 assigns after init
    let mut promotable_names = []
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "LetMutStmt" {
            let assigns = count_var_assigns(body, stmt.name)
            if assigns == 0 {
                // No reassignment → safe to promote to let
                promotable_names = promotable_names.push(stmt.name)
            }
        }
        i = i + 1
    }
    // Second pass: rewrite LetMutStmt → LetStmt for promotable vars
    if len(promotable_names) == 0 { return body }
    let mut out = []
    i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "LetMutStmt" {
            let mut found = false
            let pn = len(promotable_names)
            let mut pi = 0
            while pi < pn {
                if promotable_names[pi] == stmt.name { found = true }
                pi = pi + 1
            }
            if found {
                // Promote to LetStmt
                out = out.push(AstNode {
                    kind: "LetStmt", name: stmt.name, value: stmt.value, op: "",
                    left: stmt.left, right: "", cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                })
                m975_mem2reg_promoted = m975_mem2reg_promoted + 1
            } else {
                out = out.push(stmt)
            }
        } else {
            out = out.push(stmt)
        }
        i = i + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════════
//  #36 @inline_always — force-inline small hot functions.
//  Functions marked @inline_always have their body inlined at call sites.
//  Limit: body <= 10 stmts to prevent code bloat.
// ═══════════════════════════════════════════════════════════════════

// Check if a FnDecl has @inline_always attr
fn has_inline_always(fn_node) {
    if fn_node.value == "" { return false }
    let attrs = split_attrs_m0(fn_node.value)
    return attr_has(attrs, "inline_always")
}

// Collect @inline_always fn bodies for inlining (pre-pass)
fn collect_inline_always_fns(ast) {
    m976_ia_names = []
    m976_ia_bodies = []
    m976_ia_params = []
    let n = len(ast)
    let mut i = 0
    while i < n {
        let node = ast[i]
        if node.kind == "FnDecl" && has_inline_always(node) {
            let bsz = body_stmt_count(node.body)
            if bsz <= 10 {
                m976_ia_names = m976_ia_names.push(node.name)
                m976_ia_bodies = m976_ia_bodies.push(node.body)
                m976_ia_params = m976_ia_params.push(node.params)
                m976_inline_always_ok = m976_inline_always_ok + 1
                println("[ai-native] fn " + node.name + " OK: @inline_always (" + to_string(bsz) + " stmt(s))")
            } else {
                m976_inline_always_too_big = m976_inline_always_too_big + 1
                println("[ai-native] fn " + node.name + " WARN: @inline_always body too large (" + to_string(bsz) + " stmts > 10)")
            }
        }
        i = i + 1
    }
}

// Substitute params with args in an expression (for inlining)
fn subst_expr(expr, param_names, arg_exprs) {
    if type_of(expr) == "string" { return expr }
    let k = expr.kind
    if k == "Ident" {
        let n = len(param_names)
        let mut i = 0
        while i < n {
            if param_names[i] == expr.name {
                if i < len(arg_exprs) { return arg_exprs[i] }
            }
            i = i + 1
        }
        return expr
    }
    if k == "BinOp" {
        let nl = subst_expr(expr.left, param_names, arg_exprs)
        let nr = subst_expr(expr.right, param_names, arg_exprs)
        return AstNode {
            kind: "BinOp", name: "", value: "", op: expr.op,
            left: nl, right: nr, cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    if k == "UnaryOp" {
        let no = subst_expr(expr.left, param_names, arg_exprs)
        return AstNode {
            kind: "UnaryOp", name: "", value: "", op: expr.op,
            left: no, right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    if k == "Call" {
        let mut new_args = []
        if type_of(expr.args) == "array" {
            let an = len(expr.args)
            let mut ai = 0
            while ai < an {
                new_args = new_args.push(subst_expr(expr.args[ai], param_names, arg_exprs))
                ai = ai + 1
            }
        }
        return AstNode {
            kind: "Call", name: expr.name, value: expr.value, op: expr.op,
            left: rewrite_approx_expr(expr.left, precision_str), right: "", cond: "", then_body: "", else_body: "",
            kind: "Call", name: "", value: "", op: "",
            left: subst_expr(expr.left, param_names, arg_exprs), right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: new_args, fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    if expr.kind == "BinOp" {
        return AstNode {
            kind: "BinOp", name: "", value: "", op: expr.op,
            left: rewrite_approx_expr(expr.left, precision_str), right: rewrite_approx_expr(expr.right, precision_str), cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    if expr.kind == "UnaryOp" {
        return AstNode {
            kind: "UnaryOp", name: "", value: "", op: expr.op,
            left: rewrite_approx_expr(expr.left, precision_str), right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    if expr.kind == "Index" {
        return AstNode {
            kind: "Index", name: "", value: "", op: "",
            left: rewrite_approx_expr(expr.left, precision_str), right: rewrite_approx_expr(expr.right, precision_str), cond: "", then_body: "", else_body: "",
    if k == "Index" {
        return AstNode {
            kind: "Index", name: "", value: "", op: "",
            left: subst_expr(expr.left, param_names, arg_exprs), right: subst_expr(expr.right, param_names, arg_exprs), cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    return expr
}

fn rewrite_approx_body(body, precision_str) {
    if type_of(body) != "array" { return body }
    let mut out = []
// ── #47 @stack_alloc detection ─────────────────────────────────
// Detects bounded-size arrays that can be allocated on the stack.
// Pattern: `@stack_alloc(N)` on let mut arr = [] followed by
// bounded pushes (< N), or `@stack_alloc` on fn with known-bounded arrays.
// The pass marks the node for codegen to use alloca instead of malloc.
fn detect_stack_alloc_candidate(body) {
    if type_of(body) != "array" { return 0 }
    let mut candidates = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ReturnStmt" {
            out = out.push(AstNode {
                kind: "ReturnStmt", name: "", value: "", op: "",
                left: rewrite_approx_expr(stmt.left, precision_str), right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            })
        } else if k == "LetStmt" || k == "LetMutStmt" {
            out = out.push(AstNode {
                kind: k, name: stmt.name, value: stmt.value, op: "",
                left: rewrite_approx_expr(stmt.left, precision_str), right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: stmt.ret_type,
                target: "", trait_name: "", methods: ""
            })
        } else if k == "AssignStmt" {
            out = out.push(AstNode {
                kind: "AssignStmt", name: stmt.name, value: stmt.value, op: "",
                left: stmt.left, right: rewrite_approx_expr(stmt.right, precision_str), cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            })
        } else if k == "ExprStmt" {
            out = out.push(AstNode {
                kind: "ExprStmt", name: "", value: "", op: "",
                left: rewrite_approx_expr(stmt.left, precision_str), right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            })
        } else if k == "WhileStmt" {
            out = out.push(AstNode {
                kind: "WhileStmt", name: "", value: "", op: "",
                left: "", right: "", cond: rewrite_approx_expr(stmt.cond, precision_str), then_body: "", else_body: "",
                params: "", body: rewrite_approx_body(stmt.body, precision_str), args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            })
        } else if k == "IfStmt" {
            let mut eb = ""
            if type_of(stmt.else_body) == "array" { eb = rewrite_approx_body(stmt.else_body, precision_str) }
            out = out.push(AstNode {
                kind: "IfStmt", name: "", value: "", op: "",
                left: "", right: "", cond: rewrite_approx_expr(stmt.cond, precision_str), then_body: rewrite_approx_body(stmt.then_body, precision_str), else_body: eb,
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            })
        } else {
            out = out.push(stmt)
        }
        i = i + 1
    }
    return out
}

// ── M975: DCE extended — unused let bindings + unused imports ──
// Collects all names read in body, then drops LetStmt/LetMutStmt whose name
// is never referenced. Preserves side-effecting initializers (Call exprs).

fn collect_used_names_expr(expr, used) {
    if type_of(expr) == "string" { return used }
    if expr.kind == "Ident" { return used.push(expr.name) }
    if expr.kind == "BinOp" {
        let u1 = collect_used_names_expr(expr.left, used)
        return collect_used_names_expr(expr.right, u1)
    }
    if expr.kind == "UnaryOp" { return collect_used_names_expr(expr.left, used) }
    if expr.kind == "Index" {
        let u1 = collect_used_names_expr(expr.left, used)
        return collect_used_names_expr(expr.right, u1)
    }
    if expr.kind == "Call" {
        let mut u = collect_used_names_expr(expr.left, used)
        if type_of(expr.args) == "array" {
            let mut ai = 0
            while ai < len(expr.args) {
                u = collect_used_names_expr(expr.args[ai], u)
                ai = ai + 1
            }
        }
        return u
    }
    if expr.kind == "FieldAccess" { return collect_used_names_expr(expr.left, used) }
    return used
}

fn collect_used_names_body(body, used) {
    if type_of(body) != "array" { return used }
    let n = len(body)
    let mut i = 0
    let mut u = used
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ReturnStmt" { u = collect_used_names_expr(stmt.left, u) }
        if k == "LetStmt" || k == "LetMutStmt" { u = collect_used_names_expr(stmt.left, u) }
        if k == "AssignStmt" {
            u = collect_used_names_expr(stmt.left, u)
            u = collect_used_names_expr(stmt.right, u)
        }
        if k == "ExprStmt" { u = collect_used_names_expr(stmt.left, u) }
        if k == "WhileStmt" {
            u = collect_used_names_expr(stmt.cond, u)
            u = collect_used_names_body(stmt.body, u)
        }
        if k == "IfStmt" {
            u = collect_used_names_expr(stmt.cond, u)
            u = collect_used_names_body(stmt.then_body, u)
            if type_of(stmt.else_body) == "array" { u = collect_used_names_body(stmt.else_body, u) }
        }
        if k == "ForStmt" {
            u = collect_used_names_expr(stmt.iter_expr, u)
            u = collect_used_names_body(stmt.body, u)
        }
        i = i + 1
    }
    return u
}

fn expr_has_side_effect(expr) {
    if type_of(expr) == "string" { return false }
    if expr.kind == "Call" { return true }
    if expr.kind == "BinOp" { return expr_has_side_effect(expr.left) || expr_has_side_effect(expr.right) }
    if expr.kind == "UnaryOp" { return expr_has_side_effect(expr.left) }
    return false
}

fn name_in_list(name, lst) {
    let mut i = 0
    while i < len(lst) {
        if lst[i] == name { return true }
        i = i + 1
    }
    return false
}

fn eliminate_unused_lets(body) {
    if type_of(body) != "array" { return body }
    // Pass 1: collect all used names
    let used = collect_used_names_body(body, [])
    // Pass 2: drop unused let bindings (preserve side-effecting inits)
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "LetStmt" || k == "LetMutStmt" {
            let nm = stmt.name
            // Check if this name is used anywhere else in the body
            let mut is_used = false
            let mut j = 0
            while j < len(used) {
                // Only count uses that are NOT from this binding's own init
                if used[j] == nm { is_used = true }
                j = j + 1
            }
            // More precise: check if name appears in any stmt OTHER than this one
            let used_elsewhere = collect_used_names_body_except(body, i, [])
            if name_in_list(nm, used_elsewhere) {
                out = out.push(stmt)
            } else if expr_has_side_effect(stmt.left) {
                // Keep as ExprStmt to preserve side effects
                out = out.push(make_expr_stmt(stmt.left))
                m975_dce_unused_lets = m975_dce_unused_lets + 1
            } else {
                m975_dce_unused_lets = m975_dce_unused_lets + 1
            }
        } else if k == "WhileStmt" {
            out = out.push(AstNode {
                kind: "WhileStmt", name: "", value: "", op: "",
                left: "", right: "", cond: stmt.cond, then_body: "", else_body: "",
                params: "", body: eliminate_unused_lets(stmt.body), args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            })
        } else if k == "IfStmt" {
            let mut eb = ""
            if type_of(stmt.else_body) == "array" { eb = eliminate_unused_lets(stmt.else_body) }
            out = out.push(AstNode {
                kind: "IfStmt", name: "", value: "", op: "",
                left: "", right: "", cond: stmt.cond, then_body: eliminate_unused_lets(stmt.then_body), else_body: eb,
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            })
        } else {
            out = out.push(stmt)
        }
        i = i + 1
    }
    return out
}

fn collect_used_names_body_except(body, skip_idx, used) {
    if type_of(body) != "array" { return used }
    let n = len(body)
    let mut i = 0
    let mut u = used
    while i < n {
        if i != skip_idx {
            let stmt = body[i]
            let k = stmt.kind
            if k == "ReturnStmt" { u = collect_used_names_expr(stmt.left, u) }
            if k == "LetStmt" || k == "LetMutStmt" { u = collect_used_names_expr(stmt.left, u) }
            if k == "AssignStmt" {
                u = collect_used_names_expr(stmt.left, u)
                u = collect_used_names_expr(stmt.right, u)
            }
            if k == "ExprStmt" { u = collect_used_names_expr(stmt.left, u) }
            if k == "WhileStmt" {
                u = collect_used_names_expr(stmt.cond, u)
                u = collect_used_names_body(stmt.body, u)
            }
            if k == "IfStmt" {
                u = collect_used_names_expr(stmt.cond, u)
                u = collect_used_names_body(stmt.then_body, u)
                if type_of(stmt.else_body) == "array" { u = collect_used_names_body(stmt.else_body, u) }
            }
        }
        i = i + 1
    }
    return u
}

// Unused import detection (module-level UseStmt elimination)
fn eliminate_unused_imports(ast) {
    if type_of(ast) != "array" { return ast }
    // Pass 1: collect all names referenced across all stmts
    let used = collect_used_names_body(ast, [])
    // Pass 2: drop UseStmt whose imported name is never used
    let mut out = []
    let n = len(ast)
    let mut i = 0
    while i < n {
        let stmt = ast[i]
        if type_of(stmt) != "string" && stmt.kind == "UseStmt" {
            // import name is the last segment of the path
            let import_name = stmt.name
            if name_in_list(import_name, used) {
                out = out.push(stmt)
            } else {
                m975_dce_unused_imports = m975_dce_unused_imports + 1
            }
        } else {
            out = out.push(stmt)
        }
        i = i + 1
    }
    return out
}

// ── M976: DP sliding window rewrite — O(n) → O(k) memory ──
// When dp[i] = f(dp[i-1], dp[i-2]) is detected, rewrite the while loop
// to use k scalar variables instead of array allocation.
// This function detects the max lookback distance K in a DP expression.
fn max_dp_lookback(expr, arr_name) {
    if type_of(expr) == "string" { return 0 }
    if expr.kind == "Index" {
        if type_of(expr.left) != "string" && expr.left.kind == "Ident" && expr.left.name == arr_name {
            if type_of(expr.right) != "string" && expr.right.kind == "BinOp" && expr.right.op == "-" {
                if type_of(expr.right.right) != "string" && expr.right.right.kind == "IntLit" {
                    return parse_int_str(expr.right.right.value)
                }
            }
        }
    }
    if expr.kind == "BinOp" {
        let l = max_dp_lookback(expr.left, arr_name)
        let r = max_dp_lookback(expr.right, arr_name)
        if l > r { return l }
        return r
    }
    if expr.kind == "UnaryOp" { return max_dp_lookback(expr.left, arr_name) }
    if expr.kind == "Call" {
        let mut mx = 0
        if type_of(expr.args) == "array" {
            let mut ai = 0
            while ai < len(expr.args) {
                let v = max_dp_lookback(expr.args[ai], arr_name)
                if v > mx { mx = v }
                ai = ai + 1
            }
        }
        return mx
    }
    return 0
}

// Detect DP sliding window pattern in a while-loop body.
// Returns [arr_name, lookback_k] or "" if not found.
fn detect_dp_sliding_pattern(body) {
        if type_of(stmt) != "string" {
            if stmt.kind == "LetMutStmt" {
                // Check if init is empty array literal and bounded pushes follow
                if type_of(stmt.left) != "string" && stmt.left.kind == "ArrayLit" {
                    // Count pushes to this var in subsequent stmts
                    let vname = stmt.name
                    let bound = count_pushes_to_var(body, vname, i + 1)
                    if bound > 0 && bound <= 1024 {
                        candidates = candidates + 1
                    }
                }
            }
            if stmt.kind == "WhileStmt" {
                candidates = candidates + detect_stack_alloc_candidate(stmt.body)
            }
        }
        i = i + 1
    }
    return candidates
}

fn count_pushes_to_var(body, vname, start) {
    let n = len(body)
    let mut count = 0
    let mut i = start
    while i < n {
        let stmt = body[i]
        if type_of(stmt) != "string" && stmt.kind == "AssignStmt" {
            if stmt.name == vname {
                if type_of(stmt.right) != "string" && stmt.right.kind == "MethodCall" {
                    if stmt.right.method == "push" {
                        count = count + 1
                    }
                }
            }
        }
        i = i + 1
    }
    return count
}

// ── #48 Induction Variable Simplification ──────────────────────
// Detects loop induction variable expressions like `i * stride`
// used inside while-loops and simplifies to additive form.
// Pattern:
//   while i < n { ... arr[i * stride] ... i = i + 1 }
// Simplified:
//   let mut __iv = 0; while i < n { ... arr[__iv] ... __iv = __iv + stride; i = i + 1 }
fn detect_iv_multiply_in_loop(body) {
    if type_of(body) != "array" { return 0 }
    let mut count = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if type_of(stmt) != "string" && stmt.kind == "WhileStmt" {
            let loop_body = stmt.body
            if type_of(loop_body) == "array" {
                // Find the induction variable (i = i + 1 pattern)
                let iv_name = find_loop_iv(loop_body)
                if iv_name != "" {
                    // Count multiply-by-iv expressions in the body
                    count = count + count_iv_multiply_exprs(loop_body, iv_name)
                }
            }
        }
        i = i + 1
    }
    return count
}

fn find_loop_iv(body) {
    if type_of(body) != "array" { return "" }
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "WhileStmt" {
            if type_of(stmt.body) == "array" {
                let wn = len(stmt.body)
                let mut wi = 0
                while wi < wn {
                    let ws = stmt.body[wi]
                    if ws.kind == "AssignStmt" {
                        let lhs = ws.left
                        if type_of(lhs) != "string" && lhs.kind == "Index" {
                            if type_of(lhs.left) != "string" && lhs.left.kind == "Ident" {
                                let arr_nm = lhs.left.name
                                let lookbacks = detect_dp_lookback(ws.right, arr_nm)
                                if lookbacks > 0 {
                                    let k = max_dp_lookback(ws.right, arr_nm)
                                    if k > 0 {
                                        return [arr_nm, k]
                                    }
                                }
                            }
                        }
                    }
                    wi = wi + 1
        if type_of(stmt) != "string" && stmt.kind == "AssignStmt" {
            // pattern: x = x + 1
            if type_of(stmt.right) != "string" && stmt.right.kind == "BinOp" {
                if stmt.right.op == "+" {
                    if type_of(stmt.right.left) != "string" && stmt.right.left.kind == "Ident" {
                        if stmt.right.left.name == stmt.name {
                            if type_of(stmt.right.right) != "string" && stmt.right.right.kind == "IntLit" {
                                return stmt.name
                            }
                        }
                    }
                }
            }
        }
        i = i + 1
    }
    return ""
}

// Rewrite DP body: replace dp array with K sliding variables.
// dp[i-1] → prev1, dp[i-2] → prev2, etc.
// After loop body, shift: prev2 = prev1; prev1 = current.
fn rewrite_dp_sliding_expr(expr, arr_name, k) {
    if type_of(expr) == "string" { return expr }
    if expr.kind == "Index" {
        if type_of(expr.left) != "string" && expr.left.kind == "Ident" && expr.left.name == arr_name {
            if type_of(expr.right) != "string" && expr.right.kind == "BinOp" && expr.right.op == "-" {
                if type_of(expr.right.right) != "string" && expr.right.right.kind == "IntLit" {
                    let offset = parse_int_str(expr.right.right.value)
                    return make_ident("__dp_prev" + to_string(offset))
                }
            }
            // dp[i] → __dp_cur
            return make_ident("__dp_cur")
        }
    }
    if expr.kind == "BinOp" {
        return AstNode {
            kind: "BinOp", name: "", value: "", op: expr.op,
            left: rewrite_dp_sliding_expr(expr.left, arr_name, k), right: rewrite_dp_sliding_expr(expr.right, arr_name, k), cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    if expr.kind == "UnaryOp" {
        return AstNode {
            kind: "UnaryOp", name: "", value: "", op: expr.op,
            left: rewrite_dp_sliding_expr(expr.left, arr_name, k), right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    if expr.kind == "Call" {
        let mut new_args = []
        if type_of(expr.args) == "array" {
            let mut ai = 0
            while ai < len(expr.args) {
                new_args = new_args.push(rewrite_dp_sliding_expr(expr.args[ai], arr_name, k))
// Inline @inline_always calls in an expression: replace Call(f, args) with body[last].left (return expr)
// For simplicity, only inline single-return-expr bodies (body = [ReturnStmt(expr)])
fn inline_always_expr(expr) {
    if type_of(expr) == "string" { return expr }
    let k = expr.kind
    if k == "Call" {
        let callee = expr.left
        if type_of(callee) != "string" && callee.kind == "Ident" {
            let cname = callee.name
            let in_n = len(m976_ia_names)
            let mut ii = 0
            while ii < in_n {
                if m976_ia_names[ii] == cname {
                    let fbody = m976_ia_bodies[ii]
                    let fparams = m976_ia_params[ii]
                    // Only inline if body is a single ReturnStmt
                    if type_of(fbody) == "array" && len(fbody) >= 1 {
                        let last_stmt = fbody[len(fbody) - 1]
                        if last_stmt.kind == "ReturnStmt" {
                            // Build param name list
                            let mut pnames = []
                            let pn = len(fparams)
                            let mut pi = 0
                            while pi < pn {
                                pnames = pnames.push(fparams[pi].name)
                                pi = pi + 1
                            }
                            // Build arg list (recurse first)
                            let mut new_args = []
                            if type_of(expr.args) == "array" {
                                let an = len(expr.args)
                                let mut ai = 0
                                while ai < an {
                                    new_args = new_args.push(inline_always_expr(expr.args[ai]))
                                    ai = ai + 1
                                }
                            }
                            let result = subst_expr(last_stmt.left, pnames, new_args)
                            m976_inline_always_inlined = m976_inline_always_inlined + 1
                            return result
                        }
                    }
                }
                ii = ii + 1
            }
        }
        // Recurse into args
        let mut new_args = []
        if type_of(expr.args) == "array" {
            let an = len(expr.args)
            let mut ai = 0
            while ai < an {
                new_args = new_args.push(inline_always_expr(expr.args[ai]))
                ai = ai + 1
            }
        }
        return AstNode {
            kind: "Call", name: expr.name, value: expr.value, op: expr.op,
            kind: "Call", name: "", value: "", op: "",
            left: expr.left, right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: new_args, fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    return expr
}
