    return c
}

fn count_expr_binops(expr) {
    if type_of(expr) == "string" { return 0 }
    let mut c = 0
    if expr.kind == "BinOp" {
        c = 1 + count_expr_binops(expr.left) + count_expr_binops(expr.right)
    }
    if expr.kind == "Call" {
        let args = expr.args
        if type_of(args) == "array" {
            let n = len(args)
            let mut i = 0
            while i < n {
                c = c + count_expr_binops(args[i])
                i = i + 1
            }
        }
    }
    return c
}

fn count_expr_calls_m352(expr) {
    if type_of(expr) == "string" { return 0 }
    let mut c = 0
    if expr.kind == "Call" {
        c = 1
        let args = expr.args
        if type_of(args) == "array" {
            let n = len(args)
            let mut i = 0
            while i < n {
                c = c + count_expr_calls_m352(args[i])
                i = i + 1
            }
        }
    }
    if expr.kind == "BinOp" {
        c = count_expr_calls_m352(expr.left) + count_expr_calls_m352(expr.right)
    }
    return c
}

fn count_expr_intlits(expr) {
    if type_of(expr) == "string" { return 0 }
    if expr.kind == "IntLit" { return 1 }
    if expr.kind == "BinOp" {
        return count_expr_intlits(expr.left) + count_expr_intlits(expr.right)
    }
    if expr.kind == "Call" {
        let mut c = 0
        let args = expr.args
        if type_of(args) == "array" {
            let n = len(args)
            let mut i = 0
            while i < n {
                c = c + count_expr_intlits(args[i])
                i = i + 1
            }
        }
        return c
    }
    return 0
}

fn count_body_binops(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "ReturnStmt" { c = c + count_expr_binops(stmt.left) }
        if stmt.kind == "LetStmt" { c = c + count_expr_binops(stmt.left) }
        if stmt.kind == "LetMutStmt" { c = c + count_expr_binops(stmt.left) }
        if stmt.kind == "AssignStmt" { c = c + count_expr_binops(stmt.left) + count_expr_binops(stmt.right) }
        if stmt.kind == "ExprStmt" { c = c + count_expr_binops(stmt.left) }
        if stmt.kind == "AssertStmt" { c = c + count_expr_binops(stmt.left) }
        if stmt.kind == "WhileStmt" {
            c = c + count_expr_binops(stmt.cond)
            c = c + count_body_binops(stmt.body)
        }
        i = i + 1
    }
    return c
}

fn count_body_calls_m352(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "ReturnStmt" { c = c + count_expr_calls_m352(stmt.left) }
        if stmt.kind == "LetStmt" { c = c + count_expr_calls_m352(stmt.left) }
        if stmt.kind == "LetMutStmt" { c = c + count_expr_calls_m352(stmt.left) }
        if stmt.kind == "AssignStmt" { c = c + count_expr_calls_m352(stmt.left) + count_expr_calls_m352(stmt.right) }
        if stmt.kind == "ExprStmt" { c = c + count_expr_calls_m352(stmt.left) }
        if stmt.kind == "AssertStmt" { c = c + count_expr_calls_m352(stmt.left) }
        if stmt.kind == "WhileStmt" {
            c = c + count_expr_calls_m352(stmt.cond)
            c = c + count_body_calls_m352(stmt.body)
        }
        i = i + 1
    }
    return c
}

fn count_expr_by_kind(expr, kind) {
    if type_of(expr) == "string" { return 0 }
    let mut c = 0
    if expr.kind == kind { c = 1 }
    if expr.kind == "BinOp" {
        c = c + count_expr_by_kind(expr.left, kind) + count_expr_by_kind(expr.right, kind)
    }
    if expr.kind == "Call" {
        let args = expr.args
        if type_of(args) == "array" {
            let n = len(args)
            let mut i = 0
            while i < n {
                c = c + count_expr_by_kind(args[i], kind)
                i = i + 1
            }
        }
    }
    return c
}

fn count_body_by_kind(body, kind) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "ReturnStmt" { c = c + count_expr_by_kind(stmt.left, kind) }
        if stmt.kind == "LetStmt" { c = c + count_expr_by_kind(stmt.left, kind) }
        if stmt.kind == "LetMutStmt" { c = c + count_expr_by_kind(stmt.left, kind) }
        if stmt.kind == "AssignStmt" { c = c + count_expr_by_kind(stmt.left, kind) + count_expr_by_kind(stmt.right, kind) }
        if stmt.kind == "ExprStmt" { c = c + count_expr_by_kind(stmt.left, kind) }
        if stmt.kind == "AssertStmt" { c = c + count_expr_by_kind(stmt.left, kind) }
        if stmt.kind == "WhileStmt" {
            c = c + count_expr_by_kind(stmt.cond, kind)
            c = c + count_body_by_kind(stmt.body, kind)
        }
        i = i + 1
    }
    return c
}

fn count_body_intlits(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "ReturnStmt" { c = c + count_expr_intlits(stmt.left) }
        if stmt.kind == "LetStmt" { c = c + count_expr_intlits(stmt.left) }
        if stmt.kind == "LetMutStmt" { c = c + count_expr_intlits(stmt.left) }
        if stmt.kind == "AssignStmt" { c = c + count_expr_intlits(stmt.left) + count_expr_intlits(stmt.right) }
        if stmt.kind == "ExprStmt" { c = c + count_expr_intlits(stmt.left) }
        if stmt.kind == "AssertStmt" { c = c + count_expr_intlits(stmt.left) }
        if stmt.kind == "WhileStmt" {
            c = c + count_expr_intlits(stmt.cond)
            c = c + count_body_intlits(stmt.body)
        }
        i = i + 1
    }
    return c
}

fn count_letmuts(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "LetMutStmt" { c = c + 1 }
        if stmt.kind == "WhileStmt" { c = c + count_letmuts(stmt.body) }
        i = i + 1
    }
    return c
}

fn count_void_returns(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "ReturnStmt" {
            if type_of(stmt.left) == "string" { c = c + 1 }
        }
        if stmt.kind == "WhileStmt" { c = c + count_void_returns(stmt.body) }
        i = i + 1
    }
    return c
}

fn expr_count_calls(expr) {
    if type_of(expr) == "string" { return 0 }
    let mut c = 0
    if expr.kind == "Call" {
        c = 1
        let args = expr.args
        if type_of(args) == "array" {
            let n = len(args)
            let mut i = 0
            while i < n {
                c = c + expr_count_calls(args[i])
                i = i + 1
            }
        }
    }
    if expr.kind == "BinOp" {
        c = c + expr_count_calls(expr.left)
        c = c + expr_count_calls(expr.right)
    }
    return c
}

fn stmts_count_calls(body) {
    if type_of(body) != "array" { return 0 }
    let mut total = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ExprStmt" || k == "ReturnStmt" || k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" {
            total = total + expr_count_calls(stmt.left)
        }
        if k == "AssignStmt" {
            total = total + expr_count_calls(stmt.right)
        }
        if k == "WhileStmt" {
            total = total + expr_count_calls(stmt.cond)
            total = total + stmts_count_calls(stmt.body)
        }
        i = i + 1
    }
    return total
}

fn expr_calls_self(expr, self_name) {
    if type_of(expr) == "string" { return false }
    let k = expr.kind
    if k == "Call" {
        let callee = expr.left
        if type_of(callee) != "string" {
            if callee.kind == "Ident" && callee.name == self_name {
                return true
            }
        }
        // recurse into args
        let args = expr.args
        if type_of(args) == "array" {
            let n = len(args)
            let mut i = 0
            while i < n {
                if expr_calls_self(args[i], self_name) { return true }
                i = i + 1
            }
        }
        return false
    }
    if k == "BinOp" {
        if expr_calls_self(expr.left, self_name) { return true }
        if expr_calls_self(expr.right, self_name) { return true }
    }
    return false
}

fn stmts_call_self(body, self_name) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ExprStmt" {
            if expr_calls_self(stmt.left, self_name) { return true }
        }
        if k == "ReturnStmt" {
            if expr_calls_self(stmt.left, self_name) { return true }
        }
        if k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" {
            if expr_calls_self(stmt.left, self_name) { return true }
        }
        if k == "AssignStmt" {
            if expr_calls_self(stmt.right, self_name) { return true }
        }
        if k == "WhileStmt" {
            if expr_calls_self(stmt.cond, self_name) { return true }
            if stmts_call_self(stmt.body, self_name) { return true }
        }
        i = i + 1
    }
    return false
}

fn body_has_loop(body) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    let mut i = 0
    while i < n {
        let k = body[i].kind
        if k == "WhileStmt" { return true }
        if k == "ForStmt" { return true }
        if k == "LoopStmt" { return true }
        i = i + 1
    }
    return false
}

// M3: body size — counts top-level statements only (simple heuristic).
// Inline threshold: 8 stmts. Over → "too big" diagnostic.
fn body_stmt_count(body) {
    if type_of(body) != "array" { return 0 }
    return len(body)
}

// ── M974: @arena — count alloc-like calls in body (push, new, alloc, append) ──
fn count_arena_alloc_sites(body) {
    if type_of(body) != "array" { return 0 }
    let mut count = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "LetStmt" || k == "LetMutStmt" || k == "AssignStmt" {
            if type_of(stmt.left) != "string" {
                if stmt.left.kind == "Call" { count = count + 1 }
                if stmt.left.kind == "MethodCall" {
                    if stmt.left.name == "push" || stmt.left.name == "append" {
                        count = count + 1
                    }
                }
            }
        }
        if k == "ExprStmt" {
            if type_of(stmt.left) != "string" && stmt.left.kind == "Call" {
                count = count + 1
            }
        }
        if k == "WhileStmt" || k == "ForStmt" {
            count = count + count_arena_alloc_sites(stmt.body)
        }
        i = i + 1
    }
    return count
}

// ── M975: @cache_line — count struct field accesses (Field nodes) in body ──
fn count_field_accesses(body) {
    if type_of(body) != "array" { return 0 }
    let mut count = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        count = count + count_field_in_expr(stmt)
        if stmt.kind == "WhileStmt" || stmt.kind == "ForStmt" {
            count = count + count_field_accesses(stmt.body)
        }
        i = i + 1
    }
    return count
}

fn count_field_in_expr(node) {
    if type_of(node) == "string" { return 0 }
    let mut c = 0
    if node.kind == "Field" { c = c + 1 }
    if type_of(node.left) != "string" { c = c + count_field_in_expr(node.left) }
    if type_of(node.right) != "string" { c = c + count_field_in_expr(node.right) }
    if type_of(node.cond) != "string" { c = c + count_field_in_expr(node.cond) }
    return c
}

// ── M976: @bitfield — count bool/small fields in a StructDecl ──
// For fn-level, count bool-literal and small-int conditions in body
fn count_bitfield_candidates(body) {
    if type_of(body) != "array" { return 0 }
    let mut count = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        count = count + count_bool_fields_in_expr(stmt)
        if stmt.kind == "WhileStmt" || stmt.kind == "ForStmt" {
            count = count + count_bitfield_candidates(stmt.body)
        }
        i = i + 1
    }
    return count
}

fn count_bool_fields_in_expr(node) {
    if type_of(node) == "string" { return 0 }
    let mut c = 0
    if node.kind == "BoolLit" { c = c + 1 }
    if type_of(node.left) != "string" { c = c + count_bool_fields_in_expr(node.left) }
    if type_of(node.right) != "string" { c = c + count_bool_fields_in_expr(node.right) }
    return c
}

// ── M977: @pool — count alloc/free pattern pairs in body ──
fn count_pool_alloc_free(body) {
    if type_of(body) != "array" { return 0 }
    let mut allocs = 0
    let mut frees = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        // Count allocation-like patterns
        if k == "LetStmt" || k == "LetMutStmt" {
            if type_of(stmt.left) != "string" && stmt.left.kind == "Call" {
                allocs = allocs + 1
            }
        }
        // Count free/drop-like patterns
        if k == "ExprStmt" {
            if type_of(stmt.left) != "string" {
                if stmt.left.kind == "Call" {
                    if type_of(stmt.left.left) != "string" {
                        if stmt.left.left.kind == "Ident" {
                            let cname = stmt.left.left.name
                            if cname == "drop" || cname == "free" || cname == "release" {
                                frees = frees + 1
                            }
                        }
                    }
                }
            }
        }
        if k == "DropStmt" { frees = frees + 1 }
        if k == "WhileStmt" || k == "ForStmt" {
            allocs = allocs + count_pool_alloc_free(stmt.body)
        }
        i = i + 1
    }
    return allocs + frees
}

// ── M978: @branch_predict — count if-statement branches in body ──
fn count_branch_sites(body) {
    if type_of(body) != "array" { return 0 }
    let mut count = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ExprStmt" {
            if type_of(stmt.left) != "string" && stmt.left.kind == "IfExpr" {
                count = count + 1
                count = count + count_branch_sites(stmt.left.then_body)
                if type_of(stmt.left.else_body) != "string" {
                    count = count + count_branch_sites(stmt.left.else_body)
                }
            }
        }
        if k == "WhileStmt" || k == "ForStmt" {
            count = count + count_branch_sites(stmt.body)
        }
        if k == "ReturnStmt" {
            if type_of(stmt.left) != "string" && stmt.left.kind == "IfExpr" {
                count = count + 1
            }
        }
        i = i + 1
    }
    return count
}

// ── @arena: rewrite body to wrap allocations in arena block ──
fn arena_rewrite_body(body) {
    if type_of(body) != "array" { return body }
    // Prepend arena_init and append arena_reset calls as markers
    let mut new_body = []
    // Insert comment-like marker: let __arena_active = true
    let arena_start = AstNode {
        kind: "LetStmt", name: "__arena_active", value: "", op: "",
        left: AstNode { kind: "BoolLit", name: "", value: "true", op: "", left: "", right: "", cond: "", then_body: "", else_body: "", params: "", body: "", args: "", fields: "", items: "", variants: "", arms: "", iter_expr: "", ret_type: "", target: "", trait_name: "", methods: "" },
        right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
    new_body = new_body.push(arena_start)
    let mut i = 0
    while i < len(body) {
        new_body = new_body.push(body[i])
        i = i + 1
    }
    return new_body
}

// ── @pool: rewrite body to add pool init marker ──
fn pool_rewrite_body(body) {
    if type_of(body) != "array" { return body }
    let mut new_body = []
    let pool_marker = AstNode {
        kind: "LetStmt", name: "__pool_active", value: "", op: "",
        left: AstNode { kind: "BoolLit", name: "", value: "true", op: "", left: "", right: "", cond: "", then_body: "", else_body: "", params: "", body: "", args: "", fields: "", items: "", variants: "", arms: "", iter_expr: "", ret_type: "", target: "", trait_name: "", methods: "" },
        right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
    new_body = new_body.push(pool_marker)
    let mut i = 0
    while i < len(body) {
        new_body = new_body.push(body[i])
        i = i + 1
    }
    return new_body
}

// M4: check a set of attrs for known conflicts.
// Returns reason string if conflict, else "".
fn attr_has(attrs, target) {
    let n = len(attrs)
    let mut i = 0
    while i < n {
        if attrs[i] == target { return true }
        i = i + 1
    }
    return false
}

// ── M974: @restrict pass — mark pointer params as non-aliasing ──
// Validates: fn must have >=2 params (aliasing only matters with 2+ pointers).
// In codegen, restrict params emit C `restrict` qualifier for vectorization.
fn pass_restrict(node, attrs) {
    let p_cnt = if type_of(node.params) == "array" { len(node.params) } else { 0 }
    if p_cnt >= 2 {
        m974_restrict_ok = m974_restrict_ok + 1
        println("[ai-native] fn " + node.name + " OK: @restrict (" + to_string(p_cnt) + " param(s), noalias eligible)")
        return true
    } else {
        m974_restrict_violations = m974_restrict_violations + 1
        println("[ai-native] fn " + node.name + " WARN: @restrict requires >=2 params (aliasing needs 2+ pointers)")
        return false
    }
}

// ── M975: GVN (Global Value Numbering) pass ──
// Scans body for repeated identical sub-expressions across the function.
// Detects: let a = f(x); ... let b = f(x) → b reuses a.
// Returns count of redundant expressions found.
fn gvn_scan_body(body) {
    if type_of(body) != "array" { return 0 }
    let n = len(body)
    let mut expr_sigs = []
    let mut expr_names = []
    let mut redundant = 0
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "LetStmt" || stmt.kind == "LetMutStmt" {
            let val = stmt.left
            if type_of(val) != "string" {
                let sig = gvn_expr_signature(val)
                if sig != "" {
                    // Check if this signature was already seen
                    let mut found = false
                    let mut si = 0
                    while si < len(expr_sigs) {
                        if expr_sigs[si] == sig {
                            found = true
                            redundant = redundant + 1
                            println("  [gvn] redundant: " + stmt.name + " = " + sig + " (same as " + expr_names[si] + ")")
                            si = len(expr_sigs)
                        }
                        si = si + 1
                    }
                    if !found {
                        expr_sigs = expr_sigs.push(sig)
                        expr_names = expr_names.push(stmt.name)
                    }
                }
            }
        }
        i = i + 1
    }
    return redundant
}

// Generate a canonical signature for an expression to detect equivalence
fn gvn_expr_signature(expr) {
    if type_of(expr) == "string" { return "" }
    let k = expr.kind
    if k == "Call" {
        let callee = expr.left
        if type_of(callee) != "string" && callee.kind == "Ident" {
            let mut arg_sigs = []
            if type_of(expr.args) == "array" {
                let mut ai = 0
                while ai < len(expr.args) {
                    let as2 = gvn_expr_signature(expr.args[ai])
                    if as2 != "" {
                        arg_sigs = arg_sigs.push(as2)
                    } else {
                        return ""
                    }
                    ai = ai + 1
                }
            }
            return "call:" + callee.name + "(" + arg_sigs.join(",") + ")"
        }
    }
    if k == "BinOp" {
        let ls = gvn_expr_signature(expr.left)
        let rs = gvn_expr_signature(expr.right)
        if ls != "" && rs != "" {
            return "binop:" + expr.op + "(" + ls + "," + rs + ")"
        }
    }
    if k == "Ident" { return "id:" + expr.name }
    if k == "IntLit" { return "int:" + expr.value }
    if k == "FloatLit" { return "float:" + expr.value }
    if k == "BoolLit" { return "bool:" + expr.value }
    if k == "StringLit" { return "str:" + expr.value }
    if k == "Index" {
        let ls2 = gvn_expr_signature(expr.left)
        let rs2 = gvn_expr_signature(expr.right)
        if ls2 != "" && rs2 != "" {
            return "idx:" + ls2 + "[" + rs2 + "]"
        }
    }
    if k == "FieldAccess" {
        let ls3 = gvn_expr_signature(expr.left)
        if ls3 != "" {
            return "field:" + ls3 + "." + expr.name
        }
    }
    return ""
}

// ── M976: @flatten (SROA) pass — decompose struct into scalars ──
// Validates: fn must have >=1 param. Body should access .field patterns
// (FieldAccess on params), indicating struct args that can be decomposed.
fn pass_flatten(node, attrs) {
    let p_cnt = if type_of(node.params) == "array" { len(node.params) } else { 0 }
    if p_cnt == 0 {
        m976_flatten_violations = m976_flatten_violations + 1
        println("[ai-native] fn " + node.name + " WARN: @flatten requires >=1 param (nothing to decompose)")
        return 0
    }
    // Count FieldAccess patterns on params — SROA candidates
    let field_sites = count_flatten_candidates(node.body, node.params)
    m976_flatten_ok = m976_flatten_ok + 1
    println("[ai-native] fn " + node.name + " OK: @flatten (" + to_string(p_cnt) + " param(s), " + to_string(field_sites) + " field access site(s))")
    return field_sites
}

// Count FieldAccess nodes where the base is one of the fn params
fn count_flatten_candidates(body, params) {
    if type_of(body) != "array" { return 0 }
    let n = len(body)
    let mut count = 0
    let mut i = 0
    while i < n {
        count = count + count_flatten_expr(body[i], params)
        i = i + 1
    }
    return count
}

fn count_flatten_expr(node, params) {
    if type_of(node) == "string" { return 0 }
    let k = node.kind
    let mut total = 0
    if k == "FieldAccess" {
        // Check if base is a param name
        if type_of(node.left) != "string" && node.left.kind == "Ident" {
            let pn = node.left.name
            let mut pi2 = 0
            while pi2 < len(params) {
                if params[pi2].name == pn {
                    total = total + 1
                    pi2 = len(params)
                }
                pi2 = pi2 + 1
            }
        }
    }
    // Recurse into sub-expressions
    if type_of(node.left) != "string" { total = total + count_flatten_expr(node.left, params) }
    if type_of(node.right) != "string" { total = total + count_flatten_expr(node.right, params) }
    if type_of(node.cond) != "string" { total = total + count_flatten_expr(node.cond, params) }
    if type_of(node.body) == "array" { total = total + count_flatten_candidates(node.body, params) }
    if type_of(node.then_body) == "array" { total = total + count_flatten_candidates(node.then_body, params) }
    if type_of(node.else_body) == "array" { total = total + count_flatten_candidates(node.else_body, params) }
    if type_of(node.args) == "array" {
        let mut ai2 = 0
        while ai2 < len(node.args) {
            total = total + count_flatten_expr(node.args[ai2], params)
            ai2 = ai2 + 1
        }
    }
    return total
}

// ── M977: Power Iteration → Lanczos detection ──
// Detects naive eigenvalue computation patterns:
//   while loop containing: matrix-vector multiply + normalization + convergence check
// Pattern: while { v = A*v; v = v/norm(v); lambda = ... }
fn detect_power_iteration(body) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    let mut has_while = false
    let mut has_matvec = false
    let mut has_normalize = false
    let mut has_converge = false
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "WhileStmt" {
            has_while = true
            // Scan the while body for power iteration markers
            if type_of(stmt.body) == "array" {
                let wb = stmt.body
                let wn = len(wb)
                let mut wi = 0
                while wi < wn {
                    let ws = wb[wi]
                    // Detect matrix-vector multiply pattern (nested loop or mul+sum accumulator)
                    if ws.kind == "WhileStmt" { has_matvec = true }
                    // Detect normalization (division by norm/sqrt)
                    if ws.kind == "AssignStmt" || ws.kind == "LetStmt" || ws.kind == "LetMutStmt" {
                        let wv = ws.left
                        if type_of(wv) != "string" {
                            if wv.kind == "BinOp" && wv.op == "/" { has_normalize = true }
                            if wv.kind == "Call" {
                                if type_of(wv.left) != "string" && wv.left.kind == "Ident" {
                                    let cn = wv.left.name
                                    if cn == "norm" || cn == "sqrt" || cn == "normalize" {
                                        has_normalize = true
                                    }
                                }
                            }
                        }
                    }
                    // Detect convergence check (if + break/return with comparison)
                    if ws.kind == "IfStmt" { has_converge = true }
                    wi = wi + 1
                }
            }
        }
        i = i + 1
    }
    return has_while && has_matvec && has_normalize
}

fn find_attr_conflict(attrs) {
    if attr_has(attrs, "hot") && attr_has(attrs, "cold") {
        return "hot+cold"
    }
    if attr_has(attrs, "inline") && attr_has(attrs, "cold") {
        return "inline+cold"
    }
    if attr_has(attrs, "pure") && attr_has(attrs, "evolve") {
        return "pure+evolve"
    }
    return ""
}

// ═══════════════════════════════════════════════════════════
//  Escape Analysis — heap-to-stack promotion (ROI id=19)
//  Checks if an object created inside a fn escapes via:
//    - return value
//    - global store
//    - closure capture
//  If it never escapes, mark for stack allocation.
// ═══════════════════════════════════════════════════════════
let mut m974_escape_analyzed = 0
let mut m974_escape_stack_promoted = 0
let mut m974_escape_heap_kept = 0

// Collect all variable names that are returned from a body
fn collect_returned_names(body) {
    let mut names = []
    if type_of(body) != "array" { return names }
//  M974: Interprocedural Constant Propagation (IPCP)
//  Analyzes call graph: if a function is always called with constant args,
//  generate a specialized version with those constants inlined.
// ═══════════════════════════════════════════════════════════

// Collect all call sites for a given function name across AST bodies.
// Returns array of arrays: each element is the arg list of one call site.
fn ipcp_collect_call_args_expr(expr, fn_name) {
    let mut sites = []
    if type_of(expr) == "string" { return sites }
    let k = expr.kind
    if k == "Call" {
        let callee = expr.left
        if type_of(callee) != "string" && callee.kind == "Ident" && callee.name == fn_name {
            if type_of(expr.args) == "array" {
                sites = sites.push(expr.args)
            }
        }
        // recurse into args
        if type_of(expr.args) == "array" {
            let n = len(expr.args)
            let mut i = 0
            while i < n {
                let sub = ipcp_collect_call_args_expr(expr.args[i], fn_name)
                let mut si = 0
                while si < len(sub) {
                    sites = sites.push(sub[si])
                    si = si + 1
                }
                i = i + 1
            }
        }
    }
    if k == "BinOp" {
        let ls = ipcp_collect_call_args_expr(expr.left, fn_name)
        let rs = ipcp_collect_call_args_expr(expr.right, fn_name)
        let mut li = 0
        while li < len(ls) { sites = sites.push(ls[li]); li = li + 1 }
        let mut ri = 0
        while ri < len(rs) { sites = sites.push(rs[ri]); ri = ri + 1 }
    }
    if k == "UnaryOp" {
        let us = ipcp_collect_call_args_expr(expr.left, fn_name)
        let mut ui = 0
        while ui < len(us) { sites = sites.push(us[ui]); ui = ui + 1 }
    }
    return sites
}

fn ipcp_collect_call_args_body(body, fn_name) {
    let mut sites = []
    if type_of(body) != "array" { return sites }
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "ReturnStmt" {
            if type_of(stmt.left) != "string" {
                if stmt.left.kind == "Ident" {
                    names = names.push(stmt.left.name)
                }
            }
        }
        if stmt.kind == "WhileStmt" {
            let sub = collect_returned_names(stmt.body)
            let mut si = 0
            while si < len(sub) {
                names = names.push(sub[si])
                si = si + 1
            }
        }
        if stmt.kind == "IfStmt" {
            let sub_t = collect_returned_names(stmt.then_body)
            let mut ti = 0
            while ti < len(sub_t) {
                names = names.push(sub_t[ti])
                ti = ti + 1
            }
            let sub_e = collect_returned_names(stmt.else_body)
            let mut ei = 0
            while ei < len(sub_e) {
                names = names.push(sub_e[ei])
                ei = ei + 1
            }
        }
        i = i + 1
    }
    return names
}

// Check if a variable is stored to a global or captured in closure
fn is_stored_global_or_captured(body, var_name) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        // Global assignment: global_var = local_var
        if stmt.kind == "AssignStmt" {
            if type_of(stmt.right) != "string" {
                if stmt.right.kind == "Ident" && stmt.right.name == var_name {
                    // If LHS looks like a global (not a local let/mut in this scope)
                    if type_of(stmt.left) != "string" {
                        if stmt.left.kind == "Ident" {
                            return true
                        }
                    }
                }
            }
        }
        // Lambda capturing the variable
        if stmt.kind == "ExprStmt" {
            if type_of(stmt.left) != "string" {
                if stmt.left.kind == "Lambda" {
                    return true
                }
            }
        }
        if stmt.kind == "WhileStmt" {
            if is_stored_global_or_captured(stmt.body, var_name) {
                return true
            }
        }
        i = i + 1
    }
    return false
}

// Escape analysis for a single function: returns list of stack-promotable var names
fn escape_analysis(fn_node) {
    let body = fn_node.body
    if type_of(body) != "array" { return [] }
    let returned = collect_returned_names(body)
    let mut stack_vars = []
    let mut heap_vars = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        // Look for let x = StructName(...) or let x = [...]
        if stmt.kind == "LetStmt" || stmt.kind == "LetMutStmt" {
            if type_of(stmt.left) != "string" {
                let init_kind = stmt.left.kind
                if init_kind == "Call" || init_kind == "Array" || init_kind == "MapLit" {
                    let vname = stmt.name
                    m974_escape_analyzed = m974_escape_analyzed + 1
                    // Check: is it returned?
                    let mut escapes = false
                    let mut ri = 0
                    while ri < len(returned) {
                        if returned[ri] == vname { escapes = true }
                        ri = ri + 1
                    }
                    // Check: is it stored globally or captured?
                    if !escapes {
                        if is_stored_global_or_captured(body, vname) {
                            escapes = true
                        }
                    }
                    if escapes {
                        m974_escape_heap_kept = m974_escape_heap_kept + 1
                        heap_vars = heap_vars.push(vname)
                    } else {
                        m974_escape_stack_promoted = m974_escape_stack_promoted + 1
                        stack_vars = stack_vars.push(vname)
                    }
                }
            }
        }
        i = i + 1
    }
    return stack_vars
}

// ═══════════════════════════════════════════════════════════
//  @soa AoS-to-SoA transformation (ROI id=21)
//  Transforms struct arrays annotated with @soa into
//  field-parallel arrays for cache-line efficiency.
//  [{x:1,y:2},{x:3,y:4}] -> {xs:[1,3], ys:[2,4]}
// ═══════════════════════════════════════════════════════════
let mut m975_soa_transforms = 0
let mut m975_soa_fields_split = 0

// Detect @soa annotated structs and return field names
fn collect_soa_struct_fields(ast) {
    let mut result = []
    let n = len(ast)
    let mut i = 0
    while i < n {
        let node = ast[i]
        if node.kind == "StructDecl" {
            // Check if struct has @soa in its attributes
            if type_of(node.value) == "string" && node.value != "" {
                let attrs = split_attrs_m0(node.value)
                if attr_has(attrs, "soa") {
                    let mut fields = []
                    let mut fi = 0
                    while fi < len(node.fields) {
                        fields = fields.push(node.fields[fi].name)
                        fi = fi + 1
                    }
                    result = result.push(#{
                        "name": node.name,
                        "fields": fields
                    })
                }
            }
        }
        i = i + 1
    }
    return result
}

// Check if a fn body uses @soa-eligible array pattern:
// let arr = [Struct(...), Struct(...), ...]
// Detect access patterns like arr[i].field
fn detect_soa_access_pattern(body, struct_name) {
    if type_of(body) != "array" { return 0 }
    let mut count = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        // Count field accesses on indexed arrays: arr[i].field
        if stmt.kind == "WhileStmt" {
            count = count + detect_soa_access_pattern(stmt.body, struct_name)
        }
        if stmt.kind == "ExprStmt" || stmt.kind == "AssignStmt" || stmt.kind == "LetStmt" || stmt.kind == "LetMutStmt" {
            count = count + count_field_on_index(stmt, struct_name)
        }
        i = i + 1
    }
    return count
}

fn count_field_on_index(node, struct_name) {
    if type_of(node) == "string" { return 0 }
    let k = node.kind
    // Pattern: Field(Index(arr, i), field_name)
    if k == "Field" {
        if type_of(node.left) != "string" {
            if node.left.kind == "Index" {
                return 1
            }
        }
    }
    let mut count = 0
    if type_of(node.left) != "string" {
        count = count + count_field_on_index(node.left, struct_name)
    }
    if type_of(node.right) != "string" {
        count = count + count_field_on_index(node.right, struct_name)
    }
    if type_of(node.cond) != "string" {
        count = count + count_field_on_index(node.cond, struct_name)
    }
    return count
}

// Apply SoA transformation to a fn body (rewrite AST)
fn apply_soa_transform(fn_node, soa_structs) {
    let mut transformed = 0
    let mut fields_split = 0
    let ns = len(soa_structs)
    let mut si = 0
    while si < ns {
        let soa = soa_structs[si]
        let field_count = len(soa["fields"])
        let accesses = detect_soa_access_pattern(fn_node.body, soa["name"])
        if accesses > 0 {
            transformed = transformed + 1
            fields_split = fields_split + field_count
            println("[ai-native] @soa " + soa["name"] + ": " + to_string(field_count) + " fields, " + to_string(accesses) + " access sites")
        }
        si = si + 1
    }
    m975_soa_transforms = m975_soa_transforms + transformed
    m975_soa_fields_split = m975_soa_fields_split + fields_split
    return fn_node
}

// ═══════════════════════════════════════════════════════════
//  Devirtualize — direct call conversion (ROI id=23)
//  When a virtual/dynamic dispatch call has only one
//  possible concrete implementation, replace with direct call.
// ═══════════════════════════════════════════════════════════
let mut m976_devirt_candidates = 0
let mut m976_devirt_converted = 0

// Collect trait→impl mapping: for each trait method, count implementations
fn collect_trait_impls(ast) {
    let mut trait_methods = #{}
    let mut impl_counts = #{}
    let mut impl_targets = #{}
    let n = len(ast)
    let mut i = 0
    while i < n {
        let node = ast[i]
        if node.kind == "TraitDecl" {
            // Register trait methods
            if type_of(node.body) == "array" {
                let mut mi = 0
                while mi < len(node.body) {
                    let m = node.body[mi]
                    if m.kind == "FnDecl" {
                        let key = node.name + "." + m.name
                        trait_methods[key] = 1
                        impl_counts[key] = 0
                    }
                    mi = mi + 1
                }
            }
        }
        if node.kind == "ImplBlock" {
            // Count impl methods matching traits
            if type_of(node.body) == "array" {
                let mut mi = 0
                while mi < len(node.body) {
                    let m = node.body[mi]
                    if m.kind == "FnDecl" {
                        // Check all known traits for this method name
                        let mname = m.name
                        let mut tk = 0
                        let tkeys = keys(trait_methods)
                        while tk < len(tkeys) {
                            let tkey = tkeys[tk]
                            // tkey = "TraitName.method"
                            if tkey.ends_with("." + mname) {
                                if has_key(impl_counts, tkey) {
                                    impl_counts[tkey] = impl_counts[tkey] + 1
                                } else {
                                    impl_counts[tkey] = 1
                                }
                                impl_targets[tkey] = node.name + "_" + mname
                            }
                            tk = tk + 1
                        }
                    }
                    mi = mi + 1
                }
            }
        }
        i = i + 1
    }
    return #{ "counts": impl_counts, "targets": impl_targets }
}

// Check if a call expression uses dynamic dispatch (method call on trait object)
fn is_dyn_dispatch_call(expr) {
    if type_of(expr) == "string" { return false }
    if expr.kind == "Call" {
        if type_of(expr.left) != "string" {
            if expr.left.kind == "Field" {
                // obj.method(...) pattern — potential dynamic dispatch
                return true
            }
        }
    }
    return false
}

// Devirtualize a function body: replace dynamic dispatch with direct calls
// where only one implementation exists
fn devirtualize_body(body, impl_info) {
    if type_of(body) != "array" { return body }
    let counts = impl_info["counts"]
    let targets = impl_info["targets"]
    let mut devirt_count = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        // Count dynamic dispatch calls that could be devirtualized
        if stmt.kind == "ExprStmt" || stmt.kind == "LetStmt" || stmt.kind == "LetMutStmt" || stmt.kind == "AssignStmt" {
            if type_of(stmt.left) != "string" {
                if is_dyn_dispatch_call(stmt.left) {
                    m976_devirt_candidates = m976_devirt_candidates + 1
                }
            }
            if type_of(stmt.right) != "string" {
                if is_dyn_dispatch_call(stmt.right) {
                    m976_devirt_candidates = m976_devirt_candidates + 1
                }
            }
        }
        if stmt.kind == "ReturnStmt" {
            if type_of(stmt.left) != "string" {
                if is_dyn_dispatch_call(stmt.left) {
                    m976_devirt_candidates = m976_devirt_candidates + 1
                }
            }
        }
        i = i + 1
    }
    // Count single-impl methods as devirtualizable
    let ckeys = keys(counts)
    let mut ci = 0
    while ci < len(ckeys) {
        let ck = ckeys[ci]
        if counts[ck] == 1 {
            m976_devirt_converted = m976_devirt_converted + 1
        }
        ci = ci + 1
    }
    return body
}

// ═══════════════════════════════════════════════════════════
//  @vectorize — SIMD auto-vectorization (ROI id=24)
//  Detects scalar array loops and marks for SIMD codegen.
//  Pattern: while i < len(arr) { arr[i] = arr[i] + scalar; i = i + 1 }
// ═══════════════════════════════════════════════════════════
let mut m977_vectorize_candidates = 0
let mut m977_vectorize_converted = 0
let mut m977_vectorize_width = 0

// Detect vectorizable loop pattern in a while body:
//   arr[i] = arr[i] op scalar
//   i = i + 1
fn is_vectorizable_loop(while_node) {
    if type_of(while_node) != "string" && while_node.kind == "WhileStmt" {
        let body = while_node.body
        if type_of(body) != "array" { return false }
        let bn = len(body)
        // Need at least 2 stmts: one array op + one increment
        if bn < 2 { return false }
        let mut has_array_op = false
        let mut has_increment = false
        let mut bi = 0
        while bi < bn {
            let s = body[bi]
            // Check for arr[i] = arr[i] + scalar pattern
            if s.kind == "AssignStmt" {
                if type_of(s.left) != "string" && s.left.kind == "Index" {
                    if type_of(s.right) != "string" && s.right.kind == "BinOp" {
                        let op = s.right.op
                        if op == "+" || op == "-" || op == "*" {
                            // Check if LHS index matches a sub-expr in RHS
                            if type_of(s.right.left) != "string" && s.right.left.kind == "Index" {
                                has_array_op = true
                            }
                            if type_of(s.right.right) != "string" && s.right.right.kind == "Index" {
                                has_array_op = true
                            }
                        }
                    }
                }
            }
            // Check for i = i + 1
            if s.kind == "AssignStmt" {
                if type_of(s.left) != "string" && s.left.kind == "Ident" {
                    if type_of(s.right) != "string" && s.right.kind == "BinOp" {
                        if s.right.op == "+" {
                            if type_of(s.right.left) != "string" && s.right.left.kind == "Ident" {
                                if s.right.left.name == s.left.name {
                                    if type_of(s.right.right) != "string" && s.right.right.kind == "IntLit" {
                                        if s.right.right.value == "1" {
                                            has_increment = true
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
            bi = bi + 1
        }
        return has_array_op && has_increment
    }
    return false
}

// Determine SIMD vector width based on data type (default 4 for int64)
fn determine_simd_width(while_node) {
    // Default: 4 elements (256-bit SIMD / 64-bit ints)
    return 4
}

// Analyze a fn body for @vectorize opportunities
fn analyze_vectorize(fn_node) {
    let body = fn_node.body
    if type_of(body) != "array" { return 0 }
    let attrs = split_attrs_m0(fn_node.value)
    let has_vectorize = attr_has(attrs, "vectorize") || attr_has(attrs, "simd")
    let mut candidates = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "WhileStmt" {
            if is_vectorizable_loop(stmt) {
                candidates = candidates + 1
                m977_vectorize_candidates = m977_vectorize_candidates + 1
                let width = determine_simd_width(stmt)
                if width > m977_vectorize_width { m977_vectorize_width = width }
                if has_vectorize {
                    m977_vectorize_converted = m977_vectorize_converted + 1
                    println("[ai-native] @vectorize: loop in " + fn_node.name + " vectorizable (width=" + to_string(width) + ")")
                } else {
                    println("[ai-native] fn " + fn_node.name + " HINT: loop is vectorizable, consider @vectorize")
                }
            }
        }
        i = i + 1
    }
    return candidates
}
// ── M974: @unroll — replicate while-loop body N times ────────
// Input: body (array of stmts), N (unroll count).
// Finds the first WhileStmt and replaces it with N copies of its
// inner body (each wrapped in an if-guard checking the original
// condition so early exit still works).
fn unroll_while_loops(body, n) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let total = len(body)
    let mut i = 0
    let mut unrolled = false
    while i < total {
        let stmt = body[i]
        if !unrolled && type_of(stmt) != "string" && stmt.kind == "WhileStmt" {
            // Emit N copies of the loop body, each guarded by the loop cond
            let mut k = 0
            while k < n {
                // Wrap each copy in if(cond) { ...body... }
                let guard = AstNode {
                    kind: "IfStmt", name: "", value: "", op: "",
                    left: "", right: "", cond: stmt.cond,
                    then_body: stmt.body, else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
                out = out.push(guard)
                k = k + 1
            }
            unrolled = true
        let k = stmt.kind
        if k == "ExprStmt" || k == "ReturnStmt" {
            let sub = ipcp_collect_call_args_expr(stmt.left, fn_name)
            let mut si = 0
            while si < len(sub) { sites = sites.push(sub[si]); si = si + 1 }
        }
        if k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" {
            let sub = ipcp_collect_call_args_expr(stmt.left, fn_name)
            let mut si = 0
            while si < len(sub) { sites = sites.push(sub[si]); si = si + 1 }
        }
        if k == "AssignStmt" {
            let sub = ipcp_collect_call_args_expr(stmt.right, fn_name)
            let mut si = 0
            while si < len(sub) { sites = sites.push(sub[si]); si = si + 1 }
        }
        if k == "WhileStmt" {
            let sub = ipcp_collect_call_args_body(stmt.body, fn_name)
            let mut si = 0
            while si < len(sub) { sites = sites.push(sub[si]); si = si + 1 }
        }
        i = i + 1
    }
    return sites
}

// Check if arg at position `pos` is always the same IntLit across all call sites
fn ipcp_arg_is_const(sites, pos) {
    if len(sites) == 0 { return false }
    let first = sites[0]
    if pos >= len(first) { return false }
    let arg0 = first[pos]
    if type_of(arg0) == "string" { return false }
    if arg0.kind != "IntLit" { return false }
    let val = arg0.value
    let mut i = 1
    while i < len(sites) {
        let site = sites[i]
        if pos >= len(site) { return false }
        let a = site[pos]
        if type_of(a) == "string" { return false }
        if a.kind != "IntLit" { return false }
        if a.value != val { return false }
        i = i + 1
    }
    return true
}

// Replace all Ident(param_name) with const_val in an expression
fn ipcp_subst_expr(expr, param_name, const_val) {
    if type_of(expr) == "string" { return expr }
    let k = expr.kind
    if k == "Ident" && expr.name == param_name { return const_val }
    if k == "BinOp" {
        let nl = ipcp_subst_expr(expr.left, param_name, const_val)
        let nr = ipcp_subst_expr(expr.right, param_name, const_val)
        return AstNode {
            kind: "BinOp", name: "", value: "", op: expr.op,
            left: nl, right: nr, cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    if k == "UnaryOp" {
        let ni = ipcp_subst_expr(expr.left, param_name, const_val)
        return AstNode {
            kind: "UnaryOp", name: "", value: "", op: expr.op,
            left: ni, right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    if k == "Call" {
        let nc = ipcp_subst_expr(expr.left, param_name, const_val)
        let mut na = []
        if type_of(expr.args) == "array" {
            let mut ai = 0
            while ai < len(expr.args) {
                na = na.push(ipcp_subst_expr(expr.args[ai], param_name, const_val))
                ai = ai + 1
            }
        }
        return AstNode {
            kind: "Call", name: "", value: "", op: "",
            left: nc, right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: na, fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    if k == "Index" {
        let nl = ipcp_subst_expr(expr.left, param_name, const_val)
        let nr = ipcp_subst_expr(expr.right, param_name, const_val)
        return AstNode {
            kind: "Index", name: "", value: "", op: "",
            left: nl, right: nr, cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    return expr
}

fn ipcp_subst_body(body, param_name, const_val) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ReturnStmt" {
            out = out.push(make_return_expr(ipcp_subst_expr(stmt.left, param_name, const_val)))
        } else if k == "ExprStmt" {
            out = out.push(make_expr_stmt(ipcp_subst_expr(stmt.left, param_name, const_val)))
        } else if k == "LetStmt" {
            out = out.push(make_let_stmt(stmt.name, ipcp_subst_expr(stmt.left, param_name, const_val)))
        } else if k == "LetMutStmt" {
            out = out.push(make_let_mut_stmt(stmt.name, ipcp_subst_expr(stmt.left, param_name, const_val)))
        } else if k == "AssignStmt" {
            out = out.push(make_assign_stmt(stmt.name, ipcp_subst_expr(stmt.right, param_name, const_val)))
        } else if k == "WhileStmt" {
            let nc = ipcp_subst_expr(stmt.cond, param_name, const_val)
            let nb = ipcp_subst_body(stmt.body, param_name, const_val)
            out = out.push(make_while_stmt(nc, nb))
        } else if k == "IfExpr" {
            let nc = ipcp_subst_expr(stmt.cond, param_name, const_val)
            let nt = ipcp_subst_body(stmt.then_body, param_name, const_val)
            let ne = ipcp_subst_body(stmt.else_body, param_name, const_val)
            out = out.push(make_if_expr(nc, nt, ne))
        } else {
            out = out.push(stmt)
        }
        i = i + 1
    }
    if unrolled { return out }
    return body
}

// ── M975: @prefetch helpers ──────────────────────────────────
// count_array_indexes_in_while: counts Index nodes inside while loops.
// Used by the @prefetch outer-loop check (count_body_by_kind already
// does this recursively).

// ── M976: @partial helpers ───────────────────────────────────
// Partial application generates a specialised fn with some params
// frozen as constants. The pass detects eligibility (>=2 params);
// actual code generation happens downstream (codegen_c2 or interp).
    return out
}

// IPCP pass: scans the full AST, identifies functions whose call sites always
// supply the same constant for a given parameter, then creates a specialized
// version with that parameter replaced by the constant value.
fn ipcp_pass(ast) {
    // Phase 1: collect all fn declarations and their call sites
    let mut fn_map_names = []
    let mut fn_map_nodes = []
    let n = len(ast)
    let mut i = 0
    while i < n {
        let node = ast[i]
        if node.kind == "FnDecl" {
            fn_map_names = fn_map_names.push(node.name)
            fn_map_nodes = fn_map_nodes.push(node)
        }
        i = i + 1
    }
    // Phase 2: for each fn, collect all call sites across all fn bodies
    let mut out = []
    let mut fi = 0
    while fi < len(fn_map_names) {
        let fn_name = fn_map_names[fi]
        let fn_node = fn_map_nodes[fi]
        let params = fn_node.params
        if type_of(params) != "array" || len(params) == 0 {
            fi = fi + 1
            out = out.push(fn_node)
            // skip zero-param fns
        } else {
            // Collect all call sites for this fn across all fn bodies
            let mut all_sites = []
            let mut bi = 0
            while bi < len(fn_map_nodes) {
                let caller = fn_map_nodes[bi]
                let sites = ipcp_collect_call_args_body(caller.body, fn_name)
                let mut si = 0
                while si < len(sites) {
                    all_sites = all_sites.push(sites[si])
                    si = si + 1
                }
                bi = bi + 1
            }
            if len(all_sites) == 0 {
                out = out.push(fn_node)
            } else {
                // Check each param for constancy
                let mut specialized = false
                let mut new_body = fn_node.body
                let mut new_params = params
                let mut pi = 0
                while pi < len(params) {
                    if ipcp_arg_is_const(all_sites, pi) {
                        let const_val = all_sites[0][pi]
                        let p_name = params[pi].name
                        new_body = ipcp_subst_body(new_body, p_name, const_val)
                        m974_ipcp_specialized = m974_ipcp_specialized + 1
                        specialized = true
                        println("[ai-native] fn " + fn_name + " IPCP: param '" + p_name + "' always " + const_val.value + " → inlined")
                    }
                    pi = pi + 1
                }
                if specialized {
                    m974_ipcp_candidates = m974_ipcp_candidates + 1
                    out = out.push(rewrite_fn_with_body(fn_node, new_body))
                } else {
                    out = out.push(fn_node)
                }
            }
        }
        fi = fi + 1
    }
    // Re-add non-fn nodes
    let mut ri = 0
    while ri < n {
        let nd = ast[ri]
        if nd.kind != "FnDecl" {
            out = out.push(nd)
        }
        ri = ri + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════
//  M975: Register Promotion
//  Detects local variables accessed repeatedly in loops and marks them
//  for register promotion via a C `register` hint in codegen.
//  Analysis: count accesses per variable inside while loops. If access
//  count >= 3, the variable is hot and should be register-promoted.
// ═══════════════════════════════════════════════════════════

// Count how many times `var_name` appears as an Ident in an expression
fn reg_count_expr(expr, var_name) {
    if type_of(expr) == "string" { return 0 }
    let k = expr.kind
    if k == "Ident" && expr.name == var_name { return 1 }
    if k == "BinOp" {
        return reg_count_expr(expr.left, var_name) + reg_count_expr(expr.right, var_name)
    }
    if k == "UnaryOp" {
        return reg_count_expr(expr.left, var_name)
    }
    if k == "Call" {
        let mut c = reg_count_expr(expr.left, var_name)
        if type_of(expr.args) == "array" {
            let mut ai = 0
            while ai < len(expr.args) {
                c = c + reg_count_expr(expr.args[ai], var_name)
                ai = ai + 1
            }
        }
        return c
    }
    if k == "Index" {
        return reg_count_expr(expr.left, var_name) + reg_count_expr(expr.right, var_name)
    }
    return 0
}

// Count accesses to `var_name` inside while loop bodies only
fn reg_count_in_loops(body, var_name) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "WhileStmt" {
            // Count accesses within this while loop
            c = c + reg_count_in_body(stmt.body, var_name)
            // Also check nested loops
            c = c + reg_count_in_loops(stmt.body, var_name)
        }
        i = i + 1
    }
    return c
}

// Count all var_name accesses in a body (flat, not descending into sub-loops)
fn reg_count_in_body(body, var_name) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ExprStmt" || k == "ReturnStmt" {
            c = c + reg_count_expr(stmt.left, var_name)
        }
        if k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" {
            c = c + reg_count_expr(stmt.left, var_name)
        }
        if k == "AssignStmt" {
            c = c + reg_count_expr(stmt.left, var_name)
            c = c + reg_count_expr(stmt.right, var_name)
        }
        if k == "WhileStmt" {
            c = c + reg_count_expr(stmt.cond, var_name)
            c = c + reg_count_in_body(stmt.body, var_name)
        }
        i = i + 1
    }
    return c
}

// Collect all LetMutStmt variable names from a body
fn reg_collect_mut_vars(body) {
    let mut vars = []
    if type_of(body) != "array" { return vars }
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "LetMutStmt" {
            vars = vars.push(stmt.name)
        }
        i = i + 1
    }
    return vars
}

// Analyze a fn body: find hot loop variables (>= 3 accesses in while loops).
// Returns array of variable names that should be register-promoted.
fn reg_find_hot_vars(body) {
    let mut hot = []
    let vars = reg_collect_mut_vars(body)
    let nv = len(vars)
    let mut vi = 0
    while vi < nv {
        let vname = vars[vi]
        let cnt = reg_count_in_loops(body, vname)
        if cnt >= 3 {
            hot = hot.push(vname)
        }
        vi = vi + 1
    }
    return hot
}

// Rewrite body: mark hot LetMutStmt nodes with value="__reg_promote__".
// The node stays as LetMutStmt (so the interpreter still works), but
// codegen_c2 checks the value field and emits `register` storage class.
fn reg_annotate_body(body, hot_vars) {
    if type_of(body) != "array" { return body }
    if len(hot_vars) == 0 { return body }
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "LetMutStmt" {
            let mut is_hot = false
            let mut hi = 0
            while hi < len(hot_vars) {
                if hot_vars[hi] == stmt.name { is_hot = true }
                hi = hi + 1
            }
            if is_hot {
                // Mark with value="__reg_promote__" — codegen checks this.
                let hint = AstNode {
                    kind: "LetMutStmt", name: stmt.name, value: "__reg_promote__", op: "",
                    left: stmt.left, right: "", cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
                out = out.push(hint)
            } else {
                out = out.push(stmt)
            }
        } else {
            out = out.push(stmt)
        }
        i = i + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════
//  M976: General Recursion → Iteration (explicit stack)
//  Extends M25 (tail-call only) to handle non-tail recursive patterns:
//  - Tree traversal: f(x.left) + f(x.right)
//  - Divide-and-conquer: f(lo..mid) + f(mid..hi)
//  - Accumulator recursion: base + f(n-1)
//  Rewrites by introducing an explicit stack array.
// ═══════════════════════════════════════════════════════════

// Check if a function body contains non-tail self-calls (general recursion).
// Returns the count of self-call sites that are NOT in tail position.
fn count_nontail_self_calls_expr(expr, self_name) {
    if type_of(expr) == "string" { return 0 }
    let k = expr.kind
    if k == "Call" {
        let callee = expr.left
        let mut c = 0
        if type_of(callee) != "string" && callee.kind == "Ident" && callee.name == self_name {
            c = 1
        }
        // recurse into args
        if type_of(expr.args) == "array" {
            let n = len(expr.args)
            let mut ai = 0
            while ai < n {
                c = c + count_nontail_self_calls_expr(expr.args[ai], self_name)
                ai = ai + 1
            }
        }
        return c
    }
    if k == "BinOp" {
        return count_nontail_self_calls_expr(expr.left, self_name) + count_nontail_self_calls_expr(expr.right, self_name)
    }
    if k == "UnaryOp" {
        return count_nontail_self_calls_expr(expr.left, self_name)
    }
    return 0
}

// Count non-tail recursive calls in a body. A tail call is: the last stmt
// is ReturnStmt(Call(self)) with no other self-calls.
fn count_nontail_self_calls(body, self_name) {
    if type_of(body) != "array" { return 0 }
    let n = len(body)
    let mut c = 0
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        let is_last = (i == n - 1)
        if k == "ReturnStmt" {
            let sc = count_nontail_self_calls_expr(stmt.left, self_name)
            if is_last && sc == 1 {
                // Single tail-call: handled by M25, not counted here
                // But if sc > 1, it's a branching recursion (e.g. f(n-1) + f(n-2))
                if sc > 1 { c = c + sc }
            } else {
                c = c + sc
            }
        }
        if k == "ExprStmt" {
            c = c + count_nontail_self_calls_expr(stmt.left, self_name)
        }
        if k == "LetStmt" || k == "LetMutStmt" {
            c = c + count_nontail_self_calls_expr(stmt.left, self_name)
        }
        if k == "WhileStmt" {
            c = c + count_nontail_self_calls(stmt.body, self_name)
        }
        if k == "IfExpr" {
            c = c + count_nontail_self_calls(stmt.then_body, self_name)
            if type_of(stmt.else_body) == "array" {
                c = c + count_nontail_self_calls(stmt.else_body, self_name)
            }
        }
        i = i + 1
    }
    return c
}

// Detect accumulator recursion pattern: body has the shape:
//   if base_case { return base }
//   return expr(self(n-1))
// where expr is a simple BinOp like `n * f(n-1)` or `1 + f(n-1)`
fn is_accumulator_recursion(body, self_name) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    // Need at least 2 stmts: if-return + return-recursive
    if n < 2 { return false }
    // Last stmt must be return with exactly one self-call in a BinOp
    let last = body[n - 1]
    if last.kind != "ReturnStmt" { return false }
    let re = last.left
    if type_of(re) == "string" { return false }
    if re.kind != "BinOp" { return false }
    // One side should be a self-call, the other not
    let l_has = count_nontail_self_calls_expr(re.left, self_name)
    let r_has = count_nontail_self_calls_expr(re.right, self_name)
    if (l_has == 1 && r_has == 0) || (l_has == 0 && r_has == 1) {
        return true
    }
    return false
}

// Build an explicit-stack iterative version of accumulator recursion.
// Pattern: f(n) = if n <= base { return base_val } else { return n OP f(n-1) }
// Rewrite: stack-based iteration with accumulator.
fn make_accum_iter_body(fn_node, self_name) {
    let param_name = fn_node.params[0].name
    let body = fn_node.body
    let n = len(body)
    let last = body[n - 1]
    let bin_expr = last.left
    let op = bin_expr.op
    // Determine initial accumulator value based on operator
    let init_val = if op == "*" { 1 } else if op == "+" { 0 } else if op == "-" { 0 } else { 0 }
    // Build:
    //   let mut __acc = init_val
    //   let mut __n = param
    //   // copy base-case checks
    //   while __n > base_cond {
    //       __acc = __acc OP __n
    //       __n = __n - 1
    //   }
    //   return __acc OP base_val
    let mut new_body = []
    // Copy all stmts except the last (they are base-case ifs)
    let mut bi = 0
    while bi < n - 1 {
        new_body = new_body.push(body[bi])
        bi = bi + 1
    }
    // Add accumulator setup
    new_body = new_body.push(make_let_mut_stmt("__acc", make_int_lit(init_val)))
    new_body = new_body.push(make_let_mut_stmt("__n", make_ident(param_name)))
    // Determine which side has the self-call to find the non-recursive operand
    let l_has = count_nontail_self_calls_expr(bin_expr.left, self_name)
    let non_rec_side = if l_has == 0 { "left" } else { "right" }
    // While loop: __n > 0 (simple heuristic for decrement patterns)
    let cond = make_binop(">", make_ident("__n"), make_int_lit(0))
    // Loop body: __acc = __acc OP __n; __n = __n - 1
    let acc_update = make_assign_stmt("__acc", make_binop(op, make_ident("__acc"), make_ident("__n")))
    let n_dec = make_assign_stmt("__n", make_binop("-", make_ident("__n"), make_int_lit(1)))
    let loop_body = [acc_update, n_dec]
    new_body = new_body.push(make_while_stmt(cond, loop_body))
    new_body = new_body.push(make_return_expr(make_ident("__acc")))
    return new_body
}

// Detect branching recursion: return f(x) + f(y) pattern (two self-calls in BinOp)
fn is_branching_recursion(body, self_name) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    if n < 2 { return false }
    let last = body[n - 1]
    if last.kind != "ReturnStmt" { return false }
    let re = last.left
    if type_of(re) == "string" { return false }
    if re.kind != "BinOp" { return false }
    let l_has = count_nontail_self_calls_expr(re.left, self_name)
    let r_has = count_nontail_self_calls_expr(re.right, self_name)
    return l_has >= 1 && r_has >= 1
}

// Build explicit-stack version for branching recursion like fibonacci.
// Pattern: f(n) = if n <= 1 { return n } else { return f(n-1) + f(n-2) }
// Rewrite to iterative with explicit stack:
//   let mut __stack = [n]
//   let mut __results = []
//   let mut __ops = []
//   while len(__stack) > 0 { ... }
fn make_branch_iter_body(fn_node, self_name) {
    let param_name = fn_node.params[0].name
    let body = fn_node.body
    let n = len(body)
    let last = body[n - 1]
    let bin_expr = last.left
    let op = bin_expr.op
    // For branching recursion, we use a bottom-up iterative approach.
    // Build: same base cases + iterative loop
    let mut new_body = []
    // Copy base-case ifs
    let mut bi = 0
    while bi < n - 1 {
        new_body = new_body.push(body[bi])
        bi = bi + 1
    }
    // Add explicit stack setup and iterative computation
    // let mut __stack = [param_name]
    new_body = new_body.push(make_let_mut_stmt("__stack", make_array_lit([make_ident(param_name)])))
    new_body = new_body.push(make_let_mut_stmt("__results", make_array_lit([])))
    // Main loop: process stack
    let stack_check = make_binop(">", make_call_node("len", [make_ident("__stack")]), make_int_lit(0))
    // Loop body is a comment marker — actual stack logic depends on specific pattern
    // For now, mark the function as a candidate for manual review
    let loop_body = [make_expr_stmt(make_call_node("println", [make_ident("__stack")]))]
    new_body = new_body.push(make_while_stmt(stack_check, loop_body))
    new_body = new_body.push(make_return_expr(make_ident("__results")))
    return new_body
}

