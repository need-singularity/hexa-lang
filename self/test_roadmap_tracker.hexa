// test_roadmap_tracker.hexa — roadmap_tracker 검증
//
// mock JSON/JSONL 입력으로 완성도(%) 계산이 일관적인지 확인.
// 실행: ./target/release/hexa self/test_roadmap_tracker.hexa

import "ml/roadmap_tracker.hexa"

println("=== test_roadmap_tracker ===")

// ── mock paths ───────────────────────────────────────────
let mock_dir = "build"
let mock_json = "build/mock_roadmap.json"
let mock_jsonl = "build/mock_zeta_compare.jsonl"

// 존재하는 파일 몇개(테스트 시그널용)
// self/ml/zeta_bench.hexa 는 repo 에 존재 → 100% 히트 유도
let present_a = "self/ml/zeta_bench.hexa"
let present_b = "self/ml/conscious_lm.hexa"
let present_c = "self/ml/phi_metric.hexa"
let absent_a = "self/ml/__nonexistent_phase0_A.hexa"
let absent_b = "self/ml/__nonexistent_phase0_B.hexa"

// mock roadmap JSON (원본 포맷 유지)
let mock_roadmap_parts = ["{\n", "  \"source\": \"mock\",\n", "  \"summary\": \"mock roadmap\",\n", "  \"phases\": [\n", "    {\"id\": \"phase0\", \"name\": \"infra\"},\n", "    {\"id\": \"phase1\", \"name\": \"init\"}\n", "  ]\n", "}\n"]
let mock_roadmap_text = mock_roadmap_parts.join("")

write_file(mock_json, mock_roadmap_text)

// mock bench jsonl: phase0 → 2 records (phi>0, phi=0), phase1 → 1 record phi>0
let mock_bench_parts = ["{\"hexa_name\":\"mock-phase0-run\",\"phi\":0.0123}\n", "{\"hexa_name\":\"mock-phase0-run-zero\",\"phi\":0.0}\n", "{\"hexa_name\":\"mock-phase1-run\",\"phi\":0.5}\n"]
let mock_bench = mock_bench_parts.join("")

write_file(mock_jsonl, mock_bench)

// Override: phase0 → 2 present + 2 absent → tests_found=2/4 = 0.5
//           phase1 → 1 present only → 1/1 = 1.0
//           phase2..4 → [] (tests_total=0 → S1=0)
let phase0_tests = [present_a, present_b, absent_a, absent_b]
let phase1_tests = [present_c]
let empty_list = []
let override_ids = ["phase0", "phase1", "phase2", "phase3", "phase4"]
let override_paths = [phase0_tests, phase1_tests, empty_list, empty_list, empty_list]

let result = rt_track(mock_json, mock_jsonl, override_ids, override_paths)
let block = result[0]
let results = result[1]

println("block = " + block)

// ── assertions ───────────────────────────────────────────

// phase0:
//   S1 = 2/4 = 500
//   S2 = min(1, 2/1) = 1000
//   S3 = 1/2 = 500
//   score = (500*5 + 1000*3 + 500*2) / 10 = (2500+3000+1000)/10 = 650
//   pct = (650+5)/10 = 65
let p0 = results[0]
println("phase0 -> pct=" + rt_itos(p0[1]) + " tests=" + rt_itos(p0[2]) + "/" + rt_itos(p0[3]) + " bench=" + rt_itos(p0[4]) + " phi_ok=" + rt_itos(p0[5]))
assert p0[0] == "phase0"
assert p0[2] == 2
assert p0[3] == 4
assert p0[4] == 2
assert p0[5] == 1
assert p0[1] == 65

// phase1:
//   S1 = 1/1 = 1000
//   S2 = min(1, 1/1) = 1000
//   S3 = 1/1 = 1000
//   pct = 100
let p1 = results[1]
println("phase1 -> pct=" + rt_itos(p1[1]))
assert p1[1] == 100

// phase2..4: tests_total=0, bench=0 → S1=0, S2=0, S3=0 → 0
let p2 = results[2]
assert p2[1] == 0
let p3 = results[3]
assert p3[1] == 0
let p4 = results[4]
assert p4[1] == 0

// roadmap file 재기록 확인: phase_completion 필드 포함
let updated = read_file(mock_json)
println("updated contains phase_completion: " + rt_itos(rt_index_of(updated, "phase_completion")))
assert rt_index_of(updated, "phase_completion") >= 0
assert rt_index_of(updated, "phase0") >= 0

// 두번째 호출도 멱등해야 함 (crash 없음)
let result2 = rt_track(mock_json, mock_jsonl, override_ids, override_paths)
let p0b = result2[1][0]
assert p0b[1] == 65

println("=== test_roadmap_tracker: ALL PASSED ===")

// ── 실제 파일에도 현재 상태 스냅샷 (있을 때만) ─────────
