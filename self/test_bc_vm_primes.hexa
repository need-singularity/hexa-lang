// rt#36-C extended smoke (bonus): primes_up_to(limit) on bc_vm.
//
// Sister bench to test_bc_vm_collatz.hexa — adds nested loop +
// inner break + LE/LT mixed predicates. First test on bc_vm with
// two backward jumps in a single function and an early exit out of
// the inner loop via forward JMP (the "break" pattern).
//
// Verified test vectors (count of primes p with 2 <= p <= limit):
//   primes_up_to(10) =  4   (2 3 5 7)
//   primes_up_to(50) = 15   (… 47)
//
// Run via module_loader (T36-flat):
//   ./build/hexa_stage0 self/module_loader.hexa \
//     self/test_bc_vm_primes.hexa /tmp/bcvm_primes.hexa
//   ./build/hexa_stage0 /tmp/bcvm_primes.hexa

use "bc_emitter"
use "bc_vm"

// ── BcProto registry helpers (mirrors test_bc_vm_smoke). ─────
fn bcvp_push_proto(name, n_params, codes, n_locals, max_stack) {
    let p = BcProto {
        name: name,
        n_params: n_params,
        n_locals: n_locals,
        max_stack: max_stack,
        code_len: len(codes),
        consts_len: 0
    }
    bc_protos            = bc_protos.push(p)
    bc_proto_codes       = bc_proto_codes.push(codes)
    bc_proto_consts      = bc_proto_consts.push([])
    bc_proto_localcounts = bc_proto_localcounts.push(n_locals)
    bc_proto_max_stacks  = bc_proto_max_stacks.push(max_stack)
}

fn bcvp_reset() {
    bc_protos            = []
    bc_proto_codes       = []
    bc_proto_consts      = []
    bc_proto_localcounts = []
    bc_proto_max_stacks  = []
}

// ── primes_up_to(limit) proto body. ──────────────────────────
//
// Locals: 0=limit(param) 1=count 2=k 3=d 4=is_prime
//
//  pc | instr             | comment
//  ---+-------------------+------------------------------------
//   0 | LOADI 0           | count = 0
//   1 | STORE_LOCAL 1     |
//   2 | LOADI 2           | k = 2
//   3 | STORE_LOCAL 2     |
//  OUTER (pc=4):
//   4 | LOAD_LOCAL 2      | push k
//   5 | LOAD_LOCAL 0      | push limit
//   6 | LE                | k <= limit
//   7 | JMPF +33          | exit outer → pc=41
//   8 | LOADI 1           | is_prime = 1
//   9 | STORE_LOCAL 4     |
//  10 | LOADI 2           | d = 2
//  11 | STORE_LOCAL 3     |
//  INNER (pc=12):
//  12 | LOAD_LOCAL 3      | push d
//  13 | LOAD_LOCAL 2      | push k
//  14 | LT                | d < k
//  15 | JMPF +14          | exit inner → pc=30
//  16 | LOAD_LOCAL 2      | push k
//  17 | LOAD_LOCAL 3      | push d
//  18 | MOD               | k % d
//  19 | LOADI 0           |
//  20 | EQ                | (k%d == 0) ?
//  21 | JMPF +3           | not divisible → pc=25
//  22 | LOADI 0           | is_prime = 0
//  23 | STORE_LOCAL 4     |
//  24 | JMP +5            | break inner → pc=30
//  25 | LOAD_LOCAL 3      | d = d + 1
//  26 | LOADI 1           |
//  27 | ADD               |
//  28 | STORE_LOCAL 3     |
//  29 | JMP -18           | back to INNER (pc=12)
//  POST_INNER (pc=30):
//  30 | LOAD_LOCAL 4      | push is_prime
//  31 | JMPF +4           | not prime → SKIPCNT (pc=36)
//  32 | LOAD_LOCAL 1      | count = count + 1
//  33 | LOADI 1           |
//  34 | ADD               |
//  35 | STORE_LOCAL 1     |
//  SKIPCNT (pc=36):
//  36 | LOAD_LOCAL 2      | k = k + 1
//  37 | LOADI 1           |
//  38 | ADD               |
//  39 | STORE_LOCAL 2     |
//  40 | JMP -37           | back to OUTER (pc=4)
//  POST_OUTER (pc=41):
//  41 | LOAD_LOCAL 1      | push count
//  42 | RETURN            |
fn bcvp_make_primes_code() {
    return [
        bc_enc_sbx(BC_OP_LOADI, 0),
        bc_enc_abx(BC_OP_STORE_LOCAL, 1),
        bc_enc_sbx(BC_OP_LOADI, 2),
        bc_enc_abx(BC_OP_STORE_LOCAL, 2),
        bc_enc_abx(BC_OP_LOAD_LOCAL, 2),
        bc_enc_abx(BC_OP_LOAD_LOCAL, 0),
        bc_enc_abx(BC_OP_LE, 0),
        bc_enc_sbx(BC_OP_JMPF, 33),
        bc_enc_sbx(BC_OP_LOADI, 1),
        bc_enc_abx(BC_OP_STORE_LOCAL, 4),
        bc_enc_sbx(BC_OP_LOADI, 2),
        bc_enc_abx(BC_OP_STORE_LOCAL, 3),
        bc_enc_abx(BC_OP_LOAD_LOCAL, 3),
        bc_enc_abx(BC_OP_LOAD_LOCAL, 2),
        bc_enc_abx(BC_OP_LT, 0),
        bc_enc_sbx(BC_OP_JMPF, 14),
        bc_enc_abx(BC_OP_LOAD_LOCAL, 2),
        bc_enc_abx(BC_OP_LOAD_LOCAL, 3),
        bc_enc_abx(BC_OP_MOD, 0),
        bc_enc_sbx(BC_OP_LOADI, 0),
        bc_enc_abx(BC_OP_EQ, 0),
        bc_enc_sbx(BC_OP_JMPF, 3),
        bc_enc_sbx(BC_OP_LOADI, 0),
        bc_enc_abx(BC_OP_STORE_LOCAL, 4),
        bc_enc_sbx(BC_OP_JMP, 5),
        bc_enc_abx(BC_OP_LOAD_LOCAL, 3),
        bc_enc_sbx(BC_OP_LOADI, 1),
        bc_enc_abx(BC_OP_ADD, 0),
        bc_enc_abx(BC_OP_STORE_LOCAL, 3),
        bc_enc_sbx(BC_OP_JMP, -18),
        bc_enc_abx(BC_OP_LOAD_LOCAL, 4),
        bc_enc_sbx(BC_OP_JMPF, 4),
        bc_enc_abx(BC_OP_LOAD_LOCAL, 1),
        bc_enc_sbx(BC_OP_LOADI, 1),
        bc_enc_abx(BC_OP_ADD, 0),
        bc_enc_abx(BC_OP_STORE_LOCAL, 1),
        bc_enc_abx(BC_OP_LOAD_LOCAL, 2),
        bc_enc_sbx(BC_OP_LOADI, 1),
        bc_enc_abx(BC_OP_ADD, 0),
        bc_enc_abx(BC_OP_STORE_LOCAL, 2),
        bc_enc_sbx(BC_OP_JMP, -37),
        bc_enc_abx(BC_OP_LOAD_LOCAL, 1),
        bc_enc_abx(BC_OP_RETURN, 0)
    ]
}

// <main>: LOADI limit ; CALL primes ; RETURN
fn bcvp_run_case(limit, expected) {
    println("[primes_up_to(" + to_string(limit) + ")] expect " + to_string(expected))
    bcvp_reset()
    let main_code = [
        bc_enc_sbx(BC_OP_LOADI, limit),
        bc_enc_ab16(BC_OP_CALL, 1, 1),
        bc_enc_abx(BC_OP_RETURN, 0)
    ]
    bcvp_push_proto("<main>",        0, main_code,                0, 2)
    bcvp_push_proto("primes_up_to",  1, bcvp_make_primes_code(),  5, 4)
    let r = bc_vm_run()
    if r == expected {
        println("  PASS primes_up_to(" + to_string(limit) + ")=" + to_string(r))
    } else {
        println("  FAIL primes_up_to(" + to_string(limit) + ") got=" + to_string(r) + " want=" + to_string(expected))
    }
}

fn bcvp_main() {
    println("=== rt#36-C bc_vm primes bench ===")
    bcvp_run_case(10,  4)
    bcvp_run_case(50, 15)
    println("=== done ===")
}

bcvp_main()
