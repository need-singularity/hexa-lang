// ═══════════════════════════════════════════════════════════════
//  self/test_neon_fp16_gemm.hexa — ROI #182 tests
//
//  Verifies the scaffold in self/codegen/neon_fp16_gemm.hexa:
//    1. Encoder bit-patterns (FMLA.8H / LD1.8H / ST1.8H / DUP.8H-from-H[]).
//    2. Inner-tile byte count / alignment.
//    3. Inner-tile instruction mix (counts of LD1 / DUP / FMLA / ST1).
//    4. Tiled GEMM oracle matches scalar GEMM ground-truth on small
//       m/n/k dummies (the "result verification" step in the ROI brief).
//    5. Edge cases: small k, larger tile walk (m=8, n=16, k=3).
//
//  Standalone — mirrors encoder math from neon_fp16_gemm.hexa so the
//  suite runs without module-loader (same style as test_peephole_arm64.hexa
//  and test_peephole_arm64_tier2.hexa).
//
//  Run: ./hexa self/test_neon_fp16_gemm.hexa
// ═══════════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name: string, cond: bool) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

// ─── Mirrored tile sizes ─────────────────────────────────────────
fn t_m_tile() -> int { return 4 }
fn t_n_tile() -> int { return 8 }
fn t_k_tile() -> int { return 1 }

// ─── Mirrored encoders (must match neon_fp16_gemm.hexa) ─────────
fn t_push_word(buf: [int], word: int) -> [int] {
    let mut b = buf
    b.push(word % 256)
    b.push((word / 256) % 256)
    b.push((word / 65536) % 256)
    b.push((word / 16777216) % 256)
    return b
}

fn t_read_word_le(code: [int], off: int) -> int {
    return code[off] + code[off + 1] * 256 + code[off + 2] * 65536 + code[off + 3] * 16777216
}

fn t_enc_fmla_8h(rd: int, rn: int, rm: int) -> int {
    return 1312820224 + rm * 65536 + rn * 32 + rd
}

fn t_enc_ld1_8h_post(vt: int, xn: int) -> int {
    return 1289712640 + xn * 32 + vt
}

fn t_enc_st1_8h_post(vt: int, xn: int) -> int {
    return 1285518336 + xn * 32 + vt
}

fn t_enc_dup_8h_from_h_elt(vd: int, vn: int, index: int) -> int {
    let imm5 = index * 4 + 2
    return 1308623872 + imm5 * 65536 + vn * 32 + vd
}

// ─── Mirrored emitter ───────────────────────────────────────────
fn t_emit_fp16_tile_k_step() -> [int] {
    let mt = t_m_tile()
    let mut buf = []
    buf = t_push_word(buf, t_enc_ld1_8h_post(1, 1))
    let mut i = 0
    while i < mt {
        let v_ai = 2 + i
        let v_ci = 6 + i
        buf = t_push_word(buf, t_enc_dup_8h_from_h_elt(v_ai, 0, i))
        buf = t_push_word(buf, t_enc_fmla_8h(v_ci, 1, v_ai))
        i = i + 1
    }
    return buf
}

fn t_emit_fp16_tile_epilogue() -> [int] {
    let mt = t_m_tile()
    let mut buf = []
    let mut i = 0
    while i < mt {
        buf = t_push_word(buf, t_enc_st1_8h_post(6 + i, 2))
        i = i + 1
    }
    return buf
}

fn t_emit_fp16_tile_kernel() -> [int] {
    let mut buf = []
    let kt = t_k_tile()
    let mut k = 0
    while k < kt {
        let step = t_emit_fp16_tile_k_step()
        let mut j = 0
        let n = len(step)
        while j < n {
            buf.push(step[j])
            j = j + 1
        }
        k = k + 1
    }
    let ep = t_emit_fp16_tile_epilogue()
    let mut j2 = 0
    let n2 = len(ep)
    while j2 < n2 {
        buf.push(ep[j2])
        j2 = j2 + 1
    }
    return buf
}

// ─── Mirrored GEMM oracles ─────────────────────────────────────
fn t_make_A(m: int, k: int) -> [int] {
    let mut a = []
    let mut i = 0
    while i < m {
        let mut j = 0
        while j < k {
            a.push(((i + 1) * 3 + (j + 2)) % 11)
            j = j + 1
        }
        i = i + 1
    }
    return a
}

fn t_make_B(k: int, n: int) -> [int] {
    let mut b = []
    let mut i = 0
    while i < k {
        let mut j = 0
        while j < n {
            b.push(((i + 2) + (j + 1) * 2) % 13)
            j = j + 1
        }
        i = i + 1
    }
    return b
}

fn t_make_C(m: int, n: int) -> [int] {
    let mut c = []
    let mut i = 0
    while i < m * n {
        c.push(0)
        i = i + 1
    }
    return c
}

fn t_gemm_scalar(a: [int], b: [int], c_in: [int], m: int, n: int, k: int) -> [int] {
    let mut c = c_in
    let mut i = 0
    while i < m {
        let mut j = 0
        while j < n {
            let mut acc = c[i * n + j]
            let mut p = 0
            while p < k {
                acc = acc + a[i * k + p] * b[p * n + j]
                p = p + 1
            }
            let mut out = []
            let mut q = 0
            let nn = len(c)
            let idx = i * n + j
            while q < nn {
                if q == idx {
                    out.push(acc)
                } else {
                    out.push(c[q])
                }
                q = q + 1
            }
            c = out
            j = j + 1
        }
        i = i + 1
    }
    return c
}

fn t_gemm_tiled(a: [int], b: [int], c_in: [int], m: int, n: int, k: int) -> [int] {
    let mt = t_m_tile()
    let nt = t_n_tile()
    let mut c = c_in
    let mut mb = 0
    while mb < m {
        let mut nb = 0
        while nb < n {
            let mut acc = []
            let mut init_i = 0
            while init_i < mt {
                let mut init_j = 0
                while init_j < nt {
                    acc.push(c[(mb + init_i) * n + (nb + init_j)])
                    init_j = init_j + 1
                }
                init_i = init_i + 1
            }
            let mut p = 0
            while p < k {
                let mut ai = 0
                while ai < mt {
                    let a_val = a[(mb + ai) * k + p]
                    let mut bj = 0
                    while bj < nt {
                        let b_val = b[p * n + (nb + bj)]
                        let idx = ai * nt + bj
                        let mut new_acc = []
                        let mut s = 0
                        let ns = len(acc)
                        while s < ns {
                            if s == idx {
                                new_acc.push(acc[s] + a_val * b_val)
                            } else {
                                new_acc.push(acc[s])
                            }
                            s = s + 1
                        }
                        acc = new_acc
                        bj = bj + 1
                    }
                    ai = ai + 1
                }
                p = p + 1
            }
            let mut si = 0
            while si < mt {
                let mut sj = 0
                while sj < nt {
                    let idx_full = (mb + si) * n + (nb + sj)
                    let v = acc[si * nt + sj]
                    let mut out = []
                    let mut q = 0
                    let nn = len(c)
                    while q < nn {
                        if q == idx_full {
                            out.push(v)
                        } else {
                            out.push(c[q])
                        }
                        q = q + 1
                    }
                    c = out
                    sj = sj + 1
                }
                si = si + 1
            }
            nb = nb + nt
        }
        mb = mb + mt
    }
    return c
}

fn t_arrays_equal(a: [int], b: [int]) -> bool {
    if len(a) != len(b) { return false }
    let mut i = 0
    let n = len(a)
    while i < n {
        if a[i] != b[i] { return false }
        i = i + 1
    }
    return true
}

// ═══════════════════════════════════════════
//  Test 1 — FMLA.8H encoding sanity
// ═══════════════════════════════════════════
fn test_fmla_encoding() {
    // FMLA V6.8H, V1.8H, V2.8H → 0x4E420C26
    //   rd=6, rn=1, rm=2 → 0x4E400C00 + (2<<16) + (1<<5) + 6 = 0x4E420C26
    let w = t_enc_fmla_8h(6, 1, 2)
    // 0x4E420C26 = 1312951334
    check("FMLA V6,V1,V2 word", w == 1312951334)

    // Round-trip via byte packing.
    let mut buf = []
    buf = t_push_word(buf, w)
    check("FMLA byte0 = 0x26", buf[0] == 38)
    check("FMLA byte1 = 0x0C", buf[1] == 12)
    check("FMLA byte2 = 0x42", buf[2] == 66)
    check("FMLA byte3 = 0x4E", buf[3] == 78)
}

// ═══════════════════════════════════════════
//  Test 2 — LD1 / ST1 .8H encoding sanity
// ═══════════════════════════════════════════
fn test_ld1_st1_encoding() {
    // LD1 {V1.8H}, [X1], #16 → 0x4CDF7421
    let ld = t_enc_ld1_8h_post(1, 1)
    check("LD1 V1,[X1] word", ld == 1289712640 + 32 + 1)

    // ST1 {V6.8H}, [X2], #16 → 0x4C9F7446
    let st = t_enc_st1_8h_post(6, 2)
    check("ST1 V6,[X2] word", st == 1285518336 + 64 + 6)
}

// ═══════════════════════════════════════════
//  Test 3 — DUP.8H from H[i] encoding sanity
// ═══════════════════════════════════════════
fn test_dup_encoding() {
    // DUP V2.8H, V0.H[0] → imm5 = 0b00010 = 2; base 0x4E000400
    //   0x4E000400 + (2<<16) + (0<<5) + 2 = 0x4E020402
    let w0 = t_enc_dup_8h_from_h_elt(2, 0, 0)
    check("DUP V2,V0.H[0] word", w0 == 1308623872 + 2 * 65536 + 2)

    // DUP V5.8H, V0.H[3] → imm5 = (3<<2)|2 = 14; base 0x4E000400
    let w3 = t_enc_dup_8h_from_h_elt(5, 0, 3)
    check("DUP V5,V0.H[3] word", w3 == 1308623872 + 14 * 65536 + 5)
}

// ═══════════════════════════════════════════
//  Test 4 — K-step byte layout (instruction mix)
// ═══════════════════════════════════════════
fn test_kstep_layout() {
    let step = t_emit_fp16_tile_k_step()
    check("k-step size = 36", len(step) == 36)
    check("k-step multiple of 4", len(step) % 4 == 0)

    // First instr is LD1 V1, [X1]
    let w0 = t_read_word_le(step, 0)
    check("k-step[0] = LD1 V1,[X1]", w0 == t_enc_ld1_8h_post(1, 1))

    // Next 4 pairs should be DUP/FMLA for i in 0..4.
    let mut i = 0
    let mut ok = true
    while i < t_m_tile() {
        let off_dup = 4 + i * 8
        let off_fmla = off_dup + 4
        let w_dup = t_read_word_le(step, off_dup)
        let w_fmla = t_read_word_le(step, off_fmla)
        if w_dup != t_enc_dup_8h_from_h_elt(2 + i, 0, i) { ok = false }
        if w_fmla != t_enc_fmla_8h(6 + i, 1, 2 + i) { ok = false }
        i = i + 1
    }
    check("k-step DUP+FMLA pairs correct", ok)
}

// ═══════════════════════════════════════════
//  Test 5 — Epilogue layout
// ═══════════════════════════════════════════
fn test_epilogue_layout() {
    let ep = t_emit_fp16_tile_epilogue()
    check("epilogue size = 16", len(ep) == 16)
    check("epilogue multiple of 4", len(ep) % 4 == 0)
    let mut ok = true
    let mut i = 0
    while i < t_m_tile() {
        let w = t_read_word_le(ep, i * 4)
        if w != t_enc_st1_8h_post(6 + i, 2) { ok = false }
        i = i + 1
    }
    check("epilogue ST1 sequence correct", ok)
}

// ═══════════════════════════════════════════
//  Test 6 — Full tile size
// ═══════════════════════════════════════════
fn test_full_tile_size() {
    let full = t_emit_fp16_tile_kernel()
    // k_tile=1 → 36 + 16 = 52 bytes
    check("full tile size = 52", len(full) == 52)
    check("full tile multiple of 4", len(full) % 4 == 0)
}

// ═══════════════════════════════════════════
//  Test 7 — Tiled GEMM oracle vs. scalar GEMM: minimal 4×8 k=1
// ═══════════════════════════════════════════
fn test_gemm_4x8_k1() {
    let m = 4
    let n = 8
    let k = 1
    let a = t_make_A(m, k)
    let b = t_make_B(k, n)
    let c = t_make_C(m, n)
    let gold = t_gemm_scalar(a, b, c, m, n, k)
    let got = t_gemm_tiled(a, b, c, m, n, k)
    check("GEMM 4×8 k=1: len match", len(gold) == len(got))
    check("GEMM 4×8 k=1: tiled == scalar", t_arrays_equal(gold, got))
}

// ═══════════════════════════════════════════
//  Test 8 — Tiled GEMM with k>1 (inner accumulation)
// ═══════════════════════════════════════════
fn test_gemm_4x8_k3() {
    let m = 4
    let n = 8
    let k = 3
    let a = t_make_A(m, k)
    let b = t_make_B(k, n)
    let c = t_make_C(m, n)
    let gold = t_gemm_scalar(a, b, c, m, n, k)
    let got = t_gemm_tiled(a, b, c, m, n, k)
    check("GEMM 4×8 k=3: tiled == scalar", t_arrays_equal(gold, got))
}

// ═══════════════════════════════════════════
//  Test 9 — Tile walk over multiple blocks (m=8, n=16, k=3)
// ═══════════════════════════════════════════
fn test_gemm_8x16_k3() {
    let m = 8
    let n = 16
    let k = 3
    let a = t_make_A(m, k)
    let b = t_make_B(k, n)
    let c = t_make_C(m, n)
    let gold = t_gemm_scalar(a, b, c, m, n, k)
    let got = t_gemm_tiled(a, b, c, m, n, k)
    check("GEMM 8×16 k=3: tiled == scalar", t_arrays_equal(gold, got))
}

// ═══════════════════════════════════════════
//  Test 10 — C not zero-initialised (accumulate semantics)
// ═══════════════════════════════════════════
fn test_gemm_accumulate() {
    let m = 4
    let n = 8
    let k = 2
    let a = t_make_A(m, k)
    let b = t_make_B(k, n)
    // non-zero initial C
    let mut c = []
    let mut i = 0
    while i < m * n {
        c.push((i % 5) + 1)
        i = i + 1
    }
    let gold = t_gemm_scalar(a, b, c, m, n, k)
    let got = t_gemm_tiled(a, b, c, m, n, k)
    check("GEMM accumulate 4×8 k=2: tiled == scalar", t_arrays_equal(gold, got))
}

// ═══════════════════════════════════════════
//  Test 11 — Register plan sanity (no encoder aliasing in k-step)
// ═══════════════════════════════════════════
fn test_register_plan_disjoint() {
    // V_B (v1), V_A (v0), V_Ai (v2..v5), V_C (v6..v9) must be unique.
    // Encode all and look for collisions via the low 5 bits of the LD1/DUP/FMLA Rd.
    let step = t_emit_fp16_tile_k_step()
    // LD1 Rt = bits [4:0] of word at offset 0 — should be 1 (V1)
    let w_ld = t_read_word_le(step, 0)
    check("k-step LD1 Rt == 1", w_ld % 32 == 1)

    // DUP Rd at pair i → should be 2+i
    let mut ok_dup = true
    let mut i = 0
    while i < t_m_tile() {
        let w = t_read_word_le(step, 4 + i * 8)
        if w % 32 != 2 + i { ok_dup = false }
        i = i + 1
    }
    check("k-step DUP Rd = 2..5", ok_dup)

    // FMLA Rd at pair i → should be 6+i
    let mut ok_fm = true
    let mut j = 0
    while j < t_m_tile() {
        let w = t_read_word_le(step, 8 + j * 8)
        if w % 32 != 6 + j { ok_fm = false }
        j = j + 1
    }
    check("k-step FMLA Rd = 6..9", ok_fm)
}

// ═══════════════════════════════════════════
//  Driver
// ═══════════════════════════════════════════
fn run_all() {
    test_fmla_encoding()
    test_ld1_st1_encoding()
    test_dup_encoding()
    test_kstep_layout()
    test_epilogue_layout()
    test_full_tile_size()
    test_gemm_4x8_k1()
    test_gemm_4x8_k3()
    test_gemm_8x16_k3()
    test_gemm_accumulate()
    test_register_plan_disjoint()

    println("")
    println("═══════════════════════════════════════")
    println("  ROI #182 NEON fp16 GEMM tests")
    println("  PASS: " + to_string(pass_count))
    println("  FAIL: " + to_string(fail_count))
    println("═══════════════════════════════════════")
}

run_all()
