// ═══════════════════════════════════════════════════════════
//  test_struct_patterns.hexa — Struct & Impl Advanced Patterns
//  Tests: nested structs, struct with arrays, struct in map,
//         builder pattern, struct methods chaining, struct comparison,
//         factory functions, struct with closures, struct in loops
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA Struct & Impl Advanced Pattern Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Basic struct with impl ────────────────────────────

println("--- Basic Struct + Impl ---")

struct Vec2 {
    x: int,
    y: int
}

impl Vec2 {
    fn mag_sq(self) {
        return self.x * self.x + self.y * self.y
    }
    fn add(self, other) {
        return Vec2 { x: self.x + other.x, y: self.y + other.y }
    }
    fn scale(self, s) {
        return Vec2 { x: self.x * s, y: self.y * s }
    }
    fn dot(self, other) {
        return self.x * other.x + self.y * other.y
    }
}

let v1 = Vec2 { x: 3, y: 4 }
let v2 = Vec2 { x: 1, y: 2 }
check("mag_sq", v1.mag_sq(), 25)
let v3 = v1.add(v2)
check("add x", v3.x, 4)
check("add y", v3.y, 6)
let v4 = v1.scale(3)
check("scale x", v4.x, 9)
check("scale y", v4.y, 12)
check("dot product", v1.dot(v2), 11)

// ── 2. Struct with string field ──────────────────────────

println("")
println("--- String Fields ---")

struct Entry {
    key: string,
    value: int
}

impl Entry {
    fn format(self) {
        return self.key + "=" + to_string(self.value)
    }
}

let e1 = Entry { key: "score", value: 95 }
check("entry key", e1.key, "score")
check("entry value", e1.value, 95)
check("entry format", e1.format(), "score=95")

// ── 3. Array of structs ──────────────────────────────────

println("")
println("--- Array of Structs ---")

let points = [
    Vec2 { x: 0, y: 0 },
    Vec2 { x: 1, y: 1 },
    Vec2 { x: 3, y: 4 }
]
check("arr struct len", len(points), 3)
check("arr struct [0].x", points[0].x, 0)
check("arr struct [2].mag_sq", points[2].mag_sq(), 25)

let mut total_mag = 0
let mut i = 0
while i < len(points) {
    total_mag = total_mag + points[i].mag_sq()
    i = i + 1
}
check("sum mag_sq", total_mag, 27)

// ── 4. Struct factory function ───────────────────────────

println("")
println("--- Factory Functions ---")

fn make_vec(x, y) {
    return Vec2 { x: x, y: y }
}
let fv = make_vec(5, 10)
check("factory x", fv.x, 5)
check("factory y", fv.y, 10)

fn zero_vec() {
    return Vec2 { x: 0, y: 0 }
}
let zv = zero_vec()
check("zero_vec x", zv.x, 0)
check("zero_vec y", zv.y, 0)

// ── 5. Struct with bool field ────────────────────────────

println("")
println("--- Bool Fields ---")

struct Task {
    name: string,
    done: bool,
    priority: int
}

impl Task {
    fn describe(self) {
        let status = match self.done {
            true -> "done",
            _ -> "pending"
        }
        return self.name + " [" + status + "] P" + to_string(self.priority)
    }
}

let t1 = Task { name: "build", done: true, priority: 1 }
let t2 = Task { name: "test", done: false, priority: 2 }
check("task1 name", t1.name, "build")
check("task1 done", t1.done, true)
check("task1 desc", t1.describe(), "build [done] P1")
check("task2 desc", t2.describe(), "test [pending] P2")

// ── 6. Struct in match ───────────────────────────────────

println("")
println("--- Struct in Match ---")

fn classify_vec(v) {
    return match v.mag_sq() {
        0 -> "origin",
        1 -> "unit",
        _ -> "other"
    }
}
check("classify origin", classify_vec(zero_vec()), "origin")
check("classify unit", classify_vec(make_vec(1, 0)), "unit")
check("classify other", classify_vec(make_vec(3, 4)), "other")

// ── 7. Struct with computation ───────────────────────────

println("")
println("--- Struct Computation ---")

struct Rect {
    w: int,
    h: int
}

impl Rect {
    fn area(self) { return self.w * self.h }
    fn perimeter(self) { return 2 * (self.w + self.h) }
    fn is_square(self) { return self.w == self.h }
}

let r1 = Rect { w: 5, h: 3 }
let r2 = Rect { w: 4, h: 4 }
check("rect area", r1.area(), 15)
check("rect perim", r1.perimeter(), 16)
check("rect not square", r1.is_square(), false)
check("rect is square", r2.is_square(), true)

// ── 8. Struct in loop accumulation ───────────────────────

println("")
println("--- Struct Loop ---")

let mut rects = []
let mut ri = 1
while ri <= 4 {
    rects.push(Rect { w: ri, h: ri + 1 })
    ri = ri + 1
}
check("rects len", len(rects), 4)

let mut total_area = 0
let mut rj = 0
while rj < len(rects) {
    total_area = total_area + rects[rj].area()
    rj = rj + 1
}
// 1*2 + 2*3 + 3*4 + 4*5 = 2+6+12+20 = 40
check("total area", total_area, 40)

// ── 9. Method returning struct ───────────────────────────

println("")
println("--- Method Returns Struct ---")

let v5 = make_vec(1, 2)
let v6 = v5.scale(3)
check("method ret struct x", v6.x, 3)
check("method ret struct y", v6.y, 6)
let v7 = v5.add(v6)
check("chained method x", v7.x, 4)
check("chained method y", v7.y, 8)

// ── 10. Struct with closures ─────────────────────────────

println("")
println("--- Struct + Closure ---")

// Struct passed to closure
fn make_formatter(prefix) {
    return |v| prefix + ": " + to_string(v.x) + "," + to_string(v.y)
}
let fmt = make_formatter("point")
check("closure + struct", fmt(make_vec(3, 4)), "point: 3,4")
check("closure + struct 2", fmt(zero_vec()), "point: 0,0")

// Closure captures struct
let ref_vec = make_vec(10, 20)
let get_x = |_| ref_vec.x
let get_y = |_| ref_vec.y
check("capture struct x", get_x(0), 10)
check("capture struct y", get_y(0), 20)

let sum_fn = |_| ref_vec.x + ref_vec.y
check("capture struct sum", sum_fn(0), 30)

// ── Summary ──────────────────────────────────────────────

println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    throw "TESTS FAILED: " + to_string(fail_count)
}
