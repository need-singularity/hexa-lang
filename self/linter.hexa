use "self/stdlib/law_io"

// self/linter.hexa — Hexa-only 소스 린터
// 문법 pitfalls (P1~P5, G5) + 자주 틀리는 패턴 감지
//
// 사용:
//   hexa linter.hexa <file.hexa>
//   hexa linter.hexa --dir <dir>
//   hexa linter.hexa --fix <file.hexa>   (자동 수정 가능한 것만)

let cli_args = real_args()
if len(cli_args) < 1 {
    eprintln("usage: hexa linter.hexa <file.hexa>")
    eprintln("       hexa linter.hexa --dir <dir>")
    eprintln("       hexa linter.hexa --fix <file.hexa>")
    exit(1)
}

// ── Lint 결과 구조 ──────────────────────────────────────
struct LintMsg {
    level: string,
    line: int,
    rule: string,
    msg: string
}

fn fmt_msg(m) {
    return m.level + ": line " + to_string(m.line) + " [" + m.rule + "] " + m.msg
}

// ── P1: 세미콜론 감지 ──────────────────────────────────
fn check_semicolons(lines) {
    let mut results = []
    let mut i = 0
    for line in lines {
        i = i + 1
        let t = trim(line)
        if t == "" { continue }
        if starts_with(t, "//") { continue }
        if ends_with(t, ";") {
            if !contains(t, "extern ") && !contains(t, "for ") {
                results.push(LintMsg {
                    level: "warn",
                    line: i,
                    rule: "P1",
                    msg: "semicolons are not idiomatic in Hexa; use newlines"
                })
            }
        }
    }
    return results
}

// ── P3: exec() without try-catch ────────────────────────
fn check_exec_no_try(lines) {
    let mut results = []
    let mut i = 0
    let mut in_try = false
    for line in lines {
        i = i + 1
        let t = trim(line)
        if starts_with(t, "//") { continue }
        if contains(t, "try {") || contains(t, "try{") {
            in_try = true
        }
        if in_try && contains(t, "} catch") {
            in_try = false
            continue
        }
        if !in_try && contains(t, "exec(") {
            if !contains(t, "try") {
                results.push(LintMsg {
                    level: "warn",
                    line: i,
                    rule: "P3",
                    msg: "exec() without try-catch; failures return Error -> method calls crash"
                })
            }
        }
    }
    return results
}

// ── P5: 상대 경로 read_file/write_file ──────────────────
fn check_relative_paths(lines) {
    let mut results = []
    let file_fns = ["read_file", "write_file", "append_file"]
    let mut i = 0
    for line in lines {
        i = i + 1
        let t = trim(line)
        if starts_with(t, "//") { continue }
        for fn_name in file_fns {
            let pat = fn_name + "(\""
            if contains(t, pat) {
                let idx = t.index_of(pat)
                if idx >= 0 {
                    let after = t.substring(idx + len(pat), len(t))
                    if !starts_with(after, "/") {
                        results.push(LintMsg {
                            level: "warn",
                            line: i,
                            rule: "P5",
                            msg: fn_name + "() with relative path; use absolute path to avoid CWD failures"
                        })
                    }
                }
            }
        }
    }
    return results
}

// ── G5: if 블록 내 StructInit 모호성 ────────────────────
fn check_struct_in_if(lines) {
    let mut results = []
    let mut i = 0
    let mut in_if_block = false
    let mut brace_depth = 0
    for line in lines {
        i = i + 1
        let t = trim(line)
        if starts_with(t, "//") { continue }
        if starts_with(t, "if ") && contains(t, "{") {
            in_if_block = true
            brace_depth = 1
            continue
        }
        if in_if_block {
            let chars = t.chars()
            for ch in chars {
                if ch == '{' { brace_depth = brace_depth + 1 }
                if ch == '}' { brace_depth = brace_depth - 1 }
            }
            if brace_depth <= 0 {
                in_if_block = false
                continue
            }
            if contains(t, "{") && contains(t, ":") && !contains(t, "(") {
                let first_ch = t.substring(0, 1)
                if first_ch == first_ch.to_upper() && first_ch != first_ch.to_lower() {
                    results.push(LintMsg {
                        level: "warn",
                        line: i,
                        rule: "G5",
                        msg: "struct literal in if-block causes parser ambiguity (G5); assign to variable first"
                    })
                }
            }
        }
    }
    return results
}

// ── 잘못된 메서드명 감지 ────────────────────────────────
fn check_method_names(lines) {
    let mut results = []
    let wrong_methods = [
        ".substr(",    ".substring(",
        ".split_whitespace(", ".split(\" \")",
        ".find(",      ".index_of(",
        ".includes(",  ".contains(",
        ".append(",    ".push(",
        ".size(",      ".len(",
        ".length(",    ".len(",
        ".indexOf(",   ".index_of(",
        ".toString(",  ".to_string(",
        ".toUpper(",   ".to_upper(",
        ".toLower(",   ".to_lower(",
        ".startsWith(", ".starts_with(",
        ".endsWith(",  ".ends_with(",
        ".trimStart(", ".trim(",
        ".trimEnd(",   ".trim("
    ]
    let mut i = 0
    for line in lines {
        i = i + 1
        let t = trim(line)
        if starts_with(t, "//") { continue }
        let mut j = 0
        while j < len(wrong_methods) {
            let wrong = wrong_methods[j]
            let right = wrong_methods[j + 1]
            if contains(t, wrong) {
                results.push(LintMsg {
                    level: "warn",
                    line: i,
                    rule: "method",
                    msg: wrong + ") does not exist in Hexa; use " + right + ")"
                })
            }
            j = j + 2
        }
    }
    return results
}

// ── 배열 리터럴 혼합 타입 ───────────────────────────────
fn check_mixed_arrays(lines) {
    let mut results = []
    let mut i = 0
    for line in lines {
        i = i + 1
        let t = trim(line)
        if starts_with(t, "//") { continue }
        let eq_idx = t.index_of("= [")
        if eq_idx < 0 { continue }
        let bracket_start = eq_idx + 2
        let bracket_end = t.index_of("]")
        if bracket_end < 0 { continue }
        if bracket_end <= bracket_start { continue }
        let inner = t.substring(bracket_start + 1, bracket_end)
        let items = split(inner, ",")
        let mut has_int = false
        let mut has_str = false
        let mut has_bool = false
        let mut has_float = false
        for item in items {
            let v = trim(item)
            if v == "" { continue }
            if v == "true" || v == "false" {
                has_bool = true
            } else if starts_with(v, "\"") || starts_with(v, "'") {
                has_str = true
            } else if contains(v, ".") && !contains(v, "(") {
                has_float = true
            } else if len(v) > 0 {
                let ch = v.substring(0, 1)
                let digits = "0123456789"
                if contains(digits, ch) {
                    has_int = true
                } else if ch == "-" && len(v) > 1 {
                    has_int = true
                }
            }
        }
        let mut type_count = 0
        if has_int { type_count = type_count + 1 }
        if has_str { type_count = type_count + 1 }
        if has_bool { type_count = type_count + 1 }
        if has_float { type_count = type_count + 1 }
        if type_count >= 2 {
            let mut types = []
            if has_int { types.push("Int") }
            if has_float { types.push("Float") }
            if has_str { types.push("String") }
            if has_bool { types.push("Bool") }
            results.push(LintMsg {
                level: "warn",
                line: i,
                rule: "type",
                msg: "mixed types in array literal (" + join(types, ", ") + "); arrays should be uniform"
            })
        }
    }
    return results
}

// ── 미사용 import 감지 ──────────────────────────────────
fn check_unused_imports(lines, source) {
    let mut results = []
    let mut i = 0
    for line in lines {
        i = i + 1
        let t = trim(line)
        if !starts_with(t, "use ") && !starts_with(t, "import ") { continue }
        let parts = split(t, "::")
        let mut name = ""
        if len(parts) > 1 {
            name = trim(parts[len(parts) - 1])
        } else {
            let words = split(t, " ")
            if len(words) >= 2 {
                name = trim(words[len(words) - 1])
            }
        }
        if name == "" { continue }
        let mut used = false
        let mut j = 0
        for check_line in lines {
            j = j + 1
            if j == i { continue }
            let ct = trim(check_line)
            if starts_with(ct, "//") { continue }
            if starts_with(ct, "use ") || starts_with(ct, "import ") { continue }
            if contains(ct, name) {
                used = true
                break
            }
        }
        if !used {
            results.push(LintMsg {
                level: "warn",
                line: i,
                rule: "import",
                msg: "unused import: `" + name + "`"
            })
        }
    }
    return results
}

// ── 전체 린트 실행 ──────────────────────────────────────
fn lint_file(path) {
    let mut source = ""
    try {
        source = to_string(read_file(path))
    } catch e {
        eprintln("error: cannot read " + path + " (" + to_string(e) + ")")
        return []
    }
    let lines = split(source, "\n")

    let mut all = []
    let r1 = check_semicolons(lines)
    for m in r1 { all.push(m) }
    let r2 = check_exec_no_try(lines)
    for m in r2 { all.push(m) }
    let r3 = check_relative_paths(lines)
    for m in r3 { all.push(m) }
    let r4 = check_struct_in_if(lines)
    for m in r4 { all.push(m) }
    let r5 = check_method_names(lines)
    for m in r5 { all.push(m) }
    let r6 = check_mixed_arrays(lines)
    for m in r6 { all.push(m) }
    let r7 = check_unused_imports(lines, source)
    for m in r7 { all.push(m) }

    return all
}

// ── 자동 수정 (P1: 세미콜론 제거) ──────────────────────
fn autofix_file(path) {
    let mut source = ""
    try {
        source = to_string(read_file(path))
    } catch e {
        eprintln("error: " + to_string(e))
        return
    }
    let lines = split(source, "\n")
    let mut fixed = []
    let mut fix_count = 0
    for line in lines {
        let t = trim(line)
        if ends_with(t, ";") && !starts_with(t, "//") && !contains(t, "extern ") && !contains(t, "for ") {
            let new_line = line.substring(0, len(line) - 1)
            fixed.push(new_line)
            fix_count = fix_count + 1
        } else {
            fixed.push(line)
        }
    }
    if fix_count > 0 {
        safe_write_file(path, join(fixed, "\n"))
        println(path + " -- " + to_string(fix_count) + " semicolons removed")
    } else {
        println(path + " -- no autofix needed")
    }
}

// ── CLI ─────────────────────────────────────────────────
let mode = cli_args[0]

if mode == "--dir" {
    if len(cli_args) < 2 {
        eprintln("usage: hexa linter.hexa --dir <dir>")
        exit(1)
    }
    let dir = cli_args[1]
    let mut files = []
    let _find_result = ""
    try {
        _find_result = to_string(exec("find " + dir + " -name '*.hexa' -type f"))
    } catch e {
        eprintln("error: " + to_string(e))
        exit(1)
    }
    let _found = split(_find_result, "\n")
    for f in _found {
        let ft = trim(f)
        if ft != "" { files.push(ft) }
    }
    let mut total_warns = 0
    let mut file_warns = 0
    for file in files {
        let msgs = lint_file(file)
        if len(msgs) > 0 {
            file_warns = file_warns + 1
            for m in msgs {
                println(file + ": " + fmt_msg(m))
                total_warns = total_warns + 1
            }
        }
    }
    println("\n" + to_string(total_warns) + " warning(s) in " + to_string(file_warns) + " file(s)")
    exit(0)
}

if mode == "--fix" {
    if len(cli_args) < 2 {
        eprintln("usage: hexa linter.hexa --fix <file.hexa>")
        exit(1)
    }
    autofix_file(cli_args[1])
    exit(0)
}

// 단일 파일 린트
let file = mode
let msgs = lint_file(file)
if len(msgs) == 0 {
    println(file + " -- clean")
} else {
    for m in msgs {
        println(file + ": " + fmt_msg(m))
    }
    let warn_count = len(msgs)
    println("\n" + to_string(warn_count) + " warning(s)")
}
