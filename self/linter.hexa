use "self/stdlib/law_io"

// self/linter.hexa — Hexa-only 소스 린터
// 문법 pitfalls (P1~P5, G5) + 자주 틀리는 패턴 감지
//
// 사용:
//   hexa linter.hexa <file.hexa>
//   hexa linter.hexa --dir <dir>
//   hexa linter.hexa --fix <file.hexa>   (자동 수정 가능한 것만)

let cli_args = real_args()
if len(cli_args) < 1 {
    eprintln("usage: hexa linter.hexa <file.hexa>")
    eprintln("       hexa linter.hexa --dir <dir>")
    eprintln("       hexa linter.hexa --fix <file.hexa>")
    exit(1)
}

// ── Lint 결과 구조 ──────────────────────────────────────
struct LintMsg {
    level: string,
    line: int,
    rule: string,
    msg: string
}

fn fmt_msg(m) {
    return m.level + ": line " + to_string(m.line) + " [" + m.rule + "] " + m.msg
}

// ── P1: 세미콜론 감지 ──────────────────────────────────
fn check_semicolons(lines) {
    let mut results = []
    let mut i = 0
    for line in lines {
        i = i + 1
        let t = trim(line)
        if t == "" { continue }
        if starts_with(t, "//") { continue }
        if ends_with(t, ";") {
            if !contains(t, "extern ") && !contains(t, "for ") {
                results.push(LintMsg {
                    level: "warn",
                    line: i,
                    rule: "P1",
                    msg: "semicolons are not idiomatic in Hexa; use newlines"
                })
            }
        }
    }
    return results
}

// ── P3: exec() without try-catch ────────────────────────
fn check_exec_no_try(lines) {
    let mut results = []
    let mut i = 0
    let mut in_try = false
    for line in lines {
        i = i + 1
        let t = trim(line)
        if starts_with(t, "//") { continue }
        if contains(t, "try {") || contains(t, "try{") {
            in_try = true
        }
        if in_try && contains(t, "} catch") {
            in_try = false
            continue
        }
        if !in_try && contains(t, "exec(") {
            if !contains(t, "try") {
                results.push(LintMsg {
                    level: "warn",
                    line: i,
                    rule: "P3",
                    msg: "exec() without try-catch; failures return Error -> method calls crash"
                })
            }
        }
    }
    return results
}

// ── RFC-007: exec(cmd) == int_literal silent-fail (exec returns string, not int)
// See: proposals/rfc_007_exec_lint_rule.md, tool/exec_eq_int_lint.hexa
// Pattern: `exec(...) == 0`, `exec(...) != N`, or `let rc = exec(...); if rc == N`
fn check_exec_eq_int(lines) {
    let mut results = []
    let mut exec_vars = []
    let mut i = 0
    for line in lines {
        i = i + 1
        let t = trim(line)
        if starts_with(t, "//") { continue }
        if contains(t, "// exec_eq_int_lint: allow") { continue }

        // Track `let [mut] <name> = exec(...)` (no chained `.method()`).
        if starts_with(t, "let ") {
            let rest_start = if starts_with(t, "let mut ") { 8 } else { 4 }
            let rest = t.substring(rest_start, len(t))
            let eq_at = rest.index_of("=")
            if eq_at > 0 {
                let name = trim(rest.substring(0, eq_at))
                let rhs = trim(rest.substring(eq_at + 1, len(rest)))
                if starts_with(rhs, "exec(") && ends_with(rhs, ")") {
                    if !contains(name, " ") && !contains(name, ":") && len(name) > 0 {
                        exec_vars.push(name)
                    }
                }
            }
        }

        // Detect comparison with int literal where one side is exec(...) or
        // a recorded exec-bound variable.
        let ops = ["==", "!=", "<=", ">="]
        let mut op_idx = -1
        let mut op_str = ""
        let mut oi = 0
        while oi < len(ops) {
            let p = t.index_of(ops[oi])
            if p >= 0 {
                if op_idx < 0 || p < op_idx { op_idx = p; op_str = ops[oi] }
            }
            oi = oi + 1
        }
        if op_idx < 0 { continue }
        let lhs = trim(t.substring(0, op_idx))
        let rhs = trim(t.substring(op_idx + len(op_str), len(t)))
        // strip leading `if `, `while `, `else if `, `return `
        let lhs2 =
            if starts_with(lhs, "if ") { trim(lhs.substring(3, len(lhs))) }
            else if starts_with(lhs, "while ") { trim(lhs.substring(6, len(lhs))) }
            else if starts_with(lhs, "return ") { trim(lhs.substring(7, len(lhs))) }
            else { lhs }
        // strip trailing `{` and one unbalanced `)`
        let mut rhs2 = rhs
        if ends_with(rhs2, "{") { rhs2 = trim(rhs2.substring(0, len(rhs2) - 1)) }
        // Quick exec-side detection
        let lhs_exec = starts_with(lhs2, "exec(") && ends_with(lhs2, ")")
        let rhs_exec = starts_with(rhs2, "exec(") && ends_with(rhs2, ")")
        // Quick int-literal detection (digits only, optional leading sign)
        let lhs_int = _is_pure_int_lit(lhs2)
        let rhs_int = _is_pure_int_lit(rhs2)
        let mut lhs_bound = false
        let mut rhs_bound = false
        let mut bv = 0
        while bv < len(exec_vars) {
            if lhs2 == exec_vars[bv] { lhs_bound = true }
            if rhs2 == exec_vars[bv] { rhs_bound = true }
            bv = bv + 1
        }
        let exec_side = lhs_exec || rhs_exec || lhs_bound || rhs_bound
        let int_side = lhs_int || rhs_int
        if !(exec_side && int_side) { continue }
        if (lhs_exec || lhs_bound) && (rhs_exec || rhs_bound) { continue }
        if lhs_int && rhs_int { continue }
        results.push(LintMsg {
            level: "warn",
            line: i,
            rule: "RFC-007",
            msg: "exec() vs int literal — exec returns string; use exec_with_status(cmd)[1] for exit code"
        })
    }
    return results
}

// helper: pure-integer literal (digits only, optional +/-)
fn _is_pure_int_lit(s) {
    if len(s) == 0 { return false }
    let mut start = 0
    let f = s.substring(0, 1)
    if f == "-" || f == "+" {
        if len(s) == 1 { return false }
        start = 1
    }
    let mut k = start
    while k < len(s) {
        let ch = s.substring(k, k + 1)
        if !contains("0123456789", ch) { return false }
        k = k + 1
    }
    return true
}

// ── P5: 상대 경로 read_file/write_file ──────────────────
fn check_relative_paths(lines) {
    let mut results = []
    let file_fns = ["read_file", "write_file", "append_file"]
    let mut i = 0
    for line in lines {
        i = i + 1
        let t = trim(line)
        if starts_with(t, "//") { continue }
        for fn_name in file_fns {
            let pat = fn_name + "(\""
            if contains(t, pat) {
                let idx = t.index_of(pat)
                if idx >= 0 {
                    let after = t.substring(idx + len(pat), len(t))
                    if !starts_with(after, "/") {
                        results.push(LintMsg {
                            level: "warn",
                            line: i,
                            rule: "P5",
                            msg: fn_name + "() with relative path; use absolute path to avoid CWD failures"
                        })
                    }
                }
            }
        }
    }
    return results
}

// ── G5: if 블록 내 StructInit 모호성 ────────────────────
fn check_struct_in_if(lines) {
    let mut results = []
    let mut i = 0
    let mut in_if_block = false
    let mut brace_depth = 0
    for line in lines {
        i = i + 1
        let t = trim(line)
        if starts_with(t, "//") { continue }
        if starts_with(t, "if ") && contains(t, "{") {
            in_if_block = true
            brace_depth = 1
            continue
        }
        if in_if_block {
            let chars = t.chars()
            for ch in chars {
                if ch == '{' { brace_depth = brace_depth + 1 }
                if ch == '}' { brace_depth = brace_depth - 1 }
            }
            if brace_depth <= 0 {
                in_if_block = false
                continue
            }
            if contains(t, "{") && contains(t, ":") && !contains(t, "(") {
                let first_ch = t.substring(0, 1)
                if first_ch == first_ch.to_upper() && first_ch != first_ch.to_lower() {
                    results.push(LintMsg {
                        level: "warn",
                        line: i,
                        rule: "G5",
                        msg: "struct literal in if-block causes parser ambiguity (G5); assign to variable first"
                    })
                }
            }
        }
    }
    return results
}

// ── 잘못된 메서드명 감지 ────────────────────────────────
fn check_method_names(lines) {
    let mut results = []
    let wrong_methods = [
        ".substr(",    ".substring(",
        ".split_whitespace(", ".split(\" \")",
        ".find(",      ".index_of(",
        ".includes(",  ".contains(",
        ".append(",    ".push(",
        ".size(",      ".len(",
        ".length(",    ".len(",
        ".indexOf(",   ".index_of(",
        ".toString(",  ".to_string(",
        ".toUpper(",   ".to_upper(",
        ".toLower(",   ".to_lower(",
        ".startsWith(", ".starts_with(",
        ".endsWith(",  ".ends_with(",
        ".trimStart(", ".trim(",
        ".trimEnd(",   ".trim("
    ]
    let mut i = 0
    for line in lines {
        i = i + 1
        let t = trim(line)
        if starts_with(t, "//") { continue }
        let mut j = 0
        while j < len(wrong_methods) {
            let wrong = wrong_methods[j]
            let right = wrong_methods[j + 1]
            if contains(t, wrong) {
                results.push(LintMsg {
                    level: "warn",
                    line: i,
                    rule: "method",
                    msg: wrong + ") does not exist in Hexa; use " + right + ")"
                })
            }
            j = j + 2
        }
    }
    return results
}

// ── 배열 리터럴 혼합 타입 ───────────────────────────────
fn check_mixed_arrays(lines) {
    let mut results = []
    let mut i = 0
    for line in lines {
        i = i + 1
        let t = trim(line)
        if starts_with(t, "//") { continue }
        let eq_idx = t.index_of("= [")
        if eq_idx < 0 { continue }
        let bracket_start = eq_idx + 2
        let bracket_end = t.index_of("]")
        if bracket_end < 0 { continue }
        if bracket_end <= bracket_start { continue }
        let inner = t.substring(bracket_start + 1, bracket_end)
        let items = split(inner, ",")
        let mut has_int = false
        let mut has_str = false
        let mut has_bool = false
        let mut has_float = false
        for item in items {
            let v = trim(item)
            if v == "" { continue }
            if v == "true" || v == "false" {
                has_bool = true
            } else if starts_with(v, "\"") || starts_with(v, "'") {
                has_str = true
            } else if contains(v, ".") && !contains(v, "(") {
                has_float = true
            } else if len(v) > 0 {
                let ch = v.substring(0, 1)
                let digits = "0123456789"
                if contains(digits, ch) {
                    has_int = true
                } else if ch == "-" && len(v) > 1 {
                    has_int = true
                }
            }
        }
        let mut type_count = 0
        if has_int { type_count = type_count + 1 }
        if has_str { type_count = type_count + 1 }
        if has_bool { type_count = type_count + 1 }
        if has_float { type_count = type_count + 1 }
        if type_count >= 2 {
            let mut types = []
            if has_int { types.push("Int") }
            if has_float { types.push("Float") }
            if has_str { types.push("String") }
            if has_bool { types.push("Bool") }
            results.push(LintMsg {
                level: "warn",
                line: i,
                rule: "type",
                msg: "mixed types in array literal (" + join(types, ", ") + "); arrays should be uniform"
            })
        }
    }
    return results
}

// ── A4: array param mutation visibility ─────────────────
// HX-safety A4 (BG-HX1, 2026-05-02): hexa array values are passed by
// reference (shared), so a function that mutates a parameter array
// (`xs.push(...)`, `xs[i] = ...`, `xs = xs + ...`) silently propagates
// the mutation back to the caller. This causes "mutation leak between
// sub-tests" in selftest harnesses (the canonical case is hxc_v3
// selftest where a fixture array carries state across test cases).
//
// This lint flags the static signature `fn name(...arr_param...)` followed
// by mutation of that param, recommending one of:
//   (a) accept and return a new array (functional style)
//   (b) document the in-place mutation contract via `// @mut <param>`
//   (c) clone at top-of-fn (e.g. `let mut local = arr_param + []`)
//
// False-negative tolerated: param-name shadowing inside nested fns is not
// tracked. False-positive minimized: the rule fires only when the param
// name is referenced LHS of `=`, `[i] =`, or `.push(` / `.pop(` / `.insert(`.
fn check_array_param_mutation(lines) {
    let mut results = []
    let mut i = 0
    let mut in_fn = false
    let mut fn_brace_depth = 0
    let mut params = []

    for line in lines {
        i = i + 1
        let t = trim(line)
        if starts_with(t, "//") {
            continue
        }

        // Detect fn signature start
        if !in_fn && (starts_with(t, "fn ") || starts_with(t, "pub fn ") || starts_with(t, "async fn ") || starts_with(t, "pure fn ")) {
            let lp = t.index_of("(")
            let rp = t.index_of(")")
            if lp >= 0 && rp > lp {
                let plist = t.substring(lp + 1, rp)
                let pparts = split(plist, ",")
                params = []
                for pp in pparts {
                    let pname = trim(pp)
                    let cidx = pname.index_of(":")
                    if cidx > 0 { pname = trim(pname.substring(0, cidx)) }
                    if starts_with(pname, "mut ") { pname = trim(pname.substring(4, len(pname))) }
                    if len(pname) > 0 && pname != "self" {
                        params.push(pname)
                    }
                }
                if contains(t, "{") {
                    in_fn = true
                    fn_brace_depth = 1
                }
            }
            continue
        }

        if !in_fn { continue }

        // Track brace depth within fn body
        let chars = t.chars()
        for ch in chars {
            if ch == '{' { fn_brace_depth = fn_brace_depth + 1 }
            if ch == '}' { fn_brace_depth = fn_brace_depth - 1 }
        }
        if fn_brace_depth <= 0 {
            in_fn = false
            params = []
            continue
        }

        // Check each param for mutation patterns
        for p in params {
            // pattern a: p.push( / .pop( / .insert( / .remove( / .clear(
            let mut hit = false
            let mut_methods = [".push(", ".pop(", ".insert(", ".remove(", ".clear(", ".append(", ".extend("]
            for mm in mut_methods {
                if contains(t, p + mm) { hit = true }
            }
            // pattern b: p[i] = ... or p[...] = ...
            if !hit && contains(t, p + "[") {
                let bidx = t.index_of(p + "[")
                if bidx >= 0 {
                    let rest = t.substring(bidx, len(t))
                    let rb = rest.index_of("]")
                    if rb > 0 {
                        let after_b = rest.substring(rb + 1, len(rest))
                        if starts_with(trim(after_b), "=") && !starts_with(trim(after_b), "==") {
                            hit = true
                        }
                    }
                }
            }
            // pattern c: p = p + ... (rebinding param)
            if !hit && starts_with(t, p + " = ") {
                hit = true
            }
            if hit {
                results.push(LintMsg {
                    level: "warn",
                    line: i,
                    rule: "A4",
                    msg: "param '" + p + "' mutated in fn body — array params are by-reference; mutation leaks to caller. Clone (`let mut local = " + p + " + []`) or document via `// @mut " + p + "`"
                })
            }
        }
    }
    return results
}

// ── A8: env() personal-path-leak (raw 15) ───────────────
// HX-safety A8 (BG-HX1, 2026-05-02): top-of-file `env(KEY)` followed by
// concatenation that bakes a personal absolute path (e.g.
// `env("HOME") + "/Dev/hexa-lang/..."` or `env_or("X", "/Users/<user>/...")`),
// or 2-arg `env("KEY", "/Users/...")` form, leaks per-developer locations
// into committed source. Lint rule A8 flags:
//
//   1. `env(...)` default 2nd arg starting with `/Users/`, `/home/`, `/root/`
//   2. `env_or(KEY, "/<absolute personal path>")` (common helper alias)
//   3. top-of-file (line ≤ 50) string concat of `env(` result with
//      a path containing `/Dev/`, `/core/`, `/Users/`, `/home/` literal.
//
// Recommendation: load defaults from a config file under repo root
// (e.g. `config/dev_paths.json`) or require the env var unconditionally
// with a clear error.
fn check_env_personal_path_default(lines) {
    let mut results = []
    let mut i = 0
    let personal_prefixes = ["\"/Users/", "\"/home/", "\"/root/", "\"/srv/"]
    let personal_substrings = ["/Dev/", "/core/", "/workspace/", "/Users/", "/home/"]
    for line in lines {
        i = i + 1
        let t = trim(line)
        if starts_with(t, "//") { continue }
        if contains(t, "// a8_lint: allow") { continue }

        // Pattern 1+2: env(KEY, "/abs/personal/...") or env_or(KEY, "/abs/...")
        let mut hit_default = false
        let mut prefix_hit = ""
        let calls = ["env_or(", "env("]
        for call in calls {
            if !contains(t, call) { continue }
            let cidx = t.index_of(call)
            if cidx < 0 { continue }
            let after = t.substring(cidx + len(call), len(t))
            // find first `,` inside the call (rough — single-arg env() will not have one)
            let comma_idx = after.index_of(",")
            if comma_idx < 0 { continue }
            let arg2 = trim(after.substring(comma_idx + 1, len(after)))
            for pp in personal_prefixes {
                if starts_with(arg2, pp) {
                    hit_default = true
                    prefix_hit = pp
                }
            }
        }
        if hit_default {
            results.push(LintMsg {
                level: "warn",
                line: i,
                rule: "A8",
                msg: "env() lazy default with personal absolute path (" + prefix_hit + "...) — extract to config/dev_paths.json or require env var explicitly"
            })
            continue
        }

        // Pattern 3: top-of-file (≤ line 50) `env(` concat with personal substring
        if i > 50 { continue }
        if !contains(t, "env(") { continue }
        if !contains(t, "+") { continue }
        for ss in personal_substrings {
            if contains(t, ss) {
                results.push(LintMsg {
                    level: "warn",
                    line: i,
                    rule: "A8",
                    msg: "top-of-file env() concat with personal path fragment '" + ss + "' — leaks per-developer location into committed source (raw 15)"
                })
                break
            }
        }
    }
    return results
}

// ── 미사용 import 감지 ──────────────────────────────────
fn check_unused_imports(lines, source) {
    let mut results = []
    let mut i = 0
    for line in lines {
        i = i + 1
        let t = trim(line)
        if !starts_with(t, "use ") && !starts_with(t, "import ") { continue }
        let parts = split(t, "::")
        let mut name = ""
        if len(parts) > 1 {
            name = trim(parts[len(parts) - 1])
        } else {
            let words = split(t, " ")
            if len(words) >= 2 {
                name = trim(words[len(words) - 1])
            }
        }
        if name == "" { continue }
        let mut used = false
        let mut j = 0
        for check_line in lines {
            j = j + 1
            if j == i { continue }
            let ct = trim(check_line)
            if starts_with(ct, "//") { continue }
            if starts_with(ct, "use ") || starts_with(ct, "import ") { continue }
            if contains(ct, name) {
                used = true
                break
            }
        }
        if !used {
            results.push(LintMsg {
                level: "warn",
                line: i,
                rule: "import",
                msg: "unused import: `" + name + "`"
            })
        }
    }
    return results
}

// ── 전체 린트 실행 ──────────────────────────────────────
fn lint_file(path) {
    let mut source = ""
    try {
        source = to_string(read_file(path))
    } catch e {
        eprintln("error: cannot read " + path + " (" + to_string(e) + ")")
        return []
    }
    let lines = split(source, "\n")

    let mut all = []
    let r1 = check_semicolons(lines)
    for m in r1 { all.push(m) }
    let r2 = check_exec_no_try(lines)
    for m in r2 { all.push(m) }
    let r2b = check_exec_eq_int(lines)
    for m in r2b { all.push(m) }
    let r3 = check_relative_paths(lines)
    for m in r3 { all.push(m) }
    let r4 = check_struct_in_if(lines)
    for m in r4 { all.push(m) }
    let r5 = check_method_names(lines)
    for m in r5 { all.push(m) }
    let r6 = check_mixed_arrays(lines)
    for m in r6 { all.push(m) }
    let r7 = check_unused_imports(lines, source)
    for m in r7 { all.push(m) }
    // A4: array param mutation visibility (BG-HX1)
    let r_a4 = check_array_param_mutation(lines)
    for m in r_a4 { all.push(m) }
    // A8: env() personal-path-leak (BG-HX1, raw 15)
    let r8 = check_env_personal_path_default(lines)
    for m in r8 { all.push(m) }

    return all
}

// ── 자동 수정 (P1: 세미콜론 제거) ──────────────────────
fn autofix_file(path) {
    let mut source = ""
    try {
        source = to_string(read_file(path))
    } catch e {
        eprintln("error: " + to_string(e))
        return
    }
    let lines = split(source, "\n")
    let mut fixed = []
    let mut fix_count = 0
    for line in lines {
        let t = trim(line)
        if ends_with(t, ";") && !starts_with(t, "//") && !contains(t, "extern ") && !contains(t, "for ") {
            let new_line = line.substring(0, len(line) - 1)
            fixed.push(new_line)
            fix_count = fix_count + 1
        } else {
            fixed.push(line)
        }
    }
    if fix_count > 0 {
        safe_write_file(path, join(fixed, "\n"))
        println(path + " -- " + to_string(fix_count) + " semicolons removed")
    } else {
        println(path + " -- no autofix needed")
    }
}

// ── CLI ─────────────────────────────────────────────────
let mode = cli_args[0]

if mode == "--dir" {
    if len(cli_args) < 2 {
        eprintln("usage: hexa linter.hexa --dir <dir>")
        exit(1)
    }
    let dir = cli_args[1]
    let mut files = []
    let _find_result = ""
    try {
        _find_result = to_string(exec("find " + dir + " -name '*.hexa' -type f"))
    } catch e {
        eprintln("error: " + to_string(e))
        exit(1)
    }
    let _found = split(_find_result, "\n")
    for f in _found {
        let ft = trim(f)
        if ft != "" { files.push(ft) }
    }
    let mut total_warns = 0
    let mut file_warns = 0
    for file in files {
        let msgs = lint_file(file)
        if len(msgs) > 0 {
            file_warns = file_warns + 1
            for m in msgs {
                println(file + ": " + fmt_msg(m))
                total_warns = total_warns + 1
            }
        }
    }
    println("\n" + to_string(total_warns) + " warning(s) in " + to_string(file_warns) + " file(s)")
    exit(0)
}

if mode == "--fix" {
    if len(cli_args) < 2 {
        eprintln("usage: hexa linter.hexa --fix <file.hexa>")
        exit(1)
    }
    autofix_file(cli_args[1])
    exit(0)
}

// 단일 파일 린트
let file = mode
let msgs = lint_file(file)
if len(msgs) == 0 {
    println(file + " -- clean")
} else {
    for m in msgs {
        println(file + ": " + fmt_msg(m))
    }
    let warn_count = len(msgs)
    println("\n" + to_string(warn_count) + " warning(s)")
}
