// quick smoke test for mat_add_inplace + matmul_into
let A = tensor_zeros(4)
let B = tensor_zeros(4)
let C = mat_add_inplace(A, B)
println("mat_add_inplace OK, len=" + str(len(C)))

let X = tensor_zeros(2 * 2)
let Y = tensor_zeros(2 * 2)
let out = tensor_zeros(2 * 2)
let Z = matmul_into(X, Y, 2, 2, 2, out)
println("matmul_into OK, len=" + str(len(Z)))
