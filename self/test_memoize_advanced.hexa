// ═══════════════════════════════════════════════════════════
//  test_memoize_advanced.hexa — @memoize Composite Tests
//  Tests: multi-arg, string args, mutual memo, bool, chained
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA @memoize Advanced Tests")
println("═══════════════════════════════════════════════════════")

// ── 1. Memoized fibonacci ────────────────────────────────
// decreases n — structural
@memoize fn mfib(n: int) -> int {
    if n < 2 { return n }
    return mfib(n - 1) + mfib(n - 2)
}
check("mfib(0)", mfib(0), 0)
check("mfib(1)", mfib(1), 1)
check("mfib(2)", mfib(2), 1)
check("mfib(10)", mfib(10), 55)
check("mfib(20)", mfib(20), 6765)
check("mfib(30)", mfib(30), 832040)

// ── 2. Memoized factorial ────────────────────────────────
// decreases n — structural
@memoize fn mfact(n: int) -> int {
    if n <= 1 { return 1 }
    return n * mfact(n - 1)
}
check("mfact(0)", mfact(0), 1)
check("mfact(1)", mfact(1), 1)
check("mfact(5)", mfact(5), 120)
check("mfact(10)", mfact(10), 3628800)
check("mfact(12)", mfact(12), 479001600)

// ── 3. Memoized two-arg (binomial) ───────────────────────
// decreases n — structural
@memoize fn mbinom(n: int, k: int) -> int {
    if k == 0 { return 1 }
    if k == n { return 1 }
    if k < 0 { return 0 }
    if k > n { return 0 }
    return mbinom(n - 1, k - 1) + mbinom(n - 1, k)
}
check("C(0,0)", mbinom(0, 0), 1)
check("C(5,0)", mbinom(5, 0), 1)
check("C(5,5)", mbinom(5, 5), 1)
check("C(5,2)", mbinom(5, 2), 10)
check("C(10,3)", mbinom(10, 3), 120)
check("C(10,5)", mbinom(10, 5), 252)
check("C(15,7)", mbinom(15, 7), 6435)
check("C(20,10)", mbinom(20, 10), 184756)

// ── 4. Memoized Ackermann (small) ─────────────────────────
// decreases m — structural
@memoize fn mack(m: int, n: int) -> int {
    if m == 0 { return n + 1 }
    if n == 0 { return mack(m - 1, 1) }
    return mack(m - 1, mack(m, n - 1))
}
check("ack(0,0)", mack(0, 0), 1)
check("ack(1,1)", mack(1, 1), 3)
check("ack(2,2)", mack(2, 2), 7)
check("ack(3,3)", mack(3, 3), 61)

// ── 5. Memoized with string arg ──────────────────────────
@memoize fn mstrlen(s: string) -> int {
    return len(s)
}
check("mstrlen empty", mstrlen(""), 0)
check("mstrlen a", mstrlen("a"), 1)
check("mstrlen hello", mstrlen("hello"), 5)
check("mstrlen repeat", mstrlen("hello"), 5)
check("mstrlen longer", mstrlen("abcdefghij"), 10)

// ── 6. Memoized with bool arg ────────────────────────────
@memoize fn mneg(b: bool) -> bool {
    if b { return false }
    return true
}
check("mneg true", mneg(true), false)
check("mneg false", mneg(false), true)
check("mneg true 2", mneg(true), false)

// ── 7. Memoized Collatz length ───────────────────────────
// decreases n — structural
@memoize fn mcoll(n: int) -> int {
    if n <= 1 { return 0 }
    if n % 2 == 0 { return 1 + mcoll(n / 2) }
    return 1 + mcoll(3 * n + 1)
}
check("collatz(1)", mcoll(1), 0)
check("collatz(2)", mcoll(2), 1)
check("collatz(3)", mcoll(3), 7)
check("collatz(27)", mcoll(27), 111)

// ── 8. Memoized GCD ──────────────────────────────────────
// decreases a — structural
@memoize fn mgcd(a: int, b: int) -> int {
    if b == 0 { return a }
    return mgcd(b, a % b)
}
check("gcd(12,8)", mgcd(12, 8), 4)
check("gcd(100,75)", mgcd(100, 75), 25)
check("gcd(17,13)", mgcd(17, 13), 1)
check("gcd(1024,256)", mgcd(1024, 256), 256)
check("gcd(0,5)", mgcd(0, 5), 5)

// ── 9. Mutual-ish memoized ───────────────────────────────
@memoize fn meven(n: int) -> bool {
    if n == 0 { return true }
    return modd(n - 1)
}
@memoize fn modd(n: int) -> bool {
    if n == 0 { return false }
    return meven(n - 1)
}
check("even(0)", meven(0), true)
check("even(10)", meven(10), true)
check("odd(7)", modd(7), true)
check("odd(0)", modd(0), false)
check("even(25)", meven(25), false)

println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")
