fn apply(x, f) {
    println("  inside apply, f = " + to_string(f))
    return f(x)
}

fn double(x) { return x * 2 }
fn add_ten(x) { return x + 10 }

println("=== Call 1: apply(4, double) ===")
let r1 = apply(4, double)
println("r1 = " + to_string(r1))

println("")
println("=== Call 2: apply(6, add_ten) ===")
let r2 = apply(6, add_ten)
println("r2 = " + to_string(r2))
