// test_dispatch_pure.hexa — Tests for self/runtime/dispatch_pure.hexa
// Covers: array_truncate_pure, index_get_pure, iter_get_pure,
//         index_set_pure, is_type_pure.
//
// -- inlined from self/runtime/dispatch_pure.hexa --
// (codegen import not wired for test files; same pattern as
//  test_char_pure.hexa / test_string_pure.hexa)

fn array_truncate_pure(arr, n) {
    if type_of(arr) != "array" { return arr }
    let arr_len = len(arr)
    let mut new_len = n
    if type_of(new_len) != "int" { return arr }
    if new_len < 0 { new_len = 0 }
    if new_len > arr_len { new_len = arr_len }
    let mut out = []
    let mut i = 0
    while i < new_len {
        out.push(arr[i])
        i = i + 1
    }
    out
}

fn index_get_pure(container, key) {
    let ct = type_of(container)
    let kt = type_of(key)
    if ct == "map" {
        if kt != "string" { return nil }
        if has_key(container, key) == false { return nil }
        return container[key]
    }
    if ct == "array" {
        if kt != "int" { return nil }
        if key < 0 { return nil }
        if key >= len(container) { return nil }
        return container[key]
    }
    nil
}

fn iter_get_pure(v, idx) {
    let t = type_of(v)
    if type_of(idx) != "int" { return nil }
    if idx < 0 { return nil }
    if t == "map" {
        let ks = keys(v)
        if idx >= len(ks) { return nil }
        return ks[idx]
    }
    if t == "array" {
        if idx >= len(v) { return nil }
        return v[idx]
    }
    nil
}

fn index_set_pure(container, key, val) {
    let ct = type_of(container)
    let kt = type_of(key)
    if ct == "map" {
        if kt != "string" { return container }
        let mut out = #{}
        let ks = keys(container)
        let n = len(ks)
        let mut i = 0
        while i < n {
            let k = ks[i]
            if k == key {
                out[k] = val
            } else {
                out[k] = container[k]
            }
            i = i + 1
        }
        if has_key(out, key) == false {
            out[key] = val
        }
        return out
    }
    if ct == "array" {
        if kt != "int" { return container }
        if key < 0 { return container }
        let arr_len = len(container)
        if key >= arr_len { return container }
        let mut out = []
        let mut i = 0
        while i < arr_len {
            if i == key {
                out.push(val)
            } else {
                out.push(container[i])
            }
            i = i + 1
        }
        return out
    }
    container
}

fn is_type_pure(v, type_name) {
    if type_of(type_name) != "string" { return false }
    let t = type_of(v)
    if t == "valstruct" {
        return type_name == "Val"
    }
    if t == "map" {
        if has_key(v, "__type__") == false { return false }
        let stored = v["__type__"]
        if type_of(stored) != "string" { return false }
        return stored == type_name
    }
    t == type_name
}

// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  Pure-Hexa Dispatch / Container Ops Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── array_truncate_pure ───────────────────────────────────────────
println("--- array_truncate_pure ---")
let a5 = [10, 20, 30, 40, 50]
check("trunc mid",     array_truncate_pure(a5, 3),     [10, 20, 30])
check("trunc to 0",    array_truncate_pure(a5, 0),     [])
check("trunc empty",   array_truncate_pure([], 5),     [])
check("trunc over",    array_truncate_pure([1, 2], 9), [1, 2])    // clamp
check("trunc neg",     array_truncate_pure([1, 2, 3], -4), [])    // -> 0
check("trunc non-arr", array_truncate_pure("nope", 2), "nope")    // identity

// ── index_get_pure ────────────────────────────────────────────────
println("")
println("--- index_get_pure ---")
let m = #{ "a": 1, "b": 2, "c": 3 }
let av = [100, 200, 300]
check("map get",        index_get_pure(m, "b"),        2)
check("map miss",       index_get_pure(m, "zzz"),      nil)
check("map int key",    index_get_pure(m, 0),          nil)
check("arr get",        index_get_pure(av, 1),         200)
check("arr oob hi",     index_get_pure(av, 9),         nil)
check("arr neg",        index_get_pure(av, -1),        nil)

// ── iter_get_pure ─────────────────────────────────────────────────
println("")
println("--- iter_get_pure ---")
let imap = #{ "x": 10, "y": 20 }
let iarr = ["p", "q", "r"]
check("iter arr 0",     iter_get_pure(iarr, 0),       "p")
check("iter arr last",  iter_get_pure(iarr, 2),       "r")
check("iter arr oob",   iter_get_pure(iarr, 5),       nil)
check("iter map 0",     iter_get_pure(imap, 0),       "x")
check("iter map 1",     iter_get_pure(imap, 1),       "y")
check("iter neg",       iter_get_pure(iarr, -1),      nil)

// ── index_set_pure ────────────────────────────────────────────────
println("")
println("--- index_set_pure ---")
let sa = [1, 2, 3]
check("arr set 0",       index_set_pure(sa, 0, 99),        [99, 2, 3])
check("arr set mid",     index_set_pure(sa, 1, 88),        [1, 88, 3])
check("arr set oob",     index_set_pure(sa, 5, 77),        [1, 2, 3])  // no-op
let sm = #{ "a": 1 }
check("map set new",     index_set_pure(sm, "b", 2),       #{ "a": 1, "b": 2 })
check("map set replace", index_set_pure(#{"k": 1}, "k", 9), #{ "k": 9 })
check("set on int",      index_set_pure(42, 0, 1),         42)         // identity

// ── is_type_pure ──────────────────────────────────────────────────
println("")
println("--- is_type_pure ---")
check("int is int",     is_type_pure(42, "int"),        true)
check("str is string",  is_type_pure("hi", "string"),   true)
check("arr is array",   is_type_pure([1, 2], "array"),  true)
check("map tagged",     is_type_pure(#{ "__type__": "Point", "x": 1 }, "Point"), true)
check("map mistagged",  is_type_pure(#{ "__type__": "Point" }, "Line"), false)
check("int vs string",  is_type_pure(42, "string"),     false)

println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    println("FAIL")
    exit(1)
}
println("ALL PASS")
