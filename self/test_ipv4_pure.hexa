// self/test_ipv4_pure.hexa -- Tests for self/runtime/ipv4_pure.hexa
//
// Reference behavior: strict canonical IPv4 dotted decimal.
//   four octets [0..255], no leading zeros, no whitespace, no shorthand.

// ── inlined from self/runtime/ipv4_pure.hexa ──────────────────────

fn _is_digit_byte(b) {
    b >= 48 && b <= 57
}

fn _parse_octet(s, i) {
    let n = len(s)
    if i >= n { return [0 - 1, i] }
    let mut j = i
    let mut digits = 0
    let mut val = 0
    while j < n && digits < 4 {
        let b = ord(s.substring(j, j + 1))
        if _is_digit_byte(b) == false { break }
        val = val * 10 + (b - 48)
        digits = digits + 1
        j = j + 1
    }
    if digits == 0 { return [0 - 1, i] }
    if digits > 3  { return [0 - 1, i] }
    if digits > 1 {
        let first = ord(s.substring(i, i + 1))
        if first == 48 { return [0 - 1, i] }
    }
    if val > 255 { return [0 - 1, i] }
    [val, j]
}

fn ipv4_parse_pure(s) {
    if type_of(s) != "string" { return nil }
    let n = len(s)
    if n < 7 { return nil }
    if n > 15 { return nil }

    let mut octets = []
    let mut i = 0
    let mut octet_count = 0
    while octet_count < 4 {
        let r = _parse_octet(s, i)
        let v = r[0]
        let new_i = r[1]
        if v < 0 { return nil }
        octets = octets.push(v)
        i = new_i
        octet_count = octet_count + 1
        if octet_count < 4 {
            if i >= n { return nil }
            if s.substring(i, i + 1) != "." { return nil }
            i = i + 1
        }
    }
    if i != n { return nil }
    octets
}

fn ipv4_is_valid_pure(s) {
    let r = ipv4_parse_pure(s)
    if type_of(r) == "void" { return false }
    true
}

fn ipv4_to_int_pure(s) {
    let r = ipv4_parse_pure(s)
    if type_of(r) == "void" { return 0 - 1 }
    r[0] * 16777216 + r[1] * 65536 + r[2] * 256 + r[3]
}

fn ipv4_format_pure(arr) {
    if type_of(arr) != "array" { return "" }
    if len(arr) != 4 { return "" }
    let mut parts = []
    let mut i = 0
    while i < 4 {
        let v = arr[i]
        if type_of(v) != "int" { return "" }
        if v < 0 || v > 255 { return "" }
        parts = parts.push(to_string(v))
        i = i + 1
    }
    parts[0] + "." + parts[1] + "." + parts[2] + "." + parts[3]
}

fn ipv4_from_int_pure(n) {
    if type_of(n) != "int" { return "" }
    if n < 0 { return "" }
    if n > 4294967295 { return "" }
    let a = n / 16777216
    let r1 = n - a * 16777216
    let b = r1 / 65536
    let r2 = r1 - b * 65536
    let c = r2 / 256
    let d = r2 - c * 256
    to_string(a) + "." + to_string(b) + "." + to_string(c) + "." + to_string(d)
}

// ── end inlined ───────────────────────────────────────────────────

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  ipv4_pure.hexa — test runner")
println("═══════════════════════════════════════════════════════")

// ── ipv4_is_valid_pure — happy path ─────────────────────────────
println("")
println("--- ipv4_is_valid_pure (valid) ---")
check("'0.0.0.0'",         ipv4_is_valid_pure("0.0.0.0"),         true)
check("'1.2.3.4'",         ipv4_is_valid_pure("1.2.3.4"),         true)
check("'10.0.0.1'",        ipv4_is_valid_pure("10.0.0.1"),        true)
check("'127.0.0.1'",       ipv4_is_valid_pure("127.0.0.1"),       true)
check("'192.168.1.1'",     ipv4_is_valid_pure("192.168.1.1"),     true)
check("'255.255.255.255'", ipv4_is_valid_pure("255.255.255.255"), true)
check("'8.8.8.8'",         ipv4_is_valid_pure("8.8.8.8"),         true)

// ── ipv4_is_valid_pure — invalid forms ──────────────────────────
println("")
println("--- ipv4_is_valid_pure (invalid) ---")
check("empty",              ipv4_is_valid_pure(""),              false)
check("3 octets",           ipv4_is_valid_pure("1.2.3"),         false)
check("5 octets",           ipv4_is_valid_pure("1.2.3.4.5"),     false)
check("octet 256",          ipv4_is_valid_pure("1.2.3.256"),     false)
check("octet 999",          ipv4_is_valid_pure("999.0.0.0"),     false)
check("leading zero '01'",  ipv4_is_valid_pure("01.2.3.4"),      false)
check("leading zero '001'", ipv4_is_valid_pure("0.0.0.001"),     false)
check("trailing dot",       ipv4_is_valid_pure("1.2.3.4."),      false)
check("leading dot",        ipv4_is_valid_pure(".1.2.3.4"),      false)
check("double dot",         ipv4_is_valid_pure("1..2.3.4"),      false)
check("alpha char",         ipv4_is_valid_pure("1.2.a.4"),       false)
check("space inside",       ipv4_is_valid_pure("1.2 .3.4"),      false)
check("ipv6-ish",           ipv4_is_valid_pure("::1"),           false)
check("non-string nil",     ipv4_is_valid_pure(nil),             false)
check("non-string int",     ipv4_is_valid_pure(42),              false)
check("too long padded",    ipv4_is_valid_pure("123.456.789.012"), false)

// ── ipv4_parse_pure — array equality via to_string ──────────────
println("")
println("--- ipv4_parse_pure (octet extraction) ---")
let arr1 = ipv4_parse_pure("1.2.3.4")
check("'1.2.3.4'[0]==1",      arr1[0], 1)
check("'1.2.3.4'[1]==2",      arr1[1], 2)
check("'1.2.3.4'[2]==3",      arr1[2], 3)
check("'1.2.3.4'[3]==4",      arr1[3], 4)
let arr2 = ipv4_parse_pure("255.255.255.255")
check("max[0]==255",          arr2[0], 255)
check("max[3]==255",          arr2[3], 255)
let arr3 = ipv4_parse_pure("0.0.0.0")
check("zero[0]==0",           arr3[0], 0)
check("zero[3]==0",           arr3[3], 0)

// ── ipv4_to_int_pure ────────────────────────────────────────────
println("")
println("--- ipv4_to_int_pure ---")
check("'0.0.0.0' = 0",         ipv4_to_int_pure("0.0.0.0"),         0)
check("'0.0.0.1' = 1",         ipv4_to_int_pure("0.0.0.1"),         1)
check("'0.0.1.0' = 256",       ipv4_to_int_pure("0.0.1.0"),         256)
check("'0.1.0.0' = 65536",     ipv4_to_int_pure("0.1.0.0"),         65536)
check("'1.0.0.0' = 16777216",  ipv4_to_int_pure("1.0.0.0"),         16777216)
check("'127.0.0.1'",           ipv4_to_int_pure("127.0.0.1"),       2130706433)
check("'255.255.255.255'",     ipv4_to_int_pure("255.255.255.255"), 4294967295)
check("invalid → -1",          ipv4_to_int_pure("bad"),             0 - 1)

// ── ipv4_format_pure ────────────────────────────────────────────
println("")
println("--- ipv4_format_pure ---")
check("[0,0,0,0]",        ipv4_format_pure([0, 0, 0, 0]),         "0.0.0.0")
check("[1,2,3,4]",        ipv4_format_pure([1, 2, 3, 4]),         "1.2.3.4")
check("[127,0,0,1]",      ipv4_format_pure([127, 0, 0, 1]),       "127.0.0.1")
check("[255,255,255,255]", ipv4_format_pure([255, 255, 255, 255]), "255.255.255.255")
check("len 3 → ''",       ipv4_format_pure([1, 2, 3]),            "")
check("octet 256 → ''",   ipv4_format_pure([1, 2, 3, 256]),       "")
check("non-array → ''",   ipv4_format_pure("1.2.3.4"),            "")
check("nil → ''",         ipv4_format_pure(nil),                  "")

// ── ipv4_from_int_pure ──────────────────────────────────────────
println("")
println("--- ipv4_from_int_pure ---")
check("0 = '0.0.0.0'",         ipv4_from_int_pure(0),          "0.0.0.0")
check("1 = '0.0.0.1'",         ipv4_from_int_pure(1),          "0.0.0.1")
check("256 = '0.0.1.0'",       ipv4_from_int_pure(256),        "0.0.1.0")
check("16777216 = '1.0.0.0'",  ipv4_from_int_pure(16777216),   "1.0.0.0")
check("2130706433 = '127.0.0.1'", ipv4_from_int_pure(2130706433), "127.0.0.1")
check("4294967295 = max",      ipv4_from_int_pure(4294967295), "255.255.255.255")
check("negative → ''",         ipv4_from_int_pure(0 - 1),      "")
check("over-max → ''",         ipv4_from_int_pure(4294967296), "")
check("non-int → ''",          ipv4_from_int_pure("x"),        "")

// ── round-trip ──────────────────────────────────────────────────
println("")
println("--- round-trip parse/format ---")
check("rt 0.0.0.0",         ipv4_format_pure(ipv4_parse_pure("0.0.0.0")),         "0.0.0.0")
check("rt 1.2.3.4",         ipv4_format_pure(ipv4_parse_pure("1.2.3.4")),         "1.2.3.4")
check("rt 255.255.255.255", ipv4_format_pure(ipv4_parse_pure("255.255.255.255")), "255.255.255.255")
check("rt int 12345",       ipv4_to_int_pure(ipv4_from_int_pure(12345)),          12345)
check("rt int 0",           ipv4_to_int_pure(ipv4_from_int_pure(0)),              0)
check("rt int 4294967295",  ipv4_to_int_pure(ipv4_from_int_pure(4294967295)),     4294967295)

// ── Summary ─────────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    println("FAIL")
    exit(1)
}
println("ALL PASS")
