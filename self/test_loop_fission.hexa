//  test_loop_fission.hexa — ROI #54 Loop Fission Tests
//  Verifies that splitting a multi-operation loop into
//  separate single-operation loops preserves semantics.
//
//  Tests the fission_* helpers and anp_detect_fission /
//  anp_apply_fission / anp_fission_pass from ai_native_pass.hexa.
// ═══════════════════════════════════════════════════════════

// -- inlined from self/ml/loop_fission.hexa --
// codegen import not wired for test files

// self/ml/loop_fission.hexa — ROI #54: Loop Fission (루프 피셔닝)
// Splits loops with multiple independent operations into
// separate single-operation loops. Improves cache utilization
// and enables vectorization.
//
// Example:
//   for i in 0..n { a[i] = b[i] + 1; c[i] = d[i] * 2 }
// becomes:
//   for i in 0..n { a[i] = b[i] + 1 }
//   for i in 0..n { c[i] = d[i] * 2 }

// Collect all identifiers written (assigned/mutated) in a statement.
fn fission_collect_writes(stmt) {
    if type_of(stmt) == "string" { return [] }
    let k = stmt.kind
    if k == "AssignStmt" {
        let mut out = []
        if stmt.name != "" {
            out = out.push(stmt.name)
        }
        return out
    }
    if k == "LetStmt" || k == "LetMutStmt" {
        let mut out = []
        if stmt.name != "" {
            out = out.push(stmt.name)
        }
        return out
    }
    return []
}

// Collect all identifiers read in an expression (recursive).
fn fission_collect_reads_expr(expr) {
    if type_of(expr) == "string" { return [] }
    if type_of(expr) != "string" && type_of(expr) != "array" {
        let k = expr.kind
        if k == "Ident" {
            let mut out = []
            out = out.push(expr.name)
            return out
        }
        if k == "BinaryExpr" || k == "BinOp" {
            let l = fission_collect_reads_expr(expr.left)
            let r = fission_collect_reads_expr(expr.right)
            let mut out = l
            let mut ri = 0
            while ri < len(r) {
                out = out.push(r[ri])
                ri = ri + 1
            }
            return out
        }
        if k == "UnaryExpr" {
            return fission_collect_reads_expr(expr.left)
        }
        if k == "Call" {
            let mut out = []
            if type_of(expr.args) == "array" {
                let mut ai = 0
                while ai < len(expr.args) {
                    let sub = fission_collect_reads_expr(expr.args[ai])
                    let mut si = 0
                    while si < len(sub) {
                        out = out.push(sub[si])
                        si = si + 1
                    }
                    ai = ai + 1
                }
            }
            return out
        }
        if k == "Index" {
            let l2 = fission_collect_reads_expr(expr.left)
            let r2 = fission_collect_reads_expr(expr.right)
            let mut out = l2
            let mut ri2 = 0
            while ri2 < len(r2) {
                out = out.push(r2[ri2])
                ri2 = ri2 + 1
            }
            return out
        }
        if k == "MethodCall" {
            let base = fission_collect_reads_expr(expr.left)
            let mut out = base
            if type_of(expr.args) == "array" {
                let mut ai2 = 0
                while ai2 < len(expr.args) {
                    let sub2 = fission_collect_reads_expr(expr.args[ai2])
                    let mut si2 = 0
                    while si2 < len(sub2) {
                        out = out.push(sub2[si2])
                        si2 = si2 + 1
                    }
                    ai2 = ai2 + 1
                }
            }
            return out
        }
        if k == "IntLit" || k == "FloatLit" || k == "BoolLit" || k == "StringLit" {
            return []
        }
        if k == "Field" {
            return fission_collect_reads_expr(expr.left)
        }
        let mut out = []
        if type_of(expr.left) != "string" || expr.left != "" {
            let sl = fission_collect_reads_expr(expr.left)
            let mut sli = 0
            while sli < len(sl) {
                out = out.push(sl[sli])
                sli = sli + 1
            }
        }
        if type_of(expr.right) != "string" || expr.right != "" {
            let sr = fission_collect_reads_expr(expr.right)
            let mut sri = 0
            while sri < len(sr) {
                out = out.push(sr[sri])
                sri = sri + 1
            }
        }
        return out
    }
    return []
}

// Collect all identifiers read in a statement (RHS / condition / index).
fn fission_collect_reads(stmt) {
    if type_of(stmt) == "string" { return [] }
    let k = stmt.kind
    if k == "AssignStmt" {
        let mut out = fission_collect_reads_expr(stmt.right)
        if type_of(stmt.left) != "string" && type_of(stmt.left) != "array" {
            if stmt.left.kind == "Index" {
                let idx_reads = fission_collect_reads_expr(stmt.left.right)
                let mut iri = 0
                while iri < len(idx_reads) {
                    out = out.push(idx_reads[iri])
                    iri = iri + 1
                }
                let base_reads = fission_collect_reads_expr(stmt.left.left)
                let mut bri = 0
                while bri < len(base_reads) {
                    out = out.push(base_reads[bri])
                    bri = bri + 1
                }
            }
        }
        return out
    }
    if k == "LetStmt" || k == "LetMutStmt" {
        if type_of(stmt.left) != "string" {
            return fission_collect_reads_expr(stmt.left)
        }
        return []
    }
    if k == "ExprStmt" {
        return fission_collect_reads_expr(stmt.left)
    }
    return []
}

// Check if name exists in an array of strings
fn fission_name_in(name, arr) {
    let mut i = 0
    while i < len(arr) {
        if arr[i] == name { return true }
        i = i + 1
    }
    return false
}

// Check if two statement groups are independent (no data dependency).
// Independent iff:
//   W_A ∩ R_B = empty  AND  W_B ∩ R_A = empty  AND  W_A ∩ W_B = empty
fn fission_groups_independent(writes_a, reads_a, writes_b, reads_b) {
    let mut i = 0
    while i < len(writes_a) {
        if fission_name_in(writes_a[i], reads_b) { return false }
        i = i + 1
    }
    let mut j = 0
    while j < len(writes_b) {
        if fission_name_in(writes_b[j], reads_a) { return false }
        j = j + 1
    }
    let mut k = 0
    while k < len(writes_a) {
        if fission_name_in(writes_a[k], writes_b) { return false }
        k = k + 1
    }
    return true
}

// anp_detect_fission(node) — detects loops with >=2 independent
// statement groups (no data dependencies between groups).
// Returns the number of groups the loop body can be split into,
// or 0 if fission is not applicable.
fn anp_detect_fission(node) {
    if type_of(node) == "string" { return 0 }
    let k = node.kind
    if k != "ForStmt" && k != "WhileStmt" { return 0 }
    let body = node.body
    if type_of(body) != "array" { return 0 }
    let n = len(body)
    if n < 2 { return 0 }
    // For WhileStmt: last statement is typically the induction variable
    // increment (i = i + 1). Exclude from fission and replicate in each.
    let mut effective_n = n
    if k == "WhileStmt" {
        let last = body[n - 1]
        if type_of(last) != "string" && last.kind == "AssignStmt" {
            effective_n = n - 1
        }
    }
    if effective_n < 2 { return 0 }
    // Build per-statement write/read sets
    let mut all_writes = []
    let mut all_reads = []
    let mut si = 0
    while si < effective_n {
        all_writes = all_writes.push(fission_collect_writes(body[si]))
        all_reads = all_reads.push(fission_collect_reads(body[si]))
        si = si + 1
    }
    // Greedy grouping: assign each statement to first compatible group
    let mut groups = []
    let mut gw = []
    let mut gr = []
    let mut si2 = 0
    while si2 < effective_n {
        let sw = all_writes[si2]
        let sr = all_reads[si2]
        let mut placed = false
        let mut gi = 0
        while gi < len(groups) {
            if fission_groups_independent(gw[gi], gr[gi], sw, sr) {
                let mut cur_g = groups[gi]
                cur_g = cur_g.push(si2)
                groups[gi] = cur_g
                let mut cwi = 0
                let mut merged_w = gw[gi]
                while cwi < len(sw) {
                    merged_w = merged_w.push(sw[cwi])
                    cwi = cwi + 1
                }
                gw[gi] = merged_w
                let mut cri = 0
                let mut merged_r = gr[gi]
                while cri < len(sr) {
                    merged_r = merged_r.push(sr[cri])
                    cri = cri + 1
                }
                gr[gi] = merged_r
                placed = true
                gi = len(groups)
            }
            gi = gi + 1
        }
        if placed == false {
            let mut new_g = []
            new_g = new_g.push(si2)
            groups = groups.push(new_g)
            gw = gw.push(sw)
            gr = gr.push(sr)
        }
        si2 = si2 + 1
    }
    if len(groups) < 2 { return 0 }
    return len(groups)
}

// anp_apply_fission(node) — splits the loop into N separate loops,
// one per independent statement group. Returns an array of loop nodes.
// If fission is not applicable, returns single-element array with original.
fn anp_apply_fission(node) {
    let ngroups = anp_detect_fission(node)
    if ngroups < 2 {
        let mut out = []
        out = out.push(node)
        return out
    }
    let k = node.kind
    let body = node.body
    let n = len(body)
    let mut has_iv_inc = false
    let mut iv_stmt = ""
    let mut effective_n = n
    if k == "WhileStmt" {
        let last = body[n - 1]
        if type_of(last) != "string" && last.kind == "AssignStmt" {
            has_iv_inc = true
            iv_stmt = last
            effective_n = n - 1
        }
    }
    // Re-run grouping
    let mut all_writes = []
    let mut all_reads = []
    let mut si = 0
    while si < effective_n {
        all_writes = all_writes.push(fission_collect_writes(body[si]))
        all_reads = all_reads.push(fission_collect_reads(body[si]))
        si = si + 1
    }
    let mut groups = []
    let mut gw = []
    let mut gr = []
    let mut si2 = 0
    while si2 < effective_n {
        let sw = all_writes[si2]
        let sr = all_reads[si2]
        let mut placed = false
        let mut gi = 0
        while gi < len(groups) {
            if fission_groups_independent(gw[gi], gr[gi], sw, sr) {
                let mut cur_g = groups[gi]
                cur_g = cur_g.push(si2)
                groups[gi] = cur_g
                let mut cwi = 0
                let mut merged_w = gw[gi]
                while cwi < len(sw) {
                    merged_w = merged_w.push(sw[cwi])
                    cwi = cwi + 1
                }
                gw[gi] = merged_w
                let mut cri = 0
                let mut merged_r = gr[gi]
                while cri < len(sr) {
                    merged_r = merged_r.push(sr[cri])
                    cri = cri + 1
                }
                gr[gi] = merged_r
                placed = true
                gi = len(groups)
            }
            gi = gi + 1
        }
        if placed == false {
            let mut new_g = []
            new_g = new_g.push(si2)
            groups = groups.push(new_g)
            gw = gw.push(sw)
            gr = gr.push(sr)
        }
        si2 = si2 + 1
    }
    // Build one loop per group
    let mut result = []
    let mut gi2 = 0
    while gi2 < len(groups) {
        let grp = groups[gi2]
        let mut new_body = []
        let mut gsi = 0
        while gsi < len(grp) {
            new_body = new_body.push(body[grp[gsi]])
            gsi = gsi + 1
        }
        if has_iv_inc {
            new_body = new_body.push(iv_stmt)
        }
        if k == "ForStmt" {
            result = result.push(#{
                "kind": "ForStmt",
                "name": node.name,
                "iter_expr": node.iter_expr,
                "body": new_body
            })
        } else {
            result = result.push(#{
                "kind": "WhileStmt",
                "cond": node.cond,
                "body": new_body
            })
        }
        gi2 = gi2 + 1
    }
    return result
}

// anp_fission_pass(ast) — walks top-level AST applying loop fission.
// Descends into function bodies. Returns transformed AST.
let mut m980_fission_splits = 0

fn anp_fission_pass_body(body) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if type_of(stmt) == "string" {
            out = out.push(stmt)
            i = i + 1
            continue
        }
        let k = stmt.kind
        if k == "IfStmt" {
            let mut new_then = stmt.then_body
            if type_of(new_then) == "array" {
                new_then = anp_fission_pass_body(new_then)
            }
            let mut new_else = stmt.else_body
            if type_of(new_else) == "array" {
                new_else = anp_fission_pass_body(new_else)
            }
            out = out.push(#{
                "kind": "IfStmt",
                "cond": stmt.cond,
                "then_body": new_then,
                "else_body": new_else
            })
            i = i + 1
            continue
        }
        if k == "ForStmt" || k == "WhileStmt" {
            let mut inner_body = stmt.body
            if type_of(inner_body) == "array" {
                inner_body = anp_fission_pass_body(inner_body)
            }
            let mut processed_stmt = stmt
            if k == "ForStmt" {
                processed_stmt = #{
                    "kind": "ForStmt",
                    "name": stmt.name,
                    "iter_expr": stmt.iter_expr,
                    "body": inner_body
                }
            } else {
                processed_stmt = #{
                    "kind": "WhileStmt",
                    "cond": stmt.cond,
                    "body": inner_body
                }
            }
            let splits = anp_apply_fission(processed_stmt)
            if len(splits) > 1 {
                m980_fission_splits = m980_fission_splits + len(splits)
            }
            let mut spi = 0
            while spi < len(splits) {
                out = out.push(splits[spi])
                spi = spi + 1
            }
            i = i + 1
            continue
        }
        out = out.push(stmt)
        i = i + 1
    }
    return out
}

fn anp_fission_pass(ast) {
    if type_of(ast) != "array" { return ast }
    m980_fission_splits = 0
    let mut out = []
    let n = len(ast)
    let mut i = 0
    while i < n {
        let node = ast[i]
        if type_of(node) != "string" && node.kind == "FnDecl" {
            let new_body = anp_fission_pass_body(node.body)
            out = out.push(#{
                "kind": "FnDecl",
                "name": node.name,
                "params": node.params,
                "body": new_body,
                "value": node.value,
                "ret_type": node.ret_type
            })
        } else {
            out = out.push(node)
        }
        i = i + 1
    }
    if m980_fission_splits > 0 {
        println("[ai-native] loop-fission: " + to_string(m980_fission_splits) + " loop(s) split")
    }
    return out
}


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn check_eq(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_arr(name, actual, expected) {
    if len(actual) != len(expected) {
        println("[FAIL] " + name + " — len mismatch: " + to_string(len(actual)) + " vs " + to_string(len(expected)))
        fail_count = fail_count + 1
        return
    }
    let mut ok = true
    let mut i = 0
    while i < len(actual) {
        if actual[i] != expected[i] { ok = false }
        i = i + 1
    }
    if ok {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — actual: " + to_string(actual) + ", expected: " + to_string(expected))
        fail_count = fail_count + 1
    }
}

fn fabs_(x) {
    if x < 0.0 { return -x } else { return x }
}

println("═══════════════════════════════════════════════════════")
println("  ROI #54: Loop Fission Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ═══════════════════════════════════════════════════════════
//  Section 1: Basic independent operations — 2-way fission
// ═══════════════════════════════════════════════════════════

println("--- 1. Basic 2-way fission (independent arrays) ---")

// Original: single loop with two independent operations
fn original_2way(n) {
    let mut a = []
    let mut c = []
    let mut i = 0
    while i < n {
        a = a.push(i + 1)
        c = c.push(i * 2)
        i = i + 1
    }
    return [a, c]
}

// Fissioned: two separate loops
fn fissioned_2way(n) {
    let mut a = []
    let mut i = 0
    while i < n {
        a = a.push(i + 1)
        i = i + 1
    }
    let mut c = []
    let mut j = 0
    while j < n {
        c = c.push(j * 2)
        j = j + 1
    }
    return [a, c]
}

let r1_orig = original_2way(5)
let r1_fiss = fissioned_2way(5)
check_arr("2way: a matches", r1_fiss[0], r1_orig[0])
check_arr("2way: c matches", r1_fiss[1], r1_orig[1])

let r1e = original_2way(0)
check_eq("2way: empty a", len(r1e[0]), 0)
check_eq("2way: empty c", len(r1e[1]), 0)

// ═══════════════════════════════════════════════════════════
//  Section 2: Three-way fission
// ═══════════════════════════════════════════════════════════

println("")
println("--- 2. Three-way fission ---")

fn original_3way(n) {
    let mut a = []
    let mut b = []
    let mut c = []
    let mut i = 0
    while i < n {
        a = a.push(i * i)
        b = b.push(i + 10)
        c = c.push(i * 3)
        i = i + 1
    }
    return [a, b, c]
}

fn fissioned_3way(n) {
    let mut a = []
    let mut i = 0
    while i < n {
        a = a.push(i * i)
        i = i + 1
    }
    let mut b = []
    let mut j = 0
    while j < n {
        b = b.push(j + 10)
        j = j + 1
    }
    let mut c = []
    let mut k = 0
    while k < n {
        c = c.push(k * 3)
        k = k + 1
    }
    return [a, b, c]
}

let r2_orig = original_3way(6)
let r2_fiss = fissioned_3way(6)
check_arr("3way: a matches", r2_fiss[0], r2_orig[0])
check_arr("3way: b matches", r2_fiss[1], r2_orig[1])
check_arr("3way: c matches", r2_fiss[2], r2_orig[2])

// ═══════════════════════════════════════════════════════════
//  Section 3: Dependent operations — no fission
// ═══════════════════════════════════════════════════════════

println("")
println("--- 3. Dependent operations (no fission) ---")

// c[i] depends on a[i], so they must stay in the same loop
fn dependent_loop(n) {
    let mut a = []
    let mut c = []
    let mut i = 0
    while i < n {
        a = a.push(i + 1)
        c = c.push(a[i] * 2)
        i = i + 1
    }
    return [a, c]
}

let r3 = dependent_loop(4)
check_arr("dep: a correct", r3[0], [1, 2, 3, 4])
check_arr("dep: c correct", r3[1], [2, 4, 6, 8])

// ═══════════════════════════════════════════════════════════
//  Section 4: Single statement loop — no fission
// ═══════════════════════════════════════════════════════════

println("")
println("--- 4. Single statement (no fission) ---")

fn single_stmt_loop(n) {
    let mut a = []
    let mut i = 0
    while i < n {
        a = a.push(i * i)
        i = i + 1
    }
    return a
}

check_arr("single: correct", single_stmt_loop(5), [0, 1, 4, 9, 16])

// ═══════════════════════════════════════════════════════════
//  Section 5: Float operations — fission preserves precision
// ═══════════════════════════════════════════════════════════

println("")
println("--- 5. Float operations ---")

fn original_float(n) {
    let mut a = []
    let mut b = []
    let mut i = 0
    while i < n {
        a = a.push(to_float(i) * 1.5)
        b = b.push(to_float(i) / 3.0)
        i = i + 1
    }
    return [a, b]
}

fn fissioned_float(n) {
    let mut a = []
    let mut i = 0
    while i < n {
        a = a.push(to_float(i) * 1.5)
        i = i + 1
    }
    let mut b = []
    let mut j = 0
    while j < n {
        b = b.push(to_float(j) / 3.0)
        j = j + 1
    }
    return [a, b]
}

let r5_orig = original_float(4)
let r5_fiss = fissioned_float(4)
check_eq("float: a len", len(r5_fiss[0]), len(r5_orig[0]))
check_eq("float: b len", len(r5_fiss[1]), len(r5_orig[1]))
let mut float_ok = true
let mut fi = 0
while fi < len(r5_orig[0]) {
    if fabs_(r5_fiss[0][fi] - r5_orig[0][fi]) > 0.0001 { float_ok = false }
    if fabs_(r5_fiss[1][fi] - r5_orig[1][fi]) > 0.0001 { float_ok = false }
    fi = fi + 1
}
check("float: values match", float_ok)

// ═══════════════════════════════════════════════════════════
//  Section 6: Mixed independent + dependent — partial fission
// ═══════════════════════════════════════════════════════════

println("")
println("--- 6. Partial fission (mixed deps) ---")

// a[i] and c[i] are independent, but b depends on a
// So a+b stay together, c splits off
fn original_partial(n) {
    let mut a = []
    let mut b = []
    let mut c = []
    let mut i = 0
    while i < n {
        a = a.push(i + 1)
        b = b.push(a[i] * 3)
        c = c.push(i * 10)
        i = i + 1
    }
    return [a, b, c]
}

fn fissioned_partial(n) {
    // a and b stay together (b depends on a)
    let mut a = []
    let mut b = []
    let mut i = 0
    while i < n {
        a = a.push(i + 1)
        b = b.push(a[i] * 3)
        i = i + 1
    }
    // c is independent
    let mut c = []
    let mut j = 0
    while j < n {
        c = c.push(j * 10)
        j = j + 1
    }
    return [a, b, c]
}

let r6_orig = original_partial(5)
let r6_fiss = fissioned_partial(5)
check_arr("partial: a matches", r6_fiss[0], r6_orig[0])
check_arr("partial: b matches", r6_fiss[1], r6_orig[1])
check_arr("partial: c matches", r6_fiss[2], r6_orig[2])

// ═══════════════════════════════════════════════════════════
//  Section 7: Large array correctness
// ═══════════════════════════════════════════════════════════

println("")
println("--- 7. Large array correctness ---")

fn original_large(n) {
    let mut a = []
    let mut b = []
    let mut i = 0
    while i < n {
        a = a.push(i * 7 + 3)
        b = b.push(i * 11 - 2)
        i = i + 1
    }
    return [a, b]
}

fn fissioned_large(n) {
    let mut a = []
    let mut i = 0
    while i < n {
        a = a.push(i * 7 + 3)
        i = i + 1
    }
    let mut b = []
    let mut j = 0
    while j < n {
        b = b.push(j * 11 - 2)
        j = j + 1
    }
    return [a, b]
}

let r7_orig = original_large(100)
let r7_fiss = fissioned_large(100)
check_eq("large: a len", len(r7_fiss[0]), 100)
check_eq("large: b len", len(r7_fiss[1]), 100)
let mut large_ok = true
let mut li = 0
while li < 100 {
    if r7_fiss[0][li] != r7_orig[0][li] { large_ok = false }
    if r7_fiss[1][li] != r7_orig[1][li] { large_ok = false }
    li = li + 1
}
check("large: all values match", large_ok)

// ═══════════════════════════════════════════════════════════
//  Section 8: fission_name_in helper
// ═══════════════════════════════════════════════════════════

println("")
println("--- 8. fission_name_in helper ---")

check("name_in: found", fission_name_in("x", ["a", "x", "b"]))
check("name_in: not found", fission_name_in("z", ["a", "x", "b"]) == false)
check("name_in: empty", fission_name_in("x", []) == false)
check("name_in: single match", fission_name_in("a", ["a"]))
check("name_in: single no match", fission_name_in("b", ["a"]) == false)

// ═══════════════════════════════════════════════════════════
//  Section 9: fission_groups_independent helper
// ═══════════════════════════════════════════════════════════

println("")
println("--- 9. fission_groups_independent ---")

// Independent: no overlap
check("indep: disjoint", fission_groups_independent(["a"], ["b"], ["c"], ["d"]))
// Dependent: W_A reads in R_B
check("dep: W_A in R_B", fission_groups_independent(["a"], ["b"], ["c"], ["a"]) == false)
// Dependent: W_B reads in R_A
check("dep: W_B in R_A", fission_groups_independent(["c"], ["a"], ["a"], ["d"]) == false)
// Dependent: W_A intersects W_B (write-write conflict)
check("dep: W_A ∩ W_B", fission_groups_independent(["x"], ["b"], ["x"], ["d"]) == false)
// Independent: both empty writes
check("indep: empty writes", fission_groups_independent([], ["a"], [], ["b"]))
// Both completely empty
check("indep: all empty", fission_groups_independent([], [], [], []))

// ═══════════════════════════════════════════════════════════
//  Section 10: Accumulator pattern — not splittable
// ═══════════════════════════════════════════════════════════

println("")
println("--- 10. Accumulator (not splittable) ---")

fn accumulator_loop(n) {
    let mut sum = 0
    let mut product = 1
    let mut i = 0
    while i < n {
        sum = sum + i
        product = product * (i + 1)
        i = i + 1
    }
    return [sum, product]
}

// sum and product are independent of each other!
// Each only reads/writes itself. They CAN be fissioned.
let r10 = accumulator_loop(5)
check_eq("accum: sum", r10[0], 10)
check_eq("accum: product", r10[1], 120)

// Verify fissioned version gives same result
fn fissioned_accum(n) {
    let mut sum = 0
    let mut i = 0
    while i < n {
        sum = sum + i
        i = i + 1
    }
    let mut product = 1
    let mut j = 0
    while j < n {
        product = product * (j + 1)
        j = j + 1
    }
    return [sum, product]
}

let r10f = fissioned_accum(5)
check_eq("accum fissioned: sum", r10f[0], 10)
check_eq("accum fissioned: product", r10f[1], 120)

// ═══════════════════════════════════════════════════════════
//  Section 11: String operations
// ═══════════════════════════════════════════════════════════

println("")
println("--- 11. String operations ---")

fn original_strings(n) {
    let mut nums = []
    let mut doubled = []
    let mut i = 0
    while i < n {
        nums = nums.push(to_string(i))
        doubled = doubled.push(to_string(i * 2))
        i = i + 1
    }
    return [nums, doubled]
}

fn fissioned_strings(n) {
    let mut nums = []
    let mut i = 0
    while i < n {
        nums = nums.push(to_string(i))
        i = i + 1
    }
    let mut doubled = []
    let mut j = 0
    while j < n {
        doubled = doubled.push(to_string(j * 2))
        j = j + 1
    }
    return [nums, doubled]
}

let r11_orig = original_strings(4)
let r11_fiss = fissioned_strings(4)
check_arr("strings: nums", r11_fiss[0], r11_orig[0])
check_arr("strings: doubled", r11_fiss[1], r11_orig[1])

// ═══════════════════════════════════════════════════════════
//  Section 12: Four-way fission
// ═══════════════════════════════════════════════════════════

println("")
println("--- 12. Four-way fission ---")

fn original_4way(n) {
    let mut a = []
    let mut b = []
    let mut c = []
    let mut d = []
    let mut i = 0
    while i < n {
        a = a.push(i + 1)
        b = b.push(i * 2)
        c = c.push(i * i)
        d = d.push(i + 100)
        i = i + 1
    }
    return [a, b, c, d]
}

fn fissioned_4way(n) {
    let mut a = []
    let mut i = 0
    while i < n {
        a = a.push(i + 1)
        i = i + 1
    }
    let mut b = []
    let mut j = 0
    while j < n {
        b = b.push(j * 2)
        j = j + 1
    }
    let mut c = []
    let mut k = 0
    while k < n {
        c = c.push(k * k)
        k = k + 1
    }
    let mut d = []
    let mut l = 0
    while l < n {
        d = d.push(l + 100)
        l = l + 1
    }
    return [a, b, c, d]
}

let r12_orig = original_4way(8)
let r12_fiss = fissioned_4way(8)
check_arr("4way: a", r12_fiss[0], r12_orig[0])
check_arr("4way: b", r12_fiss[1], r12_orig[1])
check_arr("4way: c", r12_fiss[2], r12_orig[2])
check_arr("4way: d", r12_fiss[3], r12_orig[3])

// ═══════════════════════════════════════════════════════════
//  Section 13: Edge case — n=1
// ═══════════════════════════════════════════════════════════

println("")
println("--- 13. Edge case n=1 ---")

let r13_orig = original_2way(1)
let r13_fiss = fissioned_2way(1)
check_arr("n=1: a", r13_fiss[0], r13_orig[0])
check_arr("n=1: c", r13_fiss[1], r13_orig[1])

// ═══════════════════════════════════════════════════════════
//  Section 14: All-dependent chain (no fission possible)
// ═══════════════════════════════════════════════════════════

println("")
println("--- 14. All-dependent chain ---")

fn all_dependent(n) {
    let mut a = 0
    let mut i = 0
    while i < n {
        a = a + i
        a = a * 2
        i = i + 1
    }
    return a
}

check_eq("all-dep: n=5", all_dependent(5), 52)

// ═══════════════════════════════════════════════════════════
//  Section 15: Conditional inside loop — not fissioned
//  (opaque body prevents simple analysis)
// ═══════════════════════════════════════════════════════════

println("")
println("--- 15. Conditional inside loop ---")

fn cond_in_loop(n) {
    let mut evens = []
    let mut odds = []
    let mut i = 0
    while i < n {
        if i % 2 == 0 {
            evens = evens.push(i)
        } else {
            odds = odds.push(i)
        }
        i = i + 1
    }
    return [evens, odds]
}

let r15 = cond_in_loop(6)
check_arr("cond: evens", r15[0], [0, 2, 4])
check_arr("cond: odds", r15[1], [1, 3, 5])

// ═══════════════════════════════════════════════════════════
//  Section 16: Negative indices / decreasing loop
// ═══════════════════════════════════════════════════════════

println("")
println("--- 16. Decreasing loop ---")

fn original_decr(n) {
    let mut a = []
    let mut b = []
    let mut i = n - 1
    while i >= 0 {
        a = a.push(i)
        b = b.push(i * 3)
        i = i - 1
    }
    return [a, b]
}

fn fissioned_decr(n) {
    let mut a = []
    let mut i = n - 1
    while i >= 0 {
        a = a.push(i)
        i = i - 1
    }
    let mut b = []
    let mut j = n - 1
    while j >= 0 {
        b = b.push(j * 3)
        j = j - 1
    }
    return [a, b]
}

let r16_orig = original_decr(4)
let r16_fiss = fissioned_decr(4)
check_arr("decr: a", r16_fiss[0], r16_orig[0])
check_arr("decr: b", r16_fiss[1], r16_orig[1])

// ═══════════════════════════════════════════════════════════
//  Section 17: Idempotence — fissioning already-fissioned
// ═══════════════════════════════════════════════════════════

println("")
println("--- 17. Idempotence ---")

// A single-op loop stays as-is
fn single_op(n) {
    let mut a = []
    let mut i = 0
    while i < n {
        a = a.push(i + 1)
        i = i + 1
    }
    return a
}

check_arr("idempotent: single loop", single_op(5), [1, 2, 3, 4, 5])

// ═══════════════════════════════════════════════════════════
//  Section 18: Nested independent operations
// ═══════════════════════════════════════════════════════════

println("")
println("--- 18. Nested independent ops ---")

fn nested_indep(n) {
    let mut sums = []
    let mut products = []
    let mut i = 0
    while i < n {
        let mut s = 0
        let mut j = 0
        while j <= i {
            s = s + j
            j = j + 1
        }
        sums = sums.push(s)
        products = products.push(i * i)
        i = i + 1
    }
    return [sums, products]
}

let r18 = nested_indep(5)
check_arr("nested: sums", r18[0], [0, 1, 3, 6, 10])
check_arr("nested: products", r18[1], [0, 1, 4, 9, 16])

// ═══════════════════════════════════════════════════════════
//  Section 19: Read-only shared variable (both read 'n')
// ═══════════════════════════════════════════════════════════

println("")
println("--- 19. Shared read-only variable ---")

fn shared_readonly(n) {
    let mut a = []
    let mut b = []
    let mut i = 0
    while i < n {
        a = a.push(n - i)
        b = b.push(n + i)
        i = i + 1
    }
    return [a, b]
}

fn fissioned_shared(n) {
    let mut a = []
    let mut i = 0
    while i < n {
        a = a.push(n - i)
        i = i + 1
    }
    let mut b = []
    let mut j = 0
    while j < n {
        b = b.push(n + j)
        j = j + 1
    }
    return [a, b]
}

let r19_orig = shared_readonly(5)
let r19_fiss = fissioned_shared(5)
check_arr("shared-ro: a", r19_fiss[0], r19_orig[0])
check_arr("shared-ro: b", r19_fiss[1], r19_orig[1])

// ═══════════════════════════════════════════════════════════
//  Section 20: Write-write conflict
// ═══════════════════════════════════════════════════════════

println("")
println("--- 20. Write-write conflict ---")

fn write_write(n) {
    let mut a = 0
    let mut i = 0
    while i < n {
        a = a + 1
        a = a * 2
        i = i + 1
    }
    return a
}

check_eq("ww-conflict: n=3", write_write(3), 14)

// ═══════════════════════════════════════════════════════════
//  Section 21: Boolean array operations
// ═══════════════════════════════════════════════════════════

println("")
println("--- 21. Boolean arrays ---")

fn original_bools(n) {
    let mut evens = []
    let mut positives = []
    let mut i = 0
    while i < n {
        evens = evens.push(i % 2 == 0)
        positives = positives.push(i > 0)
        i = i + 1
    }
    return [evens, positives]
}

fn fissioned_bools(n) {
    let mut evens = []
    let mut i = 0
    while i < n {
        evens = evens.push(i % 2 == 0)
        i = i + 1
    }
    let mut positives = []
    let mut j = 0
    while j < n {
        positives = positives.push(j > 0)
        j = j + 1
    }
    return [evens, positives]
}

let r21_orig = original_bools(5)
let r21_fiss = fissioned_bools(5)
check_arr("bools: evens", r21_fiss[0], r21_orig[0])
check_arr("bools: positives", r21_fiss[1], r21_orig[1])

// ═══════════════════════════════════════════════════════════
//  Section 22: Sum reduction after fission
// ═══════════════════════════════════════════════════════════

println("")
println("--- 22. Sum after fission ---")

fn sum_arr(arr) {
    let mut s = 0
    let mut i = 0
    while i < len(arr) {
        s = s + arr[i]
        i = i + 1
    }
    return s
}

let r22_orig = original_2way(10)
let r22_fiss = fissioned_2way(10)
check_eq("sum: a orig==fiss", sum_arr(r22_orig[0]), sum_arr(r22_fiss[0]))
check_eq("sum: c orig==fiss", sum_arr(r22_orig[1]), sum_arr(r22_fiss[1]))

// ═══════════════════════════════════════════════════════════
//  Section 23: Boundary values
// ═══════════════════════════════════════════════════════════

println("")
println("--- 23. Boundary values ---")

let r23_0 = original_2way(0)
let r23_1 = original_2way(1)
let f23_0 = fissioned_2way(0)
let f23_1 = fissioned_2way(1)
check_eq("boundary: n=0 a len", len(r23_0[0]), 0)
check_eq("boundary: n=0 c len", len(r23_0[1]), 0)
check_arr("boundary: n=1 a", f23_1[0], r23_1[0])
check_arr("boundary: n=1 c", f23_1[1], r23_1[1])

