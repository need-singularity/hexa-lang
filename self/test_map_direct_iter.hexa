// test_map_direct_iter.hexa — regression guard for `for k in map { ... }`
// Direct hashmap iteration: iterating a map yields its keys (Python-style).
// Note: this feature currently works only via the self-host pipeline
//       (./self/native/hexa_v2 → C → clang). The prebuilt `./hexa` Rust
//       binary still rejects direct map iteration at type-check time.
//       For that path, use `for k in m.keys()` instead.

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("=== Map Direct Iteration ===")

// 1. Simple direct key iteration + m[k] lookup
let m1 = #{"a": 1, "b": 2, "c": 3}
let mut nkeys = 0
let mut sum_via_lookup = 0
for k in m1 {
    sum_via_lookup = sum_via_lookup + m1[k]
    nkeys = nkeys + 1
}
check("direct iter key count", nkeys, 3)
check("direct iter sum via m[k]", sum_via_lookup, 6)

// 2. Empty map — zero iterations
let empty = #{}
let mut ne = 0
for k in empty { ne = ne + 1 }
check("empty map direct iter", ne, 0)

// 3. Mutable dynamic build, then iterate
let mut freq = #{}
let words = ["x", "y", "x", "z", "y", "x"]
for w in words {
    if freq.contains_key(w) {
        freq[w] = freq[w] + 1
    } else {
        freq[w] = 1
    }
}
let mut total_via_direct = 0
for k in freq { total_via_direct = total_via_direct + freq[k] }
check("freq total via direct iter", total_via_direct, 6)

// 4. Non-regression: array direct iter still works
let arr = [10, 20, 30]
let mut arr_sum = 0
for v in arr { arr_sum = arr_sum + v }
check("array direct iter sum", arr_sum, 60)

// 5. Non-regression: range iter still works
let mut range_sum = 0
let mut i = 0

while i < 5 { range_sum = range_sum + i }
check("range iter sum 0..5", range_sum, 10)

// 6. Non-regression: .keys()/.values() still work
let m6 = #{"p": 1, "q": 2}
let mut via_keys = 0
for k in m6.keys() { via_keys = via_keys + 1 }
check("m.keys() still works", via_keys, 2)

let mut via_vals = 0
for v in m6.values() { via_vals = via_vals + v }
check("m.values() still works", via_vals, 3)

println("")
let total = pass_count + fail_count
println("Results: " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL / " + to_string(total) + " total")
if fail_count == 0 { println("ALL MAP DIRECT ITER TESTS PASSED") }
