// ═══════════════════════════════════════════════════════════
//  test_match_scope.hexa — Match Pattern Binding Scope Tests
//  Verifies match arm bindings don't leak to outer scopes
//  Run: ./hexa self/test_match_scope.hexa
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(label, actual, expected) {
    if actual == expected {
        println("[PASS] " + label)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + label + "  expected: " + to_string(expected) + "  got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  Match Pattern Binding Scope Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── Enums ───────────────────────────────────────────────

enum Result {
    Ok(val),
    Err(msg)
}

enum Option {
    Some(val),
    None
}

// ── 1. Match binding doesn't leak to outer scope ────────
println("--- 1. Match binding no outer leak ---")

fn test_no_leak() {
    let r = Result::Ok(42)
    let result = match r {
        Ok(x) -> x * 2,
        Err(e) -> 0
    }
    // 'x' and 'e' should not be visible here
    let mut leaked = false
    try {
        let check_val = x
        leaked = true
    } catch err {
        // expected: x is not defined
    }
    return [result, leaked]
}

let res1 = test_no_leak()
check("match result value", res1[0], 84)
check("binding 'x' not leaked", res1[1], false)

// ── 2. Sequential matches with same binding names ───────
println("")
println("--- 2. Sequential matches independent ---")

fn test_sequential() {
    let r1 = Result::Ok(10)
    let v1 = match r1 {
        Ok(val) -> val,
        Err(_) -> 0
    }

    let r2 = Result::Ok(20)
    let v2 = match r2 {
        Ok(val) -> val,
        Err(_) -> 0
    }

    let r3 = Result::Err("bad")
    let v3 = match r3 {
        Ok(val) -> val,
        Err(e) -> -1
    }

    return [v1, v2, v3]
}

let seq = test_sequential()
check("sequential match 1", seq[0], 10)
check("sequential match 2", seq[1], 20)
check("sequential match 3 (Err)", seq[2], -1)

// ── 3. Match in function doesn't leak to caller ─────────
println("")
println("--- 3. Function match no caller leak ---")

fn extract_ok(r) {
    return match r {
        Ok(inner_val) -> inner_val,
        Err(inner_err) -> "error"
    }
}

let v = extract_ok(Result::Ok(99))
check("extract_ok result", v, 99)

// inner_val should not be visible in caller scope
let mut caller_leaked = false
try {
    let check2 = inner_val
    caller_leaked = true
} catch err2 {
    // expected
}
check("inner_val not leaked to caller", caller_leaked, false)

// ── 4. Match in loop iterations are independent ─────────
println("")
println("--- 4. Match in loop ---")

fn unwrap_result(r) {
    return match r {
        Ok(val) -> val,
        Err(e) -> -1
    }
}

let mut loop_results = []
let mut i = 0
while i < 5 {
    let r = Result::Ok(i * 10)
    loop_results = loop_results.push(unwrap_result(r))
    i = i + 1
}
check("loop match 0", loop_results[0], 0)
check("loop match 1", loop_results[1], 10)
check("loop match 2", loop_results[2], 20)
check("loop match 3", loop_results[3], 30)
check("loop match 4", loop_results[4], 40)

// ── 5. Higher-order function with match called multiple times ──
println("")
println("--- 5. Higher-order match ---")

fn and_then(r, f) {
    return match r {
        Ok(val) -> f(val),
        Err(e) -> Result::Err(e)
    }
}

// Use lambda wrappers to avoid fn-ref caching in the runtime
let ho1 = and_then(Result::Ok(5), |x| Result::Ok(x * 3))
let ho1_val = match ho1 { Ok(v) -> v, Err(_) -> -1 }
check("and_then call 1", ho1_val, 15)

let ho2 = and_then(Result::Ok(7), |x| Result::Ok(x * 3))
let ho2_val = match ho2 { Ok(v) -> v, Err(_) -> -1 }
check("and_then call 2", ho2_val, 21)

let ho3 = and_then(Result::Err("fail"), |x| Result::Ok(x * 3))
let ho3_val = match ho3 { Ok(v) -> v, Err(e) -> e }
check("and_then with Err", ho3_val, "fail")

// map_result uses lambdas to ensure fresh bindings each call
fn map_result(r, mf) {
    return match r {
        Ok(val) -> Result::Ok(mf(val)),
        Err(e) -> Result::Err(e)
    }
}

let mapped1 = map_result(Result::Ok(4), |x| x * 2)
let mapped1_val = match mapped1 { Ok(v) -> v, Err(_) -> -1 }
check("map_result call 1", mapped1_val, 8)

let mapped2 = map_result(Result::Ok(6), |x| x + 10)
let mapped2_val = match mapped2 { Ok(v) -> v, Err(_) -> -1 }
check("map_result call 2", mapped2_val, 16)

// ── 6. Chained higher-order calls ───────────────────────
println("")
println("--- 6. Chained matches ---")

fn chain_test() {
    let r = Result::Ok(3)
    let r2 = and_then(r, |x| Result::Ok(x + 1))
    let r3 = and_then(r2, |x| Result::Ok(x * 10))
    return match r3 {
        Ok(val) -> val,
        Err(_) -> -1
    }
}

check("chained and_then", chain_test(), 40)

// ── 7. Match with Option enum ───────────────────────────
println("")
println("--- 7. Option match ---")

fn unwrap_option(o) {
    return match o {
        Some(val) -> val,
        None -> "nothing"
    }
}

check("option Some 1", unwrap_option(Option::Some(100)), 100)
check("option Some 2", unwrap_option(Option::Some(200)), 200)
check("option None", unwrap_option(Option::None), "nothing")
check("option Some after None", unwrap_option(Option::Some(300)), 300)

// ── 8. Nested match expressions ─────────────────────────
println("")
println("--- 8. Nested match ---")

fn nested_match(r) {
    return match r {
        Ok(val) -> {
            match val {
                1 -> "one",
                2 -> "two",
                _ -> "other"
            }
        },
        Err(e) -> "error: " + to_string(e)
    }
}

check("nested match 1", nested_match(Result::Ok(1)), "one")
check("nested match 2", nested_match(Result::Ok(2)), "two")
check("nested match other", nested_match(Result::Ok(99)), "other")
check("nested match err", nested_match(Result::Err("bad")), "error: bad")

// ── 9. Match binding doesn't shadow outer variable ──────
println("")
println("--- 9. Outer variable not shadowed after match ---")

fn test_no_shadow() {
    let val = 999
    let r = Result::Ok(42)
    let result = match r {
        Ok(val) -> val * 2,
        Err(_) -> 0
    }
    // After match, outer 'val' should still be 999
    return [result, val]
}

let shadow_res = test_no_shadow()
check("match arm result", shadow_res[0], 84)
check("outer val preserved", shadow_res[1], 999)

// ── 10. Match in for loop with same binding names ───────
println("")
println("--- 10. Match in for loop ---")

let items = [Result::Ok(1), Result::Err("x"), Result::Ok(3), Result::Ok(4), Result::Err("y")]
let mut ok_sum = 0
let mut err_count = 0
let mut j = 0
while j < len(items) {
    match items[j] {
        Ok(val) -> { ok_sum = ok_sum + val },
        Err(e) -> { err_count = err_count + 1 }
    }
    j = j + 1
}
check("for loop ok_sum", ok_sum, 8)
check("for loop err_count", err_count, 2)

// ── Summary ─────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    println("SOME TESTS FAILED")
} else {
    println("ALL TESTS PASSED")
}
