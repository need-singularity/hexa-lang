// =====================================================================
//  test_loop_interchange.hexa -- ROI #56 Loop Interchange pass verification
//
//  Verifies that nested for-loops with column-major access patterns
//  produce correct results after loop interchange optimization.
//  The pass swaps loop order so that a[j][i] access in
//  for i { for j { ... } } becomes for j { for i { ... } } for
//  row-major (cache-friendly) traversal.
//
//  Tests (22):
//    1. basic column-major write produces correct matrix
//    2. basic row-major write (no interchange needed) correctness
//    3. column-major read + accumulation
//    4. column-major write with expression (a[j][i] = i * cols + j)
//    5. identity matrix construction via column-major
//    6. matrix transpose via column-major access
//    7. nested loop with addition accumulator (a[j][i] += val)
//    8. mixed: column-major write + scalar accumulator
//    9. rectangular matrix (rows != cols)
//   10. single row matrix (1 x N)
//   11. single column matrix (N x 1)
//   12. 1x1 matrix edge case
//   13. large-ish matrix (10x10) sum
//   14. column-major with multiplication in body
//   15. column-major with conditional value
//   16. triple nested loop (only inner pair interchanged)
//   17. two separate nested loops in one function
//   18. zero-size range (no iterations)
//   19. column-major read for dot-product-like pattern
//   20. column-major with subtraction pattern
//   21. overwrite pattern: last write wins
//   22. diagonal sum via column-major access
//
//  Run: ./hexa test self/test_loop_interchange.hexa
// =====================================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn check_eq(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

// Helper: create a rows x cols matrix filled with zero
fn make_matrix(rows, cols) {
    let mut m = []
    for r in 0..rows {
        let mut row = []
        for c in 0..cols {
            row = row + [0]
        }
        m = m + [row]
    }
    return m
}

// Helper: flatten matrix to a string for comparison
fn mat_str(m) {
    let mut s = "["
    for r in 0..len(m) {
        if r > 0 { s = s + "," }
        s = s + "["
        for c in 0..len(m[r]) {
            if c > 0 { s = s + "," }
            s = s + to_string(m[r][c])
        }
        s = s + "]"
    }
    s = s + "]"
    return s
}

println("=====================================================")
println("  Loop Interchange (ROI #56) Tests")
println("=====================================================")
println("")

// -- 1. Basic column-major write --
println("--- 1. basic column-major write ---")
fn test_col_major_write() {
    let rows = 3
    let cols = 3
    let mut m = make_matrix(rows, cols)
    let mut val = 1
    // Column-major pattern: for i (col) { for j (row) { m[j][i] = val } }
    // After interchange this should still produce correct results
    for i in 0..cols {
        for j in 0..rows {
            m[j][i] = val
            val = val + 1
        }
    }
    return m
}
let m1 = test_col_major_write()
// Column-major fill: col0=[1,2,3], col1=[4,5,6], col2=[7,8,9]
check_eq("col-major write [0][0]", m1[0][0], 1)
check_eq("col-major write [1][0]", m1[1][0], 2)
check_eq("col-major write [2][2]", m1[2][2], 9)

// -- 2. Row-major write (should not be interchanged) --
println("")
println("--- 2. row-major write (no interchange) ---")
fn test_row_major_write() {
    let rows = 3
    let cols = 3
    let mut m = make_matrix(rows, cols)
    let mut val = 1
    for i in 0..rows {
        for j in 0..cols {
            m[i][j] = val
            val = val + 1
        }
    }
    return m
}
let m2 = test_row_major_write()
check_eq("row-major write [0][0]", m2[0][0], 1)
check_eq("row-major write [0][2]", m2[0][2], 3)
check_eq("row-major write [2][2]", m2[2][2], 9)

// -- 3. Column-major read + accumulation --
println("")
println("--- 3. column-major read accumulation ---")
fn test_col_major_read_sum() {
    let rows = 3
    let cols = 3
    let mut m = make_matrix(rows, cols)
    // Fill row-major
    for r in 0..rows {
        for c in 0..cols {
            m[r][c] = r * cols + c + 1
        }
    }
    // Read column-major
    let mut sum = 0
    for i in 0..cols {
        for j in 0..rows {
            sum = sum + m[j][i]
        }
    }
    return sum
}
// Sum of 1..9 = 45
check_eq("col-major read sum", test_col_major_read_sum(), 45)

// -- 4. Column-major write with expression --
println("")
println("--- 4. column-major write with expression ---")
fn test_col_major_expr() {
    let rows = 2
    let cols = 4
    let mut m = make_matrix(rows, cols)
    for i in 0..cols {
        for j in 0..rows {
            m[j][i] = j * cols + i
        }
    }
    return m
}
let m4 = test_col_major_expr()
check_eq("expr [0][0]", m4[0][0], 0)
check_eq("expr [0][3]", m4[0][3], 3)
check_eq("expr [1][0]", m4[1][0], 4)
check_eq("expr [1][3]", m4[1][3], 7)

// -- 5. Identity matrix via column-major --
println("")
println("--- 5. identity matrix column-major ---")
fn test_identity_col() {
    let n = 4
    let mut m = make_matrix(n, n)
    for i in 0..n {
        for j in 0..n {
            if j == i {
                m[j][i] = 1
            }
        }
    }
    return m
}
let m5 = test_identity_col()
check_eq("identity [0][0]", m5[0][0], 1)
check_eq("identity [1][1]", m5[1][1], 1)
check_eq("identity [0][1]", m5[0][1], 0)
check_eq("identity [3][3]", m5[3][3], 1)

// -- 6. Matrix transpose --
println("")
println("--- 6. matrix transpose ---")
fn test_transpose() {
    let rows = 2
    let cols = 3
    let mut src = make_matrix(rows, cols)
    for r in 0..rows {
        for c in 0..cols {
            src[r][c] = r * 10 + c
        }
    }
    // Transpose: dst[c][r] = src[r][c]
    let mut dst = make_matrix(cols, rows)
    for r in 0..rows {
        for c in 0..cols {
            dst[c][r] = src[r][c]
        }
    }
    return dst
}
let m6 = test_transpose()
check_eq("transpose [0][0]", m6[0][0], 0)
check_eq("transpose [0][1]", m6[0][1], 10)
check_eq("transpose [2][0]", m6[2][0], 2)
check_eq("transpose [2][1]", m6[2][1], 12)

// -- 7. Accumulator pattern --
println("")
println("--- 7. accumulator a[j][i] += ---")
fn test_accum() {
    let n = 3
    let mut m = make_matrix(n, n)
    // Fill with ones
    for r in 0..n {
        for c in 0..n {
            m[r][c] = 1
        }
    }
    // Add 10 column-major
    for i in 0..n {
        for j in 0..n {
            m[j][i] = m[j][i] + 10
        }
    }
    return m[1][2]
}
check_eq("accum [1][2]", test_accum(), 11)

// -- 8. Mixed: column-major write + scalar --
println("")
println("--- 8. mixed column-major + scalar ---")
fn test_mixed_scalar() {
    let n = 3
    let mut m = make_matrix(n, n)
    let mut total = 0
    for i in 0..n {
        for j in 0..n {
            m[j][i] = i + j
            total = total + m[j][i]
        }
    }
    return total
}
// i+j for all (i,j) in 0..3 x 0..3: 0+1+2+1+2+3+2+3+4 = 18
check_eq("mixed scalar total", test_mixed_scalar(), 18)

// -- 9. Rectangular matrix --
println("")
println("--- 9. rectangular matrix ---")
fn test_rect() {
    let rows = 2
    let cols = 5
    let mut m = make_matrix(rows, cols)
    for i in 0..cols {
        for j in 0..rows {
            m[j][i] = i * rows + j
        }
    }
    return m[1][4]
}
check_eq("rect [1][4]", test_rect(), 9)

// -- 10. Single row (1 x N) --
println("")
println("--- 10. single row ---")
fn test_single_row() {
    let rows = 1
    let cols = 5
    let mut m = make_matrix(rows, cols)
    for i in 0..cols {
        for j in 0..rows {
            m[j][i] = i * 10
        }
    }
    return m[0][3]
}
check_eq("single row [0][3]", test_single_row(), 30)

// -- 11. Single column (N x 1) --
println("")
println("--- 11. single column ---")
fn test_single_col() {
    let rows = 4
    let cols = 1
    let mut m = make_matrix(rows, cols)
    for i in 0..cols {
        for j in 0..rows {
            m[j][i] = j * 3
        }
    }
    return m[3][0]
}
check_eq("single col [3][0]", test_single_col(), 9)

// -- 12. 1x1 matrix --
println("")
println("--- 12. 1x1 matrix ---")
fn test_1x1() {
    let mut m = make_matrix(1, 1)
    for i in 0..1 {
        for j in 0..1 {
            m[j][i] = 42
        }
    }
    return m[0][0]
}
check_eq("1x1 matrix", test_1x1(), 42)

// -- 13. Larger matrix sum --
println("")
println("--- 13. 10x10 sum ---")
fn test_10x10_sum() {
    let n = 10
    let mut m = make_matrix(n, n)
    for i in 0..n {
        for j in 0..n {
            m[j][i] = 1
        }
    }
    let mut sum = 0
    for r in 0..n {
        for c in 0..n {
            sum = sum + m[r][c]
        }
    }
    return sum
}
check_eq("10x10 sum", test_10x10_sum(), 100)

// -- 14. Column-major with multiplication --
println("")
println("--- 14. column-major multiply ---")
fn test_col_mul() {
    let n = 3
    let mut m = make_matrix(n, n)
    for i in 0..n {
        for j in 0..n {
            m[j][i] = (i + 1) * (j + 1)
        }
    }
    // m[r][c] = (c+1)*(r+1)
    return m[2][2]
}
check_eq("col multiply [2][2]", test_col_mul(), 9)

// -- 15. Column-major with conditional --
println("")
println("--- 15. column-major conditional ---")
fn test_col_cond() {
    let n = 4
    let mut m = make_matrix(n, n)
    for i in 0..n {
        for j in 0..n {
            if i == j {
                m[j][i] = 100
            } else {
                m[j][i] = 0
            }
        }
    }
    return m[2][2] + m[0][1]
}
check_eq("col conditional", test_col_cond(), 100)

// -- 16. Triple nested loop --
println("")
println("--- 16. triple nested ---")
fn test_triple() {
    let n = 3
    let mut total = 0
    // Only the inner pair has column-major access
    for k in 0..2 {
        let mut m = make_matrix(n, n)
        for i in 0..n {
            for j in 0..n {
                m[j][i] = k + i + j
            }
        }
        total = total + m[1][2]
    }
    // k=0: m[1][2] = 0+2+1=3; k=1: m[1][2] = 1+2+1=4; total=7
    return total
}
check_eq("triple nested", test_triple(), 7)

// -- 17. Two separate nested loops --
println("")
println("--- 17. two separate nested loops ---")
fn test_two_loops() {
    let n = 3
    let mut a = make_matrix(n, n)
    let mut b = make_matrix(n, n)
    for i in 0..n {
        for j in 0..n {
            a[j][i] = i + j
        }
    }
    for i in 0..n {
        for j in 0..n {
            b[j][i] = i * j
        }
    }
    return a[2][1] + b[2][1]
}
// a[2][1] = 1+2=3, b[2][1] = 1*2=2, total=5
check_eq("two loops", test_two_loops(), 5)

// -- 18. Zero-size range --
println("")
println("--- 18. zero-size range ---")
fn test_zero_range() {
    let mut m = make_matrix(3, 3)
    for i in 0..0 {
        for j in 0..3 {
            m[j][i] = 99
        }
    }
    return m[0][0]
}
check_eq("zero range", test_zero_range(), 0)

// -- 19. Column-major read for sum-of-columns --
println("")
println("--- 19. sum of columns ---")
fn test_sum_cols() {
    let rows = 3
    let cols = 4
    let mut m = make_matrix(rows, cols)
    for r in 0..rows {
        for c in 0..cols {
            m[r][c] = c + 1
        }
    }
    // Sum each column via column-major traversal
    let mut col_sums = [0, 0, 0, 0]
    for i in 0..cols {
        for j in 0..rows {
            col_sums[i] = col_sums[i] + m[j][i]
        }
    }
    // Each column c has value (c+1) repeated 3 times
    return col_sums[0] + col_sums[1] + col_sums[2] + col_sums[3]
}
// 3*1 + 3*2 + 3*3 + 3*4 = 3+6+9+12 = 30
check_eq("sum of columns", test_sum_cols(), 30)

// -- 20. Column-major subtraction --
println("")
println("--- 20. column-major subtraction ---")
fn test_col_sub() {
    let n = 3
    let mut m = make_matrix(n, n)
    // Fill with 100
    for r in 0..n {
        for c in 0..n {
            m[r][c] = 100
        }
    }
    // Subtract column-major
    for i in 0..n {
        for j in 0..n {
            m[j][i] = m[j][i] - i - j
        }
    }
    // m[2][2] = 100 - 2 - 2 = 96
    return m[2][2]
}
check_eq("col subtraction", test_col_sub(), 96)

// -- 21. Overwrite pattern --
println("")
println("--- 21. overwrite (last write wins) ---")
fn test_overwrite() {
    let n = 3
    let mut m = make_matrix(n, n)
    // First pass
    for i in 0..n {
        for j in 0..n {
            m[j][i] = 1
        }
    }
    // Second pass overwrites
    for i in 0..n {
        for j in 0..n {
            m[j][i] = 2
        }
    }
    return m[1][1]
}
check_eq("overwrite", test_overwrite(), 2)

// -- 22. Diagonal sum --
println("")
println("--- 22. diagonal sum ---")
fn test_diag_sum() {
    let n = 4
    let mut m = make_matrix(n, n)
    for i in 0..n {
        for j in 0..n {
            m[j][i] = i + j
        }
    }
    let mut diag = 0
    for k in 0..n {
        diag = diag + m[k][k]
    }
    // diag: m[0][0]=0, m[1][1]=2, m[2][2]=4, m[3][3]=6 => 12
    return diag
}
check_eq("diagonal sum", test_diag_sum(), 12)

// -- Summary --
println("")
println("=====================================================")
println("  Loop Interchange: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("=====================================================")
assert(fail_count == 0)
