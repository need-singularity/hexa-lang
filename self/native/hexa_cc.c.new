HexaVal ret_stmt(HexaVal e) {
    return mk(hexa_str("ReturnStmt"), hexa_str(""), hexa_str(""), hexa_str(""), e, hexa_str(""), hexa_str(""), hexa_str(""), hexa_str(""), hexa_str(""), hexa_str(""), hexa_str(""), hexa_str(""));
    return hexa_void();
