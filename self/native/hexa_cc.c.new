                tc_error(hexa_add(hexa_add(hexa_add(hexa_add(hexa_add(hexa_add(hexa_str("Arithmetic type mismatch: '"), lt), hexa_str("' ")), op), hexa_str(" '")), rt), hexa_str("'")));
