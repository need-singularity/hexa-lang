HexaVal annotation_to_type(HexaVal ann) {
    if (hexa_truthy(hexa_eq(ann, hexa_str("")))) {
        return hexa_str("unknown");
    }
    if (hexa_truthy(hexa_eq(ann, hexa_str("int")))) {
