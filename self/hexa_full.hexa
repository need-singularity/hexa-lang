// @ai-contract: interp-interpreter
// @ssot: self/hexa_full.hexa                       role=source
// @registry: self/hexa_full.json                   consume_before_edit=true
// @runtime: self/runtime.c                         link=static
// @transpiler: self/native/hexa_v2                 invoke=transpile
// @binary: build/hexa_interp                       produces=true gitignored=true
//
// @precheck: load(self/hexa_full.json) → assert invariants[I1..I4]
// @postcheck: pipeline(transpile,compile,sign) → verify(println("ok"))
//
// @invariant I1 pass-by-value          test: grep -nE '^\s+\w+\.push\(' self/hexa_full.hexa → ∅
// @invariant I2 Ident.name             test: grep -nE 'env_lookup\(\w+\.value\)' self/hexa_full.hexa → ∅
// @invariant I3 host_args=raw[1..]     test: grep -A2 'fn host_args' | grep 'let mut i = 1' → 1
// @invariant I4 binary=gitignored      test: git check-ignore build/hexa_interp → 0
//
// @pipeline rebuild:
//   exec: self/native/hexa_v2 self/hexa_full.hexa /tmp/hexa_full_regen.c
//   exec: clang -O2 -std=c11 -Wno-trigraphs -I self -o build/hexa_interp /tmp/hexa_full_regen.c
//   exec: codesign --force --sign - build/hexa_interp
//   verify: echo 'println("ok")' > /tmp/_hx.hexa && build/hexa_interp /tmp/_hx.hexa == "ok"
//
// @on_edit: update self/hexa_full.json.evolution[] append {commit, date, event, verdict}
// @on_new_bug: append self/hexa_full.json.invariants[] or .known_gaps[]
// @on_verdict_pass: bump self/hexa_full.json.state.ossification_pct

// ── T1 Phase B: runtime core 분리 (proof/fuse/match/stack 22 fns) ──
// runtime_core.hexa 는 hexa_v2 가 `use` 디렉티브를 silent-drop 하므로
// tool/build_interp.hexa 의 flatten 단계가 파일들을 하나로 합친 뒤 transpile 한다.
use "runtime_core"

// ── P4 self-host: codegen_c2 AOT compiler ──────────────────────
// codegen_c2.hexa 를 포함하여 `--compile` CLI 로 .hexa → .c 변환 가능.
// flatten_imports 가 이 use 디렉티브를 resolve 한다.
use "codegen_c2"

// ── rt#36-D bridge: bc_emitter + bc_vm for `hexa run --vm ...` ──
// flatten_imports.hexa 가 토포 정렬로 self/bc_emitter.hexa + self/bc_vm.hexa
// 의 정의들을 interp 번들에 포함시킨다. HEXA_VM 환경변수가 "1" 이면 parse
// 직후 interpret() 대신 ast_to_bc_walk_root → bc_compile_root → bc_vm_run()
// 경로로 라우팅된다. (See entry-point block at EOF.)
use "bc_emitter"
use "bc_vm"

// ── pure runtime modules (self/runtime/*_pure.hexa) ──────────────
// Zero-C, self-hosted stdlib. flatten_imports resolves these from self/runtime/.
use "runtime/math_pure"
use "runtime/string_pure"
use "runtime/bit_pure"
use "runtime/value_pure"
use "runtime/array_pure"
use "runtime/array_higher_pure"
use "runtime/conv_pure"
use "runtime/map_pure"
use "runtime/parse_pure"
use "runtime/hex_pure"
use "runtime/format_pure"
use "runtime/hash_pure"
use "runtime/path_pure"
use "runtime/url_pure"
use "runtime/base64_pure"
use "runtime/bitset_pure"
use "runtime/cmp_pure"
use "runtime/crc32_pure"
use "runtime/datetime_pure"
use "runtime/file_pure"
use "runtime/range_pure"
use "runtime/ipv4_pure"
use "runtime/arena_pure"

// ── T3 Phase A: declarative @invariant DSL (replaces shell-grep above) ──
// 위 주석형 invariant 는 R1 (보존 우선) 으로 그대로 유지하되, 본 phase 에서는
// AST 기반 checker 가 인식하는 정식 InvariantDecl 노드로 I1 을 병기한다.
// I2~I4 는 다음 phase 에서 동일 패턴으로 추가 예정 (현재는 stub 만 정의 가능).
// 검증: `./hexa check self/hexa_full.hexa` → 0 violation 기대.
@invariant {
    id: "I1",
    name: "pass_by_value",
    predicate: "deny_method",
    pattern: { target: "push", context: "statement" },
    exempt: []
}

struct Token {
    kind: string,
    value: string,
    line: int,
    col: int
}

// Check if a word is one of the 56 HEXA keywords (sigma*tau+sopfr+3) + import alias
fn is_keyword(word) {
    if word == "if" { return true }
    if word == "else" { return true }
    if word == "match" { return true }
    if word == "for" { return true }
    if word == "while" { return true }
    if word == "loop" { return true }
    if word == "type" { return true }
    if word == "struct" { return true }
    if word == "enum" { return true }
    if word == "trait" { return true }
    if word == "impl" { return true }
    if word == "fn" { return true }
    if word == "return" { return true }
    if word == "yield" { return true }
    if word == "async" { return true }
    if word == "await" { return true }
    if word == "let" { return true }
    if word == "mut" { return true }
    if word == "const" { return true }
    if word == "static" { return true }
    if word == "mod" { return true }
    if word == "use" { return true }
    if word == "import" { return true }
    if word == "pub" { return true }
    if word == "crate" { return true }
    if word == "own" { return true }
    if word == "borrow" { return true }
    if word == "move" { return true }
    if word == "drop" { return true }
    if word == "spawn" { return true }
    if word == "channel" { return true }
    if word == "select" { return true }
    if word == "atomic" { return true }
    if word == "effect" { return true }
    if word == "handle" { return true }
    if word == "resume" { return true }
    if word == "pure" { return true }
    if word == "proof" { return true }
    if word == "assert" { return true }
    if word == "invariant" { return true }
    if word == "theorem" { return true }
    if word == "macro" { return true }
    if word == "derive" { return true }
    if word == "where" { return true }
    if word == "comptime" { return true }
    if word == "try" { return true }
    if word == "catch" { return true }
    if word == "throw" { return true }
    if word == "panic" { return true }
    if word == "recover" { return true }
    if word == "intent" { return true }
    if word == "generate" { return true }
    if word == "verify" { return true }
    if word == "optimize" { return true }
    if word == "extern" { return true }
    if word == "break" { return true }
    if word == "continue" { return true }
    if word == "dyn" { return true }
    if word == "scope" { return true }
    if word == "in" { return true }
    if word == "do" { return true }
    if word == "defer" { return true }
    if word == "typeof" { return true }
    if word == "guard" { return true }
    if word == "with" { return true }
    if word == "as" { return true }
    return false
}

// ── ROI-18: keyword_kind direct lookup table ──
// Replaces is_keyword() call + per-char capitalize (N+3 allocs per token)
// with a single direct string return (0 allocs).
fn keyword_kind(word) {
    if word == "true" { return "BoolLit" }
    if word == "false" { return "BoolLit" }
    if word == "import" { return "Use" }
    if word == "if" { return "If" }
    if word == "else" { return "Else" }
    if word == "match" { return "Match" }
    if word == "for" { return "For" }
    if word == "while" { return "While" }
    if word == "loop" { return "Loop" }
    if word == "type" { return "Type" }
    if word == "struct" { return "Struct" }
    if word == "enum" { return "Enum" }
    if word == "trait" { return "Trait" }
    if word == "impl" { return "Impl" }
    if word == "fn" { return "Fn" }
    if word == "return" { return "Return" }
    if word == "yield" { return "Yield" }
    if word == "async" { return "Async" }
    if word == "await" { return "Await" }
    if word == "let" { return "Let" }
    if word == "mut" { return "Mut" }
    if word == "const" { return "Const" }
    if word == "static" { return "Static" }
    if word == "mod" { return "Mod" }
    if word == "use" { return "Use" }
    if word == "pub" { return "Pub" }
    if word == "crate" { return "Crate" }
    if word == "own" { return "Own" }
    if word == "borrow" { return "Borrow" }
    if word == "move" { return "Move" }
    if word == "drop" { return "Drop" }
    if word == "spawn" { return "Spawn" }
    if word == "channel" { return "Channel" }
    if word == "select" { return "Select" }
    if word == "atomic" { return "Atomic" }
    if word == "effect" { return "Effect" }
    if word == "handle" { return "Handle" }
    if word == "resume" { return "Resume" }
    if word == "pure" { return "Pure" }
    if word == "proof" { return "Proof" }
    if word == "assert" { return "Assert" }
    if word == "invariant" { return "Invariant" }
    if word == "theorem" { return "Theorem" }
    if word == "macro" { return "Macro" }
    if word == "derive" { return "Derive" }
    if word == "where" { return "Where" }
    if word == "comptime" { return "Comptime" }
    if word == "try" { return "Try" }
    if word == "catch" { return "Catch" }
    if word == "throw" { return "Throw" }
    if word == "panic" { return "Panic" }
    if word == "recover" { return "Recover" }
    if word == "intent" { return "Intent" }
    if word == "generate" { return "Generate" }
    if word == "verify" { return "Verify" }
    if word == "optimize" { return "Optimize" }
    if word == "extern" { return "Extern" }
    if word == "break" { return "Break" }
    if word == "continue" { return "Continue" }
    if word == "dyn" { return "Dyn" }
    if word == "scope" { return "Scope" }
    if word == "in" { return "In" }
    if word == "do" { return "Do" }
    if word == "defer" { return "Defer" }
    if word == "typeof" { return "Typeof" }
    if word == "guard" { return "Guard" }
    if word == "with" { return "With" }
    if word == "as" { return "As" }
    return "Ident"
}

// Check if character is valid identifier start (alpha or _)
fn is_ident_start(ch) {
    if is_alpha(ch) { return true }
    if ch == '_' { return true }
    return false
}

// Check if character is valid identifier continuation (alphanumeric or _)
fn is_ident_char(ch) {
    if is_alphanumeric(ch) { return true }
    if ch == '_' { return true }
    return false
}

// Check if character is a hex digit (0-9, a-f, A-F)
fn is_hex_digit(ch) {
    if is_digit(ch) { return true }
    if ch == 'a' || ch == 'b' || ch == 'c' || ch == 'd' || ch == 'e' || ch == 'f' { return true }
    if ch == 'A' || ch == 'B' || ch == 'C' || ch == 'D' || ch == 'E' || ch == 'F' { return true }
    return false
}

// chars array slice → string (avoids per-char push + join)
fn slice_str(cs, a, b) {
    let mut parts = []
    let mut k = a
    while k < b {
        parts.push("" + cs[k])
        k = k + 1
    }
    return parts.join("")
}

// Main tokenizer function
fn tokenize(source) {
    let mut tokens = []
    let chars = source.chars()
    let mut pos = 0
    let mut line = 1
    let mut col = 1
    let total = len(chars)
    let mut paren_depth = 0

    // 2026-04-26 silent-failure-enforcement Class 3 — POSIX shebang skip.
    // Mirror self/lexer.hexa line 138-145. The hexa_v2 transpile path already
    // has this; the interp tolerated `#!hexa strict` as comment-like via the
    // standalone-`#` skip arm but our new mid-file `#!` hard-fail (line ~870)
    // would misfire on any first-line shebang without this pre-skip.
    if total >= 2 && chars[0] == '#' && chars[1] == '!' {
        while pos < total && chars[pos] != '\n' {
            pos = pos + 1
            col = col + 1
        }
    }

    while pos < total {
        let ch = chars[pos]

        // Skip whitespace (not newlines)
        if ch == ' ' || ch == '\t' || ch == '\r' {
            pos = pos + 1
            col = col + 1
            // Continue to next iteration
        } else if ch == '\n' {
            // Newline token — suppressed inside () and []
            if paren_depth == 0 {
                tokens.push(Token { kind: "Newline", value: "\n", line: line, col: col })
            }
            pos = pos + 1
            line = line + 1
            col = 1
        } else if ch == '/' && pos + 1 < total && chars[pos + 1] == '/' {
            // Line comment — skip until newline
            pos = pos + 2
            col = col + 2
            while pos < total && chars[pos] != '\n' {
                pos = pos + 1
                col = col + 1
            }
        } else if ch == '/' && pos + 1 < total && chars[pos + 1] == '*' {
            // Block comment (supports nesting)
            pos = pos + 2
            col = col + 2
            let mut depth = 1
            while depth > 0 && pos < total {
                if pos + 1 < total && chars[pos] == '/' && chars[pos + 1] == '*' {
                    depth = depth + 1
                    pos = pos + 2
                    col = col + 2
                } else if pos + 1 < total && chars[pos] == '*' && chars[pos + 1] == '/' {
                    depth = depth - 1
                    pos = pos + 2
                    col = col + 2
                } else if chars[pos] == '\n' {
                    pos = pos + 1
                    line = line + 1
                    col = 1
                } else {
                    pos = pos + 1
                    col = col + 1
                }
            }
        } else if is_ident_start(ch) {
            // Identifier or keyword
            let start_col = col
            let start_pos = pos
            while pos < total && is_ident_char(chars[pos]) {
                pos = pos + 1
                col = col + 1
            }
            let word = slice_str(chars, start_pos, pos)
            let kind = keyword_kind(word)
            tokens.push(Token { kind: kind, value: word, line: line, col: start_col })
        } else if is_digit(ch) {
            // Number literal — integer, float, or hex (0x)
            // Underscore separators: 1_000_000 -> 1000000, 0xFF_FF -> 0xFFFF
            // Rules: _ only between digits, no leading/trailing _, no consecutive __
            let start_col = col
            let mut num_parts = []
            let mut is_float = false
            let mut is_hex = false

            // Check for hex prefix 0x / 0X
            if ch == '0' && pos + 1 < total && (chars[pos + 1] == 'x' || chars[pos + 1] == 'X') {
                is_hex = true
                num_parts.push("0x")
                pos = pos + 2
                col = col + 2
                // Collect hex digits; accept _ only between hex digits (lookahead)
                while pos < total && is_hex_digit(chars[pos]) {
                    num_parts.push(to_string(chars[pos]))
                    pos = pos + 1
                    col = col + 1
                    // After a hex digit, consume a single _ if followed by another hex digit
                    if pos < total && chars[pos] == '_' {
                        if pos + 1 < total && is_hex_digit(chars[pos + 1]) {
                            // Valid separator — skip _ and let loop consume next digit
                            pos = pos + 1
                            col = col + 1
                        }
                        // else: trailing _ or __ — stop; _ left for next token
                    }
                }
            } else {
                // Decimal integer part: collect digits; accept _ only between digits
                while pos < total && is_digit(chars[pos]) {
                    num_parts.push(to_string(chars[pos]))
                    pos = pos + 1
                    col = col + 1
                    // After a digit, consume a single _ if followed by another digit
                    if pos < total && chars[pos] == '_' {
                        if pos + 1 < total && is_digit(chars[pos + 1]) {
                            pos = pos + 1
                            col = col + 1
                        }
                    }
                }
                // Check for decimal point (not range ..)
                if pos < total && chars[pos] == '.' {
                    if pos + 1 < total && is_digit(chars[pos + 1]) {
                        // It's a float: consume . and fractional digits
                        is_float = true
                        num_parts.push(".")
                        pos = pos + 1
                        col = col + 1
                        while pos < total && is_digit(chars[pos]) {
                            num_parts.push(to_string(chars[pos]))
                            pos = pos + 1
                            col = col + 1
                            // After a digit, consume a single _ if followed by another digit
                            if pos < total && chars[pos] == '_' {
                                if pos + 1 < total && is_digit(chars[pos + 1]) {
                                    pos = pos + 1
                                    col = col + 1
                                }
                            }
                        }
                    }
                }
                // Scientific notation: e/E [+-]? digits (1e10, 1e-5, 1.5e+3)
                if pos < total && (chars[pos] == 'e' || chars[pos] == 'E') {
                    let mut ep = pos + 1
                    if ep < total && (chars[ep] == '+' || chars[ep] == '-') { ep = ep + 1 }
                    if ep < total && is_digit(chars[ep]) {
                        is_float = true
                        num_parts.push(to_string(chars[pos]))
                        pos = pos + 1
                        col = col + 1
                        if pos < total && (chars[pos] == '+' || chars[pos] == '-') {
                            num_parts.push(to_string(chars[pos]))
                            pos = pos + 1
                            col = col + 1
                        }
                        while pos < total && is_digit(chars[pos]) {
                            num_parts.push(to_string(chars[pos]))
                            pos = pos + 1
                            col = col + 1
                        }
                    }
                }
            }
            let num_str = join(num_parts, "")
            if is_float {
                tokens.push(Token { kind: "FloatLit", value: num_str, line: line, col: start_col })
            } else {
                tokens.push(Token { kind: "IntLit", value: num_str, line: line, col: start_col })
            }
        } else if ch == '"' {
            // String literal — check for triple-quote """
            let start_col = col
            if pos + 2 < total && chars[pos + 1] == '"' && chars[pos + 2] == '"' {
                // Triple-quoted multiline string
                pos = pos + 3
                col = col + 3
                // Skip optional leading newline after opening """
                if pos < total && chars[pos] == '\n' {
                    pos = pos + 1
                    line = line + 1
                    col = 1
                } else if pos < total && chars[pos] == '\r' && pos + 1 < total && chars[pos + 1] == '\n' {
                    pos = pos + 2
                    line = line + 1
                    col = 1
                }
                let mut ts_parts = []
                let mut ts_done = false
                while pos < total && !ts_done {
                    if pos + 2 < total && chars[pos] == '"' && chars[pos + 1] == '"' && chars[pos + 2] == '"' {
                        ts_done = true
                        pos = pos + 3
                        col = col + 3
                    } else {
                        let tc = chars[pos]
                        ts_parts.push(to_string(tc))
                        pos = pos + 1
                        if tc == '\n' {
                            line = line + 1
                            col = 1
                        } else {
                            col = col + 1
                        }
                    }
                }
                let ts = join(ts_parts, "")
                tokens.push(Token { kind: "StringLit", value: ts, line: line, col: start_col })
            } else {
                // Regular string literal
                pos = pos + 1
                col = col + 1
                let mut s_parts = []
                let mut done = false
                while pos < total && !done {
                    let c = chars[pos]
                    if c == '"' {
                        done = true
                        pos = pos + 1
                        col = col + 1
                    } else if c == '\\' {
                        pos = pos + 1
                        col = col + 1
                        if pos < total {
                            let esc = chars[pos]
                            if esc == 'n' { s_parts.push("\n") }
                            else if esc == 't' { s_parts.push("\t") }
                            else if esc == 'r' { s_parts.push("\r") }
                            else if esc == '\\' { s_parts.push("\\") }
                            else if esc == '"' { s_parts.push("\"") }
                            else if esc == '0' { s_parts.push("\0") }
                            else { s_parts.push(to_string(esc)) }
                            pos = pos + 1
                            col = col + 1
                        }
                    } else {
                        s_parts.push(to_string(c))
                        pos = pos + 1
                        if c == '\n' {
                            line = line + 1
                            col = 1
                        } else {
                            col = col + 1
                        }
                    }
                }
                let s = join(s_parts, "")
                tokens.push(Token { kind: "StringLit", value: s, line: line, col: start_col })
            }
        } else if ch == '\'' {
            let start_col = col
            // Check for label: 'ident where ident is >=2 chars or followed by ':'
            // Labels: 'outer  (used with labeled break/continue)
            // Char literals: 'x' or '\n'
            let mut is_label = false
            if pos + 1 < total && is_ident_start(chars[pos + 1]) {
                // Peek ahead to see if this is a multi-char ident (label) or char lit
                let mut peek_pos = pos + 1
                while peek_pos < total && is_ident_char(chars[peek_pos]) {
                    peek_pos = peek_pos + 1
                }
                let ident_len = peek_pos - pos - 1
                if ident_len > 1 {
                    // Multi-char ident after ' → label (e.g. 'outer)
                    is_label = true
                } else if peek_pos < total && chars[peek_pos] != '\'' {
                    // Single-char ident NOT followed by closing ' → label
                    is_label = true
                }
            }
            if is_label {
                // Label token: 'identifier
                pos = pos + 1  // skip '
                col = col + 1
                let start_pos = pos
                while pos < total && is_ident_char(chars[pos]) {
                    pos = pos + 1
                    col = col + 1
                }
                let label_name = slice_str(chars, start_pos, pos)
                tokens.push(Token { kind: "Label", value: label_name, line: line, col: start_col })
            } else {
                // Char literal
                pos = pos + 1
                col = col + 1
                let mut ch_val = ""
                if pos < total && chars[pos] == '\\' {
                    pos = pos + 1
                    col = col + 1
                    if pos < total {
                        let esc = chars[pos]
                        if esc == 'n' { ch_val = "\n" }
                        else if esc == 't' { ch_val = "\t" }
                        else if esc == 'r' { ch_val = "\r" }
                        else if esc == '\\' { ch_val = "\\" }
                        else if esc == '\'' { ch_val = "'" }
                        else if esc == '0' { ch_val = "\0" }
                        else { ch_val = to_string(esc) }
                        pos = pos + 1
                        col = col + 1
                    }
                } else if pos < total {
                    ch_val = to_string(chars[pos])
                    pos = pos + 1
                    col = col + 1
                }
                // Consume closing quote
                if pos < total && chars[pos] == '\'' {
                    pos = pos + 1
                    col = col + 1
                }
                tokens.push(Token { kind: "CharLit", value: ch_val, line: line, col: start_col })
            }
        } else {
            // Operators and delimiters
            let start_col = col
            if ch == '+' {
                if pos + 1 < total && chars[pos + 1] == '=' {
                    tokens.push(Token { kind: "PlusEq", value: "+=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens.push(Token { kind: "Plus", value: "+", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '-' {
                if pos + 1 < total && chars[pos + 1] == '>' {
                    tokens.push(Token { kind: "Arrow", value: "->", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else if pos + 1 < total && chars[pos + 1] == '=' {
                    tokens.push(Token { kind: "MinusEq", value: "-=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens.push(Token { kind: "Minus", value: "-", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '*' {
                if pos + 1 < total && chars[pos + 1] == '*' {
                    tokens.push(Token { kind: "Power", value: "**", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else if pos + 1 < total && chars[pos + 1] == '=' {
                    tokens.push(Token { kind: "StarEq", value: "*=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens.push(Token { kind: "Star", value: "*", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '/' {
                if pos + 1 < total && chars[pos + 1] == '=' {
                    tokens.push(Token { kind: "SlashEq", value: "/=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens.push(Token { kind: "Slash", value: "/", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '%' {
                if pos + 1 < total && chars[pos + 1] == '=' {
                    tokens.push(Token { kind: "PercentEq", value: "%=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens.push(Token { kind: "Percent", value: "%", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '=' {
                if pos + 1 < total && chars[pos + 1] == '=' {
                    tokens.push(Token { kind: "EqEq", value: "==", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else if pos + 1 < total && chars[pos + 1] == '>' {
                    tokens.push(Token { kind: "FatArrow", value: "=>", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens.push(Token { kind: "Eq", value: "=", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '!' {
                if pos + 1 < total && chars[pos + 1] == '=' {
                    tokens.push(Token { kind: "NotEq", value: "!=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens.push(Token { kind: "Not", value: "!", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '<' {
                if pos + 1 < total && chars[pos + 1] == '=' {
                    tokens.push(Token { kind: "LtEq", value: "<=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else if pos + 1 < total && chars[pos + 1] == '<' {
                    tokens.push(Token { kind: "Shl", value: "<<", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens.push(Token { kind: "Lt", value: "<", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '>' {
                if pos + 1 < total && chars[pos + 1] == '=' {
                    tokens.push(Token { kind: "GtEq", value: ">=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else if pos + 1 < total && chars[pos + 1] == '>' {
                    tokens.push(Token { kind: "Shr", value: ">>", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens.push(Token { kind: "Gt", value: ">", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '&' {
                if pos + 1 < total && chars[pos + 1] == '&' {
                    if pos + 2 < total && chars[pos + 2] == '=' {
                        tokens.push(Token { kind: "AndAssign", value: "&&=", line: line, col: start_col })
                        pos = pos + 3
                        col = col + 3
                    } else {
                        tokens.push(Token { kind: "And", value: "&&", line: line, col: start_col })
                        pos = pos + 2
                        col = col + 2
                    }
                } else {
                    tokens.push(Token { kind: "BitAnd", value: "&", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '|' {
                if pos + 1 < total && chars[pos + 1] == '|' {
                    if pos + 2 < total && chars[pos + 2] == '=' {
                        tokens.push(Token { kind: "OrAssign", value: "||=", line: line, col: start_col })
                        pos = pos + 3
                        col = col + 3
                    } else {
                        tokens.push(Token { kind: "Or", value: "||", line: line, col: start_col })
                        pos = pos + 2
                        col = col + 2
                    }
                } else {
                    tokens.push(Token { kind: "BitOr", value: "|", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '^' {
                if pos + 1 < total && chars[pos + 1] == '^' {
                    tokens.push(Token { kind: "Xor", value: "^^", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens.push(Token { kind: "BitXor", value: "^", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '~' {
                tokens.push(Token { kind: "BitNot", value: "~", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == '?' {
                if pos + 1 < total && chars[pos + 1] == '?' {
                    // `??=` must greedy-match here — later dead branch (line
                    // 841ish) emits NullCoalescingAssign but is unreachable
                    // because this `?` arm fires first. Without the `=` peek
                    // the lexer tokenizes `a ??= x` as NullCoal + Eq + …,
                    // causing "unexpected token Eq" parse error.
                    if pos + 2 < total && chars[pos + 2] == '=' {
                        tokens.push(Token { kind: "NullCoalescingAssign", value: "??=", line: line, col: start_col })
                        pos = pos + 3
                        col = col + 3
                    } else {
                        tokens.push(Token { kind: "NullCoal", value: "??", line: line, col: start_col })
                        pos = pos + 2
                        col = col + 2
                    }
                } else {
                    tokens.push(Token { kind: "Question", value: "?", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '@' {
                // AI-native attribute marker (M0)
                tokens.push(Token { kind: "At", value: "@", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == ':' {
                if pos + 1 < total && chars[pos + 1] == '=' {
                    tokens.push(Token { kind: "ColonEq", value: ":=", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else if pos + 1 < total && chars[pos + 1] == ':' {
                    tokens.push(Token { kind: "ColonColon", value: "::", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens.push(Token { kind: "Colon", value: ":", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '.' {
                if pos + 2 < total && chars[pos + 1] == '.' && chars[pos + 2] == '.' {
                    // G8: spread operator `...` — must check 3 dots before 2-dot range
                    tokens.push(Token { kind: "DotDotDot", value: "...", line: line, col: start_col })
                    pos = pos + 3
                    col = col + 3
                } else if pos + 1 < total && chars[pos + 1] == '.' {
                    if pos + 2 < total && chars[pos + 2] == '=' {
                        tokens.push(Token { kind: "DotDotEq", value: "..=", line: line, col: start_col })
                        pos = pos + 3
                        col = col + 3
                    } else {
                        tokens.push(Token { kind: "DotDot", value: "..", line: line, col: start_col })
                        pos = pos + 2
                        col = col + 2
                    }
                } else {
                    tokens.push(Token { kind: "Dot", value: ".", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '(' {
                tokens.push(Token { kind: "LParen", value: "(", line: line, col: start_col })
                paren_depth = paren_depth + 1
                pos = pos + 1
                col = col + 1
            } else if ch == ')' {
                tokens.push(Token { kind: "RParen", value: ")", line: line, col: start_col })
                if paren_depth > 0 { paren_depth = paren_depth - 1 }
                pos = pos + 1
                col = col + 1
            } else if ch == '{' {
                tokens.push(Token { kind: "LBrace", value: "{", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == '}' {
                tokens.push(Token { kind: "RBrace", value: "}", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == '[' {
                tokens.push(Token { kind: "LBracket", value: "[", line: line, col: start_col })
                paren_depth = paren_depth + 1
                pos = pos + 1
                col = col + 1
            } else if ch == ']' {
                tokens.push(Token { kind: "RBracket", value: "]", line: line, col: start_col })
                if paren_depth > 0 { paren_depth = paren_depth - 1 }
                pos = pos + 1
                col = col + 1
            } else if ch == ',' {
                tokens.push(Token { kind: "Comma", value: ",", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == ';' {
                tokens.push(Token { kind: "Semicolon", value: ";", line: line, col: start_col })
                pos = pos + 1
                col = col + 1
            } else if ch == '?' {
                // Optional chaining: ?.
                if pos + 1 < total && chars[pos + 1] == '.' {
                    tokens.push(Token { kind: "QuestionDot", value: "?.", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else {
                    tokens.push(Token { kind: "Question", value: "?", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '@' {
                // Attribute token: @name
                pos = pos + 1
                col = col + 1
                let start_pos = pos
                while pos < total && is_ident_char(chars[pos]) {
                    pos = pos + 1
                    col = col + 1
                }
                let attr_name = slice_str(chars, start_pos, pos)
                tokens.push(Token { kind: "Attribute", value: attr_name, line: line, col: start_col })
            } else if ch == '?' {
                if pos + 1 < total && chars[pos + 1] == '?' {
                    if pos + 2 < total && chars[pos + 2] == '=' {
                        tokens.push(Token { kind: "NullCoalescingAssign", value: "??=", line: line, col: start_col })
                        pos = pos + 3
                        col = col + 3
                    } else {
                        tokens.push(Token { kind: "NullCoalescing", value: "??", line: line, col: start_col })
                        pos = pos + 2
                        col = col + 2
                    }
                } else {
                    tokens.push(Token { kind: "Question", value: "?", line: line, col: start_col })
                    pos = pos + 1
                    col = col + 1
                }
            } else if ch == '#' {
                // Map literal: #{...}
                if pos + 1 < total && chars[pos + 1] == '{' {
                    tokens.push(Token { kind: "HashLBrace", value: "#{", line: line, col: start_col })
                    pos = pos + 2
                    col = col + 2
                } else if pos + 1 < total && chars[pos + 1] == '!' {
                    // 2026-04-26 silent-failure-enforcement Class 3 (interp lexer):
                    // mid-file `#!hexa …` shebang. The first-line shebang is
                    // consumed by the pre-loop POSIX skip. Reaching this branch
                    // means line >1 — typical cause: bad sed insert. Without
                    // this hard-fail the previous behavior was: `#` skipped
                    // silently → `!` tokenized → `hexa` ident → cryptic error.
                    println("error: shebang `#!` must be on line 1 of the file; found at line " + to_string(line) + ":" + to_string(start_col))
                    println("hint: remove the shebang OR move it to the very first line")
                    println("ref: silent-failure-enforcement Class 3 (doc/audit/silent_failure_enforcement_audit.md)")
                    exit(1)
                } else {
                    // Standalone # — skip
                    pos = pos + 1
                    col = col + 1
                }
            } else {
                // Unknown character — skip
                pos = pos + 1
                col = col + 1
            }
        }
    }

    // Add EOF token
    tokens.push(Token { kind: "Eof", value: "", line: line, col: col })
    return tokens
}

// Count tokens by kind
fn count_kind(tokens, kind) {
    let mut count = 0
    for t in tokens {
        if t.kind == kind {
            count = count + 1
        }
    }
    return count
}
// self/parser.hexa — HEXA parser written in HEXA (Stage 2 of self-hosting)
// Recursive descent parser: tokens -> AST (represented as structs)
// Covers: let, const, static, fn, if/else, while, for, loop, return,
//   struct, enum, match, try/catch, throw, panic, drop, spawn, scope,
//   select, async fn, extern fn, type alias, atomic let, lambda,
//   type params <T>, where clauses, break, continue, yield,
//   comptime (fn/const/let/assert/block), intent, verify, generate,
//   optimize, effect, pure fn, macro!, derive, theorem, handle/with,
//   guard, guard let, with/as, walrus :=
//   — 49 parse functions, full self-hosting coverage.

// ══════════════════════════════════════════════════════════════
// AST Node types — represented as simple structs
// ══════════════════════════════════════════════════════════════
// We use a uniform AstNode struct with a "kind" discriminator.
// Fields that don't apply to a given kind are set to "" or [].
//
// Kinds:
//   Statements: LetStmt, ConstStmt, StaticStmt, FnDecl, StructDecl,
//               EnumDecl, ForStmt, WhileStmt, LoopStmt, ReturnStmt,
//               AssignStmt, ExprStmt, MatchStmt, ImplBlock, TraitDecl,
//               ProofStmt, AssertStmt, UseStmt, ModStmt,
//               TryCatch, ThrowStmt, PanicStmt, DropStmt,
//               SpawnStmt, ScopeStmt, SelectStmt,
//               AsyncFnDecl, ExternFnDecl, TypeAlias, AtomicLet,
//               BreakStmt, ContinueStmt, YieldStmt, DoWhileStmt,
//               ForElseStmt, DeferStmt,
//               ComptimeFnDecl, ComptimeConst, ComptimeLet,
//               ComptimeBlock, ComptimeAssert,
//               IntentStmt, VerifyStmt, GenerateFnStmt, GenerateStmt,
//               OptimizeFnStmt, EffectDecl, PureFnDecl,
//               MacroDef, DeriveDecl, TheoremStmt, HandleWithStmt,
//               DestructLetStmt, MapDestructLetStmt,
//               GuardStmt, GuardLetStmt, WithStmt
//   Expressions: IntLit, FloatLit, BoolLit, StringLit, CharLit,
//                Ident, BinOp, UnaryOp, Call, Field, Index,
//                IfExpr, MatchExpr, Array, StructInit, Range,
//                EnumPath, Block, Lambda, Wildcard, Tuple, Spread,
//                WalrusExpr

// ══════════════════════════════════════════════════════════════
// Token struct (same as lexer.hexa)
// ══════════════════════════════════════════════════════════════


// ══════════════════════════════════════════════════════════════
// AstNode — universal node type
// ══════════════════════════════════════════════════════════════
// Using separate fields for different data shapes.
// "kind" determines which fields are meaningful.

// AstNode is now a Map (#{...}) instead of struct — fixes deep copy issues

// ══════════════════════════════════════════════════════════════
// Node constructors — each returns an AstNode
// ══════════════════════════════════════════════════════════════

// Empty node for defaults
fn empty_node() {
    return #{
        "kind": "", "name": "", "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

fn node_int_lit(val) {
    let n = empty_node()
    // We can't mutate struct fields, so rebuild
    return #{
        "kind": "IntLit", "name": "", "value": val, "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

fn node_float_lit(val) {
    return #{
        "kind": "FloatLit", "name": "", "value": val, "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

fn node_bool_lit(val) {
    return #{
        "kind": "BoolLit", "name": "", "value": val, "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

fn node_string_lit(val) {
    return #{
        "kind": "StringLit", "name": "", "value": val, "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

fn node_char_lit(val) {
    return #{
        "kind": "CharLit", "name": "", "value": val, "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

fn node_ident(name) {
    return #{
        "kind": "Ident", "name": name, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

fn node_wildcard() {
    return #{
        "kind": "Wildcard", "name": "_", "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ══════════════════════════════════════════════════════════════
// Parser state — module-level mutable variables
// Since HEXA doesn't support struct field mutation,
// we use module-level variables that all parse_* functions share.
// ══════════════════════════════════════════════════════════════

// NOTE: These are declared `pub let mut` so that the self-interpreter's
// module loader (src/interpreter.rs exec_use) injects them into the
// importer's scope. Without `pub`, the module scope is popped after load
// and callers get "undefined variable: p_tokens" when invoking parse().
// See sprint commit: fix(self/parser): expose module state via pub let mut.
pub let mut p_tokens = []
pub let mut p_pos = 0
pub let mut p_pending_symbol = ""   // @symbol("name") — pending C symbol alias
pub let mut p_pending_link = ""     // @link("lib") — pending library name
// M0: AI-native @attr accumulator — parse_stmt fills this, parse_fn_decl consumes
pub let mut p_pending_attrs = ""
// M0+: AI-native typed annotations with raw-arg capture
// Elements serialized as "kind|raw_arg_tokens". Filled by parse_stmt's
// @attr loop when attr_name is one of: cli, flag, doc, schema, gate, memo.
// Consumed by parse_fn_decl / parse_async_fn and written to FnDecl.annotations.
pub let mut p_pending_annotations = []
// @contract desugar: pending requires/ensures AST expressions
// Filled by parse_stmt's @attr loop when attr_name == "contract"
// Consumed by parse_fn_decl → injected as ContractAssert nodes
pub let mut p_pending_contract_requires = ""   // AST expr or ""
pub let mut p_pending_contract_ensures = ""    // AST expr or ""
pub let mut p_pending_contract_req_text = ""   // source text for error msg
pub let mut p_pending_contract_ens_text = ""   // source text for error msg
// Struct literal disambiguation: when set, `Name {` is NOT parsed as
// struct literal (used inside if/while/match conditions where `{` is body).
pub let mut p_suppress_struct_lit = false

// ── I1: Error Recovery ─────────────────────────────────────
// Collect all parse errors instead of halting on the first one.
// p_errors: list of #{line, col, message} maps
// p_max_errors: stop collecting after this many (avoid runaway)
pub let mut p_errors = []
pub let mut p_max_errors = 50
// HX-parse-dedup: suppress consecutive identical prints.
pub let mut p_last_err_key = ""

fn p_record_error(line, col, message) {
    if len(p_errors) < p_max_errors {
        p_errors.push(#{"line": line, "col": col, "message": message})
    }
}

fn p_emit_parse_error(tok, msg) {
    let key = to_string(tok.line) + ":" + to_string(tok.col) + ":" + msg
    if key == p_last_err_key { return 0 }
    p_last_err_key = key
    println("Parse error at " + to_string(tok.line) + ":" + to_string(tok.col) + ": " + msg)
    return 1
}

fn p_synchronize() {
    // Skip tokens until we reach a likely statement boundary.
    // Synchronization points: newlines followed by a keyword, or Eof.
    while !p_at_end() {
        let cur = p_peek()
        // If we hit a newline, check if next token starts a statement
        if cur.kind == "Newline" {
            p_advance()
            let next = p_peek()
            if next.kind == "Let" { return true }
            if next.kind == "Const" { return true }
            if next.kind == "Static" { return true }
            if next.kind == "Fn" { return true }
            if next.kind == "Struct" { return true }
            if next.kind == "Enum" { return true }
            if next.kind == "For" { return true }
            if next.kind == "While" { return true }
            if next.kind == "Loop" { return true }
            if next.kind == "Do" { return true }
            if next.kind == "Defer" { return true }
            if next.kind == "Return" { return true }
            if next.kind == "If" { return true }
            if next.kind == "Match" { return true }
            if next.kind == "Impl" { return true }
            if next.kind == "Trait" { return true }
            if next.kind == "Use" { return true }
            if next.kind == "Mod" { return true }
            if next.kind == "Try" { return true }
            if next.kind == "Assert" { return true }
            if next.kind == "Proof" { return true }
            if next.kind == "At" { return true }
            if next.kind == "Eof" { return true }
            // keep skipping
        } else {
            p_advance()
        }
    }
    return false
}

fn p_get_errors() {
    return p_errors
}

fn p_has_errors() {
    return len(p_errors) > 0
}

fn p_error_count() {
    return len(p_errors)
}

fn p_format_errors() {
    let mut lines = []
    let mut i = 0
    while i < len(p_errors) {
        let e = p_errors[i]
        lines.push("  error[" + to_string(i + 1) + "] " + to_string(e.line) + ":" + to_string(e.col) + " — " + e.message)
        i = i + 1
    }
    return lines.join("\n")
}

// ── Helpers ─────────────────────────────────────────────────

fn p_peek() {
    if p_pos >= len(p_tokens) {
        return Token { kind: "Eof", value: "", line: 0, col: 0 }
    }
    return p_tokens[p_pos]
}

fn p_peek_kind() {
    return p_peek().kind
}

fn p_peek_ahead(offset) {
    let idx = p_pos + offset
    if idx >= len(p_tokens) {
        return Token { kind: "Eof", value: "", line: 0, col: 0 }
    }
    return p_tokens[idx]
}

fn p_at_end() {
    return p_peek_kind() == "Eof"
}

fn p_advance() {
    let tok = p_peek()
    p_pos = p_pos + 1
    return tok
}

fn p_check(expected_kind) {
    return p_peek_kind() == expected_kind
}

fn p_expect(expected_kind) {
    if p_check(expected_kind) {
        return p_advance()
    }
    let tok = p_peek()
    let msg = "expected " + expected_kind + ", got " + tok.kind + " ('" + tok.value + "')"
    // HX-parse-leak-fix: throw at cap to escape runaway recovery.
    if len(p_errors) >= p_max_errors { throw "too many parse errors" }
    p_record_error(tok.line, tok.col, msg)
    p_emit_parse_error(tok, msg)
    return tok
}

// P51: narrow reserved-keyword list that is commonly mis-used as
// identifiers in numeric/algorithmic code (bignum borrow flag etc.).
// Keep this list tight to avoid breaking fields/params elsewhere.
fn p_is_reserved_id_kind(k) {
    if k == "Borrow" { return true }
    if k == "Own" { return true }
    if k == "Move" { return true }
    return false
}

fn p_reserved_id_hint(k) {
    if k == "Borrow" { return "br" }
    if k == "Own" { return "owner" }
    if k == "Move" { return "mv" }
    return "_x"
}

// Contextual keywords: lex'd as keywords so statement dispatch can
// still recognize `guard`/`generate` at statement-start, but accepted
// as identifiers in expression / decl-name / param-name positions.
// (hxa-20260422-003, mirrors parser.hexa SSOT.)
fn p_is_contextual_kw_kind(k) {
    if k == "Guard" { return true }
    if k == "Generate" { return true }
    return false
}

// FIX-6 (BG-HX2, 2026-05-04): hard-keyword check for parameter / let-binding
// name positions. Mirrors parser.hexa SSOT — silent no-op repro
// (commit 08e2d9aa: `fn foo(fn) { ... }` → exit 0, empty stdout) traced to
// p_expect_ident's lenient generic-error branch leaving the keyword token in
// place, RParen cascade silently maxing p_max_errors.
fn p_is_strict_reserved_kw_kind(k) {
    if k == "Fn" { return true }
    if k == "Let" { return true }
    if k == "If" { return true }
    if k == "Else" { return true }
    if k == "While" { return true }
    if k == "For" { return true }
    if k == "Return" { return true }
    if k == "Pub" { return true }
    if k == "Struct" { return true }
    if k == "Enum" { return true }
    if k == "Match" { return true }
    if k == "Use" { return true }
    if k == "As" { return true }
    if k == "Trait" { return true }
    if k == "Impl" { return true }
    if k == "Loop" { return true }
    if k == "Break" { return true }
    if k == "Continue" { return true }
    if k == "Const" { return true }
    if k == "Static" { return true }
    if k == "Mut" { return true }
    if k == "Async" { return true }
    if k == "Await" { return true }
    return false
}

// Emit a clear "reserved keyword '<kw>' cannot be used as <context>"
// diagnostic and consume the offending token. `ctx` e.g. "parameter name".
fn p_check_strict_reserved(ctx) {
    let tok = p_peek()
    if !p_is_strict_reserved_kw_kind(tok.kind) { return false }
    let msg = "FIX-6: reserved keyword '" + tok.value + "' cannot be used as " + ctx + " — rename the binding"
    if len(p_errors) >= p_max_errors { throw "too many parse errors" }
    p_record_error(tok.line, tok.col, msg)
    p_emit_parse_error(tok, msg)
    p_pos = p_pos + 1
    return true
}

// `guard` is a keyword statement iff `Else` appears at paren/bracket
// depth 0 before a terminator. Otherwise it is an identifier.
fn p_guard_is_stmt_here() {
    let mut i = p_pos + 1
    let mut depth = 0
    while i < len(p_tokens) {
        let t = p_tokens[i]
        let k = t.kind
        if k == "LParen" || k == "LBracket" {
            depth = depth + 1
        } else if k == "RParen" || k == "RBracket" {
            if depth > 0 { depth = depth - 1 }
        } else if depth == 0 {
            if k == "Else" { return true }
            if k == "Newline" { return false }
            if k == "Semi" { return false }
            if k == "LBrace" { return false }
            if k == "Eof" { return false }
        }
        i = i + 1
    }
    return false
}

// `generate` is a keyword statement iff followed by `fn`, `{`, or an
// Ident then `{`. Anything else is an expression statement.
fn p_generate_is_stmt_here() {
    let nk = p_peek_ahead(1).kind
    if nk == "Fn" { return true }
    if nk == "LBrace" { return true }
    if nk == "Ident" {
        if p_peek_ahead(2).kind == "LBrace" { return true }
    }
    return false
}

fn p_expect_ident() {
    let tok = p_peek()
    if tok.kind == "Ident" || p_is_contextual_kw_kind(tok.kind) {
        p_pos = p_pos + 1
        return tok.value
    }
    // P51: reserved keyword used in identifier position — loud error.
    let mut msg2 = ""
    if p_is_reserved_id_kind(tok.kind) {
        msg2 = "P51: reserved keyword '" + tok.value + "' cannot be used as identifier — rename to '" + p_reserved_id_hint(tok.kind) + "'"
    } else {
        msg2 = "expected identifier, got " + tok.kind + " ('" + tok.value + "')"
    }
    // HX-parse-leak-fix: throw at cap to escape runaway recovery.
    if len(p_errors) >= p_max_errors { throw "too many parse errors" }
    p_record_error(tok.line, tok.col, msg2)
    p_emit_parse_error(tok, msg2)
    // Consume the offending reserved token to avoid infinite-loop parse
    // cascades on the same token.
    if p_is_reserved_id_kind(tok.kind) { p_pos = p_pos + 1 }
    return ""
}

fn p_skip_newlines() {
    while p_peek_kind() == "Newline" || p_peek_kind() == "Semicolon" {
        p_pos = p_pos + 1
    }
}

// T35: If the current token is a Newline and the first non-newline token
// ahead matches any name in `kinds`, skip the newlines and return true.
// Used by binary-expression parsers so `return x \n + 1` and its cousins
// are treated as continuation of the current expression. Callers pass
// ONLY kinds that can never start a statement on their own (Plus,
// Star, Slash, Percent, Power, Or, And, Xor, NullCoal, Pipe, EqEq,
// NotEq, Lt, Gt, LtEq, GtEq). Minus / Bang are excluded because they
// are unary-ambiguous.
fn p_continue_bin_op(kinds) {
    if p_peek_kind() != "Newline" { return false }
    let mut _o = 1
    // @partial — exits via internal break/return on non-newline/semicolon
    while true {
        let _t = p_peek_ahead(_o)
        if _t.kind != "Newline" && _t.kind != "Semicolon" {
            let mut _i = 0
            while _i < len(kinds) {
                if _t.kind == kinds[_i] {
                    p_skip_newlines()
                    return true
                }
                _i = _i + 1
            }
            return false
        }
        _o = _o + 1
    }
    return false
}

// ══════════════════════════════════════════════════════════════
// Main parse entry point
// ══════════════════════════════════════════════════════════════

fn is_comparison_op(k) {
    if k == "Lt" { return true }
    if k == "Gt" { return true }
    if k == "Le" { return true }
    if k == "Ge" { return true }
    if k == "EqEq" { return true }
    if k == "NotEq" { return true }
    return false
}

fn parse(tokens) {
    p_tokens = tokens
    p_pos = 0
    p_pending_symbol = ""
    p_pending_link = ""
    p_pending_attrs = ""
    p_pending_annotations = []
    p_pending_contract_requires = ""
    p_pending_contract_ensures = ""
    p_pending_contract_req_text = ""
    p_pending_contract_ens_text = ""
    p_errors = []
    p_max_errors = 50
    p_last_err_key = ""
    let mut stmts = []
    p_skip_newlines()
    while !p_at_end() {
        // Early bail: p_max_errors 도달 시 즉시 종료. 없으면 unrecoverable
        // syntax (e.g. void bundle 의 `[T; N]`) 를 무한 재시도하며 매 loop
        // 당 부분 AST map leak → 10GB+ RSS 폭주 후 jetsam SIGKILL.
        if len(p_errors) >= p_max_errors { return stmts }
        let prev_pos = p_pos
        let mut parse_ok = true
        try {
            stmts.push(parse_stmt())
        } catch parse_err {
            // parse_stmt threw — record & synchronize
            let err_tok = p_peek()
            p_record_error(err_tok.line, err_tok.col, to_string(parse_err))
            p_synchronize()
            parse_ok = false
        }
        // Forward-progress guard — applies to BOTH success and error paths.
        // Previously only checked in parse_ok branch; synchronize that failed
        // to advance on a stuck token caused infinite no-progress loop until
        // max_errors capped recording (but allocations kept leaking).
        if p_pos == prev_pos { p_advance() }
        p_skip_newlines()
    }
    // 2026-04-26 silent-failure-enforcement Class 1 (interp parser):
    // mirror self/parser.hexa _check_main_double_invoke. Without this the
    // interp T49 path (line 18289-18304) silently runs main() twice when
    // user writes `fn main()` + top-level `main()` — codegen suppresses
    // (T34 in codegen_c2.hexa) so AOT was correct but interp was not.
    // Now both paths reject the pattern uniformly.
    _check_main_double_invoke(stmts)
    return stmts
}

// _check_main_double_invoke — see self/parser.hexa for full rationale.
// Inlined here because hexa_full.hexa is a self-contained interp build.
fn _check_main_double_invoke(stmts) {
    let mut has_main_fn = false
    let mut has_explicit_main_call = false
    let mut manual_main_optout = false
    let mut i = 0
    while i < len(stmts) {
        let s = stmts[i]
        if s.kind == "FnDecl" && s.name == "main" {
            has_main_fn = true
            if type_of(s.value) == "string" {
                if s.value.contains("manual_main") {
                    manual_main_optout = true
                }
            }
        } else if s.kind == "ExprStmt" {
            if type_of(s.left) != "string" {
                let e = s.left
                if e.kind == "Call" && type_of(e.left) != "string" {
                    let callee = e.left
                    if callee.kind == "Ident" && callee.name == "main" {
                        has_explicit_main_call = true
                    }
                }
            }
        }
        i = i + 1
    }
    if has_main_fn && has_explicit_main_call && !manual_main_optout {
        println("error: auto-invoke conflict — `fn main()` is auto-called by hexa-strict")
        println("       AND a top-level `main()` call was found, which would run main() twice")
        println("       in the interp path (codegen suppresses but interp deliberately double-calls).")
        println("hint: remove the explicit `main()` call (auto-invoke handles it)")
        println("hint: OR add `@manual_main` attribute on `fn main` to opt out of auto-invoke")
        println("ref: silent-failure-enforcement Class 1 (doc/audit/silent_failure_enforcement_audit.md)")
        exit(1)
    }
}

// parse_strict — original behavior: halt on first error (for backward compat)
fn parse_strict(tokens) {
    p_tokens = tokens
    p_pos = 0
    p_pending_symbol = ""
    p_pending_link = ""
    p_pending_attrs = ""
    p_pending_annotations = []
    p_errors = []
    let mut stmts = []
    p_skip_newlines()
    while !p_at_end() {
        stmts.push(parse_stmt())
        p_skip_newlines()
    }
    return stmts
}

// ══════════════════════════════════════════════════════════════
// Level 2: Statement
// ══════════════════════════════════════════════════════════════

fn parse_stmt() {
    p_skip_newlines()
    // HX-pub-prefix: absorb `pub` visibility marker. Codegen ignores
    // visibility (single TU); just consume + discard.
    if p_peek_kind() == "Pub" {
        parse_visibility()
    }
    // M0: collect leading @attr markers (e.g. @optimize @memoize @pure @async)
    while p_peek_kind() == "At" {
        p_advance() // consume @
        // Attribute name may be a keyword (e.g. @pure where `pure` is a keyword)
        let next_tok = p_peek()
        let mut attr_name = ""
        if p_peek_kind() == "Ident" {
            attr_name = p_expect_ident()
        } else {
            // Accept any keyword token's value as the attribute name
            attr_name = next_tok.value
            p_advance()
        }
        // ── @invariant { id, name, predicate, pattern, exempt } DSL ──
        // T3 Phase A: declarative invariant block. mirror parser.hexa.
        if attr_name == "invariant" && p_peek_kind() == "LBrace" {
            return parse_invariant_decl()
        }
        // ── @contract — parse requires/ensures clauses ──────
        if attr_name == "contract" && p_peek_kind() == "LParen" {
            p_advance() // consume (
            p_pending_contract_requires = ""
            p_pending_contract_ensures = ""
            p_pending_contract_req_text = ""
            p_pending_contract_ens_text = ""
            while p_peek_kind() != "RParen" && p_peek_kind() != "Eof" {
                // Expect "requires" or "ensures" identifier
                let clause_tok = p_advance()
                let clause_name = clause_tok.value
                // Consume the colon after requires/ensures
                if p_peek_kind() == "Colon" {
                    p_advance()
                }
                // Capture token position for source text extraction
                let expr_start = p_pos
                // Parse the clause expression using the full expression parser
                let clause_expr = parse_expr()
                // Build source text from consumed tokens for error messages
                let mut src_text = ""
                let mut _si = expr_start
                while _si < p_pos {
                    if src_text != "" {
                        src_text = src_text + " "
                    }
                    src_text = src_text + p_tokens[_si].value
                    _si = _si + 1
                }
                if clause_name == "requires" {
                    p_pending_contract_requires = clause_expr
                    p_pending_contract_req_text = src_text
                } else if clause_name == "ensures" {
                    p_pending_contract_ensures = clause_expr
                    p_pending_contract_ens_text = src_text
                }
                // Skip comma separator between clauses
                if p_peek_kind() == "Comma" {
                    p_advance()
                }
            }
            p_expect("RParen")
            if p_pending_attrs == "" {
                p_pending_attrs = "contract"
            } else {
                p_pending_attrs = p_pending_attrs + ",contract"
            }
        } else if attr_name == "symbol" || attr_name == "link" {
            // @symbol("x") / @link("libm") — single string argument
            let mut attr_arg = ""
            if p_peek_kind() == "LParen" {
                p_advance()
                if p_peek_kind() != "RParen" {
                    let tok = p_advance()
                    attr_arg = tok.value
                    while p_peek_kind() != "RParen" && p_peek_kind() != "Eof" {
                        p_advance()
                    }
                }
                p_expect("RParen")
            }
            if attr_name == "symbol" {
                p_pending_symbol = attr_arg
            } else {
                p_pending_link = attr_arg
            }
        } else if attr_name == "cli" || attr_name == "flag" || attr_name == "doc" || attr_name == "schema" || attr_name == "gate" || attr_name == "memo" {
            // M0+: typed AI-native annotations — capture raw arg tokens
            // StringLit tokens are re-quoted so the serialized form round-trips.
            let mut raw = ""
            if p_peek_kind() == "LParen" {
                p_advance() // consume (
                let mut depth = 1
                while depth > 0 && p_peek_kind() != "Eof" {
                    let pk2 = p_peek_kind()
                    if pk2 == "LParen" {
                        depth = depth + 1
                        let t = p_advance()
                        if raw != "" { raw = raw + " " }
                        raw = raw + t.value
                    } else if pk2 == "RParen" {
                        depth = depth - 1
                        if depth == 0 {
                            p_advance() // consume closing )
                        } else {
                            let t = p_advance()
                            if raw != "" { raw = raw + " " }
                            raw = raw + t.value
                        }
                    } else {
                        let t = p_advance()
                        if raw != "" { raw = raw + " " }
                        if pk2 == "StringLit" {
                            raw = raw + "\"" + t.value + "\""
                        } else {
                            raw = raw + t.value
                        }
                    }
                }
            }
            p_pending_annotations.push(attr_name + "|" + raw)
        } else {
            // Generic attribute — skip optional parenthesized content
            if p_peek_kind() == "LParen" {
                p_advance()
                if p_peek_kind() != "RParen" {
                    let tok = p_advance()
                    while p_peek_kind() != "RParen" && p_peek_kind() != "Eof" {
                        p_advance()
                    }
                }
                p_expect("RParen")
            }
            if p_pending_attrs == "" {
                p_pending_attrs = attr_name
            } else {
                p_pending_attrs = p_pending_attrs + "," + attr_name
            }
        }
        p_skip_newlines()
    }
    // G39: after @attr collection, absorb `pub` if present — allows `@pure pub fn`
    // (3-source replication: parser.hexa:714, hexa_cc.c:2155, hexa_full.hexa here)
    if p_peek_kind() == "Pub" {
        parse_visibility()
    }
    let kind = p_peek_kind()

    if kind == "Let" { return parse_let() }
    if kind == "Const" { return parse_const() }
    if kind == "Static" { return parse_static() }
    if kind == "Fn" { return parse_fn_decl() }
    if kind == "Struct" { return parse_struct_decl() }
    if kind == "Enum" { return parse_enum_decl() }
    if kind == "For" { return parse_for_stmt() }
    if kind == "While" { return parse_while_stmt() }
    if kind == "Loop" { return parse_loop_stmt() }
    if kind == "Do" { return parse_do_while_stmt() }
    if kind == "Defer" { return parse_defer_stmt() }
    if kind == "Return" { return parse_return() }
    if kind == "Proof" { return parse_proof_stmt() }
    if kind == "Assert" { return parse_assert_stmt() }
    if kind == "Invariant" { return parse_invariant_stmt() }
    if kind == "Impl" { return parse_impl_block() }
    if kind == "Trait" { return parse_trait_decl() }
    if kind == "Use" { return parse_use_decl() }
    if kind == "Mod" { return parse_mod_decl() }
    // Phase2 C1 — `import "path.hexa"` 지시문.
    // module_loader.hexa 전처리기가 인라인 확장해야 정상이지만,
    // 파서 수준에서도 관대히 받아들여 NoOp 로 취급한다.
    if kind == "Ident" {
        let tok = p_peek()
        if tok.value == "import" {
            p_advance() // consume 'import'
            let mut path = ""
            if p_peek_kind() == "StringLit" {
                let str_tok = p_advance()
                path = str_tok.value
            }
            // 2026-05-04 (feat/import-alias-runtime-fix): accept optional
            // `as <ident>` alias suffix. The alias is stored in node.value
            // for the runtime loader to register `<ident>::<fnname>` dispatch
            // routing. Previously the bare `as` token after the path string
            // produced a parse error in the direct-interp path; in the CLI
            // (preprocessed) path it was silently stripped along with the
            // import directive, so call sites of the form `alias::helper()`
            // dispatched into val_enum() (silent void). Reported by orpheus
            // puzzle/sweep agents.
            let mut alias = ""
            if p_peek_kind() == "As" {
                p_advance() // consume 'as'
                if p_peek_kind() == "Ident" {
                    let alias_tok = p_advance()
                    alias = alias_tok.value
                }
            }
            return #{
                "kind": "ImportStmt", "name": path, "value": alias, "op": "",
                "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }
        }
    }
    if kind == "Try" { return parse_try_catch() }
    if kind == "Throw" { return parse_throw_stmt() }
    if kind == "Panic" { return parse_panic_stmt() }
    if kind == "Drop" { return parse_drop_stmt() }
    if kind == "Spawn" { return parse_spawn_stmt() }
    if kind == "Scope" { return parse_scope_stmt() }
    if kind == "Select" { return parse_select_stmt() }
    if kind == "Async" { return parse_async_fn() }
    if kind == "Extern" { return parse_extern_fn() }
    if kind == "Type" { return parse_type_alias() }
    if kind == "Atomic" { return parse_atomic_let() }
    if kind == "Break" { return parse_break_stmt() }
    if kind == "Continue" { return parse_continue_stmt() }
    if kind == "Yield" { return parse_yield_stmt() }
    if kind == "Comptime" { return parse_comptime_stmt() }
    if kind == "Intent" { return parse_intent_stmt() }
    if kind == "Verify" { return parse_verify_stmt() }
    if kind == "Generate" {
        if p_generate_is_stmt_here() { return parse_generate_stmt() }
        // else: fall through, treat `generate` as identifier in expr-stmt
    }
    if kind == "Optimize" { return parse_optimize_stmt() }
    if kind == "Effect" { return parse_effect_decl() }
    if kind == "Pure" { return parse_pure_fn() }
    if kind == "Macro" { return parse_macro_def() }
    if kind == "Derive" { return parse_derive_decl() }
    if kind == "Theorem" { return parse_theorem_stmt() }
    if kind == "Handle" { return parse_handle_stmt() }
    if kind == "Recover" { return parse_recover_stmt() }
    if kind == "Resume" { return parse_resume_stmt() }
    if kind == "Guard" {
        if p_guard_is_stmt_here() { return parse_guard_stmt() }
        // else: fall through, treat `guard` as identifier in expr-stmt
    }
    if kind == "With" { return parse_with_stmt() }

    // Labeled loop: 'label: for/while/loop { ... }
    if kind == "Label" {
        return parse_labeled_loop()
    }

    // @attribute(...) — consume and attach to next declaration
    if kind == "Attribute" {
        return parse_attribute_prefix()
    }

    // Expression statement or assignment (incl. compound: +=, -=, *=, /=, %=)
    let expr = parse_expr()
    let pk = p_peek_kind()
    if pk == "Eq" {
        p_advance() // consume =
        p_skip_newlines()  // allow `x =\n <expr>` (match parse_let semantics)
        let rhs = parse_expr()
        return #{
            "kind": "AssignStmt", "name": "", "value": "", "op": "",
            "left": expr, "right": rhs, "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    if pk == "PlusEq" || pk == "MinusEq" || pk == "StarEq" || pk == "SlashEq" || pk == "PercentEq" {
        let op_tok = p_advance()
        let op_str = if pk == "PlusEq" { "+" } else { if pk == "MinusEq" { "-" } else { if pk == "StarEq" { "*" } else { if pk == "SlashEq" { "/" } else { "%" } } } }
        p_skip_newlines()  // allow `x +=\n <expr>` similarly
        let rhs = parse_expr()
        return #{
            "kind": "CompoundAssign", "name": "", "value": "", "op": op_str,
            "left": expr, "right": rhs, "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    if pk == "NullCoalescingAssign" || pk == "OrAssign" || pk == "AndAssign" {
        let op_tok = p_advance()
        let op_str = if pk == "NullCoalescingAssign" { "??=" } else { if pk == "OrAssign" { "||=" } else { "&&=" } }
        let rhs = parse_expr()
        return #{
            "kind": "LogicalAssign", "name": "", "value": "", "op": op_str,
            "left": expr, "right": rhs, "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    return #{
        "kind": "ExprStmt", "name": "", "value": "", "op": "",
        "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── let [mut] name [: type] = expr ──────────────────────────
// G9: also handles destructuring:
//   let [a, b, ...rest] = expr   → DestructLetStmt
//   let {x, y} = expr            → MapDestructLetStmt

fn parse_let() {
    p_advance() // consume 'let'
    let mut is_mut = false
    if p_peek_kind() == "Mut" {
        p_advance()
        is_mut = true
    }

    // G9: array destructuring — let [a, b, ...rest] = expr
    if p_peek_kind() == "LBracket" {
        p_advance() // consume [
        let mut patterns = []
        let mut rest_name = ""
        while p_peek_kind() != "RBracket" && p_peek_kind() != "Eof" {
            if p_peek_kind() == "DotDotDot" {
                // ...rest pattern
                p_advance() // consume ...
                rest_name = p_expect_ident()
            } else {
                patterns.push(p_expect_ident())
            }
            if p_peek_kind() == "Comma" {
                p_advance()
            }
        }
        p_expect("RBracket")
        p_expect("Eq")
        let expr = parse_expr()
        return #{
            "kind": "DestructLetStmt", "name": rest_name, "value": "", "op": "",
            "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": patterns, "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }

    // G9: map/struct destructuring — let {x, y} = expr
    if p_peek_kind() == "LBrace" {
        p_advance() // consume {
        let mut patterns = []
        while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
            patterns.push(p_expect_ident())
            if p_peek_kind() == "Comma" {
                p_advance()
            }
        }
        p_expect("RBrace")
        p_expect("Eq")
        let expr = parse_expr()
        return #{
            "kind": "MapDestructLetStmt", "name": "", "value": "", "op": "",
            "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": patterns, "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }

    // FIX-6 (BG-HX2): reject reserved keywords as let-binding name.
    let mut name = ""
    if p_check_strict_reserved("let-binding name") {
        name = ""
    } else {
        name = p_expect_ident()
    }
    // optional type annotation — supports T?, (T,U), T|U via parse_type_annotation
    let mut typ = ""
    if p_peek_kind() == "Colon" {
        p_advance()
        typ = parse_type_annotation()
    }
    p_expect("Eq")
    // Allow `let X =\n <expr>` — RHS on next line. Previously failed with
    // "unexpected token Newline" (interp) / silently emitted empty map {}
    // (AOT, recovery-mode). Caused repeated .roadmap sabotage from
    // roadmap_banner.hexa multi-line concat (d2da6daa).
    p_skip_newlines()
    let expr = parse_expr()
    let mut kind_str = "LetStmt"
    if is_mut {
        kind_str = "LetMutStmt"
    }
    return #{
        "kind": kind_str, "name": name, "value": typ, "op": "",
        "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── const name [: type] = expr ──────────────────────────────

fn parse_const() {
    p_advance() // consume 'const'
    let name = p_expect_ident()
    let mut typ = ""
    if p_peek_kind() == "Colon" {
        p_advance()
        typ = parse_type_annotation()
    }
    p_expect("Eq")
    let expr = parse_expr()
    return #{
        "kind": "ConstStmt", "name": name, "value": typ, "op": "",
        "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── static name [: type] = expr ─────────────────────────────

fn parse_static() {
    p_advance() // consume 'static'
    let name = p_expect_ident()
    let mut typ = ""
    if p_peek_kind() == "Colon" {
        p_advance()
        typ = parse_type_annotation()
    }
    p_expect("Eq")
    let expr = parse_expr()
    return #{
        "kind": "StaticStmt", "name": name, "value": typ, "op": "",
        "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── return [expr] ───────────────────────────────────────────

fn parse_return() {
    p_advance() // consume 'return'
    let k = p_peek_kind()
    if k == "Newline" || k == "Eof" || k == "RBrace" {
        return #{
            "kind": "ReturnStmt", "name": "", "value": "", "op": "",
            "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    let expr = parse_expr()
    return #{
        "kind": "ReturnStmt", "name": "", "value": "", "op": "",
        "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── proof name { body } ─────────────────────────────────────

fn parse_proof_stmt() {
    p_advance() // consume 'proof'
    let name = p_expect_ident()
    let body = parse_block()
    return #{
        "kind": "ProofStmt", "name": name, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": body, "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── assert expr ─────────────────────────────────────────────

fn parse_assert_stmt() {
    p_advance() // consume 'assert'
    let expr = parse_expr()
    return #{
        "kind": "AssertStmt", "name": "", "value": "", "op": "",
        "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── resume [expr] (inside effect handler) ──────────────────
// P51: bare `resume` (no expr) is valid — means resume with void.
// Guards Newline/RBrace/Eof before parse_expr() to avoid empty-LHS
// ident fall-through error when resume appears at end of handler body.
fn parse_resume_stmt() {
    p_advance() // consume 'resume'
    let mut expr = ""
    if p_peek_kind() != "Newline" && p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
        expr = parse_expr()
    }
    return #{
        "kind": "Resume", "name": "", "value": "", "op": "",
        "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── invariant expr (proof block hint) ───────────────────────
fn parse_invariant_stmt() {
    p_advance() // consume 'invariant'
    let expr = parse_expr()
    return #{
        "kind": "Invariant", "name": "", "value": "", "op": "",
        "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── @invariant { id, name, predicate, pattern, exempt } DSL ─
// T3 Phase A: mirrors parser.hexa parse_invariant_decl.
// 본 interp 인터프리터 안에도 동일 노드를 만들어 hexa run / 모듈 로더가
// 해당 선언을 만나도 silent no-op 으로 흘러가도록 한다.
fn parse_invariant_decl() {
    p_expect("LBrace")
    p_skip_newlines()
    let mut id_str = ""
    let mut name_str = ""
    let mut pred_str = ""
    let mut tgt_str = ""
    let mut ctx_str = ""
    let mut exempt_list = []
    while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
        let key_tok = p_peek()
        let mut key_name = ""
        if key_tok.kind == "Ident" {
            p_advance()
            key_name = key_tok.value
        } else {
            p_advance()
            key_name = key_tok.value
        }
        if p_peek_kind() == "Colon" {
            p_advance()
        }
        let vk = p_peek_kind()
        if vk == "StringLit" {
            let vt = p_advance()
            if key_name == "id" { id_str = vt.value }
            else if key_name == "name" { name_str = vt.value }
            else if key_name == "predicate" { pred_str = vt.value }
            else if key_name == "target" { tgt_str = vt.value }
            else if key_name == "context" { ctx_str = vt.value }
        } else if vk == "LBrace" {
            p_advance()
            p_skip_newlines()
            while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
                let nk_tok = p_peek()
                let mut nk = ""
                if nk_tok.kind == "Ident" {
                    p_advance()
                    nk = nk_tok.value
                } else {
                    p_advance()
                    nk = nk_tok.value
                }
                if p_peek_kind() == "Colon" {
                    p_advance()
                }
                if p_peek_kind() == "StringLit" {
                    let nv = p_advance()
                    if key_name == "pattern" {
                        if nk == "target" { tgt_str = nv.value }
                        else if nk == "context" { ctx_str = nv.value }
                    }
                } else {
                    p_advance()
                }
                if p_peek_kind() == "Comma" { p_advance() }
                p_skip_newlines()
            }
            p_expect("RBrace")
        } else if vk == "LBracket" {
            p_advance()
            p_skip_newlines()
            while p_peek_kind() != "RBracket" && p_peek_kind() != "Eof" {
                if p_peek_kind() == "StringLit" {
                    let et = p_advance()
                    if key_name == "exempt" {
                        exempt_list.push(et.value)
                    }
                } else {
                    p_advance()
                }
                if p_peek_kind() == "Comma" { p_advance() }
                p_skip_newlines()
            }
            p_expect("RBracket")
        } else {
            p_advance()
        }
        if p_peek_kind() == "Comma" { p_advance() }
        p_skip_newlines()
    }
    p_expect("RBrace")
    return #{
        "kind": "InvariantDecl", "name": id_str, "value": name_str, "op": pred_str,
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": exempt_list,
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": tgt_str, "trait_name": ctx_str, "methods": ""
    }
}

// ── use path::to::module  OR  use "path/to/module" ──────────
//
// Accepts both forms:
//   (a) Rust-style ident path — `use foo::bar::baz`
//       Stored as items = ["foo", "bar", "baz"]
//   (b) String-literal path — `use "serving/voice_routes"`
//       Stored as name = "serving/voice_routes" (ImportStmt shape)
// Form (b) is the dominant usage in downstream hexa projects (anima
// serving/*.hexa etc.) and was previously parse-error'd here because
// p_expect_ident rejects StringLit tokens. The module_loader preprocessor
// masked this at the CLI layer by commenting out the directive before the
// parser ran; direct interp invocations (bypassing the preprocessor) and
// `hexa parse` on raw source both leaked the parse error.
fn parse_use_decl() {
    p_advance() // consume 'use'
    // Form (b): string-literal path → ImportStmt shape for runtime loader.
    if p_peek_kind() == "StringLit" {
        let str_tok = p_advance()
        // 2026-05-04 (feat/import-alias-runtime-fix): optional `as <ident>`
        // alias suffix (parity with `import "..." as <ident>` form).
        let mut alias_b = ""
        if p_peek_kind() == "As" {
            p_advance() // consume 'as'
            if p_peek_kind() == "Ident" {
                let alias_tok_b = p_advance()
                alias_b = alias_tok_b.value
            }
        }
        return #{
            "kind": "ImportStmt", "name": str_tok.value, "value": alias_b, "op": "",
            "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    // Form (a): ident::ident::... path.
    let mut path = []
    path.push(p_expect_ident())
    while p_peek_kind() == "ColonColon" {
        p_advance()
        path.push(p_expect_ident())
    }
    // 2026-05-04 (feat/import-alias-runtime-fix): optional `as <ident>` for
    // `use a::b::c as alias` (Rust-style). Stored in node.value.
    let mut alias_a = ""
    if p_peek_kind() == "As" {
        p_advance() // consume 'as'
        if p_peek_kind() == "Ident" {
            let alias_tok_a = p_advance()
            alias_a = alias_tok_a.value
        }
    }
    return #{
        "kind": "UseStmt", "name": "", "value": alias_a, "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": path,
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── mod name { body } ───────────────────────────────────────

fn parse_mod_decl() {
    p_advance() // consume 'mod'
    let name = p_expect_ident()
    let body = parse_block()
    return #{
        "kind": "ModStmt", "name": name, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": body, "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ══════════════════════════════════════════════════════════════
// Level 3: Declarations
// ══════════════════════════════════════════════════════════════

// ── fn name(params) [-> ret] { body } ───────────────────────

fn parse_fn_decl() {
    p_advance() // consume 'fn'
    let name = p_expect_ident()
    // C4: Optional type parameters — fn foo<T, U>(params) { ... }
    let mut tparams = []
    if p_peek_kind() == "Lt" {
        tparams = parse_type_params()
    }
    p_expect("LParen")
    let params = parse_params()
    p_expect("RParen")
    let mut ret = ""
    if p_peek_kind() == "Arrow" {
        p_advance()
        ret = parse_type_annotation()
    }
    let body = parse_block()
    // M0: consume any pending @attrs into FnDecl.value (comma-separated)
    let attrs = p_pending_attrs
    p_pending_attrs = ""

    // M0+: consume typed annotations (@cli/@flag/@doc/@schema/@gate/@memo)
    // Serialized as "kind|raw;kind|raw" and stored in FnDecl.annotations.
    let mut annot_str = ""
    let mut _ai = 0
    while _ai < len(p_pending_annotations) {
        if annot_str != "" { annot_str = annot_str + ";" }
        annot_str = annot_str + p_pending_annotations[_ai]
        _ai = _ai + 1
    }
    p_pending_annotations = []

    // ── @contract desugar: inject ContractAssert nodes ──────
    let mut final_body = body
    let req_expr = p_pending_contract_requires
    let ens_expr = p_pending_contract_ensures
    let req_text = p_pending_contract_req_text
    let ens_text = p_pending_contract_ens_text
    p_pending_contract_requires = ""
    p_pending_contract_ensures = ""
    p_pending_contract_req_text = ""
    p_pending_contract_ens_text = ""

    if req_expr != "" {
        // Prepend requires check: if !(<requires_expr>) throw "contract ..."
        let req_node = #{
            "kind": "ContractAssert", "name": name, "value": "requires: " + req_text, "op": "requires",
            "left": req_expr, "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
        let mut new_body = [req_node]
        for stmt in final_body {
            new_body.push(stmt)
        }
        final_body = new_body
    }

    if ens_expr != "" {
        // Walk body and wrap every ReturnStmt with ensures check.
        // Replace: return <expr>
        // With:    let __contract_result = <expr>
        //          ContractAssert(ensures_expr)  // result bound to __contract_result
        //          return __contract_result
        final_body = contract_wrap_returns(final_body, ens_expr, name, ens_text)
    }

    return #{
        "kind": "FnDecl", "name": name, "value": attrs, "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": params, "body": final_body, "args": "", "fields": "", "items": tparams,
        "variants": "", "arms": "", "iter_expr": "", "ret_type": ret,
        "target": "", "trait_name": "", "methods": "", "annotations": annot_str
    }
}

// ── @contract ensures: wrap return statements ───────────────
// Walks a body array, replacing every ReturnStmt with a 3-node sequence:
//   1. let __contract_result = <return_expr>
//   2. ContractAssert(ensures_expr)   — interpreter binds `result`
//   3. return __contract_result
// Recurses into if/else blocks to catch early returns in branches.

// decreases body — structural
fn contract_wrap_returns(body, ens_expr, fn_name, ens_text) {
    let mut out = []
    for stmt in body {
        if type_of(stmt) == "string" {
            out.push(stmt)
        } else if stmt.kind == "ReturnStmt" || stmt.kind == "Return" {
            // 1. let __contract_result = <original return expr>
            let let_node = #{
                "kind": "LetStmt", "name": "__contract_result", "value": "", "op": "",
                "left": stmt.left, "right": "", "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }
            // 2. ContractAssert — ensures check (result = __contract_result)
            let assert_node = #{
                "kind": "ContractAssert", "name": fn_name, "value": "ensures: " + ens_text, "op": "ensures",
                "left": ens_expr, "right": "", "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }
            // 3. return __contract_result
            let ret_node = #{
                "kind": "ReturnStmt", "name": "", "value": "", "op": "",
                "left": node_ident("__contract_result"),
                "right": "", "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }
            out.push(let_node)
            out.push(assert_node)
            out.push(ret_node)
        } else if stmt.kind == "IfStmt" {
            // Recurse into if/else branches to catch returns there
            let mut wrapped = stmt
            if type_of(stmt.then_body) == "array" {
                wrapped = #{
                    "kind": "IfStmt", "name": stmt.name, "value": stmt.value, "op": stmt.op,
                    "left": stmt.left, "right": stmt.right, "cond": stmt.cond,
                    "then_body": contract_wrap_returns(stmt.then_body, ens_expr, fn_name, ens_text),
                    "else_body": stmt.else_body,
                    "params": stmt.params, "body": stmt.body, "args": stmt.args,
                    "fields": stmt.fields, "items": stmt.items,
                    "variants": stmt.variants, "arms": stmt.arms,
                    "iter_expr": stmt.iter_expr, "ret_type": stmt.ret_type,
                    "target": stmt.target, "trait_name": stmt.trait_name, "methods": stmt.methods
                }
            }
            if type_of(wrapped.else_body) == "array" {
                wrapped = #{
                    "kind": "IfStmt", "name": wrapped.name, "value": wrapped.value, "op": wrapped.op,
                    "left": wrapped.left, "right": wrapped.right, "cond": wrapped.cond,
                    "then_body": wrapped.then_body,
                    "else_body": contract_wrap_returns(wrapped.else_body, ens_expr, fn_name, ens_text),
                    "params": wrapped.params, "body": wrapped.body, "args": wrapped.args,
                    "fields": wrapped.fields, "items": wrapped.items,
                    "variants": wrapped.variants, "arms": wrapped.arms,
                    "iter_expr": wrapped.iter_expr, "ret_type": wrapped.ret_type,
                    "target": wrapped.target, "trait_name": wrapped.trait_name, "methods": wrapped.methods
                }
            }
            out.push(wrapped)
        } else {
            out.push(stmt)
        }
    }
    return out
}

// Parse a type annotation after ':' or '->'
// Supports: Ident, *Ident (pointer), [T] (array),
//   G34: T? (optional type), G35: (T, U) (tuple type),
//   G36: T | U (union type), G38: <T: Bound> (generic constraint)
// decreases x — structural
fn parse_type_annotation() {
    let mut base = ""
    if p_peek_kind() == "Star" {
        p_advance() // consume '*'
        base = "*" + p_expect_ident()
    } else if p_peek_kind() == "LBracket" {
        p_advance() // consume '['
        let inner = parse_type_annotation()
        // [T; N] — Rust-style fixed-size array support (accept, emit as [T])
        if p_peek_kind() == "Semicolon" {
            p_advance() // consume ';'
            if p_peek_kind() != "RBracket" { p_advance() }  // skip size expr
        }
        p_expect("RBracket")
        base = "[" + inner + "]"
    } else if p_peek_kind() == "LParen" {
        // G35: Tuple type — (T, U, ...)
        p_advance() // consume '('
        let mut parts = []
        if p_peek_kind() != "RParen" {
            parts.push(parse_type_annotation())
            while p_peek_kind() == "Comma" {
                p_advance()
                parts.push(parse_type_annotation())
            }
        }
        p_expect("RParen")
        base = "(" + join(parts, ", ") + ")"
    } else {
        base = p_expect_ident()
    }
    // G34: Optional type suffix — T?
    if p_peek_kind() == "Question" {
        p_advance()
        base = base + "?"
    }
    // G36: Union type — T | U | V ...
    while p_peek_kind() == "BitOr" {
        p_advance()
        let next = parse_type_annotation()
        base = base + " | " + next
    }
    return base
}

fn parse_params() {
    let mut params = []
    if p_peek_kind() == "RParen" {
        return params
    }
    // Optional `mut` modifier on parameter
    if p_peek_kind() == "Mut" { p_advance() }
    // FIX-6 (BG-HX2): reject reserved keywords as param name.
    let mut name = ""
    if p_check_strict_reserved("parameter name") {
        name = ""
    } else {
        name = p_expect_ident()
    }
    let mut typ = ""
    if p_peek_kind() == "Colon" {
        p_advance()
        typ = parse_type_annotation()
    }
    params.push(#{
        "kind": "Param", "name": name, "value": typ, "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    })
    while p_peek_kind() == "Comma" {
        p_advance()
        if p_peek_kind() == "Mut" { p_advance() }
        let mut pname = ""
        if p_check_strict_reserved("parameter name") {
            pname = ""
        } else {
            pname = p_expect_ident()
        }
        let mut ptyp = ""
        if p_peek_kind() == "Colon" {
            p_advance()
            ptyp = parse_type_annotation()
        }
        params.push(#{
            "kind": "Param", "name": pname, "value": ptyp, "op": "",
            "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        })
    }
    return params
}

// ── struct Name { field: type, ... } ────────────────────────

fn parse_struct_decl() {
    p_advance() // consume 'struct'
    let name = p_expect_ident()
    // C4: Optional type parameters — struct Foo<T, U> { ... }
    let mut tparams = []
    if p_peek_kind() == "Lt" {
        tparams = parse_type_params()
    }
    p_expect("LBrace")
    p_skip_newlines()
    let mut fields = []
    while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
        let fname = p_expect_ident()
        // Type annotation is optional: `value` and `value: int` both parse.
        let mut ftype = ""
        if p_peek_kind() == "Colon" {
            p_advance()
            ftype = parse_type_annotation()
        }
        fields.push(#{
            "kind": "StructField", "name": fname, "value": ftype, "op": "",
            "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        })
        if p_peek_kind() == "Comma" {
            p_advance()
        }
        p_skip_newlines()
    }
    p_expect("RBrace")
    return #{
        "kind": "StructDecl", "name": name, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": fields, "items": tparams,
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── enum Name { Variant1, Variant2(type), ... } ─────────────

fn parse_enum_decl() {
    p_advance() // consume 'enum'
    let name = p_expect_ident()
    p_expect("LBrace")
    p_skip_newlines()
    let mut variants = []
    while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
        let vname = p_expect_ident()
        let mut vtypes = []
        if p_peek_kind() == "LParen" {
            p_advance()
            while p_peek_kind() != "RParen" && p_peek_kind() != "Eof" {
                vtypes.push(p_expect_ident())
                if p_peek_kind() == "Comma" {
                    p_advance()
                }
            }
            p_expect("RParen")
        }
        variants.push(#{
            "kind": "EnumVariant", "name": vname, "value": "", "op": "",
            "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": vtypes,
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        })
        if p_peek_kind() == "Comma" {
            p_advance()
        }
        p_skip_newlines()
    }
    p_expect("RBrace")
    return #{
        "kind": "EnumDecl", "name": name, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": variants, "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── trait Name { fn method(params) -> ret { body } } ────────

fn parse_trait_decl() {
    p_advance() // consume 'trait'
    let name = p_expect_ident()
    p_expect("LBrace")
    p_skip_newlines()
    let mut methods = []
    while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
        p_skip_newlines()
        if p_peek_kind() == "RBrace" { }
        else {
            p_expect("Fn")
            let mname = p_expect_ident()
            p_expect("LParen")
            let mparams = parse_params()
            p_expect("RParen")
            let mut mret = ""
            if p_peek_kind() == "Arrow" {
                p_advance()
                mret = parse_type_annotation()
            }
            let mut mbody = []
            if p_peek_kind() == "LBrace" {
                mbody = parse_block()
            }
            methods.push(#{
                "kind": "FnDecl", "name": mname, "value": "", "op": "",
                "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
                "params": mparams, "body": mbody, "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": mret,
                "target": "", "trait_name": "", "methods": "", "annotations": ""
            })
            p_skip_newlines()
        }
    }
    p_expect("RBrace")
    return #{
        "kind": "TraitDecl", "name": name, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": methods
    }
}

// ── impl [Trait for] Type { methods } ───────────────────────

fn parse_impl_block() {
    p_advance() // consume 'impl'
    let first_name = p_expect_ident()
    let mut trait_n = ""
    let mut target_n = first_name
    if p_peek_kind() == "For" {
        p_advance()
        trait_n = first_name
        target_n = p_expect_ident()
    }
    p_expect("LBrace")
    p_skip_newlines()
    let mut methods = []
    while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
        p_skip_newlines()
        if p_peek_kind() == "RBrace" { }
        else {
            p_expect("Fn")
            let mname = p_expect_ident()
            p_expect("LParen")
            let mparams = parse_params()
            p_expect("RParen")
            let mut mret = ""
            if p_peek_kind() == "Arrow" {
                p_advance()
                mret = parse_type_annotation()
            }
            let mbody = parse_block()
            methods.push(#{
                "kind": "FnDecl", "name": mname, "value": "", "op": "",
                "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
                "params": mparams, "body": mbody, "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": mret,
                "target": "", "trait_name": "", "methods": "", "annotations": ""
            })
            p_skip_newlines()
        }
    }
    p_expect("RBrace")
    return #{
        "kind": "ImplBlock", "name": "", "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": target_n, "trait_name": trait_n, "methods": methods
    }
}

// ══════════════════════════════════════════════════════════════
// Level 4: Control Flow
// ══════════════════════════════════════════════════════════════

// ── for var in expr { body } ────────────────────────────────

fn parse_for_stmt() {
    p_advance() // consume 'for'
    let var = p_expect_ident()
    // expect 'in' keyword
    let in_tok = p_advance()
    if in_tok.value != "in" {
        let for_msg = format("expected 'in' after for variable, got '{}'", in_tok.value)
        p_record_error(in_tok.line, in_tok.col, for_msg)
        println("Parse error: " + for_msg)
    }
    let prev_supp = p_suppress_struct_lit
    p_suppress_struct_lit = true
    let iter = parse_expr()
    p_suppress_struct_lit = prev_supp
    let body = parse_block()
    // Check for optional else block: for x in arr { } else { }
    let saved = p_pos
    p_skip_newlines()
    let mut else_body = ""
    if p_peek_kind() == "Else" {
        p_advance()
        else_body = parse_block()
        return #{
            "kind": "ForElseStmt", "name": var, "value": "", "op": "",
            "left": "", "right": "", "cond": "", "then_body": "", "else_body": else_body,
            "params": "", "body": body, "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": iter, "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    } else {
        // No else — backtrack past consumed newlines
        p_pos = saved
    }
    return #{
        "kind": "ForStmt", "name": var, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": body, "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": iter, "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── while cond { body } ─────────────────────────────────────

fn parse_while_stmt() {
    p_advance() // consume 'while'
    // Suppress struct-literal parsing inside the condition (Name { ... } would
    // collide with while body brace).
    let prev_supp = p_suppress_struct_lit
    p_suppress_struct_lit = true
    let cond = parse_expr()
    p_suppress_struct_lit = prev_supp
    let body = parse_block()
    return #{
        "kind": "WhileStmt", "name": "", "value": "", "op": "",
        "left": "", "right": "", "cond": cond, "then_body": "", "else_body": "",
        "params": "", "body": body, "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── loop { body } ───────────────────────────────────────────

fn parse_loop_stmt() {
    p_advance() // consume 'loop'
    let body = parse_block()
    return #{
        "kind": "LoopStmt", "name": "", "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": body, "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── if cond { then } [else { else }] (expression) ──────────

// decreases x — structural
fn parse_if_expr() {
    p_advance() // consume 'if'
    // G32: if let PATTERN = EXPR { body } else { alt }
    if p_peek_kind() == "Let" {
        p_advance() // consume 'let'
        let pattern = parse_match_pattern()
        p_expect("Eq") // consume '='
        let prev_supp = p_suppress_struct_lit
        p_suppress_struct_lit = true
        let scrutinee = parse_expr()
        p_suppress_struct_lit = prev_supp
        let then_b = parse_block()
        let saved = p_pos
        p_skip_newlines()
        let mut else_b = []
        if p_peek_kind() == "Else" {
            p_advance()
            if p_peek_kind() == "If" {
                let nested = parse_if_expr()
                else_b = [#{
                    "kind": "ExprStmt", "name": "", "value": "", "op": "",
                    "left": nested, "right": "", "cond": "", "then_body": "", "else_body": "",
                    "params": "", "body": "", "args": "", "fields": "", "items": "",
                    "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                    "target": "", "trait_name": "", "methods": ""
                }]
            } else {
                else_b = parse_block()
            }
        } else {
            p_pos = saved
        }
        return #{
            "kind": "IfLetExpr", "name": "", "value": "", "op": "",
            "left": pattern, "right": scrutinee, "cond": "", "then_body": then_b, "else_body": else_b,
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    let prev_supp = p_suppress_struct_lit
    p_suppress_struct_lit = true
    let cond = parse_expr()
    p_suppress_struct_lit = prev_supp
    let then_b = parse_block()
    let saved = p_pos
    p_skip_newlines()
    let mut else_b = []
    if p_peek_kind() == "Else" {
        p_advance()
        if p_peek_kind() == "If" {
            // else if -> nested
            let nested = parse_if_expr()
            else_b = [#{
                "kind": "ExprStmt", "name": "", "value": "", "op": "",
                "left": nested, "right": "", "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }]
        } else {
            else_b = parse_block()
        }
    } else {
        // No else — backtrack past consumed newlines
        p_pos = saved
    }
    return #{
        "kind": "IfExpr", "name": "", "value": "", "op": "",
        "left": "", "right": "", "cond": cond, "then_body": then_b, "else_body": else_b,
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── match expr { pattern -> body, ... } ─────────────────────

fn parse_match_expr() {
    p_advance() // consume 'match'
    let prev_supp = p_suppress_struct_lit
    p_suppress_struct_lit = true
    let scrutinee = parse_expr()
    p_suppress_struct_lit = prev_supp
    p_expect("LBrace")
    p_skip_newlines()
    let mut arms = []
    while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
        let pattern = parse_match_pattern()
        // G30: Or patterns — 1 | 2 | 3 -> body
        let mut or_patterns = ""
        if p_peek_kind() == "BitOr" {
            or_patterns = [pattern]
            while p_peek_kind() == "BitOr" {
                p_advance() // consume '|'
                or_patterns.push(parse_match_pattern())
            }
        }
        // Optional guard clause: pattern if condition -> body
        // NOTE: `guard` is a reserved keyword (GuardStmt). Use `_mguard` as the
        // variable name so the parser doesn't lex it as the keyword and crash
        // the rebuild of hexa_v2 from this file.
        let mut _mguard = ""
        if p_peek_kind() == "If" {
            p_advance() // consume 'if'
            _mguard = parse_expr()
        }
        p_expect("Arrow")
        let mut arm_body = []
        if p_peek_kind() == "LBrace" {
            arm_body = parse_block()
        } else {
            let arm_expr = parse_expr()
            arm_body = [#{
                "kind": "ExprStmt", "name": "", "value": "", "op": "",
                "left": arm_expr, "right": "", "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }]
        }
        arms.push(#{
            "kind": "MatchArm", "name": "", "value": "", "op": "",
            "left": pattern, "right": "", "cond": _mguard, "then_body": "", "else_body": "",
            "params": "", "body": arm_body, "args": "", "fields": "", "items": or_patterns,
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        })
        if p_peek_kind() == "Comma" {
            p_advance()
        }
        p_skip_newlines()
    }
    p_expect("RBrace")
    return #{
        "kind": "MatchExpr", "name": "", "value": "", "op": "",
        "left": scrutinee, "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": arms, "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// decreases x — structural
fn parse_match_pattern() {
    let tok = p_peek()
    // Wildcard _
    if tok.kind == "Ident" && tok.value == "_" {
        p_advance()
        return node_wildcard()
    }
    // Enum path: Name::Variant
    if tok.kind == "Ident" && p_peek_ahead(1).kind == "ColonColon" {
        let ename = tok.value
        p_advance() // enum name
        p_advance() // ::
        let vname = p_expect_ident()
        let mut data = ""
        let mut pat_items = ""
        if p_peek_kind() == "LParen" {
            p_advance()
            let mut plist = []
            while p_peek_kind() != "RParen" && p_peek_kind() != "Eof" {
                plist.push(parse_match_pattern())
                if p_peek_kind() == "Comma" { p_advance() }
            }
            p_expect("RParen")
            if len(plist) == 1 {
                data = plist[0]
            } else {
                pat_items = plist
            }
        }
        return #{
            "kind": "EnumPath", "name": ename, "value": vname, "op": "",
            "left": data, "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": pat_items,
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    // Array pattern: [first, second, ...rest]
    if tok.kind == "LBracket" {
        p_advance() // consume '['
        let mut pat_items = []
        while p_peek_kind() != "RBracket" && p_peek_kind() != "Eof" {
            // G32: ...rest spread pattern in array destructuring
            if p_peek_kind() == "DotDotDot" {
                p_advance() // consume '...'
                let rest_name = p_expect_ident()
                pat_items.push(#{
                    "kind": "RestPattern", "name": rest_name, "value": "", "op": "",
                    "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
                    "params": "", "body": "", "args": "", "fields": "", "items": "",
                    "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                    "target": "", "trait_name": "", "methods": ""
                })
            } else {
                pat_items.push(parse_match_pattern())
            }
            if p_peek_kind() == "Comma" { p_advance() }
        }
        p_expect("RBracket")
        return #{
            "kind": "Array", "name": "", "value": "", "op": "",
            "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": pat_items,
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    // Regular expression
    return parse_expr()
}

// ── G28: guard condition else { body } ─────────────────────
// guard EXPR else { BODY }
// guard let NAME = EXPR else { BODY }

fn parse_guard_stmt() {
    p_advance() // consume 'guard'
    // Check for `guard let x = expr else { ... }`
    if p_peek_kind() == "Let" {
        p_advance() // consume 'let'
        let name = p_expect_ident()
        p_expect("Eq")
        let expr = parse_expr()
        // expect 'else' keyword (token kind "Else")
        p_expect("Else")
        let else_body = parse_block()
        return #{
            "kind": "GuardLetStmt", "name": name, "value": "", "op": "",
            "left": expr, "right": "", "cond": "", "then_body": "", "else_body": else_body,
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    // Plain guard: guard EXPR else { BODY }
    let prev_supp = p_suppress_struct_lit
    p_suppress_struct_lit = true
    let cond = parse_expr()
    p_suppress_struct_lit = prev_supp
    p_expect("Else")
    let else_body = parse_block()
    return #{
        "kind": "GuardStmt", "name": "", "value": "", "op": "",
        "left": "", "right": "", "cond": cond, "then_body": "", "else_body": else_body,
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── G27: with EXPR as NAME { body } ───────────────────────

fn parse_with_stmt() {
    p_advance() // consume 'with'
    let expr = parse_expr()
    // expect 'as' keyword (token kind "As")
    let mut name = "_resource"
    if p_peek_kind() == "As" {
        p_advance() // consume 'as'
        name = p_expect_ident()
    }
    let body = parse_block()
    return #{
        "kind": "WithStmt", "name": name, "value": "", "op": "",
        "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": body, "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ══════════════════════════════════════════════════════════════
// Block: { stmts }
// ══════════════════════════════════════════════════════════════

fn parse_block() {
    p_skip_newlines()
    p_expect("LBrace")
    p_skip_newlines()
    let mut stmts = []
    while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
        stmts.push(parse_stmt())
        p_skip_newlines()
    }
    p_expect("RBrace")
    return stmts
}

// ══════════════════════════════════════════════════════════════
// Level 5: Expression (precedence climbing)
// ══════════════════════════════════════════════════════════════

fn parse_expr() {
    let left = parse_pipe()
    // G24: Walrus operator :=  (assignment expression)
    // If the left-hand side is an Ident and the next token is :=, treat as
    // walrus: evaluate RHS, bind to LHS name in current scope, return value.
    if p_peek_kind() == "ColonEq" {
        p_advance() // consume :=
        let right = parse_pipe()
        return #{
            "kind": "WalrusExpr", "name": left.name, "value": "", "op": ":=",
            "left": left, "right": right, "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    return left
}

// Level 5.0a: |> (pipe operator, lowest binary precedence)
fn parse_pipe() {
    let mut left = parse_null_coal()
    while p_peek_kind() == "Pipe" || p_continue_bin_op(["Pipe"]) {
        let op_tok = p_advance()
        p_skip_newlines()
        let right = parse_null_coal()
        left = #{
            "kind": "BinOp", "name": "", "value": "", "op": op_tok.value,
            "left": left, "right": right, "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    return left
}

// Level 5.0b: ?? (null coalescing — lower precedence than ||)
fn parse_null_coal() {
    let mut left = parse_or()
    while p_peek_kind() == "NullCoal" || p_continue_bin_op(["NullCoal"]) {
        let op_tok = p_advance()
        p_skip_newlines()
        let right = parse_or()
        left = #{
            "kind": "BinOp", "name": "", "value": "", "op": op_tok.value,
            "left": left, "right": right, "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    return left
}

// Level 5.1: || ^^
fn parse_or() {
    let mut left = parse_and()
    while p_peek_kind() == "Or" || p_peek_kind() == "Xor" || p_continue_bin_op(["Or", "Xor"]) {
        let op_tok = p_advance()
        p_skip_newlines()
        let right = parse_and()
        left = #{
            "kind": "BinOp", "name": "", "value": "", "op": op_tok.value,
            "left": left, "right": right, "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    return left
}

// Level 5.2: &&
fn parse_and() {
    let mut left = parse_bit_ops()
    while p_peek_kind() == "And" || p_continue_bin_op(["And"]) {
        let op_tok = p_advance()
        p_skip_newlines()
        let right = parse_bit_ops()
        left = #{
            "kind": "BinOp", "name": "", "value": "", "op": op_tok.value,
            "left": left, "right": right, "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    return left
}

// Level 5.2b: bitwise & | ^ << >> (between && and ==, C-like precedence)
// G40-G42: `|` is safe here — in infix position (after a left operand), `|`
// can only be bitwise-OR.  Lambda `|x| body` is parsed in parse_primary()
// which is expression-start only.  Similarly `<<`/`>>` have no ambiguity
// since generics `<T>` are parsed in type-annotation contexts, never here.
fn parse_bit_ops() {
    let mut left = parse_comparison()
    while p_peek_kind() == "BitAnd" || p_peek_kind() == "BitXor" || p_peek_kind() == "BitOr" || p_peek_kind() == "Shl" || p_peek_kind() == "Shr" || p_continue_bin_op(["BitAnd", "BitXor", "BitOr", "Shl", "Shr"]) {
        let op_tok = p_advance()
        p_skip_newlines()
        let right = parse_comparison()
        left = #{
            "kind": "BinOp", "name": "", "value": "", "op": op_tok.value,
            "left": left, "right": right, "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    return left
}

// Level 5.3: == != < > <= >= in is
fn parse_comparison() {
    let mut left = parse_bitwise()
    if !is_comparison_op(p_peek_kind()) {
        return left
    }
    let op_tok = p_advance()
    p_skip_newlines()
    let mut right = parse_bitwise()
    left = #{
        "kind": "BinOp", "name": "", "value": "", "op": op_tok.value,
        "left": left, "right": right, "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
    // G16: chained comparisons — a < b < c → (a < b) && (b < c)
    while is_comparison_op(p_peek_kind()) {
        let op2_tok = p_advance()
        p_skip_newlines()
        // "right" is the middle operand shared between two comparisons.
        // Wrap it in a LetStmt-style temp to ensure single evaluation.
        // For simplicity, reuse the already-parsed node (pure expressions).
        let middle = right
        let next = parse_bitwise()
        let right_cmp = #{
            "kind": "BinOp", "name": "", "value": "", "op": op2_tok.value,
            "left": middle, "right": next, "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
        left = #{
            "kind": "BinOp", "name": "", "value": "", "op": "&&",
            "left": left, "right": right_cmp, "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
        right = next
    }
    return left
}

// Level 5.3b: & | ^ << >> (bitwise operators)
fn parse_bitwise() {
    let mut left = parse_addition()
    while p_peek_kind() == "EqEq" || p_peek_kind() == "NotEq" || p_peek_kind() == "Lt" || p_peek_kind() == "Gt" || p_peek_kind() == "LtEq" || p_peek_kind() == "GtEq" || p_peek_kind() == "In" || (p_peek_kind() == "Ident" && p_peek().value == "is") || p_continue_bin_op(["EqEq", "NotEq", "Lt", "Gt", "LtEq", "GtEq"]) {
        let op_tok = p_advance()
        p_skip_newlines()
        if op_tok.value == "is" {
            // 'is' — right side is a type name (identifier), not an expression
            let type_tok = p_advance()
            let right = #{
                "kind": "Ident", "name": type_tok.value, "value": type_tok.value, "op": "",
                "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }
            left = #{
                "kind": "BinOp", "name": "", "value": "", "op": "is",
                "left": left, "right": right, "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }
        } else {
            let right = parse_addition()
            left = #{
                "kind": "BinOp", "name": "", "value": "", "op": op_tok.value,
                "left": left, "right": right, "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }
        }
    }
    return left
}

// Level 5.4: + -
fn parse_addition() {
    let mut left = parse_multiplication()
    // T35: Plus can't start a standalone statement. p_continue_bin_op
    // looks past newlines and, if the first meaningful token matches,
    // skips the newlines so the existing while condition sees `+`.
    // Minus stays out of the kinds list because it doubles as unary `-`.
    while p_peek_kind() == "Plus" || p_peek_kind() == "Minus" || p_continue_bin_op(["Plus"]) {
        let op_tok = p_advance()
        p_skip_newlines()
        let right = parse_multiplication()
        left = #{
            "kind": "BinOp", "name": "", "value": "", "op": op_tok.value,
            "left": left, "right": right, "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    return left
}

// Level 5.5: * / % **
fn parse_multiplication() {
    let mut left = parse_unary()
    while p_peek_kind() == "Star" || p_peek_kind() == "Slash" || p_peek_kind() == "Percent" || p_peek_kind() == "Power" || p_continue_bin_op(["Star", "Slash", "Percent", "Power"]) {
        let op_tok = p_advance()
        p_skip_newlines()
        let right = parse_unary()
        left = #{
            "kind": "BinOp", "name": "", "value": "", "op": op_tok.value,
            "left": left, "right": right, "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    return left
}

// Level 5.6: Unary ! - ~ typeof
// decreases x — structural
fn parse_unary() {
    let k = p_peek_kind()
    if k == "Not" || k == "Minus" || k == "BitNot" {
        let op_tok = p_advance()
        let operand = parse_unary()
        return #{
            "kind": "UnaryOp", "name": "", "value": "", "op": op_tok.value,
            "left": operand, "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    // G37: typeof operator — typeof x returns "int", "str", etc.
    if k == "Typeof" {
        p_advance()
        let operand = parse_unary()
        return #{
            "kind": "UnaryOp", "name": "", "value": "", "op": "typeof",
            "left": operand, "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    return parse_postfix()
}

// ── Postfix: call, field access, index ──────────────────────

fn parse_postfix() {
    let mut expr = parse_primary()
    let mut cont = true
    // @partial — body break/return/throw governs termination
    while cont {
        let mut k = p_peek_kind()
        // `.method()` / `.field` on next line: Rust/JS-style continuation.
        // Peek past newlines; if next meaningful token is Dot, consume the
        // newlines so the Dot branch below fires. Non-Dot token → break.
        if k == "Newline" {
            let mut _off = 1
            while p_peek_ahead(_off).kind == "Newline" { _off = _off + 1 }
            if p_peek_ahead(_off).kind == "Dot" {
                while p_peek_kind() == "Newline" { p_advance() }
                k = "Dot"
            } else {
                cont = false
                k = ""
            }
        }
        if k == "LParen" {
            // Function call
            p_advance()
            let args = parse_args()
            p_expect("RParen")
            expr = #{
                "kind": "Call", "name": "", "value": "", "op": "",
                "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": args, "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }
        } else if k == "Dot" {
            // Field access or tuple index (.0, .1, ...)
            p_advance()
            let next_k = p_peek_kind()
            if next_k == "IntLit" {
                // Tuple field: expr.0 → Index(expr, IntLit)
                let idx_tok = p_advance()
                expr = #{
                    "kind": "Index", "name": "", "value": "", "op": "",
                    "left": expr, "right": #{"kind": "IntLit", "name": "", "value": idx_tok["value"], "op": "", "left": "", "right": "", "cond": "", "then_body": "", "else_body": "", "params": "", "body": "", "args": "", "fields": "", "items": "", "variants": "", "arms": "", "iter_expr": "", "ret_type": "", "target": "", "trait_name": "", "methods": ""}, "cond": "", "then_body": "", "else_body": "",
                    "params": "", "body": "", "args": "", "fields": "", "items": "",
                    "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                    "target": "", "trait_name": "", "methods": ""
                }
            } else {
                let field_name = p_expect_ident()
                expr = #{
                    "kind": "Field", "name": field_name, "value": "", "op": "",
                    "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
                    "params": "", "body": "", "args": "", "fields": "", "items": "",
                    "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                    "target": "", "trait_name": "", "methods": ""
                }
            }
        } else if k == "QuestionDot" {
            // Optional chaining: expr?.field — returns void if expr is void
            p_advance()
            let field_name = p_expect_ident()
            expr = #{
                "kind": "OptField", "name": field_name, "value": "", "op": "",
                "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }
        } else if k == "LBracket" {
            // Index access or slice syntax: arr[i], arr[1:3], arr[:3], arr[2:], arr[:]
            p_advance()
            // G20: Check for slice syntax — [:...] (colon immediately)
            if p_peek_kind() == "Colon" {
                // arr[:end] or arr[:]
                p_advance() // consume ':'
                let mut slice_end = ""
                if p_peek_kind() != "RBracket" {
                    slice_end = parse_expr()
                }
                p_expect("RBracket")
                expr = #{
                    "kind": "Slice", "name": "", "value": "", "op": "",
                    "left": expr, "right": "", "cond": slice_end, "then_body": "", "else_body": "",
                    "params": "", "body": "", "args": "", "fields": "", "items": "",
                    "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                    "target": "", "trait_name": "", "methods": ""
                }
            } else {
                let index = parse_expr()
                // G20: Check if this is a slice: arr[start:end] or arr[start:]
                if p_peek_kind() == "Colon" {
                    p_advance() // consume ':'
                    let mut slice_end = ""
                    if p_peek_kind() != "RBracket" {
                        slice_end = parse_expr()
                    }
                    p_expect("RBracket")
                    expr = #{
                        "kind": "Slice", "name": "", "value": "", "op": "",
                        "left": expr, "right": index, "cond": slice_end, "then_body": "", "else_body": "",
                        "params": "", "body": "", "args": "", "fields": "", "items": "",
                        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                        "target": "", "trait_name": "", "methods": ""
                    }
                } else {
                    p_expect("RBracket")
                    expr = #{
                        "kind": "Index", "name": "", "value": "", "op": "",
                        "left": expr, "right": index, "cond": "", "then_body": "", "else_body": "",
                        "params": "", "body": "", "args": "", "fields": "", "items": "",
                        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                        "target": "", "trait_name": "", "methods": ""
                    }
                }
            }
        } else if k == "DotDot" {
            // Range
            p_advance()
            let end = parse_addition()
            // G21: step range — 0..10 step 2
            let mut step_expr = ""
            if p_peek_kind() == "Step" {
                p_advance() // consume 'step'
                step_expr = parse_addition()
            }
            expr = #{
                "kind": "Range", "name": "", "value": "exclusive", "op": "",
                "left": expr, "right": end, "cond": step_expr, "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }
        } else if k == "DotDotEq" {
            // Inclusive range
            p_advance()
            let end = parse_addition()
            // G21: step range — 0..=10 step 2
            let mut step_expr2 = ""
            if p_peek_kind() == "Step" {
                p_advance() // consume 'step'
                step_expr2 = parse_addition()
            }
            expr = #{
                "kind": "Range", "name": "", "value": "inclusive", "op": "",
                "left": expr, "right": end, "cond": step_expr2, "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }
        } else if k == "As" {
            // G10: type cast — x as int / x as float / x as str
            p_advance()
            let type_name = p_expect_ident()
            expr = #{
                "kind": "BinOp", "name": "", "value": "", "op": "as",
                "left": expr, "right": node_ident(type_name), "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }
        } else {
            cont = false
        }
    }
    return expr
}

fn parse_args() {
    let mut args = []
    // G12: allow newline-separated multiline call args — skip newlines before/after each arg and commas
    p_skip_newlines()
    if p_peek_kind() == "RParen" {
        return args
    }
    p_skip_newlines()
    // G8: spread in call args — `f(...args)`
    if p_peek_kind() == "DotDotDot" {
        p_advance()
        let spread_expr = parse_expr()
        args.push(#{
            "kind": "Spread", "name": "", "value": "", "op": "",
            "left": spread_expr, "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        })
    } else {
        args.push(parse_expr())
    }
    p_skip_newlines()
    while p_peek_kind() == "Comma" {
        p_advance()
        p_skip_newlines()
        if p_peek_kind() == "DotDotDot" {
            p_advance()
            let spread_expr = parse_expr()
            args.push(#{
                "kind": "Spread", "name": "", "value": "", "op": "",
                "left": spread_expr, "right": "", "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            })
        } else {
            args.push(parse_expr())
        }
        p_skip_newlines()
    }
    p_skip_newlines()
    return args
}

// ══════════════════════════════════════════════════════════════
// Level 6: Primary
// ══════════════════════════════════════════════════════════════

// G-AMBIG (2026-05-04): `Foo<Bar` ambiguity — disambiguate generic-args
// from comparison `<`. Pure lookahead: scan forward from the current `<`
// token, tracking `<>` nesting and accepting only tokens that can appear
// inside a generic-arg list (Ident/path/Comma/Colon/Question/brackets).
// Commit to type-args ONLY if a matching `>` is found AND the next token
// is `{` (struct literal — the only context that consumes type_args here)
// OR `(` (turbofish-style call). Otherwise return false → `<` is treated
// as comparison.  Repro that motivated this: `while L < n_layers { ... }`
// with capital `L` was eaten as `L<n_layers>` and then the trailing `{`
// emitted a parse error. (See C8 commit c6a62ecb workaround.)
// Mirror of self/parser.hexa::p_lookahead_generic_args().
fn p_lookahead_generic_args() {
    if p_peek_kind() != "Lt" { return false }
    let mut i = 1   // offset past the opening `<`
    let mut depth = 1
    let max_scan = 64   // bound — generic lists are short; comparisons are common
    while i < max_scan {
        let t = p_peek_ahead(i)
        let k = t.kind
        if k == "Eof" { return false }
        if k == "Newline" { return false }
        if k == "Semicolon" { return false }
        if k == "LBrace" { return false }
        if k == "RBrace" { return false }
        if k == "Lt" { depth = depth + 1 }
        else if k == "Gt" {
            depth = depth - 1
            if depth == 0 {
                let nxt = p_peek_ahead(i + 1).kind
                if nxt == "LBrace" { return true }
                if nxt == "LParen" { return true }
                return false
            }
        }
        else if k == "GtEq" {
            return false
        }
        else if k == "Shr" || k == "ShrAssign" {
            return false
        }
        else if k == "Ident" || k == "ColonColon" || k == "Comma" || k == "Colon"
             || k == "Question" || k == "LBracket" || k == "RBracket"
             || k == "LParen" || k == "RParen" || k == "Amp" || k == "Star"
             || k == "IntLit" || k == "BitOr" || k == "Pipe" {
            // OK — valid inside a type expression
        }
        else {
            return false
        }
        i = i + 1
    }
    return false
}

fn parse_primary() {
    let tok = p_peek()
    let k = tok.kind

    if k == "IntLit" {
        p_advance()
        return node_int_lit(tok.value)
    }
    if k == "FloatLit" {
        p_advance()
        return node_float_lit(tok.value)
    }
    if k == "BoolLit" {
        p_advance()
        return node_bool_lit(tok.value)
    }
    if k == "StringLit" {
        p_advance()
        return node_string_lit(tok.value)
    }
    if k == "CharLit" {
        p_advance()
        return node_char_lit(tok.value)
    }
    if k == "Ident" || p_is_contextual_kw_kind(k) {
        p_advance()
        let name = tok.value
        // Check for enum path: Name::Variant
        if p_peek_kind() == "ColonColon" {
            p_advance() // consume ::
            let variant = p_expect_ident()
            return #{
                "kind": "EnumPath", "name": name, "value": variant, "op": "",
                "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }
        }
        // C4: Check for generic struct init: Name<Int, String> { ... }
        // or plain struct init: Name { field: val, ... }
        // Convention: name starts with uppercase.
        // G-AMBIG: also require p_lookahead_generic_args() — see helper above.
        // Without this gate, `while L < n_layers { ... }` (capital `L`) is
        // eaten as a generic-args list, then the trailing `{` panics.
        let mut type_args = []
        if p_peek_kind() == "Lt" {
            let chars = name.chars()
            if len(chars) > 0 {
                let first_ch = chars[0]
                if is_alpha(first_ch) && to_string(first_ch) == to_string(first_ch).to_upper() {
                    if p_lookahead_generic_args() {
                        type_args = parse_type_params()
                    }
                }
            }
        }
        if p_peek_kind() == "LBrace" && !p_suppress_struct_lit {
            let chars = name.chars()
            if len(chars) > 0 {
                let first_ch = chars[0]
                if is_alpha(first_ch) && to_string(first_ch) == to_string(first_ch).to_upper() {
                    p_advance() // consume {
                    p_skip_newlines()
                    let mut fields = []
                    while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
                        let fname = p_expect_ident()
                        p_expect("Colon")
                        let fval = parse_expr()
                        fields.push(#{
                            "kind": "FieldInit", "name": fname, "value": "", "op": "",
                            "left": fval, "right": "", "cond": "", "then_body": "", "else_body": "",
                            "params": "", "body": "", "args": "", "fields": "", "items": "",
                            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                            "target": "", "trait_name": "", "methods": ""
                        })
                        if p_peek_kind() == "Comma" {
                            p_advance()
                        }
                        p_skip_newlines()
                    }
                    p_expect("RBrace")
                    return #{
                        "kind": "StructInit", "name": name, "value": "", "op": "",
                        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
                        "params": "", "body": "", "args": "", "fields": fields, "items": type_args,
                        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                        "target": "", "trait_name": "", "methods": ""
                    }
                }
            }
        }
        return node_ident(name)
    }
    if k == "LParen" {
        p_advance()
        let expr = parse_expr()
        // Check for tuple
        if p_peek_kind() == "Comma" {
            let mut items = [expr]
            while p_peek_kind() == "Comma" {
                p_advance()
                if p_peek_kind() == "RParen" { }
                else {
                    items.push(parse_expr())
                }
            }
            p_expect("RParen")
            return #{
                "kind": "Tuple", "name": "", "value": "", "op": "",
                "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": items,
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }
        }
        p_expect("RParen")
        return expr  // grouped expression
    }
    if k == "LBracket" {
        // Array literal or list comprehension
        p_advance()
        // T35+: multi-line array literal — skip newlines after `[`.
        p_skip_newlines()
        // Empty array: []
        if p_peek_kind() == "RBracket" {
            p_advance()
            return #{
                "kind": "Array", "name": "", "value": "", "op": "",
                "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": [],
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }
        }
        // Parse first expression
        let first = parse_expr()
        // Check for list comprehension: [expr for var in iterable]
        //                            or [expr for var in iterable if cond]
        if p_peek_kind() == "For" {
            p_advance() // consume 'for'
            let comp_var = p_expect_ident()
            let in_tok = p_advance()
            if in_tok.value != "in" {
                let comp_msg = format("expected 'in' after comprehension variable, got '{}'", in_tok.value)
                p_record_error(in_tok.line, in_tok.col, comp_msg)
                println("Parse error: " + comp_msg)
            }
            let comp_iter = parse_expr()
            // Optional filter: if condition
            let mut comp_cond = ""
            if p_peek_kind() == "If" {
                p_advance() // consume 'if'
                comp_cond = parse_expr()
            }
            p_expect("RBracket")
            return #{
                "kind": "ListComp", "name": comp_var, "value": "", "op": "",
                "left": first, "right": "", "cond": comp_cond, "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": comp_iter, "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }
        }
        // Normal array literal: continue parsing remaining items
        let mut items = [first]
        if p_peek_kind() == "Comma" {
            p_advance()
        }
        // T35+: multi-line array literal — skip newlines after first comma.
        p_skip_newlines()
        while p_peek_kind() != "RBracket" && p_peek_kind() != "Eof" {
            if p_peek_kind() == "DotDotDot" {
                // G8: spread element — `...expr`
                p_advance() // consume ...
                let spread_expr = parse_expr()
                items.push(#{
                    "kind": "Spread", "name": "", "value": "", "op": "",
                    "left": spread_expr, "right": "", "cond": "", "then_body": "", "else_body": "",
                    "params": "", "body": "", "args": "", "fields": "", "items": "",
                    "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                    "target": "", "trait_name": "", "methods": ""
                })
            } else {
                items.push(parse_expr())
            }
            if p_peek_kind() == "Comma" {
                p_advance()
            }
            // T35+: multi-line array literal — skip newlines after each item/comma.
            p_skip_newlines()
        }
        p_expect("RBracket")
        return #{
            "kind": "Array", "name": "", "value": "", "op": "",
            "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": items,
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    if k == "HashLBrace" {
        // Map literal: #{ "key": value, ... }
        p_advance() // consume #{
        p_skip_newlines()
        let mut items = []
        while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
            let key_expr = parse_expr()
            p_expect("Colon")
            let val_expr = parse_expr()
            items.push(#{
                "kind": "MapEntry", "name": "", "value": "", "op": "",
                "left": key_expr, "right": val_expr, "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            })
            if p_peek_kind() == "Comma" {
                p_advance()
            }
            p_skip_newlines()
        }
        p_expect("RBrace")
        return #{
            "kind": "MapLit", "name": "", "value": "", "op": "",
            "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": items,
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    // hxa-20260423-005: empty map literal `{}` at expression position.
    // Accepts only when LBrace is immediately followed by RBrace — avoids
    // ambiguity with block expressions. Non-empty maps still require `#{...}`
    // to distinguish from struct init / block expressions.
    if k == "LBrace" && p_peek_ahead(1).kind == "RBrace" {
        p_advance() // consume {
        p_advance() // consume }
        return #{
            "kind": "MapLit", "name": "", "value": "", "op": "",
            "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": [],
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    // hxa-20260423-014: `comptime { expr }` at expression position.
    // Mirrors the self/parser.hexa fix — consume the block-wrapped
    // expression and return a ComptimeExpr wrapper for codegen.
    if k == "Comptime" {
        p_advance() // consume 'comptime'
        p_expect("LBrace")
        p_skip_newlines()
        let inner = parse_expr()
        p_skip_newlines()
        p_expect("RBrace")
        return #{
            "kind": "ComptimeExpr", "name": "", "value": "", "op": "",
            "left": inner, "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": [],
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    if k == "If" {
        return parse_if_expr()
    }
    if k == "Match" {
        return parse_match_expr()
    }
    if k == "BitOr" {
        // Lambda: |params| body
        p_advance() // consume first |
        let mut lparams = []
        if p_peek_kind() != "BitOr" {
            lparams.push(p_expect_ident())
            while p_peek_kind() == "Comma" {
                p_advance()
                lparams.push(p_expect_ident())
            }
        }
        p_expect("BitOr") // consume closing |
        let mut lbody = ""
        if p_peek_kind() == "LBrace" {
            lbody = parse_block()
        } else {
            lbody = parse_expr()
        }
        return #{
            "kind": "Lambda", "name": "", "value": "", "op": "",
            "left": lbody, "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": lparams, "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    if k == "Or" {
        // Zero-arg lambda: || body
        // Ambiguous with logical-or, but in primary-expression position
        // we're always at the START of an expression so || must be lambda.
        p_advance() // consume ||
        let mut lbody = ""
        if p_peek_kind() == "LBrace" {
            lbody = parse_block()
        } else {
            lbody = parse_expr()
        }
        return #{
            "kind": "Lambda", "name": "", "value": "", "op": "",
            "left": lbody, "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": [], "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    if k == "Fn" {
        // Anonymous fn: fn(params) -> ret? { body }
        p_advance() // consume 'fn'
        p_expect("LParen")
        let fparams = parse_params()
        p_expect("RParen")
        // Optional return type
        if p_peek_kind() == "Arrow" {
            p_advance()
            let _ret = parse_type_annotation()
        }
        let fbody = parse_block()
        return #{
            "kind": "Lambda", "name": "", "value": "", "op": "",
            "left": fbody, "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": fparams, "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }

    // T26: comptime { expr } — compile-time evaluated block in expression position.
    // MVP: parse as a block expression wrapped in ComptimeExpr; the inner block
    // is evaluated at runtime. Full comptime semantics (evaluation during
    // parse/analysis, literal folding) can be tightened later.
    if k == "Comptime" {
        p_advance() // consume 'comptime'
        let cbody = parse_block()
        return #{
            "kind": "ComptimeExpr", "name": "", "value": "", "op": "",
            "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": cbody, "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }

    // Unknown token
    let msg3 = "unexpected token " + tok.kind + " ('" + tok.value + "')"
    p_record_error(tok.line, tok.col, msg3)
    p_emit_parse_error(tok, msg3)
    p_advance() // skip to avoid infinite loop
    return empty_node()
}

// ══════════════════════════════════════════════════════════════
// Phase 1 additions: 14 missing parse functions for self-hosting
// ══════════════════════════════════════════════════════════════

// ── try { ... } catch(e) { ... } ────────────────────────────
fn parse_try_catch() {
    p_advance() // consume 'try'
    let try_body = parse_block()
    p_skip_newlines()
    p_expect("Catch")
    let mut catch_var = "_"
    if p_peek_kind() == "LParen" {
        // catch(e) syntax
        p_advance()
        catch_var = p_expect_ident()
        p_expect("RParen")
    } else {
        if p_peek_kind() == "Ident" {
            // catch e syntax (no parens)
            catch_var = p_expect_ident()
        }
    }
    let catch_body = parse_block()
    return #{
        "kind": "TryCatch", "name": catch_var, "value": "", "op": "",
        "left": try_body, "right": catch_body, "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── throw expr ──────────────────────────────────────────────
fn parse_throw_stmt() {
    p_advance() // consume 'throw'
    let expr = parse_expr()
    return #{
        "kind": "ThrowStmt", "name": "", "value": "", "op": "",
        "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── panic(msg) ──────────────────────────────────────────────
fn parse_panic_stmt() {
    p_advance() // consume 'panic'
    p_expect("LParen")
    let msg = parse_expr()
    p_expect("RParen")
    return #{
        "kind": "PanicStmt", "name": "", "value": "", "op": "",
        "left": msg, "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── recover { body } | recover |e| { body } ───────────────
fn parse_recover_stmt() {
    p_advance() // consume 'recover'
    let mut catch_var = "_"
    // Check for |e| error binding syntax
    if p_peek_kind() == "BitOr" {
        p_advance() // consume first |
        catch_var = p_expect_ident()
        p_expect("BitOr") // consume closing |
    }
    let body = parse_block()
    return #{
        "kind": "RecoverStmt", "name": catch_var, "value": "", "op": "",
        "left": body, "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── drop(var) ───────────────────────────────────────────────
fn parse_drop_stmt() {
    p_advance() // consume 'drop'
    p_expect("LParen")
    let var_name = p_expect_ident()
    p_expect("RParen")
    return #{
        "kind": "DropStmt", "name": var_name, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── spawn { body } ──────────────────────────────────────────
fn parse_spawn_stmt() {
    p_advance() // consume 'spawn'
    let body = parse_block()
    return #{
        "kind": "SpawnStmt", "name": "", "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": body, "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── scope { body } ──────────────────────────────────────────
fn parse_scope_stmt() {
    p_advance() // consume 'scope'
    let body = parse_block()
    return #{
        "kind": "ScopeStmt", "name": "", "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": body, "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── select { arm1, arm2, ... } ──────────────────────────────
fn parse_select_stmt() {
    p_advance() // consume 'select'
    p_expect("LBrace")
    p_skip_newlines()
    let mut arms = []
    while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
        let expr = parse_expr()
        p_expect("Arrow")
        let body = parse_block()
        arms.push(#{
            "kind": "SelectArm", "name": "", "value": "", "op": "",
            "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": body, "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        })
        p_skip_newlines()
    }
    p_expect("RBrace")
    return #{
        "kind": "SelectStmt", "name": "", "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": arms, "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── async fn name(params) { body } ──────────────────────────
fn parse_async_fn() {
    p_advance() // consume 'async'
    p_expect("Fn")
    let name = p_expect_ident()
    p_expect("LParen")
    let params = parse_params()
    p_expect("RParen")
    let mut ret = ""
    if p_peek_kind() == "Arrow" {
        p_advance()
        ret = parse_type_annotation()
    }
    let body = parse_block()
    // M0+: consume typed annotations (same channel as parse_fn_decl)
    let mut annot_str = ""
    let mut _ai = 0
    while _ai < len(p_pending_annotations) {
        if annot_str != "" { annot_str = annot_str + ";" }
        annot_str = annot_str + p_pending_annotations[_ai]
        _ai = _ai + 1
    }
    p_pending_annotations = []
    return #{
        "kind": "AsyncFnDecl", "name": name, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": params, "body": body, "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": ret,
        "target": "", "trait_name": "", "methods": "", "annotations": annot_str
    }
}

// ── @attribute(...) prefix ───────────────────────────────────
// Handles @symbol("name"), @link("lib"), and other attributes.
// Stores the value in pending state, then re-dispatches parse_stmt.
fn parse_attribute_prefix() {
    let attr = p_advance() // consume Attribute token
    let attr_name = attr.value

    if attr_name == "symbol" || attr_name == "link" {
        p_expect("LParen")
        let tok = p_advance()
        let val = tok.value
        p_expect("RParen")
        if attr_name == "symbol" {
            p_pending_symbol = val
        } else {
            p_pending_link = val
        }
        p_skip_newlines()
        return parse_stmt()
    }

    // Unknown attribute — skip and continue
    if p_peek_kind() == "LParen" {
        p_advance() // consume (
        let mut depth = 1
        while depth > 0 && p_peek_kind() != "Eof" {
            if p_peek_kind() == "LParen" { depth = depth + 1 }
            if p_peek_kind() == "RParen" { depth = depth - 1 }
            p_advance()
        }
    }
    p_skip_newlines()
    return parse_stmt()
}

// ── extern fn name(params) -> ret ───────────────────────────
// Supports @symbol("c_name") and @link("lib") attributes.
// @symbol("c_name") maps hexa name to a different C symbol for dlsym.
// The symbol_name field holds the C symbol; if empty, name is used.
fn parse_extern_fn() {
    p_advance() // consume 'extern'
    p_expect("Fn")
    let name = p_expect_ident()
    p_expect("LParen")
    let params = parse_params()
    p_expect("RParen")
    let mut ret = ""
    if p_peek_kind() == "Arrow" {
        p_advance()
        ret = parse_type_annotation()
    }
    // extern fn may have no body (declaration only)
    let mut body = []
    if p_peek_kind() == "LBrace" {
        body = parse_block()
    }
    // Consume pending @symbol / @link attributes
    let sym = p_pending_symbol
    let link = p_pending_link
    p_pending_symbol = ""
    p_pending_link = ""
    return #{
        "kind": "ExternFnDecl", "name": name, "value": sym, "op": link,
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": params, "body": body, "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": ret,
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── type Name = existing_type ───────────────────────────────
fn parse_type_alias() {
    p_advance() // consume 'type'
    let name = p_expect_ident()
    p_expect("Eq")
    let typ = parse_type_annotation()
    return #{
        "kind": "TypeAlias", "name": name, "value": typ, "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── atomic let name = expr ──────────────────────────────────
fn parse_atomic_let() {
    p_advance() // consume 'atomic'
    p_expect("Let")
    let name = p_expect_ident()
    // Optional type annotation: atomic let x: int = 0
    let mut typ = ""
    if p_peek_kind() == "Colon" {
        p_advance()
        typ = parse_type_annotation()
    }
    p_expect("Eq")
    let expr = parse_expr()
    return #{
        "kind": "AtomicLet", "name": name, "value": typ, "op": "",
        "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ══════════════════════════════════════════════════════════════
// Phase 2 additions: 15 missing parse functions for full parity
// ══════════════════════════════════════════════════════════════

// ── break [label] ──────────────────────────────────────────
fn parse_break_stmt() {
    p_advance() // consume 'break'
    // Optional label: break 'outer  or  break outer
    let mut label = ""
    if p_peek_kind() == "Label" {
        label = p_advance().value
    } else if p_peek_kind() == "Ident" {
        // Also support unlabeled syntax: break outer
        label = p_advance().value
    }
    return #{
        "kind": "BreakStmt", "name": label, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── continue [label] ──────────────────────────────────────
fn parse_continue_stmt() {
    p_advance() // consume 'continue'
    // Optional label: continue 'outer  or  continue outer
    let mut label = ""
    if p_peek_kind() == "Label" {
        label = p_advance().value
    } else if p_peek_kind() == "Ident" {
        label = p_advance().value
    }
    return #{
        "kind": "ContinueStmt", "name": label, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── do { body } while cond ─────────────────────────────────
fn parse_do_while_stmt() {
    p_advance() // consume 'do'
    let body = parse_block()
    // expect 'while' keyword
    if p_peek_kind() == "While" {
        p_advance()
    } else {
        let tok = p_peek()
        p_record_error(tok.line, tok.col, "expected 'while' after do block")
        println("Parse error: expected 'while' after do block")
    }
    let prev_supp = p_suppress_struct_lit
    p_suppress_struct_lit = true
    let cond = parse_expr()
    p_suppress_struct_lit = prev_supp
    return #{
        "kind": "DoWhileStmt", "name": "", "value": "", "op": "",
        "left": "", "right": "", "cond": cond, "then_body": "", "else_body": "",
        "params": "", "body": body, "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── defer { block } | defer expr ───────────────────────────
fn parse_defer_stmt() {
    p_advance() // consume 'defer'
    let mut body = []
    if p_peek_kind() == "LBrace" {
        // Block form: defer { cleanup() }
        body = parse_block()
    } else {
        // Single expression form: defer close(file)
        let expr = parse_expr()
        body = [#{
            "kind": "ExprStmt", "name": "", "value": "", "op": "",
            "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }]
    }
    return #{
        "kind": "DeferStmt", "name": "", "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": body, "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── 'label: for/while/loop { ... } ─────────────────────────
fn parse_labeled_loop() {
    let label = p_advance().value  // consume Label token (value is the label name)
    // expect ':'
    if p_peek_kind() == "Colon" {
        p_advance()
    } else {
        let tok = p_peek()
        p_record_error(tok.line, tok.col, "expected ':' after label")
        println("Parse error: expected ':' after label '" + label + "'")
    }
    // Parse the loop statement — must be for/while/loop
    let next = p_peek_kind()
    let mut loop_node = ""
    if next == "For" {
        loop_node = parse_for_stmt()
    } else if next == "While" {
        loop_node = parse_while_stmt()
    } else if next == "Loop" {
        loop_node = parse_loop_stmt()
    } else {
        let tok = p_peek()
        p_record_error(tok.line, tok.col, "expected for/while/loop after label")
        println("Parse error: expected for/while/loop after label '" + label + "'")
        return empty_node()
    }
    // Attach the label to the loop node via the "name" field
    // ForStmt already uses "name" for the variable, so use "target" for label
    return #{
        "kind": loop_node.kind, "name": loop_node.name, "value": label, "op": loop_node.op,
        "left": loop_node.left, "right": loop_node.right, "cond": loop_node.cond,
        "then_body": loop_node.then_body, "else_body": loop_node.else_body,
        "params": loop_node.params, "body": loop_node.body, "args": loop_node.args,
        "fields": loop_node.fields, "items": loop_node.items,
        "variants": loop_node.variants, "arms": loop_node.arms,
        "iter_expr": loop_node.iter_expr, "ret_type": loop_node.ret_type,
        "target": loop_node.target, "trait_name": loop_node.trait_name,
        "methods": loop_node.methods
    }
}

// ── yield expr ──────────────────────────────────────────────
fn parse_yield_stmt() {
    p_advance() // consume 'yield'
    let mut expr = ""
    if p_peek_kind() != "Newline" && p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
        expr = parse_expr()
    }
    return #{
        "kind": "YieldStmt", "name": "", "value": "", "op": "",
        "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── comptime { block } | comptime fn | comptime const | comptime let ──
fn parse_comptime_stmt() {
    p_advance() // consume 'comptime'
    let next = p_peek_kind()
    if next == "Fn" {
        // comptime fn name(params) { body }
        p_advance() // consume 'fn'
        let name = p_expect_ident()
        p_expect("LParen")
        let params = parse_params()
        p_expect("RParen")
        let mut ret = ""
        if p_peek_kind() == "Arrow" {
            p_advance()
            ret = parse_type_annotation()
        }
        let body = parse_block()
        return #{
            "kind": "ComptimeFnDecl", "name": name, "value": "", "op": "",
            "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": params, "body": body, "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": ret,
            "target": "", "trait_name": "", "methods": ""
        }
    }
    if next == "Const" {
        // comptime const name = expr
        p_advance() // consume 'const'
        let name = p_expect_ident()
        let mut typ = ""
        if p_peek_kind() == "Colon" {
            p_advance()
            typ = parse_type_annotation()
        }
        p_expect("Eq")
        let expr = parse_expr()
        return #{
            "kind": "ComptimeConst", "name": name, "value": typ, "op": "",
            "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    if next == "Let" {
        // comptime let name = expr
        p_advance() // consume 'let'
        if p_peek_kind() == "Mut" {
            p_advance()
        }
        let name = p_expect_ident()
        let mut typ = ""
        if p_peek_kind() == "Colon" {
            p_advance()
            typ = parse_type_annotation()
        }
        p_expect("Eq")
        let expr = parse_expr()
        return #{
            "kind": "ComptimeLet", "name": name, "value": typ, "op": "",
            "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    if next == "Assert" {
        // comptime assert expr
        p_advance() // consume 'assert'
        let expr = parse_expr()
        return #{
            "kind": "ComptimeAssert", "name": "", "value": "", "op": "",
            "left": expr, "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        }
    }
    // comptime { block } — compile-time block
    let body = parse_block()
    return #{
        "kind": "ComptimeBlock", "name": "", "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": body, "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── intent "description" { key: value, ... } ────────────────
fn parse_intent_stmt() {
    p_advance() // consume 'intent'
    // intent accepts a string literal or identifier as description
    let mut desc = ""
    if p_peek_kind() == "StringLit" {
        desc = p_advance().value
    } else {
        desc = p_expect_ident()
    }
    p_expect("LBrace")
    p_skip_newlines()
    let mut fields = []
    while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
        let key = p_expect_ident()
        p_expect("Colon")
        let val = parse_expr()
        fields.push(#{
            "kind": "IntentField", "name": key, "value": "", "op": "",
            "left": val, "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        })
        if p_peek_kind() == "Comma" {
            p_advance()
        }
        p_skip_newlines()
    }
    p_expect("RBrace")
    return #{
        "kind": "IntentStmt", "name": desc, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": fields, "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── verify "name" { block } ────────────────────────────────
fn parse_verify_stmt() {
    p_advance() // consume 'verify'
    let mut name = ""
    if p_peek_kind() == "StringLit" {
        name = p_advance().value
    } else {
        name = p_expect_ident()
    }
    let body = parse_block()
    return #{
        "kind": "VerifyStmt", "name": name, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": body, "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── generate fn name(params) { "desc" } | generate { "desc" } ──
fn parse_generate_stmt() {
    p_advance() // consume 'generate'
    if p_peek_kind() == "Fn" {
        // generate fn name(params) -> ret { "description" }
        p_advance() // consume 'fn'
        let name = p_expect_ident()
        p_expect("LParen")
        let params = parse_params()
        p_expect("RParen")
        let mut ret = ""
        if p_peek_kind() == "Arrow" {
            p_advance()
            ret = parse_type_annotation()
        }
        p_expect("LBrace")
        p_skip_newlines()
        let mut desc = ""
        if p_peek_kind() == "StringLit" {
            desc = p_advance().value
        }
        p_skip_newlines()
        p_expect("RBrace")
        return #{
            "kind": "GenerateFnStmt", "name": name, "value": desc, "op": "",
            "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": params, "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": ret,
            "target": "", "trait_name": "", "methods": ""
        }
    }
    // generate [type_hint] { "description" }
    let mut type_hint = ""
    if p_peek_kind() != "LBrace" {
        type_hint = p_expect_ident()
    }
    p_expect("LBrace")
    p_skip_newlines()
    let mut desc = ""
    if p_peek_kind() == "StringLit" {
        desc = p_advance().value
    }
    p_skip_newlines()
    p_expect("RBrace")
    return #{
        "kind": "GenerateStmt", "name": type_hint, "value": desc, "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── optimize fn name(params) { body } ──────────────────────
fn parse_optimize_stmt() {
    p_advance() // consume 'optimize'
    p_expect("Fn")
    let name = p_expect_ident()
    p_expect("LParen")
    let params = parse_params()
    p_expect("RParen")
    let mut ret = ""
    if p_peek_kind() == "Arrow" {
        p_advance()
        ret = parse_type_annotation()
    }
    let body = parse_block()
    return #{
        "kind": "OptimizeFnStmt", "name": name, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": params, "body": body, "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": ret,
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── effect Name { fn op(params) -> ret, ... } ──────────────
fn parse_effect_decl() {
    p_advance() // consume 'effect'
    let name = p_expect_ident()
    // Optional type params: effect State<T> { ... }
    let mut tparams = []
    if p_peek_kind() == "Lt" {
        tparams = parse_type_params()
    }
    p_skip_newlines()
    p_expect("LBrace")
    p_skip_newlines()
    let mut ops = []
    while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
        p_expect("Fn")
        let op_name = p_expect_ident()
        p_expect("LParen")
        let op_params = parse_params()
        p_expect("RParen")
        let mut op_ret = ""
        if p_peek_kind() == "Arrow" {
            p_advance()
            op_ret = parse_type_annotation()
        }
        ops.push(#{
            "kind": "EffectOp", "name": op_name, "value": "", "op": "",
            "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": op_params, "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": op_ret,
            "target": "", "trait_name": "", "methods": ""
        })
        p_skip_newlines()
    }
    p_expect("RBrace")
    return #{
        "kind": "EffectDecl", "name": name, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": tparams, "body": "", "args": "", "fields": "", "items": ops,
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── pure fn name(params) { body } ──────────────────────────
fn parse_pure_fn() {
    p_advance() // consume 'pure'
    p_expect("Fn")
    let name = p_expect_ident()
    p_expect("LParen")
    let params = parse_params()
    p_expect("RParen")
    let mut ret = ""
    if p_peek_kind() == "Arrow" {
        p_advance()
        ret = parse_type_annotation()
    }
    let body = parse_block()
    return #{
        "kind": "PureFnDecl", "name": name, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": params, "body": body, "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": ret,
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── macro! name { (pattern) => { body }, ... } ─────────────
fn parse_macro_def() {
    p_advance() // consume 'macro'
    // Expect '!' after macro
    if p_peek_kind() == "Not" {
        p_advance()
    }
    let name = p_expect_ident()
    p_expect("LBrace")
    p_skip_newlines()
    // Simplified: collect arms as (pattern_tokens, body_block) pairs
    let mut rules = []
    while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
        // Parse pattern: ( ... )
        p_expect("LParen")
        p_skip_newlines()
        let mut pat_tokens = []
        while p_peek_kind() != "RParen" && p_peek_kind() != "Eof" {
            let tok = p_advance()
            pat_tokens.push(tok.value)
            p_skip_newlines()
        }
        p_expect("RParen")
        // Expect => (FatArrow)
        // Since we may not have FatArrow token, accept Eq + Gt combo or just skip
        if p_peek_kind() == "Eq" {
            p_advance()
            if p_peek_kind() == "Gt" {
                p_advance()
            }
        }
        let body = parse_block()
        rules.push(#{
            "kind": "MacroRule", "name": "", "value": "", "op": "",
            "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": pat_tokens, "body": body, "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        })
        if p_peek_kind() == "Comma" || p_peek_kind() == "Semicolon" {
            p_advance()
        }
        p_skip_newlines()
    }
    p_expect("RBrace")
    return #{
        "kind": "MacroDef", "name": name, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": rules,
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── derive(Trait1, Trait2) for TypeName ─────────────────────
fn parse_derive_decl() {
    p_advance() // consume 'derive'
    p_expect("LParen")
    let mut traits = []
    traits.push(p_expect_ident())
    while p_peek_kind() == "Comma" {
        p_advance()
        traits.push(p_expect_ident())
    }
    p_expect("RParen")
    // Expect 'for' — it's a keyword or ident
    if p_peek_kind() == "For" {
        p_advance()
    } else {
        p_expect_ident() // "for" as ident
    }
    let type_name = p_expect_ident()
    return #{
        "kind": "DeriveDecl", "name": type_name, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": traits,
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── theorem name { proof_body } ─────────────────────────────
fn parse_theorem_stmt() {
    p_advance() // consume 'theorem'
    let name = p_expect_ident()
    p_expect("LBrace")
    p_skip_newlines()
    let mut stmts = []
    while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
        stmts.push(parse_stmt())
        p_skip_newlines()
    }
    p_expect("RBrace")
    return #{
        "kind": "TheoremStmt", "name": name, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": stmts, "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── handle { body } with { Effect.op(params) => { handler }, ... } ──
fn parse_handle_stmt() {
    p_advance() // consume 'handle'
    let body = parse_block()
    p_skip_newlines()
    // Expect 'with' keyword
    if p_peek_kind() == "With" {
        p_advance() // consume 'with' keyword
    } else {
        p_expect_ident() // fallback: consume "with" as ident
    }
    p_skip_newlines()
    p_expect("LBrace")
    p_skip_newlines()
    let mut handlers = []
    while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
        // Parse: Effect.op(params) => { body }
        let effect_name = p_expect_ident()
        p_expect("Dot")
        let op_name = p_expect_ident()
        let mut hparams = []
        if p_peek_kind() == "LParen" {
            p_advance()
            while p_peek_kind() != "RParen" && p_peek_kind() != "Eof" {
                hparams.push(p_expect_ident())
                if p_peek_kind() == "Comma" {
                    p_advance()
                }
            }
            p_expect("RParen")
        }
        // Expect => (Eq + Gt) or -> (Arrow) or FatArrow
        let pk = p_peek_kind()
        if pk == "Eq" {
            p_advance()
            if p_peek_kind() == "Gt" {
                p_advance()
            }
        } else {
            if pk == "Arrow" || pk == "FatArrow" {
                p_advance()
            }
        }
        let hbody = parse_block()
        handlers.push(#{
            "kind": "EffectHandler", "name": op_name, "value": "", "op": "",
            "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": hparams, "body": hbody, "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": effect_name, "trait_name": "", "methods": ""
        })
        p_skip_newlines()
    }
    p_expect("RBrace")
    return #{
        "kind": "HandleWithStmt", "name": "", "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": body, "args": "", "fields": "", "items": handlers,
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ── pub/pub(crate) prefix — returns visibility string ───────
fn parse_visibility() {
    if p_peek_kind() == "Pub" {
        p_advance()
        if p_peek_kind() == "LParen" {
            p_advance()
            let vis_scope = p_expect_ident() // "crate" or "mod"
            p_expect("RParen")
            return vis_scope
        }
        return "pub"
    }
    return "private"
}

// ── <T, U: Trait> — type parameters ─────────────────────────
// G38: Generic constraint annotation — fn sort<T: Ord>(arr: [T]) -> [T]
fn parse_type_params() {
    if p_peek_kind() != "Lt" { return [] }
    p_advance() // consume <
    let mut tparams = []
    let name = p_expect_ident()
    let mut bound = ""
    if p_peek_kind() == "Colon" {
        p_advance()
        bound = parse_type_annotation()
    }
    tparams.push(#{
        "kind": "TypeParam", "name": name, "value": bound, "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    })
    while p_peek_kind() == "Comma" {
        p_advance()
        let pname = p_expect_ident()
        let mut pbound = ""
        if p_peek_kind() == "Colon" {
            p_advance()
            pbound = parse_type_annotation()
        }
        tparams.push(#{
            "kind": "TypeParam", "name": pname, "value": pbound, "op": "",
            "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        })
    }
    p_expect("Gt")
    return tparams
}

// ── where T: Trait, U: Clone ────────────────────────────────
fn parse_where_clauses() {
    if p_peek_kind() != "Where" { return [] }
    p_advance() // consume 'where'
    let mut clauses = []
    let tname = p_expect_ident()
    p_expect("Colon")
    let tbound = parse_type_annotation()
    clauses.push(#{
        "kind": "WhereClause", "name": tname, "value": tbound, "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    })
    while p_peek_kind() == "Comma" {
        p_advance()
        let wname = p_expect_ident()
        p_expect("Colon")
        let wbound = parse_type_annotation()
        clauses.push(#{
            "kind": "WhereClause", "name": wname, "value": wbound, "op": "",
            "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
            "params": "", "body": "", "args": "", "fields": "", "items": "",
            "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
            "target": "", "trait_name": "", "methods": ""
        })
    }
    return clauses
}

// ══════════════════════════════════════════════════════════════
// Utility: AST pretty-printer
// ══════════════════════════════════════════════════════════════

// decreases node — structural
fn ast_to_string(node, indent) {
    let pad = ""
    let mut i = 0
    while i < indent {
        pad = pad + "  "
        i = i + 1
    }

    let k = node.kind

    if k == "IntLit" { return pad + "IntLit(" + node.value + ")" }
    if k == "FloatLit" { return pad + "FloatLit(" + node.value + ")" }
    if k == "BoolLit" { return pad + "BoolLit(" + node.value + ")" }
    if k == "StringLit" { return pad + "StringLit(\"" + node.value + "\")" }
    if k == "CharLit" { return pad + "CharLit('" + node.value + "')" }
    if k == "Ident" { return pad + "Ident(" + node.name + ")" }
    if k == "Wildcard" { return pad + "Wildcard" }

    if k == "BinOp" {
        let l = ast_to_string(node.left, 0)
        let r = ast_to_string(node.right, 0)
        return pad + "BinOp(" + node.op + ", " + l + ", " + r + ")"
    }
    if k == "UnaryOp" {
        let operand = ast_to_string(node.left, 0)
        return pad + "UnaryOp(" + node.op + ", " + operand + ")"
    }
    if k == "Call" {
        let callee = ast_to_string(node.left, 0)
        return pad + "Call(" + callee + ", [" + to_string(len(node.args)) + " args])"
    }
    if k == "Field" {
        let obj = ast_to_string(node.left, 0)
        return pad + "Field(" + obj + "." + node.name + ")"
    }
    if k == "OptField" {
        let obj = ast_to_string(node.left, 0)
        return pad + "OptField(" + obj + "?." + node.name + ")"
    }
    if k == "Index" {
        let obj = ast_to_string(node.left, 0)
        let idx = ast_to_string(node.right, 0)
        return pad + "Index(" + obj + "[" + idx + "])"
    }
    if k == "IfExpr" {
        let c = ast_to_string(node.cond, 0)
        return pad + "IfExpr(" + c + ", then=[" + to_string(len(node.then_body)) + "], else=[" + to_string(len(node.else_body)) + "])"
    }
    if k == "IfLetExpr" {
        let p = ast_to_string(node.left, 0)
        return pad + "IfLetExpr(" + p + ", then=[" + to_string(len(node.then_body)) + "], else=[" + to_string(len(node.else_body)) + "])"
    }
    if k == "MatchExpr" {
        return pad + "MatchExpr([" + to_string(len(node.arms)) + " arms])"
    }
    if k == "Array" {
        return pad + "Array([" + to_string(len(node.items)) + " items])"
    }
    if k == "ListComp" {
        let body_s = ast_to_string(node.left, 0)
        let iter_s = ast_to_string(node.iter_expr, 0)
        let filt = ""
        if type_of(node.cond) != "string" { filt = " if " + ast_to_string(node.cond, 0) }
        return pad + "ListComp(" + body_s + " for " + node.name + " in " + iter_s + filt + ")"
    }
    if k == "StructInit" {
        return pad + "StructInit(" + node.name + ", [" + to_string(len(node.fields)) + " fields])"
    }
    if k == "Slice" {
        let obj = ast_to_string(node.left, 0)
        let mut s_str = ""
        if node.right != "" { s_str = ast_to_string(node.right, 0) }
        let mut e_str = ""
        if node.cond != "" { e_str = ast_to_string(node.cond, 0) }
        return pad + "Slice(" + obj + "[" + s_str + ":" + e_str + "])"
    }
    if k == "Range" {
        let s = ast_to_string(node.left, 0)
        let e = ast_to_string(node.right, 0)
        let mut step_str = ""
        if node.cond != "" { step_str = " step " + ast_to_string(node.cond, 0) }
        return pad + "Range(" + s + ".." + e + ", " + node.value + step_str + ")"
    }
    if k == "EnumPath" {
        return pad + "EnumPath(" + node.name + "::" + node.value + ")"
    }
    if k == "Lambda" {
        return pad + "Lambda([" + to_string(len(node.params)) + " params])"
    }
    if k == "Tuple" {
        return pad + "Tuple([" + to_string(len(node.items)) + " items])"
    }

    // Statements
    if k == "LetStmt" || k == "LetMutStmt" {
        let v = ast_to_string(node.left, 0)
        return pad + k + "(" + node.name + " = " + v + ")"
    }
    if k == "ConstStmt" || k == "StaticStmt" {
        let v = ast_to_string(node.left, 0)
        return pad + k + "(" + node.name + " = " + v + ")"
    }
    if k == "ReturnStmt" {
        if node.left == "" {
            return pad + "ReturnStmt()"
        }
        let v = ast_to_string(node.left, 0)
        return pad + "ReturnStmt(" + v + ")"
    }
    if k == "FnDecl" {
        return pad + "FnDecl(" + node.name + ", [" + to_string(len(node.params)) + " params], [" + to_string(len(node.body)) + " stmts])"
    }
    if k == "StructDecl" {
        return pad + "StructDecl(" + node.name + ", [" + to_string(len(node.fields)) + " fields])"
    }
    if k == "EnumDecl" {
        return pad + "EnumDecl(" + node.name + ", [" + to_string(len(node.variants)) + " variants])"
    }
    if k == "ForStmt" {
        return pad + "ForStmt(" + node.name + " in ..., [" + to_string(len(node.body)) + " stmts])"
    }
    if k == "WhileStmt" {
        return pad + "WhileStmt(..., [" + to_string(len(node.body)) + " stmts])"
    }
    if k == "LoopStmt" {
        return pad + "LoopStmt([" + to_string(len(node.body)) + " stmts])"
    }
    if k == "ExprStmt" {
        let v = ast_to_string(node.left, 0)
        return pad + "ExprStmt(" + v + ")"
    }
    if k == "AssignStmt" {
        let l = ast_to_string(node.left, 0)
        let r = ast_to_string(node.right, 0)
        return pad + "AssignStmt(" + l + " = " + r + ")"
    }
    if k == "AssertStmt" {
        let v = ast_to_string(node.left, 0)
        return pad + "AssertStmt(" + v + ")"
    }
    if k == "ProofStmt" {
        return pad + "ProofStmt(" + node.name + ", [" + to_string(len(node.body)) + " stmts])"
    }
    if k == "ImplBlock" {
        return pad + "ImplBlock(" + node.target + ", [" + to_string(len(node.methods)) + " methods])"
    }
    if k == "TraitDecl" {
        return pad + "TraitDecl(" + node.name + ", [" + to_string(len(node.methods)) + " methods])"
    }
    if k == "UseStmt" {
        return pad + "UseStmt([" + to_string(len(node.items)) + " segments])"
    }
    if k == "ModStmt" {
        return pad + "ModStmt(" + node.name + ")"
    }

    // Phase 2 node kinds
    if k == "BreakStmt" { return pad + "BreakStmt" }
    if k == "ContinueStmt" { return pad + "ContinueStmt" }
    if k == "YieldStmt" {
        if node.left == "" { return pad + "YieldStmt()" }
        return pad + "YieldStmt(" + ast_to_string(node.left, 0) + ")"
    }
    if k == "ComptimeFnDecl" {
        return pad + "ComptimeFnDecl(" + node.name + ", [" + to_string(len(node.params)) + " params])"
    }
    if k == "ComptimeConst" || k == "ComptimeLet" {
        let v = ast_to_string(node.left, 0)
        return pad + k + "(" + node.name + " = " + v + ")"
    }
    if k == "ComptimeBlock" {
        return pad + "ComptimeBlock([" + to_string(len(node.body)) + " stmts])"
    }
    if k == "ComptimeExpr" {
        return pad + "ComptimeExpr([" + to_string(len(node.body)) + " stmts])"
    }
    if k == "ComptimeAssert" {
        return pad + "ComptimeAssert(" + ast_to_string(node.left, 0) + ")"
    }
    if k == "IntentStmt" {
        return pad + "IntentStmt(" + node.name + ", [" + to_string(len(node.fields)) + " fields])"
    }
    if k == "VerifyStmt" {
        return pad + "VerifyStmt(" + node.name + ", [" + to_string(len(node.body)) + " stmts])"
    }
    if k == "GenerateFnStmt" || k == "GenerateStmt" {
        return pad + k + "(" + node.name + ")"
    }
    if k == "OptimizeFnStmt" {
        return pad + "OptimizeFnStmt(" + node.name + ", [" + to_string(len(node.params)) + " params])"
    }
    if k == "EffectDecl" {
        return pad + "EffectDecl(" + node.name + ", [" + to_string(len(node.items)) + " ops])"
    }
    if k == "PureFnDecl" {
        return pad + "PureFnDecl(" + node.name + ", [" + to_string(len(node.params)) + " params])"
    }
    if k == "MacroDef" {
        return pad + "MacroDef(" + node.name + ", [" + to_string(len(node.items)) + " rules])"
    }
    if k == "DeriveDecl" {
        return pad + "DeriveDecl(" + node.name + ", [" + to_string(len(node.items)) + " traits])"
    }
    if k == "TheoremStmt" {
        return pad + "TheoremStmt(" + node.name + ", [" + to_string(len(node.body)) + " stmts])"
    }
    if k == "HandleWithStmt" {
        return pad + "HandleWithStmt([" + to_string(len(node.items)) + " handlers])"
    }
    if k == "GuardStmt" {
        return pad + "GuardStmt(cond, [" + to_string(len(node.else_body)) + " else stmts])"
    }
    if k == "GuardLetStmt" {
        return pad + "GuardLetStmt(" + node.name + ", [" + to_string(len(node.else_body)) + " else stmts])"
    }
    if k == "WithStmt" {
        return pad + "WithStmt(" + node.name + ", [" + to_string(len(node.body)) + " body stmts])"
    }
    if k == "WalrusExpr" {
        return pad + "WalrusExpr(" + node.name + ", " + ast_to_string(node.right, 0) + ")"
    }
    // Phase 1 node kinds that may have been missing from printer
    if k == "TryCatch" {
        return pad + "TryCatch(" + node.name + ")"
    }
    if k == "ThrowStmt" {
        return pad + "ThrowStmt(" + ast_to_string(node.left, 0) + ")"
    }
    if k == "PanicStmt" {
        return pad + "PanicStmt(" + ast_to_string(node.left, 0) + ")"
    }
    if k == "DropStmt" {
        return pad + "DropStmt(" + node.name + ")"
    }
    if k == "SpawnStmt" {
        return pad + "SpawnStmt([" + to_string(len(node.body)) + " stmts])"
    }
    if k == "ScopeStmt" {
        return pad + "ScopeStmt([" + to_string(len(node.body)) + " stmts])"
    }
    if k == "SelectStmt" {
        return pad + "SelectStmt([" + to_string(len(node.arms)) + " arms])"
    }
    if k == "AsyncFnDecl" {
        return pad + "AsyncFnDecl(" + node.name + ", [" + to_string(len(node.params)) + " params])"
    }
    if k == "ExternFnDecl" {
        let sym_info = ""
        if node.value != "" {
            sym_info = ", @symbol(\"" + node.value + "\")"
        }
        return pad + "ExternFnDecl(" + node.name + ", [" + to_string(len(node.params)) + " params]" + sym_info + ")"
    }
    if k == "TypeAlias" {
        return pad + "TypeAlias(" + node.name + " = " + node.value + ")"
    }
    if k == "AtomicLet" {
        return pad + "AtomicLet(" + node.name + ")"
    }

    // G9: destructuring statements
    if k == "DestructLetStmt" {
        let v = ast_to_string(node.left, 0)
        let rest = node.name
        let names = join(node.params, ", ")
        if rest != "" {
            return pad + "DestructLetStmt([" + names + ", ..." + rest + "] = " + v + ")"
        }
        return pad + "DestructLetStmt([" + names + "] = " + v + ")"
    }
    if k == "MapDestructLetStmt" {
        let v = ast_to_string(node.left, 0)
        let names = join(node.params, ", ")
        return pad + "MapDestructLetStmt({" + names + "} = " + v + ")"
    }

    return pad + "Unknown(" + k + ")"
}

fn print_ast(stmts) {
    for s in stmts {
        println(ast_to_string(s, 0))
    }
}

// ═══════════════════════════════════════════════════════════
//  self/interpreter.hexa — HEXA interpreter written in HEXA
//  Phase 2 of self-hosting: execute AST directly
//  Minimal core: variables, functions, arrays, strings, control flow
// ═══════════════════════════════════════════════════════════

// ── Value representation ─────────────────────────────────
// Values are represented as structs with a numeric tag discriminator.
// Numeric tags avoid string comparisons on every value dispatch (perf #4).

let TAG_INT = 0
let TAG_FLOAT = 1
let TAG_BOOL = 2
let TAG_STR = 3
let TAG_CHAR = 4
let TAG_ARRAY = 5
let TAG_FN = 6
let TAG_STRUCT = 7
let TAG_VOID = 8
let TAG_ENUM = 9
let TAG_MAP = 10
let TAG_TENSOR = 11
let TAG_ERROR = 12
let TAG_POINTER = 13
let TAG_CHANNEL = 14
let TAG_EFFECT_REQUEST = 15
let TAG_ATOMIC = 16
let TAG_BIGINT = 17
let TAG_NOT_BUILTIN = 18
let TAG_NOT_FUSED = 19

// ── O(n²) string concat detection ───────────────────────
let mut __str_concat_count = 0
let mut __str_concat_warned = 0

// ── RFC-010 Stage 4 (interp fuel) ───────────────────────────
// Fuel charges at every loop backedge + every fn call. Hard cap throws
// RuntimeError; soft cap warns once on stderr. Disabled by default
// (cap=0) so existing scripts run unchanged. Activation:
//   HEXA_MAX_FUEL=N    — hard cap (instructions)
//   HEXA_SOFT_FUEL=N   — soft cap (warning only); auto-set to 80% of max
//                        when only HEXA_MAX_FUEL is given.
let mut _fuel_max = 0
let mut _fuel_soft = 0
let mut _fuel_used = 0
let mut _fuel_warned = false
let mut _fuel_inited = false

fn _fuel_init() {
    if _fuel_inited { return }
    _fuel_inited = true
    let cap_str = env_var("HEXA_MAX_FUEL")
    if cap_str != "" { _fuel_max = to_int(cap_str) }
    let soft_str = env_var("HEXA_SOFT_FUEL")
    if soft_str != "" { _fuel_soft = to_int(soft_str) }
    if _fuel_max > 0 && _fuel_soft == 0 {
        _fuel_soft = _fuel_max * 4 / 5
    }
}

fn _fuel_telemetry_emit(kind, ticks, max_ticks) {
    // RFC-010 (f) telemetry — append JSONL line to ~/.hx/log/runaway_telemetry.jsonl.
    // Best-effort: any IO error swallowed (silent-by-design — must not mask the
    // RuntimeError throw that triggered emission).
    let home = env_var("HOME")
    if home == "" { return }
    let path = home + "/.hx/log/runaway_telemetry.jsonl"
    let line = "{\"event\":\"hexa.runtime.fuel_" + kind + "\",\"ticks\":" + to_string(ticks)
              + ",\"max\":" + to_string(max_ticks) + "}\n"
    try { append_file(path, line) } catch e { }
}

fn _fuel_charge() {
    if _fuel_max == 0 { return }
    if throw_flag { return }
    _fuel_used = _fuel_used + 1
    if !_fuel_warned && _fuel_soft > 0 && _fuel_used >= _fuel_soft {
        _fuel_warned = true
        eprintln("[hexa-runtime] fuel soft threshold reached: " + to_string(_fuel_used) + "/" + to_string(_fuel_max))
        _fuel_telemetry_emit("soft", _fuel_used, _fuel_max)
    }
    if _fuel_used >= _fuel_max {
        _fuel_telemetry_emit("abort", _fuel_used, _fuel_max)
        exec_throw(val_str("RuntimeError: fuel exhausted at " + to_string(_fuel_used) + " ticks"))
    }
}

fn tag_name(t) {
    if t == TAG_INT { return "int" }
    if t == TAG_FLOAT { return "float" }
    if t == TAG_BOOL { return "bool" }
    // HX-typeof-align: "string" (not "str") — align interp interpreter's
    // type_of builtin with runtime.c hexa_type_of ("string"). codegen_c2
    // has 82+ `type_of(x) != "string"` call sites that were SILENTLY
    // always-true when running under interp, causing gen2_expr's Ident
    // branch to wrongly recurse into gen2_expr("") → void. Every user's
    // transpile-via-interpreter path was broken pre-align.
    if t == TAG_STR { return "string" }
    if t == TAG_CHAR { return "char" }
    if t == TAG_ARRAY { return "array" }
    if t == TAG_FN { return "fn" }
    if t == TAG_STRUCT { return "struct" }
    if t == TAG_VOID { return "void" }
    if t == TAG_ENUM { return "enum" }
    if t == TAG_MAP { return "map" }
    if t == TAG_TENSOR { return "tensor" }
    if t == TAG_ERROR { return "error" }
    if t == TAG_POINTER { return "pointer" }
    if t == TAG_CHANNEL { return "channel" }
    if t == TAG_EFFECT_REQUEST { return "effect_request" }
    if t == TAG_ATOMIC { return "atomic" }
    if t == TAG_BIGINT { return "bigint" }
    if t == TAG_NOT_BUILTIN { return "__not_builtin__" }
    if t == TAG_NOT_FUSED { return "__not_fused__" }
    return "unknown"
}

struct Val {
    tag: int,       // TAG_INT, TAG_FLOAT, TAG_BOOL, TAG_STR, TAG_CHAR, TAG_VOID, TAG_ARRAY, TAG_FN, TAG_STRUCT, etc.
    int_val: int,
    float_val: float,
    bool_val: bool,
    str_val: string,
    char_val: string,
    array_val: string,  // stored as external ref
    fn_name: string,
    fn_params: string,
    fn_body: string,
    struct_name: string,
    struct_fields: string
}

// rt 32: cached val_void/val_bool singletons — avoids 14× hexa_map_set per call.
// val_void() is called millions of times by interpreter (exec_stmt return
// paths, missing args, type guards). Module-level let with `mut` so the
// reset path can rebuild after array_store wipe, but normal execution
// returns the cached struct directly. Same Val map shared everywhere is
// safe because nothing mutates Val fields after construction.
// ROI-6: shared empty-string constant — eliminates ~27M dead "" allocations
// per d64 run. The C runtime interns "" at the native level (Optimization #11),
// but interpreter-level Val construction allocates a fresh string per "" literal.
// Caching one instance here makes all Val constructors share a single object.
let __E = ""

pub let mut __VAL_VOID = Val { tag: TAG_VOID, int_val: 0, float_val: 0.0, bool_val: false, str_val: __E, char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E }
pub let mut __VAL_TRUE = Val { tag: TAG_BOOL, int_val: 0, float_val: 0.0, bool_val: true, str_val: __E, char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E }
pub let mut __VAL_FALSE = Val { tag: TAG_BOOL, int_val: 0, float_val: 0.0, bool_val: false, str_val: __E, char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E }
// rt 32: small-int Val cache — loop counters, indices, refcounts heavily
// concentrate in 0..127. Avoids ~70% of val_int hexa_map allocations on
// typical inner loops (matvec inner col index, scope refcount adjustments).
// Filled lazily by val_int on first access; entries are immutable after init.
pub let mut __VAL_INT_CACHE = []
pub let mut __VAL_INT_CACHE_LEN = 0

fn __init_val_int_cache() {
    let mut k = 0
    while k < 256 {
        let v = Val { tag: TAG_INT, int_val: k, float_val: 0.0, bool_val: false, str_val: __E, char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E }
        __VAL_INT_CACHE.push(v)
        k = k + 1
    }
    __VAL_INT_CACHE_LEN = 256
}

fn val_int(n) {
    // T33 Val arena fix: __VAL_INT_CACHE is eagerly populated by `interpret()`
    // at module-load time (mark_top == 0) so its 256 entries live in heap,
    // not arena. Lazy populate previously triggered from inside a user fn
    // frame would land the cache in arena → pop dangles → next val_int(0)
    // returns corrupted Val (type_of "map"). See T33 repro_t33_g.
    if n >= 0 && n < __VAL_INT_CACHE_LEN { return __VAL_INT_CACHE[n] }
    return Val { tag: TAG_INT, int_val: n, float_val: 0.0, bool_val: false, str_val: __E, char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E }
}
// rt 32-C: val_float 싱글톤 캐시 — gelu/sigmoid/tanh/layernorm 수식이 0.0/1.0/0.5/2.0
// 상수를 매 BinOp 결과로 재생성. Val struct는 immutable(construction 후 필드 수정 없음)이라
// 같은 상수 인스턴스를 공유해도 안전. IEEE exact match만 hit — approximate 비교 금지(LN 경계값 등
// 구분 가능해야 함). val_int 0..255 캐시(Phase 1)와 동일한 싱글톤 패턴.
// -1.0 제외 이유: 현재 interp transpiler(self/native/hexa_v2)가 float 감산/음수 literal을 integer
// bit-pattern 연산으로 miscompile (`0.0 - 1.0` → `hexa_int((hexa_float(0.0)).i - (hexa_float(1.0)).i)`).
// -1.0 싱글톤을 생성하면 garbage bits가 박혀 downstream에 유입 — transpiler 수정 이후 복구 예정(RT 32-E 후보).
pub let mut __VAL_FLOAT_0   = Val { tag: TAG_FLOAT, int_val: 0, float_val: 0.0, bool_val: false, str_val: __E, char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E }
pub let mut __VAL_FLOAT_1   = Val { tag: TAG_FLOAT, int_val: 0, float_val: 1.0, bool_val: false, str_val: __E, char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E }
pub let mut __VAL_FLOAT_H   = Val { tag: TAG_FLOAT, int_val: 0, float_val: 0.5, bool_val: false, str_val: __E, char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E }
pub let mut __VAL_FLOAT_2   = Val { tag: TAG_FLOAT, int_val: 0, float_val: 2.0, bool_val: false, str_val: __E, char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E }

fn val_float(f) {
    // IEEE 정확 일치만 hit — 근사 비교 금지
    if f == 0.0 { return __VAL_FLOAT_0 }
    if f == 1.0 { return __VAL_FLOAT_1 }
    if f == 0.5 { return __VAL_FLOAT_H }
    if f == 2.0 { return __VAL_FLOAT_2 }
    return Val { tag: TAG_FLOAT, int_val: 0, float_val: f, bool_val: false, str_val: __E, char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E }
}
fn val_bool(b) { if b { return __VAL_TRUE } return __VAL_FALSE }

// T39: deep-copy a Val struct — returns a fresh allocation with identical field
// values. Used by LetMutStmt to decouple mutable bindings from cached singletons
// (__VAL_INT_CACHE, __VAL_FLOAT_*, __VAL_VOID, __VAL_TRUE, __VAL_FALSE).
// Without this, env_define stores a shared pointer to the singleton's
// HexaValStruct; any downstream mutation (e.g. hexa_valstruct_set_by_key
// routed via hexa_map_set) corrupts the cache entry and all other bindings
// that reference it.
fn val_copy(v) {
    return Val { tag: v.tag, int_val: v.int_val, float_val: v.float_val, bool_val: v.bool_val, str_val: v.str_val, char_val: v.char_val, array_val: v.array_val, fn_name: v.fn_name, fn_params: v.fn_params, fn_body: v.fn_body, struct_name: v.struct_name, struct_fields: v.struct_fields }
}
fn val_str(s) { return Val { tag: TAG_STR, int_val: 0, float_val: 0.0, bool_val: false, str_val: s, char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E } }
fn val_void() { return __VAL_VOID }

// ── Environment (scope-based variable storage) ───────────
// NOTE: All module-level state declared `pub let mut` so cross-module
// callers (host_test.hexa, bootstrap pipelines, fixpoint runners) can
// reset and re-enter `interpret()`. Same pattern as self/parser.hexa.
// Without `pub`, lookups from within import dispatch see uninitialized
// captures and fail with "undefined variable: env_vars".

// rt 32-E: split tuple-of-arrays → struct-of-arrays to eliminate the
// per-env_define `[name, value]` inner allocation. Before: every define
// allocated a fresh 2-element array (1 array_new + 2 pushes just for the
// tuple) on top of the env_vars append. After: two parallel pushes, no
// tuple alloc. env_vars itself is kept as a legacy alias (always empty)
// purely for closure-capture backward compat paths that snapshot it.
pub let mut env_var_names = []   // parallel: binding names
pub let mut env_var_vals = []    // parallel: binding values
pub let mut env_vars = []        // legacy snapshot target; unused in hot path
pub let mut env_scopes = [0]   // scope boundary stack
// ── O(1) env_lookup cache (perf) ──────────────────────────
// Parallel to env_var_names/vals: 64 buckets. rt 32-E also splits each
// bucket into parallel (names, idxs) arrays to eliminate the per-define
// `[name, idx]` inner alloc. Same 6-push → 4-push / -2 array_new savings
// applies to the cache side.
// env_define appends; env_lookup/set scan only the name's bucket and
// pick the entry with the largest index (newest binding still in scope).
// env_pop_scope prunes entries whose index >= new boundary.
// Bucket count 64 = power of two, empirically covers typical
// top-level fn + let counts (~100) with avg chain length <2.
pub let mut env_cache_names = []   // list of 64 buckets; each bucket is [name, ...]
pub let mut env_cache_idxs = []    // list of 64 buckets; each bucket is [idx, ...]
pub let mut env_cache = []     // legacy alias: len==64 flag retained for fallback branch
// ── Scope-dirty tracking (perf opt #8) ──────────────────────
// Stack of dirty-bucket sets, one per scope. Each entry is an array of
// bucket indices that were modified (by env_define) during that scope.
// On scope pop, only those buckets need pruning — not all 64.
pub let mut env_scope_dirty = []   // stack of [bucket_idx, ...] arrays
pub let mut env_fns = []      // function registry: name -> {params, body}
// ── Runtime `use`/`import` module cache (2026-04-20 bugfix) ──
// CLI path (self/main.hexa cmd_run) preprocesses imports via
// self/module_loader.hexa BEFORE the interpreter sees them, so UseStmt/
// ImportStmt nodes normally never reach exec_stmt. This cache backs the
// runtime-level fallback path for cases the preprocessor cannot cover
// (direct build/hexa_interp invocation, re-entered AST eval, `use a::b`
// Rust-style paths that module_loader.hexa's `replace("\nuse \"", ...)`
// does NOT match, etc.). Keyed by resolved absolute/relative path; value
// is true once the module's top-level fns/structs are pushed into env_fns.
// Guards against circular imports + double-load.
// See feedback_hexa_silent_exit_5_imports.md for the separate 3+ chain
// silent-exit regression (not fixed here; this fallback keeps depth low).
pub let mut __use_loaded_paths = []
// Script dir captured at interpret() start — used by UseStmt runtime loader
// to resolve caller-relative paths (`use "voice_routes"` from serving/*.hexa
// must look in serving/, not cwd).
pub let mut __use_script_dir = ""
// 2026-05-04 (feat/import-alias-runtime-fix) — `import "x" as alias` registry.
// Each entry: [alias, [fn_name_1, fn_name_2, ...]].
// `__use_load_module_from_path` records this when called with an alias arg;
// `eval_call`'s EnumPath branch consults it to route `alias::fn` calls to
// the bare-name fn registered in env_fns (which is what the loader did).
// Without this, `alias::fn(...)` parses as EnumPath{name=alias, value=fn}
// and falls through to val_enum() — a silent void at the call site.
// Reported by orpheus puzzle/sweep agents (orpheus.blk.3) where selftests
// had to inline algorithms because cross-file imports silently failed.
pub let mut __use_alias_fns = []
// ── O(1) fn_lookup cache (perf) ─────────────────────────
// Parallel to env_fns: 64 buckets, each a list of [name, env_fns_index].
// find_fn scans only the name's bucket and picks the entry with the
// largest index (newest definition = shadowing). Same pattern as env_cache.
pub let mut fn_cache = []     // list of 64 buckets; each bucket is [[name, idx], ...]
pub let mut return_flag = false
pub let mut return_val = val_void()
pub let mut break_flag = false
pub let mut break_label = ""
pub let mut continue_flag = false
pub let mut continue_label = ""
pub let mut defer_stack = []
pub let mut throw_flag = false
pub let mut throw_val = val_void()
// Panic: unrecoverable abort. Propagates through all enclosing blocks like
// throw, but is NOT cleared by try/catch or recover — only program exit
// observes it (interpret() prints "panic: <msg>" to stderr and returns void).
pub let mut panic_flag = false
pub let mut panic_msg = ""
pub let mut call_stack = []    // stack trace: pre-alloc buffer of function names
pub let mut call_stack_top = 0 // ROI-14: index pointer — push/pop are O(1) index bumps
// ── Sprint C: yield / eager generator buffer ─────────────
// Functions containing `yield` accumulate values into gen_buffer; upon
// return the accumulated array becomes the function's result. This is
// semantically correct for finite generators (no coroutines required).
// Each call frame saves/restores the outer buffer+flag so nested and
// non-generator calls are unaffected.
pub let mut gen_buffer = []
pub let mut gen_active = false

// T25 fix: enum declaration registry so `EnumName.Variant` field access
// can produce a proper enum value instead of dropping to void.
// Layout: [[enum_name, [variant_name, ...]], ...]
pub let mut enum_decls = []
// ROI-7: 64-bucket hash cache for O(1) variant lookup + dedup on register.
// Each bucket: [["name::variant", true], ...].  Keyed on "EnumName::Variant".
pub let mut enum_variant_cache = []

fn enum_variant_cache_init() {
    let mut buckets = []
    let mut i = 0
    while i < 64 {
        buckets.push([])
        i = i + 1
    }
    enum_variant_cache = buckets
}

fn enum_decls_register(name, variant_names) {
    // ROI-7: deduplicate on insertion — skip if all variants already cached.
    if len(enum_variant_cache) != 64 { enum_variant_cache_init() }
    let mut any_new = false
    let mut vi = 0
    while vi < len(variant_names) {
        let key = name + "::" + variant_names[vi]
        let b = env_hash(key)
        let bucket = enum_variant_cache[b]
        let mut found = false
        let mut bi = 0
        while bi < len(bucket) {
            if bucket[bi] == key { found = true; bi = len(bucket) }
            bi = bi + 1
        }
        if found == false {
            enum_variant_cache[b] = enum_variant_cache[b].push(key)
            any_new = true
        }
        vi = vi + 1
    }
    if any_new { enum_decls.push([name, variant_names]) }
    return val_void()
}

fn enum_decls_has_variant(name, variant) {
    // ROI-7: probe hash cache first for O(1) average lookup.
    if len(enum_variant_cache) == 64 {
        let key = name + "::" + variant
        let b = env_hash(key)
        let bucket = enum_variant_cache[b]
        let mut bi = 0
        while bi < len(bucket) {
            if bucket[bi] == key { return true }
            bi = bi + 1
        }
        return false
    }
    // Fallback: linear scan (only if cache not initialized).
    let mut i = 0
    while i < len(enum_decls) {
        if enum_decls[i][0] == name {
            let vs = enum_decls[i][1]
            let mut j = 0
            while j < len(vs) {
                if vs[j] == variant { return true }
                j = j + 1
            }
        }
        i = i + 1
    }
    return false
}

// ═══════════════════════════════════════════════════════════
// rt 32-B: reusable args accumulator for NK_CALL path
// ───────────────────────────────────────────────────────────
// Every Call AST node used to allocate a fresh `call_args = []` then
// hexa_array_push each evaluated arg. At d64 200-step that path alone
// contributed ~5M hexa_array_new + ~15M hexa_array_push. This shared
// buffer uses stack-discipline (snapshot top, push args via push_nostat
// which bypasses the stat counter, hand an independent slice to the
// callee via slice_fast [single malloc+memcpy], then truncate the
// global buffer back to the snapshot) so recursive NK_CALLs nest
// correctly without disturbing the caller's slice (the slice is a
// separate backing store owned by its recipient).
//
// Safety note: slice_fast copies items before we truncate, so callee
// recursion that grows call_arg_buf cannot invalidate the parent's
// handed-down slice. I1 (pass-by-value) satisfied — every `push_nostat`
// reassignment follows the canonical `xs.push(v)` pattern.
pub let mut call_arg_buf = []
pub let mut call_arg_top = 0

// ═══════════════════════════════════════════════════════════
//  Numeric dispatch IDs — node kinds
//  String→int conversion done once at lookup; eval dispatches on int.
//  ~45 sequential string comparisons → single int comparison per arm.
// ═══════════════════════════════════════════════════════════
let NK_UNKNOWN       = 0
let NK_INT_LIT       = 1
let NK_FLOAT_LIT     = 2
let NK_BOOL_LIT      = 3
let NK_STRING_LIT    = 4
let NK_CHAR_LIT      = 5
let NK_IDENT         = 6
let NK_BIN_OP        = 7
let NK_UNARY_OP      = 8
let NK_ARRAY         = 9
let NK_INDEX         = 10
let NK_CALL          = 11
let NK_FIELD         = 12
let NK_IF_EXPR       = 13
let NK_LAMBDA        = 14
let NK_MAP_LIT       = 15
let NK_RANGE         = 16
let NK_ASSIGN        = 17
let NK_TUPLE_LIT     = 18
let NK_STRUCT_INIT   = 19
let NK_ENUM_PATH     = 20
let NK_THROW_EXPR    = 21
let NK_THROW_STMT    = 22
let NK_BLOCK         = 23
let NK_BLOCK_EXPR    = 24
let NK_TUPLE         = 25
let NK_TUPLE_EXPR    = 26
let NK_HANDLE_WITH   = 27
let NK_EFFECT_CALL   = 28
let NK_RESUME        = 29
let NK_RESUME_EXPR   = 30
let NK_COMPTIME      = 31
let NK_COMPTIME_EXPR = 32
let NK_TEMPLATE      = 33
let NK_TEMPLATE_EXPR = 34
let NK_INTERP_STR    = 35
let NK_WILDCARD      = 36
let NK_ARRAY_PATTERN = 37
let NK_OWN           = 38
let NK_MOVE          = 39
let NK_MOVE_EXPR     = 40
let NK_BORROW        = 41
let NK_BORROW_EXPR   = 42
let NK_AWAIT         = 43
let NK_AWAIT_EXPR    = 44
let NK_DYN_CAST      = 45
let NK_DYN_CAST_EXPR = 46
let NK_MACRO_INVOC   = 47
let NK_MACRO_INVOCATION = 48
let NK_TRY_CATCH_EXPR = 49
let NK_TRY_CATCH     = 50
let NK_MATCH_EXPR    = 51
let NK_OPT_FIELD     = 52
let NK_LIST_COMP     = 53
let NK_WALRUS        = 54
let NK_GUARD         = 55
let NK_GUARD_LET     = 56
let NK_WITH          = 57

// ── Numeric dispatch IDs — binary operators ─────────────
let OP_UNKNOWN  = 0
let OP_ADD      = 1
let OP_SUB      = 2
let OP_MUL      = 3
let OP_DIV      = 4
let OP_MOD      = 5
let OP_POW      = 6
let OP_EQ       = 7
let OP_NE       = 8
let OP_LT       = 9
let OP_GT       = 10
let OP_LE       = 11
let OP_GE       = 12
let OP_AND      = 13
let OP_OR       = 14
let OP_BIT_AND  = 15
let OP_BIT_OR   = 16
let OP_BIT_XOR  = 17
let OP_SHL      = 18
let OP_SHR      = 19
let OP_NULL_COAL = 20
let OP_PIPE      = 21
let OP_IN        = 22
let OP_IS        = 23
let OP_AS        = 24

// ── Node-kind string → int conversion (called once per node) ──
fn node_kind_to_id(kind) {
    if kind == "IntLit" { return NK_INT_LIT }
    if kind == "FloatLit" { return NK_FLOAT_LIT }
    if kind == "BoolLit" { return NK_BOOL_LIT }
    if kind == "StringLit" { return NK_STRING_LIT }
    if kind == "CharLit" { return NK_CHAR_LIT }
    if kind == "Ident" { return NK_IDENT }
    if kind == "BinOp" { return NK_BIN_OP }
    if kind == "UnaryOp" { return NK_UNARY_OP }
    if kind == "Array" { return NK_ARRAY }
    if kind == "Index" { return NK_INDEX }
    if kind == "Call" { return NK_CALL }
    if kind == "Field" { return NK_FIELD }
    if kind == "IfExpr" { return NK_IF_EXPR }
    if kind == "Lambda" { return NK_LAMBDA }
    if kind == "MapLit" { return NK_MAP_LIT }
    if kind == "Range" { return NK_RANGE }
    if kind == "Assign" { return NK_ASSIGN }
    if kind == "TupleLit" { return NK_TUPLE_LIT }
    if kind == "StructInit" { return NK_STRUCT_INIT }
    if kind == "EnumPath" { return NK_ENUM_PATH }
    if kind == "ThrowExpr" { return NK_THROW_EXPR }
    if kind == "ThrowStmt" { return NK_THROW_STMT }
    if kind == "Block" { return NK_BLOCK }
    if kind == "BlockExpr" { return NK_BLOCK_EXPR }
    if kind == "Tuple" { return NK_TUPLE }
    if kind == "TupleExpr" { return NK_TUPLE_EXPR }
    if kind == "HandleWith" { return NK_HANDLE_WITH }
    if kind == "EffectCall" { return NK_EFFECT_CALL }
    if kind == "Resume" { return NK_RESUME }
    if kind == "ResumeExpr" { return NK_RESUME_EXPR }
    if kind == "Comptime" { return NK_COMPTIME }
    if kind == "ComptimeExpr" { return NK_COMPTIME_EXPR }
    if kind == "Template" { return NK_TEMPLATE }
    if kind == "TemplateExpr" { return NK_TEMPLATE_EXPR }
    if kind == "InterpolatedString" { return NK_INTERP_STR }
    if kind == "Wildcard" { return NK_WILDCARD }
    if kind == "ArrayPattern" { return NK_ARRAY_PATTERN }
    if kind == "Own" { return NK_OWN }
    if kind == "Move" { return NK_MOVE }
    if kind == "MoveExpr" { return NK_MOVE_EXPR }
    if kind == "Borrow" { return NK_BORROW }
    if kind == "BorrowExpr" { return NK_BORROW_EXPR }
    if kind == "Await" { return NK_AWAIT }
    if kind == "AwaitExpr" { return NK_AWAIT_EXPR }
    if kind == "DynCast" { return NK_DYN_CAST }
    if kind == "DynCastExpr" { return NK_DYN_CAST_EXPR }
    if kind == "MacroInvoc" { return NK_MACRO_INVOC }
    if kind == "MacroInvocation" { return NK_MACRO_INVOCATION }
    if kind == "TryCatchExpr" { return NK_TRY_CATCH_EXPR }
    if kind == "TryCatch" { return NK_TRY_CATCH }
    if kind == "MatchExpr" { return NK_MATCH_EXPR }
    if kind == "OptField" { return NK_OPT_FIELD }
    if kind == "ListComp" { return NK_LIST_COMP }
    if kind == "WalrusExpr" { return NK_WALRUS }
    if kind == "GuardStmt" { return NK_GUARD }
    if kind == "GuardLetStmt" { return NK_GUARD_LET }
    if kind == "WithStmt" { return NK_WITH }
    return NK_UNKNOWN
}

// ── Operator string → int conversion (called once per binop node) ──
fn op_to_id(op) {
    if op == "+" { return OP_ADD }
    if op == "-" { return OP_SUB }
    if op == "*" { return OP_MUL }
    if op == "/" { return OP_DIV }
    if op == "%" { return OP_MOD }
    if op == "**" { return OP_POW }
    if op == "==" { return OP_EQ }
    if op == "!=" { return OP_NE }
    if op == "<" { return OP_LT }
    if op == ">" { return OP_GT }
    if op == "<=" { return OP_LE }
    if op == ">=" { return OP_GE }
    if op == "&&" { return OP_AND }
    if op == "||" { return OP_OR }
    if op == "&" { return OP_BIT_AND }
    if op == "|" { return OP_BIT_OR }
    if op == "^" { return OP_BIT_XOR }
    if op == "<<" { return OP_SHL }
    if op == ">>" { return OP_SHR }
    if op == "??" { return OP_NULL_COAL }
    if op == "|>" { return OP_PIPE }
    if op == "in" { return OP_IN }
    if op == "is" { return OP_IS }
    if op == "as" { return OP_AS }
    return OP_UNKNOWN
}

// ── Node-kind ID cache (ROI-28: 64-bucket hash) ────────
// Maps node kind string → int ID. Populated lazily so the string→int
// conversion happens at most once per unique kind string, not every eval.
// 64-bucket hash — same pattern as env_cache / fn_cache.
pub let mut nk_cache = []    // 64 buckets; each [[kind_string, id_int], ...]

fn nk_hash(key) {
    let mut h = 0
    let mut ci = 0
    let n = len(key)
    while ci < n {
        h = (h * 31 + char_code(key, ci)) % 9999991
        ci = ci + 1
    }
    let mut b = h % 64
    while b < 0 { b = b + 64 }
    return b
}

fn nk_cache_init() {
    let mut buckets = []
    let mut i = 0
    while i < 64 {
        buckets.push([])
        i = i + 1
    }
    nk_cache = buckets
}

fn nk_cached_id(kind) {
    // ROI-28: hash-bucketed O(1) avg lookup
    if len(nk_cache) == 64 {
        let b = nk_hash(kind)
        let bucket = nk_cache[b]
        let mut i = 0
        let n = len(bucket)
        while i < n {
            if bucket[i][0] == kind { return bucket[i][1] }
            i = i + 1
        }
        // Miss — compute, store in bucket, return
        let id = node_kind_to_id(kind)
        nk_cache[b] = nk_cache[b].push([kind, id])
        return id
    }
    // First call — init buckets, then insert
    nk_cache_init()
    let id = node_kind_to_id(kind)
    let b = nk_hash(kind)
    nk_cache[b] = nk_cache[b].push([kind, id])
    return id
}

// ── Operator ID cache (ROI-28: 64-bucket hash) ─────────
pub let mut op_cache = []    // 64 buckets; each [[op_string, id_int], ...]

fn op_cache_init() {
    let mut buckets = []
    let mut i = 0
    while i < 64 {
        buckets.push([])
        i = i + 1
    }
    op_cache = buckets
}

fn op_cached_id(op) {
    // ROI-28: hash-bucketed O(1) avg lookup
    if len(op_cache) == 64 {
        let b = nk_hash(op)
        let bucket = op_cache[b]
        let mut i = 0
        let n = len(bucket)
        while i < n {
            if bucket[i][0] == op { return bucket[i][1] }
            i = i + 1
        }
        let id = op_to_id(op)
        op_cache[b] = op_cache[b].push([op, id])
        return id
    }
    op_cache_init()
    let id = op_to_id(op)
    let b = nk_hash(op)
    op_cache[b] = op_cache[b].push([op, id])
    return id
}

// ── @memo/@memoize/@cache runtime support ───────────────
// fn_attrs: maps function name -> comma-separated attr string
pub let mut fn_attrs = []      // [[name, attrs_str], ...]
// ── @stable/@track/@deprecated evolution tracking ────────
pub let mut stable_fns = []        // names of @stable-declared functions
pub let mut deprecated_warned = [] // names already warned for @deprecated
// ── S-1c scout: profile counters would live here ─────────
// Proposed (see self/hexa_full.profile_hook.hexa.draft):
//   pub let mut profile_counts = []  // parallel arrays: names[i], calls[i]
//   pub let mut profile_names  = []
// Increment hook site: fn call_user_fn (this file, ~L8650) — right before
// attr_bits compute, gated on env_var("HEXA_PROFILE") == "1".
// Dump site: top-level runner reset path (this file, ~L16765 vicinity
// where call_stack_top resets) or a new emit_profile() helper.
// Status: DRAFT ONLY — no runtime change. 2026-04-17 (S-1c, HX8-safe).
// ── Optimization #5: pre-parsed attribute flags ─────────
// ROI-15: 64-bucket hash cache for O(1) avg attribute lookup.
// Each bucket is [[name, bitmask], ...] where bitmask bits:
//   bit 0 (1): memo/memoize/cache
//   bit 1 (2): lazy
//   bit 2 (4): specialize
//   bit 3 (8): pure
//   bit 4 (16): stable
//   bit 5 (32): track
//   bit 6 (64): deprecated
// Populated by fn_attrs_set; queried by fn_attr_bitmask.
pub let mut fn_attr_cache = []  // 64 buckets; each [[name, bitmask], ...]
pub let mut fn_attr_flags = []  // legacy flat array (kept for compat)
// ── Optimization #6: hash-bucketed memo cache ───────────
// 64 buckets, each a list of [key, result_val] pairs.
// Same pattern as env_cache. Replaces linear memo_cache scan.
pub let mut memo_cache = []    // 64 buckets; each bucket is [[key, val], ...]

// ── @limit runtime — active call-count tracking ─────────
// Flat [[name, count], ...] list. Singleton enforcement checks count==0
// before entering body; increments on entry, decrements on exit. No load
// threshold constants — system state (sysctl loadavg/ncpu) drives refusal.
pub let mut active_fn_counts = []

fn fn_attr_cache_init() {
    let mut buckets = []
    let mut i = 0
    while i < 64 {
        buckets.push([])
        i = i + 1
    }
    fn_attr_cache = buckets
}

fn fn_attrs_set(name, attrs) {
    fn_attrs.push([name, attrs])
    // ── ROI-11+15: parse ALL attribute flags once at define time ──
    // Compute bitmask: bit0=memo, bit1=lazy, bit2=specialize, bit3=pure,
    // bit4=stable, bit5=track, bit6=deprecated, bit7=close, bit8=limit,
    // bit9=retry, bit10=fallback, bit11=guard
    let mut bitmask = 0
    if attrs != "" {
        if attrs == "memoize" || attrs == "memo" || attrs == "cache" {
            bitmask = bitmask + 1
        } else {
            if contains(attrs, "memoize") { bitmask = bitmask + 1 }
            if bitmask == 0 && contains(attrs, "memo") { bitmask = bitmask + 1 }
            if bitmask == 0 && contains(attrs, "cache") { bitmask = bitmask + 1 }
        }
        if attrs == "lazy" || contains(attrs, "lazy") {
            bitmask = bitmask + 2
        }
        if attrs == "specialize" || contains(attrs, "specialize") {
            bitmask = bitmask + 4
        }
        if attrs == "pure" || contains(attrs, "pure") {
            bitmask = bitmask + 8
        }
        if attrs == "stable" || contains(attrs, "stable") {
            bitmask = bitmask + 16
        }
        if attrs == "track" || contains(attrs, "track") {
            bitmask = bitmask + 32
        }
        if attrs == "deprecated" || contains(attrs, "deprecated") {
            bitmask = bitmask + 64
        }
        if attrs == "close" || contains(attrs, "close") {
            bitmask = bitmask + 128
        }
        if attrs == "limit" || contains(attrs, "limit") {
            bitmask = bitmask + 256
        }
        if attrs == "retry" || contains(attrs, "retry") {
            bitmask = bitmask + 512
        }
        if attrs == "fallback" || contains(attrs, "fallback") {
            bitmask = bitmask + 1024
        }
        if attrs == "guard" || contains(attrs, "guard") {
            bitmask = bitmask + 2048
        }
        // Bits 12-16 added 2026-04-20 (runtime resource gates — Mac panic prevention).
        // @refuse (4096): Darwin exit(77) unless HEXA_MAC_OK=1
        if attrs == "refuse" || contains(attrs, "refuse") {
            bitmask = bitmask + 4096
        }
        // @watchdog (8192): fork shell watchdog with rss_mb/time_s caps
        if attrs == "watchdog" || contains(attrs, "watchdog") {
            bitmask = bitmask + 8192
        }
        // @monitor (16384): getrusage snapshot → .hexa-monitor.jsonl
        if attrs == "monitor" || contains(attrs, "monitor") {
            bitmask = bitmask + 16384
        }
        // @heavy (32768): advisory + auto-imply refuse+watchdog
        if attrs == "heavy" || contains(attrs, "heavy") {
            bitmask = bitmask + 32768
            // Auto-imply @refuse if not already set
            if (bitmask / 4096) % 2 == 0 { bitmask = bitmask + 4096 }
            // Auto-imply @watchdog if not already set
            if (bitmask / 8192) % 2 == 0 { bitmask = bitmask + 8192 }
        }
        // @repuse (65536): hostname allowlist gate
        if attrs == "repuse" || contains(attrs, "repuse") {
            bitmask = bitmask + 65536
        }
    }
    // ── @stable: redefinition guard ──
    // If this function was previously declared @stable, warn or error
    if (bitmask / 16) % 2 == 1 {
        // Check if already in stable_fns (redefinition)
        let mut _si = 0
        let mut _was_stable = false
        while _si < len(stable_fns) {
            if stable_fns[_si] == name { _was_stable = true }
            _si = _si + 1
        }
        if _was_stable {
            if env_var("HEXA_STRICT_STABLE") == "1" {
                println("ERROR: @stable function '" + name + "' redefined (HEXA_STRICT_STABLE=1)")
            } else {
                eprintln("[stable] WARNING: @stable function '" + name + "' redefined")
            }
        } else {
            stable_fns.push(name)
        }
    }
    // Legacy flat array (kept for backward compat)
    let is_memo = (bitmask % 2) == 1
    let is_pure = (bitmask / 8) % 2 == 1
    fn_attr_flags.push([name, is_memo, is_pure])
    // ROI-15: hash-bucketed cache insert
    if len(fn_attr_cache) != 64 { fn_attr_cache_init() }
    let b = env_hash(name)
    fn_attr_cache[b] = fn_attr_cache[b].push([name, bitmask])
}

fn fn_attrs_get(name) {
    let mut i = len(fn_attrs) - 1
    while i >= 0 {
        if fn_attrs[i][0] == name { return fn_attrs[i][1] }
        i = i - 1
    }
    return ""
}

// ── @limit: active call-count helpers ───────────────────
fn active_fn_get(name) {
    let mut i = 0
    while i < len(active_fn_counts) {
        if active_fn_counts[i][0] == name { return active_fn_counts[i][1] }
        i = i + 1
    }
    return 0
}

fn active_fn_inc(name) {
    let mut i = 0
    while i < len(active_fn_counts) {
        if active_fn_counts[i][0] == name {
            active_fn_counts[i] = [name, active_fn_counts[i][1] + 1]
            return 0
        }
        i = i + 1
    }
    active_fn_counts.push([name, 1])
    return 0
}

fn active_fn_dec(name) {
    let mut i = 0
    while i < len(active_fn_counts) {
        if active_fn_counts[i][0] == name {
            let c = active_fn_counts[i][1]
            if c > 0 { active_fn_counts[i] = [name, c - 1] }
            return 0
        }
        i = i + 1
    }
    return 0
}

// ── @limit: system-state readers (sysctl via exec passthrough) ──
// Returns [load1, load5, load15] as floats. Parses "{ 1.23 2.34 3.45 }".
// On parse failure returns [0.0, 0.0, 0.0] (caller treats as "no data").
fn loadavg_triple() {
    let raw = exec("sysctl -n vm.loadavg")
    let mut l1 = 0.0
    let mut l5 = 0.0
    let mut l15 = 0.0
    let s = raw.replace("{", " ").replace("}", " ").trim()
    let parts = s.split(" ")
    let mut idx = 0
    let mut i = 0
    while i < len(parts) {
        let p = parts[i].trim()
        if p != "" {
            if idx == 0 { l1 = to_float(p) }
            if idx == 1 { l5 = to_float(p) }
            if idx == 2 { l15 = to_float(p) }
            idx = idx + 1
        }
        i = i + 1
    }
    return [l1, l5, l15]
}

fn ncpus_detected() {
    let raw = exec("sysctl -n hw.ncpu").trim()
    let n = to_int(raw)
    if n <= 0 { return 1 }
    return n
}

// ── @refuse/@repuse/@watchdog/@monitor runtime helpers ───
// Added 2026-04-20 after Mac kernel panic from train_alm_lora_mac.
// Purpose: make previously-advisory attrs actually enforce at fn entry.

fn host_is_darwin() {
    let u = exec("uname 2>/dev/null").trim()
    return u == "Darwin"
}

fn host_name_short() {
    let h = exec("hostname -s 2>/dev/null").trim()
    if h == "" { return exec("hostname 2>/dev/null").trim() }
    return h
}

// Returns current process RSS in KB (0 on failure).
fn pid_rss_kb() {
    let raw = exec("ps -o rss= -p $$ 2>/dev/null").trim()
    let n = to_int(raw)
    if n < 0 { return 0 }
    return n
}

// Extract integer arg from attrs string like "watchdog(rss_mb=8192,time_s=7200)".
// Returns default if attr not present or arg not found.
fn attr_arg_int(attrs, attr_name, arg_name, default_v) {
    let marker = attr_name + "("
    let idx = attrs.index_of(marker)
    if idx < 0 { return default_v }
    let after = attrs.substring(idx + len(marker), len(attrs))
    let close = after.index_of(")")
    if close < 0 { return default_v }
    let body = after.substring(0, close)
    let key = arg_name + "="
    let ki = body.index_of(key)
    if ki < 0 { return default_v }
    let rest = body.substring(ki + len(key), len(body))
    // Collect digits only
    let mut num = ""
    let chars = rest.chars()
    let mut ci = 0
    let mut stop = false
    while ci < len(chars) && !stop {
        let ch = chars[ci]
        let c = char_code(to_string(ch), 0)
        if c >= 48 && c <= 57 { num = num + to_string(ch) } else { stop = true }
        ci = ci + 1
    }
    if num == "" { return default_v }
    return to_int(num)
}

// Host allowlist for @repuse. Hardcoded for MVP; override via HEXA_REPUSE_OK=1.
fn repuse_host_allowed(h) {
    if h == "" { return false }
    let hl = h.to_lower()
    if hl == "ubu" { return true }
    if hl == "ubu2" { return true }
    if hl == "hetzner" { return true }
    if hl == "htz" { return true }
    if hl == "runpod" { return true }
    // RunPod pods often named like "xxxxxx-x" — accept if env HEXA_HOST_CLASS=remote
    if env_var("HEXA_HOST_CLASS") == "remote" { return true }
    return false
}

// Watchdog state: [[fn_name, wpid], ...]. wpid="" means no watchdog spawned.
pub let mut watchdog_pids = []

fn watchdog_spawn(name, rss_mb, time_s) {
    // Shell watchdog: polls parent RSS every 500ms; SIGKILL on breach.
    // Also kills after time_s seconds regardless.
    let ppid = exec("echo $$").trim()
    let cap_kb = rss_mb * 1024
    let script = "(PPID_TO_WATCH=" + ppid + "; DEADLINE=$(($(date +%s)+" + to_string(time_s) + ")); "
                + "while kill -0 $PPID_TO_WATCH 2>/dev/null; do "
                + "  RSS=$(ps -o rss= -p $PPID_TO_WATCH 2>/dev/null | tr -d ' '); "
                + "  if [ -n \"$RSS\" ] && [ \"$RSS\" -gt \"" + to_string(cap_kb) + "\" ]; then "
                + "    echo \"[watchdog] RSS $RSS kb > " + to_string(cap_kb) + " kb — KILL fn=" + name + "\" >&2; "
                + "    kill -9 $PPID_TO_WATCH; break; fi; "
                + "  if [ $(date +%s) -gt $DEADLINE ]; then "
                + "    echo \"[watchdog] wall > " + to_string(time_s) + "s — KILL fn=" + name + "\" >&2; "
                + "    kill -9 $PPID_TO_WATCH; break; fi; "
                + "  sleep 0.5; "
                + "done) & echo $!"
    let wpid = exec(script).trim()
    watchdog_pids.push([name, wpid])
    return wpid
}

fn watchdog_stop(name) {
    let mut i = len(watchdog_pids) - 1
    while i >= 0 {
        if watchdog_pids[i][0] == name {
            let wpid = watchdog_pids[i][1]
            if wpid != "" { exec("kill " + wpid + " 2>/dev/null") }
            // Pop entry (remove by rebuild — hexa list PBV)
            let mut nl = []
            let mut k = 0
            while k < len(watchdog_pids) {
                if k != i { nl.push(watchdog_pids[k]) }
                k = k + 1
            }
            watchdog_pids = nl
            return 0
        }
        i = i - 1
    }
    return 0
}

fn monitor_emit(name, wall_ms, rss_peak_kb) {
    let sink = env_var("HEXA_MONITOR_SINK")
    let path = if sink == "" { ".hexa-monitor.jsonl" } else { sink }
    let line = "{\"fn\":\"" + name + "\",\"wall_ms\":" + to_string(wall_ms)
             + ",\"rss_peak_kb\":" + to_string(rss_peak_kb) + "}"
    exec("printf '%s\\n' " + shell_quote(line) + " >> " + shell_quote(path) + " 2>/dev/null")
    return 0
}

fn shell_quote(s) {
    // Minimal single-quote escape for shell.
    return "'" + s.replace("'", "'\\''") + "'"
}

// ── ROI-15: O(1) avg bitmask lookup via 64-bucket hash ──
fn fn_attr_bitmask(name) {
    if len(fn_attr_cache) == 64 {
        let b = env_hash(name)
        let bucket = fn_attr_cache[b]
        let mut j = len(bucket) - 1
        while j >= 0 {
            if bucket[j][0] == name { return bucket[j][1] }
            j = j - 1
        }
    }
    return 0
}

// ── Opt #5 legacy: O(1) flag check replaces substring matching ──
fn fn_attr_flag_memo(name) {
    return (fn_attr_bitmask(name) % 2) == 1
}

fn has_memo_attr(name) {
    return (fn_attr_bitmask(name) % 2) == 1
}

fn memo_key_for_args(name, args) {
    let mut key = name + "("
    let mut i = 0
    while i < len(args) {
        if i > 0 { key = key + "," }
        key = key + val_to_string(args[i])
        i = i + 1
    }
    key = key + ")"
    return key
}

// ── Opt #6: hash-bucketed memo cache (64 buckets) ────────
// Same design as env_cache. Hash the key string into a bucket,
// then linear-scan only that bucket (~len/64 entries on average).

fn memo_hash(key) {
    let mut h = 0
    let mut i = 0
    let n = len(key)
    while i < n {
        h = h + char_code(key, i)
        i = i + 1
    }
    let mut b = h
    while b < 0 { b = b + 64 }
    return b % 64
}

fn memo_cache_init() {
    let mut buckets = []
    let mut i = 0
    while i < 64 {
        buckets.push([])
        i = i + 1
    }
    memo_cache = buckets
}

fn memo_lookup(key) {
    if len(memo_cache) != 64 { return "" }
    let b = memo_hash(key)
    let bucket = memo_cache[b]
    let mut i = 0
    let n = len(bucket)
    while i < n {
        if bucket[i][0] == key { return bucket[i] }
        i = i + 1
    }
    return ""
}

fn memo_store(key, result) {
    if len(memo_cache) != 64 { memo_cache_init() }
    let b = memo_hash(key)
    memo_cache[b] = memo_cache[b].push([key, result])
}

// ── @specialize inline cache (V8-style IC) ─────────────
// ROI-12: 64-bucket hash replaces flat-array full rebuild.
// Each bucket is [[fn_name, [[type_tag, hit_count], ...]], ...].
// Mutate only the target bucket entry — no full-array copy.
pub let mut specialize_ic = []      // legacy (unused, kept for reset compat)
pub let mut specialize_ic_cache = []  // 64 buckets

fn specialize_ic_cache_init() {
    let mut buckets = []
    let mut i = 0
    while i < 64 {
        buckets.push([])
        i = i + 1
    }
    specialize_ic_cache = buckets
}

fn specialize_ic_record(fn_name, arg_tag) {
    if len(specialize_ic_cache) != 64 { specialize_ic_cache_init() }
    let b = env_hash(fn_name)
    let bucket = specialize_ic_cache[b]
    // Find existing entry in bucket
    let mut fi = 0
    let blen = len(bucket)
    while fi < blen {
        if bucket[fi][0] == fn_name {
            let mut entries = bucket[fi][1]
            // Find tag entry and update count
            let mut ti = 0
            let mut tag_found = false
            while ti < len(entries) {
                if entries[ti][0] == arg_tag {
                    // In-place count bump: rebuild only this tag's entries array
                    let mut new_entries = []
                    let mut ui = 0
                    while ui < len(entries) {
                        if ui == ti {
                            new_entries.push([arg_tag, entries[ti][1] + 1])
                        } else {
                            new_entries.push(entries[ui])
                        }
                        ui = ui + 1
                    }
                    entries = new_entries
                    tag_found = true
                }
                ti = ti + 1
            }
            if !tag_found {
                entries.push([arg_tag, 1])
            }
            // Update only this bucket entry (not full IC array)
            let mut new_bucket = []
            let mut ri = 0
            while ri < blen {
                if ri == fi {
                    new_bucket.push([fn_name, entries])
                } else {
                    new_bucket.push(bucket[ri])
                }
                ri = ri + 1
            }
            specialize_ic_cache[b] = new_bucket
            return 0
        }
        fi = fi + 1
    }
    // New fn_name: append to bucket
    specialize_ic_cache[b] = bucket.push([fn_name, [[arg_tag, 1]]])
}

fn specialize_ic_dominant_type(fn_name) {
    if len(specialize_ic_cache) != 64 { return "" }
    let b = env_hash(fn_name)
    let bucket = specialize_ic_cache[b]
    let mut fi = 0
    while fi < len(bucket) {
        if bucket[fi][0] == fn_name {
            let entries = bucket[fi][1]
            let mut total = 0
            let mut max_tag = ""
            let mut max_count = 0
            let mut ei = 0
            while ei < len(entries) {
                total = total + entries[ei][1]
                if entries[ei][1] > max_count {
                    max_count = entries[ei][1]
                    max_tag = entries[ei][0]
                }
                ei = ei + 1
            }
            // Monomorphic: >= 80% of calls have same type
            if total > 0 && (max_count * 100 / total) >= 80 {
                return max_tag
            }
            return ""
        }
        fi = fi + 1
    }
    return ""
}
// ── @lazy thunk runtime support ─────────────────────────
// ROI-16: lazy_cache upgraded from flat list to 64-bucket hash.
// Each bucket is [[fn_name, result_val], ...]. O(1) avg lookup.
pub let mut lazy_cache = []

fn lazy_cache_init() {
    let mut buckets = []
    let mut i = 0
    while i < 64 {
        buckets.push([])
        i = i + 1
    }
    lazy_cache = buckets
}

fn has_lazy_attr(name) {
    // ROI-11: single bitmask probe replaces fn_attrs_get + 3 string checks
    return (fn_attr_bitmask(name) / 2) % 2 == 1
}

fn lazy_lookup(name) {
    // ROI-16: 64-bucket hash probe, fallback empty string
    if len(lazy_cache) == 64 {
        let b = env_hash(name)
        let bucket = lazy_cache[b]
        let mut j = len(bucket) - 1
        while j >= 0 {
            if bucket[j][0] == name { return bucket[j] }
            j = j - 1
        }
    }
    return ""
}

fn has_specialize_attr(name) {
    // ROI-11: single bitmask probe replaces fn_attrs_get + 3 string checks
    return (fn_attr_bitmask(name) / 4) % 2 == 1
}
fn lazy_store(name, result) {
    // ROI-16: insert into 64-bucket hash
    if len(lazy_cache) != 64 { lazy_cache_init() }
    let b = env_hash(name)
    lazy_cache[b] = lazy_cache[b].push([name, result])
}

// ── Extern FFI storage ──────────────────────────────────
// Each entry: [hexa_name, c_symbol, ret_type, link_lib]
// c_symbol is from @symbol("name"); if empty, hexa_name is used for dlsym.
pub let mut extern_fns = []

// ── extern_fn_cache: 64-bucket hash cache (mirrors fn_cache pattern) ──
// Each bucket is [[hexa_name, idx_into_extern_fns], ...].
// Avoids O(n) linear scan on every FFI call; O(1) avg via env_hash.
pub let mut extern_fn_cache = []

// ── ROI-4: one-shot FFI real-pointer mode flag ──────────
// Cached result of HXLAYER_FFI_LIVE env-var check. Set once at interpret()
// init; eliminates per-call env_var overhead in alloc_raw / free_raw.
pub let mut ffi_real_pointer_mode = false

// ── ROI-45: one-shot arena-active flag ──────────
// Cached result of HEXA_VAL_ARENA env-var. When false (default), env_set
// skips the heapify round-trip entirely — no env_var lookup, no
// return_val save/restore. Set once at interpret() init.
pub let mut val_arena_active = false

fn extern_fn_cache_init() {
    let mut buckets = []
    let mut i = 0
    while i < 64 {
        buckets.push([])
        i = i + 1
    }
    extern_fn_cache = buckets
}

fn extern_fn_cache_add(name, idx) {
    if len(extern_fn_cache) != 64 { extern_fn_cache_init() }
    let b = env_hash(name)
    extern_fn_cache[b] = extern_fn_cache[b].push([name, idx])
}

// Look up the C symbol name for a hexa extern function.
// Returns the @symbol alias if set, otherwise the hexa name itself.
// ROI-5: probe 64-bucket cache first, fallback to linear scan.
fn extern_c_symbol(hexa_name) {
    if len(extern_fn_cache) == 64 {
        let b = env_hash(hexa_name)
        let bucket = extern_fn_cache[b]
        let mut j = len(bucket) - 1
        while j >= 0 {
            if bucket[j][0] == hexa_name {
                return extern_fns[bucket[j][1]][1]
            }
            j = j - 1
        }
    }
    let mut i = len(extern_fns) - 1
    while i >= 0 {
        if extern_fns[i][0] == hexa_name {
            return extern_fns[i][1]
        }
        i = i - 1
    }
    return hexa_name
}

// Look up the link library for a hexa extern function.
// ROI-5: probe 64-bucket cache first, fallback to linear scan.
fn extern_link_lib(hexa_name) {
    if len(extern_fn_cache) == 64 {
        let b = env_hash(hexa_name)
        let bucket = extern_fn_cache[b]
        let mut j = len(bucket) - 1
        while j >= 0 {
            if bucket[j][0] == hexa_name {
                return extern_fns[bucket[j][1]][3]
            }
            j = j - 1
        }
    }
    let mut i = len(extern_fns) - 1
    while i >= 0 {
        if extern_fns[i][0] == hexa_name {
            return extern_fns[i][3]
        }
        i = i - 1
    }
    return ""
}

// ── Impl block storage (struct method dispatch) ─────────
// Each entry: [target_name, methods_array]
// methods_array: each is a FnDecl node with .name, .params, .body
pub let mut impl_store = []

// ── ROI-17: impl_cache — 64-bucket hash for O(1) method dispatch ──
// Key: "StructName::method" → [impl_store_idx, method_idx]
// Eliminates O(N*M) double linear scan in call_method hot path.
pub let mut impl_cache = []

fn impl_cache_init() {
    let mut buckets = []
    let mut i = 0
    while i < 64 {
        buckets.push([])
        i = i + 1
    }
    impl_cache = buckets
}

fn impl_cache_add(sname, mname, is_idx, m_idx) {
    if len(impl_cache) != 64 { impl_cache_init() }
    let key = sname + "::" + mname
    let b = env_hash(key)
    impl_cache[b] = impl_cache[b].push([key, is_idx, m_idx])
}

fn impl_cache_lookup(sname, mname) {
    // Returns [is_idx, m_idx] or "" on miss
    if len(impl_cache) == 64 {
        let key = sname + "::" + mname
        let b = env_hash(key)
        let bucket = impl_cache[b]
        let mut j = len(bucket) - 1
        while j >= 0 {
            if bucket[j][0] == key { return [bucket[j][1], bucket[j][2]] }
            j = j - 1
        }
    }
    return ""
}

// ── Closure environment storage ─────────────────────────
// Closures capture a snapshot of [env_vars, env_cache] at creation time.
// On closure call, both arrays are swapped in O(1) — no env_rebuild_cache().
pub let mut closure_store = []

// ── G22/G23: Named arguments passing ───────────────────
// Temporary storage for named args during a call dispatch.
// Each entry: [param_name, evaluated_val]
pub let mut pending_named_args = []

// ── Callback trampoline storage (G4) ───────────────────
// Pool of 16 callback slots for interpreter mode.
// Each slot: [in_use (0/1), fn_val]
pub let mut callback_slots = []
pub let mut callback_inited = false

fn callback_init() {
    if callback_inited { return 0 }
    callback_inited = true
    let mut i = 0
    while i < 16 {
        callback_slots.push([0, val_void()])
        i = i + 1
    }
    return 0
}

// ── ROI-20: direct index mutation (O(1) in-place, C3 PBV fix) ──
// Replaces full 16-slot array rebuild (16 push+copy) with single arr[i]=v.
fn callback_slots_put(idx, entry) {
    callback_slots[idx] = entry
}

fn callback_alloc(fn_val) {
    callback_init()
    let mut i = 0
    while i < 16 {
        if callback_slots[i][0] == 0 {
            callback_slots_put(i, [1, fn_val])
            return i
        }
        i = i + 1
    }
    println("callback pool exhausted (16 slots)")
    return -1
}

fn callback_release(slot) {
    callback_init()
    if slot >= 0 && slot < 16 {
        callback_slots_put(slot, [0, val_void()])
    }
}

fn callback_call(slot, args) {
    callback_init()
    if slot < 0 || slot >= 16 { return val_void() }
    if callback_slots[slot][0] == 0 { return val_void() }
    let fn_val = callback_slots[slot][1]
    if fn_val.tag == TAG_FN {
        return call_fn_val(fn_val, args)
    }
    return val_void()
}

// ── Host builtin shims ─────────────────────────────────────
// call_builtin's parameter `args` shadows the host's `args()` builtin,
// so we need top-level helpers (no `args` param) to reach it.
// host_args: would return host CLI args, but call_builtin's `args` param
// shadows the host builtin. Top-level capture also clashes with how the
// host hexa loads modules. Returning empty array as safe fallback.
// User code calling args() inside self-host.
// Return raw[1..] to skip the duplicated argv[0] inserted by hexa_set_args.
// Resulting layout: [bin_dup, script, mode, target, extra...] — so user
// code accessing args()[2], args()[3] gets (mode, target) as the
// hook-entry.hexa / legacy scripts expect (pre-interp convention).
fn host_args() {
    let raw = args()
    let mut result = []
    let mut i = 1
    while i < len(raw) {
        result.push(raw[i])
        i = i + 1
    }
    return result
}
fn host_argc() { return len(args()) }
fn host_arg(i) {
    let a = host_args()
    if i >= 0 && i < len(a) { return a[i] }
    return ""
}

// ═══════════════════════════════════════════════════════════
//  Phase 7 골화 — FFI: extern fn dispatch + value/C ABI bridge
//  src/interpreter.rs:10814 (call_extern_fn) 대응
// ═══════════════════════════════════════════════════════════
//  Self-host 인터프리터는 dlsym+transmute를 직접 못 함.
//  대신 호스트 인터프리터(이 코드를 실행 중인 native hexa)가
//  제공하는 빌트인 `__host_extern_call`을 거쳐 dispatch.
//  호스트가 그 빌트인을 노출하지 않는 경우는 error 반환.

// Convert a Val to a C-ABI i64 (matches src::value_to_c_arg)
//   int → i64 그대로
//   bool → 0/1
//   float → bit-cast (정확도는 호스트 책임)
//   str → 호스트가 펀딩한 UTF-8 ptr (현 self-host: 길이만 반환)
//   pointer → addr
//   기타 → 0
fn value_to_c_arg(v) {
    if v.tag == TAG_INT { return v.int_val }
    if v.tag == TAG_BOOL { if v.bool_val { return 1 } else { return 0 } }
    if v.tag == TAG_POINTER { return v.int_val }
    if v.tag == TAG_CHAR {
        let cs = v.char_val
        if len(cs) > 0 { return cs[0] }
        return 0
    }
    // float / str / 기타: self-host에선 안전 fallback
    return 0
}

// Convert a C-ABI i64 return back to a Val based on declared ret_type.
//   "int"|"i64"|"" → int
//   "bool" → bool
//   "ptr"|"void*" → pointer
//   "char"|"i8" → char
//   기타 → int
fn c_ret_to_value(raw, ret_type) {
    if ret_type == "bool" { return val_bool(raw != 0) }
    if ret_type == "ptr" || ret_type == "void*" || ret_type == "*mut" {
        return val_pointer(raw)
    }
    if ret_type == "char" || ret_type == "i8" {
        return Val { tag: TAG_CHAR, int_val: raw, float_val: 0.0, bool_val: false, str_val: __E, char_val: to_string(raw), array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E }
    }
    return val_int(raw)
}

// call_extern_fn(builtin_name, args) — dispatch C extern from .hexa interpreter
//   builtin_name format: "__extern_<fn_name>"
//   1. Extract fn_name
//   2. Look up declared ret_type
//   3. Resolve C symbol via @symbol alias (extern_c_symbol)
//   4. Pass Vals through directly — __host_extern_call inspects tags for
//      int/float ABI lane assignment (C2 Step 3, 2026-04-16).
//   5. Convert result via c_ret_to_value
fn call_extern_fn(builtin_name, args) {
    let fn_name = builtin_name.substring(9, len(builtin_name))   // strip "__extern_"
    let c_sym = extern_c_symbol(fn_name)
    let lib = extern_link_lib(fn_name)
    // ROI-5: ret_type lookup via cache, fallback linear scan
    let mut ret_type = ""
    let mut ret_found = false
    if len(extern_fn_cache) == 64 {
        let b = env_hash(fn_name)
        let bucket = extern_fn_cache[b]
        let mut j = len(bucket) - 1
        while j >= 0 {
            if bucket[j][0] == fn_name {
                ret_type = extern_fns[bucket[j][1]][2]
                ret_found = true
                j = -1
            } else {
                j = j - 1
            }
        }
    }
    if ret_found == false {
        let mut i = len(extern_fns) - 1
        while i >= 0 {
            if extern_fns[i][0] == fn_name {
                ret_type = extern_fns[i][2]
                i = -1
            } else {
                i = i - 1
            }
        }
    }
    // Wrap args directly so the host sees original tags (float in xmm,
    // int in gpr). hexa_extern_call_typed handles the mixed ABI.
    let host_result = call_builtin("__host_extern_call", [val_str(c_sym), val_str(lib), val_array(args), val_str(ret_type)])
    if host_result.tag == TAG_NOT_BUILTIN {
        return Val { tag: TAG_ERROR, int_val: 0, float_val: 0.0, bool_val: false, str_val: "extern '" + fn_name + "': host runtime does not expose __host_extern_call", char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E }
    }
    if host_result.tag == TAG_INT {
        return c_ret_to_value(host_result.int_val, ret_type)
    }
    return host_result
}

// Helper: build a Val::Array from a flat int array (used by call_extern_fn)
fn val_array_simple(int_items) {
    let mut wrapped = []
    for n in int_items { wrapped.push(val_int(n)) }
    return val_array(wrapped)
}

// ═══════════════════════════════════════════════════════════
//  T1 Phase B — proof / fuse 카테고리 → self/runtime_core.hexa 로 이동
//    - 17 proof_* fns      (proof_var..proof_unknown, expr_to_proof_expr, execute_proof_block_stmt)
//    - 3  fuse_* fns        (fuse_sentinel, is_fuse_terminal, try_fuse_chain)
//  빌드 경로: tool/build_interp.hexa → flatten_imports → hexa_v2 transpile
// ═══════════════════════════════════════════════════════════

// ── env_cache helpers (O(1) avg lookup) ───────────────────
// Hash a name into one of 64 buckets. Simple sum-of-char-codes mod 64;
// collisions are fine because each bucket is still linearly scanned,
// just over a much smaller set (~len(env_vars)/64).
fn env_hash(name) {
    let mut h = 0
    let mut i = 0
    let n = len(name)
    while i < n {
        h = h + char_code(name, i)
        i = i + 1
    }
    let mut b = h
    while b < 0 { b = b + 64 }
    return b % 64
}

fn env_cache_init() {
    // rt 32-E: init both parallel cache arrays (names, idxs). env_cache
    // retained as legacy len==64 sentinel checked by fallback branches.
    let mut names_buckets = []
    let mut idxs_buckets = []
    let mut legacy_buckets = []
    let mut i = 0
    while i < 64 {
        names_buckets.push([])
        idxs_buckets.push([])
        legacy_buckets.push([])
        i = i + 1
    }
    env_cache_names = names_buckets
    env_cache_idxs = idxs_buckets
    env_cache = legacy_buckets
}

// Rebuild cache from current env_var_names. Fallback for cases where a
// cached snapshot is unavailable (e.g., interpret() reset, legacy paths).
fn env_rebuild_cache() {
    env_cache_init()
    let mut i = 0
    let n = len(env_var_names)
    while i < n {
        let nm = env_var_names[i]
        let b = env_hash(nm)
        env_cache_names[b] = env_cache_names[b].push(nm)
        env_cache_idxs[b] = env_cache_idxs[b].push(i)
        i = i + 1
    }
}

// ── O(1) fn_cache helpers (mirrors env_cache pattern) ────
// Reuse env_hash for bucket index — same 64-bucket, sum-of-char-codes scheme.

fn fn_cache_init() {
    let mut buckets = []
    let mut i = 0
    while i < 64 {
        buckets.push([])
        i = i + 1
    }
    fn_cache = buckets
}

fn fn_cache_add(name, idx) {
    if len(fn_cache) != 64 { fn_cache_init() }
    let b = env_hash(name)
    fn_cache[b] = fn_cache[b].push([name, idx])
}

fn fn_rebuild_cache() {
    fn_cache_init()
    let mut i = 0
    let n = len(env_fns)
    while i < n {
        let entry = env_fns[i]
        let b = env_hash(entry[0])
        fn_cache[b] = fn_cache[b].push([entry[0], i])
        i = i + 1
    }
}

fn env_push_scope() {
    // rt 32-K: 2-push per-scope-enter pattern batched as single logical event.
    // env_scopes (boundary marker) and env_scope_dirty (per-scope dirty bucket)
    // are amortised global stacks pushed in lockstep on every scope enter
    // (same rt 32-J semantics as env_define's name/val/cache pair). Charge ONE
    // stat push for the canonical "scope enter" event (env_scopes) and use
    // push_nostat for env_scope_dirty so the stat counter reflects scope-enter
    // frequency rather than array-touch-frequency. Physical realloc/memcpy
    // behavior unchanged — only the array_push counter semantics shift.
    env_scopes.push(len(env_var_names))     // ← canonical stat bump for the scope-enter event
    // rt 32: defer the per-scope `[]` allocation to env_define when actually
    // needed. ML hot loops (matvec inner col loop) push hundreds of scopes
    // with zero defines — pre-allocating a host array each time was a major
    // hexa_array_new contributor (~900K/d64 micro). Sentinel `0` marks
    // an empty scope; env_define lazy-converts to a real bucket list.
    env_scope_dirty.push(0)     // paired sibling — same scope-enter event
}

fn env_pop_scope() {
    let boundary = env_scopes[len(env_scopes) - 1]
    // bt 55 — in-place truncate replaces the rebuild-loop that leaked O(N)
    // per scope pop. truncate() shrinks .len without reallocating, retaining
    // capacity for amortized re-growth and releasing the old backing buffer
    // reference. `env_vars = env_vars.truncate(n)` pattern satisfies I1
    // (hexa lists pass-by-value) via reassignment.
    // Remove the last scope marker
    env_scopes = env_scopes.truncate(len(env_scopes) - 1)
    // rt 32: decref array/struct slots before truncating env_var_vals. Without
    // this the array_store freelist never reclaims slots (refcount stays
    // ≥ 1 even after the binding goes out of scope), defeating the slot
    // reuse optimization and leaking ~64 floats × N steps per matvec.
    let env_len = len(env_var_names)
    let mut _di = boundary
    while _di < env_len {
        let old_val = env_var_vals[_di]
        if old_val.tag == TAG_ARRAY {
            array_decref(old_val.int_val)
        }
        if old_val.tag == TAG_STRUCT {
            struct_decref(old_val.int_val)
        }
        _di = _di + 1
    }
    // Truncate parallel arrays to boundary
    env_var_names = env_var_names.truncate(boundary)
    env_var_vals = env_var_vals.truncate(boundary)
    // Prune cache: only scan buckets that were modified during this scope.
    // Dirty-tracking reduces O(64 + total_cache_entries) to O(dirty_buckets).
    let sdn = len(env_scope_dirty)
    if sdn > 0 {
        let dirty = env_scope_dirty[sdn - 1]
        // Pop the dirty set
        env_scope_dirty = env_scope_dirty.truncate(sdn - 1)
        // rt 32: sentinel `0` (int) means scope had no defines → no cache
        // pruning needed. Skips the entire dirty loop for empty scopes
        // (matvec/vec_gelu inner while bodies — hottest path).
        if type_of(dirty) != "int" {
            let mut _pdi = 0
            let dn = len(dirty)
            while _pdi < dn {
                let bi = dirty[_pdi]
                // rt 32-E: walk parallel (names, idxs) buckets; keep only
                // entries whose idx is still < boundary.
                let b_names = env_cache_names[bi]
                let b_idxs = env_cache_idxs[bi]
                let mut kept_names = []
                let mut kept_idxs = []
                let mut ki = 0
                let bn = len(b_idxs)
                while ki < bn {
                    let eidx = b_idxs[ki]
                    if eidx < boundary {
                        kept_names.push(b_names[ki])
                        kept_idxs.push(eidx)
                    }
                    ki = ki + 1
                }
                env_cache_names[bi] = kept_names
                env_cache_idxs[bi] = kept_idxs
                _pdi = _pdi + 1
            }
        }
    }
}

fn env_define(name, value) {
    // Perf #10/#11 COW: incref when array/struct value is bound to a new name.
    if value.tag == TAG_ARRAY {
        array_incref(value.int_val)
    }
    if value.tag == TAG_STRUCT {
        struct_incref(value.int_val)
    }
    // rt 32-E: parallel push — no `[name, value]` tuple alloc (-1 array_new,
    // -2 array_push per define).
    // rt 32-J: 4-push per-define pattern batched as single logical event.
    // env_var_names/env_var_vals and env_cache_names[b]/env_cache_idxs[b]
    // are amortised global buffers (same rt 32-B semantics as call_arg_buf):
    // each env_define is ONE logical bind event that physically touches 4
    // arrays in lockstep. Charge ONE stat push for the event and use
    // push_nostat for the paired siblings so the stat counter reflects
    // define-frequency rather than array-touch-frequency. env_scope_dirty
    // bucket push is also a side-effect of the same event → push_nostat.
    let idx = len(env_var_names)
    env_var_names.push(name)            // ← canonical stat bump for the define event
    env_var_vals.push(value)       // paired sibling
    // Lazily init cache on first define after reset.
    if len(env_cache_names) != 64 { env_cache_init() }
    let b = env_hash(name)
    // rt 32-E: parallel push to (names, idxs) bucket — no tuple alloc.
    // rt 32-J: cache update is a side effect of the same define event.
    env_cache_names[b] = env_cache_names[b].push(name)
    env_cache_idxs[b] = env_cache_idxs[b].push(idx)
    // Track dirty bucket in current scope (opt #8)
    let sdn = len(env_scope_dirty)
    if sdn > 0 {
        let top = env_scope_dirty[sdn - 1]
        // rt 32: lazy bucket — sentinel `0` (int) means empty.  Allocate the
        // real bucket list on first define in this scope.
        if type_of(top) == "int" {
            env_scope_dirty[sdn - 1] = [b]
        } else {
            // Avoid duplicate bucket entries in the dirty set
            let mut already = false
            let mut di = 0
            while di < len(top) {
                if top[di] == b { already = true }
                di = di + 1
            }
            if !already {
                // rt 32-J: dirty-tracking is also a side effect of the define.
                env_scope_dirty[sdn - 1] = top.push(b)
            }
        }
    }
}

fn env_lookup(name) {
    // O(1) avg via bucket cache. Fall back to linear scan only if
    // cache is empty (e.g., right after wholesale env_vars swap that
    // forgot to rebuild — defensive).
    if len(env_cache_names) == 64 {
        let b = env_hash(name)
        let b_names = env_cache_names[b]
        let b_idxs = env_cache_idxs[b]
        // Pick entry with largest index (newest binding still in scope).
        let mut best = -1
        let mut bi = 0
        let bn = len(b_names)
        while bi < bn {
            if b_names[bi] == name {
                let ei = b_idxs[bi]
                if ei > best { best = ei }
            }
            bi = bi + 1
        }
        if best >= 0 && best < len(env_var_vals) {
            return env_var_vals[best]
        }
        return val_void()
    }
    // Fallback linear scan
    let mut i = len(env_var_names) - 1
    while i >= 0 {
        if env_var_names[i] == name {
            return env_var_vals[i]
        }
        i = i - 1
    }
    return val_void()
}

fn env_set(name, value) {
    // Perf #10/#11 COW: on reassignment, incref new array/struct value.
    if value.tag == TAG_ARRAY {
        array_incref(value.int_val)
    }
    if value.tag == TAG_STRUCT {
        struct_incref(value.int_val)
    }
    // T40: under HEXA_VAL_ARENA=1, assigning an arena-allocated Val to an
    // outer-scope binding (below the current scope boundary — especially
    // top-level globals) must heapify the RHS first. Otherwise the
    // VALSTRUCT (arena-allocated when inside a fn scope) and any nested
    // array_store slot contents get rewound on env_pop_scope, leaving the
    // binding dangling / len=0. Mirrors the return-path heapify.
    let _scope_top = len(env_scopes)
    let _boundary = if _scope_top > 0 { env_scopes[_scope_top - 1] } else { 0 }
    let mut _heapified = value
    if len(env_cache_names) == 64 {
        let b = env_hash(name)
        let b_names = env_cache_names[b]
        let b_idxs = env_cache_idxs[b]
        let mut best = -1
        let mut bi = 0
        let bn = len(b_names)
        while bi < bn {
            if b_names[bi] == name {
                let ei = b_idxs[bi]
                if ei > best { best = ei }
            }
            bi = bi + 1
        }
        if best >= 0 && best < len(env_var_vals) {
            // ROI-45: skip heapify round-trip when arena inactive (default)
            if val_arena_active && best < _boundary {
                let _saved_rv = return_val
                return_val = _heapified
                let _h = env_var("__HEXA_ARENA_HEAPIFY_RETURN__")
                _heapified = return_val
                return_val = _saved_rv
            }
            // Decref old value if it was an array or struct
            let old_val = env_var_vals[best]
            if old_val.tag == TAG_ARRAY {
                array_decref(old_val.int_val)
            }
            if old_val.tag == TAG_STRUCT {
                struct_decref(old_val.int_val)
            }
            env_var_vals[best] = _heapified
            return true
        }
        return false
    }
    let mut i = len(env_var_names) - 1
    while i >= 0 {
        if env_var_names[i] == name {
            // ROI-45: skip heapify round-trip when arena inactive (default)
            if val_arena_active && i < _boundary {
                let _saved_rv = return_val
                return_val = _heapified
                let _h = env_var("__HEXA_ARENA_HEAPIFY_RETURN__")
                _heapified = return_val
                return_val = _saved_rv
            }
            // Decref old value if it was an array or struct
            let old_val = env_var_vals[i]
            if old_val.tag == TAG_ARRAY {
                array_decref(old_val.int_val)
            }
            if old_val.tag == TAG_STRUCT {
                struct_decref(old_val.int_val)
            }
            env_var_vals[i] = _heapified
            return true
        }
        i = i - 1
    }
    return false
}

// ── Core: eval_expr ──────────────────────────────────────

fn eval_expr_at(arr, idx) {
    // Defensive: parser may emit Str("") or non-struct stubs when recovering
    // from a syntax error. Bail out to void instead of crashing.
    let elem = arr[idx]
    if type_of(elem) == "string" { return val_void() }
    if type_of(elem) == "int" { return val_int(elem) }
    if type_of(elem) == "float" { return val_float(elem) }
    if type_of(elem) != "struct" && type_of(elem) != "map" { return val_void() }
    let k = elem.kind
    if type_of(k) != "string" { return val_void() }

    // Numeric dispatch for hot-path literals (int compare vs string compare)
    let kid = nk_cached_id(k)
    if kid == NK_INT_LIT { return val_int(arr[idx].value.parse_int()) }
    if kid == NK_FLOAT_LIT { return val_float(arr[idx].value.parse_float()) }
    if kid == NK_BOOL_LIT { return val_bool(arr[idx].value == "true") }
    if kid == NK_STRING_LIT { return val_str(arr[idx].value) }
    if kid == NK_CHAR_LIT { return val_str(arr[idx].value) }
    if kid == NK_IDENT { return env_lookup(arr[idx].name) }
    // For complex nodes, we need to extract children
    // This is OK because arr[idx].left gives a reference, not a deep copy
    return eval_expr_inner(arr[idx])
}

fn eval_expr(node) {
    // rt 32-E: eliminate the `let _tmp_arr = [node]` 1-element array that
    // every eval_expr call was creating (1 array_new + 1 push PER call).
    // d64 micro: ~8-10M eval_expr calls in matvec inner col loop alone.
    // eval_expr_inner already has identical fast-path literal dispatch;
    // direct forwarding is semantically equivalent and orders of magnitude
    // cheaper on the hot path.
    return eval_expr_inner(node)
}

fn eval_expr_inner(node) {
    // Defensive: parser may produce non-struct stub values when recovering
    // from a syntax error. Treat them as void to keep interpret() resilient.
    if type_of(node) == "string" { return val_void() }
    if type_of(node) == "int" { return val_int(node) }
    if type_of(node) == "float" { return val_float(node) }
    if type_of(node) != "struct" && type_of(node) != "map" { return val_void() }
    let k = node.kind
    if type_of(k) != "string" { return val_void() }

    // hxa-20260423-014: ComptimeExpr wrapper is transparent at runtime —
    // evaluate the inner expression as normal. Codegen (codegen_c2 path)
    // folds via comptime_eval where possible; the interpreter always
    // executes at runtime.
    if k == "ComptimeExpr" { return eval_expr(node.left) }

    // ── Numeric dispatch: convert kind string → int once, compare ints ──
    let kid = nk_cached_id(k)

    if kid == NK_INT_LIT { return val_int(node.value.parse_int()) }
    if kid == NK_FLOAT_LIT { return val_float(node.value.parse_float()) }
    if kid == NK_BOOL_LIT { return val_bool(node.value == "true") }
    if kid == NK_STRING_LIT { return val_str(node.value) }
    if kid == NK_CHAR_LIT { return val_str(node.value) }
    if kid == NK_IDENT { return env_lookup(node.name) }

    if kid == NK_BIN_OP {
        // ── is operator: v is int — type check without evaluating RHS ──
        if node.op == "is" {
            let lv = eval_expr(node.left)
            let type_name = node.right.name
            if type_name == "int" { return val_bool(lv.tag == TAG_INT) }
            if type_name == "float" { return val_bool(lv.tag == TAG_FLOAT) }
            if type_name == "str" || type_name == "string" { return val_bool(lv.tag == TAG_STR) }
            if type_name == "bool" { return val_bool(lv.tag == TAG_BOOL) }
            if type_name == "char" { return val_bool(lv.tag == TAG_CHAR) }
            if type_name == "array" { return val_bool(lv.tag == TAG_ARRAY) }
            if type_name == "map" { return val_bool(lv.tag == TAG_MAP) }
            if type_name == "fn" || type_name == "function" { return val_bool(lv.tag == TAG_FN) }
            if type_name == "void" { return val_bool(lv.tag == TAG_VOID) }
            if type_name == "struct" { return val_bool(lv.tag == TAG_STRUCT) }
            if type_name == "enum" { return val_bool(lv.tag == TAG_ENUM) }
            if type_name == "error" { return val_bool(lv.tag == TAG_ERROR) }
            // User-defined struct type name
            if lv.tag == TAG_STRUCT && lv.struct_name == type_name { return val_bool(true) }
            return val_bool(false)
        }
        // ── as operator: v as int / v as float / v as string / v as bool ──
        // Type cast — RHS is a type-name Ident. Coerces value to target tag.
        // Numeric→numeric uses arithmetic conversion; string parsing for
        // str→int/float; to_string for any→str. Returns void on impossible.
        if node.op == "as" {
            let lv = eval_expr(node.left)
            let type_name = node.right.name
            if type_name == "int" {
                if lv.tag == TAG_INT { return lv }
                if lv.tag == TAG_FLOAT { return val_int(to_int(lv.float_val)) }
                if lv.tag == TAG_BOOL { return val_int(if lv.bool_val { 1 } else { 0 }) }
                if lv.tag == TAG_STR { return val_int(to_int(lv.str_val)) }
                if lv.tag == TAG_CHAR { return val_int(char_code(lv.char_val, 0)) }
                return val_int(0)
            }
            if type_name == "float" {
                if lv.tag == TAG_FLOAT { return lv }
                if lv.tag == TAG_INT { return val_float(to_float(lv.int_val)) }
                if lv.tag == TAG_BOOL { return val_float(if lv.bool_val { 1.0 } else { 0.0 }) }
                if lv.tag == TAG_STR { return val_float(to_float(lv.str_val)) }
                return val_float(0.0)
            }
            if type_name == "str" || type_name == "string" {
                if lv.tag == TAG_STR { return lv }
                return val_str(to_string(lv))
            }
            if type_name == "bool" {
                if lv.tag == TAG_BOOL { return lv }
                if lv.tag == TAG_INT { return val_bool(lv.int_val != 0) }
                if lv.tag == TAG_FLOAT { return val_bool(lv.float_val != 0.0) }
                if lv.tag == TAG_STR { return val_bool(len(lv.str_val) > 0) }
                if lv.tag == TAG_VOID { return val_bool(false) }
                return val_bool(true)
            }
            // Unknown target type — pass through (no-op cast).
            return lv
        }
        // ── Pipe operator: x |> f  desugars to  f(x) ──
        if node.op == "|>" {
            let lv = eval_expr(node.left)
            if throw_flag || panic_flag { return val_void() }
            let rk = node.right.kind
            // x |> f(y)  =>  f(x, y)  — partial call, prepend left as first arg
            if rk == "Call" {
                // rt 32-B: reuse shared call_arg_buf (same stack-discipline as NK_CALL).
                let _ca_base = call_arg_top
                call_arg_buf.push(lv)
                call_arg_top = call_arg_top + 1
                let raw_args = node.right.args
                if type_of(raw_args) == "array" {
                    let mut _ai = 0
                    while _ai < len(raw_args) {
                        call_arg_buf.push(eval_expr_at(raw_args, _ai))
                        call_arg_top = call_arg_top + 1
                        if throw_flag || panic_flag {
                            call_arg_buf = call_arg_buf.truncate(_ca_base)
                            call_arg_top = _ca_base
                            return val_void()
                        }
                        _ai = _ai + 1
                    }
                }
                let call_args = call_arg_buf.slice_fast(_ca_base, call_arg_top)
                call_arg_buf = call_arg_buf.truncate(_ca_base)
                call_arg_top = _ca_base
                let callee = node.right.left
                if type_of(callee) != "string" && callee.kind == "Ident" {
                    let fname = callee.name
                    let user_info = find_fn(fname)
                    if user_info != "" { return call_user_fn(fname, call_args) }
                    let br = call_builtin(fname, call_args)
                    if br.tag != "__not_builtin__" { return br }
                    return call_user_fn(fname, call_args)
                }
                if type_of(callee) != "string" && callee.kind == "Field" {
                    let obj = eval_expr(callee.left)
                    let method = callee.name
                    return call_method(obj, method, call_args)
                }
                let callee_val = eval_expr(callee)
                if callee_val.tag == "fn" { return call_fn_val(callee_val, call_args) }
                return val_void()
            }
            // x |> f  =>  f(x)  — bare function name
            if rk == "Ident" {
                let fname = node.right.name
                let args = [lv]
                let user_info = find_fn(fname)
                if user_info != "" { return call_user_fn(fname, args) }
                let br = call_builtin(fname, args)
                if br.tag != "__not_builtin__" { return br }
                // Could be a closure/variable holding a fn value
                let fn_val = env_lookup(fname)
                if fn_val.tag == "fn" { return call_fn_val(fn_val, args) }
                return call_user_fn(fname, args)
            }
            // x |> (fn(a) { ... })  =>  lambda(x)
            if rk == "Lambda" {
                let rv = eval_expr(node.right)
                if rv.tag == "fn" { return call_fn_val(rv, [lv]) }
                return val_void()
            }
            // Fallback: evaluate right side and try to call it
            let rv = eval_expr(node.right)
            if rv.tag == "fn" { return call_fn_val(rv, [lv]) }
            println("Runtime error: pipe operator |> requires a function on the right side")
            return val_void()
        }
        // Short-circuit evaluation for && and ||
        if node.op == "&&" {
            let lv = eval_expr(node.left)
            if !is_truthy(lv) { return val_bool(false) }
            let rv = eval_expr(node.right)
            return val_bool(is_truthy(rv))
        }
        if node.op == "||" {
            let lv = eval_expr(node.left)
            if is_truthy(lv) { return val_bool(true) }
            let rv = eval_expr(node.right)
            return val_bool(is_truthy(rv))
        }
        let lv = eval_expr(node.left)
        let rv = eval_expr(node.right)
        return eval_binop(node.op, lv, rv)
    }

    // G24: Walrus operator :=  (assignment expression)
    // Evaluate RHS, bind to LHS name in current scope, return the value.
    if kid == NK_WALRUS {
        let val = eval_expr(node.right)
        env_define(node.name, val)
        return val
    }

    if kid == NK_UNARY_OP {
        // G37: typeof operator — returns type name as string
        if node.op == "typeof" {
            let v = eval_expr(node.left)
            let t = tag_name(v.tag)
            return val_str(t)
        }
        let v = eval_expr(node.left)
        if node.op == "-" {
            if v.tag == TAG_INT { return val_int(-v.int_val) }
            if v.tag == TAG_FLOAT { return val_float(-v.float_val) }
        }
        if node.op == "!" {
            return val_bool(!is_truthy(v))
        }
        // Bitwise NOT (ported from src/interpreter.rs eval_unary)
        if node.op == "~" {
            if v.tag == TAG_INT { return val_int(~v.int_val) }
        }
        return v
    }

    if kid == NK_ARRAY {
        let mut items = []
        for item in node.items {
            if type_of(item) != "string" && item.kind == "Spread" {
                let spread_val = eval_expr(item.left)
                if spread_val.tag == "array" {
                    let spread_items = get_array(spread_val)
                    let mut si = 0
                    while si < len(spread_items) {
                        items.push(spread_items[si])
                        si = si + 1
                    }
                } else {
                    items.push(spread_val)
                }
            } else {
                items.push(eval_expr(item))
            }
        }
        return val_array(items)
    }

    // List comprehension: [expr for var in iterable if cond]
    if kid == NK_LIST_COMP {
        let iter_val = eval_expr(node.iter_expr)
        let mut src_items = []
        if iter_val.tag == TAG_ARRAY {
            src_items = get_array(iter_val)
        } else if iter_val.tag == TAG_MAP {
            src_items = get_map_keys(iter_val)
        }
        let has_filter = type_of(node.cond) != "string"
        let mut result = []
        let mut _lci = 0
        while _lci < len(src_items) {
            env_push_scope()
            env_define(node.name, src_items[_lci])
            if has_filter {
                let cond_val = eval_expr(node.cond)
                if is_truthy(cond_val) {
                    result.push(eval_expr(node.left))
                }
            } else {
                result.push(eval_expr(node.left))
            }
            env_pop_scope()
            _lci = _lci + 1
        }
        return val_array(result)
    }

    if kid == NK_INDEX {
        // G13: array/string slicing — arr[start..end] or arr[start..=end]
        if type_of(node.right) != "string" && node.right.kind == "Range" {
            let arr_s = eval_expr(node.left)
            let s = eval_expr(node.right.left).int_val
            let e_raw = eval_expr(node.right.right).int_val
            // parser encodes inclusive/exclusive in node.value
            let inc = node.right.value == "inclusive"
            if arr_s.tag == TAG_ARRAY {
                let items = get_array(arr_s)
                let n = len(items)
                let mut e = e_raw
                if inc { e = e + 1 }
                if e > n { e = n }
                if s > e { return val_array([]) }
                let mut out = []
                let mut i = s
                while i < e {
                    out.push(items[i])
                    i = i + 1
                }
                return val_array(out)
            }
            if arr_s.tag == TAG_STR {
                let chars = arr_s.str_val.chars()
                let n = len(chars)
                let mut e = e_raw
                if inc { e = e + 1 }
                if e > n { e = n }
                if s > e { return val_str("") }
                let mut out = ""
                let mut i = s
                while i < e {
                    out = out + to_string(chars[i])
                    i = i + 1
                }
                return val_str(out)
            }
            return val_void()
        }
        // ── Perf #13: arr[i] fast path — Ident left avoids full clone ──
        // When left is a plain identifier, env_lookup returns the value
        // directly; we index into it without evaluating the whole sub-tree.
        let left_node = node.left
        let mut arr = val_void()
        if left_node.kind == "Ident" {
            arr = env_lookup(left_node.name)
        } else {
            arr = eval_expr(left_node)
        }
        let idx = eval_expr(node.right)
        // 2026-04-17: safe index extraction — idx might not be TAG_INT
        // (e.g. TAG_FLOAT from arithmetic), causing stale int_val reads.
        let _safe_idx = if idx.tag == TAG_INT { idx.int_val } else { to_int(idx) }
        if arr.tag == TAG_ARRAY {
            let items = get_array(arr)
            // Python-style negative index (AOT hexa_array_get 와 align) — 음수면
            // len() 더해서 wraparound. 이전엔 interp 가 OOB throw 라 divergence.
            let mut _aidx = _safe_idx
            if _aidx < 0 { _aidx = _aidx + len(items) }
            if _aidx < 0 || _aidx >= len(items) {
                exec_throw(val_str("index " + to_string(_safe_idx) + " out of bounds (len " + to_string(len(items)) + ")"))
                return val_void()
            }
            return items[_aidx]
        }
        if arr.tag == TAG_TENSOR {
            let items = tensor_data(arr)
            let mut _tidx = _safe_idx
            if _tidx < 0 { _tidx = _tidx + len(items) }
            if _tidx < 0 || _tidx >= len(items) {
                exec_throw(val_str("index " + to_string(_safe_idx) + " out of bounds (len " + to_string(len(items)) + ")"))
                return val_void()
            }
            return val_float(if type_of(items[_tidx]) == "float" { items[_tidx] } else { to_float_val(items[_tidx]) })
        }
        if arr.tag == TAG_STR {
            let chars = arr.str_val.chars()
            let mut _sidx = _safe_idx
            if _sidx < 0 { _sidx = _sidx + len(chars) }
            if _sidx < 0 || _sidx >= len(chars) {
                exec_throw(val_str("index " + to_string(_safe_idx) + " out of bounds (len " + to_string(len(chars)) + ")"))
                return val_str("")
            }
            return val_str(to_string(chars[_sidx]))
        }
        if arr.tag == TAG_MAP {
            // hexa-only Mac menubar 부활: dict indexing 지원 (2026-04-14, airgenome T4)
            // map_get 는 key 를 Val 로 받음 — string idx 는 그대로 사용.
            return map_get(arr, idx)
        }
        return val_void()
    }

    if kid == NK_CALL {
        // Inline Call handling (avoid struct copy issue with eval_call)
        // G8: spread args — `f(...args)` flattens array into arg list
        //
        // rt 32-B: reusable buffer. Stack-discipline on call_arg_buf:
        //   1) snapshot current top (= our base)
        //   2) push each evaluated arg via push_nostat (no stat counter bump)
        //   3) slice_fast(base, top) to get an independent copy for callee
        //   4) truncate call_arg_buf back to base (retains capacity)
        // This replaces the prior `let mut call_args = []` which was a
        // per-call hexa_array_new + N× hexa_array_push.
        let _ca_base = call_arg_top
        let raw_args = node.args
        if type_of(raw_args) == "array" {
            let mut _ai = 0
            while _ai < len(raw_args) {
                let arg_node = raw_args[_ai]
                if type_of(arg_node) != "string" && arg_node.kind == "Spread" {
                    let spread_val = eval_expr(arg_node.left)
                    if spread_val.tag == "array" {
                        let spread_items = get_array(spread_val)
                        let mut si = 0
                        while si < len(spread_items) {
                            call_arg_buf.push(spread_items[si])
                            call_arg_top = call_arg_top + 1
                            si = si + 1
                        }
                    } else {
                        call_arg_buf.push(spread_val)
                        call_arg_top = call_arg_top + 1
                    }
                } else {
                    call_arg_buf.push(eval_expr_at(raw_args, _ai))
                    call_arg_top = call_arg_top + 1
                }
                // Propagate throw from arg expression evaluation
                if throw_flag || panic_flag {
                    // Reset buffer top to base so stale partially-pushed args
                    // do not leak into the next NK_CALL on this thread.
                    call_arg_buf = call_arg_buf.truncate(_ca_base)
                    call_arg_top = _ca_base
                    return val_void()
                }
                _ai = _ai + 1
            }
        }
        // Hand the callee its own independent args buffer (single malloc+memcpy)
        // then release the scratch region on the shared accumulator.
        let call_args = call_arg_buf.slice_fast(_ca_base, call_arg_top)
        call_arg_buf = call_arg_buf.truncate(_ca_base)
        call_arg_top = _ca_base
        let callee = node.left
        // Enum variant constructor call: Name::Variant(args...)
        //
        // 2026-05-04 (feat/import-alias-runtime-fix): EnumPath now also covers
        // `alias::fn(args)` for `import "x.hexa" as alias`. Resolution order:
        //   1. Aliased import dispatch (__use_alias_lookup_fn) — wins over
        //      the enum constructor when the prefix is a registered import
        //      alias. Routes to the bare fn registered in env_fns by the
        //      runtime loader.
        //   2. Real enum constructor — when the prefix matches a registered
        //      enum (enum_decls_has_variant). Same legacy behaviour for
        //      `Color::Red(...)` etc.
        //   3. Flatten-preprocessor fallback — when neither alias nor enum
        //      matches but the bare fn name (`callee.value`) IS registered,
        //      treat as call to that fn. This covers the `module_loader.hexa`
        //      flow where `import "x.hexa" as a` is stripped at the textual
        //      preprocess step (no runtime ImportStmt exec) and the call
        //      site `a::helper()` arrives at runtime with no alias context.
        //   4. Explicit error — emit "[hexa] symbol 'X::Y' not found (import
        //      alias may be unregistered)" instead of returning silent void.
        //      Issue 3 in the orpheus repro: previously this fell through to
        //      val_enum() and the call-site coerced the void-tagged value
        //      back through println, hiding the real bug.
        if type_of(callee) != "string" && callee.kind == "EnumPath" {
            // 1. Aliased import dispatch.
            let _alias_hit = __use_alias_lookup_fn(callee.name, callee.value)
            if _alias_hit != "" {
                return call_user_fn(_alias_hit, call_args)
            }
            // 2. Real enum constructor.
            if enum_decls_has_variant(callee.name, callee.value) {
                if len(call_args) == 0 {
                    return val_enum(callee.name, callee.value, "")
                }
                if len(call_args) == 1 {
                    return val_enum(callee.name, callee.value, call_args[0])
                }
                return val_enum(callee.name, callee.value, val_array(call_args))
            }
            // 3. Flatten-preprocessor fallback — bare fn with the same name
            //    as the EnumPath value is resolvable.
            let _bare_info = find_fn(callee.value)
            if _bare_info != "" {
                return call_user_fn(callee.value, call_args)
            }
            // 4. Explicit error (Issue 3). Fall through to val_enum only when
            //    the prefix MIGHT be an enum that happens to lack this variant
            //    (preserves legacy implicit-enum behaviour for genuine enums);
            //    when the prefix is unknown, emit the diagnostic + void.
            //    enum_decls is checked by name only above; if we reach here
            //    the prefix is neither a known enum nor a known alias, so the
            //    most actionable message names the alias possibility.
            println("[hexa] symbol '" + callee.name + "::" + callee.value + "' not found (import alias may be unregistered)")
            return val_void()
        }
        if type_of(callee) != "string" && callee.kind == "Ident" {
            let fname = callee.name
            // User function takes precedence over builtin (allows shadowing)
            let user_info = find_fn(fname)
            if user_info != "" { return call_user_fn(fname, call_args) }
            let br = call_builtin(fname, call_args)
            if br.tag != TAG_NOT_BUILTIN { return br }
            return call_user_fn(fname, call_args)
        }
        if type_of(callee) != "string" && (callee.kind == "Field" || callee.kind == "OptField") {
            // Optional chaining: if callee is OptField and receiver is void, short-circuit
            let is_opt_call = callee.kind == "OptField"
            // Effect call: if receiver is an Ident naming a registered effect,
            // route to eval_effect_call. effect_def_lookup returns either a
            // host array (of op names) or val_void() on miss.
            if type_of(callee.left) != "string" && callee.left.kind == "Ident" {
                let recv_name = callee.left.name
                let ops_or_void = effect_def_lookup(recv_name)
                if type_of(ops_or_void) == "array" {
                    return eval_effect_call(recv_name, callee.name, call_args)
                }
            }
            // ── Phase 8 골화: fusion chain 시도 ──
            // src/interpreter.rs:11441 try_fuse_chain 동치.
            // map/filter/fold/sum/count/any/all/find의 인접 체인을
            // single-pass 루프로 병합. 미스매치 시 fallback.
            let fuse_result = try_fuse_chain(callee.left, callee.name, node.args)
            if fuse_result.tag != TAG_NOT_FUSED { return fuse_result }

            let obj = eval_expr(callee.left)
            // Optional chaining short-circuit: obj?.method() → void when obj is void
            if is_opt_call && obj.tag == "void" { return val_void() }
            let method = callee.name
            let result = call_method(obj, method, call_args)
            // In-place mutation: if receiver is a plain Ident and method is a mutator,
            // write the new array back into the variable slot.
            if type_of(callee.left) != "string" && callee.left.kind == "Ident" {
                if obj.tag == TAG_ARRAY && result.tag == TAG_ARRAY {
                    if method == "push" || method == "pop" {
                        env_set(callee.left.name, result)
                    }
                }
            }
            return result
        }
        let callee_val = eval_expr(callee)
        if callee_val.tag == TAG_FN { return call_fn_val(callee_val, call_args) }
        return val_void()
    }

    // Optional chaining: obj?.field — return void if obj is void
    if kid == NK_OPT_FIELD {
        // ── Perf #14b: Ident fast path for optional chaining ──
        let left_oc = node.left
        let mut obj = val_void()
        if left_oc.kind == "Ident" {
            obj = env_lookup(left_oc.name)
        } else {
            obj = eval_expr(left_oc)
        }
        if obj.tag == TAG_VOID { return val_void() }
        let field = node.name
        if obj.tag == TAG_STRUCT {
            let fields = get_struct_fields(obj)
            return fields[field]
        }
        if obj.tag == TAG_MAP {
            return map_get(obj, val_str(field))
        }
        return val_void()
    }

    if kid == NK_FIELD {
        // ── Perf #14: obj.field fast path — Ident left skips eval dispatch ──
        let left_f = node.left
        let mut obj = val_void()
        if left_f.kind == "Ident" {
            obj = env_lookup(left_f.name)
        } else {
            obj = eval_expr(left_f)
        }
        let field = node.name
        // Method call is handled in eval_call
        // Field access on struct
        if obj.tag == TAG_STRUCT {
            let fields = get_struct_fields(obj)
            return fields[field]
        }
        // Map field access: m.key === m["key"]
        if obj.tag == TAG_MAP {
            return map_get(obj, val_str(field))
        }
        // T25 fix: EnumName.Variant — when left is an Ident that names a
        // registered enum and obj lookup returned void, produce enum value.
        if obj.tag == TAG_VOID && left_f.kind == "Ident" {
            if enum_decls_has_variant(left_f.name, field) {
                return val_enum(left_f.name, field, "")
            }
        }
        return val_void()
    }

    if kid == NK_IF_EXPR {
        let cond = eval_expr(node.cond)
        if is_truthy(cond) {
            return eval_block(node.then_body)
        }
        if node.else_body != "" {
            return eval_block(node.else_body)
        }
        return val_void()
    }

    // G32: if let PATTERN = EXPR { body } else { alt }
    if k == "IfLetExpr" {
        let pattern = node.left
        let scrutinee = eval_expr(node.right)
        // rt 32-E: snapshot parallel env arrays
        let saved_env_names = env_var_names
        let saved_env_vals = env_var_vals
        let saved_env_scopes = env_scopes
        env_push_scope()
        if match_pattern(pattern, scrutinee) {
            let result = eval_body(node.then_body)
            env_pop_scope()
            env_var_names = saved_env_names
            env_var_vals = saved_env_vals
            env_scopes = saved_env_scopes
            env_rebuild_cache()
            if return_flag { return return_val }
            return result
        }
        env_pop_scope()
        env_var_names = saved_env_names
        env_var_vals = saved_env_vals
        env_scopes = saved_env_scopes
        env_rebuild_cache()
        if node.else_body != "" { return eval_block(node.else_body) }
        return val_void()
    }

    if kid == NK_LAMBDA {
        // Capture current environment for closure
        // rt 32-E: captured still uses [name,value] tuples (read by
        // val_closure and call_fn_val which unpack with snap[0]/snap[1]).
        let mut captured = []
        let mut ci = 0
        while ci < len(env_var_names) {
            captured.push([env_var_names[ci], env_var_vals[ci]])
            ci = ci + 1
        }
        return val_closure("__lambda__", node.params, node.left, captured)
    }

    if kid == NK_MAP_LIT {
        let mut keys = []
        let mut values = []
        let entries = node.items
        let mut mi = 0
        while mi < len(entries) {
            let entry = entries[mi]
            keys.push(eval_expr(entry.left))
            values.push(eval_expr(entry.right))
            mi = mi + 1
        }
        return val_map(keys, values)
    }

    // Slice: arr[1:3], arr[:3], arr[2:], str[1:3]
    if k == "Slice" {
        let obj = eval_expr(node.left)
        let mut s = 0
        let mut e = 0
        if obj.tag == TAG_ARRAY {
            let items = get_array(obj)
            e = len(items)
            if node.right != "" { s = eval_expr(node.right).int_val }
            if node.cond != "" { e = eval_expr(node.cond).int_val }
            if s < 0 { s = 0 }
            if e > len(items) { e = len(items) }
            let mut result = []
            let mut si = s
            while si < e { result.push(items[si]); si = si + 1 }
            return val_array(result)
        }
        if obj.tag == TAG_STR {
            e = len(obj.str_val)
            if node.right != "" { s = eval_expr(node.right).int_val }
            if node.cond != "" { e = eval_expr(node.cond).int_val }
            return val_str(obj.str_val.substring(s, e))
        }
        return val_void()
    }

    if kid == NK_RANGE {
        let start = eval_expr(node.left)
        let end_val = eval_expr(node.right)
        // G21: step range — use cond field for step value
        let mut step = 1
        if node.cond != "" { step = eval_expr(node.cond).int_val }
        if step <= 0 { step = 1 }
        let mut items = []
        let mut ri = start.int_val
        if node.value == "inclusive" {
            while ri <= end_val.int_val {
                items.push(val_int(ri))
                ri = ri + step
            }
        } else {
            while ri < end_val.int_val {
                items.push(val_int(ri))
                ri = ri + step
            }
        }
        return val_array(items)
    }

    if kid == NK_ASSIGN {
        let val = eval_expr(node.right)
        if node.left.kind == "Ident" {
            env_set(node.left.name, val)
        }
        if node.left.kind == "Index" {
            let arr = eval_expr(node.left.left)
            let idx = eval_expr(node.left.right)
            if arr.tag == TAG_ARRAY {
                // ω-interp-4 (2026-04-26): O(1) inplace fast path. Drops the
                // redundant `array_store[arr.int_val] = items` write-back
                // (items pointer didn't move; host hexa_array_set already
                // mutated the buffer in place) and skips fn-arena heapify via
                // @no_arena on the helper. ~1.9× speedup on indexed-write
                // hot loops (vocal_hexa class). See array_set_inplace_idx.
                // 2026-04-17: guard — idx.int_val on non-INT Val reads
                // stale/garbage from the int_val slot (pointer-as-index).
                let safe_idx = if idx.tag == TAG_INT { idx.int_val } else { to_int(idx) }
                array_set_inplace_idx(arr, safe_idx, val)
            }
            // Fix 2026-04-14 — map IndexAssign 누락 버그 (dispatch map["new_key"] = v no-op)
            // NEXUS-6 DISC-P1-1 NDJSON parser blocker. map_set 으로 새 payload 만든 뒤
            // map_store 의 해당 slot 을 덮어써서 기존 변수 바인딩이 바뀐 맵을 보도록 한다.
            if arr.tag == TAG_MAP {
                let new_map = map_set(arr, idx, val)
                map_store[arr.int_val] = map_store[new_map.int_val]
            }
        }
        // Perf #11: struct field assignment — obj.field = val
        // Uses COW: if the struct is shared, copy before mutating.
        if node.left.kind == "Field" {
            let obj = eval_expr(node.left.left)
            if obj.tag == TAG_STRUCT {
                let field_name = node.left.name
                let updated = set_struct_field(obj, field_name, val)
                // Write back to the variable if the receiver is an Ident
                if type_of(node.left.left) != "string" && node.left.left.kind == "Ident" {
                    env_set(node.left.left.name, updated)
                }
            }
        }
        return val
    }

    if kid == NK_TUPLE_LIT {
        let mut items = []
        for item in node.items {
            items.push(eval_expr(item))
        }
        return val_array(items)
    }

    // ── StructInit: Name { field: val, ... } ────────────────
    if kid == NK_STRUCT_INIT {
        let sname = node.name
        let field_inits = node.fields
        let mut field_map = #{}
        let mut si = 0
        while si < len(field_inits) {
            let fi = field_inits[si]
            let fname = fi.name
            let mut fval = eval_expr(fi.left)
            // ROI #154 interpreter alias fix: shallow-clone TAG_ARRAY field
            // values at struct construction so two struct instances built
            // from the same source array (or the same variable `xs`) each
            // own a private array_store slot. Without this, a subsequent
            // `.push` on one instance's .items field sees refcount==1 (slot
            // appears sole-owner) and mutates the shared buffer in place,
            // leaking into sibling structs and the original source.
            // Native path mirror: self/runtime.c hexa_struct_pack_map +
            // hexa_array_shallow_clone (ROI #148 commit ef98e4ec).
            if type_of(fval) != "string" {
                if fval.tag == TAG_ARRAY {
                    let src_items = get_array(fval)
                    let mut clone_items = []
                    let mut ci = 0
                    let cn = len(src_items)
                    while ci < cn {
                        clone_items.push(src_items[ci])
                        ci = ci + 1
                    }
                    fval = val_array(clone_items)
                }
            }
            field_map[fname] = fval
            si = si + 1
        }
        return val_struct(sname, field_map)
    }

    // ── EnumPath: EnumName::Variant or EnumName::Variant(data) ──
    if kid == NK_ENUM_PATH {
        let data = node.left
        let mut data_val = ""
        if type_of(data) != "string" || data != "" {
            data_val = eval_expr(data)
        }
        return val_enum(node.name, node.value, data_val)
    }

    // ── ThrowExpr: throw as expression (returns void, sets throw_flag) ──
    if kid == NK_THROW_EXPR || kid == NK_THROW_STMT {
        let err = eval_expr(node.left)
        exec_throw(err)
        return val_void()
    }

    // ═══════════════════════════════════════════════════════
    //  Phase 10 골화 — 추가 expression kinds
    // ═══════════════════════════════════════════════════════

    // Block expression: { stmts; final_expr }
    if kid == NK_BLOCK || kid == NK_BLOCK_EXPR {
        return eval_block(node.body)
    }

    // Tuple expression: (a, b, c) — represented as array of evaluated elements
    if kid == NK_TUPLE || kid == NK_TUPLE_EXPR {
        let mut items = []
        if type_of(node.elements) == "array" {
            for e in node.elements { items.push(eval_expr(e)) }
        }
        return val_array(items)
    }

    // HandleWith: handle { body } with { eff.op(...) -> ... }
    //   Note: AST stores effect name in `name` field (not `effect`, which is a keyword)
    if kid == NK_HANDLE_WITH {
        let mut entries = []
        if type_of(node.handlers) == "array" {
            for h in node.handlers {
                let key = h.name + "." + h.op
                entries.push([key, h.params, h.body])
            }
        }
        effect_handler_push(entries)
        let result = eval_expr(node.body)
        effect_handler_pop()
        return result
    }

    // EffectCall: eff.op(args) — AST uses `name` for effect identifier
    if kid == NK_EFFECT_CALL {
        let mut eargs = []
        if type_of(node.args) == "array" {
            for a in node.args { eargs.push(eval_expr(a)) }
        }
        return eval_effect_call(node.name, node.op, eargs)
    }

    // Resume: inside an effect handler, set the resume value (parser: .left)
    // P51: bare `resume` (no expr) → resume with void when node.left == "".
    if kid == NK_RESUME || kid == NK_RESUME_EXPR {
        let mut v = val_void()
        if type_of(node.left) != "string" { v = eval_expr(node.left) }
        resume_value = v
        resume_set = true
        return val_void()
    }

    // Comptime expression: evaluate at compile time (here just eval normally).
    // T26: parser emits ComptimeExpr with `.body` as an array of stmts (block form).
    // Fallback: if body is empty, try `.left` (single-expression wrapper form).
    if kid == NK_COMPTIME || kid == NK_COMPTIME_EXPR {
        if type_of(node.body) == "array" { return eval_block(node.body) }
        return eval_expr(node.left)
    }

    // Template / string interpolation: concatenate parts
    //   parts: array of {kind: "lit", value} | {kind: "expr", expr}
    if kid == NK_TEMPLATE || kid == NK_TEMPLATE_EXPR || kid == NK_INTERP_STR {
        let mut out = ""
        if type_of(node.parts) == "array" {
            for p in node.parts {
                if type_of(p) == "string" {
                    out = out + p
                } else {
                    if p.kind == "lit" || p.kind == "StringLit" { out = out + p.value }
                    else { out = out + val_to_string(eval_expr(p.expr)) }
                }
            }
        }
        return val_str(out)
    }

    // Wildcard / ArrayPattern: only meaningful in patterns; in expr context yields void
    if kid == NK_WILDCARD || kid == NK_ARRAY_PATTERN {
        return val_void()
    }

    // Own / Move / Borrow: ownership annotations have no runtime effect
    if kid == NK_OWN || kid == NK_MOVE || kid == NK_MOVE_EXPR || kid == NK_BORROW || kid == NK_BORROW_EXPR {
        return eval_expr(node.expr)
    }

    // Await: in single-thread interpreter, await is identity (already-resolved)
    if kid == NK_AWAIT || kid == NK_AWAIT_EXPR {
        let v = eval_expr(node.expr)
        // If it's a future struct, extract value; else passthrough
        if v.tag == TAG_STRUCT && v.struct_name == "Future" {
            let fields = get_struct_fields(v)
            if type_of(fields) == "map" { return map_get(fields, val_str("value")) }
        }
        return v
    }

    // DynCast: trait object dispatch (.hexa interp doesn't track trait impls
    //   strongly; passthrough the value tagged with trait_name)
    if kid == NK_DYN_CAST || kid == NK_DYN_CAST_EXPR {
        return eval_expr(node.expr)
    }

    // MacroInvoc: macros are pre-expanded by parser; if seen here, treat
    //   as a tagged Call to a function with the same name
    if kid == NK_MACRO_INVOC || kid == NK_MACRO_INVOCATION {
        let mut margs = []
        if type_of(node.args) == "array" {
            for a in node.args { margs.push(eval_expr(a)) }
        }
        return call_user_fn(node.name, margs)
    }

    // TryCatch as expression
    if kid == NK_TRY_CATCH_EXPR || kid == NK_TRY_CATCH {
        let try_body = node.try_body
        let catch_var = node.catch_var
        let catch_body = node.catch_body
        env_push_scope()
        let result = eval_body(try_body)
        env_pop_scope()
        if throw_flag {
            let caught = throw_val
            throw_flag = false
            throw_val = val_void()
            env_push_scope()
            if type_of(catch_var) == "string" && catch_var != "" {
                env_define(catch_var, caught)
            }
            let cresult = eval_body(catch_body)
            env_pop_scope()
            return cresult
        }
        return result
    }

    // ── MatchExpr: match expr { pattern -> body, ... } ──────
    if kid == NK_MATCH_EXPR {
        let scrutinee = eval_expr(node.left)
        let arms = node.arms
        let mut mi = 0
        while mi < len(arms) {
            let arm = arms[mi]
            let pattern = arm.left
            let arm_body = arm.body
            // NOTE: `guard` is a reserved keyword (GuardStmt). Rename to
            // `_mguard` so the parser doesn't misclassify on rebuild.
            let _mguard = arm.cond
            // Save env state before each arm — explicit snapshot ensures
            // pattern bindings never leak to the parent scope, even if
            // env_push/pop_scope is defeated by nested calls.
            // rt 32-E: snapshot parallel arrays instead of tuple env_vars
            let saved_env_names = env_var_names
            let saved_env_vals = env_var_vals
            let saved_env_scopes = env_scopes
            let saved_env_cache_names = env_cache_names
            let saved_env_cache_idxs = env_cache_idxs
            let saved_env_dirty = env_scope_dirty
            env_push_scope()
            if match_pattern(pattern, scrutinee) {
                // Check guard clause if present
                let mut guard_ok = true
                if type_of(_mguard) != "string" || _mguard != "" {
                    let gv = eval_expr(_mguard)
                    guard_ok = is_truthy(gv)
                }
                if guard_ok {
                    let result = eval_body(arm_body)
                    env_pop_scope()
                    // Restore env to pre-match state — O(1) swap, no rebuild
                    env_var_names = saved_env_names
                    env_var_vals = saved_env_vals
                    env_scopes = saved_env_scopes
                    env_cache_names = saved_env_cache_names
                    env_cache_idxs = saved_env_cache_idxs
                    env_scope_dirty = saved_env_dirty
                    if return_flag {
                        return return_val
                    }
                    return result
                }
            }
            env_pop_scope()
            // Restore env to pre-match state for failed arms too — O(1)
            env_var_names = saved_env_names
            env_var_vals = saved_env_vals
            env_scopes = saved_env_scopes
            env_cache_names = saved_env_cache_names
            env_cache_idxs = saved_env_cache_idxs
            env_scope_dirty = saved_env_dirty
            mi = mi + 1
        }
        return val_void()
    }

    return val_void()
}

// ── Binary operations ────────────────────────────────────

// decreases op — structural
fn eval_binop(op, a, b) {
    // ── Numeric operator dispatch: convert op string → int once ──
    let oid = op_cached_id(op)

    // Null coalescing: a ?? b → if a is void or empty string, return b
    if oid == OP_NULL_COAL {
        if a.tag == TAG_VOID { return b }
        if a.tag == TAG_STR && a.str_val == "" { return b }
        return a
    }

    // in operator: x in arr / key in map / sub in str
    if oid == OP_IN {
        if b.tag == TAG_ARRAY {
            let items = get_array(b)
            let mut _ii = 0
            while _ii < len(items) {
                if vals_equal(a, items[_ii]) { return val_bool(true) }
                _ii = _ii + 1
            }
            return val_bool(false)
        }
        if b.tag == TAG_MAP {
            return val_bool(map_contains_key(b, a.str_val))
        }
        if b.tag == TAG_STR && a.tag == TAG_STR {
            return val_bool(b.str_val.contains(a.str_val))
        }
        return val_bool(false)
    }

    // Int fast path
    if a.tag == TAG_INT && b.tag == TAG_INT {
        let x = a.int_val
        let y = b.int_val
        if oid == OP_ADD { return val_int(x + y) }
        if oid == OP_SUB { return val_int(x - y) }
        if oid == OP_MUL { return val_int(x * y) }
        if oid == OP_DIV {
            if y == 0 { exec_throw(val_str("division by zero")); return val_void() }
            return val_int(x / y)
        }
        if oid == OP_MOD {
            if y == 0 { exec_throw(val_str("modulo by zero")); return val_void() }
            return val_int(x % y)
        }
        if oid == OP_POW { return val_int(to_int(pow(x, y))) }
        if oid == OP_EQ { return val_bool(x == y) }
        if oid == OP_NE { return val_bool(x != y) }
        if oid == OP_LT { return val_bool(x < y) }
        if oid == OP_GT { return val_bool(x > y) }
        if oid == OP_LE { return val_bool(x <= y) }
        if oid == OP_GE { return val_bool(x >= y) }
        if oid == OP_AND { return val_bool(x != 0 && y != 0) }
        if oid == OP_OR { return val_bool(x != 0 || y != 0) }
        // Bitwise operations — parser now supports `&` and `^` directly.
        // `|` still uses runtime shim due to lambda-param `|x| x+1` ambiguity.
        if oid == OP_BIT_AND {
            return val_int(x & y)
        }
        if oid == OP_BIT_OR {
            return val_int(bit_or(x, y))
        }
        if oid == OP_BIT_XOR {
            return val_int(x ^ y)
        }
        if oid == OP_SHL {
            // x << y = x * 2^y (avoiding << parser issues)
            let r = x * to_int(pow(2, y))
            return val_int(r)
        }
        if oid == OP_SHR {
            // x >> y = x / 2^y (avoiding >> parser issues)
            let r = x / to_int(pow(2, y))
            return val_int(r)
        }
    }
    // String concatenation (str + anything)
    // PERF lint is pedagogical — gated by HEXA_PERF_WARN=1 because it fires
    // on any non-trivial program (>100 concats across a whole run is a very
    // low bar: every JSON emit, every path/URL build, every log line).
    // Producing stderr spam on every invocation broke downstream stderr
    // parsers (nexus resolver, anima log ingest).
    if a.tag == TAG_STR && oid == OP_ADD {
        if env("HEXA_PERF_WARN") == "1" {
            __str_concat_count = __str_concat_count + 1
            if __str_concat_count > 100 && __str_concat_warned == 0 {
                eprintln("PERF: " + to_string(__str_concat_count) + " string concatenations detected — likely O(n^2) loop. Use parts.push() + .join() instead.")
                __str_concat_warned = 1
            }
        }
        return val_str(a.str_val + val_to_string(b))
    }
    // Char + String / Char + Char concatenation
    if a.tag == TAG_CHAR && oid == OP_ADD {
        if env("HEXA_PERF_WARN") == "1" {
            __str_concat_count = __str_concat_count + 1
            if __str_concat_count > 100 && __str_concat_warned == 0 {
                eprintln("PERF: " + to_string(__str_concat_count) + " string concatenations detected — likely O(n^2) loop. Use parts.push() + .join() instead.")
                __str_concat_warned = 1
            }
        }
        return val_str(a.str_val + val_to_string(b))
    }
    // Float arithmetic (with int-to-float coercion)
    if (a.tag == TAG_FLOAT || b.tag == TAG_FLOAT) {
        let x = to_float(a)
        let y = to_float(b)
        if oid == OP_ADD { return val_float(x + y) }
        if oid == OP_SUB { return val_float(x - y) }
        if oid == OP_MUL { return val_float(x * y) }
        if oid == OP_DIV {
            if y == 0.0 { exec_throw(val_str("division by zero")); return val_void() }
            return val_float(x / y)
        }
        if oid == OP_MOD { return val_float(x % y) }
        if oid == OP_POW { return val_float(pow(x, y)) }
        if oid == OP_EQ { return val_bool(x == y) }
        if oid == OP_NE { return val_bool(x != y) }
        if oid == OP_LT { return val_bool(x < y) }
        if oid == OP_GT { return val_bool(x > y) }
        if oid == OP_LE { return val_bool(x <= y) }
        if oid == OP_GE { return val_bool(x >= y) }
    }
    // Bool operations
    if a.tag == TAG_BOOL && b.tag == TAG_BOOL {
        if oid == OP_EQ { return val_bool(a.bool_val == b.bool_val) }
        if oid == OP_NE { return val_bool(a.bool_val != b.bool_val) }
        if oid == OP_AND { return val_bool(a.bool_val && b.bool_val) }
        if oid == OP_OR { return val_bool(a.bool_val || b.bool_val) }
        if oid == OP_BIT_XOR { return val_bool(a.bool_val != b.bool_val) }
    }
    // String comparisons
    if a.tag == TAG_STR && b.tag == TAG_STR {
        if oid == OP_EQ { return val_bool(a.str_val == b.str_val) }
        if oid == OP_NE { return val_bool(a.str_val != b.str_val) }
        // Lexicographic ordering — 이전엔 void 반환해서 AOT (runtime.c
        // hexa_cmp_lt 가 __hx_to_double 으로 강제 float 변환) 와 divergence.
        // 실은 AOT 도 string cmp 를 본격 지원 안 하지만 char-array 해 double
        // 변환되어 문자열 "abc" < "abd" 이 pos 로 이어져 true 반환.
        // interp 는 순수 hexa str 비교로 정렬 기준 일관.
        if oid == OP_LT { return val_bool(a.str_val < b.str_val) }
        if oid == OP_GT { return val_bool(a.str_val > b.str_val) }
        if oid == OP_LE { return val_bool(a.str_val <= b.str_val) }
        if oid == OP_GE { return val_bool(a.str_val >= b.str_val) }
    }
    // Char comparisons
    if a.tag == TAG_CHAR && b.tag == TAG_CHAR {
        if oid == OP_EQ { return val_bool(a.str_val == b.str_val) }
        if oid == OP_NE { return val_bool(a.str_val != b.str_val) }
        if oid == OP_LT { return val_bool(a.str_val < b.str_val) }
        if oid == OP_GT { return val_bool(a.str_val > b.str_val) }
        if oid == OP_LE { return val_bool(a.str_val <= b.str_val) }
        if oid == OP_GE { return val_bool(a.str_val >= b.str_val) }
    }
    // Array concatenation (ported from src/interpreter.rs)
    if a.tag == TAG_ARRAY && b.tag == TAG_ARRAY && oid == OP_ADD {
        let a_items = get_array(a)
        let b_items = get_array(b)
        let mut result = []
        for item in a_items { result.push(item) }
        for item in b_items { result.push(item) }
        return val_array(result)
    }
    // Array repetition: [1,2] * 3 => [1,2,1,2,1,2]
    if a.tag == TAG_ARRAY && b.tag == TAG_INT && oid == OP_MUL {
        let items = get_array(a)
        let n = b.int_val
        let mut result = []
        let mut ri = 0
        while ri < n {
            for item in items { result.push(item) }
            ri = ri + 1
        }
        return val_array(result)
    }
    // Array equality
    if a.tag == TAG_ARRAY && b.tag == TAG_ARRAY {
        if oid == OP_EQ {
            let a_items = get_array(a)
            let b_items = get_array(b)
            if len(a_items) != len(b_items) { return val_bool(false) }
            let mut ei = 0
            while ei < len(a_items) {
                if !vals_equal(a_items[ei], b_items[ei]) { return val_bool(false) }
                ei = ei + 1
            }
            return val_bool(true)
        }
        if oid == OP_NE {
            let eq = eval_binop("==", a, b)
            return val_bool(!eq.bool_val)
        }
    }
    // 'in' operator: a in b — membership test
    if op == "in" {
        if b.tag == "array" {
            let items = get_array(b)
            let mut ii = 0
            while ii < len(items) {
                if vals_equal(a, items[ii]) { return val_bool(true) }
                ii = ii + 1
            }
            return val_bool(false)
        }
        if b.tag == "map" {
            return val_bool(map_contains_key(b, a))
        }
        if b.tag == "str" {
            if a.tag == "str" { return val_bool(b.str_val.contains(a.str_val)) }
            if a.tag == "char" { return val_bool(b.str_val.contains(a.str_val)) }
            return val_bool(false)
        }
        return val_bool(false)
    }
    // Map ref-equality — 같은 map_store slot 가리키면 equal. value eq 은
    // struct/closure 처럼 deep compare 가 필요하지만 일단 self-compare
    // (`m == m`) 정도만 맞춰서 AOT hexa_eq TAG_MAP branch 와 동형성 유지.
    if a.tag == TAG_MAP && b.tag == TAG_MAP {
        if oid == OP_EQ { return val_bool(a.int_val == b.int_val) }
        if oid == OP_NE { return val_bool(a.int_val != b.int_val) }
    }
    // Cross-type Eq/Ne: different value types are never equal
    if oid == OP_EQ { return val_bool(false) }
    if oid == OP_NE { return val_bool(true) }
    return val_void()
}

// ── Value equality (for pattern matching) ───────────────

fn vals_equal(a, b) {
    if a.tag != b.tag { return false }
    if a.tag == TAG_INT { return a.int_val == b.int_val }
    if a.tag == TAG_FLOAT { return a.float_val == b.float_val }
    if a.tag == TAG_BOOL { return a.bool_val == b.bool_val }
    if a.tag == TAG_STR { return a.str_val == b.str_val }
    if a.tag == TAG_ENUM { return a.struct_name == b.struct_name && a.int_val == b.int_val }
    if a.tag == TAG_VOID { return true }
    return false
}

// ── Pattern matching ────────────────────────────────────
// T1 Phase B: match_pattern — inline stub (was in runtime_core.hexa)
fn match_pattern(pattern, scrutinee) {
    // pattern 은 AST 노드 (kind/value 필드), scrutinee 는 이미 평가된 Val.
    // 이전 구현은 pattern.tag 를 Val.tag (int) 와 비교했는데 pattern 은 AST 라
    // tag 필드 자체가 없음 — 모든 specific branch 실패 → wildcard return true
    // 로 떨어져서 first arm 이 항상 match (실제 match=2 가 "one" 반환하던 버그).
    // 수정: pattern 을 eval_expr 로 Val 변환 후 tag 기반 비교. wildcard `_`
    // 와 binding 은 Ident kind 로 식별.
    if pattern.kind == "Ident" {
        // `_` 은 wildcard, 그 외 Ident 는 binding (여기선 단순히 match 만 판정)
        return true
    }
    // Enum variant: `Color::Red` 패턴과 scrutinee 둘 다 TAG_ENUM 이면
    // struct_name (full "Enum::Variant") 비교. 이전엔 eval_expr 후 tag
    // 분기에 TAG_ENUM 이 없어 항상 false 반환 → match 가 void 로 나옴.
    if pattern.kind == "EnumPath" && scrutinee.tag == TAG_ENUM {
        let full = pattern.name + "::" + pattern.value
        return scrutinee.struct_name == full
    }
    let pv = eval_expr(pattern)
    if pv.tag == TAG_INT && scrutinee.tag == TAG_INT { return pv.int_val == scrutinee.int_val }
    if pv.tag == TAG_FLOAT && scrutinee.tag == TAG_FLOAT { return pv.float_val == scrutinee.float_val }
    if pv.tag == TAG_STR && scrutinee.tag == TAG_STR { return pv.str_val == scrutinee.str_val }
    if pv.tag == TAG_BOOL && scrutinee.tag == TAG_BOOL { return pv.bool_val == scrutinee.bool_val }
    if pv.tag == TAG_ENUM && scrutinee.tag == TAG_ENUM { return pv.struct_name == scrutinee.struct_name }
    if pv.tag == TAG_VOID { return scrutinee.tag == TAG_VOID }
    return false
}

// Stubs for proof/fuse features (not yet implemented in self-host)
fn execute_proof_block_stmt(ps) { return val_void() }
fn try_fuse_chain(obj, method, args) { return Val { tag: TAG_NOT_FUSED, int_val: 0, float_val: 0.0, bool_val: false, str_val: __E, char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E } }
fn format_stack_trace() { return "" }

// ── Error handling helpers ────────────────────────────────

fn exec_throw(err) {
    // rt#36-E T-try-mvp: raw-value passthrough for throw/catch, matching
    // the VM (self/bc_vm.hexa OP_THROW). Previously we wrapped a thrown
    // string inside a `{message, trace}` map and added `trace` to map
    // values, so `catch e { print(e) }` surfaced a synthesized object
    // instead of the original thrown value. Stack trace info remains
    // available as a side-channel via the `stack_trace()` builtin.
    throw_val = err
    throw_flag = true
}

fn exec_try_catch(try_body, catch_var, catch_body) {
    // Save throw state
    let saved_throw = throw_flag
    throw_flag = false

    // Execute try body
    env_push_scope()
    let mut ti = 0
    while ti < len(try_body) {
        if return_flag || throw_flag || panic_flag { ti = len(try_body) } else {
            exec_stmt_at(try_body, ti)
            ti = ti + 1
        }
    }
    env_pop_scope()

    // Panic is not catchable — propagate immediately.
    if panic_flag { return val_void() }

    if throw_flag {
        // Error was thrown — execute catch body
        let err = throw_val
        throw_flag = false
        throw_val = val_void()
        env_push_scope()
        env_define(catch_var, err)
        let mut ci = 0
        while ci < len(catch_body) {
            if return_flag || throw_flag || panic_flag { ci = len(catch_body) } else {
                exec_stmt_at(catch_body, ci)
                ci = ci + 1
            }
        }
        env_pop_scope()
    } else {
        throw_flag = saved_throw
    }
    return val_void()
}

// ── Core: exec_stmt ──────────────────────────────────────

// rt 32-H audit (2026-04-13): the prior `fn exec_stmt(node) { let _tmp = [node]
// return exec_stmt_at(_tmp, 0) }` wrapper had the exact 1-element [node] shape
// that RT 32-E killed in eval_expr. Audit shows it had ZERO callsites in
// hexa_full.hexa — every statement dispatch goes through exec_stmt_at directly
// at the eval_body / try / catch / loop sites (lines 7123,7142,7484,7519,7562,
// 7601,7940,8183,8186,13912,14846,14959). Removing the dead wrapper as
// cleanup; perf impact is nil because it never ran in any benchmark.

// decreases stmts — structural
fn exec_stmt_at(stmts, idx) {
    let node = stmts[idx]
    // Defensive: parser may emit Str("") or non-struct stub on syntax error
    if type_of(node) == "string" { return val_void() }
    if type_of(node) != "struct" && type_of(node) != "map" { return val_void() }
    let k = node.kind
    if type_of(k) != "string" { return val_void() }

    if k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" || k == "StaticStmt" {
        let val = val_void()
        let init = node.left
        if type_of(init) != "string" || init != "" {
            val = eval_expr(init)
        }
        // T39: mutable bindings must own a private Val — val_int/val_float/val_bool
        // return cached singletons whose HexaValStruct is shared by pointer.
        // Without val_copy, env_define stores the singleton pointer and any later
        // hexa_map_set (routed to hexa_valstruct_set_by_key) corrupts the cache,
        // causing `let mut x = 0` to inherit the previous binding's type/value.
        if k == "LetMutStmt" {
            val = val_copy(val)
        }
        env_define(node.name, val)
        return val_void()
    }

    // G9: array destructuring — let [a, b, ...rest] = expr
    if k == "DestructLetStmt" {
        let rhs = eval_expr(node.left)
        let patterns = node.params
        if rhs.tag == "array" {
            let arr_items = get_array(rhs)
            let arr_len = len(arr_items)
            let pat_len = len(patterns)
            // Bind each positional pattern
            let mut pi = 0
            while pi < pat_len {
                if pi < arr_len {
                    env_define(patterns[pi], arr_items[pi])
                } else {
                    env_define(patterns[pi], val_void())
                }
                pi = pi + 1
            }
            // Bind ...rest if present (rest_name stored in node.name)
            let rest_name = node.name
            if rest_name != "" {
                let mut rest_items = []
                let mut ri = pat_len
                while ri < arr_len {
                    rest_items.push(arr_items[ri])
                    ri = ri + 1
                }
                env_define(rest_name, val_array(rest_items))
            }
        } else {
            // RHS is not an array — bind first pattern to value, rest to void
            let pat_len = len(patterns)
            if pat_len > 0 {
                env_define(patterns[0], rhs)
                let mut pi = 1
                while pi < pat_len {
                    env_define(patterns[pi], val_void())
                    pi = pi + 1
                }
            }
            let rest_name = node.name
            if rest_name != "" {
                env_define(rest_name, val_array([]))
            }
        }
        return val_void()
    }

    // G9: map/struct destructuring — let {x, y} = expr
    if k == "MapDestructLetStmt" {
        let rhs = eval_expr(node.left)
        let patterns = node.params
        let mut pi = 0
        while pi < len(patterns) {
            let key_name = patterns[pi]
            if rhs.tag == "map" {
                let v = map_get(rhs, val_str(key_name))
                env_define(key_name, v)
            } else if rhs.tag == "struct" {
                let fields = get_struct_fields(rhs)
                env_define(key_name, fields[key_name])
            } else {
                env_define(key_name, val_void())
            }
            pi = pi + 1
        }
        return val_void()
    }

    if k == "AssignStmt" {
        let val = eval_expr(node.right)
        if node.left.kind == "Ident" {
            env_set(node.left.name, val)
        }
        // rt#36-d trivial fix (2026-04-15): port Index LHS from NK_ASSIGN
        // expression-path so statement-level `arr[i] = v` / `m[k] = v`
        // actually mutates. Previously the statement-path silently dropped
        // Index LHS → mut_mvp.hexa diverged from VM.
        if node.left.kind == "Index" {
            let arr = eval_expr(node.left.left)
            let idx = eval_expr(node.left.right)
            let _si2 = if idx.tag == TAG_INT { idx.int_val } else { to_int(idx) }
            if arr.tag == TAG_ARRAY {
                // ω-interp-4 (2026-04-26): see NK_ASSIGN block above for fast
                // path rationale (drops redundant array_store write-back +
                // skips fn-arena heapify).
                array_set_inplace_idx(arr, _si2, val)
            }
            if arr.tag == TAG_MAP {
                let new_map = map_set(arr, idx, val)
                map_store[arr.int_val] = map_store[new_map.int_val]
            }
        }
        // Perf #11: struct field assignment in AssignStmt
        if node.left.kind == "Field" {
            let obj = eval_expr(node.left.left)
            if obj.tag == TAG_STRUCT {
                let field_name = node.left.name
                let updated = set_struct_field(obj, field_name, val)
                if type_of(node.left.left) != "string" && node.left.left.kind == "Ident" {
                    env_set(node.left.left.name, updated)
                }
            }
        }
        return val_void()
    }

    if k == "ExprStmt" {
        let expr = node.left
        if type_of(expr) == "string" { return val_void() }
        return eval_expr(expr)
    }

    if k == "ReturnStmt" {
        if node.left != "" {
            return_val = eval_expr(node.left)
        } else {
            return_val = val_void()
        }
        return_flag = true
        return val_void()
    }

    // Sprint C: yield <expr> — append to current gen_buffer and mark
    // this call frame as a generator. Does not set return_flag, so
    // execution continues and further yields may append more values.
    if k == "YieldStmt" {
        let yv = val_void()
        if node.left != "" {
            yv = eval_expr(node.left)
        }
        gen_buffer.push(yv)
        gen_active = true
        return val_void()
    }

    if k == "FnDecl" || k == "AsyncFnDecl" {
        env_fns.push([node.name, node.params, node.body])
        fn_cache_add(node.name, len(env_fns) - 1)
        let fn_val = val_fn(node.name, node.params, node.body)
        env_define(node.name, fn_val)
        // Store @attrs for runtime interception (@memo/@memoize/@cache)
        if node.value != "" {
            fn_attrs_set(node.name, node.value)
        }
        return val_void()
    }

    if k == "ExternFnDecl" {
        // Register extern function declaration.
        // node.value = @symbol("c_name") alias (empty → use node.name)
        // node.op    = @link("lib") library name (empty → default)
        let c_symbol = node.value
        if c_symbol == "" {
            c_symbol = node.name
        }
        let ret = node.ret_type
        let link = node.op
        extern_fns.push([node.name, c_symbol, ret, link])
        // ROI-5: insert into 64-bucket hash cache for O(1) avg lookup
        extern_fn_cache_add(node.name, len(extern_fns) - 1)
        // Register as a builtin-style binding so calls route to FFI
        let builtin_name = "__extern_" + node.name
        env_define(node.name, val_str(builtin_name))
        return val_void()
    }

    if k == "IfStmt" {
        let cond = eval_expr(node.cond)
        if is_truthy(cond) {
            env_push_scope()
            eval_body(node.then_body)
            env_pop_scope()
        } else if node.else_body != "" {
            env_push_scope()
            eval_body(node.else_body)
            env_pop_scope()
        }
        return val_void()
    }

    if k == "CompoundAssign" {
        let lv = eval_expr(node.left)
        let rv = eval_expr(node.right)
        let result = eval_binop(node.op, lv, rv)
        if node.left.kind == "Ident" {
            env_set(node.left.name, result)
        }
        if node.left.kind == "Index" {
            let arr = eval_expr(node.left.left)
            let idx = eval_expr(node.left.right)
            let _si3 = if idx.tag == TAG_INT { idx.int_val } else { to_int(idx) }
            if arr.tag == "array" || arr.tag == TAG_ARRAY {
                // ω-interp-4 (2026-04-26): see NK_ASSIGN block above for fast
                // path rationale (drops redundant array_store write-back +
                // skips fn-arena heapify).
                array_set_inplace_idx(arr, _si3, result)
            }
            if arr.tag == "map" {
                let new_map = map_set(arr, idx, result)
                map_store[arr.int_val] = map_store[new_map.int_val]
            }
        }
        // Perf #11: struct field compound assignment — obj.field += val
        if node.left.kind == "Field" {
            let obj = eval_expr(node.left.left)
            if obj.tag == TAG_STRUCT {
                let field_name = node.left.name
                let updated = set_struct_field(obj, field_name, result)
                if type_of(node.left.left) != "string" && node.left.left.kind == "Ident" {
                    env_set(node.left.left.name, updated)
                }
            }
        }
        return val_void()
    }

    if k == "LogicalAssign" {
        if node.left.kind == "Ident" {
            let current = env_lookup(node.left.name)
            if node.op == "??=" {
                // Null-coalescing assignment: assign only if current is void or empty string.
                // Prior code compared `.tag == "str"` / `"void"` — but tag is an int
                // (TAG_STR=3, TAG_VOID=8). Comparison was always false → assignment
                // never fired. Matches AOT hexa_null_coal (runtime.c:648).
                if current.tag == TAG_VOID || (current.tag == TAG_STR && current.str_val == "") {
                    env_set(node.left.name, eval_expr(node.right))
                }
            } else if node.op == "||=" {
                // Logical OR assignment: assign if current is falsy
                if !is_truthy(current) {
                    env_set(node.left.name, eval_expr(node.right))
                }
            } else if node.op == "&&=" {
                // Logical AND assignment: assign if current is truthy
                if is_truthy(current) {
                    env_set(node.left.name, eval_expr(node.right))
                }
            }
        }
        return val_void()
    }

    if k == "BreakStmt" {
        break_flag = true
        break_label = node.name
        return val_void()
    }

    if k == "ContinueStmt" {
        continue_flag = true
        continue_label = node.name
        return val_void()
    }

    if k == "DeferStmt" {
        defer_stack.push(node.body)
        return val_void()
    }

    if k == "StructDecl" || k == "EnumDecl" || k == "TraitDecl" {
        // Type declarations — store for later use
        // T25 fix: register enum variants so `EnumName.Variant` produces a value
        if k == "EnumDecl" {
            let vs = node.variants
            if type_of(vs) == "array" {
                let mut vnames = []
                let mut vi = 0
                while vi < len(vs) {
                    let v = vs[vi]
                    if type_of(v) == "struct" || type_of(v) == "map" {
                        vnames.push(v.name)
                    }
                    vi = vi + 1
                }
                enum_decls_register(node.name, vnames)
            }
        }
        return val_void()
    }

    if k == "ImplBlock" {
        // Store impl block methods for struct method dispatch
        let target = node.target
        let methods = node.methods
        let is_idx = len(impl_store)
        impl_store.push([target, methods])
        // ROI-17: populate impl_cache for O(1) method dispatch
        let mut mi = 0
        while mi < len(methods) {
            let m = methods[mi]
            impl_cache_add(target, m.name, is_idx, mi)
            // Also register methods as functions with mangled names: Type__method
            let mangled = target + "__" + m.name
            env_fns.push([mangled, m.params, m.body])
            fn_cache_add(mangled, len(env_fns) - 1)
            mi = mi + 1
        }
        return val_void()
    }

    if k == "ThrowStmt" {
        let err = eval_expr(node.left)
        exec_throw(err)
        return val_void()
    }

    if k == "PanicStmt" {
        let msg_val = eval_expr(node.left)
        if msg_val.tag == TAG_STR {
            panic_msg = msg_val.str_val
        } else {
            panic_msg = val_to_string(msg_val)
        }
        panic_flag = true
        // Also set throw_flag so existing propagation checks in while/for/if
        // blocks (which test throw_flag) abort immediately. The flag is never
        // cleared by try/catch/recover because panic_flag remains set and
        // those arms only reset throw_flag while panic_flag stays true, which
        // our propagation checks also watch.
        throw_flag = true
        return val_void()
    }

    if k == "TryCatch" {
        return exec_try_catch(node.left, node.name, node.right)
    }

    if k == "RecoverStmt" {
        let body = node.left
        let catch_var = node.name

        // Save throw state
        let saved_throw = throw_flag
        throw_flag = false

        // Execute body
        env_push_scope()
        let mut result = val_void()
        let mut ri = 0
        while ri < len(body) {
            if return_flag || throw_flag || panic_flag { ri = len(body) } else {
                result = exec_stmt_at(body, ri)
                ri = ri + 1
            }
        }
        env_pop_scope()

        // Panic is not recoverable — propagate to program exit.
        if panic_flag { return val_void() }

        if throw_flag {
            // Throw occurred — recover from it
            let err = throw_val
            throw_flag = false
            throw_val = val_void()
            if catch_var != "_" {
                // Bind the error to the variable in the calling scope
                env_define(catch_var, err)
            }
            return val_void()
        } else {
            throw_flag = saved_throw
        }
        return result
    }

    if k == "WhileStmt" {
        let loop_label = node.value
        // @partial — body break/return/throw governs termination
        while !return_flag && !break_flag && !throw_flag {
            _fuel_charge()
            if throw_flag { return val_void() }
            let cond = eval_expr(node.cond)
            if !is_truthy(cond) { return val_void() }
            env_push_scope()
            continue_flag = false
            let mut _wi = 0
            while _wi < len(node.body) {
                if return_flag || break_flag || continue_flag || throw_flag { _wi = len(node.body) } else {
                    exec_stmt_at(node.body, _wi)
                    _wi = _wi + 1
                }
            }
            env_pop_scope()
            if continue_flag {
                if continue_label == "" || continue_label == loop_label { continue_flag = false; continue_label = "" }
            }
        }
        if break_flag {
            if break_label == "" || break_label == loop_label { break_flag = false; break_label = "" }
        }
        return val_void()
    }

    if k == "ForStmt" || k == "ForElseStmt" {
        let loop_label = node.value
        let iter_val = eval_expr(node.iter_expr)
        // Uniform iteration: array → elements, map → keys (Python-style).
        // Converted to a simple list so the loop body stays identical.
        let mut items = []
        if iter_val.tag == TAG_ARRAY {
            items = get_array(iter_val)
        } else if iter_val.tag == TAG_MAP {
            items = get_map_keys(iter_val)
        }
        if k == "ForElseStmt" && len(items) == 0 {
            if node.else_body != "" {
                env_push_scope()
                eval_body(node.else_body)
                env_pop_scope()
            }
            return val_void()
        }
        // ROI-35: scope hoist — push/pop once, rebind with env_set per iteration
        let _fi2_len = len(items)
        if _fi2_len > 0 {
            env_push_scope()
            env_define(node.name, items[0])
            continue_flag = false
            let mut _fbi = 0
            while _fbi < len(node.body) {
                if return_flag || break_flag || continue_flag || throw_flag { _fbi = len(node.body) } else {
                    exec_stmt_at(node.body, _fbi)
                    _fbi = _fbi + 1
                }
            }
            if continue_flag {
                if continue_label == "" || continue_label == loop_label { continue_flag = false; continue_label = "" }
            }
            let mut _fi2 = 1
            while _fi2 < _fi2_len {
                if return_flag || break_flag || throw_flag { _fi2 = _fi2_len } else {
                    continue_flag = false
                    env_set(node.name, items[_fi2])
                    let mut _fbi2 = 0
                    while _fbi2 < len(node.body) {
                        if return_flag || break_flag || continue_flag || throw_flag { _fbi2 = len(node.body) } else {
                            exec_stmt_at(node.body, _fbi2)
                            _fbi2 = _fbi2 + 1
                        }
                    }
                    if continue_flag {
                        if continue_label == "" || continue_label == loop_label { continue_flag = false; continue_label = "" }
                    }
                    _fi2 = _fi2 + 1
                }
            }
            env_pop_scope()
        }
        if break_flag {
            if break_label == "" || break_label == loop_label { break_flag = false; break_label = "" }
        }
        return val_void()
    }

    if k == "LoopStmt" {
        let loop_label = node.value
        // @partial — termination delegated to user code via break/return/throw
        while !return_flag && !break_flag && !throw_flag {
            _fuel_charge()
            if throw_flag { return val_void() }
            env_push_scope()
            eval_body(node.body)
            env_pop_scope()
        }
        if break_flag {
            if break_label == "" || break_label == loop_label { break_flag = false; break_label = "" }
        }
        return val_void()
    }

    if k == "DoWhileStmt" {
        let loop_label = node.value
        let mut do_continue = true
        // @partial — body break/return/throw governs termination
        while do_continue && !return_flag && !break_flag && !throw_flag {
            env_push_scope()
            continue_flag = false
            let mut _dwi = 0
            while _dwi < len(node.body) {
                if return_flag || break_flag || continue_flag || throw_flag { _dwi = len(node.body) } else {
                    exec_stmt_at(node.body, _dwi)
                    _dwi = _dwi + 1
                }
            }
            env_pop_scope()
            if continue_flag {
                if continue_label == "" || continue_label == loop_label { continue_flag = false; continue_label = "" }
            }
            if !return_flag && !break_flag && !throw_flag {
                let cond = eval_expr(node.cond)
                if !is_truthy(cond) { do_continue = false }
            }
        }
        if break_flag {
            if break_label == "" || break_label == loop_label { break_flag = false; break_label = "" }
        }
        return val_void()
    }

    // ═══════════════════════════════════════════════════════
    //  Phase 10 골화 — 추가 statement kinds (.rs 대응)
    // ═══════════════════════════════════════════════════════

    // Stmt::Mod — module declaration: just exec body in current scope
    if k == "Mod" || k == "ModStmt" {
        let body = node.body
        if type_of(body) == "array" { eval_body(body) }
        return val_void()
    }

    // Stmt::Use / ImportStmt — module path import.
    //
    // 2026-04-20 fix (shared/state/voice_routes_loader_stall_20260420.json):
    //   Previously `return val_void()` with no side effect → imported fns
    //   never landed in env_fns → "Runtime error: undefined function: X"
    //   for every call site in downstream projects (anima voice_routes /
    //   hire_routes E2E blocked dest1_alm P1). The CLI preprocessor
    //   (self/main.hexa cmd_run → self/module_loader.hexa) already inlines
    //   `use "path"` directives for the normal flow, but direct interp
    //   invocations + `use a::b::c` Rust-style paths fell through the
    //   preprocessor's textual replace() patterns and hit this no-op.
    //
    // Fix: resolve path, parse target module, register its top-level fns
    // into env_fns + run its top-level body for global-let initialisation.
    // Dedup via __use_loaded_paths so re-entry and circular imports are safe.
    // Silent on unresolvable paths (matches legacy no-op — caller's own
    // "undefined function" error surfaces downstream if the load failed).
    if k == "Use" || k == "UseStmt" || k == "ImportStmt" {
        let _use_path = __use_extract_path(node)
        if _use_path == "" { return val_void() }
        let _resolved = __use_resolve_module_path(_use_path)
        if _resolved == "" { return val_void() }
        // 2026-05-04 (feat/import-alias-runtime-fix): forward optional `as
        // <alias>` qualifier (parser stores alias in node.value for both
        // ImportStmt and the string-form UseStmt). Empty alias = no-op
        // (legacy behaviour: bare-name dispatch only).
        let _alias_q = node.value
        if type_of(_alias_q) != "string" { _alias_q = "" }
        __use_load_module_from_path_with_alias(_resolved, _alias_q)
        return val_void()
    }

    // Stmt::InvariantDecl — T3 declarative @invariant DSL block.
    // Runtime no-op — checked separately by self/invariant_check.hexa
    // (`hexa check <file>`). 본 인터프리터 경로는 interp 실행만 담당.
    if k == "InvariantDecl" {
        return val_void()
    }

    // Stmt::Assert — runtime assertion (parser uses .left)
    if k == "AssertStmt" || k == "Assert" {
        let cond = eval_expr(node.left)
        if !is_truthy(cond) {
            throw_flag = true
            throw_val = val_str("assertion failed")
        }
        return val_void()
    }
    // Stmt::Invariant — proof block invariant marker (treat like assertion at runtime)
    if k == "Invariant" {
        let cond = eval_expr(node.left)
        if !is_truthy(cond) {
            throw_flag = true
            throw_val = val_str("invariant violated")
        }
        return val_void()
    }

    // Stmt::Resume — inside effect handler, capture value and halt body
    // P51: bare `resume` (no expr) resumes with void — node.left == "".
    if k == "Resume" {
        let mut v = val_void()
        if type_of(node.left) != "string" { v = eval_expr(node.left) }
        resume_value = v
        resume_set = true
        return_flag = true  // halt handler body
        return_val = v
        return val_void()
    }

    // Stmt::ContractAssert — @contract requires/ensures runtime check
    // node.op = "requires" | "ensures"
    // node.name = function name
    // node.value = clause source text (e.g. "requires: x > 0")
    // node.left = condition expression AST
    // For ensures: __contract_result is already bound in scope by
    //   the LetDecl injected before this node.  Bind "result" alias
    //   so the ensures expression can reference it.
    if k == "ContractAssert" {
        let clause_type = node.op
        if clause_type == "ensures" {
            // Bind "result" to __contract_result so ensures expr can use it
            let cr = env_lookup("__contract_result")
            env_define("result", cr)
        }
        let cond = eval_expr(node.left)
        if !is_truthy(cond) {
            throw_flag = true
            let fn_name = node.name
            let clause_text = node.value
            throw_val = val_str("ContractViolation: " + fn_name + " — " + clause_text)
        }
        return val_void()
    }

    // Stmt::EffectDecl — register an effect with its operations
    //   parser stores op list in `items`, each EffectOp has .name
    if k == "EffectDecl" {
        let effect_name = node.name
        let mut op_names = []
        if type_of(node.items) == "array" {
            for op in node.items { op_names.push(op.name) }
        }
        effect_def_add(effect_name, op_names)
        return val_void()
    }

    // Stmt::TypeAlias / Stmt::DeriveDecl — declarative, no runtime effect
    if k == "TypeAlias" || k == "TypeAliasStmt" || k == "DeriveDecl" || k == "DeriveStmt" {
        return val_void()
    }

    // Stmt::AtomicLet — let with Atomic wrapper
    if k == "AtomicLet" {
        let val = eval_expr(node.left)
        let atom = val_atomic(val)
        env_define(node.name, atom)
        return val_void()
    }

    // Stmt::Spawn — fire-and-forget block (single-threaded eval: just run inline)
    if k == "Spawn" || k == "SpawnNamed" || k == "SpawnStmt" {
        let body = node.body
        if type_of(body) == "array" { eval_body(body) }
        return val_void()
    }

    // Stmt::Scope — scoped block
    if k == "Scope" || k == "ScopeStmt" {
        let body = node.body
        if type_of(body) == "array" { eval_block(body) }
        return val_void()
    }

    // Stmt::DropStmt — explicit destructor call (interpreter no-op)
    if k == "DropStmt" || k == "Drop" {
        return val_void()
    }

    // Stmt::ProofBlock / Theorem — formal proof statements
    if k == "ProofBlock" || k == "Theorem" {
        let stmts = node.proof_stmts
        if type_of(stmts) == "array" {
            for ps in stmts {
                let r = execute_proof_block_stmt(ps)
                // Result format: ["proved" | "refuted" | "skipped" | ...]
                if type_of(r) == "array" && len(r) >= 1 && r[0] == "refuted" {
                    throw_flag = true
                    throw_val = val_str("proof refuted: " + r[1])
                    return val_void()
                }
            }
        }
        return val_void()
    }

    // Stmt::Intent / Stmt::Verify / Stmt::ConsciousnessBlock / Stmt::EvolveFn
    // — declarative consciousness/AI markers, no runtime effect in self-host
    if k == "Intent" || k == "IntentStmt" || k == "Verify" || k == "VerifyStmt" {
        return val_void()
    }
    if k == "ConsciousnessBlock" || k == "EvolveFn" || k == "EvolveFnDecl" {
        return val_void()
    }

    // Stmt::MacroDef — macro registration (interpreter ignores; expansion at parser)
    if k == "MacroDef" || k == "MacroDefStmt" {
        return val_void()
    }
    if k == "ComptimeFn" || k == "ComptimeFnDecl" {
        // Comptime functions evaluated lazily; treat as regular FnDecl
        env_fns.push([node.name, node.params, node.body])
        fn_cache_add(node.name, len(env_fns) - 1)
        return val_void()
    }

    // Stmt::Generate / Stmt::Optimize — directive declarations
    if k == "Generate" || k == "Optimize" || k == "OptimizeStmt" || k == "GenerateStmt" || k == "GenerateFnStmt" || k == "OptimizeFnStmt" {
        return val_void()
    }

    // Stmt::TheoremStmt — alias for Theorem (Phase 9 proof block)
    if k == "TheoremStmt" {
        let stmts = node.proof_stmts
        if type_of(stmts) == "array" {
            for ps in stmts { execute_proof_block_stmt(ps) }
        }
        return val_void()
    }

    // Stmt::HandleWithStmt — statement-form of handle/with
    //   parser stores handlers in `items`, each EffectHandler has
    //   .target = effect name, .name = op name, .params, .body
    if k == "HandleWithStmt" {
        let mut entries = []
        if type_of(node.items) == "array" {
            for h in node.items {
                let key = h.target + "." + h.name
                entries.push([key, h.params, h.body])
            }
        }
        effect_handler_push(entries)
        eval_body(node.body)
        effect_handler_pop()
        return val_void()
    }

    // Stmt::PureFnDecl — function declared @pure; same as FnDecl, but tag the
    //   pure flag so effect calls inside trigger an error.
    if k == "PureFnDecl" {
        env_fns.push([node.name, node.params, node.body])
        fn_cache_add(node.name, len(env_fns) - 1)
        fn_attrs_set(node.name, "pure")
        return val_void()
    }

    // Comptime variants — evaluated in regular context (no compile-time phase)
    if k == "ComptimeAssert" {
        let cond = eval_expr(node.left)
        if !is_truthy(cond) {
            throw_flag = true
            throw_val = val_str("comptime assertion failed")
        }
        return val_void()
    }
    if k == "ComptimeBlock" {
        let body = node.body
        if type_of(body) == "array" { eval_body(body) }
        return val_void()
    }
    if k == "ComptimeLet" || k == "ComptimeConst" {
        let val = eval_expr(node.left)
        env_define(node.name, val)
        return val_void()
    }
    if k == "ComptimeFnDecl" {
        env_fns.push([node.name, node.params, node.body])
        fn_cache_add(node.name, len(env_fns) - 1)
        return val_void()
    }

    // Stmt::Select — channel select (single-thread: pick first ready)
    //   Note: AST uses `chan` field for channel expression (channel is a keyword)
    if k == "Select" || k == "SelectStmt" {
        let arms = node.arms
        if type_of(arms) == "array" && len(arms) > 0 {
            for arm in arms {
                let ch = eval_expr(arm.chan)
                if ch.tag == TAG_CHANNEL {
                    let v = channel_recv(ch)
                    if v.tag != TAG_VOID {
                        env_push_scope()
                        if type_of(arm.var_name) == "string" && arm.var_name != "" {
                            env_define(arm.var_name, v)
                        }
                        eval_body(arm.body)
                        env_pop_scope()
                        return val_void()
                    }
                }
            }
        }
        return val_void()
    }

    // G28: guard EXPR else { BODY }
    // If EXPR is falsy, execute BODY (which should contain return/break).
    if k == "GuardStmt" {
        let cond = eval_expr(node.cond)
        if !is_truthy(cond) {
            env_push_scope()
            eval_body(node.else_body)
            env_pop_scope()
        }
        return val_void()
    }

    // G28: guard let NAME = EXPR else { BODY }
    // If EXPR is void/falsy, execute BODY (early exit). Otherwise bind NAME.
    if k == "GuardLetStmt" {
        let val = eval_expr(node.left)
        if !is_truthy(val) {
            env_push_scope()
            eval_body(node.else_body)
            env_pop_scope()
        } else {
            env_define(node.name, val)
        }
        return val_void()
    }

    // G27: with EXPR as NAME { BODY }
    // Evaluate EXPR, bind to NAME, execute BODY, then call .close() or
    // drop() on the resource if available. Cleanup runs even on error.
    if k == "WithStmt" {
        let resource = eval_expr(node.left)
        env_push_scope()
        env_define(node.name, resource)
        // Save throw state to ensure cleanup on error
        let saved_throw = throw_flag
        let saved_throw_val_w = throw_val
        throw_flag = false
        eval_body(node.body)
        let had_throw = throw_flag
        let body_throw_val = throw_val
        // Temporarily clear throw so cleanup can run
        throw_flag = false
        // Cleanup: try Type__close then Type__drop (mangled impl methods)
        if resource.tag == "struct" {
            let sname = resource.struct_name
            let close_mangled = sname + "__close"
            let drop_mangled = sname + "__drop"
            let close_info = find_fn(close_mangled)
            if close_info != "" {
                call_user_fn(close_mangled, [resource])
            } else {
                let drop_info = find_fn(drop_mangled)
                if drop_info != "" {
                    call_user_fn(drop_mangled, [resource])
                }
            }
        }
        env_pop_scope()
        // Restore throw state: body error takes priority
        if had_throw {
            throw_flag = true
            throw_val = body_throw_val
        } else if saved_throw {
            throw_flag = true
            throw_val = saved_throw_val_w
        }
        return val_void()
    }

    // Ignore unknown statement kinds
    return val_void()
}

// ── Execute a block of statements ────────────────────────

fn eval_body(stmts) {
    let mut result = val_void()
    let mut _bi = 0
    while _bi < len(stmts) {
        if return_flag || throw_flag { return result }
        result = exec_stmt_at(stmts, _bi)
        _bi = _bi + 1
    }
    return result
}

fn eval_block(stmts) {
    env_push_scope()
    let result = eval_body(stmts)
    env_pop_scope()
    return result
}

// ── Runtime `use`/`import` fallback loader (2026-04-20 bugfix) ──
//
// Background:
//   The canonical import resolution path is the CLI preprocessor in
//   self/main.hexa::cmd_run, which invokes self/module_loader.hexa to
//   flatten `use "path"` / `import "path"` directives into a single source
//   before the interpreter sees them. That path handles transitive imports,
//   hashset dedup, and leaves-first topo order.
//
// The gap this block closes:
//   If hexa_full is entered WITHOUT the preprocessor (direct interp run,
//   eval'd AST, `use a::b::c` Rust-style paths that module_loader's
//   replace("\nuse \"", ...) does not match), UseStmt/ImportStmt nodes
//   previously executed as silent val_void() — downstream projects then saw
//   "Runtime error: undefined function" for every imported symbol. Ref:
//   shared/state/voice_routes_loader_stall_20260420.json.
//
// Semantics (best-effort, preprocessor-compatible):
//   * Resolve path: `<name>.hexa`, `<name>`, caller-dir-relative, cwd
//   * Dedup via __use_loaded_paths (prevents circular + double-load)
//   * Tokenize + parse the module, then register every top-level
//     FnDecl/AsyncFnDecl/PureFnDecl/ExternFnDecl into env_fns (mirrors
//     the hoist pass in interpret()). Struct/enum decls are left to the
//     normal eval pass when the module body runs.
//   * Top-level exec via eval_body so global `let` bindings initialise.
//   * On any resolution or parse failure: silently return val_void()
//     (match the legacy behaviour — interpreter never aborts on bad use).
//
// Depth caveat:
//   feedback_hexa_silent_exit_5_imports.md documents a interp silent-exit
//   at 3+ import chain depth. This loader does NOT work around that — it
//   just resolves ONE level at a time. Deep chains still need the CLI
//   preprocessor or an explicit flatten step.

fn __use_resolve_module_path(name) {
    // 1. Exact path as given (absolute or cwd-relative).
    if file_exists(name) { return name }
    let with_ext = name + ".hexa"
    if file_exists(with_ext) { return with_ext }
    // 2. Script-dir-relative — mirrors module_loader.hexa's caller-dir lookup.
    //    `use "voice_routes"` from serving/serve_alm_native.hexa must find
    //    serving/voice_routes.hexa, not cwd/voice_routes.hexa.
    if len(__use_script_dir) > 0 {
        let sd_raw = __use_script_dir + "/" + name
        if file_exists(sd_raw) { return sd_raw }
        let sd_ext = __use_script_dir + "/" + name + ".hexa"
        if file_exists(sd_ext) { return sd_ext }
    }
    // 3. HEXA_LANG project-root fallback — matches module_loader.hexa semantics.
    let hl = env_var("HEXA_LANG")
    if len(hl) > 0 {
        let pr = hl + "/" + name
        if file_exists(pr) { return pr }
        let pr_ext = hl + "/" + name + ".hexa"
        if file_exists(pr_ext) { return pr_ext }
    }
    return ""
}

fn __use_register_module_fns(mod_ast) {
    // Mirrors interpret()'s FIX-9-1 pre-registration pass (lines ~17056–17086).
    // Pushes every top-level fn-like decl into env_fns + fn_cache + env so that
    // subsequent `find_fn` / `call_user_fn` calls from the caller resolve.
    //
    // 2026-05-04 (feat/import-alias-runtime-fix): also returns the list of fn
    // names that were registered, so `__use_load_module_from_path` can wire
    // them into __use_alias_fns when called with an `as alias` qualifier.
    let mut _mi = 0
    let mut _fn_names = []
    while _mi < len(mod_ast) {
        let _mn = mod_ast[_mi]
        if type_of(_mn) == "struct" || type_of(_mn) == "map" {
            let _mk = _mn.kind
            if type_of(_mk) == "string" {
                if _mk == "FnDecl" || _mk == "AsyncFnDecl" || _mk == "PureFnDecl" {
                    env_fns.push([_mn.name, _mn.params, _mn.body])
                    fn_cache_add(_mn.name, len(env_fns) - 1)
                    let _mfv = val_fn(_mn.name, _mn.params, _mn.body)
                    env_define(_mn.name, _mfv)
                    if _mn.value != "" {
                        fn_attrs_set(_mn.name, _mn.value)
                    }
                    _fn_names.push(_mn.name)
                }
                if _mk == "ExternFnDecl" {
                    let _ec = _mn.value
                    if _ec == "" { _ec = _mn.name }
                    let _el = _mn.op
                    extern_fns.push([_mn.name, _ec, _mn.ret_type, _el])
                    extern_fn_cache_add(_mn.name, len(extern_fns) - 1)
                    env_define(_mn.name, val_str("__extern_" + _mn.name))
                    _fn_names.push(_mn.name)
                }
            }
        }
        _mi = _mi + 1
    }
    return _fn_names
}

// 2026-05-04 (feat/import-alias-runtime-fix) — alias registry helpers.
//
// `__use_alias_register` records that `alias::<fn>` should dispatch to bare
// fn `<fn>` for every name in `fn_names`. Called by the runtime loader when
// the source carried `import "..." as <alias>`.
//
// `__use_alias_lookup_fn` returns the bare fn name string if `alias::fname`
// is registered, or "" on miss. Called by eval_call's EnumPath branch to
// route aliased calls to the user fn instead of falling through to val_enum.
//
// Idempotent: re-registering the same alias merges fn_names (dedup by name).
fn __use_alias_register(alias, fn_names) {
    if alias == "" { return false }
    if type_of(fn_names) != "array" { return false }
    // Find existing entry and merge.
    let mut _ai = 0
    while _ai < len(__use_alias_fns) {
        let _ae = __use_alias_fns[_ai]
        if _ae[0] == alias {
            let mut _existing = _ae[1]
            let mut _ni = 0
            while _ni < len(fn_names) {
                let _nm = fn_names[_ni]
                let mut _seen = false
                let mut _ei = 0
                while _ei < len(_existing) {
                    if _existing[_ei] == _nm { _seen = true }
                    _ei = _ei + 1
                }
                if !_seen { _existing.push(_nm) }
                _ni = _ni + 1
            }
            __use_alias_fns[_ai] = [alias, _existing]
            return true
        }
        _ai = _ai + 1
    }
    __use_alias_fns.push([alias, fn_names])
    return true
}

fn __use_alias_lookup_fn(alias, fname) {
    if alias == "" { return "" }
    let mut _ai = 0
    while _ai < len(__use_alias_fns) {
        let _ae = __use_alias_fns[_ai]
        if _ae[0] == alias {
            let _names = _ae[1]
            let mut _ni = 0
            while _ni < len(_names) {
                if _names[_ni] == fname { return fname }
                _ni = _ni + 1
            }
            // Alias is registered but fname is not — caller should emit the
            // explicit "symbol not found" error (Issue 3 in import-alias fix).
            return ""
        }
        _ai = _ai + 1
    }
    return ""
}

fn __use_alias_is_registered(alias) {
    if alias == "" { return false }
    let mut _ai = 0
    while _ai < len(__use_alias_fns) {
        if __use_alias_fns[_ai][0] == alias { return true }
        _ai = _ai + 1
    }
    return false
}

fn __use_load_module_from_path(resolved_path) {
    return __use_load_module_from_path_with_alias(resolved_path, "")
}

fn __use_load_module_from_path_with_alias(resolved_path, alias) {
    // Dedup — prevent circular imports + double load. Even on dedup hit we
    // still register the alias if one was supplied (so re-imports under a
    // different alias still get a working dispatch entry).
    let mut _ui = 0
    let mut _already_loaded = false
    while _ui < len(__use_loaded_paths) {
        if __use_loaded_paths[_ui] == resolved_path { _already_loaded = true }
        _ui = _ui + 1
    }
    if _already_loaded {
        // Re-derive fn names from already-registered env_fns by re-parsing the
        // module head (cheap; the source is already on disk and tokenize+parse
        // are idempotent). Skip body exec on dedup hit.
        if alias != "" {
            let _saved_tokens_d = p_tokens
            let _saved_pos_d = p_pos
            let _saved_errors_d = p_errors
            let _src_d = read_file(resolved_path)
            let _toks_d = tokenize(_src_d)
            let _mod_ast_d = parse(_toks_d)
            p_tokens = _saved_tokens_d
            p_pos = _saved_pos_d
            p_errors = _saved_errors_d
            let mut _names_d = []
            let mut _di = 0
            while _di < len(_mod_ast_d) {
                let _dn = _mod_ast_d[_di]
                if type_of(_dn) == "struct" || type_of(_dn) == "map" {
                    let _dk = _dn.kind
                    if type_of(_dk) == "string" {
                        if _dk == "FnDecl" || _dk == "AsyncFnDecl" || _dk == "PureFnDecl" || _dk == "ExternFnDecl" {
                            _names_d.push(_dn.name)
                        }
                    }
                }
                _di = _di + 1
            }
            __use_alias_register(alias, _names_d)
        }
        return true
    }
    __use_loaded_paths.push(resolved_path)

    // Snapshot parser globals — tokenize + parse share mutable state and the
    // outer parse has already completed, but a defensive save-restore keeps
    // re-entrant use (module-level use inside a loaded module) safe.
    let _saved_tokens = p_tokens
    let _saved_pos = p_pos
    let _saved_errors = p_errors

    let _src = read_file(resolved_path)
    let _toks = tokenize(_src)
    let _mod_ast = parse(_toks)

    // Restore parser globals — the outer AST was already parsed, but other
    // eval paths (e.g. `@comptime`) might re-enter parse later.
    p_tokens = _saved_tokens
    p_pos = _saved_pos
    p_errors = _saved_errors

    let _registered_names = __use_register_module_fns(_mod_ast)
    if alias != "" {
        __use_alias_register(alias, _registered_names)
    }
    // Also execute module's top-level stmts so globals/consts initialise.
    // eval_body respects return_flag/throw_flag; if the module throws on
    // top-level, that propagates to the caller — same as a preprocessed run.
    eval_body(_mod_ast)
    return true
}

fn __use_extract_path(node) {
    // ImportStmt: parser stores path in node.name as string.
    if node.name != "" && type_of(node.name) == "string" { return node.name }
    // UseStmt: parser stores ident segments in node.items as array.
    let items = node.items
    if type_of(items) == "array" {
        let n = len(items)
        if n == 0 { return "" }
        // Join with "/" so `use foo::bar` resolves to foo/bar(.hexa)
        let mut parts = []
        let mut _pi = 0
        while _pi < n {
            let seg = items[_pi]
            if type_of(seg) == "string" {
                parts.push(seg)
            }
            _pi = _pi + 1
        }
        if len(parts) == 0 { return "" }
        return parts.join("/")
    }
    return ""
}

// ── Function call ────────────────────────────────────────

fn eval_call(node) {
    _fuel_charge()
    if throw_flag { return val_void() }
    // Collect arguments — G8: spread args support
    let saved_named = pending_named_args
    let mut args = []
    let mut named = []
    let raw_args = node.args
    if type_of(raw_args) == "array" {
        for a in raw_args {
            if type_of(a) != "string" && a.kind == "Spread" {
                let spread_val = eval_expr(a.left)
                if spread_val.tag == "array" {
                    let spread_items = get_array(spread_val)
                    let mut si = 0
                    while si < len(spread_items) {
                        args.push(spread_items[si])
                        si = si + 1
                    }
                } else {
                    args.push(spread_val)
                }
            } else {
                args.push(eval_expr(a))
            }
        }
    }

    // Method call: obj.method(args) or obj?.method(args)
    let callee = node.left
    if type_of(callee) != "string" && (callee.kind == "Field" || callee.kind == "OptField") {
        let obj = eval_expr(callee.left)
        // Optional chaining short-circuit: obj?.method() → void when obj is void
        if callee.kind == "OptField" && obj.tag == "void" { return val_void() }
        let method = callee.name
        let result = call_method(obj, method, args)
        if type_of(callee.left) != "string" && callee.left.kind == "Ident" {
            if obj.tag == TAG_ARRAY && result.tag == TAG_ARRAY {
                if method == "push" || method == "pop" {
                    env_set(callee.left.name, result)
                }
            }
        }
        pending_named_args = saved_named
        return result
    }

    // Direct call: name(args)
    if type_of(callee) != "string" && callee.kind == "Ident" {
        let name = callee.name
        // User function takes precedence over builtin (allows shadowing)
        let user_info = find_fn(name)
        if user_info != "" {
            let r = call_user_fn(name, args)
            pending_named_args = saved_named
            return r
        }
        let builtin_result = call_builtin(name, args)
        if builtin_result.tag != TAG_NOT_BUILTIN {
            return builtin_result
        }
        let r = call_user_fn(name, args)
        pending_named_args = saved_named
        return r
    }

    // Indirect call (lambda etc)
    let callee_val = eval_expr(callee)
    if callee_val.tag == TAG_FN {
        return call_fn_val(callee_val, args)
    }

    pending_named_args = saved_named
    return val_void()
}

fn find_fn(name) {
    // O(1) avg via bucket cache. Fall back to linear scan only if
    // cache is empty (e.g., right after wholesale env_fns swap that
    // forgot to rebuild — defensive).
    if len(fn_cache) == 64 {
        let b = env_hash(name)
        let bucket = fn_cache[b]
        // Pick entry with largest index (newest definition = shadowing).
        let mut best = -1
        let mut bi = 0
        let bn = len(bucket)
        while bi < bn {
            let entry = bucket[bi]
            if entry[0] == name {
                if entry[1] > best { best = entry[1] }
            }
            bi = bi + 1
        }
        if best >= 0 && best < len(env_fns) {
            return env_fns[best]
        }
        return ""
    }
    // Fallback linear scan
    let mut i = len(env_fns) - 1
    while i >= 0 {
        if env_fns[i][0] == name { return env_fns[i] }
        i = i - 1
    }
    return ""
}

fn call_user_fn(name, args) {
    let fn_info = find_fn(name)
    if fn_info == "" {
        // Try env lookup (for closures/passed functions)
        let fn_val = env_lookup(name)
        if fn_val.tag == TAG_FN {
            return call_fn_val(fn_val, args)
        }
        // C2 Step 3: ExternFnDecl dispatches via env-stored sentinel.
        // ExternFnDecl handler binds name -> val_str("__extern_<name>");
        // when the bare name is called, route to call_extern_fn which
        // delegates to host builtin __host_extern_call.
        if fn_val.tag == TAG_STR {
            let sentinel = fn_val.str_val
            if len(sentinel) > 9 && sentinel.substring(0, 9) == "__extern_" {
                return call_extern_fn(sentinel, args)
            }
        }
        println("Runtime error: undefined function: " + name)
        return val_void()
    }

    // ── S-1c scout: profile counter hook would go HERE ──
    // Proposed (draft in self/hexa_full.profile_hook.hexa.draft):
    //   if env_var("HEXA_PROFILE") == "1" {
    //       let _pi = profile_index_of(name)          // O(1) via 64-bucket cache
    //       if _pi < 0 { profile_names.push(name)
    //                    profile_counts.push(1) }
    //       else      { profile_counts[_pi] = profile_counts[_pi] + 1 }
    //   }
    // Default behavior MUST be unchanged (env gate). Dump deferred to runner exit.
    // ── ROI-11: single bitmask probe replaces 3 separate O(N) scans ──
    let attr_bits = fn_attr_bitmask(name)
    // bit 2 (4): @specialize — record type feedback in inline cache
    if (attr_bits / 4) % 2 == 1 && len(args) > 0 {
        specialize_ic_record(name, args[0].tag)
    }
    // bit 1 (2): @lazy — check thunk cache before execution
    let is_lazy = (attr_bits / 2) % 2 == 1
    if is_lazy {
        let lazy_hit = lazy_lookup(name)
        if lazy_hit != "" {
            return lazy_hit[1]
        }
    }

    // bit 5 (32): @track — log function call to stderr
    if (attr_bits / 32) % 2 == 1 {
        if env_var("HEXA_TRACK") == "1" {
            let _ts = timestamp()
            eprintln("{\"event\":\"call\",\"fn\":\"" + name + "\",\"ts\":" + to_string(_ts) + "}")
        } else {
            eprintln("[track] " + name + " called")
        }
    }
    // bit 6 (64): @deprecated — warn once per function
    if (attr_bits / 64) % 2 == 1 {
        let mut _already_warned = false
        let mut _di = 0
        while _di < len(deprecated_warned) {
            if deprecated_warned[_di] == name { _already_warned = true }
            _di = _di + 1
        }
        if !_already_warned {
            deprecated_warned.push(name)
            if env_var("HEXA_STRICT_DEPRECATED") == "1" {
                println("ERROR: " + name + "() is deprecated (HEXA_STRICT_DEPRECATED=1)")
            } else {
                eprintln("[deprecated] " + name + "() is deprecated")
            }
        }
    }

    // bit 0 (1): @memo/@memoize/@cache — check cache before execution
    let is_memo = attr_bits % 2 == 1
    let mut memo_key = ""
    if is_memo {
        memo_key = memo_key_for_args(name, args)
        let cached = memo_lookup(memo_key)
        if cached != "" {
            return cached[1]
        }
    }

    let params = fn_info[1]
    let body = fn_info[2]

    // ROI-14: O(1) pre-alloc buffer push — no array grow on hot path
    if call_stack_top >= len(call_stack) {
        // Geometric grow (rare after init pre-alloc)
        let mut _grow_n = len(call_stack)
        if _grow_n == 0 { _grow_n = 128 }
        while _grow_n > 0 {
            call_stack.push("")
            _grow_n = _grow_n - 1
        }
    }
    if call_stack_top > 1000 {
        eprintln("runtime error: maximum recursion depth exceeded (1000)")
        return val_void()
    }
    call_stack[call_stack_top] = name
    call_stack_top = call_stack_top + 1
    env_push_scope()
    // rt 32-L: mark Val arena frontier on fn entry. Any Val { ... } literals
    // allocated during this call (the dominant fib RSS contributor) bump the
    // shared arena; on fn exit we heapify the return value and rewind to this
    // mark in O(1). Side-channeled through the `env(...)` builtin so no
    // transpiler / hexa_v2 changes are required. Only fn boundaries push the
    // arena mark — inner block scopes (if/while/for env_push_scope sites)
    // intentionally do NOT push, so values flowing up via env_set within the
    // same fn body remain valid until fn exit.
    let _arena_push = env_var("__HEXA_ARENA_PUSH__")
    // G22/G23: bind positional args, then named args, then defaults
    let mut i = 0
    // Phase 1: bind positional args in order
    while i < len(params) && i < len(args) {
        if type_of(params[i]) == "string" {
            env_define(params[i], args[i])
        } else {
            env_define(params[i].name, args[i])
        }
        i = i + 1
    }
    // Phase 2: for remaining unbound params, try named args then defaults
    while i < len(params) {
        let p = params[i]
        let mut pname = ""
        if type_of(p) == "string" { pname = p } else { pname = p.name }
        // G23: check named args for this param
        let mut found_named = false
        let mut ni = 0
        while ni < len(pending_named_args) {
            if pending_named_args[ni][0] == pname {
                env_define(pname, pending_named_args[ni][1])
                found_named = true
                ni = len(pending_named_args)
            }
            ni = ni + 1
        }
        if !found_named {
            // G22: check for default value in param AST node
            if type_of(p) != "string" && p.left != "" {
                env_define(pname, eval_expr(p.left))
            } else {
                // No arg, no named, no default — bind void
                env_define(pname, val_void())
            }
        }
        i = i + 1
    }
    // G23: bind any named args that target positional params (override)
    // ROI-46: skip loop entirely when no named args (common case)
    if len(pending_named_args) > 0 {
        let mut ni2 = 0
        while ni2 < len(pending_named_args) {
            let na_name = pending_named_args[ni2][0]
            let na_val = pending_named_args[ni2][1]
            // Check if this named arg targets a param already bound positionally
            let mut pi2 = 0
            while pi2 < len(params) && pi2 < len(args) {
                let pp = params[pi2]
                let mut ppname = ""
                if type_of(pp) == "string" { ppname = pp } else { ppname = pp.name }
                if ppname == na_name {
                    // Override the positional binding with the named value
                    env_set(na_name, na_val)
                    pi2 = len(params)
                }
                pi2 = pi2 + 1
            }
            ni2 = ni2 + 1
        }
    }

    // bit 9 (512): @retry — retry on failure up to N times (default 3)
    let is_retry_fn = (attr_bits / 512) % 2 == 1
    // bit 10 (1024): @fallback — catch errors, return void on failure
    let is_fallback_fn = (attr_bits / 1024) % 2 == 1
    // bit 11 (2048): @guard — monitor + detect + resolve (timing + fallback)
    let is_guard_fn = (attr_bits / 2048) % 2 == 1
    let mut guard_start_ms = 0
    if is_guard_fn {
        guard_start_ms = timestamp()
    }
    // ── bits 12-16 (added 2026-04-20 after Mac kernel panic) ──
    // Pre-body runtime gates: refuse/repuse/watchdog-spawn/monitor-start.
    // Order: refuse → repuse → watchdog → monitor → limit (most restrictive first).
    let attrs_raw = fn_attrs_get(name)
    // bit 12 (4096): @refuse — Darwin block unless HEXA_MAC_OK=1
    let is_refuse_fn = (attr_bits / 4096) % 2 == 1
    if is_refuse_fn {
        if host_is_darwin() && env_var("HEXA_MAC_OK") != "1" {
            throw_val = val_str("@refuse: " + name + " blocked on Darwin (Mac panic prevention). "
                              + "Set HEXA_MAC_OK=1 to override or dispatch to ubu/hetzner.")
            throw_flag = true
            return val_void()
        }
    }
    // bit 16 (65536): @repuse — hostname allowlist (ubu/ubu2/hetzner/htz/runpod)
    let is_repuse_fn = (attr_bits / 65536) % 2 == 1
    if is_repuse_fn {
        if env_var("HEXA_REPUSE_OK") != "1" {
            let h = host_name_short()
            if !repuse_host_allowed(h) {
                throw_val = val_str("@repuse: " + name + " blocked on host '" + h + "' "
                                  + "(allowlist: ubu,ubu2,hetzner,htz,runpod). "
                                  + "Set HEXA_REPUSE_OK=1 to override.")
                throw_flag = true
                return val_void()
            }
        }
    }
    // bit 13 (8192): @watchdog — spawn shell watchdog with rss_mb/time_s caps
    let is_watchdog_fn = (attr_bits / 8192) % 2 == 1
    if is_watchdog_fn {
        let wrss = attr_arg_int(attrs_raw, "watchdog", "rss_mb", 4096)
        let wtime = attr_arg_int(attrs_raw, "watchdog", "time_s", 300)
        watchdog_spawn(name, wrss, wtime)
    }
    // bit 14 (16384): @monitor — wall/rss snapshot start
    let is_monitor_fn = (attr_bits / 16384) % 2 == 1
    let mut mon_start_ms = 0
    let mut mon_start_rss = 0
    if is_monitor_fn {
        mon_start_ms = timestamp()
        mon_start_rss = pid_rss_kb()
    }
    // bit 8 (256): @limit — singleton + system-state refusal (pre-body gate)
    // Self-calibrating: no hardcoded threshold. Refuses if (a) same fn already
    // running (count>0) or (b) loadavg monotonically rising AND load1 > ncpus.
    // Decrement happens post-body (paired with env_pop_scope tail).
    // Extended 2026-04-20: if @limit(mem_mb=N) arg present, also refuse when
    // current RSS already exceeds cap at entry.
    let is_limit_fn = (attr_bits / 256) % 2 == 1
    if is_limit_fn {
        if active_fn_get(name) > 0 {
            throw_val = val_str("@limit violation: " + name + " already active (singleton)")
            throw_flag = true
            if is_watchdog_fn { watchdog_stop(name) }
            return val_void()
        }
        let lim_mem = attr_arg_int(attrs_raw, "limit", "mem_mb", 0)
        if lim_mem > 0 {
            let cur_rss = pid_rss_kb()
            if cur_rss > lim_mem * 1024 {
                throw_val = val_str("@limit(mem_mb=" + to_string(lim_mem) + "): " + name
                                  + " refused — RSS " + to_string(cur_rss / 1024) + "MB already over cap")
                throw_flag = true
                if is_watchdog_fn { watchdog_stop(name) }
                return val_void()
            }
        }
        let la = loadavg_triple()
        let nc = ncpus_detected()
        let l1 = la[0]
        let l5 = la[1]
        let l15 = la[2]
        if l1 > l5 && l5 > l15 && l1 > to_float(to_string(nc)) {
            throw_val = val_str("@limit refusal: " + name + " loadavg rising + oversubscribed")
            throw_flag = true
            if is_watchdog_fn { watchdog_stop(name) }
            return val_void()
        }
        active_fn_inc(name)
    }

    let saved_flag = return_flag
    return_flag = false
    let saved_defer_stack = defer_stack
    defer_stack = []
    // Sprint C: save outer generator frame, start a fresh empty buffer
    // so that yields inside this call accumulate here only.
    let saved_gen_buffer = gen_buffer
    let saved_gen_active = gen_active
    gen_buffer = []
    gen_active = false
    // Inline body execution (avoid struct copy via eval_body)
    // Track the last ExprStmt's value for implicit return semantics:
    // a fn body ending in `expr` (no return) yields that expr's value.
    let mut last_expr_val = val_void()
    let mut _cbi = 0
    while _cbi < len(body) {
        if return_flag || throw_flag { _cbi = len(body) } else {
            let stmt = body[_cbi]
            if type_of(stmt) != "string" && type_of(stmt) == "struct" || type_of(stmt) == "map" {
                if stmt.kind == "ExprStmt" {
                    last_expr_val = eval_expr(stmt.left)
                } else {
                    exec_stmt_at(body, _cbi)
                }
            } else {
                exec_stmt_at(body, _cbi)
            }
            _cbi = _cbi + 1
        }
    }
    // ── @retry (bit 9): re-execute body on throw, up to 3 attempts ──
    if is_retry_fn && throw_flag {
        let retry_max = 3
        let mut retry_attempt = 1
        let saved_throw_err = throw_val
        while throw_flag && retry_attempt < retry_max {
            retry_attempt = retry_attempt + 1
            eprintln("[retry] " + name + " attempt " + to_string(retry_attempt) + "/" + to_string(retry_max))
            throw_flag = false
            throw_val = val_void()
            return_flag = false
            return_val = val_void()
            last_expr_val = val_void()
            _cbi = 0
            while _cbi < len(body) {
                if return_flag || throw_flag { _cbi = len(body) } else {
                    let rstmt = body[_cbi]
                    if type_of(rstmt) != "string" && type_of(rstmt) == "struct" || type_of(rstmt) == "map" {
                        if rstmt.kind == "ExprStmt" {
                            last_expr_val = eval_expr(rstmt.left)
                        } else {
                            exec_stmt_at(body, _cbi)
                        }
                    } else {
                        exec_stmt_at(body, _cbi)
                    }
                    _cbi = _cbi + 1
                }
            }
        }
        // If still throwing after all retries, restore original error
        if throw_flag {
            throw_val = saved_throw_err
        }
    }
    // ── @fallback (bit 10): catch errors, return void on failure ──
    if is_fallback_fn && throw_flag {
        eprintln("[fallback] " + name + " failed, using fallback")
        throw_flag = false
        throw_val = val_void()
        return_flag = true
        return_val = val_void()
    }
    // ── @guard (bit 11): timing + error reporting ──
    if is_guard_fn {
        let guard_elapsed = timestamp() - guard_start_ms
        if throw_flag {
            if throw_val.tag == TAG_STR {
                eprintln("[guard] " + name + " FAILED after " + to_string(guard_elapsed) + "ms: " + throw_val.str_val)
            } else {
                eprintln("[guard] " + name + " FAILED after " + to_string(guard_elapsed) + "ms")
            }
            // @guard includes fallback behavior: swallow the error
            throw_flag = false
            throw_val = val_void()
            return_flag = true
            return_val = val_void()
        } else {
            eprintln("[guard] " + name + " completed in " + to_string(guard_elapsed) + "ms")
        }
    }
    let mut result = return_val
    // Implicit return: if no explicit return fired, use last expression value
    if !return_flag && result.tag == TAG_VOID && last_expr_val.tag != TAG_VOID {
        result = last_expr_val
    }
    // Sprint C: if at least one yield happened AND no explicit return
    // value was set, convert the accumulated buffer into an array value.
    if gen_active && !return_flag {
        result = val_array(gen_buffer)
    }
    gen_buffer = saved_gen_buffer
    gen_active = saved_gen_active
    // Execute deferred statements in LIFO order before restoring flags
    let saved_rf = return_flag
    let saved_tf = throw_flag
    return_flag = false
    throw_flag = false
    let mut _di = len(defer_stack) - 1
    while _di >= 0 {
        eval_body(defer_stack[_di])
        _di = _di - 1
    }
    return_flag = saved_rf
    throw_flag = saved_tf
    defer_stack = saved_defer_stack
    return_flag = saved_flag
    // rt 32-L: heapify the call's return value before rewinding the Val
    // arena. We assign `result` back to the global return_val so the C-side
    // env("__HEXA_ARENA_HEAPIFY_RETURN__") interception (which reads the
    // global) deep-copies the right value. Read it back into `result` after
    // heapify so the local handle now points at malloc'd storage; then it is
    // safe to rewind the arena via __HEXA_ARENA_POP__.
    return_val = result
    let _arena_heap = env_var("__HEXA_ARENA_HEAPIFY_RETURN__")
    result = return_val
    return_val = val_void()
    env_pop_scope()
    let _arena_pop = env_var("__HEXA_ARENA_POP__")
    // ROI-14: O(1) call stack pop — index decrement, no slice/copy
    call_stack_top = call_stack_top - 1

    // ── @limit: pair with pre-body increment ──
    if is_limit_fn { active_fn_dec(name) }

    // ── @watchdog (bit 13): kill spawned watchdog child ──
    if is_watchdog_fn { watchdog_stop(name) }

    // ── @monitor (bit 14): emit metric line ──
    if is_monitor_fn {
        let mon_end_ms = timestamp()
        let mon_end_rss = pid_rss_kb()
        let wall_ms = mon_end_ms - mon_start_ms
        let peak_rss = if mon_end_rss > mon_start_rss { mon_end_rss } else { mon_start_rss }
        monitor_emit(name, wall_ms, peak_rss)
    }

    // ── @lazy: store result in thunk cache ──
    if is_lazy {
        lazy_store(name, result)
    }

    // ── @memo/@memoize/@cache: store result in cache ──
    if is_memo {
        memo_store(memo_key, result)
    }

    return result
}

// decreases fn_val — structural
fn call_fn_val(fn_val, args) {
    // ── Special functional closures ─────────────────────────
    if fn_val.str_val == "compose" {
        // compose(f, g) → f(g(x))
        let captured = closure_store[fn_val.int_val][0]
        let mut f = val_void()
        let mut g = val_void()
        let mut ci = 0
        while ci < len(captured) {
            if captured[ci][0] == "__compose_f" { f = captured[ci][1] }
            if captured[ci][0] == "__compose_g" { g = captured[ci][1] }
            ci = ci + 1
        }
        let inner = call_fn_val(g, args)
        return call_fn_val(f, [inner])
    }
    if fn_val.str_val == "curry" {
        // curry(fn, ...partial) → fn(partial..., args...)
        let captured = closure_store[fn_val.int_val][0]
        let mut f = val_void()
        let mut partial_arr = val_void()
        let mut ci = 0
        while ci < len(captured) {
            if captured[ci][0] == "__curry_fn" { f = captured[ci][1] }
            if captured[ci][0] == "__curry_partial" { partial_arr = captured[ci][1] }
            ci = ci + 1
        }
        let partial = get_array(partial_arr)
        let mut all_args = []
        for p in partial { all_args.push(p) }
        for a in args { all_args.push(a) }
        return call_fn_val(f, all_args)
    }
    if fn_val.str_val == "constant" {
        // constant(x) → fn() => x
        let captured = closure_store[fn_val.int_val][0]
        let mut ci = 0
        while ci < len(captured) {
            if captured[ci][0] == "__constant_val" { return captured[ci][1] }
            ci = ci + 1
        }
        return val_void()
    }

    // fn_val has fn_params (array) and fn_body (AST array)
    let params = fn_val.fn_params
    let body = fn_val.fn_body
    let is_closure = fn_val.str_val == "closure"

    // For closures, save current env triple and restore captured env+cache O(1)
    // rt 32-E: snap[0] is a list of [name, value] tuples (closure capture
    // retains tuple format since it's a one-shot alloc at lambda creation,
    // not on every env_define). Unpack into parallel arrays on restore.
    let mut saved_names = []
    let mut saved_vals = []
    let mut saved_scopes = []
    let mut saved_cache_names = []
    let mut saved_cache_idxs = []
    let mut saved_dirty = []
    if is_closure {
        saved_names = env_var_names
        saved_vals = env_var_vals
        saved_scopes = env_scopes
        saved_cache_names = env_cache_names
        saved_cache_idxs = env_cache_idxs
        saved_dirty = env_scope_dirty
        let snap = closure_store[fn_val.int_val]
        let captured = snap[0]
        let mut _cn = []
        let mut _cv = []
        let mut _ci = 0
        while _ci < len(captured) {
            _cn.push(captured[_ci][0])
            _cv.push(captured[_ci][1])
            _ci = _ci + 1
        }
        env_var_names = _cn
        env_var_vals = _cv
        // rt 32-E: restore parallel bucket snap if available (snap has 3
        // elems: [captured, cache_names, cache_idxs]). Falls back to rebuild
        // for legacy 2-elem entries (compose/curry/constant builtins).
        if len(snap) >= 3 && len(snap[1]) == 64 {
            env_cache_names = snap[1]
            env_cache_idxs = snap[2]
            // Init the legacy env_cache sentinel buckets too
            let mut _lb = []
            let mut _li = 0
            while _li < 64 { _lb.push([]); _li = _li + 1 }
            env_cache = _lb
        } else {
            env_rebuild_cache()
        }
        env_scopes = [0]
        env_scope_dirty = []
    }

    env_push_scope()
    // rt 32-L: same Val arena mark as call_user_fn — closure invocation is
    // also a fn-boundary for escape purposes. Heapify the closure return on
    // exit before rewinding.
    let _arena_push_clo = env_var("__HEXA_ARENA_PUSH__")
    // G22/G23: bind positional args, then named args, then defaults
    let mut i = 0
    // Phase 1: bind positional args in order
    while i < len(params) && i < len(args) {
        if type_of(params[i]) == "string" {
            env_define(params[i], args[i])
        } else {
            env_define(params[i].name, args[i])
        }
        i = i + 1
    }
    // Phase 2: for remaining unbound params, try named args then defaults
    while i < len(params) {
        let p = params[i]
        let mut pname = ""
        if type_of(p) == "string" { pname = p } else { pname = p.name }
        // G23: check named args
        let mut found_named = false
        let mut ni = 0
        while ni < len(pending_named_args) {
            if pending_named_args[ni][0] == pname {
                env_define(pname, pending_named_args[ni][1])
                found_named = true
                ni = len(pending_named_args)
            }
            ni = ni + 1
        }
        if !found_named {
            // G22: check for default value
            if type_of(p) != "string" && p.left != "" {
                env_define(pname, eval_expr(p.left))
            } else {
                env_define(pname, val_void())
            }
        }
        i = i + 1
    }
    // G23: bind named args targeting already-bound positional params
    // ROI-46: skip loop entirely when no named args (common case)
    if len(pending_named_args) > 0 {
        let mut ni2 = 0
        while ni2 < len(pending_named_args) {
            let na_name = pending_named_args[ni2][0]
            let na_val = pending_named_args[ni2][1]
            let mut pi2 = 0
            while pi2 < len(params) && pi2 < len(args) {
                let pp = params[pi2]
                let mut ppname = ""
                if type_of(pp) == "string" { ppname = pp } else { ppname = pp.name }
                if ppname == na_name {
                    env_set(na_name, na_val)
                    pi2 = len(params)
                }
                pi2 = pi2 + 1
            }
            ni2 = ni2 + 1
        }
    }

    let saved_flag = return_flag
    return_flag = false
    let saved_defer_stack = defer_stack
    defer_stack = []
    // Sprint C: generator frame save/restore (see call_user_fn for notes)
    let saved_gen_buffer = gen_buffer
    let saved_gen_active = gen_active
    gen_buffer = []
    gen_active = false
    if type_of(body) == "array" {
        eval_body(body)
    } else {
        // Single expression body (lambda)
        return_val = eval_expr(body)
        return_flag = true
    }
    let mut result = return_val
    if gen_active && !return_flag {
        result = val_array(gen_buffer)
    }
    gen_buffer = saved_gen_buffer
    gen_active = saved_gen_active
    // Execute deferred statements in LIFO order before restoring flags
    let saved_rf = return_flag
    let saved_tf = throw_flag
    return_flag = false
    throw_flag = false
    let mut _di = len(defer_stack) - 1
    while _di >= 0 {
        eval_body(defer_stack[_di])
        _di = _di - 1
    }
    return_flag = saved_rf
    throw_flag = saved_tf
    defer_stack = saved_defer_stack
    return_flag = saved_flag
    // rt 32-L: heapify return before arena rewind (mirror call_user_fn).
    return_val = result
    let _arena_heap_clo = env_var("__HEXA_ARENA_HEAPIFY_RETURN__")
    result = return_val
    return_val = val_void()
    env_pop_scope()
    let _arena_pop_clo = env_var("__HEXA_ARENA_POP__")

    // Restore env for closures — O(1) swap back, no rebuild needed
    if is_closure {
        env_var_names = saved_names
        env_var_vals = saved_vals
        env_scopes = saved_scopes
        env_cache_names = saved_cache_names
        env_cache_idxs = saved_cache_idxs
        env_scope_dirty = saved_dirty
    }

    return result
}

// ── Builtin functions ────────────────────────────────────

// decreases args — structural
fn call_builtin(name, args) {
    let not_builtin = Val { tag: TAG_NOT_BUILTIN, int_val: 0, float_val: 0.0, bool_val: false, str_val: __E, char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E }

    // ── Fast-path dispatch: top 13 hot builtins ──────────────────────
    // These 13 names account for the vast majority of call_builtin
    // invocations during interpreter execution. By placing them before
    // the 400+ sequential if-chain, they resolve in O(13) instead of
    // O(200+). The original implementations further down remain but are
    // now unreachable for these names (harmless dead code).
    if name == "len" {
        if len(args) > 0 {
            let a = args[0]
            if a.tag == TAG_STR { return val_int(len(a.str_val)) }
            if a.tag == TAG_ARRAY { return val_int(len(get_array(a))) }
            if a.tag == TAG_TENSOR { return val_int(len(tensor_data(a))) }
            if a.tag == TAG_MAP { return val_int(len(get_map_keys(a))) }
        }
        return val_int(0)
    }
    if name == "to_string" {
        if len(args) > 0 { return val_str(val_to_string(args[0])) }
        return val_str("")
    }
    if name == "type_of" {
        if len(args) > 0 { return val_str(tag_name(args[0].tag)) }
        return val_str("void")
    }
    if name == "push" {
        if len(args) >= 2 && args[0].tag == TAG_ARRAY {
            return array_push_inplace(args[0], args[1])
        }
        return args[0]
    }
    if name == "int" || name == "to_int" || name == "to_i64" {
        // hxa-20260424-006: to_i64 is an alias for to_int with permissive
        // semantics — nexus/tool/dormancy_wake_tick.hexa expects to_i64("")
        // or to_i64("abc") to return 0 (wrapped in try/catch). Because the
        // to_int branch exec_throws on non-integer input, we catch the
        // throw here when the caller asked for to_i64 and return 0.
        if len(args) == 0 { return val_int(0) }
        let v = args[0]
        if v.tag == TAG_INT { return v }
        if v.tag == TAG_FLOAT {
            // Truncate toward zero (C cast semantics) — align with AOT
            // runtime.c:hexa_to_int 의 (int64_t)HX_FLOAT(v). 이전엔 floor() 로
            // 음수에서 AOT=-3 / interp=-4 divergence.
            let f = v.float_val
            if f < 0.0 { return val_int(ceil(f)) }
            return val_int(floor(f))
        }
        if v.tag == TAG_STR {
            let s = v.str_val
            let trimmed = s.trim()
            if len(trimmed) == 0 { return val_int(0) }
            let mut start = 0
            let cs0 = trimmed.chars()
            let first = to_string(cs0[0])
            if first == "+" || first == "-" { start = 1 }
            let mut is_hex = false
            if len(trimmed) >= start + 2 {
                let p0 = to_string(cs0[start])
                let p1 = to_string(cs0[start + 1])
                if p0 == "0" && (p1 == "x" || p1 == "X") {
                    is_hex = true
                    start = start + 2
                }
            }
            if start >= len(trimmed) {
                if name == "to_i64" { return val_int(0) }
                exec_throw(val_str("to_int: invalid integer literal \"" + s + "\""))
                return val_int(0)
            }
            let mut i = start
            let mut ok = true
            while i < len(trimmed) {
                let c = to_string(cs0[i])
                let code = char_code(c, 0)
                let is_dec = code >= 48 && code <= 57
                let is_hex_digit = is_hex && ((code >= 65 && code <= 70) || (code >= 97 && code <= 102))
                if !is_dec && !is_hex_digit {
                    ok = false
                    i = len(trimmed)
                } else {
                    i = i + 1
                }
            }
            if !ok {
                if name == "to_i64" { return val_int(0) }
                exec_throw(val_str("to_int: invalid integer literal \"" + s + "\""))
                return val_int(0)
            }
            return val_int(trimmed.parse_int())
        }
        if v.tag == TAG_BOOL { if v.bool_val { return val_int(1) } else { return val_int(0) } }
        return val_int(0)
    }
    if name == "float" || name == "to_float" {
        if len(args) == 0 { return val_float(0.0) }
        let v = args[0]
        if v.tag == TAG_FLOAT { return v }
        if v.tag == TAG_INT { return val_float(v.int_val * 1.0) }
        if v.tag == TAG_STR {
            let s = v.str_val
            let trimmed = s.trim()
            if len(trimmed) == 0 { return val_float(0.0) }
            let cs0 = trimmed.chars()
            let mut i = 0
            let first = to_string(cs0[0])
            if first == "+" || first == "-" { i = 1 }
            let mut seen_digit = false
            let mut seen_dot = false
            let mut seen_exp = false
            let mut ok = true
            while i < len(trimmed) {
                let c = to_string(cs0[i])
                let code = char_code(c, 0)
                let is_dec = code >= 48 && code <= 57
                if is_dec {
                    seen_digit = true
                    i = i + 1
                } else if c == "." && !seen_dot && !seen_exp {
                    seen_dot = true
                    i = i + 1
                } else if (c == "e" || c == "E") && seen_digit && !seen_exp {
                    seen_exp = true
                    i = i + 1
                    if i < len(trimmed) {
                        let cn = to_string(cs0[i])
                        if cn == "+" || cn == "-" { i = i + 1 }
                    }
                    seen_digit = false
                } else {
                    ok = false
                    i = len(trimmed)
                }
            }
            if !ok || !seen_digit {
                exec_throw(val_str("to_float: invalid float literal \"" + s + "\""))
                return val_float(0.0)
            }
            return val_float(trimmed.parse_float())
        }
        return val_float(0.0)
    }
    if name == "bool" {
        if len(args) > 0 { return val_bool(is_truthy(args[0])) }
        return val_bool(false)
    }
    if name == "join" {
        if len(args) == 0 { return val_str("") }
        let arr = args[0]
        let sep = if len(args) > 1 { args[1].str_val } else { "" }
        if arr.tag != TAG_ARRAY { return val_str("") }
        let items = get_array(arr)
        let mut parts = []
        let mut _ji = 0
        while _ji < len(items) {
            let item = items[_ji]
            if item.tag == TAG_STR { parts.push(item.str_val) }
            else { parts.push(val_to_string(item)) }
            _ji = _ji + 1
        }
        return val_str(parts.join(sep))
    }
    if name == "chars" {
        if len(args) > 0 && args[0].tag == TAG_STR {
            let cs = args[0].str_val.chars()
            let mut result = []
            for c in cs { result.push(val_str(to_string(c))) }
            return val_array(result)
        }
        return val_array([])
    }
    if name == "abs" {
        if len(args) > 0 {
            let a = args[0]
            if a.tag == TAG_INT { if a.int_val < 0 { return val_int(0 - a.int_val) } else { return a } }
            if a.tag == TAG_FLOAT { if a.float_val < 0.0 { return val_float(0.0 - a.float_val) } else { return a } }
        }
        return val_int(0)
    }
    // ω-stdlib-8 fix: was reading args[0].float_val directly, which crashed
    // when an INT was passed (e.g. floor(3) ⇒ 0.0 instead of 3). Match the
    // canonical body in the second-chain duplicate (now removed) by routing
    // through to_float_val so int args are coerced safely.
    if name == "floor" { if len(args) > 0 { return val_int(floor(to_float_val(args[0]))) } else { return val_int(0) } }
    if name == "sqrt" { if len(args) > 0 { return val_float(sqrt(to_float_val(args[0]))) } else { return val_float(0.0) } }
    // G1-FLOAT-PRIM 2026-05-06 (.roadmap.stdlib G1) — interpreter dispatch
    // for lgamma + IEEE-754 classifiers. Mirrors codegen_c2.cg_math_sym +
    // runtime.c hexa_math_lgamma/isnan/isinf/isfinite. Fast-path placement
    // matches sqrt above (Beta-Binomial Bayesian audit hot path).
    if name == "lgamma"   { if len(args) > 0 { return val_float(lgamma(to_float_val(args[0])))   } else { return val_float(0.0) } }
    if name == "isnan"    { if len(args) > 0 { return val_bool(isnan(to_float_val(args[0])))     } else { return val_bool(false) } }
    if name == "isinf"    { if len(args) > 0 { return val_bool(isinf(to_float_val(args[0])))     } else { return val_bool(false) } }
    if name == "isfinite" { if len(args) > 0 { return val_bool(isfinite(to_float_val(args[0])))  } else { return val_bool(true) } }
    // ── End fast-path ────────────────────────────────────────────────

    if name == "println" {
        let mut parts = []
        for a in args { parts.push(val_to_string(a)) }
        let out = parts.join("")
        // R19: BrokenPipe(파이프 조기 종료) 감지 → graceful exit(0).
        // | head, | tail 등으로 consumer 종료 시 silent exit 1 방지.
        try {
            println(out)
        } catch e {
            let es = e.to_string()
            if es.contains("pipe") || es.contains("EPIPE") || es.contains("BrokenPipe") {
                exit(0)
            }
            eprintln("❌ [interpreter.println] " + es)
            exit(1)
        }
        return val_void()
    }
    if name == "eprintln" {
        let mut parts = []
        for a in args { parts.push(val_to_string(a)) }
        let out = parts.join("")
        try {
            eprintln(out)
        } catch e {
            let es = e.to_string()
            if es.contains("pipe") || es.contains("EPIPE") || es.contains("BrokenPipe") {
                exit(0)
            }
            // can't use eprintln to report eprintln failure — fall to plain println
            println("[interpreter.eprintln] " + es)
            exit(1)
        }
        return val_void()
    }
    // FIX (2026-04-20): eprint — stderr + no-newline counterpart of eprintln.
    // Stage0 host has no `eprint` primitive under seed-freeze; approximate
    // with host `eprintln` (adds a trailing newline) so the interpreter at
    // least routes the call to stderr without raising "undefined function".
    // Native/AOT path uses hexa_eprint (runtime.c) for true no-newline.
    if name == "eprint" {
        let mut parts_en = []
        for a in args { parts_en.push(val_to_string(a)) }
        let out_en = parts_en.join("")
        try {
            eprintln(out_en)
        } catch e {
            let es = e.to_string()
            if es.contains("pipe") || es.contains("EPIPE") || es.contains("BrokenPipe") {
                exit(0)
            }
            println("[interpreter.eprint] " + es)
            exit(1)
        }
        return val_void()
    }
    if name == "print" {
        let mut parts = []
        for a in args { parts.push(val_to_string(a)) }
        let out = parts.join("")
        try {
            print(out)
        } catch e {
            let es = e.to_string()
            if es.contains("pipe") || es.contains("EPIPE") || es.contains("BrokenPipe") {
                exit(0)
            }
            eprintln("❌ [interpreter.print] " + es)
            exit(1)
        }
        return val_void()
    }
    // ── Phase 12 골화 — 호스트 빌트인 패스스루 ──
    // exec(cmd) → 호스트 shell에 위임. 실패 시 tag="error" Val.
    //   exec()는 매우 자주 쓰이며 P11 안티패턴(`exec(...).trim()`)의 출처.
    //   여기선 호스트 인터프리터 빌트인을 직접 호출.
    if name == "exec" {
        if len(args) == 0 { return val_str("") }
        let _exec_str = args[0].str_val
        // Metachar warning은 기본 silent. HEXA_EXEC_WARN=1 일 때만 노출.
        // 기존은 무조건 eprintln 이라 수많은 legitimate 복합 shell 호출
        // (test -e ... && echo y || echo n 등) 이 노이즈만 뿌렸음.
        // hxa-20260422-005 resolution (2026-04-23).
        if _exec_str.contains(";") || _exec_str.contains("|") || _exec_str.contains("$(") || _exec_str.contains("`") {
            if env("HEXA_EXEC_WARN") == "1" {
                eprintln("security warning: exec() argument contains shell metacharacters: " + _exec_str)
            }
        }
        try {
            let result = exec(args[0].str_val)
            return val_str(result)
        } catch e {
            return Val { tag: TAG_ERROR, int_val: 0, float_val: 0.0, bool_val: false, str_val: e.to_string(), char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E }
        }
    }
    // exec_capture(cmd) → [stdout, stderr, exit_code]. Routes to the
    // runtime.c pipe/fork implementation via the hx_exec_capture bt-73
    // TAG_FN shim (the pure-hexa transpile path couldn't separate stderr).
    if name == "exec_capture" {
        if len(args) == 0 { return val_array([val_str(""), val_str(""), val_int(0)]) }
        try {
            let r = hx_exec_capture(args[0].str_val)
            // r is a host HexaVal array [stdout, stderr, exit]; re-wrap
            // each element as interpreter Val. to_string/to_int on host
            // HexaVal round-trips through the runtime without losing type.
            return val_array([val_str(to_string(r[0])), val_str(to_string(r[1])), val_int(to_int(r[2]))])
        } catch e {
            return val_array([val_str(""), val_str(e.to_string()), val_int(1)])
        }
    }
    // ── ω-runtime-1 Phase A: persistent-pipe primitive (2026-04-26) ──
    // Five new builtins (handle-based bidirectional child-process API):
    //   pipe_spawn(cmd) -> int            : spawn `/bin/sh -c cmd`, ret handle id (-1 err)
    //   pipe_send_line(h, str) -> bool    : write payload + '\n' to child stdin
    //   pipe_recv_line(h, timeout_ms)     : read until '\n' or timeout (returns line w/o \n)
    //   pipe_close(h) -> bool             : SIGTERM(100ms grace)→SIGKILL→waitpid→free slot
    //   pipe_alive(h) -> bool             : kill(pid,0) probe + slot validity
    // Routes to runtime.c hexa_pipe_* via hx_pipe_* bt-73 TAG_FN shims
    // (same pattern as hx_exec_capture / hx_sha256). Powers ω-audio-2
    // 60× chain target by eliminating per-call fork+FIFO+bash overhead.
    if name == "pipe_spawn" {
        if len(args) == 0 { return val_int(-1) }
        try {
