            sum_exp = sum_exp + exp(f - max_l)
        }
        let target_v = if type_of(logits[target]) == "float" { logits[target] } else { to_float_val(logits[target]) }
        let log_softmax = (target_v - max_l) - ln(sum_exp)
        return val_float(0.0 - log_softmax)
    }
    if name == "cosine_lr" {
        // cosine_lr(base_lr, step, total_steps[, min_lr]) — cosine annealing schedule
        if len(args) < 3 { return val_float(0.0) }
        let base = to_float_val(args[0])
        let step = to_float_val(args[1])
        let total = to_float_val(args[2])
        let min_lr = if len(args) >= 4 { to_float_val(args[3]) } else { 0.0 }
        if total <= 0.0 { return val_float(base) }
        let progress = step / total
        let factor = 0.5 * (1.0 + cos(3.14159265358979 * progress))
        return val_float(min_lr + (base - min_lr) * factor)
    }
    if name == "base64_encode" {
        if len(args) == 0 { return val_str("") }
        // Self-host: delegate to host if exposed; else simple stub
        let s = if args[0].tag == TAG_STR { args[0].str_val } else { val_to_string(args[0]) }
        try {
            let result = base64_encode(s)
            return val_str(result)
        } catch e {
            return val_str(s)
        }
    }
    if name == "base64_decode" {
        if len(args) == 0 { return val_str("") }
        let s = args[0].str_val
        try {
            let result = base64_decode(s)
            return val_str(result)
        } catch e {
            return val_str(s)
        }
    }
    if name == "dropout" {
        // dropout(x, rate) — for inference, identity (rate ignored)
        if len(args) == 0 { return val_void() }
        return args[0]
    }
    if name == "batch_norm" {
        // batch_norm(x, mean, var, eps) — (x - mean) / sqrt(var + eps)
        if len(args) < 4 { return val_void() }
        let arr = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let mean = to_float_val(args[1])
        let var = to_float_val(args[2])
        let eps = to_float_val(args[3])
        let denom = sqrt(var + eps)
        let mut out = []
        for v in arr {
            let f = if type_of(v) == "float" { v } else { to_float_val(v) }
            out.push((f - mean) / denom)
        }
        if args[0].tag == TAG_TENSOR { return val_tensor(tensor_shape(args[0]), out) }
        return val_array(out)
    }
    if name == "embedding" {
        // 4-arg: embedding(tokens, table, vocab, dim) → concat rows for each token
        // 3-arg: embedding(table, idx, dim) → single row
        if len(args) < 3 { return val_array([]) }
        if len(args) >= 4 {
            // batch mode: tokens=args[0], table=args[1], vocab=args[2], dim=args[3]
            let tokens = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
            let table = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
            let dim = args[3].int_val
            let mut out = []
            let mut ti = 0
            while ti < len(tokens) {
                let idx = tokens[ti].int_val
                let base = idx * dim
                let mut di = 0
                while di < dim {
                    if base + di < len(table) {
                        let v = table[base + di]
                        if type_of(v) == "float" { out.push(v) }
                        else { out.push(to_float_val(v)) }
                    } else {
                        out.push(val_float(0.0))
                    }
                    di = di + 1
                }
                ti = ti + 1
            }
            return val_tensor([len(tokens), dim], out)
        }
        let table = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let idx = args[1].int_val
        let dim = args[2].int_val
        let base = idx * dim
        if base < 0 || base + dim > len(table) { return val_array([]) }
        let mut out = []
        let mut i = 0
        while i < dim {
            let v = table[base + i]
            if type_of(v) == "float" { out.push(v) }
            else { out.push(to_float_val(v)) }
            i = i + 1
        }
        return val_tensor([dim], out)
    }
    if name == "softmax" {
        if len(args) == 0 { return val_array([]) }
        let arr = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        if len(arr) == 0 { return val_array([]) }
        // stable softmax
        let mut max_v = to_float_val(arr[0])
        for v in arr {
            let f = to_float_val(v)
            if f > max_v { max_v = f }
        }
        let mut exps = []
        let mut sum_e = 0.0
        for v in arr {
            let f = to_float_val(v)
            let e = exp(f - max_v)
            exps.push(e)
            sum_e = sum_e + e
        }
        // Wrap each result as val_float so downstream sum/map work
        let mut out = []
        for e in exps { out.push(val_float(e / sum_e)) }
        if args[0].tag == TAG_TENSOR {
            let mut raw_out = []
            for w in out { raw_out.push(w.float_val) }
            return val_tensor(tensor_shape(args[0]), raw_out)
        }
        return val_array(out)
    }

    // ── Phase 13 골화 — ML training builtins ──
    // adam_step(p, g, m, v, lr, b1, b2, eps, t) → [new_p..., new_m..., new_v...]
    if name == "adam_step" {
        if len(args) < 9 { return val_array([]) }
        let p = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let g = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let m = if args[2].tag == TAG_TENSOR { tensor_data(args[2]) } else { get_array(args[2]) }
        let v = if args[3].tag == TAG_TENSOR { tensor_data(args[3]) } else { get_array(args[3]) }
        let lr = to_float_val(args[4])
        let beta1 = to_float_val(args[5])
        let beta2 = to_float_val(args[6])
        let eps = to_float_val(args[7])
        let t = to_float_val(args[8])
        let n = len(p)
        let bc1 = 1.0 - pow(beta1, t)
        let bc2 = 1.0 - pow(beta2, t)
        let mut new_p = []
        let mut new_m = []
        let mut new_v = []
        let mut i = 0
        while i < n {
            let pf = if type_of(p[i]) == "float" { p[i] } else { to_float_val(p[i]) }
            let gf = if type_of(g[i]) == "float" { g[i] } else { to_float_val(g[i]) }
            let mf = if type_of(m[i]) == "float" { m[i] } else { to_float_val(m[i]) }
            let vf = if type_of(v[i]) == "float" { v[i] } else { to_float_val(v[i]) }
            let mi = beta1 * mf + (1.0 - beta1) * gf
            let vi = beta2 * vf + (1.0 - beta2) * gf * gf
            let m_hat = mi / bc1
            let v_hat = vi / bc2
            let pi_new = pf - lr * m_hat / (sqrt(v_hat) + eps)
            new_p.push(pi_new)
            new_m.push(mi)
            new_v.push(vi)
            i = i + 1
        }
        // Concat: [new_p..., new_m..., new_v...]
        let mut result = []
        for x in new_p { result.push(val_float(x)) }
        for x in new_m { result.push(val_float(x)) }
        for x in new_v { result.push(val_float(x)) }
        return val_array(result)
    }
    // adamw_step — same as adam but decoupled weight decay
    if name == "adamw_step" {
        if len(args) < 10 { return val_array([]) }
        let p = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let g = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let m = if args[2].tag == TAG_TENSOR { tensor_data(args[2]) } else { get_array(args[2]) }
        let v = if args[3].tag == TAG_TENSOR { tensor_data(args[3]) } else { get_array(args[3]) }
        let lr = to_float_val(args[4])
        let beta1 = to_float_val(args[5])
        let beta2 = to_float_val(args[6])
        let eps = to_float_val(args[7])
        let t = to_float_val(args[8])
        let wd = to_float_val(args[9])
        let n = len(p)
        let bc1 = 1.0 - pow(beta1, t)
        let bc2 = 1.0 - pow(beta2, t)
        let mut new_p = []
        let mut new_m = []
        let mut new_v = []
        let mut i = 0
        while i < n {
            let pf = if type_of(p[i]) == "float" { p[i] } else { to_float_val(p[i]) }
            let gf = if type_of(g[i]) == "float" { g[i] } else { to_float_val(g[i]) }
            let mf = if type_of(m[i]) == "float" { m[i] } else { to_float_val(m[i]) }
            let vf = if type_of(v[i]) == "float" { v[i] } else { to_float_val(v[i]) }
            let mi = beta1 * mf + (1.0 - beta1) * gf
            let vi = beta2 * vf + (1.0 - beta2) * gf * gf
            let m_hat = mi / bc1
            let v_hat = vi / bc2
            let pi_new = pf * (1.0 - lr * wd) - lr * m_hat / (sqrt(v_hat) + eps)
            new_p.push(pi_new)
            new_m.push(mi)
            new_v.push(vi)
            i = i + 1
        }
        let mut result = []
        for x in new_p { result.push(val_float(x)) }
        for x in new_m { result.push(val_float(x)) }
        for x in new_v { result.push(val_float(x)) }
        return val_array(result)
    }
    // warmup_lr(base, step, warmup_steps)
    if name == "warmup_lr" {
        if len(args) < 3 { return val_float(0.0) }
        let base = to_float_val(args[0])
        let step = to_float_val(args[1])
        let warmup = to_float_val(args[2])
        if step < warmup { return val_float(base * step / warmup) }
        return val_float(base)
    }
    // phase_lr(base, step, total, n_phases)
    if name == "phase_lr" {
        if len(args) < 4 { return val_float(0.0) }
        let base = to_float_val(args[0])
        let step = to_float_val(args[1])
        let total = to_float_val(args[2])
        let n_phases = args[3].int_val
        let phase_idx = floor(step / total * n_phases)
        let phase_clamped = if phase_idx >= n_phases { n_phases - 1 } else { phase_idx }
        let decay = pow(0.5, phase_clamped)
        return val_float(base * decay)
    }
    // layer_norm(x, dim) → normalized
    if name == "layer_norm" {
        if len(args) < 2 { return val_array([]) }
        let x = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let dim = args[1].int_val
        if dim == 0 { return val_array([]) }
        let n_samples = len(x) / dim
        let mut result = []
        let mut s = 0
        while s < n_samples {
            let base = s * dim
            let mut mean = 0.0
            let mut d = 0
            while d < dim {
                let v = if type_of(x[base + d]) == "float" { x[base + d] } else { to_float_val(x[base + d]) }
                mean = mean + v
                d = d + 1
            }
            mean = mean / dim
            let mut var = 0.0
            d = 0
            while d < dim {
                let v = if type_of(x[base + d]) == "float" { x[base + d] } else { to_float_val(x[base + d]) }
                var = var + (v - mean) * (v - mean)
                d = d + 1
            }
            var = var / dim
            let denom = sqrt(var + 0.00001)
            d = 0
            while d < dim {
                let v = if type_of(x[base + d]) == "float" { x[base + d] } else { to_float_val(x[base + d]) }
                result.push(val_float((v - mean) / denom))
                d = d + 1
            }
            s = s + 1
        }
        return val_array(result)
    }
    // mse(pred, target)
    if name == "mse" || name == "mean_squared_error" {
        if len(args) < 2 { return val_float(0.0) }
        let p = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let t = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let n = if len(p) < len(t) { len(p) } else { len(t) }
        if n == 0 { return val_float(0.0) }
        let mut total = 0.0
        let mut i = 0
        while i < n {
            let pf = if type_of(p[i]) == "float" { p[i] } else { to_float_val(p[i]) }
            let tf = if type_of(t[i]) == "float" { t[i] } else { to_float_val(t[i]) }
            let d = pf - tf
            total = total + d * d
            i = i + 1
        }
        return val_float(total / n)
    }
    // mae(pred, target)
    if name == "mae" || name == "mean_absolute_error" {
        if len(args) < 2 { return val_float(0.0) }
        let p = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let t = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let n = if len(p) < len(t) { len(p) } else { len(t) }
        if n == 0 { return val_float(0.0) }
        let mut total = 0.0
        let mut i = 0
        while i < n {
            let pf = if type_of(p[i]) == "float" { p[i] } else { to_float_val(p[i]) }
            let tf = if type_of(t[i]) == "float" { t[i] } else { to_float_val(t[i]) }
            let d = pf - tf
            total = total + abs(d)
            i = i + 1
        }
        return val_float(total / n)
    }
    // smooth_l1_loss / huber_loss
    if name == "smooth_l1_loss" || name == "huber_loss" {
        if len(args) < 2 { return val_float(0.0) }
        let p = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let t = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let beta = if len(args) > 2 { to_float_val(args[2]) } else { 1.0 }
        let n = if len(p) < len(t) { len(p) } else { len(t) }
        if n == 0 { return val_float(0.0) }
        let mut total = 0.0
        let mut i = 0
        while i < n {
            let pf = if type_of(p[i]) == "float" { p[i] } else { to_float_val(p[i]) }
            let tf = if type_of(t[i]) == "float" { t[i] } else { to_float_val(t[i]) }
            let diff = abs(pf - tf)
            if diff < beta { total = total + 0.5 * diff * diff / beta }
            else { total = total + diff - 0.5 * beta }
            i = i + 1
        }
        return val_float(total / n)
    }
    // focal_loss(pred, target, gamma)
    if name == "focal_loss" {
        if len(args) < 2 { return val_float(0.0) }
        let p = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let t = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let gamma = if len(args) > 2 { to_float_val(args[2]) } else { 2.0 }
        let n = if len(p) < len(t) { len(p) } else { len(t) }
        if n == 0 { return val_float(0.0) }
        let mut total = 0.0
        let mut i = 0
        while i < n {
            let pf = if type_of(p[i]) == "float" { p[i] } else { to_float_val(p[i]) }
            let tf = if type_of(t[i]) == "float" { t[i] } else { to_float_val(t[i]) }
            let pt = if tf > 0.5 { pf } else { 1.0 - pf }
            let pt_safe = if pt < 0.000001 { 0.000001 } else { pt }
            total = total - pow(1.0 - pt_safe, gamma) * ln(pt_safe)
            i = i + 1
        }
        return val_float(total / n)
    }
    // contrastive_loss(emb1, emb2, label, margin) — InfoNCE-ish
    if name == "contrastive_loss" {
        if len(args) < 3 { return val_float(0.0) }
        let e1 = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let e2 = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let label = to_float_val(args[2])
        let margin = if len(args) > 3 { to_float_val(args[3]) } else { 1.0 }
        let n = if len(e1) < len(e2) { len(e1) } else { len(e2) }
        let mut dist_sq = 0.0
        let mut i = 0
        while i < n {
            let a = if type_of(e1[i]) == "float" { e1[i] } else { to_float_val(e1[i]) }
            let b = if type_of(e2[i]) == "float" { e2[i] } else { to_float_val(e2[i]) }
            let d = a - b
            dist_sq = dist_sq + d * d
            i = i + 1
        }
        let dist = sqrt(dist_sq)
        // similar (label=1): minimize dist^2; dissimilar (label=0): maximize margin-dist
        let pos = label * dist_sq
        let neg_diff = if margin - dist > 0.0 { margin - dist } else { 0.0 }
        let neg = (1.0 - label) * neg_diff * neg_diff
        return val_float(0.5 * (pos + neg))
    }
    // gelu(x) — Gaussian Error Linear Unit
    if name == "gelu" {
        if len(args) == 0 { return val_array([]) }
        let arr = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let mut result = []
        for v in arr {
            let f = if type_of(v) == "float" { v } else { to_float_val(v) }
            // approximation: 0.5 * x * (1 + tanh(sqrt(2/pi) * (x + 0.044715 * x^3)))
            let inner = sqrt(2.0 / 3.14159265358979) * (f + 0.044715 * f * f * f)
            let g = 0.5 * f * (1.0 + tanh(inner))
            result.push(val_float(g))
        }
        if args[0].tag == TAG_TENSOR {
            // ω-stdlib-6 fix: was returning val_tensor(shape, [].push(0)) — a
            // dummy single-element tensor — silently dropping the gelu result.
            // Now thread `result` (Val-wrapped floats) into raw float data.
            let mut raw_out = []
            for w in result { raw_out.push(w.float_val) }
            return val_tensor(tensor_shape(args[0]), raw_out)
        }
        return val_array(result)
    }
    // swish(x) = x * sigmoid(x)
    // ω-stdlib-7 (2026-04-26): (a) tensor-shape passthrough — was returning
    // val_array even when input was TAG_TENSOR (silent shape loss, mirror of
    // the ω-stdlib-6 gelu fix). (b) numerically-stable sigmoid factor —
    // 1/(1+exp(-f)) overflows for very negative f; branch on sign.
    if name == "swish" || name == "silu" {
        if len(args) == 0 { return val_array([]) }
        let arr = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let mut result = []
        for v in arr {
            let f = if type_of(v) == "float" { v } else { to_float_val(v) }
            let s = if f >= 0.0 {
                let z = exp(0.0 - f)
                1.0 / (1.0 + z)
            } else {
                let z = exp(f)
                z / (1.0 + z)
            }
            result.push(val_float(f * s))
        }
        if args[0].tag == TAG_TENSOR {
            let mut raw_out = []
            for w in result { raw_out.push(w.float_val) }
            return val_tensor(tensor_shape(args[0]), raw_out)
        }
        return val_array(result)
    }
    // transpose(matrix, rows, cols) → transposed flat array
    if name == "transpose" {
        if len(args) < 3 { return val_array([]) }
        let m = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let rows = args[1].int_val
        let cols = args[2].int_val
        let mut result = []
        let mut c = 0
        while c < cols {
            let mut r = 0
            while r < rows {
                let v = m[r * cols + c]
                if type_of(v) == "float" { result.push(val_float(v)) }
                else { result.push(v) }
                r = r + 1
            }
            c = c + 1
        }
        return val_array(result)
    }
    // zeros(n) / ones(n)
    if name == "zeros" {
        if len(args) == 0 { return val_array([]) }
        let n = args[0].int_val
        let mut result = []
        let mut i = 0
        while i < n { result.push(val_float(0.0)); i = i + 1 }
        return val_array(result)
    }
    if name == "ones" {
        if len(args) == 0 { return val_array([]) }
        let n = args[0].int_val
        let mut result = []
        let mut i = 0
        while i < n { result.push(val_float(1.0)); i = i + 1 }
        return val_array(result)
    }
    // ── Phase 13b 골화 — attention/conv/lora ──
    // attention(Q, K, V, seq, dim, causal?) — scaled dot-product attention
    if name == "attention" {
        if len(args) < 5 { return val_array([]) }
        let q = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let k = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let v = if args[2].tag == TAG_TENSOR { tensor_data(args[2]) } else { get_array(args[2]) }
        let seq = args[3].int_val
        let dim = args[4].int_val
        let causal = if len(args) > 5 { args[5].bool_val } else { false }
        let scale = 1.0 / sqrt(dim + 0.0)
        let mut output = []
        let mut i = 0
        while i < seq {
            let mut scores = []
            let mut j = 0
            while j < seq {
                if causal && j > i {
                    scores.push(0.0 - 1000000000.0)
                } else {
                    let mut dot = 0.0
                    let mut d = 0
                    while d < dim {
                        let qv = if type_of(q[i * dim + d]) == "float" { q[i * dim + d] } else { to_float_val(q[i * dim + d]) }
                        let kv = if type_of(k[j * dim + d]) == "float" { k[j * dim + d] } else { to_float_val(k[j * dim + d]) }
                        dot = dot + qv * kv
                        d = d + 1
                    }
                    scores.push(dot * scale)
                }
                j = j + 1
            }
            // softmax
            let mut max_s = scores[0]
            for s in scores { if s > max_s { max_s = s } }
            let mut exps = []
            let mut sum_e = 0.0
            for s in scores {
                let e = exp(s - max_s)
                exps.push(e)
                sum_e = sum_e + e
            }
            // weighted V
            let mut d = 0
            while d < dim {
                let mut val = 0.0
                let mut jj = 0
                while jj < seq {
                    let w = exps[jj] / sum_e
                    let vv = if type_of(v[jj * dim + d]) == "float" { v[jj * dim + d] } else { to_float_val(v[jj * dim + d]) }
                    val = val + w * vv
                    jj = jj + 1
                }
                output.push(val_float(val))
                d = d + 1
            }
            i = i + 1
        }
        return val_array(output)
    }
    // conv1d(input, kernel, in_len, k_len, stride) → output
    if name == "conv1d" {
        if len(args) < 4 { return val_array([]) }
        let x = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let k = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let in_len = args[2].int_val
        let k_len = args[3].int_val
        let stride = if len(args) > 4 { args[4].int_val } else { 1 }
        let out_len = (in_len - k_len) / stride + 1
        let mut result = []
        let mut o = 0
        while o < out_len {
            let mut acc = 0.0
            let mut ki = 0
            while ki < k_len {
                let xv = if type_of(x[o * stride + ki]) == "float" { x[o * stride + ki] } else { to_float_val(x[o * stride + ki]) }
                let kv = if type_of(k[ki]) == "float" { k[ki] } else { to_float_val(k[ki]) }
                acc = acc + xv * kv
                ki = ki + 1
            }
            result.push(val_float(acc))
            o = o + 1
        }
        return val_array(result)
    }
    // lora_init(in_dim, out_dim, rank) → [A, B]
    if name == "lora_init" {
        if len(args) < 3 { return val_array([]) }
        let ind = args[0].int_val
        let outd = args[1].int_val
        let rank = args[2].int_val
        let std = sqrt(1.0 / rank)
        let mut a = []
        let mut i = 0
        while i < rank * ind {
            // simple deterministic hash for reproducibility
            let h = ((i * 2654435761) % 10000) / 10000.0 - 0.5
            a.push(val_float(h * 2.0 * std))
            i = i + 1
        }
        let mut b = []
        i = 0
        while i < outd * rank { b.push(val_float(0.0)); i = i + 1 }
        return val_array([val_array(a), val_array(b)])
    }
    // lora_forward(x, W, A, B, in_dim, out_dim, rank, alpha)
    if name == "lora_forward" {
        if len(args) < 8 { return val_array([]) }
        let x = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let w = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let a = if args[2].tag == TAG_TENSOR { tensor_data(args[2]) } else { get_array(args[2]) }
        let b = if args[3].tag == TAG_TENSOR { tensor_data(args[3]) } else { get_array(args[3]) }
        let ind = args[4].int_val
        let outd = args[5].int_val
        let rank = args[6].int_val
        let alpha = to_float_val(args[7])
        // base = W @ x  [outd]
        let mut base = []
        let mut r = 0
        while r < outd {
            let mut acc = 0.0
            let mut c = 0
            while c < ind {
                let wv = if type_of(w[r * ind + c]) == "float" { w[r * ind + c] } else { to_float_val(w[r * ind + c]) }
                let xv = if type_of(x[c]) == "float" { x[c] } else { to_float_val(x[c]) }
                acc = acc + wv * xv
                c = c + 1
            }
            base.push(acc)
            r = r + 1
        }
        // ax = A @ x  [rank]
        let mut ax = []
        r = 0
        while r < rank {
            let mut acc = 0.0
            let mut c = 0
            while c < ind {
                let av = if type_of(a[r * ind + c]) == "float" { a[r * ind + c] } else { to_float_val(a[r * ind + c]) }
                let xv = if type_of(x[c]) == "float" { x[c] } else { to_float_val(x[c]) }
                acc = acc + av * xv
                c = c + 1
            }
            ax.push(acc)
            r = r + 1
        }
        // base += alpha * (B @ ax)
        r = 0
        while r < outd {
            let mut delta = 0.0
            let mut c = 0
            while c < rank {
                let bv = if type_of(b[r * rank + c]) == "float" { b[r * rank + c] } else { to_float_val(b[r * rank + c]) }
                delta = delta + bv * ax[c]
                c = c + 1
            }
            base[r] = base[r] + alpha * delta
            r = r + 1
        }
        let mut result = []
        for v in base { result.push(val_float(v)) }
        return val_array(result)
    }
    // cosine_sim_matrix(hiddens, n, dim) → [n*n] flat similarity matrix
    if name == "cosine_sim_matrix" {
        if len(args) < 3 { return val_array([]) }
        let h = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let n = args[1].int_val
        let dim = args[2].int_val
        let mut result = []
        let mut i = 0
        while i < n {
            let mut j = 0
            while j < n {
                let mut dot = 0.0
                let mut ni = 0.0
                let mut nj = 0.0
                let mut d = 0
                while d < dim {
                    let vi = if type_of(h[i * dim + d]) == "float" { h[i * dim + d] } else { to_float_val(h[i * dim + d]) }
                    let vj = if type_of(h[j * dim + d]) == "float" { h[j * dim + d] } else { to_float_val(h[j * dim + d]) }
                    dot = dot + vi * vj
                    ni = ni + vi * vi
                    nj = nj + vj * vj
                    d = d + 1
                }
                let denom = sqrt(ni) * sqrt(nj)
                if denom == 0.0 { result.push(val_float(0.0)) }
                else { result.push(val_float(dot / denom)) }
                j = j + 1
            }
            i = i + 1
        }
        return val_array(result)
    }
    // ── Phase 14 골화 — 수론/수학/유틸 ──
    // sigma(n) — sum of divisors
    if name == "sigma" {
        if len(args) == 0 { return val_int(0) }
        let n = args[0].int_val
        if n <= 0 { return val_int(0) }
        let mut s = 0
        let mut d = 1
        while d * d <= n {
            if n % d == 0 {
                s = s + d
                if d != n / d { s = s + n / d }
            }
            d = d + 1
        }
        return val_int(s)
    }
    // tau(n) — number of divisors
    if name == "tau" {
        if len(args) == 0 { return val_int(0) }
        let n = args[0].int_val
        if n <= 0 { return val_int(0) }
        let mut t = 0
        let mut d = 1
        while d * d <= n {
            if n % d == 0 {
                t = t + 1
                if d != n / d { t = t + 1 }
            }
            d = d + 1
        }
        return val_int(t)
    }
    // sopfr(n) — sum of prime factors with repetition
    if name == "sopfr" {
        if len(args) == 0 { return val_int(0) }
        let mut n = args[0].int_val
        if n <= 1 { return val_int(0) }
        let mut s = 0
        let mut p = 2
        while p * p <= n {
            // decreases n — n shrinks by factor p each iter
            while n % p == 0 {
                s = s + p
                n = n / p
            }
            p = p + 1
        }
        if n > 1 { s = s + n }
        return val_int(s)
    }
    // mean(arr)
    if name == "mean" {
        if len(args) == 0 { return val_float(0.0) }
        let arr = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        if len(arr) == 0 { return val_float(0.0) }
        let mut total = 0.0
        for v in arr { total = total + (if type_of(v) == "float" { v } else { to_float_val(v) }) }
        return val_float(total / len(arr))
    }
    // normalize(arr) — divide by L2 norm
    if name == "normalize" {
        if len(args) == 0 { return val_array([]) }
        let arr = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let mut sq = 0.0
        for v in arr {
            let f = if type_of(v) == "float" { v } else { to_float_val(v) }
            sq = sq + f * f
        }
        let norm = sqrt(sq)
        if norm == 0.0 { return args[0] }
        let mut result = []
        for v in arr {
            let f = if type_of(v) == "float" { v } else { to_float_val(v) }
            result.push(val_float(f / norm))
        }
        if args[0].tag == TAG_TENSOR {
            // ω-stdlib-6 fix: was returning a dummy single-element tensor,
            // discarding the normalized vector. Thread `result` through.
            let mut raw_out = []
            for w in result { raw_out.push(w.float_val) }
            return val_tensor(tensor_shape(args[0]), raw_out)
        }
        return val_array(result)
    }
    // matmul(a, b, m, n, k) — general matmul
    if name == "matmul" {
        if len(args) < 5 { return val_array([]) }
        let a = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let b = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let m = args[2].int_val
        let n = args[3].int_val
        let k = args[4].int_val
        let mut out = []
        let mut mi = 0
        while mi < m {
            let mut nj = 0
            while nj < n {
                let mut acc = 0.0
                let mut kk = 0
                while kk < k {
                    let av = if type_of(a[mi * k + kk]) == "float" { a[mi * k + kk] } else { to_float_val(a[mi * k + kk]) }
                    let bv = if type_of(b[kk * n + nj]) == "float" { b[kk * n + nj] } else { to_float_val(b[kk * n + nj]) }
                    acc = acc + av * bv
                    kk = kk + 1
                }
                out.push(val_float(acc))
                nj = nj + 1
            }
            mi = mi + 1
        }
        return val_array(out)
    }
    // matvec(W, x, rows, cols)
    if name == "matvec" {
        if len(args) < 4 { return val_array([]) }
        let w = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let x = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let rows = args[2].int_val
        let cols = args[3].int_val
        let mut out = []
        let mut r = 0
        while r < rows {
            let mut acc = 0.0
            let mut c = 0
            while c < cols {
                let wv = if type_of(w[r * cols + c]) == "float" { w[r * cols + c] } else { to_float_val(w[r * cols + c]) }
                let xv = if type_of(x[c]) == "float" { x[c] } else { to_float_val(x[c]) }
                acc = acc + wv * xv
                c = c + 1
            }
            out.push(val_float(acc))
            r = r + 1
        }
        return val_array(out)
    }
    // hadamard(a, b) — element-wise product
    if name == "hadamard" {
        if len(args) < 2 { return val_array([]) }
        let a = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let b = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let n = if len(a) < len(b) { len(a) } else { len(b) }
        let mut out = []
        let mut i = 0
        while i < n {
            let av = if type_of(a[i]) == "float" { a[i] } else { to_float_val(a[i]) }
            let bv = if type_of(b[i]) == "float" { b[i] } else { to_float_val(b[i]) }
            out.push(val_float(av * bv))
            i = i + 1
        }
        return val_array(out)
    }
    // one_hot(idx, n) → [n] vector with 1.0 at idx
    if name == "one_hot" {
        if len(args) < 2 { return val_array([]) }
        let idx = args[0].int_val
        let n = args[1].int_val
        let mut out = []
        let mut i = 0
        while i < n {
            if i == idx { out.push(val_float(1.0)) }
            else { out.push(val_float(0.0)) }
            i = i + 1
        }
        return val_array(out)
    }
    // topk(arr, k) — top-k indices (descending by value)
    if name == "topk" {
        if len(args) < 2 { return val_array([]) }
        let arr = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let k = args[1].int_val
        let mut indices = []
        let mut values = []
        let mut i = 0
        while i < len(arr) {
            indices.push(i)
            let v = if type_of(arr[i]) == "float" { arr[i] } else { to_float_val(arr[i]) }
            values.push(v)
            i = i + 1
        }
        // simple selection: pick max k times
        let mut result = []
        let mut picked = 0
        while picked < k && picked < len(arr) {
            let mut best = -1
            let mut best_v = 0.0 - 1000000000.0
            let mut j = 0
            while j < len(indices) {
                if indices[j] >= 0 && values[j] > best_v { best = j; best_v = values[j] }
                j = j + 1
            }
            if best < 0 { picked = k }
            else {
                result.push(val_int(indices[best]))
                indices[best] = -1
                picked = picked + 1
            }
        }
        return val_array(result)
    }
    // shuffle(arr) — random permutation (Fisher-Yates)
    if name == "shuffle" {
        if len(args) == 0 { return val_array([]) }
        let arr = get_array(args[0])
        let n = len(arr)
        let mut result = []
        for v in arr { result.push(v) }
        let mut i = n - 1
        while i > 0 {
            let j = floor(random() * (i + 1))
            let tmp = result[i]
            result[i] = result[j]
            result[j] = tmp
            i = i - 1
        }
        return val_array(result)
    }
    // randn() — normal random ~ N(0,1) (Box-Muller, simplified)
    if name == "randn" {
        let u1 = random()
        let u2 = random()
        let safe_u1 = if u1 < 0.000001 { 0.000001 } else { u1 }
        let z = sqrt(0.0 - 2.0 * ln(safe_u1)) * cos(2.0 * 3.14159265358979 * u2)
        return val_float(z)
    }
    if name == "random_int" {
        // ω-stdlib-13: tag-guard added — string/void args previously coerced
        // to silent 0 via .int_val on non-INT tags, distorting [lo,hi).
        if len(args) < 2 { return val_int(0) }
        if args[0].tag != TAG_INT || args[1].tag != TAG_INT { return val_int(0) }
        let lo = args[0].int_val
        let hi = args[1].int_val
        if hi <= lo { return val_int(lo) }
        let r = lo + floor(random() * (hi - lo))
        return val_int(r)
    }
    // hex_encode(s) → hex string
    if name == "hex_encode" {
        if len(args) == 0 { return val_str("") }
        let s = args[0].str_val
        let mut out = ""
        let cs = s.chars()
        for c in cs {
            let code = char_code(to_string(c), 0)
            out = out + hex(code).pad_left(2, "0")
        }
        return val_str(out)
    }
    // hex_decode(hex_str) → string (reverse of hex_encode, simplified)
    if name == "hex_decode" {
        if len(args) == 0 { return val_str("") }
        let s = args[0].str_val
        let n = len(s) / 2
        let mut out = ""
        let mut i = 0
        while i < n {
            let pair = s.substring(i * 2, i * 2 + 2)
            // simple hex parse (assume 2-char pairs)
            try {
                let code = to_int("0x" + pair)
                out = out + to_string(code)
            } catch e {
                // skip invalid
            }
            i = i + 1
        }
        return val_str(out)
    }
    // bytes_encode(s) → array of byte ints
    if name == "bytes_encode" {
        if len(args) == 0 { return val_array([]) }
        let s = args[0].str_val
        let cs = s.chars()
        let mut result = []
        for c in cs { result.push(val_int(char_code(to_string(c), 0))) }
        return val_array(result)
    }
    // bytes_decode(bytes_arr) → string
    if name == "bytes_decode" {
        if len(args) == 0 { return val_str("") }
        let arr = get_array(args[0])
        let mut out = ""
        for b in arr { out = out + to_string(b.int_val) }
        return val_str(out)
    }
    // log(base, x) — alias log_b(x); also log(x) = ln(x)
    if name == "log" {
        if len(args) == 0 { return val_float(0.0) }
        if len(args) == 1 { return val_float(ln(to_float_val(args[0]))) }
        let base = to_float_val(args[0])
        let x = to_float_val(args[1])
        return val_float(ln(x) / ln(base))
    }
    // print_err — alias eprintln
    if name == "print_err" {
        let mut out = ""
        for a in args { out = out + val_to_string(a) }
        try { eprintln(out) } catch e { println("[print_err] " + e.to_string()) }
        return val_void()
    }
    // timestamp / now / time_elapsed
    // hxa-20260424-008: time_now is an alias for timestamp — nexus
    // bisociation/convergence_index.hexa L225/L245 emit to_string(time_now())
    // as the "ts" JSON field. Runtime.c already declares hexa_timestamp();
    // interp merely needs the name to resolve here instead of falling
    // through to "unknown builtin".
    if name == "timestamp" || name == "now" || name == "time_now" {
        return val_int(timestamp())
    }
    if name == "time_elapsed" {
        // ω-stdlib-13: tag-guard added — string args silently produced
        // garbage diff via .int_val on TAG_STR.
        if len(args) == 0 { return val_int(0) }
        if args[0].tag != TAG_INT { return val_int(0) }
        return val_int(timestamp() - args[0].int_val)
    }
    // time_ms / now_monotonic_s / sleep_s (runtime.c parity — 2026-04-19)
    if name == "time_ms" {
        return val_int(time_ms())
    }
    if name == "now_monotonic_s" {
        return val_float(now_monotonic_s())
    }
    if name == "sleep_s" {
        if len(args) == 0 { return val_void() }
        sleep_s(args[0])
        return val_void()
    }
    // TUI-PRIM L1 (kick T1.A) — interpreter dispatch DEFERRED.
    // The raw POSIX wrappers in self/native/term_ffi.c expose plain-C
    // signatures (int-returning), but interpreter dispatch needs HexaVal-
    // returning shims. The codegen_c2 / build_c / env / runtime.c path
    // already covers AOT-compiled `term_*` calls (canonical dogfood
    // surface). Adding interpreter-side dispatch needs a separate set of
    // val_int(hexa_term_*()) → HexaVal proxies that strip the HexaVal
    // wrapping; deferring until L2 needs interactive interp dogfood.
    // utc_iso_now / utc_compact_now — UTC wall-clock formatters
    if name == "utc_iso_now" {
        return val_str(utc_iso_now())
    }
    // G4-ISO8601 2026-05-06 (.roadmap.stdlib.G4) — format/parse mirrors.
    if name == "utc_iso_format" {
        if len(args) == 0 { return val_str("") }
        return val_str(utc_iso_format(args[0].int_val))
    }
    if name == "utc_iso_parse" {
        if len(args) == 0 { return val_int(0) }
        return val_int(utc_iso_parse(args[0].str_val))
    }
    if name == "utc_compact_now" {
        return val_str(utc_compact_now())
    }
    // to_bool — universal truthy coercion
    if name == "to_bool" {
        if len(args) == 0 { return val_bool(false) }
        return val_bool(to_bool(args[0]))
    }
    // byte_len — utf8-aware byte count (string/array/map)
    if name == "byte_len" {
        if len(args) == 0 { return val_int(0) }
        return val_int(byte_len(args[0]))
    }
    // model_size_kb(byte_count) → KB
    if name == "model_size_kb" {
        if len(args) == 0 { return val_float(0.0) }
        return val_float(args[0].int_val / 1024.0)
    }
    // ── ML extras ──
    // rms_norm(x, dim, eps?) — RMS normalization
    if name == "rms_norm" {
        if len(args) < 2 { return val_array([]) }
        let x = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let dim = args[1].int_val
        let eps = if len(args) > 2 { to_float_val(args[2]) } else { 0.000001 }
        let n_samples = len(x) / dim
        let mut result = []
        let mut s = 0
        while s < n_samples {
            let base = s * dim
            let mut sq = 0.0
            let mut d = 0
            while d < dim {
                let v = if type_of(x[base + d]) == "float" { x[base + d] } else { to_float_val(x[base + d]) }
                sq = sq + v * v
                d = d + 1
            }
            let rms = sqrt(sq / dim + eps)
            d = 0
            while d < dim {
                let v = if type_of(x[base + d]) == "float" { x[base + d] } else { to_float_val(x[base + d]) }
                result.push(val_float(v / rms))
                d = d + 1
            }
            s = s + 1
        }
        return val_array(result)
    }
    // xavier_init(in_dim, out_dim) — Glorot init
    if name == "xavier_init" {
        if len(args) < 2 { return val_array([]) }
        let ind = args[0].int_val
        let outd = args[1].int_val
        let std = sqrt(2.0 / (ind + outd))
        let mut result = []
        let mut i = 0
        while i < ind * outd {
            let h = ((i * 2654435761) % 10000) / 10000.0 - 0.5
            result.push(val_float(h * 2.0 * std))
            i = i + 1
        }
        return val_array(result)
    }
    // kaiming_init(in_dim, out_dim) — He init
    if name == "kaiming_init" {
        if len(args) < 2 { return val_array([]) }
        let ind = args[0].int_val
        let outd = args[1].int_val
        let std = sqrt(2.0 / ind)
        let mut result = []
        let mut i = 0
        while i < ind * outd {
            let h = ((i * 2654435761) % 10000) / 10000.0 - 0.5
            result.push(val_float(h * 2.0 * std))
            i = i + 1
        }
        return val_array(result)
    }
    // sgd_step(params, grads, lr)
    if name == "sgd_step" {
        if len(args) < 3 { return val_array([]) }
        let p = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let g = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let lr = to_float_val(args[2])
        let n = if len(p) < len(g) { len(p) } else { len(g) }
        let mut result = []
        let mut i = 0
        while i < n {
            let pf = if type_of(p[i]) == "float" { p[i] } else { to_float_val(p[i]) }
            let gf = if type_of(g[i]) == "float" { g[i] } else { to_float_val(g[i]) }
            result.push(val_float(pf - lr * gf))
            i = i + 1
        }
        return val_array(result)
    }
    // weight_decay(params, decay)
    if name == "weight_decay" {
        if len(args) < 2 { return val_array([]) }
        let p = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let decay = to_float_val(args[1])
        let mut result = []
        for v in p {
            let f = if type_of(v) == "float" { v } else { to_float_val(v) }
            result.push(val_float(f * (1.0 - decay)))
        }
        return val_array(result)
    }
    // kl_divergence(p, q) — KL(p || q)
    if name == "kl_divergence" {
        if len(args) < 2 { return val_float(0.0) }
        let p = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let q = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let n = if len(p) < len(q) { len(p) } else { len(q) }
        let mut total = 0.0
        let mut i = 0
        while i < n {
            let pv = if type_of(p[i]) == "float" { p[i] } else { to_float_val(p[i]) }
            let qv = if type_of(q[i]) == "float" { q[i] } else { to_float_val(q[i]) }
            if pv > 0.0 && qv > 0.0 { total = total + pv * ln(pv / qv) }
            i = i + 1
        }
        return val_float(total)
    }
    // js_divergence(p, q) — symmetric Jensen-Shannon
    if name == "js_divergence" {
        if len(args) < 2 { return val_float(0.0) }
        let p = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let q = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let n = if len(p) < len(q) { len(p) } else { len(q) }
        let mut total = 0.0
        let mut i = 0
        while i < n {
            let pv = if type_of(p[i]) == "float" { p[i] } else { to_float_val(p[i]) }
            let qv = if type_of(q[i]) == "float" { q[i] } else { to_float_val(q[i]) }
            let m = 0.5 * (pv + qv)
            if pv > 0.0 && m > 0.0 { total = total + 0.5 * pv * ln(pv / m) }
            if qv > 0.0 && m > 0.0 { total = total + 0.5 * qv * ln(qv / m) }
            i = i + 1
        }
        return val_float(total)
    }
    // grad_clip_norm(grads, max_norm)
    if name == "grad_clip_norm" {
        if len(args) < 2 { return val_array([]) }
        let g = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let max_norm = to_float_val(args[1])
        let mut sq = 0.0
        for v in g {
            let f = if type_of(v) == "float" { v } else { to_float_val(v) }
            sq = sq + f * f
        }
        let total_norm = sqrt(sq)
        if total_norm <= max_norm { return args[0] }
        let scale = max_norm / total_norm
        let mut result = []
        for v in g {
            let f = if type_of(v) == "float" { v } else { to_float_val(v) }
            result.push(val_float(f * scale))
        }
        return val_array(result)
    }
    // numerical_grad — finite difference (placeholder, requires fn pointer)
    if name == "numerical_grad" {
        return val_array([])
    }
    // sinusoidal_pe(seq_len, dim) — sinusoidal positional encoding
    if name == "sinusoidal_pe" {
        if len(args) < 2 { return val_array([]) }
        let seq = args[0].int_val
        let dim = args[1].int_val
        let mut result = []
        let mut pos = 0
        while pos < seq {
            let mut d = 0
            while d < dim {
                let dpf = (d / 2) * 2 + 0.0
                let divisor = pow(10000.0, dpf / dim)
                let theta = pos / divisor
                if d % 2 == 0 { result.push(val_float(sin(theta))) }
                else { result.push(val_float(cos(theta))) }
                d = d + 1
            }
            pos = pos + 1
        }
        return val_array(result)
    }
    // label_smoothing(target_idx, n_classes, eps) → smoothed distribution
    if name == "label_smoothing" {
        if len(args) < 3 { return val_array([]) }
        let target = args[0].int_val
        let n = args[1].int_val
        let eps = to_float_val(args[2])
        let mut result = []
        let mut i = 0
        while i < n {
            if i == target { result.push(val_float(1.0 - eps + eps / n)) }
            else { result.push(val_float(eps / n)) }
            i = i + 1
        }
        return val_array(result)
    }
    // mse_loss — alias mse
    if name == "mse_loss" {
        if len(args) < 2 { return val_float(0.0) }
        let p = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let t = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let n = if len(p) < len(t) { len(p) } else { len(t) }
        if n == 0 { return val_float(0.0) }
        let mut total = 0.0
        let mut i = 0
        while i < n {
            let pf = if type_of(p[i]) == "float" { p[i] } else { to_float_val(p[i]) }
            let tf = if type_of(t[i]) == "float" { t[i] } else { to_float_val(t[i]) }
            let d = pf - tf
            total = total + d * d
            i = i + 1
        }
        return val_float(total / n)
    }

    // ── Phase 15 골화 — KV-cache / RoPE / multi-head / etc ──
    // KV-cache: registry of [shape_data, data, write_pos] per cache
    // (single-stream interpreter — no real concurrency, just bookkeeping)
    if name == "kv_cache_init" {
        // kv_cache_init(max_len, n_kv_head, head_dim) → cache (tensor wrapper)
        if len(args) < 3 { return val_void() }
        let max_len = args[0].int_val
        let n_kv = args[1].int_val
        let head_dim = args[2].int_val
        let total = max_len * n_kv * head_dim
        let mut data = []
        let mut i = 0
        while i < total { data.push(0.0); i = i + 1 }
        return val_tensor([max_len, n_kv, head_dim], data)
    }
    if name == "kv_cache_reset" {
        // Reset cache to zeros (in-place fill)
        if len(args) == 0 { return val_void() }
        let cache = args[0]
        if cache.tag != TAG_TENSOR { return val_void() }
        let n = tensor_numel(cache)
        let mut data = []
        let mut i = 0
        while i < n { data.push(0.0); i = i + 1 }
        tensor_set_data(cache, data)
        return cache
    }
    if name == "kv_cache_append" {
        // kv_cache_append(cache, k, v, pos) — write at row `pos`
        if len(args) < 4 { return val_void() }
        let cache = args[0]
        let k_in = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let pos = args[3].int_val
        if cache.tag != TAG_TENSOR { return val_void() }
        let shape = tensor_shape(cache)
        if len(shape) < 3 { return val_void() }
        let head_dim = shape[2]
        let n_kv = shape[1]
        let row_size = n_kv * head_dim
        let mut data = tensor_data(cache)
        let base = pos * row_size
        let mut d = 0
        while d < row_size && d < len(k_in) {
            let v = if type_of(k_in[d]) == "float" { k_in[d] } else { to_float_val(k_in[d]) }
            data[base + d] = v
            d = d + 1
        }
        tensor_set_data(cache, data)
        return cache
    }
    if name == "kv_cache_decode" {
        // kv_cache_decode(cache, q, pos, n_kv_head, head_dim) → output [head_dim]
        // Single-step decode: attend to all positions <= pos
        if len(args) < 5 { return val_array([]) }
        let cache = args[0]
        let q = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let pos = args[2].int_val
        let n_kv = args[3].int_val
        let head_dim = args[4].int_val
        if cache.tag != TAG_TENSOR { return val_array([]) }
        // ω-stdlib-6 fix: pos < 0 left scores empty; subsequent
        // scores[0] indexing crashed. Treat negative pos as NULL-RESULT.
        if pos < 0 { return val_array([]) }
        let cd = tensor_data(cache)
        let row_size = n_kv * head_dim
        let scale = 1.0 / sqrt(head_dim + 0.0)
        // scores[i] = q · K[i] * scale
        let mut scores = []
        let mut i = 0
        while i <= pos {
            let mut dot = 0.0
            let mut d = 0
            while d < head_dim {
                let qv = if type_of(q[d]) == "float" { q[d] } else { to_float_val(q[d]) }
                let kv = cd[i * row_size + d]
                dot = dot + qv * kv
                d = d + 1
            }
            scores.push(dot * scale)
            i = i + 1
        }
        // softmax
        let mut max_s = scores[0]
        for s in scores { if s > max_s { max_s = s } }
        let mut exps = []
        let mut sum_e = 0.0
        for s in scores {
            let e = exp(s - max_s)
            exps.push(e)
            sum_e = sum_e + e
        }
        let mut output = []
        let mut d = 0
        while d < head_dim {
            let mut val = 0.0
            i = 0
            while i <= pos {
                let w = exps[i] / sum_e
                let vv = cd[i * row_size + d]
                val = val + w * vv
                i = i + 1
            }
            output.push(val_float(val))
            d = d + 1
        }
        return val_array(output)
    }
    if name == "kv_cache_decode_bench" {
        return val_int(0)
    }

    // rope(x, pos, dim) — Rotary Position Embedding (single token)
    //   x: input vector [dim], pos: token position, dim: embedding dim
    //   Pairs (x[2i], x[2i+1]) rotated by angle = pos / 10000^(2i/dim)
    if name == "rope" || name == "rope_inplace" {
        if len(args) < 3 { return val_array([]) }
        let x = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let pos = args[1].int_val
        let dim = args[2].int_val
        let mut result = []
        let mut i = 0
        while i < dim - 1 {
            let exponent = (i + 0.0) / dim
            let theta = pos / pow(10000.0, exponent)
            let c = cos(theta)
            let s = sin(theta)
            let x0 = if type_of(x[i]) == "float" { x[i] } else { to_float_val(x[i]) }
            let x1 = if type_of(x[i + 1]) == "float" { x[i + 1] } else { to_float_val(x[i + 1]) }
            result.push(val_float(x0 * c - x1 * s))
            result.push(val_float(x0 * s + x1 * c))
            i = i + 2
        }
        // remainder if dim is odd
        if i < dim {
            result.push(val_float(if type_of(x[i]) == "float" { x[i] } else { to_float_val(x[i]) }))
        }
        return val_array(result)
    }

    // multi_head_attention(Q, K, V, seq, n_heads, head_dim, causal?)
    if name == "multi_head_attention" {
        if len(args) < 6 { return val_array([]) }
        let q_all = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let k_all = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let v_all = if args[2].tag == TAG_TENSOR { tensor_data(args[2]) } else { get_array(args[2]) }
        let seq = args[3].int_val
        let n_h = args[4].int_val
        let head_dim = args[5].int_val
        let causal = if len(args) > 6 { args[6].bool_val } else { false }
        let scale = 1.0 / sqrt(head_dim + 0.0)
        let dim = n_h * head_dim
        let mut output = []
        let mut h = 0
        while h < n_h {
            let h_off = h * head_dim
            let mut qh = []
            let mut kh = []
            let mut vh = []
            // extract head h from each token
            let mut t = 0
            while t < seq {
                let mut d = 0
                while d < head_dim {
                    let qv = if type_of(q_all[t * dim + h_off + d]) == "float" { q_all[t * dim + h_off + d] } else { to_float_val(q_all[t * dim + h_off + d]) }
                    let kv = if type_of(k_all[t * dim + h_off + d]) == "float" { k_all[t * dim + h_off + d] } else { to_float_val(k_all[t * dim + h_off + d]) }
                    let vv = if type_of(v_all[t * dim + h_off + d]) == "float" { v_all[t * dim + h_off + d] } else { to_float_val(v_all[t * dim + h_off + d]) }
                    qh.push(qv)
                    kh.push(kv)
                    vh.push(vv)
                    d = d + 1
                }
                t = t + 1
            }
            // attention within this head
            let mut head_out = []
            t = 0
            while t < seq {
                let mut scores = []
                let mut j = 0
                while j < seq {
                    if causal && j > t {
                        scores.push(0.0 - 1000000000.0)
                    } else {
                        let mut dot = 0.0
                        let mut d = 0
                        while d < head_dim {
                            dot = dot + qh[t * head_dim + d] * kh[j * head_dim + d]
                            d = d + 1
                        }
                        scores.push(dot * scale)
                    }
                    j = j + 1
                }
                let mut max_s = scores[0]
                for s in scores { if s > max_s { max_s = s } }
                let mut exps = []
                let mut sum_e = 0.0
                for s in scores {
                    let e = exp(s - max_s)
                    exps.push(e)
                    sum_e = sum_e + e
                }
                let mut d = 0
                while d < head_dim {
                    let mut val = 0.0
                    j = 0
                    while j < seq {
                        val = val + (exps[j] / sum_e) * vh[j * head_dim + d]
                        j = j + 1
                    }
                    head_out.push(val)
                    d = d + 1
                }
                t = t + 1
            }
            // assemble output (interleave heads back)
            t = 0
            while t < seq {
                let mut d = 0
                while d < head_dim {
                    output.push(val_float(head_out[t * head_dim + d]))
                    d = d + 1
                }
                t = t + 1
            }
            h = h + 1
        }
        return val_array(output)
    }

    // grouped_query_attention — wraps multi_head with KV grouping
    if name == "grouped_query_attention" {
        return val_array([])
    }
    // sliding_window_attention(Q, K, V, seq, dim, window)
    if name == "sliding_window_attention" {
        if len(args) < 6 { return val_array([]) }
        let q = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let k = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let v = if args[2].tag == TAG_TENSOR { tensor_data(args[2]) } else { get_array(args[2]) }
        let seq = args[3].int_val
        let dim = args[4].int_val
        let window = args[5].int_val
        let scale = 1.0 / sqrt(dim + 0.0)
        let mut output = []
        let mut i = 0
        while i < seq {
            let lo = if i - window < 0 { 0 } else { i - window }
            let mut scores = []
            let mut j = lo
            while j <= i {
                let mut dot = 0.0
                let mut d = 0
                while d < dim {
                    let qv = if type_of(q[i * dim + d]) == "float" { q[i * dim + d] } else { to_float_val(q[i * dim + d]) }
                    let kv = if type_of(k[j * dim + d]) == "float" { k[j * dim + d] } else { to_float_val(k[j * dim + d]) }
                    dot = dot + qv * kv
                    d = d + 1
                }
                scores.push(dot * scale)
                j = j + 1
            }
            let mut max_s = scores[0]
            for s in scores { if s > max_s { max_s = s } }
            let mut exps = []
            let mut sum_e = 0.0
            for s in scores { let e = exp(s - max_s); exps.push(e); sum_e = sum_e + e }
            let mut d = 0
            while d < dim {
                let mut val = 0.0
                let mut idx = 0
                j = lo
                while j <= i {
                    let vv = if type_of(v[j * dim + d]) == "float" { v[j * dim + d] } else { to_float_val(v[j * dim + d]) }
                    val = val + (exps[idx] / sum_e) * vv
                    idx = idx + 1
                    j = j + 1
                }
                output.push(val_float(val))
                d = d + 1
            }
            i = i + 1
        }
        return val_array(output)
    }

    // group_norm(x, n_groups, dim) — normalize per group
    if name == "group_norm" {
        if len(args) < 3 { return val_array([]) }
        let x = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let n_groups = args[1].int_val
        let dim = args[2].int_val
        let group_size = dim / n_groups
        let n_samples = len(x) / dim
        let mut result = []
        let mut s = 0
        while s < n_samples {
            let mut g = 0
            while g < n_groups {
                let base = s * dim + g * group_size
                let mut mean = 0.0
                let mut k = 0
                while k < group_size {
                    let v = if type_of(x[base + k]) == "float" { x[base + k] } else { to_float_val(x[base + k]) }
                    mean = mean + v
                    k = k + 1
                }
                mean = mean / group_size
                let mut var = 0.0
                k = 0
                while k < group_size {
                    let v = if type_of(x[base + k]) == "float" { x[base + k] } else { to_float_val(x[base + k]) }
                    var = var + (v - mean) * (v - mean)
                    k = k + 1
                }
                var = var / group_size
                let denom = sqrt(var + 0.00001)
                k = 0
                while k < group_size {
                    let v = if type_of(x[base + k]) == "float" { x[base + k] } else { to_float_val(x[base + k]) }
                    result.push(val_float((v - mean) / denom))
                    k = k + 1
                }
                g = g + 1
            }
            s = s + 1
        }
        return val_array(result)
    }

    // max_pool1d(x, kernel_size, stride)
    if name == "max_pool1d" {
        if len(args) < 3 { return val_array([]) }
        let x = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let k = args[1].int_val
        let stride = args[2].int_val
        let n = len(x)
        let out_n = (n - k) / stride + 1
        let mut result = []
        let mut o = 0
        while o < out_n {
            let mut best = if type_of(x[o * stride]) == "float" { x[o * stride] } else { to_float_val(x[o * stride]) }
            let mut i = 1
            while i < k {
                let v = if type_of(x[o * stride + i]) == "float" { x[o * stride + i] } else { to_float_val(x[o * stride + i]) }
                if v > best { best = v }
                i = i + 1
            }
            result.push(val_float(best))
            o = o + 1
        }
        return val_array(result)
    }

    // gru_cell(x, h, Wxr, Whr, Wxz, Whz, Wxn, Whn) — simplified GRU
    if name == "gru_cell" {
        // 8-arg signature, returns new hidden state. Skip if args insufficient.
        return val_array([])
    }

    // moe_gate(x, gates, n_experts) → top-1 expert index + softmax weight
    if name == "moe_gate" {
        if len(args) < 3 { return val_array([]) }
        let g = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let n_experts = args[2].int_val
        // softmax over gates
        let mut max_g = if type_of(g[0]) == "float" { g[0] } else { to_float_val(g[0]) }
        let mut i = 0
        while i < n_experts {
            let v = if type_of(g[i]) == "float" { g[i] } else { to_float_val(g[i]) }
            if v > max_g { max_g = v }
            i = i + 1
        }
        let mut exps = []
        let mut sum_e = 0.0
        i = 0
        while i < n_experts {
            let v = if type_of(g[i]) == "float" { g[i] } else { to_float_val(g[i]) }
            let e = exp(v - max_g)
            exps.push(e)
            sum_e = sum_e + e
            i = i + 1
        }
        // pick max
        let mut best = 0
        let mut best_p = exps[0] / sum_e
        i = 1
        while i < n_experts {
            let p = exps[i] / sum_e
            if p > best_p { best = i; best_p = p }
            i = i + 1
        }
        return val_array([val_int(best), val_float(best_p)])
    }
    if name == "moe_combine" {
        // moe_combine(expert_outputs, weights) — weighted sum
        if len(args) < 2 { return val_array([]) }
        let outs = get_array(args[0])
        let ws = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        if len(outs) == 0 { return val_array([]) }
        let first = if outs[0].tag == TAG_TENSOR { tensor_data(outs[0]) } else { get_array(outs[0]) }
        let dim = len(first)
        // ω-stdlib-6 fix: weights shorter than experts caused ws[e]
        // out-of-bounds. Cap iteration to min(len(outs), len(ws)) — missing
        // weights are zero (NULL-RESULT for that expert).
        let n_exp = if len(outs) < len(ws) { len(outs) } else { len(ws) }
        let mut result = []
        let mut d = 0
        while d < dim {
            let mut acc = 0.0
            let mut e = 0
            while e < n_exp {
                let exp_data = if outs[e].tag == TAG_TENSOR { tensor_data(outs[e]) } else { get_array(outs[e]) }
                let v = if type_of(exp_data[d]) == "float" { exp_data[d] } else { to_float_val(exp_data[d]) }
                let w = if type_of(ws[e]) == "float" { ws[e] } else { to_float_val(ws[e]) }
                acc = acc + w * v
                e = e + 1
            }
            result.push(val_float(acc))
            d = d + 1
        }
        return val_array(result)
    }

    // ── Phase 16 골화 — FFI memory + JSON + utility ──
    // alloc_raw(size) — return Pointer to managed buffer.
    //
    // C2 Step 3 (2026-04-16): when ffi_real_pointer_mode is true the
    // interpreter routes alloc_raw/free_raw/write_f32/deref_f32 to the
    // real-pointer builtins (ptr_alloc / ptr_write_f32 / ptr_read_f32 /
    // ptr_free) so that addresses can be passed to @link extern fns.
    // ROI-4: mode is set once at interpret() init via env_var cache +
    // dlopen auto-detect. Legacy caller pattern (TAG_POINTER +
    // atomic_store registry) is preserved.
    if name == "alloc_raw" {
        if len(args) == 0 { return val_int(0) }
        let size = args[0].int_val
        if size <= 0 { return val_int(0) }
        if ffi_real_pointer_mode {
            let p = ptr_alloc(size)
            return val_int(ptr_addr(p))
        }
        // Use atomic_store as a buffer registry: alloc one cell of zeros
        let mut buf = []
        let mut i = 0
        while i < size { buf.push(val_int(0)); i = i + 1 }
        let id = len(atomic_store)
        atomic_store.push(val_array(buf))
        return val_pointer(id + 1000000)  // managed-registry tag
    }
    if name == "free_raw" {
        if ffi_real_pointer_mode {
            if len(args) >= 1 {
                let p = args[0]
                if p.tag == TAG_INT {
                    let size = if len(args) >= 2 { args[1].int_val } else { 0 }
                    ptr_free(p.int_val, size)
                }
            }
        }
        // Default: No-op in self-host (storage GC'd elsewhere)
        return val_void()
    }
    if name == "arena_reset" {
        return val_void()
    }
    // ── @arena runtime support ──────────────────────────────
    // arena_new() → create a new arena region, return arena id
    if name == "arena_new" {
        let id = len(atomic_store)
        atomic_store.push(val_array([]))
        return val_int(id)
    }
    // arena_alloc(arena_id, value) → allocate value in arena, return value
    if name == "arena_alloc" {
        if len(args) < 2 { return val_void() }
        // Just return the value; arena tracking is semantic (bulk free)
        return args[1]
    }
    // arena_free(arena_id) → bulk free all allocations in arena
    if name == "arena_free" {
        // No-op in interpreter (GC handles memory)
        return val_void()
    }
    // ── @pool runtime support ───────────────────────────────
    // pool_new(capacity) → create a freelist pool, return pool id
    if name == "pool_new" {
        let cap = if len(args) >= 1 { args[0].int_val } else { 64 }
        let mut pool = []
        let mut pi = 0
        while pi < cap {
            pool.push(val_void())
            pi = pi + 1
        }
        let id = len(atomic_store)
        atomic_store.push(val_array(pool))
        return val_int(id)
    }
    // pool_get(pool_id) → get an object from pool (reuse), return value
    if name == "pool_get" {
        if len(args) < 1 { return val_void() }
        // Return void (semantic placeholder; real pool returns recycled object)
        return val_void()
    }
    // pool_put(pool_id, value) → return object to pool for reuse
    if name == "pool_put" {
        // No-op in interpreter (object remains in GC scope)
        return val_void()
    }
    if name == "mem_budget" || name == "mem_stats" {
        // Return [used, total] as array of ints (best-effort: report 0)
        return val_array([val_int(0), val_int(0)])
    }
    if name == "mem_region" {
        return val_void()
    }
    if name == "memcpy_host" {
        // memcpy_host(dst, src, n) — copy n elements
        if len(args) < 3 { return val_void() }
        let n = args[2].int_val
        let src = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        if args[0].tag == TAG_TENSOR {
            let mut data = []
            let mut i = 0
            while i < n && i < len(src) { data.push(src[i]); i = i + 1 }
            tensor_set_data(args[0], data)
        }
        return val_void()
    }
    if name == "deref_f32" || name == "deref_i32" {
        // Read from pointer. TAG_INT = real malloc address (C2 Step 3
        // live-FFI path). TAG_POINTER = legacy atomic_store registry id.
        if len(args) == 0 { return val_int(0) }
        let p = args[0]
        let offset = if len(args) > 1 { args[1].int_val } else { 0 }
        if p.tag == TAG_INT {
            if name == "deref_f32" {
                return val_float(ptr_read_f32(p.int_val, offset))
            }
            return val_int(ptr_read_i32(p.int_val, offset))
        }
        if p.tag != TAG_POINTER { return val_int(0) }
        let id = p.int_val - 1000000
        if id < 0 || id >= len(atomic_store) { return val_int(0) }
        let buf_val = atomic_store[id]
        if buf_val.tag != TAG_ARRAY { return val_int(0) }
        let buf = get_array(buf_val)
        if offset < 0 || offset >= len(buf) { return val_int(0) }
        return buf[offset]
    }
    if name == "write_f32" || name == "write_i32" || name == "write_i64" {
        // write(ptr, offset, value) — TAG_INT = real address, TAG_POINTER = registry.
        if len(args) < 3 { return val_void() }
        let p = args[0]
        let offset = args[1].int_val
        if p.tag == TAG_INT {
            if name == "write_f32" {
                ptr_write_f32(p.int_val, offset, to_float_val(args[2]))
            } else {
                ptr_write_i32(p.int_val, offset, args[2].int_val)
            }
            return val_void()
        }
        if p.tag != TAG_POINTER { return val_void() }
        let id = p.int_val - 1000000
        if id < 0 || id >= len(atomic_store) { return val_void() }
        let buf_val = atomic_store[id]
        if buf_val.tag != TAG_ARRAY { return val_void() }
        let mut buf = get_array(buf_val)
        if offset >= 0 && offset < len(buf) {
            buf[offset] = args[2]
            atomic_store[id] = val_array(buf)
        }
        return val_void()
    }
    if name == "ptr_from_int" {
        if len(args) == 0 { return val_pointer(0) }
        return val_pointer(args[0].int_val)
    }
    if name == "from_cstring_n" {
        // Convert pointer + length to string (best-effort: return as int wrapper)
        if len(args) == 0 { return val_str("") }
        return val_str("")
    }
    if name == "tensor_data_f32_ptr" {
        // Get pointer to underlying tensor data (registry-tagged)
        if len(args) == 0 { return val_pointer(0) }
        let t = args[0]
        if t.tag != TAG_TENSOR { return val_pointer(0) }
        return val_pointer(t.int_val + 2000000)  // tensor-tagged ptr
    }
    if name == "tensor_from_f32_ptr" {
        // Reverse: pointer → tensor
        if len(args) == 0 { return val_tensor([0], []) }
        let p = args[0]
        if p.tag != TAG_POINTER { return val_tensor([0], []) }
        let id = p.int_val - 2000000
        if id < 0 || id >= len(tensor_shape_store) { return val_tensor([0], []) }
        return Val { tag: TAG_TENSOR, int_val: id, float_val: 0.0, bool_val: false, str_val: __E, char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E }
    }

    // ── JSON: proper parse/stringify ──
    if name == "json_stringify" {
        if len(args) == 0 { return val_str("null") }
        return val_str(val_to_json(args[0]))
    }
    if name == "json_parse" {
        if len(args) == 0 { return val_void() }
        return json_to_val(args[0].str_val)
    }

    // ── benchmark / test runner ──
    if name == "bench_fn" {
        // bench_fn(fn, n_iters) → elapsed time in milliseconds
        if len(args) < 2 { return val_int(0) }
        let f = args[0]
        let n = args[1].int_val
        let start_time = timestamp()
        let mut i = 0
        while i < n {
            call_fn_val(f, [])
            i = i + 1
        }
        return val_int(timestamp() - start_time)
    }
    if name == "run_tests" || name == "run_benchmarks" {
        // Self-host stub: actual test harness lives in user code
        return val_int(0)
    }

    // ── ascii visualization ──
    if name == "ascii_bar" {
        // ascii_bar(value, max, width) → string bar
        if len(args) < 3 { return val_str("") }
        let v = to_float_val(args[0])
        let max_v = to_float_val(args[1])
        let width = args[2].int_val
        if max_v <= 0.0 { return val_str("") }
        let n_filled = floor(v / max_v * width)
        let mut out = ""
        let mut i = 0
        while i < n_filled { out = out + "█"; i = i + 1 }
        while i < width { out = out + "·"; i = i + 1 }
        return val_str(out)
    }
    if name == "ascii_plot" {
        // ascii_plot(values, height) → multi-line string
        if len(args) == 0 { return val_str("") }
        let values = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let height = if len(args) > 1 { args[1].int_val } else { 10 }
        let n = len(values)
        if n == 0 { return val_str("") }
        let mut max_v = if type_of(values[0]) == "float" { values[0] } else { to_float_val(values[0]) }
        let mut min_v = max_v
        for v in values {
            let f = if type_of(v) == "float" { v } else { to_float_val(v) }
            if f > max_v { max_v = f }
            if f < min_v { min_v = f }
        }
        let range = max_v - min_v
        if range == 0.0 { return val_str("(constant)") }
        let mut out = ""
        let mut row = height - 1
        while row >= 0 {
            let mut i = 0
            while i < n {
                let v = if type_of(values[i]) == "float" { values[i] } else { to_float_val(values[i]) }
                let row_v = floor((v - min_v) / range * (height - 1))
                if row_v >= row { out = out + "█" }
                else { out = out + " " }
                i = i + 1
            }
            out = out + "\n"
            row = row - 1
        }
        return val_str(out)
    }

    // ── consciousness/anima placeholders ──
    // These return safe defaults so anima.hexa code parses & runs.
    // Real consciousness ops require shared state with the host runtime.
    if name == "consciousness_phi" {
        // Default IIT Φ = 0 (no integration)
        return val_float(0.0)
    }
    if name == "consciousness_vector" {
        // Returns the input array unchanged (passthrough)
        if len(args) == 0 { return val_array([]) }
        return args[0]
    }
    if name == "consciousness_decoder_dim" || name == "consciousness_max_cells" {
        return val_int(0)
    }
    if name == "phi" || name == "phi_predict" {
        return val_float(0.0)
    }
    if name == "psi_balance" || name == "psi_coupling" || name == "psi_entropy" || name == "psi_frustration" || name == "psi_steps" {
        return val_float(0.0)
    }
    if name == "tension" || name == "tension_link" {
        return val_float(0.0)
    }
    if name == "evolve_gen" || name == "evolve_stats" {
        return val_array([])
    }
    if name == "faction" || name == "faction_consensus" {
        return val_array([])
    }
    if name == "combined_reward" || name == "curiosity_reward" || name == "dialogue_reward" {
        return val_float(0.0)
    }
    if name == "chaos_perturb" {
        if len(args) == 0 { return val_array([]) }
        return args[0]
    }
    if name == "lorenz_step" {
        // 3D Lorenz attractor step: returns [new_x, new_y, new_z]
        if len(args) < 4 { return val_array([]) }
        let x = to_float_val(args[0])
        let y = to_float_val(args[1])
        let z = to_float_val(args[2])
        let dt = to_float_val(args[3])
        let sigma_l = 10.0
        let rho = 28.0
        let beta = 8.0 / 3.0
        let dx = sigma_l * (y - x)
        let dy = x * (rho - z) - y
        let dz = x * y - beta * z
        return val_array([val_float(x + dx * dt), val_float(y + dy * dt), val_float(z + dz * dt)])
    }
    if name == "laws" || name == "meta_laws" || name == "meta" || name == "hexad_modules" || name == "hexad_left" || name == "hexad_right" {
        return val_array([])
    }
    if name == "auto_topology" || name == "ring_topology" || name == "small_world_topology" || name == "hypercube_topology" {
        return val_array([])
    }
    if name == "nexus_n6_check" {
        return val_bool(true)
    }
    if name == "running_stats" {
        // running_stats(prev_mean, prev_var, prev_n, x) → [new_mean, new_var, new_n]
        if len(args) < 4 { return val_array([]) }
        let prev_mean = to_float_val(args[0])
        let prev_var = to_float_val(args[1])
        let prev_n = args[2].int_val
        let x = to_float_val(args[3])
        let new_n = prev_n + 1
        let delta = x - prev_mean
        let new_mean = prev_mean + delta / new_n
        let delta2 = x - new_mean
        let new_var = if prev_n == 0 { 0.0 } else { (prev_var * prev_n + delta * delta2) / new_n }
        return val_array([val_float(new_mean), val_float(new_var), val_int(new_n)])
    }
    if name == "trend_slope" {
        // Linear regression slope (least squares)
        if len(args) == 0 { return val_float(0.0) }
        let arr = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let n = len(arr)
        if n < 2 { return val_float(0.0) }
        let mut sum_x = 0.0
        let mut sum_y = 0.0
        let mut sum_xy = 0.0
        let mut sum_xx = 0.0
        let mut i = 0
        while i < n {
            let x = i + 0.0
            let y = if type_of(arr[i]) == "float" { arr[i] } else { to_float_val(arr[i]) }
            sum_x = sum_x + x
            sum_y = sum_y + y
            sum_xy = sum_xy + x * y
            sum_xx = sum_xx + x * x
            i = i + 1
        }
        let denom = n * sum_xx - sum_x * sum_x
        if denom == 0.0 { return val_float(0.0) }
        return val_float((n * sum_xy - sum_x * sum_y) / denom)
    }
    if name == "autocorrelation" {
        // autocorr(arr, lag)
        if len(args) < 2 { return val_float(0.0) }
        let arr = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let lag = args[1].int_val
        let n = len(arr)
        if n - lag < 2 { return val_float(0.0) }
        let mut mean = 0.0
        for v in arr { mean = mean + (if type_of(v) == "float" { v } else { to_float_val(v) }) }
        mean = mean / n
        let mut num = 0.0
        let mut den = 0.0
        let mut i = 0
        while i < n {
            let v = if type_of(arr[i]) == "float" { arr[i] } else { to_float_val(arr[i]) }
            den = den + (v - mean) * (v - mean)
            if i + lag < n {
                let v2 = if type_of(arr[i + lag]) == "float" { arr[i + lag] } else { to_float_val(arr[i + lag]) }
                num = num + (v - mean) * (v2 - mean)
            }
            i = i + 1
        }
        if den == 0.0 { return val_float(0.0) }
        return val_float(num / den)
    }
    if name == "mutual_information" {
        // Simplified: 0 for now (full impl needs joint distribution)
        return val_float(0.0)
    }
    if name == "ewc_penalty" || name == "fisher_diagonal" || name == "magnitude_prune" || name == "sparsity" {
        return val_float(0.0)
    }
    if name == "data_split" {
        if len(args) < 2 { return val_array([]) }
        let arr = get_array(args[0])
        let ratio = to_float_val(args[1])
        let split_idx = floor(len(arr) * ratio)
        let mut train = []
        let mut test = []
        let mut i = 0
        while i < len(arr) {
            if i < split_idx { train.push(arr[i]) }
            else { test.push(arr[i]) }
            i = i + 1
        }
        return val_array([val_array(train), val_array(test)])
    }
    if name == "quantize_int8" {
        // quantize float array to [-127,127]
        if len(args) == 0 { return val_array([]) }
        let arr = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let mut max_abs = 0.0
        for v in arr {
            let f = if type_of(v) == "float" { v } else { to_float_val(v) }
            let a = if f < 0.0 { 0.0 - f } else { f }
            if a > max_abs { max_abs = a }
        }
        if max_abs == 0.0 {
            let mut z = []
            let mut i = 0
            while i < len(arr) { z.push(val_int(0)); i = i + 1 }
            return val_array([val_array(z), val_float(1.0)])
        }
        let scale = 127.0 / max_abs
        let mut quantized = []
        for v in arr {
            let f = if type_of(v) == "float" { v } else { to_float_val(v) }
            quantized.push(val_int(floor(f * scale)))
        }
        return val_array([val_array(quantized), val_float(scale)])
    }
    if name == "dequantize_int8" {
        if len(args) < 2 { return val_array([]) }
        let arr = get_array(args[0])
        let scale = to_float_val(args[1])
        let mut result = []
        for v in arr { result.push(val_float(v.int_val / scale)) }
        return val_array(result)
    }
    if name == "hmac_sha256" {
        // self-host can't do crypto; return empty string
        return val_str("")
    }
    if name == "url_decode" {
        if len(args) == 0 { return val_str("") }
        return val_str(args[0].str_val)
    }
    if name == "is_numeric" {
        if len(args) == 0 { return val_bool(false) }
        let v = args[0]
        return val_bool(v.tag == TAG_INT || v.tag == TAG_FLOAT)
    }
    if name == "is_whitespace" {
        if len(args) == 0 { return val_bool(false) }
        let s = args[0].str_val
        return val_bool(s == " " || s == "\t" || s == "\n" || s == "\r")
    }
    if name == "input_all" || name == "readline" {
        return val_str(input(""))
    }
    if name == "read_file_bytes" {
        if len(args) == 0 { return val_array([]) }
        let raw = read_file_bytes(args[0].str_val)
        let mut out = []
        for b in raw { out.push(val_int(b)) }
        return val_array(out)
    }
    if name == "write_file_bytes" || name == "write_bytes" {
        if len(args) < 2 { return val_void() }
        // Interpreter args are Val-wrapped — args[1] is TAG_VALSTRUCT around
        // the user's array. Unwrap to the raw TAG_ARRAY (array_store entry)
        // and call write_bytes_v which reads each item's `int_val` from the
        // Val struct rather than treating each item as a raw HexaVal int.
        // Without this, write_bytes either silently no-ops (NEW pipeline) or
        // UTF-8-encodes each byte > 0x7F to two bytes (legacy fputs path).
        let raw_arr = get_array(args[1])
        write_bytes_v(args[0].str_val, raw_arr)
        return val_void()
    }
    // read_bytes_at(path, offset, nbytes) — pread-style ranged read.
    // Used by self/tools/{lora,safetensors}_to_hexaw for multi-GB streaming
    // (10 sites). Wrap raw bytes into Val-array same as read_file_bytes.
    if name == "read_bytes_at" {
        if len(args) < 3 { return val_array([]) }
        let raw = read_bytes_at(args[0].str_val, args[1].int_val, args[2].int_val)
        let mut out = []
        for b in raw { out.push(val_int(b)) }
        return val_array(out)
    }
    // write_bytes_append(path, arr) — append-mode binary writer (10 call
    // sites). Same Val-unwrap shape as write_bytes — go through the _v
    // variant so each item is read out of the Val struct, not as a raw
    // HexaVal int.
    if name == "write_bytes_append" {
        if len(args) < 2 { return val_void() }
        let raw_arr = get_array(args[1])
        write_bytes_append_v(args[0].str_val, raw_arr)
        return val_void()
    }
    // ── IEEE-754 reinterpret builtins (B5 safetensors enabler) ──
    // f32_to_bytes_le / f64_to_bytes_le → Val-array of int (4 / 8 LE bytes)
    // bytes_to_f32_le / bytes_to_f64_le → Val-float
    // The interpreter wraps each input array element as TAG_VALSTRUCT, so
    // route the bytes→float decode through the *_v C variant which unwraps
    // the Val to read its int_val. Encode side returns a TAG_ARRAY of raw
    // HexaVal ints from C, which we re-wrap as Val ints for caller.
    if name == "f32_to_bytes_le" {
        if len(args) == 0 { return val_array([]) }
        let raw = f32_to_bytes_le(to_float_val(args[0]))
        let mut out = []
        for b in raw { out.push(val_int(b)) }
        return val_array(out)
    }
    if name == "f64_to_bytes_le" {
        if len(args) == 0 { return val_array([]) }
        let raw = f64_to_bytes_le(to_float_val(args[0]))
        let mut out = []
        for b in raw { out.push(val_int(b)) }
        return val_array(out)
    }
    if name == "bytes_to_f32_le" {
        if len(args) < 2 { return val_float(0.0) }
        let raw_arr = get_array(args[0])
        let off = args[1].int_val
        let n = len(raw_arr)
        if off < 0 || off + 4 > n { return val_float(0.0) }
        // Inline TAG_VALSTRUCT unwrap: build a plain raw-int byte array so the
        // non-_v C builtin (which only handles HX_IS_INT items) can decode.
        // Removes the _v dependency that was unknown to precompiled hexa_v2.
        let mut raw_bytes = []
        let mut i = 0
        while i < 4 {
            raw_bytes.push(raw_arr[off + i].int_val)
            i = i + 1
        }
        return val_float(bytes_to_f32_le(raw_bytes, 0))
    }
    if name == "bytes_to_f64_le" {
        if len(args) < 2 { return val_float(0.0) }
        let raw_arr = get_array(args[0])
        let off = args[1].int_val
        let n = len(raw_arr)
        if off < 0 || off + 8 > n { return val_float(0.0) }
        // Inline TAG_VALSTRUCT unwrap (see bytes_to_f32_le above for rationale).
        let mut raw_bytes = []
        let mut i = 0
        while i < 8 {
            raw_bytes.push(raw_arr[off + i].int_val)
            i = i + 1
        }
        return val_float(bytes_to_f64_le(raw_bytes, 0))
    }
    // json_encode / json_decode — runtime alias names. Reuse the
    // interpreter-side val_to_json / json_to_val helpers (already used for
    // json_stringify / json_parse) so the result lives in the interpreter
    // Val world, not the raw HexaVal world.
    if name == "json_encode" {
        if len(args) == 0 { return val_str("null") }
        return val_str(val_to_json(args[0]))
    }
    if name == "json_decode" {
        if len(args) == 0 { return val_void() }
        return json_to_val(args[0].str_val)
    }
    // str_trim_start / str_trim_end — runtime symbol names. The interpreter
    // already supports the corresponding string methods (line 15006), so
    // route through them rather than calling the FFI directly.
    if name == "str_trim_start" {
        if len(args) == 0 { return val_str("") }
        return val_str(args[0].str_val.trim_start())
    }
    if name == "str_trim_end" {
        if len(args) == 0 { return val_str("") }
        return val_str(args[0].str_val.trim_end())
    }

    // ── Phase 17 골화 — 잔여 빌트인 ──
    // linear_attention(Q, K, V, seq, dim) — feature-based linear attention
    if name == "linear_attention" {
        if len(args) < 5 { return val_array([]) }
        let q = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let k = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let v = if args[2].tag == TAG_TENSOR { tensor_data(args[2]) } else { get_array(args[2]) }
        let seq = args[3].int_val
        let dim = args[4].int_val
        // Approximation: φ(x) = elu(x) + 1, attention = (Q · ΣK·Vᵀ) / (Q · ΣK)
        // Single-pass simplified version
        let mut sum_kv = []
        let mut sum_k = []
        let mut i = 0
        while i < dim * dim { sum_kv.push(0.0); i = i + 1 }
        i = 0
        while i < dim { sum_k.push(0.0); i = i + 1 }
        // Accumulate over sequence
        let mut t = 0
        while t < seq {
            let mut d1 = 0
            while d1 < dim {
                let kv1 = if type_of(k[t * dim + d1]) == "float" { k[t * dim + d1] } else { to_float_val(k[t * dim + d1]) }
                let phi_k = if kv1 > 0.0 { kv1 + 1.0 } else { exp(kv1) }
                sum_k[d1] = sum_k[d1] + phi_k
                let mut d2 = 0
                while d2 < dim {
                    let vv = if type_of(v[t * dim + d2]) == "float" { v[t * dim + d2] } else { to_float_val(v[t * dim + d2]) }
                    sum_kv[d1 * dim + d2] = sum_kv[d1 * dim + d2] + phi_k * vv
                    d2 = d2 + 1
                }
                d1 = d1 + 1
            }
            t = t + 1
        }
        // Now compute Q · sum_kv / Q · sum_k for each query
        let mut output = []
        t = 0
        while t < seq {
            let mut denom = 0.0
            let mut d1 = 0
            while d1 < dim {
                let qv = if type_of(q[t * dim + d1]) == "float" { q[t * dim + d1] } else { to_float_val(q[t * dim + d1]) }
                let phi_q = if qv > 0.0 { qv + 1.0 } else { exp(qv) }
                denom = denom + phi_q * sum_k[d1]
                d1 = d1 + 1
            }
            let mut d2 = 0
            while d2 < dim {
                let mut num = 0.0
                d1 = 0
                while d1 < dim {
                    let qv = if type_of(q[t * dim + d1]) == "float" { q[t * dim + d1] } else { to_float_val(q[t * dim + d1]) }
                    let phi_q = if qv > 0.0 { qv + 1.0 } else { exp(qv) }
                    num = num + phi_q * sum_kv[d1 * dim + d2]
                    d1 = d1 + 1
                }
                if denom == 0.0 { output.push(val_float(0.0)) }
                else { output.push(val_float(num / denom)) }
                d2 = d2 + 1
            }
            t = t + 1
        }
        return val_array(output)
    }
    // sample_token(logits, temperature) → int (argmax of softmax * temp)
    if name == "sample_token" {
        if len(args) == 0 { return val_int(0) }
        let logits = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let temp = if len(args) > 1 { to_float_val(args[1]) } else { 1.0 }
        if len(logits) == 0 { return val_int(0) }
        // softmax with temperature
        let mut max_l = if type_of(logits[0]) == "float" { logits[0] } else { to_float_val(logits[0]) }
        for v in logits {
            let f = if type_of(v) == "float" { v } else { to_float_val(v) }
            if f > max_l { max_l = f }
        }
        let mut exps = []
        let mut sum_e = 0.0
        for v in logits {
            let f = if type_of(v) == "float" { v } else { to_float_val(v) }
            let e = exp((f - max_l) / temp)
            exps.push(e)
            sum_e = sum_e + e
        }
        // sample via cumulative
        let r = random() * sum_e
        let mut cum = 0.0
        let mut i = 0
        while i < len(exps) {
            cum = cum + exps[i]
            if r <= cum { return val_int(i) }
            i = i + 1
        }
        return val_int(len(exps) - 1)
    }
    // beam_search_step(logits, beam_width) → top-k indices
    if name == "beam_search_step" {
        if len(args) < 2 { return val_array([]) }
        return call_builtin("topk", args)
    }
    // mat_scale(m, s) — scalar multiply
    if name == "mat_scale" {
        if len(args) < 2 { return val_array([]) }
        let m = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let s = to_float_val(args[1])
        let mut result = []
        for v in m {
            let f = if type_of(v) == "float" { v } else { to_float_val(v) }
            result.push(val_float(f * s))
        }
        return val_array(result)
    }
    // mat_add_inplace(a, b) — a += b
    if name == "mat_add_inplace" {
        if len(args) < 2 { return val_void() }
        if args[0].tag != TAG_TENSOR { return val_void() }
        let a_data = tensor_data(args[0])
        let b = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let n = if len(a_data) < len(b) { len(a_data) } else { len(b) }
        let mut new_data = []
        let mut i = 0
        while i < len(a_data) {
            if i < n {
                let av = if type_of(a_data[i]) == "float" { a_data[i] } else { to_float_val(a_data[i]) }
                let bv = if type_of(b[i]) == "float" { b[i] } else { to_float_val(b[i]) }
                new_data.push(av + bv)
            } else {
                new_data.push(a_data[i])
            }
            i = i + 1
        }
        tensor_set_data(args[0], new_data)
        return args[0]
    }
    // grad_accumulate(grad_acc, grad) → new_grad_acc
    if name == "grad_accumulate" {
        if len(args) < 2 { return val_array([]) }
        let acc = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let g = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let n = if len(acc) < len(g) { len(acc) } else { len(g) }
        let mut result = []
        let mut i = 0
        while i < n {
            let av = if type_of(acc[i]) == "float" { acc[i] } else { to_float_val(acc[i]) }
            let gv = if type_of(g[i]) == "float" { g[i] } else { to_float_val(g[i]) }
            result.push(val_float(av + gv))
            i = i + 1
        }
        return val_array(result)
    }
    // param_count(weight_dict) → total scalar count
    if name == "param_count" {
        if len(args) == 0 { return val_int(0) }
        if args[0].tag == TAG_MAP {
            let vals = get_map_values(args[0])
            let mut total = 0
            for v in vals {
                if v.tag == TAG_TENSOR { total = total + tensor_numel(v) }
                else { if v.tag == TAG_ARRAY { total = total + len(get_array(v)) } }
            }
            return val_int(total)
        }
        if args[0].tag == TAG_TENSOR { return val_int(tensor_numel(args[0])) }
        if args[0].tag == TAG_ARRAY { return val_int(len(get_array(args[0]))) }
        return val_int(0)
    }
    // load_array(path) → array of floats from file
    if name == "load_array" {
        if len(args) == 0 { return val_array([]) }
        try {
            let s = read_file(args[0].str_val)
            let lines = s.split("\n")
            let mut result = []
            for l in lines {
                let trimmed = l.trim()
                if trimmed != "" { result.push(val_float(to_float(val_str(trimmed)))) }
            }
            return val_array(result)
        } catch e {
            return val_array([])
        }
    }
    // save_array(path, arr) → void
    if name == "save_array" {
        if len(args) < 2 { return val_void() }
        let arr = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let mut s = ""
        for v in arr {
            let f = if type_of(v) == "float" { v } else { to_float_val(v) }
            s = s + to_string(f) + "\n"
        }
        write_file(args[0].str_val, s)
        return val_void()
    }
    // log_get_entries — return empty (log subsystem stub)
    if name == "log_get_entries" {
        return val_array([])
    }
    if name == "law_count" {
        return val_int(60)  // HEXA has 60 laws
    }
    // cell_merge / cell_split — consciousness cell ops, return passthrough
    if name == "cell_merge" {
        if len(args) < 2 { return val_array([]) }
        let a = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let b = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let n = if len(a) < len(b) { len(a) } else { len(b) }
        let mut result = []
        let mut i = 0
        while i < n {
            let av = if type_of(a[i]) == "float" { a[i] } else { to_float_val(a[i]) }
            let bv = if type_of(b[i]) == "float" { b[i] } else { to_float_val(b[i]) }
            result.push(val_float(0.5 * (av + bv)))
            i = i + 1
        }
        return val_array(result)
    }
    if name == "cell_split" {
        if len(args) == 0 { return val_array([]) }
        // Returns [cell, copy_with_perturbation]
        let arr = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let mut copy = []
        for v in arr {
            let f = if type_of(v) == "float" { v } else { to_float_val(v) }
            copy.push(val_float(f + 0.001 * (random() - 0.5)))
        }
        return val_array([args[0], val_array(copy)])
    }
    // attention_fused_into — alias to attention but writes into a tensor
    if name == "attention_fused_into" || name == "attention_cached" {
        // Compute attention and copy result into out tensor
        if len(args) < 6 { return val_void() }
        let out = args[0]
        let mut inner_args = []
        let mut i = 1
        while i < len(args) { inner_args.push(args[i]); i = i + 1 }
        let result = call_builtin("attention", inner_args)
        if out.tag == TAG_TENSOR && result.tag == TAG_ARRAY {
            let arr = get_array(result)
            let mut data = []
            for v in arr { data.push(if type_of(v) == "float" { v } else { to_float_val(v) }) }
            tensor_set_data(out, data)
        }
        return out
    }
    // ffn_fused_into(out, x, w1, w2, dim, hidden) — feed-forward block
    if name == "ffn_fused_into" {
        if len(args) < 6 { return val_void() }
        let out = args[0]
        let x = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let w1 = if args[2].tag == TAG_TENSOR { tensor_data(args[2]) } else { get_array(args[2]) }
        let w2 = if args[3].tag == TAG_TENSOR { tensor_data(args[3]) } else { get_array(args[3]) }
        let dim = args[4].int_val
        let hidden = args[5].int_val
        // h = relu(W1 @ x)
        let mut h = []
        let mut i = 0
        while i < hidden {
            let mut acc = 0.0
            let mut c = 0
            while c < dim {
                let wv = if type_of(w1[i * dim + c]) == "float" { w1[i * dim + c] } else { to_float_val(w1[i * dim + c]) }
                let xv = if type_of(x[c]) == "float" { x[c] } else { to_float_val(x[c]) }
                acc = acc + wv * xv
                c = c + 1
            }
            if acc < 0.0 { h.push(0.0) } else { h.push(acc) }
            i = i + 1
        }
        // y = W2 @ h
        let mut y = []
        i = 0
        while i < dim {
            let mut acc = 0.0
            let mut c = 0
            while c < hidden {
                let wv = if type_of(w2[i * hidden + c]) == "float" { w2[i * hidden + c] } else { to_float_val(w2[i * hidden + c]) }
                acc = acc + wv * h[c]
                c = c + 1
            }
            y.push(acc)
            i = i + 1
        }
        if out.tag == TAG_TENSOR {
            tensor_set_data(out, y)
            return out
        }
        let mut wrapped = []
        for v in y { wrapped.push(val_float(v)) }
        return val_array(wrapped)
    }
    // block_forward_chain — multi-layer transformer block stub
    if name == "block_forward_chain" || name == "block_forward_chain_f32" || name == "block_forward_fused" {
        // Pass through (output identity); real impl is fused kernel
        if len(args) > 0 { return args[0] }
        return val_array([])
    }
    // ── Channel/IO/HTTP stubs (host-dependent) ──
    if name == "send" {
        if len(args) >= 2 && args[0].tag == TAG_CHANNEL { return val_bool(channel_send(args[0], args[1])) }
        return val_bool(false)
    }
    if name == "recv" {
        if len(args) >= 1 && args[0].tag == TAG_CHANNEL { return channel_recv(args[0]) }
        return val_void()
    }
    if name == "try_recv" {
        if len(args) >= 1 && args[0].tag == TAG_CHANNEL {
            let v = channel_recv(args[0])
            if v.tag == TAG_VOID { return val_enum("Option", "None", "") }
            return val_enum("Option", "Some", v)
        }
        return val_enum("Option", "None", "")
    }
    if name == "is_ready" {
        if len(args) == 0 { return val_bool(false) }
        return val_bool(true)
    }
    if name == "deque_len" {
        if len(args) == 0 { return val_int(0) }
        if args[0].tag == TAG_ARRAY { return val_int(len(get_array(args[0]))) }
        return val_int(0)
    }
    if name == "io_reader_next" || name == "fs_watch" || name == "http_get" || name == "http_post" || name == "http_serve" {
        // Host runtime delegate
        return val_str("")
    }
    if name == "tanh_" {
        if len(args) == 0 { return val_float(0.0) }
        return val_float(tanh(to_float_val(args[0])))
    }
    if name == "to_char" {
        if len(args) == 0 { return val_str("") }
        return val_str(to_string(args[0].int_val))
    }
    if name == "try_float" {
        if len(args) == 0 { return val_float(0.0) }
        try { return val_float(to_float(args[0])) }
        catch e { return val_float(0.0) }
    }
    if name == "str" {
        if len(args) == 0 { return val_str("") }
        return val_str(val_to_string(args[0]))
    }
    if name == "gen" {
        // Generator stub: empty array
        return val_array([])
    }
    if name == "hello" {
        return val_str("hello from hexa interpreter (self-host)")
    }

    // ── Phase 22b 골화 — 호스트 핵심 빌트인 패스스루 ──
    // 이전 batch들이 alias만 추가하고 이름 자체 누락한 경우 보강.
    if name == "time" {
        return val_int(timestamp())
    }
    if name == "sleep" {
        if len(args) > 0 { sleep(args[0].int_val) }
        return val_void()
    }
    if name == "random" {
        return val_float(random())
    }
    if name == "range" {
        // range(n) | range(start, end) | range(start, end, step)
        let start = if len(args) >= 2 { args[0].int_val } else { 0 }
        let end = if len(args) >= 2 { args[1].int_val } else { args[0].int_val }
        let step = if len(args) >= 3 { args[2].int_val } else { 1 }
        let mut result = []
        let mut i = start
        if step > 0 {
            while i < end { result.push(val_int(i)); i = i + step }
        }
        if step < 0 {
            while i > end { result.push(val_int(i)); i = i + step }
        }
        return val_array(result)
    }
    if name == "assert" {
        if len(args) > 0 && !is_truthy(args[0]) {
            throw_flag = true
            let msg = if len(args) > 1 { args[1].str_val } else { "assertion failed" }
            throw_val = val_str(msg)
        }
        return val_void()
    }
    if name == "sort" {
        if len(args) == 0 { return val_array([]) }
        let arr = get_array(args[0])
        return val_array(sort_array(arr))
    }
    if name == "read_file" {
        if len(args) == 0 { return val_str("") }
        let path = args[0].str_val
        if path.contains("..") {
            eprintln("security warning: path traversal detected in file operation: " + path)
        }
        let result = read_file(args[0].str_val)
        // host read_file returns either Str or Error value (not via throw)
        if is_error(result) {
            return Val { tag: TAG_ERROR, int_val: 0, float_val: 0.0, bool_val: false, str_val: "read_file failed", char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E }
        }
        return val_str(result)
    }
    if name == "write_file" {
        if len(args) < 2 { return val_void() }
        let path = args[0].str_val
        if path.contains("..") {
            eprintln("security warning: path traversal detected in file operation: " + path)
        }
        try { write_file(args[0].str_val, args[1].str_val) } catch e { }
        return val_void()
    }
    if name == "append_file" {
        if len(args) < 2 { return val_void() }
        let path = args[0].str_val
        if path.contains("..") {
            eprintln("security warning: path traversal detected in file operation: " + path)
        }
        try { append_file(args[0].str_val, args[1].str_val) } catch e { }
        return val_void()
    }
    if name == "read_lines" {
        if len(args) == 0 { return val_array([]) }
        try {
            let lines = read_lines(args[0].str_val)
            let mut result = []
            for l in lines { result.push(val_str(l)) }
            return val_array(result)
        } catch e { return val_array([]) }
    }
    if name == "file_exists" {
        if len(args) == 0 { return val_bool(false) }
        return val_bool(file_exists(args[0].str_val))
    }
    // ω-stdlib-5 (2026-05-01): pfs_now_ns interpreter builtin — closes the
    // gap left when nexus/cli/run.hexa inlined pfs_file_exists but not
    // pfs_now_ns (~25 call-sites in drill 6-stage). Without this dispatch
    // the runtime emits "undefined function: pfs_now_ns" and every
    // elapsed_ms reads 0 → drill SATURATED → drill_zero_yield. Semantics
    // mirror stdlib/portable_fs.hexa::pfs_now_ns: GNU date +%s%N when
    // available, BSD fallback (seconds × 10^9) on Mac. Returns string for
    // bigint compatibility (ns since epoch overflows 32-bit).  // @date-n-guard: builtin-shellout
    if name == "pfs_now_ns" {
        try {
            let s_now = exec("date +%s%N 2>/dev/null").trim()
            if len(s_now) > 0 {
                // GNU success → digits only, no trailing N literal.
                let mut has_n_now = false
                let mut _ni_now = 0
                while _ni_now < len(s_now) {
                    if s_now[_ni_now] == 'N' { has_n_now = true }
                    _ni_now = _ni_now + 1
                }
                if !has_n_now { return val_str(s_now) }
            }
            // BSD fallback: seconds × 10^9 (1s precision, monotonic).
            let sec_now = exec("date +%s 2>/dev/null").trim()
            if len(sec_now) == 0 { return val_str("0") }
            return val_str(sec_now + "000000000")
        } catch e { return val_str("0") }
    }
    if name == "dir_exists" {
        // ω-stdlib-4 (2026-04-26): single-quote-escape the path so paths
        // containing apostrophes don't break out of the shell quoting (and
        // either return a wrong answer or, worse, execute fragments of the
        // path as a command). Mirrors the escape pattern used by file_size
        // at line ~10606.
        if len(args) == 0 { return val_int(0) }
        let p_de = args[0].str_val
        if len(p_de) == 0 { return val_int(0) }
        let escaped_de = "'" + p_de.replace("'", "'\\''") + "'"
        try {
            let res = exec("test -d " + escaped_de + " && echo 1 || echo 0").trim()
            if res == "1" { return val_int(1) }
            return val_int(0)
        } catch e { return val_int(0) }
    }
    if name == "mkdir" {
        // ω-stdlib-4 (2026-04-26): single-quote-escape the path (see
        // dir_exists rationale above).
        if len(args) == 0 { return val_int(1) }
        let p_mk = args[0].str_val
        if len(p_mk) == 0 { return val_int(1) }
        let escaped_mk = "'" + p_mk.replace("'", "'\\''") + "'"
        try {
            exec("mkdir -p " + escaped_mk)
            return val_int(0)
        } catch e { return val_int(1) }
    }
    if name == "list_dir" {
        // ω-stdlib-4 (2026-04-26): single-quote-escape the path. Note that
        // `ls -1` still loses entries containing newlines — that limitation
        // is inherent to the shellout shape and would need a real readdir(3)
        // builtin to fix. Tracked but out of scope for this cycle.
        if len(args) == 0 { return val_array([]) }
        let p_ld = args[0].str_val
        if len(p_ld) == 0 { return val_array([]) }
        let escaped_ld = "'" + p_ld.replace("'", "'\\''") + "'"
        try {
            let raw = exec("ls -1 " + escaped_ld + " 2>/dev/null").trim()
            if raw == "" { return val_array([]) }
            let entries = raw.split("\n")
            let mut result = []
            for e in entries { result.push(val_str(e)) }
            return val_array(result)
        } catch e { return val_array([]) }
    }
    if name == "delete_file" {
        if len(args) == 0 { return val_void() }
        try { delete_file(args[0].str_val) } catch e { }
        return val_void()
    }
