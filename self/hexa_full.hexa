            while fi <= n {
                let tmp = a + b
                a = b
                b = tmp
                fi = fi + 1
            }
            return val_int(b)
        }
        return val_int(0)
    }
    if name == "is_prime" {
        if len(args) > 0 {
            let n = args[0].int_val
            if n < 2 { return val_bool(false) }
            if n < 4 { return val_bool(true) }
            if n % 2 == 0 { return val_bool(false) }
            if n % 3 == 0 { return val_bool(false) }
            let mut i = 5
            while i * i <= n {
                if n % i == 0 || n % (i + 2) == 0 { return val_bool(false) }
                i = i + 6
            }
            return val_bool(true)
        }
        return val_bool(false)
    }
    if name == "mod" {
        // Euclidean modulo: always returns non-negative for positive divisor
        if len(args) >= 2 {
            let a = args[0].int_val
            let b = args[1].int_val
            if b == 0 { return val_int(0) }
            let r = a % b
            if r < 0 { return val_int(r + abs(b)) }
            return val_int(r)
        }
        return val_int(0)
    }

    // ═══════════════════════════════════════════════════════
    //  Phase 2-5 골화 — Tensor / BLAS / Quant / Attention
    //  src/interpreter.rs:4779-5400 대응
    // ═══════════════════════════════════════════════════════

    // ── tensor(array, shape?) — flat data + optional shape ──
    if name == "tensor" {
        if len(args) == 0 { return val_void() }
        // already a tensor → identity
        if args[0].tag == TAG_TENSOR { return args[0] }
        let src = get_array(args[0])
        let mut data = []
        for v in src { data.push(to_float_val(v)) }
        let mut shape = [len(data)]
        if len(args) > 1 && args[1].tag == TAG_ARRAY {
            let s_arr = get_array(args[1])
            let mut shp2 = []
            for sv in s_arr { shp2.push(sv.int_val) }
            shape = shp2
        }
        return val_tensor(shape, data)
    }
    if name == "tensor_zeros" {
        let n = args[0].int_val
        if n < 0 { return val_void() }
        let mut data = []
        let mut zi = 0
        while zi < n { data.push(0.0); zi = zi + 1 }
        return val_tensor([n], data)
    }
    // FIX-A 2nd batch: tensor_ones(n) — mirror hexa_tensor_ones in runtime.c.
    // Runtime returns flat array (not tensor); keep interpreter semantics aligned.
    if name == "tensor_ones" {
        if len(args) == 0 { return val_array([]) }
        let n = args[0].int_val
        if n < 0 { return val_array([]) }
        let mut data = []
        let mut oi = 0
        while oi < n { data.push(val_float(1.0)); oi = oi + 1 }
        return val_array(data)
    }
    // FIX-A 2nd batch: swiglu_vec(gate, up) = silu(gate) * up elementwise.
    // silu(x) = x / (1 + exp(-x)). Shape = min(|gate|, |up|).
    if name == "swiglu_vec" {
        if len(args) < 2 { return val_array([]) }
        let sg = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let su = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let sng = len(sg)
        let snu = len(su)
        let sk = if sng < snu { sng } else { snu }
        let mut sout = []
        let mut si = 0
        while si < sk {
            let sgv = if type_of(sg[si]) == "float" { sg[si] } else { to_float_val(sg[si]) }
            let suv = if type_of(su[si]) == "float" { su[si] } else { to_float_val(su[si]) }
            let silu = sgv / (1.0 + exp(0.0 - sgv))
            sout.push(val_float(silu * suv))
            si = si + 1
        }
        return val_array(sout)
    }
    if name == "tensor_fill" {
        let n = args[0].int_val
        let v = to_float_val(args[1])
        if n < 0 { return val_void() }
        let mut data = []
        let mut fi = 0
        while fi < n { data.push(v); fi = fi + 1 }
        return val_tensor([n], data)
    }
    if name == "tensor_last_row" {
        // tensor_last_row(t, rows, cols) — return shape=[cols] copy of last row
        let rows = args[1].int_val
        let cols = args[2].int_val
        if rows <= 0 || cols <= 0 { return val_void() }
        let src = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let n_src = len(src)
        if n_src < rows * cols { return val_void() }
        let base = (rows - 1) * cols
        let mut data = []
        let mut ri = 0
        while ri < cols {
            let v = src[base + ri]
            if type_of(v) == "float" { data.push(v) }
            else { data.push(to_float_val(v)) }
            ri = ri + 1
        }
        return val_tensor([cols], data)
    }
    // weight_dict([names], [tensors]) → map name -> tensor
    if name == "weight_dict" {
        let names = get_array(args[0])
        let tensors = get_array(args[1])
        let mut keys = []
        let mut vals = []
        let mut wi = 0
        while wi < len(names) && wi < len(tensors) {
            keys.push(names[wi])
            vals.push(tensors[wi])
            wi = wi + 1
        }
        return val_map(keys, vals)
    }
    // dot(a, b) — vector dot product (returns float)
    if name == "dot" || name == "tensor_dot" {
        let a = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let b = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let n_dot = if len(a) < len(b) { len(a) } else { len(b) }
        let mut acc = 0.0
        let mut di = 0
        while di < n_dot {
            let av = if type_of(a[di]) == "float" { a[di] } else { to_float_val(a[di]) }
            let bv = if type_of(b[di]) == "float" { b[di] } else { to_float_val(b[di]) }
            acc = acc + av * bv
            di = di + 1
        }
        return val_float(acc)
    }
    // tensor_slice(arr, lo, hi) — subarray [lo, hi) with clamped bounds.
    // Mirrors hexa_tensor_slice in runtime.c.
    if name == "tensor_slice" {
        if len(args) < 3 { return val_array([]) }
        let tsa = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let tsn = len(tsa)
        let mut tslo = args[1].int_val
        let mut tshi = args[2].int_val
        if tslo < 0 { tslo = 0 }
        if tshi > tsn { tshi = tsn }
        let mut tsout = []
        let mut tsi = tslo
        while tsi < tshi { tsout.push(tsa[tsi]); tsi = tsi + 1 }
        return val_array(tsout)
    }
    // tensor_add(a, b) — elementwise sum, length = min(|a|, |b|).
    if name == "tensor_add" {
        if len(args) < 2 { return val_array([]) }
        let taa = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let tab = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let tak = if len(taa) < len(tab) { len(taa) } else { len(tab) }
        let mut taout = []
        let mut tai = 0
        while tai < tak {
            let tav = if type_of(taa[tai]) == "float" { taa[tai] } else { to_float_val(taa[tai]) }
            let tbv = if type_of(tab[tai]) == "float" { tab[tai] } else { to_float_val(tab[tai]) }
            taout.push(val_float(tav + tbv))
            tai = tai + 1
        }
        return val_array(taout)
    }
    // tensor_mul_scalar(a, s) — elementwise a[i] * s.
    if name == "tensor_mul_scalar" {
        if len(args) < 2 { return val_array([]) }
        let tma = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let tms = to_float_val(args[1])
        let mut tmout = []
        let mut tmi = 0
        let tmn = len(tma)
        while tmi < tmn {
            let tmv = if type_of(tma[tmi]) == "float" { tma[tmi] } else { to_float_val(tma[tmi]) }
            tmout.push(val_float(tmv * tms))
            tmi = tmi + 1
        }
        return val_array(tmout)
    }
    // fma(a, b, c) — fused multiply-add: a * b + c.
    if name == "fma" {
        if len(args) < 3 { return val_float(0.0) }
        let fmaa = to_float_val(args[0])
        let fmab = to_float_val(args[1])
        let fmac = to_float_val(args[2])
        return val_float(fmaa * fmab + fmac)
    }
    // dict_keys(m) — alias of map_keys for anima-speak nn_core compatibility.
    if name == "dict_keys" {
        if len(args) < 1 || args[0].tag != TAG_MAP { return val_array([]) }
        let dks = get_map_keys(args[0])
        return val_array(dks)
    }

    // ── BLAS kernels (Phase 3) ──
    // matmul_into — out[m,n] = a[m,k] . b[k,n]
    // Convention A: matmul_into(out, a, b, m, n, k) — out first
    // Convention B: matmul_into(a, b, m, n, k, out) — out last
    if name == "matmul_into" {
        // Detect convention: if last arg is tensor/array, it is the output buffer
        let mut out_t = args[0]
        let mut a_t = args[1]
        let mut b_t = args[2]
        let mut m_v = args[3].int_val
        let mut n_v = args[4].int_val
        let mut k_v = args[5].int_val
        if args[5].tag == TAG_TENSOR || args[5].tag == TAG_ARRAY {
            // Convention B: (a, b, m, n, k, out)
            a_t = args[0]
            b_t = args[1]
            m_v = args[2].int_val
            n_v = args[3].int_val
            k_v = args[4].int_val
            out_t = args[5]
        }
        let a = if a_t.tag == TAG_TENSOR { tensor_data(a_t) } else { get_array(a_t) }
        let b = if b_t.tag == TAG_TENSOR { tensor_data(b_t) } else { get_array(b_t) }
        let mut out = if out_t.tag == TAG_TENSOR { tensor_data(out_t) } else { [] }
        if len(out) < m_v * n_v {
            let mut z = 0
            while len(out) < m_v * n_v { out.push(0.0); z = z + 1 }
        }
        let mut mi = 0
        while mi < m_v {
            let mut nj = 0
            while nj < n_v {
                let mut acc = 0.0
                let mut kk = 0
                while kk < k_v {
                    acc = acc + a[mi * k_v + kk] * b[kk * n_v + nj]
                    kk = kk + 1
                }
                out[mi * n_v + nj] = acc
                nj = nj + 1
            }
            mi = mi + 1
        }
        if out_t.tag == TAG_TENSOR { tensor_set_data(out_t, out); return out_t }
        return val_tensor([m_v, n_v], out)
    }
    // matmul_into_accumulate(out, a, b, m, n, k) — out += a · b
    if name == "matmul_into_accumulate" {
        let out_t = args[0]
        let a = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let b = if args[2].tag == TAG_TENSOR { tensor_data(args[2]) } else { get_array(args[2]) }
        let m = args[3].int_val
        let n = args[4].int_val
        let k = args[5].int_val
        let mut out = if out_t.tag == TAG_TENSOR { tensor_data(out_t) } else { [] }
        while len(out) < m * n { out.push(0.0) }
        let mut mi = 0
        while mi < m {
            let mut nj = 0
            while nj < n {
                let mut acc = out[mi * n + nj]
                let mut kk = 0
                while kk < k {
                    acc = acc + a[mi * k + kk] * b[kk * n + nj]
                    kk = kk + 1
                }
                out[mi * n + nj] = acc
                nj = nj + 1
            }
            mi = mi + 1
        }
        if out_t.tag == TAG_TENSOR { tensor_set_data(out_t, out); return out_t }
        return val_tensor([m, n], out)
    }
    // matmul_transpose_a_into(out, a, b, m, n, k) — out = aᵀ · b, a shape [k,m]
    if name == "matmul_transpose_a_into" {
        let out_t = args[0]
        let a = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let b = if args[2].tag == TAG_TENSOR { tensor_data(args[2]) } else { get_array(args[2]) }
        let m = args[3].int_val
        let n = args[4].int_val
        let k = args[5].int_val
        let mut out = if out_t.tag == TAG_TENSOR { tensor_data(out_t) } else { [] }
        while len(out) < m * n { out.push(0.0) }
        let mut mi = 0
        while mi < m {
            let mut nj = 0
            while nj < n {
                let mut acc = 0.0
                let mut kk = 0
                while kk < k {
                    acc = acc + a[kk * m + mi] * b[kk * n + nj]
                    kk = kk + 1
                }
                out[mi * n + nj] = acc
                nj = nj + 1
            }
            mi = mi + 1
        }
        if out_t.tag == TAG_TENSOR { tensor_set_data(out_t, out); return out_t }
        return val_tensor([m, n], out)
    }
    // matmul_transpose_b_into(out, a, b, m, n, k) — out = a · bᵀ, b shape [n,k]
    if name == "matmul_transpose_b_into" {
        let out_t = args[0]
        let a = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let b = if args[2].tag == TAG_TENSOR { tensor_data(args[2]) } else { get_array(args[2]) }
        let m = args[3].int_val
        let n = args[4].int_val
        let k = args[5].int_val
        let mut out = if out_t.tag == TAG_TENSOR { tensor_data(out_t) } else { [] }
        while len(out) < m * n { out.push(0.0) }
        let mut mi = 0
        while mi < m {
            let mut nj = 0
            while nj < n {
                let mut acc = 0.0
                let mut kk = 0
                while kk < k {
                    acc = acc + a[mi * k + kk] * b[nj * k + kk]
                    kk = kk + 1
                }
                out[mi * n + nj] = acc
                nj = nj + 1
            }
            mi = mi + 1
        }
        if out_t.tag == TAG_TENSOR { tensor_set_data(out_t, out); return out_t }
        return val_tensor([m, n], out)
    }
    // axpy — BLAS-1 y = alpha*x + y
    // 4-arg: axpy(out, alpha, x, y) — write into out
    // 3-arg: axpy(x, y, alpha)      — return new tensor
    if name == "axpy" {
        if len(args) >= 4 {
            let out_t = args[0]
            let alpha = to_float_val(args[1])
            let x = if args[2].tag == TAG_TENSOR { tensor_data(args[2]) } else { get_array(args[2]) }
            let y = if args[3].tag == TAG_TENSOR { tensor_data(args[3]) } else { get_array(args[3]) }
            let n_axpy = if len(x) < len(y) { len(x) } else { len(y) }
            let mut out = []
            let mut ai = 0
            while ai < n_axpy {
                out.push(alpha * x[ai] + y[ai])
                ai = ai + 1
            }
            if out_t.tag == TAG_TENSOR { tensor_set_data(out_t, out); return out_t }
            return val_tensor([n_axpy], out)
        }
        if len(args) >= 3 {
            let x = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
            let y = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
            let alpha = to_float_val(args[2])
            let n_axpy = if len(x) < len(y) { len(x) } else { len(y) }
            let mut out = []
            let mut ai = 0
            while ai < n_axpy {
                out.push(alpha * x[ai] + y[ai])
                ai = ai + 1
            }
            return val_tensor([n_axpy], out)
        }
        return val_void()
    }
    // mat_add(a, b) — element-wise addition
    if name == "mat_add" {
        let a = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let b = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let n_add = if len(a) < len(b) { len(a) } else { len(b) }
        let mut out = []
        let mut ai = 0
        while ai < n_add { out.push(a[ai] + b[ai]); ai = ai + 1 }
        let shape = if args[0].tag == TAG_TENSOR { tensor_shape(args[0]) } else { [n_add] }
        return val_tensor(shape, out)
    }
    // mat_scale_inplace(t, s) — t *= s in place
    if name == "mat_scale_inplace" {
        let t = args[0]
        let s_scale = to_float_val(args[1])
        if t.tag != TAG_TENSOR { return val_void() }
        let data = tensor_data(t)
        let mut out = []
        for v in data { out.push(v * s_scale) }
        tensor_set_data(t, out)
        return t
    }

    // ── Quant + GGUF (Phase 4) ──
    // q4_0_dequantize(blocks, n_elements) — Q4_0 → f32 array
    // Q4_0 block: 18 bytes = 2 bytes f16 scale + 16 bytes (32 quants × 4 bits)
    if name == "q4_0_dequantize" {
        let blocks = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let n_elem = args[1].int_val
        let mut out = []
        let n_blocks = n_elem / 32
        let mut bi = 0
        while bi < n_blocks {
            let block_off = bi * 18
            // f16 scale (we approximate via float read; real impl needs f16 decode)
            let scale = blocks[block_off + 0]
            let mut qi = 0
            while qi < 16 {
                let byte = blocks[block_off + 2 + qi]
                let lo = (byte % 16) - 8
                let hi = (byte / 16) - 8
                out.push(scale * lo)
                out.push(scale * hi)
                qi = qi + 1
            }
            bi = bi + 1
        }
        return val_tensor([n_elem], out)
    }
    // q4_0_matvec(out, weight_q, x, m, k) — y[m] = W[m,k] · x[k] (W in Q4_0)
    if name == "q4_0_matvec" {
        let out_t = args[0]
        let w = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let x = if args[2].tag == TAG_TENSOR { tensor_data(args[2]) } else { get_array(args[2]) }
        let m = args[3].int_val
        let k = args[4].int_val
        let block_size = 32
        let n_blocks_per_row = k / block_size
        let block_bytes = 18
        let mut out = []
        let mut mi = 0
        while mi < m {
            let mut acc = 0.0
            let mut bi = 0
            while bi < n_blocks_per_row {
                let block_off = (mi * n_blocks_per_row + bi) * block_bytes
                let scale = w[block_off]
                let mut qi = 0
                while qi < 16 {
                    let byte = w[block_off + 2 + qi]
                    let lo = (byte % 16) - 8
                    let hi = (byte / 16) - 8
                    let xi = bi * block_size + qi * 2
                    acc = acc + scale * lo * x[xi]
                    acc = acc + scale * hi * x[xi + 1]
                    qi = qi + 1
                }
                bi = bi + 1
            }
            out.push(acc)
            mi = mi + 1
        }
        if out_t.tag == TAG_TENSOR { tensor_set_data(out_t, out); return out_t }
        return val_tensor([m], out)
    }
    // mmap_gguf(path) → [names, tensors] — stub: delegates to file_read + parse
    if name == "mmap_gguf" || name == "mmap_weights" || name == "load_weights_bin" {
        // Real GGUF parsing requires byte-level f16/i32 decoding which the
        // self-host interpreter cannot do efficiently. We expose an error tag
        // value that downstream code can detect; production code uses Rust path.
        return Val { tag: TAG_ERROR, int_val: 0, float_val: 0.0, bool_val: false, str_val: "mmap_gguf: requires native runtime (not available in self-host)", char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E }
    }

    // ── Attention fusion (Phase 5) ──
    // gqa_expand_kv_into(out, kv, n_kv_head, n_head, head_dim) — broadcast KV groups
    if name == "gqa_expand_kv_into" {
        let out_t = args[0]
        let kv = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
        let n_kv = args[2].int_val
        let n_h = args[3].int_val
        let head_dim = args[4].int_val
        let group = n_h / n_kv
        let mut out = []
        let mut hi = 0
        while hi < n_h {
            let kv_idx = hi / group
            let base = kv_idx * head_dim
            let mut di = 0
            while di < head_dim {
                out.push(kv[base + di])
                di = di + 1
            }
            hi = hi + 1
        }
        if out_t.tag == TAG_TENSOR { tensor_set_data(out_t, out); return out_t }
        return val_tensor([n_h * head_dim], out)
    }
    // qkv_fused_into — fused QKV projection
    // 9-arg: qkv_fused_into(q_out, k_out, v_out, w_qkv, x, n_q, n_k, n_v, dim)
    // 8-arg: qkv_fused_into(X, Uqkv, M, K, R, out_q, out_k, out_v)
    //        Uqkv is [K, 3R] row-major. Extract R-wide column blocks as
    //        flat sub-arrays Uq/Uk/Uv, then run matmul(X, Uq, M, K, R)
    //        on each — same indexing as the standalone matmul builtin.
    //        Returns [Q_tensor, K_tensor, V_tensor]
    if name == "qkv_fused_into" {
        if len(args) == 8 {
            let x_data = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
            let w_data = if args[1].tag == TAG_TENSOR { tensor_data(args[1]) } else { get_array(args[1]) }
            let m_v = args[2].int_val
            let kk_dim = args[3].int_val
            let r_v = args[4].int_val
            let q_out = args[5]
            let k_out = args[6]
            let v_out = args[7]
            let stride = 3 * r_v
            // Extract flat sub-arrays (R cols per block, K rows)
            let mut uq = []
            let mut uk = []
            let mut uv = []
            let mut row = 0
            while row < kk_dim {
                let mut ci = 0
                while ci < r_v {
                    uq.push(w_data[row * stride + ci])
                    uk.push(w_data[row * stride + r_v + ci])
                    uv.push(w_data[row * stride + 2 * r_v + ci])
                    ci = ci + 1
                }
                row = row + 1
            }
            // matmul(X, sub, m, n, k) convention: a[m,k]*b[k,n]->out[m,n]
            // With M, K, R: the matmul sees m=M, n=K, k=R so that
            //   a[mi*R + kk] * b[kk*K + nj]
            // matches matmul(X, Uq, M, K, R) exactly.
            let mm = m_v
            let nn = kk_dim
            let kk = r_v
            let mut q_data = []
            let mut k_data = []
            let mut v_data = []
            let mut mi = 0
            while mi < mm {
                let mut nj = 0
                while nj < nn {
                    let mut aq = 0.0
                    let mut ak = 0.0
                    let mut av2 = 0.0
                    let mut ki = 0
                    while ki < kk {
                        let xv = x_data[mi * kk + ki]
                        aq = aq + xv * uq[ki * nn + nj]
                        ak = ak + xv * uk[ki * nn + nj]
                        av2 = av2 + xv * uv[ki * nn + nj]
                        ki = ki + 1
                    }
                    q_data.push(aq)
                    k_data.push(ak)
                    v_data.push(av2)
                    nj = nj + 1
                }
                mi = mi + 1
            }
            if q_out.tag == TAG_TENSOR { tensor_set_data(q_out, q_data) }
            if k_out.tag == TAG_TENSOR { tensor_set_data(k_out, k_data) }
            if v_out.tag == TAG_TENSOR { tensor_set_data(v_out, v_data) }
            let qt = if q_out.tag == TAG_TENSOR { q_out } else { val_tensor([mm, nn], q_data) }
            let kt = if k_out.tag == TAG_TENSOR { k_out } else { val_tensor([mm, nn], k_data) }
            let vt = if v_out.tag == TAG_TENSOR { v_out } else { val_tensor([mm, nn], v_data) }
            return val_array([qt, kt, vt])
        }
        // 9-arg convention: (q_out, k_out, v_out, w_qkv, x, n_q, n_k, n_v, dim)
        let q_out = args[0]
        let k_out = args[1]
        let v_out = args[2]
        let w = if args[3].tag == TAG_TENSOR { tensor_data(args[3]) } else { get_array(args[3]) }
        let x = if args[4].tag == TAG_TENSOR { tensor_data(args[4]) } else { get_array(args[4]) }
        let n_q = args[5].int_val
        let n_k = args[6].int_val
        let n_v = args[7].int_val
        let dim = args[8].int_val
        let total = n_q + n_k + n_v
        let mut all_out = []
        let mut oi = 0
        while oi < total {
            let mut acc = 0.0
            let mut di = 0
            while di < dim { acc = acc + w[oi * dim + di] * x[di]; di = di + 1 }
            all_out.push(acc)
            oi = oi + 1
        }
        let mut q_data = []
        let mut k_data = []
        let mut v_data = []
        let mut si = 0
        while si < n_q { q_data.push(all_out[si]); si = si + 1 }
        while si < n_q + n_k { k_data.push(all_out[si]); si = si + 1 }
        while si < total { v_data.push(all_out[si]); si = si + 1 }
        if q_out.tag == TAG_TENSOR { tensor_set_data(q_out, q_data) }
        if k_out.tag == TAG_TENSOR { tensor_set_data(k_out, k_data) }
        if v_out.tag == TAG_TENSOR { tensor_set_data(v_out, v_data) }
        return val_array([val_tensor([n_q], q_data), val_tensor([n_k], k_data), val_tensor([n_v], v_data)])
    }
    // repeat_kv(kv, n_repeat, n_kv_head, head_dim) — broadcast each KV head n_repeat times
    if name == "repeat_kv" {
        let kv = if args[0].tag == TAG_TENSOR { tensor_data(args[0]) } else { get_array(args[0]) }
        let n_rep = args[1].int_val
        let n_kv = args[2].int_val
        let head_dim = args[3].int_val
        let mut out = []
        let mut hi = 0
        while hi < n_kv {
            let base = hi * head_dim
            let mut ri = 0
            while ri < n_rep {
                let mut di = 0
                while di < head_dim { out.push(kv[base + di]); di = di + 1 }
                ri = ri + 1
            }
            hi = hi + 1
        }
        return val_tensor([n_kv * n_rep * head_dim], out)
    }

    // ── C2 Step 3: __host_extern_call(c_sym, link_lib, val_arr, ret_type) ──
    //
    // Dispatches an @link extern fn through dlopen/dlsym + scalar-fanout
    // host_ffi_call_6. args[2] is a hexa-level Val array (array_store-
    // backed); we cannot pass it directly through host_ffi_call, so we
    // unwrap up to 6 positional args and feed them as individual Vals.
    if name == "__host_extern_call" {
        if len(args) < 3 {
            return not_builtin
        }
        let c_sym = args[0].str_val
        let lib = args[1].str_val
        let val_arr_v = args[2]
        let ret_type = if len(args) >= 4 { args[3].str_val } else { "" }
        // NOTE: `handle` is a reserved word (effects group), so use lib_h.
        let lib_h = host_ffi_open(lib)
        if lib_h == 0 {
            return Val { tag: TAG_ERROR, int_val: 0, float_val: 0.0, bool_val: false, str_val: "host_ffi_open failed for '" + lib + "'", char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E }
        }
        let fn_ptr = host_ffi_sym(lib_h, c_sym)
        if fn_ptr == 0 {
            return Val { tag: TAG_ERROR, int_val: 0, float_val: 0.0, bool_val: false, str_val: "host_ffi_sym failed for '" + c_sym + "'", char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E }
        }
        let call_args = get_array(val_arr_v)
        let nargs = len(call_args)
        // Pre-flight: reject TAG_POINTER args (registry indices, not real
        // addresses). alloc_raw without ffi_real_pointer_mode returns these;
        // passing them to a native extern segfaults on first deref.
        let mut pp = 0
        while pp < nargs {
            if call_args[pp].tag == TAG_POINTER {
                return Val { tag: TAG_ERROR, int_val: 0, float_val: 0.0, bool_val: false, str_val: "extern '" + c_sym + "' arg " + to_string(pp) + " is TAG_POINTER (registry index). Set HXLAYER_FFI_LIVE=1 or ensure libhxlayer is loadable so alloc_raw returns real pointers.", char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E }
            }
            pp = pp + 1
        }
        let void_v = val_void()
        let a0 = if nargs > 0 { call_args[0] } else { void_v }
        let a1 = if nargs > 1 { call_args[1] } else { void_v }
        let a2 = if nargs > 2 { call_args[2] } else { void_v }
        let a3 = if nargs > 3 { call_args[3] } else { void_v }
        let a4 = if nargs > 4 { call_args[4] } else { void_v }
        let a5 = if nargs > 5 { call_args[5] } else { void_v }
        // Build float_mask via int doubling (no native <<).
        let mut float_mask = 0
        let mut k = 0
        while k < nargs && k < 14 {
            if call_args[k].tag == TAG_FLOAT {
                let mut bit = 1
                let mut bi = 0
                while bi < k { bit = bit * 2; bi = bi + 1 }
                float_mask = float_mask + bit
            }
            k = k + 1
        }
        let mut ret_kind = 1
        if ret_type == "float" || ret_type == "f64" || ret_type == "f32" || ret_type == "double" { ret_kind = 2 }
        if ret_type == "bool" { ret_kind = 3 }
        if ret_type == "ptr" || ret_type == "void*" || ret_type == "*mut" { ret_kind = 4 }
        if ret_type == "void" || ret_type == "Void" || ret_type == "" { ret_kind = 0 }
        // For >6 args (vDSP_mmul 9, cblas_sgemm 14): use magic fn_ptr=-1
        // call to push overflow args into C-side static buffer first, then
        // dispatch the real call with nargs>6 so C reads from the buffer.
        if nargs > 6 {
            let o0 = if nargs > 6  { call_args[6]  } else { void_v }
            let o1 = if nargs > 7  { call_args[7]  } else { void_v }
            let o2 = if nargs > 8  { call_args[8]  } else { void_v }
            let o3 = if nargs > 9  { call_args[9]  } else { void_v }
            let o4 = if nargs > 10 { call_args[10] } else { void_v }
            let o5 = if nargs > 11 { call_args[11] } else { void_v }
            let _ = host_ffi_call_6(val_int(0 - 1), val_int(nargs - 6), val_int(0), val_int(0), o0, o1, o2, o3, o4, o5)
            if nargs > 12 {
                let p0 = if nargs > 12 { call_args[12] } else { void_v }
                let p1 = if nargs > 13 { call_args[13] } else { void_v }
                let _ = host_ffi_call_6(val_int(0 - 2), val_int(nargs - 12), val_int(0), val_int(0), p0, p1, void_v, void_v, void_v, void_v)
            }
        }
        // host_ffi_call_6 with real fn_ptr dispatches the call.
        // When nargs>6, C side reads overflow args from the static buffer.
        return host_ffi_call_6(fn_ptr, nargs, float_mask, ret_kind, a0, a1, a2, a3, a4, a5)
    }

    // ── stdlib/array free-standing helpers ──────────────────
    if name == "array_reverse" {
        let arr_val = args[0]
        if arr_val.tag != TAG_ARRAY { return val_array([]) }
        let items = get_array(arr_val)
        let n = len(items)
        if n < 2 { return arr_val }
        let mut out = []
        let mut i = n - 1
        while i > 0 { out.push(items[i]); i = i - 1 }
        out.push(items[0])
        return val_array(out)
    }
    if name == "array_contains" {
        let items = get_array(args[0])
        let needle = args[1]
        let mut i = 0
        while i < len(items) {
            if val_eq(items[i], needle) { return val_bool(true) }
            i = i + 1
        }
        return val_bool(false)
    }
    if name == "array_index_of" {
        let items = get_array(args[0])
        let needle = args[1]
        let mut i = 0
        while i < len(items) {
            if val_eq(items[i], needle) { return val_int(i) }
            i = i + 1
        }
        return val_int(-1)
    }
    if name == "array_sum" {
        // ω-stdlib-5 (2026-04-26): mixed int/float fix. Was: accumulated into
        // a single `total` and `total = total + items[i].float_val` silently
        // promoted to float, but `return val_int(total)` truncated the
        // fractional part — silent precision loss. Mirrors the `sum` arm
        // (line ~14403) which already does this correctly.
        if len(args) == 0 || args[0].tag != TAG_ARRAY { return val_int(0) }
        let items = get_array(args[0])
        let mut has_float = false
        let mut int_total = 0
        let mut float_total = 0.0
        let mut i = 0
        while i < len(items) {
            if items[i].tag == TAG_FLOAT {
                has_float = true
                float_total = float_total + items[i].float_val
            } else {
                int_total = int_total + items[i].int_val
            }
            i = i + 1
        }
        if has_float { return val_float(int_total * 1.0 + float_total) }
        return val_int(int_total)
    }
    if name == "array_product" {
        // ω-stdlib-5 (2026-04-26): same fix as array_sum — mixed int/float
        // products were truncated by `return val_int(total)` after float
        // promotion. Now keep separate accumulators and return val_float when
        // any float was seen.
        if len(args) == 0 || args[0].tag != TAG_ARRAY { return val_int(1) }
        let items = get_array(args[0])
        let n = len(items)
        if n == 0 { return val_int(1) }
        let mut has_float = false
        let mut int_total = 1
        let mut float_total = 1.0
        let mut i = 0
        while i < n {
            if items[i].tag == TAG_FLOAT {
                has_float = true
                float_total = float_total * items[i].float_val
            } else {
                int_total = int_total * items[i].int_val
            }
            i = i + 1
        }
        if has_float { return val_float(int_total * 1.0 * float_total) }
        return val_int(int_total)
    }
    if name == "array_min" {
        // ω-stdlib-5 (2026-04-26): float-aware. Was: `let v = items[i].int_val`
        // unconditionally — every float element compared as 0 (uninitialized
        // int_val on a TAG_FLOAT Val), so `array_min([3.5, 1.2, 9.0])` returned
        // 0 instead of the smallest. Now coerces via float when any float seen.
        if len(args) == 0 || args[0].tag != TAG_ARRAY { return val_void() }
        let items = get_array(args[0])
        let n = len(items)
        if n == 0 { return val_void() }
        let mut has_float = false
        let mut i = 0
        while i < n {
            if items[i].tag == TAG_FLOAT { has_float = true; i = n } else { i = i + 1 }
        }
        if has_float {
            let mut best = to_float_val(items[0])
            let mut j = 1
            while j < n {
                let v = to_float_val(items[j])
                if v < best { best = v }
                j = j + 1
            }
            return val_float(best)
        }
        let mut best_i = items[0].int_val
        let mut k = 1
        while k < n {
            let v = items[k].int_val
            if v < best_i { best_i = v }
            k = k + 1
        }
        return val_int(best_i)
    }
    if name == "array_max" {
        // ω-stdlib-5 (2026-04-26): float-aware (see array_min rationale).
        if len(args) == 0 || args[0].tag != TAG_ARRAY { return val_void() }
        let items = get_array(args[0])
        let n = len(items)
        if n == 0 { return val_void() }
        let mut has_float = false
        let mut i = 0
        while i < n {
            if items[i].tag == TAG_FLOAT { has_float = true; i = n } else { i = i + 1 }
        }
        if has_float {
            let mut best = to_float_val(items[0])
            let mut j = 1
            while j < n {
                let v = to_float_val(items[j])
                if v > best { best = v }
                j = j + 1
            }
            return val_float(best)
        }
        let mut best_i = items[0].int_val
        let mut k = 1
        while k < n {
            let v = items[k].int_val
            if v > best_i { best_i = v }
            k = k + 1
        }
        return val_int(best_i)
    }
    if name == "array_concat" {
        // ω-stdlib-5 (2026-04-26): tag-guard. Was: get_array on non-array
        // would either crash or silently return []. Now we explicitly guard
        // and tolerate either side being non-array (treated as empty).
        if len(args) < 2 { return val_array([]) }
        let a = if args[0].tag == TAG_ARRAY { get_array(args[0]) } else { [] }
        let b = if args[1].tag == TAG_ARRAY { get_array(args[1]) } else { [] }
        let mut out = []
        let mut i = 0
        while i < len(a) { out.push(a[i]); i = i + 1 }
        i = 0
        while i < len(b) { out.push(b[i]); i = i + 1 }
        return val_array(out)
    }
    if name == "array_take" {
        let items = get_array(args[0])
        let n = args[1].int_val
        let sz = len(items)
        let take_n = if n < sz { n } else { sz }
        let mut out = []
        let mut i = 0
        while i < take_n { out.push(items[i]); i = i + 1 }
        return val_array(out)
    }
    if name == "array_drop" {
        let items = get_array(args[0])
        let n = args[1].int_val
        let sz = len(items)
        let start = if n < sz { n } else { sz }
        let mut out = []
        let mut i = start
        while i < sz { out.push(items[i]); i = i + 1 }
        return val_array(out)
    }
    if name == "array_count" {
        let items = get_array(args[0])
        let needle = args[1]
        let mut cnt = 0
        let mut i = 0
        while i < len(items) {
            if val_eq(items[i], needle) { cnt = cnt + 1 }
            i = i + 1
        }
        return val_int(cnt)
    }

    // ── stdlib/map free-standing helpers ─────────────────────
    // ω-stdlib-12 (2026-04-26): TAG_MAP guards added to mirror dict_keys
    // pattern. Previously all map_* free-standing arms called
    // get_map_keys(args[0]) → map_store[v.int_val] which crashes when caller
    // passes void/empty-array/null on cold-start paths. Now degrade to
    // empty/false/fallback identically to call_method() void-fallback at
    // line 15938. Mirror: anti-spoof L0 lift (silent void crash → empty
    // contract) per omega-cycle stdlib sweep series.
    if name == "map_size" {
        if len(args) < 1 || args[0].tag != TAG_MAP { return val_int(0) }
        let ks = get_map_keys(args[0])
        return val_int(len(ks))
    }
    if name == "map_contains_key" {
        if len(args) < 2 || args[0].tag != TAG_MAP { return val_bool(false) }
        let ks = get_map_keys(args[0])
        let key = args[1]
        let mut i = 0
        while i < len(ks) {
            if val_eq(ks[i], key) { return val_bool(true) }
            i = i + 1
        }
        return val_bool(false)
    }
    if name == "map_get_or" {
        if len(args) < 3 { return val_void() }
        if args[0].tag != TAG_MAP { return args[2] }
        let ks = get_map_keys(args[0])
        let vs = get_map_values(args[0])
        let key = args[1]
        let fallback = args[2]
        let mut i = 0
        while i < len(ks) {
            if val_eq(ks[i], key) { return vs[i] }
            i = i + 1
        }
        return fallback
    }
    if name == "map_keys" {
        if len(args) < 1 || args[0].tag != TAG_MAP { return val_array([]) }
        let ks = get_map_keys(args[0])
        return val_array(ks)
    }
    if name == "map_values" {
        if len(args) < 1 || args[0].tag != TAG_MAP { return val_array([]) }
        let vs = get_map_values(args[0])
        return val_array(vs)
    }
    if name == "map_entries" {
        if len(args) < 1 || args[0].tag != TAG_MAP { return val_array([]) }
        let ks = get_map_keys(args[0])
        let vs = get_map_values(args[0])
        let mut out = []
        let mut i = 0
        while i < len(ks) {
            let pair = val_array([ks[i], vs[i]])
            out.push(pair)
            i = i + 1
        }
        return val_array(out)
    }
    if name == "map_is_empty" {
        if len(args) < 1 || args[0].tag != TAG_MAP { return val_bool(true) }
        let ks = get_map_keys(args[0])
        return val_bool(len(ks) == 0)
    }
    if name == "map_sum_values" {
        // ω-stdlib-5 (2026-04-26): float-aware (mirrors array_sum fix). Was:
        // single-accumulator with float promotion silently truncated by
        // `return val_int(total)`.
        // ω-stdlib-12 (2026-04-26): TAG_MAP guard added.
        if len(args) == 0 { return val_int(0) }
        if args[0].tag != TAG_MAP { return val_int(0) }
        let vs = get_map_values(args[0])
        let mut has_float = false
        let mut int_total = 0
        let mut float_total = 0.0
        let mut i = 0
        while i < len(vs) {
            if vs[i].tag == TAG_FLOAT {
                has_float = true
                float_total = float_total + vs[i].float_val
            } else {
                int_total = int_total + vs[i].int_val
            }
            i = i + 1
        }
        if has_float { return val_float(int_total * 1.0 + float_total) }
        return val_int(int_total)
    }
    if name == "map_count_values" {
        // ω-stdlib-12 (2026-04-26): TAG_MAP guard.
        if len(args) < 2 || args[0].tag != TAG_MAP { return val_int(0) }
        let vs = get_map_values(args[0])
        let needle = args[1]
        let mut cnt = 0
        let mut i = 0
        while i < len(vs) {
            if val_eq(vs[i], needle) { cnt = cnt + 1 }
            i = i + 1
        }
        return val_int(cnt)
    }

    // ── has_key(map, key) — free-function alias for map.contains_key ──
    if name == "has_key" {
        if len(args) >= 2 && args[0].tag == TAG_MAP {
            return val_bool(map_contains_key(args[0], args[1]))
        }
        return val_bool(false)
    }

    // ── keys(map) — free-function alias for map.keys() ──
    if name == "keys" {
        if len(args) >= 1 && args[0].tag == TAG_MAP {
            let ks = get_map_keys(args[0])
            return val_array(ks)
        }
        return val_array([])
    }

    // ── rand_2d(rows, cols, seed_ref) — 2D array of pseudo-random floats ──
    if name == "rand_2d" {
        if len(args) < 2 { return val_array([]) }
        let rows = args[0].int_val
        let cols = args[1].int_val
        // seed_ref is a 1-element array used as mutable PRNG state
        let mut seed = 42
        if len(args) >= 3 {
            let sr = get_array(args[2])
            if len(sr) > 0 { seed = sr[0].int_val }
        }
        let mut result = []
        let mut ri = 0
        while ri < rows {
            let mut row = []
            let mut ci = 0
            while ci < cols {
                // LCG PRNG: same algorithm as conscious_lm.hexa rand_float
                seed = (seed * 1103515245 + 12345) % 2147483647
                let f = (seed % 20000) - 10000
                row.push(val_float(f / 100000.0))
                ci = ci + 1
            }
            result.push(val_array(row))
            ri = ri + 1
        }
        // Write back updated seed
        if len(args) >= 3 && args[2].tag == TAG_ARRAY {
            let sr = get_array(args[2])
            if len(sr) > 0 {
                sr[0] = val_int(seed)
            }
        }
        return val_array(result)
    }

    // ── gc_num_segments(num_layers, seg_size) — ceiling division ──
    if name == "gc_num_segments" {
        if len(args) >= 2 {
            let num_layers = args[0].int_val
            let seg_size = args[1].int_val
            if seg_size <= 0 { return val_int(num_layers) }
            let mut s = num_layers / seg_size
            if num_layers % seg_size != 0 { s = s + 1 }
            return val_int(s)
        }
        return val_int(0)
    }

    return not_builtin
}

// ── Method dispatch ──────────────────────────────────────

fn call_method(obj, method, args) {
    // ── Void/nil defensive fallback (hxa-20260424-008) ──
    // nexus bisociation/convergence_index.hexa patterns such as
    //   let rkeys = results.keys()  // results may be void on empty trial
    //   while i < ci.layers.len()   // ci.layers may be void on first tick
    // rely on void.keys() → [] and void.len() → 0 (P13 골화 semantics).
    // Previously void.keys() raised "not callable on void" → tool abort.
    // Mirror: null-safe navigation. Other methods fall through to the
    // dispatcher tail (which produces a diagnostic error) — only these
    // two collection shapes are defensivised.
    if obj.tag == TAG_VOID {
        if method == "keys" { return val_array([]) }
        if method == "len" { return val_int(0) }
        if method == "is_empty" { return val_bool(true) }
        if method == "to_string" { return val_str("") }
    }
    // ── Error fallback (P13 골화, mirrors src/interpreter.rs:3717) ──
    // exec(...).trim() 패턴이 subprocess 실패 시 Error → .trim() 크래시로 이어지던
    // P11 안티패턴 영구 소거. tag="error"는 string method 호출 시 안전 기본값 반환.
    if obj.tag == TAG_ERROR {
        if method == "trim" || method == "to_lower" || method == "to_upper" || method == "to_lowercase" || method == "to_uppercase" {
            return val_str("")
        }
        if method == "len" { return val_int(0) }
        if method == "is_empty" { return val_bool(true) }
        if method == "contains" || method == "starts_with" || method == "ends_with" {
            return val_bool(false)
        }
        if method == "split" || method == "lines" || method == "chars" || method == "bytes" {
            return val_array([])
        }
        if method == "replace" || method == "replacen" { return val_str("") }
        if method == "find" || method == "rfind" || method == "index_of" || method == "last_index_of" { return val_int(-1) }
        if method == "char_at" || method == "slice" || method == "nth_char" || method == "char_substring" { return val_str("") }
        if method == "byte_at" || method == "char_count" { return val_int(0) }
        // ω-stdlib-16: dead duplicate dispatcher removed.
        // `to_lowercase`/`to_uppercase` were already covered by the
        // first-branch chain at the top of this TAG_ERROR scope (see
        // first if at start of TAG_ERROR block), so this line was
        // unreachable (first-match-wins). Mirror of stdlib-15 sweep.
        if method == "to_string" { return val_str(obj.str_val) }
        // 그 외 메소드는 fall-through (오류 명시는 dispatcher 끝에서)
    }

    // String methods
    if obj.tag == TAG_STR {
        let s = obj.str_val
        if method == "chars" {
            // 2026-04-20: UTF-8 codepoint-aware iteration at dispatch level.
            // Native s.chars() byte-splits multibyte content (Korean/emoji),
            // corrupting downstream index math. Walk UTF-8 boundaries here:
            // head bytes are those with top 2 bits != 10 (0x80..=0xBF).
            let sl = len(s)
            let mut result = []
            let mut bi = 0
            while bi < sl {
                let b = char_code(s, bi)
                let mut cp_len = 1
                if b >= 240 { cp_len = 4 }
                else if b >= 224 { cp_len = 3 }
                else if b >= 192 { cp_len = 2 }
                else if b >= 128 { cp_len = 1 }
                else { cp_len = 1 }
                let mut endx = bi + cp_len
                if endx > sl { endx = sl }
                result.push(val_str(s.substring(bi, endx)))
                bi = endx
            }
            return val_array(result)
        }
        if method == "len" { return val_int(len(s)) }
        if method == "contains" { return val_bool(s.contains(args[0].str_val)) }
        if method == "starts_with" { return val_bool(s.starts_with(args[0].str_val)) }
        if method == "ends_with" { return val_bool(s.ends_with(args[0].str_val)) }
        if method == "to_upper" { return val_str(s.to_upper()) }
        if method == "to_lower" { return val_str(s.to_lower()) }
        if method == "trim" { return val_str(s.trim()) }
        if method == "split" {
            let parts = s.split(args[0].str_val)
            let mut result = []
            for p in parts { result.push(val_str(p)) }
            return val_array(result)
        }
        if method == "replace" { return val_str(s.replace(args[0].str_val, args[1].str_val)) }
        if method == "substring" { return val_str(s.substring(args[0].int_val, args[1].int_val)) }
        if method == "substr" {
            // JS-style .substr(start, length) — second arg is length,
            // not end index. Clamp start/length to [0, len(s)] so
            // out-of-range calls return "" instead of host crash.
            let slen = len(s)
            let mut start = args[0].int_val
            if start < 0 { start = 0 }
            if start > slen { start = slen }
            let mut count = if len(args) >= 2 { args[1].int_val } else { slen - start }
            if count < 0 { count = 0 }
            let mut end_idx = start + count
            if end_idx > slen { end_idx = slen }
            return val_str(s.substring(start, end_idx))
        }
        if method == "index_of" {
            // hxa-20260423-012: 2-arg form .index_of(sub, start) must honor
            // start offset. Previously args[1] was silently dropped.
            if len(args) >= 2 {
                let sub2 = args[0].str_val
                let mut st = args[1].int_val
                let slen2 = len(s)
                let sublen2 = len(sub2)
                if st < 0 { st = 0 }
                if sublen2 == 0 { return val_int(st) }
                if st > slen2 { return val_int(-1) }
                let mut ix = st
                while ix + sublen2 <= slen2 {
                    if s.substring(ix, ix + sublen2) == sub2 { return val_int(ix) }
                    ix = ix + 1
                }
                return val_int(-1)
            }
            return val_int(s.index_of(args[0].str_val))
        }
        if method == "repeat" {
            let n = args[0].int_val
            let mut result = ""
            let mut ri = 0
            while ri < n {
                result = result + s
                ri = ri + 1
            }
            return val_str(result)
        }
        if method == "reverse" {
            let cs = s.chars()
            let mut out = ""
            let mut ri = len(cs) - 1
            while ri >= 0 {
                out = out + to_string(cs[ri])
                ri = ri - 1
            }
            return val_str(out)
        }
        if method == "is_empty" {
            return val_bool(s == "")
        }
        if method == "count" {
            // .count(substr) — count occurrences
            if len(args) > 0 && args[0].tag == TAG_STR {
                let sub = args[0].str_val
                let slen = len(s)
                let sublen = len(sub)
                if sublen == 0 { return val_int(0) }
                let mut cnt = 0
                let mut ci = 0
                while ci <= slen - sublen {
                    if s.substring(ci, ci + sublen) == sub {
                        cnt = cnt + 1
                        ci = ci + sublen
                    } else {
                        ci = ci + 1
                    }
                }
                return val_int(cnt)
            }
            return val_int(0)
        }
        if method == "pad_left" {
            let width = args[0].int_val
            let ch = args[1].str_val
            let mut out = s
            while len(out) < width { out = ch + out }
            return val_str(out)
        }
        if method == "pad_right" {
            let width = args[0].int_val
            let ch = args[1].str_val
            let mut out = s
            while len(out) < width { out = out + ch }
            return val_str(out)
        }
        if method == "center" {
            let width = args[0].int_val
            let ch = args[1].str_val
            let slen = len(s)
            if slen >= width { return val_str(s) }
            let total_pad = width - slen
            let left_pad = total_pad / 2
            let right_pad = total_pad - left_pad
            let mut out = ""
            let mut li = 0
            while li < left_pad { out = out + ch; li = li + 1 }
            out = out + s
            let mut ri = 0
            while ri < right_pad { out = out + ch; ri = ri + 1 }
            return val_str(out)
        }
        // ── String methods ported from src/interpreter.rs call_string_method ──
        if method == "trim_start" { return val_str(s.trim_start()) }
        if method == "trim_end" { return val_str(s.trim_end()) }
        if method == "parse_int" {
            let trimmed = s.trim()
            let n = to_int(trimmed)
            return val_int(n)
        }
        if method == "parse_float" {
            let trimmed = s.trim()
            let n = to_float(val_str(trimmed))
            return val_float(n)
        }
        if method == "join" {
            // "sep".join(array) — join array elements with separator
            // FIX: O(n²) → O(n). 네이티브 str_parts.join(sep) 위임.
            if len(args) > 0 && args[0].tag == TAG_ARRAY {
                let items = get_array(args[0])
                let mut str_parts = []
                for item in items {
                    str_parts.push(val_to_string(item))
                }
                return val_str(str_parts.join(s))
            }
            return val_str("")
        }
        if method == "bytes" {
            let cs = s.chars()
            let mut result = []
            for c in cs { result.push(val_int(char_code(to_string(c), 0))) }
            return val_array(result)
        }
        // ── Byte-indexed string API (2026-04-20) ────────────────
        // Standardized semantics: ALL string indices are BYTE offsets.
        // This matches s.len() (bytes), s.index_of() (bytes), and
        // s.substring(a,b) (bytes via native memcpy). For multibyte
        // (UTF-8) content use .char_count() / .nth_char() / .chars().
        if method == "find" {
            // .find(sub) — alias for .index_of. Missing method fix
            // (previously forced anima to workaround via .index_of).
            return val_int(s.index_of(args[0].str_val))
        }
        if method == "rfind" || method == "last_index_of" {
            // .last_index_of(sub) — byte position of LAST occurrence.
            // Returns -1 if not found. Previously missing; workaround
            // was manual backward scan (see tool/raw_exemptions.hexa).
            if len(args) == 0 || args[0].tag != TAG_STR { return val_int(-1) }
            let sub = args[0].str_val
            let slen = len(s)
            let sublen = len(sub)
            if sublen == 0 { return val_int(slen) }
            if sublen > slen { return val_int(-1) }
            let mut li = slen - sublen
            while li >= 0 {
                if s.substring(li, li + sublen) == sub { return val_int(li) }
                li = li - 1
            }
            return val_int(-1)
        }
        if method == "char_at" {
            // .char_at(i) — byte-indexed single-byte extract.
            // For ASCII this returns the expected character; for
            // multibyte content it returns the raw byte at i (use
            // .nth_char(i) for codepoint-aware access).
            // 음수 idx wraparound (Python-style) — AOT hexa_str_char_at 와 align.
            if len(args) == 0 { return val_str("") }
            let mut i = args[0].int_val
            let sl = len(s)
            if i < 0 { i = i + sl }
            if i < 0 || i >= sl { return val_str("") }
            return val_str(s.substring(i, i + 1))
        }
        if method == "char_code_at" {
            // .char_code_at(i) — byte value (0..255) at offset i, -1 if OOB.
            // AOT runtime: hexa_str_char_code_at. 이전엔 interp 에만 누락되어
            // "unknown method" Runtime error.
            if len(args) == 0 { return val_int(-1) }
            let mut i = args[0].int_val
            let sl = len(s)
            if i < 0 { i = i + sl }
            if i < 0 || i >= sl { return val_int(-1) }
            return val_int(char_code(s, i))
        }
        if method == "slice" {
            // .slice(start, end) — alias for .substring(start, end).
            // Byte indices. Both args optional-ish: if end omitted
            // (len(args) < 2), slice to end of string.
            if len(args) == 0 { return val_str(s) }
            let sl = len(s)
            let mut a = args[0].int_val
            let mut b = if len(args) >= 2 { args[1].int_val } else { sl }
            if a < 0 { a = 0 }
            if b > sl { b = sl }
            if a >= b { return val_str("") }
            return val_str(s.substring(a, b))
        }
        if method == "byte_at" {
            // .byte_at(i) — raw byte value (0-255) at byte index i.
            // Returns -1 if out of range.
            if len(args) == 0 { return val_int(-1) }
            let i = args[0].int_val
            let sl = len(s)
            if i < 0 || i >= sl { return val_int(-1) }
            return val_int(char_code(s, i))
        }
        if method == "char_count" {
            // .char_count() — UTF-8 codepoint count (multibyte-safe).
            // For ASCII equals .len(); for Korean/emoji is smaller.
            // Counts bytes whose top 2 bits are not 10 (continuation).
            let sl = len(s)
            let mut cc = 0
            let mut bi = 0
            while bi < sl {
                let b = char_code(s, bi)
                // continuation bytes: 10xxxxxx (0x80..=0xBF)
                if b < 128 || b >= 192 { cc = cc + 1 }
                bi = bi + 1
            }
            return val_int(cc)
        }
        if method == "nth_char" {
            // .nth_char(i) — UTF-8 codepoint at char position i,
            // returned as a string. Returns "" if out of range.
            if len(args) == 0 { return val_str("") }
            let target = args[0].int_val
            if target < 0 { return val_str("") }
            let sl = len(s)
            let mut cc = 0
            let mut bi = 0
            let mut start = -1
            let mut endx = -1
            while bi < sl {
                let b = char_code(s, bi)
                let is_head = b < 128 || b >= 192
                if is_head {
                    if cc == target { start = bi }
                    if start >= 0 && bi > start && endx == -1 { endx = bi }
                    cc = cc + 1
                }
                bi = bi + 1
            }
            if start < 0 { return val_str("") }
            if endx < 0 { endx = sl }
            return val_str(s.substring(start, endx))
        }
        if method == "char_substring" {
            // .char_substring(a, b) — char-indexed substring.
            // Safe for multibyte content. Converts char indices to
            // byte offsets via UTF-8 walk, then delegates to native
            // byte-level .substring(). Use this for JSON/text where
            // indices come from char-counted sources.
            if len(args) < 2 { return val_str("") }
            let ca = args[0].int_val
            let cb = args[1].int_val
            if ca >= cb { return val_str("") }
            let sl = len(s)
            let mut cc = 0
            let mut bi = 0
            let mut byte_a = -1
            let mut byte_b = -1
            let mut done = false
            while bi <= sl && !done {
                let mut is_boundary = bi == sl
                if !is_boundary {
                    let bb = char_code(s, bi)
                    if bb < 128 || bb >= 192 { is_boundary = true }
                }
                if is_boundary {
                    if cc == ca { byte_a = bi }
                    if cc == cb { byte_b = bi; done = true }
                    cc = cc + 1
                }
                bi = bi + 1
            }
            if byte_a < 0 { return val_str("") }
            if byte_b < 0 { byte_b = sl }
            return val_str(s.substring(byte_a, byte_b))
        }
        if method == "to_lowercase" {
            return val_str(s.to_lower())
        }
        if method == "to_uppercase" {
            return val_str(s.to_upper())
        }
    }

    // ── Phase 7 골화 — Pointer methods ──
    if obj.tag == TAG_POINTER {
        if method == "is_null" { return val_bool(obj.int_val == 0) }
        if method == "addr" { return val_int(obj.int_val) }
        if method == "to_string" { return val_str("0x" + hex(obj.int_val)) }
    }

    // ── Phase 7 골화 — Atomic methods ──
    if obj.tag == TAG_ATOMIC {
        if method == "load" { return atomic_load(obj) }
        if method == "store" { atomic_store_op(obj, args[0]); return val_void() }
        if method == "compare_swap" || method == "compare_and_swap" {
            return atomic_compare_swap(obj, args[0], args[1])
        }
        if method == "fetch_add" { return atomic_fetch_add(obj, args[0]) }
    }

    // ── Phase 7 골화 — Channel methods (Sender/Receiver unified) ──
    if obj.tag == TAG_CHANNEL {
        if method == "send" { return val_bool(channel_send(obj, args[0])) }
        if method == "recv" {
            let r = channel_recv(obj)
            if r.tag == TAG_VOID {
                return Val { tag: TAG_ERROR, int_val: 0, float_val: 0.0, bool_val: false, str_val: "channel closed", char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E }
            }
            return r
        }
        if method == "try_recv" {
            let r = channel_recv(obj)
            // Some(r) | None as enum
            if r.tag == TAG_VOID { return val_enum("Option", "None", "") }
            return val_enum("Option", "Some", r)
        }
        if method == "close" { channel_close(obj); return val_void() }
        if method == "receiver" { return val_channel_recv_view(obj) }
    }

    // ── Phase 2 골화 — Tensor methods ──
    if obj.tag == TAG_TENSOR {
        if method == "shape" {
            let shp = tensor_shape(obj)
            let mut wrapped = []
            for d in shp { wrapped.push(val_int(d)) }
            return val_array(wrapped)
        }
        if method == "data" {
            let d = tensor_data(obj)
            let mut wrapped = []
            for v in d { wrapped.push(val_float(v)) }
            return val_array(wrapped)
        }
        if method == "numel" || method == "len" { return val_int(tensor_numel(obj)) }
        if method == "rank" { return val_int(len(tensor_shape(obj))) }
        if method == "to_array" {
            let d = tensor_data(obj)
            let mut wrapped = []
            for v in d { wrapped.push(val_float(v)) }
            return val_array(wrapped)
        }
    }

    // ── Phase 4 골화 — BigInt methods ──
    if obj.tag == TAG_BIGINT {
        if method == "to_string" { return val_str(bigint_str(obj)) }
        if method == "to_int" { return val_int(to_int(bigint_str(obj))) }
    }

    // Array methods
    if obj.tag == TAG_ARRAY {
        let items = get_array(obj)
        if method == "len" { return val_int(len(items)) }
        // Perf #10: in-place push when sole owner (refcount==1), else COW
        if method == "push" { return array_push_inplace(obj, args[0]) }
        // bt 55 — truncate: in-place length shrink. Sole owner mutates
        // backing store via host .truncate (retains cap); shared path COWs.
        if method == "truncate" {
            let mut new_len = args[0].int_val
            if new_len < 0 { new_len = 0 }
            if new_len > len(items) { new_len = len(items) }
            let idx = obj.int_val
            if array_is_sole_owner(idx) {
                array_store[idx] = items.truncate(new_len)
                return obj
            }
            // Shared: COW — build a truncated copy, decref old
            let mut copy = []
            let mut ti = 0
            while ti < new_len {
                copy.push(items[ti])
                ti = ti + 1
            }
            array_decref(idx)
            return val_array(copy)
        }
        if method == "pop" {
            if len(items) == 0 { return val_array([]) }
            let mut result = []
            let mut pi = 0
            while pi < len(items) - 1 {
                result.push(items[pi])
                pi = pi + 1
            }
            return val_array(result)
        }
        if method == "contains" {
            let target = args[0]
            for item in items {
                if val_eq(item, target) { return val_bool(true) }
            }
            return val_bool(false)
        }
        if method == "join" {
            // FIX: 이전 `out = out + sep` 반복 연결은 O(n²) — 16K줄 .join() 시
            // 125GB 할당 → 11.7GB RSS. 네이티브 str_parts.join(sep) 위임으로 O(n).
            let sep = args[0].str_val
            let mut str_parts = []
            for item in items {
                str_parts.push(val_to_string(item))
            }
            return val_str(str_parts.join(sep))
        }
        if method == "index_of" {
            let target = args[0]
            let mut ii = 0
            while ii < len(items) {
                if val_eq(items[ii], target) { return val_int(ii) }
                ii = ii + 1
            }
            return val_int(-1)
        }
        if method == "slice" {
            let start = args[0].int_val
            let end_idx = args[1].int_val
            let mut result = []
            let mut si = start
            while si < end_idx && si < len(items) {
                result.push(items[si])
                si = si + 1
            }
            return val_array(result)
        }
        if method == "reverse" {
            let mut result = []
            let mut ri = len(items) - 1
            while ri >= 0 {
                result.push(items[ri])
                ri = ri - 1
            }
            return val_array(result)
        }
        if method == "map" {
            let mut result = []
            for item in items {
                result.push(call_fn_val(args[0], [item]))
            }
            return val_array(result)
        }
        if method == "filter" {
            let mut result = []
            for item in items {
                let keep = call_fn_val(args[0], [item])
                if is_truthy(keep) { result.push(item) }
            }
            return val_array(result)
        }
        if method == "fold" {
            let mut acc = args[0]
            let f = args[1]
            for item in items {
                acc = call_fn_val(f, [acc, item])
            }
            return acc
        }
        if method == "for_each" {
            for item in items {
                call_fn_val(args[0], [item])
            }
            return val_void()
        }
        if method == "any" {
            for item in items {
                let r = call_fn_val(args[0], [item])
                if is_truthy(r) { return val_bool(true) }
            }
            return val_bool(false)
        }
        if method == "all" {
            for item in items {
                let r = call_fn_val(args[0], [item])
                if !is_truthy(r) { return val_bool(false) }
            }
            return val_bool(true)
        }
        if method == "flat_map" {
            let mut result = []
            for item in items {
                let sub = call_fn_val(args[0], [item])
                if sub.tag == TAG_ARRAY {
                    let sub_items = get_array(sub)
                    for s in sub_items { result.push(s) }
                } else {
                    result.push(sub)
                }
            }
            return val_array(result)
        }
        if method == "sort" {
            let sorted = sort_array(items)
            return val_array(sorted)
        }
        if method == "enumerate" {
            let mut result = []
            let mut ei = 0
            while ei < len(items) {
                result.push(val_array([val_int(ei), items[ei]]))
                ei = ei + 1
            }
            return val_array(result)
        }
        if method == "zip" {
            if len(args) > 0 && args[0].tag == TAG_ARRAY {
                let other = get_array(args[0])
                let mut result = []
                let mut zi = 0
                let zn = min(len(items), len(other))
                while zi < zn {
                    result.push(val_array([items[zi], other[zi]]))
                    zi = zi + 1
                }
                return val_array(result)
            }
            return val_array([])
        }
        if method == "take" {
            let n = args[0].int_val
            let mut result = []
            let mut ti = 0
            while ti < n && ti < len(items) {
                result.push(items[ti])
                ti = ti + 1
            }
            return val_array(result)
        }
        if method == "drop" {
            let n = args[0].int_val
            let mut result = []
            let mut di = n
            while di < len(items) {
                result.push(items[di])
                di = di + 1
            }
            return val_array(result)
        }
        if method == "unique" {
            let mut result = []
            let mut seen = []
            for item in items {
                let key = val_to_string(item)
                let mut found = false
                for s in seen {
                    if s == key { found = true }
                }
                if !found {
                    result.push(item)
                    seen.push(key)
                }
            }
            return val_array(result)
        }
        if method == "count" {
            let mut c = 0
            for item in items {
                let r = call_fn_val(args[0], [item])
                if is_truthy(r) { c = c + 1 }
            }
            return val_int(c)
        }
        if method == "find" {
            for item in items {
                let r = call_fn_val(args[0], [item])
                if is_truthy(r) { return item }
            }
            return val_void()
        }
        if method == "group_by" {
            let mut keys = []
            let mut values = []
            for item in items {
                let key = call_fn_val(args[0], [item])
                let key_str = val_to_string(key)
                let mut found_idx = -1
                let mut gi = 0
                while gi < len(keys) {
                    if val_to_string(keys[gi]) == key_str { found_idx = gi }
                    gi = gi + 1
                }
                if found_idx == -1 {
                    keys.push(key)
                    values.push(val_array([item]))
                } else {
                    let existing = get_array(values[found_idx])
                    values[found_idx] = val_array(existing.push(item))
                }
            }
            return val_map(keys, values)
        }
        if method == "flatten" {
            let mut result = []
            for item in items {
                if item.tag == TAG_ARRAY {
                    let sub = get_array(item)
                    for s in sub { result.push(s) }
                } else {
                    result.push(item)
                }
            }
            return val_array(result)
        }
        if method == "sum" {
            let mut has_float = false
            let mut int_total = 0
            let mut float_total = 0.0
            for item in items {
                if item.tag == TAG_FLOAT {
                    has_float = true
                    float_total = float_total + item.float_val
                } else {
                    int_total = int_total + item.int_val
                }
            }
            if has_float { return val_float(int_total * 1.0 + float_total) }
            return val_int(int_total)
        }
        if method == "min" {
            if len(items) == 0 { return val_void() }
            let mut best = items[0]
            let mut mi = 1
            while mi < len(items) {
                if to_float_val(items[mi]) < to_float_val(best) { best = items[mi] }
                mi = mi + 1
            }
            return best
        }
        if method == "max" {
            if len(items) == 0 { return val_void() }
            let mut best = items[0]
            let mut mi = 1
            while mi < len(items) {
                if to_float_val(items[mi]) > to_float_val(best) { best = items[mi] }
                mi = mi + 1
            }
            return best
        }
        if method == "chunk" {
            let n = args[0].int_val
            if n <= 0 { return val_array([]) }
            let mut result = []
            let mut ci = 0
            while ci < len(items) {
                let mut chunk = []
                let mut cj = 0
                while cj < n && ci + cj < len(items) {
                    chunk.push(items[ci + cj])
                    cj = cj + 1
                }
                result.push(val_array(chunk))
                ci = ci + n
            }
            return val_array(result)
        }
        if method == "window" {
            let n = args[0].int_val
            if n <= 0 || n > len(items) { return val_array([]) }
            let mut result = []
            let mut wi = 0
            while wi + n <= len(items) {
                let mut win = []
                let mut wj = 0
                while wj < n {
                    win.push(items[wi + wj])
                    wj = wj + 1
                }
                result.push(val_array(win))
                wi = wi + 1
            }
            return val_array(result)
        }
        if method == "scan" {
            // .scan(init, fn) — like fold but returns intermediate results
            let mut acc = args[0]
            let f = args[1]
            let mut result = [acc]
            for item in items {
                acc = call_fn_val(f, [acc, item])
                result.push(acc)
            }
            return val_array(result)
        }
        if method == "partition" {
            let pred = args[0]
            let mut matching = []
            let mut non_matching = []
            for item in items {
                let r = call_fn_val(pred, [item])
                if is_truthy(r) {
                    matching.push(item)
                } else {
                    non_matching.push(item)
                }
            }
            return val_array([val_array(matching), val_array(non_matching)])
        }
        if method == "interleave" {
            if len(args) > 0 && args[0].tag == TAG_ARRAY {
                let other = get_array(args[0])
                let mut result = []
                let max_len = max(len(items), len(other))
                let mut ii = 0
                while ii < max_len {
                    if ii < len(items) { result.push(items[ii]) }
                    if ii < len(other) { result.push(other[ii]) }
                    ii = ii + 1
                }
                return val_array(result)
            }
            return val_array(items)
        }
        if method == "frequencies" {
            let mut keys = []
            let mut values = []
            for item in items {
                let key_str = val_to_string(item)
                let mut found_idx = -1
                let mut fi = 0
                while fi < len(keys) {
                    if val_to_string(keys[fi]) == key_str { found_idx = fi }
                    fi = fi + 1
                }
                if found_idx == -1 {
                    keys.push(item)
                    values.push(val_int(1))
                } else {
                    values[found_idx] = val_int(values[found_idx].int_val + 1)
                }
            }
            return val_map(keys, values)
        }
        if method == "rotate" {
            let n_items = len(items)
            if n_items == 0 { return val_array([]) }
            let mut n = args[0].int_val
            // Normalize: positive = rotate left
            n = n % n_items
            if n < 0 { n = n + n_items }
            let mut result = []
            let mut ri = 0
            while ri < n_items {
                result.push(items[(ri + n) % n_items])
                ri = ri + 1
            }
            return val_array(result)
        }
        if method == "sample" {
            let n = args[0].int_val
            let n_items = len(items)
            if n_items == 0 || n <= 0 { return val_array([]) }
            let mut result = []
            let mut si = 0
            while si < n {
                let idx = floor(random() * n_items)
                result.push(items[idx])
                si = si + 1
            }
            return val_array(result)
        }
        // .fill(value) — return new array of same length, all entries = value
        if method == "fill" {
            let v = args[0]
            let mut result = []
            let mut fi = 0
            while fi < len(items) {
                result.push(v)
                fi = fi + 1
            }
            return val_array(result)
        }
        // .swap(i, j) — return new array with positions i and j swapped
        if method == "swap" {
            let i = args[0].int_val
            let j = args[1].int_val
            let n_items = len(items)
            if i < 0 || j < 0 || i >= n_items || j >= n_items { return val_array(items) }
            let mut result = []
            let mut si = 0
            while si < n_items {
                if si == i { result.push(items[j]) }
                else if si == j { result.push(items[i]) }
                else { result.push(items[si]) }
                si = si + 1
            }
            return val_array(result)
        }
    }

    // Map methods
    if obj.tag == TAG_MAP {
        if method == "get" { return map_get(obj, args[0]) }
        if method == "set" { return map_set(obj, args[0], args[1]) }
        if method == "contains_key" { return val_bool(map_contains_key(obj, args[0])) }
        // RFC-002 P1: m.has(key) -> bool — alias of contains_key, idiomatic
        // member-existence check matching JS Set/Map / Python dict semantics.
        // Closes anima-eeg gap (16x _kv_lookup string-blob parsing eliminated).
        if method == "has" { return val_bool(map_contains_key(obj, args[0])) }
        if method == "keys" {
            let ks = get_map_keys(obj)
            return val_array(ks)
        }
        if method == "values" {
            let vs = get_map_values(obj)
            return val_array(vs)
        }
        if method == "len" { return val_int(len(get_map_keys(obj))) }
        if method == "remove" { return map_remove(obj, args[0]) }
        if method == "entries" {
            let ks = get_map_keys(obj)
            let vs = get_map_values(obj)
            let mut result = []
            let mut ei = 0
            while ei < len(ks) {
                let pair = val_array([ks[ei], vs[ei]])
                result.push(pair)
                ei = ei + 1
            }
            return val_array(result)
        }
        if method == "merge" {
            if len(args) > 0 && args[0].tag == TAG_MAP {
                let other_ks = get_map_keys(args[0])
                let other_vs = get_map_values(args[0])
                let mut merged = obj
                let mut mi = 0
                while mi < len(other_ks) {
                    merged = map_set(merged, other_ks[mi], other_vs[mi])
                    mi = mi + 1
                }
                return merged
            }
            return obj
        }
        if method == "map_values" {
            let ks = get_map_keys(obj)
            let vs = get_map_values(obj)
            let mut new_vs = []
            let mut mi = 0
            while mi < len(vs) {
                new_vs.push(call_fn_val(args[0], [vs[mi]]))
                mi = mi + 1
            }
            return val_map(ks, new_vs)
        }
        if method == "filter_keys" {
            let ks = get_map_keys(obj)
            let vs = get_map_values(obj)
            let mut new_ks = []
            let mut new_vs = []
            let mut mi = 0
            while mi < len(ks) {
                let keep = call_fn_val(args[0], [ks[mi]])
                if is_truthy(keep) {
                    new_ks.push(ks[mi])
                    new_vs.push(vs[mi])
                }
                mi = mi + 1
            }
            return val_map(new_ks, new_vs)
        }
        if method == "to_array" {
            let ks = get_map_keys(obj)
            let vs = get_map_values(obj)
            let mut result = []
            let mut mi = 0
            while mi < len(ks) {
                result.push(val_array([ks[mi], vs[mi]]))
                mi = mi + 1
            }
            return val_array(result)
        }
        if method == "from_array" {
            // Static-like: called on empty map, takes an array of [key, val] pairs
            if len(args) > 0 && args[0].tag == TAG_ARRAY {
                let pairs = get_array(args[0])
                let mut new_ks = []
                let mut new_vs = []
                for pair in pairs {
                    if pair.tag == TAG_ARRAY {
                        let p = get_array(pair)
                        if len(p) >= 2 {
                            new_ks.push(p[0])
                            new_vs.push(p[1])
                        }
                    }
                }
                return val_map(new_ks, new_vs)
            }
            return val_map([], [])
        }
        if method == "invert" {
            let ks = get_map_keys(obj)
            let vs = get_map_values(obj)
            return val_map(vs, ks)
        }
        if method == "count" {
            let ks = get_map_keys(obj)
            let vs = get_map_values(obj)
            if len(args) > 0 {
                let pred = args[0]
                let mut cnt = 0
                let mut mi = 0
                while mi < len(ks) {
                    let r = call_fn_val(pred, [ks[mi], vs[mi]])
                    if is_truthy(r) { cnt = cnt + 1 }
                    mi = mi + 1
                }
                return val_int(cnt)
            }
            return val_int(len(ks))
        }
        if method == "any" {
            let ks = get_map_keys(obj)
            let vs = get_map_values(obj)
            if len(args) > 0 {
                let pred = args[0]
                let mut mi = 0
                while mi < len(ks) {
                    let r = call_fn_val(pred, [ks[mi], vs[mi]])
                    if is_truthy(r) { return val_bool(true) }
                    mi = mi + 1
                }
            }
            return val_bool(false)
        }
        if method == "all" {
            let ks = get_map_keys(obj)
            let vs = get_map_values(obj)
            if len(args) > 0 {
                let pred = args[0]
                let mut mi = 0
                while mi < len(ks) {
                    let r = call_fn_val(pred, [ks[mi], vs[mi]])
                    if !is_truthy(r) { return val_bool(false) }
                    mi = mi + 1
                }
            }
            return val_bool(true)
        }
    }

    // Struct method dispatch via impl blocks
    if obj.tag == TAG_STRUCT {
        let sname = obj.struct_name
        // ROI-17: probe 64-bucket impl_cache first for O(1) dispatch
        let ic_hit = impl_cache_lookup(sname, method)
        if ic_hit != "" {
            let m = impl_store[ic_hit[0]][1][ic_hit[1]]
            let mparams = m.params
            let mbody = m.body
            env_push_scope()
            let _arena_push = env_var("__HEXA_ARENA_PUSH__")
            env_define("self", obj)
            let mut pi = 0
            let mut ai = 0
            while pi < len(mparams) {
                let mut pname = ""
                if type_of(mparams[pi]) == "string" {
                    pname = mparams[pi]
                } else {
                    pname = mparams[pi].name
                }
                if pname == "self" {
                    // skip — already bound
                } else {
                    if ai < len(args) {
                        env_define(pname, args[ai])
                        ai = ai + 1
                    } else {
                        let mut mp_found = false
                        let mut mni = 0
                        while mni < len(pending_named_args) {
                            if pending_named_args[mni][0] == pname {
                                env_define(pname, pending_named_args[mni][1])
                                mp_found = true
                                mni = len(pending_named_args)
                            }
                            mni = mni + 1
                        }
                        if !mp_found {
                            let mp = mparams[pi]
                            if type_of(mp) != "string" && mp.left != "" {
                                env_define(pname, eval_expr(mp.left))
                            } else {
                                env_define(pname, val_void())
                            }
                        }
                    }
                }
                pi = pi + 1
            }
            let saved_flag = return_flag
            return_flag = false
            let mut bi = 0
            while bi < len(mbody) {
                if return_flag { bi = len(mbody) } else {
                    exec_stmt_at(mbody, bi)
                    bi = bi + 1
                }
            }
            let mut result = return_val
            return_flag = saved_flag
            return_val = result
            let _arena_heap = env_var("__HEXA_ARENA_HEAPIFY_RETURN__")
            result = return_val
            return_val = val_void()
            env_pop_scope()
            let _arena_pop = env_var("__HEXA_ARENA_POP__")
            return result
        }
        // Fallback: linear scan (should not reach here after cache populated)
        let mut ii = 0
        while ii < len(impl_store) {
            if impl_store[ii][0] == sname {
                let methods = impl_store[ii][1]
                let mut mi = 0
                while mi < len(methods) {
                    if methods[mi].name == method {
                        let m = methods[mi]
                        let mparams = m.params
                        let mbody = m.body
                        env_push_scope()
                        // T33 Fix 2: mark Val arena frontier on method entry.
                        // Mirrors call_user_fn envelope (L7914+L8049). Without
                        // this push/heapify/pop, method bodies that build arena
                        // strings/maps and return them would leak past scope
                        // pop and get clobbered by the next arena alloc — a
                        // corruption that bites method chains and impl getters.
                        let _arena_push = env_var("__HEXA_ARENA_PUSH__")
                        // Bind self to the object
                        env_define("self", obj)
                        // Bind remaining params (skip 'self' if first param)
                        // G22/G23: also handle defaults and named args
                        let mut pi = 0
                        let mut ai = 0
                        while pi < len(mparams) {
                            let mut pname = ""
                            if type_of(mparams[pi]) == "string" {
                                pname = mparams[pi]
                            } else {
                                pname = mparams[pi].name
                            }
                            if pname == "self" {
                                // skip — already bound
                            } else {
                                if ai < len(args) {
                                    env_define(pname, args[ai])
                                    ai = ai + 1
                                } else {
                                    // G23: check named args
                                    let mut mp_found = false
                                    let mut mni = 0
                                    while mni < len(pending_named_args) {
                                        if pending_named_args[mni][0] == pname {
                                            env_define(pname, pending_named_args[mni][1])
                                            mp_found = true
                                            mni = len(pending_named_args)
                                        }
                                        mni = mni + 1
                                    }
                                    if !mp_found {
                                        // G22: check default
                                        let mp = mparams[pi]
                                        if type_of(mp) != "string" && mp.left != "" {
                                            env_define(pname, eval_expr(mp.left))
                                        } else {
                                            env_define(pname, val_void())
                                        }
                                    }
                                }
                            }
                            pi = pi + 1
                        }
                        let saved_flag = return_flag
                        return_flag = false
                        let mut bi = 0
                        while bi < len(mbody) {
                            if return_flag { bi = len(mbody) } else {
                                exec_stmt_at(mbody, bi)
                                bi = bi + 1
                            }
                        }
                        let mut result = return_val
                        return_flag = saved_flag
                        // T33 Fix 2: heapify return before arena rewind so
                        // arena-allocated strings/maps that escape via `result`
                        // survive env_pop_scope + arena pop. Round-trip via
                        // return_val so C-side __HEXA_ARENA_HEAPIFY_RETURN__
                        // deep-copies the right value (same pattern as
                        // call_user_fn L8045-8050).
                        return_val = result
                        let _arena_heap = env_var("__HEXA_ARENA_HEAPIFY_RETURN__")
                        result = return_val
                        return_val = val_void()
                        env_pop_scope()
                        let _arena_pop = env_var("__HEXA_ARENA_POP__")
                        return result
                    }
                    mi = mi + 1
                }
            }
            ii = ii + 1
        }
        // Also try field access on struct as a fn val
        let fields = get_struct_fields(obj)
        if type_of(fields) != "string" {
            // Try calling method as a stored function value in fields
        }
    }

    // Generic fallback — universal methods that apply to any value.
    // AOT codegen rewrites `.to_string()`/`.to_int()`/`.to_float()`/`.to_bool()`
    // method calls into hexa_to_* free-fn calls. interp 도 같은 경로를 빌려서
    // `call_builtin` 으로 위임 → interp↔AOT 동형성 유지.
    if method == "to_string" { return val_str(val_to_string(obj)) }
    if method == "to_int" { return call_builtin("to_int", [obj]) }
    if method == "to_float" { return call_builtin("to_float", [obj]) }
    if method == "to_bool" { return val_bool(is_truthy(obj)) }

    println("Runtime error: unknown method ." + method + "() on " + tag_name(obj.tag))
    return val_void()
}

// ── Helpers ──────────────────────────────────────────────

fn is_truthy(v) {
    if v.tag == TAG_BOOL { return v.bool_val }
    if v.tag == TAG_INT { return v.int_val != 0 }
    if v.tag == TAG_STR { return v.str_val != "" }
    if v.tag == TAG_VOID { return false }
    return true
}

// decreases v — structural
fn val_to_string(v) {
    // anima P0 bug #6 (2026-04-18): TAG_INT corruption guard.
    // When Val arena rewinds prematurely (T33 class), the outer tag may
    // stay TAG_INT while int_val holds a stale heap pointer (typical
    // macOS range 0x10000_00000 — 0x70000_00000 = 1.0e12 — 4.8e14).
    // Prefer str_val if present — a genuine TAG_INT has str_val == ""
    // (via val_int factory). Keeps user-visible output readable even
    // under rebuild regression without masking legitimate large ints
    // (which have str_val == "" and cannot collide).
    if v.tag == TAG_INT {
        if v.str_val != "" { return v.str_val }
        return to_string(v.int_val)
    }
    if v.tag == TAG_FLOAT { return to_string(v.float_val) }
    if v.tag == TAG_BOOL { return to_string(v.bool_val) }
    if v.tag == TAG_STR { return v.str_val }
    if v.tag == TAG_VOID { return "void" }
    if v.tag == TAG_ARRAY {
        let items = get_array(v)
        let mut parts = []
        for item in items { parts.push(val_to_string(item)) }
        return "[" + parts.join(", ") + "]"
    }
    if v.tag == TAG_MAP {
        let ks = get_map_keys(v)
        let vs = get_map_values(v)
        let mut parts = []
        let mut mi = 0
        while mi < len(ks) {
            parts.push(val_to_string(ks[mi]) + ": " + val_to_string(vs[mi]))
            mi = mi + 1
        }
        return "{" + parts.join(", ") + "}"
    }
    if v.tag == TAG_FN { return "<fn " + v.fn_name + ">" }
    if v.tag == TAG_ENUM {
        let s = v.struct_name
        if v.int_val >= 0 {
            return s + "(" + val_to_string(get_enum_data(v)) + ")"
        }
        return s
    }
    return "<" + tag_name(v.tag) + ">"
}

// ── JSON serialization / deserialization ─────────────────

// decreases v — structural
fn val_to_json(v) {
    if v.tag == TAG_INT { return to_string(v.int_val) }
    if v.tag == TAG_FLOAT { return to_string(v.float_val) }
    if v.tag == TAG_BOOL {
        if v.bool_val { return "true" } else { return "false" }
    }
    if v.tag == TAG_STR {
        // Escape special characters in JSON string
        let s = v.str_val
        let s = s.replace("\\", "\\\\")
        let s = s.replace("\"", "\\\"")
        let s = s.replace("\n", "\\n")
        let s = s.replace("\t", "\\t")
        return "\"" + s + "\""
    }
    if v.tag == TAG_VOID { return "null" }
    if v.tag == TAG_ARRAY {
        let items = get_array(v)
        let mut parts = []
        for item in items { parts.push(val_to_json(item)) }
        return "[" + parts.join(",") + "]"
    }
    if v.tag == TAG_MAP {
        let ks = get_map_keys(v)
        let vs = get_map_values(v)
        let mut parts = []
        let mut mi = 0
        while mi < len(ks) {
            let key_str = val_to_json(ks[mi])
            // Ensure key is always a JSON string
            if !key_str.starts_with("\"") {
                key_str = "\"" + val_to_string(ks[mi]) + "\""
            }
            parts.push(key_str + ":" + val_to_json(vs[mi]))
            mi = mi + 1
        }
        return "{" + parts.join(",") + "}"
    }
    return "null"
}

// decreases s — structural
fn json_to_val(s) {
    // hxa-20260424-005 #3: scope-down strict-JSON parse with full escape
    // coverage (\", \\, \/, \b, \f, \n, \r, \t, \uXXXX) and proper
    // int/float distinction (`.` / `e` / `E` → float). Preserves the
    // existing split-and-recurse structure at the top level (\_top_split
    // / \_top_colon ignore quoted strings + respect bracket/brace depth)
    // but unescapes JSON string literals via char-indexed scan so
    // \uXXXX round-trips and `{"k":"v$weird"}` survives without shell
    // escape collisions. Rationale: nexus tool/proposal_archive.hexa,
    // tool/proposal_sweep.py, tool/cross_repo_floor_check.hexa currently
    // subprocess `jq` or python3 per entry — O(spawn · entries) gone.
    let s = s.trim()
    if s == "null" { return val_void() }
    if s == "true" { return val_bool(true) }
    if s == "false" { return val_bool(false) }
    // String
    if s.starts_with("\"") && s.ends_with("\"") && len(s) >= 2 {
        let inner = s.substring(1, len(s) - 1)
        return val_str(json_unescape(inner))
    }
    // Array
    if s.starts_with("[") && s.ends_with("]") {
        let inner = s.substring(1, len(s) - 1).trim()
        if inner == "" { return val_array([]) }
        let parts = json_split_top(inner)
        let mut items = []
        for p in parts { items.push(json_to_val(p)) }
        return val_array(items)
    }
    // Object
    if s.starts_with("{") && s.ends_with("}") {
        let inner = s.substring(1, len(s) - 1).trim()
        if inner == "" { return val_map([], []) }
        let parts = json_split_top(inner)
        let mut keys = []
        let mut values = []
        for p in parts {
            let colon = json_find_colon(p)
            if colon >= 0 {
                let k = p.substring(0, colon).trim()
                let v = p.substring(colon + 1, len(p)).trim()
                keys.push(json_to_val(k))
                values.push(json_to_val(v))
            }
        }
        return val_map(keys, values)
    }
    // Number — distinguish int vs float via `.`/`e`/`E` in token.
    // Handles 1e10, -0.5, 1.0e-3 etc. Fallback: bare digits → int.
    if s.contains(".") || s.contains("e") || s.contains("E") {
        return val_float(to_float(s))
    }
    return val_int(to_int(s))
}

// Unescape a JSON string body (without surrounding quotes). Strict-JSON
// escapes: \" \\ \/ \b \f \n \r \t \uXXXX. Unknown escape → passthrough
// the backslashed char (lenient — matches python's json.loads on
// well-formed input and nothing worse on malformed).
fn json_unescape(body) {
    let cs = body.chars()
    let n = len(cs)
    let mut out = ""
    let mut i = 0
    while i < n {
        let ch = to_string(cs[i])
        if ch == "\\" && i + 1 < n {
            let nx = to_string(cs[i + 1])
            if nx == "\"" { out = out + "\""; i = i + 2 }
            else if nx == "\\" { out = out + "\\"; i = i + 2 }
            else if nx == "/" { out = out + "/"; i = i + 2 }
            else if nx == "b" { out = out + from_char_code(8); i = i + 2 }
            else if nx == "f" { out = out + from_char_code(12); i = i + 2 }
            else if nx == "n" { out = out + "\n"; i = i + 2 }
            else if nx == "r" { out = out + "\r"; i = i + 2 }
            else if nx == "t" { out = out + "\t"; i = i + 2 }
            else if nx == "u" && i + 5 < n {
                // Parse 4 hex digits, emit as UTF-8 via from_char_code.
                // Does not handle surrogate pairs (BMP-only). Adequate
                // for nexus JSON content which is ASCII + occasional
                // non-BMP rare-case (falls through to 3-byte UTF-8).
                let hex = ""
                    + to_string(cs[i + 2])
                    + to_string(cs[i + 3])
                    + to_string(cs[i + 4])
                    + to_string(cs[i + 5])
                let cp = json_hex4_to_int(hex)
                out = out + from_char_code(cp)
                i = i + 6
            }
            else {
                // Unknown escape: pass through the literal char.
                out = out + nx
                i = i + 2
            }
        } else {
            out = out + ch
            i = i + 1
        }
    }
    return out
}

// Parse a 4-char hex string into an int. 0 on malformed.
fn json_hex4_to_int(hex) {
    let cs = hex.chars()
    let n = len(cs)
    let mut v = 0
    let mut i = 0
    while i < n {
        let c = to_string(cs[i])
        let code = char_code(c, 0)
        let mut d = 0
        if code >= 48 && code <= 57 { d = code - 48 }
        else if code >= 97 && code <= 102 { d = code - 87 }
        else if code >= 65 && code <= 70 { d = code - 55 }
        else { return 0 }
        v = v * 16 + d
        i = i + 1
    }
    return v
}

// Split a JSON string at top-level commas (not inside [] {} or "")
fn json_split_top(s) {
    let chars = s.chars()
    let n = len(chars)
    let mut parts = []
    let mut depth = 0
    let mut in_str = false
    let mut start = 0
    let mut i = 0
    while i < n {
        let ch = to_string(chars[i])
        if in_str {
            if ch == "\\" { i = i + 1 }
            else if ch == "\"" { in_str = false }
        } else {
            if ch == "\"" { in_str = true }
            else if ch == "[" || ch == "{" { depth = depth + 1 }
            else if ch == "]" || ch == "}" { depth = depth - 1 }
            else if ch == "," && depth == 0 {
                parts.push(s.substring(start, i).trim())
                start = i + 1
            }
        }
        i = i + 1
    }
    if start < n { parts.push(s.substring(start, n).trim()) }
    return parts
}

// Find the first top-level colon in a JSON key:value pair
fn json_find_colon(s) {
    let chars = s.chars()
    let n = len(chars)
    let mut in_str = false
    let mut i = 0
    while i < n {
        let ch = to_string(chars[i])
        if in_str {
            if ch == "\\" { i = i + 1 }
            else if ch == "\"" { in_str = false }
        } else {
            if ch == "\"" { in_str = true }
            else if ch == ":" { return i }
        }
        i = i + 1
    }
    return -1
}

fn to_float(v) {
    if v.tag == TAG_FLOAT { return v.float_val }
    if v.tag == TAG_INT { return v.int_val * 1.0 }
    return 0.0
}

fn to_float_val(v) {
    if v.tag == TAG_FLOAT { return v.float_val }
    if v.tag == TAG_INT { return v.int_val * 1.0 }
    return 0.0
}

// ── Array storage (using host arrays) ────────────────────
// We store arrays as actual hexa arrays wrapped in Val
// Perf #10: reference counting for in-place push.
// array_refcounts tracks how many Val handles point to each array_store slot.
// When refcount==1 (sole owner), push can mutate array_store[idx] directly
// instead of allocating a new slot — turning O(n) copy into O(1) amortized.

pub let mut array_store = []
pub let mut array_refcounts = []   // parallel to array_store; each entry is an int >= 1
// rt 32: freelist for array_store slot reclamation. When a slot's refcount
// drops to 0 (in array_decref), we push the idx here and clear the slot's
// items to a tiny placeholder. Subsequent val_array() calls pop from this
// list before extending array_store. Bounds total array_store length to
// max-live count instead of monotonic growth, eliminating multi-GB
// retention seen in d64 ML microbench (rt B agent, 2026-04-13).
pub let mut array_free_list = []

fn val_array(items) {
    // M4-fix: freelist reuse disabled — see array_decref comment.
    // Original rt 32 freelist pop (disabled):
    // let fl_n = len(array_free_list)
    // if fl_n > 0 {
    //     let idx = array_free_list[fl_n - 1]
    //     array_free_list = array_free_list.truncate(fl_n - 1)
    //     array_store[idx] = items
    //     array_refcounts[idx] = 1
    //     return Val { ... }
    // }
    let idx = len(array_store)
    array_store.push(items)
    array_refcounts.push(1)
    return Val { tag: TAG_ARRAY, int_val: idx, float_val: 0.0, bool_val: false, str_val: __E, char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E }
}

// val_array_reuse: create a Val pointing to an existing array_store slot.
// Increments refcount. Used when a variable is copied (assignment, param passing)
// without mutation — the two Vals share the same backing store until one writes.
fn val_array_reuse(idx) {
    if idx >= 0 && idx < len(array_refcounts) {
        array_refcounts[idx] = array_refcounts[idx] + 1
    }
    return Val { tag: TAG_ARRAY, int_val: idx, float_val: 0.0, bool_val: false, str_val: __E, char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E }
}

fn array_incref(idx) {
    if idx >= 0 && idx < len(array_refcounts) {
        array_refcounts[idx] = array_refcounts[idx] + 1
    }
}

fn array_decref(idx) {
    if idx >= 0 && idx < len(array_refcounts) {
        if array_refcounts[idx] > 0 {
            array_refcounts[idx] = array_refcounts[idx] - 1
            // M4-fix: freelist reclamation DISABLED. rt 32 pushed freed
            // slots onto array_free_list for val_array() reuse, but struct
            // fields hold array slot references without incrementing refcount.
            // This caused slot aliasing corruption: a struct's array field
            // would point to a slot reused by a different variable.
            // Disabling freelist means array_store grows monotonically
            // (pre-rt32 behavior) — safe, at the cost of higher memory for
            // long-running loops. A full struct-field refcount integration
            // can re-enable this later.
            //
            // Original rt 32 code (disabled):
            // if array_refcounts[idx] == 0 {
            //     array_store[idx] = []
            //     array_free_list.push(idx)
            // }
        }
    }
}

fn array_is_sole_owner(idx) {
    if idx >= 0 && idx < len(array_refcounts) {
        return array_refcounts[idx] <= 1
    }
    return true
}

// ω-interp-1 (2026-04-26): single-binding-owner predicate for push.
//
// Background: env_define always increments the array refcount by 1 when a
// TAG_ARRAY value is bound to a name. So a freshly allocated `let mut x = []`
// has refcount = 2 (val_array=1 + env_define=2), not 1. The original
// `array_is_sole_owner` (refcount <= 1) therefore NEVER fires for env-bound
// arrays — every push allocates a fresh array_store slot via COW. Combined
// with M4-fix (freelist disabled), this caused monotonic array_store growth:
// 4800 .push() calls inside vocal_hexa() leaked 4800 dead slots per call,
// hanging on the 2nd+ invocation when host array_store realloc/COW costs
// dominated. Repro: see /tmp/test_push_small.hexa (500 push x 5 calls
// showed 99→103→118→137→161ms scaling without this fix).
//
// Fix: treat refcount <= 2 as "single binding holds it" — the binding-owner
// is the caller, no other Val handle exists, push can mutate in-place.
//
// Aliasing-safety: `let y = x` (or fn-arg passing) goes through env_define
// which increments to >=3, so `x.push(1)` afterward correctly hits the COW
// path. Shared structs (set_struct_field) also incref via array_incref,
// pushing the count past the threshold. Truncated to push only — truncate
// and cow_copy_on_write keep the strict <=1 check (those paths must NOT
// mutate even an env-bound array if any other handle could observe it).
//
// M4-fix invariant preserved: freelist remains disabled (array_decref does
// not push to array_free_list). This fix only changes WHEN we mutate vs
// allocate — not whether reclaimed slots get reused.
fn array_is_push_sole_owner(idx) {
    if idx >= 0 && idx < len(array_refcounts) {
        return array_refcounts[idx] <= 2
    }
    return true
}

// array_push_inplace: O(1) amortized push when sole owner, else COW.
// Returns a Val pointing to the (possibly new) array slot.
//
// ω-interp-1 (2026-04-26): @no_arena suppresses __hexa_fn_arena_enter/return
// emission. Without it, every call to array_push_inplace fires
// __hexa_fn_arena_return → hexa_val_heapify(arr_val) → T33 Fix 4 walk over
// array_store[idx] (the entire current samples buffer). For 4800 .push()
// calls in vocal_hexa() that's O(N²) heapify work per call (~11M ops at
// N=4800), and accumulates across calls because previously-bound TAG_VALSTRUCT
// fields keep pointing at heap targets that still get re-walked. The push
// fast path returns its INPUT arr_val (already heap-side, no arena Vals
// allocated by this fn) — no escape analysis is needed, so skipping the
// fn-arena machinery is correctness-safe here.
@no_arena
fn array_push_inplace(arr_val, item) {
    let idx = arr_val.int_val
    if array_is_push_sole_owner(idx) {
        // Sole owner: mutate the backing store directly (host .push is O(1) amortized)
        let items = array_store[idx]
        array_store[idx] = items.push(item)
        return arr_val
    }
    // Shared: COW — allocate new slot with old items + new item
    let items = array_store[idx]
    let new_items = items.push(item)
    array_decref(idx)
    return val_array(new_items)
}

// ω-interp-4 (2026-04-26): array_set_inplace_idx — O(1) indexed write fast path.
//
// Background: ω-audio-6 found that `arr[i] = v` ran 2.6× SLOWER than `arr.push(v)`
// in the interpreter (vocal_hexa: 401ms alloc-indexed vs 155ms push). Microbench
// confirmed: indexed-write was ~11.3μs vs push ~5.8μs per element (1.93× slower).
//
// Diagnosis: the indexed-assign code path at AssignStmt/CompoundAssign/NK_ASSIGN
// did THREE host-array operations per write:
//   let items = get_array(arr)        // 1× hexa_array_get on array_store
//   items[_si2] = val                 // 1× hexa_array_set on items (in-place)
//   array_store[arr.int_val] = items  // 1× hexa_array_set on array_store (NO-OP write-back —
//                                     //   `items` is the SAME pointer hexa_array_set just mutated;
//                                     //   the host runtime mutates items->arr_ptr in-place)
//
// Fix: collapse to one host-array_set on the items buffer; skip the redundant
// write-back. Also @no_arena to suppress __hexa_fn_arena_return → hexa_val_heapify
// walk on every call (mirrors array_push_inplace pattern).
//
// Sole-owner check is NOT needed for indexed assign (unlike push): writes mutate
// in place at the same logical index — no aliasing change, no slot reallocation.
// COW is irrelevant: the items pointer doesn't move, and refcount is unchanged.
@no_arena
fn array_set_inplace_idx(arr_val, idx_int, val) {
    let items = array_store[arr_val.int_val]
    items[idx_int] = val
    return val
}

fn get_array(v) {
    return array_store[v.int_val]
}

// ── sort helper (insertion sort) ────────────────────────
fn sort_val_compare(a, b) {
    // Returns negative if a < b, 0 if equal, positive if a > b
    if a.tag == TAG_INT && b.tag == TAG_INT {
        return a.int_val - b.int_val
    }
    if a.tag == TAG_FLOAT || b.tag == TAG_FLOAT {
        let fa = to_float_val(a)
        let fb = to_float_val(b)
        if fa < fb { return -1 }
        if fa > fb { return 1 }
        return 0
    }
    // Default: compare as strings
    let sa = val_to_string(a)
    let sb = val_to_string(b)
    if sa < sb { return -1 }
    if sa > sb { return 1 }
    return 0
}

fn sort_array(items) {
    // Insertion sort — simple, correct, good enough for interpreted use
    let mut arr = []
    let mut i = 0
    while i < len(items) {
        arr.push(items[i])
        i = i + 1
    }
    let mut i = 1
    while i < len(arr) {
        let key = arr[i]
        let mut j = i - 1
        while j >= 0 && sort_val_compare(arr[j], key) > 0 {
            arr[j + 1] = arr[j]
            j = j - 1
        }
        arr[j + 1] = key
        i = i + 1
    }
    return arr
}

fn val_fn(name, params, body) {
    return Val { tag: TAG_FN, int_val: 0, float_val: 0.0, bool_val: false, str_val: __E, char_val: __E, array_val: __E, fn_name: name, fn_params: params, fn_body: body, struct_name: __E, struct_fields: __E }
}

fn val_closure(name, params, body, captured_env) {
    // Store [captured_env_tuples, cache_snap] in closure_store.
    // rt 32-E: cache_snap stores parallel (cache_names, cache_idxs) bucket
    // snapshots filtered to entries whose idx is within captured_env. Used
    // by call_fn_val to skip env_rebuild_cache() on closure invocation.
    let idx = len(closure_store)
    let cap_n = len(captured_env)
    let mut cn_buckets = []
    let mut ci_buckets = []
    if len(env_cache_names) == 64 {
        let mut bi = 0
        while bi < 64 {
            let b_names = env_cache_names[bi]
            let b_idxs = env_cache_idxs[bi]
            let mut kept_n = []
            let mut kept_i = []
            let mut ki = 0
            let bn = len(b_idxs)
            while ki < bn {
                if b_idxs[ki] < cap_n {
                    kept_n.push(b_names[ki])
                    kept_i.push(b_idxs[ki])
                }
                ki = ki + 1
            }
            cn_buckets.push(kept_n)
            ci_buckets.push(kept_i)
            bi = bi + 1
        }
    }
    // rt 36-D: heapify captured values before storing in closure_store.
    // Captured vals may hold arena-allocated HexaValStructs (arrays, maps,
    // strings) that get invalidated when the enclosing fn scope pops its
    // arena mark. closure_store is a global that outlives all scopes, so
    // any arena pointers inside the captured tuples become dangling after
    // return. Round-trip through return_val to invoke the C-side
    // hexa_val_heapify which deep-copies arena data to the malloc heap.
    let _saved_rv_clo = return_val
    return_val = captured_env
    let _h_clo = env_var("__HEXA_ARENA_HEAPIFY_RETURN__")
    let heapified_env = return_val
    return_val = _saved_rv_clo
    closure_store.push([heapified_env, cn_buckets, ci_buckets])
    return Val { tag: TAG_FN, int_val: idx, float_val: 0.0, bool_val: false, str_val: "closure", char_val: __E, array_val: __E, fn_name: name, fn_params: params, fn_body: body, struct_name: __E, struct_fields: __E }
}

// ── Map storage ─────────────────────────────────────────
// Maps stored as pairs of [keys_array, values_array]
pub let mut map_store = []

fn val_map(keys, values) {
    let idx = len(map_store)
    map_store.push([keys, values])
    return Val { tag: TAG_MAP, int_val: idx, float_val: 0.0, bool_val: false, str_val: __E, char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E }
}

fn get_map_keys(v) {
    return map_store[v.int_val][0]
}

fn get_map_values(v) {
    return map_store[v.int_val][1]
}

fn map_get(v, key) {
    let keys = get_map_keys(v)
    let values = get_map_values(v)
    let mut i = 0
    while i < len(keys) {
        if val_eq(keys[i], key) { return values[i] }
        i = i + 1
    }
    return val_void()
}

fn map_set(v, key, value) {
    let keys = get_map_keys(v)
    let values = get_map_values(v)
    let mut new_keys = []
    let mut new_values = []
    let mut found = false
    let mut i = 0
    while i < len(keys) {
        if val_eq(keys[i], key) {
            new_keys.push(keys[i])
            new_values.push(value)
            found = true
        } else {
            new_keys.push(keys[i])
            new_values.push(values[i])
        }
        i = i + 1
    }
    if !found {
        new_keys.push(key)
        new_values.push(value)
    }
    return val_map(new_keys, new_values)
}

fn map_contains_key(v, key) {
    let keys = get_map_keys(v)
    let mut i = 0
    while i < len(keys) {
        if val_eq(keys[i], key) { return true }
        i = i + 1
    }
    return false
}

fn map_remove(v, key) {
    let keys = get_map_keys(v)
    let values = get_map_values(v)
    let mut new_keys = []
    let mut new_values = []
    let mut i = 0
    while i < len(keys) {
        if !val_eq(keys[i], key) {
            new_keys.push(keys[i])
            new_values.push(values[i])
        }
        i = i + 1
    }
    return val_map(new_keys, new_values)
}

fn val_eq(a, b) {
    if a.tag != b.tag { return false }
    if a.tag == TAG_INT { return a.int_val == b.int_val }
    if a.tag == TAG_FLOAT { return a.float_val == b.float_val }
    if a.tag == TAG_BOOL { return a.bool_val == b.bool_val }
    if a.tag == TAG_STR { return a.str_val == b.str_val }
    if a.tag == TAG_ENUM { return a.struct_name == b.struct_name }
    return false
}

// ── Struct storage ───────────────────────────────────────
// Perf #11: COW (copy-on-write) for structs.
// struct_refcounts tracks how many Val handles share each struct_store slot.
// On assignment/param-pass, we share the slot (incref) instead of deep-copying.
// On mutation (field write), if refcount > 1 we COW: copy fields to a new slot,
// decref the old, and return the fresh sole-owner Val.
pub let mut struct_store = []
pub let mut struct_refcounts = []   // parallel to struct_store

// ROI #154 (interpreter twin of ROI #148): shallow-clone for TAG_ARRAY
// field values is performed at the NK_STRUCT_INIT call site (see eval_expr)
// so that two struct instances built from the same source array each own a
// private array_store slot. val_struct itself is kept minimal because
// `fields` here is a host-level map (#{}) whose ".tag" lookup would fire
// "map key 'tag' not found". The construction-site clone covers every
// user-visible `Name { field: xs }` path.
//
// Native path mirror: self/runtime.c hexa_struct_pack_map +
// hexa_array_shallow_clone (ROI #148 commit ef98e4ec).
fn val_struct(name, fields) {
    let idx = len(struct_store)
    struct_store.push(fields)
    struct_refcounts.push(1)
    return Val { tag: TAG_STRUCT, int_val: idx, float_val: 0.0, bool_val: false, str_val: __E, char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: name, struct_fields: __E }
}

// val_struct_reuse: share an existing struct_store slot (bump refcount).
// Used when a struct Val is copied without mutation (assignment, param pass, return).
fn val_struct_reuse(v) {
    let idx = v.int_val
    if idx >= 0 && idx < len(struct_refcounts) {
        struct_refcounts[idx] = struct_refcounts[idx] + 1
    }
    return v
}

fn struct_incref(idx) {
    if idx >= 0 && idx < len(struct_refcounts) {
        struct_refcounts[idx] = struct_refcounts[idx] + 1
    }
}

fn struct_decref(idx) {
    if idx >= 0 && idx < len(struct_refcounts) {
        if struct_refcounts[idx] > 0 {
            struct_refcounts[idx] = struct_refcounts[idx] - 1
        }
    }
}

fn struct_is_sole_owner(idx) {
    if idx >= 0 && idx < len(struct_refcounts) {
        return struct_refcounts[idx] <= 1
    }
    return true
}

// struct_cow_if_shared: if the struct is shared (refcount > 1), copy fields
// to a new slot and return a fresh sole-owner Val. Otherwise return as-is.
// Call this before any field mutation.
fn struct_cow_if_shared(v) {
    let idx = v.int_val
    if !struct_is_sole_owner(idx) {
        // COW: deep-copy fields to new slot
        let old_fields = struct_store[idx]
        struct_decref(idx)
        return val_struct(v.struct_name, old_fields)
    }
    return v
}

fn get_struct_fields(v) {
    return struct_store[v.int_val]
}

// set_struct_field: COW-aware field mutation.
// Returns the (possibly new) Val with the field updated.
// M4-fix: properly manage array/struct refcounts for field values.
// Without this, replacing an array field can free the old slot to the
// freelist while the struct (or the same slot reused as new_val) still
// references it — causing slot aliasing corruption.
fn set_struct_field(v, field_name, new_val) {
    let sv = struct_cow_if_shared(v)
    let fields = struct_store[sv.int_val]
    let old_val = fields[field_name]
    // Incref new BEFORE decref old — prevents premature free when old==new
    // (in-place push returns same slot idx).
    if type_of(new_val) != "string" {
        if new_val.tag == TAG_ARRAY {
            array_incref(new_val.int_val)
        }
        if new_val.tag == TAG_STRUCT {
            struct_incref(new_val.int_val)
        }
    }
    // Decref old field value if it was an array or struct
    if type_of(old_val) != "string" {
        if old_val.tag == TAG_ARRAY {
            array_decref(old_val.int_val)
        }
        if old_val.tag == TAG_STRUCT {
            struct_decref(old_val.int_val)
        }
    }
    fields[field_name] = new_val
    struct_store[sv.int_val] = fields
    return sv
}

// ── Enum value storage ──────────────────────────────────
// Enum values: tag="enum", struct_name="EnumName::Variant", str_val stores variant name
// If the variant carries data, it's stored in enum_data_store[int_val]
pub let mut enum_data_store = []

fn val_enum(enum_name, variant, data) {
    let full_name = enum_name + "::" + variant
    let mut data_idx = -1
    if type_of(data) != "string" || data != "" {
        data_idx = len(enum_data_store)
        enum_data_store.push(data)
    }
    return Val { tag: TAG_ENUM, int_val: data_idx, float_val: 0.0, bool_val: false, str_val: variant, char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: full_name, struct_fields: __E }
}

fn get_enum_data(v) {
    if v.int_val < 0 { return val_void() }
    return enum_data_store[v.int_val]
}

// ═══════════════════════════════════════════════════════════
//  Phase 1 골화 — 확장 Value 타입 (7종)
// ═══════════════════════════════════════════════════════════
// ═══════════════════════════════════════════════════════════
//  @cow runtime support — copy-on-write for shared data
// ═══════════════════════════════════════════════════════════
// cow_ref_counts tracks reference counts for array/struct indices.
// When ref_count > 1 and a mutation is attempted, the data is
// deep-copied first (COW semantics: defer copy until write).
pub let mut cow_ref_counts = []

fn cow_ensure_capacity(idx) {
    // ROI-10: geometric growth — amortized O(1) instead of O(idx) per jump.
    if len(cow_ref_counts) > idx { return 0 }
    let mut target = len(cow_ref_counts)
    if target == 0 { target = 16 }
    while target <= idx { target = target * 2 }
    while len(cow_ref_counts) < target {
        cow_ref_counts.push(1)
    }
}

fn cow_incref(idx) {
    cow_ensure_capacity(idx)
    cow_ref_counts[idx] = cow_ref_counts[idx] + 1
}

fn cow_decref(idx) {
    cow_ensure_capacity(idx)
    if cow_ref_counts[idx] > 0 {
        cow_ref_counts[idx] = cow_ref_counts[idx] - 1
    }
}

fn cow_is_shared(idx) {
    cow_ensure_capacity(idx)
    return cow_ref_counts[idx] > 1
}

fn cow_copy_on_write(v) {
    // Perf #10/#11: delegate to per-type refcount-based COW.
    // Fixes original bug: used string tags "array"/"struct" instead of numeric TAG_*.
    if v.tag == TAG_ARRAY {
        if !array_is_sole_owner(v.int_val) {
            let old_data = array_store[v.int_val]
            array_decref(v.int_val)
            return val_array(old_data)
        }
    }
    if v.tag == TAG_STRUCT {
        return struct_cow_if_shared(v)
    }
    return v
}

//  Val struct 자체는 변경 없음. int_val을 ref index로 쓰는
//  기존 array/map/struct/enum/closure 패턴을 그대로 적용.
//  각 신규 타입은 별도 storage + 생성자/접근자 함수 한 쌍.
//  src/interpreter.rs의 Value::{Tensor,Sender,Receiver,EffectRequest,
//  Atomic,Pointer,BigInt} variant들에 대응.

// ── Tensor: shape + flat data (f64) ──────────────────────
pub let mut tensor_shape_store = []   // [[d0,d1,...], ...]
pub let mut tensor_data_store = []    // [[f0,f1,...], ...]

fn val_tensor(shape, data) {
    let idx = len(tensor_shape_store)
    tensor_shape_store.push(shape)
    tensor_data_store.push(data)
    return Val { tag: TAG_TENSOR, int_val: idx, float_val: 0.0, bool_val: false, str_val: __E, char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E }
}

fn tensor_shape(v) {
    if v.tag != TAG_TENSOR { return [] }
    return tensor_shape_store[v.int_val]
}

fn tensor_data(v) {
    if v.tag != TAG_TENSOR { return [] }
    return tensor_data_store[v.int_val]
}

fn tensor_set_data(v, new_data) {
    // in-place update via slot replacement (immutable wrapper, mutable storage)
    if v.tag != TAG_TENSOR { return }
    tensor_data_store[v.int_val] = new_data
}

fn tensor_numel(v) {
    let shape = tensor_shape(v)
    let mut n = 1
    for d in shape { n = n * d }
    return n
}

// ── Channel: bounded queue (Sender + Receiver share id) ──
//  src의 Value::Sender/Value::Receiver는 같은 채널을 가리키는
//  두 view. .hexa에선 단일 tag="channel" + 방향 플래그(int_val 부호로 인코딩).
//    int_val ≥ 0: sender (idx)
//    int_val <  0: receiver, idx = -int_val - 1
pub let mut channel_buffer_store = []  // [[items], ...]
pub let mut channel_closed_store = []  // [bool, ...]
pub let mut channel_capacity_store = []

fn val_channel_make(cap) {
    let idx = len(channel_buffer_store)
    channel_buffer_store.push([])
    channel_closed_store.push(false)
    channel_capacity_store.push(cap)
    return Val { tag: TAG_CHANNEL, int_val: idx, float_val: 0.0, bool_val: false, str_val: "sender", char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E }
}

fn val_channel_recv_view(sender) {
    // sender→receiver view: same id, str_val flag
    return Val { tag: TAG_CHANNEL, int_val: sender.int_val, float_val: 0.0, bool_val: false, str_val: "receiver", char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E }
}

fn channel_send(ch, item) {
    if ch.tag != TAG_CHANNEL { return false }
    let id = ch.int_val
    if channel_closed_store[id] { return false }
    let cap = channel_capacity_store[id]
    let buf = channel_buffer_store[id]
    if cap > 0 && len(buf) >= cap { return false }
    channel_buffer_store[id] = buf.push(item)
    return true
}

fn channel_recv(ch) {
    if ch.tag != TAG_CHANNEL { return val_void() }
    let id = ch.int_val
    let buf = channel_buffer_store[id]
    if len(buf) == 0 { return val_void() }
    let head = buf[0]
    let mut rest = []
    let mut ri = 1
    while ri < len(buf) { rest.push(buf[ri]); ri = ri + 1 }
    channel_buffer_store[id] = rest
    return head
}

fn channel_close(ch) {
    if ch.tag != TAG_CHANNEL { return }
    channel_closed_store[ch.int_val] = true
}

// ── EffectRequest: algebraic effect propagation ──────────
//  Each request: {effect: name, op: name, args: [Val], k: continuation}
pub let mut effect_effect_store = []
pub let mut effect_op_store = []
pub let mut effect_args_store = []
pub let mut effect_k_store = []         // resumption (Val of tag="fn") or void

fn val_effect_request(effect_name, op, args) {
    let idx = len(effect_effect_store)
    effect_effect_store.push(effect_name)
    effect_op_store.push(op)
    effect_args_store.push(args)
    effect_k_store.push(val_void())
    return Val { tag: TAG_EFFECT_REQUEST, int_val: idx, float_val: 0.0, bool_val: false, str_val: effect_name, char_val: op, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E }
}

fn effect_args(v) {
    if v.tag != TAG_EFFECT_REQUEST { return [] }
    return effect_args_store[v.int_val]
}

fn effect_set_continuation(v, k) {
    if v.tag != TAG_EFFECT_REQUEST { return }
    effect_k_store[v.int_val] = k
}

fn effect_continuation(v) {
    if v.tag != TAG_EFFECT_REQUEST { return val_void() }
    return effect_k_store[v.int_val]
}

// ── Atomic: single-cell with lock-free ops ───────────────
//  HEXA interpreter is single-threaded so atomic == regular cell.
//  But the API needs to exist for self-host parity.
pub let mut atomic_store = []   // [Val, ...]

fn val_atomic(initial) {
    let idx = len(atomic_store)
    atomic_store.push(initial)
    return Val { tag: TAG_ATOMIC, int_val: idx, float_val: 0.0, bool_val: false, str_val: __E, char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E }
}

fn atomic_load(v) {
    if v.tag != TAG_ATOMIC { return val_void() }
    return atomic_store[v.int_val]
}

fn atomic_store_op(v, new_val) {
    if v.tag != TAG_ATOMIC { return }
    atomic_store[v.int_val] = new_val
}

fn atomic_compare_swap(v, expected, new_val) {
    if v.tag != TAG_ATOMIC { return val_bool(false) }
    let cur = atomic_store[v.int_val]
    if val_eq(cur, expected) {
        atomic_store[v.int_val] = new_val
        return val_bool(true)
    }
    return val_bool(false)
}

fn atomic_fetch_add(v, delta) {
    if v.tag != TAG_ATOMIC { return val_int(0) }
    let cur = atomic_store[v.int_val]
    let next = val_int(cur.int_val + delta.int_val)
    atomic_store[v.int_val] = next
    return cur
}

// ── BigInt: arbitrary precision integer (string-encoded) ──
//  Stored as decimal string for simplicity. Large arithmetic ops
//  are routed through string-based long arithmetic helpers.
pub let mut bigint_store = []   // [string, ...]

fn val_bigint(decimal_str) {
    let idx = len(bigint_store)
    bigint_store.push(decimal_str)
    return Val { tag: TAG_BIGINT, int_val: idx, float_val: 0.0, bool_val: false, str_val: decimal_str, char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E }
}

fn val_bigint_from_int(n) {
    return val_bigint(to_string(n))
}

fn bigint_str(v) {
    if v.tag != TAG_BIGINT { return "0" }
    return bigint_store[v.int_val]
}

// ── Pointer: opaque address (FFI) ────────────────────────
//  Stored as raw int64. Used for C extern fn calls.
fn val_pointer(addr) {
    return Val { tag: TAG_POINTER, int_val: addr, float_val: 0.0, bool_val: false, str_val: __E, char_val: __E, array_val: __E, fn_name: __E, fn_params: __E, fn_body: __E, struct_name: __E, struct_fields: __E }
}

fn pointer_addr(v) {
    if v.tag != TAG_POINTER { return 0 }
    return v.int_val
}

fn pointer_is_null(v) {
    if v.tag != TAG_POINTER { return true }
    return v.int_val == 0
}

// ═══════════════════════════════════════════════════════════
//  Phase 6 골화 — Algebraic Effects (handle/with + resume)
//  src/interpreter.rs:11872-11933 대응
// ═══════════════════════════════════════════════════════════
//  Effect 등록부: effect 이름 → 허용된 op 이름 배열
//  Handler stack: 각 프레임은 [[key, params, body], ...]
//  Resume value: handler 안에서 resume(v) 호출 시 저장
//  Pure flag: 순수 함수 안에서 effect 호출 차단

pub let mut effect_defs_keys = []      // [effect_name, ...]
pub let mut effect_defs_ops = []       // [[op1, op2, ...], ...]
pub let mut effect_handler_stack = []  // [[entry, ...], ...] — 각 entry: [key, params, body]
pub let mut resume_value = val_void()
pub let mut resume_set = false
pub let mut in_pure_fn = false

fn effect_def_add(effect_name, ops) {
    effect_defs_keys.push(effect_name)
    effect_defs_ops.push(ops)
}

fn effect_def_lookup(effect_name) {
    let mut i = 0
    while i < len(effect_defs_keys) {
        if effect_defs_keys[i] == effect_name { return effect_defs_ops[i] }
        i = i + 1
    }
    return val_void()
}

fn effect_def_has_op(effect_name, op) {
    let ops = effect_def_lookup(effect_name)
    if type_of(ops) != "array" { return false }
    let mut i = 0
    while i < len(ops) {
        if ops[i] == op { return true }
        i = i + 1
    }
    return false
}

fn effect_handler_push(handlers) {
    // handlers: array of [key, params, body] entries
    effect_handler_stack.push(handlers)
}

fn effect_handler_pop() {
    let n = len(effect_handler_stack)
    if n == 0 { return }
    let mut new_stack = []
    let mut i = 0
    while i < n - 1 { new_stack.push(effect_handler_stack[i]); i = i + 1 }
    effect_handler_stack = new_stack
}

fn effect_handler_find(key) {
    // Search from top of stack down (most recent first)
    let mut i = len(effect_handler_stack) - 1
    while i >= 0 {
        let frame = effect_handler_stack[i]
        let mut j = 0
        while j < len(frame) {
            let entry = frame[j]
            if entry[0] == key { return entry }
            j = j + 1
        }
        i = i - 1
    }
    return val_void()
}

// eval_effect_call(effect, op, args) — dispatch effect operation
//   1. pure-fn 차단
//   2. effect 정의 검증
//   3. handler stack 검색
//   4. 발견 시 handler body 실행 (resume_value 반영)
//   5. 미발견 시 EffectRequest 전파 (caller가 handle해야 함)
fn eval_effect_call(effect_name, op, args) {
    if in_pure_fn {
        throw_flag = true
        throw_val = val_str("effect " + effect_name + "." + op + " not allowed in pure function")
        return val_void()
    }
    if !effect_def_has_op(effect_name, op) {
        throw_flag = true
        throw_val = val_str("undefined effect or operation: " + effect_name + "." + op)
        return val_void()
    }
    let key = effect_name + "." + op
    let entry = effect_handler_find(key)
    // entry is a host array on hit, val_void() on miss
    if type_of(entry) != "array" {
        // No handler — propagate as EffectRequest
        return val_effect_request(effect_name, op, args)
    }
    // entry: [key, params, body]
    let params = entry[1]
    let body = entry[2]
    env_push_scope()
    // T33 Fix 3: mark Val arena frontier on effect handler entry. Without
    // this, a handler that builds an arena string/map and returns it (or
    // passes it through resume) would be clobbered by the next arena alloc
    // once this scope pops. Mirrors call_user_fn envelope L7914+L8049.
    let _arena_push = env_var("__HEXA_ARENA_PUSH__")
    let mut pi = 0
    while pi < len(params) && pi < len(args) {
        env_define(params[pi], args[pi])
        pi = pi + 1
    }
    resume_set = false
    resume_value = val_void()
    let mut result = val_void()
    let mut bi = 0
    while bi < len(body) && !return_flag && !throw_flag && !panic_flag {
        result = exec_stmt_at(body, bi)
        bi = bi + 1
    }
    if return_flag {
        result = return_val
        return_flag = false
    }
    // T33 Fix 3: heapify result (and resume_value) before arena rewind.
    // Both paths return a Val that may have been allocated in this frame's
    // arena slice, so both need the round-trip heapify before pop.
    return_val = result
    let _arena_heap = env_var("__HEXA_ARENA_HEAPIFY_RETURN__")
    result = return_val
    return_val = val_void()
    if resume_set {
        return_val = resume_value
        let _arena_heap2 = env_var("__HEXA_ARENA_HEAPIFY_RETURN__")
        resume_value = return_val
        return_val = val_void()
    }
    env_pop_scope()
    let _arena_pop = env_var("__HEXA_ARENA_POP__")
    if resume_set {
        let r = resume_value
        resume_set = false
        return r
    }
    return result
}

// eval_handle_with(body_fn, handler_entries) — push frame, eval body, pop
//   handler_entries: [[key, params, body_stmts], ...]
fn eval_handle_with(body_fn, handler_entries) {
    effect_handler_push(handler_entries)
    let result = call_fn_val(body_fn, [])
    effect_handler_pop()
    return result
}

// ── Stack trace helper ──────────────────────────────────
// T1 Phase B: format_stack_trace → self/runtime_core.hexa

// ── Main entry: run AST ──────────────────────────────────

fn interpret(ast) {
    _fuel_init()
    // Reset state
    // rt 32-E: reset parallel env arrays (names + vals).
    env_var_names = []
    env_var_vals = []
    env_vars = []
    env_scopes = [0]
    env_cache_init()
    env_scope_dirty = []
    env_fns = []
    fn_cache_init()
    // 2026-04-20 use-loader fix — reset per-run cache so module bodies
    // re-exec on fresh interpret() (CLM train loops re-use the interpreter).
    __use_loaded_paths = []
    // 2026-05-04 (feat/import-alias-runtime-fix) — reset alias registry per
    // run so loop-reused interpreters do not leak alias entries across runs.
    __use_alias_fns = []
    return_flag = false
    return_val = val_void()
    break_flag = false
    break_label = ""
    continue_flag = false
    continue_label = ""
    defer_stack = []
    throw_flag = false
    throw_val = val_void()
    panic_flag = false
    panic_msg = ""
    gen_buffer = []
    gen_active = false
    enum_decls = []
    enum_variant_cache = []
    array_store = []
    array_refcounts = []
    array_free_list = []
    map_store = []
    struct_store = []
    struct_refcounts = []
    impl_store = []
    impl_cache = []
    lazy_cache = []
    closure_store = []
    extern_fns = []
    extern_fn_cache = []
    enum_data_store = []
    // ROI-14: pre-alloc call_stack buffer — 128 slots covers typical recursion
    // depth without any dynamic grow on the hot path.
    call_stack = []
    call_stack_top = 0
    let mut _cs_i = 0
    while _cs_i < 128 {
        call_stack.push("")
        _cs_i = _cs_i + 1
    }
    fn_attrs = []
    fn_attr_flags = []
    fn_attr_cache = []
    specialize_ic_cache = []
    memo_cache_init()
    // ─── T33 Val arena fix: eager small-int cache populate ───
    // Populate __VAL_INT_CACHE here at top-level (mark_top == 0) so the 256
    // entries land in module-lifetime heap, not the user-fn arena. Lazy
    // populate triggered from inside a user fn frame would otherwise dangle
    // on arena pop → next val_int(0) returns corrupted Val (type_of "map").
    __VAL_INT_CACHE = []
    __VAL_INT_CACHE_LEN = 0
    __init_val_int_cache()
    __str_concat_count = 0
    __str_concat_warned = 0

    // ─── FIX-9-1: Top-level FnDecl pre-registration pass ───
    // Rust interpreter.rs:run() 와 동일 패턴. 본 실행 루프 전에 모든 FnDecl 을
    // env_define 하여 forward reference 및 상호 재귀 지원. 단일 pass 가 아니므로
    // fn 정의 순서 무관하게 호출 가능. blowup.hexa 류 대형 파일의 O(N²) 누적
    // env_lookup 문제도 완화 (fn 이름은 pre-reg 시점 고정 위치로 영속).
    // 참고: shared/hexa/interpreter_fixes_20260411.json FIX-9-1
    let mut _pr = 0
    while _pr < len(ast) {
        let _pn = ast[_pr]
        if type_of(_pn) == "struct" || type_of(_pn) == "map" {
            let _pk = _pn.kind
            if type_of(_pk) == "string" {
                // FnDecl / AsyncFnDecl / PureFnDecl / ComptimeFnDecl 전부 포함
                if _pk == "FnDecl" || _pk == "AsyncFnDecl" || _pk == "PureFnDecl" {
                    env_fns.push([_pn.name, _pn.params, _pn.body])
                    fn_cache_add(_pn.name, len(env_fns) - 1)
                    let _pfv = val_fn(_pn.name, _pn.params, _pn.body)
                    env_define(_pn.name, _pfv)
                    // @attrs 도 pre-reg 단계에서 등록 (@memo/@memoize/@cache)
                    if _pn.value != "" {
                        fn_attrs_set(_pn.name, _pn.value)
                    }
                }
                // ─── ROI-3: ExternFnDecl hoist ───
                // Pre-register extern fn declarations so FFI calls
                // before the decl site resolve correctly (like FnDecl).
                if _pk == "ExternFnDecl" {
                    let _ec = _pn.value
                    if _ec == "" { _ec = _pn.name }
                    let _el = _pn.op
                    extern_fns.push([_pn.name, _ec, _pn.ret_type, _el])
                    extern_fn_cache_add(_pn.name, len(extern_fns) - 1)
                    env_define(_pn.name, val_str("__extern_" + _pn.name))
                }
            }
        }
        _pr = _pr + 1
    }

    // ─── hxa-20260424-006: `args` top-level global binding ───
    // Top-level scripts (nexus/tool/proposal_archive.hexa line 443:
    // `args.len()`) spell the CLI argv as a bare identifier rather than
    // the call-form `args()`. Pre-bind `args` in the global env so that
    // `args.len()`, `args[i]` work without a call.
    //
    // Contract (task hxa-20260424-006):
    //   args[0]  = script path (interp path under `hexa run <script>`)
    //   args[i]  for i ≥ 1 = caller args
    //
    // Under interp, raw hexa_args() returns [driver, driver, script, user...]
    // (hexa_set_args dup-inserts argv[0]). Skip indices 0..1 to land on
    // [script, user...], matching the canonical real_args() start offset.
    // For AOT path the raw layout is [bin, bin, user...], so args[0] = first
    // user arg (there is no script path once AOT-compiled).
    let _bound_args_raw = args()
    let mut _bound_args = []
    let mut _bai = if len(_bound_args_raw) >= 2 { 2 } else { len(_bound_args_raw) }
    while _bai < len(_bound_args_raw) {
        _bound_args.push(val_str(to_string(_bound_args_raw[_bai])))
        _bai = _bai + 1
    }
    env_define("args", val_array(_bound_args))

    // ─── ROI-4: one-shot FFI real-pointer mode init ───
    // Cache env_var("HXLAYER_FFI_LIVE") once so alloc_raw/free_raw skip
    // per-call env_var overhead. Also auto-detect: if any libhx*.dylib
    // is loadable, enable real-pointer mode automatically.
    ffi_real_pointer_mode = false
    if env_var("HXLAYER_FFI_LIVE") == "1" {
        ffi_real_pointer_mode = true
    } else {
        // Auto-detect: probe for loadable hxlayer library
        let _probe = host_ffi_open("hxlayer")
        if _probe != 0 { ffi_real_pointer_mode = true }
    }

    // ─── ROI-45: one-shot arena-active init ───
    val_arena_active = false
    if env_var("HEXA_VAL_ARENA") == "1" {
        val_arena_active = true
    }

    let mut result = val_void()
    let mut _si = 0
    while _si < len(ast) {
        if panic_flag || throw_flag || return_flag { _si = len(ast) } else {
            // FnDecl pre-reg 됐으므로 exec_stmt_at 재호출 시 중복 define 발생.
            // 중복 define 은 env_vars 에 [name,value] 를 push 만 하므로 env_lookup
            // 이 최신(뒤쪽) 엔트리를 먼저 찾음 → 동작 동일, 약간의 메모리 오버헤드.
            // 안전 우선으로 재실행 허용 (exec_stmt_at 의 FnDecl 분기가 idempotent 확인).
            result = exec_stmt_at(ast, _si)
            _si = _si + 1
            // Top-level return: capture value and stop iteration.
            if return_flag {
                result = return_val
                _si = len(ast)
            }
        }
    }
    return_flag = false
    // T49 — auto-call user fn main() if present (T23 follow-up for
    // interpreter + bridge paths; codegen_c2 already emits u_main()
    // at C main() tail). Semantics: top-level runs FIRST so
    // initializers / imports / global bindings are observable, THEN
    // main() is invoked as the logical entry point. Skip if top-level
    // already panicked or threw — the diagnostic blocks below surface
    // the abort unchanged. Matches codegen_c2's T23 unconditional
    // u_main() call (double-call if user also invoked main() from
    // top-level is user's responsibility, same as the C path).
    if !panic_flag && !throw_flag {
        let _main_fn = find_fn("main")
        if _main_fn != "" {
            result = call_user_fn("main", [])
            return_flag = false
        }
    }
    // Uncaught panic — print diagnostic. Uses println (no stderr binding in
    // self interp), prefixed with "panic: " so callers can detect the abort.
    if panic_flag {
        println("panic: " + panic_msg)
    }
    // T34: Uncaught throw — same treatment as panic. Without this the
    // process exits silently with status 0 when an exec_throw (from
    // to_int("1.01"), to_float("x"), user `throw`, etc.) escapes the
    // last try/catch. Print a visible diagnostic so the failure is
    // observable at the shell level.
    if throw_flag {
        let mut msg = "uncaught throw"
        if throw_val.tag == TAG_STR {
            msg = throw_val.str_val
        } else if throw_val.tag == TAG_MAP {
            let keys = get_map_keys(throw_val)
            let vals = get_map_values(throw_val)
            let mut ki = 0
            while ki < len(keys) {
                if keys[ki].tag == TAG_STR && keys[ki].str_val == "message" {
                    if vals[ki].tag == TAG_STR { msg = vals[ki].str_val }
                }
                ki = ki + 1
            }
        }
        println("error: " + msg)
    }
    return result
}


// ── Script execution entry (2026-04-13) ──────────────────
// If argv provides a file path, read + tokenize + parse + execute it.
//
// rt#36-D bridge: when HEXA_VM=1, we DEFER execution to the bottom of
// bc_emitter.hexa (which is concatenated AFTER this file by
// tool/flatten_imports.hexa). The deferral is required because the
// bc_emitter's opcode constants (BC_OP_LOADI, BC_OP_ADD, ...) are
// top-level `let` bindings that init in the C main() in appearance
// order — and this entry point appears BEFORE bc_emitter in the flat
// file, so running bc_vm_run() here would read uninitialized (zero)
// opcode constants. Saving parsed AST + flag into module globals and
// letting bc_emitter.hexa's tail block run after its own let-inits
// resolves the ordering.
let mut _hx_ast = []
let mut _hx_has_script = false
// T56 — unified argv parsing. `args()` returns [bin, bin, argv1, argv2, ...]
// (hexa_set_args dup-inserts argv[0]). We walk args starting at index 2 and:
//   * skip the literal "run" subcommand (matches ./hexa wrapper convention)
//   * consume "--vm" / "--bc" as VM-mode flags (sets HEXA_VM-equivalent)
//   * the first non-flag token is the script path; remainder are user args
// This unblocks `build/hexa_interp run <file>` and `... --vm <file>` invocations
// that automation scripts rely on, without requiring HEXA_VM env export.
let _hx_av = args()
let mut _hx_i = 2
let mut _hx_file = ""
let mut _hx_vm_flag = false
let mut _hx_mode = "run"
while _hx_i < len(_hx_av) {
    let _hx_a = _hx_av[_hx_i]
    if _hx_a == "run" {
        _hx_i = _hx_i + 1
    } else if _hx_a == "test" {
        _hx_mode = "test"
        _hx_i = _hx_i + 1
    } else if _hx_a == "bench" {
        _hx_mode = "bench"
        _hx_i = _hx_i + 1
    } else if _hx_a == "--vm" {
        _hx_vm_flag = true
        _hx_i = _hx_i + 1
    } else if _hx_a == "--bc" {
        _hx_vm_flag = true
        _hx_i = _hx_i + 1
    // --compile removed from interp CLI to avoid hexa_v2 transpile issues.
    // Self-host compile is done via standalone driver script instead:
    //   ./hexa tool/compile.hexa input.hexa output.c
    } else {
        _hx_file = _hx_a
        _hx_i = len(_hx_av)
    }
}
if _hx_file != "" {
    let _hx_src = read_file(_hx_file)
    let _hx_tokens = tokenize(_hx_src)
    _hx_ast = parse(_hx_tokens)
    _hx_has_script = true
    // Capture script-dir for runtime `use` loader so caller-relative
    // `use "voice_routes"` from serving/*.hexa resolves to serving/voice_routes.hexa.
    // Inline dirname — last '/' in path; '.' if no slash. Uses substring(i,i+1)
    // byte match instead of path[i] char indexing to avoid the interp char
    // coercion path (hexa string indexing returns chars not strings, and the
    // '/' literal is an ASCII code; portability of == across those varies).
    let mut __sd_i = len(_hx_file) - 1
    let mut __sd_pos = 0 - 1
    while __sd_i >= 0 {
        if _hx_file.substring(__sd_i, __sd_i + 1) == "/" {
            __sd_pos = __sd_i
            __sd_i = 0 - 1
        } else {
            __sd_i = __sd_i - 1
        }
    }
    if __sd_pos >= 0 {
        __use_script_dir = _hx_file.substring(0, __sd_pos)
    } else {
        __use_script_dir = "."
    }
    if _hx_mode == "test" {
        // @test runner: interpret to populate fn_attrs, then run @test fns
        interpret(_hx_ast)
        let mut _hx_tp = 0
        let mut _hx_tf = 0
        let mut _hx_ts = 0
        let mut _hx_seen = []
        let mut _hx_ti = 0
        while _hx_ti < len(fn_attrs) {
            let _hx_tn = fn_attrs[_hx_ti][0]
            let _hx_ta = fn_attrs[_hx_ti][1]
            if _hx_ta.contains("test") {
                // deduplicate: fn_attrs has entries from both pre-reg and exec
                let mut _hx_dup = false
                let mut _hx_si = 0
                while _hx_si < len(_hx_seen) {
                    if _hx_seen[_hx_si] == _hx_tn { _hx_dup = true }
                    _hx_si = _hx_si + 1
                }
                if !_hx_dup {
                    _hx_seen.push(_hx_tn)
                    if _hx_ta.contains("skip") {
                        println("  SKIP  " + _hx_tn)
                        _hx_ts = _hx_ts + 1
                    } else {
                        throw_flag = false
                        throw_val = val_void()
                        call_user_fn(_hx_tn, [])
                        if throw_flag || panic_flag {
                            let mut _hx_msg = "assertion failed"
                            if throw_val.tag == TAG_STR {
                                _hx_msg = throw_val.str_val
                            }
                            println("  FAIL  " + _hx_tn + " — " + _hx_msg)
                            _hx_tf = _hx_tf + 1
                            throw_flag = false
                            panic_flag = false
                        } else {
                            println("  PASS  " + _hx_tn)
                            _hx_tp = _hx_tp + 1
                        }
                    }
                }
            }
            _hx_ti = _hx_ti + 1
        }
        println("")
        println("" + to_string(_hx_tp) + " pass, " + to_string(_hx_tf) + " fail, " + to_string(_hx_ts) + " skip")
        if _hx_tf > 0 {
            exit(1)
        }
    } else if _hx_mode == "bench" {
        // @bench runner: interpret to populate fn_attrs, then bench @bench fns
        interpret(_hx_ast)
        let mut _hx_bs = 0
        let mut _hx_bseen = []
        let mut _hx_bi = 0
        while _hx_bi < len(fn_attrs) {
            let _hx_bn = fn_attrs[_hx_bi][0]
            let _hx_ba = fn_attrs[_hx_bi][1]
            if _hx_ba.contains("bench") {
                // deduplicate
                let mut _hx_bdup = false
                let mut _hx_bsi = 0
                while _hx_bsi < len(_hx_bseen) {
                    if _hx_bseen[_hx_bsi] == _hx_bn { _hx_bdup = true }
                    _hx_bsi = _hx_bsi + 1
                }
                if !_hx_bdup {
                    _hx_bseen.push(_hx_bn)
                    if _hx_ba.contains("skip") {
                        println("  SKIP  " + _hx_bn)
                        _hx_bs = _hx_bs + 1
                    } else {
                        let _hx_iters = 100
                        let _hx_bt0 = clock()
                        let mut _hx_bmin = 999999.0
                        let mut _hx_bj = 0
                        while _hx_bj < _hx_iters {
                            let _hx_iter_t0 = clock()
                            call_user_fn(_hx_bn, [])
                            let _hx_iter_dt = (clock() - _hx_iter_t0) * 1000.0
                            if _hx_iter_dt < _hx_bmin {
                                _hx_bmin = _hx_iter_dt
                            }
                            _hx_bj = _hx_bj + 1
                        }
                        let _hx_btotal = (clock() - _hx_bt0) * 1000.0
                        let _hx_bmean = _hx_btotal / _hx_iters
                        println("  BENCH " + _hx_bn + "  total=" + to_string(_hx_btotal) + "ms  mean=" + to_string(_hx_bmean) + "ms  min=" + to_string(_hx_bmin) + "ms  (n=" + to_string(_hx_iters) + ")")
                    }
                }
            }
            _hx_bi = _hx_bi + 1
        }
    } else {
        // Classic path: run the tree-walking interpreter inline ONLY if
        // we are not in VM mode. In VM mode, bc_emitter.hexa's tail block
        // picks this up via the (_hx_has_script, _hx_ast) globals.
        let _hx_env_vm = env_var("HEXA_VM") == "1"
        if !_hx_vm_flag && !_hx_env_vm {
            interpret(_hx_ast)
        }
    }
}
