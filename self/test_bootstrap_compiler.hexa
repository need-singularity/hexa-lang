// self/test_bootstrap_compiler.hexa — Tests for the self-hosting compiler pipeline
// Verifies that lexer -> parser -> type_checker -> compiler work together.
// This file tests each stage independently and the full pipeline.

// ══════════════════════════════════════════════════════════════
// Minimal shared structs
// ══════════════════════════════════════════════════════════════

struct Token {
    kind: string,
    value: string,
    line: int,
    col: int
}

struct AstNode {
    kind: string,
    name: string,
    value: string,
    op: string,
    left: string,
    right: string,
    cond: string,
    then_body: string,
    else_body: string,
    params: string,
    body: string,
    args: string,
    fields: string,
    items: string,
    variants: string,
    arms: string,
    iter_expr: string,
    ret_type: string,
    target: string,
    trait_name: string,
    methods: string
}

struct TypeError {
    message: string,
    name: string
}

struct Instruction {
    op: string,
    operand: string
}

struct CompiledFn {
    name: string,
    arity: int,
    param_names: string,
    code: string,
    local_count: int
}

// ══════════════════════════════════════════════════════════════
// Inline lexer (minimal, no else-if)
// ══════════════════════════════════════════════════════════════

fn is_keyword(word) {
    if word == "if" { return true }
    if word == "else" { return true }
    if word == "fn" { return true }
    if word == "return" { return true }
    if word == "let" { return true }
    if word == "mut" { return true }
    if word == "const" { return true }
    if word == "while" { return true }
    if word == "for" { return true }
    if word == "struct" { return true }
    if word == "assert" { return true }
    return false
}

fn keyword_kind(word) {
    if word == "true" { return "BoolLit" }
    if word == "false" { return "BoolLit" }
    if is_keyword(word) {
        let first = to_string(word.chars()[0]).to_upper()
        let rest = ""
        let chars = word.chars()
        let i = 1
        while i < len(chars) {
            rest = rest + to_string(chars[i])
            i = i + 1
        }
        return first + rest
    }
    return "Ident"
}

fn my_is_alpha(s) {
    if s == "a" || s == "b" || s == "c" || s == "d" || s == "e" || s == "f" { return true }
    if s == "g" || s == "h" || s == "i" || s == "j" || s == "k" || s == "l" { return true }
    if s == "m" || s == "n" || s == "o" || s == "p" || s == "q" || s == "r" { return true }
    if s == "s" || s == "t" || s == "u" || s == "v" || s == "w" || s == "x" { return true }
    if s == "y" || s == "z" { return true }
    if s == "A" || s == "B" || s == "C" || s == "D" || s == "E" || s == "F" { return true }
    if s == "G" || s == "H" || s == "I" || s == "J" || s == "K" || s == "L" { return true }
    if s == "M" || s == "N" || s == "O" || s == "P" || s == "Q" || s == "R" { return true }
    if s == "S" || s == "T" || s == "U" || s == "V" || s == "W" || s == "X" { return true }
    if s == "Y" || s == "Z" { return true }
    return false
}

fn my_is_digit(s) {
    if s == "0" || s == "1" || s == "2" || s == "3" || s == "4" { return true }
    if s == "5" || s == "6" || s == "7" || s == "8" || s == "9" { return true }
    return false
}

fn is_ident_start_s(s) {
    if my_is_alpha(s) { return true }
    if s == "_" { return true }
    return false
}

fn is_ident_char_s(s) {
    if my_is_alpha(s) { return true }
    if my_is_digit(s) { return true }
    if s == "_" { return true }
    return false
}

fn ch_at(chars, pos) {
    return to_string(chars[pos])
}

fn tokenize(source) {
    let mut tokens = []
    let chars = source.chars()
    let mut pos = 0
    let mut line = 1
    let mut col = 1
    let total = len(chars)

    while pos < total {
        let ch = ch_at(chars, pos)
        if ch == " " || ch == "\t" || ch == "\r" {
            pos = pos + 1
            col = col + 1
        } else {
            if ch == "\n" {
                tokens = tokens.push(Token { kind: "Newline", value: "\n", line: line, col: col })
                pos = pos + 1
                line = line + 1
                col = 1
            } else {
                if ch == "/" && pos + 1 < total && ch_at(chars, pos + 1) == "/" {
                    pos = pos + 2
                    col = col + 2
                    while pos < total && ch_at(chars, pos) != "\n" {
                        pos = pos + 1
                        col = col + 1
                    }
                } else {
                    if is_ident_start_s(ch) {
                        let start_col = col
                        let mut word = ""
                        while pos < total && is_ident_char_s(ch_at(chars, pos)) {
                            word = word + to_string(chars[pos])
                            pos = pos + 1
                            col = col + 1
                        }
                        let kind = keyword_kind(word)
                        tokens = tokens.push(Token { kind: kind, value: word, line: line, col: start_col })
                    } else {
                        if my_is_digit(ch) {
                            let start_col = col
                            let mut num_str = ""
                            while pos < total && my_is_digit(ch_at(chars, pos)) {
                                num_str = num_str + to_string(chars[pos])
                                pos = pos + 1
                                col = col + 1
                            }
                            tokens = tokens.push(Token { kind: "IntLit", value: num_str, line: line, col: start_col })
                        } else {
                            if ch == "\"" {
                                let start_col = col
                                pos = pos + 1
                                col = col + 1
                                let mut s = ""
                                while pos < total && ch_at(chars, pos) != "\"" {
                                    s = s + to_string(chars[pos])
                                    pos = pos + 1
                                    col = col + 1
                                }
                                if pos < total {
                                    pos = pos + 1
                                    col = col + 1
                                }
                                tokens = tokens.push(Token { kind: "StringLit", value: s, line: line, col: start_col })
                            } else {
                                let start_col = col
                                if ch == "+" {
                                    tokens = tokens.push(Token { kind: "Plus", value: "+", line: line, col: start_col })
                                    pos = pos + 1
                                    col = col + 1
                                } else {
                                if ch == "-" {
                                    if pos + 1 < total && ch_at(chars, pos + 1) == ">" {
                                        tokens = tokens.push(Token { kind: "Arrow", value: "->", line: line, col: start_col })
                                        pos = pos + 2
                                        col = col + 2
                                    } else {
                                        tokens = tokens.push(Token { kind: "Minus", value: "-", line: line, col: start_col })
                                        pos = pos + 1
                                        col = col + 1
                                    }
                                } else {
                                if ch == "*" {
                                    tokens = tokens.push(Token { kind: "Star", value: "*", line: line, col: start_col })
                                    pos = pos + 1
                                    col = col + 1
                                } else {
                                if ch == "/" {
                                    tokens = tokens.push(Token { kind: "Slash", value: "/", line: line, col: start_col })
                                    pos = pos + 1
                                    col = col + 1
                                } else {
                                if ch == "=" {
                                    if pos + 1 < total && ch_at(chars, pos + 1) == "=" {
                                        tokens = tokens.push(Token { kind: "EqEq", value: "==", line: line, col: start_col })
                                        pos = pos + 2
                                        col = col + 2
                                    } else {
                                        tokens = tokens.push(Token { kind: "Eq", value: "=", line: line, col: start_col })
                                        pos = pos + 1
                                        col = col + 1
                                    }
                                } else {
                                if ch == "!" {
                                    if pos + 1 < total && ch_at(chars, pos + 1) == "=" {
                                        tokens = tokens.push(Token { kind: "NotEq", value: "!=", line: line, col: start_col })
                                        pos = pos + 2
                                        col = col + 2
                                    } else {
                                        tokens = tokens.push(Token { kind: "Not", value: "!", line: line, col: start_col })
                                        pos = pos + 1
                                        col = col + 1
                                    }
                                } else {
                                if ch == "<" {
                                    if pos + 1 < total && ch_at(chars, pos + 1) == "=" {
                                        tokens = tokens.push(Token { kind: "LtEq", value: "<=", line: line, col: start_col })
                                        pos = pos + 2
                                        col = col + 2
                                    } else {
                                        tokens = tokens.push(Token { kind: "Lt", value: "<", line: line, col: start_col })
                                        pos = pos + 1
                                        col = col + 1
                                    }
                                } else {
                                if ch == ">" {
                                    if pos + 1 < total && ch_at(chars, pos + 1) == "=" {
                                        tokens = tokens.push(Token { kind: "GtEq", value: ">=", line: line, col: start_col })
                                        pos = pos + 2
                                        col = col + 2
                                    } else {
                                        tokens = tokens.push(Token { kind: "Gt", value: ">", line: line, col: start_col })
                                        pos = pos + 1
                                        col = col + 1
                                    }
                                } else {
                                if ch == "(" {
                                    tokens = tokens.push(Token { kind: "LParen", value: "(", line: line, col: start_col })
                                    pos = pos + 1
                                    col = col + 1
                                } else {
                                if ch == ")" {
                                    tokens = tokens.push(Token { kind: "RParen", value: ")", line: line, col: start_col })
                                    pos = pos + 1
                                    col = col + 1
                                } else {
                                if ch == "{" {
                                    tokens = tokens.push(Token { kind: "LBrace", value: "{", line: line, col: start_col })
                                    pos = pos + 1
                                    col = col + 1
                                } else {
                                if ch == "}" {
                                    tokens = tokens.push(Token { kind: "RBrace", value: "}", line: line, col: start_col })
                                    pos = pos + 1
                                    col = col + 1
                                } else {
                                if ch == "[" {
                                    tokens = tokens.push(Token { kind: "LBracket", value: "[", line: line, col: start_col })
                                    pos = pos + 1
                                    col = col + 1
                                } else {
                                if ch == "]" {
                                    tokens = tokens.push(Token { kind: "RBracket", value: "]", line: line, col: start_col })
                                    pos = pos + 1
                                    col = col + 1
                                } else {
                                if ch == "," {
                                    tokens = tokens.push(Token { kind: "Comma", value: ",", line: line, col: start_col })
                                    pos = pos + 1
                                    col = col + 1
                                } else {
                                if ch == ":" {
                                    tokens = tokens.push(Token { kind: "Colon", value: ":", line: line, col: start_col })
                                    pos = pos + 1
                                    col = col + 1
                                } else {
                                if ch == "." {
                                    if pos + 1 < total && ch_at(chars, pos + 1) == "." {
                                        tokens = tokens.push(Token { kind: "DotDot", value: "..", line: line, col: start_col })
                                        pos = pos + 2
                                        col = col + 2
                                    } else {
                                        tokens = tokens.push(Token { kind: "Dot", value: ".", line: line, col: start_col })
                                        pos = pos + 1
                                        col = col + 1
                                    }
                                } else {
                                if ch == "@" {
                                    tokens = tokens.push(Token { kind: "At", value: "@", line: line, col: start_col })
                                    pos = pos + 1
                                    col = col + 1
                                } else {
                                    pos = pos + 1
                                    col = col + 1
                                } } } } } } } } } } } } } } } } } }
                            }
                        }
                    }
                }
            }
        }
    }
    tokens = tokens.push(Token { kind: "Eof", value: "", line: line, col: col })
    return tokens
}

// ══════════════════════════════════════════════════════════════
// Inline parser (core subset)
// ══════════════════════════════════════════════════════════════

fn empty_node() {
    return AstNode {
        kind: "", name: "", value: "", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn node_int_lit(val) {
    return AstNode {
        kind: "IntLit", name: "", value: val, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn node_string_lit(val) {
    return AstNode {
        kind: "StringLit", name: "", value: val, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn node_bool_lit(val) {
    return AstNode {
        kind: "BoolLit", name: "", value: val, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn node_ident(name) {
    return AstNode {
        kind: "Ident", name: name, value: "", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

let mut p_tokens = []
let mut p_pos = 0
let mut p_pending_attrs = ""

fn p_peek() {
    if p_pos >= len(p_tokens) {
        return Token { kind: "Eof", value: "", line: 0, col: 0 }
    }
    return p_tokens[p_pos]
}
fn p_peek_kind() { return p_peek().kind }
fn p_at_end() { return p_peek_kind() == "Eof" }
fn p_advance() {
    let tok = p_peek()
    p_pos = p_pos + 1
    return tok
}
fn p_check(ek) { return p_peek_kind() == ek }
fn p_expect(ek) {
    if p_check(ek) { return p_advance() }
    let tok = p_peek()
    println("Parse error: expected " + ek + ", got " + tok.kind)
    return tok
}
fn p_expect_ident() {
    let tok = p_peek()
    if tok.kind == "Ident" {
        p_pos = p_pos + 1
        return tok.value
    }
    println("Parse error: expected ident, got " + tok.kind)
    return ""
}
fn p_skip_newlines() {
    while p_peek_kind() == "Newline" { p_pos = p_pos + 1 }
}

fn parse(tokens) {
    p_tokens = tokens
    p_pos = 0
    let mut stmts = []
    p_skip_newlines()
    while !p_at_end() {
        stmts = stmts.push(parse_stmt())
        p_skip_newlines()
    }
    return stmts
}

fn parse_stmt() {
    p_skip_newlines()
    while p_peek_kind() == "At" {
        p_advance()
        let attr_name = p_expect_ident()
        // M70: optional int argument @name(N) → encode as "name:N"
        let mut encoded = attr_name
        if p_peek_kind() == "LParen" {
            p_advance()
            if p_peek_kind() == "IntLit" {
                let arg_tok = p_advance()
                encoded = attr_name + ":" + arg_tok.value
            }
            if p_peek_kind() == "RParen" { p_advance() }
        }
        if p_pending_attrs == "" {
            p_pending_attrs = encoded
        } else {
            p_pending_attrs = p_pending_attrs + "," + encoded
        }
        p_skip_newlines()
    }
    let kind = p_peek_kind()
    if kind == "Let" { return parse_let() }
    if kind == "Const" { return parse_const() }
    if kind == "Fn" { return parse_fn_decl() }
    if kind == "While" { return parse_while_stmt() }
    if kind == "Return" { return parse_return() }
    if kind == "Assert" { return parse_assert_stmt() }
    let expr = parse_expr()
    if p_peek_kind() == "Eq" {
        p_advance()
        let rhs = parse_expr()
        return AstNode {
            kind: "AssignStmt", name: "", value: "", op: "",
            left: expr, right: rhs, cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    return AstNode {
        kind: "ExprStmt", name: "", value: "", op: "",
        left: expr, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn parse_let() {
    p_advance()
    let mut is_mut = false
    if p_peek_kind() == "Mut" {
        p_advance()
        is_mut = true
    }
    let name = p_expect_ident()
    p_expect("Eq")
    let expr = parse_expr()
    let mut ks = "LetStmt"
    if is_mut { ks = "LetMutStmt" }
    return AstNode {
        kind: ks, name: name, value: "", op: "",
        left: expr, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn parse_const() {
    p_advance()
    let name = p_expect_ident()
    p_expect("Eq")
    let expr = parse_expr()
    return AstNode {
        kind: "ConstStmt", name: name, value: "", op: "",
        left: expr, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn parse_return() {
    p_advance()
    let k = p_peek_kind()
    if k == "Newline" || k == "Eof" || k == "RBrace" {
        return AstNode {
            kind: "ReturnStmt", name: "", value: "", op: "",
            left: "", right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    let expr = parse_expr()
    return AstNode {
        kind: "ReturnStmt", name: "", value: "", op: "",
        left: expr, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn parse_assert_stmt() {
    p_advance()
    let expr = parse_expr()
    return AstNode {
        kind: "AssertStmt", name: "", value: "", op: "",
        left: expr, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn parse_fn_decl() {
    p_advance()
    let name = p_expect_ident()
    p_expect("LParen")
    let params = parse_params()
    p_expect("RParen")
    let body = parse_block()
    let attrs = p_pending_attrs
    p_pending_attrs = ""
    return AstNode {
        kind: "FnDecl", name: name, value: attrs, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: params, body: body, args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn parse_params() {
    let mut params = []
    if p_peek_kind() == "RParen" { return params }
    let name = p_expect_ident()
    params = params.push(AstNode {
        kind: "Param", name: name, value: "", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    })
    while p_peek_kind() == "Comma" {
        p_advance()
        let pname = p_expect_ident()
        params = params.push(AstNode {
            kind: "Param", name: pname, value: "", op: "",
            left: "", right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        })
    }
    return params
}

fn parse_while_stmt() {
    p_advance()
    let cond = parse_expr()
    let body = parse_block()
    return AstNode {
        kind: "WhileStmt", name: "", value: "", op: "",
        left: "", right: "", cond: cond, then_body: "", else_body: "",
        params: "", body: body, args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn parse_block() {
    p_skip_newlines()
    p_expect("LBrace")
    p_skip_newlines()
    let mut stmts = []
    while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
        stmts = stmts.push(parse_stmt())
        p_skip_newlines()
    }
    p_expect("RBrace")
    return stmts
}

fn parse_expr() { return parse_comparison() }

fn parse_comparison() {
    let mut left = parse_addition()
    while p_peek_kind() == "EqEq" || p_peek_kind() == "NotEq" || p_peek_kind() == "Lt" || p_peek_kind() == "Gt" || p_peek_kind() == "LtEq" || p_peek_kind() == "GtEq" {
        let op_tok = p_advance()
        let right = parse_addition()
        left = AstNode {
            kind: "BinOp", name: "", value: "", op: op_tok.value,
            left: left, right: right, cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    return left
}

fn parse_addition() {
    let mut left = parse_multiplication()
    while p_peek_kind() == "Plus" || p_peek_kind() == "Minus" {
        let op_tok = p_advance()
        let right = parse_multiplication()
        left = AstNode {
            kind: "BinOp", name: "", value: "", op: op_tok.value,
            left: left, right: right, cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    return left
}

fn parse_multiplication() {
    let mut left = parse_unary()
    while p_peek_kind() == "Star" || p_peek_kind() == "Slash" {
        let op_tok = p_advance()
        let right = parse_unary()
        left = AstNode {
            kind: "BinOp", name: "", value: "", op: op_tok.value,
            left: left, right: right, cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    return left
}

fn parse_unary() {
    if p_peek_kind() == "Not" || p_peek_kind() == "Minus" {
        let op_tok = p_advance()
        let operand = parse_unary()
        return AstNode {
            kind: "UnaryOp", name: "", value: "", op: op_tok.value,
            left: operand, right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    return parse_postfix()
}

fn parse_postfix() {
    let mut expr = parse_primary()
    let mut cont = true
    while cont {
        let k = p_peek_kind()
        if k == "LParen" {
            p_advance()
            let args = parse_args()
            p_expect("RParen")
            expr = AstNode {
                kind: "Call", name: "", value: "", op: "",
                left: expr, right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: args, fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            }
        } else {
            if k == "Dot" {
                p_advance()
                let fn2 = p_expect_ident()
                expr = AstNode {
                    kind: "Field", name: fn2, value: "", op: "",
                    left: expr, right: "", cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            } else {
                if k == "LBracket" {
                    p_advance()
                    let index = parse_expr()
                    p_expect("RBracket")
                    expr = AstNode {
                        kind: "Index", name: "", value: "", op: "",
                        left: expr, right: index, cond: "", then_body: "", else_body: "",
                        params: "", body: "", args: "", fields: "", items: "",
                        variants: "", arms: "", iter_expr: "", ret_type: "",
                        target: "", trait_name: "", methods: ""
                    }
                } else {
                    cont = false
                }
            }
        }
    }
    return expr
}

fn parse_args() {
    let mut args = []
    if p_peek_kind() == "RParen" { return args }
    args = args.push(parse_expr())
    while p_peek_kind() == "Comma" {
        p_advance()
        args = args.push(parse_expr())
    }
    return args
}

fn parse_primary() {
    let tok = p_peek()
    let k = tok.kind
    if k == "IntLit" {
        p_advance()
        return node_int_lit(tok.value)
    }
    if k == "BoolLit" {
        p_advance()
        return node_bool_lit(tok.value)
    }
    if k == "StringLit" {
        p_advance()
        return node_string_lit(tok.value)
    }
    if k == "Ident" {
        p_advance()
        return node_ident(tok.value)
    }
    if k == "LParen" {
        p_advance()
        let expr = parse_expr()
        p_expect("RParen")
        return expr
    }
    if k == "LBracket" {
        p_advance()
        let mut items = []
        while p_peek_kind() != "RBracket" && p_peek_kind() != "Eof" {
            items = items.push(parse_expr())
            if p_peek_kind() == "Comma" { p_advance() }
        }
        p_expect("RBracket")
        return AstNode {
            kind: "Array", name: "", value: "", op: "",
            left: "", right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: items,
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    println("Unexpected token: " + tok.kind)
    p_advance()
    return empty_node()
}

// ══════════════════════════════════════════════════════════════
// Inline type checker (minimal)
// ══════════════════════════════════════════════════════════════

let mut tc_errors = []
let mut scope_names = []
let mut scope_types = []
let mut scope_depths = []
let mut tc_depth = 0
let mut fn_names = []
let mut fn_arities = []

fn tc_error(msg) {
    tc_errors = tc_errors.push(TypeError { message: msg, name: "" })
}

fn tc_define(name, typ) {
    scope_names = scope_names.push(name)
    scope_types = scope_types.push(typ)
    scope_depths = scope_depths.push(tc_depth)
}

fn tc_lookup(name) {
    let mut i = len(scope_names) - 1
    while i >= 0 {
        if scope_names[i] == name { return scope_types[i] }
        i = i - 1
    }
    return ""
}

fn tc_register_fn(name, arity) {
    fn_names = fn_names.push(name)
    fn_arities = fn_arities.push(arity)
}

fn tc_lookup_fn_arity(name) {
    let mut i = 0
    while i < len(fn_names) {
        if fn_names[i] == name { return fn_arities[i] }
        i = i + 1
    }
    return -1
}

fn tc_infer(node) {
    if type_of(node) == "string" { return "void" }
    let k = node.kind
    if k == "IntLit" { return "int" }
    if k == "BoolLit" { return "bool" }
    if k == "StringLit" { return "string" }
    if k == "Ident" {
        let t = tc_lookup(node.name)
        if t == "" {
            tc_error("Undeclared variable '" + node.name + "'")
            return "unknown"
        }
        return t
    }
    if k == "BinOp" {
        tc_infer(node.left)
        tc_infer(node.right)
        if node.op == "==" || node.op == "!=" || node.op == "<" || node.op == ">" {
            return "bool"
        }
        return "int"
    }
    if k == "Call" {
        let mut i = 0
        while i < len(node.args) {
            tc_infer(node.args[i])
            i = i + 1
        }
        if type_of(node.left) != "string" && node.left.kind == "Ident" {
            let arity = tc_lookup_fn_arity(node.left.name)
            if arity >= 0 && arity != len(node.args) {
                tc_error("'" + node.left.name + "' expects " + to_string(arity) + " args, got " + to_string(len(node.args)))
            }
        }
        return "unknown"
    }
    return "unknown"
}

fn tc_check_stmt(node) {
    let k = node.kind
    if k == "LetStmt" || k == "LetMutStmt" {
        let t = tc_infer(node.left)
        tc_define(node.name, t)
        return
    }
    if k == "ConstStmt" {
        let t = tc_infer(node.left)
        tc_define(node.name, t)
        return
    }
    if k == "FnDecl" {
        tc_register_fn(node.name, len(node.params))
        tc_define(node.name, "fn")
        let saved_n = scope_names
        let saved_t = scope_types
        let saved_d = scope_depths
        let saved_depth = tc_depth
        tc_depth = tc_depth + 1
        let mut i = 0
        while i < len(node.params) {
            tc_define(node.params[i].name, "unknown")
            i = i + 1
        }
        tc_check_stmts(node.body)
        scope_names = saved_n
        scope_types = saved_t
        scope_depths = saved_d
        tc_depth = saved_depth
        return
    }
    if k == "WhileStmt" {
        tc_infer(node.cond)
        tc_check_stmts(node.body)
        return
    }
    if k == "ReturnStmt" {
        if type_of(node.left) != "string" { tc_infer(node.left) }
        return
    }
    if k == "AssignStmt" {
        if type_of(node.left) != "string" && node.left.kind == "Ident" {
            if tc_lookup(node.left.name) == "" {
                tc_error("Assign to undeclared '" + node.left.name + "'")
            }
        }
        tc_infer(node.right)
        return
    }
    if k == "ExprStmt" {
        tc_infer(node.left)
        return
    }
    if k == "AssertStmt" {
        tc_infer(node.left)
        return
    }
}

fn tc_check_stmts(stmts) {
    if type_of(stmts) == "string" { return }
    let mut i = 0
    while i < len(stmts) {
        tc_check_stmt(stmts[i])
        i = i + 1
    }
}

fn type_check(stmts) {
    tc_errors = []
    scope_names = []
    scope_types = []
    scope_depths = []
    tc_depth = 0
    fn_names = []
    fn_arities = []
    // Register builtins
    tc_register_fn("println", -1)
    tc_register_fn("print", -1)
    tc_register_fn("format", -1)
    tc_register_fn("len", 1)
    tc_register_fn("to_string", 1)
    // First pass: collect fns
    let mut i = 0
    while i < len(stmts) {
        if stmts[i].kind == "FnDecl" {
            tc_register_fn(stmts[i].name, len(stmts[i].params))
            tc_define(stmts[i].name, "fn")
        }
        i = i + 1
    }
    tc_check_stmts(stmts)
    return tc_errors
}

// ══════════════════════════════════════════════════════════════
// Inline compiler (minimal)
// ══════════════════════════════════════════════════════════════

fn instr(op, operand) { return Instruction { op: op, operand: operand } }
fn instr_op(op) { return Instruction { op: op, operand: "" } }

let mut c_code = []
let mut c_consts = []
let mut c_local_names = []
let mut c_next_local = 0
let mut c_functions = []

fn c_add_const(val) {
    let mut i = 0
    while i < len(c_consts) {
        if c_consts[i] == val { return i }
        i = i + 1
    }
    c_consts = c_consts.push(val)
    return len(c_consts) - 1
}

fn c_emit(op, operand) {
    c_code = c_code.push(instr(op, operand))
    return len(c_code) - 1
}

fn c_emit_op(op) {
    c_code = c_code.push(instr_op(op))
    return len(c_code) - 1
}

fn c_current_pos() { return len(c_code) }

fn c_patch_jump(pos, target) {
    let old = c_code[pos]
    c_code[pos] = Instruction { op: old.op, operand: to_string(target) }
}

fn c_resolve_local(name) {
    let mut i = len(c_local_names) - 1
    while i >= 0 {
        if c_local_names[i] == name { return i }
        i = i - 1
    }
    return -1
}

fn c_define_local(name) {
    let slot = c_next_local
    c_local_names = c_local_names.push(name)
    c_next_local = c_next_local + 1
    return slot
}

fn c_compile_expr(node) {
    if type_of(node) == "string" {
        c_emit_op("VOID")
        return
    }
    let k = node.kind
    if k == "IntLit" || k == "BoolLit" || k == "StringLit" {
        let idx = c_add_const(node.value)
        c_emit("CONST", to_string(idx))
        return
    }
    if k == "Ident" {
        let slot = c_resolve_local(node.name)
        if slot >= 0 {
            c_emit("GET_LOCAL", to_string(slot))
        } else {
            c_emit("GET_GLOBAL", node.name)
        }
        return
    }
    if k == "BinOp" {
        c_compile_expr(node.left)
        c_compile_expr(node.right)
        if node.op == "+" { c_emit_op("ADD") }
        if node.op == "-" { c_emit_op("SUB") }
        if node.op == "*" { c_emit_op("MUL") }
        if node.op == "/" { c_emit_op("DIV") }
        if node.op == "==" { c_emit_op("EQ") }
        if node.op == "!=" { c_emit_op("NE") }
        if node.op == "<" { c_emit_op("LT") }
        if node.op == ">" { c_emit_op("GT") }
        return
    }
    if k == "UnaryOp" {
        c_compile_expr(node.left)
        if node.op == "-" { c_emit_op("NEG") }
        if node.op == "!" { c_emit_op("NOT") }
        return
    }
    if k == "Call" {
        let ac = len(node.args)
        let mut i = 0
        while i < ac {
            c_compile_expr(node.args[i])
            i = i + 1
        }
        if type_of(node.left) != "string" && node.left.kind == "Ident" {
            let fname = node.left.name
            if fname == "println" {
                c_emit("PRINTLN", to_string(ac))
                return
            }
            if fname == "print" {
                c_emit("PRINT", to_string(ac))
                return
            }
            c_emit("CALL", fname + ":" + to_string(ac))
            return
        }
        c_emit("CALL_INDIRECT", to_string(ac))
        return
    }
    if k == "Array" {
        let count = len(node.items)
        let mut i = 0
        while i < count {
            c_compile_expr(node.items[i])
            i = i + 1
        }
        c_emit("MAKE_ARRAY", to_string(count))
        return
    }
    c_emit_op("VOID")
}

fn c_compile_stmt(node) {
    let k = node.kind
    if k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" {
        c_compile_expr(node.left)
        let slot = c_define_local(node.name)
        c_emit("SET_LOCAL", to_string(slot))
        return
    }
    if k == "FnDecl" {
        let saved = c_code
        let saved_locals = c_local_names
        let saved_next = c_next_local
        c_code = []
        c_local_names = []
        c_next_local = 0
        let pc = len(node.params)
        let mut pn = []
        let mut i = 0
        while i < pc {
            pn = pn.push(node.params[i].name)
            c_define_local(node.params[i].name)
            i = i + 1
        }
        c_compile_stmts(node.body)
        c_emit_op("VOID")
        c_emit_op("RETURN")
        let fn_code = c_code
        let fn_locals = c_next_local
        c_code = saved
        c_local_names = saved_locals
        c_next_local = saved_next
        c_functions = c_functions.push(CompiledFn {
            name: node.name, arity: pc, param_names: pn,
            code: fn_code, local_count: fn_locals
        })
        return
    }
    if k == "ReturnStmt" {
        if type_of(node.left) != "string" {
            c_compile_expr(node.left)
        } else {
            c_emit_op("VOID")
        }
        c_emit_op("RETURN")
        return
    }
    if k == "AssignStmt" {
        c_compile_expr(node.right)
        if type_of(node.left) != "string" && node.left.kind == "Ident" {
            let slot = c_resolve_local(node.left.name)
            if slot >= 0 {
                c_emit("SET_LOCAL", to_string(slot))
            } else {
                c_emit("SET_GLOBAL", node.left.name)
            }
        }
        return
    }
    if k == "WhileStmt" {
        let ls = c_current_pos()
        c_compile_expr(node.cond)
        let ej = c_emit("JUMP_IF_FALSE", "0")
        c_compile_stmts(node.body)
        c_emit("JUMP", to_string(ls))
        c_patch_jump(ej, c_current_pos())
        return
    }
    if k == "ExprStmt" {
        c_compile_expr(node.left)
        c_emit_op("POP")
        return
    }
    if k == "AssertStmt" {
        c_compile_expr(node.left)
        c_emit_op("ASSERT")
        return
    }
}

fn c_compile_stmts(stmts) {
    if type_of(stmts) == "string" { return }
    let mut i = 0
    while i < len(stmts) {
        c_compile_stmt(stmts[i])
        i = i + 1
    }
}

fn compile_program(stmts) {
    c_code = []
    c_consts = []
    c_local_names = []
    c_next_local = 0
    c_functions = []
    c_compile_stmts(stmts)
    return c_code
}

// ══════════════════════════════════════════════════════════════
// Inline ai_native_pass (M0)
// ══════════════════════════════════════════════════════════════

fn split_attrs_m0(s) {
    let mut out = []
    if s == "" { return out }
    let chars = s.chars()
    let total = len(chars)
    let mut i = 0
    let mut cur = ""
    while i < total {
        let c = to_string(chars[i])
        if c == "," {
            if cur != "" { out = out.push(cur) }
            cur = ""
        } else {
            cur = cur + c
        }
        i = i + 1
    }
    if cur != "" { out = out.push(cur) }
    return out
}

fn classify_attr_m0(name) {
    if name == "optimize" { return "G1" }
    if name == "memoize" { return "G1" }
    if name == "pure" { return "G1" }
    if name == "inline" { return "G1" }
    if name == "hot" { return "G1" }
    if name == "cold" { return "G1" }
    if name == "bounded" { return "G1" }
    if name == "fuse" { return "G2" }
    if name == "compact" { return "G2" }
    if name == "lazy" { return "G2" }
    if name == "cache" { return "G2" }
    if name == "algebraic" { return "G2" }
    if name == "parallel" { return "G3" }
    if name == "simd" { return "G3" }
    if name == "gpu" { return "G3" }
    if name == "specialize" { return "G3" }
    if name == "predict" { return "G3" }
    if name == "symbolic" { return "G4" }
    if name == "reduce" { return "G4" }
    if name == "approximate" { return "G4" }
    if name == "evolve" { return "G4" }
    if name == "learn" { return "G4" }
    if name == "contract" { return "G4" }
    if name == "profile" { return "G4" }
    if name == "test" { return "meta" }
    if name == "bench" { return "meta" }
    if name == "deprecated" { return "meta" }
    if name == "link" { return "meta" }
    return "unknown"
}

// M2: @pure purity checker — recursive. Scans a FnDecl body and
// descends into nested WhileStmt bodies. Flags side-effecting
// patterns: assignments, mutable bindings, println/print calls,
// or impure return expressions. Returns "" if pure, else reason.
fn check_purity_expr(expr) {
    if type_of(expr) == "string" { return "" }
    if expr.kind == "Call" {
        let callee = expr.left
        if type_of(callee) != "string" {
            if callee.kind == "Ident" {
                if callee.name == "println" { return "println call" }
                if callee.name == "print" { return "print call" }
            }
        }
    }
    return ""
}

fn check_purity_m1(body) {
    if type_of(body) != "array" { return "" }
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "AssignStmt" { return "assignment" }
        if k == "LetMutStmt" { return "mutable binding" }
        if k == "ExprStmt" {
            let er = check_purity_expr(stmt.left)
            if er != "" { return er }
        }
        if k == "ReturnStmt" {
            let rr = check_purity_expr(stmt.left)
            if rr != "" { return rr }
        }
        if k == "WhileStmt" {
            // M2: recurse into loop body
            let wr = check_purity_m1(stmt.body)
            if wr != "" { return "while:" + wr }
        }
        i = i + 1
    }
    return ""
}

// M1 diagnostics counters (module-level so tests can assert)
let mut m1_pure_ok = 0
let mut m1_pure_violations = 0
// M3/M4 diagnostics
let mut m3_inline_ok = 0
let mut m3_inline_too_big = 0
let mut m4_attr_conflicts = 0
// M5/M6 diagnostics
let mut m5_memoize_ok = 0
let mut m5_memoize_bad = 0
let mut m6_total_fns = 0
let mut m6_annotated_fns = 0
let mut m6_g1 = 0
let mut m6_g2 = 0
let mut m6_g3 = 0
let mut m6_g4 = 0
// M7 meta counters
let mut m7_test = 0
let mut m7_bench = 0
let mut m7_deprecated = 0
// M8: hardware attrs — loop presence check
let mut m8_hw_ok = 0
let mut m8_hw_no_loop = 0
// M9: self-recursion detection
let mut m9_recursive = 0
// M10: @memoize score
let mut m10_memoize_score_sum = 0
// M11: total Call nodes across annotated fns
let mut m11_call_count = 0
// M12: body size sums per group
let mut m12_g1_size = 0
let mut m12_g2_size = 0
let mut m12_g3_size = 0
let mut m12_g4_size = 0
// M13: max while-nesting depth across annotated fns
let mut m13_max_while_depth = 0
// M14: bubble-sort candidate heuristic
let mut m14_bubble_candidates = 0
// M15: tail-call candidate
let mut m15_tail_call_candidates = 0
// M16: Strassen candidate (triple nested loop)
let mut m16_strassen_candidates = 0
// M17: DP/memoize missed opportunity
let mut m17_dp_missed = 0
// M19: unreachable code after Return in same block
let mut m19_unreachable = 0
// M20: empty annotated body
let mut m20_empty_body = 0
// M21: constant-return body (return literal only)
let mut m21_const_return = 0
// M22: AST rewrite — auto-insert `return 0` into empty annotated body
let mut m22_rewrites = 0
// M23: auto-add @memoize to recursive @optimize fns (M17 recommendation → action)
let mut m23_auto_memoize = 0
// M24: dead code elimination — drop stmts after ReturnStmt
let mut m24_dce_fns = 0
let mut m24_dce_stmts = 0
// M25: G1 tail-call → while loop body rewrite
let mut m25_tail_rewrites = 0
// M26: duplicate attr removal
let mut m26_attr_dedups = 0
// M27: attr canonical sort
let mut m27_attr_sorts = 0
// M29: annotated fn name registry
let mut m29_registry = []
// M30: algebraic simplification (x+0, x*0, x*1)
let mut m30_algebraic = 0
// M31: self-expression identity (x-x→0)
// M32: integer constant folding
let mut m32_folds = 0
// M33: comparison constant folding
let mut m33_cmp_folds = 0
// M34: unary constant folding
let mut m34_unary_folds = 0
// M35: boolean short-circuit folding
let mut m35_bool_folds = 0
// M36: per-fn complexity score max
let mut m36_max_complexity = 0
// M41: dead while(false) loops eliminated
let mut m41_dead_loops = 0
// M42: fn name hash sum (simple rolling hash)
let mut m42_hash_sum = 0
// M43/M44/M45: AST shape stats
let mut m43_max_binop_depth = 0
let mut m44_int_lit_count = 0
let mut m45_bool_lit_count = 0
// M46: max annotated fn name length
let mut m46_max_name_len = 0
// M47: total Ident references in annotated bodies
let mut m47_ident_refs = 0
// M48: total ReturnStmt count
let mut m48_return_count = 0
// M49: min annotated fn name length (0 = unset)
let mut m49_min_name_len = 0
// M50/M51/M52: stmt kind counters
let mut m50_while_count = 0
let mut m51_let_count = 0
let mut m52_assign_count = 0
// M53: cross-annotated fn call count
let mut m53_cross_calls = 0
// M54: leaf annotated fn count (0 outgoing calls)
let mut m54_leaf_count = 0
// M151: leaf fn without @pure (missed optimization)
let mut m151_leaf_not_pure = 0
// M152: auto @pure on leaf fn (8th detection→rewrite promotion)
let mut m152_auto_pure_leaf = 0
// M55: per-fn max body size
let mut m55_max_body_size = 0
// M56/M57: total body size + avg
let mut m56_total_body_size = 0
// M60: longest attr string length (char count after join)
let mut m60_longest_attrs = 0
// M62: per-attr frequency (core set)
let mut m62_pure_uses = 0
let mut m62_inline_uses = 0
let mut m62_optimize_uses = 0
let mut m62_memoize_uses = 0
// M63: unique attr names seen (diversity)
let mut m63_attr_set = []
// M64/M67: total attrs sum, max attrs per fn
let mut m64_total_attrs = 0
let mut m67_max_attrs_per_fn = 0
// M71: bounded value extraction + huge warning
let mut m71_bounded_max = 0
let mut m71_bounded_huge = 0
// M72/M73: bounded fn count + unroll-eligible
let mut m72_bounded_fns = 0
let mut m73_unrollable = 0
// M74: identity fn (return n where n is first param)
let mut m74_identity_fns = 0
// M75: trivial wrapper (return other_fn(...))
let mut m75_wrapper_fns = 0
// M82: auto @inline injection on identity fns
let mut m82_auto_inline = 0
// M83: auto @inline injection on trivial wrappers
let mut m83_wrapper_inline = 0
// M84: auto @pure injection on stubs (const-return)
let mut m84_stub_pure = 0
// M85: @bench must be zero-arg
let mut m85_bench_bad = 0
// M86: @test must be zero-arg
let mut m86_test_bad = 0
// M87: fixpoint total iterations
let mut m87_fixpoint_iters = 0
// M88: fixpoint converged flag (true = reached stable, false = max_iters hit)
let mut m88_fixpoint_converged = false
// M89: total rewrites across all fixpoint passes
let mut m89_fixpoint_total_rewrites = 0
// M90: @memoize on impure fn warning
let mut m90_unsafe_memoize = 0
// M91: ideal memoize (pure + recursive + memoize)
let mut m91_ideal_memoize = 0
// M92: zero-param annotated fn count
let mut m92_nullary = 0
// M93: max params across annotated
let mut m93_max_params = 0
// M100~M103: AST shape node counters
let mut m100_asserts = 0
let mut m101_arrays = 0
let mut m102_indexes = 0
let mut m103_fields = 0
// M122: total BinOp count
let mut m122_binops = 0
// M123: total UnaryOp count
let mut m123_unaryops = 0
// M127: unique BinOp operator set
let mut m127_op_set = []
// M171: Call arg max count
let mut m171_max_call_args = 0
// M172: total Call args sum
let mut m172_total_call_args = 0
// M128: unique UnaryOp operator set
let mut m128_uop_set = []
// M129: StringLit total count
let mut m129_string_lits = 0
// M130: CharLit total count
let mut m130_char_lits = 0
// M131: total AST node count (all kinds)
let mut m131_total_nodes = 0
// M133: per-fn max node count
let mut m133_max_nodes_per_fn = 0
// M134: per-fn min node count (0 = unset)
let mut m134_min_nodes_per_fn = 0
// M136: trivially simple fn (no while, no call, size ≤ 2)
let mut m136_trivial_fns = 0
// M153: trivial → auto @inline (9th promotion)
let mut m153_trivial_inline = 0
// M177: return-only fn count (single stmt, kind == ReturnStmt)
let mut m177_return_only = 0
// M250: constant propagation counter
let mut m250_const_prop = 0
// M251: dead store elimination counter
let mut m251_dead_stores = 0
// M259: copy propagation counter
let mut m259_copy_prop = 0
// M271: redundant mut → let conversion
let mut m271_mut_to_let = 0
// M272: self-assignment elimination
let mut m272_self_assigns = 0
// M273: return forwarding (let x = e; return x → return e)
let mut m273_return_fwd = 0
// M274: while true { return X } → return X (single-iter elimination)
let mut m274_while_to_return = 0
// M275: dead AssignStmt (overwritten or never read again)
let mut m275_dead_assigns = 0

fn eliminate_dead_assigns(body) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let mut skip = false
        if stmt.kind == "AssignStmt" {
            let lhs = stmt.left
            if type_of(lhs) != "string" && lhs.kind == "Ident" {
                if !remaining_uses_name(body, i + 1, lhs.name) {
                    skip = true
                    m275_dead_assigns = m275_dead_assigns + 1
                }
            }
        }
        if !skip { out = out.push(stmt) }
        i = i + 1
    }
    return out
}

fn collapse_while_returns(body) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let mut replaced = false
        if stmt.kind == "WhileStmt" {
            let c = stmt.cond
            if type_of(c) != "string" && c.kind == "BoolLit" && c.value == "true" {
                let wb = stmt.body
                if type_of(wb) == "array" && len(wb) >= 1 {
                    if wb[0].kind == "ReturnStmt" {
                        out = out.push(wb[0])
                        replaced = true
                        m274_while_to_return = m274_while_to_return + 1
                    }
                }
            }
        }
        if !replaced { out = out.push(stmt) }
        i = i + 1
    }
    return out
}

fn count_uses_in_body(body, target) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ReturnStmt" || k == "ExprStmt" || k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" || k == "AssertStmt" {
            if expr_uses_name(stmt.left, target) { c = c + 1 }
        }
        if k == "AssignStmt" {
            if expr_uses_name(stmt.right, target) { c = c + 1 }
        }
        if k == "WhileStmt" {
            if expr_uses_name(stmt.cond, target) { c = c + 1 }
            c = c + count_uses_in_body(stmt.body, target)
        }
        i = i + 1
    }
    return c
}

fn forward_returns(body) {
    if type_of(body) != "array" { return body }
    let n = len(body)
    if n < 2 { return body }
    let last_idx = n - 1
    let last = body[last_idx]
    if last.kind != "ReturnStmt" { return body }
    let ret_e = last.left
    if type_of(ret_e) == "string" { return body }
    if ret_e.kind != "Ident" { return body }
    let target_name = ret_e.name
    let prev = body[last_idx - 1]
    if prev.kind != "LetStmt" { return body }
    if prev.name != target_name { return body }
    // Check single use
    if count_uses_in_body(body, target_name) != 1 { return body }
    // Rewrite: drop let, replace return with init
    let new_ret = AstNode {
        kind: "ReturnStmt", name: "", value: "", op: "",
        left: prev.left, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
    let mut out = []
    let mut i = 0
    while i < last_idx - 1 {
        out = out.push(body[i])
        i = i + 1
    }
    out = out.push(new_ret)
    m273_return_fwd = m273_return_fwd + 1
    return out
}

fn eliminate_self_assigns(body) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let mut skip = false
        if stmt.kind == "AssignStmt" {
            let lhs = stmt.left
            let rhs = stmt.right
            if type_of(lhs) != "string" && type_of(rhs) != "string" {
                if lhs.kind == "Ident" && rhs.kind == "Ident" && lhs.name == rhs.name {
                    skip = true
                    m272_self_assigns = m272_self_assigns + 1
                }
            }
        }
        if !skip { out = out.push(stmt) }
        i = i + 1
    }
    return out
}

fn name_assigned_in_body(body, target) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "AssignStmt" {
            let lhs = stmt.left
            if type_of(lhs) != "string" && lhs.kind == "Ident" && lhs.name == target {
                return true
            }
        }
        if stmt.kind == "WhileStmt" {
            if name_assigned_in_body(stmt.body, target) { return true }
        }
        i = i + 1
    }
    return false
}

fn convert_mut_to_let(body) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "LetMutStmt" && !name_assigned_in_body(body, stmt.name) {
            m271_mut_to_let = m271_mut_to_let + 1
            out = out.push(AstNode {
                kind: "LetStmt", name: stmt.name, value: stmt.value, op: "",
                left: stmt.left, right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            })
        } else {
            out = out.push(stmt)
        }
        i = i + 1
    }
    return out
}

fn propagate_copies_body(body) {
    if type_of(body) != "array" { return body }
    let mut copy_names = []   // alias name
    let mut copy_targets = [] // original Ident node
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "LetStmt" {
            let init = stmt.left
            if type_of(init) != "string" && init.kind == "Ident" {
                copy_names = copy_names.push(stmt.name)
                copy_targets = copy_targets.push(init)
            }
            out = out.push(stmt)
        } else {
            if k == "AssignStmt" {
                // Kill on reassign
                let lhs = stmt.left
                if type_of(lhs) != "string" && lhs.kind == "Ident" {
                    let cn = len(copy_names)
                    let mut nn = []
                    let mut nt = []
                    let mut j = 0
                    while j < cn {
                        if copy_names[j] != lhs.name {
                            nn = nn.push(copy_names[j])
                            nt = nt.push(copy_targets[j])
                        }
                        j = j + 1
                    }
                    copy_names = nn
                    copy_targets = nt
                }
                let new_r = propagate_expr(stmt.right, copy_names, copy_targets)
                out = out.push(AstNode {
                    kind: "AssignStmt", name: "", value: "", op: "",
                    left: stmt.left, right: new_r, cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                })
            } else {
                if k == "WhileStmt" {
                    copy_names = []
                    copy_targets = []
                    out = out.push(stmt)
                } else {
                    if k == "ReturnStmt" || k == "ExprStmt" || k == "ConstStmt" {
                        let new_e = propagate_expr(stmt.left, copy_names, copy_targets)
                        // Count copy substitutions separately by checking
                        out = out.push(AstNode {
                            kind: k, name: stmt.name, value: stmt.value, op: "",
                            left: new_e, right: "", cond: "", then_body: "", else_body: "",
                            params: "", body: "", args: "", fields: "", items: "",
                            variants: "", arms: "", iter_expr: "", ret_type: "",
                            target: "", trait_name: "", methods: ""
                        })
                    } else {
                        out = out.push(stmt)
                    }
                }
            }
        }
        i = i + 1
    }
    return out
}
// M252: @contract auto pre-assert injection
let mut m252_contract_injects = 0
// M253: cross-fn inlining (const-return stubs + identity fns)
let mut m253_inlined_calls = 0
// Inlining tables (parallel arrays)
let mut m253_stub_names = []
let mut m253_stub_lits = []   // AstNode literal value
let mut m253_id_names = []
let mut m253_id_param0 = []   // first param name

// Inline a Call expression if matches a known stub or identity
fn inline_expr(expr) {
    if type_of(expr) == "string" { return expr }
    let k = expr.kind
    if k == "Call" {
        let callee = expr.left
        if type_of(callee) != "string" {
            if callee.kind == "Ident" {
                let cname = callee.name
                // Check stub table first
                let sn = len(m253_stub_names)
                let mut si = 0
                while si < sn {
                    if m253_stub_names[si] == cname {
                        m253_inlined_calls = m253_inlined_calls + 1
                        return m253_stub_lits[si]
                    }
                    si = si + 1
                }
                // Check identity table — replace with first arg
                let idn = len(m253_id_names)
                let mut ii = 0
                while ii < idn {
                    if m253_id_names[ii] == cname {
                        let args = expr.args
                        if type_of(args) == "array" && len(args) >= 1 {
                            m253_inlined_calls = m253_inlined_calls + 1
                            return inline_expr(args[0])
                        }
                    }
                    ii = ii + 1
                }
            }
        }
        // Recurse into args (other calls may inline)
        let args = expr.args
        let mut new_args = []
        if type_of(args) == "array" {
            let an = len(args)
            let mut ai = 0
            while ai < an {
                new_args = new_args.push(inline_expr(args[ai]))
                ai = ai + 1
            }
        }
        return AstNode {
            kind: "Call", name: "", value: "", op: "",
            left: expr.left, right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: new_args, fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    if k == "BinOp" {
        let nl = inline_expr(expr.left)
        let nr = inline_expr(expr.right)
        return AstNode {
            kind: "BinOp", name: "", value: "", op: expr.op,
            left: nl, right: nr, cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    if k == "UnaryOp" {
        let no = inline_expr(expr.left)
        return AstNode {
            kind: "UnaryOp", name: "", value: "", op: expr.op,
            left: no, right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    return expr
}

fn inline_body(body) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ReturnStmt" || k == "ExprStmt" || k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" {
            let new_e = inline_expr(stmt.left)
            out = out.push(AstNode {
                kind: k, name: stmt.name, value: stmt.value, op: "",
                left: new_e, right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            })
        } else {
            if k == "AssignStmt" {
                let new_r = inline_expr(stmt.right)
                out = out.push(AstNode {
                    kind: "AssignStmt", name: "", value: "", op: "",
                    left: stmt.left, right: new_r, cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                })
            } else {
                out = out.push(stmt)
            }
        }
        i = i + 1
    }
    return out
}

fn make_contract_assert(param_name) {
    // Build: assert param_name != 0
    let lhs = AstNode {
        kind: "Ident", name: param_name, value: "", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
    let zero = make_int_lit(0)
    let cond = AstNode {
        kind: "BinOp", name: "", value: "", op: "!=",
        left: lhs, right: zero, cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
    return AstNode {
        kind: "AssertStmt", name: "", value: "", op: "",
        left: cond, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

// Check if body already starts with our injected assert (idempotence)
fn body_has_contract_assert(body, param_name) {
    if type_of(body) != "array" { return false }
    if len(body) == 0 { return false }
    let s = body[0]
    if s.kind != "AssertStmt" { return false }
    let c = s.left
    if type_of(c) == "string" { return false }
    if c.kind != "BinOp" { return false }
    if c.op != "!=" { return false }
    if type_of(c.left) == "string" { return false }
    if c.left.kind != "Ident" { return false }
    return c.left.name == param_name
}

fn inject_contract_assert(body, param_name) {
    if body_has_contract_assert(body, param_name) { return body }
    let mut out = []
    out = out.push(make_contract_assert(param_name))
    if type_of(body) == "array" {
        let n = len(body)
        let mut i = 0
        while i < n {
            out = out.push(body[i])
            i = i + 1
        }
    }
    return out
}

// Check if expression references an identifier by name (recursive)
fn expr_uses_name(expr, target) {
    if type_of(expr) == "string" { return false }
    let k = expr.kind
    if k == "Ident" { return expr.name == target }
    if k == "BinOp" {
        if expr_uses_name(expr.left, target) { return true }
        if expr_uses_name(expr.right, target) { return true }
        return false
    }
    if k == "UnaryOp" { return expr_uses_name(expr.left, target) }
    if k == "Call" {
        if expr_uses_name(expr.left, target) { return true }
        let args = expr.args
        if type_of(args) == "array" {
            let an = len(args)
            let mut ai = 0
            while ai < an {
                if expr_uses_name(args[ai], target) { return true }
                ai = ai + 1
            }
        }
        return false
    }
    return false
}

// Check if any stmt in remaining body references name
fn remaining_uses_name(body, from_idx, target) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    let mut i = from_idx
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ReturnStmt" || k == "ExprStmt" || k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" || k == "AssertStmt" {
            if expr_uses_name(stmt.left, target) { return true }
        }
        if k == "AssignStmt" {
            // LHS use = kill, skip; RHS use = true
            if expr_uses_name(stmt.right, target) { return true }
            if type_of(stmt.left) != "string" && stmt.left.kind == "Ident" && stmt.left.name == target {
                // Name is reassigned — original binding is dead if no prior use
                return false
            }
        }
        if k == "WhileStmt" {
            if expr_uses_name(stmt.cond, target) { return true }
            if remaining_uses_name(stmt.body, 0, target) { return true }
        }
        i = i + 1
    }
    return false
}

// Drop Let/LetMut stmts whose bound name is never used subsequently
fn eliminate_dead_stores(body) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        let mut keep = true
        if k == "LetStmt" || k == "LetMutStmt" {
            // Drop if name is never used later
            if !remaining_uses_name(body, i + 1, stmt.name) {
                keep = false
                m251_dead_stores = m251_dead_stores + 1
            }
        }
        if keep { out = out.push(stmt) }
        i = i + 1
    }
    return out
}

// Walk expression substituting Ident → literal when tracked
fn propagate_expr(expr, names, vals) {
    if type_of(expr) == "string" { return expr }
    let k = expr.kind
    if k == "Ident" {
        let n = len(names)
        let mut i = 0
        while i < n {
            if names[i] == expr.name {
                m250_const_prop = m250_const_prop + 1
                return vals[i]
            }
            i = i + 1
        }
        return expr
    }
    if k == "BinOp" {
        let nl = propagate_expr(expr.left, names, vals)
        let nr = propagate_expr(expr.right, names, vals)
        return AstNode {
            kind: "BinOp", name: "", value: "", op: expr.op,
            left: nl, right: nr, cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    if k == "UnaryOp" {
        let no = propagate_expr(expr.left, names, vals)
        return AstNode {
            kind: "UnaryOp", name: "", value: "", op: expr.op,
            left: no, right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    if k == "Call" {
        let args = expr.args
        let mut new_args = []
        if type_of(args) == "array" {
            let an = len(args)
            let mut ai = 0
            while ai < an {
                new_args = new_args.push(propagate_expr(args[ai], names, vals))
                ai = ai + 1
            }
        }
        return AstNode {
            kind: "Call", name: "", value: "", op: "",
            left: expr.left, right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: new_args, fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    return expr
}

// Forward pass: track immutable let bindings to literal values
fn propagate_consts_body(body) {
    if type_of(body) != "array" { return body }
    let mut names = []
    let mut vals = []
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "LetStmt" {
            // Record (name, lit) if init is literal
            let init = stmt.left
            if type_of(init) != "string" {
                if is_literal_kind(init.kind) {
                    names = names.push(stmt.name)
                    vals = vals.push(init)
                }
            }
            out = out.push(stmt)
        } else {
            if k == "LetMutStmt" {
                out = out.push(stmt)
            } else {
                if k == "AssignStmt" {
                    // LHS modified — drop from consts
                    let lhs = stmt.left
                    if type_of(lhs) != "string" && lhs.kind == "Ident" {
                        let nn = len(names)
                        let mut nn_new = []
                        let mut vv_new = []
                        let mut j = 0
                        while j < nn {
                            if names[j] != lhs.name {
                                nn_new = nn_new.push(names[j])
                                vv_new = vv_new.push(vals[j])
                            }
                            j = j + 1
                        }
                        names = nn_new
                        vals = vv_new
                    }
                    // propagate RHS
                    let new_r = propagate_expr(stmt.right, names, vals)
                    out = out.push(AstNode {
                        kind: "AssignStmt", name: "", value: "", op: "",
                        left: stmt.left, right: new_r, cond: "", then_body: "", else_body: "",
                        params: "", body: "", args: "", fields: "", items: "",
                        variants: "", arms: "", iter_expr: "", ret_type: "",
                        target: "", trait_name: "", methods: ""
                    })
                } else {
                    if k == "WhileStmt" {
                        // Safety: clear consts at loop boundary
                        names = []
                        vals = []
                        out = out.push(stmt)
                    } else {
                        if k == "ReturnStmt" || k == "ExprStmt" || k == "ConstStmt" {
                            let new_e = propagate_expr(stmt.left, names, vals)
                            out = out.push(AstNode {
                                kind: k, name: stmt.name, value: stmt.value, op: "",
                                left: new_e, right: "", cond: "", then_body: "", else_body: "",
                                params: "", body: "", args: "", fields: "", items: "",
                                variants: "", arms: "", iter_expr: "", ret_type: "",
                                target: "", trait_name: "", methods: ""
                            })
                        } else {
                            out = out.push(stmt)
                        }
                    }
                }
            }
        }
        i = i + 1
    }
    return out
}
// M179: single-stmt fn count (any kind)
let mut m179_single_stmt = 0
// M141: param count histogram
let mut m141_p0 = 0
let mut m141_p1 = 0
let mut m141_p2 = 0
let mut m141_p3plus = 0
// M144/M145: complex fn count + high complexity warnings
let mut m144_complex_fns = 0
let mut m145_high_cplx_warn = 0
// M146: max param name length
let mut m146_max_param_name = 0
// M147: total param name chars
let mut m147_total_param_chars = 0

fn count_nodes_expr(expr) {
    if type_of(expr) == "string" { return 0 }
    let mut c = 1
    if expr.kind == "BinOp" {
        c = c + count_nodes_expr(expr.left)
        c = c + count_nodes_expr(expr.right)
    }
    if expr.kind == "UnaryOp" { c = c + count_nodes_expr(expr.left) }
    if expr.kind == "Call" {
        c = c + count_nodes_expr(expr.left)
        let args = expr.args
        if type_of(args) == "array" {
            let an4 = len(args)
            let mut qi = 0
            while qi < an4 {
                c = c + count_nodes_expr(args[qi])
                qi = qi + 1
            }
        }
    }
    return c
}

fn count_nodes_body(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        c = c + 1
        let stmt = body[i]
        let k = stmt.kind
        if k == "ReturnStmt" || k == "ExprStmt" || k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" || k == "AssertStmt" {
            c = c + count_nodes_expr(stmt.left)
        }
        if k == "AssignStmt" {
            c = c + count_nodes_expr(stmt.left)
            c = c + count_nodes_expr(stmt.right)
        }
        if k == "WhileStmt" {
            c = c + count_nodes_expr(stmt.cond)
            c = c + count_nodes_body(stmt.body)
        }
        i = i + 1
    }
    return c
}
