// Test 223: M250+M251 🔥 진짜 AI-native 돌파 — 상수 전파 + DSE 합성
println("Test 223: 🔥 const-prop + DSE chain")
// let x = 5\n return x → const-prop → let x = 5; return 5 → DSE → return 5
let ast223 = parse(tokenize("@pure\nfn f() {\n  let x = 5\n  return x\n}"))
let r223 = ai_native_pass(ast223)
assert m250_const_prop == 1
// After full pipeline: body has only [return 5]
assert len(r223[0].body) == 1
assert r223[0].body[0].kind == "ReturnStmt"
assert r223[0].body[0].left.kind == "IntLit"
assert r223[0].body[0].left.value == "5"
// 체인: let + let + prop + fold + DSE → return 5만
let ast223b = parse(tokenize("@pure\nfn g() {\n  let x = 2\n  let y = 3\n  return x + y\n}"))
let r223b = ai_native_pass(ast223b)
assert len(r223b[0].body) == 1
assert r223b[0].body[0].left.kind == "IntLit"
assert r223b[0].body[0].left.value == "5"
println("  PASS")

// Test 224: M251 🔥 Dead Store Elimination
println("Test 224: 🔥 dead store elimination")
// let dead = 99 이후 dead 미사용 → 드롭
let ast224 = parse(tokenize("@pure\nfn f(n) {\n  let dead = 99\n  return n\n}"))
assert len(ast224[0].body) == 2
let r224 = ai_native_pass(ast224)
assert m251_dead_stores == 1
// After DSE: body = [return n] 만 남음
assert len(r224[0].body) == 1
assert r224[0].body[0].kind == "ReturnStmt"
// 사용되는 let은 유지
let ast224b = parse(tokenize("@pure\nfn g(n) {\n  let x = 5\n  return x + n\n}"))
let r224b = ai_native_pass(ast224b)
// x는 return에서 사용 → prop에 의해 숫자로 치환되지만 let stmt는 이후 미참조 → DSE 드롭
assert m251_dead_stores >= 1
println("  PASS")

// Test 225: M252 🔥 @contract auto pre-assert injection
println("Test 225: 🔥 @contract auto-assert")
let ast225 = parse(tokenize("@contract\nfn safe(n) {\n  return n + 1\n}"))
assert len(ast225[0].body) == 1
let r225 = ai_native_pass(ast225)
assert m252_contract_injects == 1
// After injection: body[0] is AssertStmt, body[1] is original return
assert len(r225[0].body) == 2
assert r225[0].body[0].kind == "AssertStmt"
let cond = r225[0].body[0].left
assert cond.kind == "BinOp"
assert cond.op == "!="
assert cond.left.kind == "Ident"
assert cond.left.name == "n"
assert cond.right.kind == "IntLit"
assert cond.right.value == "0"
// Idempotence: 두 번째 호출에서는 안 추가
let _r225b = ai_native_pass(r225)
assert m252_contract_injects == 0
println("  PASS")

