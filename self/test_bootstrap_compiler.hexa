let tokens11 = tokenize(source11)
let ast11 = parse(tokens11)
let errors11 = type_check(ast11)
assert len(errors11) == 0
let bytecodes11 = compile_program(ast11)
assert len(bytecodes11) > 0
println(format("  Pipeline: {} tokens -> {} stmts -> 0 errors -> {} instructions", len(tokens11), len(ast11), len(bytecodes11)))
println("  PASS")

