// Tests: Struct Codegen
// ══════════════════════════════════════════════════════════════

// Test 17: Struct declaration -> constructor function
println("Test 17: Codegen - struct constructor")
let struct_c = gen2_struct_decl_c("Point", ["x", "y"])
assert struct_c.contains("HexaVal Point(HexaVal x, HexaVal y)")
assert struct_c.contains("hexa_map_new()")
assert struct_c.contains("hexa_map_set(__s, hexa_str(\"x\"), x)")
assert struct_c.contains("hexa_map_set(__s, hexa_str(\"y\"), y)")
assert struct_c.contains("return __s;")
println("  PASS")

// Test 18: Struct field access -> hexa_map_get
println("Test 18: Codegen - struct field access")
let a18 = parse(tokenize("let v = p.x"))
let e18 = a18[0].left
assert e18.kind == "Field"
assert e18.name == "x"
let c18 = gen2_expr(e18)
assert c18.contains("hexa_map_get")
assert c18.contains("hexa_str(\"x\")")
println("  PASS")

// Test 19: Struct init -> hexa_map_new + hexa_map_set chain
println("Test 19: Codegen - struct init pattern")
let struct3 = gen2_struct_decl_c("Color", ["r", "g", "b"])
assert struct3.contains("HexaVal Color(HexaVal r, HexaVal g, HexaVal b)")
assert struct3.contains("hexa_map_new()")
assert struct3.contains("hexa_map_set(__s, hexa_str(\"r\"), r)")
assert struct3.contains("hexa_map_set(__s, hexa_str(\"g\"), g)")
assert struct3.contains("hexa_map_set(__s, hexa_str(\"b\"), b)")
println("  PASS")

