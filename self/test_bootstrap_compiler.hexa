                        if attr_has(fresh_stats, "simd") { m497_pure_inline_simd = m497_pure_inline_simd + 1 }
                        if attr_has(fresh_stats, "hot") { m498_pure_inline_hot = m498_pure_inline_hot + 1 }
                    }
