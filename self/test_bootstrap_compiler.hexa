let mut m104_const_assert_false = 0
// M116: assert(true) elimination
let mut m116_assert_elim = 0

fn eliminate_trivial_asserts(body) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let mut skip_it = false
        if stmt.kind == "AssertStmt" {
            let e = stmt.left
            if type_of(e) != "string" {
                if e.kind == "BoolLit" && e.value == "true" {
                    skip_it = true
                    m116_assert_elim = m116_assert_elim + 1
                }
            }
        }
        if !skip_it { out = out.push(stmt) }
        i = i + 1
    }
    return out
}
// M105: @pure + @inline combo
let mut m105_pure_inline_combo = 0

fn count_shape_expr(expr) {
    if type_of(expr) == "string" { return }
    let k = expr.kind
    if k == "Array" { m101_arrays = m101_arrays + 1 }
    if k == "Index" { m102_indexes = m102_indexes + 1 }
    if k == "Field" { m103_fields = m103_fields + 1 }
    if k == "BinOp" {
        m122_binops = m122_binops + 1
        // M127: track unique operator
        if !name_in_registry(expr.op, m127_op_set) {
            m127_op_set = m127_op_set.push(expr.op)
        }
        count_shape_expr(expr.left)
        count_shape_expr(expr.right)
    }
    if k == "UnaryOp" {
        m123_unaryops = m123_unaryops + 1
        if !name_in_registry(expr.op, m128_uop_set) {
            m128_uop_set = m128_uop_set.push(expr.op)
        }
        count_shape_expr(expr.left)
    }
    if k == "Call" {
        count_shape_expr(expr.left)
        let args = expr.args
        if type_of(args) == "array" {
            let an3 = len(args)
            if an3 > m171_max_call_args { m171_max_call_args = an3 }
            m172_total_call_args = m172_total_call_args + an3
            let mut ci = 0
            while ci < an3 {
                count_shape_expr(args[ci])
                ci = ci + 1
            }
        }
    }
    if k == "Index" { count_shape_expr(expr.left) }
    if k == "Field" { count_shape_expr(expr.left) }
}

fn count_shape_body(body) {
    if type_of(body) != "array" { return }
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "AssertStmt" { m100_asserts = m100_asserts + 1 }
        if k == "ReturnStmt" || k == "ExprStmt" || k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" || k == "AssertStmt" {
            count_shape_expr(stmt.left)
        }
        if k == "AssignStmt" {
            count_shape_expr(stmt.left)
            count_shape_expr(stmt.right)
        }
        if k == "WhileStmt" {
            count_shape_expr(stmt.cond)
            count_shape_body(stmt.body)
        }
        i = i + 1
    }
}

fn is_identity_fn(body, params) {
    if type_of(body) != "array" { return false }
    if len(body) != 1 { return false }
    if len(params) == 0 { return false }
    let s = body[0]
    if s.kind != "ReturnStmt" { return false }
    let e = s.left
    if type_of(e) == "string" { return false }
    if e.kind != "Ident" { return false }
    return e.name == params[0].name
}

fn is_trivial_wrapper(body, self_name) {
    if type_of(body) != "array" { return false }
    if len(body) != 1 { return false }
    let s = body[0]
    if s.kind != "ReturnStmt" { return false }
    let e = s.left
    if type_of(e) == "string" { return false }
    if e.kind != "Call" { return false }
    let callee = e.left
    if type_of(callee) == "string" { return false }
    if callee.kind != "Ident" { return false }
    return callee.name != self_name
}

fn extract_bounded_value(attr) {
    let chars = attr.chars()
    let n = len(chars)
    let mut i = 0
    let mut found_colon = false
    let mut num_str = ""
    while i < n {
        let c = to_string(chars[i])
        if found_colon { num_str = num_str + c }
        if c == ":" { found_colon = true }
        i = i + 1
    }
    if !found_colon { return -1 }
    return parse_int_str(num_str)
}

fn name_in_registry(name, registry) {
    let n = len(registry)
    let mut i = 0
    while i < n {
        if registry[i] == name { return true }
        i = i + 1
    }
    return false
}

fn count_cross_calls_expr(expr, registry) {
    if type_of(expr) == "string" { return 0 }
    let mut c = 0
    if expr.kind == "Call" {
        let callee = expr.left
        if type_of(callee) != "string" {
            if callee.kind == "Ident" {
                if name_in_registry(callee.name, registry) { c = c + 1 }
            }
        }
        let args = expr.args
        if type_of(args) == "array" {
            let an2 = len(args)
            let mut ai = 0
            while ai < an2 {
                c = c + count_cross_calls_expr(args[ai], registry)
                ai = ai + 1
            }
        }
    }
    if expr.kind == "BinOp" {
        c = c + count_cross_calls_expr(expr.left, registry)
        c = c + count_cross_calls_expr(expr.right, registry)
    }
    if expr.kind == "UnaryOp" {
        c = c + count_cross_calls_expr(expr.left, registry)
    }
    return c
}

fn count_cross_calls_body(body, registry) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ReturnStmt" || k == "ExprStmt" || k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" {
            c = c + count_cross_calls_expr(stmt.left, registry)
        }
        if k == "AssignStmt" {
            c = c + count_cross_calls_expr(stmt.right, registry)
        }
        if k == "WhileStmt" {
            c = c + count_cross_calls_expr(stmt.cond, registry)
            c = c + count_cross_calls_body(stmt.body, registry)
        }
        i = i + 1
    }
    return c
}

fn count_stmt_kinds(body) {
    if type_of(body) != "array" { return }
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "WhileStmt" {
            m50_while_count = m50_while_count + 1
            count_stmt_kinds(stmt.body)
        }
        if k == "LetStmt" || k == "LetMutStmt" { m51_let_count = m51_let_count + 1 }
        if k == "AssignStmt" { m52_assign_count = m52_assign_count + 1 }
        i = i + 1
    }
}

fn count_returns_body(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "ReturnStmt" { c = c + 1 }
        if stmt.kind == "WhileStmt" { c = c + count_returns_body(stmt.body) }
        i = i + 1
    }
    return c
}

fn count_idents_expr(expr) {
    if type_of(expr) == "string" { return }
    if expr.kind == "Ident" { m47_ident_refs = m47_ident_refs + 1 }
    if expr.kind == "BinOp" {
        count_idents_expr(expr.left)
        count_idents_expr(expr.right)
    }
    if expr.kind == "UnaryOp" { count_idents_expr(expr.left) }
    if expr.kind == "Call" {
        count_idents_expr(expr.left)
        let args = expr.args
        if type_of(args) == "array" {
            let n = len(args)
            let mut i = 0
            while i < n {
                count_idents_expr(args[i])
                i = i + 1
            }
        }
    }
}

fn count_idents_body(body) {
    if type_of(body) != "array" { return }
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ReturnStmt" || k == "ExprStmt" || k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" {
            count_idents_expr(stmt.left)
        }
        if k == "AssignStmt" {
            count_idents_expr(stmt.left)
            count_idents_expr(stmt.right)
        }
        if k == "WhileStmt" {
            count_idents_expr(stmt.cond)
            count_idents_body(stmt.body)
        }
        i = i + 1
    }
}

fn expr_binop_depth(expr) {
    if type_of(expr) == "string" { return 0 }
    if expr.kind != "BinOp" { return 0 }
    let ld = expr_binop_depth(expr.left)
    let rd = expr_binop_depth(expr.right)
    let mx = ld
    if rd > mx { mx = rd }
    return 1 + mx
}

fn count_lits_expr(expr) {
    if type_of(expr) == "string" { return }
    if expr.kind == "IntLit" { m44_int_lit_count = m44_int_lit_count + 1 }
    if expr.kind == "BoolLit" { m45_bool_lit_count = m45_bool_lit_count + 1 }
    if expr.kind == "StringLit" { m129_string_lits = m129_string_lits + 1 }
    if expr.kind == "CharLit" { m130_char_lits = m130_char_lits + 1 }
    if expr.kind == "BinOp" {
        count_lits_expr(expr.left)
        count_lits_expr(expr.right)
    }
    if expr.kind == "UnaryOp" {
        count_lits_expr(expr.left)
    }
    if expr.kind == "Call" {
        let args = expr.args
        if type_of(args) == "array" {
            let n = len(args)
            let mut i = 0
            while i < n {
                count_lits_expr(args[i])
                i = i + 1
            }
        }
    }
}

fn count_lits_body(body) {
    if type_of(body) != "array" { return }
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ReturnStmt" || k == "ExprStmt" || k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" {
            count_lits_expr(stmt.left)
        }
        if k == "AssignStmt" { count_lits_expr(stmt.right) }
        if k == "WhileStmt" {
            count_lits_expr(stmt.cond)
            count_lits_body(stmt.body)
        }
        i = i + 1
    }
}

fn max_binop_depth_body(body) {
    if type_of(body) != "array" { return 0 }
    let mut mx = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        let mut d = 0
        if k == "ReturnStmt" || k == "ExprStmt" || k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" {
            d = expr_binop_depth(stmt.left)
        }
        if k == "AssignStmt" { d = expr_binop_depth(stmt.right) }
        if k == "WhileStmt" {
            let dc = expr_binop_depth(stmt.cond)
            let db = max_binop_depth_body(stmt.body)
            if dc > d { d = dc }
            if db > d { d = db }
        }
        if d > mx { mx = d }
        i = i + 1
    }
    return mx
}

fn str_hash(s) {
    let chars = s.chars()
    let n = len(chars)
    let mut h = 0
    let mut i = 0
    while i < n {
        let c = to_string(chars[i])
        let d = digit_val(c)
        if d >= 0 {
            h = h * 31 + d
        } else {
            // Non-digit: use length contribution (cheap fallback)
            h = h * 31 + n
        }
        i = i + 1
    }
    return h
}
// M37: stub fns (body is just `return <literal>`)
let mut m37_stubs = 0
// M38: attr count histogram
let mut m38_one = 0
let mut m38_two = 0
let mut m38_three = 0
let mut m38_four_plus = 0
// M39: total params + zero-param fns + max arity
let mut m39_param_sum = 0
