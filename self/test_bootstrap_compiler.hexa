                left: "", right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            }
        }
        // M115: x / x → 1 (assumes x != 0)
        if same_ident(l, r) {
            m30_algebraic = m30_algebraic + 1
            return make_int_lit(1)
        }
        // M265: (x*c) / c → x
        if type_of(l) != "string" && type_of(r) != "string" {
            if l.kind == "BinOp" && l.op == "*" && r.kind == "IntLit" {
                if type_of(l.right) != "string" && l.right.kind == "IntLit" {
                    if l.right.value == r.value && r.value != "0" {
                        m30_algebraic = m30_algebraic + 1
                        return l.left
                    }
                }
            }
        }
    }
    if op == "&&" {
        if is_bool_false(l) {
            m35_bool_folds = m35_bool_folds + 1
            return l
        }
        if is_bool_false(r) {
            m35_bool_folds = m35_bool_folds + 1
            return r
        }
        if is_bool_true(l) {
            m35_bool_folds = m35_bool_folds + 1
            return r
        }
        if is_bool_true(r) {
            m35_bool_folds = m35_bool_folds + 1
            return l
        }
        // M108: x && x → x
        if same_ident(l, r) {
            m35_bool_folds = m35_bool_folds + 1
            return l
        }
        // M113: x && !x → false / !x && x → false
        if is_not_of(l, r) || is_not_of(r, l) {
            m35_bool_folds = m35_bool_folds + 1
            return make_bool_lit_from_bool(false)
        }
    }
    if op == "||" {
        if is_bool_true(l) {
            m35_bool_folds = m35_bool_folds + 1
            return l
        }
        if is_bool_true(r) {
            m35_bool_folds = m35_bool_folds + 1
            return r
        }
        if is_bool_false(l) {
            m35_bool_folds = m35_bool_folds + 1
            return r
        }
        if is_bool_false(r) {
            m35_bool_folds = m35_bool_folds + 1
            return l
        }
        // M109: x || x → x
        if same_ident(l, r) {
            m35_bool_folds = m35_bool_folds + 1
            return l
        }
        // M113: x || !x → true / !x || x → true
        if is_not_of(l, r) || is_not_of(r, l) {
            m35_bool_folds = m35_bool_folds + 1
            return make_bool_lit_from_bool(true)
        }
    }
    // Rebuild with simplified children
    return AstNode {
        kind: "BinOp", name: "", value: "", op: op,
        left: l, right: r, cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn simplify_body(body) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ReturnStmt" || k == "ExprStmt" || k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" {
            let new_e = simplify_expr(stmt.left)
            out = out.push(AstNode {
                kind: k, name: stmt.name, value: stmt.value, op: "",
                left: new_e, right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            })
        } else {
            if k == "AssignStmt" {
                let new_r = simplify_expr(stmt.right)
                out = out.push(AstNode {
                    kind: "AssignStmt", name: "", value: "", op: "",
                    left: stmt.left, right: new_r, cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                })
            } else {
                if k == "WhileStmt" {
                    let new_cond = simplify_expr(stmt.cond)
                    // M41: while(false) { ... } → drop entirely
                    if is_bool_false(new_cond) {
                        m41_dead_loops = m41_dead_loops + 1
                        // don't push anything
                    } else {
                        let new_body = simplify_body(stmt.body)
                        out = out.push(AstNode {
                            kind: "WhileStmt", name: "", value: "", op: "",
                            left: "", right: "", cond: new_cond, then_body: "", else_body: "",
                            params: "", body: new_body, args: "", fields: "", items: "",
                            variants: "", arms: "", iter_expr: "", ret_type: "",
                            target: "", trait_name: "", methods: ""
                        })
                    }
                } else {
                    out = out.push(stmt)
                }
            }
        }
        i = i + 1
    }
    return out
}

// Canonical attr rank (lower = earlier). Integer comparison only.
fn attr_rank(name) {
    if name == "pure" { return 10 }
    if name == "inline" { return 20 }
    if name == "hot" { return 30 }
    if name == "cold" { return 31 }
    if name == "bounded" { return 40 }
    if name == "memoize" { return 50 }
    if name == "optimize" { return 60 }
    if name == "fuse" { return 70 }
    if name == "compact" { return 71 }
    if name == "lazy" { return 72 }
    if name == "cache" { return 73 }
    if name == "algebraic" { return 74 }
    if name == "parallel" { return 80 }
    if name == "simd" { return 81 }
    if name == "gpu" { return 82 }
    if name == "specialize" { return 83 }
    if name == "predict" { return 84 }
    if name == "symbolic" { return 90 }
    if name == "reduce" { return 91 }
    if name == "approximate" { return 92 }
    if name == "evolve" { return 93 }
    if name == "learn" { return 94 }
    if name == "contract" { return 95 }
    if name == "profile" { return 96 }
    if name == "test" { return 200 }
    if name == "bench" { return 201 }
    if name == "deprecated" { return 202 }
    if name == "link" { return 203 }
    return 999
}

fn sort_attrs(attrs) {
    // Selection sort by rank — stable for equal ranks
    let n = len(attrs)
    let mut result = []
    let mut i = 0
    while i < n {
        result = result.push(attrs[i])
        i = i + 1
    }
    let mut k = 0
    while k < n {
        let mut min_idx = k
        let mut j = k + 1
        while j < n {
            if attr_rank(result[j]) < attr_rank(result[min_idx]) {
                min_idx = j
            }
            j = j + 1
        }
        if min_idx != k {
            // swap via rebuild
            let mut tmp = []
            let mut t = 0
            while t < n {
                if t == k { tmp = tmp.push(result[min_idx]) }
                else { if t == min_idx { tmp = tmp.push(result[k]) }
                       else { tmp = tmp.push(result[t]) } }
                t = t + 1
            }
            result = tmp
        }
        k = k + 1
    }
    return result
}

fn arrays_equal_str(a, b) {
    if len(a) != len(b) { return false }
    let n = len(a)
    let mut i = 0
    while i < n {
        if a[i] != b[i] { return false }
        i = i + 1
    }
    return true
}

fn dedup_attrs(attrs) {
    let mut seen = []
    let n = len(attrs)
    let mut i = 0
    while i < n {
        let a = attrs[i]
        let mut already = false
        let sn = len(seen)
        let mut j = 0
        while j < sn {
            if seen[j] == a { already = true }
            j = j + 1
        }
        if !already { seen = seen.push(a) }
        i = i + 1
    }
    return seen
}

fn join_attrs(attrs) {
    let n = len(attrs)
    if n == 0 { return "" }
    let mut out = attrs[0]
    let mut i = 1
    while i < n {
        out = out + "," + attrs[i]
        i = i + 1
    }
    return out
}

fn make_bool_lit(v) {
    return AstNode {
        kind: "BoolLit", name: "", value: v, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_while_true_empty() {
    return AstNode {
        kind: "WhileStmt", name: "", value: "", op: "",
        left: "", right: "", cond: make_bool_lit("true"), then_body: "", else_body: "",
        params: "", body: [], args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

// Simple tail-call: body is exactly [ReturnStmt(Call(Ident self, ...))]
fn is_simple_tail_only(body, self_name) {
    if type_of(body) != "array" { return false }
    if len(body) != 1 { return false }
    let s = body[0]
    if s.kind != "ReturnStmt" { return false }
    let e = s.left
    if type_of(e) == "string" { return false }
    if e.kind != "Call" { return false }
    let callee = e.left
    if type_of(callee) == "string" { return false }
    if callee.kind != "Ident" { return false }
    return callee.name == self_name
}

fn eliminate_dead(body) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let n = len(body)
    let mut i = 0
    let mut stopped = false
    while i < n {
        if !stopped {
            out = out.push(body[i])
            if body[i].kind == "ReturnStmt" { stopped = true }
        }
        i = i + 1
    }
    return out
}

fn rewrite_fn_with_attrs(fn_node, new_attrs) {
    return AstNode {
        kind: "FnDecl", name: fn_node.name, value: new_attrs, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: fn_node.params, body: fn_node.body, args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: fn_node.ret_type,
        target: "", trait_name: "", methods: ""
    }
}

fn make_return_zero() {
    let lit = AstNode {
        kind: "IntLit", name: "", value: "0", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
    return AstNode {
        kind: "ReturnStmt", name: "", value: "", op: "",
        left: lit, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn rewrite_fn_with_body(fn_node, new_body) {
    return AstNode {
        kind: "FnDecl", name: fn_node.name, value: fn_node.value, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: fn_node.params, body: new_body, args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: fn_node.ret_type,
        target: "", trait_name: "", methods: ""
    }
}

fn is_literal_kind(k) {
    if k == "IntLit" { return true }
    if k == "FloatLit" { return true }
    if k == "BoolLit" { return true }
    if k == "StringLit" { return true }
    if k == "CharLit" { return true }
    return false
}

fn body_is_const_return(body) {
    if type_of(body) != "array" { return false }
    if len(body) != 1 { return false }
    let s = body[0]
    if s.kind != "ReturnStmt" { return false }
    let e = s.left
    if type_of(e) == "string" { return false }
    return is_literal_kind(e.kind)
}

fn count_unreachable(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    let mut hit = false
    while i < n {
        let stmt = body[i]
        if hit { c = c + 1 }
        if stmt.kind == "ReturnStmt" { hit = true }
        if stmt.kind == "WhileStmt" {
            c = c + count_unreachable(stmt.body)
        }
        i = i + 1
    }
    return c
}

fn is_tail_call(body, self_name) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    if n == 0 { return false }
    let last = body[n - 1]
    if last.kind != "ReturnStmt" { return false }
    return expr_calls_self(last.left, self_name)
}

fn body_has_let_mut(body) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    let mut i = 0
    while i < n {
        let k = body[i].kind
        if k == "LetMutStmt" { return true }
        if k == "WhileStmt" {
            if body_has_let_mut(body[i].body) { return true }
        }
        i = i + 1
    }
    return false
}

fn while_depth(body) {
    if type_of(body) != "array" { return 0 }
    let mut maxd = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "WhileStmt" {
            let sub = while_depth(stmt.body)
            let here = 1 + sub
            if here > maxd { maxd = here }
        }
        i = i + 1
    }
    return maxd
}

fn expr_count_calls(expr) {
    if type_of(expr) == "string" { return 0 }
    let mut c = 0
    if expr.kind == "Call" {
        c = 1
        let args = expr.args
        if type_of(args) == "array" {
            let n = len(args)
            let mut i = 0
            while i < n {
                c = c + expr_count_calls(args[i])
                i = i + 1
            }
        }
    }
    if expr.kind == "BinOp" {
        c = c + expr_count_calls(expr.left)
        c = c + expr_count_calls(expr.right)
    }
    return c
}

fn stmts_count_calls(body) {
    if type_of(body) != "array" { return 0 }
    let mut total = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ExprStmt" || k == "ReturnStmt" || k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" {
            total = total + expr_count_calls(stmt.left)
        }
        if k == "AssignStmt" {
            total = total + expr_count_calls(stmt.right)
        }
        if k == "WhileStmt" {
            total = total + expr_count_calls(stmt.cond)
            total = total + stmts_count_calls(stmt.body)
        }
        i = i + 1
    }
    return total
}

fn expr_calls_self(expr, self_name) {
    if type_of(expr) == "string" { return false }
    let k = expr.kind
    if k == "Call" {
        let callee = expr.left
        if type_of(callee) != "string" {
            if callee.kind == "Ident" && callee.name == self_name {
                return true
            }
        }
        // recurse into args
        let args = expr.args
        if type_of(args) == "array" {
            let n = len(args)
            let mut i = 0
            while i < n {
                if expr_calls_self(args[i], self_name) { return true }
                i = i + 1
            }
        }
        return false
    }
    if k == "BinOp" {
        if expr_calls_self(expr.left, self_name) { return true }
        if expr_calls_self(expr.right, self_name) { return true }
    }
    return false
}

fn stmts_call_self(body, self_name) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ExprStmt" {
            if expr_calls_self(stmt.left, self_name) { return true }
        }
        if k == "ReturnStmt" {
            if expr_calls_self(stmt.left, self_name) { return true }
        }
        if k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" {
            if expr_calls_self(stmt.left, self_name) { return true }
        }
        if k == "AssignStmt" {
            if expr_calls_self(stmt.right, self_name) { return true }
        }
        if k == "WhileStmt" {
            if expr_calls_self(stmt.cond, self_name) { return true }
            if stmts_call_self(stmt.body, self_name) { return true }
        }
        i = i + 1
    }
    return false
}

fn body_has_loop(body) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    let mut i = 0
    while i < n {
        let k = body[i].kind
        if k == "WhileStmt" { return true }
        if k == "ForStmt" { return true }
        if k == "LoopStmt" { return true }
        i = i + 1
    }
    return false
}

// M3: body size — counts top-level statements only (simple heuristic).
// Inline threshold: 8 stmts. Over → "too big" diagnostic.
fn body_stmt_count(body) {
    if type_of(body) != "array" { return 0 }
    return len(body)
}

// M4: check a set of attrs for known conflicts.
// Returns reason string if conflict, else "".
fn attr_has(attrs, target) {
    let n = len(attrs)
    let mut i = 0
    while i < n {
        if attrs[i] == target { return true }
        i = i + 1
    }
    return false
}

fn find_attr_conflict(attrs) {
    if attr_has(attrs, "hot") && attr_has(attrs, "cold") {
        return "hot+cold"
    }
    if attr_has(attrs, "inline") && attr_has(attrs, "cold") {
        return "inline+cold"
    }
    if attr_has(attrs, "pure") && attr_has(attrs, "evolve") {
        return "pure+evolve"
    }
    return ""
}

fn ai_native_pass(ast) {
    let mut seen = 0
    m1_pure_ok = 0
    m1_pure_violations = 0
    m3_inline_ok = 0
    m3_inline_too_big = 0
    m4_attr_conflicts = 0
    m5_memoize_ok = 0
    m5_memoize_bad = 0
    m6_total_fns = 0
    m6_annotated_fns = 0
    m6_g1 = 0
    m6_g2 = 0
    m6_g3 = 0
    m6_g4 = 0
    m7_test = 0
    m7_bench = 0
    m7_deprecated = 0
    m8_hw_ok = 0
    m8_hw_no_loop = 0
    m9_recursive = 0
    m10_memoize_score_sum = 0
    m11_call_count = 0
    m12_g1_size = 0
    m12_g2_size = 0
    m12_g3_size = 0
    m12_g4_size = 0
    m13_max_while_depth = 0
    m14_bubble_candidates = 0
    m15_tail_call_candidates = 0
    m16_strassen_candidates = 0
    m17_dp_missed = 0
    m19_unreachable = 0
    m20_empty_body = 0
    m21_const_return = 0
    m22_rewrites = 0
    m23_auto_memoize = 0
    m24_dce_fns = 0
    m24_dce_stmts = 0
    m25_tail_rewrites = 0
    m26_attr_dedups = 0
    m27_attr_sorts = 0
    m29_registry = []
    m30_algebraic = 0
    m32_folds = 0
    m33_cmp_folds = 0
    m34_unary_folds = 0
    m35_bool_folds = 0
    m36_max_complexity = 0
    m41_dead_loops = 0
    m42_hash_sum = 0
    m43_max_binop_depth = 0
    m44_int_lit_count = 0
    m45_bool_lit_count = 0
    m46_max_name_len = 0
    m47_ident_refs = 0
    m48_return_count = 0
    m49_min_name_len = 0
    m50_while_count = 0
    m51_let_count = 0
    m52_assign_count = 0
    m53_cross_calls = 0
    m54_leaf_count = 0
    m151_leaf_not_pure = 0
    m152_auto_pure_leaf = 0
    m55_max_body_size = 0
    m56_total_body_size = 0
    m60_longest_attrs = 0
    m62_pure_uses = 0
    m62_inline_uses = 0
    m62_optimize_uses = 0
    m62_memoize_uses = 0
    m63_attr_set = []
    m64_total_attrs = 0
    m67_max_attrs_per_fn = 0
    m71_bounded_max = 0
    m71_bounded_huge = 0
    m72_bounded_fns = 0
    m73_unrollable = 0
    m74_identity_fns = 0
    m75_wrapper_fns = 0
    m82_auto_inline = 0
    m83_wrapper_inline = 0
    m84_stub_pure = 0
    m85_bench_bad = 0
    m86_test_bad = 0
    m90_unsafe_memoize = 0
    m91_ideal_memoize = 0
    m92_nullary = 0
    m93_max_params = 0
    m100_asserts = 0
    m101_arrays = 0
    m102_indexes = 0
    m103_fields = 0
    m122_binops = 0
    m123_unaryops = 0
    m127_op_set = []
    m171_max_call_args = 0
    m172_total_call_args = 0
    m128_uop_set = []
    m129_string_lits = 0
    m130_char_lits = 0
    m131_total_nodes = 0
    m133_max_nodes_per_fn = 0
    m134_min_nodes_per_fn = 0
    m136_trivial_fns = 0
    m153_trivial_inline = 0
    m177_return_only = 0
    m179_single_stmt = 0
    m250_const_prop = 0
    m251_dead_stores = 0
    m259_copy_prop = 0
    m271_mut_to_let = 0
    m272_self_assigns = 0
    m273_return_fwd = 0
    m274_while_to_return = 0
    m275_dead_assigns = 0
    m252_contract_injects = 0
    m253_inlined_calls = 0
    m253_stub_names = []
    m253_stub_lits = []
    m253_id_names = []
    m253_id_param0 = []
    m141_p0 = 0
    m141_p1 = 0
    m141_p2 = 0
    m141_p3plus = 0
    m144_complex_fns = 0
    m145_high_cplx_warn = 0
    m146_max_param_name = 0
    m147_total_param_chars = 0
    m124_max_memoize_score = 0
    m125_ideal_helpers = 0
    m104_const_assert_true = 0
    m104_const_assert_false = 0
    m116_assert_elim = 0
    m105_pure_inline_combo = 0
    m37_stubs = 0
    m38_one = 0
    m38_two = 0
    m38_three = 0
    m38_four_plus = 0
    m39_param_sum = 0
    m39_zero_arg = 0
    m39_max_arity = 0
    let inline_threshold = 8
    let mut out = []
    let n = len(ast)
    let mut i = 0
    while i < n {
        let mut node = ast[i]
        // M20 diagnostic captured BEFORE any M22 rewrite
        let was_empty = node.kind == "FnDecl" && node.value != "" && body_stmt_count(node.body) == 0
        if was_empty {
            println("[ai-native] fn " + node.name + " WARN: empty body with @attrs")
            m20_empty_body = m20_empty_body + 1
        }
        // M22: if annotated with empty body, rewrite to inject `return 0`
        if was_empty {
            let new_body = [make_return_zero()]
            node = rewrite_fn_with_body(node, new_body)
            m22_rewrites = m22_rewrites + 1
            println("[ai-native] fn " + node.name + " REWRITE: inserted `return 0`")
        }
        if node.kind == "FnDecl" {
            m6_total_fns = m6_total_fns + 1
        }
        if node.kind == "FnDecl" && node.value != "" {
            m6_annotated_fns = m6_annotated_fns + 1
            // M29: register this fn name
            m29_registry = m29_registry.push(node.name)
            let raw_attrs = split_attrs_m0(node.value)
            // M26: deduplicate attrs
            let deduped = dedup_attrs(raw_attrs)
            if len(deduped) < len(raw_attrs) {
                node = rewrite_fn_with_attrs(node, join_attrs(deduped))
                m26_attr_dedups = m26_attr_dedups + (len(raw_attrs) - len(deduped))
                println("[ai-native] fn " + node.name + " REWRITE: dedup attrs → " + join_attrs(deduped))
            }
            // M27: canonical alpha sort
            let sorted = sort_attrs(deduped)
            let attrs = sorted
            if !arrays_equal_str(deduped, sorted) {
                node = rewrite_fn_with_attrs(node, join_attrs(sorted))
                m27_attr_sorts = m27_attr_sorts + 1
                println("[ai-native] fn " + node.name + " REWRITE: sort attrs → " + join_attrs(sorted))
            }
            let an = len(attrs)
            // M9: pre-compute self-recursion once per fn
            let is_rec = stmts_call_self(node.body, node.name)
            if is_rec {
                m9_recursive = m9_recursive + 1
                println("[ai-native] fn " + node.name + " RECURSIVE")
            }
            // M11: accumulate call count for this annotated fn
            let calls_here = stmts_count_calls(node.body)
            m11_call_count = m11_call_count + calls_here
            // M54: leaf detection
            if calls_here == 0 { m54_leaf_count = m54_leaf_count + 1 }
            // M177/M179: single-stmt fn
            if body_stmt_count(node.body) == 1 {
                m179_single_stmt = m179_single_stmt + 1
                if node.body[0].kind == "ReturnStmt" {
                    m177_return_only = m177_return_only + 1
                }
            }
            // M151/M152: leaf fn missing @pure → auto inject (requires purity check)
            // Re-read fresh attrs from node.value (may have been updated by earlier rewrites)
            let fresh_attrs_leaf = split_attrs_m0(node.value)
            if calls_here == 0 && !attr_has(fresh_attrs_leaf, "pure") {
                m151_leaf_not_pure = m151_leaf_not_pure + 1
                // Only auto-inject if body is also syntactically pure
                let pur_reason = check_purity_m1(node.body)
                if pur_reason == "" {
                    node = rewrite_fn_with_attrs(node, node.value + ",pure")
                    m152_auto_pure_leaf = m152_auto_pure_leaf + 1
                    println("[ai-native] fn " + node.name + " REWRITE: auto @pure (leaf + syntactically pure)")
                }
            }
            // M136/M153: trivial simple = no calls + no while + body ≤ 2 → auto @inline
            // Skip identity fns (handled by M82) and wrappers (handled by M83)
            if calls_here == 0 && while_depth(node.body) == 0 && body_stmt_count(node.body) <= 2 && !is_identity_fn(node.body, node.params) && !is_trivial_wrapper(node.body, node.name) {
                m136_trivial_fns = m136_trivial_fns + 1
                let fresh_attrs_triv = split_attrs_m0(node.value)
                if !attr_has(fresh_attrs_triv, "inline") {
                    node = rewrite_fn_with_attrs(node, node.value + ",inline")
                    m153_trivial_inline = m153_trivial_inline + 1
                    println("[ai-native] fn " + node.name + " REWRITE: auto @inline (trivial)")
                }
            }
            // M74/M82/M125: identity fn → auto @inline + ideal helper
            if is_identity_fn(node.body, node.params) {
                m74_identity_fns = m74_identity_fns + 1
                let fresh_ai = split_attrs_m0(node.value)
                if !attr_has(fresh_ai, "inline") {
                    node = rewrite_fn_with_attrs(node, node.value + ",inline")
                    m82_auto_inline = m82_auto_inline + 1
                    println("[ai-native] fn " + node.name + " REWRITE: auto @inline (identity)")
                }
                if attr_has(fresh_ai, "pure") {
                    m125_ideal_helpers = m125_ideal_helpers + 1
                }
            }
            // M75/M83: trivial wrapper → auto @inline
            if is_trivial_wrapper(node.body, node.name) {
                m75_wrapper_fns = m75_wrapper_fns + 1
                let fresh_wr = split_attrs_m0(node.value)
                if !attr_has(fresh_wr, "inline") {
                    node = rewrite_fn_with_attrs(node, node.value + ",inline")
                    m83_wrapper_inline = m83_wrapper_inline + 1
                    println("[ai-native] fn " + node.name + " REWRITE: auto @inline (wrapper)")
                }
            }
            // M55/M56: per-fn max + total body size tracking
            let bs = body_stmt_count(node.body)
            if bs > m55_max_body_size { m55_max_body_size = bs }
            m56_total_body_size = m56_total_body_size + bs
            // M36: per-fn complexity score = body_size + calls*2 + while_depth*5
            let sz_here = body_stmt_count(node.body)
            let cplx = sz_here + calls_here * 2 + while_depth(node.body) * 5
            if cplx > m36_max_complexity { m36_max_complexity = cplx }
            // M144: complex fn (body > 5)
            if sz_here > 5 { m144_complex_fns = m144_complex_fns + 1 }
            // M145: high complexity warning (> 10)
            if cplx > 10 {
                m145_high_cplx_warn = m145_high_cplx_warn + 1
                println("[ai-native] fn " + node.name + " WARN: high complexity " + to_string(cplx))
            }
            println("[ai-native] fn " + node.name + " complexity=" + to_string(cplx))
            // M37/M84: stub → auto @pure (use fresh attrs from node.value)
            if body_is_const_return(node.body) {
                m37_stubs = m37_stubs + 1
                let fresh_attrs_stub = split_attrs_m0(node.value)
                if !attr_has(fresh_attrs_stub, "pure") {
                    node = rewrite_fn_with_attrs(node, node.value + ",pure")
                    m84_stub_pure = m84_stub_pure + 1
                    println("[ai-native] fn " + node.name + " REWRITE: auto @pure (stub)")
                }
            }
            // M38: attr count histogram
            if an == 1 { m38_one = m38_one + 1 }
            if an == 2 { m38_two = m38_two + 1 }
            if an == 3 { m38_three = m38_three + 1 }
            if an >= 4 { m38_four_plus = m38_four_plus + 1 }
            // M64/M67: attrs sum + max per fn
            m64_total_attrs = m64_total_attrs + an
            if an > m67_max_attrs_per_fn { m67_max_attrs_per_fn = an }
            // M39: parameter stats
            let pn = len(node.params)
            m39_param_sum = m39_param_sum + pn
            if pn == 0 { m39_zero_arg = m39_zero_arg + 1 }
            if pn > m39_max_arity { m39_max_arity = pn }
            // M42: fn name hash accumulator
            m42_hash_sum = m42_hash_sum + str_hash(node.name)
            // M60: longest attr string
            let al = len(node.value.chars())
            if al > m60_longest_attrs { m60_longest_attrs = al }
            // M43/M44/M45: shape stats
            let bd = max_binop_depth_body(node.body)
            if bd > m43_max_binop_depth { m43_max_binop_depth = bd }
            count_lits_body(node.body)
            // M46: max name length
            let nl = len(node.name.chars())
            if nl > m46_max_name_len { m46_max_name_len = nl }
            // M49: min name length
            if m49_min_name_len == 0 || nl < m49_min_name_len {
                m49_min_name_len = nl
            }
            // M47: ident refs
            count_idents_body(node.body)
            // M48: return count
            m48_return_count = m48_return_count + count_returns_body(node.body)
            // M131/M133/M134: total + max + min node count
            let nc_here = count_nodes_body(node.body)
            m131_total_nodes = m131_total_nodes + nc_here
            if nc_here > m133_max_nodes_per_fn { m133_max_nodes_per_fn = nc_here }
            if m134_min_nodes_per_fn == 0 || nc_here < m134_min_nodes_per_fn {
                m134_min_nodes_per_fn = nc_here
            }
            // M100~M103: shape node counters
            count_shape_body(node.body)
            // M116: eliminate assert(true) stmts
            let before_elim = m116_assert_elim
            let trimmed = eliminate_trivial_asserts(node.body)
            if m116_assert_elim > before_elim {
                node = rewrite_fn_with_body(node, trimmed)
                println("[ai-native] fn " + node.name + " REWRITE: dropped " + to_string(m116_assert_elim - before_elim) + " trivial assert(s)")
            }
            // M104: const-folded assertion check (top-level only)
            let bnn = body_stmt_count(node.body)
            let mut ci = 0
            while ci < bnn {
                let s = node.body[ci]
                if s.kind == "AssertStmt" {
                    let e = s.left
                    if type_of(e) != "string" {
                        if e.kind == "BoolLit" && e.value == "true" {
                            m104_const_assert_true = m104_const_assert_true + 1
                        }
                        if e.kind == "BoolLit" && e.value == "false" {
                            m104_const_assert_false = m104_const_assert_false + 1
                            println("[ai-native] fn " + node.name + " WARN: assert false (unreachable)")
                        }
                    }
                }
                ci = ci + 1
            }
            // M105: @pure + @inline combo
            if attr_has(attrs, "pure") && attr_has(attrs, "inline") {
                m105_pure_inline_combo = m105_pure_inline_combo + 1
            }
            // M50/M51/M52: stmt kind aggregation
            count_stmt_kinds(node.body)
            // M13: track max while nesting
            let wd = while_depth(node.body)
            if wd > m13_max_while_depth { m13_max_while_depth = wd }
            // M14: bubble-sort heuristic — @optimize + nested while + let mut
            if attr_has(attrs, "optimize") && wd >= 2 && body_has_let_mut(node.body) {
                println("[ai-native] fn " + node.name + " CANDIDATE: bubble→merge")
                m14_bubble_candidates = m14_bubble_candidates + 1
            }
            // M15: tail-call heuristic — @optimize + last stmt is Return(self_call)
            if attr_has(attrs, "optimize") && is_tail_call(node.body, node.name) {
                println("[ai-native] fn " + node.name + " CANDIDATE: tail→loop")
                m15_tail_call_candidates = m15_tail_call_candidates + 1
                // M25: if the body is EXACTLY a single tail-return, rewrite to while(true){}; return 0
                if is_simple_tail_only(node.body, node.name) {
                    let new_body = [make_while_true_empty(), make_return_zero()]
                    node = rewrite_fn_with_body(node, new_body)
                    m25_tail_rewrites = m25_tail_rewrites + 1
                    println("[ai-native] fn " + node.name + " REWRITE: tail→while(true)")
                }
            }
            // M16: Strassen heuristic — @optimize + while depth >= 3
            if attr_has(attrs, "optimize") && wd >= 3 {
                println("[ai-native] fn " + node.name + " CANDIDATE: matmul→Strassen")
                m16_strassen_candidates = m16_strassen_candidates + 1
            }
            // M17/M23: recursive @optimize without @memoize → auto-inject
            if attr_has(attrs, "optimize") && is_rec && !attr_has(attrs, "memoize") {
                println("[ai-native] fn " + node.name + " REWRITE: auto-added @memoize")
                m17_dp_missed = m17_dp_missed + 1
                node = rewrite_fn_with_attrs(node, node.value + ",memoize")
                m23_auto_memoize = m23_auto_memoize + 1
            }
            // M250: constant propagation (run before simplify for compose)
            let before_cp = m250_const_prop
            let propagated_body = propagate_consts_body(node.body)
            if m250_const_prop > before_cp {
                node = rewrite_fn_with_body(node, propagated_body)
                println("[ai-native] fn " + node.name + " REWRITE: const-prop +" + to_string(m250_const_prop - before_cp))
            }
            // M259: copy propagation (let y = x → use x)
            let before_copy = m250_const_prop
            let copy_body = propagate_copies_body(node.body)
            // m250_const_prop counts substitutions; track delta
            let copy_delta = m250_const_prop - before_copy
            if copy_delta > 0 {
                m259_copy_prop = m259_copy_prop + copy_delta
                node = rewrite_fn_with_body(node, copy_body)
                println("[ai-native] fn " + node.name + " REWRITE: copy-prop +" + to_string(copy_delta))
            }
            // M275: dead AssignStmt elimination
            let before_da = m275_dead_assigns
            let da_body = eliminate_dead_assigns(node.body)
            if m275_dead_assigns > before_da {
                node = rewrite_fn_with_body(node, da_body)
                println("[ai-native] fn " + node.name + " REWRITE: dead-assign drop x" + to_string(m275_dead_assigns - before_da))
            }
            // M274: while true { return X } → return X
            let before_w2r = m274_while_to_return
            let w2r_body = collapse_while_returns(node.body)
            if m274_while_to_return > before_w2r {
                node = rewrite_fn_with_body(node, w2r_body)
                println("[ai-native] fn " + node.name + " REWRITE: while(true)→return")
            }
            // M273: return forwarding (let x = e; return x → return e)
            let before_rf = m273_return_fwd
            let rf_body = forward_returns(node.body)
            if m273_return_fwd > before_rf {
                node = rewrite_fn_with_body(node, rf_body)
                println("[ai-native] fn " + node.name + " REWRITE: return forwarding")
            }
            // M272: self-assign elimination (before mut→let conversion)
            let before_sa = m272_self_assigns
            let sa_body = eliminate_self_assigns(node.body)
            if m272_self_assigns > before_sa {
                node = rewrite_fn_with_body(node, sa_body)
                println("[ai-native] fn " + node.name + " REWRITE: drop self-assign x" + to_string(m272_self_assigns - before_sa))
            }
            // M271: redundant mut → let conversion (before DSE)
            let before_mtl = m271_mut_to_let
            let mtl_body = convert_mut_to_let(node.body)
            if m271_mut_to_let > before_mtl {
                node = rewrite_fn_with_body(node, mtl_body)
                println("[ai-native] fn " + node.name + " REWRITE: mut→let " + to_string(m271_mut_to_let - before_mtl))
            }
            // M251: dead store elimination (after const prop makes lets dead)
            let before_ds = m251_dead_stores
            let dse_body = eliminate_dead_stores(node.body)
            if m251_dead_stores > before_ds {
                node = rewrite_fn_with_body(node, dse_body)
                println("[ai-native] fn " + node.name + " REWRITE: DSE dropped " + to_string(m251_dead_stores - before_ds) + " dead let(s)")
            }
            // M252: @contract → auto pre-assert injection (param0 != 0)
            let fresh_attrs_ct = split_attrs_m0(node.value)
            if attr_has(fresh_attrs_ct, "contract") && len(node.params) > 0 {
                let pname = node.params[0].name
                if !body_has_contract_assert(node.body, pname) {
                    let injected = inject_contract_assert(node.body, pname)
                    node = rewrite_fn_with_body(node, injected)
                    m252_contract_injects = m252_contract_injects + 1
                    println("[ai-native] fn " + node.name + " REWRITE: @contract assert " + pname + " != 0 prepended")
                }
            }
            // M30/M32/M33/M34/M35/M41: folding + dead loop elimination
            let before_alg = m30_algebraic
            let before_fold = m32_folds
            let before_cmp = m33_cmp_folds
            let before_un = m34_unary_folds
            let before_bool = m35_bool_folds
            let before_dead_loop = m41_dead_loops
            let simplified_body = simplify_body(node.body)
            if m30_algebraic > before_alg || m32_folds > before_fold || m33_cmp_folds > before_cmp || m34_unary_folds > before_un || m35_bool_folds > before_bool || m41_dead_loops > before_dead_loop {
                node = rewrite_fn_with_body(node, simplified_body)
                println("[ai-native] fn " + node.name + " REWRITE: simplify (+" + to_string(m30_algebraic - before_alg) + " alg, +" + to_string(m32_folds - before_fold) + " fold, +" + to_string(m33_cmp_folds - before_cmp) + " cmp, +" + to_string(m34_unary_folds - before_un) + " una)")
            }
            // M19/M24: unreachable code → detect + eliminate
            let unr = count_unreachable(node.body)
            if unr > 0 {
                println("[ai-native] fn " + node.name + " WARN: " + to_string(unr) + " unreachable stmt(s) after return")
                m19_unreachable = m19_unreachable + unr
                let cleaned = eliminate_dead(node.body)
                node = rewrite_fn_with_body(node, cleaned)
                m24_dce_fns = m24_dce_fns + 1
                m24_dce_stmts = m24_dce_stmts + unr
                println("[ai-native] fn " + node.name + " REWRITE: DCE dropped " + to_string(unr) + " stmt(s)")
            }
            // M20 already counted above (pre-rewrite)
            // M21: constant return
            if body_is_const_return(node.body) {
                println("[ai-native] fn " + node.name + " NOTE: constant-return, @pure/@memoize redundant")
                m21_const_return = m21_const_return + 1
            }
            // M12: track body size per primary group (first attr wins)
            if an > 0 {
                let primary_cat = classify_attr_m0(attrs[0])
                let sz2 = body_stmt_count(node.body)
                if primary_cat == "G1" { m12_g1_size = m12_g1_size + sz2 }
                if primary_cat == "G2" { m12_g2_size = m12_g2_size + sz2 }
                if primary_cat == "G3" { m12_g3_size = m12_g3_size + sz2 }
                if primary_cat == "G4" { m12_g4_size = m12_g4_size + sz2 }
            }
            // M10: @memoize score — +1 if recursive, +1 if also @pure
            if attr_has(attrs, "memoize") {
                let mut score = 0
                if is_rec { score = score + 1 }
                if attr_has(attrs, "pure") { score = score + 1 }
                m10_memoize_score_sum = m10_memoize_score_sum + score
                if score > m124_max_memoize_score { m124_max_memoize_score = score }
                println("[ai-native] fn " + node.name + " memoize-score=" + to_string(score))
                // M90: @memoize without @pure is potentially unsafe
                if !attr_has(attrs, "pure") {
                    m90_unsafe_memoize = m90_unsafe_memoize + 1
                    println("[ai-native] fn " + node.name + " WARN: @memoize without @pure (unsafe)")
                }
                // M91: ideal = pure + recursive + memoize
                if attr_has(attrs, "pure") && is_rec {
                    m91_ideal_memoize = m91_ideal_memoize + 1
                }
            }
            // M92/M93/M141: per-fn param stats
            let pcount2 = len(node.params)
            if pcount2 == 0 { m92_nullary = m92_nullary + 1 }
            if pcount2 > m93_max_params { m93_max_params = pcount2 }
            if pcount2 == 0 { m141_p0 = m141_p0 + 1 }
            if pcount2 == 1 { m141_p1 = m141_p1 + 1 }
            if pcount2 == 2 { m141_p2 = m141_p2 + 1 }
            if pcount2 >= 3 { m141_p3plus = m141_p3plus + 1 }
            // M146/M147: max + total param name length
            let mut pi = 0
            while pi < pcount2 {
                let pn_len = len(node.params[pi].name.chars())
                if pn_len > m146_max_param_name { m146_max_param_name = pn_len }
                m147_total_param_chars = m147_total_param_chars + pn_len
                pi = pi + 1
            }
            // M4: attr conflict (once per fn)
            let conflict = find_attr_conflict(attrs)
            if conflict != "" {
                println("[ai-native] fn " + node.name + " CONFLICT: " + conflict)
                m4_attr_conflicts = m4_attr_conflicts + 1
            }
            let mut j = 0
            while j < an {
                let attr = attrs[j]
                let cat = classify_attr_m0(attr)
                println("[ai-native] fn " + node.name + " @" + attr + " (" + cat + ")")
                // M1/M2: @pure → verify body recursively
                if attr == "pure" {
                    let reason = check_purity_m1(node.body)
                    if reason == "" {
                        println("  [pure] OK")
                        m1_pure_ok = m1_pure_ok + 1
                    } else {
                        println("  [pure] VIOLATION: " + reason)
                        m1_pure_violations = m1_pure_violations + 1
                    }
                }
                // M3: @inline → body size check
                if attr == "inline" {
                    let sz = body_stmt_count(node.body)
                    if sz <= inline_threshold {
                        println("  [inline] OK (" + to_string(sz) + " stmts)")
                        m3_inline_ok = m3_inline_ok + 1
                    } else {
                        println("  [inline] TOO BIG (" + to_string(sz) + " stmts > " + to_string(inline_threshold) + ")")
                        m3_inline_too_big = m3_inline_too_big + 1
                    }
                }
                // M5: @memoize — needs ≥1 param (cache key)
                if attr == "memoize" {
                    let pcount = 0
                    let pc = len(node.params)
                    if pc >= 1 {
                        println("  [memoize] OK (" + to_string(pc) + " param(s))")
                        m5_memoize_ok = m5_memoize_ok + 1
                    } else {
                        println("  [memoize] INELIGIBLE: zero-arg fn")
                        m5_memoize_bad = m5_memoize_bad + 1
                    }
                }
                // M6: group distribution
                if cat == "G1" { m6_g1 = m6_g1 + 1 }
                if cat == "G2" { m6_g2 = m6_g2 + 1 }
                if cat == "G3" { m6_g3 = m6_g3 + 1 }
                if cat == "G4" { m6_g4 = m6_g4 + 1 }
                // M7: meta attrs
                if attr == "test" {
                    m7_test = m7_test + 1
                    if len(node.params) > 0 {
                        m86_test_bad = m86_test_bad + 1
                        println("[ai-native] fn " + node.name + " WARN: @test must be zero-arg")
                    }
                }
                if attr == "bench" {
                    m7_bench = m7_bench + 1
                    // M85: @bench requires zero-arg fn
                    if len(node.params) > 0 {
                        m85_bench_bad = m85_bench_bad + 1
                        println("[ai-native] fn " + node.name + " WARN: @bench must be zero-arg")
                    }
                }
                if attr == "deprecated" { m7_deprecated = m7_deprecated + 1 }
                // M62: core attr frequency
                if attr == "pure" { m62_pure_uses = m62_pure_uses + 1 }
                if attr == "inline" { m62_inline_uses = m62_inline_uses + 1 }
                if attr == "optimize" { m62_optimize_uses = m62_optimize_uses + 1 }
                if attr == "memoize" { m62_memoize_uses = m62_memoize_uses + 1 }
                // M63: diversity — add to set if new
                if !name_in_registry(attr, m63_attr_set) {
                    m63_attr_set = m63_attr_set.push(attr)
                }
                // M71/M72/M73: bounded value analysis
                if len(attr.chars()) > 8 && attr.substring(0, 8) == "bounded:" {
                    let bv = extract_bounded_value(attr)
                    if bv >= 0 {
                        m72_bounded_fns = m72_bounded_fns + 1
                        if bv > m71_bounded_max { m71_bounded_max = bv }
                        if bv > 1000 {
                            m71_bounded_huge = m71_bounded_huge + 1
                            println("[ai-native] fn " + node.name + " WARN: @bounded(" + to_string(bv) + ") exceeds 1000")
                        }
                        if bv <= 4 && bv > 0 {
                            m73_unrollable = m73_unrollable + 1
                            println("[ai-native] fn " + node.name + " TAG: unrollable (N=" + to_string(bv) + ")")
                        }
                    }
                }
                // M8: hardware attrs require a loop in body
                if attr == "parallel" || attr == "simd" || attr == "gpu" {
                    if body_has_loop(node.body) {
                        println("  [" + attr + "] OK (loop found)")
                        m8_hw_ok = m8_hw_ok + 1
                    } else {
                        println("  [" + attr + "] WARN: no loop in body")
                        m8_hw_no_loop = m8_hw_no_loop + 1
                    }
                }
                j = j + 1
            }
            seen = seen + 1
        }
        out = out.push(node)
        i = i + 1
    }
    // M53: second pass — count cross-annotated calls (registry now complete)
    let on = len(out)
    let mut oi = 0
    while oi < on {
        let nd = out[oi]
        if nd.kind == "FnDecl" && nd.value != "" {
            m53_cross_calls = m53_cross_calls + count_cross_calls_body(nd.body, m29_registry)
        }
        oi = oi + 1
    }
    // M253 pre-pass: collect inlinable fn signatures (stub + identity)
    let mut pi3 = 0
    while pi3 < on {
        let nd3 = out[pi3]
        if nd3.kind == "FnDecl" {
            // Const-return stub: body == [Return(literal)]
            if body_is_const_return(nd3.body) {
                m253_stub_names = m253_stub_names.push(nd3.name)
                m253_stub_lits = m253_stub_lits.push(nd3.body[0].left)
            } else {
                // Identity: 1 stmt, return param0
                if is_identity_fn(nd3.body, nd3.params) {
                    m253_id_names = m253_id_names.push(nd3.name)
                    m253_id_param0 = m253_id_param0.push(nd3.params[0].name)
                }
            }
        }
        pi3 = pi3 + 1
    }
    // M253 inline pass: rewrite all FnDecl bodies
    let mut out2 = []
    let mut pi4 = 0
    while pi4 < on {
        let nd4 = out[pi4]
        if nd4.kind == "FnDecl" {
            let before_in = m253_inlined_calls
            let new_body = inline_body(nd4.body)
            if m253_inlined_calls > before_in {
                out2 = out2.push(rewrite_fn_with_body(nd4, new_body))
                println("[ai-native] fn " + nd4.name + " REWRITE: inlined " + to_string(m253_inlined_calls - before_in) + " call(s)")
            } else {
                out2 = out2.push(nd4)
            }
        } else {
            out2 = out2.push(nd4)
        }
        pi4 = pi4 + 1
    }
    out = out2
    let mut cov_pct = 0
    if m6_total_fns > 0 {
        cov_pct = (m6_annotated_fns * 100) / m6_total_fns
    }
    println("[ai-native] pass complete — " + to_string(seen) + " annotated fn(s), pure " + to_string(m1_pure_ok) + "/" + to_string(m1_pure_violations) + ", inline " + to_string(m3_inline_ok) + "/" + to_string(m3_inline_too_big) + ", memoize " + to_string(m5_memoize_ok) + "/" + to_string(m5_memoize_bad) + ", conflicts " + to_string(m4_attr_conflicts))
    println("[ai-native] coverage " + to_string(m6_annotated_fns) + "/" + to_string(m6_total_fns) + " (" + to_string(cov_pct) + "%), G1=" + to_string(m6_g1) + " G2=" + to_string(m6_g2) + " G3=" + to_string(m6_g3) + " G4=" + to_string(m6_g4))
    println("[ai-native] meta test=" + to_string(m7_test) + " bench=" + to_string(m7_bench) + " deprecated=" + to_string(m7_deprecated))
    println("[ai-native] hw " + to_string(m8_hw_ok) + " ok / " + to_string(m8_hw_no_loop) + " no-loop")
    println("[ai-native] recursive " + to_string(m9_recursive) + ", calls " + to_string(m11_call_count) + ", memoize-score-sum " + to_string(m10_memoize_score_sum))
    println("[ai-native] body-size G1=" + to_string(m12_g1_size) + " G2=" + to_string(m12_g2_size) + " G3=" + to_string(m12_g3_size) + " G4=" + to_string(m12_g4_size) + ", max-while-depth " + to_string(m13_max_while_depth) + ", max-complexity " + to_string(m36_max_complexity))
    println("[ai-native] stubs " + to_string(m37_stubs) + ", attr-hist 1=" + to_string(m38_one) + " 2=" + to_string(m38_two) + " 3=" + to_string(m38_three) + " 4+=" + to_string(m38_four_plus) + ", params sum=" + to_string(m39_param_sum) + " zero-arg=" + to_string(m39_zero_arg) + " max-arity=" + to_string(m39_max_arity))
    println("[ai-native] bubble-candidates " + to_string(m14_bubble_candidates) + ", tail-call-candidates " + to_string(m15_tail_call_candidates) + ", strassen-candidates " + to_string(m16_strassen_candidates) + ", dp-missed " + to_string(m17_dp_missed))
    // M81: digest line — compact one-shot summary
    let total_rewrites = m22_rewrites + m23_auto_memoize + m24_dce_fns + m25_tail_rewrites + m26_attr_dedups + m27_attr_sorts + m30_algebraic + m32_folds + m33_cmp_folds + m34_unary_folds + m35_bool_folds + m41_dead_loops
    println("[ai-native] DIGEST fns=" + to_string(m6_annotated_fns) + "/" + to_string(m6_total_fns) + " attrs=" + to_string(m64_total_attrs) + " diversity=" + to_string(len(m63_attr_set)) + " rewrites=" + to_string(total_rewrites) + " leaves=" + to_string(m54_leaf_count) + " identity=" + to_string(m74_identity_fns) + " wrapper=" + to_string(m75_wrapper_fns) + " stubs=" + to_string(m37_stubs) + " nodes=" + to_string(m131_total_nodes) + " max-cplx=" + to_string(m36_max_complexity))
    let m18_total_suggestions = m14_bubble_candidates + m15_tail_call_candidates + m16_strassen_candidates + m17_dp_missed + m3_inline_too_big + m5_memoize_bad + m8_hw_no_loop + m4_attr_conflicts + m1_pure_violations + m19_unreachable
    println("[ai-native] unreachable " + to_string(m19_unreachable) + ", empty-body " + to_string(m20_empty_body) + ", const-return " + to_string(m21_const_return) + ", rewrites " + to_string(m22_rewrites) + ", auto-memoize " + to_string(m23_auto_memoize) + ", dce " + to_string(m24_dce_stmts) + " stmt(s) in " + to_string(m24_dce_fns) + " fn(s), tail-rewrites " + to_string(m25_tail_rewrites))
    println("[ai-native] TOTAL actionable items: " + to_string(m18_total_suggestions))
    return out
}

// ══════════════════════════════════════════════════════════════
// Tests
// ══════════════════════════════════════════════════════════════

println("=== HEXA Bootstrap Compiler Tests ===")
println("")

// Test 1: Lexer produces correct tokens
println("Test 1: Lexer")
let t1 = tokenize("let x = 42")
assert len(t1) == 5
assert t1[0].kind == "Let"
assert t1[1].kind == "Ident"
assert t1[2].kind == "Eq"
assert t1[3].kind == "IntLit"
assert t1[3].value == "42"
assert t1[4].kind == "Eof"
println("  PASS")

// Test 2: Parser produces correct AST
println("Test 2: Parser - let binding")
let a2 = parse(tokenize("let x = 42"))
assert len(a2) == 1
assert a2[0].kind == "LetStmt"
assert a2[0].name == "x"
assert a2[0].left.kind == "IntLit"
assert a2[0].left.value == "42"
println("  PASS")

// Test 3: Parser - function declaration
println("Test 3: Parser - fn decl")
let a3 = parse(tokenize("fn add(a, b) {\n  return a + b\n}"))
assert len(a3) == 1
assert a3[0].kind == "FnDecl"
assert a3[0].name == "add"
assert len(a3[0].params) == 2
assert a3[0].params[0].name == "a"
assert a3[0].params[1].name == "b"
println("  PASS")

// Test 4: Parser - precedence
println("Test 4: Parser - precedence 1 + 2 * 3")
let a4 = parse(tokenize("1 + 2 * 3"))
let e4 = a4[0].left
assert e4.kind == "BinOp"
assert e4.op == "+"
assert e4.left.value == "1"
assert e4.right.kind == "BinOp"
assert e4.right.op == "*"
assert e4.right.left.value == "2"
assert e4.right.right.value == "3"
println("  PASS")

// Test 5: Type checker - undeclared variable
println("Test 5: Type checker - undeclared var")
let a5 = parse(tokenize("let y = x + 1"))
let e5 = type_check(a5)
assert len(e5) > 0
assert e5[0].message == "Undeclared variable 'x'"
println("  PASS")

// Test 6: Type checker - valid program (no errors)
println("Test 6: Type checker - valid program")
let a6 = parse(tokenize("let x = 10\nlet y = x + 1"))
let e6 = type_check(a6)
assert len(e6) == 0
println("  PASS")

// Test 7: Type checker - function arity mismatch
println("Test 7: Type checker - arity mismatch")
let a7 = parse(tokenize("fn foo(a) {\n  return a\n}\nfoo(1, 2)"))
let e7 = type_check(a7)
assert len(e7) > 0
println(format("  Error: {}", e7[0].message))
println("  PASS")

// Test 8: Compiler - basic let + println
println("Test 8: Compiler - let + println")
let a8 = parse(tokenize("let x = 42\nprintln(x)"))
let code8 = compile_program(a8)
assert len(code8) > 0
// Should have: CONST 0, SET_LOCAL 0, GET_LOCAL 0, PRINTLN 1, POP
assert code8[0].op == "CONST"
assert code8[1].op == "SET_LOCAL"
assert code8[2].op == "GET_LOCAL"
assert code8[3].op == "PRINTLN"
assert code8[4].op == "POP"
println("  PASS")

// Test 9: Compiler - function compilation
println("Test 9: Compiler - fn add")
let a9 = parse(tokenize("fn add(a, b) {\n  return a + b\n}"))
let code9 = compile_program(a9)
assert len(c_functions) == 1
assert c_functions[0].name == "add"
assert c_functions[0].arity == 2
// Function body: GET_LOCAL 0, GET_LOCAL 1, ADD, RETURN, VOID, RETURN
let fc = c_functions[0].code
assert fc[0].op == "GET_LOCAL"
assert fc[1].op == "GET_LOCAL"
assert fc[2].op == "ADD"
assert fc[3].op == "RETURN"
println("  PASS")

// Test 10: Compiler - while loop
println("Test 10: Compiler - while loop")
let a10 = parse(tokenize("let mut i = 0\nwhile i < 10 {\n  i = i + 1\n}"))
let code10 = compile_program(a10)
assert len(code10) > 0
// Should contain: CONST, SET_LOCAL, GET_LOCAL, CONST, LT, JUMP_IF_FALSE, ..., JUMP
let mut has_jump = false
let mut has_jif = false
let mut idx = 0
while idx < len(code10) {
    if code10[idx].op == "JUMP" { has_jump = true }
    if code10[idx].op == "JUMP_IF_FALSE" { has_jif = true }
    idx = idx + 1
}
assert has_jump
assert has_jif
println("  PASS")

// Test 11: Full pipeline - compile and verify
println("Test 11: Full pipeline")
let source11 = "let a = 10\nlet b = 20\nlet c = a + b\nprintln(c)"
let tokens11 = tokenize(source11)
let ast11 = parse(tokens11)
let errors11 = type_check(ast11)
