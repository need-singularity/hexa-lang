assert ast19a[0].value == "pure"
let _unused19a = ai_native_pass(ast19a)
// M1 top-level-only would miss this; M2 recursion must catch it
assert m1_pure_ok == 0
assert m1_pure_violations == 1
// Pure while (empty body) still OK
let ast19b = parse(tokenize("@pure\nfn idle(n) {\n  while n {\n  }\n  return n\n}"))
let _unused19b = ai_native_pass(ast19b)
assert m1_pure_ok == 1
assert m1_pure_violations == 0
// ReturnStmt with println in it — caught by check_purity_expr
let ast19c = parse(tokenize("@pure\nfn ret(n) {\n  return println(n)\n}"))
let _unused19c = ai_native_pass(ast19c)
assert m1_pure_violations == 1
println("  PASS")

