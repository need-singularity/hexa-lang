// Tests: Control Flow Codegen
// ══════════════════════════════════════════════════════════════

// Test 30: Compiler - while loop generates correct bytecode ops
println("Test 30: Compiler - while loop bytecode detail")
let a30 = parse(tokenize("let mut x = 0\nwhile x < 5 {\n  x = x + 1\n}"))
let code30 = compile_program(a30)
// Verify JUMP loops back to start (operand == loop start pos)
let mut jump_pos = -1
let mut jif_pos = -1
let mut i30 = 0
while i30 < len(code30) {
    if code30[i30].op == "JUMP" { jump_pos = i30 }
    if code30[i30].op == "JUMP_IF_FALSE" { jif_pos = i30 }
    i30 = i30 + 1
}
assert jump_pos > jif_pos
// JUMP operand should point to position 2 (start of condition: GET_LOCAL)
assert code30[jump_pos].operand == "2"
println("  PASS")

// Test 31: Codegen - while loop C output
println("Test 31: Codegen_c2 - while loop")
let a31 = parse(tokenize("let mut i = 0\nwhile i < 10 {\n  i = i + 1\n}"))
let mut c31 = ""
let mut i31 = 0
while i31 < len(a31) {
    c31 = c31 + gen2_stmt(a31[i31], 1)
    i31 = i31 + 1
}
assert c31.contains("while (hexa_truthy(")
assert c31.contains("hexa_bool((i).i < (hexa_int(10)).i)")
println("  PASS")

