// Test 17: M0 AI-native @attr — lexer/parser + ai_native_pass smoke
println("Test 17: AI-native @attr infrastructure")
let src17 = "@optimize\nfn fib(n) {\n  return n\n}"
let tok17 = tokenize(src17)
// expect At, Optimize (keyword), Newline, Fn, Ident, LParen, Ident, RParen, LBrace, ...
let mut has_at = false
let mut i17 = 0
while i17 < len(tok17) {
    if tok17[i17].kind == "At" { has_at = true }
    i17 = i17 + 1
}
assert has_at
let ast17 = parse(tok17)
assert len(ast17) == 1
assert ast17[0].kind == "FnDecl"
assert ast17[0].name == "fib"
assert ast17[0].value == "optimize"
// Multi-attr
let src17b = "@optimize\n@memoize\nfn foo(n) { return n }"
let ast17b = parse(tokenize(src17b))
assert ast17b[0].kind == "FnDecl"
assert ast17b[0].value == "optimize,memoize"
// Run ai_native_pass smoke — classification + pass-through
let passed = ai_native_pass(ast17b)
assert len(passed) == 1
assert passed[0].value == "optimize,memoize"
// Negative: fn without attr keeps value == ""
let ast17c = parse(tokenize("fn bar(x) { return x }"))
assert ast17c[0].value == ""
println("  PASS")

// Test 18: M1 @pure purity checker — pure + impure cases
println("Test 18: @pure purity checker")
// Pure: only a return expression in the body
let ast18a = parse(tokenize("@pure\nfn square(n) {\n  return n + n\n}"))
assert ast18a[0].value == "pure"
let _unused18a = ai_native_pass(ast18a)
assert m1_pure_ok == 1
assert m1_pure_violations == 0
// Impure: println call in body
let ast18b = parse(tokenize("@pure\nfn shout(n) {\n  println(n)\n  return n\n}"))
assert ast18b[0].value == "pure"
let _unused18b = ai_native_pass(ast18b)
assert m1_pure_ok == 0
assert m1_pure_violations == 1
// Impure: mutable binding
let ast18c = parse(tokenize("@pure\nfn accum(n) {\n  let mut x = n\n  return x\n}"))
let _unused18c = ai_native_pass(ast18c)
assert m1_pure_violations == 1
// Non-@pure fn is ignored by the checker
let ast18d = parse(tokenize("@optimize\nfn f(n) {\n  println(n)\n  return n\n}"))
let _unused18d = ai_native_pass(ast18d)
assert m1_pure_ok == 0
assert m1_pure_violations == 0
println("  PASS")

println("")
println("=== ALL 18 TESTS PASSED ===")
