    kind: "WhileStmt", name: "", value: "", op: "",
    left: "", right: "", cond: true_lit, then_body: "", else_body: "",
    params: "", body: [inner_ret], args: "", fields: "", items: "",
    variants: "", arms: "", iter_expr: "", ret_type: "",
    target: "", trait_name: "", methods: ""
}
let fn248 = AstNode {
    kind: "FnDecl", name: "f", value: "pure", op: "",
    left: "", right: "", cond: "", then_body: "", else_body: "",
    params: [], body: [while_node], args: "", fields: "", items: "",
    variants: "", arms: "", iter_expr: "", ret_type: "",
    target: "", trait_name: "", methods: ""
}
