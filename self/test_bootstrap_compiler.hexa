let e7 = type_check(a7)
assert len(e7) > 0
println(format("  Error: {}", e7[0].message))
println("  PASS")

// Test 8: Compiler - basic let + println
println("Test 8: Compiler - let + println")
let a8 = parse(tokenize("let x = 42\nprintln(x)"))
let code8 = compile_program(a8)
assert len(code8) > 0
// Should have: CONST 0, SET_LOCAL 0, GET_LOCAL 0, PRINTLN 1, POP
assert code8[0].op == "CONST"
assert code8[1].op == "SET_LOCAL"
assert code8[2].op == "GET_LOCAL"
assert code8[3].op == "PRINTLN"
assert code8[4].op == "POP"
println("  PASS")

// Test 9: Compiler - function compilation
println("Test 9: Compiler - fn add")
let a9 = parse(tokenize("fn add(a, b) {\n  return a + b\n}"))
let code9 = compile_program(a9)
assert len(c_functions) == 1
assert c_functions[0].name == "add"
assert c_functions[0].arity == 2
// Function body: GET_LOCAL 0, GET_LOCAL 1, ADD, RETURN, VOID, RETURN
let fc = c_functions[0].code
assert fc[0].op == "GET_LOCAL"
assert fc[1].op == "GET_LOCAL"
assert fc[2].op == "ADD"
assert fc[3].op == "RETURN"
println("  PASS")

// Test 10: Compiler - while loop
println("Test 10: Compiler - while loop")
let a10 = parse(tokenize("let mut i = 0\nwhile i < 10 {\n  i = i + 1\n}"))
let code10 = compile_program(a10)
assert len(code10) > 0
// Should contain: CONST, SET_LOCAL, GET_LOCAL, CONST, LT, JUMP_IF_FALSE, ..., JUMP
let mut has_jump = false
let mut has_jif = false
let mut idx = 0
while idx < len(code10) {
    if code10[idx].op == "JUMP" { has_jump = true }
    if code10[idx].op == "JUMP_IF_FALSE" { has_jif = true }
    idx = idx + 1
}
assert has_jump
assert has_jif
println("  PASS")

