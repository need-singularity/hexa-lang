println("Test 32: Compiler - nested function calls")
let a32 = parse(tokenize("println(1 + 2)"))
let code32 = compile_program(a32)
// Should have: CONST 0, CONST 1, ADD, PRINTLN 1, POP
assert code32[0].op == "CONST"
assert code32[1].op == "CONST"
assert code32[2].op == "ADD"
assert code32[3].op == "PRINTLN"
println("  PASS")

