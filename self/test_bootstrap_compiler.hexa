// M28: fixpoint runner — call ai_native_pass until no rewrites occur
fn ai_native_fixpoint(ast) {
    let mut cur = ast
    let mut iter = 0
    let max_iters = 5
    while iter < max_iters {
        let next = ai_native_pass(cur)
        let total_rewrites = m22_rewrites + m23_auto_memoize + m24_dce_fns + m25_tail_rewrites + m26_attr_dedups + m27_attr_sorts
        if total_rewrites == 0 {
            println("[ai-native] FIXPOINT reached after " + to_string(iter + 1) + " iter(s)")
            return next
        }
        cur = next
        iter = iter + 1
    }
    println("[ai-native] FIXPOINT max_iters hit (" + to_string(max_iters) + ")")
    return cur
}

