// self/test_bootstrap_compiler.hexa — Tests for the self-hosting compiler pipeline
// Verifies that lexer -> parser -> type_checker -> compiler work together.
// This file tests each stage independently and the full pipeline.

// ══════════════════════════════════════════════════════════════
// Minimal shared structs
// ══════════════════════════════════════════════════════════════

struct Token {
    kind: string,
    value: string,
    line: int,
    col: int
}

struct AstNode {
    kind: string,
    name: string,
    value: string,
    op: string,
    left: string,
    right: string,
    cond: string,
    then_body: string,
    else_body: string,
    params: string,
    body: string,
    args: string,
    fields: string,
    items: string,
    variants: string,
    arms: string,
    iter_expr: string,
    ret_type: string,
    target: string,
    trait_name: string,
    methods: string
}

struct TypeError {
    message: string,
    name: string
}

struct Instruction {
    op: string,
    operand: string
}

struct CompiledFn {
    name: string,
    arity: int,
    param_names: string,
    code: string,
    local_count: int
}

// ══════════════════════════════════════════════════════════════
// Inline lexer (minimal, no else-if)
// ══════════════════════════════════════════════════════════════

fn is_keyword(word) {
    if word == "if" { return true }
    if word == "else" { return true }
    if word == "fn" { return true }
    if word == "return" { return true }
    if word == "let" { return true }
    if word == "mut" { return true }
    if word == "const" { return true }
    if word == "while" { return true }
    if word == "for" { return true }
    if word == "struct" { return true }
    if word == "assert" { return true }
    return false
}

fn keyword_kind(word) {
    if word == "true" { return "BoolLit" }
    if word == "false" { return "BoolLit" }
    if is_keyword(word) {
        let first = to_string(word.chars()[0]).to_upper()
        let rest = ""
        let chars = word.chars()
        let i = 1
        while i < len(chars) {
            rest = rest + to_string(chars[i])
            i = i + 1
        }
        return first + rest
    }
    return "Ident"
}

fn my_is_alpha(s) {
    if s == "a" || s == "b" || s == "c" || s == "d" || s == "e" || s == "f" { return true }
    if s == "g" || s == "h" || s == "i" || s == "j" || s == "k" || s == "l" { return true }
    if s == "m" || s == "n" || s == "o" || s == "p" || s == "q" || s == "r" { return true }
    if s == "s" || s == "t" || s == "u" || s == "v" || s == "w" || s == "x" { return true }
    if s == "y" || s == "z" { return true }
    if s == "A" || s == "B" || s == "C" || s == "D" || s == "E" || s == "F" { return true }
    if s == "G" || s == "H" || s == "I" || s == "J" || s == "K" || s == "L" { return true }
    if s == "M" || s == "N" || s == "O" || s == "P" || s == "Q" || s == "R" { return true }
    if s == "S" || s == "T" || s == "U" || s == "V" || s == "W" || s == "X" { return true }
    if s == "Y" || s == "Z" { return true }
    return false
}

fn my_is_digit(s) {
    if s == "0" || s == "1" || s == "2" || s == "3" || s == "4" { return true }
    if s == "5" || s == "6" || s == "7" || s == "8" || s == "9" { return true }
    return false
}

fn is_ident_start_s(s) {
    if my_is_alpha(s) { return true }
    if s == "_" { return true }
    return false
}

fn is_ident_char_s(s) {
    if my_is_alpha(s) { return true }
    if my_is_digit(s) { return true }
    if s == "_" { return true }
    return false
}

fn ch_at(chars, pos) {
    return to_string(chars[pos])
}

fn tokenize(source) {
    let mut tokens = []
    let chars = source.chars()
    let mut pos = 0
    let mut line = 1
    let mut col = 1
    let total = len(chars)

    while pos < total {
        let ch = ch_at(chars, pos)
        if ch == " " || ch == "\t" || ch == "\r" {
            pos = pos + 1
            col = col + 1
        } else {
            if ch == "\n" {
                tokens = tokens.push(Token { kind: "Newline", value: "\n", line: line, col: col })
                pos = pos + 1
                line = line + 1
                col = 1
            } else {
                if ch == "/" && pos + 1 < total && ch_at(chars, pos + 1) == "/" {
                    pos = pos + 2
                    col = col + 2
                    while pos < total && ch_at(chars, pos) != "\n" {
                        pos = pos + 1
                        col = col + 1
                    }
                } else {
                    if is_ident_start_s(ch) {
                        let start_col = col
                        let mut word = ""
                        while pos < total && is_ident_char_s(ch_at(chars, pos)) {
                            word = word + to_string(chars[pos])
                            pos = pos + 1
                            col = col + 1
                        }
                        let kind = keyword_kind(word)
                        tokens = tokens.push(Token { kind: kind, value: word, line: line, col: start_col })
                    } else {
                        if my_is_digit(ch) {
                            let start_col = col
                            let mut num_str = ""
                            while pos < total && my_is_digit(ch_at(chars, pos)) {
                                num_str = num_str + to_string(chars[pos])
                                pos = pos + 1
                                col = col + 1
                            }
                            tokens = tokens.push(Token { kind: "IntLit", value: num_str, line: line, col: start_col })
                        } else {
                            if ch == "\"" {
                                let start_col = col
                                pos = pos + 1
                                col = col + 1
                                let mut s = ""
                                while pos < total && ch_at(chars, pos) != "\"" {
                                    s = s + to_string(chars[pos])
                                    pos = pos + 1
                                    col = col + 1
                                }
                                if pos < total {
                                    pos = pos + 1
                                    col = col + 1
                                }
                                tokens = tokens.push(Token { kind: "StringLit", value: s, line: line, col: start_col })
                            } else {
                                let start_col = col
                                if ch == "+" {
                                    tokens = tokens.push(Token { kind: "Plus", value: "+", line: line, col: start_col })
                                    pos = pos + 1
                                    col = col + 1
                                } else {
                                if ch == "-" {
                                    if pos + 1 < total && ch_at(chars, pos + 1) == ">" {
                                        tokens = tokens.push(Token { kind: "Arrow", value: "->", line: line, col: start_col })
                                        pos = pos + 2
                                        col = col + 2
                                    } else {
                                        tokens = tokens.push(Token { kind: "Minus", value: "-", line: line, col: start_col })
                                        pos = pos + 1
                                        col = col + 1
                                    }
                                } else {
                                if ch == "*" {
                                    tokens = tokens.push(Token { kind: "Star", value: "*", line: line, col: start_col })
                                    pos = pos + 1
                                    col = col + 1
                                } else {
                                if ch == "/" {
                                    tokens = tokens.push(Token { kind: "Slash", value: "/", line: line, col: start_col })
                                    pos = pos + 1
                                    col = col + 1
                                } else {
                                if ch == "=" {
                                    if pos + 1 < total && ch_at(chars, pos + 1) == "=" {
                                        tokens = tokens.push(Token { kind: "EqEq", value: "==", line: line, col: start_col })
                                        pos = pos + 2
                                        col = col + 2
                                    } else {
                                        tokens = tokens.push(Token { kind: "Eq", value: "=", line: line, col: start_col })
                                        pos = pos + 1
                                        col = col + 1
                                    }
                                } else {
                                if ch == "!" {
                                    if pos + 1 < total && ch_at(chars, pos + 1) == "=" {
                                        tokens = tokens.push(Token { kind: "NotEq", value: "!=", line: line, col: start_col })
                                        pos = pos + 2
                                        col = col + 2
                                    } else {
                                        tokens = tokens.push(Token { kind: "Not", value: "!", line: line, col: start_col })
                                        pos = pos + 1
                                        col = col + 1
                                    }
                                } else {
                                if ch == "<" {
                                    if pos + 1 < total && ch_at(chars, pos + 1) == "=" {
                                        tokens = tokens.push(Token { kind: "LtEq", value: "<=", line: line, col: start_col })
                                        pos = pos + 2
                                        col = col + 2
                                    } else {
                                        tokens = tokens.push(Token { kind: "Lt", value: "<", line: line, col: start_col })
                                        pos = pos + 1
                                        col = col + 1
                                    }
                                } else {
                                if ch == ">" {
                                    if pos + 1 < total && ch_at(chars, pos + 1) == "=" {
                                        tokens = tokens.push(Token { kind: "GtEq", value: ">=", line: line, col: start_col })
                                        pos = pos + 2
                                        col = col + 2
                                    } else {
                                        tokens = tokens.push(Token { kind: "Gt", value: ">", line: line, col: start_col })
                                        pos = pos + 1
                                        col = col + 1
                                    }
                                } else {
                                if ch == "(" {
                                    tokens = tokens.push(Token { kind: "LParen", value: "(", line: line, col: start_col })
                                    pos = pos + 1
                                    col = col + 1
                                } else {
                                if ch == ")" {
                                    tokens = tokens.push(Token { kind: "RParen", value: ")", line: line, col: start_col })
                                    pos = pos + 1
                                    col = col + 1
                                } else {
                                if ch == "{" {
                                    tokens = tokens.push(Token { kind: "LBrace", value: "{", line: line, col: start_col })
                                    pos = pos + 1
                                    col = col + 1
                                } else {
                                if ch == "}" {
                                    tokens = tokens.push(Token { kind: "RBrace", value: "}", line: line, col: start_col })
                                    pos = pos + 1
                                    col = col + 1
                                } else {
                                if ch == "[" {
                                    tokens = tokens.push(Token { kind: "LBracket", value: "[", line: line, col: start_col })
                                    pos = pos + 1
                                    col = col + 1
                                } else {
                                if ch == "]" {
                                    tokens = tokens.push(Token { kind: "RBracket", value: "]", line: line, col: start_col })
                                    pos = pos + 1
                                    col = col + 1
                                } else {
                                if ch == "," {
                                    tokens = tokens.push(Token { kind: "Comma", value: ",", line: line, col: start_col })
                                    pos = pos + 1
                                    col = col + 1
                                } else {
                                if ch == ":" {
                                    tokens = tokens.push(Token { kind: "Colon", value: ":", line: line, col: start_col })
                                    pos = pos + 1
                                    col = col + 1
                                } else {
                                if ch == "." {
                                    if pos + 1 < total && ch_at(chars, pos + 1) == "." {
                                        tokens = tokens.push(Token { kind: "DotDot", value: "..", line: line, col: start_col })
                                        pos = pos + 2
                                        col = col + 2
                                    } else {
                                        tokens = tokens.push(Token { kind: "Dot", value: ".", line: line, col: start_col })
                                        pos = pos + 1
                                        col = col + 1
                                    }
                                } else {
                                if ch == "@" {
                                    tokens = tokens.push(Token { kind: "At", value: "@", line: line, col: start_col })
                                    pos = pos + 1
                                    col = col + 1
                                } else {
                                    pos = pos + 1
                                    col = col + 1
                                } } } } } } } } } } } } } } } } } }
                            }
                        }
                    }
                }
            }
        }
    }
    tokens = tokens.push(Token { kind: "Eof", value: "", line: line, col: col })
    return tokens
}

// ══════════════════════════════════════════════════════════════
// Inline parser (core subset)
// ══════════════════════════════════════════════════════════════

fn empty_node() {
    return AstNode {
        kind: "", name: "", value: "", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn node_int_lit(val) {
    return AstNode {
        kind: "IntLit", name: "", value: val, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn node_string_lit(val) {
    return AstNode {
        kind: "StringLit", name: "", value: val, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn node_bool_lit(val) {
    return AstNode {
        kind: "BoolLit", name: "", value: val, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn node_ident(name) {
    return AstNode {
        kind: "Ident", name: name, value: "", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

let mut p_tokens = []
let mut p_pos = 0
let mut p_pending_attrs = ""

fn p_peek() {
    if p_pos >= len(p_tokens) {
        return Token { kind: "Eof", value: "", line: 0, col: 0 }
    }
    return p_tokens[p_pos]
}
fn p_peek_kind() { return p_peek().kind }
fn p_at_end() { return p_peek_kind() == "Eof" }
fn p_advance() {
    let tok = p_peek()
    p_pos = p_pos + 1
    return tok
}
fn p_check(ek) { return p_peek_kind() == ek }
fn p_expect(ek) {
    if p_check(ek) { return p_advance() }
    let tok = p_peek()
    println("Parse error: expected " + ek + ", got " + tok.kind)
    return tok
}
fn p_expect_ident() {
    let tok = p_peek()
    if tok.kind == "Ident" {
        p_pos = p_pos + 1
        return tok.value
    }
    println("Parse error: expected ident, got " + tok.kind)
    return ""
}
fn p_skip_newlines() {
    while p_peek_kind() == "Newline" { p_pos = p_pos + 1 }
}

fn parse(tokens) {
    p_tokens = tokens
    p_pos = 0
    let mut stmts = []
    p_skip_newlines()
    while !p_at_end() {
        stmts = stmts.push(parse_stmt())
        p_skip_newlines()
    }
    return stmts
}

fn parse_stmt() {
    p_skip_newlines()
    while p_peek_kind() == "At" {
        p_advance()
        let attr_name = p_expect_ident()
        if p_pending_attrs == "" {
            p_pending_attrs = attr_name
        } else {
            p_pending_attrs = p_pending_attrs + "," + attr_name
        }
        p_skip_newlines()
    }
    let kind = p_peek_kind()
    if kind == "Let" { return parse_let() }
    if kind == "Const" { return parse_const() }
    if kind == "Fn" { return parse_fn_decl() }
    if kind == "While" { return parse_while_stmt() }
    if kind == "Return" { return parse_return() }
    if kind == "Assert" { return parse_assert_stmt() }
    let expr = parse_expr()
    if p_peek_kind() == "Eq" {
        p_advance()
        let rhs = parse_expr()
        return AstNode {
            kind: "AssignStmt", name: "", value: "", op: "",
            left: expr, right: rhs, cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    return AstNode {
        kind: "ExprStmt", name: "", value: "", op: "",
        left: expr, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn parse_let() {
    p_advance()
    let mut is_mut = false
    if p_peek_kind() == "Mut" {
        p_advance()
        is_mut = true
    }
    let name = p_expect_ident()
    p_expect("Eq")
    let expr = parse_expr()
    let mut ks = "LetStmt"
    if is_mut { ks = "LetMutStmt" }
    return AstNode {
        kind: ks, name: name, value: "", op: "",
        left: expr, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn parse_const() {
    p_advance()
    let name = p_expect_ident()
    p_expect("Eq")
    let expr = parse_expr()
    return AstNode {
        kind: "ConstStmt", name: name, value: "", op: "",
        left: expr, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn parse_return() {
    p_advance()
    let k = p_peek_kind()
    if k == "Newline" || k == "Eof" || k == "RBrace" {
        return AstNode {
            kind: "ReturnStmt", name: "", value: "", op: "",
            left: "", right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    let expr = parse_expr()
    return AstNode {
        kind: "ReturnStmt", name: "", value: "", op: "",
        left: expr, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn parse_assert_stmt() {
    p_advance()
    let expr = parse_expr()
    return AstNode {
        kind: "AssertStmt", name: "", value: "", op: "",
        left: expr, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn parse_fn_decl() {
    p_advance()
    let name = p_expect_ident()
    p_expect("LParen")
    let params = parse_params()
    p_expect("RParen")
    let body = parse_block()
    let attrs = p_pending_attrs
    p_pending_attrs = ""
    return AstNode {
        kind: "FnDecl", name: name, value: attrs, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: params, body: body, args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn parse_params() {
    let mut params = []
    if p_peek_kind() == "RParen" { return params }
    let name = p_expect_ident()
    params = params.push(AstNode {
        kind: "Param", name: name, value: "", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    })
    while p_peek_kind() == "Comma" {
        p_advance()
        let pname = p_expect_ident()
        params = params.push(AstNode {
            kind: "Param", name: pname, value: "", op: "",
            left: "", right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        })
    }
    return params
}

fn parse_while_stmt() {
    p_advance()
    let cond = parse_expr()
    let body = parse_block()
    return AstNode {
        kind: "WhileStmt", name: "", value: "", op: "",
        left: "", right: "", cond: cond, then_body: "", else_body: "",
        params: "", body: body, args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn parse_block() {
    p_skip_newlines()
    p_expect("LBrace")
    p_skip_newlines()
    let mut stmts = []
    while p_peek_kind() != "RBrace" && p_peek_kind() != "Eof" {
        stmts = stmts.push(parse_stmt())
        p_skip_newlines()
    }
    p_expect("RBrace")
    return stmts
}

fn parse_expr() { return parse_comparison() }

fn parse_comparison() {
    let mut left = parse_addition()
    while p_peek_kind() == "EqEq" || p_peek_kind() == "NotEq" || p_peek_kind() == "Lt" || p_peek_kind() == "Gt" || p_peek_kind() == "LtEq" || p_peek_kind() == "GtEq" {
        let op_tok = p_advance()
        let right = parse_addition()
        left = AstNode {
            kind: "BinOp", name: "", value: "", op: op_tok.value,
            left: left, right: right, cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    return left
}

fn parse_addition() {
    let mut left = parse_multiplication()
    while p_peek_kind() == "Plus" || p_peek_kind() == "Minus" {
        let op_tok = p_advance()
        let right = parse_multiplication()
        left = AstNode {
            kind: "BinOp", name: "", value: "", op: op_tok.value,
            left: left, right: right, cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    return left
}

fn parse_multiplication() {
    let mut left = parse_unary()
    while p_peek_kind() == "Star" || p_peek_kind() == "Slash" {
        let op_tok = p_advance()
        let right = parse_unary()
        left = AstNode {
            kind: "BinOp", name: "", value: "", op: op_tok.value,
            left: left, right: right, cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    return left
}

fn parse_unary() {
    if p_peek_kind() == "Not" || p_peek_kind() == "Minus" {
        let op_tok = p_advance()
        let operand = parse_unary()
        return AstNode {
            kind: "UnaryOp", name: "", value: "", op: op_tok.value,
            left: operand, right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    return parse_postfix()
}

fn parse_postfix() {
    let mut expr = parse_primary()
    let mut cont = true
    while cont {
        let k = p_peek_kind()
        if k == "LParen" {
            p_advance()
            let args = parse_args()
            p_expect("RParen")
            expr = AstNode {
                kind: "Call", name: "", value: "", op: "",
                left: expr, right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: args, fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            }
        } else {
            if k == "Dot" {
                p_advance()
                let fn2 = p_expect_ident()
                expr = AstNode {
                    kind: "Field", name: fn2, value: "", op: "",
                    left: expr, right: "", cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            } else {
                if k == "LBracket" {
                    p_advance()
                    let index = parse_expr()
                    p_expect("RBracket")
                    expr = AstNode {
                        kind: "Index", name: "", value: "", op: "",
                        left: expr, right: index, cond: "", then_body: "", else_body: "",
                        params: "", body: "", args: "", fields: "", items: "",
                        variants: "", arms: "", iter_expr: "", ret_type: "",
                        target: "", trait_name: "", methods: ""
                    }
                } else {
                    cont = false
                }
            }
        }
    }
    return expr
}

fn parse_args() {
    let mut args = []
    if p_peek_kind() == "RParen" { return args }
    args = args.push(parse_expr())
    while p_peek_kind() == "Comma" {
        p_advance()
        args = args.push(parse_expr())
    }
    return args
}

fn parse_primary() {
    let tok = p_peek()
    let k = tok.kind
    if k == "IntLit" {
        p_advance()
        return node_int_lit(tok.value)
    }
    if k == "BoolLit" {
        p_advance()
        return node_bool_lit(tok.value)
    }
    if k == "StringLit" {
        p_advance()
        return node_string_lit(tok.value)
    }
    if k == "Ident" {
        p_advance()
        return node_ident(tok.value)
    }
    if k == "LParen" {
        p_advance()
        let expr = parse_expr()
        p_expect("RParen")
        return expr
    }
    if k == "LBracket" {
        p_advance()
        let mut items = []
        while p_peek_kind() != "RBracket" && p_peek_kind() != "Eof" {
            items = items.push(parse_expr())
            if p_peek_kind() == "Comma" { p_advance() }
        }
        p_expect("RBracket")
        return AstNode {
            kind: "Array", name: "", value: "", op: "",
            left: "", right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: items,
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
    }
    println("Unexpected token: " + tok.kind)
    p_advance()
    return empty_node()
}

// ══════════════════════════════════════════════════════════════
// Inline type checker (minimal)
// ══════════════════════════════════════════════════════════════

let mut tc_errors = []
let mut scope_names = []
let mut scope_types = []
let mut scope_depths = []
let mut tc_depth = 0
let mut fn_names = []
let mut fn_arities = []

fn tc_error(msg) {
    tc_errors = tc_errors.push(TypeError { message: msg, name: "" })
}

fn tc_define(name, typ) {
    scope_names = scope_names.push(name)
    scope_types = scope_types.push(typ)
    scope_depths = scope_depths.push(tc_depth)
}

fn tc_lookup(name) {
    let mut i = len(scope_names) - 1
    while i >= 0 {
        if scope_names[i] == name { return scope_types[i] }
        i = i - 1
    }
    return ""
}

fn tc_register_fn(name, arity) {
    fn_names = fn_names.push(name)
    fn_arities = fn_arities.push(arity)
}

fn tc_lookup_fn_arity(name) {
    let mut i = 0
    while i < len(fn_names) {
        if fn_names[i] == name { return fn_arities[i] }
        i = i + 1
    }
    return -1
}

fn tc_infer(node) {
    if type_of(node) == "string" { return "void" }
    let k = node.kind
    if k == "IntLit" { return "int" }
    if k == "BoolLit" { return "bool" }
    if k == "StringLit" { return "string" }
    if k == "Ident" {
        let t = tc_lookup(node.name)
        if t == "" {
            tc_error("Undeclared variable '" + node.name + "'")
            return "unknown"
        }
        return t
    }
    if k == "BinOp" {
        tc_infer(node.left)
        tc_infer(node.right)
        if node.op == "==" || node.op == "!=" || node.op == "<" || node.op == ">" {
            return "bool"
        }
        return "int"
    }
    if k == "Call" {
        let mut i = 0
        while i < len(node.args) {
            tc_infer(node.args[i])
            i = i + 1
        }
        if type_of(node.left) != "string" && node.left.kind == "Ident" {
            let arity = tc_lookup_fn_arity(node.left.name)
            if arity >= 0 && arity != len(node.args) {
                tc_error("'" + node.left.name + "' expects " + to_string(arity) + " args, got " + to_string(len(node.args)))
            }
        }
        return "unknown"
    }
    return "unknown"
}

fn tc_check_stmt(node) {
    let k = node.kind
    if k == "LetStmt" || k == "LetMutStmt" {
        let t = tc_infer(node.left)
        tc_define(node.name, t)
        return
    }
    if k == "ConstStmt" {
        let t = tc_infer(node.left)
        tc_define(node.name, t)
        return
    }
    if k == "FnDecl" {
        tc_register_fn(node.name, len(node.params))
        tc_define(node.name, "fn")
        let saved_n = scope_names
        let saved_t = scope_types
        let saved_d = scope_depths
        let saved_depth = tc_depth
        tc_depth = tc_depth + 1
        let mut i = 0
        while i < len(node.params) {
            tc_define(node.params[i].name, "unknown")
            i = i + 1
        }
        tc_check_stmts(node.body)
        scope_names = saved_n
        scope_types = saved_t
        scope_depths = saved_d
        tc_depth = saved_depth
        return
    }
    if k == "WhileStmt" {
        tc_infer(node.cond)
        tc_check_stmts(node.body)
        return
    }
    if k == "ReturnStmt" {
        if type_of(node.left) != "string" { tc_infer(node.left) }
        return
    }
    if k == "AssignStmt" {
        if type_of(node.left) != "string" && node.left.kind == "Ident" {
            if tc_lookup(node.left.name) == "" {
                tc_error("Assign to undeclared '" + node.left.name + "'")
            }
        }
        tc_infer(node.right)
        return
    }
    if k == "ExprStmt" {
        tc_infer(node.left)
        return
    }
    if k == "AssertStmt" {
        tc_infer(node.left)
        return
    }
}

fn tc_check_stmts(stmts) {
    if type_of(stmts) == "string" { return }
    let mut i = 0
    while i < len(stmts) {
        tc_check_stmt(stmts[i])
        i = i + 1
    }
}

fn type_check(stmts) {
    tc_errors = []
    scope_names = []
    scope_types = []
    scope_depths = []
    tc_depth = 0
    fn_names = []
    fn_arities = []
    // Register builtins
    tc_register_fn("println", -1)
    tc_register_fn("print", -1)
    tc_register_fn("format", -1)
    tc_register_fn("len", 1)
    tc_register_fn("to_string", 1)
    // First pass: collect fns
    let mut i = 0
    while i < len(stmts) {
        if stmts[i].kind == "FnDecl" {
            tc_register_fn(stmts[i].name, len(stmts[i].params))
            tc_define(stmts[i].name, "fn")
        }
        i = i + 1
    }
    tc_check_stmts(stmts)
    return tc_errors
}

// ══════════════════════════════════════════════════════════════
// Inline compiler (minimal)
// ══════════════════════════════════════════════════════════════

fn instr(op, operand) { return Instruction { op: op, operand: operand } }
fn instr_op(op) { return Instruction { op: op, operand: "" } }

let mut c_code = []
let mut c_consts = []
let mut c_local_names = []
let mut c_next_local = 0
let mut c_functions = []

fn c_add_const(val) {
    let mut i = 0
    while i < len(c_consts) {
        if c_consts[i] == val { return i }
        i = i + 1
    }
    c_consts = c_consts.push(val)
    return len(c_consts) - 1
}

fn c_emit(op, operand) {
    c_code = c_code.push(instr(op, operand))
    return len(c_code) - 1
}

fn c_emit_op(op) {
    c_code = c_code.push(instr_op(op))
    return len(c_code) - 1
}

fn c_current_pos() { return len(c_code) }

fn c_patch_jump(pos, target) {
    let old = c_code[pos]
    c_code[pos] = Instruction { op: old.op, operand: to_string(target) }
}

fn c_resolve_local(name) {
    let mut i = len(c_local_names) - 1
    while i >= 0 {
        if c_local_names[i] == name { return i }
        i = i - 1
    }
    return -1
}

fn c_define_local(name) {
    let slot = c_next_local
    c_local_names = c_local_names.push(name)
    c_next_local = c_next_local + 1
    return slot
}

fn c_compile_expr(node) {
    if type_of(node) == "string" {
        c_emit_op("VOID")
        return
    }
    let k = node.kind
    if k == "IntLit" || k == "BoolLit" || k == "StringLit" {
        let idx = c_add_const(node.value)
        c_emit("CONST", to_string(idx))
        return
    }
    if k == "Ident" {
        let slot = c_resolve_local(node.name)
        if slot >= 0 {
            c_emit("GET_LOCAL", to_string(slot))
        } else {
            c_emit("GET_GLOBAL", node.name)
        }
        return
    }
    if k == "BinOp" {
        c_compile_expr(node.left)
        c_compile_expr(node.right)
        if node.op == "+" { c_emit_op("ADD") }
        if node.op == "-" { c_emit_op("SUB") }
        if node.op == "*" { c_emit_op("MUL") }
        if node.op == "/" { c_emit_op("DIV") }
        if node.op == "==" { c_emit_op("EQ") }
        if node.op == "!=" { c_emit_op("NE") }
        if node.op == "<" { c_emit_op("LT") }
        if node.op == ">" { c_emit_op("GT") }
        return
    }
    if k == "UnaryOp" {
        c_compile_expr(node.left)
        if node.op == "-" { c_emit_op("NEG") }
        if node.op == "!" { c_emit_op("NOT") }
        return
    }
    if k == "Call" {
        let ac = len(node.args)
        let mut i = 0
        while i < ac {
            c_compile_expr(node.args[i])
            i = i + 1
        }
        if type_of(node.left) != "string" && node.left.kind == "Ident" {
            let fname = node.left.name
            if fname == "println" {
                c_emit("PRINTLN", to_string(ac))
                return
            }
            if fname == "print" {
                c_emit("PRINT", to_string(ac))
                return
            }
            c_emit("CALL", fname + ":" + to_string(ac))
            return
        }
        c_emit("CALL_INDIRECT", to_string(ac))
        return
    }
    if k == "Array" {
        let count = len(node.items)
        let mut i = 0
        while i < count {
            c_compile_expr(node.items[i])
            i = i + 1
        }
        c_emit("MAKE_ARRAY", to_string(count))
        return
    }
    c_emit_op("VOID")
}

fn c_compile_stmt(node) {
    let k = node.kind
    if k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" {
        c_compile_expr(node.left)
        let slot = c_define_local(node.name)
        c_emit("SET_LOCAL", to_string(slot))
        return
    }
    if k == "FnDecl" {
        let saved = c_code
        let saved_locals = c_local_names
        let saved_next = c_next_local
        c_code = []
        c_local_names = []
        c_next_local = 0
        let pc = len(node.params)
        let mut pn = []
        let mut i = 0
        while i < pc {
            pn = pn.push(node.params[i].name)
            c_define_local(node.params[i].name)
            i = i + 1
        }
        c_compile_stmts(node.body)
        c_emit_op("VOID")
        c_emit_op("RETURN")
        let fn_code = c_code
        let fn_locals = c_next_local
        c_code = saved
        c_local_names = saved_locals
        c_next_local = saved_next
        c_functions = c_functions.push(CompiledFn {
            name: node.name, arity: pc, param_names: pn,
            code: fn_code, local_count: fn_locals
        })
        return
    }
    if k == "ReturnStmt" {
        if type_of(node.left) != "string" {
            c_compile_expr(node.left)
        } else {
            c_emit_op("VOID")
        }
        c_emit_op("RETURN")
        return
    }
    if k == "AssignStmt" {
        c_compile_expr(node.right)
        if type_of(node.left) != "string" && node.left.kind == "Ident" {
            let slot = c_resolve_local(node.left.name)
            if slot >= 0 {
                c_emit("SET_LOCAL", to_string(slot))
            } else {
                c_emit("SET_GLOBAL", node.left.name)
            }
        }
        return
    }
    if k == "WhileStmt" {
        let ls = c_current_pos()
        c_compile_expr(node.cond)
        let ej = c_emit("JUMP_IF_FALSE", "0")
        c_compile_stmts(node.body)
        c_emit("JUMP", to_string(ls))
        c_patch_jump(ej, c_current_pos())
        return
    }
    if k == "ExprStmt" {
        c_compile_expr(node.left)
        c_emit_op("POP")
        return
    }
    if k == "AssertStmt" {
        c_compile_expr(node.left)
        c_emit_op("ASSERT")
        return
    }
}

fn c_compile_stmts(stmts) {
    if type_of(stmts) == "string" { return }
    let mut i = 0
    while i < len(stmts) {
        c_compile_stmt(stmts[i])
        i = i + 1
    }
}

fn compile_program(stmts) {
    c_code = []
    c_consts = []
    c_local_names = []
    c_next_local = 0
    c_functions = []
    c_compile_stmts(stmts)
    return c_code
}

// ══════════════════════════════════════════════════════════════
// Inline ai_native_pass (M0)
// ══════════════════════════════════════════════════════════════

fn split_attrs_m0(s) {
    let mut out = []
    if s == "" { return out }
    let chars = s.chars()
    let total = len(chars)
    let mut i = 0
    let mut cur = ""
    while i < total {
        let c = to_string(chars[i])
        if c == "," {
            if cur != "" { out = out.push(cur) }
            cur = ""
        } else {
            cur = cur + c
        }
        i = i + 1
    }
    if cur != "" { out = out.push(cur) }
    return out
}

fn classify_attr_m0(name) {
    if name == "optimize" { return "G1" }
    if name == "memoize" { return "G1" }
    if name == "pure" { return "G1" }
    if name == "inline" { return "G1" }
    if name == "hot" { return "G1" }
    if name == "cold" { return "G1" }
    if name == "bounded" { return "G1" }
    if name == "fuse" { return "G2" }
    if name == "compact" { return "G2" }
    if name == "lazy" { return "G2" }
    if name == "cache" { return "G2" }
    if name == "algebraic" { return "G2" }
    if name == "parallel" { return "G3" }
    if name == "simd" { return "G3" }
    if name == "gpu" { return "G3" }
    if name == "specialize" { return "G3" }
    if name == "predict" { return "G3" }
    if name == "symbolic" { return "G4" }
    if name == "reduce" { return "G4" }
    if name == "approximate" { return "G4" }
    if name == "evolve" { return "G4" }
    if name == "learn" { return "G4" }
    if name == "contract" { return "G4" }
    if name == "profile" { return "G4" }
    if name == "test" { return "meta" }
    if name == "bench" { return "meta" }
    if name == "deprecated" { return "meta" }
    if name == "link" { return "meta" }
    return "unknown"
}

// M2: @pure purity checker — recursive. Scans a FnDecl body and
// descends into nested WhileStmt bodies. Flags side-effecting
// patterns: assignments, mutable bindings, println/print calls,
// or impure return expressions. Returns "" if pure, else reason.
fn check_purity_expr(expr) {
    if type_of(expr) == "string" { return "" }
    if expr.kind == "Call" {
        let callee = expr.left
        if type_of(callee) != "string" {
            if callee.kind == "Ident" {
                if callee.name == "println" { return "println call" }
                if callee.name == "print" { return "print call" }
            }
        }
    }
    return ""
}

fn check_purity_m1(body) {
    if type_of(body) != "array" { return "" }
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "AssignStmt" { return "assignment" }
        if k == "LetMutStmt" { return "mutable binding" }
        if k == "ExprStmt" {
            let er = check_purity_expr(stmt.left)
            if er != "" { return er }
        }
        if k == "ReturnStmt" {
            let rr = check_purity_expr(stmt.left)
            if rr != "" { return rr }
        }
        if k == "WhileStmt" {
            // M2: recurse into loop body
            let wr = check_purity_m1(stmt.body)
            if wr != "" { return "while:" + wr }
        }
        i = i + 1
    }
    return ""
}

// M1 diagnostics counters (module-level so tests can assert)
let mut m1_pure_ok = 0
let mut m1_pure_violations = 0
// M3/M4 diagnostics
let mut m3_inline_ok = 0
let mut m3_inline_too_big = 0
let mut m4_attr_conflicts = 0
// M5/M6 diagnostics
let mut m5_memoize_ok = 0
let mut m5_memoize_bad = 0
let mut m6_total_fns = 0
let mut m6_annotated_fns = 0
let mut m6_g1 = 0
let mut m6_g2 = 0
let mut m6_g3 = 0
let mut m6_g4 = 0
// M7 meta counters
let mut m7_test = 0
let mut m7_bench = 0
let mut m7_deprecated = 0
// M8: hardware attrs — loop presence check
let mut m8_hw_ok = 0
let mut m8_hw_no_loop = 0
// M9: self-recursion detection
let mut m9_recursive = 0
// M10: @memoize score
let mut m10_memoize_score_sum = 0
// M11: total Call nodes across annotated fns
let mut m11_call_count = 0
// M12: body size sums per group
let mut m12_g1_size = 0
let mut m12_g2_size = 0
let mut m12_g3_size = 0
let mut m12_g4_size = 0
// M13: max while-nesting depth across annotated fns
let mut m13_max_while_depth = 0
// M14: bubble-sort candidate heuristic
let mut m14_bubble_candidates = 0
// M15: tail-call candidate
let mut m15_tail_call_candidates = 0
// M16: Strassen candidate (triple nested loop)
let mut m16_strassen_candidates = 0
// M17: DP/memoize missed opportunity
let mut m17_dp_missed = 0
// M19: unreachable code after Return in same block
let mut m19_unreachable = 0
// M20: empty annotated body
let mut m20_empty_body = 0
// M21: constant-return body (return literal only)
let mut m21_const_return = 0
// M22: AST rewrite — auto-insert `return 0` into empty annotated body
let mut m22_rewrites = 0
// M23: auto-add @memoize to recursive @optimize fns (M17 recommendation → action)
let mut m23_auto_memoize = 0
// M24: dead code elimination — drop stmts after ReturnStmt
let mut m24_dce_fns = 0
let mut m24_dce_stmts = 0
// M25: G1 tail-call → while loop body rewrite
let mut m25_tail_rewrites = 0
// M26: duplicate attr removal
let mut m26_attr_dedups = 0
// M27: attr canonical sort
let mut m27_attr_sorts = 0
// M29: annotated fn name registry
let mut m29_registry = []
// M30: algebraic simplification (x+0, x*0, x*1)
let mut m30_algebraic = 0
// M31: self-expression identity (x-x→0)

fn same_ident(a, b) {
    if type_of(a) == "string" { return false }
    if type_of(b) == "string" { return false }
    if a.kind != "Ident" { return false }
    if b.kind != "Ident" { return false }
    return a.name == b.name
}

fn is_int_zero(e) {
    if type_of(e) == "string" { return false }
    if e.kind != "IntLit" { return false }
    return e.value == "0"
}

fn is_int_one(e) {
    if type_of(e) == "string" { return false }
    if e.kind != "IntLit" { return false }
    return e.value == "1"
}

fn simplify_expr(expr) {
    if type_of(expr) == "string" { return expr }
    if expr.kind != "BinOp" { return expr }
    // Recursively simplify children first
    let l = simplify_expr(expr.left)
    let r = simplify_expr(expr.right)
    let op = expr.op
    if op == "+" {
        if is_int_zero(l) {
            m30_algebraic = m30_algebraic + 1
            return r
        }
        if is_int_zero(r) {
            m30_algebraic = m30_algebraic + 1
            return l
        }
    }
    if op == "-" {
        if is_int_zero(r) {
            m30_algebraic = m30_algebraic + 1
            return l
        }
        if same_ident(l, r) {
            m30_algebraic = m30_algebraic + 1
            return AstNode {
                kind: "IntLit", name: "", value: "0", op: "",
                left: "", right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            }
        }
    }
    if op == "*" {
        if is_int_zero(l) || is_int_zero(r) {
            m30_algebraic = m30_algebraic + 1
            return AstNode {
                kind: "IntLit", name: "", value: "0", op: "",
                left: "", right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            }
        }
        if is_int_one(l) {
            m30_algebraic = m30_algebraic + 1
            return r
        }
        if is_int_one(r) {
            m30_algebraic = m30_algebraic + 1
            return l
        }
    }
    // Rebuild with simplified children
    return AstNode {
        kind: "BinOp", name: "", value: "", op: op,
        left: l, right: r, cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn simplify_body(body) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "ReturnStmt" {
            let new_e = simplify_expr(stmt.left)
            out = out.push(AstNode {
                kind: "ReturnStmt", name: "", value: "", op: "",
                left: new_e, right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            })
        } else {
            out = out.push(stmt)
        }
        i = i + 1
    }
    return out
}

// Canonical attr rank (lower = earlier). Integer comparison only.
fn attr_rank(name) {
    if name == "pure" { return 10 }
    if name == "inline" { return 20 }
    if name == "hot" { return 30 }
    if name == "cold" { return 31 }
    if name == "bounded" { return 40 }
    if name == "memoize" { return 50 }
    if name == "optimize" { return 60 }
    if name == "fuse" { return 70 }
    if name == "compact" { return 71 }
    if name == "lazy" { return 72 }
    if name == "cache" { return 73 }
    if name == "algebraic" { return 74 }
    if name == "parallel" { return 80 }
    if name == "simd" { return 81 }
    if name == "gpu" { return 82 }
    if name == "specialize" { return 83 }
    if name == "predict" { return 84 }
    if name == "symbolic" { return 90 }
    if name == "reduce" { return 91 }
    if name == "approximate" { return 92 }
    if name == "evolve" { return 93 }
    if name == "learn" { return 94 }
    if name == "contract" { return 95 }
    if name == "profile" { return 96 }
    if name == "test" { return 200 }
    if name == "bench" { return 201 }
    if name == "deprecated" { return 202 }
    if name == "link" { return 203 }
    return 999
}

fn sort_attrs(attrs) {
    // Selection sort by rank — stable for equal ranks
    let n = len(attrs)
    let mut result = []
    let mut i = 0
    while i < n {
        result = result.push(attrs[i])
        i = i + 1
    }
    let mut k = 0
    while k < n {
        let mut min_idx = k
        let mut j = k + 1
        while j < n {
            if attr_rank(result[j]) < attr_rank(result[min_idx]) {
                min_idx = j
            }
            j = j + 1
        }
        if min_idx != k {
            // swap via rebuild
            let mut tmp = []
            let mut t = 0
            while t < n {
                if t == k { tmp = tmp.push(result[min_idx]) }
                else { if t == min_idx { tmp = tmp.push(result[k]) }
                       else { tmp = tmp.push(result[t]) } }
                t = t + 1
            }
            result = tmp
        }
        k = k + 1
    }
    return result
}

fn arrays_equal_str(a, b) {
    if len(a) != len(b) { return false }
    let n = len(a)
    let mut i = 0
    while i < n {
        if a[i] != b[i] { return false }
        i = i + 1
    }
    return true
}

fn dedup_attrs(attrs) {
    let mut seen = []
    let n = len(attrs)
    let mut i = 0
    while i < n {
        let a = attrs[i]
        let mut already = false
        let sn = len(seen)
        let mut j = 0
        while j < sn {
            if seen[j] == a { already = true }
            j = j + 1
        }
        if !already { seen = seen.push(a) }
        i = i + 1
    }
    return seen
}

fn join_attrs(attrs) {
    let n = len(attrs)
    if n == 0 { return "" }
    let mut out = attrs[0]
    let mut i = 1
    while i < n {
        out = out + "," + attrs[i]
        i = i + 1
    }
    return out
}

fn make_bool_lit(v) {
    return AstNode {
        kind: "BoolLit", name: "", value: v, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_while_true_empty() {
    return AstNode {
        kind: "WhileStmt", name: "", value: "", op: "",
        left: "", right: "", cond: make_bool_lit("true"), then_body: "", else_body: "",
        params: "", body: [], args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

// Simple tail-call: body is exactly [ReturnStmt(Call(Ident self, ...))]
fn is_simple_tail_only(body, self_name) {
    if type_of(body) != "array" { return false }
    if len(body) != 1 { return false }
    let s = body[0]
    if s.kind != "ReturnStmt" { return false }
    let e = s.left
    if type_of(e) == "string" { return false }
    if e.kind != "Call" { return false }
    let callee = e.left
    if type_of(callee) == "string" { return false }
    if callee.kind != "Ident" { return false }
    return callee.name == self_name
}

fn eliminate_dead(body) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let n = len(body)
    let mut i = 0
    let mut stopped = false
    while i < n {
        if !stopped {
            out = out.push(body[i])
            if body[i].kind == "ReturnStmt" { stopped = true }
        }
        i = i + 1
    }
    return out
}

fn rewrite_fn_with_attrs(fn_node, new_attrs) {
    return AstNode {
        kind: "FnDecl", name: fn_node.name, value: new_attrs, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: fn_node.params, body: fn_node.body, args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: fn_node.ret_type,
        target: "", trait_name: "", methods: ""
    }
}

fn make_return_zero() {
    let lit = AstNode {
        kind: "IntLit", name: "", value: "0", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
    return AstNode {
        kind: "ReturnStmt", name: "", value: "", op: "",
        left: lit, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn rewrite_fn_with_body(fn_node, new_body) {
    return AstNode {
        kind: "FnDecl", name: fn_node.name, value: fn_node.value, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: fn_node.params, body: new_body, args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: fn_node.ret_type,
        target: "", trait_name: "", methods: ""
    }
}

fn is_literal_kind(k) {
    if k == "IntLit" { return true }
    if k == "FloatLit" { return true }
    if k == "BoolLit" { return true }
    if k == "StringLit" { return true }
    if k == "CharLit" { return true }
    return false
}

fn body_is_const_return(body) {
    if type_of(body) != "array" { return false }
    if len(body) != 1 { return false }
    let s = body[0]
    if s.kind != "ReturnStmt" { return false }
    let e = s.left
    if type_of(e) == "string" { return false }
    return is_literal_kind(e.kind)
}

fn count_unreachable(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    let mut hit = false
    while i < n {
        let stmt = body[i]
        if hit { c = c + 1 }
        if stmt.kind == "ReturnStmt" { hit = true }
        if stmt.kind == "WhileStmt" {
            c = c + count_unreachable(stmt.body)
        }
        i = i + 1
    }
    return c
}

fn is_tail_call(body, self_name) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    if n == 0 { return false }
    let last = body[n - 1]
    if last.kind != "ReturnStmt" { return false }
    return expr_calls_self(last.left, self_name)
}

fn body_has_let_mut(body) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    let mut i = 0
    while i < n {
        let k = body[i].kind
        if k == "LetMutStmt" { return true }
        if k == "WhileStmt" {
            if body_has_let_mut(body[i].body) { return true }
        }
        i = i + 1
    }
    return false
}

fn while_depth(body) {
    if type_of(body) != "array" { return 0 }
    let mut maxd = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "WhileStmt" {
            let sub = while_depth(stmt.body)
            let here = 1 + sub
            if here > maxd { maxd = here }
        }
        i = i + 1
    }
    return maxd
}

fn expr_count_calls(expr) {
    if type_of(expr) == "string" { return 0 }
    let mut c = 0
    if expr.kind == "Call" {
        c = 1
        let args = expr.args
        if type_of(args) == "array" {
            let n = len(args)
            let mut i = 0
            while i < n {
                c = c + expr_count_calls(args[i])
                i = i + 1
            }
        }
    }
    if expr.kind == "BinOp" {
        c = c + expr_count_calls(expr.left)
        c = c + expr_count_calls(expr.right)
    }
    return c
}

fn stmts_count_calls(body) {
    if type_of(body) != "array" { return 0 }
    let mut total = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ExprStmt" || k == "ReturnStmt" || k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" {
            total = total + expr_count_calls(stmt.left)
        }
        if k == "AssignStmt" {
            total = total + expr_count_calls(stmt.right)
        }
        if k == "WhileStmt" {
            total = total + expr_count_calls(stmt.cond)
            total = total + stmts_count_calls(stmt.body)
        }
        i = i + 1
    }
    return total
}

fn expr_calls_self(expr, self_name) {
    if type_of(expr) == "string" { return false }
    let k = expr.kind
    if k == "Call" {
        let callee = expr.left
        if type_of(callee) != "string" {
            if callee.kind == "Ident" && callee.name == self_name {
                return true
            }
        }
        // recurse into args
        let args = expr.args
        if type_of(args) == "array" {
            let n = len(args)
            let mut i = 0
            while i < n {
                if expr_calls_self(args[i], self_name) { return true }
                i = i + 1
            }
        }
        return false
    }
    if k == "BinOp" {
        if expr_calls_self(expr.left, self_name) { return true }
        if expr_calls_self(expr.right, self_name) { return true }
    }
    return false
}

fn stmts_call_self(body, self_name) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ExprStmt" {
            if expr_calls_self(stmt.left, self_name) { return true }
        }
        if k == "ReturnStmt" {
            if expr_calls_self(stmt.left, self_name) { return true }
        }
        if k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" {
            if expr_calls_self(stmt.left, self_name) { return true }
        }
        if k == "AssignStmt" {
            if expr_calls_self(stmt.right, self_name) { return true }
        }
        if k == "WhileStmt" {
            if expr_calls_self(stmt.cond, self_name) { return true }
            if stmts_call_self(stmt.body, self_name) { return true }
        }
        i = i + 1
    }
    return false
}

fn body_has_loop(body) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    let mut i = 0
    while i < n {
        let k = body[i].kind
        if k == "WhileStmt" { return true }
        if k == "ForStmt" { return true }
        if k == "LoopStmt" { return true }
        i = i + 1
    }
    return false
}

// M3: body size — counts top-level statements only (simple heuristic).
// Inline threshold: 8 stmts. Over → "too big" diagnostic.
fn body_stmt_count(body) {
    if type_of(body) != "array" { return 0 }
    return len(body)
}

// M4: check a set of attrs for known conflicts.
// Returns reason string if conflict, else "".
fn attr_has(attrs, target) {
    let n = len(attrs)
    let mut i = 0
    while i < n {
        if attrs[i] == target { return true }
        i = i + 1
    }
    return false
}

fn find_attr_conflict(attrs) {
    if attr_has(attrs, "hot") && attr_has(attrs, "cold") {
        return "hot+cold"
    }
    if attr_has(attrs, "inline") && attr_has(attrs, "cold") {
        return "inline+cold"
    }
    if attr_has(attrs, "pure") && attr_has(attrs, "evolve") {
        return "pure+evolve"
    }
    return ""
}

fn ai_native_pass(ast) {
    let mut seen = 0
    m1_pure_ok = 0
    m1_pure_violations = 0
    m3_inline_ok = 0
    m3_inline_too_big = 0
    m4_attr_conflicts = 0
    m5_memoize_ok = 0
    m5_memoize_bad = 0
    m6_total_fns = 0
    m6_annotated_fns = 0
    m6_g1 = 0
    m6_g2 = 0
    m6_g3 = 0
    m6_g4 = 0
    m7_test = 0
    m7_bench = 0
    m7_deprecated = 0
    m8_hw_ok = 0
    m8_hw_no_loop = 0
    m9_recursive = 0
    m10_memoize_score_sum = 0
    m11_call_count = 0
    m12_g1_size = 0
    m12_g2_size = 0
    m12_g3_size = 0
    m12_g4_size = 0
    m13_max_while_depth = 0
    m14_bubble_candidates = 0
    m15_tail_call_candidates = 0
    m16_strassen_candidates = 0
    m17_dp_missed = 0
    m19_unreachable = 0
    m20_empty_body = 0
    m21_const_return = 0
    m22_rewrites = 0
    m23_auto_memoize = 0
    m24_dce_fns = 0
    m24_dce_stmts = 0
    m25_tail_rewrites = 0
    m26_attr_dedups = 0
    m27_attr_sorts = 0
    m29_registry = []
    m30_algebraic = 0
    let inline_threshold = 8
    let mut out = []
    let n = len(ast)
    let mut i = 0
    while i < n {
        let mut node = ast[i]
        // M20 diagnostic captured BEFORE any M22 rewrite
        let was_empty = node.kind == "FnDecl" && node.value != "" && body_stmt_count(node.body) == 0
        if was_empty {
            println("[ai-native] fn " + node.name + " WARN: empty body with @attrs")
            m20_empty_body = m20_empty_body + 1
        }
        // M22: if annotated with empty body, rewrite to inject `return 0`
        if was_empty {
            let new_body = [make_return_zero()]
            node = rewrite_fn_with_body(node, new_body)
            m22_rewrites = m22_rewrites + 1
            println("[ai-native] fn " + node.name + " REWRITE: inserted `return 0`")
        }
        if node.kind == "FnDecl" {
            m6_total_fns = m6_total_fns + 1
        }
        if node.kind == "FnDecl" && node.value != "" {
            m6_annotated_fns = m6_annotated_fns + 1
            // M29: register this fn name
            m29_registry = m29_registry.push(node.name)
            let raw_attrs = split_attrs_m0(node.value)
            // M26: deduplicate attrs
            let deduped = dedup_attrs(raw_attrs)
            if len(deduped) < len(raw_attrs) {
                node = rewrite_fn_with_attrs(node, join_attrs(deduped))
                m26_attr_dedups = m26_attr_dedups + (len(raw_attrs) - len(deduped))
                println("[ai-native] fn " + node.name + " REWRITE: dedup attrs → " + join_attrs(deduped))
            }
            // M27: canonical alpha sort
            let sorted = sort_attrs(deduped)
            let attrs = sorted
            if !arrays_equal_str(deduped, sorted) {
                node = rewrite_fn_with_attrs(node, join_attrs(sorted))
                m27_attr_sorts = m27_attr_sorts + 1
                println("[ai-native] fn " + node.name + " REWRITE: sort attrs → " + join_attrs(sorted))
            }
            let an = len(attrs)
            // M9: pre-compute self-recursion once per fn
            let is_rec = stmts_call_self(node.body, node.name)
            if is_rec {
                m9_recursive = m9_recursive + 1
                println("[ai-native] fn " + node.name + " RECURSIVE")
            }
            // M11: accumulate call count for this annotated fn
            let calls_here = stmts_count_calls(node.body)
            m11_call_count = m11_call_count + calls_here
            // M13: track max while nesting
            let wd = while_depth(node.body)
            if wd > m13_max_while_depth { m13_max_while_depth = wd }
            // M14: bubble-sort heuristic — @optimize + nested while + let mut
            if attr_has(attrs, "optimize") && wd >= 2 && body_has_let_mut(node.body) {
                println("[ai-native] fn " + node.name + " CANDIDATE: bubble→merge")
                m14_bubble_candidates = m14_bubble_candidates + 1
            }
            // M15: tail-call heuristic — @optimize + last stmt is Return(self_call)
            if attr_has(attrs, "optimize") && is_tail_call(node.body, node.name) {
                println("[ai-native] fn " + node.name + " CANDIDATE: tail→loop")
                m15_tail_call_candidates = m15_tail_call_candidates + 1
                // M25: if the body is EXACTLY a single tail-return, rewrite to while(true){}; return 0
                if is_simple_tail_only(node.body, node.name) {
                    let new_body = [make_while_true_empty(), make_return_zero()]
                    node = rewrite_fn_with_body(node, new_body)
                    m25_tail_rewrites = m25_tail_rewrites + 1
                    println("[ai-native] fn " + node.name + " REWRITE: tail→while(true)")
                }
            }
            // M16: Strassen heuristic — @optimize + while depth >= 3
            if attr_has(attrs, "optimize") && wd >= 3 {
                println("[ai-native] fn " + node.name + " CANDIDATE: matmul→Strassen")
                m16_strassen_candidates = m16_strassen_candidates + 1
            }
            // M17/M23: recursive @optimize without @memoize → auto-inject
            if attr_has(attrs, "optimize") && is_rec && !attr_has(attrs, "memoize") {
                println("[ai-native] fn " + node.name + " REWRITE: auto-added @memoize")
                m17_dp_missed = m17_dp_missed + 1
                node = rewrite_fn_with_attrs(node, node.value + ",memoize")
                m23_auto_memoize = m23_auto_memoize + 1
            }
            // M30: algebraic simplification on return expressions
            let before_alg = m30_algebraic
            let simplified_body = simplify_body(node.body)
            if m30_algebraic > before_alg {
                node = rewrite_fn_with_body(node, simplified_body)
                println("[ai-native] fn " + node.name + " REWRITE: algebraic simplify (+" + to_string(m30_algebraic - before_alg) + ")")
            }
            // M19/M24: unreachable code → detect + eliminate
            let unr = count_unreachable(node.body)
            if unr > 0 {
                println("[ai-native] fn " + node.name + " WARN: " + to_string(unr) + " unreachable stmt(s) after return")
                m19_unreachable = m19_unreachable + unr
                let cleaned = eliminate_dead(node.body)
                node = rewrite_fn_with_body(node, cleaned)
                m24_dce_fns = m24_dce_fns + 1
                m24_dce_stmts = m24_dce_stmts + unr
                println("[ai-native] fn " + node.name + " REWRITE: DCE dropped " + to_string(unr) + " stmt(s)")
            }
            // M20 already counted above (pre-rewrite)
            // M21: constant return
            if body_is_const_return(node.body) {
                println("[ai-native] fn " + node.name + " NOTE: constant-return, @pure/@memoize redundant")
                m21_const_return = m21_const_return + 1
            }
            // M12: track body size per primary group (first attr wins)
            if an > 0 {
                let primary_cat = classify_attr_m0(attrs[0])
                let sz2 = body_stmt_count(node.body)
                if primary_cat == "G1" { m12_g1_size = m12_g1_size + sz2 }
                if primary_cat == "G2" { m12_g2_size = m12_g2_size + sz2 }
                if primary_cat == "G3" { m12_g3_size = m12_g3_size + sz2 }
                if primary_cat == "G4" { m12_g4_size = m12_g4_size + sz2 }
            }
            // M10: @memoize score — +1 if recursive, +1 if also @pure
            if attr_has(attrs, "memoize") {
                let mut score = 0
                if is_rec { score = score + 1 }
                if attr_has(attrs, "pure") { score = score + 1 }
                m10_memoize_score_sum = m10_memoize_score_sum + score
                println("[ai-native] fn " + node.name + " memoize-score=" + to_string(score))
            }
            // M4: attr conflict (once per fn)
            let conflict = find_attr_conflict(attrs)
            if conflict != "" {
                println("[ai-native] fn " + node.name + " CONFLICT: " + conflict)
                m4_attr_conflicts = m4_attr_conflicts + 1
            }
            let mut j = 0
            while j < an {
                let attr = attrs[j]
                let cat = classify_attr_m0(attr)
                println("[ai-native] fn " + node.name + " @" + attr + " (" + cat + ")")
                // M1/M2: @pure → verify body recursively
                if attr == "pure" {
                    let reason = check_purity_m1(node.body)
                    if reason == "" {
                        println("  [pure] OK")
                        m1_pure_ok = m1_pure_ok + 1
                    } else {
                        println("  [pure] VIOLATION: " + reason)
                        m1_pure_violations = m1_pure_violations + 1
                    }
                }
                // M3: @inline → body size check
                if attr == "inline" {
                    let sz = body_stmt_count(node.body)
                    if sz <= inline_threshold {
                        println("  [inline] OK (" + to_string(sz) + " stmts)")
                        m3_inline_ok = m3_inline_ok + 1
                    } else {
                        println("  [inline] TOO BIG (" + to_string(sz) + " stmts > " + to_string(inline_threshold) + ")")
                        m3_inline_too_big = m3_inline_too_big + 1
                    }
                }
                // M5: @memoize — needs ≥1 param (cache key)
                if attr == "memoize" {
                    let pcount = 0
                    let pc = len(node.params)
                    if pc >= 1 {
                        println("  [memoize] OK (" + to_string(pc) + " param(s))")
                        m5_memoize_ok = m5_memoize_ok + 1
                    } else {
                        println("  [memoize] INELIGIBLE: zero-arg fn")
                        m5_memoize_bad = m5_memoize_bad + 1
                    }
                }
                // M6: group distribution
                if cat == "G1" { m6_g1 = m6_g1 + 1 }
                if cat == "G2" { m6_g2 = m6_g2 + 1 }
                if cat == "G3" { m6_g3 = m6_g3 + 1 }
                if cat == "G4" { m6_g4 = m6_g4 + 1 }
                // M7: meta attrs
                if attr == "test" { m7_test = m7_test + 1 }
                if attr == "bench" { m7_bench = m7_bench + 1 }
                if attr == "deprecated" { m7_deprecated = m7_deprecated + 1 }
                // M8: hardware attrs require a loop in body
                if attr == "parallel" || attr == "simd" || attr == "gpu" {
                    if body_has_loop(node.body) {
                        println("  [" + attr + "] OK (loop found)")
                        m8_hw_ok = m8_hw_ok + 1
                    } else {
                        println("  [" + attr + "] WARN: no loop in body")
                        m8_hw_no_loop = m8_hw_no_loop + 1
                    }
                }
                j = j + 1
            }
            seen = seen + 1
        }
        out = out.push(node)
        i = i + 1
    }
    let mut cov_pct = 0
    if m6_total_fns > 0 {
        cov_pct = (m6_annotated_fns * 100) / m6_total_fns
    }
    println("[ai-native] pass complete — " + to_string(seen) + " annotated fn(s), pure " + to_string(m1_pure_ok) + "/" + to_string(m1_pure_violations) + ", inline " + to_string(m3_inline_ok) + "/" + to_string(m3_inline_too_big) + ", memoize " + to_string(m5_memoize_ok) + "/" + to_string(m5_memoize_bad) + ", conflicts " + to_string(m4_attr_conflicts))
    println("[ai-native] coverage " + to_string(m6_annotated_fns) + "/" + to_string(m6_total_fns) + " (" + to_string(cov_pct) + "%), G1=" + to_string(m6_g1) + " G2=" + to_string(m6_g2) + " G3=" + to_string(m6_g3) + " G4=" + to_string(m6_g4))
    println("[ai-native] meta test=" + to_string(m7_test) + " bench=" + to_string(m7_bench) + " deprecated=" + to_string(m7_deprecated))
    println("[ai-native] hw " + to_string(m8_hw_ok) + " ok / " + to_string(m8_hw_no_loop) + " no-loop")
    println("[ai-native] recursive " + to_string(m9_recursive) + ", calls " + to_string(m11_call_count) + ", memoize-score-sum " + to_string(m10_memoize_score_sum))
    println("[ai-native] body-size G1=" + to_string(m12_g1_size) + " G2=" + to_string(m12_g2_size) + " G3=" + to_string(m12_g3_size) + " G4=" + to_string(m12_g4_size) + ", max-while-depth " + to_string(m13_max_while_depth))
    println("[ai-native] bubble-candidates " + to_string(m14_bubble_candidates) + ", tail-call-candidates " + to_string(m15_tail_call_candidates) + ", strassen-candidates " + to_string(m16_strassen_candidates) + ", dp-missed " + to_string(m17_dp_missed))
    let m18_total_suggestions = m14_bubble_candidates + m15_tail_call_candidates + m16_strassen_candidates + m17_dp_missed + m3_inline_too_big + m5_memoize_bad + m8_hw_no_loop + m4_attr_conflicts + m1_pure_violations + m19_unreachable
    println("[ai-native] unreachable " + to_string(m19_unreachable) + ", empty-body " + to_string(m20_empty_body) + ", const-return " + to_string(m21_const_return) + ", rewrites " + to_string(m22_rewrites) + ", auto-memoize " + to_string(m23_auto_memoize) + ", dce " + to_string(m24_dce_stmts) + " stmt(s) in " + to_string(m24_dce_fns) + " fn(s), tail-rewrites " + to_string(m25_tail_rewrites))
    println("[ai-native] TOTAL actionable items: " + to_string(m18_total_suggestions))
    return out
}

