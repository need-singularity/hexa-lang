fn count_passthrough_calls_expr(expr) {
    if type_of(expr) == "string" { return 0 }
    let mut c = 0
    if expr.kind == "Call" {
        let args = expr.args
        if type_of(args) == "array" && len(args) == 1 {
            let a0 = args[0]
            if type_of(a0) != "string" && a0.kind == "Ident" {
                c = c + 1
            }
        }
        if type_of(args) == "array" {
            let an = len(args)
            let mut ai = 0
            while ai < an {
                c = c + count_passthrough_calls_expr(args[ai])
                ai = ai + 1
            }
        }
    }
    if expr.kind == "BinOp" {
        c = c + count_passthrough_calls_expr(expr.left)
        c = c + count_passthrough_calls_expr(expr.right)
    }
    if expr.kind == "UnaryOp" { c = c + count_passthrough_calls_expr(expr.left) }
    return c
}

fn count_passthrough_calls_body(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        let k = stmt.kind
        if k == "ReturnStmt" || k == "ExprStmt" || k == "LetStmt" || k == "LetMutStmt" || k == "ConstStmt" {
            c = c + count_passthrough_calls_expr(stmt.left)
        }
        if k == "AssignStmt" { c = c + count_passthrough_calls_expr(stmt.right) }
        if k == "WhileStmt" { c = c + count_passthrough_calls_body(stmt.body) }
        i = i + 1
    }
    return c
}

fn count_for_loops(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "LetMutStmt" && i + 1 < n {
            // init must be IntLit (typically 0)
            let init = stmt.left
            if type_of(init) != "string" && init.kind == "IntLit" {
                let nxt = body[i + 1]
                if nxt.kind == "WhileStmt" {
                    let cond = nxt.cond
                    // cond must be BinOp(< or <=, Ident matching, ...)
                    if type_of(cond) != "string" && cond.kind == "BinOp" {
                        if cond.op == "<" || cond.op == "<=" {
                            if type_of(cond.left) != "string" && cond.left.kind == "Ident" && cond.left.name == stmt.name {
                                if body_increments_name(nxt.body, stmt.name) {
                                    c = c + 1
                                }
                            }
                        }
                    }
                }
            }
        }
        i = i + 1
    }
    return c
}

fn body_has_mul_to(body, target) {
    if type_of(body) != "array" { return false }
    let n = len(body)
    let mut i = 0
    while i < n {
        let s = body[i]
        if s.kind == "AssignStmt" {
            let lhs = s.left
            let rhs = s.right
            if type_of(lhs) != "string" && type_of(rhs) != "string" {
                if lhs.kind == "Ident" && lhs.name == target {
                    if rhs.kind == "BinOp" && rhs.op == "*" {
                        if type_of(rhs.left) != "string" && rhs.left.kind == "Ident" && rhs.left.name == target {
                            return true
                        }
                    }
                }
            }
        }
        i = i + 1
    }
    return false
}

fn count_product_loops(body) {
    if type_of(body) != "array" { return 0 }
    let mut c = 0
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if stmt.kind == "LetMutStmt" && i + 1 < n {
            let nxt = body[i + 1]
            if nxt.kind == "WhileStmt" {
                if body_has_mul_to(nxt.body, stmt.name) {
                    c = c + 1
                }
            }
        }
        i = i + 1
    }
    return c
}

