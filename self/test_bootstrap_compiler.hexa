let tok35 = tokenize(src35)
let ast35 = parse(tok35)
let err35 = type_check(ast35)
assert len(err35) == 0
let c_out35 = codegen_c2(ast35)
assert c_out35.contains("#include \"runtime.c\"")
assert c_out35.contains("int main()")
assert c_out35.contains("HexaVal x = hexa_int(42);")
assert c_out35.contains("hexa_println(x)")
assert c_out35.contains("return 0;")
println("  PASS")

