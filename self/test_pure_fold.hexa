// test_pure_fold.hexa — ROI #57 @pure function inline+folding tests
// Exercises: pf_is_const, pf_const_val, pf_val_to_ast, pf_eval_expr,
//            pf_eval_body, anp_pure_fold_call, anp_pure_fold_pass
// Self-contained: no imports needed

struct AstNode {
    kind: string,
    name: string,
    value: string,
    op: string,
    left: string,
    right: string,
    cond: string,
    then_body: string,
    else_body: string,
    params: string,
    body: string,
    args: string,
    fields: string,
    items: string,
    variants: string,
    arms: string,
    iter_expr: string,
    ret_type: string,
    target: string,
    trait_name: string,
    methods: string
}

// ── Global counters ──────────────────────────────────────────
let mut m990_pure_fold_calls = 0
let mut m990_pure_fold_skips = 0

// ── AST constructors ─────────────────────────────────────────

fn make_int_lit(n) {
    return AstNode {
        kind: "IntLit", name: "", value: to_string(n), op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_float_lit(n) {
    return AstNode {
        kind: "FloatLit", name: "", value: to_string(n), op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_bool_lit_from_bool(b) {
    let v = "false"
    if b { v = "true" }
    return AstNode {
        kind: "BoolLit", name: "", value: v, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_string_lit(s) {
    return AstNode {
        kind: "StringLit", name: "", value: s, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_ident(name) {
    return AstNode {
        kind: "Ident", name: name, value: "", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_binop(op, left, right) {
    return AstNode {
        kind: "BinOp", name: "", value: "", op: op,
        left: left, right: right, cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_call_node(callee_name, call_args) {
    return AstNode {
        kind: "Call", name: "", value: "", op: "",
        left: make_ident(callee_name), right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: call_args, fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_param(name) {
    return AstNode {
        kind: "Param", name: name, value: "", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_return_expr(expr) {
    return AstNode {
        kind: "ReturnStmt", name: "", value: "", op: "",
        left: expr, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn make_let_stmt(name, expr) {
    return AstNode {
        kind: "LetStmt", name: name, value: "", op: "",
        left: expr, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

// ── Pure fold logic ──────────────────────────────────────────

fn pf_is_const(node) {
    if type_of(node) == "string" { return false }
    if node.kind == "IntLit" { return true }
    if node.kind == "FloatLit" { return true }
    if node.kind == "BoolLit" { return true }
    if node.kind == "StringLit" { return true }
    return false
}

fn pf_const_val(node) {
    if node.kind == "IntLit" { return parse_int(node.value) }
    if node.kind == "FloatLit" { return parse_float(node.value) }
    if node.kind == "BoolLit" {
        if node.value == "true" { return true }
        return false
    }
    if node.kind == "StringLit" { return node.value }
    return ""
}

fn pf_val_to_ast(val) {
    if type_of(val) == "int" {
        return make_int_lit(val)
    }
    if type_of(val) == "bool" {
        return make_bool_lit_from_bool(val)
    }
    if type_of(val) == "string" {
        return make_string_lit(val)
    }
    if type_of(val) == "float" {
        return make_float_lit(val)
    }
    return make_string_lit(to_string(val))
}

fn pf_eval_expr(node) {
    if type_of(node) == "string" { return "" }
    if pf_is_const(node) { return pf_const_val(node) }
    if node.kind == "BinOp" {
        let l = pf_eval_expr(node.left)
        let r = pf_eval_expr(node.right)
        if node.op == "+" {
            if type_of(l) == "string" && type_of(r) == "string" { return l + r }
            return l + r
        }
        if node.op == "-" { return l - r }
        if node.op == "*" { return l * r }
        if node.op == "/" { return l / r }
        if node.op == "%" { return l % r }
        if node.op == "==" { return l == r }
        if node.op == "!=" { return l != r }
        if node.op == "<" { return l < r }
        if node.op == ">" { return l > r }
        if node.op == "<=" { return l <= r }
        if node.op == ">=" { return l >= r }
        if node.op == "&&" { return l && r }
        if node.op == "||" { return l || r }
    }
    return ""
}

fn pf_subst_expr(node, param_names, arg_nodes) {
    if type_of(node) == "string" { return node }
    if node.kind == "Ident" {
        let mut i = 0
        while i < len(param_names) {
            if node.name == param_names[i] { return arg_nodes[i] }
            i = i + 1
        }
        return node
    }
    if node.kind == "BinOp" {
        let new_left = pf_subst_expr(node.left, param_names, arg_nodes)
        let new_right = pf_subst_expr(node.right, param_names, arg_nodes)
        return make_binop(node.op, new_left, new_right)
    }
    return node
}

fn pf_eval_body(body, param_names, arg_nodes) {
    if type_of(body) != "array" { return "" }
    if len(body) == 0 { return "" }
    // Build environment: param_names -> evaluated arg values
    let mut env_names = []
    let mut env_nodes = []
    let mut i = 0
    while i < len(param_names) {
        env_names.push(param_names[i])
        env_nodes.push(arg_nodes[i])
        i = i + 1
    }
    let mut j = 0
    while j < len(body) {
        let stmt = body[j]
        if stmt.kind == "ReturnStmt" {
            let subst = pf_subst_expr(stmt.left, env_names, env_nodes)
            return pf_eval_expr(subst)
        }
        if stmt.kind == "LetStmt" {
            let subst_val = pf_subst_expr(stmt.left, env_names, env_nodes)
            let evaled = pf_eval_expr(subst_val)
            env_names.push(stmt.name)
            env_nodes.push(pf_val_to_ast(evaled))
        }
        j = j + 1
    }
    return ""
}

fn has_pure_attr(attrs_str) {
    if attrs_str == "pure" { return true }
    if type_of(attrs_str) != "string" { return false }
    let parts = attrs_str.split(",")
    let mut i = 0
    while i < len(parts) {
        if parts[i] == "pure" { return true }
        i = i + 1
    }
    return false
}

fn anp_pure_fold_call(call_node, fn_names, fn_nodes) {
    if call_node.kind != "Call" { return call_node }
    let callee = call_node.left
    if type_of(callee) == "string" { return call_node }
    if callee.kind != "Ident" { return call_node }
    let fname = callee.name
    // Find function in table
    let mut idx = -1
    let mut k = 0
    while k < len(fn_names) {
        if fn_names[k] == fname { idx = k }
        k = k + 1
    }
    if idx == -1 { return call_node }
    let fn_node = fn_nodes[idx]
    // Must be @pure
    if !has_pure_attr(fn_node.value) {
        return call_node
    }
    // Check arity
    let call_args = call_node.args
    let params = fn_node.params
    if type_of(call_args) != "array" { return call_node }
    if type_of(params) != "array" { return call_node }
    if len(call_args) != len(params) {
        m990_pure_fold_skips = m990_pure_fold_skips + 1
        return call_node
    }
    // Check all args are const
    let mut a = 0
    while a < len(call_args) {
        if !pf_is_const(call_args[a]) {
            m990_pure_fold_skips = m990_pure_fold_skips + 1
            return call_node
        }
        a = a + 1
    }
    // Extract param names
    let mut pnames = []
    let mut p = 0
    while p < len(params) {
        pnames.push(params[p].name)
        p = p + 1
    }
    // Evaluate
    let result = pf_eval_body(fn_node.body, pnames, call_args)
    m990_pure_fold_calls = m990_pure_fold_calls + 1
    return pf_val_to_ast(result)
}

fn pf_walk_expr(node, fn_names, fn_nodes) {
    if type_of(node) == "string" { return node }
    if node.kind == "Call" {
        // First walk args recursively
        let mut new_args = []
        if type_of(node.args) == "array" {
            let mut i = 0
            while i < len(node.args) {
                new_args.push(pf_walk_expr(node.args[i], fn_names, fn_nodes))
                i = i + 1
            }
        }
        let new_call = AstNode {
            kind: "Call", name: node.name, value: node.value, op: node.op,
            left: node.left, right: node.right, cond: node.cond,
            then_body: node.then_body, else_body: node.else_body,
            params: node.params, body: node.body, args: new_args,
            fields: node.fields, items: node.items,
            variants: node.variants, arms: node.arms,
            iter_expr: node.iter_expr, ret_type: node.ret_type,
            target: node.target, trait_name: node.trait_name,
            methods: node.methods
        }
        return anp_pure_fold_call(new_call, fn_names, fn_nodes)
    }
    return node
}

fn pf_walk_body(body, fn_names, fn_nodes) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let mut i = 0
    while i < len(body) {
        let stmt = body[i]
        if stmt.kind == "LetStmt" {
            let new_expr = pf_walk_expr(stmt.left, fn_names, fn_nodes)
            out.push(make_let_stmt(stmt.name, new_expr))
        } else {
            if stmt.kind == "ReturnStmt" {
                let new_expr = pf_walk_expr(stmt.left, fn_names, fn_nodes)
                out.push(make_return_expr(new_expr))
            } else {
                out.push(stmt)
            }
        }
        i = i + 1
    }
    return out
}

fn anp_pure_fold_pass(ast) {
    if type_of(ast) != "array" { return ast }
    // First pass: collect @pure functions
    let mut fn_names = []
    let mut fn_nodes = []
    let mut i = 0
    while i < len(ast) {
        let node = ast[i]
        if type_of(node) != "string" && node.kind == "FnDecl" {
            if has_pure_attr(node.value) {
                fn_names.push(node.name)
                fn_nodes.push(node)
            }
        }
        i = i + 1
    }
    // Second pass: walk all function bodies
    m990_pure_fold_calls = 0
    m990_pure_fold_skips = 0
    let mut out = []
    let mut j = 0
    while j < len(ast) {
        let node = ast[j]
        if type_of(node) != "string" && node.kind == "FnDecl" {
            let new_body = pf_walk_body(node.body, fn_names, fn_nodes)
            let new_fn = AstNode {
                kind: "FnDecl", name: node.name, value: node.value, op: node.op,
                left: node.left, right: node.right, cond: node.cond,
                then_body: node.then_body, else_body: node.else_body,
                params: node.params, body: new_body, args: node.args,
                fields: node.fields, items: node.items,
                variants: node.variants, arms: node.arms,
                iter_expr: node.iter_expr, ret_type: node.ret_type,
                target: node.target, trait_name: node.trait_name,
                methods: node.methods
            }
            out.push(new_fn)
        } else {
            out.push(node)
        }
        j = j + 1
    }
    return out
}

// ── Helpers ──────────────────────────────────────────────────

fn parse_int(s) {
    let chars = s.chars()
    let n = len(chars)
    if n == 0 { return 0 }
    let mut i = 0
    let mut result = 0
    let mut neg = false
    if to_string(chars[0]) == "-" {
        neg = true
        i = 1
    }
    while i < n {
        let c = to_string(chars[i])
        let mut d = 0
        if c == "0" { d = 0 }
        if c == "1" { d = 1 }
        if c == "2" { d = 2 }
        if c == "3" { d = 3 }
        if c == "4" { d = 4 }
        if c == "5" { d = 5 }
        if c == "6" { d = 6 }
        if c == "7" { d = 7 }
        if c == "8" { d = 8 }
        if c == "9" { d = 9 }
        result = result * 10 + d
        i = i + 1
    }
    if neg { return 0 - result }
    return result
}

fn parse_float(s) {
    // Simple: just return the string-to-float via runtime
    return 0.0
}

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

