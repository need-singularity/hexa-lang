// ── Section 1: pf_is_const ──────────────────────────────────

println("--- pf_is_const ---")

let int_node = make_int_lit(42)
let float_node = make_float_lit(3.14)
let bool_node = make_bool_lit_from_bool(true)
let str_node = make_string_lit("hello")
let ident_node = make_ident("x")

check("T01 IntLit is const", pf_is_const(int_node) == true)
check("T02 FloatLit is const", pf_is_const(float_node) == true)
check("T03 BoolLit is const", pf_is_const(bool_node) == true)
check("T04 StringLit is const", pf_is_const(str_node) == true)
check("T05 Ident is not const", pf_is_const(ident_node) == false)
check("T06 string is not const", pf_is_const("foo") == false)

// ── Section 2: pf_const_val ─────────────────────────────────

println("")
println("--- pf_const_val ---")

check("T07 IntLit val", pf_const_val(int_node) == 42)
check("T08 BoolLit val true", pf_const_val(bool_node) == true)
check("T09 BoolLit val false", pf_const_val(make_bool_lit_from_bool(false)) == false)
check("T10 StringLit val", pf_const_val(str_node) == "hello")

// ── Section 3: pf_val_to_ast ────────────────────────────────

println("")
println("--- pf_val_to_ast ---")

let ast_int = pf_val_to_ast(99)
check("T11 val_to_ast int kind", ast_int.kind == "IntLit")
check("T12 val_to_ast int value", ast_int.value == "99")

let ast_bool = pf_val_to_ast(true)
check("T13 val_to_ast bool kind", ast_bool.kind == "BoolLit")
check("T14 val_to_ast bool value", ast_bool.value == "true")

let ast_str = pf_val_to_ast("world")
check("T15 val_to_ast string kind", ast_str.kind == "StringLit")
check("T16 val_to_ast string value", ast_str.value == "world")

// ── Section 4: pf_eval_expr — arithmetic ────────────────────

println("")
println("--- pf_eval_expr arithmetic ---")

let add_expr = make_binop("+", make_int_lit(3), make_int_lit(4))
check("T17 eval 3+4", pf_eval_expr(add_expr) == 7)

let mul_expr = make_binop("*", make_int_lit(5), make_int_lit(6))
check("T18 eval 5*6", pf_eval_expr(mul_expr) == 30)

let sub_expr = make_binop("-", make_int_lit(10), make_int_lit(3))
check("T19 eval 10-3", pf_eval_expr(sub_expr) == 7)

let div_expr = make_binop("/", make_int_lit(20), make_int_lit(4))
check("T20 eval 20/4", pf_eval_expr(div_expr) == 5)

let mod_expr = make_binop("%", make_int_lit(17), make_int_lit(5))
check("T21 eval 17%5", pf_eval_expr(mod_expr) == 2)

// ── Section 5: pf_eval_expr — comparisons ───────────────────

println("")
println("--- pf_eval_expr comparisons ---")

let eq_expr = make_binop("==", make_int_lit(5), make_int_lit(5))
check("T22 eval 5==5", pf_eval_expr(eq_expr) == true)

let ne_expr = make_binop("!=", make_int_lit(3), make_int_lit(4))
check("T23 eval 3!=4", pf_eval_expr(ne_expr) == true)

let lt_expr = make_binop("<", make_int_lit(2), make_int_lit(9))
check("T24 eval 2<9", pf_eval_expr(lt_expr) == true)

let ge_expr = make_binop(">=", make_int_lit(7), make_int_lit(7))
check("T25 eval 7>=7", pf_eval_expr(ge_expr) == true)

// ── Section 6: pf_eval_expr — bool logic ────────────────────

println("")
println("--- pf_eval_expr bool ---")

let and_expr = make_binop("&&", make_bool_lit_from_bool(true), make_bool_lit_from_bool(false))
check("T26 eval true&&false", pf_eval_expr(and_expr) == false)

let or_expr = make_binop("||", make_bool_lit_from_bool(false), make_bool_lit_from_bool(true))
check("T27 eval false||true", pf_eval_expr(or_expr) == true)

// ── Section 7: pf_eval_expr — string concat ─────────────────

println("")
println("--- pf_eval_expr string ---")

let cat_expr = make_binop("+", make_string_lit("hel"), make_string_lit("lo"))
check("T28 eval str concat", pf_eval_expr(cat_expr) == "hello")

let str_eq = make_binop("==", make_string_lit("a"), make_string_lit("a"))
check("T29 eval str eq", pf_eval_expr(str_eq) == true)

// ── Section 8: pf_subst_expr ────────────────────────────────

println("")
println("--- pf_subst_expr ---")

let x_ident = make_ident("x")
let subst_result = pf_subst_expr(x_ident, ["x"], [make_int_lit(10)])
check("T30 subst ident->lit", subst_result.kind == "IntLit" && subst_result.value == "10")

let binop_with_idents = make_binop("+", make_ident("a"), make_ident("b"))
let subst2 = pf_subst_expr(binop_with_idents, ["a", "b"], [make_int_lit(3), make_int_lit(4)])
let subst2_val = pf_eval_expr(subst2)
check("T31 subst binop a+b -> 3+4", subst2_val == 7)

// ── Section 9: pf_eval_body — simple return ─────────────────

println("")
println("--- pf_eval_body ---")

// Body: [return a + b]
let body_simple = [
    make_return_expr(make_binop("+", make_ident("a"), make_ident("b")))
]
let r1 = pf_eval_body(body_simple, ["a", "b"], [make_int_lit(10), make_int_lit(20)])
check("T32 eval body return a+b", r1 == 30)

// Body: [let c = a * b; return c + 1]
let body_let_chain = [
    make_let_stmt("c", make_binop("*", make_ident("a"), make_ident("b"))),
    make_return_expr(make_binop("+", make_ident("c"), make_int_lit(1)))
]
let r2 = pf_eval_body(body_let_chain, ["a", "b"], [make_int_lit(3), make_int_lit(4)])
check("T33 eval body let-chain", r2 == 13)

// Body: empty -> ""
let r3 = pf_eval_body([], ["x"], [make_int_lit(1)])
check("T34 eval empty body", r3 == "")

// ── Section 10: anp_pure_fold_call ──────────────────────────

println("")
println("--- anp_pure_fold_call ---")

// Build a @pure fn: @pure fn add(a, b) { return a + b }
let pure_add = AstNode {
    kind: "FnDecl", name: "add", value: "pure", op: "",
    left: "", right: "", cond: "", then_body: "", else_body: "",
    params: [make_param("a"), make_param("b")],
    body: [make_return_expr(make_binop("+", make_ident("a"), make_ident("b")))],
    args: "", fields: "", items: "",
    variants: "", arms: "", iter_expr: "", ret_type: "",
    target: "", trait_name: "", methods: ""
}

let ft_names = ["add"]
let ft_nodes = [pure_add]

// Call: add(3, 4) -> should fold to 7
m990_pure_fold_calls = 0
m990_pure_fold_skips = 0
let call_add = make_call_node("add", [make_int_lit(3), make_int_lit(4)])
let folded = anp_pure_fold_call(call_add, ft_names, ft_nodes)
check("T35 fold add(3,4) kind", folded.kind == "IntLit")
check("T36 fold add(3,4) value", folded.value == "7")
check("T37 fold counter incremented", m990_pure_fold_calls == 1)

// Call with non-const arg -> should NOT fold
m990_pure_fold_calls = 0
m990_pure_fold_skips = 0
let call_var = make_call_node("add", [make_ident("x"), make_int_lit(4)])
let not_folded = anp_pure_fold_call(call_var, ft_names, ft_nodes)
check("T38 non-const arg not folded", not_folded.kind == "Call")
check("T39 skip counter incremented", m990_pure_fold_skips == 1)

// ── Section 11: non-pure fn not folded ──────────────────────

println("")
println("--- non-pure fn ---")

let impure_fn = AstNode {
    kind: "FnDecl", name: "impure_add", value: "inline", op: "",
    left: "", right: "", cond: "", then_body: "", else_body: "",
    params: [make_param("a"), make_param("b")],
    body: [make_return_expr(make_binop("+", make_ident("a"), make_ident("b")))],
    args: "", fields: "", items: "",
    variants: "", arms: "", iter_expr: "", ret_type: "",
    target: "", trait_name: "", methods: ""
