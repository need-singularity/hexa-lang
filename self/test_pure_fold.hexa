// main's body let r = ... should now be let r = 10
let main_result = result_ast[1]
let let_stmt = main_result.body[0]
check("T42 pass: let stmt preserved", let_stmt.kind == "LetStmt")
check("T43 pass: folded to IntLit", let_stmt.left.kind == "IntLit")
check("T44 pass: folded value is 10", let_stmt.left.value == "10")
check("T45 pass: fold counter", m990_pure_fold_calls == 1)

