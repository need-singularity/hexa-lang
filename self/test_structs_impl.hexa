// ═══════════════════════════════════════════════════════════
//  test_structs_impl.hexa — Struct & Impl Method Tests
//  Tests: struct creation, field access, field update, impl methods,
//         self parameter, struct in array, nested structs, builder pattern
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA Struct & Impl Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Basic struct creation & field access ───────────────

println("--- Basic Struct ---")

struct Point {
    x: int,
    y: int
}

let p1 = Point { x: 3, y: 4 }
check("struct field x", p1.x, 3)
check("struct field y", p1.y, 4)

let p2 = Point { x: 0, y: 0 }
check("origin x", p2.x, 0)
check("origin y", p2.y, 0)

// ── 2. Struct with different field types ──────────────────

println("")
println("--- Multi-Type Struct ---")

struct Person {
    name: string,
    age: int,
    active: bool
}

let alice = Person { name: "Alice", age: 30, active: true }
check("person name", alice.name, "Alice")
check("person age", alice.age, 30)
check("person active", alice.active, true)

// ── 3. Struct in expressions ──────────────────────────────

println("")
println("--- Struct in Expressions ---")

check("field arithmetic", p1.x + p1.y, 7)
check("field multiply", p1.x * p1.y, 12)
check("field comparison", p1.x < p1.y, true)

fn distance_sq(a, b) {
    let dx = a.x - b.x
    let dy = a.y - b.y
    return dx * dx + dy * dy
}
check("distance_sq", distance_sq(p2, p1), 25)

// ── 4. Impl methods ──────────────────────────────────────

println("")
println("--- Impl Methods ---")

struct Rect {
    w: int,
    h: int
}

impl Rect {
    fn area(self) {
        return self.w * self.h
    }

    fn perimeter(self) {
        return 2 * (self.w + self.h)
    }

    fn is_square(self) {
        return self.w == self.h
    }
}

let r1 = Rect { w: 5, h: 3 }
check("rect area", r1.area(), 15)
check("rect perimeter", r1.perimeter(), 16)
check("rect is_square false", r1.is_square(), false)

let r2 = Rect { w: 4, h: 4 }
check("square is_square", r2.is_square(), true)

// ── 5. Point with impl ───────────────────────────────────

println("")
println("--- Point Methods ---")

impl Point {
    fn distance_sq(self, other) {
        let dx = self.x - other.x
        let dy = self.y - other.y
        return dx * dx + dy * dy
    }

    fn manhattan(self, other) {
        return abs(self.x - other.x) + abs(self.y - other.y)
    }

    fn to_str(self) {
        return "(" + to_string(self.x) + ", " + to_string(self.y) + ")"
    }
}

let a = Point { x: 0, y: 0 }
let b = Point { x: 3, y: 4 }
check("point dist_sq", a.distance_sq(b), 25)
check("point manhattan", a.manhattan(b), 7)
check("point to_str", b.to_str(), "(3, 4)")

// ── 6. Struct array ───────────────────────────────────────

println("")
println("--- Struct Arrays ---")

let mut points = []
points = points.push(Point { x: 1, y: 1 })
points = points.push(Point { x: 2, y: 4 })
points = points.push(Point { x: 3, y: 9 })

check("points len", len(points), 3)
check("points[0].x", points[0].x, 1)
check("points[1].y", points[1].y, 4)
check("points[2].x", points[2].x, 3)

// Sum all x values
let mut x_sum = 0
for p in points {
    x_sum = x_sum + p.x
}
check("sum of x", x_sum, 6)

// ── 7. Struct as function return ──────────────────────────

println("")
println("--- Struct Return ---")

fn make_point(x, y) {
    return Point { x: x, y: y }
}

let p3 = make_point(10, 20)
check("make_point x", p3.x, 10)
check("make_point y", p3.y, 20)

fn midpoint(a, b) {
    return Point {
        x: (a.x + b.x) / 2,
        y: (a.y + b.y) / 2
    }
}

let mid = midpoint(Point { x: 0, y: 0 }, Point { x: 10, y: 20 })
check("midpoint x", mid.x, 5)
check("midpoint y", mid.y, 10)

// ── 8. Counter pattern with struct ────────────────────────

println("")
println("--- Counter Pattern ---")

struct Counter {
    value: int,
    step: int
}

impl Counter {
    fn current(self) {
        return self.value
    }
}

fn counter_new(step) {
    return Counter { value: 0, step: step }
}

fn counter_inc(c) {
    return Counter { value: c.value + c.step, step: c.step }
}

let mut c = counter_new(3)
check("counter init", c.current(), 0)
c = counter_inc(c)
check("counter +3", c.current(), 3)
c = counter_inc(c)
check("counter +6", c.current(), 6)
c = counter_inc(c)
check("counter +9", c.current(), 9)

// ── 9. Linked list pattern ────────────────────────────────

println("")
println("--- Stack Pattern ---")

// Simple stack using array
struct Stack {
    items: array
}

impl Stack {
    fn size(self) {
        return len(self.items)
    }

    fn peek(self) {
        return self.items[len(self.items) - 1]
    }
}

fn stack_new() {
    return Stack { items: [] }
}

fn stack_push(s, val) {
    return Stack { items: s.items.push(val) }
}

let mut stk = stack_new()
check("stack empty", stk.size(), 0)
stk = stack_push(stk, 10)
stk = stack_push(stk, 20)
stk = stack_push(stk, 30)
check("stack size 3", stk.size(), 3)
check("stack peek", stk.peek(), 30)

// ── 10. Complex struct composition ────────────────────────

println("")
println("--- Struct Composition ---")

struct Color {
    r: int,
    g: int,
    b: int
}

struct Shape {
    name: string,
    color: string,
    sides: int
}

impl Shape {
    fn describe(self) {
        return self.color + " " + self.name + " (" + to_string(self.sides) + " sides)"
    }
}

let triangle = Shape { name: "triangle", color: "red", sides: 3 }
let square = Shape { name: "square", color: "blue", sides: 4 }

check("triangle describe", triangle.describe(), "red triangle (3 sides)")
check("square describe", square.describe(), "blue square (4 sides)")

