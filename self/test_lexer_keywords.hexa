// self/test_lexer_keywords.hexa — Verify all 56 keywords are recognized by the self-hosted lexer
// Tests is_keyword() for every keyword in the canonical 56-keyword set (sigma*tau+sopfr+3)

let mut pass = 0
let mut fail = 0

fn check(word, expected) {
    // is_keyword should return true for all 56 keywords
    let result = is_keyword(word)
    if result == expected {
        pass = pass + 1
        println("[PASS] is_keyword(\"" + word + "\") = " + to_string(result))
    } else {
        fail = fail + 1
        println("[FAIL] is_keyword(\"" + word + "\") expected " + to_string(expected) + " got " + to_string(result))
    }
}

// ── is_keyword() — inline replica from self/lexer.hexa ──
// We replicate is_keyword here so we can test it standalone without imports.
fn is_keyword(word) {
    if word == "if" { return true }
    if word == "else" { return true }
    if word == "match" { return true }
    if word == "for" { return true }
    if word == "while" { return true }
    if word == "loop" { return true }
    if word == "type" { return true }
    if word == "struct" { return true }
    if word == "enum" { return true }
    if word == "trait" { return true }
    if word == "impl" { return true }
    if word == "fn" { return true }
    if word == "return" { return true }
    if word == "yield" { return true }
    if word == "async" { return true }
    if word == "await" { return true }
    if word == "let" { return true }
    if word == "mut" { return true }
    if word == "const" { return true }
    if word == "static" { return true }
    if word == "mod" { return true }
    if word == "use" { return true }
    if word == "pub" { return true }
    if word == "crate" { return true }
    if word == "own" { return true }
    if word == "borrow" { return true }
    if word == "move" { return true }
    if word == "drop" { return true }
    if word == "spawn" { return true }
    if word == "channel" { return true }
    if word == "select" { return true }
    if word == "atomic" { return true }
    if word == "effect" { return true }
    if word == "handle" { return true }
    if word == "resume" { return true }
    if word == "pure" { return true }
    if word == "proof" { return true }
    if word == "assert" { return true }
    if word == "invariant" { return true }
    if word == "theorem" { return true }
    if word == "macro" { return true }
    if word == "derive" { return true }
    if word == "where" { return true }
    if word == "comptime" { return true }
    if word == "try" { return true }
    if word == "catch" { return true }
    if word == "throw" { return true }
    if word == "panic" { return true }
    if word == "recover" { return true }
    if word == "intent" { return true }
    if word == "generate" { return true }
    if word == "verify" { return true }
    if word == "optimize" { return true }
    if word == "extern" { return true }
    if word == "break" { return true }
    if word == "continue" { return true }
    if word == "dyn" { return true }
    if word == "scope" { return true }
    return false
}

println("══════════════════════════════════════════════════")
println("  LEXER KEYWORD TEST — 56 keywords + negatives")
println("══════════════════════════════════════════════════")

// GROUP 1: Control Flow (6)
check("if", true)
check("else", true)
check("match", true)
check("for", true)
check("while", true)
check("loop", true)

// GROUP 2: Type Declarations (5)
check("type", true)
check("struct", true)
check("enum", true)
check("trait", true)
check("impl", true)

// GROUP 3: Functions (5)
check("fn", true)
check("return", true)
check("yield", true)
check("async", true)
check("await", true)

// GROUP 4: Variable Bindings (4)
check("let", true)
check("mut", true)
check("const", true)
check("static", true)

// GROUP 5: Modules (4)
check("mod", true)
check("use", true)
check("pub", true)
check("crate", true)

// GROUP 6: Ownership (4)
check("own", true)
check("borrow", true)
check("move", true)
check("drop", true)

// GROUP 7: Concurrency (4)
check("spawn", true)
check("channel", true)
check("select", true)
check("atomic", true)

// GROUP 8: Effects (4)
check("effect", true)
check("handle", true)
check("resume", true)
check("pure", true)

// GROUP 9: Verification (4)
check("proof", true)
check("assert", true)
check("invariant", true)
check("theorem", true)

// GROUP 10: Metaprogramming (4)
check("macro", true)
check("derive", true)
check("where", true)
check("comptime", true)

// GROUP 11: Error Handling (5)
check("try", true)
check("catch", true)
check("throw", true)
check("panic", true)
check("recover", true)

// GROUP 12: AI-Native (4)
check("intent", true)
check("generate", true)
check("verify", true)
check("optimize", true)

// GROUP 13: Additional (+3 from sigma*tau+sopfr)
check("break", true)
check("continue", true)
check("extern", true)

// GROUP 14: New keywords (dyn, scope)
check("dyn", true)
check("scope", true)

// ── Negative tests: non-keywords must return false ──
println("")
println("── Negative tests ──")
check("foo", false)
check("bar", false)
check("hello", false)
check("main", false)
check("print", false)
check("true", false)
check("false", false)
check("int", false)
check("string", false)

// ── Count check ──
let keyword_count = 58  // 56 positive + 2 (dyn, scope make 58 total positive checks)
// Actually: 56 keywords tested positive = 56 checks + 9 negative = 65 total

println("")
println("══════════════════════════════════════════════════")
println("  LEXER KEYWORD TEST SUMMARY")
println("  PASS: " + to_string(pass))
println("  FAIL: " + to_string(fail))
if fail == 0 {
    println("  STATUS: ALL PASS")
} else {
    println("  STATUS: FAILURES DETECTED")
}
println("══════════════════════════════════════════════════")
