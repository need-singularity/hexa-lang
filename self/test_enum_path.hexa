// ═══════════════════════════════════════════════════════════
//  self/test_enum_path.hexa
//  P7-6 step 3f — payload-free EnumPath lowering (ROI #145)
//
//  Scope:
//    Verifies the module-level enum registry (module_add_enum /
//    module_find_variant_idx) used by tool/native_build.hexa
//    nb_lower_expr EnumPath branch and Pass 1 EnumDecl walker.
//
//    Exercises the same entry points the native-build Pass 1 calls
//    (module_add_enum), then asserts that the tag returned by
//    module_find_variant_idx is the positional index. This is exactly
//    what nb_lower_expr EnumPath emits as `bld_const_i64(tag)`.
//
//    A second set of asserts pokes the exact shape the parser produces
//    for EnumDecl nodes — node.variants is an array of EnumVariant
//    records each with a `name` field — so the Pass 1 walker's
//    `vnames.push(var_ast[vi].name)` stays honest if the AST shape
//    drifts.
//
//  Run:
//    hexa run self/test_enum_path.hexa
//
//  Expected: "ALL PASS — N/N".
//
//  NOTE: We do NOT link the real IrModule struct here — the builder
//  module wires in deep module dependencies that would force a full
//  stage0-linked test binary. Instead we reconstruct the same parallel
//  arrays the registry uses (enum_names + enum_variants) and verify
//  the exact algorithm that module_add_enum / module_find_variant_idx
//  implement. This mirrors the shape of tests/native_build/cov_*.hexa.
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check_true(name: string, cond: bool) {
    if cond {
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn check_int_eq(name: string, got: int, expected: int) {
    if got == expected {
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " expected=" + to_string(expected) + " got=" + to_string(got))
        fail_count = fail_count + 1
    }
}

// ── Mirror of IrModule enum registry slice ──────────────────
// Parallel arrays: enum_names[i] ↔ enum_variants[i]. Same shape as
// self/ir/instr.hexa IrModule + module_add_enum / module_find_variant_idx.
struct EnumReg {
    names:    array,
    variants: array
}

fn mk_reg() -> EnumReg {
    return EnumReg { names: [], variants: [] }
}

fn reg_add(r: EnumReg, enum_name: string, variant_names: array) -> EnumReg {
    // Idempotent — overwrite on re-register. Matches module_add_enum.
    let mut i = 0
    let mut new_names = []
    let mut new_vars  = []
    let mut found = false
    while i < len(r.names) {
        if r.names[i] == enum_name {
            new_names = new_names.push(r.names[i])
            new_vars  = new_vars.push(variant_names)
            found = true
        } else {
            new_names = new_names.push(r.names[i])
            new_vars  = new_vars.push(r.variants[i])
        }
        i = i + 1
    }
    if !found {
        new_names = new_names.push(enum_name)
        new_vars  = new_vars.push(variant_names)
    }
    return EnumReg { names: new_names, variants: new_vars }
}

fn reg_find_variant_idx(r: EnumReg, enum_name: string, variant_name: string) -> int {
    let mut i = 0
    while i < len(r.names) {
        if r.names[i] == enum_name {
            let vs = r.variants[i]
            let mut j = 0
            while j < len(vs) {
                if vs[j] == variant_name {
                    return j
                }
                j = j + 1
            }
            return -1
        }
        i = i + 1
    }
    return -1
}

// ── AST shape probes ────────────────────────────────────────
// Mirrors the EnumDecl / EnumVariant records parser.hexa emits
// (lines 1547/1561). Pass 1 reads node.variants[vi].name — these
// asserts pin the shape.
fn mk_enum_variant(name: string) {
    return #{
        "kind": "EnumVariant", "name": name, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

fn mk_enum_decl(name: string, variants: array) {
    return #{
        "kind": "EnumDecl", "name": name, "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": variants, "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

fn mk_enum_path(enum_name: string, variant: string) {
    return #{
        "kind": "EnumPath", "name": enum_name, "value": variant, "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// ═══════════════════════════════════════════════════════════
//  Tests
// ═══════════════════════════════════════════════════════════

println("═══════════════════════════════════════════════════════")
println("  P7-6 step 3f — payload-free EnumPath lowering")
println("═══════════════════════════════════════════════════════")

// ── T1 basic add + lookup ─────────────────────────────────
let mut r1 = mk_reg()
r1 = reg_add(r1, "Color", ["Red", "Green", "Blue"])
check_int_eq("Color::Red tag", reg_find_variant_idx(r1, "Color", "Red"), 0)
check_int_eq("Color::Green tag", reg_find_variant_idx(r1, "Color", "Green"), 1)
check_int_eq("Color::Blue tag", reg_find_variant_idx(r1, "Color", "Blue"), 2)

// ── T2 miss → -1 (nb_lower_expr returns -1 for unknown enum) ──
check_int_eq("Color::Unknown tag", reg_find_variant_idx(r1, "Color", "Unknown"), -1)
check_int_eq("Unknown enum tag", reg_find_variant_idx(r1, "Shape", "Circle"), -1)

// ── T3 multi-enum independence ────────────────────────────
r1 = reg_add(r1, "Shape", ["Circle", "Square", "Triangle", "Hexagon"])
check_int_eq("Color::Red after Shape add", reg_find_variant_idx(r1, "Color", "Red"), 0)
check_int_eq("Shape::Circle tag", reg_find_variant_idx(r1, "Shape", "Circle"), 0)
check_int_eq("Shape::Hexagon tag", reg_find_variant_idx(r1, "Shape", "Hexagon"), 3)

// ── T4 idempotent re-register ─────────────────────────────
r1 = reg_add(r1, "Color", ["Red", "Green", "Blue", "Alpha"])  // overwrite
check_int_eq("Color::Alpha tag (after overwrite)", reg_find_variant_idx(r1, "Color", "Alpha"), 3)
check_int_eq("Color::Red tag (after overwrite)", reg_find_variant_idx(r1, "Color", "Red"), 0)
check_true("Color still present once", len(r1.names) == 2)

// ── T5 Pass 1 AST walk simulation ─────────────────────────
// Exact shape native_build.hexa Pass 1 walks:
//   node.kind == "EnumDecl", then node.variants[vi].name
let decl = mk_enum_decl("Result", [
    mk_enum_variant("Ok"),
    mk_enum_variant("Err"),
    mk_enum_variant("Pending")
])
check_true("EnumDecl kind", decl.kind == "EnumDecl")
check_true("EnumDecl name", decl.name == "Result")
let vs = decl.variants
check_int_eq("EnumDecl variant count", len(vs), 3)
check_true("variant[0] kind", vs[0].kind == "EnumVariant")
check_true("variant[1].name == Err", vs[1].name == "Err")

// Simulate the Pass 1 loop (native_build.hexa:1498-1511 equivalent)
let mut r2 = mk_reg()
let mut collected = []
let mut vi2 = 0
while vi2 < len(vs) {
    collected = collected.push(vs[vi2].name)
    vi2 = vi2 + 1
}
r2 = reg_add(r2, decl.name, collected)
check_int_eq("Result::Ok tag (Pass 1 sim)", reg_find_variant_idx(r2, "Result", "Ok"), 0)
check_int_eq("Result::Err tag (Pass 1 sim)", reg_find_variant_idx(r2, "Result", "Err"), 1)
check_int_eq("Result::Pending tag (Pass 1 sim)", reg_find_variant_idx(r2, "Result", "Pending"), 2)

// ── T6 EnumPath shape invariants ──────────────────────────
// Pin the shape nb_lower_expr reads (e.name + e.value).
let ep = mk_enum_path("Result", "Ok")
check_true("EnumPath kind", ep.kind == "EnumPath")
check_true("EnumPath.name = enum type", ep.name == "Result")
check_true("EnumPath.value = variant name", ep.value == "Ok")
// Payload-free → e.left is "" and e.items is ""
check_true("EnumPath.left empty (payload-free)", ep.left == "")
check_true("EnumPath.items empty (payload-free)", ep.items == "")

// ── T7 match-arm equality dispatch (simulated) ────────────
// With tag in hand, the MVP match arm emits cmp_eq(scrut_vid, pv).
// Here we verify the tag values match when the scrutinee was built
// from the same constructor — i.e. Result::Ok vs pattern Result::Ok.
let scrut_tag = reg_find_variant_idx(r2, "Result", "Ok")
let patt_tag  = reg_find_variant_idx(r2, "Result", "Ok")
check_true("match arm equality: Ok == Ok", scrut_tag == patt_tag)
check_true("match arm inequality: Ok != Err",
           reg_find_variant_idx(r2, "Result", "Ok") !=
           reg_find_variant_idx(r2, "Result", "Err"))

// ═══════════════════════════════════════════════════════════
println("═══════════════════════════════════════════════════════")
if fail_count == 0 {
    println("ALL PASS — " + to_string(pass_count) + "/" + to_string(pass_count))
} else {
    println("FAIL — " + to_string(pass_count) + " pass / " + to_string(fail_count) + " fail")
    exit(1)
}
