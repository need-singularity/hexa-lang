// self/loop_unroll.hexa — HEXA loop unrolling ported from src/loop_unroll.rs
// Detects small constant-bound for loops and unrolls them at the AST level.
// Only unrolls loops where:
// - The iterator is a constant range (e.g., 0..4, 1..=7)
// - The range has fewer than MAX_UNROLL_ITERATIONS iterations
// - The loop body does not contain break/return/throw

let MAX_UNROLL_ITERATIONS = 8

// ── Result ─────────────────────────────────────────────────────

struct UnrollResult {
    stmts: [string],
    unrolled_count: int
}

// ── Context ────────────────────────────────────────────────────

struct UnrollCtx {
    unrolled: int
}

// ── Entry point ────────────────────────────────────────────────

fn unroll_loops(stmts: [string]) -> UnrollResult {
    let ctx = UnrollCtx { unrolled: 0 }
    let optimized = unroll_ctx_process_block(ctx, stmts)
    return UnrollResult { stmts: optimized, unrolled_count: ctx.unrolled }
}

fn unroll_ctx_process_block(ctx: UnrollCtx, stmts: [string]) -> [string] {
    let mut result = []
    for stmt in stmts {
        // In full impl, try_unroll checks if stmt is For with constant range
        // For now, pass through
        result.push(stmt)
    }
    return result
}

// ── Try unroll a for-loop ──────────────────────────────────────

struct ForLoopInfo {
    var_name: string,
    start: int,
    end: int,
    inclusive: bool,
    body: [string]
}

fn try_unroll(info: ForLoopInfo) -> UnrollResult {
    let count = 0
    if info.inclusive {
        count = info.end - info.start + 1
    } else {
        if info.end <= info.start {
            return UnrollResult { stmts: [], unrolled_count: 1 }
        }
        count = info.end - info.start
    }

    if count > MAX_UNROLL_ITERATIONS {
        return UnrollResult { stmts: [], unrolled_count: 0 }
    }
    if count == 0 {
        return UnrollResult { stmts: [], unrolled_count: 0 }
    }

    // Check body doesn't contain terminators
    if body_has_terminator(info.body) {
        return UnrollResult { stmts: [], unrolled_count: 0 }
    }

    // Generate unrolled statements
    let mut unrolled = []
    let upper = info.end
    if info.inclusive {
        upper = info.end + 1
    }
    let i = info.start
    while i < upper {
        // let var = i
        unrolled.push("let " + info.var_name + " = " + str(i))
        for body_stmt in info.body {
            unrolled.push(body_stmt)
        }
        i = i + 1
    }

    return UnrollResult { stmts: unrolled, unrolled_count: 1 }
}

// ── Extract constant int ───────────────────────────────────────

fn const_int(expr: string) -> int {
    // In full impl, match IntLit or negated IntLit
    // Sentinel -999999 for "not a constant"
    return -999999
}

// ── Body has terminator check ──────────────────────────────────

fn body_has_terminator(stmts: [string]) -> bool {
    for stmt in stmts {
        if stmt == "Return" { return true }
        if stmt == "Throw" { return true }
    }
    return false
}
