// Debug the env scope mechanism directly
let mut vars = []
let mut scopes = [0]

fn push_scope() {
    scopes = scopes.push(len(vars))
    println("  push_scope: boundary=" + to_string(len(vars)) + " scopes=" + to_string(scopes))
}

fn pop_scope() {
    let boundary = scopes[len(scopes) - 1]
    println("  pop_scope: boundary=" + to_string(boundary) + " vars_len=" + to_string(len(vars)))
    let mut new_scopes = []
    let mut i = 0
    while i < len(scopes) - 1 {
        new_scopes = new_scopes.push(scopes[i])
        i = i + 1
    }
    scopes = new_scopes
    let mut new_vars = []
    i = 0
    while i < boundary {
        new_vars = new_vars.push(vars[i])
        i = i + 1
    }
    vars = new_vars
    println("  after pop: vars_len=" + to_string(len(vars)) + " scopes=" + to_string(scopes))
}

fn define(name, value) {
    vars = vars.push([name, value])
    println("  define: " + name + " = " + to_string(value) + " vars_len=" + to_string(len(vars)))
}

fn lookup(name) {
    let mut i = len(vars) - 1
    while i >= 0 {
        if vars[i][0] == name {
            println("  lookup: " + name + " -> " + to_string(vars[i][1]) + " (at index " + to_string(i) + ")")
            return vars[i][1]
        }
        i = i - 1
    }
    println("  lookup: " + name + " -> NOT FOUND")
    return "NOT_FOUND"
}

// Simulate two calls to the same function with different params
println("=== Simulating call_user_fn('apply', [4, 'double']) ===")
push_scope()
define("x", 4)
define("f", "double")
println("  calling f(x):")
let f1 = lookup("f")
let x1 = lookup("x")
println("  result: " + f1 + "(" + to_string(x1) + ")")
pop_scope()

println("")
println("=== Simulating call_user_fn('apply', [6, 'add_ten']) ===")
push_scope()
define("x", 6)
define("f", "add_ten")
println("  calling f(x):")
let f2 = lookup("f")
let x2 = lookup("x")
println("  result: " + f2 + "(" + to_string(x2) + ")")
pop_scope()
