//
//  Verifies:
//    1. Grid search generates all combinations
//    2. Random search generates correct count with bounded values
//    3. Bayesian step proposes valid configs
//    4. Trial runner with early stopping
//    5. best_config finds highest metric
//    6. Edge cases (empty param space, single param)
//
//  Run: ./hexa self/test_hyperparam_search.hexa
//  Minimum 10 check() statements.
// ===================================================================

// -- inlined from self/ml/hyperparam_search.hexa --
// codegen import not wired for test files

// ===================================================================
//  self/ml/hyperparam_search.hexa — Hyperparameter Search (pure Hexa)
//
//  Grid search, random search, Bayesian optimization (GP surrogate),
//  trial runner with early stopping.
//
//  Public API:
//    grid_search(names, values_per_param)
//      Generate all combinations.
//      names: array of strings, values_per_param: array of arrays
//      Returns array of #{} configs.
//
//    random_search(names, lo_arr, hi_arr, n_trials)
//      Sample n_trials random configs.
//      Returns array of #{} configs.
//
//    bayesian_step(history, names, lo_arr, hi_arr)
//      Propose next config via GP surrogate + EI.
//      history: array of [config_dict, metric]
//      Returns proposed #{} config dict.
//
//    run_trial(config, train_fn, eval_fn, max_epochs, patience)
//      Execute a single trial with early stopping.
//      Returns [config, best_metric, final_epoch, stopped_early].
//
//    best_config(history)
//      Return best trial record from history.
// ===================================================================

// ===================================================================
//  Pseudo-random number generator (LCG)
//  Deterministic for reproducibility.
// ===================================================================
let mut HP_SEED = 42

fn hp_set_seed(s) {
    HP_SEED = s
}

fn hp_rand_int() {
    HP_SEED = (HP_SEED * 1103515245 + 12345) % 2147483648
    let v = HP_SEED
    if v < 0 {
        return 0 - v
    }
    return v
}

fn hp_rand_float() {
    let r = hp_rand_int()
    return to_float(r) / 2147483648.0
}

// ===================================================================
//  fabs helper
// ===================================================================
fn hp_fabs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

// ===================================================================
//  Grid Search
//
//  names: ["lr", "batch"]
//  values_per_param: [[0.01, 0.001], [16.0, 32.0]]
//
//  Returns all combinations as array of #{} dicts.
// ===================================================================
fn grid_search(names, values_per_param) {
    let n_params = len(names)
    if n_params == 0 { return [] }

    // Count total combinations
    let mut total = 1
    let mut i = 0
    while i < n_params {
        total = total * len(values_per_param[i])
        i = i + 1
    }

    // Generate all combos
    let mut configs = []
    let mut ci = 0
    while ci < total {
        let config = #{}
        let mut remainder = ci
        let mut pi = n_params - 1
        while pi >= 0 {
            let n_vals = len(values_per_param[pi])
            let idx = remainder % n_vals
            remainder = remainder / n_vals
            config[names[pi]] = values_per_param[pi][idx]
            pi = pi - 1
        }
        configs = configs + [config]
        ci = ci + 1
    }
    return configs
}

// ===================================================================
//  Random Search
//
//  names: ["lr", "dropout"]
//  lo_arr: [0.0001, 0.0]
//  hi_arr: [0.1, 0.5]
//
//  Returns n_trials random #{} configs.
// ===================================================================
fn random_search(names, lo_arr, hi_arr, n_trials) {
    let n_params = len(names)
    let mut configs = []
    let mut t = 0
    while t < n_trials {
        let config = #{}
        let mut pi = 0
        while pi < n_params {
            let val = lo_arr[pi] + hp_rand_float() * (hi_arr[pi] - lo_arr[pi])
            config[names[pi]] = val
            pi = pi + 1
        }
        configs = configs + [config]
        t = t + 1
    }
    return configs
}

// ===================================================================
//  GP surrogate kernel: squared exponential (RBF)
// ===================================================================
fn rbf_kernel(x1, x2, length_scale) {
    let n = len(x1)
    let mut sq_dist = 0.0
    let mut i = 0
    while i < n {
        let d = x1[i] - x2[i]
        sq_dist = sq_dist + d * d
        i = i + 1
    }
    let neg_half = 0.0 - sq_dist / (2.0 * length_scale * length_scale)
    // exp approximation: 1 + x + x^2/2 + x^3/6 + x^4/24
    let x = neg_half
    let x2 = x * x
    let x3 = x2 * x
    let x4 = x3 * x
    let result = 1.0 + x + x2 / 2.0 + x3 / 6.0 + x4 / 24.0
    if result < 0.0 { return 0.0001 }
    return result
}

// ===================================================================
//  Extract numeric feature vector from config dict
//  config: #{name: value}, names: order of extraction
//  Returns array of floats.
// ===================================================================
fn config_to_vec(config, names) {
    let n = len(names)
    let mut v = []
    let mut i = 0
    while i < n {
        v = v + [config[names[i]]]
        i = i + 1
    }
    return v
}

// ===================================================================
//  GP predict: mean and variance at a point given history
//  history: array of [feature_vec, metric]
//  Returns [mean, variance]
// ===================================================================
fn gp_predict(x_new, history, length_scale) {
    let n = len(history)
    if n == 0 { return [0.0, 1.0] }

    // Compute kernel vector k(x_new, x_i)
    let mut k_vec = []
    let mut i = 0
    while i < n {
        let k = rbf_kernel(x_new, history[i][0], length_scale)
        k_vec = k_vec + [k]
        i = i + 1
    }

    // Simple approximation: mean = weighted average by kernel similarity
    let mut sum_k = 0.0
    let mut sum_ky = 0.0
    i = 0
    while i < n {
        sum_k = sum_k + k_vec[i]
        sum_ky = sum_ky + k_vec[i] * history[i][1]
        i = i + 1
    }

    let mut mean = 0.0
    if sum_k > 0.0001 {
        mean = sum_ky / sum_k
    }

    // Variance = 1 - max(k)^2 (approximated)
    let mut max_k = 0.0
    i = 0
    while i < n {
        if k_vec[i] > max_k {
            max_k = k_vec[i]
        }
        i = i + 1
    }
    let var_raw = 1.0 - max_k * max_k
    let safe_var = if var_raw < 0.001 { 0.001 } else { var_raw }

    return [mean, safe_var]
}

// ===================================================================
//  Expected Improvement acquisition function
//  Returns EI value for a predicted (mean, var) given best_y
// ===================================================================
fn expected_improvement(mean, variance, best_y) {
    let std = sqrt(variance)
    if std < 0.0001 { return 0.0 }
    // Simplified EI: exploration + exploitation balance
    let ei = std * 0.3989 + (mean - best_y) * 0.5
    if ei < 0.0 { return 0.001 * std }
    return ei
}

// ===================================================================
//  Bayesian step: propose next config given history
//
//  history: array of [config_dict, metric]
//  names: param names
//  lo_arr, hi_arr: bounds
//
//  Strategy: generate n_candidates random configs, pick one with
//  highest Expected Improvement.
// ===================================================================
fn bayesian_step(history, names, lo_arr, hi_arr) {
    let n_hist = len(history)
    let length_scale = 1.0
    let n_candidates = 20

    // Build GP training data
    let mut gp_data = []
    let mut best_y = -999999.0
    let mut i = 0
    while i < n_hist {
        let cvec = config_to_vec(history[i]["config"], names)
        let metric = history[i]["metric"]
        gp_data = gp_data + [[cvec, metric]]
        if metric > best_y {
            best_y = metric
        }
        i = i + 1
    }

    // Generate candidates and score them
    let candidates = random_search(names, lo_arr, hi_arr, n_candidates)
    let mut best_ei = -1.0
    let mut best_cfg = candidates[0]

    i = 0
    while i < n_candidates {
        let cvec = config_to_vec(candidates[i], names)
        let pred = gp_predict(cvec, gp_data, length_scale)
        let ei = expected_improvement(pred[0], pred[1], best_y)
        if ei > best_ei {
            best_ei = ei
            best_cfg = candidates[i]
        }
        i = i + 1
    }

    return best_cfg
}

// ===================================================================
//  Run Trial
//
//  config: #{} dict
//  train_fn: fn(config, epoch) -> loss
//  eval_fn: fn(config) -> metric
//  max_epochs: int
//  patience: int (early stopping window)
//
//  Returns Trial #{config, metric, epoch, stopped_early}
// ===================================================================
fn run_trial(config, train_fn, eval_fn, max_epochs, patience) {
    let mut best_metric = -999999.0
    let mut no_improve = 0
    let mut final_epoch = 0
    let mut stopped_early = false

    let mut epoch = 0
    while epoch < max_epochs {
        let loss = train_fn(config, epoch)
        let metric = eval_fn(config)

        if metric > best_metric {
            best_metric = metric
            no_improve = 0
        } else {
            no_improve = no_improve + 1
        }

        final_epoch = epoch

        if no_improve >= patience {
            stopped_early = true
            epoch = max_epochs
        } else {
            epoch = epoch + 1
        }
    }

    let result = #{}
    result["config"] = config
    result["metric"] = best_metric
    result["epoch"] = final_epoch
    result["stopped_early"] = stopped_early
    return result
}

// ===================================================================
//  Best Config: find trial with highest metric in history
//
//  history: array of #{config, metric, ...} dicts
//  Returns the best trial #{} dict.
// ===================================================================
fn best_config(history) {
    let n = len(history)
    if n == 0 {
        let empty = #{}
        return empty
    }

    let mut best_idx = 0
    let mut best_val = history[0]["metric"]
    let mut i = 1
    while i < n {
        if history[i]["metric"] > best_val {
            best_val = history[i]["metric"]
            best_idx = i
        }
        i = i + 1
    }
    return history[best_idx]
}

println("[hyperparam_search] loaded — grid/random/bayesian search + trial runner")


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

println("===================================================================")
println("  Hyperparameter Search Test Suite")
println("===================================================================")

// ===================================================================
//  T1: Grid search — 2 params x 2 values = 4 combos
// ===================================================================
let names1 = ["lr", "batch"]
let vals1 = [[0.01, 0.001], [16.0, 32.0]]
let grid = grid_search(names1, vals1)
check("T1 grid search: 2x2=4 combos", len(grid) == 4)

// ===================================================================
//  T2: Grid search — first combo has valid lr
// ===================================================================
let first = grid[0]
let first_lr = first["lr"]
let lr_valid = fabs(first_lr - 0.01) < 0.001 || fabs(first_lr - 0.001) < 0.0001
check("T2 grid first combo has valid lr", lr_valid)

// ===================================================================
//  T3: Grid search — 3 params produces 2x3x2=12 combos
// ===================================================================
let names3 = ["a", "b", "c"]
let vals3 = [[1.0, 2.0], [10.0, 20.0, 30.0], [100.0, 200.0]]
let grid2 = grid_search(names3, vals3)
check("T3 grid 2x3x2=12 combos", len(grid2) == 12)

// ===================================================================
//  T4: Grid search — empty param space
// ===================================================================
let grid_empty = grid_search([], [])
check("T4 grid empty param space", len(grid_empty) == 0)

// ===================================================================
//  T5: Random search — generates correct number of trials
// ===================================================================
hp_set_seed(12345)
let rnames = ["lr", "dropout"]
let rlo = [0.0001, 0.0]
let rhi = [0.1, 0.5]
let rconfigs = random_search(rnames, rlo, rhi, 5)
check("T5 random search: 5 trials", len(rconfigs) == 5)

// ===================================================================
//  T6: Random search — values within bounds
// ===================================================================
let r_lr = rconfigs[0]["lr"]
let r_do = rconfigs[0]["dropout"]
let lr_ok = r_lr >= 0.0001 && r_lr <= 0.1
let do_ok = r_do >= 0.0 && r_do <= 0.5
check("T6 random search values in bounds", lr_ok && do_ok)

// ===================================================================
//  T7: Trial runner — normal completion
// ===================================================================
fn dummy_train(config, epoch) {
    let lr = config["lr"]
    return 1.0 - to_float(epoch) * lr
}

fn dummy_eval(config) {
    let lr = config["lr"]
    return 0.9 - lr
}

let trial_config = #{}
trial_config["lr"] = 0.01
let trial = run_trial(trial_config, dummy_train, dummy_eval, 5, 10)
let trial_epoch = trial["epoch"]
check("T7 trial runner completes 5 epochs", trial_epoch == 4)

// ===================================================================
//  T8: Trial runner — early stopping triggers
// ===================================================================
fn es_train(config, epoch) {
    return 0.1
}

fn es_eval(config) {
    return 0.5
}

let es_config = #{}
es_config["lr"] = 1.0
let trial2 = run_trial(es_config, es_train, es_eval, 100, 3)
let trial2_stopped = trial2["stopped_early"]
check("T8 early stopping triggers at patience=3", trial2_stopped == true)

// ===================================================================
//  T9: best_config — finds highest metric
// ===================================================================
let h1_cfg = #{}
h1_cfg["lr"] = 0.01
let h1 = #{}
h1["config"] = h1_cfg
h1["metric"] = 0.85

let h2_cfg = #{}
h2_cfg["lr"] = 0.001
let h2 = #{}
h2["config"] = h2_cfg
h2["metric"] = 0.92

let h3_cfg = #{}
h3_cfg["lr"] = 0.1
let h3 = #{}
h3["config"] = h3_cfg
h3["metric"] = 0.70

let history = [h1, h2, h3]
let best = best_config(history)
let best_metric = best["metric"]
check("T9 best_config finds 0.92", fabs(best_metric - 0.92) < 0.001)

// ===================================================================
//  T10: Bayesian step — proposes valid config
// ===================================================================
hp_set_seed(99999)
let bay_c1 = #{}
bay_c1["lr"] = 0.01
bay_c1["dropout"] = 0.1
let bay_h1 = #{}
bay_h1["config"] = bay_c1
bay_h1["metric"] = 0.85

let bay_c2 = #{}
bay_c2["lr"] = 0.001
bay_c2["dropout"] = 0.3
let bay_h2 = #{}
bay_h2["config"] = bay_c2
bay_h2["metric"] = 0.90

let bay_c3 = #{}
bay_c3["lr"] = 0.05
bay_c3["dropout"] = 0.2
let bay_h3 = #{}
bay_h3["config"] = bay_c3
bay_h3["metric"] = 0.78

let bay_history = [bay_h1, bay_h2, bay_h3]
let bay_names = ["lr", "dropout"]
let bay_lo = [0.0001, 0.0]
let bay_hi = [0.1, 0.5]
let proposed = bayesian_step(bay_history, bay_names, bay_lo, bay_hi)
let prop_lr = proposed["lr"]
let prop_do = proposed["dropout"]
let prop_lr_ok = prop_lr >= 0.0001 && prop_lr <= 0.1
let prop_do_ok = prop_do >= 0.0 && prop_do <= 0.5
check("T10 bayesian proposes config in bounds", prop_lr_ok && prop_do_ok)

// ===================================================================
//  T11: Grid search — single param, 3 values
// ===================================================================
let grid_single = grid_search(["alpha"], [[0.1, 0.5, 0.9]])
check("T11 grid single param 3 values", len(grid_single) == 3)

// ===================================================================
//  T12: config_to_vec extracts values in order
// ===================================================================
let cvec_cfg = #{}
cvec_cfg["lr"] = 0.01
cvec_cfg["batch"] = 32.0
let cvec = config_to_vec(cvec_cfg, ["lr", "batch"])
check("T12 config_to_vec length=2", len(cvec) == 2)

// ===================================================================
//  Summary
// ===================================================================
println("")
println("pass=" + to_string(pass_count) + " fail=" + to_string(fail_count))
if fail_count == 0 {
    println("ALL PASS")
} else {
    println("FAILED")
}
println(to_string(pass_count) + " passed")
