// ═══════════════════════════════════════════════════════════════
//  test_curriculum.hexa — Curriculum Learning (#117) verification
//
//  Tests (25+):
//    1.  score_difficulty preserves loss values
//    2.  score_difficulty highest value
//    3.  score_difficulty_length maps lengths to float
//    4.  score_difficulty_composite weighted blend
//    5.  normalize_scores min=0 max=1
//    6.  normalize_scores uniform input -> 0.5
//    7.  pace_linear boundaries (0, 0.5, 1.0)
//    8.  pace_sqrt faster early unlock than linear
//    9.  pace_exp starts near 0
//   10.  pace_exp approaches 1.0 at end
//   11.  pace_exp higher gamma -> faster unlock
//   12.  pace_step discrete jumps
//   13.  all pacing reaches 1.0 at total
//   14.  competence_from_val at init = 0
//   15.  competence_from_val at target = 1
//   16.  competence_from_val midway
//   17.  update_competence EMA smoothing
//   18.  assign_stage easy/medium/hard
//   19.  filter_by_stage correct indices
//   20.  filter_up_to_stage cumulative
//   21.  competence_to_stage boundaries
//   22.  sort_indices ascending order
//   23.  schedule_batch easy first at low competence
//   24.  schedule_batch full competence includes all
//   25.  schedule_batch_hard_first picks hardest
//   26.  rank_difficulty correct ranking
//   27.  curriculum_train_step early < late loss
//   28.  curriculum_train_step exp mode
//   29.  curriculum_train_step_staged progression
//   30.  baby_step_pool gradual growth
//
//  run: ./hexa self/test_curriculum.hexa
// ═══════════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx(a, b, eps) { return fabs(a - b) < eps }

// ── inlined from curriculum.hexa ─────────────────────────────

fn cl_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn cl_sqrt(x) {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    for _i in 0..30 {
        g = (g + x / g) / 2.0
    }
    return g
}

fn cl_exp(x) {
    let mut v = x
    if v > 20.0 { v = 20.0 }
    if v < -20.0 { v = -20.0 }
    let mut result = 1.0
    let mut term = 1.0
    for i in 1..30 {
        term = term * v / to_float(i)
        result = result + term
    }
    if result < 0.0 { return 0.0 }
    return result
}

fn cl_log(x) {
    if x <= 0.0 { return -30.0 }
    let mut v = x
    let mut count = 0
    while v > 2.0 {
        v = v / 2.718281828
        count = count + 1
    }
    while v < 0.5 {
        v = v * 2.718281828
        count = count - 1
    }
    let d = v - 1.0
    return to_float(count) + d - d * d / 2.0 + d * d * d / 3.0 - d * d * d * d / 4.0
}

fn cl_floor(x) {
    let i = to_int(x)
    if to_float(i) > x { return i - 1 }
    return i
}

fn cl_min(a, b) {
    if a < b { return a }
    return b
}

fn cl_max(a, b) {
    if a > b { return a }
    return b
}

fn cl_clamp(x, lo, hi) {
    if x < lo { return lo }
    if x > hi { return hi }
    return x
}

fn cl_zeros(n) {
    let mut v = []
    for _i in 0..n { v = v + [0.0] }
    return v
}

fn score_difficulty(losses) {
    let n = len(losses)
    let mut scores = cl_zeros(n)
    for i in 0..n { scores[i] = losses[i] }
    return scores
}

fn score_difficulty_length(lengths) {
    let n = len(lengths)
    let mut scores = cl_zeros(n)
    for i in 0..n { scores[i] = to_float(lengths[i]) }
    return scores
}

fn score_difficulty_composite(losses, lengths, w_loss, w_len) {
    let n = len(losses)
    let mut scores = cl_zeros(n)
    for i in 0..n {
        scores[i] = w_loss * losses[i] + w_len * to_float(lengths[i])
    }
    return scores
}

fn normalize_scores(scores) {
    let n = len(scores)
    if n == 0 { return [] }
    let mut lo = scores[0]
    let mut hi = scores[0]
    for i in 1..n {
        if scores[i] < lo { lo = scores[i] }
        if scores[i] > hi { hi = scores[i] }
    }
    let range = hi - lo
    let mut out = cl_zeros(n)
    if range < 1.0e-10 {
        for i in 0..n { out[i] = 0.5 }
        return out
    }
    for i in 0..n { out[i] = (scores[i] - lo) / range }
    return out
}

fn pace_linear(step, total) {
    if total <= 0 { return 1.0 }
    let c = to_float(step) / to_float(total)
    return cl_min(c, 1.0)
}

fn pace_sqrt(step, total) {
    if total <= 0 { return 1.0 }
    let ratio = to_float(step) / to_float(total)
    let c = cl_sqrt(cl_min(ratio, 1.0))
    return cl_min(c, 1.0)
}

fn pace_exp(step, total, gamma) {
    if total <= 0 { return 1.0 }
    let ratio = to_float(step) / to_float(total)
    let c = 1.0 - cl_exp(0.0 - gamma * ratio)
    return cl_clamp(c, 0.0, 1.0)
}

fn pace_step(step, total, n_stages) {
    if total <= 0 { return 1.0 }
    if n_stages <= 0 { return 1.0 }
    let stage_len = total / n_stages
    if stage_len <= 0 { return 1.0 }
    let cur_stage = step / stage_len
    let s = cl_min(cur_stage + 1, n_stages)
    return to_float(s) / to_float(n_stages)
}

fn competence_from_val(val_loss, init_loss, target_loss) {
    let denom = init_loss - target_loss
    if cl_abs(denom) < 1.0e-10 { return 1.0 }
    let c = (init_loss - val_loss) / denom
    return cl_clamp(c, 0.0, 1.0)
}

fn update_competence(prev_c, val_loss, init_loss, target_loss, momentum) {
    let raw = competence_from_val(val_loss, init_loss, target_loss)
    let c = momentum * prev_c + (1.0 - momentum) * raw
    return cl_clamp(c, 0.0, 1.0)
}

fn assign_stage(score, thresholds) {
    if score <= thresholds[0] { return 0 }
    if score <= thresholds[1] { return 1 }
    return 2
}

fn filter_by_stage(scores, stage, thresholds) {
    let n = len(scores)
    let mut out = []
    for i in 0..n {
        let s = assign_stage(scores[i], thresholds)
        if s == stage {
            out = out + [i]
        }
    }
    return out
}

fn filter_up_to_stage(scores, max_stage, thresholds) {
    let n = len(scores)
    let mut out = []
    for i in 0..n {
        let s = assign_stage(scores[i], thresholds)
        if s <= max_stage {
            out = out + [i]
        }
    }
    return out
}

fn competence_to_stage(competence) {
    if competence < 0.33 { return 0 }
    if competence < 0.66 { return 1 }
    return 2
}

fn sort_indices_by_score(scores) {
    let n = len(scores)
    let mut indices = []
    for i in 0..n { indices = indices + [i] }
    for i in 0..n {
        let mut best = i
        for j in (i + 1)..n {
            if scores[indices[j]] < scores[indices[best]] { best = j }
        }
        if best != i {
            let tmp = indices[i]
            indices[i] = indices[best]
            indices[best] = tmp
        }
    }
    return indices
}

fn schedule_batch(scores, competence, batch_size) {
    let n = len(scores)
    let sorted_idx = sort_indices_by_score(scores)
    let pool_size_f = competence * to_float(n)
    let mut pool_size = cl_floor(pool_size_f)
    if pool_size < 1 { pool_size = 1 }
    if pool_size > n { pool_size = n }
    let mut batch = []
    let actual_bs = cl_min(batch_size, pool_size)
    for i in 0..actual_bs {
        let idx = i % pool_size
        batch = batch + [sorted_idx[idx]]
    }
    return batch
}

fn schedule_batch_hard_first(scores, competence, batch_size) {
    let n = len(scores)
    let sorted_idx = sort_indices_by_score(scores)
    let mut rev_idx = []
    for i in 0..n { rev_idx = rev_idx + [sorted_idx[n - 1 - i]] }
    let pool_size_f = competence * to_float(n)
    let mut pool_size = cl_floor(pool_size_f)
    if pool_size < 1 { pool_size = 1 }
    if pool_size > n { pool_size = n }
    let mut batch = []
    let actual_bs = cl_min(batch_size, pool_size)
    for i in 0..actual_bs {
        let idx = i % pool_size
        batch = batch + [rev_idx[idx]]
    }
    return batch
}

fn rank_difficulty(losses) {
    let n = len(losses)
    let sorted_idx = sort_indices_by_score(losses)
    let mut ranks = cl_zeros(n)
    for r in 0..n {
        let orig = sorted_idx[r]
        ranks[orig] = to_float(r) / to_float(n)
    }
    return ranks
}

fn curriculum_train_step(weights, data, scores, step, total_steps, batch_size, pace_mode) {
    let mut competence = 0.0
    if pace_mode == 0 { competence = pace_linear(step, total_steps) }
    if pace_mode == 1 { competence = pace_sqrt(step, total_steps) }
    if pace_mode == 2 { competence = pace_step(step, total_steps, 5) }
    if pace_mode == 3 { competence = pace_exp(step, total_steps, 3.0) }
    let batch_indices = schedule_batch(scores, competence, batch_size)
    let bs = len(batch_indices)
    let mut total_loss = 0.0
    for i in 0..bs {
        let idx = batch_indices[i]
        total_loss = total_loss + scores[idx]
    }
    let avg_loss = total_loss / to_float(bs)
    return [avg_loss, competence]
}

fn curriculum_train_step_staged(weights, data, scores, step, total_steps, batch_size, thresholds) {
    let competence = pace_linear(step, total_steps)
    let stage = competence_to_stage(competence)
    let eligible = filter_up_to_stage(scores, stage, thresholds)
    let n_eligible = len(eligible)
    if n_eligible == 0 {
        return [0.0, to_float(stage)]
    }
    let actual_bs = cl_min(batch_size, n_eligible)
    let mut total_loss = 0.0
    for i in 0..actual_bs {
        let idx = eligible[i]
        total_loss = total_loss + scores[idx]
    }
    let avg_loss = total_loss / to_float(actual_bs)
    return [avg_loss, to_float(stage)]
}

fn baby_step_pool(epoch, n_samples) {
    let pool = epoch + 1
    if pool > n_samples { return n_samples }
    return pool
}

// ═══════════════════════════════════════════════════════════════
//  TESTS
// ═══════════════════════════════════════════════════════════════

println("=== Curriculum Learning Tests (SSOT #117) ===")

// ── 1. score_difficulty preserves loss values ─────────────────
let losses1 = [0.5, 1.2, 0.1, 2.0, 0.8]
let scores1 = score_difficulty(losses1)
check("score_difficulty preserves values", approx(scores1[0], 0.5, 0.01))

// ── 2. score_difficulty highest value ─────────────────────────
check("score_difficulty highest", approx(scores1[3], 2.0, 0.01))

// ── 3. score_difficulty_length maps lengths to float ──────────
let lens = [10, 50, 5, 100]
let len_scores = score_difficulty_length(lens)
check("length_scorer maps correctly", approx(len_scores[1], 50.0, 0.01))

// ── 4. score_difficulty_composite weighted blend ──────────────
let comp_losses = [1.0, 2.0]
let comp_lens = [10, 20]
let comp_scores = score_difficulty_composite(comp_losses, comp_lens, 0.5, 0.1)
// score[0] = 0.5*1.0 + 0.1*10 = 1.5
// score[1] = 0.5*2.0 + 0.1*20 = 3.0
check("composite scorer weighted", approx(comp_scores[0], 1.5, 0.01))
check("composite scorer second", approx(comp_scores[1], 3.0, 0.01))

// ── 5. normalize_scores min=0 max=1 ──────────────────────────
let norm1 = normalize_scores(scores1)
check("normalize min=0", approx(norm1[2], 0.0, 0.01))
check("normalize max=1", approx(norm1[3], 1.0, 0.01))

// ── 6. normalize_scores uniform input -> 0.5 ─────────────────
let uniform = [3.0, 3.0, 3.0]
let norm_u = normalize_scores(uniform)
check("normalize uniform=0.5", approx(norm_u[0], 0.5, 0.01))

// ── 7. pace_linear boundaries ─────────────────────────────────
check("pace_linear(0,100)=0", approx(pace_linear(0, 100), 0.0, 0.01))
check("pace_linear(50,100)=0.5", approx(pace_linear(50, 100), 0.5, 0.01))
check("pace_linear(100,100)=1", approx(pace_linear(100, 100), 1.0, 0.01))

// ── 8. pace_sqrt faster early unlock ──────────────────────────
let sqrt_25 = pace_sqrt(25, 100)
let lin_25 = pace_linear(25, 100)
check("pace_sqrt > pace_linear at 25%", sqrt_25 > lin_25)

// ── 9. pace_exp starts near 0 ─────────────────────────────────
let exp_0 = pace_exp(0, 100, 3.0)
check("pace_exp(0)=0", approx(exp_0, 0.0, 0.01))

// ── 10. pace_exp approaches 1.0 at end ────────────────────────
let exp_end = pace_exp(100, 100, 3.0)
check("pace_exp(100) near 1", exp_end > 0.9)

// ── 11. pace_exp higher gamma -> faster unlock ────────────────
let exp_slow = pace_exp(30, 100, 2.0)
let exp_fast = pace_exp(30, 100, 5.0)
check("higher gamma faster unlock", exp_fast > exp_slow)

// ── 12. pace_step discrete jumps ──────────────────────────────
let step_0 = pace_step(0, 100, 5)
let step_21 = pace_step(21, 100, 5)
check("pace_step stage 1", approx(step_0, 0.2, 0.01))
check("pace_step stage 2", approx(step_21, 0.4, 0.01))

// ── 13. all pacing reaches 1.0 at total ──────────────────────
check("linear reaches 1.0", approx(pace_linear(100, 100), 1.0, 0.01))
check("sqrt reaches 1.0", approx(pace_sqrt(100, 100), 1.0, 0.01))
check("step reaches 1.0", approx(pace_step(100, 100, 5), 1.0, 0.01))

// ── 14. competence_from_val at init = 0 ──────────────────────
let c_init = competence_from_val(5.0, 5.0, 1.0)
check("competence at init loss=0", approx(c_init, 0.0, 0.01))

// ── 15. competence_from_val at target = 1 ─────────────────────
let c_target = competence_from_val(1.0, 5.0, 1.0)
check("competence at target loss=1", approx(c_target, 1.0, 0.01))

// ── 16. competence_from_val midway ────────────────────────────
let c_mid = competence_from_val(3.0, 5.0, 1.0)
check("competence midway=0.5", approx(c_mid, 0.5, 0.01))

// ── 17. update_competence EMA smoothing ───────────────────────
// prev=0.3, raw competence=0.5, momentum=0.9 -> 0.9*0.3 + 0.1*0.5 = 0.32
let c_ema = update_competence(0.3, 3.0, 5.0, 1.0, 0.9)
check("EMA competence smoothed", approx(c_ema, 0.32, 0.01))

// ── 18. assign_stage easy/medium/hard ─────────────────────────
let thr = [0.33, 0.66]
check("assign_stage easy", assign_stage(0.1, thr) == 0)
check("assign_stage medium", assign_stage(0.5, thr) == 1)
check("assign_stage hard", assign_stage(0.9, thr) == 2)

// ── 19. filter_by_stage correct indices ───────────────────────
let staged_scores = [0.1, 0.5, 0.9, 0.2, 0.7]
let easy_idx = filter_by_stage(staged_scores, 0, thr)
check("filter easy count=2", len(easy_idx) == 2)
check("filter easy contains idx 0", easy_idx[0] == 0)
check("filter easy contains idx 3", easy_idx[1] == 3)

// ── 20. filter_up_to_stage cumulative ─────────────────────────
let upto_medium = filter_up_to_stage(staged_scores, 1, thr)
// easy: 0,3  medium: 1  (0.7 > 0.66 => hard, not medium) -> total 3
check("filter_up_to medium count=3", len(upto_medium) == 3)
let upto_hard = filter_up_to_stage(staged_scores, 2, thr)
check("filter_up_to hard=all", len(upto_hard) == 5)

// ── 21. competence_to_stage boundaries ────────────────────────
check("c2s low=0", competence_to_stage(0.1) == 0)
check("c2s mid=1", competence_to_stage(0.5) == 1)
check("c2s high=2", competence_to_stage(0.9) == 2)

// ── 22. sort_indices ascending order ──────────────────────────
let scores_sort = [3.0, 1.0, 4.0, 0.5, 2.0]
let sorted_idx = sort_indices_by_score(scores_sort)
check("sort first=easiest (idx 3)", sorted_idx[0] == 3)
check("sort last=hardest (idx 2)", sorted_idx[4] == 2)

// ── 23. schedule_batch easy first at low competence ───────────
let scores_sched = [5.0, 1.0, 3.0, 0.5, 4.0]
let batch_low = schedule_batch(scores_sched, 0.3, 2)
check("batch_low selects easy samples", batch_low[0] == 3)

// ── 24. schedule_batch full competence includes all ───────────
let batch_full = schedule_batch(scores_sched, 1.0, 5)
check("batch_full size=5", len(batch_full) == 5)

// ── 25. schedule_batch_hard_first picks hardest ───────────────
let batch_hard = schedule_batch_hard_first(scores_sched, 0.3, 1)
check("anti-curriculum picks hardest", batch_hard[0] == 0)

// ── 26. rank_difficulty correct ranking ───────────────────────
let ranks = rank_difficulty([3.0, 1.0, 2.0])
check("rank of easiest (1.0) is lowest", ranks[1] < ranks[2])
check("rank of hardest (3.0) is highest", ranks[0] > ranks[2])

// ── 27. curriculum_train_step early < late loss ───────────────
let mock_scores = [0.1, 0.5, 0.9, 1.5, 2.0, 3.0, 4.0, 5.0]
let result_early = curriculum_train_step([], [], mock_scores, 1, 100, 3, 0)
let result_late = curriculum_train_step([], [], mock_scores, 99, 100, 3, 0)
check("early curriculum avg_loss < late", result_early[0] < result_late[0])

// ── 28. curriculum_train_step exp mode ────────────────────────
let result_exp_early = curriculum_train_step([], [], mock_scores, 5, 100, 3, 3)
let result_exp_late = curriculum_train_step([], [], mock_scores, 95, 100, 3, 3)
check("exp mode early < late", result_exp_early[0] < result_exp_late[0])

// ── 29. curriculum_train_step_staged progression ──────────────
let staged_s = [0.1, 0.2, 0.5, 0.6, 0.8, 0.9]
let thr2 = [0.33, 0.66]
let res_s_early = curriculum_train_step_staged([], [], staged_s, 10, 100, 3, thr2)
let res_s_late = curriculum_train_step_staged([], [], staged_s, 90, 100, 3, thr2)
// early stage=0 (easy only), late stage=2 (all) -> late includes harder
check("staged early stage <= late stage", res_s_early[1] <= res_s_late[1])

// ── 30. baby_step_pool gradual growth ─────────────────────────
check("baby_step epoch 0 pool=1", baby_step_pool(0, 10) == 1)
check("baby_step epoch 4 pool=5", baby_step_pool(4, 10) == 5)
check("baby_step epoch 20 capped", baby_step_pool(20, 10) == 10)

// ═══════════════════════════════════════════════════════════════
println("")
println("=== Curriculum Learning (#117) test summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
