// ═══════════════════════════════════════════════════════════
//  test_memo_cache.hexa — @memo / @memoize / @cache runtime tests
//  Verifies self-hosted interpreter memoization support
// ═══════════════════════════════════════════════════════════

let mut pass = 0
let mut fail = 0

fn check(label: string, got, expected) {
    if got == expected {
        println("  PASS: " + label)
        pass = pass + 1
    } else {
        println("  FAIL: " + label + " — got " + to_string(got) + ", expected " + to_string(expected))
        fail = fail + 1
    }
}

println("=== @memo/@memoize/@cache Runtime Tests ===")
println("")

// ── 1. Basic @memoize: fibonacci ────────────────────────
println("--- 1. @memoize fibonacci ---")

@memoize fn fib(n: int) -> int {
    if n <= 1 { return n }
    return fib(n - 1) + fib(n - 2)
}

check("fib(0)", fib(0), 0)
check("fib(1)", fib(1), 1)
check("fib(2)", fib(2), 1)
check("fib(5)", fib(5), 5)
check("fib(10)", fib(10), 55)
check("fib(20)", fib(20), 6765)
check("fib(30)", fib(30), 832040)

// Cache hit: same value returned
let f10a = fib(10)
let f10b = fib(10)
check("fib(10) cache hit consistent", f10a == f10b, true)

println("")

// ── 2. @memo alias ──────────────────────────────────────
println("--- 2. @memo alias ---")

@memo fn factorial(n: int) -> int {
    if n <= 1 { return 1 }
    return n * factorial(n - 1)
}

check("fact(0)", factorial(0), 1)
check("fact(1)", factorial(1), 1)
check("fact(5)", factorial(5), 120)
check("fact(10)", factorial(10), 3628800)

println("")

// ── 3. @cache alias ─────────────────────────────────────
println("--- 3. @cache alias ---")

@cache fn triangle(n: int) -> int {
    if n <= 0 { return 0 }
    return n + triangle(n - 1)
}

check("triangle(0)", triangle(0), 0)
check("triangle(1)", triangle(1), 1)
check("triangle(5)", triangle(5), 15)
check("triangle(10)", triangle(10), 55)
check("triangle(100)", triangle(100), 5050)

println("")

// ── 4. Call counter (verify caching reduces calls) ──────
println("--- 4. Call counter verification ---")

let mut call_count = 0

@memoize fn counted_square(n: int) -> int {
    call_count = call_count + 1
    return n * n
}

counted_square(5)
counted_square(5)
counted_square(5)
check("counted_square(5) called once", call_count, 1)

counted_square(10)
check("counted_square(10) adds one call", call_count, 2)

counted_square(5)
counted_square(10)
check("re-calls from cache, no new calls", call_count, 2)

println("")

// ── 5. Multiple arguments ───────────────────────────────
println("--- 5. Multiple arguments ---")

@memoize fn add(a: int, b: int) -> int {
    return a + b
}

check("add(2,3)", add(2, 3), 5)
check("add(10,20)", add(10, 20), 30)
check("add(0,0)", add(0, 0), 0)
check("add(-1,1)", add(-1, 1), 0)

// Different arg order = different cache key
@memoize fn sub(a: int, b: int) -> int {
    return a - b
}

check("sub(10,3)", sub(10, 3), 7)
check("sub(3,10)", sub(3, 10), -7)

println("")

// ── 6. No arguments ────────────────────────────────────
println("--- 6. No arguments ---")

let mut no_arg_count = 0

@memoize fn constant_fn() -> int {
    no_arg_count = no_arg_count + 1
    return 42
}

check("constant_fn()", constant_fn(), 42)
check("constant_fn() cached", constant_fn(), 42)
check("constant_fn called once", no_arg_count, 1)

println("")

// ── 7. Binomial coefficient (two-arg recursive) ────────
println("--- 7. Binomial coefficient ---")

@memoize fn binom(n: int, k: int) -> int {
    if k == 0 || k == n { return 1 }
    return binom(n - 1, k - 1) + binom(n - 1, k)
}

check("binom(5,0)", binom(5, 0), 1)
check("binom(5,5)", binom(5, 5), 1)
check("binom(5,2)", binom(5, 2), 10)
check("binom(10,3)", binom(10, 3), 120)
check("binom(10,5)", binom(10, 5), 252)
check("binom(20,10)", binom(20, 10), 184756)

println("")

// ── 8. String argument memoization ─────────────────────
println("--- 8. String arguments ---")

@memoize fn str_len(s: string) -> int {
    return len(s)
}

check("str_len hello", str_len("hello"), 5)
check("str_len empty", str_len(""), 0)
check("str_len cached", str_len("hello"), 5)

println("")

// ── 9. Boolean return memoization ──────────────────────
println("--- 9. Boolean return ---")

@memoize fn is_even(n: int) -> bool {
    return n % 2 == 0
}

check("is_even(4)", is_even(4), true)
check("is_even(7)", is_even(7), false)
check("is_even(0)", is_even(0), true)

println("")

// ── 10. Non-memoized function (control) ────────────────
println("--- 10. Non-memoized control ---")

let mut plain_count = 0

fn plain_fn(n: int) -> int {
    plain_count = plain_count + 1
    return n * 2
}

plain_fn(5)
plain_fn(5)
plain_fn(5)
check("plain_fn called every time", plain_count, 3)

println("")

// ── Summary ────────────────────────────────────────────
println("=== Results: " + to_string(pass) + " passed, " + to_string(fail) + " failed ===")
if fail == 0 {
    println("ALL TESTS PASSED")
} else {
    println("SOME TESTS FAILED")
}
