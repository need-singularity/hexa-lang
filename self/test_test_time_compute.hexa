// ═══════════════════════════════════════════════════════════════════
//  test_test_time_compute.hexa — Test-Time Compute (#291)
// ═══════════════════════════════════════════════════════════════════

import "ml/test_time_compute.hexa"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs_(v) { if v < 0.0 { return 0.0 - v } return v }
fn approx_(a, b, eps) { return fabs_(a - b) < eps }

println("=== Test-Time Compute (#291) ===")

// ── Dataset: 3-class XOR-like, D_in=2, D_out=3 ──────────────
let X = [
    [0.1, 0.1], [0.2, 0.15], [0.15, 0.2],
    [0.9, 0.1], [0.85, 0.2], [0.8, 0.15],
    [0.1, 0.9], [0.2, 0.85], [0.15, 0.8],
    [0.5, 0.5], [0.6, 0.4], [0.4, 0.6]
]
let Y = [0, 0, 0, 1, 1, 1, 2, 2, 2, 0, 1, 2]

// ── T1: init model shapes ──────────────────────────────────────
let model = ttc_init(2, 8, 3, 42)
check("T1 W_h shape", len(model["W_h"]) == 8 && len(model["W_h"][0]) == 2)
check("T1 W_o shape", len(model["W_o"]) == 3 && len(model["W_o"][0]) == 8)
check("T1 W_v shape", len(model["W_v"]) == 8 && len(model["W_v"][0]) == 5)
check("T1 w_vs len", len(model["w_vs"]) == 8)

// ── T2: forward produces correct-length logits ────────────────
let logits2 = ttc_forward(model, [0.5, 0.5])
check("T2 logits length", len(logits2) == 3)

// ── T3: softmax sums to 1 ─────────────────────────────────────
let sm3 = ttc_softmax(logits2)
let mut sum3 = 0.0
let mut i = 0

while i < 3 { sum3 = sum3 + sm3[i] }
check("T3 softmax sums to 1", approx_(sum3, 1.0, 1.0e-6))

// ── T4: score returns value in [0,1] ──────────────────────────
let cand4 = ttc_softmax(ttc_forward(model, [0.1, 0.9]))
let sc4 = ttc_score(model, [0.1, 0.9], cand4)
check("T4 score in [0,1]", sc4 >= 0.0 && sc4 <= 1.0)

// ── T5: best_of_n returns valid structure ─────────────────────
let bon5 = ttc_best_of_n(model, [0.5, 0.5], 5, 42)
check("T5 best_of_n has candidate", len(bon5["candidate"]) == 3)
check("T5 best_of_n score in [0,1]", bon5["score"] >= 0.0 && bon5["score"] <= 1.0)
check("T5 best_of_n n_sampled", bon5["n_sampled"] == 5)

// ── T6: more samples => score >= single sample ────────────────
let bon_1 = ttc_best_of_n(model, [0.5, 0.5], 1, 42)
let bon_10 = ttc_best_of_n(model, [0.5, 0.5], 10, 42)
check("T6 more samples >= single score", bon_10["score"] >= bon_1["score"] - 0.01)

// ── T7: beam search returns valid structure ───────────────────
let bs7 = ttc_beam_search(model, [0.3, 0.7], 3, 2)
check("T7 beam candidate len", len(bs7["candidate"]) == 3)
check("T7 beam score > 0", bs7["score"] > 0.0)
check("T7 beam depth/width", bs7["depth"] == 2 && bs7["beam_width"] == 3)

// ── T8: adaptive budget returns valid structure ───────────────
let ab8 = ttc_adaptive_budget(model, [0.5, 0.5], 10)
check("T8 adaptive has candidate", len(ab8["candidate"]) == 3)
check("T8 adaptive entropy >= 0", ab8["entropy"] >= 0.0)
check("T8 adaptive difficulty in [0,1]", ab8["difficulty"] >= 0.0 && ab8["difficulty"] <= 1.0)
check("T8 adaptive budget <= max", ab8["budget_used"] <= ab8["max_budget"])
check("T8 adaptive budget >= 1", ab8["budget_used"] >= 1)

// ── T9: training reduces base loss ────────────────────────────
let mut loss_before = 0.0
let mut i = 0

while i < len(X) {
    let logits = ttc_forward(model, X[i])
    let p = ttc_softmax(logits)
    let mut py = p[Y[i]]
    if py < 1.0e-12 { py = 1.0e-12 }
    loss_before = loss_before + (0.0 - ttc_log(py))
}

let mut m = model
let mut _step = 0

while _step < 200 {
    m = ttc_train_step(m, X, Y, 0.5)
}

let mut loss_after = 0.0
let mut i = 0

while i < len(X) {
    let logits = ttc_forward(m, X[i])
    let p = ttc_softmax(logits)
    let mut py = p[Y[i]]
    if py < 1.0e-12 { py = 1.0e-12 }
    loss_after = loss_after + (0.0 - ttc_log(py))
}
check("T9 training reduces loss", loss_after < loss_before)

// ── T10: determinism — same seed, same model ──────────────────
let ma = ttc_init(2, 4, 3, 7)
let mb = ttc_init(2, 4, 3, 7)
let fa = ttc_forward(ma, [0.3, 0.7])
let fb = ttc_forward(mb, [0.3, 0.7])
let mut det_ok = true
let mut i = 0

while i < 3 {
    if fabs_(fa[i] - fb[i]) > 1.0e-9 { det_ok = false }
}
check("T10 deterministic init", det_ok)

// ── T11: entropy of uniform distribution is maximal ───────────
let uniform_p = [0.333333, 0.333333, 0.333334]
let peaked_p = [0.95, 0.025, 0.025]
let h_uniform = ttc_entropy(uniform_p)
let h_peaked = ttc_entropy(peaked_p)
check("T11 uniform entropy > peaked", h_uniform > h_peaked)

// ── T12: adaptive budget scales with difficulty ───────────────
// Confident input should use less budget than uncertain input
let ab_easy = ttc_adaptive_budget(m, [0.1, 0.1], 20)
let ab_hard = ttc_adaptive_budget(m, [0.5, 0.5], 20)
check("T12 adaptive budget responds to input", ab_easy["budget_used"] >= 1 && ab_hard["budget_used"] >= 1)

// ── T13: verifier score improves after training ───────────────
// After training, correct candidate should score higher than wrong
let correct_cand = [0.0, 0.0, 1.0]
let wrong_cand = [0.333, 0.333, 0.334]
let sc_correct = ttc_score(m, [0.1, 0.9], correct_cand)
let sc_wrong = ttc_score(m, [0.1, 0.9], wrong_cand)
check("T13 verifier scores in [0,1]", sc_correct >= 0.0 && sc_correct <= 1.0 && sc_wrong >= 0.0 && sc_wrong <= 1.0)

// ── T14: best_of_n after training produces valid probs ────────
let bon14 = ttc_best_of_n(m, [0.9, 0.1], 8, 99)
let mut sum14 = 0.0
let mut i = 0

while i < 3 { sum14 = sum14 + bon14["candidate"][i] }
check("T14 trained best_of_n probs sum to 1", approx_(sum14, 1.0, 0.01))

println("")
println("=== TTC summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
