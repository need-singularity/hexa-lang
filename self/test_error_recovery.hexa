// ═══════════════════════════════════════════════════════════
//  test_error_recovery.hexa — Error Recovery & Result/Option Tests
//  Tests: try/catch chaining, error context, Result combinators,
//         Option combinators, error recovery strategies,
//         fallback chains, retry patterns, error accumulation
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA Error Recovery Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── Result / Option types (inline stdlib) ────────────────

enum Result { Ok(val), Err(msg) }
enum Option { Some(val), None }

fn ok(v) { return Result::Ok(v) }
fn err(m) { return Result::Err(m) }
fn is_ok(r) { return match r { Ok(_) -> true, Err(_) -> false } }
fn is_err(r) { return match r { Ok(_) -> false, Err(_) -> true } }
fn unwrap(r) { return match r { Ok(x) -> x, Err(e) -> { throw "unwrap on Err" } } }
fn unwrap_or(r, d) { return match r { Ok(x) -> x, Err(_) -> d } }

fn some(v) { return Option::Some(v) }
fn none() { return Option::None }
fn is_some(o) { return match o { Some(_) -> true, None -> false } }
fn is_none(o) { return match o { Some(_) -> false, None -> true } }
fn unwrap_opt(o) { return match o { Some(x) -> x, None -> { throw "unwrap on None" } } }
fn unwrap_opt_or(o, d) { return match o { Some(x) -> x, None -> d } }

// ── 1. Try/catch chaining ────────────────────────────────

println("--- Try/Catch Chaining ---")

let mut chain_result = 0
let mut chain_caught = false

try {
    throw "error_a"
} catch e1 {
    try {
        throw "error_b"
    } catch e2 {
        chain_result = 42
        chain_caught = true
    }
}
check("chain fallback value", chain_result, 42)
check("chain caught inner", chain_caught, true)

// Three-level chain
let mut level = ""
try {
    throw "L1"
} catch e1 {
    try {
        throw "L2"
    } catch e2 {
        try {
            throw "L3"
        } catch e3 {
            level = "L3 caught"
        }
    }
}
check("three-level chain", level, "L3 caught")

// ── 2. Error context enrichment ──────────────────────────

println("")
println("--- Error Context ---")

fn safe_divide(a, b) {
    if b == 0 { throw "division by zero" }
    return a / b
}

let mut ctx_result = ok(0)
try {
    ctx_result = ok(safe_divide(10, 2))
} catch e {
    ctx_result = err("division: " + to_string(e))
}
check("context ok", is_ok(ctx_result), true)
check("context ok val", unwrap(ctx_result), 5)

let mut ctx_result2 = ok(0)
try {
    ctx_result2 = ok(safe_divide(10, 0))
} catch e {
    ctx_result2 = err("context_err")
}
check("context err", is_err(ctx_result2), true)
check("context err fallback", unwrap_or(ctx_result2, "fallback"), "fallback")

// ── 3. Result combinators ────────────────────────────────

println("")
println("--- Result Combinators ---")

fn map_result(r, f) {
    return match r { Ok(x) -> ok(f(x)), Err(e) -> err(e) }
}

fn and_then_r(r, f) {
    return match r { Ok(x) -> f(x), Err(e) -> err(e) }
}

fn or_else_r(r, f) {
    return match r { Ok(x) -> ok(x), Err(e) -> f(e) }
}

let v1 = ok(5)
let v2 = map_result(v1, |x| x * 2)
check("map ok", unwrap(v2), 10)

let v3 = err("nope")
let v4 = map_result(v3, |x| x * 2)
check("map err passthrough", is_err(v4), true)

let v5 = and_then_r(ok(3), |x| ok(x + 10))
check("and_then ok", unwrap(v5), 13)

let v6 = and_then_r(err("fail"), |x| ok(x + 10))
check("and_then err", is_err(v6), true)

let v7 = or_else_r(err("first"), |e| ok(99))
check("or_else recovery", unwrap(v7), 99)

let v8 = or_else_r(ok(42), |e| ok(99))
check("or_else skip on ok", unwrap(v8), 42)

// ── 4. Option combinators ────────────────────────────────

println("")
println("--- Option Combinators ---")

fn map_opt(o, f) {
    return match o { Some(x) -> some(f(x)), None -> none() }
}

fn and_then_opt(o, f) {
    return match o { Some(x) -> f(x), None -> none() }
}

fn or_opt(o, default) {
    return match o { Some(x) -> some(x), None -> some(default) }
}

let o1 = some(10)
let o2 = map_opt(o1, |x| x * 3)
check("map_opt some", unwrap_opt(o2), 30)

let o3 = map_opt(none(), |x| x * 3)
check("map_opt none", is_none(o3), true)

let o4 = and_then_opt(some(5), |x| {
    if x > 0 { return some(x * x) }
    return none()
})
check("and_then_opt some", unwrap_opt(o4), 25)

let o5 = or_opt(none(), 42)
check("or_opt none gives default", unwrap_opt(o5), 42)

let o6 = or_opt(some(7), 42)
check("or_opt some keeps val", unwrap_opt(o6), 7)

// ── 5. Retry pattern (inline) ────────────────────────────

println("")
println("--- Retry Pattern ---")

let mut attempt_count = 0

fn retry_inline(max_retries) {
    let mut i = 0
    while i < max_retries {
        try {
            attempt_count = attempt_count + 1
            if attempt_count < 3 {
                throw "not ready"
            }
            return ok("success")
        } catch e {
            // continue
        }
        i = i + 1
    }
    return err("max retries exceeded")
}

let rr = retry_inline(5)
check("retry succeeded", is_ok(rr), true)
check("retry value", unwrap(rr), "success")
check("retry attempts", attempt_count, 3)

// Test retry that always fails
let mut fail_attempts = 0
fn retry_always_fail(max_retries) {
    let mut i = 0
    while i < max_retries {
        try {
            fail_attempts = fail_attempts + 1
            throw "always fails"
        } catch e {
            // continue
        }
        i = i + 1
    }
    return err("all failed")
}

let rr2 = retry_always_fail(3)
check("retry all fail", is_err(rr2), true)
check("retry fail count", fail_attempts, 3)

// ── 6. Error accumulation ────────────────────────────────

println("")
println("--- Error Accumulation ---")

let items_good = [1, 2, 3, 4, 5]
let mut good_errors = []
let mut good_values = []
for item in items_good {
    try {
        if item < 0 { throw "negative" }
        good_values = good_values.push(item)
    } catch e {
        good_errors = good_errors.push(to_string(e))
    }
}
check("accumulate all good", len(good_errors), 0)
check("accumulate good count", len(good_values), 5)

let items_mixed = [1, -2, 3, -4, 5]
let mut mixed_errors = []
let mut mixed_values = []
for item in items_mixed {
    try {
        if item < 0 { throw "negative: " + to_string(item) }
        mixed_values = mixed_values.push(item)
    } catch e {
        mixed_errors = mixed_errors.push(to_string(e))
    }
}
check("accumulate mixed errors", len(mixed_errors), 2)
check("accumulate mixed values", len(mixed_values), 3)

// ── 7. Fallback chain ────────────────────────────────────

println("")
println("--- Fallback Chain ---")

fn fallback_chain() {
    let mut result = err("init")
    try {
        throw "source1 down"
    } catch e1 {
        try {
            throw "source2 down"
        } catch e2 {
            result = ok(42)
        }
    }
    return result
}
let fbc = fallback_chain()
check("catch chain result", unwrap(fbc), 42)
check("catch chain is ok", is_ok(fbc), true)

// Parse fallback
fn try_parse_int(s) {
    let mut result = err("parse error")
    try {
        result = ok(to_int(s))
    } catch e {
        result = err("cannot parse: " + s)
    }
    return result
}

let p1 = try_parse_int("42")
check("parse 42 ok", unwrap(p1), 42)

let p2 = try_parse_int("abc")
check("parse abc err", is_err(p2), true)

// First-success over candidates
let candidates = ["bad", "nope", "123", "456"]
let mut first_parsed = err("none found")
for c in candidates {
    if is_err(first_parsed) {
        let attempt = try_parse_int(c)
        if is_ok(attempt) {
            first_parsed = attempt
        }
    }
}
check("first success parse", unwrap(first_parsed), 123)

// ═══════════════════════════════════════════════════════════
