// ── inlined from self/runtime/graph_pure.hexa ──────────────────
// codegen_c2 import/use resolution for runtime/*_pure.hexa is not wired
// for test files; inline the module contents (same pattern as test_rle_pure).

fn graph_new(n) {
    let mut g = []
    let mut i = 0
    while i < n {
        g.push([])
        i = i + 1
    }
    g
}

fn graph_add_edge(g, u, v) {
    let n = len(g)
    let mut out = []
    let mut i = 0
    while i < n {
        if i == u {
            out.push(g[i].push(v))
        } else {
            if i == v {
                out.push(g[i].push(u))
            } else {
                out.push(g[i])
            }
        }
        i = i + 1
    }
    out
}

fn graph_add_directed(g, u, v) {
    let n = len(g)
    let mut out = []
    let mut i = 0
    while i < n {
        if i == u {
            out.push(g[i].push(v))
        } else {
            out.push(g[i])
        }
        i = i + 1
    }
    out
}

fn _contains(arr, val) {
    let mut i = 0
    while i < len(arr) {
        if arr[i] == val { return true }
        i = i + 1
    }
    false
}

fn graph_bfs(g, start) {
    let mut visited = []
    let mut queue = []
    queue.push(start)
    visited.push(start)
    let mut head = 0
    while head < len(queue) {
        let cur = queue[head]
        head = head + 1
        let neighbors = g[cur]
        let mut j = 0
        while j < len(neighbors) {
            let nb = neighbors[j]
            if _contains(visited, nb) == false {
                visited.push(nb)
                queue.push(nb)
            }
            j = j + 1
        }
    }
    visited
}

fn graph_dfs(g, start) {
    let mut visited = []
    let mut stack = []
    stack.push(start)
    while len(stack) > 0 {
        let cur = stack[len(stack) - 1]
        let mut new_stack = []
        let mut si = 0
        while si < len(stack) - 1 {
            new_stack.push(stack[si])
            si = si + 1
        }
        stack = new_stack
        if _contains(visited, cur) == false {
            visited.push(cur)
            let neighbors = g[cur]
            let mut j = len(neighbors) - 1
            while j >= 0 {
                if _contains(visited, neighbors[j]) == false {
                    stack.push(neighbors[j])
                }
                j = j - 1
            }
        }
    }
    visited
}

fn graph_has_path(g, src, dst) {
    if src == dst { return true }
    let reachable = graph_bfs(g, src)
    _contains(reachable, dst)
}

fn graph_num_components(g) {
    let n = len(g)
    let mut all_visited = []
    let mut components = 0
    let mut i = 0
    while i < n {
        if _contains(all_visited, i) == false {
            components = components + 1
            let reached = graph_bfs(g, i)
            let mut j = 0
            while j < len(reached) {
                all_visited.push(reached[j])
                j = j + 1
            }
        }
        i = i + 1
    }
    components
}

// ── end inlined ───────────────────────────────────────────────────

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn arrays_equal(a, b) {
    if len(a) != len(b) { return false }
    let mut i = 0
    while i < len(a) {
        if to_string(a[i]) != to_string(b[i]) { return false }
        i = i + 1
    }
    true
}

