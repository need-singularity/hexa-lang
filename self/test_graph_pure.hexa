println("  graph_pure.hexa — test runner")
println("═══════════════════════════════════════════════════════")

// ── graph_new ──────────────────────────────────────────────────
println("")
println("--- graph_new ---")
let g0 = graph_new(4)
check("graph_new size", len(g0), 4)
check("graph_new node0 empty", len(g0[0]), 0)
check("graph_new node3 empty", len(g0[3]), 0)

// ── graph_add_edge ─────────────────────────────────────────────
println("")
println("--- graph_add_edge ---")
let g1 = graph_add_edge(graph_new(3), 0, 1)
check("add_edge 0-1 node0", _contains(g1[0], 1), true)
check("add_edge 0-1 node1", _contains(g1[1], 0), true)
check("add_edge 0-1 node2 empty", len(g1[2]), 0)

// ── graph_add_directed ─────────────────────────────────────────
println("")
println("--- graph_add_directed ---")
let gd = graph_add_directed(graph_new(3), 0, 2)
check("add_dir 0->2 node0", _contains(gd[0], 2), true)
check("add_dir 0->2 node2 no back", _contains(gd[2], 0), false)

// ── BFS: linear chain 0-1-2-3 ──────────────────────────────────
println("")
println("--- BFS linear chain ---")
let mut gc = graph_new(4)
gc = graph_add_edge(gc, 0, 1)
gc = graph_add_edge(gc, 1, 2)
gc = graph_add_edge(gc, 2, 3)
let mut bfs_order = []
bfs_order = graph_bfs(gc, 0)
check("bfs len", len(bfs_order), 4)
check("bfs starts at 0", bfs_order[0], 0)
check("bfs visits all", _contains(bfs_order, 3), true)

// ── DFS: linear chain ──────────────────────────────────────────
println("")
println("--- DFS linear chain ---")
let mut dfs_order = []
dfs_order = graph_dfs(gc, 0)
check("dfs len", len(dfs_order), 4)
check("dfs starts at 0", dfs_order[0], 0)
check("dfs visits all", _contains(dfs_order, 3), true)

// ── has_path ───────────────────────────────────────────────────
println("")
println("--- has_path ---")
check("has_path 0->3", graph_has_path(gc, 0, 3), true)
check("has_path self", graph_has_path(gc, 2, 2), true)

// disconnected graph
let mut gd2 = graph_new(4)
gd2 = graph_add_edge(gd2, 0, 1)
// 2 and 3 are isolated
check("no path 0->2", graph_has_path(gd2, 0, 2), false)

// ── num_components ─────────────────────────────────────────────
println("")
println("--- num_components ---")
check("chain components", graph_num_components(gc), 1)
check("disconnected components", graph_num_components(gd2), 3)

let mut g_all_iso = graph_new(5)
check("all isolated", graph_num_components(g_all_iso), 5)

let mut g_one = graph_new(1)
check("single node", graph_num_components(g_one), 1)

// ── Summary ────────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    println("FAIL")
    exit(1)
}
println("ALL PASS")
