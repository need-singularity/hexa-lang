// self/raw_loader.hexa — .raw / .own 파일 파서
// SSOT 포맷: hexa-like directive
//   raw <num> <status> "<name>"
//     <key> <value...>
//     ...
//   (빈 줄 = rule 구분, # = 주석, 같은 key 여러 줄 = 배열)
// 배열풀 SSOT: .raw 의 raw:self-format rule — keys / statuses-rule / statuses-roadmap / statuses-loop.
// 코드는 런타임 파싱만 — 하드코딩 pool 없음 (_extract_pool 이 텍스트 스캔). 풀 미선언 시 tolerant fallback.
// 주: 'hook' 키는 2026-04-19 폐기 (git-hook 전면 제거). 파일에 잔존 시 deprecated warning 후 skip.
// slug: stable identifier (번호와 독립). 외부 참조는 raw:<slug> 형식 — 번호 shift 에 불변. 순서 변경 잦음 → num 참조 금지.

use "self/core/law_io"

fn _rstrip(s: string) -> string {
    let mut end = len(s)
    while end > 0 {
        let c = s.substring(end - 1, end)
        if c == " " || c == "\t" || c == "\r" {
            end = end - 1
        } else {
            break
        }
    }
    return s.substring(0, end)
}

// chain-kind additions (raw#0 forward-chain): step.<id>.<prop> flat keys
// are accepted in addition to the declared whitelist. Prefix match here
// lets .chain files declare arbitrary step ids without parser extension.
fn _is_chain_step_key(k: string) -> bool {
    if len(k) < 6 { return false }
    if k.substring(0, 5) != "step." { return false }
    let rest = k.substring(5, len(k))
    if rest.index_of(".") < 0 { return false }
    return true
}

// ─── runtime pool extraction from .raw raw:self-format ──────────────
// Public entry point for bracket-array values — `['a','b','c']` syntax.
// Also the conventional parser for the new `refs` key (cross-rule slug lists).
// `parse_slug_array` is the canonical name; `_parse_brackarr_tok` kept as a
// thin alias for legacy call sites inside this file.
pub fn parse_slug_array(s: string) -> array {
    let t = s.trim()
    let n = len(t)
    if n < 2 { return [] }
    if t.substring(0, 1) != "[" { return [] }
    if t.substring(n - 1, n) != "]" { return [] }
    let inner = t.substring(1, n - 1)
    let parts = split(inner, ",")
    let mut out = []
    for p in parts {
        let q = p.trim()
        let qn = len(q)
        if qn == 0 { continue }
        let first = q.substring(0, 1)
        let last = q.substring(qn - 1, qn)
        if (first == "'" && last == "'") || (first == "\"" && last == "\"") {
            out.push(q.substring(1, qn - 1))
        } else {
            out.push(q)
        }
    }
    return out
}

let mut __pool_raw_path_cache = ""
fn _pool_raw_path() -> string {
    // Cached — called ~130+ times per verify run (every is_valid_raw_key +
    // every allowed_status_for_kind through the validator). Single concat amortized.
    if __pool_raw_path_cache != "" { return __pool_raw_path_cache }
    let mut p = env("PWD")
    if p == "" { p = to_string(exec("pwd")).trim() }
    let parts = [p, "/.raw"]
    __pool_raw_path_cache = parts.join("")
    return __pool_raw_path_cache
}

// 순수 텍스트 스캔 — is_valid_raw_key 호출 없음 (chicken-egg 회피)
fn _extract_pool() -> array {
    let path = _pool_raw_path()
    if !file_exists(path) { return [[], [], [], []] }
    let src = to_string(read_file(path))
    let lines = split(src, "\n")
    let mut in_target = false
    let mut p_keys = []
    let mut p_sr = []
    let mut p_sm = []
    let mut p_sl = []
    for raw_line in lines {
        let line = _rstrip(raw_line)
        if len(line) == 0 { in_target = false; continue }
        let first = line.substring(0, 1)
        if first == "#" { continue }
        if first != " " && first != "\t" {
            in_target = false
            continue
        }
        let stripped = line.trim_start()
        let sp = stripped.index_of(" ")
        if sp < 0 { continue }
        let k = stripped.substring(0, sp)
        let v = stripped.substring(sp + 1, len(stripped)).trim()
        if k == "slug" {
            if v == "self-format" { in_target = true } else { in_target = false }
            continue
        }
        if !in_target { continue }
        if k == "keys"             { p_keys = parse_slug_array(v) }
        else if k == "statuses-rule"    { p_sr   = parse_slug_array(v) }
        else if k == "statuses-roadmap" { p_sm   = parse_slug_array(v) }
        else if k == "statuses-loop"    { p_sl   = parse_slug_array(v) }
    }
    return [p_keys, p_sr, p_sm, p_sl]
}

pub fn is_valid_raw_status(s: string) -> bool {
    let pool = _extract_pool()
    let arr = pool[1]
    if len(arr) == 0 { return true }
    for v in arr { if v == s { return true } }
    return false
}

pub fn is_valid_raw_key(k: string) -> bool {
    if _is_chain_step_key(k) { return true }
    let pool = _extract_pool()
    let arr = pool[0]
    if len(arr) == 0 { return true }
    for v in arr { if v == k { return true } }
    return false
}

// local (forward-ref-free) chain-status check for _parse_header
fn _chain_status_ok(s: string) -> bool {
    if s == "live" || s == "paused" || s == "planned" || s == "deferred" { return true }
    return false
}

// header: `raw 1 warn "name text"` / `own 2 live ...` / `chain 1 live ...`
// returns [kind, id, status, name] or []
fn _parse_header(line: string) -> array {
    let sp1 = line.index_of(" ")
    if sp1 < 0 { return [] }
    let kind = line.substring(0, sp1)
    if kind != "raw" && kind != "own" && kind != "chain" { return [] }

    let rest1 = line.substring(sp1 + 1, len(line))
    let sp2 = rest1.index_of(" ")
    if sp2 < 0 { return [] }
    let id = rest1.substring(0, sp2)

    let rest2 = rest1.substring(sp2 + 1, len(rest1))
    let sp3 = rest2.index_of(" ")
    if sp3 < 0 { return [] }
    let status = rest2.substring(0, sp3)
    if kind == "chain" {
        if !_chain_status_ok(status) { return [] }
    } else {
        if !is_valid_raw_status(status) { return [] }
    }

    let mut name = rest2.substring(sp3 + 1, len(rest2)).trim()
    if len(name) >= 2 && name.substring(0, 1) == "\"" {
        name = name.substring(1, len(name) - 1)
    }
    return [kind, id, status, name]
}

// ─── strict format validator (spec A) ──────────────────────────────
// 규칙:
//   · column 0: 3종만 — rule header / # 주석 / 빈 줄 (whitespace-only 금지)
//   · column 2: `  <key>(\s+.*)?` — 정확히 2 스페이스 indent + key 토큰
//   · 전역 금지: tab 문자, trailing whitespace, 0/2 이외 indent
//   · 구조: 2 rule header 사이 ≥1 빈 줄 (EOF 는 관대)
// 반환: error 문자열 배열 (빈 배열 = pass). 포맷:
//   "[<path>:<lineno>] <reason>: <line>"  (line >80 자 truncate)
fn _fmt_trunc(s: string) -> string {
    if len(s) <= 80 { return s }
    return s.substring(0, 80) + "…"
}

fn _fmt_is_header_token(line: string) -> bool {
    // "raw|own|ext|roadmap|loop|chain|checkpoint <id> <status?> \"...\""
    // checkpoint is an inline .roadmap section kind (CP1/CP2/FINAL). Id is
    // alphanumeric (not digits-only) and status field is optional — the
    // name is the next quoted token.
    let sp = line.index_of(" ")
    if sp < 0 { return false }
    let kind = line.substring(0, sp)
    if kind != "raw" && kind != "own" && kind != "ext" && kind != "roadmap" && kind != "loop" && kind != "chain" && kind != "checkpoint" { return false }
    return true
}

fn _fmt_count_leading_spaces(line: string) -> int {
    let mut i = 0
    let n = len(line)
    while i < n {
        let c = line.substring(i, i + 1)
        if c != " " { break }
        i = i + 1
    }
    return i
}

fn _fmt_has_tab(line: string) -> bool {
    return line.contains("\t")
}

fn _fmt_trailing_ws(line: string) -> bool {
    let n = len(line)
    if n == 0 { return false }
    let last = line.substring(n - 1, n)
    if last == " " || last == "\t" || last == "\r" { return true }
    return false
}

// column-2 key-line ident: `  <[a-zA-Z][a-zA-Z0-9_-]*>(\s+.*)?`
// NOTE: interp string range-compare (`c >= "a"`) 불안정 → .contains 으로 교체
fn _fmt_alpha() -> string { return "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ" }
// alnum now includes `.` so chain-kind flat keys like `step.<id>.<prop>` validate.
// First char still must be alpha (guarded in _fmt_is_ident_char); dot only in tail.
fn _fmt_alnum() -> string { return "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_-." }
fn _fmt_digits() -> string { return "0123456789" }

fn _fmt_is_ident_char(c: string, first: bool) -> bool {
    if len(c) == 0 { return false }
    if first { return _fmt_alpha().contains(c) }
    return _fmt_alnum().contains(c)
}

fn _fmt_validate_key_line(line: string) -> bool {
    // caller: line starts with exactly "  " (2 spaces), len >= 3
    let n = len(line)
    if n < 3 { return false }
    let first_c = line.substring(2, 3)
    if !_fmt_is_ident_char(first_c, true) { return false }
    let mut i = 3
    while i < n {
        let c = line.substring(i, i + 1)
        if c == " " || c == "\t" { return true }  // key 뒤 whitespace OK (값 있음)
        if !_fmt_is_ident_char(c, false) { return false }
        i = i + 1
    }
    // key 만 있고 값 없음도 허용 (spec A: `(\s+.*)?` optional)
    return true
}

// kind-aware status whitelist — raw/own/ext share rule-lifecycle,
// roadmap uses phase-lifecycle, loop uses schedule-lifecycle
pub fn allowed_status_for_kind(kind: string) -> array {
    if kind == "raw" || kind == "own" || kind == "ext" {
        return ["live", "warn", "new", "deferred", "convention"]
    }
    if kind == "roadmap" {
        return ["planned", "active", "done", "blocked", "deferred"]
    }
    if kind == "loop" {
        return ["live", "paused", "convention", "deferred"]
    }
    if kind == "chain" {
        // chain-kind (raw#0 forward-chain) — 4 status tokens
        return ["live", "paused", "planned", "deferred"]
    }
    if kind == "checkpoint" {
        // checkpoint-kind (.roadmap inline anchors) — 4 status tokens
        return ["planned", "active", "done", "deferred"]
    }
    return []
}

pub fn is_valid_status_for_kind(kind: string, s: string) -> bool {
    for v in allowed_status_for_kind(kind) { if v == s { return true } }
    return false
}

// Canonical status-strength ladder for rule/own/ext-kind statuses.
// Weakest → strongest: new < deferred < convention < warn < live
//
// Rationale: an advisory *violation* ("warn") is strictly stronger than
// an advisory *style note* ("convention"), which is itself stronger than
// a pending-activation ("deferred") or a freshly-declared scaffold
// ("new"). This matches the existing project-wide convention used by
// tool/own_inherit_lint.hexa and tool/own_lint.hexa (landed 59fa41f8) —
// pinned here to avoid silent semantic drift across linters.
//
// Returns -1 for unknown status strings so callers can detect typos
// (e.g. planned/active/done — those belong to the roadmap-kind ladder,
// not rule-kind).
pub fn status_strength(s: string) -> int {
    if s == "live" { return 4 }
    if s == "warn" { return 3 }
    if s == "convention" { return 2 }
    if s == "deferred" { return 1 }
    if s == "new" { return 0 }
    return -1
}

pub fn whitelist_str_for_kind(kind: string) -> string {
    let mut parts = []
    for v in allowed_status_for_kind(kind) {
        parts.push(v)
    }
    return parts.join(" ")
}

// rule header 정규 검증:
//   ^(raw|own|ext|roadmap|loop|chain) \d+ <status> "<non-empty>"$
//   ^checkpoint <alnum-id> "<non-empty>"$   (status implicit=planned; id = CP1/CP2/FINAL/...)
fn _fmt_validate_header(line: string) -> bool {
    let sp1 = line.index_of(" ")
    if sp1 < 0 { return false }
    let kind = line.substring(0, sp1)
    if kind != "raw" && kind != "own" && kind != "ext" && kind != "roadmap" && kind != "loop" && kind != "chain" && kind != "checkpoint" { return false }

    let rest1 = line.substring(sp1 + 1, len(line))
    let sp2 = rest1.index_of(" ")
    if sp2 < 0 { return false }
    let id = rest1.substring(0, sp2)
    if len(id) == 0 { return false }
    // id = digits only (except checkpoint where id is alnum, `[A-Za-z0-9_-]+`).
    let mut i = 0
    if kind == "checkpoint" {
        let alnum = _fmt_alnum()
        while i < len(id) {
            let c = id.substring(i, i + 1)
            if !alnum.contains(c) { return false }
            i = i + 1
        }
    } else {
        let digits = _fmt_digits()
        while i < len(id) {
            let c = id.substring(i, i + 1)
            if !digits.contains(c) { return false }
            i = i + 1
        }
    }

    let rest2 = rest1.substring(sp2 + 1, len(rest1))
    // checkpoint headers have no explicit status token — name follows id.
    if kind == "checkpoint" {
        let np2 = len(rest2)
        if np2 < 2 { return false }
        if rest2.substring(0, 1) != "\"" { return false }
        if rest2.substring(np2 - 1, np2) != "\"" { return false }
        if np2 < 3 { return false }
        return true
    }
    let sp3 = rest2.index_of(" ")
    if sp3 < 0 { return false }
    let status = rest2.substring(0, sp3)
    if !is_valid_status_for_kind(kind, status) { return false }

    let name_part = rest2.substring(sp3 + 1, len(rest2))
    let np = len(name_part)
    if np < 2 { return false }
    if name_part.substring(0, 1) != "\"" { return false }
    if name_part.substring(np - 1, np) != "\"" { return false }
    // name 내부 non-empty
    if np < 3 { return false }
    return true
}

fn _fmt_err(path: string, line_no: int, reason: string, raw_line: string) -> string {
    // Lazy error assembly — only called when an issue is detected. Keeps the
    // PASS hot loop at 0 string concats (was 4 per line × 5 files = O(n²)).
    let parts = ["[", path, ":", to_string(line_no), "] ", reason, _fmt_trunc(raw_line)]
    return parts.join("")
}

pub fn validate_strict(path: string) -> array {
    let mut errs = []
    if !file_exists(path) { return errs }

    let src = to_string(read_file(path))
    let lines = split(src, "\n")

    // prev_nonblank_kind: "header" | "key" | "comment" | "none"
    // saw_blank_since: 마지막 non-blank 이후 blank line 이 있었는지
    let mut prev_kind = "none"
    let mut saw_blank_since = true
    let mut line_no = 0
    let total = len(lines)

    for raw_line in lines {
        line_no = line_no + 1
        // 마지막 가상 empty line (split trailing newline) — EOF 관대: skip
        if line_no == total && len(raw_line) == 0 { continue }

        // 1) tab 탐지 (전역)
        if _fmt_has_tab(raw_line) {
            errs.push(_fmt_err(path, line_no, "tab forbidden: ", raw_line))
        }
        // 2) trailing whitespace (전역)
        if _fmt_trailing_ws(raw_line) {
            errs.push(_fmt_err(path, line_no, "trailing whitespace: ", raw_line))
        }

        let ln_len = len(raw_line)

        // 3) 빈 줄
        if ln_len == 0 {
            saw_blank_since = true
            continue
        }

        let lead = _fmt_count_leading_spaces(raw_line)
        // whitespace-only 라인 — trailing_ws 로 이미 잡혔음. blank 취급
        if lead == ln_len {
            saw_blank_since = true
            continue
        }

        // 4) 주석: column 0 에서 # 시작
        if lead == 0 && raw_line.substring(0, 1) == "#" {
            prev_kind = "comment"
            saw_blank_since = false
            continue
        }

        // 5) column-0 이면 rule header 여야 함
        if lead == 0 {
            if !_fmt_is_header_token(raw_line) {
                errs.push(_fmt_err(path, line_no, "unknown column-0 line (expected `raw|own|ext|roadmap|loop` header or `#` comment): ", raw_line))
                prev_kind = "header"
                saw_blank_since = false
                continue
            }
            if !_fmt_validate_header(raw_line) {
                errs.push(_fmt_err(path, line_no, "malformed rule header: ", raw_line))
            }
            // 직전 non-blank 이 key 이고 그 사이 blank 없으면 에러
            if prev_kind == "key" && !saw_blank_since {
                errs.push(_fmt_err(path, line_no, "rule header needs preceding blank line: ", raw_line))
            }
            prev_kind = "header"
            saw_blank_since = false
            continue
        }

        // 6) indent == 2 : key line
        if lead == 2 {
            if !_fmt_validate_key_line(raw_line) {
                errs.push(_fmt_err(path, line_no, "malformed key line (expected `  <ident>[ value]`): ", raw_line))
            }
            prev_kind = "key"
            saw_blank_since = false
            continue
        }

        // 7) 그 외 indent (1 / 3 / 4 / tab 이후 등) 전부 실패
        let parts = ["bad indent (only 0 or 2 spaces allowed, got ", to_string(lead), "): "]
        errs.push(_fmt_err(path, line_no, parts.join(""), raw_line))
        prev_kind = "key"
        saw_blank_since = false
    }

    return errs
}

// returns array of rules; each rule = [id, status, name, keys]
// where keys = array of [key, value] (repeated keys preserved in order)
pub fn load_raw_file(path: string) -> array {
    if !file_exists(path) { return [] }

    let src = to_string(read_file(path))
    let lines = split(src, "\n")

    let mut rules = []
    let mut cur_id = ""
    let mut cur_status = ""
    let mut cur_name = ""
    let mut cur_keys = []
    let mut has_rule = false
    let mut line_no = 0

    for raw_line in lines {
        line_no = line_no + 1
        let line = _rstrip(raw_line)
        if len(line) == 0 {
            if has_rule {
                rules.push([cur_id, cur_status, cur_name, cur_keys])
                has_rule = false
                cur_keys = []
            }
            continue
        }
        let first = line.substring(0, 1)
        if first == "#" { continue }

        if first == " " || first == "\t" {
            if !has_rule { continue }
            let stripped = line.trim_start()
            let sp = stripped.index_of(" ")
            if sp < 0 { continue }
            let key = stripped.substring(0, sp)
            let val = stripped.substring(sp + 1, len(stripped)).trim()
            if !is_valid_raw_key(key) {
                if key == "hook" {
                    // deprecated 2026-04-19: git-hooks fully removed. silent skip.
                    continue
                }
                eprintln("warn[raw_loader]: " + path + ":" + to_string(line_no) +
                         " unknown key '" + key + "' (whitelist 외) — 14 키 확인")
                continue
            }
            cur_keys.push([key, val])
        } else {
            if has_rule {
                rules.push([cur_id, cur_status, cur_name, cur_keys])
                cur_keys = []
            }
            let hdr = _parse_header(line)
            if len(hdr) == 0 {
                eprintln("warn[raw_loader]: " + path + ":" + to_string(line_no) +
                         " bad header — " + line)
                has_rule = false
                continue
            }
            cur_id = hdr[1]
            cur_status = hdr[2]
            cur_name = hdr[3]
            has_rule = true
        }
    }
    if has_rule {
        rules.push([cur_id, cur_status, cur_name, cur_keys])
    }
    return rules
}

pub fn keys_first(keys: array, key: string) -> string {
    for kv in keys {
        if kv[0] == key { return kv[1] }
    }
    return ""
}

pub fn keys_all(keys: array, key: string) -> array {
    let mut out = []
    for kv in keys {
        if kv[0] == key { out.push(kv[1]) }
    }
    return out
}

// derive enforce level from rule keys: script | convention | -
// (git-hook level retired 2026-04-19 — no hook key anywhere)
pub fn rule_level(rule: array) -> string {
    let keys = rule[3]
    if keys_first(keys, "enforce") != "" { return "script" }
    if rule[1] == "deferred" { return "-" }
    return "convention"
}

// derive short action string from why/note/decl
pub fn rule_action(rule: array) -> string {
    let keys = rule[3]
    let why = keys_first(keys, "why")
    if why != "" { return why }
    let note = keys_first(keys, "note")
    if note != "" { return note }
    let decl = keys_first(keys, "decl")
    if decl != "" { return "decl: " + decl }
    return ""
}
