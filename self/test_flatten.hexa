// =====================================================================
//  test_flatten.hexa -- @flatten (SROA) tests
//
//  @flatten decomposes struct arguments into scalar values for
//  register passing, eliminating memory indirection.
//  Validates: struct field access, scalar decomposition, correctness.
//
//  Run: ./hexa test self/test_flatten.hexa
// =====================================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_bool(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

println("=====================================================")
println("  HEXA @flatten (SROA) Test Suite")
println("=====================================================")
println("")

// -- 1. Basic struct field access --
println("--- 1. Basic struct SROA ---")

struct Point {
    x: int,
    y: int
}

@flatten fn point_distance_sq(p) {
    return p.x * p.x + p.y * p.y
}

let pt1 = Point { x: 3, y: 4 }
check("flatten point_distance_sq", point_distance_sq(pt1), 25)

// -- 2. Two-struct parameter --
println("")
println("--- 2. Two-struct SROA ---")

@flatten fn point_add(a, b) {
    return Point { x: a.x + b.x, y: a.y + b.y }
}

let pa = Point { x: 1, y: 2 }
let pb = Point { x: 3, y: 4 }
let pc = point_add(pa, pb)
check("flatten point_add x", pc.x, 4)
check("flatten point_add y", pc.y, 6)

// -- 3. Struct with computation --
println("")
println("--- 3. Struct computation ---")

struct Vec3 {
    x: int,
    y: int,
    z: int
}

@flatten fn vec3_dot(a, b) {
    return a.x * b.x + a.y * b.y + a.z * b.z
}

let va = Vec3 { x: 1, y: 2, z: 3 }
let vb = Vec3 { x: 4, y: 5, z: 6 }
check("flatten vec3_dot", vec3_dot(va, vb), 32)

// -- 4. @flatten + @pure combination --
println("")
println("--- 4. @flatten + @pure ---")

@flatten @pure fn point_mag_sq(p) {
    return p.x * p.x + p.y * p.y
}

let pm1 = point_mag_sq(pt1)
let pm2 = point_mag_sq(pt1)
check("flatten+pure value", pm1, 25)
check("flatten+pure same", pm1 == pm2, true)

// -- 5. Struct with scalar mix --
println("")
println("--- 5. Struct + scalar mix ---")

@flatten fn point_scale(p, factor) {
    return Point { x: p.x * factor, y: p.y * factor }
}

let ps = point_scale(Point { x: 2, y: 3 }, 5)
check("flatten point_scale x", ps.x, 10)
check("flatten point_scale y", ps.y, 15)

// -- 6. Nested field access --
println("")
println("--- 6. Multiple field uses ---")

@flatten fn point_manhattan(a, b) {
    let dx = a.x - b.x
    let dy = a.y - b.y
    let mut result = dx
    if dx < 0 { result = 0 - dx }
    let mut ry = dy
    if dy < 0 { ry = 0 - dy }
    return result + ry
}

check("flatten manhattan", point_manhattan(Point { x: 1, y: 2 }, Point { x: 4, y: 6 }), 7)

// -- 7. @flatten with @inline --
println("")
println("--- 7. @flatten + @inline ---")

@flatten @inline fn point_eq(a, b) {
    return a.x == b.x && a.y == b.y
}

check("flatten+inline eq true", point_eq(Point { x: 1, y: 2 }, Point { x: 1, y: 2 }), true)
check("flatten+inline eq false", point_eq(Point { x: 1, y: 2 }, Point { x: 3, y: 4 }), false)

// -- 8. Vec3 cross product --
println("")
println("--- 8. Vec3 cross product ---")

@flatten fn vec3_cross_x(a, b) {
    return a.y * b.z - a.z * b.y
}

@flatten fn vec3_cross_y(a, b) {
    return a.z * b.x - a.x * b.z
}

@flatten fn vec3_cross_z(a, b) {
    return a.x * b.y - a.y * b.x
}

let ca = Vec3 { x: 1, y: 0, z: 0 }
let cb = Vec3 { x: 0, y: 1, z: 0 }
check("flatten cross_x", vec3_cross_x(ca, cb), 0)
check("flatten cross_y", vec3_cross_y(ca, cb), 0)
check("flatten cross_z", vec3_cross_z(ca, cb), 1)

// -- 9. Struct zero --
println("")
println("--- 9. Struct zero ---")

@flatten fn point_is_origin(p) {
    return p.x == 0 && p.y == 0
}

check("flatten is_origin true", point_is_origin(Point { x: 0, y: 0 }), true)
check("flatten is_origin false", point_is_origin(Point { x: 1, y: 0 }), false)

// -- 10. @flatten with accumulation --
println("")
println("--- 10. @flatten accumulation ---")

@flatten fn weighted_sum(p, w) {
    return p.x * w.x + p.y * w.y
}

check("flatten weighted_sum", weighted_sum(Point { x: 3, y: 5 }, Point { x: 2, y: 4 }), 26)

// -- Summary --
println("")
println("=====================================================")
println("  @flatten tests: " + to_string(pass_count) + " PASS, " + to_string(fail_count) + " FAIL")
println("=====================================================")
if fail_count > 0 {
    println("SOME TESTS FAILED")
}
