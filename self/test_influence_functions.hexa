// -- inlined from self/ml/influence_functions.hexa --
// codegen import not wired for test files

// ═══════════════════════════════════════════════════════════════════
//  self/ml/influence_functions.hexa — Influence Functions (#282)
//
//  Koh & Liang 2017:
//
//      I_up,loss(z_test, z_train) = -∇_θ L(z_test)ᵀ · H⁻¹ · ∇_θ L(z_train)
//
//  We use a small logistic regression model (binary classifier) so
//  that gradients and the Hessian are closed-form.  To avoid full
//  matrix inversion we keep only a diagonal Hessian approximation.
//
//  Model:  p(y=1|x) = σ(wᵀx)
//  Loss :  -y·log p - (1-y)·log(1-p)
//  ∇L   :  (p - y) · x
//  H_ii :  (1/N) Σ p_n (1-p_n) x_{n,i}² + λ      (λ = damping)
//
//  API:
//    if_sigmoid(inp)                                 -> float
//    if_forward(w, feat)                             -> float         // prob
//    if_loss(w, feat, label)                         -> float
//    if_grad(w, feat, label)                         -> [float]
//    if_dataset_loss(w, X, Y)                        -> float
//    if_diag_hessian(w, X, damping)                  -> [float]
//    if_hvp_inv(grad, diag_H)                        -> [float]
//    if_influence(w, z_test_feat, z_test_label, z_train_feat, z_train_label, diag_H) -> float
//    if_rank_train(w, test_feat, test_label, X, Y, damping) -> #{"scores","order"}
//    if_fit_logreg(X, Y, lr, steps)                  -> [float]
// ═══════════════════════════════════════════════════════════════════

fn if_exp(inp) {
    let mut v = inp
    if v > 20.0 { v = 20.0 }
    if v < -20.0 { v = -20.0 }
    let mut result = 1.0
    let mut term = 1.0
    let mut i = 1

    while i < 30 {
        term = term * v / to_float(i)
        result = result + term
    }
    if result < 0.0 { return 0.0 }
    return result
}

fn if_log(inp) {
    if inp <= 0.0 { return -30.0 }
    let mut v = inp
    let mut count = 0
    while v > 2.0 {
        v = v / 2.718281828
        count = count + 1
    }
    while v < 0.5 {
        v = v * 2.718281828
        count = count - 1
    }
    let d = v - 1.0
    let ln_v = d - d * d / 2.0 + d * d * d / 3.0 - d * d * d * d / 4.0
    return to_float(count) + ln_v
}

fn if_zeros(n) {
    let mut v = []
    let mut _i = 0

    while _i < n { v = v + [0.0] }
    return v
}

@pure
fn if_sigmoid(inp) {
    if inp >= 0.0 {
        let e = if_exp(0.0 - inp)
        return 1.0 / (1.0 + e)
    } else {
        let e = if_exp(inp)
        return e / (1.0 + e)
    }
}

// ═══════════════════════════════════════════════════════════════════
//  1. Forward, loss, gradient for one example
// ═══════════════════════════════════════════════════════════════════

@pure
fn if_forward(w, feat) {
    let D = len(w)
    let mut s = 0.0
    let mut j = 0

    while j < D { s = s + w[j] * feat[j] }
    return if_sigmoid(s)
}

@pure
fn if_loss(w, feat, label) {
    let p = if_forward(w, feat)
    let mut pp = p
    if pp < 1.0e-12 { pp = 1.0e-12 }
    if pp > 1.0 - 1.0e-12 { pp = 1.0 - 1.0e-12 }
    if label == 1 {
        return 0.0 - if_log(pp)
    }
    return 0.0 - if_log(1.0 - pp)
}

@pure
fn if_grad(w, feat, label) {
    let D = len(w)
    let p = if_forward(w, feat)
    let diff = p - to_float(label)
    let mut g = if_zeros(D)
    let mut j = 0

    while j < D {
        g[j] = diff * feat[j]
    }
    return g
}

@pure
fn if_dataset_loss(w, X, Y) {
    let n = len(X)
    if n == 0 { return 0.0 }
    let mut s = 0.0
    let mut i = 0

    while i < n {
        s = s + if_loss(w, X[i], Y[i])
    }
    return s / to_float(n)
}

// ═══════════════════════════════════════════════════════════════════
//  2. Diagonal Hessian
//
//  H_ii = (1/N) Σ p_n(1-p_n) x_{n,i}² + damping
// ═══════════════════════════════════════════════════════════════════

@pure
fn if_diag_hessian(w, X, damping) {
    let n = len(X)
    let D = len(w)
    let mut diag_H = if_zeros(D)
    if n == 0 {
        let mut j = 0

        while j < D { diag_H[j] = damping }
        return diag_H
    }
    let mut i = 0

    while i < n {
        let p = if_forward(w, X[i])
        let v = p * (1.0 - p)
        let mut j = 0

        while j < D {
            diag_H[j] = diag_H[j] + v * X[i][j] * X[i][j]
        }
    }
    let nf = to_float(n)
    let mut j = 0

    while j < D {
        diag_H[j] = diag_H[j] / nf + damping
    }
    return diag_H
}

// ═══════════════════════════════════════════════════════════════════
//  3. Diagonal H⁻¹ applied to a gradient vector
// ═══════════════════════════════════════════════════════════════════

@pure
fn if_hvp_inv(grad, diag_H) {
    let D = len(grad)
    let mut out = if_zeros(D)
    let mut j = 0

    while j < D {
        let mut d = diag_H[j]
        if ofa_abs_fallback(d) < 1.0e-12 { d = 1.0e-12 }
        out[j] = grad[j] / d
    }
    return out
}

fn ofa_abs_fallback(inp) {
    if inp < 0.0 { return 0.0 - inp }
    return inp
}

// ═══════════════════════════════════════════════════════════════════
//  4. Influence of z_train on z_test
//
//  I = -∇L(z_test)ᵀ · H⁻¹ · ∇L(z_train)
// ═══════════════════════════════════════════════════════════════════

@pure
fn if_influence(w, z_test_feat, z_test_label, z_train_feat, z_train_label, diag_H) {
    let g_test = if_grad(w, z_test_feat, z_test_label)
    let g_train = if_grad(w, z_train_feat, z_train_label)
    let h_inv_g_train = if_hvp_inv(g_train, diag_H)
    let D = len(g_test)
    let mut s = 0.0
    let mut j = 0

    while j < D { s = s + g_test[j] * h_inv_g_train[j] }
    return 0.0 - s
}

// ═══════════════════════════════════════════════════════════════════
//  5. Rank training samples by absolute influence on a test point
//
//  Returns descending indices of |influence|.
// ═══════════════════════════════════════════════════════════════════

@pure
fn if_rank_train(w, test_feat, test_label, X, Y, damping) {
    let n = len(X)
    let diag_H = if_diag_hessian(w, X, damping)
    let mut scores = if_zeros(n)
    let mut i = 0

    while i < n {
        scores[i] = if_influence(w, test_feat, test_label, X[i], Y[i], diag_H)
    }
    // Sort indices by |score| descending via simple selection sort.
    let mut order = []
    let mut i = 0

    while i < n { order = order + [i] }
    let mut i = 0

    while i < n {
        let mut best = i
        let mut best_v = ofa_abs_fallback(scores[order[i]])
        let mut j = (i + 1)

        while j < n {
            let v = ofa_abs_fallback(scores[order[j]])
            if v > best_v {
                best_v = v
                best = j
            }
        }
        if best != i {
            let tmp = order[i]
            order[i] = order[best]
            order[best] = tmp
        }
    }
    return #{
        "scores": scores,
        "order": order
    }
}

// ═══════════════════════════════════════════════════════════════════
//  6. Tiny logistic regression trainer — used by tests
// ═══════════════════════════════════════════════════════════════════

@hot
fn if_fit_logreg(X, Y, lr, steps) {
    let n = len(X)
    if n == 0 { return [] }
    let D = len(X[0])
    let mut w = if_zeros(D)
    let mut _s = 0

    while _s < steps {
        let mut g = if_zeros(D)
        let mut i = 0

        while i < n {
            let p = if_forward(w, X[i])
            let diff = p - to_float(Y[i])
            let mut j = 0

            while j < D {
                g[j] = g[j] + diff * X[i][j]
            }
        }
        let nf = to_float(n)
        let mut j = 0

        while j < D {
            w[j] = w[j] - lr * g[j] / nf
        }
    }
    return w
}

println("[influence_functions] loaded — logreg gradient + diagonal Hessian⁻¹ scoring")


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs_(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx_(a, b, eps) { return fabs_(a - b) < eps }

println("=== Influence Functions (#282) Tests ===")

// ── T1 sigmoid(0) = 0.5 ─────────────────────────────────────────
check("T1 sigmoid(0)=0.5", approx_(if_sigmoid(0.0), 0.5, 1.0e-6))
check("T1 sigmoid(10)≈1", approx_(if_sigmoid(10.0), 1.0, 1.0e-3))
let ten_neg = 0.0 - 10.0
check("T1 sigmoid(-10)≈0", approx_(if_sigmoid(ten_neg), 0.0, 1.0e-3))

// ── T2 forward linear combination ──────────────────────────────
let w2 = [2.0, -1.0]
let f2 = if_forward(w2, [1.0, 0.0])
check("T2 forward σ(2)", approx_(f2, if_sigmoid(2.0), 1.0e-9))

// ── T3 loss is non-negative ────────────────────────────────────
let l3a = if_loss(w2, [1.0, 0.0], 1)
let l3b = if_loss(w2, [1.0, 0.0], 0)
check("T3 loss >=0 a", l3a >= 0.0)
check("T3 loss >=0 b", l3b >= 0.0)
check("T3 correct label smaller loss", l3a < l3b)

// ── T4 gradient shape and sign ─────────────────────────────────
let g4 = if_grad(w2, [1.0, 0.0], 1)
check("T4 grad len 2", len(g4) == 2)
// p = σ(2) ≈ 0.88, diff = p - 1 ≈ -0.12, so grad[0] = diff * 1 = negative
check("T4 grad[0] negative", g4[0] < 0.0)

// ── T5 diag Hessian positive ───────────────────────────────────
let X5 = [
    [1.0, 0.0],
    [0.0, 1.0],
    [1.0, 1.0]
]
let dH5 = if_diag_hessian(w2, X5, 0.01)
check("T5 diag H len 2", len(dH5) == 2)
check("T5 diag H[0] >= damping", dH5[0] >= 0.01)
check("T5 diag H[1] >= damping", dH5[1] >= 0.01)

// ── T6 hvp_inv divides componentwise ───────────────────────────
let dH6 = [2.0, 4.0]
let inv6 = if_hvp_inv([8.0, 16.0], dH6)
check("T6 inv[0]=4", approx_(inv6[0], 4.0, 1.0e-9))
check("T6 inv[1]=4", approx_(inv6[1], 4.0, 1.0e-9))

// ── T7 fit tiny logistic regression (linearly separable) ───────
// y=1 when x[0]+x[1] > 0, y=0 otherwise
let X7 = [
    [1.0, 1.0],
    [2.0, 2.0],
    [-1.0, -1.0],
    [-2.0, -2.0],
    [1.5, 0.5],
    [-1.5, -0.5]
]
let Y7 = [1, 1, 0, 0, 1, 0]
let w7 = if_fit_logreg(X7, Y7, 0.5, 200)
check("T7 w[0] positive", w7[0] > 0.0)
check("T7 w[1] positive", w7[1] > 0.0)
// After training, check accuracy
let mut correct = 0
let mut i = 0

while i < 6 {
    let p = if_forward(w7, X7[i])
    let pred = if p >= 0.5 { 1 } else { 0 }
    if pred == Y7[i] { correct = correct + 1 }
}
check("T7 accuracy 6/6", correct == 6)

// ── T8 influence of matching-label training point is negative ──
// (removing that point would *increase* test loss, so influence<0 means
//  -gT H^-1 g_train<0 -> g_test and g_train have similar direction)
let diag8 = if_diag_hessian(w7, X7, 0.01)
// test = a clearly positive point
let test_feat = [1.2, 0.8]
let test_lbl = 1
// train point similar to test
let infl_same = if_influence(w7, test_feat, test_lbl, [1.0, 1.0], 1, diag8)
// train point opposite label same features (harmful)
let infl_opp = if_influence(w7, test_feat, test_lbl, [1.0, 1.0], 0, diag8)
check("T8 same-label < opposite-label", infl_same < infl_opp)

// ── T9 rank_train returns n scores and n indices ───────────────
let r9 = if_rank_train(w7, test_feat, test_lbl, X7, Y7, 0.01)
check("T9 scores len = n", len(r9["scores"]) == 6)
check("T9 order len = n", len(r9["order"]) == 6)

// ── T10 ordering is by absolute score (descending) ────────────
let order10 = r9["order"]
let scores10 = r9["scores"]
let mut monotone = true
let mut i = 0

while i < 5 {
    let a = scores10[order10[i]]
    let b = scores10[order10[i + 1]]
    let aa = if a < 0.0 { 0.0 - a } else { a }
    let bb = if b < 0.0 { 0.0 - b } else { b }
    if aa < bb { monotone = false }
}
check("T10 |score| descending", monotone)

// ── T11 fit_logreg returns weight vector of correct length ────
check("T11 weight len 2", len(w7) == 2)

// ── T12 dataset_loss decreases after fit ──────────────────────
let w12_init = [0.0, 0.0]
let loss_init = if_dataset_loss(w12_init, X7, Y7)
let w12_final = if_fit_logreg(X7, Y7, 0.5, 200)
let loss_final = if_dataset_loss(w12_final, X7, Y7)
check("T12 loss decreases", loss_final < loss_init)

println("")
println("=== Influence Functions test summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
