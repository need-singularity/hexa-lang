// ═══════════════════════════════════════════════════════════════════
//  test_influence_functions.hexa — Influence Functions (#282)
//
//  Run: PATH=/Users/ghost/.cargo/bin:$PATH ./hexa self/test_influence_functions.hexa
// ═══════════════════════════════════════════════════════════════════

import "ml/influence_functions.hexa"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs_(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx_(a, b, eps) { return fabs_(a - b) < eps }

println("=== Influence Functions (#282) Tests ===")

// ── T1 sigmoid(0) = 0.5 ─────────────────────────────────────────
check("T1 sigmoid(0)=0.5", approx_(if_sigmoid(0.0), 0.5, 1.0e-6))
check("T1 sigmoid(10)≈1", approx_(if_sigmoid(10.0), 1.0, 1.0e-3))
let ten_neg = 0.0 - 10.0
check("T1 sigmoid(-10)≈0", approx_(if_sigmoid(ten_neg), 0.0, 1.0e-3))

// ── T2 forward linear combination ──────────────────────────────
let w2 = [2.0, -1.0]
let f2 = if_forward(w2, [1.0, 0.0])
check("T2 forward σ(2)", approx_(f2, if_sigmoid(2.0), 1.0e-9))

// ── T3 loss is non-negative ────────────────────────────────────
let l3a = if_loss(w2, [1.0, 0.0], 1)
let l3b = if_loss(w2, [1.0, 0.0], 0)
check("T3 loss >=0 a", l3a >= 0.0)
check("T3 loss >=0 b", l3b >= 0.0)
check("T3 correct label smaller loss", l3a < l3b)

// ── T4 gradient shape and sign ─────────────────────────────────
let g4 = if_grad(w2, [1.0, 0.0], 1)
check("T4 grad len 2", len(g4) == 2)
// p = σ(2) ≈ 0.88, diff = p - 1 ≈ -0.12, so grad[0] = diff * 1 = negative
check("T4 grad[0] negative", g4[0] < 0.0)

// ── T5 diag Hessian positive ───────────────────────────────────
let X5 = [
    [1.0, 0.0],
    [0.0, 1.0],
    [1.0, 1.0]
]
let dH5 = if_diag_hessian(w2, X5, 0.01)
check("T5 diag H len 2", len(dH5) == 2)
check("T5 diag H[0] >= damping", dH5[0] >= 0.01)
check("T5 diag H[1] >= damping", dH5[1] >= 0.01)

// ── T6 hvp_inv divides componentwise ───────────────────────────
let dH6 = [2.0, 4.0]
let inv6 = if_hvp_inv([8.0, 16.0], dH6)
check("T6 inv[0]=4", approx_(inv6[0], 4.0, 1.0e-9))
check("T6 inv[1]=4", approx_(inv6[1], 4.0, 1.0e-9))

// ── T7 fit tiny logistic regression (linearly separable) ───────
// y=1 when x[0]+x[1] > 0, y=0 otherwise
let X7 = [
    [1.0, 1.0],
    [2.0, 2.0],
    [-1.0, -1.0],
    [-2.0, -2.0],
    [1.5, 0.5],
    [-1.5, -0.5]
]
let Y7 = [1, 1, 0, 0, 1, 0]
let w7 = if_fit_logreg(X7, Y7, 0.5, 200)
check("T7 w[0] positive", w7[0] > 0.0)
check("T7 w[1] positive", w7[1] > 0.0)
// After training, check accuracy
let mut correct = 0
for i in 0..6 {
    let p = if_forward(w7, X7[i])
    let pred = if p >= 0.5 { 1 } else { 0 }
    if pred == Y7[i] { correct = correct + 1 }
}
check("T7 accuracy 6/6", correct == 6)

// ── T8 influence of matching-label training point is negative ──
// (removing that point would *increase* test loss, so influence<0 means
//  -gT H^-1 g_train<0 -> g_test and g_train have similar direction)
let diag8 = if_diag_hessian(w7, X7, 0.01)
// test = a clearly positive point
let test_feat = [1.2, 0.8]
let test_lbl = 1
// train point similar to test
let infl_same = if_influence(w7, test_feat, test_lbl, [1.0, 1.0], 1, diag8)
// train point opposite label same features (harmful)
let infl_opp = if_influence(w7, test_feat, test_lbl, [1.0, 1.0], 0, diag8)
check("T8 same-label < opposite-label", infl_same < infl_opp)

// ── T9 rank_train returns n scores and n indices ───────────────
let r9 = if_rank_train(w7, test_feat, test_lbl, X7, Y7, 0.01)
check("T9 scores len = n", len(r9["scores"]) == 6)
check("T9 order len = n", len(r9["order"]) == 6)

// ── T10 ordering is by absolute score (descending) ────────────
let order10 = r9["order"]
let scores10 = r9["scores"]
let mut monotone = true
for i in 0..5 {
    let a = scores10[order10[i]]
    let b = scores10[order10[i + 1]]
    let aa = if a < 0.0 { 0.0 - a } else { a }
    let bb = if b < 0.0 { 0.0 - b } else { b }
    if aa < bb { monotone = false }
}
check("T10 |score| descending", monotone)

// ── T11 fit_logreg returns weight vector of correct length ────
check("T11 weight len 2", len(w7) == 2)

// ── T12 dataset_loss decreases after fit ──────────────────────
let w12_init = [0.0, 0.0]
let loss_init = if_dataset_loss(w12_init, X7, Y7)
let w12_final = if_fit_logreg(X7, Y7, 0.5, 200)
let loss_final = if_dataset_loss(w12_final, X7, Y7)
check("T12 loss decreases", loss_final < loss_init)

println("")
println("=== Influence Functions test summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
