// self/test_fmt_pure.hexa -- Tests for self/runtime/fmt_pure.hexa

// ── inlined from self/runtime/fmt_pure.hexa ────────────────────
// codegen_c2 import/use resolution for runtime/*_pure.hexa is not wired
// for test files; inline the module contents (same pattern as test_rle_pure).

fn repeat_str(s, n) {
    if n <= 0 { return "" }
    let mut parts = []
    let mut i = 0
    while i < n {
        parts = parts.push(s)
        i = i + 1
    }
    parts.join("")
}

fn pad_left(s, width, ch) {
    let slen = len(s)
    if slen >= width { return s }
    let pad = repeat_str(ch, width - slen)
    pad + s
}

fn pad_right(s, width, ch) {
    let slen = len(s)
    if slen >= width { return s }
    let pad = repeat_str(ch, width - slen)
    s + pad
}

fn center(s, width, ch) {
    let slen = len(s)
    if slen >= width { return s }
    let total_pad = width - slen
    let left_pad = total_pad / 2
    let right_pad = total_pad - left_pad
    repeat_str(ch, left_pad) + s + repeat_str(ch, right_pad)
}

fn str_truncate(s, max_len) {
    let slen = len(s)
    if slen <= max_len { return s }
    if max_len <= 3 { return s.substring(0, max_len) }
    s.substring(0, max_len - 3) + "..."
}

// ── end inlined ───────────────────────────────────────────────────

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  fmt_pure.hexa — test runner")
println("═══════════════════════════════════════════════════════")

// ── repeat_str ─────────────────────────────────────────────────
println("")
println("--- repeat_str ---")
check("repeat empty", repeat_str("x", 0), "")
check("repeat neg", repeat_str("x", -1), "")
check("repeat 1", repeat_str("ab", 1), "ab")
check("repeat 3", repeat_str("ab", 3), "ababab")
check("repeat single", repeat_str("z", 5), "zzzzz")

// ── pad_left ───────────────────────────────────────────────────
println("")
println("--- pad_left ---")
check("pad_left no pad", pad_left("hello", 3, " "), "hello")
check("pad_left exact", pad_left("hello", 5, " "), "hello")
check("pad_left basic", pad_left("hi", 5, " "), "   hi")
check("pad_left zero", pad_left("hi", 5, "0"), "000hi")
check("pad_left single", pad_left("x", 4, "."), "...x")

// ── pad_right ──────────────────────────────────────────────────
println("")
println("--- pad_right ---")
check("pad_right no pad", pad_right("hello", 3, " "), "hello")
check("pad_right exact", pad_right("hello", 5, " "), "hello")
check("pad_right basic", pad_right("hi", 5, " "), "hi   ")
check("pad_right zero", pad_right("hi", 5, "0"), "hi000")

// ── center ─────────────────────────────────────────────────────
println("")
println("--- center ---")
check("center no pad", center("hello", 3, " "), "hello")
check("center exact", center("hello", 5, " "), "hello")
check("center even", center("hi", 6, "-"), "--hi--")
check("center odd", center("hi", 7, "-"), "--hi---")
check("center single", center("x", 5, "*"), "**x**")

// ── truncate ───────────────────────────────────────────────────
println("")
println("--- truncate ---")
check("truncate short", str_truncate("hi", 10), "hi")
check("truncate exact", str_truncate("hello", 5), "hello")
check("truncate over", str_truncate("hello world", 8), "hello...")
check("truncate tiny", str_truncate("hello", 3), "hel")
check("truncate 4", str_truncate("hello world", 4), "h...")

// ── Summary ────────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    println("FAIL")
    exit(1)
}
println("ALL PASS")
