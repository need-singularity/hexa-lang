// ═══════════════════════════════════════════════════════════════════
//  test_mech_interp_circuits.hexa — Mech Interp Circuits (#263)
//
//  Build a tiny transformer-like DAG with 2 "heads" and 1 "output"
//  sum, then run path patching to recover the circuit.
//
//  Run: PATH=$HOME/.cargo/bin:$PATH ./hexa self/test_mech_interp_circuits.hexa
// ═══════════════════════════════════════════════════════════════════

// -- inlined from self/ml/mech_interp_circuits.hexa --
// codegen import not wired for test files

// ═══════════════════════════════════════════════════════════════════
//  self/ml/mech_interp_circuits.hexa — Mech Interp Circuits (#263)
//
//  Automated circuit discovery via path patching.  We model a tiny
//  "micro-transformer" as a graph of edges (nodes = head outputs or
//  MLP outputs, edges = residual-stream connections).  For each edge
//  we:
//
//    1. Run the model on a CLEAN input, cache every activation.
//    2. Run the model on a CORRUPT input, cache every activation.
//    3. For each candidate edge, replace its CLEAN-side activation
//       with the CORRUPT one and re-run downstream.
//    4. Measure ΔLogit between corrupted and clean forward passes;
//       edges with the largest drop are the "important" circuit.
//
//  The micro-model is intentionally simple — a directed acyclic
//  computation graph with 3 node kinds:
//      - "input"  : x
//      - "head"   : out = W · src_vec   (linear projection)
//      - "sum"    : out = Σ src_vec     (residual)
//  Every node stores its value in a "cache" dictionary keyed by id.
//
//  API:
//    mi_build_model(layer_defs)                      -> #{nodes, order}
//    mi_forward(model, input)                        -> cache dict
//    mi_logit(cache, target_id, class_idx)           -> float
//    mi_patch_edge(model, clean_x, corrupt_x,
//                  patch_src, target_id, class_idx)  -> float  (delta)
//    mi_rank_edges(model, clean_x, corrupt_x,
//                  target_id, class_idx)             -> [#{edge, delta}]
//    mi_top_k_circuit(ranked, k)                     -> [string]
//
//  AI-NATIVE attrs:
//    @pure — cache-only forward
//    @hot  — patching loop
// ═══════════════════════════════════════════════════════════════════

fn mi_abs(x) { if x < 0.0 { return 0.0 - x } return x }

fn mi_zeros_f(n) {
    let mut v = []
    let mut _i = 0

    while _i < n { v = v + [0.0] }
    return v
}

// ═══════════════════════════════════════════════════════════════════
//  (1) Build a model from layer definitions.
//
//  Each layer def is a dict of:
//      #{
//         "id":    "h0",
//         "kind":  "input" | "head" | "sum",
//         "srcs":  ["id1", "id2"],      // input ids (for head/sum)
//         "W":     [[..]]               // only for "head"
//      }
//
//  Returns a model dict with an order array preserving topo order
//  (we assume the caller writes defs in topological order).
// ═══════════════════════════════════════════════════════════════════
fn mi_build_model(layer_defs) {
    let mut nodes = #{}
    let mut order = []
    let mut i = 0

    while i < len(layer_defs) {
        let d = layer_defs[i]
        let nid = d["id"]
        nodes[nid] = d
        order = order + [nid]
    }
    return #{
        "nodes": nodes,
        "order": order
    }
}

// ═══════════════════════════════════════════════════════════════════
//  (2) Forward pass producing a cache of every node's output
//
//  input is a dict   #{"x0": [..vec..], "x1": [..vec..], ...}
//  head nodes with srcs=[a] do  out = W · cache[a]
//  head nodes with srcs=[a,b,..] concatenate cache[a]+cache[b]+..
//  sum nodes just sum their src vectors elementwise.
// ═══════════════════════════════════════════════════════════════════
fn mi_vec_add(a, b) {
    let n = len(a)
    let mut out = mi_zeros_f(n)
    let mut i = 0

    while i < n { out[i] = a[i] + b[i] }
    return out
}

fn mi_matvec(W, x) {
    let rows = len(W)
    let cols = len(W[0])
    let mut out = mi_zeros_f(rows)
    let mut i = 0

    while i < rows {
        let mut s = 0.0
        let mut j = 0

        while j < cols { s = s + W[i][j] * x[j] }
        out[i] = s
    }
    return out
}

fn mi_concat(a, b) {
    let mut out = []
    let mut i = 0

    while i < len(a) { out = out + [a[i]] }
    let mut i = 0

    while i < len(b) { out = out + [b[i]] }
    return out
}

fn mi_forward(model, input) {
    let nodes = model["nodes"]
    let order = model["order"]
    let mut cache = #{}
    let mut i = 0

    while i < len(order) {
        let nid = order[i]
        let d = nodes[nid]
        let kind = d["kind"]
        if kind == "input" {
            cache[nid] = input[nid]
        } else {
            if kind == "head" {
                let srcs = d["srcs"]
                let mut fused = cache[srcs[0]]
                let mut k = 1
                while k < len(srcs) {
                    fused = mi_concat(fused, cache[srcs[k]])
                    k = k + 1
                }
                let W = d["W"]
                cache[nid] = mi_matvec(W, fused)
            } else {
                // sum
                let srcs = d["srcs"]
                let mut acc = cache[srcs[0]]
                let mut k = 1
                while k < len(srcs) {
                    acc = mi_vec_add(acc, cache[srcs[k]])
                    k = k + 1
                }
                cache[nid] = acc
            }
        }
    }
    return cache
}

// ═══════════════════════════════════════════════════════════════════
//  (3) Logit of a particular class index at a particular node
// ═══════════════════════════════════════════════════════════════════
@pure
fn mi_logit(cache, target_id, class_idx) {
    let v = cache[target_id]
    return v[class_idx]
}

// ═══════════════════════════════════════════════════════════════════
//  (4) Forward with one edge patched
//
//  We recompute downstream nodes after substituting cache[patch_src]
//  with corrupt_cache[patch_src].  Returns Δlogit = clean - patched.
// ═══════════════════════════════════════════════════════════════════
fn mi_forward_patched(model, clean_x, corrupt_cache, patch_src) {
    let nodes = model["nodes"]
    let order = model["order"]
    let mut cache = #{}
    let mut i = 0

    while i < len(order) {
        let nid = order[i]
        let d = nodes[nid]
        let kind = d["kind"]
        if kind == "input" {
            cache[nid] = clean_x[nid]
        } else {
            if kind == "head" {
                let srcs = d["srcs"]
                let mut src0 = cache[srcs[0]]
                if srcs[0] == patch_src { src0 = corrupt_cache[patch_src] }
                let mut fused = src0
                let mut k = 1
                while k < len(srcs) {
                    let sk = srcs[k]
                    let mut vk = cache[sk]
                    if sk == patch_src { vk = corrupt_cache[patch_src] }
                    fused = mi_concat(fused, vk)
                    k = k + 1
                }
                let W = d["W"]
                cache[nid] = mi_matvec(W, fused)
            } else {
                let srcs = d["srcs"]
                let mut s0 = cache[srcs[0]]
                if srcs[0] == patch_src { s0 = corrupt_cache[patch_src] }
                let mut acc = s0
                let mut k = 1
                while k < len(srcs) {
                    let sk = srcs[k]
                    let mut vk = cache[sk]
                    if sk == patch_src { vk = corrupt_cache[patch_src] }
                    acc = mi_vec_add(acc, vk)
                    k = k + 1
                }
                cache[nid] = acc
            }
        }
    }
    return cache
}

// ═══════════════════════════════════════════════════════════════════
//  (5) Patch effect of a single edge
// ═══════════════════════════════════════════════════════════════════
@hot
fn mi_patch_edge(model, clean_x, corrupt_x, patch_src, target_id, class_idx) {
    let clean_cache = mi_forward(model, clean_x)
    let corrupt_cache = mi_forward(model, corrupt_x)
    let patched = mi_forward_patched(model, clean_x, corrupt_cache, patch_src)
    let clean_logit = mi_logit(clean_cache, target_id, class_idx)
    let patched_logit = mi_logit(patched, target_id, class_idx)
    return clean_logit - patched_logit
}

// ═══════════════════════════════════════════════════════════════════
//  (6) Rank every node by patch effect (largest |Δ| first)
// ═══════════════════════════════════════════════════════════════════
@hot
fn mi_rank_edges(model, clean_x, corrupt_x, target_id, class_idx) {
    let order = model["order"]
    let mut results = []
    let mut i = 0

    while i < len(order) {
        let nid = order[i]
        // Skip patching the target itself — identity delta.
        if nid != target_id {
            let delta = mi_patch_edge(model, clean_x, corrupt_x, nid, target_id, class_idx)
            results = results + [#{ "edge": nid, "delta": delta, "abs": mi_abs(delta) }]
        }
    }
    // Sort by abs delta descending
    let n = len(results)
    let mut i = 0

    while i < n {
        let mut j = (i + 1)

        while j < n {
            if results[j]["abs"] > results[i]["abs"] {
                let tmp = results[i]
                results[i] = results[j]
                results[j] = tmp
            }
        }
    }
    return results
}

// ═══════════════════════════════════════════════════════════════════
//  (7) Top-K circuit edges
// ═══════════════════════════════════════════════════════════════════
@pure
fn mi_top_k_circuit(ranked, k) {
    let mut out = []
    let take = if k < len(ranked) { k } else { len(ranked) }
    let mut i = 0

    while i < take { out = out + [ranked[i]["edge"]] }
    return out
}


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs_(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx_(a, b, eps) { return fabs_(a - b) < eps }

println("=== Mech Interp Circuits (#263) Tests ===")

// ── Build model ──────────────────────────────────────────────────
// input nodes: x0, x1
// h0 (head):   W0 · x0        (depends on x0 ONLY)
// h1 (head):   W1 · x1        (depends on x1 ONLY)
// out (sum):   h0 + h1
//
// Target logit = out[0]  (class 0)
//
// Designed so that if we corrupt x0, patching h0 brings the large
// delta; patching h1 should have zero delta (h1 does not read x0).

let W0 = [
    [2.0, 0.0],
    [0.0, 2.0]
]
let W1 = [
    [1.0, 0.0],
    [0.0, 1.0]
]

let defs = [
    #{ "id": "x0", "kind": "input", "srcs": [], "W": [] },
    #{ "id": "x1", "kind": "input", "srcs": [], "W": [] },
    #{ "id": "h0", "kind": "head",  "srcs": ["x0"], "W": W0 },
    #{ "id": "h1", "kind": "head",  "srcs": ["x1"], "W": W1 },
    #{ "id": "out","kind": "sum",   "srcs": ["h0", "h1"], "W": [] }
]
let model = mi_build_model(defs)

let clean_x = #{
    "x0": [1.0, 0.0],
    "x1": [0.0, 1.0]
}
let corrupt_x = #{
    "x0": [-1.0, 0.0],   // flipped
    "x1": [0.0,  1.0]    // unchanged
}

// ── T1 clean forward shape ──────────────────────────────────────
let cache_c = mi_forward(model, clean_x)
let out_c = cache_c["out"]
check("T1 out len=2", len(out_c) == 2)
// out[0] = 2*1 + 1*0 = 2.0
check("T1 out[0]=2", approx_(out_c[0], 2.0, 1.0e-6))
// out[1] = 2*0 + 1*1 = 1.0
check("T1 out[1]=1", approx_(out_c[1], 1.0, 1.0e-6))

// ── T2 corrupt forward shape ────────────────────────────────────
let cache_k = mi_forward(model, corrupt_x)
let out_k = cache_k["out"]
// out[0] = 2*(-1) + 1*0 = -2.0
check("T2 corrupt out[0]=-2", approx_(out_k[0], -2.0, 1.0e-6))

// ── T3 logit accessor ───────────────────────────────────────────
check("T3 logit match", approx_(mi_logit(cache_c, "out", 0), 2.0, 1.0e-6))

// ── T4 patch h0 -> expect delta = clean - patched ──────────────
//   clean  out[0] = 2
//   patch h0 with corrupt h0 = -2 -> out[0] = -2 + 1*0 = -2
//   delta = 2 - (-2) = 4.0
let delta_h0 = mi_patch_edge(model, clean_x, corrupt_x, "h0", "out", 0)
check("T4 delta h0 = 4", approx_(delta_h0, 4.0, 1.0e-6))

// ── T5 patch h1 -> delta = 0 (unchanged) ────────────────────────
let delta_h1 = mi_patch_edge(model, clean_x, corrupt_x, "h1", "out", 0)
check("T5 delta h1 = 0", approx_(delta_h1, 0.0, 1.0e-6))

// ── T6 patch x0 -> same as h0 because h0 is pure function ──────
let delta_x0 = mi_patch_edge(model, clean_x, corrupt_x, "x0", "out", 0)
check("T6 delta x0 != 0", fabs_(delta_x0) > 0.0)

// ── T7 rank_edges puts h0 at top ───────────────────────────────
let ranked = mi_rank_edges(model, clean_x, corrupt_x, "out", 0)
// ranked is sorted by abs delta desc, target excluded
// expected top: h0 or x0 (both big), then the other, then h1 and x1 near 0
let top_edge = ranked[0]["edge"]
check("T7 top edge has largest abs", top_edge == "h0" || top_edge == "x0")

// ── T8 h1 delta == 0 in ranked ─────────────────────────────────
let mut h1_abs = -1.0
let mut i = 0

while i < len(ranked) {
    if ranked[i]["edge"] == "h1" { h1_abs = ranked[i]["abs"] }
}
check("T8 h1 abs ≈ 0", approx_(h1_abs, 0.0, 1.0e-6))

// ── T9 top_k_circuit returns K edges ───────────────────────────
let circuit = mi_top_k_circuit(ranked, 2)
check("T9 top2 length", len(circuit) == 2)

// ── T10 top_k_circuit excludes h1 (irrelevant) ─────────────────
let mut h1_in_top2 = false
let mut i = 0

while i < len(circuit) {
    if circuit[i] == "h1" { h1_in_top2 = true }
}
check("T10 h1 not in circuit", !h1_in_top2)

// ── T11 patching target-equivalent node yields expected sign ───
// delta should equal clean_logit - patched_logit; with clean_x==corrupt_x
// result should be 0 everywhere.
let same_corrupt = #{
    "x0": [1.0, 0.0],
    "x1": [0.0, 1.0]
}
let d_same = mi_patch_edge(model, clean_x, same_corrupt, "h0", "out", 0)
check("T11 same inputs -> delta=0", approx_(d_same, 0.0, 1.0e-6))

// ── T12 rank length = |nodes| - 1 (target excluded) ────────────
check("T12 ranked len", len(ranked) == 4)

println("")
println("=== Mech Interp Circuits test summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
