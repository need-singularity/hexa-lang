// ═══════════════════════════════════════════════════════════════════
//  self/ml/spin.hexa — Self-Play Fine-Tuning (SPIN)
//
//  SPIN aligns a language model without external preference labels.
//  The core idea: the current policy plays against itself. At each
//  iteration t:
//
//    1) The policy p_t generates synthetic responses y' ~ p_t(.|x)
//    2) Human/gold responses y are treated as "real"
//    3) A discriminator objective trains p_{t+1} to distinguish
//       human from synthetic via DPO-style log-probability ratio:
//
//       L = -log sigma(beta * (log p(y|x) - log p(y'|x)
//                              - log p_t(y|x) + log p_t(y'|x)))
//
//       where p is the new policy being trained and p_t is the
//       frozen opponent from the previous iteration.
//
//    4) The model converges when it can no longer distinguish its
//       own outputs from human text, i.e. the loss plateaus and
//       the discriminator accuracy falls to ~0.5.
//
//  This is the original SPIN paper formulation (Zhu et al., 2024,
//  "Self-Play Fine-Tuning Converts Weak Language Models to Strong
//  Language Models").
//
//  Architecture:
//    - Abstract policy = logit vector of dimension D (same as online_dpo)
//    - Self-play generation via softmax sampling from current policy
//    - DPO-style loss for (human=chosen, synthetic=rejected) pairs
//    - Multi-iteration loop with frozen opponent at each round
//    - Convergence = discriminator accuracy <= threshold
//
//  API:
//    spin_new_policy(d, seed)                 -> policy logit vec
//    spin_copy_policy(p)                      -> deep copy
//    spin_log_prob(policy, action)            -> float
//    spin_softmax(logits)                     -> [float..]
//    spin_sample(policy, seed)                -> action (int)
//    spin_generate(policy, n, seed)           -> [action..] synthetic
//    spin_loss(policy, opponent, human, synth, beta) -> [loss, margin]
//    spin_batch_loss(policy, opp, humans, synths, beta) -> float
//    spin_grad_step(policy, opp, human, synth, beta, lr) -> [policy, loss]
//    spin_batch_step(policy, opp, humans, synths, beta, lr) -> [policy, avg_loss]
//    spin_discriminator_accuracy(policy, opp, humans, synths, beta) -> float
//    spin_convergence_check(acc, threshold) -> bool
//    spin_iteration(policy, humans, beta, lr, n_steps, seed) -> [new_policy, final_loss, final_acc]
//    spin_train(policy, humans, beta, lr, max_iters, steps_per_iter, seed, threshold) -> [policy, iter, converged]
//    spin_kl_divergence(p, q)                -> float
//    spin_policy_drift(p, q)                 -> float (L2)
//    spin_reward_margin(policy, opp, human, synth, beta) -> float
//    spin_mean_reward(policy, opp, humans, synths, beta) -> [mean_human, mean_synth]
//
//  AI-NATIVE attrs:
//    @pure  — loss / log_prob / drift / convergence (no side effects)
//    @hot   — log_prob / sample / grad_step (called every step)
// ═══════════════════════════════════════════════════════════════════

// ── numeric helpers ──────────────────────────────────────────────

fn spin_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn spin_exp(x) {
    let mut v = x
    if v > 20.0 { v = 20.0 }
    if v < -20.0 { v = -20.0 }
    let mut result = 1.0
    let mut term = 1.0
    for i in 1..30 {
        term = term * v / to_float(i)
        result = result + term
    }
    if result < 0.0 { return 0.0 }
    return result
}

fn spin_log(x) {
    if x <= 0.0 { return -30.0 }
    let mut v = x
    let mut count = 0
    while v > 2.0 {
        v = v / 2.718281828
        count = count + 1
    }
    while v < 0.5 {
        v = v * 2.718281828
        count = count - 1
    }
    let d = v - 1.0
    let ln_v = d - d * d / 2.0 + d * d * d / 3.0 - d * d * d * d / 4.0
    return to_float(count) + ln_v
}

fn spin_sigmoid(x) {
    if x > 20.0 { return 1.0 }
    if x < -20.0 { return 0.0 }
    return 1.0 / (1.0 + spin_exp(0.0 - x))
}

fn spin_log_sigmoid(x) {
    let neg_x = 0.0 - x
    if neg_x > 20.0 { return 0.0 - neg_x }
    if neg_x < -20.0 { return 0.0 }
    return 0.0 - spin_log(1.0 + spin_exp(neg_x))
}

// softplus(x) = log(1 + exp(x))
fn spin_softplus(x) {
    if x > 20.0 { return x }
    if x < -20.0 { return 0.0 }
    return spin_log(1.0 + spin_exp(x))
}

// deterministic hash PRNG
fn spin_hash(seed, i) {
    let h = ((seed * 2654435761 + i * 1315423911 + 731) % 10007)
    return to_float(h) / 10007.0
}

// ── policy: logit vector of dimension D ─────────────────────────

pub fn spin_new_policy(d, seed) {
    let mut v = []
    for i in 0..d {
        let a = spin_hash(seed, i * 2)
        let b = spin_hash(seed, i * 2 + 1)
        v = v + [(a - 0.5) * 0.1 + (b - 0.5) * 0.1]
    }
    return v
}

pub fn spin_copy_policy(p) {
    let n = len(p)
    let mut out = []
    for i in 0..n { out = out + [p[i]] }
    return out
}

// ── softmax + log_prob ──────────────────────────────────────────

pub fn spin_softmax(logits) {
    let n = len(logits)
    let mut mx = logits[0]
    let mut i = 1
    while i < n {
        if logits[i] > mx { mx = logits[i] }
        i = i + 1
    }
    let mut exps = []
    let mut s = 0.0
    let mut j = 0
    while j < n {
        let e = spin_exp(logits[j] - mx)
        exps = exps + [e]
        s = s + e
        j = j + 1
    }
    if s <= 0.0 { s = 1.0e-10 }
    let mut k = 0
    while k < n {
        exps[k] = exps[k] / s
        k = k + 1
    }
    return exps
}

// log P(action | policy) via log-softmax
pub fn spin_log_prob(policy, action) {
    let n = len(policy)
    if action < 0 { return -30.0 }
    if action >= n { return -30.0 }
    let mut mx = policy[0]
    let mut i = 1
    while i < n {
        if policy[i] > mx { mx = policy[i] }
        i = i + 1
    }
    let mut sum_exp = 0.0
    let mut j = 0
    while j < n {
        sum_exp = sum_exp + spin_exp(policy[j] - mx)
        j = j + 1
    }
    let lse = mx + spin_log(sum_exp)
    return policy[action] - lse
}

// ── self-play generation ────────────────────────────────────────
//
// Sample a single action from current policy via inverse-CDF.

pub fn spin_sample(policy, seed) {
    let probs = spin_softmax(policy)
    let n = len(probs)
    let u = spin_hash(seed, 42)
    let mut acc = 0.0
    let mut chosen = n - 1
    let mut j = 0
    let mut done = false
    while j < n {
        if done == false {
            acc = acc + probs[j]
            if u <= acc {
                chosen = j
                done = true
            }
        }
        j = j + 1
    }
    return chosen
}

// Generate n synthetic responses from current policy.
// Each response is a single action index (token-level abstraction).
pub fn spin_generate(policy, n, seed) {
    let mut out = []
    let mut i = 0
    while i < n {
        let action = spin_sample(policy, seed + i * 97)
        out = out + [action]
        i = i + 1
    }
    return out
}

// ── SPIN loss ───────────────────────────────────────────────────
//
// L = -log sigma(beta * (log p(human|x) - log p(synth|x)
//                        - log p_t(human|x) + log p_t(synth|x)))
//
// This is identical to DPO loss where:
//   chosen  = human response
//   rejected = synthetic response
//   ref_model = opponent (previous iteration frozen policy)
//
// Returns [loss, margin] where margin = beta * log-ratio difference.

pub fn spin_loss(policy, opponent, human, synth, beta) {
    let lp_h = spin_log_prob(policy, human)
    let lp_s = spin_log_prob(policy, synth)
    let lo_h = spin_log_prob(opponent, human)
    let lo_s = spin_log_prob(opponent, synth)
    let log_ratio_h = lp_h - lo_h
    let log_ratio_s = lp_s - lo_s
    let margin = beta * (log_ratio_h - log_ratio_s)
    let loss = 0.0 - spin_log_sigmoid(margin)
    return [loss, margin]
}

// Average loss over a batch of (human, synthetic) pairs.
pub fn spin_batch_loss(policy, opponent, humans, synths, beta) {
    let n = len(humans)
    if n <= 0 { return 0.0 }
    let mut total = 0.0
    let mut i = 0
    while i < n {
        let res = spin_loss(policy, opponent, humans[i], synths[i], beta)
        total = total + res[0]
        i = i + 1
    }
    return total / to_float(n)
}

// ── gradient step ───────────────────────────────────────────────
//
// Analytical gradient of SPIN loss w.r.t. policy logits.
//
// d L / d logits[j]
//   = -(1 - sigma(margin)) * beta
//     * (d/d logits[j] (log p(h) - log p(s)))
//
// Since log p(a) = logits[a] - logsumexp:
//   d log p(a) / d logits[j] = (a==j) - softmax[j]
//   d (log p(h) - log p(s)) / d logits[j]
//     = (h==j) - softmax[j] - (s==j) + softmax[j]
//     = (h==j) - (s==j)
//
// d L / d logits[j] = -(1-sigma(margin)) * beta * ((h==j) - (s==j))
//                    = sigma(-margin) * beta * ((s==j) - (h==j))

pub fn spin_grad_step(policy, opponent, human, synth, beta, lr) {
    let n = len(policy)
    let res = spin_loss(policy, opponent, human, synth, beta)
    let loss = res[0]
    let margin = res[1]
    let sig_neg = spin_sigmoid(0.0 - margin)
    let mut out = spin_copy_policy(policy)
    let mut j = 0
    while j < n {
        let mut ind = 0.0
        if j == synth { ind = ind + 1.0 }
        if j == human { ind = ind - 1.0 }
        let grad = sig_neg * beta * ind
        out[j] = out[j] - lr * grad
        j = j + 1
    }
    return [out, loss]
}

// Batch gradient step over multiple (human, synth) pairs.
// Returns [updated_policy, avg_loss].
pub fn spin_batch_step(policy, opponent, humans, synths, beta, lr) {
    let n = len(humans)
    if n <= 0 { return [policy, 0.0] }
    let mut cur = spin_copy_policy(policy)
    let mut total_loss = 0.0
    let mut i = 0
    while i < n {
        let res = spin_grad_step(cur, opponent, humans[i], synths[i], beta, lr)
        cur = res[0]
        total_loss = total_loss + res[1]
        i = i + 1
    }
    return [cur, total_loss / to_float(n)]
}

// ── discriminator accuracy ──────────────────────────────────────
//
// SPIN's discriminator classifies human vs synthetic via the
// log-probability ratio: if log p(human) > log p(synth) for the
// current policy, the discriminator "correctly" identifies real.
// Accuracy = fraction of pairs where policy assigns higher prob
// to human than to synthetic.

pub fn spin_discriminator_accuracy(policy, opponent, humans, synths, beta) {
    let n = len(humans)
    if n <= 0 { return 0.5 }
    let mut correct = 0
    let mut i = 0
    while i < n {
        let res = spin_loss(policy, opponent, humans[i], synths[i], beta)
        let margin = res[1]
        // positive margin means policy correctly prefers human
        if margin > 0.0 { correct = correct + 1 }
        i = i + 1
    }
    return to_float(correct) / to_float(n)
}

// ── convergence check ───────────────────────────────────────────
//
// SPIN converges when the model cannot distinguish its own output
// from human text. This means discriminator accuracy falls near 0.5.

pub fn spin_convergence_check(acc, threshold) {
    let diff = spin_abs(acc - 0.5)
    return diff <= threshold
}

// ── reward margin ───────────────────────────────────────────────
//
// Implicit reward for human/synth via log-ratio (same as DPO).

pub fn spin_reward_margin(policy, opponent, human, synth, beta) {
    let res = spin_loss(policy, opponent, human, synth, beta)
    return res[1]
}

// Mean implicit rewards for human and synthetic sets.
pub fn spin_mean_reward(policy, opponent, humans, synths, beta) {
    let n = len(humans)
    if n <= 0 { return [0.0, 0.0] }
    let mut sum_h = 0.0
    let mut sum_s = 0.0
    let mut i = 0
    while i < n {
        let lp_h = spin_log_prob(policy, humans[i])
        let lo_h = spin_log_prob(opponent, humans[i])
        let lp_s = spin_log_prob(policy, synths[i])
        let lo_s = spin_log_prob(opponent, synths[i])
        sum_h = sum_h + beta * (lp_h - lo_h)
        sum_s = sum_s + beta * (lp_s - lo_s)
        i = i + 1
    }
    return [sum_h / to_float(n), sum_s / to_float(n)]
}

// ── KL divergence and drift ─────────────────────────────────────

pub fn spin_kl_divergence(p, q) {
    let pp = spin_softmax(p)
    let qq = spin_softmax(q)
    let n = len(pp)
    let mut kl = 0.0
    let mut i = 0
    while i < n {
        let pi = pp[i]
        if pi > 1.0e-12 {
            let qi = qq[i]
            let qsafe = if qi > 1.0e-12 { qi } else { 1.0e-12 }
            kl = kl + pi * (spin_log(pi) - spin_log(qsafe))
        }
        i = i + 1
    }
    return kl
}

pub fn spin_policy_drift(p, q) {
    let n = len(p)
    let mut s = 0.0
    let mut i = 0
    while i < n {
        let d = p[i] - q[i]
        s = s + d * d
        i = i + 1
    }
    return sqrt(s)
}

// ── single SPIN iteration ───────────────────────────────────────
//
// One iteration of the SPIN loop:
//  1) Generate synthetic data from current (opponent) policy
//  2) Train new policy against opponent using DPO-style loss
//  3) Return [new_policy, final_loss, discriminator_accuracy]

pub fn spin_iteration(policy, humans, beta, lr, n_steps, seed) {
    let n = len(humans)
    // Opponent = frozen copy of current policy (self-play)
    let opponent = spin_copy_policy(policy)

    // Generate synthetic responses from opponent
    let synths = spin_generate(opponent, n, seed)

    // Train for n_steps
    let mut cur = spin_copy_policy(policy)
    let mut last_loss = 0.0
    let mut step = 0
    while step < n_steps {
        let res = spin_batch_step(cur, opponent, humans, synths, beta, lr)
        cur = res[0]
        last_loss = res[1]
        step = step + 1
    }

    // Measure discriminator accuracy
    let acc = spin_discriminator_accuracy(cur, opponent, humans, synths, beta)

    return [cur, last_loss, acc]
}

// ── full SPIN training loop ─────────────────────────────────────
//
// Runs multiple iterations of SPIN until convergence or max_iters.
// Returns [final_policy, iterations_run, converged].

pub fn spin_train(policy, humans, beta, lr, max_iters, steps_per_iter, seed, threshold) {
    let mut cur = spin_copy_policy(policy)
    let mut iter = 0
    let mut converged = false
    while iter < max_iters {
        let res = spin_iteration(cur, humans, beta, lr, steps_per_iter, seed + iter * 1000)
        cur = res[0]
        let loss = res[1]
        let acc = res[2]

        let mut l = "{\"spin_iter\":" + str(iter)
        l = l + ",\"loss\":" + str(loss)
        l = l + ",\"disc_acc\":" + str(acc) + "}"
        println(l)

        if spin_convergence_check(acc, threshold) {
            converged = true
            iter = iter + 1
            return [cur, iter, converged]
        }
        iter = iter + 1
    }
    return [cur, iter, converged]
}

// ── diagnostic: log-prob gap between human and synthetic ────────

pub fn spin_logprob_gap(policy, humans, synths) {
    let n = len(humans)
    if n <= 0 { return 0.0 }
    let mut gap = 0.0
    let mut i = 0
    while i < n {
        let lp_h = spin_log_prob(policy, humans[i])
        let lp_s = spin_log_prob(policy, synths[i])
        gap = gap + (lp_h - lp_s)
        i = i + 1
    }
    return gap / to_float(n)
}

// ── self-play quality: how far is synthetic from human dist ─────

pub fn spin_self_play_quality(policy, humans, seed) {
    let n = len(humans)
    let synths = spin_generate(policy, n, seed)
    // Measure overlap: fraction of synthetic that match any human action
    let mut overlap = 0
    let mut i = 0
    while i < n {
        let mut j = 0
        let mut found = false
        while j < n {
            if found == false {
                if synths[i] == humans[j] { found = true }
            }
            j = j + 1
        }
        if found { overlap = overlap + 1 }
        i = i + 1
    }
    return to_float(overlap) / to_float(n)
}

println("[spin] loaded - self-play fine-tuning with iterative DPO convergence")


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx(a, b, eps) { return fabs(a - b) < eps }

println("=== SPIN Self-Play Fine-Tuning Tests (#104) ===")

let D = 8
let SEED = 42
let BETA = 0.5

// ── 1. numeric helpers ──────────────────────────────────────────

// sigmoid
check("sigmoid_pos", spin_sigmoid(5.0) > 0.99)
check("sigmoid_neg", spin_sigmoid(-5.0) < 0.01)
check("sigmoid_zero", approx(spin_sigmoid(0.0), 0.5, 0.01))

// softplus
let sp_pos = spin_softplus(1.0)
let sp_neg = spin_softplus(-1.0)
check("softplus_positive", sp_pos > 0.0)
check("softplus_monotone", sp_pos > sp_neg)

// log_sigmoid identity: log_sigmoid(x) = -softplus(-x)
let ls_val = spin_log_sigmoid(1.3)
let sp_val = spin_softplus(-1.3)
check("log_sigmoid_vs_softplus", approx(ls_val, 0.0 - sp_val, 1.0e-4))

// ── 2. policy creation ─────────────────────────────────────────

let p0 = spin_new_policy(D, SEED)
check("policy_dim", len(p0) == D)

let p0_copy = spin_copy_policy(p0)
check("policy_copy_eq", approx(p0[0], p0_copy[0], 1.0e-10))

// modify copy doesn't affect original
p0_copy[0] = p0_copy[0] + 100.0
check("policy_copy_independent", fabs(p0[0] - p0_copy[0]) > 10.0)

// ── 3. softmax sums to 1 ───────────────────────────────────────

let sm = spin_softmax(p0)
let mut sm_sum = 0.0
let mut i = 0

while i < D { sm_sum = sm_sum + sm[i] }
check("softmax_sums_to_1", approx(sm_sum, 1.0, 1.0e-6))

// ── 4. softmax invariance to constant shift ─────────────────────

let mut p_shifted = spin_copy_policy(p0)
let mut i = 0

while i < D { p_shifted[i] = p_shifted[i] + 5.0 }
let sm2 = spin_softmax(p_shifted)
check("softmax_shift_invariant", approx(sm[0], sm2[0], 1.0e-5))

// ── 5. log_prob negativity and ordering ─────────────────────────

let lp0 = spin_log_prob(p0, 0)
let lp1 = spin_log_prob(p0, 1)
check("logprob_negative", lp0 < 0.0)
check("logprob_oob_neg", spin_log_prob(p0, -1) < -20.0)
check("logprob_oob_large", spin_log_prob(p0, D + 10) < -20.0)

// ── 6. sample returns valid action ──────────────────────────────

let action = spin_sample(p0, SEED)
check("sample_valid_range", action >= 0 && action < D)

// ── 7. generate returns n synthetic responses ───────────────────

let synths = spin_generate(p0, 5, SEED)
check("generate_count", len(synths) == 5)
let mut gen_valid = true
let mut i = 0

while i < 5 {
    if synths[i] < 0 { gen_valid = false }
    if synths[i] >= D { gen_valid = false }
}
check("generate_all_valid", gen_valid)

// ── 8. single loss is positive ──────────────────────────────────

let p1 = spin_new_policy(D, SEED)
let opp = spin_copy_policy(p1)
let human_a = 0
let synth_a = 3
let res = spin_loss(p1, opp, human_a, synth_a, BETA)
check("loss_positive", res[0] > 0.0)

// ── 9. loss decreases when policy is biased toward human ────────

let mut p_biased = spin_copy_policy(p1)
p_biased[human_a] = p_biased[human_a] + 2.0
let res_biased = spin_loss(p_biased, opp, human_a, synth_a, BETA)
check("loss_lower_when_biased_to_human", res_biased[0] < res[0])

// ── 10. margin sign correctness ─────────────────────────────────

// When policy is biased toward human, margin should be positive
check("margin_positive_when_biased", res_biased[1] > 0.0)

// When policy is biased toward synthetic, margin should be negative
let mut p_anti = spin_copy_policy(p1)
p_anti[synth_a] = p_anti[synth_a] + 2.0
let res_anti = spin_loss(p_anti, opp, human_a, synth_a, BETA)
check("margin_negative_when_anti", res_anti[1] < 0.0)

// ── 11. batch loss average ──────────────────────────────────────

let humans = [0, 1, 2]
let synths_b = [3, 4, 5]
let bl = spin_batch_loss(p1, opp, humans, synths_b, BETA)
check("batch_loss_positive", bl > 0.0)

// batch loss = manual average of individual losses
let mut manual_sum = 0.0
let mut i = 0

while i < 3 {
    let r = spin_loss(p1, opp, humans[i], synths_b[i], BETA)
    manual_sum = manual_sum + r[0]
}
check("batch_loss_matches_manual", approx(bl, manual_sum / 3.0, 1.0e-8))

// ── 12. gradient step reduces loss ──────────────────────────────

let p2 = spin_new_policy(D, 99)
let opp2 = spin_copy_policy(p2)
let loss_before = spin_loss(p2, opp2, 0, 3, BETA)
let step_res = spin_grad_step(p2, opp2, 0, 3, BETA, 1.0)
let p_after = step_res[0]
let loss_after = spin_loss(p_after, opp2, 0, 3, BETA)
check("grad_step_reduces_loss", loss_after[0] < loss_before[0])

// ── 13. batch step reduces loss over multiple steps ─────────────

let p3 = spin_new_policy(D, 77)
let opp3 = spin_copy_policy(p3)
let humans3 = [0, 1, 2, 3]
let synths3 = [4, 5, 6, 7]
let bl0 = spin_batch_loss(p3, opp3, humans3, synths3, BETA)
let res3 = spin_batch_step(p3, opp3, humans3, synths3, BETA, 0.5)
let p3a = res3[0]
let bl1 = spin_batch_loss(p3a, opp3, humans3, synths3, BETA)
check("batch_step_reduces_loss", bl1 < bl0)

// ── 14. discriminator accuracy on separated data ────────────────
// Build a policy that clearly prefers low indices (human) over high (synth)

let mut p_sep = spin_new_policy(D, 55)
// Heavily bias toward low actions
p_sep[0] = p_sep[0] + 3.0
p_sep[1] = p_sep[1] + 3.0
let opp_sep = spin_new_policy(D, 55)
let humans_sep = [0, 1, 0, 1]
let synths_sep = [6, 7, 6, 7]
let acc_sep = spin_discriminator_accuracy(p_sep, opp_sep, humans_sep, synths_sep, BETA)
check("disc_acc_separated", acc_sep >= 0.75)

// ── 15. convergence check near 0.5 ─────────────────────────────

check("convergence_at_0.5", spin_convergence_check(0.5, 0.1) == true)
check("convergence_at_0.55", spin_convergence_check(0.55, 0.1) == true)

// ── 16. convergence check far from 0.5 ─────────────────────────

check("no_convergence_at_0.9", spin_convergence_check(0.9, 0.1) == false)
check("no_convergence_at_0.1", spin_convergence_check(0.1, 0.1) == false)

// ── 17. reward margin sign ──────────────────────────────────────

let rm = spin_reward_margin(p_biased, opp, human_a, synth_a, BETA)
check("reward_margin_positive_biased", rm > 0.0)

// ── 18. mean reward: human > synthetic after bias ───────────────

let mr = spin_mean_reward(p_biased, opp, [human_a, human_a], [synth_a, synth_a], BETA)
check("mean_reward_human_gt_synth", mr[0] > mr[1])

// ── 19. KL divergence non-negative ──────────────────────────────

let p4 = spin_new_policy(D, 11)
let p5 = spin_new_policy(D, 22)
let kl_val = spin_kl_divergence(p4, p5)
check("kl_nonnegative", kl_val >= -1.0e-6)

// ── 20. KL self = 0 ─────────────────────────────────────────────

let kl_self = spin_kl_divergence(p4, p4)
check("kl_self_zero", approx(kl_self, 0.0, 1.0e-4))

// ── 21. policy drift = 0 for same policy ────────────────────────

let drift_self = spin_policy_drift(p4, p4)
check("drift_self_zero", approx(drift_self, 0.0, 1.0e-10))

// ── 22. policy drift > 0 after training ─────────────────────────

let drift_diff = spin_policy_drift(p4, p5)
check("drift_different_positive", drift_diff > 0.0)

// ── 23. logprob gap direction ───────────────────────────────────
// After biasing toward human actions, gap should be positive

let gap = spin_logprob_gap(p_biased, [human_a], [synth_a])
check("logprob_gap_positive_biased", gap > 0.0)

// ── 24. self-play quality in [0,1] ──────────────────────────────

let spq = spin_self_play_quality(p0, [0, 1, 2, 3, 4, 5, 6, 7], SEED)
check("self_play_quality_range", spq >= 0.0 && spq <= 1.0)

// ── 25. single iteration improves ───────────────────────────────

let p6 = spin_new_policy(D, 33)
let humans6 = [0, 1, 2, 3]
let iter_res = spin_iteration(p6, humans6, BETA, 0.5, 5, SEED)
let iter_loss = iter_res[1]
let iter_acc = iter_res[2]
check("iteration_acc_in_range", iter_acc >= 0.0 && iter_acc <= 1.0)

// ── 26. multi-iteration training ────────────────────────────────

let p7 = spin_new_policy(D, 44)
let humans7 = [0, 1, 2, 3]
let train_res = spin_train(p7, humans7, BETA, 0.5, 5, 3, SEED, 0.15)
let final_policy = train_res[0]
let iters_run = train_res[1]
let converged = train_res[2]
check("train_runs_iterations", iters_run >= 1)
check("train_returns_policy", len(final_policy) == D)

// ── 27. gradient direction correctness ──────────────────────────
// After a grad step, the policy should increase log-prob for human
// and decrease log-prob for synthetic (gradient moves in correct dir).

let p8 = spin_new_policy(D, 88)
let opp8 = spin_new_policy(D, 200)
let h8 = 1
let s8 = 5

let lp_h_before = spin_log_prob(p8, h8)
let lp_s_before = spin_log_prob(p8, s8)
let gs_res = spin_grad_step(p8, opp8, h8, s8, BETA, 1.0)
let p8_new = gs_res[0]
let lp_h_after = spin_log_prob(p8_new, h8)
let lp_s_after = spin_log_prob(p8_new, s8)
// human logit should increase (grad pushes probability toward human)
check("grad_increases_human_logprob", p8_new[h8] > p8[h8])
// synthetic logit should decrease
check("grad_decreases_synth_logprob", p8_new[s8] < p8[s8])

// ── 28. loss symmetry: swapping human/synth flips margin ────────

let p9 = spin_new_policy(D, 66)
let opp9 = spin_copy_policy(p9)
let res_fwd = spin_loss(p9, opp9, 2, 5, BETA)
let res_rev = spin_loss(p9, opp9, 5, 2, BETA)
check("swap_flips_margin", approx(res_fwd[1], 0.0 - res_rev[1], 1.0e-6))

// ── summary ─────────────────────────────────────────────────────

println("")
println("SPIN: " + str(pass_count) + " passed, " + str(fail_count) + " failed")
