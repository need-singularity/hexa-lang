// ═══════════════════════════════════════════════════════════════════
//  self/test_spin.hexa — SPIN Self-Play Fine-Tuning (#104) tests
//
//  Scope (25+ checks):
//    1.  exp/log/sigmoid/softplus numeric helpers
//    2.  policy creation and copy
//    3.  softmax sums to 1
//    4.  log_prob negativity and ordering
//    5.  sample returns valid action
//    6.  generate returns n synthetic responses
//    7.  single loss is positive
//    8.  loss decreases when policy prefers human
//    9.  margin sign correctness
//   10.  batch loss average
//   11.  gradient step reduces loss
//   12.  batch step reduces loss over steps
//   13.  discriminator accuracy on separated data
//   14.  convergence check near 0.5
//   15.  convergence check far from 0.5
//   16.  reward margin sign
//   17.  mean reward: human > synthetic after training
//   18.  KL divergence non-negative
//   19.  KL self = 0
//   20.  policy drift = 0 for same policy
//   21.  policy drift > 0 after training
//   22.  logprob gap direction
//   23.  self-play quality in [0,1]
//   24.  single iteration reduces loss or improves accuracy
//   25.  multi-iteration training converges or runs max_iters
//   26.  softmax invariance to shift
//   27.  grad direction matches numerical gradient
//   28.  loss symmetry: swap human/synth flips margin
//
//  Run: ./hexa self/test_spin.hexa
// ═══════════════════════════════════════════════════════════════════

import "ml/spin.hexa"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx(a, b, eps) { return fabs(a - b) < eps }

println("=== SPIN Self-Play Fine-Tuning Tests (#104) ===")

let D = 8
let SEED = 42
let BETA = 0.5

// ── 1. numeric helpers ──────────────────────────────────────────

// sigmoid
check("sigmoid_pos", spin_sigmoid(5.0) > 0.99)
check("sigmoid_neg", spin_sigmoid(-5.0) < 0.01)
check("sigmoid_zero", approx(spin_sigmoid(0.0), 0.5, 0.01))

// softplus
let sp_pos = spin_softplus(1.0)
let sp_neg = spin_softplus(-1.0)
check("softplus_positive", sp_pos > 0.0)
check("softplus_monotone", sp_pos > sp_neg)

// log_sigmoid identity: log_sigmoid(x) = -softplus(-x)
let ls_val = spin_log_sigmoid(1.3)
let sp_val = spin_softplus(-1.3)
check("log_sigmoid_vs_softplus", approx(ls_val, 0.0 - sp_val, 1.0e-4))

// ── 2. policy creation ─────────────────────────────────────────

let p0 = spin_new_policy(D, SEED)
check("policy_dim", len(p0) == D)

let p0_copy = spin_copy_policy(p0)
check("policy_copy_eq", approx(p0[0], p0_copy[0], 1.0e-10))

// modify copy doesn't affect original
p0_copy[0] = p0_copy[0] + 100.0
check("policy_copy_independent", fabs(p0[0] - p0_copy[0]) > 10.0)

// ── 3. softmax sums to 1 ───────────────────────────────────────

let sm = spin_softmax(p0)
let mut sm_sum = 0.0
let mut i = 0

while i < D { sm_sum = sm_sum + sm[i] }
check("softmax_sums_to_1", approx(sm_sum, 1.0, 1.0e-6))

// ── 4. softmax invariance to constant shift ─────────────────────

let mut p_shifted = spin_copy_policy(p0)
let mut i = 0

while i < D { p_shifted[i] = p_shifted[i] + 5.0 }
let sm2 = spin_softmax(p_shifted)
check("softmax_shift_invariant", approx(sm[0], sm2[0], 1.0e-5))

// ── 5. log_prob negativity and ordering ─────────────────────────

let lp0 = spin_log_prob(p0, 0)
let lp1 = spin_log_prob(p0, 1)
check("logprob_negative", lp0 < 0.0)
check("logprob_oob_neg", spin_log_prob(p0, -1) < -20.0)
check("logprob_oob_large", spin_log_prob(p0, D + 10) < -20.0)

// ── 6. sample returns valid action ──────────────────────────────

let action = spin_sample(p0, SEED)
check("sample_valid_range", action >= 0 && action < D)

// ── 7. generate returns n synthetic responses ───────────────────

let synths = spin_generate(p0, 5, SEED)
check("generate_count", len(synths) == 5)
let mut gen_valid = true
let mut i = 0

while i < 5 {
    if synths[i] < 0 { gen_valid = false }
    if synths[i] >= D { gen_valid = false }
}
check("generate_all_valid", gen_valid)

// ── 8. single loss is positive ──────────────────────────────────

let p1 = spin_new_policy(D, SEED)
let opp = spin_copy_policy(p1)
let human_a = 0
let synth_a = 3
let res = spin_loss(p1, opp, human_a, synth_a, BETA)
check("loss_positive", res[0] > 0.0)

// ── 9. loss decreases when policy is biased toward human ────────

let mut p_biased = spin_copy_policy(p1)
p_biased[human_a] = p_biased[human_a] + 2.0
let res_biased = spin_loss(p_biased, opp, human_a, synth_a, BETA)
check("loss_lower_when_biased_to_human", res_biased[0] < res[0])

// ── 10. margin sign correctness ─────────────────────────────────

// When policy is biased toward human, margin should be positive
check("margin_positive_when_biased", res_biased[1] > 0.0)

// When policy is biased toward synthetic, margin should be negative
let mut p_anti = spin_copy_policy(p1)
p_anti[synth_a] = p_anti[synth_a] + 2.0
let res_anti = spin_loss(p_anti, opp, human_a, synth_a, BETA)
check("margin_negative_when_anti", res_anti[1] < 0.0)

// ── 11. batch loss average ──────────────────────────────────────

let humans = [0, 1, 2]
let synths_b = [3, 4, 5]
let bl = spin_batch_loss(p1, opp, humans, synths_b, BETA)
check("batch_loss_positive", bl > 0.0)

// batch loss = manual average of individual losses
let mut manual_sum = 0.0
let mut i = 0

while i < 3 {
    let r = spin_loss(p1, opp, humans[i], synths_b[i], BETA)
    manual_sum = manual_sum + r[0]
}
check("batch_loss_matches_manual", approx(bl, manual_sum / 3.0, 1.0e-8))

// ── 12. gradient step reduces loss ──────────────────────────────

let p2 = spin_new_policy(D, 99)
let opp2 = spin_copy_policy(p2)
let loss_before = spin_loss(p2, opp2, 0, 3, BETA)
let step_res = spin_grad_step(p2, opp2, 0, 3, BETA, 1.0)
let p_after = step_res[0]
let loss_after = spin_loss(p_after, opp2, 0, 3, BETA)
check("grad_step_reduces_loss", loss_after[0] < loss_before[0])

// ── 13. batch step reduces loss over multiple steps ─────────────

let p3 = spin_new_policy(D, 77)
let opp3 = spin_copy_policy(p3)
let humans3 = [0, 1, 2, 3]
let synths3 = [4, 5, 6, 7]
let bl0 = spin_batch_loss(p3, opp3, humans3, synths3, BETA)
let res3 = spin_batch_step(p3, opp3, humans3, synths3, BETA, 0.5)
let p3a = res3[0]
let bl1 = spin_batch_loss(p3a, opp3, humans3, synths3, BETA)
check("batch_step_reduces_loss", bl1 < bl0)

// ── 14. discriminator accuracy on separated data ────────────────
// Build a policy that clearly prefers low indices (human) over high (synth)

let mut p_sep = spin_new_policy(D, 55)
// Heavily bias toward low actions
p_sep[0] = p_sep[0] + 3.0
p_sep[1] = p_sep[1] + 3.0
let opp_sep = spin_new_policy(D, 55)
let humans_sep = [0, 1, 0, 1]
let synths_sep = [6, 7, 6, 7]
let acc_sep = spin_discriminator_accuracy(p_sep, opp_sep, humans_sep, synths_sep, BETA)
check("disc_acc_separated", acc_sep >= 0.75)

// ── 15. convergence check near 0.5 ─────────────────────────────

check("convergence_at_0.5", spin_convergence_check(0.5, 0.1) == true)
check("convergence_at_0.55", spin_convergence_check(0.55, 0.1) == true)

// ── 16. convergence check far from 0.5 ─────────────────────────

check("no_convergence_at_0.9", spin_convergence_check(0.9, 0.1) == false)
check("no_convergence_at_0.1", spin_convergence_check(0.1, 0.1) == false)

// ── 17. reward margin sign ──────────────────────────────────────

let rm = spin_reward_margin(p_biased, opp, human_a, synth_a, BETA)
check("reward_margin_positive_biased", rm > 0.0)

// ── 18. mean reward: human > synthetic after bias ───────────────

let mr = spin_mean_reward(p_biased, opp, [human_a, human_a], [synth_a, synth_a], BETA)
check("mean_reward_human_gt_synth", mr[0] > mr[1])

// ── 19. KL divergence non-negative ──────────────────────────────

let p4 = spin_new_policy(D, 11)
let p5 = spin_new_policy(D, 22)
let kl_val = spin_kl_divergence(p4, p5)
check("kl_nonnegative", kl_val >= -1.0e-6)

// ── 20. KL self = 0 ─────────────────────────────────────────────

let kl_self = spin_kl_divergence(p4, p4)
check("kl_self_zero", approx(kl_self, 0.0, 1.0e-4))

// ── 21. policy drift = 0 for same policy ────────────────────────

let drift_self = spin_policy_drift(p4, p4)
check("drift_self_zero", approx(drift_self, 0.0, 1.0e-10))

// ── 22. policy drift > 0 after training ─────────────────────────

let drift_diff = spin_policy_drift(p4, p5)
check("drift_different_positive", drift_diff > 0.0)

// ── 23. logprob gap direction ───────────────────────────────────
// After biasing toward human actions, gap should be positive

let gap = spin_logprob_gap(p_biased, [human_a], [synth_a])
check("logprob_gap_positive_biased", gap > 0.0)

// ── 24. self-play quality in [0,1] ──────────────────────────────

let spq = spin_self_play_quality(p0, [0, 1, 2, 3, 4, 5, 6, 7], SEED)
check("self_play_quality_range", spq >= 0.0 && spq <= 1.0)

// ── 25. single iteration improves ───────────────────────────────

let p6 = spin_new_policy(D, 33)
let humans6 = [0, 1, 2, 3]
let iter_res = spin_iteration(p6, humans6, BETA, 0.5, 5, SEED)
let iter_loss = iter_res[1]
let iter_acc = iter_res[2]
check("iteration_acc_in_range", iter_acc >= 0.0 && iter_acc <= 1.0)

// ── 26. multi-iteration training ────────────────────────────────

let p7 = spin_new_policy(D, 44)
let humans7 = [0, 1, 2, 3]
let train_res = spin_train(p7, humans7, BETA, 0.5, 5, 3, SEED, 0.15)
let final_policy = train_res[0]
let iters_run = train_res[1]
let converged = train_res[2]
check("train_runs_iterations", iters_run >= 1)
check("train_returns_policy", len(final_policy) == D)

// ── 27. gradient direction correctness ──────────────────────────
// After a grad step, the policy should increase log-prob for human
// and decrease log-prob for synthetic (gradient moves in correct dir).

let p8 = spin_new_policy(D, 88)
let opp8 = spin_new_policy(D, 200)
let h8 = 1
let s8 = 5

let lp_h_before = spin_log_prob(p8, h8)
let lp_s_before = spin_log_prob(p8, s8)
let gs_res = spin_grad_step(p8, opp8, h8, s8, BETA, 1.0)
let p8_new = gs_res[0]
let lp_h_after = spin_log_prob(p8_new, h8)
let lp_s_after = spin_log_prob(p8_new, s8)
// human logit should increase (grad pushes probability toward human)
check("grad_increases_human_logprob", p8_new[h8] > p8[h8])
// synthetic logit should decrease
check("grad_decreases_synth_logprob", p8_new[s8] < p8[s8])

// ── 28. loss symmetry: swapping human/synth flips margin ────────

let p9 = spin_new_policy(D, 66)
let opp9 = spin_copy_policy(p9)
let res_fwd = spin_loss(p9, opp9, 2, 5, BETA)
let res_rev = spin_loss(p9, opp9, 5, 2, BETA)
check("swap_flips_margin", approx(res_fwd[1], 0.0 - res_rev[1], 1.0e-6))

// ── summary ─────────────────────────────────────────────────────

println("")
println("SPIN: " + str(pass_count) + " passed, " + str(fail_count) + " failed")
