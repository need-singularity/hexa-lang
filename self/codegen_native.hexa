// self/codegen_native.hexa — Zero-tool ARM64 Mach-O binary emitter
// Proves HEXA can produce native executables without clang, as, or ld.
//
// Emits a fully runnable MH_EXECUTE Mach-O binary for Apple Silicon.
// No external tools in the compilation pipeline — pure Hexa to native.
//
// Layout (single __TEXT page + __LINKEDIT for dyld fixups / codesign slot):
//   [0x0000]  mach_header_64               32 bytes
//   [0x0020]  LC_SEGMENT_64 __PAGEZERO     72
//   [0x0068]  LC_SEGMENT_64 __TEXT        152
//   [0x0100]  LC_SEGMENT_64 __LINKEDIT     72
//   [0x0148]  LC_DYLD_CHAINED_FIXUPS       16
//   [0x0158]  LC_SYMTAB                    24
//   [0x0170]  LC_DYSYMTAB                  80
//   [0x01C0]  LC_LOAD_DYLINKER             32
//   [0x01E0]  LC_UUID                      24
//   [0x01F8]  LC_BUILD_VERSION             24
//   [0x0210]  LC_MAIN                      24
//   [0x0228]  LC_LOAD_DYLIB libSystem      56
//   [padding] zeros to 0x300 (leaves slack for codesign's LC_CODE_SIGNATURE)
//   [0x0300]  __text code section         (variable bytes of ARM64)
//   [padding] zeros to 0x4000 (PAGE)
//   [0x4000]  __LINKEDIT content           (chained-fixups header + empty strtab)
//
// ARM64 macOS syscalls (svc #0x80):
//   SYS_exit  = 1  (x0=code, x16=1)
//   SYS_write = 4  (x0=fd, x1=buf, x2=len, x16=4)
//
// ─── P26 workaround ───
//   interp has a val_int(0) singleton cache bug.  See original header.

// ═══════════════════════════════════════════════════════════
//  ARM64 instruction encoders — CORRECTED base constants
//  All base values verified via: python3 -c "print(hex(N))"
//  against ARM Architecture Reference Manual encodings.
// ═══════════════════════════════════════════════════════════

// MOVZ Xd, #imm16  ->  0xD2800000 = 3531603968
@pure
fn enc_movz(rd: int, imm: int) -> int {
    return 3531603968 + imm * 32 + rd
}

// MOVK Xd, #imm16, LSL #(hw*16)  ->  0xF2800000 = 4068474880
@pure
fn enc_movk(rd: int, imm: int, hw: int) -> int {
    return 4068474880 + hw * 2097152 + imm * 32 + rd
}

// ADD Xd, Xn, Xm  ->  0x8B000000 = 2332033024
@pure
fn enc_add(rd: int, rn: int, rm: int) -> int {
    return 2332033024 + rm * 65536 + rn * 32 + rd
}

// SUB Xd, Xn, Xm  ->  0xCB000000 = 3405774848
@pure
fn enc_sub(rd: int, rn: int, rm: int) -> int {
    return 3405774848 + rm * 65536 + rn * 32 + rd
}

// MUL Xd, Xn, Xm  ->  0x9B007C00 = 2600500224
@pure
fn enc_mul(rd: int, rn: int, rm: int) -> int {
    return 2600500224 + rm * 65536 + rn * 32 + rd
}

// SDIV Xd, Xn, Xm  ->  0x9AC00C00 = 2596277248
@pure
fn enc_sdiv(rd: int, rn: int, rm: int) -> int {
    return 2596277248 + rm * 65536 + rn * 32 + rd
}

// MOV Xd, Xn  (ORR Xd, XZR, Xn)  ->  0xAA0003E0 = 2852127712
@pure
fn enc_mov_reg(rd: int, rm: int) -> int {
    return 2852127712 + rm * 65536 + rd
}

// STR Xt, [SP, #slot*8]  ->  0xF90003E0 = 4177527776
@pure
fn enc_str_sp(rt: int, slot: int) -> int {
    return 4177527776 + slot * 1024 + rt
}

// LDR Xt, [SP, #slot*8]  ->  0xF94003E0 = 4181722080
@pure
fn enc_ldr_sp(rt: int, slot: int) -> int {
    return 4181722080 + slot * 1024 + rt
}

// STR Xt, [Xn, Xm, LSL #3]  ->  0xF8207800 = 4162877440
@pure
fn enc_str_reg(rt: int, rn: int, rm: int) -> int {
    return 4162877440 + rm * 65536 + rn * 32 + rt
}

// LDR Xt, [Xn, Xm, LSL #3]  ->  0xF8607800 = 4167071744
@pure
fn enc_ldr_reg(rt: int, rn: int, rm: int) -> int {
    return 4167071744 + rm * 65536 + rn * 32 + rt
}

// CBZ Xt, #off  ->  0xB4000000 = 3019898880 (signed 19-bit)
@pure
fn enc_cbz(rt: int, off19: int) -> int {
    let norm = if off19 >= 0 { off19 } else { off19 + 524288 }
    return 3019898880 + norm * 32 + rt
}

// CBNZ Xt, #off  ->  0xB5000000 = 3036676096 (signed 19-bit)
@pure
fn enc_cbnz(rt: int, off19: int) -> int {
    let norm = if off19 >= 0 { off19 } else { off19 + 524288 }
    return 3036676096 + norm * 32 + rt
}

// B #off  ->  0x14000000 = 335544320
// Signed 26-bit offset. Negative values must be normalized to unsigned 26-bit
// (matches enc_bl below + ir_to_arm64's ira_enc_b).
@pure
fn enc_b(off26: int) -> int {
    if off26 >= 0 {
        return 335544320 + off26
    }
    return 335544320 + off26 + 67108864
}

// BL #off  ->  0x94000000 = 2483027968  (signed 26-bit offset)
@pure
fn enc_bl(off26: int) -> int {
    if off26 >= 0 {
        return 2483027968 + off26
    }
    return 2483027968 + off26 + 67108864
}

// RET  ->  0xD65F03C0 = 3596551104
@pure
fn enc_ret() -> int {
    return 3596551104
}

// SUB SP, SP, #imm12  ->  0xD1000000 | (imm12<<10) | (31<<5) | 31
@pure
fn enc_sub_sp(imm12: int) -> int {
    return 3506438144 + imm12 * 1024 + 1023
}

// ADD SP, SP, #imm12  ->  0x91000000 | (imm12<<10) | (31<<5) | 31
@pure
fn enc_add_sp(imm12: int) -> int {
    return 2432696320 + imm12 * 1024 + 1023
}

// ADD Xd, Xn, #imm12  ->  0x91000000 | (imm12<<10) | (Rn<<5) | Rd
@pure
fn enc_add_imm(rd: int, rn: int, imm12: int) -> int {
    return 2432696320 + imm12 * 1024 + rn * 32 + rd
}

// STP X29, X30, [SP, #-frame]!  (pre-index store pair)
// base = 0xA9800000 = 2843738112
@pure
fn enc_stp_pre(frame: int) -> int {
    let slots = frame / 8
    let imm7 = 128 - slots
    return 2843738112 + imm7 * 32768 + 30 * 1024 + 31 * 32 + 29
}

// LDP X29, X30, [SP], #frame  (post-index load pair)
// base = 0xA8C00000 = 2831155200
@pure
fn enc_ldp_post(frame: int) -> int {
    let slots = frame / 8
    return 2831155200 + slots * 32768 + 30 * 1024 + 31 * 32 + 29
}

// MOV X29, SP  ->  0x910003FD = 2432697341
@pure
fn enc_mov_fp_sp() -> int {
    return 2432697341
}

// SUBS XZR, Xn, Xm (CMP)  ->  0xEB00001F = 3942645791
@pure
fn enc_cmp(rn: int, rm: int) -> int {
    return 3942645791 + rm * 65536 + rn * 32
}

// CSET Xd, cond  (CSINC Xd, XZR, XZR, cond_inv)
// base = 0x9A9F07E0 = 2594113504
// cond codes: EQ=0 NE=1 GE=10 LT=11 GT=12 LE=13
@pure
fn enc_cset(rd: int, cond_code: int) -> int {
    if cond_code == 0 { return 2594113504 + 1 * 4096 + rd }
    if cond_code == 1 { return 2594113504 + 0 * 4096 + rd }
    if cond_code == 10 { return 2594113504 + 11 * 4096 + rd }
    if cond_code == 11 { return 2594113504 + 10 * 4096 + rd }
    if cond_code == 12 { return 2594113504 + 13 * 4096 + rd }
    if cond_code == 13 { return 2594113504 + 12 * 4096 + rd }
    return 2594113504 + rd
}

// NEG Xd, Xm  (SUB Xd, XZR, Xm)  ->  0xCB0003E0 | (Xm<<16) | Rd
// base = 0xCB0003E0 = 3405775840
@pure
fn enc_neg(rd: int, rm: int) -> int {
    return 3405775840 + rm * 65536 + rd
}

// MSUB Xd, Xn, Xm, Xa  ->  0x9B008000 = 2600501248
@pure
fn enc_msub(rd: int, rn: int, rm: int, ra: int) -> int {
    return 2600501248 + rm * 65536 + ra * 1024 + rn * 32 + rd
}

// SVC #0x80  ->  0xD4001001 = 3556773889
@pure
fn enc_svc() -> int {
    return 3556773889
}

// ═══════════════════════════════════════════════════════════
//  Extended AST for full program compilation
//
//  Node kinds:
//    "int"     - integer literal (int_val)
//    "bin"     - binary op (+,-,*,/,%) (op, l, r)
//    "cmp"     - comparison (op: ==,!=,<,>,<=,>=) (l, r)
//    "var"     - variable reference (name)
//    "let"     - let binding (name, l=value, r=body)
//    "letmut"  - let mut binding (name, l=value, r=body)
//    "assign"  - assignment (name, l=value)
//    "if"      - if/else (l=cond, r=then, e=else)
//    "while"   - while loop (l=cond, r=body)
//    "block"   - statement sequence (l=start in block_children, int_val=count)
//    "call"    - function call (name, l=first arg index, int_val=nargs)
//    "return"  - return (l=value)
//    "arrlit"  - array literal (l=first elem, int_val=count)
//    "index"   - array index (l=array, r=index)
//    "nop"     - no-op
// ═══════════════════════════════════════════════════════════

struct Node {
    kind: string,
    int_val: int,
    op: string,
    name: string,
    l: int,
    r: int,
    e: int
}

@pure
fn n_int(v: int) -> Node {
    return Node { kind: "int", int_val: v, op: "", name: "", l: 0, r: 0, e: 0 }
}

@pure
fn n_bin(op: string, l: int, r: int) -> Node {
    return Node { kind: "bin", int_val: 0, op: op, name: "", l: l, r: r, e: 0 }
}

@pure
fn n_cmp(op: string, l: int, r: int) -> Node {
    return Node { kind: "cmp", int_val: 0, op: op, name: "", l: l, r: r, e: 0 }
}

@pure
fn n_var(name: string) -> Node {
    return Node { kind: "var", int_val: 0, op: "", name: name, l: 0, r: 0, e: 0 }
}

@pure
fn n_let(name: string, val_idx: int, body_idx: int) -> Node {
    return Node { kind: "let", int_val: 0, op: "", name: name, l: val_idx, r: body_idx, e: 0 }
}

@pure
fn n_letmut(name: string, val_idx: int, body_idx: int) -> Node {
    return Node { kind: "letmut", int_val: 0, op: "", name: name, l: val_idx, r: body_idx, e: 0 }
}

@pure
fn n_assign(name: string, val_idx: int) -> Node {
    return Node { kind: "assign", int_val: 0, op: "", name: name, l: val_idx, r: 0, e: 0 }
}

@pure
fn n_if(cond_idx: int, then_idx: int, else_idx: int) -> Node {
    return Node { kind: "if", int_val: 0, op: "", name: "", l: cond_idx, r: then_idx, e: else_idx }
}

@pure
fn n_while(cond_idx: int, body_idx: int) -> Node {
    return Node { kind: "while", int_val: 0, op: "", name: "", l: cond_idx, r: body_idx, e: 0 }
}

@pure
fn n_block(start: int, count: int) -> Node {
    return Node { kind: "block", int_val: count, op: "", name: "", l: start, r: 0, e: 0 }
}

@pure
fn n_call(fn_name: string, first_arg: int, nargs: int) -> Node {
    return Node { kind: "call", int_val: nargs, op: "", name: fn_name, l: first_arg, r: 0, e: 0 }
}

@pure
fn n_fn(fn_name: string, nparams: int, body_idx: int, nlocals: int) -> Node {
    return Node { kind: "fn", int_val: nparams, op: "", name: fn_name, l: body_idx, r: nlocals, e: 0 }
}

@pure
fn n_return(val_idx: int) -> Node {
    return Node { kind: "return", int_val: 0, op: "", name: "", l: val_idx, r: 0, e: 0 }
}

@pure
fn n_arrlit(first_elem: int, count: int) -> Node {
    return Node { kind: "arrlit", int_val: count, op: "", name: "", l: first_elem, r: 0, e: 0 }
}

@pure
fn n_index(arr_idx: int, idx_idx: int) -> Node {
    return Node { kind: "index", int_val: 0, op: "", name: "", l: arr_idx, r: idx_idx, e: 0 }
}

@pure
fn n_nop() -> Node {
    return Node { kind: "nop", int_val: 0, op: "", name: "", l: 0, r: 0, e: 0 }
}

// ─── Symbol table ──────────────────────────────────────────

fn lookup_slot(syms: [string], name: string) -> int {
    let mut i = len(syms) - 1
    while i >= 0 {
        if syms[i] == name { return i }
        i = i - 1
    }
    return -1
}

// ─── Function info ─────────────────────────────────────────

struct FnInfo {
    name: string,
    code_offset: int,
    nparams: int
}

// ─── Code emitter ──────────────────────────────────────────

fn emit_expr(nodes: [Node], idx: int, syms: [string], depth: int, code_in: [int], fn_table: [FnInfo], bc: [int]) -> [int] {
    let n = nodes[idx]
    let mut code = code_in
    let dst = 9 + depth

    if n.kind == "nop" {
        return code
    }

    if n.kind == "int" {
        let v = n.int_val
        if v >= 0 {
            let lo = v % 65536
            let hi = (v / 65536) % 65536
            code = code + [enc_movz(dst, lo)]
            if hi > 0 {
                code = code + [enc_movk(dst, hi, 1)]
            }
        } else {
            let abs_v = 0 - v
            let lo = abs_v % 65536
            let hi = (abs_v / 65536) % 65536
            code = code + [enc_movz(dst, lo)]
            if hi > 0 {
                code = code + [enc_movk(dst, hi, 1)]
            }
            code = code + [enc_neg(dst, dst)]
        }
        return code
    }

    if n.kind == "var" {
        let slot = lookup_slot(syms, n.name)
        if slot >= 0 {
            code = code + [enc_ldr_sp(dst, slot)]
        }
        return code
    }

    if n.kind == "bin" {
        code = emit_expr(nodes, n.l, syms, depth, code, fn_table, bc)
        code = emit_expr(nodes, n.r, syms, depth + 1, code, fn_table, bc)
        let a = 9 + depth
        let b = 9 + depth + 1
        if n.op == "+" { code = code + [enc_add(a, a, b)] }
        if n.op == "-" { code = code + [enc_sub(a, a, b)] }
        if n.op == "*" { code = code + [enc_mul(a, a, b)] }
        if n.op == "/" { code = code + [enc_sdiv(a, a, b)] }
        if n.op == "%" {
            // a % b = a - (a/b)*b via SDIV+MSUB
            let tmp = b + 1
            code = code + [enc_sdiv(tmp, a, b)]
            code = code + [enc_msub(a, tmp, b, a)]
        }
        return code
    }

    if n.kind == "cmp" {
        code = emit_expr(nodes, n.l, syms, depth, code, fn_table, bc)
        code = emit_expr(nodes, n.r, syms, depth + 1, code, fn_table, bc)
        let a = 9 + depth
        let b = 9 + depth + 1
        code = code + [enc_cmp(a, b)]
        let mut cc = 0
        if n.op == "==" { cc = 0 }
        if n.op == "!=" { cc = 1 }
        if n.op == "<" { cc = 11 }
        if n.op == ">=" { cc = 10 }
        if n.op == ">" { cc = 12 }
        if n.op == "<=" { cc = 13 }
        code = code + [enc_cset(a, cc)]
        return code
    }

    if n.kind == "let" {
        let slot = len(syms)
        code = emit_expr(nodes, n.l, syms, depth, code, fn_table, bc)
        code = code + [enc_str_sp(dst, slot)]
        let mut syms2 = syms + [n.name]
        code = emit_expr(nodes, n.r, syms2, depth, code, fn_table, bc)
        return code
    }

    if n.kind == "letmut" {
        let slot = len(syms)
        code = emit_expr(nodes, n.l, syms, depth, code, fn_table, bc)
        code = code + [enc_str_sp(dst, slot)]
        let mut syms2 = syms + [n.name]
        code = emit_expr(nodes, n.r, syms2, depth, code, fn_table, bc)
        return code
    }

    if n.kind == "assign" {
        let slot = lookup_slot(syms, n.name)
        if slot >= 0 {
            code = emit_expr(nodes, n.l, syms, depth, code, fn_table, bc)
            code = code + [enc_str_sp(dst, slot)]
        }
        return code
    }

    if n.kind == "if" {
        code = emit_expr(nodes, n.l, syms, depth, code, fn_table, bc)
        let cond_reg = 9 + depth
        let cbz_pos = len(code)
        code = code + [enc_cbz(cond_reg, 0)]
        code = emit_expr(nodes, n.r, syms, depth, code, fn_table, bc)
        let b_pos = len(code)
        code = code + [enc_b(0)]
        let else_pos = len(code)
        code = emit_expr(nodes, n.e, syms, depth, code, fn_table, bc)
        let end_pos = len(code)
        let cbz_off = else_pos - cbz_pos
        code[cbz_pos] = enc_cbz(cond_reg, cbz_off)
        let b_off = end_pos - b_pos
        code[b_pos] = enc_b(b_off)
        return code
    }

    if n.kind == "while" {
        let loop_top = len(code)
        code = emit_expr(nodes, n.l, syms, depth, code, fn_table, bc)
        let cond_reg = 9 + depth
        let cbz_pos = len(code)
        code = code + [enc_cbz(cond_reg, 0)]
        code = emit_expr(nodes, n.r, syms, depth, code, fn_table, bc)
        let back_off = loop_top - len(code)
        if back_off < 0 {
            code = code + [335544320 + (back_off + 67108864)]
        } else {
            code = code + [enc_b(back_off)]
        }
        let loop_end = len(code)
        let cbz_off = loop_end - cbz_pos
        code[cbz_pos] = enc_cbz(cond_reg, cbz_off)
        return code
    }

    if n.kind == "block" {
        let start = n.l
        let count = n.int_val
        let mut bi = 0
        while bi < count {
            let child_idx = bc[(start + bi)]
            code = emit_expr(nodes, child_idx, syms, depth, code, fn_table, bc)
            bi = bi + 1
        }
        return code
    }

    if n.kind == "call" {
        let nargs = n.int_val
        // Evaluate args into x{9+depth}..x{9+depth+nargs-1}
        let mut ai = 0
        while ai < nargs {
            code = emit_expr(nodes, n.l + ai, syms, depth + ai, code, fn_table, bc)
            ai = ai + 1
        }
        // Move args to x0..x{nargs-1}
        let mut mi = 0
        while mi < nargs {
            code = code + [enc_mov_reg(mi, 9 + depth + mi)]
            mi = mi + 1
        }
        // Save expression registers in use
        let mut si = 0
        while si < depth {
            code = code + [enc_str_sp(9 + si, 60 + si)]
            si = si + 1
        }
        // BL placeholder (patched later)
        code = code + [enc_bl(0)]
        // Restore saved
        let mut ri = 0
        while ri < depth {
            code = code + [enc_ldr_sp(9 + ri, 60 + ri)]
            ri = ri + 1
        }
        // Move result to dst
        code = code + [enc_mov_reg(dst, 0)]
        return code
    }

    if n.kind == "return" {
        code = emit_expr(nodes, n.l, syms, depth, code, fn_table, bc)
        code = code + [enc_mov_reg(0, dst)]
        return code
    }

    if n.kind == "arrlit" {
        // Store elements into stack slots, return address of first
        let count = n.int_val
        let base_slot = len(syms)
        let mut ei = 0
        while ei < count {
            code = emit_expr(nodes, n.l + ei, syms, depth, code, fn_table, bc)
            code = code + [enc_str_sp(dst, base_slot + ei)]
            ei = ei + 1
        }
        // ADD dst, SP, #(base_slot*8)
        code = code + [enc_add_imm(dst, 31, base_slot * 8)]
        return code
    }

    if n.kind == "index" {
        code = emit_expr(nodes, n.l, syms, depth, code, fn_table, bc)
        code = emit_expr(nodes, n.r, syms, depth + 1, code, fn_table, bc)
        let arr_reg = 9 + depth
        let idx_reg = 9 + depth + 1
        // LDR dst, [arr_reg, idx_reg, LSL #3]
        code = code + [enc_ldr_reg(arr_reg, arr_reg, idx_reg)]
        return code
    }

    return code
}

// ─── Function emitter ──────────────────────────────────────

fn emit_function(nodes: [Node], fn_node: Node, param_names: [string], fn_table: [FnInfo], bc: [int]) -> [int] {
    let mut code = []
    let nparams = fn_node.int_val
    let nlocals = fn_node.r
    let body_idx = fn_node.l

    // Use SUB SP / ADD SP only — avoid STP-pre/LDP-post whose imm7 is
    // signed 7-bit (range ±64 slots ⇒ ±512B), insufficient for nlocals+70.
    // Leaf functions don't need x29/x30 save since they don't BL further.
    let mut frame = (nlocals + 8) * 8
    if frame < 16 { frame = 16 }
    if frame % 16 != 0 { frame = frame + (16 - frame % 16) }

    // Prologue: SUB SP, SP, #frame  (enc_sub_sp uses 12-bit imm, up to 4095)
    code = code + [enc_sub_sp(frame)]

    // Store params into local slots
    let mut syms = []
    let mut pi = 0
    while pi < nparams {
        syms = syms + [param_names[pi]]
        code = code + [enc_str_sp(pi, pi)]
        pi = pi + 1
    }

    // Body
    code = emit_expr(nodes, body_idx, syms, 0, code, fn_table, bc)

    // Move result to x0
    code = code + [enc_mov_reg(0, 9)]

    // Epilogue: ADD SP, SP, #frame; RET
    code = code + [enc_add_sp(frame)]
    code = code + [enc_ret()]

    return code
}

// ─── Program emitter (entry point) ─────────────────────────

fn emit_program(nodes: [Node], root: int, num_slots: int, fn_table: [FnInfo], bc: [int]) -> [int] {
    let mut code = []
    let mut frame = (num_slots + 70) * 8
    if frame < 16 { frame = 16 }
    if frame % 16 != 0 { frame = frame + (16 - frame % 16) }
    code = code + [enc_sub_sp(frame)]
    let syms = []
    code = emit_expr(nodes, root, syms, 0, code, fn_table, bc)
    code = code + [enc_mov_reg(0, 9)]
    code = code + [enc_add_sp(frame)]
    code = code + [enc_movz(16, 1)]
    code = code + [enc_svc()]
    return code
}

// ═══════════════════════════════════════════════════════════
//  Mach-O builder
// ═══════════════════════════════════════════════════════════

fn u32_to_hex(v: int, h: string) -> string {
    let mut parts = []
    parts.push(h[(v % 256) / 16])
    parts.push(h[(v % 256) % 16])
    parts.push(h[((v / 256) % 256) / 16])
    parts.push(h[((v / 256) % 256) % 16])
    parts.push(h[((v / 65536) % 256) / 16])
    parts.push(h[((v / 65536) % 256) % 16])
    parts.push(h[((v / 16777216) % 256) / 16])
    parts.push(h[((v / 16777216) % 256) % 16])
    return parts.join("")
}

fn u64_to_hex(v: int, h: string) -> string {
    let lo = v % 4294967296
    let hi = v / 4294967296
    return u32_to_hex(lo, h) + u32_to_hex(hi, h)
}

fn build_macho_hex(code_u32: [int]) -> string {
    let HEX = "0123456789abcdef"
    let MH_MAGIC_64 = 4277009103
    let CPU_ARM64   = 16777228
    let MH_EXECUTE  = 2
    let HDR_FLAGS   = 2097285
    let NCMDS       = 11
    let SIZEOFCMDS  = 576
    let PAGE     = 16384
    let CODE_OFF = 768

    let code_bytes = len(code_u32) * 4
    let mut text_size_aligned = code_bytes
    if text_size_aligned % 4 != 0 {
        text_size_aligned = text_size_aligned + (4 - text_size_aligned % 4)
    }

    let mut parts = []

    // mach_header_64
    let hdr_u32 = [MH_MAGIC_64, CPU_ARM64, 0, MH_EXECUTE, NCMDS, SIZEOFCMDS, HDR_FLAGS, 0]
    let mut hi = 0
    while hi < len(hdr_u32) {
        parts.push(u32_to_hex(hdr_u32[hi], HEX))
        hi = hi + 1
    }

    // LC_SEGMENT_64 __PAGEZERO
    parts.push("19000000" + "48000000")
    parts.push("5f5f504147455a45524f0000000000" + "00")
    parts.push("0000000000000000")
    parts.push("0000000001000000")
    parts.push("0000000000000000")
    parts.push("0000000000000000")
    parts.push("00000000" + "00000000" + "00000000" + "00000000")

    // LC_SEGMENT_64 __TEXT
    parts.push("19000000" + "98000000")
    parts.push("5f5f54455854000000000000000000" + "00")
    parts.push("0000000001000000")
    parts.push("0040000000000000")
    parts.push("0000000000000000")
    parts.push("0040000000000000")
    parts.push("05000000")
    parts.push("05000000")
    parts.push("01000000")
    parts.push("00000000")

    // section __text
    parts.push("5f5f74657874000000000000000000" + "00")
    parts.push("5f5f54455854000000000000000000" + "00")
    parts.push(u64_to_hex(4294967296 + CODE_OFF, HEX))
    parts.push(u64_to_hex(text_size_aligned, HEX))
    parts.push(u32_to_hex(CODE_OFF, HEX))
    parts.push("02000000")
    parts.push("00000000" + "00000000")
    parts.push("00040080")
    parts.push("00000000" + "00000000" + "00000000")

    // LC_SEGMENT_64 __LINKEDIT
    parts.push("19000000" + "48000000")
    parts.push("5f5f4c494e4b45444954000000000000")
    parts.push("0040000001000000")
    parts.push("0040000000000000")
    parts.push("0040000000000000")
    parts.push("3100000000000000")
    parts.push("01000000" + "01000000")
    parts.push("00000000" + "00000000")

    // LC_DYLD_CHAINED_FIXUPS
    parts.push("34000080" + "10000000" + "00400000" + "30000000")

    // LC_SYMTAB
    parts.push("02000000" + "18000000")
    parts.push("30400000")
    parts.push("00000000")
    parts.push("30400000")
    parts.push("01000000")

    // LC_DYSYMTAB
    parts.push("0b000000" + "50000000")
    let mut dyz_parts = []
    let mut dyz = 0
    while dyz < 72 {
        dyz_parts.push("00")
        dyz = dyz + 1
    }
    parts.push(dyz_parts.join(""))

    // LC_LOAD_DYLINKER
    parts.push("0e000000" + "20000000" + "0c000000")
    parts.push("2f7573722f6c69622f64796c6400")
    parts.push("000000000000")

    // LC_UUID
    parts.push("1b000000" + "18000000")
    parts.push("48455841414243444546303132333435")

    // LC_BUILD_VERSION
    parts.push("32000000" + "18000000")
    parts.push("01000000")
    parts.push("00000e00")
    parts.push("00000e00")
    parts.push("00000000")

    // LC_MAIN
    parts.push("28000080" + "18000000")
    parts.push(u64_to_hex(CODE_OFF, HEX))
    parts.push("0000000000000000")

    // LC_LOAD_DYLIB libSystem
    parts.push("0c000000" + "38000000")
    parts.push("18000000")
    parts.push("02000000")
    parts.push("00000100")
    parts.push("00000100")
    parts.push("2f7573722f6c69622f6c69625379737465")
    parts.push("6d2e422e64796c696200000000000000")

    let mut s = parts.join("")

    // Pad to CODE_OFF
    while (len(s) / 2) < CODE_OFF {
        s = s + "00"
    }

    // Code section
    let mut ci = 0
    while ci < len(code_u32) {
        s = s + u32_to_hex(code_u32[ci], HEX)
        ci = ci + 1
    }

    // Pad __TEXT to PAGE
    while (len(s) / 2) < PAGE {
        s = s + "00"
    }

    // __LINKEDIT
    s = s + "00000000"
    s = s + "20000000"
    s = s + "00000000"
    s = s + "00000000"
    s = s + "00000000"
    s = s + "01000000"
    s = s + "00000000"
    s = s + "00000000"
    s = s + "03000000"
    s = s + "00000000" + "00000000" + "00000000"
    s = s + "00"

    return s
}

// ═══════════════════════════════════════════════════════════
//  Demo 1: let a=7, b=6, exit(a*b) => 42
// ═══════════════════════════════════════════════════════════

fn build_demo_42() -> string {
    let mut nodes = []
    nodes = nodes + [n_int(7)]         // 0
    nodes = nodes + [n_int(6)]         // 1
    nodes = nodes + [n_var("a")]       // 2
    nodes = nodes + [n_var("b")]       // 3
    nodes = nodes + [n_bin("*", 2, 3)] // 4
    nodes = nodes + [n_let("b", 1, 4)] // 5
    nodes = nodes + [n_let("a", 0, 5)] // 6

    let fn_table = []
    let bc = []
    let code = emit_program(nodes, 6, 4, fn_table, bc)
    return build_macho_hex(code)
}

// ═══════════════════════════════════════════════════════════
//  Demo 2: while loop sum(1..10) = 55
// ═══════════════════════════════════════════════════════════

fn build_while_demo() -> string {
    let mut nodes = []
    let mut bc = []

    nodes = nodes + [n_int(0)]           // 0: init sum
    nodes = nodes + [n_int(1)]           // 1: init i
    nodes = nodes + [n_int(10)]          // 2: limit
    nodes = nodes + [n_var("i")]         // 3
    nodes = nodes + [n_cmp("<=", 3, 2)]  // 4: i <= 10
    nodes = nodes + [n_var("sum")]       // 5
    nodes = nodes + [n_var("i")]         // 6
    nodes = nodes + [n_bin("+", 5, 6)]   // 7: sum + i
    nodes = nodes + [n_assign("sum", 7)] // 8
    nodes = nodes + [n_var("i")]         // 9
    nodes = nodes + [n_int(1)]           // 10
    nodes = nodes + [n_bin("+", 9, 10)]  // 11: i + 1
    nodes = nodes + [n_assign("i", 11)]  // 12

    // Block for while body
    bc = bc + [8]    // bc[0]
    bc = bc + [12]   // bc[1]
    nodes = nodes + [n_block(0, 2)]      // 13: while body

    nodes = nodes + [n_while(4, 13)]     // 14: while
    nodes = nodes + [n_var("sum")]       // 15: result

    // Outer blocks
    bc = bc + [14]   // bc[2] = while
    bc = bc + [15]   // bc[3] = var sum
    nodes = nodes + [n_block(2, 2)]      // 16

    nodes = nodes + [n_letmut("i", 1, 16)]   // 17
    nodes = nodes + [n_letmut("sum", 0, 17)]  // 18

    let fn_table = []
    let code = emit_program(nodes, 18, 8, fn_table, bc)
    return build_macho_hex(code)
}

// ═══════════════════════════════════════════════════════════
//  Demo 3: if/else — if 30>12 {30} else {12} => 30
// ═══════════════════════════════════════════════════════════

fn build_ifelse_demo() -> string {
    let mut nodes = []
    nodes = nodes + [n_int(30)]         // 0
    nodes = nodes + [n_int(12)]         // 1
    nodes = nodes + [n_cmp(">", 0, 1)]  // 2
    nodes = nodes + [n_int(30)]         // 3
    nodes = nodes + [n_int(12)]         // 4
    nodes = nodes + [n_if(2, 3, 4)]     // 5

    let fn_table = []
    let bc = []
    let code = emit_program(nodes, 5, 2, fn_table, bc)
    return build_macho_hex(code)
}

// ═══════════════════════════════════════════════════════════
//  Demo 4: string "42\n" via sys_write (hardcoded instrs)
// ═══════════════════════════════════════════════════════════

fn build_string_demo() -> string {
    let code_u32 = [
        2847898621, 2432697341, 3506455551,
        1384121992,  956302312,
        1384121928,  956303336,
        1384120648,  956304360,
        3531604000, 2432697313, 3531604066, 3531604112, 3556773889,
        3531603968, 3531604016, 3556773889
    ]
    return build_macho_hex(code_u32)
}

// ═══════════════════════════════════════════════════════════
//  Demo 5: function call — add(17,25) = 42
// ═══════════════════════════════════════════════════════════

fn build_fn_call_demo() -> string {
    let mut fn_nodes = []
    let bc = []

    // fn add body: a + b
    fn_nodes = fn_nodes + [n_var("a")]       // 0
    fn_nodes = fn_nodes + [n_var("b")]       // 1
    fn_nodes = fn_nodes + [n_bin("+", 0, 1)] // 2
    fn_nodes = fn_nodes + [n_return(2)]      // 3

    let add_fn_node = n_fn("add", 2, 3, 4)
    let param_names = ["a", "b"]
    let fn_table_empty = []
    let add_code = emit_function(fn_nodes, add_fn_node, param_names, fn_table_empty, bc)

    // Entry: call add(17, 25)
    let mut entry_nodes = []
    entry_nodes = entry_nodes + [n_int(17)]          // 0
    entry_nodes = entry_nodes + [n_int(25)]          // 1
    entry_nodes = entry_nodes + [n_call("add", 0, 2)] // 2

    let fn_info = FnInfo { name: "add", code_offset: 0, nparams: 2 }
    let mut fn_table = [fn_info]

    // First pass to get entry size
    let entry_code = emit_program(entry_nodes, 2, 4, fn_table, bc)
    let entry_len = len(entry_code)

    // Update fn_table with correct offset
    fn_table = [FnInfo { name: "add", code_offset: entry_len, nparams: 2 }]

    // Second pass with correct offset
    let entry_code2 = emit_program(entry_nodes, 2, 4, fn_table, bc)

    // Patch BL instructions
    let bl_sentinel = 2483027968
    let mut full_code = []
    let mut ei = 0
    while ei < len(entry_code2) {
        let inst = entry_code2[ei]
        if inst == bl_sentinel {
            let off = entry_len - ei
            full_code = full_code + [enc_bl(off)]
        } else {
            full_code = full_code + [inst]
        }
        ei = ei + 1
    }

    // Append add function
    let mut ai = 0
    while ai < len(add_code) {
        full_code = full_code + [add_code[ai]]
        ai = ai + 1
    }

    return build_macho_hex(full_code)
}

// ═══════════════════════════════════════════════════════════
//  Demo 6: array literal + indexing — [10,20,12][2] => 12
// ═══════════════════════════════════════════════════════════

fn build_array_demo() -> string {
    let mut nodes = []
    // Array elements
    nodes = nodes + [n_int(10)]         // 0
    nodes = nodes + [n_int(20)]         // 1
    nodes = nodes + [n_int(12)]         // 2
    // arrlit
    nodes = nodes + [n_arrlit(0, 3)]    // 3
    // index 2
    nodes = nodes + [n_int(2)]          // 4
    // let arr = arrlit; arr[2]
    nodes = nodes + [n_var("arr")]      // 5
    nodes = nodes + [n_index(5, 4)]     // 6
    nodes = nodes + [n_let("arr", 3, 6)] // 7

    let fn_table = []
    let bc = []
    let code = emit_program(nodes, 7, 8, fn_table, bc)
    return build_macho_hex(code)
}

// ═══════════════════════════════════════════════════════════
//  Helper: write hex, codesign, run, get exit code
// ═══════════════════════════════════════════════════════════

fn run_test(hex_data: string, path: string) -> string {
    exec("printf '%s' '" + hex_data + "' | xxd -r -p > " + path)
    exec("chmod +x " + path)
    exec("codesign -s - -f " + path + " 2>&1")
    let r = exec(path + " 2>&1; echo $?")
    let lines = r.trim().split("\n")
    return lines[(len(lines) - 1)]
}

// ═══════════════════════════════════════════════════════════
//  SH3 1.D — dynamic println("<lit>") emitter.
//  Replaces the hardcoded build_string_demo() (always "42")
//  with a per-literal builder. Pack up to 7 ASCII bytes plus a
//  trailing '\n' into one 64-bit immediate (movz/movk into x3),
//  push to the stack, sys_write(1, sp, n+1), sys_exit(0).
//  Limit: total len ≤ 8 bytes (string + newline). Longer
//  strings need a multi-store loop — deferred to 1.E.
// ═══════════════════════════════════════════════════════════

fn build_println_dyn(s: string) -> string {
    // SH3 phase 2.A: lift the prior ≤7-byte cap with an 8-byte-word
    // chunked store loop. Cap at 256 bytes (sanity — longer strings
    // would prefer .rodata addressing, deferred to phase 3).
    let n = byte_len(s)
    if n > 256 { return "" }
    let total = n + 1  // +newline
    // 8-byte word count
    let mut nwords = total / 8
    if (total % 8) != 0 { nwords = nwords + 1 }
    // 16-byte-aligned stack frame
    let mut frame = nwords * 8
    if (frame % 16) != 0 { frame = frame + 8 }

    let mut code = []
    code = code + [enc_sub_sp(frame)]

    // For each word: pack up to 8 bytes (4 16-bit chunks) and str.
    let mut wi = 0
    while wi < nwords {
        let base_p = wi * 8
        let mut chunk0 = 0
        let mut chunk1 = 0
        let mut chunk2 = 0
        let mut chunk3 = 0
        let mut bi = 0
        while bi < 8 {
            let p = base_p + bi
            let mut c = 0
            if p < n {
                c = s.byte_at(p)
            } else if p == n {
                c = 10  // newline at position n
            } else {
                c = 0   // pad
            }
            let mut mult = 1
            if (bi % 2) == 1 { mult = 256 }
            let ci = bi / 2
            if ci == 0 { chunk0 = chunk0 + c * mult }
            if ci == 1 { chunk1 = chunk1 + c * mult }
            if ci == 2 { chunk2 = chunk2 + c * mult }
            if ci == 3 { chunk3 = chunk3 + c * mult }
            bi = bi + 1
        }
        // movz x3, chunk0  (reset x3 for this word)
        code = code + [enc_movz(3, chunk0)]
        if chunk1 > 0 { code = code + [enc_movk(3, chunk1, 1)] }
        if chunk2 > 0 { code = code + [enc_movk(3, chunk2, 2)] }
        if chunk3 > 0 { code = code + [enc_movk(3, chunk3, 3)] }
        // str x3, [sp, #wi*8]
        code = code + [enc_str_sp(3, wi)]
        wi = wi + 1
    }

    // sys_write(1, sp, total). For total > 65535, would need movz+movk
    // on x2 too; 256 cap keeps total ≤ 257, well within 16-bit imm.
    code = code + [enc_movz(0, 1)]
    code = code + [enc_add_imm(1, 31, 0)]   // x1 = sp
    code = code + [enc_movz(2, total)]
    code = code + [enc_movz(16, 4)]
    code = code + [enc_svc()]

    // sys_exit(0). Skip stack restore — process exits anyway.
    code = code + [enc_movz(0, 0)]
    code = code + [enc_movz(16, 1)]
    code = code + [enc_svc()]

    return build_macho_hex(code)
}

// ═══════════════════════════════════════════════════════════
//  Demo driver — wrapped in fn so `use "self/codegen_native"`
//  imports the helpers without firing the 6-test smoke run.
//  Standalone invocation `hexa self/codegen_native.hexa` re-enters
//  the demo via the explicit call below the fn.
// ═══════════════════════════════════════════════════════════

fn run_demo() {
    println("=== HEXA zero-tool ARM64 Mach-O binary emitter (v2) ===")
    println("  Supports: let/let mut, if/else, while, +,-,*,/,%")
    println("  Supports: comparison ops, functions, calls, arrays")
    println("")

    // Test 1: 7*6 = 42
    println("[Test 1] let a=7, let b=6, exit(a*b) => 42")
    let r1 = run_test(build_demo_42(), "/tmp/hexa_native_t1")
    println("  exit code: " + r1)
    if r1 == "42" { println("  PASS") } else { println("  FAIL (expected 42)") }

    // Test 2: sum(1..10) = 55
    println("")
    println("[Test 2] while loop: sum(1..10) => 55")
    let r2 = run_test(build_while_demo(), "/tmp/hexa_native_t2")
    println("  exit code: " + r2)
    if r2 == "55" { println("  PASS") } else { println("  FAIL (expected 55)") }

    // Test 3: if/else
    println("")
    println("[Test 3] if/else: if 30>12 {30} else {12} => 30")
    let r3 = run_test(build_ifelse_demo(), "/tmp/hexa_native_t3")
    println("  exit code: " + r3)
    if r3 == "30" { println("  PASS") } else { println("  FAIL (expected 30)") }

    // Test 4: string output
    println("")
    println("[Test 4] String output via sys_write => '42'")
    let hex4 = build_string_demo()
    exec("printf '%s' '" + hex4 + "' | xxd -r -p > /tmp/hexa_native_t4")
    exec("chmod +x /tmp/hexa_native_t4")
    exec("codesign -s - -f /tmp/hexa_native_t4 2>&1")
    let r4 = exec("/tmp/hexa_native_t4 2>&1").trim()
    println("  stdout: '" + r4 + "'")
    if r4 == "42" { println("  PASS") } else { println("  FAIL (expected '42')") }

    // Test 5: function call
    println("")
    println("[Test 5] fn add(a,b) { a+b }; add(17,25) => 42")
    let r5 = run_test(build_fn_call_demo(), "/tmp/hexa_native_t5")
    println("  exit code: " + r5)
    if r5 == "42" { println("  PASS") } else { println("  FAIL (expected 42)") }

    // Test 6: array
    println("")
    println("[Test 6] [10,20,12][2] => 12")
    let r6 = run_test(build_array_demo(), "/tmp/hexa_native_t6")
    println("  exit code: " + r6)
    if r6 == "12" { println("  PASS") } else { println("  FAIL (expected 12)") }

    println("")
    println("=== Zero-tool ARM64 Mach-O emitter v2 complete ===")
    println("  No clang. No as. No ld. Pure HEXA -> ARM64 Mach-O.")
}

// SH3 1.C: gate the demo behind a hexa_main() so `use` imports stay
// silent; standalone `hexa self/codegen_native.hexa` still runs the
// demo because dispatch invokes hexa_main when present.
fn hexa_main() {
    run_demo()
}
