// self/codegen_native.hexa — Zero-tool ARM64 Mach-O binary emitter
// Proves HEXA can produce native executables without clang, as, or ld.
//
// Emits a fully runnable MH_EXECUTE Mach-O binary for Apple Silicon.
// No external tools in the compilation pipeline — pure Hexa to native.
//
// Layout (single __TEXT page + __LINKEDIT for dyld fixups / codesign slot):
//   [0x0000]  mach_header_64               32 bytes
//   [0x0020]  LC_SEGMENT_64 __PAGEZERO     72
//   [0x0068]  LC_SEGMENT_64 __TEXT        152
//   [0x0100]  LC_SEGMENT_64 __LINKEDIT     72
//   [0x0148]  LC_DYLD_CHAINED_FIXUPS       16
//   [0x0158]  LC_SYMTAB                    24
//   [0x0170]  LC_DYSYMTAB                  80
//   [0x01C0]  LC_LOAD_DYLINKER             32
//   [0x01E0]  LC_UUID                      24
//   [0x01F8]  LC_BUILD_VERSION             24
//   [0x0210]  LC_MAIN                      24
//   [0x0228]  LC_LOAD_DYLIB libSystem      56
//   [padding] zeros to 0x300 (leaves slack for codesign's LC_CODE_SIGNATURE)
//   [0x0300]  __text code section         (68 bytes of ARM64)
//   [padding] zeros to 0x4000 (PAGE)
//   [0x4000]  __LINKEDIT content           (chained-fixups header + empty strtab)
//
// ARM64 macOS syscalls (svc #0x80):
//   SYS_exit  = 1  (x0=code, x16=1)
//   SYS_write = 4  (x0=fd, x1=buf, x2=len, x16=4)
//
// ─── P26 workaround ───
//   stage0 has a val_int(0) singleton cache bug: any function whose return
//   value involves a computed 0 (common via integer division) corrupts the
//   shared 0 singleton, poisoning any subsequent call. Therefore the whole
//   generation lives inside ONE function, `build_binary_hex()`, called
//   exactly once. All u32/u64 decomposition is inlined via `HEX[...]`
//   string lookup — no nested helper is reached more than once per run.

// ═══════════════════════════════════════════════════════════
//  ARM64 instruction encoders
//  All encodings verified against `as` + `otool -t` (see /tmp/asm_check).
//  We avoid bit-shift operators (stage0 parser quirk with `<<` + parens)
//  and use plain arithmetic since all values fit in 32-bit positives.
// ═══════════════════════════════════════════════════════════

// MOVZ Xd, #imm16  ->  0xD2800000 | (imm<<5) | Rd
@pure
fn enc_movz(rd: int, imm: int) -> int {
    return 3531603968 + imm * 32 + rd
}

// MOVK Xd, #imm16, LSL #(hw*16)  ->  0xF2800000 | (hw<<21) | (imm<<5) | Rd
@pure
fn enc_movk(rd: int, imm: int, hw: int) -> int {
    return 4068474880 + hw * 2097152 + imm * 32 + rd
}

// ADD Xd, Xn, Xm  ->  0x8B000000 | (Rm<<16) | (Rn<<5) | Rd
@pure
fn enc_add(rd: int, rn: int, rm: int) -> int {
    return 2332033024 + rm * 65536 + rn * 32 + rd
}

// SUB Xd, Xn, Xm  ->  0xCB000000 | (Rm<<16) | (Rn<<5) | Rd
@pure
fn enc_sub(rd: int, rn: int, rm: int) -> int {
    return 3406774272 + rm * 65536 + rn * 32 + rd
}

// MUL Xd, Xn, Xm  ->  0x9B007C00 | (Rm<<16) | (Rn<<5) | Rd
@pure
fn enc_mul(rd: int, rn: int, rm: int) -> int {
    return 2600500224 + rm * 65536 + rn * 32 + rd
}

// SDIV Xd, Xn, Xm  ->  0x9AC00C00 | (Rm<<16) | (Rn<<5) | Rd
@pure
fn enc_sdiv(rd: int, rn: int, rm: int) -> int {
    return 2596309504 + rm * 65536 + rn * 32 + rd
}

// MOV Xd, Xn  (alias for ORR Xd, XZR, Xn)  ->  0xAA0003E0 | (Rm<<16) | Rd
@pure
fn enc_mov_reg(rd: int, rm: int) -> int {
    return 2852127200 + rm * 65536 + rd
}

// STR Xt, [SP, #slot*8]  ->  0xF90003E0 | (slot<<10) | Rt
@pure
fn enc_str_sp(rt: int, slot: int) -> int {
    return 4178968544 + slot * 1024 + rt
}

// LDR Xt, [SP, #slot*8]  ->  0xF94003E0 | (slot<<10) | Rt
@pure
fn enc_ldr_sp(rt: int, slot: int) -> int {
    return 4182113760 + slot * 1024 + rt
}

// CBZ Xt, #off  ->  0xB4000000 | (off19<<5) | Rt   (off in instructions)
@pure
fn enc_cbz(rt: int, off19: int) -> int {
    return 3019898880 + off19 * 32 + rt
}

// B #off  ->  0x14000000 | off26  (off in instructions)
@pure
fn enc_b(off26: int) -> int {
    return 335544320 + off26
}

// SUB SP, SP, #imm12  ->  0xD1000000 | (imm12<<10) | (31<<5) | 31
@pure
fn enc_sub_sp(imm12: int) -> int {
    return 3506438144 + imm12 * 1024 + 1023
}

// ADD SP, SP, #imm12  ->  0x91000000 | (imm12<<10) | (31<<5) | 31
@pure
fn enc_add_sp(imm12: int) -> int {
    return 2432696320 + imm12 * 1024 + 1023
}

// SVC #0x80  ->  0xD4001001  (constant)
@pure
fn enc_svc() -> int {
    return 3556773889
}

// ═══════════════════════════════════════════════════════════
//  Tiny AST + register-stack ARM64 emitter
//
//  Strategy: each Expr has a kind. We walk it, lowering to a register
//  stack model: subexpression values live in x9, x10, x11, ... x14
//  (stack depth bounded by 6). Final result moved to x0 for exit code.
//  Variables live in fixed SP-relative slots; if-else uses CBZ/B.
//
//  The AST is *flat* — children referenced by integer indices into
//  a [Node] array. This avoids the P26 string-serialization trap and
//  keeps the walker tail-flat enough for stage0.
// ═══════════════════════════════════════════════════════════

struct Node {
    kind: string,    // "int", "bin", "var", "let", "if", "block"
    int_val: int,
    op: string,      // "+" "-" "*" "/" for bin
    name: string,    // identifier for var / let
    l: int,          // index of left child (or cond / value for let)
    r: int,          // index of right child (or body for let)
    e: int           // index of else branch (for if)
}

@pure
fn n_int(v: int) -> Node {
    return Node { kind: "int", int_val: v, op: "", name: "", l: 0, r: 0, e: 0 }
}

@pure
fn n_bin(op: string, l: int, r: int) -> Node {
    return Node { kind: "bin", int_val: 0, op: op, name: "", l: l, r: r, e: 0 }
}

@pure
fn n_var(name: string) -> Node {
    return Node { kind: "var", int_val: 0, op: "", name: name, l: 0, r: 0, e: 0 }
}

// `let name = (l)` followed by body (r). Body's value is the let-expr value.
@pure
fn n_let(name: string, val_idx: int, body_idx: int) -> Node {
    return Node { kind: "let", int_val: 0, op: "", name: name, l: val_idx, r: body_idx, e: 0 }
}

// if cond (l) then (r) else (e)
@pure
fn n_if(cond_idx: int, then_idx: int, else_idx: int) -> Node {
    return Node { kind: "if", int_val: 0, op: "", name: "", l: cond_idx, r: then_idx, e: else_idx }
}

// ─── Symbol table: parallel arrays passed as state ─────────
// Each `let` allocates a slot (sp-relative, 8 bytes each). Lookup by name
// walks from end to support shadowing. Stack frame = 16 * MAX_SLOTS aligned.

fn lookup_slot(syms: [string], name: string) -> int {
    let mut i = len(syms) - 1
    while i >= 0 {
        if syms[i] == name { return i }
        i = i - 1
    }
    return -1
}

// ─── Code emitter ──────────────────────────────────────────
// emit_expr returns updated code list. The expression's result lands
// in register x{9 + depth - 1} after the call (stack depth grows by 1).

fn emit_expr(nodes: [Node], idx: int, syms: [string], depth: int, code_in: [int]) -> [int] {
    let n = nodes[idx]
    let mut code = code_in
    let dst = 9 + depth   // result goes here

    if n.kind == "int" {
        // MOVZ low 16 bits, then MOVK upper 16 bits if value > 65535.
        let v = n.int_val
        let lo = v % 65536
        let hi = (v / 65536) % 65536
        code = code + [enc_movz(dst, lo)]
        if hi > 0 {
            code = code + [enc_movk(dst, hi, 1)]
        }
        return code
    }

    if n.kind == "var" {
        let slot = lookup_slot(syms, n.name)
        // LDR Xdst, [SP, #slot*8]
        code = code + [enc_ldr_sp(dst, slot)]
        return code
    }

    if n.kind == "bin" {
        // Eval left into x{9+depth}, right into x{9+depth+1}, fold into x{9+depth}.
        code = emit_expr(nodes, n.l, syms, depth, code)
        code = emit_expr(nodes, n.r, syms, depth + 1, code)
        let a = 9 + depth
        let b = 9 + depth + 1
        if n.op == "+" { code = code + [enc_add(a, a, b)] }
        if n.op == "-" { code = code + [enc_sub(a, a, b)] }
        if n.op == "*" { code = code + [enc_mul(a, a, b)] }
        if n.op == "/" { code = code + [enc_sdiv(a, a, b)] }
        return code
    }

    if n.kind == "let" {
        // Evaluate value into next register, store to this slot, then body.
        let slot = len(syms)
        code = emit_expr(nodes, n.l, syms, depth, code)
        // STR x{dst}, [SP, #slot*8]
        code = code + [enc_str_sp(dst, slot)]
        let mut syms2 = syms + [n.name]
        // Body uses same depth (let value already consumed).
        code = emit_expr(nodes, n.r, syms2, depth, code)
        return code
    }

    if n.kind == "if" {
        // Lower:  eval cond -> reg c
        //         CBZ c, ELSE
        //         <then>
        //         B END
        // ELSE:   <else>
        // END:
        // Two-pass approach: emit then/else into temp lists to know their lengths.
        let cond_code_len_before = len(code)
        code = emit_expr(nodes, n.l, syms, depth, code)
        let cond_reg = 9 + depth
        // Reserve a slot for CBZ; we patch after we know then-length.
        let cbz_pos = len(code)
        code = code + [enc_cbz(cond_reg, 0)]   // placeholder
        // Then branch — also lowers result into x{dst}
        code = emit_expr(nodes, n.r, syms, depth, code)
        // Reserve slot for unconditional B over else
        let b_pos = len(code)
        code = code + [enc_b(0)]   // placeholder
        // ELSE label is here:
        let else_pos = len(code)
        code = emit_expr(nodes, n.e, syms, depth, code)
        let end_pos = len(code)
        // Patch CBZ: jump from cbz_pos to else_pos
        let cbz_off = else_pos - cbz_pos
        code[cbz_pos] = enc_cbz(cond_reg, cbz_off)
        // Patch B: jump from b_pos to end_pos
        let b_off = end_pos - b_pos
        code[b_pos] = enc_b(b_off)
        return code
    }

    return code
}

// Wrap an expression's emit into a complete `_start`-style routine that:
//   1. Sets up a stack frame (SUB SP, SP, #frame_bytes)
//   2. Evaluates expr, leaves result in x9
//   3. MOV X0, X9        (exit code)
//   4. MOVZ X16, #1      (SYS_exit)
//   5. SVC #0x80
fn emit_program(nodes: [Node], root: int, num_slots: int) -> [int] {
    let mut code = []
    // Round frame to multiple of 16, minimum 16.
    let mut frame = num_slots * 8
    if frame < 16 { frame = 16 }
    if frame % 16 != 0 { frame = frame + (16 - frame % 16) }
    code = code + [enc_sub_sp(frame)]
    let syms = []
    code = emit_expr(nodes, root, syms, 0, code)
    code = code + [enc_mov_reg(0, 9)]      // MOV X0, X9
    code = code + [enc_add_sp(frame)]      // restore SP
    code = code + [enc_movz(16, 1)]        // SYS_exit
    code = code + [enc_svc()]
    return code
}

// ═══════════════════════════════════════════════════════════
//  Single-shot Mach-O builder (P26-safe)
// ═══════════════════════════════════════════════════════════

fn build_binary_hex() {
    // Hex digit lookup — avoids if/branch helper fns.
    let HEX = "0123456789abcdef"

    // ─── Mach-O header constants ───
    let MH_MAGIC_64 = 4277009103     // 0xFEEDFACF
    let CPU_ARM64   = 16777228       // 0x0100000C
    let MH_EXECUTE  = 2
    let HDR_FLAGS   = 2097285        // MH_PIE|MH_DYLDLINK|MH_NOUNDEFS|MH_TWOLEVEL
    let NCMDS       = 11
    let SIZEOFCMDS  = 576

    // ─── Layout ───
    let PAGE     = 16384             // 0x4000 — Apple Silicon
    let CODE_OFF = 768               // 0x300 — clears load cmds + codesign slack

    // ─── ARM64 instruction encoding (verified against system assembler) ───
    //   STP  X29,X30,[SP,#-16]!       0xA9BF7BFD = 2847898621
    //   MOV  X29, SP                  0x910003FD = 2432697341
    //   SUB  SP, SP, #16              0xD10043FF = 3506455551
    //   MOVZ W8, #52 ('4')            0x52800688 = 1384121992
    //   STRB W8, [SP, #0]             0x390003E8 =  956302312
    //   MOVZ W8, #50 ('2')            0x52800648 = 1384121928
    //   STRB W8, [SP, #1]             0x390007E8 =  956303336
    //   MOVZ W8, #10 ('\n')           0x52800148 = 1384120648
    //   STRB W8, [SP, #2]             0x39000BE8 =  956304360
    //   MOVZ X0, #1 (stdout)          0xD2800020 = 3531604000
    //   MOV  X1, SP (ADD X1,SP,#0)    0x910003E1 = 2432697313
    //   MOVZ X2, #3 (len)             0xD2800062 = 3531604066
    //   MOVZ X16, #4 (SYS_write)      0xD2800090 = 3531604112
    //   SVC  #0x80                    0xD4001001 = 3556773889
    //   MOVZ X0, #0                   0xD2800000 = 3531603968
    //   MOVZ X16, #1 (SYS_exit)       0xD2800030 = 3531604016
    //   SVC  #0x80                    0xD4001001 = 3556773889
    let code_u32 = [
        2847898621, 2432697341, 3506455551,
        1384121992,  956302312,
        1384121928,  956303336,
        1384120648,  956304360,
        3531604000, 2432697313, 3531604066, 3531604112, 3556773889,
        3531603968, 3531604016, 3556773889
    ]

    let mut s = ""

    // ─── mach_header_64 (32 bytes) ───
    let hdr_u32 = [
        MH_MAGIC_64, CPU_ARM64, 0, MH_EXECUTE,
        NCMDS, SIZEOFCMDS, HDR_FLAGS, 0
    ]
    let mut hi = 0
    while hi < len(hdr_u32) {
        let v = hdr_u32[hi]
        s = s + HEX[(v % 256) / 16] + HEX[(v % 256) % 16]
        s = s + HEX[((v / 256) % 256) / 16] + HEX[((v / 256) % 256) % 16]
        s = s + HEX[((v / 65536) % 256) / 16] + HEX[((v / 65536) % 256) % 16]
        s = s + HEX[((v / 16777216) % 256) / 16] + HEX[((v / 16777216) % 256) % 16]
        hi = hi + 1
    }
    // +32 -> 32 bytes written

    // ─── LC_SEGMENT_64 __PAGEZERO (72 bytes) ───
    // cmd=0x19 cmdsize=72, segname __PAGEZERO(16),
    // vmaddr=0, vmsize=0x100000000, fileoff=0, filesize=0,
    // maxprot=0, initprot=0, nsects=0, flags=0
    s = s + "19000000" + "48000000"
    s = s + "5f5f504147455a45524f0000000000" + "00"
    s = s + "0000000000000000"    // vmaddr
    s = s + "0000000001000000"    // vmsize = 4GB
    s = s + "0000000000000000"    // fileoff
    s = s + "0000000000000000"    // filesize
    s = s + "00000000" + "00000000" + "00000000" + "00000000"
    // +72 -> 104

    // ─── LC_SEGMENT_64 __TEXT (152 bytes = 72 + 80) ───
    s = s + "19000000" + "98000000"
    s = s + "5f5f54455854000000000000000000" + "00"
    s = s + "0000000001000000"    // vmaddr = 0x100000000
    s = s + "0040000000000000"    // vmsize = PAGE
    s = s + "0000000000000000"    // fileoff = 0
    s = s + "0040000000000000"    // filesize = PAGE
    s = s + "05000000"            // maxprot = r-x
    s = s + "05000000"            // initprot = r-x
    s = s + "01000000"            // nsects = 1
    s = s + "00000000"            // flags = 0
    // +72 -> 176

    //   section __text (80 bytes):
    //   sectname "__text"(16), segname "__TEXT"(16),
    //   addr(8), size(8), offset(4), align(4), reloff(4), nreloc(4),
    //   flags(4), reserved1(4), reserved2(4), reserved3(4)
    s = s + "5f5f74657874000000000000000000" + "00"
    s = s + "5f5f54455854000000000000000000" + "00"
    s = s + "0003000001000000"    // addr = 0x100000300
    s = s + "4400000000000000"    // size = 0x44 (68)
    s = s + "00030000"            // offset = 0x300
    s = s + "02000000"            // align = 2^2
    s = s + "00000000" + "00000000"
    s = s + "00040080"            // flags = 0x80000400
    s = s + "00000000" + "00000000" + "00000000"
    // +80 -> 256

    // ─── LC_SEGMENT_64 __LINKEDIT (72 bytes) ───
    s = s + "19000000" + "48000000"
    s = s + "5f5f4c494e4b45444954000000000000"
    s = s + "0040000001000000"    // vmaddr = 0x100004000
    s = s + "0040000000000000"    // vmsize = PAGE
    s = s + "0040000000000000"    // fileoff = PAGE
    s = s + "3100000000000000"    // filesize = 49
    s = s + "01000000" + "01000000"
    s = s + "00000000" + "00000000"
    // +72 -> 328

    // ─── LC_DYLD_CHAINED_FIXUPS (16 bytes) ───
    // cmd=0x80000034, cmdsize=16, dataoff=0x4000, datasize=48
    s = s + "34000080" + "10000000" + "00400000" + "30000000"
    // +16 -> 344

    // ─── LC_SYMTAB (24 bytes) ───
    // cmd=2, cmdsize=24, symoff, nsyms=0, stroff, strsize=1
    s = s + "02000000" + "18000000"
    s = s + "30400000"            // symoff = 0x4030 (inside __LINKEDIT)
    s = s + "00000000"            // nsyms = 0
    s = s + "30400000"            // stroff = 0x4030 (reuses slot)
    s = s + "01000000"            // strsize = 1
    // +24 -> 368

    // ─── LC_DYSYMTAB (80 bytes) ───
    // cmd=0x0B, cmdsize=80, then 72 bytes of zero fields
    s = s + "0b000000" + "50000000"
    let mut dyz = 0
    while dyz < 72 {
        s = s + "00"
        dyz = dyz + 1
    }
    // +80 -> 448

    // ─── LC_LOAD_DYLINKER (32 bytes) ───
    // cmd=0x0E, cmdsize=32, name_offset=12, "/usr/lib/dyld" + pad to 20
    s = s + "0e000000" + "20000000" + "0c000000"
    s = s + "2f7573722f6c69622f64796c6400"   // "/usr/lib/dyld\0" (14 bytes)
    s = s + "000000000000"                   // pad 6 bytes -> 20
    // +32 -> 480

    // ─── LC_UUID (24 bytes) ───
    // cmd=0x1B, cmdsize=24, uuid(16 bytes). Any value is acceptable.
    s = s + "1b000000" + "18000000"
    s = s + "48455841414243444546303132333435"   // "HEXAABCDEF012345"
    // +24 -> 504

    // ─── LC_BUILD_VERSION (24 bytes) ───
    // cmd=0x32, cmdsize=24, platform=1 (macOS), minos, sdk, ntools=0
    s = s + "32000000" + "18000000"
    s = s + "01000000"           // platform = MACOS
    s = s + "00000e00"           // minos = 14.0 (14 << 16)
    s = s + "00000e00"           // sdk = 14.0
    s = s + "00000000"           // ntools = 0
    // +24 -> 528

    // ─── LC_MAIN (24 bytes) ───
    // cmd=0x80000028, cmdsize=24, entryoff(u64)=0x300, stacksize(u64)=0
    s = s + "28000080" + "18000000"
    s = s + "0003000000000000"   // entryoff = CODE_OFF
    s = s + "0000000000000000"   // stacksize
    // +24 -> 552

    // ─── LC_LOAD_DYLIB libSystem (56 bytes) ───
    // cmd=0x0C, cmdsize=56, name_offset=24, timestamp=2, curver=0x10000, compat=0x10000,
    // then "/usr/lib/libSystem.B.dylib\0" padded to 32 bytes
    s = s + "0c000000" + "38000000"
    s = s + "18000000"           // name_offset = 24
    s = s + "02000000"           // timestamp
    s = s + "00000100"           // current_version 1.0.0
    s = s + "00000100"           // compatibility_version 1.0.0
    // "/usr/lib/libSystem.B.dylib" = 26 chars + NUL = 27 bytes; pad to 32.
    // 2f 75 73 72 2f 6c 69 62 2f 6c 69 62 53 79 73 74  -> 16
    // 65 6d 2e 42 2e 64 79 6c 69 62 00 00 00 00 00 00  -> 32
    s = s + "2f7573722f6c69622f6c69625379737465"
    s = s + "6d2e422e64796c696200000000000000"
    // +56 -> 608

    // ─── Pad from current position to CODE_OFF (768) ───
    // Each hex pair = 1 byte.
    while (len(s) / 2) < CODE_OFF {
        s = s + "00"
    }

    // ─── __text code section (68 bytes of ARM64 instructions) ───
    let mut ci = 0
    while ci < len(code_u32) {
        let v = code_u32[ci]
        s = s + HEX[(v % 256) / 16] + HEX[(v % 256) % 16]
        s = s + HEX[((v / 256) % 256) / 16] + HEX[((v / 256) % 256) % 16]
        s = s + HEX[((v / 65536) % 256) / 16] + HEX[((v / 65536) % 256) % 16]
        s = s + HEX[((v / 16777216) % 256) / 16] + HEX[((v / 16777216) % 256) % 16]
        ci = ci + 1
    }

    // ─── Pad __TEXT to PAGE boundary ───
    while (len(s) / 2) < PAGE {
        s = s + "00"
    }

    // ─── __LINKEDIT (49 bytes) ───
    // dyld_chained_fixups_header (28 bytes, padded to 32)
    s = s + "00000000"           // fixups_version
    s = s + "20000000"           // starts_offset = 32
    s = s + "00000000"           // imports_offset
    s = s + "00000000"           // symbols_offset
    s = s + "00000000"           // imports_count
    s = s + "01000000"           // imports_format = DYLD_CHAINED_IMPORT
    s = s + "00000000"           // symbols_format
    s = s + "00000000"           // pad 28 -> 32
    // dyld_chained_starts_in_image (16 bytes)
    s = s + "03000000"           // seg_count = 3
    s = s + "00000000" + "00000000" + "00000000"
    // empty strtab (1 byte)
    s = s + "00"

    return s
}

// ═══════════════════════════════════════════════════════════
//  Top-level driver
// ═══════════════════════════════════════════════════════════

println("=== HEXA zero-tool ARM64 Mach-O binary emitter ===")
println("")

println("[1/5] Generating Mach-O binary (hex stream)...")
let hex = build_binary_hex()
let hex_len = len(hex)
println("  hex length: " + to_string(hex_len) + " chars (" + to_string(hex_len / 2) + " bytes)")

let output_path = "/tmp/hexa_native_42"
println("[2/5] Writing " + output_path + " via printf | xxd -r -p...")
// Hex chars are shell-safe inside single quotes.
exec("printf '%s' '" + hex + "' | xxd -r -p > " + output_path)
exec("chmod +x " + output_path)
let ls = exec("ls -la " + output_path + " 2>&1")
println("  " + ls)

println("[3/5] Verifying Mach-O header...")
let otool_out = exec("otool -hV " + output_path + " 2>&1 | tail -2")
println(otool_out)

println("[4/5] Codesigning (ad-hoc)...")
let sign_result = exec("codesign -s - -f " + output_path + " 2>&1")
if len(sign_result) > 0 {
    println("  codesign: " + sign_result)
} else {
    println("  codesign: OK")
}

println("[5/5] Running " + output_path + "...")
let output = exec(output_path + " 2>&1")
println("  output: '" + output + "'")

// exec() may strip the trailing newline.
let mut pass = false
if output == "42" { pass = true }
if output == "42\n" { pass = true }

println("")
if pass {
    println("PASS -- zero-tool native binary emitted and verified")
    println("  No clang. No as. No ld. Pure HEXA -> ARM64 Mach-O.")
} else {
    println("FAIL -- expected '42', got '" + output + "'")
}
