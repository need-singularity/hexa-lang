// ── INLINED from runtime/kmp_pure.hexa ──

@pure
pub fn kmp_build_table(pattern) {
    let m = len(pattern)
    if m == 0 { return [] }

    let mut table = [0]
    let mut k = 0
    let mut i = 1

    while i < m {
        let pi = pattern.substring(i, i + 1)
        let pk = pattern.substring(k, k + 1)

        if pi == pk {
            k = k + 1
            table.push(k)
            i = i + 1
        } else {
            if k != 0 {
                k = table[(k - 1)]
            } else {
                table.push(0)
                i = i + 1
            }
        }
    }

    return table
}

@pure
pub fn kmp_search(text, pattern) {
    let n = len(text)
    let m = len(pattern)
    if m == 0 { return [] }
    if n < m { return [] }

    let table = kmp_build_table(pattern)
    let mut results = []
    let mut i = 0
    let mut j = 0

    while i < n {
        let ti = text.substring(i, i + 1)
        let pj = pattern.substring(j, j + 1)

        if ti == pj {
            i = i + 1
            j = j + 1
            if j == m {
                results.push(i - m)
                j = 0
            }
        } else {
            if j != 0 {
                j = table[(j - 1)]
            } else {
                i = i + 1
            }
        }
    }

    return results
}

@pure
pub fn kmp_search_overlapping(text, pattern) {
    let n = len(text)
    let m = len(pattern)
    if m == 0 { return [] }
    if n < m { return [] }

    let table = kmp_build_table(pattern)
    let mut results = []
    let mut i = 0
    let mut j = 0

    while i < n {
        let ti = text.substring(i, i + 1)
        let pj = pattern.substring(j, j + 1)

        if ti == pj {
            i = i + 1
            j = j + 1
            if j == m {
                results.push(i - m)
                j = table[(j - 1)]
            }
        } else {
            if j != 0 {
                j = table[(j - 1)]
            } else {
                i = i + 1
            }
        }
    }

    return results
}

@pure
pub fn kmp_contains(text, pattern) {
    let m = len(pattern)
    if m == 0 { return false }

    let n = len(text)
    if n < m { return false }

    let table = kmp_build_table(pattern)
    let mut i = 0
    let mut j = 0

    while i < n {
        let ti = text.substring(i, i + 1)
        let pj = pattern.substring(j, j + 1)

        if ti == pj {
            i = i + 1
            j = j + 1
            if j == m {
                return true
            }
        } else {
            if j != 0 {
                j = table[(j - 1)]
            } else {
                i = i + 1
            }
        }
    }

    return false
}

@pure
pub fn kmp_count(text, pattern) {
    let hits = kmp_search(text, pattern)
    return len(hits)
}

// ── END INLINED ──

let mut pass = 0
let mut fail = 0

fn eq(name, actual, expected) {
    if actual == expected {
        pass = pass + 1
        println("[PASS] " + name)
    } else {
        fail = fail + 1
        println("[FAIL] " + name + " expected=" + to_string(expected) + " got=" + to_string(actual))
    }
}

fn check(name, cond) {
    if cond {
        pass = pass + 1
        println("[PASS] " + name)
    } else {
        fail = fail + 1
        println("[FAIL] " + name)
    }
}

fn eq_arr(name, actual, expected) {
    if len(actual) != len(expected) {
        fail = fail + 1
        println("[FAIL] " + name + " len expected=" + to_string(len(expected)) + " got=" + to_string(len(actual)))
        return 0
    }
    let mut i = 0
    while i < len(expected) {
        if actual[i] != expected[i] {
            fail = fail + 1
            println("[FAIL] " + name + " at index " + to_string(i) + " expected=" + to_string(expected[i]) + " got=" + to_string(actual[i]))
            return 0
        }
        i = i + 1
    }
    pass = pass + 1
    println("[PASS] " + name)
    return 1
}

