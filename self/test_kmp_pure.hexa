// ═══════════════════════════════════════════════════════════════════
//  test_kmp_pure.hexa — coverage for self/runtime/kmp_pure.hexa
// ═══════════════════════════════════════════════════════════════════

import "runtime/kmp_pure.hexa"

let mut pass = 0
let mut fail = 0

fn eq(name, actual, expected) {
    if actual == expected {
        pass = pass + 1
        println("[PASS] " + name)
    } else {
        fail = fail + 1
        println("[FAIL] " + name + " expected=" + to_string(expected) + " got=" + to_string(actual))
    }
}

fn check(name, cond) {
    if cond {
        pass = pass + 1
        println("[PASS] " + name)
    } else {
        fail = fail + 1
        println("[FAIL] " + name)
    }
}

fn eq_arr(name, actual, expected) {
    if len(actual) != len(expected) {
        fail = fail + 1
        println("[FAIL] " + name + " len expected=" + to_string(len(expected)) + " got=" + to_string(len(actual)))
        return 0
    }
    let mut i = 0
    while i < len(expected) {
        if actual[i] != expected[i] {
            fail = fail + 1
            println("[FAIL] " + name + " at index " + to_string(i) + " expected=" + to_string(expected[i]) + " got=" + to_string(actual[i]))
            return 0
        }
        i = i + 1
    }
    pass = pass + 1
    println("[PASS] " + name)
    return 1
}

println("═══════════════════════════════════════════════════════")
println("  kmp_pure.hexa — test runner")
println("═══════════════════════════════════════════════════════")

// ── failure table ───────────────────────────────────────────
println("")
println("--- kmp_build_table ---")
eq_arr("table ABCABC", kmp_build_table("ABCABC"), [0, 0, 0, 1, 2, 3])
eq_arr("table AAAA", kmp_build_table("AAAA"), [0, 1, 2, 3])
eq_arr("table ABCDE", kmp_build_table("ABCDE"), [0, 0, 0, 0, 0])
eq_arr("table empty", kmp_build_table(""), [])
eq_arr("table A", kmp_build_table("A"), [0])
eq_arr("table AABAA", kmp_build_table("AABAA"), [0, 1, 0, 1, 2])

// ── kmp_search (non-overlapping) ────────────────────────────
println("")
println("--- kmp_search ---")

// T1: simple match — "ABCABC" in "XABCABCABCX"
//   non-overlapping: match at 1, then j resets to 0, next scan from 7
//   chars 7..10 = "ABCX" — only 4 left, pattern needs 6. One match.
eq_arr("search ABCABC in XABCABCABCX", kmp_search("XABCABCABCX", "ABCABC"), [1])

// T2: no match
eq_arr("search no match", kmp_search("HELLO WORLD", "XYZ"), [])

// T3: pattern = text (exact match)
eq_arr("search exact match", kmp_search("ABCABC", "ABCABC"), [0])

// T4: empty pattern -> 0 matches
eq_arr("search empty pattern", kmp_search("anything", ""), [])

// T5: single char pattern
eq_arr("search single char", kmp_search("abcabc", "a"), [0, 3])

// T6: multiple non-overlapping matches
eq_arr("search multiple", kmp_search("ABCXABCXABC", "ABC"), [0, 4, 8])

// T7: pattern longer than text
eq_arr("search pattern longer", kmp_search("AB", "ABCD"), [])

// T8: repeated single char non-overlapping
eq_arr("search aa non-overlap", kmp_search("AAAA", "AA"), [0, 2])

// ── kmp_search_overlapping ──────────────────────────────────
println("")
println("--- kmp_search_overlapping ---")

// T9: overlapping "AA" in "AAAA" -> [0, 1, 2]
eq_arr("overlapping AA in AAAA", kmp_search_overlapping("AAAA", "AA"), [0, 1, 2])

// T10: overlapping "ABA" in "ABABA" -> [0, 2]
eq_arr("overlapping ABA in ABABA", kmp_search_overlapping("ABABA", "ABA"), [0, 2])

// T11: overlapping "ABCABC" in "XABCABCABCX" -> [1, 4]
eq_arr("overlapping ABCABC in XABCABCABCX", kmp_search_overlapping("XABCABCABCX", "ABCABC"), [1, 4])

// ── kmp_contains ────────────────────────────────────────────
println("")
println("--- kmp_contains ---")
eq("contains found", kmp_contains("hello world", "world"), true)
eq("contains not found", kmp_contains("hello world", "xyz"), false)
eq("contains empty pattern", kmp_contains("hello", ""), false)
eq("contains exact", kmp_contains("abc", "abc"), true)

// ── kmp_count ───────────────────────────────────────────────
println("")
println("--- kmp_count ---")
eq("count ABC in ABCXABCXABC", kmp_count("ABCXABCXABC", "ABC"), 3)
eq("count no match", kmp_count("hello", "xyz"), 0)
eq("count empty", kmp_count("hello", ""), 0)
eq("count single", kmp_count("aaa", "a"), 3)

// ── summary ─────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass) + " passed, " + to_string(fail) + " failed")
println("═══════════════════════════════════════════════════════")

if fail > 0 {
    println("FAIL")
    exit(1)
}
println("ALL PASS")
