// ===================================================================
//  test_kmp_pure.hexa -- coverage for self/runtime/kmp_pure.hexa
//
//  Pitfalls honored: P1 no semicolons, P15 let mut, P29 push rebind,
//  P39 no 0b literals, while loops only
// ===================================================================

import "runtime/kmp_pure.hexa"

let mut pass = 0
let mut fail = 0

fn check(name, cond) {
    if cond {
        pass = pass + 1
    } else {
        fail = fail + 1
        println("[FAIL] " + name)
    }
}

fn eq(name, actual, expected) {
    if actual == expected {
        pass = pass + 1
    } else {
        fail = fail + 1
        println("[FAIL] " + name + " expected=" + to_string(expected) + " got=" + to_string(actual))
    }
}

fn eq_arr(name, actual, expected) {
    let n = len(actual)
    if n != len(expected) {
        fail = fail + 1
        println("[FAIL] " + name + " len expected=" + to_string(len(expected)) + " got=" + to_string(n))
        return void
    }
    let mut i = 0
    let mut ok = true
    while i < n {
        if actual[i] != expected[i] { ok = false }
        i = i + 1
    }
    if ok {
        pass = pass + 1
    } else {
        fail = fail + 1
        println("[FAIL] " + name + " content mismatch")
    }
}

println("=== kmp_pure test suite ===")

// ================================================================
//  kmp_failure_table_pure
// ================================================================
eq_arr("fail empty", kmp_failure_table_pure(""), [])
eq_arr("fail single", kmp_failure_table_pure("a"), [0])
eq_arr("fail abc", kmp_failure_table_pure("abc"), [0, 0, 0])
eq_arr("fail aab", kmp_failure_table_pure("aab"), [0, 1, 0])
eq_arr("fail abab", kmp_failure_table_pure("abab"), [0, 0, 1, 2])
eq_arr("fail aaaa", kmp_failure_table_pure("aaaa"), [0, 1, 2, 3])
eq_arr("fail abcabd", kmp_failure_table_pure("abcabd"), [0, 0, 0, 1, 2, 0])
eq_arr("fail aabaaab", kmp_failure_table_pure("aabaaab"), [0, 1, 0, 1, 2, 2, 3])

// ================================================================
//  kmp_search_pure — single match
// ================================================================
eq("search empty pattern", kmp_search_pure("hello", ""), 0)
eq("search empty text", kmp_search_pure("", "abc"), -1)
eq("search both empty", kmp_search_pure("", ""), 0)
eq("search no match", kmp_search_pure("abcdef", "xyz"), -1)
eq("search at start", kmp_search_pure("abcdef", "abc"), 0)
eq("search at end", kmp_search_pure("abcdef", "def"), 3)
eq("search in middle", kmp_search_pure("abcdef", "cde"), 2)
eq("search single char found", kmp_search_pure("abcdef", "d"), 3)
eq("search single char not found", kmp_search_pure("abcdef", "z"), -1)
eq("search full match", kmp_search_pure("abc", "abc"), 0)
eq("search pattern longer", kmp_search_pure("ab", "abcdef"), -1)
eq("search first of multiple", kmp_search_pure("abcabcabc", "abc"), 0)
eq("search overlapping first", kmp_search_pure("aaaa", "aa"), 0)
eq("search repeated pattern", kmp_search_pure("xababx", "abab"), 1)

// ================================================================
//  kmp_search_all_pure — all matches
// ================================================================
eq_arr("all empty pattern", kmp_search_all_pure("hello", ""), [])
eq_arr("all no match", kmp_search_all_pure("abcdef", "xyz"), [])
eq_arr("all single match", kmp_search_all_pure("abcdef", "cde"), [2])
eq_arr("all multiple", kmp_search_all_pure("abcabcabc", "abc"), [0, 3, 6])
eq_arr("all overlapping aa in aaaa", kmp_search_all_pure("aaaa", "aa"), [0, 1, 2])
eq_arr("all overlapping aba in ababa", kmp_search_all_pure("ababa", "aba"), [0, 2])
eq_arr("all single char", kmp_search_all_pure("abacaba", "a"), [0, 2, 4, 6])
eq_arr("all full match", kmp_search_all_pure("abc", "abc"), [0])
eq_arr("all pattern longer", kmp_search_all_pure("ab", "abcdef"), [])
eq_arr("all adjacent", kmp_search_all_pure("xyxyxy", "xy"), [0, 2, 4])

// ================================================================
//  edge cases
// ================================================================
eq("search single char text", kmp_search_pure("a", "a"), 0)
eq("search single char no match", kmp_search_pure("a", "b"), -1)
eq_arr("all single char text match", kmp_search_all_pure("a", "a"), [0])
eq_arr("all single char text no match", kmp_search_all_pure("a", "b"), [])
eq("search long pattern in short text", kmp_search_pure("hi", "hello world"), -1)

println("===========================================================")
println("  Results: " + to_string(pass) + " passed, " + to_string(fail) + " failed")
println("===========================================================")
if fail == 0 { println("ALL PASS") } else { println("SOME FAILED") }
