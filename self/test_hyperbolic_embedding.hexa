// ===================================================================
//  test_hyperbolic_embedding.hexa — Hyperbolic Embedding (#244)
//
//  Poincaré ball model sanity.  Tests:
//    #1  hb_norm_sq basic
//    #2  hb_norm [3,4] = 5
//    #3  hb_vec_add/sub symmetric
//    #4  hb_project clips outside ball
//    #5  hb_project leaves inside unchanged
//    #6  hb_distance(x, x) = 0
//    #7  hb_distance symmetric
//    #8  hb_distance grows near boundary
//    #9  hb_mobius_add(0, v) = v
//    #10 hb_mobius_add(v, 0) = v
//    #11 hb_exp_map_zero inside ball
//    #12 hb_log_map_zero inverse of exp_map_zero
//    #13 hb_exp_map/log_map general inverse
//    #14 hb_mobius_scalar_mul r=1 identity
//    #15 hb_hierarchical_loss margin enforcement
//    #16 hb_tree_embed binary tree shape
//    #17 hb_tree_embed all coords inside ball
//    #18 hb_tree_embed root at origin
//    #19 hb_parallel_transport_zero scales
//    #20 hb_neg sign flip
// ===================================================================

import "ml/hyperbolic_embedding.hexa"

let mut pass_count = 0
let mut fail_count = 0

fn check(idx, name, cond) {
    if cond {
        println("[PASS] #" + str(idx) + " " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] #" + str(idx) + " " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx(a, b, eps) { return fabs(a - b) < eps }

println("=== Hyperbolic Embedding (#244) Tests ===")

// ---- (1-3) primitives ----

check(1, "hb_norm_sq([1,2,2])=9", approx(hb_norm_sq([1.0, 2.0, 2.0]), 9.0, 1.0e-9))
check(2, "hb_norm([3,4])=5", approx(hb_norm([3.0, 4.0]), 5.0, 1.0e-6))

let sub = hb_vec_sub([3.0, 4.0], [1.0, 1.0])
let add = hb_vec_add([1.0, 1.0], sub)
check(3, "hb_vec_add/sub round-trip", approx(add[0], 3.0, 1.0e-9) && approx(add[1], 4.0, 1.0e-9))

// ---- (4-5) project ----

let outside = [2.0, 2.0, 2.0]
let clipped = hb_project(outside, 0.01)
check(4, "hb_project clips outside", hb_norm(clipped) <= 0.99 + 1.0e-9 && hb_norm(clipped) > 0.0)

let inside = [0.1, 0.2, 0.1]
let kept = hb_project(inside, 0.01)
check(5, "hb_project keeps inside", approx(kept[0], 0.1, 1.0e-9) && approx(kept[1], 0.2, 1.0e-9))

// ---- (6-8) Poincaré distance ----

let x = [0.2, 0.3]
let y = [0.5, 0.1]
check(6, "hb_distance(x,x)=0", hb_distance(x, x) < 1.0e-6)
check(7, "hb_distance symmetric", approx(hb_distance(x, y), hb_distance(y, x), 1.0e-6))

// distances grow as points approach boundary
let near_b1 = [0.1, 0.0]
let near_b2 = [0.9, 0.0]
let mid1 = [0.1, 0.0]
let mid2 = [0.5, 0.0]
check(8, "hb_distance boundary > mid", hb_distance(near_b1, near_b2) > hb_distance(mid1, mid2))

// ---- (9-10) Möbius addition identity ----

let zero2 = [0.0, 0.0]
let v_any = [0.3, -0.2]
let zv = hb_mobius_add(zero2, v_any)
check(9, "mobius_add(0,v)=v", approx(zv[0], 0.3, 1.0e-6) && approx(zv[1], -0.2, 1.0e-6))

let vz = hb_mobius_add(v_any, zero2)
check(10, "mobius_add(v,0)=v", approx(vz[0], 0.3, 1.0e-6) && approx(vz[1], -0.2, 1.0e-6))

// ---- (11-12) exp/log map at origin ----

let tv = [0.2, 0.1, -0.05]
let exped = hb_exp_map_zero(tv)
check(11, "exp_map_zero stays in ball", hb_norm(exped) < 1.0)

let back = hb_log_map_zero(exped)
let mut ok_back = true
let mut i = 0

while i < 3 {
    if !approx(back[i], tv[i], 1.0e-4) { ok_back = false }
}
check(12, "log_map_zero inverse of exp_map_zero", ok_back)

// ---- (13) general exp_map / log_map inverse at non-zero base ----

let base_x = [0.1, -0.2]
let tan_v = [0.15, 0.05]
let ex = hb_exp_map(base_x, tan_v)
let lv = hb_log_map(base_x, ex)
check(13, "log_map(x, exp_map(x, v)) ≈ v",
    approx(lv[0], tan_v[0], 1.0e-3) && approx(lv[1], tan_v[1], 1.0e-3))

// ---- (14) Möbius scalar mul identity ----

let v14 = [0.2, 0.3]
let sm1 = hb_mobius_scalar_mul(1.0, v14)
check(14, "mobius_scalar_mul r=1 identity",
    approx(sm1[0], 0.2, 1.0e-4) && approx(sm1[1], 0.3, 1.0e-4))

// ---- (15) hierarchical loss margin ----

let u15 = [0.1, 0.0]
let v_pos = [0.12, 0.0]
let v_neg = [0.8, 0.0]
let loss_ok = hb_hierarchical_loss(u15, v_pos, v_neg, 0.1)
check(15, "hierarchical loss small when pos close", loss_ok < 1.0)

let loss_bad = hb_hierarchical_loss(u15, v_neg, v_pos, 0.1)
check(15, "hierarchical loss big when pos far", loss_bad > loss_ok)

// ---- (16-18) tree embedding ----

let tree = hb_tree_embed(3, 2)
check(16, "tree_embed depth=3 -> 15 nodes", tree["n_nodes"] == 15)

let coords = tree["coords"]
let mut all_inside = true
let mut i = 0

while i < 15 {
    if hb_norm(coords[i]) >= 1.0 { all_inside = false }
}
check(17, "tree coords all inside ball", all_inside)

check(18, "tree root at origin",
    approx(coords[0][0], 0.0, 1.0e-9) && approx(coords[0][1], 0.0, 1.0e-9))

// ---- (19) parallel transport ----

let pt_x = [0.3, 0.4]   // ||x||^2 = 0.25
let pt_v = [1.0, 0.0]
let pt = hb_parallel_transport_zero(pt_x, pt_v)
check(19, "parallel_transport scales by (1-||x||^2)",
    approx(pt[0], 0.75, 1.0e-6) && approx(pt[1], 0.0, 1.0e-6))

// ---- (20) neg ----

let nv = hb_neg([1.0, -2.0, 3.0])
check(20, "hb_neg flips sign",
    approx(nv[0], -1.0, 1.0e-9)
    && approx(nv[1], 2.0, 1.0e-9)
    && approx(nv[2], -3.0, 1.0e-9))

// ── summary ─────────────────────────────────────────────────────
println("")
println("=== hyperbolic_embedding test summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
