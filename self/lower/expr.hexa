// self/lower/expr.hexa — ported from src/lower/expr.rs
// Expression lowering — AST Expr -> HEXA-IR instructions.

// Lower an expression, returning the ValueId of the result.
// In the self-hosted port, expressions are represented as tagged arrays:
//   [tag, ...fields]
// Tags: 0=IntLit, 1=FloatLit, 2=BoolLit, 3=StringLit, 4=Ident,
//       5=Binary, 6=Unary, 7=Call, 8=If, 9=Block,
//       10=Array, 11=Index, 12=StructInit, 13=Field,
//       14=Match, 15=Range, 16=Lambda, 17=Tuple

fn EXPR_INT_LIT() -> int { return 0 }
fn EXPR_FLOAT_LIT() -> int { return 1 }
fn EXPR_BOOL_LIT() -> int { return 2 }
fn EXPR_STRING_LIT() -> int { return 3 }
fn EXPR_IDENT() -> int { return 4 }
fn EXPR_BINARY() -> int { return 5 }
fn EXPR_UNARY() -> int { return 6 }
fn EXPR_CALL() -> int { return 7 }
fn EXPR_IF() -> int { return 8 }
fn EXPR_BLOCK() -> int { return 9 }
fn EXPR_ARRAY() -> int { return 10 }
fn EXPR_INDEX() -> int { return 11 }
fn EXPR_STRUCT_INIT() -> int { return 12 }
fn EXPR_FIELD() -> int { return 13 }
fn EXPR_MATCH() -> int { return 14 }
fn EXPR_RANGE() -> int { return 15 }
fn EXPR_LAMBDA() -> int { return 16 }
fn EXPR_TUPLE() -> int { return 17 }
fn EXPR_WILDCARD() -> int { return 18 }

// Binary operator tags
fn BINOP_ADD() -> int { return 0 }
fn BINOP_SUB() -> int { return 1 }
fn BINOP_MUL() -> int { return 2 }
fn BINOP_DIV() -> int { return 3 }
fn BINOP_REM() -> int { return 4 }
fn BINOP_EQ() -> int { return 5 }
fn BINOP_NE() -> int { return 6 }
fn BINOP_LT() -> int { return 7 }
fn BINOP_GT() -> int { return 8 }
fn BINOP_LE() -> int { return 9 }
fn BINOP_GE() -> int { return 10 }
fn BINOP_AND() -> int { return 11 }
fn BINOP_OR() -> int { return 12 }

// Unary operator tags
fn UNOP_NEG() -> int { return 0 }
fn UNOP_NOT() -> int { return 1 }
fn UNOP_BITNOT() -> int { return 2 }

// Check if an expression contains a function call (for register spill).
fn expr_contains_call(expr_tag: int) -> bool {
    return expr_tag == EXPR_CALL()
}

// Resolve field index by name in struct layout.
fn resolve_field_idx(struct_fields: [string], field_name: string) -> int {
    let mut i = 0
    while i < len(struct_fields) {
        if struct_fields[i] == field_name {
            return i
        }
        i = i + 1
    }
    return 0
}
