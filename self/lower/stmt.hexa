// self/lower/stmt.hexa — ported from src/lower/stmt.rs
// Statement lowering — AST Stmt -> HEXA-IR instructions.

// Statement tags (matching AST node types)
fn STMT_LET() -> int { return 0 }
fn STMT_CONST() -> int { return 1 }
fn STMT_ASSIGN() -> int { return 2 }
fn STMT_EXPR() -> int { return 3 }
fn STMT_RETURN() -> int { return 4 }
fn STMT_WHILE() -> int { return 5 }
fn STMT_FOR() -> int { return 6 }
fn STMT_LOOP() -> int { return 7 }
fn STMT_FN_DECL() -> int { return 8 }
fn STMT_STRUCT_DECL() -> int { return 9 }
fn STMT_ENUM_DECL() -> int { return 10 }
fn STMT_IF() -> int { return 11 }
fn STMT_MATCH() -> int { return 12 }
fn STMT_BREAK() -> int { return 13 }
fn STMT_CONTINUE() -> int { return 14 }
fn STMT_ASSERT() -> int { return 15 }
fn STMT_USE() -> int { return 16 }
fn STMT_MOD() -> int { return 17 }
fn STMT_TRY_CATCH() -> int { return 18 }
fn STMT_DROP() -> int { return 19 }
fn STMT_SPAWN() -> int { return 20 }
fn STMT_PROOF() -> int { return 21 }
fn STMT_PANIC() -> int { return 22 }
fn STMT_THROW() -> int { return 23 }
fn STMT_IMPL() -> int { return 24 }
fn STMT_TRAIT() -> int { return 25 }
fn STMT_STATIC() -> int { return 26 }

// Register type/function declarations (first pass -- no codegen).
// In the self-hosted port, declarations are processed by walking
// the AST array and populating LowerCtx's func_map and struct_map.
fn register_decl_tag(tag: int) -> bool {
    return tag == STMT_FN_DECL() || tag == STMT_STRUCT_DECL() || tag == STMT_ENUM_DECL()
}

// Lower a let statement: allocate stack slot, store initial value.
// Returns the ValueId of the stored value.
fn lower_let_conceptual(name: string, init_val: int) -> int {
    // 1. alloc(ty) -> ptr
    // 2. store(ptr, init_val)
    // 3. define_var(name, ptr, Ptr(ty))
    return init_val
}

// Lower a while loop: cond block -> body block -> back-edge to cond.
fn lower_while_conceptual() -> int {
    // 1. create cond_bb, body_bb, exit_bb
    // 2. jump cond_bb
    // 3. switch_to(cond_bb): eval cond, branch(cond, body, exit)
    // 4. switch_to(body_bb): lower body stmts, jump(cond_bb)
    // 5. switch_to(exit_bb)
    return 0
}

// Lower a for loop: range decomposition + counter increment.
fn lower_for_conceptual() -> int {
    // 1. eval range -> (start, end)
    // 2. create cond_bb, body_bb, inc_bb, exit_bb
    // 3. define loop var = start
    // 4. cond: i < end -> branch(body, exit)
    // 5. body: lower stmts, jump inc_bb
    // 6. inc: i = i + 1, jump cond_bb
    // 7. switch_to exit_bb
    return 0
}
