// test_sci_notation.hexa — scientific notation parsing smoke tests
//
// Verifies that scientific notation float literals parse correctly
// and produce expected float values.
//
// Run: ./hexa self/test_sci_notation.hexa
// No semicolons (P1 pitfall). No mixed-type arrays (P53 pitfall).

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_true(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

println("=== Scientific Notation Parsing Smoke Tests ===")
println("")

// ── T1: Basic integer exponent ─────────────────────────────
// 1e10 should be a float with value 10000000000.0
let t1 = 1e10
check("T1 type_of(1e10) == float", type_of(t1), "float")
check_true("T1 1e10 == 1e10", t1 == 1e10)
check_true("T1 1e10 > 9e9", t1 > 9e9)

// ── T2: Negative exponent ──────────────────────────────────
// 1.5e-3 should be 0.0015
let t2 = 1.5e-3
check("T2 type_of(1.5e-3) == float", type_of(t2), "float")
check_true("T2 1.5e-3 > 0.0014", t2 > 0.0014)
check_true("T2 1.5e-3 < 0.0016", t2 < 0.0016)

// ── T3: Positive sign exponent ─────────────────────────────
// 2e+5 should be 200000.0
let t3 = 2e+5
check("T3 type_of(2e+5) == float", type_of(t3), "float")
check_true("T3 2e+5 > 199999.0", t3 > 199999.0)
check_true("T3 2e+5 < 200001.0", t3 < 200001.0)

// ── T4: Capital E ──────────────────────────────────────────
// 3E8 should be 300000000.0 (speed of light order)
let t4 = 3E8
check("T4 type_of(3E8) == float", type_of(t4), "float")
check_true("T4 3E8 > 2.9E8", t4 > 2.9E8)
check_true("T4 3E8 < 3.1E8", t4 < 3.1E8)

// ── T5: Large exponent ─────────────────────────────────────
// 9.99e30 should be a very large float, greater than 1e29
let t5 = 9.99e30
check("T5 type_of(9.99e30) == float", type_of(t5), "float")
check_true("T5 9.99e30 > 1e29", t5 > 1e29)
check_true("T5 9.99e30 > 9e30", t5 > 9e30)

// ── T6: Small constant (Boltzmann) ─────────────────────────
// 1.38e-23 should be a very small positive float
let t6 = 1.38e-23
check("T6 type_of(1.38e-23) == float", type_of(t6), "float")
check_true("T6 1.38e-23 > 0.0", t6 > 0.0)
check_true("T6 1.38e-23 < 1e-20", t6 < 1e-20)

// ── T7: Zero exponent ──────────────────────────────────────
// 1e0 should be 1.0
let t7 = 1e0
check("T7 type_of(1e0) == float", type_of(t7), "float")
check_true("T7 1e0 > 0.99", t7 > 0.99)
check_true("T7 1e0 < 1.01", t7 < 1.01)

// ── T8: Combined decimal + exponent (Avogadro) ─────────────
// 6.022e23 should be greater than 6e23
let t8 = 6.022e23
check("T8 type_of(6.022e23) == float", type_of(t8), "float")
check_true("T8 6.022e23 > 6e23", t8 > 6e23)
check_true("T8 6.022e23 < 7e23", t8 < 7e23)

println("")

// ── Summary ────────────────────────────────────────────────

println("===================================================")
let total = pass_count + fail_count
println("  Sci Notation: " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL / " + to_string(total) + " total")
if fail_count == 0 {
    println("  ALL SCIENTIFIC NOTATION TESTS PASSED!")
} else {
    println("  SOME TESTS FAILED")
}
println("===================================================")
