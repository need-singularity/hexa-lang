// Test: binary-safe file write with write_bytes / read_file_bytes
// Verifies null bytes survive the round-trip.

let path = "build/__test_binary_write.bin"

// Build a byte array with embedded null bytes: [72, 69, 88, 0, 65, 0, 255]
// That's "HEX\0A\0\xFF"
let bytes = [72, 69, 88, 0, 65, 0, 255]

write_bytes(path, bytes)

let back = read_file_bytes(path)

let mut pass = true
if len(back) != len(bytes) {
    println("FAIL: length mismatch — wrote " + to_string(len(bytes)) + " got " + to_string(len(back)))
    pass = false
} else {
    let mut i = 0
    for b in back {
        if b != bytes[i] {
            println("FAIL: byte[" + to_string(i) + "] expected " + to_string(bytes[i]) + " got " + to_string(b))
            pass = false
        }
        i = i + 1
    }
}

if pass {
    println("PASS: binary write/read round-trip — " + to_string(len(bytes)) + " bytes including nulls")
}

// Cleanup
exec("rm -f " + path)
