// ═══════════════════════════════════════════════════════════════════
//  test_continuous_batching_v2.hexa — Continuous Batching v2 Tests
//
//  #142 Preemption + Swap + SLA + Priority + Throughput
//
//  Tests (35):
//    T1  create returns valid state
//    T2  empty queue size is 0
//    T3  add request increases queue size
//    T4  peek returns highest-priority request
//    T5  priority ordering in queue
//    T6  admit moves request from queue to running
//    T7  prefill phase transitions to decode
//    T8  decode produces one token per step
//    T9  request completes after max_gen tokens
//    T10 completed request has phase done
//    T11 KV slots allocated on admit
//    T12 KV slots freed on completion
//    T13 max_batch limit respected
//    T14 KV slot limit prevents admission
//    T15 preempt removes from running
//    T16 preempt re-inserts into queue
//    T17 preempt frees KV slots
//    T18 preempt victim is lowest priority
//    T19 preempt count tracks correctly
//    T20 swap out moves to swapped list
//    T21 swap out frees KV slots
//    T22 swap in restores to running
//    T23 swap in re-allocates KV slots
//    T24 swap in fails if insufficient KV
//    T25 dynamic batching mid-generation
//    T26 SLA deadline boost activates
//    T27 run_until_done completes all
//    T28 throughput reports total tokens
//    T29 throughput avg latency positive
//    T30 throughput avg wait time
//    T31 stats reports correct counts
//    T32 find_request locates in running
//    T33 find_request locates in completed
//    T34 multiple requests run in parallel
//    T35 preemption pass auto-triggers on overcommit
//
//  Run: cargo run --release -- self/test_continuous_batching_v2.hexa
// ═══════════════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }

// ── inline continuous_batching_v2 functions ─────────────────────

fn cb2_phase_queued()    { return 0 }
fn cb2_phase_prefill()   { return 1 }
fn cb2_phase_decode()    { return 2 }
fn cb2_phase_preempted() { return 3 }
fn cb2_phase_swapped()   { return 4 }
fn cb2_phase_done()      { return 5 }

fn cb2_new_request(req_id, prompt_len, max_gen, priority, deadline) {
    return #{
        "req_id": req_id,
        "prompt_len": prompt_len,
        "max_gen": max_gen,
        "priority": priority,
        "deadline": deadline,
        "phase": cb2_phase_queued(),
        "tokens_generated": 0,
        "kv_slots_used": 0,
        "enqueue_time": 0,
        "start_time": 0,
        "finish_time": 0,
        "was_preempted": 0,
        "preempt_count": 0
    }
}

fn cb2_new_swap_entry(rid, kv_size, tokens_done) {
    return #{"rid": rid, "kv_size": kv_size, "tokens_done": tokens_done}
}

fn cb2_new_tracker() {
    return #{
        "total_tokens": 0,
        "total_requests_done": 0,
        "total_preemptions": 0,
        "total_swaps_out": 0,
        "total_swaps_in": 0,
        "total_latency": 0,
        "total_wait_time": 0,
        "max_latency": 0,
        "max_wait_time": 0
    }
}

fn cb2_create(max_batch, max_kv_slots) {
    return #{
        "max_batch": max_batch,
        "max_kv_slots": max_kv_slots,
        "queue": [],
        "running": [],
        "swapped": [],
        "completed": [],
        "kv_used": 0,
        "step": 0,
        "tracker": cb2_new_tracker()
    }
}

fn cb2_insert_sorted(queue, req) {
    let n = len(queue)
    if n == 0 { return [req] }
    let mut result = []
    let mut inserted = false
    let mut i = 0

    while i < n {
        if inserted == false {
            if req["priority"] > queue[i]["priority"] {
                result = result + [req]
                inserted = true
            }
        }
        result = result + [queue[i]]
    }
    if inserted == false {
        result = result + [req]
    }
    return result
}

fn cb2_add_request(s, req_id, prompt_len, max_gen, priority, deadline) {
    let mut req = cb2_new_request(req_id, prompt_len, max_gen, priority, deadline)
    req["enqueue_time"] = s["step"]
    let new_queue = cb2_insert_sorted(s["queue"], req)
    let mut s2 = s
    s2["queue"] = new_queue
    return s2
}

fn cb2_queue_size(s) {
    return len(s["queue"])
}

fn cb2_peek_queue(s) {
    if len(s["queue"]) == 0 { return #{} }
    return s["queue"][0]
}

fn cb2_running_count(s) {
    return len(s["running"])
}

fn cb2_completed_count(s) {
    return len(s["completed"])
}

fn cb2_swapped_count(s) {
    return len(s["swapped"])
}

fn cb2_kv_free(s) {
    return s["max_kv_slots"] - s["kv_used"]
}

fn cb2_kv_needed_for_req(req) {
    if req["phase"] == cb2_phase_queued() {
        return req["prompt_len"]
    }
    return 1
}

fn cb2_find_preempt_victim(running) {
    let n = len(running)
    if n == 0 { return -1 }
    let mut victim_idx = 0
    let mut victim_pri = running[0]["priority"]
    let mut victim_gen = running[0]["tokens_generated"]
    let mut i = 1

    while i < n {
        let r = running[i]
        if r["priority"] < victim_pri {
            victim_idx = i
            victim_pri = r["priority"]
            victim_gen = r["tokens_generated"]
        }
        if r["priority"] == victim_pri {
            if r["tokens_generated"] > victim_gen {
                victim_idx = i
                victim_gen = r["tokens_generated"]
            }
        }
    }
    return victim_idx
}

fn cb2_preempt_at(s, idx) {
    let running = s["running"]
    let n = len(running)
    if idx < 0 { return s }
    if idx >= n { return s }
    let victim = running[idx]
    let freed = victim["kv_slots_used"]
    let mut new_running = []
    let mut i = 0

    while i < n {
        if i != idx {
            new_running = new_running + [running[i]]
        }
    }
    let mut preempted_req = victim
    preempted_req["phase"] = cb2_phase_preempted()
    preempted_req["was_preempted"] = 1
    preempted_req["preempt_count"] = preempted_req["preempt_count"] + 1
    let mut s2 = s
    s2["running"] = new_running
    s2["kv_used"] = s["kv_used"] - freed
    s2["queue"] = cb2_insert_sorted(s2["queue"], preempted_req)
    let mut t = s2["tracker"]
    t["total_preemptions"] = t["total_preemptions"] + 1
    s2["tracker"] = t
    return s2
}

fn cb2_preempt(s, target_rid) {
    let running = s["running"]
    let n = len(running)
    let mut i = 0

    while i < n {
        if running[i]["req_id"] == target_rid {
            return cb2_preempt_at(s, i)
        }
    }
    return s
}

fn cb2_swap_out(s, rid) {
    let running = s["running"]
    let n = len(running)
    let mut found_idx = -1
    let mut i = 0

    while i < n {
        if running[i]["req_id"] == rid {
            found_idx = i
        }
    }
    if found_idx < 0 { return s }
    let victim = running[found_idx]
    let kv_size = victim["kv_slots_used"]
    let swap_entry = cb2_new_swap_entry(rid, kv_size, victim["tokens_generated"])
    let mut swapped_req = victim
    swapped_req["phase"] = cb2_phase_swapped()
    swapped_req["kv_slots_used"] = 0
    let mut new_running = []
    let mut i = 0

    while i < n {
        if i != found_idx {
            new_running = new_running + [running[i]]
        }
    }
    let mut s2 = s
    s2["running"] = new_running
    s2["swapped"] = s["swapped"] + [swapped_req]
    s2["kv_used"] = s["kv_used"] - kv_size
    let mut t = s2["tracker"]
    t["total_swaps_out"] = t["total_swaps_out"] + 1
    s2["tracker"] = t
    return s2
}

fn cb2_swap_in(s, rid) {
    let swapped = s["swapped"]
    let n = len(swapped)
    let mut found_idx = -1
    let mut i = 0

    while i < n {
        if swapped[i]["req_id"] == rid {
            found_idx = i
        }
    }
    if found_idx < 0 { return s }
    let mut restored = swapped[found_idx]
    let needed_kv = restored["prompt_len"] + restored["tokens_generated"]
    if cb2_kv_free(s) < needed_kv { return s }
    restored["phase"] = cb2_phase_decode()
    restored["kv_slots_used"] = needed_kv
    let mut new_swapped = []
    let mut i = 0

    while i < n {
        if i != found_idx {
            new_swapped = new_swapped + [swapped[i]]
        }
    }
    let mut s2 = s
    s2["running"] = s["running"] + [restored]
    s2["swapped"] = new_swapped
    s2["kv_used"] = s["kv_used"] + needed_kv
    let mut t = s2["tracker"]
    t["total_swaps_in"] = t["total_swaps_in"] + 1
    s2["tracker"] = t
    return s2
}

fn cb2_check_deadlines(s, cur_time) {
    let mut new_queue = []
    let q = s["queue"]
    let nq = len(q)
    let mut i = 0

    while i < nq {
        let mut r = q[i]
        if r["deadline"] > 0 {
            let remaining = r["deadline"] - cur_time
            if remaining >= 0 {
                let total_budget = r["deadline"] - r["enqueue_time"]
                if total_budget > 0 {
                    let fraction_left = to_float(remaining) / to_float(total_budget)
                    if fraction_left <= 0.2 {
                        r["priority"] = r["priority"] + 100
                    }
                }
            }
        }
        new_queue = new_queue + [r]
    }
    let mut new_running = []
    let running = s["running"]
    let nr = len(running)
    let mut i = 0

    while i < nr {
        let mut r = running[i]
        if r["deadline"] > 0 {
            let remaining = r["deadline"] - cur_time
            if remaining >= 0 {
                let total_budget = r["deadline"] - r["enqueue_time"]
                if total_budget > 0 {
                    let fraction_left = to_float(remaining) / to_float(total_budget)
                    if fraction_left <= 0.2 {
                        r["priority"] = r["priority"] + 100
                    }
                }
            }
        }
        new_running = new_running + [r]
    }
    let mut sorted_queue = []
    let mut i = 0

    while i < len(new_queue) {
        sorted_queue = cb2_insert_sorted(sorted_queue, new_queue[i])
    }
    let mut s2 = s
    s2["queue"] = sorted_queue
    s2["running"] = new_running
    return s2
}

fn cb2_admit(s) {
    let mut s2 = s
    let mut keep_going = true
    while keep_going {
        let nq = len(s2["queue"])
        let nr = len(s2["running"])
        if nq == 0 {
            keep_going = false
        } else {
            if nr >= s2["max_batch"] {
                keep_going = false
            } else {
                let head = s2["queue"][0]
                let needed = head["prompt_len"]
                if needed > cb2_kv_free(s2) {
                    keep_going = false
                } else {
                    let mut new_queue = []
                    let mut j = 1

                    while j < nq {
                        new_queue = new_queue + [s2["queue"][j]]
                    }
                    let mut admitted = head
                    admitted["phase"] = cb2_phase_prefill()
                    admitted["kv_slots_used"] = needed
                    admitted["start_time"] = s2["step"]
                    s2["queue"] = new_queue
                    s2["running"] = s2["running"] + [admitted]
                    s2["kv_used"] = s2["kv_used"] + needed
                }
            }
        }
    }
    return s2
}

fn cb2_prefill_phase(s) {
    let running = s["running"]
    let n = len(running)
    let mut new_running = []
    let mut i = 0

    while i < n {
        let mut r = running[i]
        if r["phase"] == cb2_phase_prefill() {
            r["phase"] = cb2_phase_decode()
        }
        new_running = new_running + [r]
    }
    let mut s2 = s
    s2["running"] = new_running
    return s2
}

fn cb2_decode_phase(s) {
    let running = s["running"]
    let n = len(running)
    let mut new_running = []
    let mut new_completed = s["completed"]
    let mut tokens_this_step = 0
    let mut freed_kv = 0
    let mut total_latency_add = 0
    let mut total_wait_add = 0
    let mut max_lat = s["tracker"]["max_latency"]
    let mut max_wait = s["tracker"]["max_wait_time"]
    let mut i = 0

    while i < n {
        let mut r = running[i]
        if r["phase"] == cb2_phase_decode() {
            r["tokens_generated"] = r["tokens_generated"] + 1
            r["kv_slots_used"] = r["kv_slots_used"] + 1
            tokens_this_step = tokens_this_step + 1
            if r["tokens_generated"] >= r["max_gen"] {
                r["phase"] = cb2_phase_done()
                r["finish_time"] = s["step"]
                let latency = r["finish_time"] - r["enqueue_time"]
                let wait = r["start_time"] - r["enqueue_time"]
                total_latency_add = total_latency_add + latency
                total_wait_add = total_wait_add + wait
                if latency > max_lat { max_lat = latency }
                if wait > max_wait { max_wait = wait }
                freed_kv = freed_kv + r["kv_slots_used"]
                new_completed = new_completed + [r]
            } else {
                new_running = new_running + [r]
            }
        } else {
            new_running = new_running + [r]
        }
    }
    let mut s2 = s
    s2["running"] = new_running
    s2["completed"] = new_completed
    s2["kv_used"] = s["kv_used"] - freed_kv + tokens_this_step
    let mut t = s2["tracker"]
    t["total_tokens"] = t["total_tokens"] + tokens_this_step
    t["total_requests_done"] = t["total_requests_done"] + len(new_completed) - len(s["completed"])
    t["total_latency"] = t["total_latency"] + total_latency_add
    t["total_wait_time"] = t["total_wait_time"] + total_wait_add
    t["max_latency"] = max_lat
    t["max_wait_time"] = max_wait
    s2["tracker"] = t
    return s2
}

fn cb2_preemption_pass(s) {
    let mut s2 = s
    let mut safety = 0
    while s2["kv_used"] > s2["max_kv_slots"] {
        if safety > 100 { return s2 }
        let n = len(s2["running"])
        if n == 0 { return s2 }
        let victim_idx = cb2_find_preempt_victim(s2["running"])
        if victim_idx < 0 { return s2 }
        s2 = cb2_preempt_at(s2, victim_idx)
        safety = safety + 1
    }
    return s2
}

fn cb2_run_step(s, cur_time) {
    let mut s2 = cb2_check_deadlines(s, cur_time)
    s2 = cb2_admit(s2)
    s2 = cb2_prefill_phase(s2)
    s2 = cb2_decode_phase(s2)
    s2 = cb2_preemption_pass(s2)
    s2["step"] = s2["step"] + 1
    return s2
}

fn cb2_run_until_done(s, max_steps) {
    let mut cur = s
    let mut _i = 0

    while _i < max_steps {
        let nq = len(cur["queue"])
        let nr = len(cur["running"])
        let ns = len(cur["swapped"])
        if nq == 0 {
            if nr == 0 {
                if ns == 0 {
                    return cur
                }
            }
        }
        cur = cb2_run_step(cur, cur["step"])
    }
    return cur
}

fn cb2_add_mid_generation(s, req_id, prompt_len, max_gen, priority, deadline) {
    return cb2_add_request(s, req_id, prompt_len, max_gen, priority, deadline)
}

fn cb2_stats(s) {
    return #{
        "queue_size": len(s["queue"]),
        "running_count": len(s["running"]),
        "swapped_count": len(s["swapped"]),
        "completed_count": len(s["completed"]),
        "kv_used": s["kv_used"],
        "kv_free": cb2_kv_free(s),
        "step": s["step"],
        "total_tokens": s["tracker"]["total_tokens"],
        "total_preemptions": s["tracker"]["total_preemptions"]
    }
}

fn cb2_throughput(s) {
    let t = s["tracker"]
    let steps = s["step"]
    let mut tok_per_step = 0.0
    if steps > 0 {
        tok_per_step = to_float(t["total_tokens"]) / to_float(steps)
    }
    let mut avg_latency = 0.0
    if t["total_requests_done"] > 0 {
        avg_latency = to_float(t["total_latency"]) / to_float(t["total_requests_done"])
    }
    let mut avg_wait = 0.0
    if t["total_requests_done"] > 0 {
        avg_wait = to_float(t["total_wait_time"]) / to_float(t["total_requests_done"])
    }
    return #{
        "tokens_per_step": tok_per_step,
        "avg_latency": avg_latency,
        "avg_wait_time": avg_wait,
        "max_latency": t["max_latency"],
        "max_wait_time": t["max_wait_time"],
        "total_tokens": t["total_tokens"],
        "total_preemptions": t["total_preemptions"],
        "total_swaps_out": t["total_swaps_out"],
        "total_swaps_in": t["total_swaps_in"],
        "total_requests_done": t["total_requests_done"]
    }
}

fn cb2_find_request(s, rid) {
    let running = s["running"]
    let mut i = 0

    while i < len(running) {
        if running[i]["req_id"] == rid { return running[i] }
    }
    let queue = s["queue"]
    let mut i = 0

    while i < len(queue) {
        if queue[i]["req_id"] == rid { return queue[i] }
    }
    let swapped = s["swapped"]
    let mut i = 0

    while i < len(swapped) {
        if swapped[i]["req_id"] == rid { return swapped[i] }
    }
    let completed = s["completed"]
    let mut i = 0

    while i < len(completed) {
        if completed[i]["req_id"] == rid { return completed[i] }
    }
    return #{}
}

fn cb2_count_by_phase(s, phase) {
    let mut count = 0
    let running = s["running"]
    let mut i = 0

    while i < len(running) {
        if running[i]["phase"] == phase { count = count + 1 }
    }
    let queue = s["queue"]
    let mut i = 0

    while i < len(queue) {
        if queue[i]["phase"] == phase { count = count + 1 }
    }
    return count
}

fn cb2_preempt_for_room(s, needed) {
    let mut s2 = s
    let mut safety = 0
    while cb2_kv_free(s2) < needed {
        if safety > 100 { return s2 }
        let n = len(s2["running"])
        if n == 0 { return s2 }
        let victim_idx = cb2_find_preempt_victim(s2["running"])
        if victim_idx < 0 { return s2 }
        s2 = cb2_preempt_at(s2, victim_idx)
        safety = safety + 1
    }
    return s2
}

// ═══════════════════════════════════════════════════════════════════
//  TESTS
// ═══════════════════════════════════════════════════════════════════

// T1: create returns valid state
let s0 = cb2_create(4, 100)
check("T1 create returns valid state", s0["max_batch"] == 4)

// T2: empty queue size is 0
check("T2 empty queue size", cb2_queue_size(s0) == 0)

// T3: add request increases queue size
let s1 = cb2_add_request(s0, 1, 10, 5, 1, 0)
check("T3 queue size after add", cb2_queue_size(s1) == 1)

// T4: peek returns highest-priority request
let s2 = cb2_add_request(s1, 2, 8, 3, 5, 0)
let peeked = cb2_peek_queue(s2)
check("T4 peek returns highest priority", peeked["req_id"] == 2)

// T5: priority ordering in queue
let s3 = cb2_add_request(s2, 3, 6, 4, 3, 0)
check("T5 queue size 3", cb2_queue_size(s3) == 3)
let top = cb2_peek_queue(s3)
check("T5 top priority is 5", top["priority"] == 5)

// T6: admit moves request from queue to running
let s4 = cb2_admit(s3)
check("T6 running after admit > 0", cb2_running_count(s4) > 0)
check("T6 queue reduced", cb2_queue_size(s4) < cb2_queue_size(s3))

// T7: prefill phase transitions to decode
let s5 = cb2_prefill_phase(s4)
let r5 = s5["running"]
let mut any_decode = false
let mut i = 0

while i < len(r5) {
    if r5[i]["phase"] == cb2_phase_decode() {
        any_decode = true
    }
}
check("T7 prefill transitions to decode", any_decode)

// T8: decode produces one token per step
let s6 = cb2_decode_phase(s5)
let r6 = s6["running"]
let mut any_gen = false
let mut i = 0

while i < len(r6) {
    if r6[i]["tokens_generated"] > 0 { any_gen = true }
}
// Also check completed for any with tokens_generated > 0
let c6 = s6["completed"]
let mut i = 0

while i < len(c6) {
    if c6[i]["tokens_generated"] > 0 { any_gen = true }
}
check("T8 decode produces token", any_gen)

// T9: request completes after max_gen tokens
let sc = cb2_create(2, 200)
let sc1 = cb2_add_request(sc, 10, 5, 3, 1, 0)
let sc2 = cb2_run_until_done(sc1, 50)
check("T9 request completed", cb2_completed_count(sc2) == 1)
let done_req = sc2["completed"][0]
check("T9 generated == max_gen", done_req["tokens_generated"] == 3)

// T10: completed request has phase done
check("T10 completed phase is done", done_req["phase"] == cb2_phase_done())

// T11: KV slots allocated on admit
let sk = cb2_create(4, 100)
let sk1 = cb2_add_request(sk, 20, 10, 5, 1, 0)
let sk2 = cb2_admit(sk1)
check("T11 kv_used > 0 after admit", sk2["kv_used"] > 0)
check("T11 kv_used == prompt_len", sk2["kv_used"] == 10)

// T12: KV slots freed on completion
let sk3 = cb2_run_until_done(sk1, 50)
check("T12 kv_used == 0 after all done", sk3["kv_used"] == 0)

// T13: max_batch limit respected
let sm = cb2_create(2, 200)
let sm1 = cb2_add_request(sm, 30, 5, 10, 1, 0)
let sm2 = cb2_add_request(sm1, 31, 5, 10, 1, 0)
let sm3 = cb2_add_request(sm2, 32, 5, 10, 1, 0)
let sm4 = cb2_admit(sm3)
check("T13 max_batch limits running", cb2_running_count(sm4) <= 2)

// T14: KV slot limit prevents admission
let sl = cb2_create(4, 15)
let sl1 = cb2_add_request(sl, 40, 10, 5, 1, 0)
let sl2 = cb2_add_request(sl1, 41, 10, 5, 1, 0)
let sl3 = cb2_admit(sl2)
// Only 15 slots total, first needs 10, second needs 10 -> only 1 fits
check("T14 KV limit prevents second admission", cb2_running_count(sl3) == 1)
check("T14 one remains in queue", cb2_queue_size(sl3) == 1)

// T15: preempt removes from running
let sp = cb2_create(4, 100)
let sp1 = cb2_add_request(sp, 50, 5, 10, 1, 0)
let sp2 = cb2_admit(sp1)
let sp3 = cb2_prefill_phase(sp2)
let sp4 = cb2_preempt(sp3, 50)
check("T15 preempt removes from running", cb2_running_count(sp4) == 0)

// T16: preempt re-inserts into queue
check("T16 preempted goes back to queue", cb2_queue_size(sp4) == 1)

// T17: preempt frees KV slots
check("T17 preempt frees KV", sp4["kv_used"] == 0)

// T18: preempt victim is lowest priority
let sv = cb2_create(4, 200)
let sv1 = cb2_add_request(sv, 60, 5, 10, 10, 0)
let sv2 = cb2_add_request(sv1, 61, 5, 10, 1, 0)
let sv3 = cb2_admit(sv2)
let sv4 = cb2_prefill_phase(sv3)
// Find victim: should be req 61 with priority 1
let victim_idx = cb2_find_preempt_victim(sv4["running"])
let victim_req = sv4["running"][victim_idx]
check("T18 victim is lowest priority", victim_req["priority"] == 1)

// T19: preempt count tracks correctly
let sv5 = cb2_preempt(sv4, 61)
let preempted_in_q = sv5["queue"][0]
check("T19 preempt count == 1", preempted_in_q["preempt_count"] == 1)

// T20: swap out moves to swapped list
let sw = cb2_create(4, 100)
let sw1 = cb2_add_request(sw, 70, 5, 10, 1, 0)
let sw2 = cb2_admit(sw1)
let sw3 = cb2_prefill_phase(sw2)
let sw4 = cb2_swap_out(sw3, 70)
check("T20 swap out -> swapped list", cb2_swapped_count(sw4) == 1)
check("T20 running reduced", cb2_running_count(sw4) == 0)

// T21: swap out frees KV slots
check("T21 swap out frees KV", sw4["kv_used"] == 0)

// T22: swap in restores to running
let sw5 = cb2_swap_in(sw4, 70)
check("T22 swap in restores to running", cb2_running_count(sw5) == 1)
check("T22 swapped list empty", cb2_swapped_count(sw5) == 0)

// T23: swap in re-allocates KV slots
check("T23 KV re-allocated after swap in", sw5["kv_used"] > 0)

// T24: swap in fails if insufficient KV
let sx = cb2_create(4, 3)
let sx1 = cb2_add_request(sx, 80, 5, 10, 1, 0)
let sx2 = cb2_admit(sx1)
// admit uses 5 KV slots but max is 3, so it might not admit
// Let's make a scenario where swap in can't fit
let sy = cb2_create(4, 10)
let sy1 = cb2_add_request(sy, 81, 5, 10, 1, 0)
let sy2 = cb2_admit(sy1)
let sy3 = cb2_prefill_phase(sy2)
// Decode a bit to use more KV
let sy4 = cb2_decode_phase(sy3)
let sy5 = cb2_swap_out(sy4, 81)
// Now add a big request that takes all KV
let sy6 = cb2_add_request(sy5, 82, 8, 2, 2, 0)
let sy7 = cb2_admit(sy6)
// Now try swap in 81 which needs 5+1=6 slots, only 2 free (10-8=2)
let sy8 = cb2_swap_in(sy7, 81)
check("T24 swap in fails if no room", cb2_swapped_count(sy8) == 1)

// T25: dynamic batching mid-generation
let sd = cb2_create(4, 200)
let sd1 = cb2_add_request(sd, 90, 5, 10, 1, 0)
let sd2 = cb2_run_step(sd1, 0)
// Add a new request mid-generation
let sd3 = cb2_add_mid_generation(sd2, 91, 5, 5, 2, 0)
let sd4 = cb2_run_step(sd3, 1)
check("T25 dynamic add: 2 running", cb2_running_count(sd4) >= 1)
let sd_done = cb2_run_until_done(sd4, 50)
check("T25 both complete", cb2_completed_count(sd_done) == 2)

// T26: SLA deadline boost activates
let dl = cb2_create(2, 100)
// Add low-priority request with tight deadline
let dl1 = cb2_add_request(dl, 100, 5, 3, 1, 5)
// Add high-priority request with no deadline
let dl2 = cb2_add_request(dl1, 101, 5, 3, 3, 0)
// Step forward near the deadline
let mut dl3 = dl2
dl3["step"] = 4
let dl4 = cb2_check_deadlines(dl3, 4)
// Request 100 should now have boosted priority (1 + 100 = 101)
let boosted = cb2_peek_queue(dl4)
check("T26 deadline boost raises priority", boosted["priority"] > 3)

// T27: run_until_done completes all requests
let rd = cb2_create(4, 200)
let rd1 = cb2_add_request(rd, 110, 5, 3, 1, 0)
let rd2 = cb2_add_request(rd1, 111, 5, 4, 2, 0)
let rd3 = cb2_add_request(rd2, 112, 5, 2, 3, 0)
let rd_done = cb2_run_until_done(rd3, 100)
check("T27 all 3 requests completed", cb2_completed_count(rd_done) == 3)

// T28: throughput reports total tokens
let tp = cb2_throughput(rd_done)
check("T28 total tokens > 0", tp["total_tokens"] > 0)
check("T28 total tokens == 3+4+2=9", tp["total_tokens"] == 9)

// T29: throughput avg latency positive
check("T29 avg latency > 0", tp["avg_latency"] > 0.0)

// T30: throughput avg wait time >= 0
check("T30 avg wait >= 0", tp["avg_wait_time"] >= 0.0)

// T31: stats reports correct counts
let st_s = cb2_create(4, 100)
let st1 = cb2_add_request(st_s, 120, 5, 3, 1, 0)
let st2 = cb2_run_step(st1, 0)
let st = cb2_stats(st2)
check("T31 stats step == 1", st["step"] == 1)
check("T31 stats kv_used >= 0", st["kv_used"] >= 0)

// T32: find_request locates in running
let fr = cb2_create(4, 100)
let fr1 = cb2_add_request(fr, 130, 5, 10, 1, 0)
let fr2 = cb2_admit(fr1)
let found = cb2_find_request(fr2, 130)
check("T32 find in running", found["req_id"] == 130)

// T33: find_request locates in completed
let fr3 = cb2_run_until_done(fr2, 50)
let found2 = cb2_find_request(fr3, 130)
check("T33 find in completed", found2["req_id"] == 130)
check("T33 completed phase", found2["phase"] == cb2_phase_done())

// T34: multiple requests run in parallel
let mp = cb2_create(4, 200)
let mp1 = cb2_add_request(mp, 140, 5, 3, 1, 0)
let mp2 = cb2_add_request(mp1, 141, 5, 3, 2, 0)
let mp3 = cb2_add_request(mp2, 142, 5, 3, 3, 0)
let mp4 = cb2_admit(mp3)
check("T34 all 3 admitted in parallel", cb2_running_count(mp4) == 3)

// T35: preemption pass auto-triggers on overcommit
// Build a state where kv_used > max_kv_slots to trigger preemption
let pp = cb2_create(4, 20)
let pp1 = cb2_add_request(pp, 150, 8, 10, 1, 0)
let pp2 = cb2_add_request(pp1, 151, 8, 10, 2, 0)
let pp3 = cb2_run_step(pp2, 0)
let pp4 = cb2_run_step(pp3, 1)
// After 2 steps with 2 requests each using 8+tokens, should be around 20
let pp_tracker = pp4["tracker"]
check("T35 preemption pass executed", pp4["kv_used"] <= pp4["max_kv_slots"])

// ═══════════════════════════════════════════════════════════════════
println("")
println("=== continuous_batching_v2 test summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
