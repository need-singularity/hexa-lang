// ===================================================================
//  test_lion_optimizer.hexa — Lion Optimizer verification (#133)
//
//  Tests (35):
//    T1  sign(positive) = 1.0
//    T2  sign(negative) = -1.0
//    T3  sign(zero) = 0.0
//    T4  default optimizer has correct lr
//    T5  default optimizer has correct beta1
//    T6  default optimizer has correct beta2
//    T7  default optimizer has correct weight_decay
//    T8  init_param_state creates zero momentum
//    T9  single step reduces loss (quadratic)
//    T10 update direction uses sign (magnitude = lr)
//    T11 momentum buffer is updated after step
//    T12 momentum uses beta2 (not beta1)
//    T13 weight decay shrinks parameters
//    T14 lr warmup at step 0 is 0
//    T15 lr warmup at midpoint is half
//    T16 lr warmup at end is base_lr
//    T17 cosine lr at step 0 is base_lr
//    T18 cosine lr at midpoint is near mid
//    T19 cosine lr at end is min_lr
//    T20 linear lr at end is min_lr
//    T21 linear lr decreases monotonically
//    T22 gradient clipping preserves direction
//    T23 gradient clipping reduces norm
//    T24 no clipping when below threshold
//    T25 param group step uses custom lr
//    T26 param group with no weight decay
//    T27 multiple steps converge (quadratic)
//    T28 Lion vs AdamW both reduce loss
//    T29 memory usage: Lion < Adam
//    T30 memory savings = 50%
//    T31 multi-tensor grad clip
//    T32 scheduled step uses warmup lr
//    T33 Rosenbrock gradient nonzero at non-minimum
//    T34 Rosenbrock loss at minimum is 0
//    T35 step_all_groups handles two groups
//
//  Run: cargo run --release -- self/test_lion_optimizer.hexa
// ===================================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx(a, b, eps) { return fabs(a - b) < eps }

// ===================================================================
//  Inlined from lion_optimizer.hexa
// ===================================================================

fn lion_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn lion_sqrt(x) {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    let mut _i = 0

    while _i < 40 {
        g = (g + x / g) / 2.0
    }
    return g
}

fn lion_cos(x) {
    let pi = 3.141592653589793
    let mut v = x
    while v > pi { v = v - 2.0 * pi }
    while v < 0.0 - pi { v = v + 2.0 * pi }
    let mut result = 1.0
    let mut term = 1.0
    let mut i = 1

    while i < 20 {
        term = 0.0 - term * v * v / to_float(2 * i * (2 * i - 1))
        result = result + term
    }
    return result
}

fn lion_zeros(n) {
    let mut v = []
    let mut _i = 0

    while _i < n { v = v + [0.0] }
    return v
}

fn lion_max_f(a, b) {
    if a > b { return a }
    return b
}

fn lion_min_f(a, b) {
    if a < b { return a }
    return b
}

fn lion_sign(x) {
    if x > 0.0 { return 1.0 }
    if x < 0.0 { return -1.0 }
    return 0.0
}

fn lion_create(lr, beta1, beta2, weight_decay) {
    return #{
        "lr": lr,
        "beta1": beta1,
        "beta2": beta2,
        "weight_decay": weight_decay,
        "step": 0
    }
}

fn lion_create_default() {
    return lion_create(0.0001, 0.9, 0.99, 0.01)
}

fn lion_init_param_state(dim) {
    return #{ "m": lion_zeros(dim) }
}

fn lion_step(opt, params, grads, state) {
    let lr = opt["lr"]
    let b1 = opt["beta1"]
    let b2 = opt["beta2"]
    let wd = opt["weight_decay"]
    let dim = len(params)
    let m = state["m"]

    let mut new_params = lion_zeros(dim)
    let mut new_m = lion_zeros(dim)

    let mut i = 0


    while i < dim {
        let c = b1 * m[i] + (1.0 - b1) * grads[i]
        let update = lion_sign(c) + wd * params[i]
        new_params[i] = params[i] - lr * update
        new_m[i] = b2 * m[i] + (1.0 - b2) * grads[i]
    }

    let new_state = #{ "m": new_m }
    return [new_params, new_state]
}

fn lion_lr_warmup(base_lr, step, warmup_steps) {
    if warmup_steps <= 0 { return base_lr }
    if step >= warmup_steps { return base_lr }
    return base_lr * to_float(step) / to_float(warmup_steps)
}

fn lion_lr_cosine(base_lr, step, total_steps, min_lr) {
    if step >= total_steps { return min_lr }
    if step <= 0 { return base_lr }
    let pi = 3.141592653589793
    let progress = to_float(step) / to_float(total_steps)
    let cosine_decay = 0.5 * (1.0 + lion_cos(pi * progress))
    return min_lr + (base_lr - min_lr) * cosine_decay
}

fn lion_lr_linear(base_lr, step, total_steps, min_lr) {
    if step >= total_steps { return min_lr }
    if step <= 0 { return base_lr }
    let progress = to_float(step) / to_float(total_steps)
    return base_lr + (min_lr - base_lr) * progress
}

fn lion_lr_schedule_cosine(base_lr, step, warmup_steps, total_steps, min_lr) {
    if step < warmup_steps {
        return lion_lr_warmup(base_lr, step, warmup_steps)
    }
    let decay_step = step - warmup_steps
    let decay_total = total_steps - warmup_steps
    return lion_lr_cosine(base_lr, decay_step, decay_total, min_lr)
}

fn lion_grad_norm(grads) {
    let mut norm_sq = 0.0
    let n = len(grads)
    let mut i = 0

    while i < n {
        norm_sq = norm_sq + grads[i] * grads[i]
    }
    return lion_sqrt(norm_sq)
}

fn lion_clip_global_norm(grads, max_norm) {
    let norm = lion_grad_norm(grads)
    if norm <= max_norm { return grads }
    let scale = max_norm / norm
    let n = len(grads)
    let mut clipped = lion_zeros(n)
    let mut i = 0

    while i < n {
        clipped[i] = grads[i] * scale
    }
    return clipped
}

fn lion_clip_multi_norm(grad_list, max_norm) {
    let mut total_sq = 0.0
    let ng = len(grad_list)
    let mut g = 0

    while g < ng {
        let grad = grad_list[g]
        let n = len(grad)
        let mut i = 0

        while i < n {
            total_sq = total_sq + grad[i] * grad[i]
        }
    }
    let total_norm = lion_sqrt(total_sq)
    if total_norm <= max_norm { return grad_list }
    let scale = max_norm / total_norm
    let mut result = []
    let mut g = 0

    while g < ng {
        let grad = grad_list[g]
        let n = len(grad)
        let mut clipped = lion_zeros(n)
        let mut i = 0

        while i < n {
            clipped[i] = grad[i] * scale
        }
        result = result + [clipped]
    }
    return result
}

fn lion_create_param_group(lr, beta1, beta2, weight_decay) {
    return #{
        "lr": lr,
        "beta1": beta1,
        "beta2": beta2,
        "weight_decay": weight_decay
    }
}

fn lion_step_group(group, params, grads, state) {
    let opt = #{
        "lr": group["lr"],
        "beta1": group["beta1"],
        "beta2": group["beta2"],
        "weight_decay": group["weight_decay"],
        "step": 0
    }
    return lion_step(opt, params, grads, state)
}

fn lion_step_all_groups(groups, params_list, grads_list, states_list) {
    let ng = len(groups)
    let mut new_params_list = []
    let mut new_states_list = []
    let mut g = 0

    while g < ng {
        let result = lion_step_group(groups[g], params_list[g], grads_list[g], states_list[g])
        new_params_list = new_params_list + [result[0]]
        new_states_list = new_states_list + [result[1]]
    }
    return [new_params_list, new_states_list]
}

fn lion_adamw_step(params, grads, m, v, lr, b1, b2, eps, wd, t) {
    let dim = len(params)
    let mut new_params = lion_zeros(dim)
    let mut new_m = lion_zeros(dim)
    let mut new_v = lion_zeros(dim)

    let mut b1_pow = 1.0
    let mut b2_pow = 1.0
    let mut _i = 0

    while _i < t {
        b1_pow = b1_pow * b1
        b2_pow = b2_pow * b2
    }
    let b1_corr = 1.0 - b1_pow
    let b2_corr = 1.0 - b2_pow

    let mut i = 0


    while i < dim {
        new_m[i] = b1 * m[i] + (1.0 - b1) * grads[i]
        new_v[i] = b2 * v[i] + (1.0 - b2) * grads[i] * grads[i]
        let m_hat = new_m[i] / b1_corr
        let v_hat = new_v[i] / b2_corr
        new_params[i] = params[i] - lr * (m_hat / (lion_sqrt(v_hat) + eps) + wd * params[i])
    }

    return [new_params, new_m, new_v]
}

fn lion_quadratic_loss(params) {
    let mut loss = 0.0
    let n = len(params)
    let mut i = 0

    while i < n {
        loss = loss + 0.5 * params[i] * params[i]
    }
    return loss
}

fn lion_quadratic_grad(params) {
    let n = len(params)
    let mut g = lion_zeros(n)
    let mut i = 0

    while i < n {
        g[i] = params[i]
    }
    return g
}

fn lion_compare(init_params, n_steps) {
    let dim = len(init_params)

    let lion_opt = lion_create(0.001, 0.9, 0.99, 0.0)
    let mut lion_params = lion_zeros(dim)
    let mut i = 0

    while i < dim { lion_params[i] = init_params[i] }
    let mut lion_state = lion_init_param_state(dim)

    let adamw_lr = 0.01
    let mut adamw_params = lion_zeros(dim)
    let mut i = 0

    while i < dim { adamw_params[i] = init_params[i] }
    let mut adamw_m = lion_zeros(dim)
    let mut adamw_v = lion_zeros(dim)

    let mut step = 0


    while step < n_steps {
        let lion_g = lion_quadratic_grad(lion_params)
        let lion_result = lion_step(lion_opt, lion_params, lion_g, lion_state)
        lion_params = lion_result[0]
        lion_state = lion_result[1]

        let adamw_g = lion_quadratic_grad(adamw_params)
        let adamw_result = lion_adamw_step(
            adamw_params, adamw_g, adamw_m, adamw_v,
            adamw_lr, 0.9, 0.999, 1.0e-8, 0.0, step + 1
        )
        adamw_params = adamw_result[0]
        adamw_m = adamw_result[1]
        adamw_v = adamw_result[2]
    }

    let lion_loss = lion_quadratic_loss(lion_params)
    let adamw_loss = lion_quadratic_loss(adamw_params)
    return [lion_loss, adamw_loss]
}

fn lion_memory_usage(dim, n_params) {
    let total_dim = dim * n_params
    let bytes_per_float = 8
    let lion_bytes = total_dim * bytes_per_float
    let adam_bytes = total_dim * bytes_per_float * 2
    let savings_pct = 50.0
    return [lion_bytes, adam_bytes, savings_pct]
}

fn lion_rosenbrock_loss(params) {
    let n = len(params)
    let mut loss = 0.0
    let mut i = 0

    while i < (n - 1) {
        let a = params[i + 1] - params[i] * params[i]
        let b = 1.0 - params[i]
        loss = loss + 100.0 * a * a + b * b
    }
    return loss
}

fn lion_rosenbrock_grad(params) {
    let n = len(params)
    let mut g = lion_zeros(n)
    let mut i = 0

    while i < (n - 1) {
        let diff = params[i + 1] - params[i] * params[i]
        g[i] = g[i] + (0.0 - 400.0) * params[i] * diff + 2.0 * (params[i] - 1.0)
        g[i + 1] = g[i + 1] + 200.0 * diff
    }
    return g
}

fn lion_step_scheduled(opt, params, grads, state, step, warmup, total, min_lr) {
    let base_lr = opt["lr"]
    let scheduled_lr = lion_lr_schedule_cosine(base_lr, step, warmup, total, min_lr)
    let scheduled_opt = #{
        "lr": scheduled_lr,
        "beta1": opt["beta1"],
        "beta2": opt["beta2"],
        "weight_decay": opt["weight_decay"],
        "step": step
    }
    return lion_step(scheduled_opt, params, grads, state)
}

// ===================================================================
//  TESTS
// ===================================================================

// T1: sign(positive) = 1.0
check("T1 sign(3.5) = 1.0", lion_sign(3.5) == 1.0)

// T2: sign(negative) = -1.0
check("T2 sign(-2.7) = -1.0", lion_sign(-2.7) == -1.0)

// T3: sign(zero) = 0.0
check("T3 sign(0.0) = 0.0", lion_sign(0.0) == 0.0)

// T4-T7: default optimizer config
let opt_def = lion_create_default()
check("T4 default lr = 0.0001", approx(opt_def["lr"], 0.0001, 1.0e-8))
check("T5 default beta1 = 0.9", approx(opt_def["beta1"], 0.9, 1.0e-8))
check("T6 default beta2 = 0.99", approx(opt_def["beta2"], 0.99, 1.0e-8))
check("T7 default weight_decay = 0.01", approx(opt_def["weight_decay"], 0.01, 1.0e-8))

// T8: init param state has zero momentum
let state0 = lion_init_param_state(4)
let m0 = state0["m"]
let mut all_zero = true
let mut i = 0

while i < 4 {
    if fabs(m0[i]) > 1.0e-10 { all_zero = false }
}
check("T8 init momentum is all zeros", all_zero)

// T9: single step reduces loss on quadratic
let p0 = [3.0, -2.0, 1.0, -4.0]
let loss_before = lion_quadratic_loss(p0)
let g0 = lion_quadratic_grad(p0)
let opt9 = lion_create(0.1, 0.9, 0.99, 0.0)
let s0 = lion_init_param_state(4)
let result9 = lion_step(opt9, p0, g0, s0)
let loss_after = lion_quadratic_loss(result9[0])
check("T9 single step reduces quadratic loss", loss_after < loss_before)

// T10: update uses sign — magnitude of change is lr per dimension
let p10 = [5.0]
let g10 = [10.0]
let opt10 = lion_create(0.1, 0.9, 0.99, 0.0)
let s10 = lion_init_param_state(1)
let result10 = lion_step(opt10, p10, g10, s10)
// With zero momentum, c = (1-b1)*g = 0.1*10 = 1.0 > 0 -> sign=1
// new_p = 5.0 - 0.1 * 1.0 = 4.9
check("T10 sign update: p = 5.0 - 0.1*sign(1.0) = 4.9", approx(result10[0][0], 4.9, 1.0e-6))

// T11: momentum buffer is updated after step
let new_state11 = result10[1]
let new_m11 = new_state11["m"]
// m_new = b2 * 0 + (1-b2) * 10 = 0.01 * 10 = 0.1
check("T11 momentum updated: m = (1-b2)*g = 0.1", approx(new_m11[0], 0.1, 1.0e-6))

// T12: momentum uses beta2 (not beta1)
// Second step: m was 0.1, grad is new_param = 4.9
let p12 = result10[0]
let g12 = lion_quadratic_grad(p12)
let result12 = lion_step(opt10, p12, g12, new_state11)
let m12 = result12[1]["m"]
// m_new = 0.99 * 0.1 + 0.01 * 4.9 = 0.099 + 0.049 = 0.148
check("T12 momentum uses beta2: m = 0.99*0.1 + 0.01*4.9", approx(m12[0], 0.148, 1.0e-4))

// T13: weight decay shrinks parameters toward zero
let p13 = [10.0, -10.0]
let g13 = [0.0, 0.0]
let opt13 = lion_create(0.1, 0.9, 0.99, 0.5)
let s13 = lion_init_param_state(2)
let result13 = lion_step(opt13, p13, g13, s13)
// With zero grad and zero momentum: sign(0) = 0, but wd * p is nonzero
// new_p[0] = 10.0 - 0.1 * (0.0 + 0.5 * 10.0) = 10.0 - 0.5 = 9.5
check("T13 weight decay shrinks params", fabs(result13[0][0]) < fabs(p13[0]))

// T14: lr warmup at step 0 is 0
let w14 = lion_lr_warmup(0.001, 0, 100)
check("T14 warmup at step=0 is 0", approx(w14, 0.0, 1.0e-10))

// T15: lr warmup at midpoint is half
let w15 = lion_lr_warmup(0.001, 50, 100)
check("T15 warmup at step=50/100 is 0.0005", approx(w15, 0.0005, 1.0e-8))

// T16: lr warmup at end returns base_lr
let w16 = lion_lr_warmup(0.001, 100, 100)
check("T16 warmup at end = base_lr", approx(w16, 0.001, 1.0e-8))

// T17: cosine lr at step 0 is base_lr
let c17 = lion_lr_cosine(0.001, 0, 1000, 0.0)
check("T17 cosine lr at step=0 is base_lr", approx(c17, 0.001, 1.0e-8))

// T18: cosine lr at midpoint is near mid
let c18 = lion_lr_cosine(0.001, 500, 1000, 0.0)
// cos(pi*0.5) = 0, so decay = 0.5*(1+0) = 0.5, lr = 0 + 0.001*0.5
check("T18 cosine lr at mid ~= 0.0005", approx(c18, 0.0005, 1.0e-4))

// T19: cosine lr at end is min_lr
let c19 = lion_lr_cosine(0.001, 1000, 1000, 0.0001)
check("T19 cosine lr at end = min_lr", approx(c19, 0.0001, 1.0e-8))

// T20: linear lr at end is min_lr
let l20 = lion_lr_linear(0.001, 1000, 1000, 0.0001)
check("T20 linear lr at end = min_lr", approx(l20, 0.0001, 1.0e-8))

// T21: linear lr decreases monotonically
let l21a = lion_lr_linear(0.001, 100, 1000, 0.0)
let l21b = lion_lr_linear(0.001, 500, 1000, 0.0)
let l21c = lion_lr_linear(0.001, 900, 1000, 0.0)
check("T21 linear lr monotone: a > b > c", l21a > l21b && l21b > l21c)

// T22: gradient clipping preserves direction
let big_grad = [3.0, 4.0]
let clipped22 = lion_clip_global_norm(big_grad, 1.0)
// Original direction: ratio 3:4, clipped should keep same ratio
let r22 = clipped22[0] / clipped22[1]
let r22_orig = 3.0 / 4.0
check("T22 clipping preserves direction", approx(r22, r22_orig, 1.0e-6))

// T23: gradient clipping reduces norm
let norm22 = lion_grad_norm(clipped22)
check("T23 clipped norm <= max_norm", norm22 <= 1.0 + 1.0e-6)

// T24: no clipping when below threshold
let small_grad = [0.1, 0.2]
let clipped24 = lion_clip_global_norm(small_grad, 10.0)
check("T24 no clip when norm < max", approx(clipped24[0], 0.1, 1.0e-10) && approx(clipped24[1], 0.2, 1.0e-10))

// T25: param group step uses custom lr
let group25 = lion_create_param_group(0.5, 0.9, 0.99, 0.0)
let p25 = [4.0]
let g25 = [4.0]
let s25 = lion_init_param_state(1)
let result25 = lion_step_group(group25, p25, g25, s25)
// c = 0.1 * 4.0 = 0.4 > 0 -> sign = 1.0
// new_p = 4.0 - 0.5 * 1.0 = 3.5
check("T25 param group uses custom lr=0.5", approx(result25[0][0], 3.5, 1.0e-6))

// T26: param group with no weight decay
let group26 = lion_create_param_group(0.1, 0.9, 0.99, 0.0)
let p26 = [10.0]
let g26 = [1.0]
let s26 = lion_init_param_state(1)
let result26 = lion_step_group(group26, p26, g26, s26)
// c = 0.1*1.0 = 0.1 > 0 -> sign = 1.0, wd=0
// new_p = 10.0 - 0.1 * (1.0 + 0.0) = 9.9
check("T26 no weight decay: p = 10.0 - 0.1*1.0 = 9.9", approx(result26[0][0], 9.9, 1.0e-6))

// T27: multiple steps converge on quadratic
// Lion uses sign updates (magnitude=lr each step), so needs higher lr
let mut p27 = [5.0, -3.0, 7.0, -1.0]
let opt27 = lion_create(0.05, 0.9, 0.99, 0.0)
let mut s27 = lion_init_param_state(4)
let loss27_init = lion_quadratic_loss(p27)
let mut _step = 0

while _step < 500 {
    let g27 = lion_quadratic_grad(p27)
    let r27 = lion_step(opt27, p27, g27, s27)
    p27 = r27[0]
    s27 = r27[1]
}
let loss27_final = lion_quadratic_loss(p27)
check("T27 500 steps converge: loss drops >90%", loss27_final < loss27_init * 0.1)

// T28: Lion vs AdamW both reduce loss
let init28 = [3.0, -2.0, 4.0, -1.0]
let cmp = lion_compare(init28, 100)
let init28_loss = lion_quadratic_loss(init28)
check("T28 Lion reduces loss", cmp[0] < init28_loss)

// T29: memory usage — Lion < Adam
let mem = lion_memory_usage(768, 100)
check("T29 Lion bytes < Adam bytes", mem[0] < mem[1])

// T30: memory savings = 50%
check("T30 memory savings = 50%", approx(mem[2], 50.0, 0.1))

// T31: multi-tensor gradient clipping
let grads31 = [[3.0, 4.0], [0.0, 5.0]]
// total norm = sqrt(9 + 16 + 0 + 25) = sqrt(50) ~ 7.07
let clipped31 = lion_clip_multi_norm(grads31, 1.0)
let mut total_sq31 = 0.0
let mut g = 0

while g < len(clipped31) {
    let arr = clipped31[g]
    let mut i = 0

    while i < len(arr) {
        total_sq31 = total_sq31 + arr[i] * arr[i]
    }
}
let clipped_norm31 = lion_sqrt(total_sq31)
check("T31 multi-tensor clip norm <= 1.0", clipped_norm31 <= 1.0 + 1.0e-6)

// T32: scheduled step uses warmup lr (during warmup phase)
let opt32 = lion_create(0.01, 0.9, 0.99, 0.0)
let p32 = [5.0]
let g32 = [5.0]
let s32 = lion_init_param_state(1)
// step=5, warmup=100 -> lr = 0.01 * 5/100 = 0.0005
let result32 = lion_step_scheduled(opt32, p32, g32, s32, 5, 100, 1000, 0.0)
// c = 0.1*5.0 = 0.5 > 0 -> sign=1.0
// new_p = 5.0 - 0.0005 * 1.0 = 4.9995
check("T32 scheduled step warmup lr", approx(result32[0][0], 4.9995, 1.0e-4))

// T33: Rosenbrock gradient nonzero at non-minimum
let rosen_p = [0.0, 0.0]
let rosen_g = lion_rosenbrock_grad(rosen_p)
let rosen_gnorm = lion_grad_norm(rosen_g)
check("T33 Rosenbrock grad nonzero at (0,0)", rosen_gnorm > 0.1)

// T34: Rosenbrock loss at minimum (1,1) is 0
let rosen_min = [1.0, 1.0]
let rosen_loss_min = lion_rosenbrock_loss(rosen_min)
check("T34 Rosenbrock loss at (1,1) = 0", approx(rosen_loss_min, 0.0, 1.0e-8))

// T35: step_all_groups handles two groups
let grp_a = lion_create_param_group(0.1, 0.9, 0.99, 0.0)
let grp_b = lion_create_param_group(0.2, 0.9, 0.99, 0.0)
let groups35 = [grp_a, grp_b]
let params35 = [[2.0, 3.0], [4.0]]
let grads35 = [[2.0, 3.0], [4.0]]
let states35 = [lion_init_param_state(2), lion_init_param_state(1)]
let result35 = lion_step_all_groups(groups35, params35, grads35, states35)
// Group A: lr=0.1, sign(0.1*g) = sign(+) = 1.0, p[0] = 2.0 - 0.1*1.0 = 1.9
// Group B: lr=0.2, sign(0.1*g) = sign(+) = 1.0, p[0] = 4.0 - 0.2*1.0 = 3.8
check("T35 group A p[0]=1.9", approx(result35[0][0][0], 1.9, 1.0e-6))
check("T35b group B p[0]=3.8", approx(result35[0][1][0], 3.8, 1.0e-6))

// ===================================================================
println("")
println("=== lion_optimizer test summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
