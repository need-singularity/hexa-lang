// ═══════════════════════════════════════════════════════════════
//  test_ttt.hexa — Test-Time Training (#189) verification
//
//  Tests (30):
//    1.  create_layer correct size
//    2.  create_layer W region non-zero
//    3.  create_layer lr stored correctly
//    4.  create_layer dim/inner_dim metadata
//    5.  self_supervised_loss non-negative
//    6.  self_supervised_loss zero for perfect W
//    7.  gradient shape matches W
//    8.  gradient non-zero for non-trivial input
//    9.  gradient zero when loss is zero
//   10.  update_hidden changes W
//   11.  update_hidden reduces loss
//   12.  update_hidden preserves Wk/Wv/Wq
//   13.  forward returns correct dim
//   14.  forward output non-zero
//   15.  forward different from input
//   16.  linear_forward matches ttt_forward
//   17.  mlp_forward returns correct dim
//   18.  mlp_forward differs from linear (ReLU effect)
//   19.  process_sequence adapts W
//   20.  process_sequence more tokens = more adaptation
//   21.  reset restores initial W
//   22.  reset preserves Wk/Wv/Wq
//   23.  create_model correct total size
//   24.  model_forward returns correct dim
//   25.  model_forward output non-zero
//   26.  adaptation_magnitude positive after update
//   27.  adaptation_magnitude zero without update
//   28.  multiple updates monotonically decrease loss
//   29.  later tokens benefit from adapted W
//   30.  model with multiple layers adapts more
//
//  run: ./hexa self/test_ttt.hexa
// ═══════════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx(a, b, eps) { return fabs(a - b) < eps }

// ── inlined helpers from ttt.hexa ───────────────────────────────

fn ttt_fabs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn ttt_sqrt(x) {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    for _i in 0..30 {
        g = (g + x / g) / 2.0
    }
    return g
}

fn ttt_zeros(n) {
    let mut v = []
    for _i in 0..n {
        v = v + [0.0]
    }
    return v
}

fn ttt_ones(n) {
    let mut v = []
    for _i in 0..n {
        v = v + [1.0]
    }
    return v
}

fn ttt_init_flat(size) {
    let mut v = []
    for i in 0..size {
        let r = i % 7
        let val = (to_float(r) - 3.0) * 0.01
        v = v + [val]
    }
    return v
}

fn ttt_init_identity(rows, cols, scale) {
    let mut v = []
    for i in 0..rows {
        for j in 0..cols {
            if i == j {
                v = v + [scale]
            } else {
                let r = (i * cols + j) % 7
                v = v + [(to_float(r) - 3.0) * 0.001]
            }
        }
    }
    return v
}

@hot
fn ttt_mat_vec(M_flat, rows, cols, v) {
    let mut out = ttt_zeros(rows)
    for i in 0..rows {
        let mut acc = 0.0
        for j in 0..cols {
            acc = acc + M_flat[i * cols + j] * v[j]
        }
        out[i] = acc
    }
    return out
}

fn ttt_outer_add(dst, a, b, m, n, scale) {
    let mut out = ttt_zeros(m * n)
    for i in 0..m {
        for j in 0..n {
            out[i * n + j] = dst[i * n + j] + scale * a[i] * b[j]
        }
    }
    return out
}

// ── layout offsets ──────────────────────────────────────────────

fn ttt_w_offset() { return 0 }
fn ttt_w_size(inner_dim) { return inner_dim * inner_dim }

fn ttt_wk_offset(inner_dim) { return inner_dim * inner_dim }
fn ttt_wk_size(inner_dim, dim) { return inner_dim * dim }

fn ttt_wv_offset(inner_dim, dim) {
    return inner_dim * inner_dim + inner_dim * dim
}
fn ttt_wv_size(inner_dim, dim) { return inner_dim * dim }

fn ttt_wq_offset(inner_dim, dim) {
    return inner_dim * inner_dim + 2 * inner_dim * dim
}
fn ttt_wq_size(dim, inner_dim) { return dim * inner_dim }

fn ttt_meta_offset(dim, inner_dim) {
    return inner_dim * inner_dim + 2 * inner_dim * dim + dim * inner_dim
}

fn ttt_layer_size(dim, inner_dim) {
    return inner_dim * inner_dim + 2 * inner_dim * dim + dim * inner_dim + 3
}

// ── sub-array extraction ────────────────────────────────────────

fn ttt_get_W(layer, inner_dim) {
    let size = inner_dim * inner_dim
    let mut w = ttt_zeros(size)
    for i in 0..size { w[i] = layer[i] }
    return w
}

fn ttt_get_Wk(layer, dim, inner_dim) {
    let off = ttt_wk_offset(inner_dim)
    let size = inner_dim * dim
    let mut w = ttt_zeros(size)
    for i in 0..size { w[i] = layer[off + i] }
    return w
}

fn ttt_get_Wv(layer, dim, inner_dim) {
    let off = ttt_wv_offset(inner_dim, dim)
    let size = inner_dim * dim
    let mut w = ttt_zeros(size)
    for i in 0..size { w[i] = layer[off + i] }
    return w
}

fn ttt_get_Wq(layer, dim, inner_dim) {
    let off = ttt_wq_offset(inner_dim, dim)
    let size = dim * inner_dim
    let mut w = ttt_zeros(size)
    for i in 0..size { w[i] = layer[off + i] }
    return w
}

fn ttt_get_lr(layer, dim, inner_dim) {
    let off = ttt_meta_offset(dim, inner_dim)
    return layer[off]
}

fn ttt_set_W(layer, W_new, inner_dim) {
    let n = len(layer)
    let w_size = inner_dim * inner_dim
    let mut out = ttt_zeros(n)
    for i in 0..w_size {
        out[i] = W_new[i]
    }
    for i in w_size..n {
        out[i] = layer[i]
    }
    return out
}

// ── core functions ──────────────────────────────────────────────

fn ttt_create_layer(dim, inner_dim) {
    let lr = 0.01
    let mut layer = ttt_init_identity(inner_dim, inner_dim, 0.1)
    let wk = ttt_init_flat(inner_dim * dim)
    for i in 0..len(wk) { layer = layer + [wk[i]] }
    let wv = ttt_init_flat(inner_dim * dim)
    for i in 0..len(wv) { layer = layer + [wv[i]] }
    let wq = ttt_init_flat(dim * inner_dim)
    for i in 0..len(wq) { layer = layer + [wq[i]] }
    layer = layer + [lr]
    layer = layer + [to_float(dim)]
    layer = layer + [to_float(inner_dim)]
    return layer
}

fn ttt_self_supervised_loss(layer, x, n, dim) {
    let inner_dim = to_int(layer[len(layer) - 1])
    let W = ttt_get_W(layer, inner_dim)
    let Wk = ttt_get_Wk(layer, dim, inner_dim)
    let Wv = ttt_get_Wv(layer, dim, inner_dim)
    let K = ttt_mat_vec(Wk, inner_dim, dim, x)
    let V = ttt_mat_vec(Wv, inner_dim, dim, x)
    let recon = ttt_mat_vec(W, inner_dim, inner_dim, K)
    let mut loss = 0.0
    for i in 0..inner_dim {
        let diff = recon[i] - V[i]
        loss = loss + diff * diff
    }
    return loss
}

fn ttt_gradient(layer, x, n, dim) {
    let inner_dim = to_int(layer[len(layer) - 1])
    let W = ttt_get_W(layer, inner_dim)
    let Wk = ttt_get_Wk(layer, dim, inner_dim)
    let Wv = ttt_get_Wv(layer, dim, inner_dim)
    let K = ttt_mat_vec(Wk, inner_dim, dim, x)
    let V = ttt_mat_vec(Wv, inner_dim, dim, x)
    let recon = ttt_mat_vec(W, inner_dim, inner_dim, K)
    let mut residual = ttt_zeros(inner_dim)
    for i in 0..inner_dim {
        residual[i] = recon[i] - V[i]
    }
    let w_size = inner_dim * inner_dim
    let mut grad = ttt_zeros(w_size)
    for i in 0..inner_dim {
        for j in 0..inner_dim {
            grad[i * inner_dim + j] = 2.0 * residual[i] * K[j]
        }
    }
    return grad
}

fn ttt_update_hidden(layer, x, n, dim) {
    let inner_dim = to_int(layer[len(layer) - 1])
    let lr = ttt_get_lr(layer, dim, inner_dim)
    let grad = ttt_gradient(layer, x, n, dim)
    let W = ttt_get_W(layer, inner_dim)
    let w_size = inner_dim * inner_dim
    let mut W_new = ttt_zeros(w_size)
    for i in 0..w_size {
        W_new[i] = W[i] - lr * grad[i]
    }
    return ttt_set_W(layer, W_new, inner_dim)
}

fn ttt_forward(layer, x, n, dim) {
    let inner_dim = to_int(layer[len(layer) - 1])
    let updated = ttt_update_hidden(layer, x, n, dim)
    let W_new = ttt_get_W(updated, inner_dim)
    let Wk = ttt_get_Wk(updated, dim, inner_dim)
    let Wq = ttt_get_Wq(updated, dim, inner_dim)
    let K = ttt_mat_vec(Wk, inner_dim, dim, x)
    let hidden = ttt_mat_vec(W_new, inner_dim, inner_dim, K)
    let output = ttt_mat_vec(Wq, dim, inner_dim, hidden)
    return output
}

fn ttt_linear_forward(layer, x, n, dim) {
    return ttt_forward(layer, x, n, dim)
}

fn ttt_mlp_forward(layer, x, n, dim) {
    let inner_dim = to_int(layer[len(layer) - 1])
    let updated = ttt_update_hidden(layer, x, n, dim)
    let W_new = ttt_get_W(updated, inner_dim)
    let Wk = ttt_get_Wk(updated, dim, inner_dim)
    let Wq = ttt_get_Wq(updated, dim, inner_dim)
    let K = ttt_mat_vec(Wk, inner_dim, dim, x)
    let h1_raw = ttt_mat_vec(W_new, inner_dim, inner_dim, K)
    let mut h1 = ttt_zeros(inner_dim)
    for i in 0..inner_dim {
        if h1_raw[i] > 0.0 {
            h1[i] = h1_raw[i]
        } else {
            h1[i] = 0.0
        }
    }
    let output = ttt_mat_vec(Wq, dim, inner_dim, h1)
    return output
}

fn ttt_process_sequence(layer, tokens, seq_len, dim) {
    let mut current_layer = layer
    for t in 0..seq_len {
        let mut x = ttt_zeros(dim)
        for d in 0..dim {
            x[d] = tokens[t * dim + d]
        }
        current_layer = ttt_update_hidden(current_layer, x, 1, dim)
    }
    return current_layer
}

fn ttt_reset(layer) {
    let dim = to_int(layer[len(layer) - 2])
    let inner_dim = to_int(layer[len(layer) - 1])
    let W_init = ttt_init_identity(inner_dim, inner_dim, 0.1)
    return ttt_set_W(layer, W_init, inner_dim)
}

fn ttt_create_model(n_layers, dim, inner_dim) {
    let lsize = ttt_layer_size(dim, inner_dim)
    let mut model = []
    for l in 0..n_layers {
        let layer = ttt_create_layer(dim, inner_dim)
        for i in 0..len(layer) {
            model = model + [layer[i]]
        }
    }
    model = model + [to_float(n_layers)]
    model = model + [to_float(dim)]
    model = model + [to_float(inner_dim)]
    model = model + [to_float(lsize)]
    return model
}

fn ttt_get_layer(model, l, lsize) {
    let off = l * lsize
    let mut layer = ttt_zeros(lsize)
    for i in 0..lsize {
        layer[i] = model[off + i]
    }
    return layer
}

fn ttt_set_layer(model, l, layer, lsize) {
    let n = len(model)
    let off = l * lsize
    let mut out = ttt_zeros(n)
    for i in 0..n {
        if i >= off {
            if i < off + lsize {
                out[i] = layer[i - off]
            } else {
                out[i] = model[i]
            }
        } else {
            out[i] = model[i]
        }
    }
    return out
}

fn ttt_model_forward(model, x, n, dim) {
    let model_len = len(model)
    let n_layers = to_int(model[model_len - 4])
    let inner_dim = to_int(model[model_len - 2])
    let lsize = to_int(model[model_len - 1])
    let mut h = x
    for l in 0..n_layers {
        let layer = ttt_get_layer(model, l, lsize)
        h = ttt_forward(layer, h, n, dim)
    }
    return h
}

fn ttt_adaptation_magnitude(layer_before, layer_after, dim, inner_dim) {
    let w_size = inner_dim * inner_dim
    let mut sum_sq = 0.0
    for i in 0..w_size {
        let diff = layer_after[i] - layer_before[i]
        sum_sq = sum_sq + diff * diff
    }
    return ttt_sqrt(sum_sq)
}

// ═══════════════════════════════════════════════════════════════
//  TESTS
// ═══════════════════════════════════════════════════════════════

println("=== Test-Time Training (TTT) Tests (SSOT #189) ===")

let dim = 4
let inner_dim = 3

// ── test input ──────────────────────────────────────────────────
let x = [0.5, 0.3, 0.8, 0.1]

// ── 1. create_layer correct size ────────────────────────────────
let layer = ttt_create_layer(dim, inner_dim)
let expected_size = ttt_layer_size(dim, inner_dim)
check("1. create_layer correct size", len(layer) == expected_size)

// ── 2. create_layer W region non-zero ───────────────────────────
let W0 = ttt_get_W(layer, inner_dim)
let mut has_nonzero = false
for i in 0..len(W0) {
    if ttt_fabs(W0[i]) > 1.0e-10 {
        has_nonzero = true
    }
}
check("2. create_layer W non-zero", has_nonzero)

// ── 3. create_layer lr stored correctly ─────────────────────────
let lr = ttt_get_lr(layer, dim, inner_dim)
check("3. create_layer lr=0.01", approx(lr, 0.01, 1.0e-6))

// ── 4. create_layer dim/inner_dim metadata ──────────────────────
let stored_dim = layer[len(layer) - 2]
let stored_inner = layer[len(layer) - 1]
check("4. metadata dim correct", approx(stored_dim, to_float(dim), 0.01))
check("4. metadata inner_dim correct", approx(stored_inner, to_float(inner_dim), 0.01))

// ── 5. self_supervised_loss non-negative ────────────────────────
let loss0 = ttt_self_supervised_loss(layer, x, 1, dim)
check("5. loss non-negative", loss0 >= 0.0)

// ── 6. self_supervised_loss zero for perfect W ──────────────────
// Construct a layer where W*K == V exactly
// Use identity-like W so W*K = K, then set W_v = W_k so V = K
let mut perfect_layer = ttt_create_layer(dim, inner_dim)
// Copy W_k values into W_v region
let wk_off = ttt_wk_offset(inner_dim)
let wv_off = ttt_wv_offset(inner_dim, dim)
let wk_sz = inner_dim * dim
// Set W to identity
let mut W_id = ttt_zeros(inner_dim * inner_dim)
for i in 0..inner_dim {
    W_id[i * inner_dim + i] = 1.0
}
perfect_layer = ttt_set_W(perfect_layer, W_id, inner_dim)
// Copy W_k into W_v
let mut pl2 = ttt_zeros(len(perfect_layer))
for i in 0..len(perfect_layer) {
    pl2[i] = perfect_layer[i]
}
for i in 0..wk_sz {
    pl2[wv_off + i] = pl2[wk_off + i]
}
let perfect_loss = ttt_self_supervised_loss(pl2, x, 1, dim)
check("6. perfect W gives zero loss", perfect_loss < 1.0e-10)

// ── 7. gradient shape matches W ─────────────────────────────────
let grad = ttt_gradient(layer, x, 1, dim)
check("7. gradient size = inner_dim^2", len(grad) == inner_dim * inner_dim)

// ── 8. gradient non-zero for non-trivial input ──────────────────
let mut grad_nonzero = false
for i in 0..len(grad) {
    if ttt_fabs(grad[i]) > 1.0e-12 {
        grad_nonzero = true
    }
}
check("8. gradient non-zero", grad_nonzero)

// ── 9. gradient zero when loss is zero ──────────────────────────
let grad_perfect = ttt_gradient(pl2, x, 1, dim)
let mut grad_perfect_sum = 0.0
for i in 0..len(grad_perfect) {
    grad_perfect_sum = grad_perfect_sum + ttt_fabs(grad_perfect[i])
}
check("9. gradient zero at perfect W", grad_perfect_sum < 1.0e-10)

// ── 10. update_hidden changes W ─────────────────────────────────
let updated = ttt_update_hidden(layer, x, 1, dim)
let W_after = ttt_get_W(updated, inner_dim)
let mut w_changed = false
for i in 0..len(W0) {
    if ttt_fabs(W0[i] - W_after[i]) > 1.0e-12 {
        w_changed = true
    }
}
check("10. update_hidden changes W", w_changed)

// ── 11. update_hidden reduces loss ──────────────────────────────
let loss_after = ttt_self_supervised_loss(updated, x, 1, dim)
check("11. update reduces loss", loss_after < loss0)

// ── 12. update_hidden preserves Wk/Wv/Wq ───────────────────────
let Wk_before = ttt_get_Wk(layer, dim, inner_dim)
let Wk_after = ttt_get_Wk(updated, dim, inner_dim)
let mut wk_same = true
for i in 0..len(Wk_before) {
    if ttt_fabs(Wk_before[i] - Wk_after[i]) > 1.0e-12 {
        wk_same = false
    }
}
check("12. update preserves Wk", wk_same)

// ── 13. forward returns correct dim ─────────────────────────────
let out = ttt_forward(layer, x, 1, dim)
check("13. forward output dim", len(out) == dim)

// ── 14. forward output non-zero ─────────────────────────────────
let mut out_nonzero = false
for i in 0..len(out) {
    if ttt_fabs(out[i]) > 1.0e-12 {
        out_nonzero = true
    }
}
check("14. forward output non-zero", out_nonzero)

// ── 15. forward different from input ────────────────────────────
let mut same_as_input = true
for i in 0..dim {
    if ttt_fabs(out[i] - x[i]) > 1.0e-6 {
        same_as_input = false
    }
}
check("15. forward differs from input", same_as_input == false)

// ── 16. linear_forward matches ttt_forward ──────────────────────
let out_linear = ttt_linear_forward(layer, x, 1, dim)
let mut lin_matches = true
for i in 0..dim {
    if ttt_fabs(out_linear[i] - out[i]) > 1.0e-10 {
        lin_matches = false
    }
}
check("16. linear_forward == ttt_forward", lin_matches)

// ── 17. mlp_forward returns correct dim ─────────────────────────
let out_mlp = ttt_mlp_forward(layer, x, 1, dim)
check("17. mlp_forward output dim", len(out_mlp) == dim)

// ── 18. mlp_forward differs from linear (ReLU effect) ───────────
// With ReLU zeroing negatives, MLP output should differ from linear
let mut mlp_differs = false
for i in 0..dim {
    if ttt_fabs(out_mlp[i] - out_linear[i]) > 1.0e-12 {
        mlp_differs = true
    }
}
check("18. mlp differs from linear", mlp_differs)

// ── 19. process_sequence adapts W ───────────────────────────────
// 2 tokens, each dim=4
let tokens2 = [0.5, 0.3, 0.8, 0.1, 0.9, 0.2, 0.4, 0.7]
let layer_seq = ttt_process_sequence(layer, tokens2, 2, dim)
let W_seq = ttt_get_W(layer_seq, inner_dim)
let mut seq_adapted = false
for i in 0..len(W0) {
    if ttt_fabs(W0[i] - W_seq[i]) > 1.0e-12 {
        seq_adapted = true
    }
}
check("19. process_sequence adapts W", seq_adapted)

// ── 20. more tokens = more adaptation ───────────────────────────
let tokens4 = [0.5, 0.3, 0.8, 0.1, 0.9, 0.2, 0.4, 0.7, 0.1, 0.6, 0.3, 0.9, 0.7, 0.4, 0.2, 0.5]
let layer_seq4 = ttt_process_sequence(layer, tokens4, 4, dim)
let mag2 = ttt_adaptation_magnitude(layer, layer_seq, dim, inner_dim)
let mag4 = ttt_adaptation_magnitude(layer, layer_seq4, dim, inner_dim)
check("20. 4 tokens adapts more than 2", mag4 > mag2)

// ── 21. reset restores initial W ────────────────────────────────
let layer_reset = ttt_reset(layer_seq)
let W_reset = ttt_get_W(layer_reset, inner_dim)
let W_fresh = ttt_get_W(ttt_create_layer(dim, inner_dim), inner_dim)
let mut reset_ok = true
for i in 0..len(W_fresh) {
    if ttt_fabs(W_reset[i] - W_fresh[i]) > 1.0e-10 {
        reset_ok = false
    }
}
check("21. reset restores initial W", reset_ok)

// ── 22. reset preserves Wk/Wv/Wq ───────────────────────────────
let Wk_reset = ttt_get_Wk(layer_reset, dim, inner_dim)
let Wk_orig = ttt_get_Wk(layer_seq, dim, inner_dim)
let mut wk_preserved = true
for i in 0..len(Wk_reset) {
    if ttt_fabs(Wk_reset[i] - Wk_orig[i]) > 1.0e-10 {
        wk_preserved = false
    }
}
check("22. reset preserves Wk", wk_preserved)

// ── 23. create_model correct total size ─────────────────────────
let model = ttt_create_model(2, dim, inner_dim)
let lsize = ttt_layer_size(dim, inner_dim)
let expected_model_size = 2 * lsize + 4
check("23. model size correct", len(model) == expected_model_size)

// ── 24. model_forward returns correct dim ───────────────────────
let model_out = ttt_model_forward(model, x, 1, dim)
check("24. model_forward output dim", len(model_out) == dim)

// ── 25. model_forward output non-zero ───────────────────────────
let mut model_out_nonzero = false
for i in 0..len(model_out) {
    if ttt_fabs(model_out[i]) > 1.0e-12 {
        model_out_nonzero = true
    }
}
check("25. model_forward output non-zero", model_out_nonzero)

// ── 26. adaptation_magnitude positive after update ──────────────
let mag_update = ttt_adaptation_magnitude(layer, updated, dim, inner_dim)
check("26. adaptation mag > 0 after update", mag_update > 0.0)

// ── 27. adaptation_magnitude zero without update ────────────────
let mag_same = ttt_adaptation_magnitude(layer, layer, dim, inner_dim)
check("27. adaptation mag = 0 without update", mag_same < 1.0e-12)

// ── 28. multiple updates monotonically decrease loss ────────────
let mut step_layer = layer
let mut prev_loss = ttt_self_supervised_loss(step_layer, x, 1, dim)
let mut monotonic = true
for _step in 0..5 {
    step_layer = ttt_update_hidden(step_layer, x, 1, dim)
    let cur_loss = ttt_self_supervised_loss(step_layer, x, 1, dim)
    if cur_loss > prev_loss + 1.0e-10 {
        monotonic = false
    }
    prev_loss = cur_loss
}
check("28. 5 SGD steps monotonically decrease loss", monotonic)

// ── 29. later tokens benefit from adapted W ─────────────────────
// First token: loss on x with fresh layer
let loss_tok1 = ttt_self_supervised_loss(layer, x, 1, dim)
// After processing x once, loss on x should be lower (W adapted to x)
let layer_after_x = ttt_update_hidden(layer, x, 1, dim)
let loss_tok2 = ttt_self_supervised_loss(layer_after_x, x, 1, dim)
check("29. later tokens benefit from adapted W", loss_tok2 < loss_tok1)

// ── 30. model with multiple layers adapts more ──────────────────
let model_1L = ttt_create_model(1, dim, inner_dim)
let model_3L = ttt_create_model(3, dim, inner_dim)
let out_1L = ttt_model_forward(model_1L, x, 1, dim)
let out_3L = ttt_model_forward(model_3L, x, 1, dim)
// More layers = more transformation (output should differ from 1-layer)
let mut layers_differ = false
for i in 0..dim {
    if ttt_fabs(out_1L[i] - out_3L[i]) > 1.0e-10 {
        layers_differ = true
    }
}
check("30. 3-layer output differs from 1-layer", layers_differ)

// ═══════════════════════════════════════════════════════════════
println("")
println("=== Test-Time Training (#189) test summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
