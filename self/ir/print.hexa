// ═══════════════════════════════════════════════════════════
//  self/ir/print.hexa — HEXA-IR Pretty Printer
//  Port of src/ir/print.rs (1:1, semantics-preserving)
//  Produces human-readable textual IR.
// ═══════════════════════════════════════════════════════════
//
// Depends on: opcodes.hexa, types.hexa, instr.hexa

fn escape_str(s) {
    // simplified escape: backslash and quote only (newline/tab handled by caller)
    let mut parts = []
    let i = 0
    while i < len(s) {
        let ch = s[i]
        if ch == "\\" {
            parts.push("\\\\")
        } else {
            if ch == "\"" {
                parts.push("\\\"")
            } else {
                parts.push(ch)
            }
        }
        i = i + 1
    }
    return parts.join("")
}

fn print_operand(op) {
    let k = op.kind
    if k == "value" {
        return "%" + to_string(op.a)
    }
    if k == "imm_i64" {
        return to_string(op.a)
    }
    if k == "imm_f64" {
        return to_string(op.a)
    }
    if k == "imm_bool" {
        if op.a == 0 {
            return "false"
        }
        return "true"
    }
    if k == "block" {
        return "bb" + to_string(op.a)
    }
    if k == "func" {
        return "@" + to_string(op.a)
    }
    if k == "field_idx" {
        return "field." + to_string(op.a)
    }
    if k == "string_ref" {
        return "@str." + to_string(op.a)
    }
    if k == "phi_entry" {
        return "[bb" + to_string(op.b) + ": %" + to_string(op.a) + "]"
    }
    if k == "switch_case" {
        return "case " + to_string(op.a) + " => bb" + to_string(op.b)
    }
    if k == "cmp" {
        return "cmp." + op.cmp
    }
    if k == "param" {
        return "param." + to_string(op.a)
    }
    return "?"
}

// Find a CmpKind operand on a Sub instruction, or "" if absent.
fn find_cmp_kind(instr) {
    if instr.op != "sub" {
        return ""
    }
    let i = 0
    while i < len(instr.operands) {
        let o = instr.operands[i]
        if o.kind == "cmp" {
            return o.cmp
        }
        i = i + 1
    }
    return ""
}

fn join_operands_skip_cmp(operands) {
    let mut parts = []
    let i = 0
    while i < len(operands) {
        let o = operands[i]
        if o.kind != "cmp" {
            parts.push(print_operand(o))
        }
        i = i + 1
    }
    return parts.join(", ")
}

fn join_operands_all(operands) {
    let mut parts = []
    let i = 0
    while i < len(operands) {
        parts.push(print_operand(operands[i]))
        i = i + 1
    }
    return parts.join(", ")
}

fn print_instruction(instr) {
    let mut parts = []
    // Result assignment (skip for void)
    if instr.ty != "void" {
        parts.push("%" + to_string(instr.result) + ": " + instr.ty + " = ")
    }

    let cmp_kind = find_cmp_kind(instr)
    if cmp_kind != "" {
        parts.push("cmp." + cmp_kind)
        let rest = join_operands_skip_cmp(instr.operands)
        if rest != "" {
            parts.push(" " + rest)
        }
    } else {
        parts.push(instr.op)
        if len(instr.operands) > 0 {
            parts.push(" " + join_operands_all(instr.operands))
        }
    }
    return parts.join("")
}

fn print_block(block) {
    let mut parts = []
    parts.push("  " + block.name + ":")
    if len(block.preds) > 0 {
        parts.push("  ; preds:")
        let i = 0
        while i < len(block.preds) {
            if i > 0 {
                parts.push(",")
            }
            parts.push(" bb" + to_string(block.preds[i]))
            i = i + 1
        }
    }
    parts.push("\n")
    let j = 0
    while j < len(block.instructions) {
        parts.push("    " + print_instruction(block.instructions[j]) + "\n")
        j = j + 1
    }
    return parts.join("")
}

fn print_function(func) {
    let mut parts = []
    parts.push("fn @" + func.name + "(")
    let mut param_parts = []
    let i = 0
    while i < len(func.params) {
        let p = func.params[i]
        param_parts.push(p[0] + ": " + p[1])
        i = i + 1
    }
    parts.push(param_parts.join(", "))
    parts.push(") -> " + func.ret_type + " {\n")
    let j = 0
    while j < len(func.blocks) {
        parts.push(print_block(func.blocks[j]))
        j = j + 1
    }
    parts.push("}\n")
    return parts.join("")
}

fn print_module(module) {
    let mut parts = []
    parts.push("; module " + module.name + "\n")
    parts.push("; strings: " + to_string(len(module.string_pool)) + "\n\n")

    // String pool
    let i = 0
    while i < len(module.string_pool) {
        parts.push("@str." + to_string(i) + " = \"" + escape_str(module.string_pool[i]) + "\"\n")
        i = i + 1
    }
    if len(module.string_pool) > 0 {
        parts.push("\n")
    }

    // Globals
    let g = 0
    while g < len(module.globals) {
        let gl = module.globals[g]
        let kw = "global"
        if gl.is_const {
            kw = "const"
        }
        parts.push(kw + " @" + gl.name + ": " + gl.ty + "\n")
        g = g + 1
    }
    if len(module.globals) > 0 {
        parts.push("\n")
    }

    // Functions
    let f = 0
    while f < len(module.functions) {
        parts.push(print_function(module.functions[f]) + "\n")
        f = f + 1
    }
    return parts.join("")
}
