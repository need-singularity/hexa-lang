// ═══════════════════════════════════════════════════════════
//  self/ir/opcodes.hexa — HEXA-IR Opcodes (J₂=24 opcodes)
//  Port of src/ir/opcode.rs (1:1, semantics-preserving)
//  τ=4 categories × n=6 each = 24 opcodes
// ═══════════════════════════════════════════════════════════

// OpCode enum — 24 variants in 4 categories
enum OpCode {
    // Category 1: Arithmetic (n=6)
    Add,
    Sub,
    Mul,
    Div,
    Mod,
    Neg,

    // Category 2: Memory (n=6)
    Load,
    Store,
    Alloc,
    Free,
    Copy,
    Move,

    // Category 3: Control (n=6)
    Jump,
    Branch,
    Call,
    Return,
    Phi,
    Switch,

    // Category 4: Proof (n=6)
    Assert,
    Assume,
    Invariant,
    LifetimeStart,
    LifetimeEnd,
    OwnershipTransfer
}

// Total opcode count = J₂(6) = 24
fn opcode_count() {
    return 24
}

// Map opcode to raw index 0..23 (mirrors Rust `*self as usize`)
fn opcode_to_index(op) {
    return match op {
        Add -> 0,
        Sub -> 1,
        Mul -> 2,
        Div -> 3,
        Mod -> 4,
        Neg -> 5,
        Load -> 6,
        Store -> 7,
        Alloc -> 8,
        Free -> 9,
        Copy -> 10,
        Move -> 11,
        Jump -> 12,
        Branch -> 13,
        Call -> 14,
        Return -> 15,
        Phi -> 16,
        Switch -> 17,
        Assert -> 18,
        Assume -> 19,
        Invariant -> 20,
        LifetimeStart -> 21,
        LifetimeEnd -> 22,
        OwnershipTransfer -> 23
    }
}

// Category index (0..τ=4)
fn opcode_category(op) {
    return opcode_to_index(op) / 6
}

// Index within category (0..n=6)
fn opcode_index_in_category(op) {
    return opcode_to_index(op) % 6
}

// Whether this opcode has side effects
fn opcode_has_side_effect(op) {
    return match op {
        Store -> true,
        Alloc -> true,
        Free -> true,
        Copy -> true,
        Move -> true,
        Call -> true,
        OwnershipTransfer -> true,
        _ -> false
    }
}

// Whether this opcode is a terminator (ends a basic block)
fn opcode_is_terminator(op) {
    return match op {
        Jump -> true,
        Branch -> true,
        Return -> true,
        Switch -> true,
        _ -> false
    }
}

// Whether this is a proof-related opcode (compile-time only)
fn opcode_is_proof(op) {
    return opcode_category(op) == 3
}

// Category name
fn opcode_category_name(op) {
    let c = opcode_category(op)
    if c == 0 {
        return "arithmetic"
    }
    if c == 1 {
        return "memory"
    }
    if c == 2 {
        return "control"
    }
    return "proof"
}

// Textual mnemonic (mirrors Display impl)
fn opcode_to_string(op) {
    return match op {
        Add -> "add",
        Sub -> "sub",
        Mul -> "mul",
        Div -> "div",
        Mod -> "mod",
        Neg -> "neg",
        Load -> "load",
        Store -> "store",
        Alloc -> "alloc",
        Free -> "free",
        Copy -> "copy",
        Move -> "move",
        Jump -> "jump",
        Branch -> "branch",
        Call -> "call",
        Return -> "ret",
        Phi -> "phi",
        Switch -> "switch",
        Assert -> "assert",
        Assume -> "assume",
        Invariant -> "invariant",
        LifetimeStart -> "lifetime.start",
        LifetimeEnd -> "lifetime.end",
        OwnershipTransfer -> "ownership.transfer"
    }
}
