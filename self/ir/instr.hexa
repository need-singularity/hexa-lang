// ═══════════════════════════════════════════════════════════
//  self/ir/instr.hexa — HEXA-IR SSA Instructions
//  Port of src/ir/instr.rs (1:1, semantics-preserving)
//  ValueId, BlockId, FuncId, Instruction, Operand,
//  BasicBlock, IrFunction, IrModule
// ═══════════════════════════════════════════════════════════

// ── SSA / CFG ids ───────────────────────────────────────────
// Ids are simple integers in Hexa; constructors exist for parity.

fn value_id(n) {
    return n
}

fn block_id(n) {
    return n
}

fn func_id(n) {
    return n
}

fn value_id_to_string(v) {
    return "%" + to_string(v)
}

fn block_id_to_string(b) {
    return "bb" + to_string(b)
}

fn func_id_to_string(f) {
    return "@" + to_string(f)
}

// ── CmpKind ─────────────────────────────────────────────────
enum CmpKind {
    Eq,
    Ne,
    Lt,
    Le,
    Gt,
    Ge
}

fn cmp_kind_to_string(k) {
    return match k {
        Eq -> "eq",
        Ne -> "ne",
        Lt -> "lt",
        Le -> "le",
        Gt -> "gt",
        Ge -> "ge"
    }
}

// ── Operand (tagged struct) ─────────────────────────────────
// Hexa enums lack per-variant payload shapes, so we encode Operand
// as a struct with a kind tag + polymorphic payload slots.
struct Operand {
    kind: string,   // "value" | "imm_i64" | "imm_f64" | "imm_bool" | "block" |
                    // "func" | "field_idx" | "string_ref" | "phi_entry" |
                    // "switch_case" | "cmp" | "param"
    a: int,         // primary payload (ValueId/ImmI64/BlockId/FuncId/idx/case-val)
    b: int,         // secondary (phi block or switch target)
    cmp: string     // cmp kind string when kind=="cmp"
}

fn op_value(v) {
    return Operand { kind: "value", a: v, b: 0, cmp: "" }
}

fn op_imm_i64(n) {
    return Operand { kind: "imm_i64", a: n, b: 0, cmp: "" }
}

fn op_imm_bool(b) {
    let v = 0
    if b {
        v = 1
    }
    return Operand { kind: "imm_bool", a: v, b: 0, cmp: "" }
}

fn op_block(bb) {
    return Operand { kind: "block", a: bb, b: 0, cmp: "" }
}

fn op_func(f) {
    return Operand { kind: "func", a: f, b: 0, cmp: "" }
}

fn op_field_idx(i) {
    return Operand { kind: "field_idx", a: i, b: 0, cmp: "" }
}

fn op_string_ref(i) {
    return Operand { kind: "string_ref", a: i, b: 0, cmp: "" }
}

fn op_phi_entry(bb, v) {
    return Operand { kind: "phi_entry", a: v, b: bb, cmp: "" }
}

fn op_switch_case(val, bb) {
    return Operand { kind: "switch_case", a: val, b: bb, cmp: "" }
}

fn op_cmp(kind_str) {
    return Operand { kind: "cmp", a: 0, b: 0, cmp: kind_str }
}

fn op_param(i) {
    return Operand { kind: "param", a: i, b: 0, cmp: "" }
}

// ── Instruction ─────────────────────────────────────────────
struct Instruction {
    result: int,        // ValueId
    op: string,         // opcode mnemonic (use opcode_to_string)
    operands: array,    // array of Operand
    ty: string          // IrType kind string (use ir_ty_to_string)
}

fn make_instruction(result, op, operands, ty) {
    return Instruction {
        result: result,
        op: op,
        operands: operands,
        ty: ty
    }
}

// ── BasicBlock ──────────────────────────────────────────────
struct BasicBlock {
    id: int,
    name: string,
    instructions: array,    // array of Instruction
    preds: array,           // array of BlockId
    succs: array            // array of BlockId
}

fn make_basic_block(id, name) {
    return BasicBlock {
        id: id,
        name: name,
        instructions: [],
        preds: [],
        succs: []
    }
}

// terminator: last instruction if it is a terminator opcode
fn block_is_terminated(b) {
    let n = len(b.instructions)
    if n == 0 {
        return false
    }
    let last = b.instructions[n - 1]
    let op = last.op
    if op == "jump" {
        return true
    }
    if op == "branch" {
        return true
    }
    if op == "ret" {
        return true
    }
    if op == "switch" {
        return true
    }
    return false
}

// ── IrFunction ──────────────────────────────────────────────
struct IrFunction {
    id: int,
    name: string,
    params: array,          // array of [name, IrType-kind-string]
    ret_type: string,       // IrType kind string
    blocks: array,          // array of BasicBlock
    next_value: int,
    next_block: int
}

fn make_ir_function(id, name, params, ret_type) {
    return IrFunction {
        id: id,
        name: name,
        params: params,
        ret_type: ret_type,
        blocks: [],
        next_value: 0,
        next_block: 0
    }
}

fn func_next_value_id(f) {
    return f.next_value
}

fn func_fresh_value(f) {
    let id = f.next_value
    f.next_value = f.next_value + 1
    return id
}

fn func_fresh_block(f, name) {
    let id = f.next_block
    f.next_block = f.next_block + 1
    push(f.blocks, make_basic_block(id, name))
    return id
}

fn func_instr_count(f) {
    let total = 0
    let i = 0
    while i < len(f.blocks) {
        total = total + len(f.blocks[i].instructions)
        i = i + 1
    }
    return total
}

fn func_entry_block(f) {
    if len(f.blocks) == 0 {
        return 0
    }
    return f.blocks[0]
}

// ── IrModule ────────────────────────────────────────────────
struct Global {
    name: string,
    ty: string,         // IrType kind
    has_init: bool,     // replacement for Option<Operand>
    is_const: bool
}

struct IrModule {
    name: string,
    functions: array,       // array of IrFunction
    globals: array,         // array of Global
    string_pool: array,     // array of string
    next_func: int,
    // P7-6 Field struct_idx: struct decl registry for field-name→idx
    // resolution. Parallel arrays so entry i = (struct_names[i],
    // struct_fields[i] = array<string>). Populated by Pass 1 of
    // native_build (and future frontends); consumed by Field/StructInit
    // lowering to replace the hardcoded idx=0 / positional-order fallback.
    struct_names:  array,   // array of string
    struct_fields: array    // array of array<string>
}

fn make_ir_module(name) {
    return IrModule {
        name: name,
        functions: [],
        globals: [],
        string_pool: [],
        next_func: 0,
        struct_names: [],
        struct_fields: []
    }
}

// ── Struct decl registry (P7-6 field_idx resolution prep) ────────
// Idempotent: re-registering same name overwrites field list. This
// lets frontends update if a struct is re-declared within a TU (rare)
// or if the parser emits partial→full progressions.
fn module_add_struct(m, struct_name: string, field_names: array) -> int {
    let mut i = 0
    while i < len(m.struct_names) {
        if m.struct_names[i] == struct_name {
            m.struct_fields[i] = field_names
            return i
        }
        i = i + 1
    }
    push(m.struct_names, struct_name)
    push(m.struct_fields, field_names)
    return len(m.struct_names) - 1
}

// Returns the list of field names for a struct, or [] if unknown.
fn module_find_struct_fields(m, struct_name: string) -> array {
    let mut i = 0
    while i < len(m.struct_names) {
        if m.struct_names[i] == struct_name {
            return m.struct_fields[i]
        }
        i = i + 1
    }
    return []
}

// Returns the positional index of a field within a struct, or -1 if
// the struct or field is unknown. Callers MUST treat -1 as "fallback
// to idx=0" or as an explicit error depending on invocation context.
fn module_find_field_idx(m, struct_name: string, field_name: string) -> int {
    let fields = module_find_struct_fields(m, struct_name)
    let mut i = 0
    while i < len(fields) {
        if fields[i] == field_name {
            return i
        }
        i = i + 1
    }
    return -1
}

fn module_add_function(m, name, params, ret_type) {
    let id = m.next_func
    m.next_func = m.next_func + 1
    push(m.functions, make_ir_function(id, name, params, ret_type))
    return id
}

fn module_find_function(m, name) {
    let i = 0
    while i < len(m.functions) {
        if m.functions[i].name == name {
            return i
        }
        i = i + 1
    }
    return -1
}

fn module_intern_string(m, s) {
    let i = 0
    while i < len(m.string_pool) {
        if m.string_pool[i] == s {
            return i
        }
        i = i + 1
    }
    let idx = len(m.string_pool)
    push(m.string_pool, s)
    return idx
}

fn module_add_global(m, name, ty, is_const) {
    push(m.globals, Global {
        name: name,
        ty: ty,
        has_init: false,
        is_const: is_const
    })
}
