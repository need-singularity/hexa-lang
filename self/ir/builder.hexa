// ═══════════════════════════════════════════════════════════
//  self/ir/builder.hexa — HEXA-IR Builder
//  Port of src/ir/builder.rs (1:1, semantics-preserving)
//  Ergonomic API for constructing IR instructions.
// ═══════════════════════════════════════════════════════════
//
// Depends on: opcodes.hexa, types.hexa, instr.hexa
// (They must be concatenated or loaded together at link time.)
//
// NOTE: Hexa dispatch is by-position; instead of Rust's `&mut self`
// methods we use free functions that take a builder struct. The
// builder holds references to the owning function via its index in
// the module.

struct IrBuilder {
    module_ref: int,    // caller-side module handle (opaque)
    func_idx: int,      // index into module.functions
    current_block: int  // BlockId of the active block
}

// Create a new builder positioned at the entry block.
// If the function has no blocks, a fresh "entry" block is created.
fn builder_new(m, func_idx) {
    let f = m.functions[func_idx]
    let entry = 0
    if len(f.blocks) == 0 {
        entry = func_fresh_block(f, "entry")
    } else {
        entry = f.blocks[0].id
    }
    return IrBuilder {
        module_ref: 0,
        func_idx: func_idx,
        current_block: entry
    }
}

fn builder_switch_to(b, blk) {
    b.current_block = blk
}

fn builder_create_block(m, b, name) {
    let f = m.functions[b.func_idx]
    return func_fresh_block(f, name)
}

// Find the index of the current block inside func.blocks
fn builder_current_block_idx(m, b) {
    let f = m.functions[b.func_idx]
    let i = 0
    while i < len(f.blocks) {
        if f.blocks[i].id == b.current_block {
            return i
        }
        i = i + 1
    }
    return -1
}

fn builder_is_current_block_terminated(m, b) {
    let idx = builder_current_block_idx(m, b)
    if idx < 0 {
        return false
    }
    let f = m.functions[b.func_idx]
    return block_is_terminated(f.blocks[idx])
}

// Emit a raw instruction into the current block, returning its result ValueId.
fn builder_emit(m, b, op_str, operands, ty_str) {
    let f = m.functions[b.func_idx]
    let result = func_fresh_value(f)
    let instr = make_instruction(result, op_str, operands, ty_str)
    let idx = builder_current_block_idx(m, b)
    if idx >= 0 {
        push(f.blocks[idx].instructions, instr)
    }
    return result
}

// ── Arithmetic (Category 1) ────────────────────────────────

fn bld_add(m, b, lhs, rhs, ty) {
    return builder_emit(m, b, "add", [op_value(lhs), op_value(rhs)], ty)
}

fn bld_sub(m, b, lhs, rhs, ty) {
    return builder_emit(m, b, "sub", [op_value(lhs), op_value(rhs)], ty)
}

fn bld_mul(m, b, lhs, rhs, ty) {
    return builder_emit(m, b, "mul", [op_value(lhs), op_value(rhs)], ty)
}

fn bld_div(m, b, lhs, rhs, ty) {
    return builder_emit(m, b, "div", [op_value(lhs), op_value(rhs)], ty)
}

fn bld_modulo(m, b, lhs, rhs, ty) {
    return builder_emit(m, b, "mod", [op_value(lhs), op_value(rhs)], ty)
}

fn bld_neg(m, b, val, ty) {
    return builder_emit(m, b, "neg", [op_value(val)], ty)
}

// ── Memory (Category 2) ────────────────────────────────────

fn bld_load(m, b, ptr, ty) {
    return builder_emit(m, b, "load", [op_value(ptr)], ty)
}

fn bld_store(m, b, ptr, val) {
    return builder_emit(m, b, "store", [op_value(ptr), op_value(val)], "void")
}

fn bld_alloc(m, b, ty) {
    return builder_emit(m, b, "alloc", [], "ptr")
}

fn bld_free(m, b, ptr) {
    return builder_emit(m, b, "free", [op_value(ptr)], "void")
}

fn bld_copy(m, b, val, ty) {
    return builder_emit(m, b, "copy", [op_value(val)], ty)
}

fn bld_move(m, b, val, ty) {
    return builder_emit(m, b, "move", [op_value(val)], ty)
}

// ── Control (Category 3) ───────────────────────────────────

fn bld_jump(m, b, target) {
    return builder_emit(m, b, "jump", [op_block(target)], "void")
}

fn bld_branch(m, b, cond, then_bb, else_bb) {
    let ops = [op_value(cond), op_block(then_bb), op_block(else_bb)]
    return builder_emit(m, b, "branch", ops, "void")
}

fn bld_call(m, b, fid, args, ret_ty) {
    let operands = [op_func(fid)]
    let i = 0
    while i < len(args) {
        push(operands, op_value(args[i]))
        i = i + 1
    }
    return builder_emit(m, b, "call", operands, ret_ty)
}

// P7-7a: syscall builtin. Emits opname "syscall"; operands are all
// value ids: args[0] is the syscall number, args[1..] are the syscall
// arguments (0..6). Backends (ir_to_arm64 / ir_to_x86) dispatch on
// opname "syscall" and emit the native trap sequence via
// self/codegen/syscall.hexa.
fn bld_syscall(m, b, args, ret_ty) {
    let operands = []
    let i = 0
    while i < len(args) {
        push(operands, op_value(args[i]))
        i = i + 1
    }
    return builder_emit(m, b, "syscall", operands, ret_ty)
}

fn bld_ret(m, b, val_or_neg1) {
    let operands = []
    if val_or_neg1 >= 0 {
        push(operands, op_value(val_or_neg1))
    }
    return builder_emit(m, b, "ret", operands, "void")
}

fn bld_phi(m, b, incoming, ty) {
    // incoming: array of [block, value]
    let operands = []
    let i = 0
    while i < len(incoming) {
        let entry = incoming[i]
        push(operands, op_phi_entry(entry[0], entry[1]))
        i = i + 1
    }
    return builder_emit(m, b, "phi", operands, ty)
}

fn bld_switch(m, b, val, cases, default_bb) {
    // cases: array of [case_val, target]
    let operands = [op_value(val)]
    let i = 0
    while i < len(cases) {
        let c = cases[i]
        push(operands, op_switch_case(c[0], c[1]))
        i = i + 1
    }
    push(operands, op_block(default_bb))
    return builder_emit(m, b, "switch", operands, "void")
}

// ── Proof (Category 4) ─────────────────────────────────────

fn bld_assert(m, b, cond) {
    return builder_emit(m, b, "assert", [op_value(cond)], "void")
}

fn bld_assume(m, b, cond) {
    return builder_emit(m, b, "assume", [op_value(cond)], "void")
}

fn bld_invariant(m, b, cond) {
    return builder_emit(m, b, "invariant", [op_value(cond)], "void")
}

fn bld_lifetime_start(m, b, val) {
    return builder_emit(m, b, "lifetime.start", [op_value(val)], "void")
}

fn bld_lifetime_end(m, b, val) {
    return builder_emit(m, b, "lifetime.end", [op_value(val)], "void")
}

fn bld_ownership_transfer(m, b, val, ty) {
    return builder_emit(m, b, "ownership.transfer", [op_value(val)], ty)
}

// ── Convenience: Parameter / constants ─────────────────────

fn bld_load_param(m, b, index, ty) {
    return builder_emit(m, b, "load", [op_param(index)], ty)
}

fn bld_const_i64(m, b, val) {
    return builder_emit(m, b, "load", [op_imm_i64(val)], "i64")
}

fn bld_const_bool(m, b, val) {
    return builder_emit(m, b, "load", [op_imm_bool(val)], "bool")
}

fn bld_const_string(m, b, idx) {
    return builder_emit(m, b, "load", [op_string_ref(idx)], "str")
}

// ── Convenience: Struct / Array ────────────────────────────

fn bld_struct_field(m, b, obj, field_idx, ty) {
    let ops = [op_value(obj), op_field_idx(field_idx)]
    return builder_emit(m, b, "load", ops, ty)
}

fn bld_struct_store_field(m, b, obj, field_idx, val) {
    let ops = [op_value(obj), op_field_idx(field_idx), op_value(val)]
    return builder_emit(m, b, "store", ops, "void")
}

fn bld_array_index(m, b, arr, idx, elem_ty) {
    let ops = [op_value(arr), op_value(idx)]
    return builder_emit(m, b, "load", ops, elem_ty)
}

fn bld_array_store(m, b, arr, idx, val) {
    let ops = [op_value(arr), op_value(idx), op_value(val)]
    return builder_emit(m, b, "store", ops, "void")
}

// ── Comparison helpers (Sub opcode + CmpKind tag → Bool) ──
// Comparisons reuse Sub opcode to keep J₂=24 intact.

fn bld_emit_cmp(m, b, lhs, rhs, kind_str) {
    let ops = [op_value(lhs), op_value(rhs), op_cmp(kind_str)]
    return builder_emit(m, b, "sub", ops, "bool")
}

fn bld_cmp_eq(m, b, lhs, rhs) {
    return bld_emit_cmp(m, b, lhs, rhs, "eq")
}

fn bld_cmp_ne(m, b, lhs, rhs) {
    return bld_emit_cmp(m, b, lhs, rhs, "ne")
}

fn bld_cmp_lt(m, b, lhs, rhs) {
    return bld_emit_cmp(m, b, lhs, rhs, "lt")
}

fn bld_cmp_gt(m, b, lhs, rhs) {
    return bld_emit_cmp(m, b, lhs, rhs, "gt")
}

fn bld_cmp_le(m, b, lhs, rhs) {
    return bld_emit_cmp(m, b, lhs, rhs, "le")
}

fn bld_cmp_ge(m, b, lhs, rhs) {
    return bld_emit_cmp(m, b, lhs, rhs, "ge")
}

// ── Logical helpers (via mul/add/sub over i64/bool) ───────

fn bld_and(m, b, lhs, rhs) {
    return bld_mul(m, b, lhs, rhs, "bool")
}

fn bld_or(m, b, lhs, rhs) {
    let sum = bld_add(m, b, lhs, rhs, "i64")
    let prod = bld_mul(m, b, lhs, rhs, "i64")
    return bld_sub(m, b, sum, prod, "bool")
}

fn bld_xor(m, b, lhs, rhs) {
    let sum = bld_add(m, b, lhs, rhs, "i64")
    let prod = bld_mul(m, b, lhs, rhs, "i64")
    let two_prod = bld_add(m, b, prod, prod, "i64")
    return bld_sub(m, b, sum, two_prod, "i64")
}
