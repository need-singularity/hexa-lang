// ═══════════════════════════════════════════════════════════
//  self/ir/types.hexa — HEXA-IR Type system (σ=12 types)
//  Port of src/ir/types.rs (1:1, semantics-preserving)
//  σ-τ=8 primitive + τ=4 compound = σ=12 total
// ═══════════════════════════════════════════════════════════

// IrType — kind is a string tag ("i8"..."fn") with payload fields
// when applicable. Hexa has no parametric enums, so we use a struct
// with a discriminant string (same shape as boot_lexer.hexa uses).
struct IrType {
    kind: string,       // "i8" | "i16" | ... | "array" | "struct" | "enum" | "fn" | "void" | "ptr" | "str"
    elem: int,          // for ptr/array: index into a side table (0 = none)
    size: int,          // for sized arrays; 0 = unsized slice
    name: string        // for struct/enum
}

// Named struct type with ordered fields
struct StructType {
    name: string,
    fields: array  // array of [name, IrType]
}

// Enum type with tagged variants
struct EnumType {
    name: string,
    variants: array  // array of [name, IrType|none]
}

// ── Type constants ──────────────────────────────────────────

fn ir_type_count() {
    return 12
}

fn ir_type_primitive_count() {
    return 8
}

fn ir_type_compound_count() {
    return 4
}

// ── Constructors ────────────────────────────────────────────

fn ir_ty_i8() {
    return IrType { kind: "i8", elem: 0, size: 0, name: "" }
}

fn ir_ty_i16() {
    return IrType { kind: "i16", elem: 0, size: 0, name: "" }
}

fn ir_ty_i32() {
    return IrType { kind: "i32", elem: 0, size: 0, name: "" }
}

fn ir_ty_i64() {
    return IrType { kind: "i64", elem: 0, size: 0, name: "" }
}

fn ir_ty_f32() {
    return IrType { kind: "f32", elem: 0, size: 0, name: "" }
}

fn ir_ty_f64() {
    return IrType { kind: "f64", elem: 0, size: 0, name: "" }
}

fn ir_ty_bool() {
    return IrType { kind: "bool", elem: 0, size: 0, name: "" }
}

fn ir_ty_byte() {
    return IrType { kind: "byte", elem: 0, size: 0, name: "" }
}

fn ir_ty_void() {
    return IrType { kind: "void", elem: 0, size: 0, name: "" }
}

fn ir_ty_str() {
    return IrType { kind: "str", elem: 0, size: 0, name: "" }
}

// ── Predicates ──────────────────────────────────────────────

fn ir_ty_is_integer(t) {
    let k = t.kind
    if k == "i8" {
        return true
    }
    if k == "i16" {
        return true
    }
    if k == "i32" {
        return true
    }
    if k == "i64" {
        return true
    }
    if k == "byte" {
        return true
    }
    return false
}

fn ir_ty_is_float(t) {
    let k = t.kind
    if k == "f32" {
        return true
    }
    if k == "f64" {
        return true
    }
    return false
}

fn ir_ty_is_numeric(t) {
    if ir_ty_is_integer(t) {
        return true
    }
    return ir_ty_is_float(t)
}

fn ir_ty_is_primitive(t) {
    if ir_ty_is_numeric(t) {
        return true
    }
    let k = t.kind
    if k == "bool" {
        return true
    }
    if k == "byte" {
        return true
    }
    return false
}

// ── Size / alignment ────────────────────────────────────────

fn align8(n) {
    return (n + 7) - ((n + 7) % 8)
}

fn ir_ty_size_bytes(t) {
    let k = t.kind
    if k == "i8" {
        return 1
    }
    if k == "byte" {
        return 1
    }
    if k == "bool" {
        return 1
    }
    if k == "i16" {
        return 2
    }
    if k == "i32" {
        return 4
    }
    if k == "f32" {
        return 4
    }
    if k == "i64" {
        return 8
    }
    if k == "f64" {
        return 8
    }
    if k == "ptr" {
        return 8
    }
    if k == "str" {
        return 16
    }
    if k == "void" {
        return 0
    }
    if k == "fn" {
        return 8
    }
    if k == "array" {
        // unsized slice → ptr + len; fixed array handled externally
        if t.size == 0 {
            return 16
        }
        return 8 * t.size
    }
    // struct/enum sizes computed by caller with field tables
    return 8
}

fn ir_ty_align_bytes(t) {
    let k = t.kind
    if k == "i8" {
        return 1
    }
    if k == "byte" {
        return 1
    }
    if k == "bool" {
        return 1
    }
    if k == "i16" {
        return 2
    }
    if k == "i32" {
        return 4
    }
    if k == "f32" {
        return 4
    }
    return 8
}

// ── Display ─────────────────────────────────────────────────

fn ir_ty_to_string(t) {
    let k = t.kind
    if k == "struct" {
        return t.name
    }
    if k == "enum" {
        return t.name
    }
    if k == "array" {
        return "[]"
    }
    if k == "ptr" {
        return "*"
    }
    if k == "fn" {
        return "fn"
    }
    return k
}
