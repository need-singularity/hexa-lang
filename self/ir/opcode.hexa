// HEXA-IR Opcode definitions — J₂=24 opcodes (τ=4 categories × n=6 each)
// Every opcode derives from n=6 arithmetic. Zero arbitrary choices.
// Port of src/ir/opcode.rs — self-host parity.

// τ=4 categories × n=6 each = J₂(6) = 24 total opcodes.
// Category indices: 0=arithmetic, 1=memory, 2=control, 3=proof.
// Within each category the six opcodes are ordered so that the last one
// is the "heaviest" (highest-side-effect or terminator).

pub let mut OPCODE_COUNT = 24
pub let mut OPCODE_CATEGORIES = 4
pub let mut OPCODE_PER_CATEGORY = 6

// ── Category 0: arithmetic ──
pub let mut OP_ADD = 0
pub let mut OP_SUB = 1
pub let mut OP_MUL = 2
pub let mut OP_DIV = 3
pub let mut OP_MOD = 4
pub let mut OP_NEG = 5

// ── Category 1: memory ──
pub let mut OP_LOAD  = 6
pub let mut OP_STORE = 7
pub let mut OP_ALLOC = 8
pub let mut OP_FREE  = 9
pub let mut OP_COPY  = 10
pub let mut OP_MOVE  = 11

// ── Category 2: control ──
pub let mut OP_JUMP   = 12
pub let mut OP_BRANCH = 13
pub let mut OP_CALL   = 14
pub let mut OP_RETURN = 15
pub let mut OP_PHI    = 16
pub let mut OP_SWITCH = 17

// ── Category 3: proof ──
pub let mut OP_ASSERT              = 18
pub let mut OP_ASSUME              = 19
pub let mut OP_INVARIANT           = 20
pub let mut OP_LIFETIME_START      = 21
pub let mut OP_LIFETIME_END        = 22
pub let mut OP_OWNERSHIP_TRANSFER  = 23

// Category index (0..τ=4).
fn opcode_category(op) {
    return op / 6
}

// Index within category (0..n=6).
fn opcode_index_in_category(op) {
    return op % 6
}

// Whether this opcode has side effects.
fn opcode_has_side_effect(op) {
    if op == OP_STORE { return true }
    if op == OP_ALLOC { return true }
    if op == OP_FREE { return true }
    if op == OP_COPY { return true }
    if op == OP_MOVE { return true }
    if op == OP_CALL { return true }
    if op == OP_OWNERSHIP_TRANSFER { return true }
    return false
}

// Whether this opcode is a terminator (ends a basic block).
fn opcode_is_terminator(op) {
    if op == OP_JUMP { return true }
    if op == OP_BRANCH { return true }
    if op == OP_RETURN { return true }
    if op == OP_SWITCH { return true }
    return false
}

// Whether this is a proof-related opcode (compile-time only).
fn opcode_is_proof(op) {
    return opcode_category(op) == 3
}

// Category name ("arithmetic" | "memory" | "control" | "proof").
fn opcode_category_name(op) {
    let c = opcode_category(op)
    if c == 0 { return "arithmetic" }
    if c == 1 { return "memory" }
    if c == 2 { return "control" }
    if c == 3 { return "proof" }
    return "?"
}

// Short mnemonic for display / assembly output.
fn opcode_display(op) {
    if op == OP_ADD { return "add" }
    if op == OP_SUB { return "sub" }
    if op == OP_MUL { return "mul" }
    if op == OP_DIV { return "div" }
    if op == OP_MOD { return "mod" }
    if op == OP_NEG { return "neg" }
    if op == OP_LOAD { return "load" }
    if op == OP_STORE { return "store" }
    if op == OP_ALLOC { return "alloc" }
    if op == OP_FREE { return "free" }
    if op == OP_COPY { return "copy" }
    if op == OP_MOVE { return "move" }
    if op == OP_JUMP { return "jump" }
    if op == OP_BRANCH { return "branch" }
    if op == OP_CALL { return "call" }
    if op == OP_RETURN { return "ret" }
    if op == OP_PHI { return "phi" }
    if op == OP_SWITCH { return "switch" }
    if op == OP_ASSERT { return "assert" }
    if op == OP_ASSUME { return "assume" }
    if op == OP_INVARIANT { return "invariant" }
    if op == OP_LIFETIME_START { return "lifetime.start" }
    if op == OP_LIFETIME_END { return "lifetime.end" }
    if op == OP_OWNERSHIP_TRANSFER { return "ownership.transfer" }
    return "?"
}

// ── Self-tests (mirror src/ir/opcode.rs `mod tests`) ──
fn _opcode_test_j2_24() {
    assert OPCODE_COUNT == 24
}
fn _opcode_test_tau_4_categories() {
    assert opcode_category(OP_ADD) == 0
    assert opcode_category(OP_LOAD) == 1
    assert opcode_category(OP_JUMP) == 2
    assert opcode_category(OP_ASSERT) == 3
}
fn _opcode_test_n6_per_category() {
    assert opcode_index_in_category(OP_NEG) == 5
    assert opcode_index_in_category(OP_MOVE) == 5
    assert opcode_index_in_category(OP_SWITCH) == 5
    assert opcode_index_in_category(OP_OWNERSHIP_TRANSFER) == 5
}
fn _opcode_test_terminators() {
    assert opcode_is_terminator(OP_JUMP)
    assert opcode_is_terminator(OP_BRANCH)
    assert opcode_is_terminator(OP_RETURN)
    assert opcode_is_terminator(OP_SWITCH)
    assert !opcode_is_terminator(OP_ADD)
}
fn _opcode_test_proof_opcodes() {
    assert opcode_is_proof(OP_ASSERT)
    assert opcode_is_proof(OP_ASSUME)
    assert opcode_is_proof(OP_INVARIANT)
    assert opcode_is_proof(OP_LIFETIME_START)
    assert opcode_is_proof(OP_LIFETIME_END)
    assert opcode_is_proof(OP_OWNERSHIP_TRANSFER)
    assert !opcode_is_proof(OP_ADD)
}

fn opcode_run_tests() {
    _opcode_test_j2_24()
    _opcode_test_tau_4_categories()
    _opcode_test_n6_per_category()
    _opcode_test_terminators()
    _opcode_test_proof_opcodes()
    println("opcode: 5 tests PASS")
}
