// ═══════════════════════════════════════════════════════════
//  self/ir/mod.hexa — HEXA-IR module index (R14 참조만)
//  Port of src/ir/mod.rs
//
//  HEXA-IR: Self-designed Intermediate Representation.
//  n=6 derived constants:
//    - J₂=24 opcodes (τ=4 categories × n=6 each)
//    - σ=12 types (8 primitive + 4 compound)
//    - σ=12 optimization passes (3 waves × 4)
//    - Egyptian memory: 1/2 + 1/3 + 1/6 = 1
//  No LLVM. No Cranelift. Pure self-built.
// ═══════════════════════════════════════════════════════════
//
// Submodules:
//   opcodes.hexa  — OpCode enum + category/mnemonic helpers
//   types.hexa    — IrType + StructType + EnumType + size/align
//   instr.hexa    — ValueId/BlockId/FuncId, Operand, Instruction,
//                   BasicBlock, IrFunction, IrModule
//   builder.hexa  — IrBuilder + bld_* emission helpers
//   print.hexa    — print_module / print_function / print_block
//
// Hexa has no `use`; callers concatenate files at link time (see
// self/hexa_build.hexa). This file exists for parity with mod.rs.

fn ir_mod_info() {
    return "HEXA-IR: J2=24 opcodes, sigma=12 types, tau=4 categories"
}
