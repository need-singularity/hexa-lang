// self/test_array_pure.hexa -- Tests for self/runtime/array_pure.hexa
//
// Run: build/hexa_stage0 self/test_array_pure.hexa
//
// Note: functions inlined here because stage0 interpreter treats
// `use "..."` as NoOp. When flatten_imports is used for native
// builds, the canonical source is self/runtime/array_pure.hexa.

// ── inlined from self/runtime/array_pure.hexa ─────────────────────

fn array_slice_pure(arr, start_idx, end_idx) {
    if type_of(arr) != "array" { return [] }
    let n = len(arr)
    let mut a = start_idx
    let mut b = end_idx
    if a < 0 { a = 0 }
    if b > n { b = n }
    if a > b { a = b }
    let mut out = []
    let mut i = a
    while i < b {
        out = out.push(arr[i])
        i = i + 1
    }
    out
}

fn array_index_of_pure(arr, item) {
    if type_of(arr) != "array" { return -1 }
    let n = len(arr)
    let mut i = 0
    while i < n {
        if arr[i] == item { return i }
        i = i + 1
    }
    -1
}

fn array_contains_pure(arr, item) {
    array_index_of_pure(arr, item) >= 0
}

fn array_reverse_pure(arr) {
    if type_of(arr) != "array" { return [] }
    let n = len(arr)
    let mut out = []
    let mut i = n - 1
    while i >= 0 {
        out = out.push(arr[i])
        i = i - 1
    }
    out
}

fn array_first_pure(arr) {
    if type_of(arr) != "array" { return nil }
    if len(arr) == 0 { return nil }
    arr[0]
}

fn array_last_pure(arr) {
    if type_of(arr) != "array" { return nil }
    let n = len(arr)
    if n == 0 { return nil }
    arr[n - 1]
}

fn array_flatten_pure(arr) {
    if type_of(arr) != "array" { return [] }
    let mut out = []
    let n = len(arr)
    let mut i = 0
    while i < n {
        let elem = arr[i]
        if type_of(elem) == "array" {
            let m = len(elem)
            let mut j = 0
            while j < m {
                out = out.push(elem[j])
                j = j + 1
            }
        } else {
            out = out.push(elem)
        }
        i = i + 1
    }
    out
}

fn array_unique_pure(arr) {
    if type_of(arr) != "array" { return [] }
    let mut out = []
    let n = len(arr)
    let mut i = 0
    while i < n {
        let elem = arr[i]
        if array_index_of_pure(out, elem) < 0 {
            out = out.push(elem)
        }
        i = i + 1
    }
    out
}

fn array_concat_pure(a, b) {
    let mut out = []
    if type_of(a) == "array" {
        let mut i = 0
        while i < len(a) {
            out = out.push(a[i])
            i = i + 1
        }
    }
    if type_of(b) == "array" {
        let mut j = 0
        while j < len(b) {
            out = out.push(b[j])
            j = j + 1
        }
    }
    out
}

// ── end inlined ───────────────────────────────────────────────────

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  array_pure.hexa — test runner")
println("═══════════════════════════════════════════════════════")

// ── 1. array_slice_pure ─────────────────────────────────────
println("")
println("--- array_slice_pure ---")
check("slice middle", array_slice_pure([1,2,3,4,5], 1, 4), [2,3,4])
check("slice full", array_slice_pure([1,2,3], 0, 3), [1,2,3])
check("slice empty range", array_slice_pure([1,2,3], 1, 1), [])
check("slice neg start clips", array_slice_pure([1,2,3,4], -2, 2), [1,2])
check("slice end over clips", array_slice_pure([1,2], 0, 99), [1,2])
check("slice start>end empty", array_slice_pure([1,2,3], 2, 1), [])
check("slice empty array", array_slice_pure([], 0, 1), [])
check("slice non-array", array_slice_pure("str", 0, 1), [])

// ── 2. array_index_of_pure ──────────────────────────────────
println("")
println("--- array_index_of_pure ---")
check("index_of hit", array_index_of_pure([10, 20, 30], 20), 1)
check("index_of first", array_index_of_pure([10, 20, 10], 10), 0)
check("index_of miss", array_index_of_pure([10, 20], 99), -1)
check("index_of empty", array_index_of_pure([], 1), -1)
check("index_of non-array", array_index_of_pure("str", "s"), -1)
check("index_of strings", array_index_of_pure(["a","b","c"], "b"), 1)

// ── 3. array_contains_pure ──────────────────────────────────
println("")
println("--- array_contains_pure ---")
check("contains hit", array_contains_pure([1,2,3], 2), true)
check("contains miss", array_contains_pure([1,2,3], 99), false)
check("contains empty", array_contains_pure([], 1), false)
check("contains non-array", array_contains_pure(42, 42), false)

// ── 4. array_reverse_pure ───────────────────────────────────
println("")
println("--- array_reverse_pure ---")
check("reverse basic", array_reverse_pure([1,2,3]), [3,2,1])
check("reverse single", array_reverse_pure([7]), [7])
check("reverse empty", array_reverse_pure([]), [])
check("reverse non-array", array_reverse_pure("str"), [])

// ── 5. array_first_pure / array_last_pure ───────────────────
println("")
println("--- array_first_pure / array_last_pure ---")
check("first basic", array_first_pure([10,20,30]), 10)
check("first single", array_first_pure([7]), 7)
check("first empty", array_first_pure([]), nil)
check("first non-array", array_first_pure(42), nil)
check("last basic", array_last_pure([10,20,30]), 30)
check("last single", array_last_pure([7]), 7)
check("last empty", array_last_pure([]), nil)
check("last non-array", array_last_pure(42), nil)

// ── 6. array_flatten_pure ───────────────────────────────────
println("")
println("--- array_flatten_pure ---")
check("flatten pairs", array_flatten_pure([[1,2],[3,4]]), [1,2,3,4])
check("flatten mixed", array_flatten_pure([[1],2,[3,4]]), [1,2,3,4])
check("flatten empty", array_flatten_pure([]), [])
check("flatten empties", array_flatten_pure([[],[]]), [])
check("flatten non-array", array_flatten_pure("str"), [])

// ── 7. array_unique_pure ────────────────────────────────────
println("")
println("--- array_unique_pure ---")
check("unique basic", array_unique_pure([1,2,1,3,2,3]), [1,2,3])
check("unique all-same", array_unique_pure([7,7,7]), [7])
check("unique empty", array_unique_pure([]), [])
check("unique no-dups", array_unique_pure([1,2,3]), [1,2,3])
check("unique strings", array_unique_pure(["a","b","a","c"]), ["a","b","c"])

// ── 8. array_concat_pure ────────────────────────────────────
println("")
println("--- array_concat_pure ---")
check("concat basic", array_concat_pure([1,2],[3,4]), [1,2,3,4])
check("concat left empty", array_concat_pure([],[1,2]), [1,2])
check("concat right empty", array_concat_pure([1,2],[]), [1,2])
check("concat both empty", array_concat_pure([],[]), [])
check("concat non-array left", array_concat_pure("x",[1,2]), [1,2])
check("concat non-array right", array_concat_pure([1,2],"x"), [1,2])

// ── Summary ─────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    println("FAIL")
    exit(1)
}
println("ALL PASS")
