// ═══════════════════════════════════════════════════════════════
//  test_liquid_nn.hexa — Liquid NN / CfC (#253) tests
//
//  Verifies:
//    1. softplus numerics
//    2. Single-cell fixed-point (zero input, x=A → stays at A)
//    3. Zero input decay towards A (monotone)
//    4. Positive input → faster decay
//    5. Large negative input (u<0) + positive w → possibly outward growth
//    6. Layer init shapes
//    7. Layer step output length matches n_neurons
//    8. Multi-step forward convergence (constant input)
//    9. Trajectory length = steps+1
//   10. Trajectory[0] = x0
//   11. Stability: no NaN/Inf on large tau
//
//  Run: ./hexa self/test_liquid_nn.hexa
// ═══════════════════════════════════════════════════════════════

// -- inlined from self/ml/liquid_nn.hexa --
// codegen import not wired for test files

// ═══════════════════════════════════════════════════════════════
//  self/ml/liquid_nn.hexa — Liquid NN / CfC (#253)
//
//  Closed-form Continuous-time RNN (CfC) — Hasani et al. 2022.
//
//  For each neuron i the hidden state follows a closed-form solution of
//  a linear ODE with a learnable time-constant and input-gated decay:
//
//    x_i(t+1) = (x_i(t) - A_i) * exp( -(w_i * u(t) + softplus(b_i)) * tau )
//              + A_i
//
//  where
//    - A_i  : steady-state value (learnable)
//    - w_i  : input-dependent decay rate (learnable)
//    - b_i  : decay bias, gated through softplus(b_i) = ln(1+exp(b_i))
//    - tau  : integration step (1.0 default)
//    - u(t) : input stimulus (can be a scalar drive)
//
//  This is the "closed-form" in CfC: no numerical ODE integrator needed.
//
//  Extension: multi-neuron with per-neuron A, b, w and a readout matrix.
//
//  AI-NATIVE attrs:
//    @pure  — closed-form step is stateless
// ═══════════════════════════════════════════════════════════════

// ── helpers ───────────────────────────────────────────────────
fn cfc_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn cfc_zeros(n) {
    let mut v = []
    for _i in 0..n { v = v + [0.0] }
    return v
}

fn cfc_zeros2d(m, n) {
    let mut w = []
    for _i in 0..m { w = w + [cfc_zeros(n)] }
    return w
}

fn cfc_hash(seed, i, j) {
    let h = (seed * 2654435761 + i * 1315423911 + j * 731) % 10007
    return to_float(h) / 10007.0 - 0.5
}

// softplus(b) = ln(1 + exp(b))
// For numerical stability: if b > 20, softplus ≈ b; if b < -20, softplus ≈ exp(b)
@pure
fn cfc_softplus(b) {
    if b > 20.0 { return b }
    if b < (0.0 - 20.0) { return exp(b) }
    return log(1.0 + exp(b))
}

// safe_exp with clamp
@pure
fn cfc_safe_exp(x) {
    if x > 50.0 { return exp(50.0) }
    if x < (0.0 - 50.0) { return 0.0 }
    return exp(x)
}

// ═══════════════════════════════════════════════════════════════
//  (1) Single-neuron closed-form update
//
//  x_new = (x - A) * exp(-(w*u + softplus(b)) * tau) + A
// ═══════════════════════════════════════════════════════════════
@pure
fn cfc_cell_step(x, u, A, w, b, tau) {
    let sp = cfc_softplus(b)
    let rate = w * u + sp
    let neg_rate_tau = 0.0 - rate * tau
    let decay = cfc_safe_exp(neg_rate_tau)
    let x_minus_A = x - A
    return x_minus_A * decay + A
}

// ═══════════════════════════════════════════════════════════════
//  (2) Multi-neuron layer
//
//  params: dict with
//    A   : [n] steady states
//    w   : [n] input decay weights
//    b   : [n] decay biases
//    W_in: [n x d] input projection (u_i = W_in[i] . input + b_in[i])
//    b_in: [n]
//  State:  x : [n]
// ═══════════════════════════════════════════════════════════════
fn cfc_init_layer(n_neurons, input_dim, seed) {
    let mut A = cfc_zeros(n_neurons)
    let mut w = cfc_zeros(n_neurons)
    let mut b = cfc_zeros(n_neurons)
    let mut W_in = cfc_zeros2d(n_neurons, input_dim)
    let mut b_in = cfc_zeros(n_neurons)

    for i in 0..n_neurons {
        A[i] = 0.5 * cfc_hash(seed + 1, i, 0)
        w[i] = 0.3 + 0.2 * cfc_hash(seed + 2, i, 1)
        b[i] = 0.1 * cfc_hash(seed + 3, i, 2)
        for j in 0..input_dim {
            W_in[i][j] = 0.5 * cfc_hash(seed + 4, i, j)
        }
        b_in[i] = 0.1 * cfc_hash(seed + 5, i, 0)
    }

    let layer = #{
        "A": A,
        "w": w,
        "b": b,
        "W_in": W_in,
        "b_in": b_in,
        "n": n_neurons,
        "d": input_dim
    }
    return layer
}

// Forward 1 step given input vector and state x
fn cfc_layer_step(layer, x, input, tau) {
    let n = layer["n"]
    let d = layer["d"]
    let A_arr = layer["A"]
    let w_arr = layer["w"]
    let b_arr = layer["b"]
    let W_in = layer["W_in"]
    let b_in = layer["b_in"]

    let mut x_new = cfc_zeros(n)
    for i in 0..n {
        // compute input drive u_i = W_in[i] . input + b_in[i]
        let mut u_i = b_in[i]
        for j in 0..d {
            u_i = u_i + W_in[i][j] * input[j]
        }
        x_new[i] = cfc_cell_step(x[i], u_i, A_arr[i], w_arr[i], b_arr[i], tau)
    }
    return x_new
}

// ═══════════════════════════════════════════════════════════════
//  (3) Multi-step unrolled forward over a sequence of inputs
//  inputs: [T x d]  → returns final state or all states
// ═══════════════════════════════════════════════════════════════
fn cfc_forward_sequence(layer, x0, inputs, tau) {
    let T = len(inputs)
    let n = layer["n"]
    let mut x = cfc_zeros(n)
    for i in 0..n { x[i] = x0[i] }
    for t in 0..T {
        x = cfc_layer_step(layer, x, inputs[t], tau)
    }
    return x
}

// Returns all hidden states along the trajectory
fn cfc_trajectory(layer, x0, inputs, tau) {
    let T = len(inputs)
    let n = layer["n"]
    let mut x = cfc_zeros(n)
    for i in 0..n { x[i] = x0[i] }
    let mut traj = [x]
    for t in 0..T {
        x = cfc_layer_step(layer, x, inputs[t], tau)
        traj = traj + [x]
    }
    return traj
}


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn approx(a, b, eps) {
    return fabs(a - b) < eps
}

println("═══════════════════════════════════════════════════════")
println("  Liquid NN / CfC (#253) Test Suite")
println("═══════════════════════════════════════════════════════")

// ── Test 1: softplus numerics ────────────────────────────────
check("softplus(0) = ln(2)", approx(cfc_softplus(0.0), 0.6931471805599453, 1.0e-6))
check("softplus(10) ≈ 10", approx(cfc_softplus(10.0), 10.000045, 1.0e-3))
check("softplus(-10) ≈ 0", cfc_softplus(0.0 - 10.0) < 1.0e-3)

// ── Test 2: Fixed point — x=A, zero input, b>0, tau>0 ───────
// x_new = (A-A)*decay + A = A
let A_val = 0.7
let x_fp = cfc_cell_step(A_val, 0.0, A_val, 0.5, 0.1, 1.0)
check("fixed point at A", approx(x_fp, A_val, 1.0e-10))

// ── Test 3: Decay towards A from x0 ≠ A ─────────────────────
// With u=0, rate=softplus(b)>0, so exp decay → x moves toward A
let x0 = 1.0
let A = 0.0
let x1 = cfc_cell_step(x0, 0.0, A, 0.5, 0.5, 1.0)
check("decay toward A", fabs(x1 - A) < fabs(x0 - A))
check("same sign movement", (x0 - A) * (x1 - A) > 0.0)

// ── Test 4: Larger positive input → faster decay ─────────────
let x2 = cfc_cell_step(x0, 2.0, A, 0.5, 0.5, 1.0)
check("faster decay with larger input", fabs(x2 - A) < fabs(x1 - A))

// ── Test 5: Small negative input → slower decay ─────────────
let x3 = cfc_cell_step(x0, 0.0 - 0.5, A, 0.5, 0.5, 1.0)
// rate = 0.5*(-0.5) + softplus(0.5) = -0.25 + 0.974 = 0.724
// still positive so decays
// rate_x1 = 0 + 0.974 = 0.974 → x1 decays faster
check("smaller rate → slower decay", fabs(x3 - A) > fabs(x1 - A))

// ── Test 6: Layer init shapes ───────────────────────────────
let layer = cfc_init_layer(3, 2, 42)
check("layer n=3", layer["n"] == 3)
check("layer d=2", layer["d"] == 2)
check("A length 3", len(layer["A"]) == 3)
check("W_in 3x2", len(layer["W_in"]) == 3 && len(layer["W_in"][0]) == 2)

// ── Test 7: Layer step output length ────────────────────────
let x0_layer = [0.0, 0.0, 0.0]
let input = [0.5, 0.3]
let x_step = cfc_layer_step(layer, x0_layer, input, 1.0)
check("layer step output length", len(x_step) == 3)

// ── Test 8: Multi-step forward with constant input converges ─
// For a stable CfC, repeated constant input makes x converge
let inputs_const = [[0.5, 0.3], [0.5, 0.3], [0.5, 0.3], [0.5, 0.3], [0.5, 0.3]]
let x_final = cfc_forward_sequence(layer, x0_layer, inputs_const, 1.0)
check("final state length", len(x_final) == 3)
// state should differ from zero initial (some dynamics)
let mut nonzero = false
for i in 0..3 {
    if fabs(x_final[i]) > 1.0e-8 {
        nonzero = true
    }
}
check("state drifted from x0", nonzero)

// ── Test 9: Trajectory length ───────────────────────────────
let traj = cfc_trajectory(layer, x0_layer, inputs_const, 1.0)
check("trajectory length = T+1", len(traj) == 6)

// ── Test 10: Trajectory[0] = x0 ─────────────────────────────
check("traj[0] = x0[0]", approx(traj[0][0], 0.0, 1.0e-12))
check("traj[0] = x0[1]", approx(traj[0][1], 0.0, 1.0e-12))
check("traj[0] = x0[2]", approx(traj[0][2], 0.0, 1.0e-12))

// ── Test 11: Stability — large tau should not blow up ──────
let layer2 = cfc_init_layer(2, 1, 7)
let x0_2 = [0.5, 0.5]
let input_big_tau = [1.0]
let x_big = cfc_layer_step(layer2, x0_2, input_big_tau, 100.0)
let mut stable = true
for i in 0..2 {
    if fabs(x_big[i]) > 1000.0 {
        stable = false
    }
}
check("large tau remains bounded", stable)

// ── Test 12: Trajectory convergence — states stop changing ──
// With settled dynamics, later traj steps should be close
let delta_last = fabs(traj[5][0] - traj[4][0]) + fabs(traj[5][1] - traj[4][1]) + fabs(traj[5][2] - traj[4][2])
let delta_first = fabs(traj[1][0] - traj[0][0]) + fabs(traj[1][1] - traj[0][1]) + fabs(traj[1][2] - traj[0][2])
check("later deltas ≤ earlier deltas", delta_last <= delta_first + 1.0e-8)

// ═══════════════════════════════════════════════════════════════
println("")
println("pass=" + to_string(pass_count) + " fail=" + to_string(fail_count))
if fail_count == 0 {
    println("ALL PASS")
} else {
    println("FAILED")
}
println(to_string(pass_count) + " passed")
