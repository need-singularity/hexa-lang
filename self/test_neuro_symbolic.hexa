// ═══════════════════════════════════════════════════════════════════
//  self/ml/neuro_symbolic.hexa — Neuro-Symbolic (#234)
//
//  Neural + symbolic reasoning integration — differentiable logic programs.
//
//  Implements:
//    1. Fuzzy logic operators: AND (product), OR (max/probsum), NOT (1-x)
//    2. Rule evaluation: differentiable forward chaining
//    3. Predicate embedding: map symbols to dense vectors
//    4. Neural rule learning: learn rule weights via gradient descent
//    5. Proof trace: extract symbolic explanation from neural activations
//    6. Knowledge base: facts + rules + inference
//
//  API (pure):
//    ns_fuzzy_and(a, b)                   -> float  (product T-norm)
//    ns_fuzzy_or(a, b)                    -> float  (probabilistic sum)
//    ns_fuzzy_not(a)                      -> float  (1 - a)
//    ns_fuzzy_and_min(a, b)               -> float  (Godel T-norm)
//    ns_fuzzy_or_max(a, b)               -> float  (Godel T-conorm)
//    ns_fuzzy_implies(a, b)               -> float  (Godel implication)
//    ns_predicate_embed(pred_id, embed_w) -> [float]
//    ns_similarity(a, b)                  -> float
//    ns_rule_fire(body_truths, weight)    -> float
//    ns_forward_chain(facts, rules, n)    -> [float]
//    ns_neural_rule_score(head_emb, body_embs, w, b) -> float
//    ns_grad_rule_weight(facts, rules, idx, eps) -> float
//    ns_proof_trace(facts, rules, query_idx) -> [int]
//    ns_unify(a, b, threshold)            -> bool
//    ns_knowledge_base_query(facts, rules, query, steps) -> float
//
//  AI-NATIVE attrs:
//    @pure  — no side effects
//    @hot   — called every inference step
// ═══════════════════════════════════════════════════════════════════

// ── helpers ──────────────────────────────────────────────────────

fn ns_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn ns_sqrt(x) {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    for _i in 0..30 {
        g = (g + x / g) / 2.0
    }
    return g
}

fn ns_exp(x) {
    let mut v = x
    if v > 20.0 { v = 20.0 }
    if v < -20.0 { v = -20.0 }
    let mut result = 1.0
    let mut term = 1.0
    for i in 1..30 {
        term = term * v / to_float(i)
        result = result + term
    }
    if result < 0.0 { return 0.0 }
    return result
}

fn ns_log(x) {
    if x <= 0.0 { return -20.0 }
    let mut y = 0.0
    if x > 1.0 { y = x / 2.0 }
    if x > 10.0 { y = 2.3 }
    for _i in 0..60 {
        let ey = ns_exp(y)
        if ey < 1.0e-15 { y = y + 1.0 } else {
            y = y + (x - ey) / ey
        }
    }
    return y
}

fn ns_zeros(n) {
    let mut v = []
    for _i in 0..n { v = v + [0.0] }
    return v
}

fn ns_zeros_int(n) {
    let mut v = []
    for _i in 0..n { v = v + [0] }
    return v
}

// ═══════════════════════════════════════════════════════════════════
//  Vector Operations
// ═══════════════════════════════════════════════════════════════════

@pure
fn ns_dot(a, b) {
    let n = len(a)
    let mut s = 0.0
    for i in 0..n {
        s = s + a[i] * b[i]
    }
    return s
}

@pure
fn ns_norm(v) {
    return ns_sqrt(ns_dot(v, v))
}

@pure
fn ns_scale(v, s) {
    let n = len(v)
    let mut out = ns_zeros(n)
    for i in 0..n {
        out[i] = v[i] * s
    }
    return out
}

@pure
fn ns_add(a, b) {
    let n = len(a)
    let mut out = ns_zeros(n)
    for i in 0..n {
        out[i] = a[i] + b[i]
    }
    return out
}

@pure
fn ns_sub(a, b) {
    let n = len(a)
    let mut out = ns_zeros(n)
    for i in 0..n {
        out[i] = a[i] - b[i]
    }
    return out
}

// ═══════════════════════════════════════════════════════════════════
//  1. Fuzzy Logic Operators
//
//  All truth values are in [0, 1].
//  Multiple T-norm/T-conorm implementations.
// ═══════════════════════════════════════════════════════════════════

// Product T-norm: AND(a, b) = a * b (differentiable)
@pure @hot
fn ns_fuzzy_and(a, b) {
    return a * b
}

// Godel T-norm: AND(a, b) = min(a, b) (non-differentiable at a==b)
@pure
fn ns_fuzzy_and_min(a, b) {
    if a < b { return a }
    return b
}

// Lukasiewicz T-norm: AND(a, b) = max(0, a + b - 1)
@pure
fn ns_fuzzy_and_luk(a, b) {
    let v = a + b - 1.0
    if v < 0.0 { return 0.0 }
    return v
}

// Probabilistic sum T-conorm: OR(a, b) = a + b - a*b (differentiable)
@pure @hot
fn ns_fuzzy_or(a, b) {
    return a + b - a * b
}

// Godel T-conorm: OR(a, b) = max(a, b)
@pure
fn ns_fuzzy_or_max(a, b) {
    if a > b { return a }
    return b
}

// Negation: NOT(a) = 1 - a
@pure @hot
fn ns_fuzzy_not(a) {
    return 1.0 - a
}

// Godel implication: a -> b = (b >= a) ? 1 : b
@pure
fn ns_fuzzy_implies(a, b) {
    if b >= a { return 1.0 }
    return b
}

// Goguen implication: a -> b = (a == 0) ? 1 : min(1, b/a)
@pure
fn ns_fuzzy_implies_goguen(a, b) {
    if a < 1.0e-12 { return 1.0 }
    let r = b / a
    if r > 1.0 { return 1.0 }
    return r
}

// Sigmoid for smooth truth values
@pure
fn ns_sigmoid(x) {
    return 1.0 / (1.0 + ns_exp(0.0 - x))
}

// ═══════════════════════════════════════════════════════════════════
//  3. Predicate Embedding
//
//  Map a predicate ID to a dense vector using an embedding matrix.
//  embed_w: [n_predicates x embed_dim] flat
// ═══════════════════════════════════════════════════════════════════
@pure
fn ns_predicate_embed(pred_id, embed_w, embed_dim) {
    let mut out = ns_zeros(embed_dim)
    let offset = pred_id * embed_dim
    for i in 0..embed_dim {
        out[i] = embed_w[offset + i]
    }
    return out
}

// Cosine similarity between two embeddings
@pure
fn ns_similarity(a, b) {
    let d = ns_dot(a, b)
    let na = ns_norm(a)
    let nb = ns_norm(b)
    let denom = na * nb
    if denom < 1.0e-12 { return 0.0 }
    return d / denom
}

// ═══════════════════════════════════════════════════════════════════
//  2. Rule Evaluation — Differentiable Forward Chaining
//
//  Rules are represented as:
//    rule = [weight, head_idx, body_idx_1, body_idx_2, ...]
//    - weight in [0,1]: confidence/learnable weight
//    - head_idx: index of the conclusion fact
//    - body_idx_*: indices of premise facts
//
//  Facts are represented as truth values in [0,1]:
//    facts = [0.9, 0.7, 0.0, ...]  (fact_0 = 0.9 truth, etc.)
//
//  Fire a single rule: truth = weight * AND(body_1, body_2, ...)
// ═══════════════════════════════════════════════════════════════════
@pure @hot
fn ns_rule_fire_single(facts, rule) {
    // rule: [weight, head_idx, body_1, body_2, ...]
    let rule_len = len(rule)
    if rule_len < 3 { return 0.0 }
    let weight = rule[0]
    // Compute body conjunction using product T-norm
    let mut body_truth = 1.0
    for i in 2..rule_len {
        let body_idx = to_int(rule[i])
        body_truth = ns_fuzzy_and(body_truth, facts[body_idx])
    }
    return weight * body_truth
}

// Forward chaining: apply all rules for n iterations
// facts: [float] truth values, rules: [[float]] each rule as above
// Returns updated facts after n rounds of forward chaining
@pure @hot
fn ns_forward_chain(facts, rules, n_iters) {
    let n_facts = len(facts)
    let n_rules = len(rules)
    let mut current = ns_zeros(n_facts)
    for i in 0..n_facts { current[i] = facts[i] }

    for _iter in 0..n_iters {
        let mut updated = ns_zeros(n_facts)
        for i in 0..n_facts { updated[i] = current[i] }

        for r in 0..n_rules {
            let rule = rules[r]
            let head_idx = to_int(rule[1])
            let fired = ns_rule_fire_single(current, rule)
            // OR-combine: existing truth OR fired rule
            updated[head_idx] = ns_fuzzy_or(updated[head_idx], fired)
        }
        for i in 0..n_facts { current[i] = updated[i] }
    }
    return current
}

// ═══════════════════════════════════════════════════════════════════
//  Convenience: fire with explicit body truths and weight
// ═══════════════════════════════════════════════════════════════════
@pure @hot
fn ns_rule_fire(body_truths, weight) {
    let n = len(body_truths)
    if n == 0 { return 0.0 }
    let mut body_conj = 1.0
    for i in 0..n {
        body_conj = ns_fuzzy_and(body_conj, body_truths[i])
    }
    return weight * body_conj
}

// ═══════════════════════════════════════════════════════════════════
//  4. Neural Rule Learning
//
//  Score a rule using neural embeddings:
//  score = sigmoid(w * concat(head_emb, mean(body_embs)) + b)
// ═══════════════════════════════════════════════════════════════════
@pure
fn ns_neural_rule_score(head_emb, body_embs, w, b) {
    let dim = len(head_emb)
    let n_body = len(body_embs)

    // Compute mean of body embeddings
    let mut body_mean = ns_zeros(dim)
    if n_body > 0 {
        for i in 0..n_body {
            body_mean = ns_add(body_mean, body_embs[i])
        }
        body_mean = ns_scale(body_mean, 1.0 / to_float(n_body))
    }

    // Concatenate head_emb and body_mean: [head; body_mean]
    let concat_dim = 2 * dim
    let mut concat_vec = ns_zeros(concat_dim)
    for i in 0..dim { concat_vec[i] = head_emb[i] }
    for i in 0..dim { concat_vec[dim + i] = body_mean[i] }

    // Linear + sigmoid: score = sigmoid(w . concat + b)
    let mut raw = b
    let w_len = len(w)
    let use_len = concat_dim
    for i in 0..use_len {
        if i < w_len {
            raw = raw + w[i] * concat_vec[i]
        }
    }
    return ns_sigmoid(raw)
}

// Gradient of rule weight via finite differences
@pure
fn ns_grad_rule_weight(facts, rules, rule_idx, target_idx, eps) {
    let n_rules = len(rules)
    let n_facts = len(facts)

    // Forward chain with original weights
    let result_orig = ns_forward_chain(facts, rules, 3)
    let val_orig = result_orig[target_idx]

    // Perturb the weight of rule at rule_idx
    let mut rules_plus = []
    for r in 0..n_rules {
        let rule = rules[r]
        if r == rule_idx {
            let mut new_rule = ns_zeros(len(rule))
            for k in 0..len(rule) { new_rule[k] = rule[k] }
            new_rule[0] = new_rule[0] + eps
            if new_rule[0] > 1.0 { new_rule[0] = 1.0 }
            rules_plus = rules_plus + [new_rule]
        } else {
            rules_plus = rules_plus + [rule]
        }
    }
    let result_plus = ns_forward_chain(facts, rules_plus, 3)
    let val_plus = result_plus[target_idx]

    return (val_plus - val_orig) / eps
}

// ═══════════════════════════════════════════════════════════════════
//  5. Proof Trace
//
//  Extract which rules contributed to a query's truth value.
//  Returns: list of rule indices that fired and increased the query.
// ═══════════════════════════════════════════════════════════════════
@pure
fn ns_proof_trace(facts, rules, query_idx) {
    let n_rules = len(rules)
    let mut contributing = []

    for r in 0..n_rules {
        let rule = rules[r]
        let head_idx = to_int(rule[1])
        if head_idx == query_idx {
            let fired = ns_rule_fire_single(facts, rule)
            if fired > 0.01 {
                contributing = contributing + [r]
            }
        }
    }
    return contributing
}

// Extended proof trace: returns rule indices and their fire strengths
@pure
fn ns_proof_trace_detailed(facts, rules, query_idx) {
    let n_rules = len(rules)
    let mut trace = []

    for r in 0..n_rules {
        let rule = rules[r]
        let head_idx = to_int(rule[1])
        if head_idx == query_idx {
            let fired = ns_rule_fire_single(facts, rule)
            if fired > 0.01 {
                trace = trace + [[to_float(r), fired]]
            }
        }
    }
    return trace
}

// ═══════════════════════════════════════════════════════════════════
//  Unification — check if two embeddings are close enough
// ═══════════════════════════════════════════════════════════════════
@pure
fn ns_unify(a, b, threshold) {
    let sim = ns_similarity(a, b)
    if sim >= threshold { return true }
    return false
}

// ═══════════════════════════════════════════════════════════════════
//  Knowledge Base Query
//
//  facts: initial truth values
//  rules: rule set
//  query: index of the fact to query
//  steps: number of forward-chaining iterations
//  Returns: truth value of the queried fact
// ═══════════════════════════════════════════════════════════════════
@pure
fn ns_knowledge_base_query(facts, rules, query_idx, steps) {
    let result = ns_forward_chain(facts, rules, steps)
    return result[query_idx]
}

// ═══════════════════════════════════════════════════════════════════
//  Cross-entropy loss for rule learning
//  target: desired truth, predicted: inferred truth
// ═══════════════════════════════════════════════════════════════════
@pure
fn ns_bce_loss(predicted, target) {
    let p = predicted
    let mut p_safe = p
    if p_safe < 1.0e-7 { p_safe = 1.0e-7 }
    if p_safe > 0.9999999 { p_safe = 0.9999999 }
    return 0.0 - (target * ns_log(p_safe) + (1.0 - target) * ns_log(1.0 - p_safe))
}

// ═══════════════════════════════════════════════════════════════════
//  Modus ponens chain depth — how many rule steps to reach query
// ═══════════════════════════════════════════════════════════════════
@pure
fn ns_chain_depth(facts, rules, query_idx, max_depth) {
    let n_facts = len(facts)
    let n_rules = len(rules)
    // Check if already true
    if facts[query_idx] > 0.5 { return 0 }

    let mut current = ns_zeros(n_facts)
    for i in 0..n_facts { current[i] = facts[i] }

    for depth in 1..(max_depth + 1) {
        let mut updated = ns_zeros(n_facts)
        for i in 0..n_facts { updated[i] = current[i] }

        for r in 0..n_rules {
            let rule = rules[r]
            let head_idx = to_int(rule[1])
            let fired = ns_rule_fire_single(current, rule)
            updated[head_idx] = ns_fuzzy_or(updated[head_idx], fired)
        }

        if updated[query_idx] > 0.5 { return depth }
        for i in 0..n_facts { current[i] = updated[i] }
    }
    return -1
}

println("[neuro_symbolic] loaded — fuzzy logic + forward chaining + predicate embedding + proof trace")


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx(a, b, eps) { return fabs(a - b) < eps }

// ═══════════════════════════════════════════════════════════════
//  TEST DATA
// ═══════════════════════════════════════════════════════════════

// Knowledge base:
//   fact[0] = "is_animal(dog)" = 0.9
//   fact[1] = "has_legs(dog)" = 0.8
//   fact[2] = "can_walk(dog)" = 0.0  (to be inferred)
//   fact[3] = "is_pet(dog)"   = 0.0  (to be inferred)
//   fact[4] = "unrelated"     = 0.0
let facts = [0.9, 0.8, 0.0, 0.0, 0.0]

// Rules:
//   rule[0]: weight=0.95, head=2(can_walk), body=[0(is_animal), 1(has_legs)]
//   rule[1]: weight=0.9,  head=3(is_pet),   body=[0(is_animal)]
let rules = [
    [0.95, 2.0, 0.0, 1.0],
    [0.9,  3.0, 0.0]
]

// Embedding weights: 3 predicates, dim=4
// Predicate 0: [1.0, 0.0, 0.5, 0.0]
// Predicate 1: [0.0, 1.0, 0.5, 0.0]
// Predicate 2: [0.9, 0.1, 0.5, 0.0]
let embed_w = [1.0, 0.0, 0.5, 0.0, 0.0, 1.0, 0.5, 0.0, 0.9, 0.1, 0.5, 0.0]

// ═══════════════════════════════════════════════════════════════
//  TESTS
// ═══════════════════════════════════════════════════════════════

// T1: fuzzy AND (product)
check("T1 fuzzy_and(0.8, 0.6) = 0.48", approx(ns_fuzzy_and(0.8, 0.6), 0.48, 0.001))

// T2: fuzzy AND identity
check("T2 fuzzy_and(1,1) = 1", approx(ns_fuzzy_and(1.0, 1.0), 1.0, 0.001))

// T3: fuzzy AND absorbing
check("T3 fuzzy_and(0.7, 0) = 0", approx(ns_fuzzy_and(0.7, 0.0), 0.0, 0.001))

// T4: fuzzy OR (probabilistic sum)
// OR(0.8, 0.6) = 0.8 + 0.6 - 0.48 = 0.92
check("T4 fuzzy_or(0.8, 0.6) = 0.92", approx(ns_fuzzy_or(0.8, 0.6), 0.92, 0.001))

// T5: fuzzy OR identity
check("T5 fuzzy_or(0, 0) = 0", approx(ns_fuzzy_or(0.0, 0.0), 0.0, 0.001))

// T6: fuzzy OR absorbing
check("T6 fuzzy_or(1, 0.5) = 1", approx(ns_fuzzy_or(1.0, 0.5), 1.0, 0.001))

// T7: fuzzy NOT(0) = 1
check("T7 fuzzy_not(0) = 1", approx(ns_fuzzy_not(0.0), 1.0, 0.001))

// T8: fuzzy NOT(1) = 0
check("T8 fuzzy_not(1) = 0", approx(ns_fuzzy_not(1.0), 0.0, 0.001))

// T9: fuzzy AND min
check("T9 fuzzy_and_min(0.8, 0.6) = 0.6", approx(ns_fuzzy_and_min(0.8, 0.6), 0.6, 0.001))

// T10: fuzzy OR max
check("T10 fuzzy_or_max(0.8, 0.6) = 0.8", approx(ns_fuzzy_or_max(0.8, 0.6), 0.8, 0.001))

// T11: fuzzy implies(0.5, 0.8) = 1 (b >= a)
check("T11 fuzzy_implies(0.5, 0.8) = 1", approx(ns_fuzzy_implies(0.5, 0.8), 1.0, 0.001))

// T12: de Morgan approximation: NOT(AND(a,b)) ~ OR(NOT(a), NOT(b))
// Product t-norm: NOT(AND(0.7,0.6)) = 1 - 0.42 = 0.58
// Prob-sum: OR(NOT(0.7), NOT(0.6)) = OR(0.3, 0.4) = 0.3+0.4-0.12 = 0.58
let dm_left = ns_fuzzy_not(ns_fuzzy_and(0.7, 0.6))
let dm_right = ns_fuzzy_or(ns_fuzzy_not(0.7), ns_fuzzy_not(0.6))
check("T12 de Morgan: NOT(AND) = OR(NOT,NOT)", approx(dm_left, dm_right, 0.001))

// T13: predicate embedding dimension
let emb0 = ns_predicate_embed(0, embed_w, 4)
check("T13 predicate embed dim = 4", len(emb0) == 4)

// T14: different predicate ids give different embeddings
let emb1 = ns_predicate_embed(1, embed_w, 4)
let mut emb_diff = false
let mut i = 0

while i < 4 {
    if fabs(emb0[i] - emb1[i]) > 0.001 { emb_diff = true }
}
check("T14 different pred ids => different embeds", emb_diff)

// T15: similarity self = 1
let sim_self = ns_similarity(emb0, emb0)
check("T15 similarity self = 1", approx(sim_self, 1.0, 0.001))

// T16: similarity orthogonal ~ 0
let orth_a = [1.0, 0.0, 0.0, 0.0]
let orth_b = [0.0, 1.0, 0.0, 0.0]
let sim_orth = ns_similarity(orth_a, orth_b)
check("T16 similarity orthogonal = 0", approx(sim_orth, 0.0, 0.001))

// T17: rule_fire with all-true body
let fire1 = ns_rule_fire([0.9, 0.8], 1.0)
check("T17 rule_fire all-true body = 0.72", approx(fire1, 0.72, 0.001))

// T18: rule_fire with zero body => 0
let fire2 = ns_rule_fire([0.9, 0.0], 1.0)
check("T18 rule_fire zero in body = 0", approx(fire2, 0.0, 0.001))

// T19: rule_fire weight scaling
let fire3 = ns_rule_fire([0.9, 0.8], 0.5)
check("T19 rule_fire weight=0.5 => 0.36", approx(fire3, 0.36, 0.001))

// T20: forward chain propagates truth
// Rule 0: can_walk = 0.95 * AND(is_animal, has_legs) = 0.95 * 0.72 = 0.684
let fc1 = ns_forward_chain(facts, rules, 1)
check("T20 forward_chain propagates can_walk", fc1[2] > 0.6)

// T21: forward chain multi-hop (rule 1 produces is_pet from is_animal)
check("T21 forward_chain is_pet inferred", fc1[3] > 0.5)

// T22: forward chain idempotent after convergence
let fc_5 = ns_forward_chain(facts, rules, 5)
let fc_10 = ns_forward_chain(facts, rules, 10)
check("T22 forward_chain converges (idempotent)", approx(fc_5[2], fc_10[2], 0.01))

// T23: neural rule score in (0, 1) -- sigmoid output
let head_e = [1.0, 0.0, 0.5, 0.0]
let body_es = [[0.0, 1.0, 0.5, 0.0]]
let nrs_w = [0.3, 0.2, 0.1, 0.4, 0.5, 0.1, 0.2, 0.3]
let nrs = ns_neural_rule_score(head_e, body_es, nrs_w, 0.0)
check("T23 neural_rule_score in (0,1)", nrs > 0.0 && nrs < 1.0)

// T24: gradient of rule weight is finite
let grad = ns_grad_rule_weight(facts, rules, 0, 2, 0.001)
check("T24 grad_rule_weight finite", ns_abs(grad) < 1000.0)

// T25: proof trace finds contributing rules
let trace = ns_proof_trace(facts, rules, 2)
check("T25 proof_trace finds rule for can_walk", len(trace) > 0)

// T26: proof trace empty when no rule targets fact[4]
let trace_empty = ns_proof_trace(facts, rules, 4)
check("T26 proof_trace empty for unrelated fact", len(trace_empty) == 0)

// T27: unify similar embeddings
let emb2 = ns_predicate_embed(2, embed_w, 4)
let unif1 = ns_unify(emb0, emb2, 0.7)
check("T27 unify similar embeddings => true", unif1)

// T28: unify dissimilar embeddings
let unif2 = ns_unify(orth_a, orth_b, 0.5)
check("T28 unify dissimilar => false", unif2 == false)

// T29: knowledge base query returns inferred truth
let kb_result = ns_knowledge_base_query(facts, rules, 2, 3)
check("T29 kb_query can_walk > 0.5", kb_result > 0.5)

// T30: chain depth correct
// can_walk (fact[2]) needs 1 step from facts[0] and facts[1]
let depth = ns_chain_depth(facts, rules, 2, 5)
check("T30 chain_depth can_walk = 1", depth == 1)

// ═══════════════════════════════════════════════════════════════
println("")
println("=== Neuro Symbolic test summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
