// ═══════════════════════════════════════════════════════════════
//  test_neuro_symbolic.hexa — Neuro-Symbolic (#234)
//
//  Tests (30):
//    T1  fuzzy_and product correctness
//    T2  fuzzy_and(1,1) = 1
//    T3  fuzzy_and(x,0) = 0
//    T4  fuzzy_or probabilistic sum
//    T5  fuzzy_or(0,0) = 0
//    T6  fuzzy_or(1,x) = 1
//    T7  fuzzy_not(0) = 1
//    T8  fuzzy_not(1) = 0
//    T9  fuzzy_and_min correctness
//    T10 fuzzy_or_max correctness
//    T11 fuzzy_implies(a,b) = 1 when b >= a
//    T12 de morgan: NOT(AND(a,b)) ~ OR(NOT(a),NOT(b))
//    T13 predicate embedding dimension
//    T14 predicate embedding different ids differ
//    T15 similarity self = 1
//    T16 similarity orthogonal ~ 0
//    T17 rule_fire with all-true body
//    T18 rule_fire with zero body => 0
//    T19 rule_fire weight scaling
//    T20 forward_chain propagates truth
//    T21 forward_chain multi-hop
//    T22 forward_chain idempotent on stable state
//    T23 neural_rule_score in (0, 1)
//    T24 grad_rule_weight finite
//    T25 proof_trace finds contributing rules
//    T26 proof_trace empty when no rule fires
//    T27 unify similar => true
//    T28 unify dissimilar => false
//    T29 knowledge_base_query returns truth
//    T30 chain_depth correct count
//
//  Run: PATH=$HOME/.cargo/bin:$PATH ./hexa self/test_neuro_symbolic.hexa
// ═══════════════════════════════════════════════════════════════

import "ml/neuro_symbolic.hexa"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx(a, b, eps) { return fabs(a - b) < eps }

// ═══════════════════════════════════════════════════════════════
//  TEST DATA
// ═══════════════════════════════════════════════════════════════

// Knowledge base:
//   fact[0] = "is_animal(dog)" = 0.9
//   fact[1] = "has_legs(dog)" = 0.8
//   fact[2] = "can_walk(dog)" = 0.0  (to be inferred)
//   fact[3] = "is_pet(dog)"   = 0.0  (to be inferred)
//   fact[4] = "unrelated"     = 0.0
let facts = [0.9, 0.8, 0.0, 0.0, 0.0]

// Rules:
//   rule[0]: weight=0.95, head=2(can_walk), body=[0(is_animal), 1(has_legs)]
//   rule[1]: weight=0.9,  head=3(is_pet),   body=[0(is_animal)]
let rules = [
    [0.95, 2.0, 0.0, 1.0],
    [0.9,  3.0, 0.0]
]

// Embedding weights: 3 predicates, dim=4
// Predicate 0: [1.0, 0.0, 0.5, 0.0]
// Predicate 1: [0.0, 1.0, 0.5, 0.0]
// Predicate 2: [0.9, 0.1, 0.5, 0.0]
let embed_w = [1.0, 0.0, 0.5, 0.0, 0.0, 1.0, 0.5, 0.0, 0.9, 0.1, 0.5, 0.0]

// ═══════════════════════════════════════════════════════════════
//  TESTS
// ═══════════════════════════════════════════════════════════════

// T1: fuzzy AND (product)
check("T1 fuzzy_and(0.8, 0.6) = 0.48", approx(ns_fuzzy_and(0.8, 0.6), 0.48, 0.001))

// T2: fuzzy AND identity
check("T2 fuzzy_and(1,1) = 1", approx(ns_fuzzy_and(1.0, 1.0), 1.0, 0.001))

// T3: fuzzy AND absorbing
check("T3 fuzzy_and(0.7, 0) = 0", approx(ns_fuzzy_and(0.7, 0.0), 0.0, 0.001))

// T4: fuzzy OR (probabilistic sum)
// OR(0.8, 0.6) = 0.8 + 0.6 - 0.48 = 0.92
check("T4 fuzzy_or(0.8, 0.6) = 0.92", approx(ns_fuzzy_or(0.8, 0.6), 0.92, 0.001))

// T5: fuzzy OR identity
check("T5 fuzzy_or(0, 0) = 0", approx(ns_fuzzy_or(0.0, 0.0), 0.0, 0.001))

// T6: fuzzy OR absorbing
check("T6 fuzzy_or(1, 0.5) = 1", approx(ns_fuzzy_or(1.0, 0.5), 1.0, 0.001))

// T7: fuzzy NOT(0) = 1
check("T7 fuzzy_not(0) = 1", approx(ns_fuzzy_not(0.0), 1.0, 0.001))

// T8: fuzzy NOT(1) = 0
check("T8 fuzzy_not(1) = 0", approx(ns_fuzzy_not(1.0), 0.0, 0.001))

// T9: fuzzy AND min
check("T9 fuzzy_and_min(0.8, 0.6) = 0.6", approx(ns_fuzzy_and_min(0.8, 0.6), 0.6, 0.001))

// T10: fuzzy OR max
check("T10 fuzzy_or_max(0.8, 0.6) = 0.8", approx(ns_fuzzy_or_max(0.8, 0.6), 0.8, 0.001))

// T11: fuzzy implies(0.5, 0.8) = 1 (b >= a)
check("T11 fuzzy_implies(0.5, 0.8) = 1", approx(ns_fuzzy_implies(0.5, 0.8), 1.0, 0.001))

// T12: de Morgan approximation: NOT(AND(a,b)) ~ OR(NOT(a), NOT(b))
// Product t-norm: NOT(AND(0.7,0.6)) = 1 - 0.42 = 0.58
// Prob-sum: OR(NOT(0.7), NOT(0.6)) = OR(0.3, 0.4) = 0.3+0.4-0.12 = 0.58
let dm_left = ns_fuzzy_not(ns_fuzzy_and(0.7, 0.6))
let dm_right = ns_fuzzy_or(ns_fuzzy_not(0.7), ns_fuzzy_not(0.6))
check("T12 de Morgan: NOT(AND) = OR(NOT,NOT)", approx(dm_left, dm_right, 0.001))

// T13: predicate embedding dimension
let emb0 = ns_predicate_embed(0, embed_w, 4)
check("T13 predicate embed dim = 4", len(emb0) == 4)

// T14: different predicate ids give different embeddings
let emb1 = ns_predicate_embed(1, embed_w, 4)
let mut emb_diff = false
for i in 0..4 {
    if fabs(emb0[i] - emb1[i]) > 0.001 { emb_diff = true }
}
check("T14 different pred ids => different embeds", emb_diff)

// T15: similarity self = 1
let sim_self = ns_similarity(emb0, emb0)
check("T15 similarity self = 1", approx(sim_self, 1.0, 0.001))

// T16: similarity orthogonal ~ 0
let orth_a = [1.0, 0.0, 0.0, 0.0]
let orth_b = [0.0, 1.0, 0.0, 0.0]
let sim_orth = ns_similarity(orth_a, orth_b)
check("T16 similarity orthogonal = 0", approx(sim_orth, 0.0, 0.001))

// T17: rule_fire with all-true body
let fire1 = ns_rule_fire([0.9, 0.8], 1.0)
check("T17 rule_fire all-true body = 0.72", approx(fire1, 0.72, 0.001))

// T18: rule_fire with zero body => 0
let fire2 = ns_rule_fire([0.9, 0.0], 1.0)
check("T18 rule_fire zero in body = 0", approx(fire2, 0.0, 0.001))

// T19: rule_fire weight scaling
let fire3 = ns_rule_fire([0.9, 0.8], 0.5)
check("T19 rule_fire weight=0.5 => 0.36", approx(fire3, 0.36, 0.001))

// T20: forward chain propagates truth
// Rule 0: can_walk = 0.95 * AND(is_animal, has_legs) = 0.95 * 0.72 = 0.684
let fc1 = ns_forward_chain(facts, rules, 1)
check("T20 forward_chain propagates can_walk", fc1[2] > 0.6)

// T21: forward chain multi-hop (rule 1 produces is_pet from is_animal)
check("T21 forward_chain is_pet inferred", fc1[3] > 0.5)

// T22: forward chain idempotent after convergence
let fc_5 = ns_forward_chain(facts, rules, 5)
let fc_10 = ns_forward_chain(facts, rules, 10)
check("T22 forward_chain converges (idempotent)", approx(fc_5[2], fc_10[2], 0.01))

// T23: neural rule score in (0, 1) -- sigmoid output
let head_e = [1.0, 0.0, 0.5, 0.0]
let body_es = [[0.0, 1.0, 0.5, 0.0]]
let nrs_w = [0.3, 0.2, 0.1, 0.4, 0.5, 0.1, 0.2, 0.3]
let nrs = ns_neural_rule_score(head_e, body_es, nrs_w, 0.0)
check("T23 neural_rule_score in (0,1)", nrs > 0.0 && nrs < 1.0)

// T24: gradient of rule weight is finite
let grad = ns_grad_rule_weight(facts, rules, 0, 2, 0.001)
check("T24 grad_rule_weight finite", ns_abs(grad) < 1000.0)

// T25: proof trace finds contributing rules
let trace = ns_proof_trace(facts, rules, 2)
check("T25 proof_trace finds rule for can_walk", len(trace) > 0)

// T26: proof trace empty when no rule targets fact[4]
let trace_empty = ns_proof_trace(facts, rules, 4)
check("T26 proof_trace empty for unrelated fact", len(trace_empty) == 0)

// T27: unify similar embeddings
let emb2 = ns_predicate_embed(2, embed_w, 4)
let unif1 = ns_unify(emb0, emb2, 0.7)
check("T27 unify similar embeddings => true", unif1)

// T28: unify dissimilar embeddings
let unif2 = ns_unify(orth_a, orth_b, 0.5)
check("T28 unify dissimilar => false", unif2 == false)

// T29: knowledge base query returns inferred truth
let kb_result = ns_knowledge_base_query(facts, rules, 2, 3)
check("T29 kb_query can_walk > 0.5", kb_result > 0.5)

// T30: chain depth correct
// can_walk (fact[2]) needs 1 step from facts[0] and facts[1]
let depth = ns_chain_depth(facts, rules, 2, 5)
check("T30 chain_depth can_walk = 1", depth == 1)

// ═══════════════════════════════════════════════════════════════
println("")
println("=== Neuro Symbolic test summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
