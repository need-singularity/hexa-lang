// self/rt/test_except.hexa — P7-7i smoke
//
// Verifies Option A Result-tagged try/throw surface without any
// setjmp/longjmp linkage. Pure data flow: rt_try wraps a callable
// that returns rt_err(...), we assert the returned record's tag
// and payload round-trip correctly.
//
// Build & run (once we can compile rt/):
//   hexa compile self/rt/test_except.hexa -o /tmp/hx_except
//   /tmp/hx_except ; echo "exit=$?"   # expect: exit=0

use self::rt::except

fn thrower_str() -> RtResult {
    return rt_throw("boom")
}

fn thrower_int() -> RtResult {
    return rt_throw(42)
}

fn happy() -> RtResult {
    return rt_ok(7)
}

fn main() -> int {
    // 1. rt_try on a fn that throws a string — ok=false, error="boom"
    let r1 = rt_try(thrower_str)
    if r1.ok { return 1 }
    if r1.error != "boom" { return 2 }

    // 2. rt_try on a fn that throws an int — ok=false, error=42
    let r2 = rt_try(thrower_int)
    if r2.ok { return 3 }
    if r2.error != 42 { return 4 }

    // 3. rt_try on a happy path — ok=true, value=7
    let r3 = rt_try(happy)
    if !r3.ok { return 5 }
    if r3.value != 7 { return 6 }

    // 4. __rt_last_error mirrors the most recent error
    let _ = rt_try(thrower_int)
    if rt_last_error() != 42 { return 7 }

    // 5. constructors round-trip
    let ok = rt_ok(99)
    if !ok.ok { return 8 }
    if ok.value != 99 { return 9 }

    let er = rt_err("x")
    if er.ok { return 10 }
    if er.error != "x" { return 11 }

    return 0
}
