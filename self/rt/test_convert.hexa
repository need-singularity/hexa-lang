// self/rt/test_convert.hexa — smoke test for rt/convert.hexa
//
// 10 assertions covering rt_to_int / rt_to_float / rt_to_bool /
// rt_to_string / rt_is_error / rt_to_cstring + rt_from_cstring
// round-trip. Style mirrors test_core.hexa. cstring round-trip is
// interpreter-only today (waits on __mem_load8/store8 codegen).

use self::rt::convert

let mut FAILS = 0

fn check(name, ok) {
    if ok {
        print("PASS ")
        println(name)
    } else {
        FAILS = FAILS + 1
        print("FAIL ")
        println(name)
    }
}

// ── rt_to_int ───────────────────────────────────────────────────────
check("to_int:int-passthru",   rt_to_int(42) == 42)
check("to_int:float-trunc",    rt_to_int(3.7) == 3)
check("to_int:string-parse",   rt_to_int("123") == 123)
check("to_int:bool-true",      rt_to_int(true) == 1)

// ── rt_to_float ─────────────────────────────────────────────────────
check("to_float:int-promote",  rt_to_float(7) == 7.0)
check("to_float:string-parse", rt_to_float("2.5") == 2.5)

// ── rt_to_bool ──────────────────────────────────────────────────────
check("to_bool:string-true",   rt_to_bool("true"))
check("to_bool:string-false",  !rt_to_bool("false"))
check("to_bool:zero-int",      !rt_to_bool(0))

// ── rt_to_string ────────────────────────────────────────────────────
check("to_string:int",         rt_to_string(5) == "5")
check("to_string:bool",        rt_to_string(true) == "true")
check("to_string:void",        rt_to_string(void) == "void")
check("to_string:arr",         rt_to_string([1, 2]) == "[1, 2]")

// ── rt_is_error ─────────────────────────────────────────────────────
check("is_error:err-sentinel", rt_is_error("ERR: boom"))
check("is_error:plain-str",    !rt_is_error("hi"))
check("is_error:int",          !rt_is_error(0))

// ── cstring round-trip ──────────────────────────────────────────────
// Interpreter-only until __mem_load8/store8 lowering lands; this
// exercises the wrapper but may no-op under native until then.
let ptr = rt_to_cstring("hi")
let back = rt_from_cstring(ptr)
check("cstring:round-trip",    back == "hi")

if FAILS == 0 {
    println("all convert tests passed")
} else {
    print("convert tests failed: ")
    println(to_string(FAILS))
}
