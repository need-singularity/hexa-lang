// self/rt/mod.hexa — P7-7 runtime module index
//
// Imports all runtime modules that collectively replace self/runtime.c.
// Consumers (hexa_full.hexa, compile_pipeline.hexa) use this single
// entry point to pull in the full syscall-based runtime.
//
// Status (2026-04-17):
//   syscall  ✓ skeleton (P7-7a)
//   alloc    ✓ skeleton (P7-7b)
//   io       ✓ skeleton (P7-7c)
//   fmt      ✓ skeleton (P7-7c-2)
//   proc     ✓ skeleton (P7-7d; exec pipe chain TODO)
//   fs       ✓ skeleton (P7-7e; Darwin readdir TODO)
//   math     ✓ skeleton (P7-7g; libm replacement, Taylor/Newton)
//
//   except   ✗ deferred (P7-7i; option: Result-return refactor)
//   ffi      ✗ deferred (P7-7 scope question; skip if not used by hexa_full)
//   intern   ✗ deferred (P7-7-intern; string pool, alloc-backed hashset)
//
// Execution gates (run on Mac ARM64; currently blocked on non-Mac session):
//   [ ] self/rt/test_syscall.hexa — baseline svc + write
//   [ ] self/rt/test_alloc.hexa — mmap/munmap arena round-trip
//   [ ] self/rt/test_io.hexa — read_file(self/rt/mod.hexa) round-trip
//   [ ] self/rt/test_proc.hexa — exit + env_var(PATH)
//   [ ] self/rt/test_math.hexa — sqrt(2)/sin(pi/2)/exp(1) vs libm reference

use self::rt::syscall
use self::rt::alloc
use self::rt::io
use self::rt::fmt
use self::rt::proc
use self::rt::fs
use self::rt::math
