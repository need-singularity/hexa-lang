// self/rt/syscall.hexa — P7-7a: syscall intrinsic wrappers
//
// Declares per-target syscall numbers and portable sys_* wrappers over
// the `syscall(num, args...)` builtin. The builtin is lowered by
// self/codegen/syscall.hexa into architecture-specific instruction
// sequences (ARM64 svc / x86_64 syscall).
//
// Spec: docs/plans/syscall_intrinsic_spec.md
//
// Usage from rt/ modules:
//
//     use self::rt::syscall
//
//     fn write_line(s: string) -> int {
//         let addr = hexa_ptr_addr(s)
//         return sys_write(1, addr, len(s))
//     }
//
// Per-target constants are const fns so codegen DCE drops the dead
// branch at --target time. `target_is_linux()` / `target_is_darwin()`
// resolve at codegen (compile-time known).

// ═══════════════════════════════════════════════════════════════════
// Target selection (compile-time, resolved by codegen --target flag)
// ═══════════════════════════════════════════════════════════════════

@pure fn target_is_linux() -> bool { return __TARGET_OS__ == 0 }
@pure fn target_is_darwin() -> bool { return __TARGET_OS__ == 1 }

// __TARGET_OS__ is a codegen-injected constant:
//   0 = linux,  1 = darwin,  2 = (reserved for freebsd)

// ═══════════════════════════════════════════════════════════════════
// Linux syscall numbers (x86_64 + arm64 unified — Linux unified ABI)
// ═══════════════════════════════════════════════════════════════════

@pure fn SYS_LINUX_READ()         -> int { return 0 }
@pure fn SYS_LINUX_WRITE()        -> int { return 1 }
@pure fn SYS_LINUX_OPEN()         -> int { return 2 }
@pure fn SYS_LINUX_CLOSE()        -> int { return 3 }
@pure fn SYS_LINUX_STAT()         -> int { return 4 }
@pure fn SYS_LINUX_FSTAT()        -> int { return 5 }
@pure fn SYS_LINUX_LSEEK()        -> int { return 8 }
@pure fn SYS_LINUX_MMAP()         -> int { return 9 }
@pure fn SYS_LINUX_MUNMAP()       -> int { return 11 }
@pure fn SYS_LINUX_BRK()          -> int { return 12 }
@pure fn SYS_LINUX_IOCTL()        -> int { return 16 }
@pure fn SYS_LINUX_PIPE()         -> int { return 22 }
@pure fn SYS_LINUX_NANOSLEEP()    -> int { return 35 }
@pure fn SYS_LINUX_FORK()         -> int { return 57 }
@pure fn SYS_LINUX_EXECVE()       -> int { return 59 }
@pure fn SYS_LINUX_WAIT4()        -> int { return 61 }
@pure fn SYS_LINUX_DUP2()         -> int { return 33 }
@pure fn SYS_LINUX_GETDENTS64()   -> int { return 217 }
@pure fn SYS_LINUX_CLOCK_GETTIME()-> int { return 228 }
@pure fn SYS_LINUX_EXIT_GROUP()   -> int { return 231 }
@pure fn SYS_LINUX_UNLINKAT()     -> int { return 263 }
@pure fn SYS_LINUX_MKDIRAT()      -> int { return 258 }
@pure fn SYS_LINUX_GETRANDOM()    -> int { return 318 }

// ═══════════════════════════════════════════════════════════════════
// Darwin syscall numbers (BSD layer, OR 0x2000000 baked in)
// ═══════════════════════════════════════════════════════════════════

@pure fn SYS_DARWIN_EXIT()        -> int { return 33554433 }  // 0x2000001
@pure fn SYS_DARWIN_FORK()        -> int { return 33554434 }  // 0x2000002
@pure fn SYS_DARWIN_READ()        -> int { return 33554435 }  // 0x2000003
@pure fn SYS_DARWIN_WRITE()       -> int { return 33554436 }  // 0x2000004
@pure fn SYS_DARWIN_OPEN()        -> int { return 33554437 }  // 0x2000005
@pure fn SYS_DARWIN_CLOSE()       -> int { return 33554438 }  // 0x2000006
@pure fn SYS_DARWIN_WAIT4()       -> int { return 33554439 }  // 0x2000007
@pure fn SYS_DARWIN_UNLINK()      -> int { return 33554442 }  // 0x200000a
@pure fn SYS_DARWIN_LSEEK()       -> int { return 33554631 }  // 0x20000c7 (arm64)
@pure fn SYS_DARWIN_EXECVE()      -> int { return 33554491 }  // 0x200003b
@pure fn SYS_DARWIN_MUNMAP()      -> int { return 33554505 }  // 0x2000049
@pure fn SYS_DARWIN_MMAP()        -> int { return 33554629 }  // 0x20000c5
@pure fn SYS_DARWIN_FSTAT64()     -> int { return 33554621 }  // 0x20000bd
@pure fn SYS_DARWIN_GETDIRENTRIES()-> int { return 33554772 } // 0x2000154
@pure fn SYS_DARWIN_GETDIRENTRIES64()->int { return 33554776 } // 0x2000158 (arm64 new-style)
@pure fn SYS_DARWIN_MKDIR()       -> int { return 33554568 }  // 0x2000088
@pure fn SYS_DARWIN_NANOSLEEP()   -> int { return 33554629 }  // (placeholder — revise)
@pure fn SYS_DARWIN_CLOCK_GETTIME()->int  { return 33558008 }  // 0x2000E78

// ═══════════════════════════════════════════════════════════════════
// Portable wrappers — callers use these, not raw syscall()
// ═══════════════════════════════════════════════════════════════════

fn sys_read(fd: int, buf: int, len: int) -> int {
    if target_is_linux() { return syscall(SYS_LINUX_READ(), fd, buf, len) }
    return syscall(SYS_DARWIN_READ(), fd, buf, len)
}

fn sys_write(fd: int, buf: int, len: int) -> int {
    if target_is_linux() { return syscall(SYS_LINUX_WRITE(), fd, buf, len) }
    return syscall(SYS_DARWIN_WRITE(), fd, buf, len)
}

fn sys_open(path_cstr: int, flags: int, mode: int) -> int {
    if target_is_linux() { return syscall(SYS_LINUX_OPEN(), path_cstr, flags, mode) }
    return syscall(SYS_DARWIN_OPEN(), path_cstr, flags, mode)
}

fn sys_close(fd: int) -> int {
    if target_is_linux() { return syscall(SYS_LINUX_CLOSE(), fd) }
    return syscall(SYS_DARWIN_CLOSE(), fd)
}

fn sys_lseek(fd: int, off: int, whence: int) -> int {
    if target_is_linux() { return syscall(SYS_LINUX_LSEEK(), fd, off, whence) }
    return syscall(SYS_DARWIN_LSEEK(), fd, off, whence)
}

fn sys_unlink(path_cstr: int) -> int {
    if target_is_linux() {
        // Linux uses unlinkat(AT_FDCWD=-100, path, 0)
        return syscall(SYS_LINUX_UNLINKAT(), -100, path_cstr, 0)
    }
    return syscall(SYS_DARWIN_UNLINK(), path_cstr)
}

fn sys_mkdir(path_cstr: int, mode: int) -> int {
    if target_is_linux() {
        // Linux: mkdirat(AT_FDCWD=-100, path, mode) — raw mkdir(2)=83 was dropped.
        return syscall(SYS_LINUX_MKDIRAT(), -100, path_cstr, mode)
    }
    return syscall(SYS_DARWIN_MKDIR(), path_cstr, mode)
}

fn sys_mmap(addr: int, size: int, prot: int, flags: int, fd: int, off: int) -> int {
    if target_is_linux() { return syscall(SYS_LINUX_MMAP(), addr, size, prot, flags, fd, off) }
    return syscall(SYS_DARWIN_MMAP(), addr, size, prot, flags, fd, off)
}

fn sys_munmap(addr: int, size: int) -> int {
    if target_is_linux() { return syscall(SYS_LINUX_MUNMAP(), addr, size) }
    return syscall(SYS_DARWIN_MUNMAP(), addr, size)
}

fn sys_exit(code: int) -> int {
    if target_is_linux() { return syscall(SYS_LINUX_EXIT_GROUP(), code) }
    return syscall(SYS_DARWIN_EXIT(), code)
}

fn sys_getrandom(buf: int, len: int, flags: int) -> int {
    if target_is_linux() { return syscall(SYS_LINUX_GETRANDOM(), buf, len, flags) }
    // Darwin has no getrandom; fall back to /dev/urandom via open+read
    let fd = sys_open(hexa_ptr_addr("/dev/urandom"), 0, 0)
    if fd < 0 { return fd }
    let n = sys_read(fd, buf, len)
    sys_close(fd)
    return n
}

fn sys_clock_gettime(clk: int, ts_ptr: int) -> int {
    if target_is_linux() { return syscall(SYS_LINUX_CLOCK_GETTIME(), clk, ts_ptr) }
    return syscall(SYS_DARWIN_CLOCK_GETTIME(), clk, ts_ptr)
}

// ═══════════════════════════════════════════════════════════════════
// Process control — fork / execve / wait4 / pipe / dup2 / nanosleep
// ═══════════════════════════════════════════════════════════════════
//
// Used by self/rt/proc.hexa (hexa_exec / hexa_exec_with_status / hexa_sleep).
// Signatures match the Linux unified ABI; Darwin uses the same layout.

fn sys_fork() -> int {
    if target_is_linux() { return syscall(SYS_LINUX_FORK()) }
    return syscall(SYS_DARWIN_FORK())
}

// argv_ptr / envp_ptr are int addresses of NULL-terminated cstring arrays.
fn sys_execve(path_cstr: int, argv_ptr: int, envp_ptr: int) -> int {
    if target_is_linux() { return syscall(SYS_LINUX_EXECVE(), path_cstr, argv_ptr, envp_ptr) }
    return syscall(SYS_DARWIN_EXECVE(), path_cstr, argv_ptr, envp_ptr)
}

// wait4(pid, &status, options, &rusage). rusage_ptr = 0 to skip.
fn sys_wait4(pid: int, status_ptr: int, options: int, rusage_ptr: int) -> int {
    if target_is_linux() { return syscall(SYS_LINUX_WAIT4(), pid, status_ptr, options, rusage_ptr) }
    return syscall(SYS_DARWIN_WAIT4(), pid, status_ptr, options, rusage_ptr)
}

// pipe(fds[2]) — fds_ptr is int addr of a 2-int array (8 bytes each on 64-bit,
// or 4 bytes if codegen emits 32-bit ints; interp convention is 64-bit slots).
// Linux pipe() returns read-end in rax and writes read/write fds to fds_ptr[0..1]
// (actually writes both slots; return value is 0 on success, -errno on error).
fn sys_pipe(fds_ptr: int) -> int {
    if target_is_linux() { return syscall(SYS_LINUX_PIPE(), fds_ptr) }
    // Darwin has no plain pipe() via BSD syscall — kernel returns r0/r1 in
    // two return regs. Current codegen exposes only the first return value,
    // so Darwin path is incomplete; pipe-based exec is Linux-only for now.
    return -1
}

fn sys_dup2(oldfd: int, newfd: int) -> int {
    if target_is_linux() { return syscall(SYS_LINUX_DUP2(), oldfd, newfd) }
    // Darwin dup2 syscall number not yet catalogued — see proc.hexa blocker.
    return -1
}

fn sys_nanosleep(req_ptr: int, rem_ptr: int) -> int {
    if target_is_linux() { return syscall(SYS_LINUX_NANOSLEEP(), req_ptr, rem_ptr) }
    return syscall(SYS_DARWIN_NANOSLEEP(), req_ptr, rem_ptr)
}

// ═══════════════════════════════════════════════════════════════════
// Open flags (POSIX shared; Linux + Darwin identical for subset below)
// ═══════════════════════════════════════════════════════════════════

@pure fn O_RDONLY()  -> int { return 0 }
@pure fn O_WRONLY()  -> int { return 1 }
@pure fn O_RDWR()    -> int { return 2 }
// Note: O_CREAT / O_APPEND / O_TRUNC values diverge between Linux and
// Darwin. Use per-target variants.
@pure fn O_CREAT_LINUX()  -> int { return 64 }    // 0x40
@pure fn O_APPEND_LINUX() -> int { return 1024 }  // 0x400
@pure fn O_TRUNC_LINUX()  -> int { return 512 }   // 0x200
@pure fn O_CREAT_DARWIN() -> int { return 512 }   // 0x200
@pure fn O_APPEND_DARWIN()-> int { return 8 }     // 0x008
@pure fn O_TRUNC_DARWIN() -> int { return 1024 }  // 0x400

fn flag_o_creat() -> int {
    if target_is_linux() { return O_CREAT_LINUX() }
    return O_CREAT_DARWIN()
}
fn flag_o_append() -> int {
    if target_is_linux() { return O_APPEND_LINUX() }
    return O_APPEND_DARWIN()
}
fn flag_o_trunc() -> int {
    if target_is_linux() { return O_TRUNC_LINUX() }
    return O_TRUNC_DARWIN()
}

// ═══════════════════════════════════════════════════════════════════
// mmap prot/flags (POSIX shared subset)
// ═══════════════════════════════════════════════════════════════════

@pure fn PROT_READ()  -> int { return 1 }
@pure fn PROT_WRITE() -> int { return 2 }
@pure fn PROT_EXEC()  -> int { return 4 }
@pure fn MAP_PRIVATE()-> int { return 2 }
@pure fn MAP_ANON_LINUX()  -> int { return 32 }    // 0x20
@pure fn MAP_ANON_DARWIN() -> int { return 4096 }  // 0x1000
fn flag_map_anon() -> int {
    if target_is_linux() { return MAP_ANON_LINUX() }
    return MAP_ANON_DARWIN()
}

// ═══════════════════════════════════════════════════════════════════
// CLOCK_* constants
// ═══════════════════════════════════════════════════════════════════

@pure fn CLOCK_REALTIME()  -> int { return 0 }
@pure fn CLOCK_MONOTONIC_LINUX()  -> int { return 1 }
@pure fn CLOCK_MONOTONIC_DARWIN() -> int { return 6 }
fn clock_monotonic() -> int {
    if target_is_linux() { return CLOCK_MONOTONIC_LINUX() }
    return CLOCK_MONOTONIC_DARWIN()
}
