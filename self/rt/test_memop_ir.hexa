// self/rt/test_memop_ir.hexa — P7-7b memory intrinsic round-trip smoke test
//
// Blocked: cannot execute until P7-6 native codegen scales the pipeline
// through hexa_full.hexa (or until the ir_to_arm64/ir_to_x86 standalone
// bridges wire into the CLI `hexa build --emit=native`). Until then this
// file parses and documents the contract — the generated IR should carry
// OP_MEM_STORE8 / OP_MEM_LOAD8 / OP_MEM_STORE64 / OP_MEM_LOAD64 opcodes
// that self/codegen/memop.hexa lowers to single LDR/STR instructions.
//
// Coverage (matches self/rt/alloc.hexa::hexa_ptr_*_byte/64 wrappers):
//   __mem_store8  → STRB Wval, [Xaddr]       (ARM64)  / MOV m8, r8    (x86_64)
//   __mem_load8   → LDRB Wdst, [Xaddr]       (ARM64)  / MOVZX r, m8   (x86_64)
//   __mem_store64 → STR  Xval, [Xaddr]       (ARM64)  / MOV m64, r64  (x86_64)
//   __mem_load64  → LDR  Xdst, [Xaddr]       (ARM64)  / MOV r64, m64  (x86_64)
//
// Build & run (post-P7-6 scaled native pipeline):
//   hexa build --target=darwin-arm64 self/rt/test_memop_ir.hexa -o /tmp/hx_mop
//   /tmp/hx_mop ; echo "exit=$?"          # expect: memop ok\n  exit=0
//
// Exit codes on failure:
//   2 = mmap returned negative (errno)
//   3 = __mem_load8 readback mismatch
//   4 = __mem_load64 readback mismatch
//   5 = munmap failed

use self::rt::syscall
use self::rt::alloc

fn main() -> int {
    // Allocate a 16-byte region via mmap. Word-aligned so __mem_store64
    // at offset 0 doesn't fault on strict-alignment ARM64 cores.
    let size = 16
    let flags = MAP_PRIVATE() + flag_map_anon()
    let prot = PROT_READ() + PROT_WRITE()
    let base = sys_mmap(0, size, prot, flags, -1, 0)
    if base < 0 {
        sys_exit(2)
        return 2
    }

    // Byte store + load round-trip at offset 0 — exercises mem_store8 /
    // mem_load8 lowering paths in ir_to_arm64 / ir_to_x86.
    let pat8 = 165   // 0xA5
    __mem_store8(base, pat8)
    let got8 = __mem_load8(base)
    if got8 != pat8 {
        sys_munmap(base, size)
        sys_exit(3)
        return 3
    }

    // 64-bit round-trip at offset 8 (aligned). Exercises STR/LDR 64-bit
    // form and the arena-header path in self/rt/alloc.hexa.
    let pat64 = 81985529216486895   // 0x0123456789ABCDEF
    __mem_store64(base + 8, pat64)
    let got64 = __mem_load64(base + 8)
    if got64 != pat64 {
        sys_munmap(base, size)
        sys_exit(4)
        return 4
    }

    let u = sys_munmap(base, size)
    if u < 0 {
        sys_exit(5)
        return 5
    }

    let msg = "memop ok\n"
    let addr = hexa_ptr_addr(msg)
    sys_write(1, addr, 9)
    sys_exit(0)
    return 0
}
