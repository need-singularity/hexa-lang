// self/rt/test_intern.hexa — P7-7-intern smoke test
//
// Verifies rt_intern contract:
//   1. Idempotent canonical ref: rt_intern("hello") == rt_intern("hello")
//   2. Hash collisions still distinguish keys (equality on string value)
//   3. Long strings (> INTERN_MAX_LEN) bypass the table
//   4. FNV-1a matches the known offset-basis for empty string
//   5. Pre-populated seeds are present after rt_intern_init()
//
// Build & run (Mac ARM64):
//   hexa compile --target=darwin-arm64 self/rt/test_intern.hexa -o /tmp/hx_intern
//   /tmp/hx_intern ; echo "exit=$?"    # expect: ok  exit=0

use self::rt::syscall
use self::rt::alloc
use self::rt::io
use self::rt::intern

fn main() -> int {
    rt_init()
    rt_intern_init()

    // 1. Same input → equal canonical output.
    let a = rt_intern("hello")
    let b = rt_intern("hello")
    if a != b { sys_exit(1) }
    if len(a) != 5 { sys_exit(2) }

    // 2. Two distinct 5-char strings are kept separate even if the
    //    table bucket hashing would collide. rt_intern uses the key
    //    for equality, so "hello" and "world" must stay distinct.
    let h = rt_intern("hello")
    let w = rt_intern("world")
    if h == w { sys_exit(3) }

    // 3. Long string (> INTERN_MAX_LEN == 64) returns as-is, not
    //    stored. Count before/after must not grow.
    let long_s = "this_is_a_very_long_string_that_exceeds_sixty_four_characters_for_sure_yes_really"
    if len(long_s) <= INTERN_MAX_LEN() { sys_exit(4) }
    let count_before = rt_intern_count()
    let r = rt_intern(long_s)
    let count_after = rt_intern_count()
    if count_before != count_after { sys_exit(5) }
    if len(r) != len(long_s) { sys_exit(6) }

    // 4. FNV-1a empty-string hash == offset basis (2166136261).
    if rt_fnv1a("") != FNV1A_OFFSET() { sys_exit(7) }

    // 5. Seeds pre-populated — "int" and "bool" must already be in
    //    the table (count_before above covers this implicitly; assert
    //    direct lookup returns the same ref on second call).
    let i1 = rt_intern("int")
    let i2 = rt_intern("int")
    if i1 != i2 { sys_exit(8) }

    rt_println("ok")
    sys_exit(0)
    return 0
}
