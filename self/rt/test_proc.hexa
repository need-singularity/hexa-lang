// self/rt/test_proc.hexa — P7-7d smoke test
//
// Covers: rt_exit (direct), rt_clock / rt_timestamp (no-op sanity), and a
// stretch exec path gated behind the RUN_EXEC flag — currently skipped
// until the pipe+fork+execve chain is validated on Linux x86_64.
//
// Build & run (Linux x86_64):
//   hexa compile --target=linux-x86_64 self/rt/test_proc.hexa -o /tmp/hx_proc
//   /tmp/hx_proc ; echo "exit=$?"   # expect: exit=0

use self::rt::syscall
use self::rt::proc
use self::rt::io

@pure fn RUN_EXEC() -> bool { return false }

fn main() -> int {
    // 1. clock / timestamp monotonicity — both should return >= 0.
    let t0 = rt_clock()
    let ts = rt_timestamp()
    if t0 < 0 { rt_exit(1) }
    if ts < 0 { rt_exit(1) }

    // 2. Stretch: exec echo, check status == 0 and stdout starts with "hx".
    if RUN_EXEC() {
        let result = rt_exec_with_status("echo hx")
        let out = result[0]
        let code = result[1]
        if code != 0 { rt_exit(2) }
        if len(out) < 2 { rt_exit(3) }
        if out[0] != 104 { rt_exit(4) }  // 'h'
        if out[1] != 120 { rt_exit(5) }  // 'x'
    }

    // 3. Exit-path: bypass any epilogue, call sys_exit directly.
    rt_exit(0)
    return 0
}
