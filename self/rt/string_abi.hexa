// self/rt/string_abi.hexa — P7-7 / ROI string: HexaVal ↔ string marshalling
//
// codegen_c2.hexa (via self/codegen/rt_symbols.hexa::rt_string_symbol) emits
// rt_str_*_v(<HexaVal expr>...) call sites when rt_target() == "rt". The
// pure-hexa kernels in rt/string.hexa (rt_str_concat, rt_str_substring, …)
// declare typed parameters (`s: string`, `start: int`, `arr: [string]`), so
// calling them directly with HexaVal-typed expressions would mis-type the C
// ABI.
//
// This file defines the `_v` wrappers — one per symbol in rt_string_symbol
// — that take polymorphic (→ HexaVal in generated C) parameters, unwrap via
// rt_to_string / rt_to_int, dispatch to the rt/string.hexa kernel, and let
// the compiler auto-box the typed return (string / int / bool / array) back
// to HexaVal at the C layer.
//
// Unwrap helpers:  rt_to_string(v)  — self/rt/convert.hexa
//                  rt_to_int(v)     — self/rt/convert.hexa
//                  (array params pass through — they are already HexaVal
//                   arrays; no per-element conversion at the boundary.)
// Wrap helper:    (implicit)        — typed return values are auto-boxed
//                                     into HexaVal at codegen_c2 emit time.
//
// Symbol names mirror self/codegen/rt_symbols.hexa::rt_string_symbol (L92-
// 118) exactly — any deviation breaks the codegen router. Semantics track
// the corresponding hexa_str_* functions in self/runtime.c (see rt/string
// .hexa docstrings for per-fn runtime.c line references and edge cases).

use self::rt::string
use self::rt::convert

// ═══════════════════════════════════════════════════════════════════
// Concat / compare / contains
// ═══════════════════════════════════════════════════════════════════

fn rt_str_concat_v(a, b) -> string {
    return rt_str_concat(rt_to_string(a), rt_to_string(b))
}

fn rt_str_contains_v(hay, needle) -> bool {
    return rt_str_contains(rt_to_string(hay), rt_to_string(needle))
}

fn rt_str_eq_v(a, b) -> bool {
    return rt_str_eq(rt_to_string(a), rt_to_string(b))
}

// ═══════════════════════════════════════════════════════════════════
// Substring / slice (int bounds)
// ═══════════════════════════════════════════════════════════════════

fn rt_str_substring_v(s, start, end) -> string {
    return rt_str_substring(rt_to_string(s), rt_to_int(start), rt_to_int(end))
}

fn rt_str_slice_v(s, start, end) -> string {
    return rt_str_slice(rt_to_string(s), rt_to_int(start), rt_to_int(end))
}

// ═══════════════════════════════════════════════════════════════════
// Trim family
// ═══════════════════════════════════════════════════════════════════

fn rt_str_trim_v(s) -> string {
    return rt_str_trim(rt_to_string(s))
}

fn rt_str_trim_start_v(s) -> string {
    return rt_str_trim_start(rt_to_string(s))
}

fn rt_str_trim_end_v(s) -> string {
    return rt_str_trim_end(rt_to_string(s))
}

// ═══════════════════════════════════════════════════════════════════
// Replace / pad / repeat
// ═══════════════════════════════════════════════════════════════════

fn rt_str_replace_v(s, from, to) -> string {
    return rt_str_replace(rt_to_string(s), rt_to_string(from), rt_to_string(to))
}

fn rt_str_pad_left_v(s, width, pad) -> string {
    return rt_str_pad_left(rt_to_string(s), rt_to_int(width), rt_to_string(pad))
}

fn rt_str_pad_right_v(s, width, pad) -> string {
    return rt_str_pad_right(rt_to_string(s), rt_to_int(width), rt_to_string(pad))
}

fn rt_str_repeat_v(s, n) -> string {
    return rt_str_repeat(rt_to_string(s), rt_to_int(n))
}

// ═══════════════════════════════════════════════════════════════════
// Search / reverse
// ═══════════════════════════════════════════════════════════════════

fn rt_str_index_of_v(s, needle) -> int {
    return rt_str_index_of(rt_to_string(s), rt_to_string(needle))
}

fn rt_str_reverse_v(s) -> string {
    return rt_str_reverse(rt_to_string(s))
}

// ═══════════════════════════════════════════════════════════════════
// Split / join (array parameters pass through)
// ═══════════════════════════════════════════════════════════════════

fn rt_str_split_v(s, sep) {
    return rt_str_split(rt_to_string(s), rt_to_string(sep))
}

fn rt_str_join_v(arr, sep) -> string {
    // arr is a HexaVal array of strings — forwarded as-is. Per-element
    // stringify is delegated to rt_str_join's pure implementation (which
    // reads elements through hexa's polymorphic len/index and relies on
    // them already being string-shaped, mirroring hexa_str_join in
    // runtime.c L3434 which does `HX_STR(item)` without coercion).
    return rt_str_join(arr, rt_to_string(sep))
}

// ═══════════════════════════════════════════════════════════════════
// Case fold
// ═══════════════════════════════════════════════════════════════════

fn rt_str_to_upper_v(s) -> string {
    return rt_str_to_upper(rt_to_string(s))
}

fn rt_str_to_lower_v(s) -> string {
    return rt_str_to_lower(rt_to_string(s))
}

// ═══════════════════════════════════════════════════════════════════
// Char access
// ═══════════════════════════════════════════════════════════════════

fn rt_str_char_at_v(s, i) -> string {
    return rt_str_char_at(rt_to_string(s), rt_to_int(i))
}

fn rt_str_char_code_at_v(s, i) -> int {
    return rt_str_char_code_at(rt_to_string(s), rt_to_int(i))
}

// ═══════════════════════════════════════════════════════════════════
// Parse numerics — 0 / 0.0 on fail (matches runtime.c L4688/L4700)
// ═══════════════════════════════════════════════════════════════════

fn rt_str_parse_int_v(s) -> int {
    return rt_str_parse_int(rt_to_string(s))
}

fn rt_str_parse_float_v(s) -> float {
    return rt_str_parse_float(rt_to_string(s))
}

// ═══════════════════════════════════════════════════════════════════
// Bytes round-trip
// ═══════════════════════════════════════════════════════════════════

fn rt_str_bytes_v(s) {
    return rt_str_bytes(rt_to_string(s))
}

fn rt_str_from_chars_v(arr) -> string {
    // arr is a HexaVal array of int codepoints — passed through to the
    // pure kernel which iterates via char_code/len, matching the loop in
    // rt_str_from_chars. No per-element unwrap needed.
    return rt_str_from_chars(arr)
}

// ═══════════════════════════════════════════════════════════════════
// Gap-closure (2026-04-19): chars / substr / lines / center / len /
// starts_with / ends_with. Mirrors runtime.c hexa_str_* semantics.
// ═══════════════════════════════════════════════════════════════════

fn rt_str_len_v(s) -> int {
    return rt_str_len(rt_to_string(s))
}

fn rt_str_starts_with_v(s, prefix) -> bool {
    return rt_str_starts_with(rt_to_string(s), rt_to_string(prefix))
}

fn rt_str_ends_with_v(s, suffix) -> bool {
    return rt_str_ends_with(rt_to_string(s), rt_to_string(suffix))
}

fn rt_str_chars_v(s) {
    // arr-of-string return; host auto-boxes to HexaVal.
    return rt_str_chars(rt_to_string(s))
}

fn rt_str_lines_v(s) {
    return rt_str_lines(rt_to_string(s))
}

fn rt_str_center_v(s, width, pad) -> string {
    return rt_str_center(rt_to_string(s), rt_to_int(width), rt_to_string(pad))
}

// substr: void-sentinel on the count parameter (runtime.c L5189). When
// count is TAG_VOID at the HexaVal ABI, default to the rest of the
// string. typeof(v)=="void" is the hexa-surface detection.
fn rt_str_substr_v(s, start, count) -> string {
    let s_str = rt_to_string(s)
    let a = rt_to_int(start)
    let slen = len(s_str)
    let mut c = 0
    if typeof(count) == "void" {
        let mut a_clamped = a
        if a_clamped < 0 { a_clamped = 0 }
        if a_clamped > slen { a_clamped = slen }
        c = slen - a_clamped
    } else {
        c = rt_to_int(count)
    }
    return rt_str_substr(s_str, a, c)
}
