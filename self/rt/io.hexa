// self/rt/io.hexa — P7-7c: hexa I/O over syscall(read/write/open/close)
//
// Replaces runtime.c file I/O and print paths. Pure hexa — no libc.
//
// Surface (matches runtime.c names for drop-in replacement):
//
//   hexa_print_val / hexa_println / hexa_eprint_val
//   hexa_read_file(path) / hexa_read_file_bytes(path)
//   hexa_write_file(path, content) / hexa_write_bytes(path, bytes)
//   hexa_append_file(path, content) / hexa_write_bytes_append(path, bytes)
//   hexa_read_lines(path)
//   hexa_delete_file(path)
//   hexa_file_size(path)
//   hexa_input(prompt)

use self::rt::syscall
use self::rt::alloc
use self::rt::fmt

// ═══════════════════════════════════════════════════════════════════
// File descriptors
// ═══════════════════════════════════════════════════════════════════

@pure fn STDIN()  -> int { return 0 }
@pure fn STDOUT() -> int { return 1 }
@pure fn STDERR() -> int { return 2 }

// ═══════════════════════════════════════════════════════════════════
// Path → null-terminated cstring helper
// ═══════════════════════════════════════════════════════════════════
//
// sys_open takes a C-string pointer. hexa string → cstring via a small
// arena alloc + copy. Caller must arena_rewind after use (or ignore if
// within same arena scope).

fn to_cstr(s: string) -> int {
    let n = len(s)
    let buf = hexa_ptr_alloc(n + 1)
    let bytes = hexa_str_bytes(s)  // [int] of byte values
    let mut i = 0
    while i < n {
        hexa_ptr_write_byte(buf, i, bytes[i])
        i = i + 1
    }
    hexa_ptr_write_byte(buf, n, 0)
    return buf
}

// ═══════════════════════════════════════════════════════════════════
// Low-level byte writers
// ═══════════════════════════════════════════════════════════════════

// Write a byte buffer (len bytes) to fd. Loops on partial writes.
fn write_all(fd: int, buf: int, len_bytes: int) -> int {
    let mut written = 0
    while written < len_bytes {
        let n = sys_write(fd, buf + written, len_bytes - written)
        if n <= 0 { return n }
        written = written + n
    }
    return written
}

// Read up to `cap` bytes into buf. Returns bytes read, or -errno.
fn read_once(fd: int, buf: int, cap: int) -> int {
    return sys_read(fd, buf, cap)
}

// Read entire fd into a freshly-allocated buffer. Returns (ptr, size).
fn read_to_end(fd: int) -> [int] {
    let chunk = 65536
    let mut buf = hexa_ptr_alloc(chunk)
    let mut cap = chunk
    let mut filled = 0
    while true {
        if filled + chunk > cap {
            let new_cap = cap * 2
            let new_buf = hexa_ptr_alloc(new_cap)
            let mut i = 0
            while i < filled {
                hexa_ptr_write_byte(new_buf, i, hexa_ptr_read_byte(buf, i))
                i = i + 1
            }
            hexa_ptr_free(buf, cap)
            buf = new_buf
            cap = new_cap
        }
        let n = sys_read(fd, buf + filled, chunk)
        if n <= 0 { return [buf, filled] }
        filled = filled + n
    }
    return [buf, filled]
}

// ═══════════════════════════════════════════════════════════════════
// print / println / eprint
// ═══════════════════════════════════════════════════════════════════

fn hexa_print_val(v) {
    let s = hexa_to_string(v)
    let cs = to_cstr(s)
    write_all(STDOUT(), cs, len(s))
}

fn hexa_println(v) {
    hexa_print_val(v)
    let nl = hexa_ptr_alloc(1)
    hexa_ptr_write_byte(nl, 0, 10)  // '\n'
    write_all(STDOUT(), nl, 1)
}

fn hexa_eprint_val(v) {
    let s = hexa_to_string(v)
    let cs = to_cstr(s)
    write_all(STDERR(), cs, len(s))
}

fn hexa_eprintln(v) {
    hexa_eprint_val(v)
    let nl = hexa_ptr_alloc(1)
    hexa_ptr_write_byte(nl, 0, 10)
    write_all(STDERR(), nl, 1)
}

// ═══════════════════════════════════════════════════════════════════
// File I/O
// ═══════════════════════════════════════════════════════════════════

fn hexa_read_file(path) -> string {
    let cs = to_cstr(path)
    let fd = sys_open(cs, O_RDONLY(), 0)
    if fd < 0 { return "" }
    let result = read_to_end(fd)
    sys_close(fd)
    let buf = result[0]
    let n = result[1]
    // Build hexa string from raw bytes.
    return bytes_to_string(buf, n)
}

fn hexa_read_file_bytes(path) -> [int] {
    let cs = to_cstr(path)
    let fd = sys_open(cs, O_RDONLY(), 0)
    if fd < 0 { return [] }
    let result = read_to_end(fd)
    sys_close(fd)
    let buf = result[0]
    let n = result[1]
    let mut out = []
    let mut i = 0
    while i < n {
        out.push(hexa_ptr_read_byte(buf, i))
        i = i + 1
    }
    return out
}

fn hexa_write_file(path, content) -> int {
    let cs = to_cstr(path)
    let flags = O_WRONLY() + flag_o_creat() + flag_o_trunc()
    let mode = 420  // 0644
    let fd = sys_open(cs, flags, mode)
    if fd < 0 { return fd }
    let s = hexa_to_string(content)
    let data = to_cstr(s)
    let n = write_all(fd, data, len(s))
    sys_close(fd)
    return n
}

fn hexa_write_bytes(path, arr) -> int {
    let cs = to_cstr(path)
    let flags = O_WRONLY() + flag_o_creat() + flag_o_trunc()
    let fd = sys_open(cs, flags, 420)
    if fd < 0 { return fd }
    let n = len(arr)
    let buf = hexa_ptr_alloc(n)
    let mut i = 0
    while i < n {
        hexa_ptr_write_byte(buf, i, arr[i])
        i = i + 1
    }
    let written = write_all(fd, buf, n)
    sys_close(fd)
    return written
}

fn hexa_append_file(path, content) -> int {
    let cs = to_cstr(path)
    let flags = O_WRONLY() + flag_o_creat() + flag_o_append()
    let fd = sys_open(cs, flags, 420)
    if fd < 0 { return fd }
    let s = hexa_to_string(content)
    let data = to_cstr(s)
    let n = write_all(fd, data, len(s))
    sys_close(fd)
    return n
}

fn hexa_write_bytes_append(path, arr) -> int {
    let cs = to_cstr(path)
    let flags = O_WRONLY() + flag_o_creat() + flag_o_append()
    let fd = sys_open(cs, flags, 420)
    if fd < 0 { return fd }
    let n = len(arr)
    let buf = hexa_ptr_alloc(n)
    let mut i = 0
    while i < n {
        hexa_ptr_write_byte(buf, i, arr[i])
        i = i + 1
    }
    let written = write_all(fd, buf, n)
    sys_close(fd)
    return written
}

fn hexa_delete_file(path) -> int {
    let cs = to_cstr(path)
    return sys_unlink(cs)
}

fn hexa_file_size(path) -> int {
    // fstat path — zero data movement, matches runtime.c semantics.
    // Linux x86_64 struct stat: st_size @ offset 48 (i64)
    // Darwin fstat64 struct:    st_size @ offset 96 (i64)
    // Falls back to lseek(END) if fstat returns <0 (portable proxy).
    let cs = to_cstr(path)
    let fd = sys_open(cs, O_RDONLY(), 0)
    if fd < 0 { return -1 }
    let stat_buf = hexa_ptr_alloc(256)  // oversized; largest stat ~144B
    let mut size = -1
    if target_is_linux() {
        let rc = syscall(SYS_LINUX_FSTAT(), fd, stat_buf)
        if rc >= 0 { size = __mem_load64(stat_buf + 48) }
    } else {
        let rc = syscall(SYS_DARWIN_FSTAT64(), fd, stat_buf)
        if rc >= 0 { size = __mem_load64(stat_buf + 96) }
    }
    if size < 0 { size = sys_lseek(fd, 0, 2) }  // SEEK_END = 2
    sys_close(fd)
    return size
}

fn hexa_file_exists(path) -> int {
    // Boolean probe (int 0/1). Avoids full read_file round-trip.
    let cs = to_cstr(path)
    let fd = sys_open(cs, O_RDONLY(), 0)
    if fd < 0 { return 0 }
    sys_close(fd)
    return 1
}

// pread-style ranged read. Used for multi-GB safetensors streaming
// (whole-file read_file_bytes can't fit). Returns [int] of ≤nbytes
// byte values; empty on open failure or past-EOF.
fn hexa_read_bytes_at(path, off: int, nbytes: int) -> [int] {
    if off < 0 { return [] }
    if nbytes <= 0 { return [] }
    let cs = to_cstr(path)
    let fd = sys_open(cs, O_RDONLY(), 0)
    if fd < 0 { return [] }
    let pos = sys_lseek(fd, off, 0)  // SEEK_SET = 0
    if pos < 0 { sys_close(fd); return [] }
    let buf = hexa_ptr_alloc(nbytes)
    let mut total = 0
    while total < nbytes {
        let n = sys_read(fd, buf + total, nbytes - total)
        if n <= 0 { break }
        total = total + n
    }
    sys_close(fd)
    let mut out = []
    let mut i = 0
    while i < total {
        out.push(hexa_ptr_read_byte(buf, i))
        i = i + 1
    }
    return out
}

fn hexa_read_lines(path) -> [string] {
    let content = hexa_read_file(path)
    return hexa_str_split(content, "\n")
}

fn hexa_input(prompt) -> string {
    if hexa_to_string(prompt) != "" {
        hexa_print_val(prompt)
    }
    // Read up to 4KB from stdin, trim trailing '\n'.
    let cap = 4096
    let buf = hexa_ptr_alloc(cap)
    let n = read_once(STDIN(), buf, cap)
    if n <= 0 { return "" }
    // Strip trailing newline.
    let mut end = n
    if end > 0 {
        if hexa_ptr_read_byte(buf, end - 1) == 10 { end = end - 1 }
    }
    return bytes_to_string(buf, end)
}

// ═══════════════════════════════════════════════════════════════════
// bytes_to_string — intrinsic shim
// ═══════════════════════════════════════════════════════════════════
//
// Transfers `n` bytes at `ptr` into a hexa string (UTF-8 assumed).
// This is a compiler builtin recognized by codegen (same class as
// syscall / __mem_load8). For the interim standalone build it is
// provided by runtime.c as hexa_str(); once P7-7b alloc + P7-7a
// syscall land, this builds a tagged string from the raw bytes.

@inline fn bytes_to_string(ptr: int, n: int) -> string {
    return __string_from_bytes(ptr, n)
}

// 64-bit load — codegen lowers to LDR (ARM64) / mov (x86_64).
// Required by fstat-based hexa_file_size for st_size field extraction.
@inline fn __mem_load64(addr: int) -> int {
    return 0
}

// ═══════════════════════════════════════════════════════════════════
// P7-7b slice 2 — rt_* surface (libc stdio independence)
// ═══════════════════════════════════════════════════════════════════
//
// Mirrors the minimal libc stdio surface needed by hexa_print_val /
// hexa_println in runtime.c L2586-2605, but routed through Darwin
// SYS_write (33554436) directly. Lets interp drop libc fwrite/puts
// for the print path.
//
// Pure hexa over self::rt::syscall.sys_write (already target-aware).
// Returns bytes written (>=0) or syscall errno (<0).

@pure fn rt_stdout_fd() -> int { return 1 }
@pure fn rt_stderr_fd() -> int { return 2 }

fn rt_write_str(fd: int, s: string) -> int {
    let n = len(s)
    let cs = to_cstr(s)
    return write_all(fd, cs, n)
}

fn rt_eprintln(s: string) -> int {
    return rt_write_str(rt_stderr_fd(), s + "\n")
}

fn rt_println(s: string) -> int {
    return rt_write_str(rt_stdout_fd(), s + "\n")
}
