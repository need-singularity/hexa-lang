// self/rt/map_ops.hexa — P7-7: pure-hexa map ops (Category A)
//
// Wraps self/runtime/map_pure.hexa (+ map_ext_pure.hexa) under the
// rt_map_* surface so codegen can swap the runtime.c hexa_map_*
// shims for hexa-native calls. Low-level allocation (new / set /
// get via the host) stays in the host primitive; everything
// higher-order runs on pure hexa.
//
// Reuse map:
//   self/runtime/map_pure.hexa      keys, values, entries, contains_key,
//                                   merge, map_values, filter_keys,
//                                   filter, invert, from_entries, update,
//                                   get_or
//   self/runtime/map_ext_pure.hexa  partition, count_by, invert_multi
//
// Inline (re)implementations (no _pure equivalent or semantic mismatch):
//   rt_map_new, rt_map_set, rt_map_get, rt_map_remove,
//   rt_map_from_array, rt_map_to_array
//
// Pitfalls (grammar.jsonl):
//   P1  no semicolons
//   P15 let mut everywhere

use self::runtime::map_pure
use self::runtime::map_ext_pure

// ═══════════════════════════════════════════════════════════════════
// Core — owns the #{} literal / mutation primitives
// ═══════════════════════════════════════════════════════════════════

@pure pub fn rt_map_new() {
    return #{}
}

// rt_map_set — functional (C version mutates; we return new to stay pure).
@pure pub fn rt_map_set(m, k, v) {
    let mut out = #{}
    let ks = keys(m)
    let n = len(ks)
    let mut i = 0
    while i < n {
        let key = ks[i]
        out[key] = m[key]
        i = i + 1
    }
    out[k] = v
    return out
}

// rt_map_get — returns value or void if absent (mirrors hexa_map_get).
@pure pub fn rt_map_get(m, k) {
    if has_key(m, k) { return m[k] }
    return void
}

// rt_map_remove — returns new map without key k.
@pure pub fn rt_map_remove(m, k) {
    let mut out = #{}
    let ks = keys(m)
    let n = len(ks)
    let mut i = 0
    while i < n {
        let key = ks[i]
        if key != k {
            out[key] = m[key]
        }
        i = i + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════════
// Reuse wrappers — over map_pure.hexa
// ═══════════════════════════════════════════════════════════════════

@pure pub fn rt_map_keys(m)                  { return map_keys_pure(m) }
@pure pub fn rt_map_values(m)                { return map_values_pure(m) }
@pure pub fn rt_map_entries(m)               { return map_entries_pure(m) }
@pure pub fn rt_map_contains_key(m, k)       { return map_has_key_pure(m, k) }
@pure pub fn rt_map_size(m)                  { return map_size_pure(m) }
@pure pub fn rt_map_get_or(m, k, def)        { return map_get_or_pure(m, k, def) }
@pure pub fn rt_map_merge(a, b)              { return map_merge_pure(a, b) }
@pure pub fn rt_map_map_values(m, fn)        { return map_map_values_pure(m, fn) }
@pure pub fn rt_map_filter_keys(m, pred)     { return map_filter_keys_pure(m, pred) }
@pure pub fn rt_map_filter(m, pred)          { return map_filter_pure(m, pred) }
@pure pub fn rt_map_invert(m)                { return map_invert_pure(m) }
@pure pub fn rt_map_update(m, k, fn, def)    { return map_update_pure(m, k, fn, def) }
@pure pub fn rt_map_partition(m, pred)       { return map_partition_pure(m, pred) }
@pure pub fn rt_map_count_by(arr, fn)        { return map_count_by_pure(arr, fn) }
@pure pub fn rt_map_invert_multi(m)          { return map_invert_multi_pure(m) }

// ═══════════════════════════════════════════════════════════════════
// Array bridges — match runtime.c hexa_map_from_array / to_array
// ═══════════════════════════════════════════════════════════════════

// rt_map_from_array — build map from [[k, v], ...] pair array.
// Mirrors hexa_map_from_array (runtime.c:1606); identical to
// map_from_entries_pure but exposed under the rt_* name.
@pure pub fn rt_map_from_array(arr) {
    return map_from_entries_pure(arr)
}

// rt_map_to_array — [[k, v], ...] view. Same shape as entries().
@pure pub fn rt_map_to_array(m) {
    return map_entries_pure(m)
}
