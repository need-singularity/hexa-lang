// self/rt/fs.hexa — P7-7e: hexa filesystem over syscalls
//
// Covers mmap-based weight loading, directory listing, stat, mkdir.
//
// Surface:
//   fs_mmap_ro(path) -> (addr, size)     — read-only mmap for weight files
//   fs_munmap(addr, size)
//   fs_stat_size(path) -> int            — file size via lseek (portable)
//   fs_exists(path) -> bool
//   fs_readdir(path) -> [string]         — directory entries
//   fs_mkdir(path, mode) -> int
//
// rt_* aliases match the project's rt_list_dir / rt_file_exists / rt_stat
// / rt_mkdir convention expected by upper layers (hexa_full, codegen).

use self::rt::syscall
use self::rt::alloc

// ═══════════════════════════════════════════════════════════════════
// mmap (read-only)
// ═══════════════════════════════════════════════════════════════════
//
// Used by weight loaders: Qwen/LoRA/vocoder all mmap binary blobs.

fn fs_mmap_ro(path: string) -> [int] {
    let cs = to_cstr(path)
    let fd = sys_open(cs, O_RDONLY(), 0)
    if fd < 0 { return [0, 0] }
    let size = sys_lseek(fd, 0, 2)
    if size <= 0 { sys_close(fd); return [0, 0] }
    let addr = sys_mmap(0, size, PROT_READ(), MAP_PRIVATE(), fd, 0)
    sys_close(fd)
    if addr < 0 { return [0, 0] }
    return [addr, size]
}

fn fs_munmap(addr: int, size: int) -> int {
    return sys_munmap(addr, size)
}

// ═══════════════════════════════════════════════════════════════════
// stat — file size via lseek (portable, avoids per-target stat struct)
// ═══════════════════════════════════════════════════════════════════

fn fs_stat_size(path: string) -> int {
    let cs = to_cstr(path)
    let fd = sys_open(cs, O_RDONLY(), 0)
    if fd < 0 { return -1 }
    let size = sys_lseek(fd, 0, 2)
    sys_close(fd)
    return size
}

fn fs_exists(path: string) -> bool {
    return fs_stat_size(path) >= 0
}

// ═══════════════════════════════════════════════════════════════════
// mkdir
// ═══════════════════════════════════════════════════════════════════

fn fs_mkdir(path: string, mode: int) -> int {
    let cs = to_cstr(path)
    return sys_mkdir(cs, mode)
}

// ═══════════════════════════════════════════════════════════════════
// readdir — directory listing
// ═══════════════════════════════════════════════════════════════════
//
// Linux: sys_getdents64(fd, buf, size). linux_dirent64 layout:
//   u64 ino, s64 off, u16 reclen, u8 type, char name[]   (19B + name)
//
// Darwin: sys_getdirentries64(fd, buf, size, &basep). dirent layout:
//   u64 d_fileno, u64 d_seekoff, u16 d_reclen, u16 d_namlen,
//   u8 d_type, char d_name[1024]                         (21B hdr + name)
// Record is reclen-aligned; d_namlen excludes the trailing NUL so we
// use it directly instead of scanning for '\0'.

fn fs_readdir(path: string) -> [string] {
    let cs = to_cstr(path)
    let fd = sys_open(cs, O_RDONLY(), 0)
    if fd < 0 { return [] }
    let mut entries = []
    if target_is_linux() {
        entries = readdir_linux(fd)
    } else {
        entries = readdir_darwin(fd)
    }
    sys_close(fd)
    return entries
}

fn readdir_linux(fd: int) -> [string] {
    let buf_size = 4096
    let buf = hexa_ptr_alloc(buf_size)
    let mut out = []
    while true {
        let n = syscall(SYS_LINUX_GETDENTS64(), fd, buf, buf_size)
        if n <= 0 { return out }
        let mut off = 0
        while off < n {
            // linux_dirent64:
            //   0: u64 d_ino, 8: s64 d_off, 16: u16 d_reclen,
            //  18: u8 d_type, 19: char d_name[]   (NUL-terminated within reclen)
            let reclen = __mem_load16(buf + off + 16)
            let mut name_end = off + 19
            while hexa_ptr_read_byte(buf, name_end) != 0 && name_end < off + reclen {
                name_end = name_end + 1
            }
            out.push(bytes_to_string(buf + off + 19, name_end - off - 19))
            off = off + reclen
        }
    }
    return out
}

fn readdir_darwin(fd: int) -> [string] {
    let buf_size = 4096
    let buf = hexa_ptr_alloc(buf_size)
    // basep is an in/out u64 — Darwin writes the next-read cookie.
    let basep = hexa_ptr_alloc(8)
    __mem_store64(basep, 0)
    let mut out = []
    while true {
        let n = syscall(SYS_DARWIN_GETDIRENTRIES64(), fd, buf, buf_size, basep)
        if n <= 0 { return out }
        let mut off = 0
        while off < n {
            // darwin dirent (64-bit inode variant):
            //   0: u64 d_fileno, 8: u64 d_seekoff,
            //  16: u16 d_reclen, 18: u16 d_namlen,
            //  20: u8  d_type,   21: char d_name[]
            let reclen = __mem_load16(buf + off + 16)
            let namlen = __mem_load16(buf + off + 18)
            out.push(bytes_to_string(buf + off + 21, namlen))
            off = off + reclen
        }
    }
    return out
}

// ═══════════════════════════════════════════════════════════════════
// rt_* aliases — names used by hexa_full / compile pipeline
// ═══════════════════════════════════════════════════════════════════

fn rt_list_dir(path: string) -> [string] { return fs_readdir(path) }
fn rt_file_exists(path: string) -> bool { return fs_exists(path) }
fn rt_stat(path: string) -> int { return fs_stat_size(path) }
fn rt_mkdir(path: string, mode: int) -> int { return fs_mkdir(path, mode) }

// ═══════════════════════════════════════════════════════════════════
// Intrinsic shims (recognized by codegen; lowered to single instrs)
// ═══════════════════════════════════════════════════════════════════

@inline fn __mem_load16(addr: int) -> int { return 0 }
@inline fn __mem_store64(addr: int, val: int) -> int { return 0 }
