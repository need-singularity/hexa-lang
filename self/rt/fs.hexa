// self/rt/fs.hexa — P7-7e: hexa filesystem over syscalls
//
// Covers mmap-based weight loading, directory listing, stat.
//
// Surface:
//   fs_mmap_ro(path) -> (addr, size)     — read-only mmap for weight files
//   fs_munmap(addr, size)
//   fs_stat_size(path) -> int            — file size via stat/lseek
//   fs_readdir(path) -> [string]         — directory entries (Linux getdents64 / Darwin getdirentries)

use self::rt::syscall
use self::rt::alloc

// ═══════════════════════════════════════════════════════════════════
// mmap (read-only)
// ═══════════════════════════════════════════════════════════════════
//
// Used by weight loaders: Qwen/LoRA/vocoder all mmap binary blobs.

fn fs_mmap_ro(path: string) -> [int] {
    let cs = to_cstr(path)
    let fd = sys_open(cs, O_RDONLY(), 0)
    if fd < 0 { return [0, 0] }
    let size = sys_lseek(fd, 0, 2)
    if size <= 0 { sys_close(fd); return [0, 0] }
    let addr = sys_mmap(0, size, PROT_READ(), MAP_PRIVATE(), fd, 0)
    sys_close(fd)
    if addr < 0 { return [0, 0] }
    return [addr, size]
}

fn fs_munmap(addr: int, size: int) -> int {
    return sys_munmap(addr, size)
}

// ═══════════════════════════════════════════════════════════════════
// stat — file size via lseek (portable, avoids per-target stat struct)
// ═══════════════════════════════════════════════════════════════════

fn fs_stat_size(path: string) -> int {
    let cs = to_cstr(path)
    let fd = sys_open(cs, O_RDONLY(), 0)
    if fd < 0 { return -1 }
    let size = sys_lseek(fd, 0, 2)
    sys_close(fd)
    return size
}

fn fs_exists(path: string) -> bool {
    return fs_stat_size(path) >= 0
}

// ═══════════════════════════════════════════════════════════════════
// readdir — directory listing
// ═══════════════════════════════════════════════════════════════════
//
// Linux: sys_getdents64(fd, buf, size). Parses linux_dirent64 layout:
//   u64 ino, s64 off, u16 reclen, u8 type, char name[]
//
// Darwin: sys_getdirentries(fd, buf, size, basep). Different struct.
// For cross-portability, we expose a single getdents parser per target.
//
// TODO(P7-7e-2): Darwin dirent layout.

fn fs_readdir(path: string) -> [string] {
    let cs = to_cstr(path)
    let fd = sys_open(cs, O_RDONLY(), 0)
    if fd < 0 { return [] }
    let mut entries = []
    if target_is_linux() {
        entries = readdir_linux(fd)
    } else {
        entries = readdir_darwin(fd)
    }
    sys_close(fd)
    return entries
}

fn readdir_linux(fd: int) -> [string] {
    let buf_size = 4096
    let buf = hexa_ptr_alloc(buf_size)
    let mut out = []
    while true {
        let n = syscall(SYS_LINUX_GETDENTS64(), fd, buf, buf_size)
        if n <= 0 { return out }
        let mut off = 0
        while off < n {
            // linux_dirent64 layout:
            //   0: u64 d_ino
            //   8: s64 d_off
            //  16: u16 d_reclen
            //  18: u8  d_type
            //  19: char d_name[]
            let reclen = __mem_load16(buf + off + 16)
            let mut name_end = off + 19
            while hexa_ptr_read_byte(buf, name_end) != 0 && name_end < off + reclen {
                name_end = name_end + 1
            }
            out = out.push(bytes_to_string(buf + off + 19, name_end - off - 19))
            off = off + reclen
        }
    }
    return out
}

fn readdir_darwin(fd: int) -> [string] {
    // TODO(P7-7e-2): Darwin dirent64 layout — ino(u64) + seekoff(u64) +
    // reclen(u16) + namlen(u16) + type(u8) + name[]. Then
    // getdirentries64 syscall number.
    return []
}

// ═══════════════════════════════════════════════════════════════════
// Intrinsic shim
// ═══════════════════════════════════════════════════════════════════

@inline fn __mem_load16(addr: int) -> int { return 0 }
