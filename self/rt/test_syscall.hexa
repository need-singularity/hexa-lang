// self/rt/test_syscall.hexa — P7-7a smoke test
//
// Pure syscall → write + exit. No runtime.c linkage. Target binary
// should be <= 4KB.
//
// Build & run (Mac ARM64):
//   hexa compile --target=darwin-arm64 self/rt/test_syscall.hexa -o /tmp/hx_sc
//   /tmp/hx_sc ; echo "exit=$?"   # expect: hello from syscall\n  exit=0
//
// Build & run (Linux x86_64):
//   hexa compile --target=linux-x86_64 self/rt/test_syscall.hexa -o /tmp/hx_sc
//   /tmp/hx_sc ; echo "exit=$?"   # expect: hello from syscall\n  exit=0

use self::rt::syscall

fn main() -> int {
    let msg = "hello from syscall\n"
    let addr = hexa_ptr_addr(msg)
    let n = sys_write(1, addr, 19)
    if n < 0 { sys_exit(1) }
    sys_exit(0)
    return 0
}
