// self/rt/test_string.hexa — P7-7b slice 3: rt_str_* verification
//
// 1-3 examples per function. Runs as a plain hexa script — each check
// prints "ok <name>" on pass, or "FAIL <name> got=<v> want=<v>". Keeps
// failures on stdout so stage0 self-hosting builds can grep.

use self::rt::string

fn check_eq_str(label: string, got: string, want: string) {
    if got == want {
        println("ok " + label)
    } else {
        println("FAIL " + label + " got=\"" + got + "\" want=\"" + want + "\"")
    }
}

fn check_eq_int(label: string, got: int, want: int) {
    if got == want {
        println("ok " + label)
    } else {
        println("FAIL " + label + " got=" + to_string(got) + " want=" + to_string(want))
    }
}

fn check_eq_bool(label: string, got: bool, want: bool) {
    if got == want {
        println("ok " + label)
    } else {
        println("FAIL " + label)
    }
}

fn check_eq_float(label: string, got: float, want: float) {
    // Exact equality is fine for our test inputs (no rounding).
    if got == want {
        println("ok " + label)
    } else {
        println("FAIL " + label + " got=" + to_string(got) + " want=" + to_string(want))
    }
}

fn main() -> int {
    // concat
    check_eq_str("concat basic",  rt_str_concat("foo", "bar"), "foobar")
    check_eq_str("concat left-empty",  rt_str_concat("", "x"), "x")
    check_eq_str("concat right-empty", rt_str_concat("x", ""), "x")

    // contains / eq
    check_eq_bool("contains yes", rt_str_contains("hello world", "wor"), true)
    check_eq_bool("contains no",  rt_str_contains("hello", "zz"), false)
    check_eq_bool("eq yes", rt_str_eq("abc", "abc"), true)
    check_eq_bool("eq no",  rt_str_eq("abc", "abd"), false)

    // substring
    check_eq_str("substring mid", rt_str_substring("hello", 1, 4), "ell")
    check_eq_str("substring clamp-hi", rt_str_substring("ab", 0, 99), "ab")
    check_eq_str("substring empty a>=b", rt_str_substring("ab", 2, 1), "")

    // slice
    check_eq_str("slice mid", rt_str_slice("hello", 1, 4), "ell")
    check_eq_str("slice clamp-neg", rt_str_slice("ab", -3, 2), "ab")
    check_eq_str("slice clamp-a>b", rt_str_slice("abcd", 3, 1), "")

    // trim family
    check_eq_str("trim", rt_str_trim("  hi  "), "hi")
    check_eq_str("trim_start", rt_str_trim_start("\t hi"), "hi")
    check_eq_str("trim_end", rt_str_trim_end("hi \n"), "hi")

    // replace
    check_eq_str("replace all", rt_str_replace("a.b.c", ".", "-"), "a-b-c")
    check_eq_str("replace noop on empty needle", rt_str_replace("abc", "", "X"), "abc")
    check_eq_str("replace grow", rt_str_replace("xx", "x", "YY"), "YYYY")

    // pad_left / pad_right
    check_eq_str("pad_left basic", rt_str_pad_left("7", 3, "0"), "007")
    check_eq_str("pad_right basic", rt_str_pad_right("7", 3, "."), "7..")
    check_eq_str("pad unchanged", rt_str_pad_left("abcd", 2, " "), "abcd")

    // repeat
    check_eq_str("repeat 3x", rt_str_repeat("ab", 3), "ababab")
    check_eq_str("repeat 0", rt_str_repeat("ab", 0), "")
    check_eq_str("repeat neg", rt_str_repeat("ab", -5), "")

    // index_of
    check_eq_int("index_of hit", rt_str_index_of("hello", "ll"), 2)
    check_eq_int("index_of miss", rt_str_index_of("hello", "zz"), -1)
    check_eq_int("index_of empty needle", rt_str_index_of("hello", ""), 0)

    // reverse
    check_eq_str("reverse", rt_str_reverse("hello"), "olleh")
    check_eq_str("reverse empty", rt_str_reverse(""), "")

    // char_at / char_code_at
    check_eq_str("char_at mid", rt_str_char_at("hello", 1), "e")
    check_eq_str("char_at oob", rt_str_char_at("hi", 5), "")
    check_eq_int("char_code_at mid", rt_str_char_code_at("hello", 0), 104)
    check_eq_int("char_code_at oob", rt_str_char_code_at("hi", 5), 0)

    // from_chars (round-trip)
    let codes = rt_str_bytes("Hi!")
    check_eq_str("from_chars roundtrip", rt_str_from_chars(codes), "Hi!")

    // parse_int — decimal, sign, hex, unparseable
    check_eq_int("parse_int dec", rt_str_parse_int("42"), 42)
    check_eq_int("parse_int neg", rt_str_parse_int("-17"), -17)
    check_eq_int("parse_int hex", rt_str_parse_int("0x2A"), 42)
    check_eq_int("parse_int junk", rt_str_parse_int("hello"), 0)
    check_eq_int("parse_int leading-zero dec", rt_str_parse_int("0777"), 777)

    // parse_float — int, frac, exp, sign, junk
    check_eq_float("parse_float int", rt_str_parse_float("3"), 3.0)
    check_eq_float("parse_float frac", rt_str_parse_float("1.5"), 1.5)
    check_eq_float("parse_float neg", rt_str_parse_float("-2.25"), -2.25)
    check_eq_float("parse_float exp+", rt_str_parse_float("2e2"), 200.0)
    check_eq_float("parse_float junk", rt_str_parse_float("abc"), 0.0)

    // to_string helpers
    check_eq_str("to_string_int", rt_str_to_string_int(42), "42")
    check_eq_str("to_string_float", rt_str_to_string_float(1.5), "1.5")

    // ═══════════════════════════════════════════════════════════════
    // Integration tests — compose multiple rt_str_* kernels to verify
    // they cohere at the boundary (not just pass in isolation).
    // ═══════════════════════════════════════════════════════════════

    // IT1: concat/eq round-trip — concat the decomposition and check
    //      rt_str_eq accepts the reassembled string.
    let it1_full = rt_str_concat(rt_str_concat("hex", "a-"), "lang")
    check_eq_str("IT1 concat roundtrip", it1_full, "hexa-lang")
    check_eq_bool("IT1 eq roundtrip",   rt_str_eq(it1_full, "hexa-lang"), true)
    check_eq_bool("IT1 eq roundtrip neg", rt_str_eq(it1_full, "hexa-LANG"), false)

    // IT2: substring bounds edge cases — negative/over-range clamp to
    //      the full string, inverted a>=b returns "", exact boundaries
    //      match the whole input.
    let it2_src = "boundary"
    check_eq_str("IT2 substring neg-start clamps",    rt_str_substring(it2_src, -4, 4), "boun")
    check_eq_str("IT2 substring over-end clamps",     rt_str_substring(it2_src, 4, 999), "dary")
    check_eq_str("IT2 substring zero-width a==b",     rt_str_substring(it2_src, 3, 3), "")
    check_eq_str("IT2 substring full span",           rt_str_substring(it2_src, 0, 8), "boundary")

    // IT3: parse_int failure path — strtoll-compatible "no digits" →
    //      0. Empty, pure junk, lone sign, and hex prefix without
    //      trailing digits all return 0 (matching runtime.c L4697).
    check_eq_int("IT3 parse_int empty",         rt_str_parse_int(""), 0)
    check_eq_int("IT3 parse_int lone sign",     rt_str_parse_int("-"), 0)
    check_eq_int("IT3 parse_int pure junk",     rt_str_parse_int("zzz"), 0)
    check_eq_int("IT3 parse_int 0x-no-digits",  rt_str_parse_int("0x"), 0)
    check_eq_int("IT3 parse_int partial consume", rt_str_parse_int("12abc"), 12)

    // IT4: split / join inverse — splitting then joining with the same
    //      separator reconstructs the source (for non-empty separators
    //      that actually appear). Matches the runtime.c pair.
    let it4_src = "a,b,c,d"
    let it4_parts = rt_str_split(it4_src, ",")
    check_eq_int("IT4 split count", len(it4_parts), 4)
    check_eq_str("IT4 split/join inverse", rt_str_join(it4_parts, ","), it4_src)
    // Inverse holds for trailing-empty edge case: "a,," → ["a","",""] → "a,,"
    let it4_trail = rt_str_split("a,,", ",")
    check_eq_int("IT4 split trailing empties", len(it4_trail), 3)
    check_eq_str("IT4 join trailing empties",  rt_str_join(it4_trail, ","), "a,,")

    // IT5: char_at ASCII + multi-byte codepoint — ASCII letter, digit,
    //      and a UTF-8 byte-level check (Korean "한" = E1 95 9C → 3 bytes,
    //      first byte 0xED = 237). char_code_at is byte-based per
    //      rt_str_bytes semantics, so we verify the first byte value.
    let it5_ascii = "Abc1"
    check_eq_str("IT5 char_at ASCII upper",      rt_str_char_at(it5_ascii, 0), "A")
    check_eq_str("IT5 char_at ASCII digit",      rt_str_char_at(it5_ascii, 3), "1")
    check_eq_int("IT5 char_code_at ASCII 'A'",   rt_str_char_code_at(it5_ascii, 0), 65)
    check_eq_int("IT5 char_code_at ASCII '1'",   rt_str_char_code_at(it5_ascii, 3), 49)
    // Korean "한" UTF-8 = 0xED 0x95 0x9C (first byte 237).
    let it5_kor = "한"
    check_eq_int("IT5 char_code_at UTF-8 first-byte", rt_str_char_code_at(it5_kor, 0), 237)
    check_eq_int("IT5 str len 3-byte codepoint",      len(it5_kor), 3)

    return 0
}
