// self/rt/test_io.hexa — P7-7c smoke test
//
// Round-trip: write "hello\n" → read back → verify → delete.
// Pure hexa over self::rt::io / syscall / alloc — no runtime.c linkage.
//
// Build & run (Mac ARM64):
//   hexa compile --target=darwin-arm64 self/rt/test_io.hexa -o /tmp/hx_io
//   /tmp/hx_io ; echo "exit=$?"   # expect: ok\n  exit=0
//
// Build & run (Linux x86_64):
//   hexa compile --target=linux-x86_64 self/rt/test_io.hexa -o /tmp/hx_io
//   /tmp/hx_io ; echo "exit=$?"   # expect: ok\n  exit=0

use self::rt::syscall
use self::rt::alloc
use self::rt::io

fn main() -> int {
    rt_init()

    let path = "/tmp/rt_io_test"
    let payload = "hello\n"

    // 1. write
    let w = hexa_write_file(path, payload)
    if w < 0 { sys_exit(1) }

    // 2. file_size matches payload length
    let sz = hexa_file_size(path)
    if sz != 6 { sys_exit(2) }

    // 3. read back and verify byte-for-byte
    let got = hexa_read_file(path)
    if len(got) != 6 { sys_exit(3) }
    let gb = hexa_str_bytes(got)
    if gb[0] != 104 { sys_exit(4) }  // 'h'
    if gb[1] != 101 { sys_exit(4) }  // 'e'
    if gb[2] != 108 { sys_exit(4) }  // 'l'
    if gb[3] != 108 { sys_exit(4) }  // 'l'
    if gb[4] != 111 { sys_exit(4) }  // 'o'
    if gb[5] != 10  { sys_exit(4) }  // '\n'

    // 4. append adds 6 more bytes
    let a = hexa_append_file(path, payload)
    if a < 0 { sys_exit(5) }
    let sz2 = hexa_file_size(path)
    if sz2 != 12 { sys_exit(6) }

    // 5. read_bytes_at mid-range
    let slice = hexa_read_bytes_at(path, 6, 3)
    if len(slice) != 3 { sys_exit(7) }
    if slice[0] != 104 { sys_exit(8) }  // 'h'

    // 6. delete + confirm gone
    let d = hexa_delete_file(path)
    if d < 0 { sys_exit(9) }
    if hexa_file_exists(path) != 0 { sys_exit(10) }

    // 7. println success marker
    rt_println("ok")
    sys_exit(0)
    return 0
}
