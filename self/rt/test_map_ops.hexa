// self/rt/test_map_ops.hexa — smoke test for rt/map_ops.hexa
//
// Verifies the rt_map_* wrappers delegate correctly by spot-checking
// five operations. Runs under the interpreter (hexa self/rt/test_map_ops.hexa).

use self::rt::map_ops

let mut FAILS = 0

fn check(name, got, expected) {
    if got == expected {
        print("PASS ")
        println(name)
    } else {
        FAILS = FAILS + 1
        print("FAIL ")
        print(name)
        print(" got=")
        print(to_string(got))
        print(" want=")
        println(to_string(expected))
    }
}

// Build a base map via rt_map_set (keeps everything on the rt_* surface).
let m0 = rt_map_new()
let m1 = rt_map_set(m0, "a", 1)
let m2 = rt_map_set(m1, "b", 2)
let m  = rt_map_set(m2, "c", 3)

// 1. size / get
check("size", rt_map_size(m), 3)
check("get-b", rt_map_get(m, "b"), 2)

// 2. contains_key — positive + negative
check("contains yes", rt_map_contains_key(m, "a"), true)
check("contains no",  rt_map_contains_key(m, "z"), false)

// 3. remove
let mr = rt_map_remove(m, "b")
check("remove-size",    rt_map_size(mr), 2)
check("remove-missing", rt_map_contains_key(mr, "b"), false)

// 4. map_values — double every value
let md = rt_map_map_values(m, |v| v * 2)
check("map_values-a", rt_map_get(md, "a"), 2)
check("map_values-c", rt_map_get(md, "c"), 6)

// 5. merge — rhs wins on collision
let other = rt_map_set(rt_map_new(), "b", 99)
let merged = rt_map_merge(m, other)
check("merge-override", rt_map_get(merged, "b"), 99)
check("merge-preserve", rt_map_get(merged, "a"), 1)

if FAILS == 0 {
    println("all map_ops tests passed")
} else {
    print("map_ops tests failed: ")
    println(to_string(FAILS))
}
