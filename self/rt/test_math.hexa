// self/rt/test_math.hexa — P7-7g verification vs libm reference values.
//
// Each assertion: math_abs(got - expected) < 1e-7. Reference values are
// libm-exact (double) constants, not recomputed — so a regression in
// math.hexa surfaces as a failed assert and a nonzero exit.

import self/rt/math
import self/rt/math_abi

let EPS: float = 1.0e-7
let mut FAILS: int = 0

fn check(name: cstr, got: float, expected: float) {
    let d = math_abs(got - expected)
    if d < EPS {
        print("ok  ")
        print(name)
        println("")
    } else {
        FAILS = FAILS + 1
        print("FAIL ")
        print(name)
        print(" got=")
        print_float(got)
        print(" want=")
        print_float(expected)
        println("")
    }
}

fn main() -> int {
    // sqrt
    check("sqrt(2)",    math_sqrt(2.0),   1.4142135623730951)
    check("sqrt(100)",  math_sqrt(100.0), 10.0)

    // pow
    check("pow(2,10)",  math_pow(2.0, 10.0), 1024.0)

    // sin / cos
    check("sin(PI/2)",  math_sin(HALF_PI()), 1.0)
    check("sin(0)",     math_sin(0.0), 0.0)
    check("cos(PI)",    math_cos(PI()), -1.0)

    // exp / log
    check("exp(1)",     math_exp(1.0), 2.718281828459045)
    check("log(E)",     math_log(E()), 1.0)

    // atan2
    check("atan2(1,1)", math_atan2(1.0, 1.0), 0.7853981633974483)

    // ── math_abi.hexa (_v marshalling round-trip) ────────────────────
    // These go through the HexaVal ↔ float ABI wrappers; inputs are
    // polymorphic (int literal boxes to TAG_INT, float to TAG_FLOAT)
    // so they exercise rt_to_float's int-promote + float-passthru paths.
    check("sqrt_v(int 16)",   rt_math_sqrt_v(16),       4.0)
    check("sqrt_v(float 2.0)",rt_math_sqrt_v(2.0),      1.4142135623730951)
    check("abs_v(-3.5)",      rt_math_abs_v(-3.5),      3.5)
    check("pow_v(3,4)",       rt_math_pow_v(3.0, 4.0),  81.0)
    check("atan2_v(1,1)",     rt_math_atan2_v(1.0, 1.0),0.7853981633974483)
    check("min_v(int,float)", rt_math_min_v(5, 2.5),    2.5)

    if FAILS == 0 {
        println("all math tests passed")
        return 0
    }
    print("math tests failed: ")
    print_int(FAILS)
    println("")
    return 1
}
