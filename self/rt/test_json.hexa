// self/rt/test_json.hexa — smoke test for rt/json.hexa
//
// Five round-trips: null, number, string, array, object. Encoding is
// compact (pretty=false). Each parse→stringify pair must yield the
// original serialised form byte-for-byte.

use self::rt::json

let mut FAILS = 0

fn check(name, ok) {
    if ok {
        print("PASS ")
        println(name)
    } else {
        FAILS = FAILS + 1
        print("FAIL ")
        println(name)
    }
}

// ── null ────────────────────────────────────────────────────────────
let v1 = rt_json_parse("null")
check("parse:null",            typeof(v1) == "void")
check("stringify:null",        rt_json_stringify(void, false) == "null")

// ── number (int) ────────────────────────────────────────────────────
let v2 = rt_json_parse("42")
check("parse:int",             v2 == 42)
check("stringify:int",         rt_json_stringify(42, false) == "42")

// ── number (float) ──────────────────────────────────────────────────
let v3 = rt_json_parse("3.5")
check("parse:float",           v3 == 3.5)

// ── string ──────────────────────────────────────────────────────────
let v4 = rt_json_parse("\"hello\"")
check("parse:string",          v4 == "hello")
check("stringify:string",      rt_json_stringify("hello", false) == "\"hello\"")

// Escaped characters.
let v5 = rt_json_parse("\"a\\nb\"")
check("parse:escape-newline",  v5 == "a\nb")

// ── bool ────────────────────────────────────────────────────────────
let v6 = rt_json_parse("true")
check("parse:bool-true",       v6 == true)
check("stringify:bool-false",  rt_json_stringify(false, false) == "false")

// ── array round-trip ────────────────────────────────────────────────
let v7 = rt_json_parse("[1,2,3]")
check("parse:array-len",       len(v7) == 3)
check("parse:array-elem",      v7[1] == 2)
check("stringify:array",       rt_json_stringify([1, 2, 3], false) == "[1,2,3]")

// ── object round-trip ───────────────────────────────────────────────
let v8 = rt_json_parse("{\"a\":1,\"b\":2}")
check("parse:obj-a",           v8["a"] == 1)
check("parse:obj-b",           v8["b"] == 2)

// Round-trip: stringify a map and re-parse.
let m = #{"x": 10, "y": 20}
let s = rt_json_stringify(m, false)
let back = rt_json_parse(s)
check("roundtrip:obj-x",       back["x"] == 10)
check("roundtrip:obj-y",       back["y"] == 20)

if FAILS == 0 {
    println("all json tests passed")
} else {
    print("json tests failed: ")
    println(to_string(FAILS))
}
