// self/rt/test_fmt.hexa — P7-7c-2 formatter verification
//
// Run: hexa self/rt/test_fmt.hexa
// Expected: "all ok" + exit 0. Any failure line prints "FAIL: <desc>" and
// the test continues so the whole surface gets exercised in one pass.

use self::rt::fmt

let mut fails = 0

fn check(ok: bool, desc: string) {
    if ok {
        println("ok: " + desc)
    } else {
        println("FAIL: " + desc)
        fails = fails + 1
    }
}

fn bytes_eq(a: [int], b: [int]) -> bool {
    if len(a) != len(b) { return false }
    let mut i = 0
    while i < len(a) {
        if a[i] != b[i] { return false }
        i = i + 1
    }
    return true
}

fn main() -> int {
    // ── int_to_string ────────────────────────────────────
    check(int_to_string(0) == "0",           "int_to_string(0)")
    check(int_to_string(1) == "1",           "int_to_string(1)")
    check(int_to_string(-1) == "-1",         "int_to_string(-1)")
    check(int_to_string(123) == "123",       "int_to_string(123)")
    check(int_to_string(-999999) == "-999999","int_to_string(-999999)")

    // ── float_to_string ──────────────────────────────────
    // 3.14 → "3.14" at prec=2. Exact because 3.14 stored as 3.140000000…
    // rounds to "3.14" after 2 decimal multiplications.
    let f1 = float_to_string(3.14, 2)
    check(f1 == "3.14",                      "float_to_string(3.14, 2)")

    // ── float_to_string_sci ──────────────────────────────
    // 6.022e23 at prec=3 → "6.022e+23". Due to fixed-point fractional
    // accumulation the last digit may drift by 1; accept both.
    let fs = float_to_string_sci(6.022e23, 3)
    let fs_ok = fs == "6.022e+23" || fs == "6.021e+23" || fs == "6.023e+23"
    check(fs_ok,                             "float_to_string_sci(6.022e23,3)=" + fs)

    // Negative + small exponent.
    let fs2 = float_to_string_sci(-1.5, 2)
    check(fs2 == "-1.50e+00",                "float_to_string_sci(-1.5,2)=" + fs2)

    // Zero special case.
    check(float_to_string_sci(0.0, 3) == "0.000e+00", "float_to_string_sci(0,3)")

    // ── hex_string ───────────────────────────────────────
    check(hex_string(255) == "0xff",         "hex_string(255)")
    check(hex_string(0) == "0x0",            "hex_string(0)")

    // ── bin_string ───────────────────────────────────────
    check(bin_string(10) == "0b1010",        "bin_string(10)")
    check(bin_string(0) == "0b0",            "bin_string(0)")

    // ── pad_left / pad_right (pad_char 32 = ' ') ────────
    check(pad_left("x", 5, 32) == "    x",   "pad_left(x,5,32)")
    check(pad_right("x", 5, 32) == "x    ",  "pad_right(x,5,32)")
    check(pad_left("toolong", 3, 32) == "toolong", "pad_left no-op when cur>=width")

    // ── format_simple ────────────────────────────────────
    let f = format_simple("%d %s", [42, "ok"])
    check(f == "42 ok",                      "format_simple(%d %s)=" + f)
    check(format_simple("%%") == "%",        "format_simple(%%)")
    let fx = format_simple("0x%x", [255])
    check(fx == "0x0xff",                    "format_simple(%x)=" + fx)

    // ── base64 round-trip ───────────────────────────────
    // "HI" = [72, 73] → "SEk=" per RFC 4648.
    let enc = base64_encode([72, 73])
    check(enc == "SEk=",                     "base64_encode([72,73])=" + enc)

    let dec = base64_decode("SEk=")
    check(bytes_eq(dec, [72, 73]),           "base64_decode(SEk=)")

    // 3-byte block (no padding): "Man" = [77,97,110] → "TWFu"
    let enc3 = base64_encode([77, 97, 110])
    check(enc3 == "TWFu",                    "base64_encode(Man)=" + enc3)
    check(bytes_eq(base64_decode("TWFu"), [77, 97, 110]), "base64_decode(TWFu)")

    // 1-byte block: [77] → "TQ=="
    let enc1 = base64_encode([77])
    check(enc1 == "TQ==",                    "base64_encode([77])=" + enc1)
    check(bytes_eq(base64_decode("TQ=="), [77]), "base64_decode(TQ==)")

    // Empty.
    check(base64_encode([]) == "",           "base64_encode([])")
    check(len(base64_decode("")) == 0,       "base64_decode(\"\")")

    if fails == 0 {
        println("all ok")
        return 0
    }
    println("FAILED: " + int_to_string(fails))
    return 1
}
