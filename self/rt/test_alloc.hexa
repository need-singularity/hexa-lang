// self/rt/test_alloc.hexa — P7-7b smoke test
//
// mmap a 4KB region, write a pattern at offset 0 and offset 2048,
// read back, verify, munmap. No runtime.c linkage. Target binary
// should be small (one mmap + one munmap + a few mem ops).
//
// Build & run (Mac ARM64):
//   hexa compile --target=darwin-arm64 self/rt/test_alloc.hexa -o /tmp/hx_al
//   /tmp/hx_al ; echo "exit=$?"   # expect: alloc ok\n  exit=0
//
// Build & run (Linux x86_64):
//   hexa compile --target=linux-x86_64 self/rt/test_alloc.hexa -o /tmp/hx_al
//   /tmp/hx_al ; echo "exit=$?"   # expect: alloc ok\n  exit=0
//
// Exit codes on failure:
//   2  = mmap returned negative (errno)
//   3  = readback at offset 0 mismatch
//   4  = readback at offset 2048 mismatch
//   5  = munmap failed

use self::rt::syscall
use self::rt::alloc

fn main() -> int {
    let size = 4096
    let flags = MAP_PRIVATE() + flag_map_anon()
    let prot = PROT_READ() + PROT_WRITE()
    let base = sys_mmap(0, size, prot, flags, -1, 0)
    if base < 0 {
        sys_exit(2)
        return 2
    }

    // Write pattern at two offsets: a low-byte at 0 and a low-byte
    // at 2048. Using the byte path exercises __mem_store8/load8.
    let pat_a = 165   // 0xA5
    let pat_b = 90    // 0x5A
    hexa_ptr_write_byte(base, 0, pat_a)
    hexa_ptr_write_byte(base, 2048, pat_b)

    let got_a = hexa_ptr_read_byte(base, 0)
    if got_a != pat_a {
        sys_munmap(base, size)
        sys_exit(3)
        return 3
    }

    let got_b = hexa_ptr_read_byte(base, 2048)
    if got_b != pat_b {
        sys_munmap(base, size)
        sys_exit(4)
        return 4
    }

    // Word-sized round-trip at an aligned offset (covers __mem_store64
    // / __mem_load64 — exercises the arena-header path).
    let pat_w = 81985529216486895   // 0x0123456789ABCDEF
    hexa_ptr_write_64(base, 16, pat_w)
    let got_w = hexa_ptr_read_64(base, 16)
    if got_w != pat_w {
        sys_munmap(base, size)
        sys_exit(4)
        return 4
    }

    let u = sys_munmap(base, size)
    if u < 0 {
        sys_exit(5)
        return 5
    }

    let msg = "alloc ok\n"
    let addr = hexa_ptr_addr(msg)
    sys_write(1, addr, 9)
    sys_exit(0)
    return 0
}
