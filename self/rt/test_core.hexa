// self/rt/test_core.hexa — P7-7b slice 4 smoke test
//
// Exercises each rt_* core op with 2-3 cases. Prints PASS / FAIL per case
// and a final summary. Style mirrors test_map_ops.hexa (top-level, no
// main()). No libc / runtime.c linkage beyond println + builtins.
//
// Run under the interpreter:
//   hexa self/rt/test_core.hexa        # expect: all core tests passed

use self::rt::core

let mut FAILS = 0

fn check(name, ok) {
    if ok {
        print("PASS ")
        println(name)
    } else {
        FAILS = FAILS + 1
        print("FAIL ")
        println(name)
    }
}

// ── truthy / null_coal / len ────────────────────────────────────────
check("truthy:int-nonzero",  rt_truthy(3))
check("truthy:int-zero",     !rt_truthy(0))
check("truthy:empty-str",    !rt_truthy(""))
check("nullcoal:void→b",     rt_null_coal(void, "fallback") == "fallback")
check("nullcoal:empty→b",    rt_null_coal("", "fallback") == "fallback")
check("nullcoal:pass-thru",  rt_null_coal("hi", "fb") == "hi")
check("len:str",             rt_len("abcd") == 4)
check("len:arr",             rt_len([1, 2, 3]) == 3)

// ── type_of / is_type ───────────────────────────────────────────────
check("typeof:int",          rt_type_of(5) == "int")
check("typeof:string",       rt_type_of("s") == "string")
check("is_type:float",       rt_is_type(1.5, "float"))
check("is_type:not-int",     !rt_is_type("x", "int"))

// ── abs ─────────────────────────────────────────────────────────────
check("abs:int-neg",         rt_abs(-7) == 7)
check("abs:int-pos",         rt_abs(4) == 4)
check("abs:float-neg",       rt_abs(-2.5) == 2.5)

// ── eq ──────────────────────────────────────────────────────────────
check("eq:int-int",          rt_eq(5, 5))
check("eq:int-float-cross",  rt_eq(5, 5.0))
check("eq:string",           rt_eq("abc", "abc"))
check("eq:array",            rt_eq([1, 2, 3], [1, 2, 3]))
check("eq:array-diff",       !rt_eq([1, 2], [1, 2, 3]))

// ── cmp ─────────────────────────────────────────────────────────────
check("cmp:lt-int",          rt_cmp_lt(2, 3))
check("cmp:gt-float",        rt_cmp_gt(3.5, 2.0))
check("cmp:le-eq",           rt_cmp_le(4, 4))
check("cmp:ge-int",          rt_cmp_ge(5, 4))
check("cmp:str-lex",         rt_cmp_lt("apple", "banana"))

// ── arithmetic ──────────────────────────────────────────────────────
check("add:int",             rt_add(2, 3) == 5)
check("add:float-mix",       rt_add(1, 2.5) == 3.5)
check("add:str-concat",      rt_add("foo", "bar") == "foobar")
check("add:arr-concat",      rt_eq(rt_add([1, 2], [3, 4]), [1, 2, 3, 4]))
check("sub:int",             rt_sub(10, 4) == 6)
check("sub:float",           rt_sub(5.0, 1.5) == 3.5)
check("mul:int",             rt_mul(3, 4) == 12)
check("mul:float-mix",       rt_mul(2, 0.5) == 1.0)
check("div:int",             rt_div(10, 3) == 3)
check("div:zero-int",        rt_div(5, 0) == 0)
check("div:float",           rt_div(1.0, 4.0) == 0.25)
check("mod:int",             rt_mod(10, 3) == 1)
check("mod:zero-int",        rt_mod(5, 0) == 0)

if FAILS == 0 {
    println("all core tests passed")
} else {
    print("core tests failed: ")
    println(to_string(FAILS))
}
