// self/rt/math.hexa — P7-7g: pure-hexa math (replaces libm)
//
// Implementations are simple and deterministic — accuracy targets ~1e-7
// relative error, sufficient for compiler + self-hosting paths (NOT for
// ML training, which should remain on the native BLAS path).
//
// Surface (matches runtime.c hexa_math_* names):
//   sqrt, pow, abs, floor, ceil, round
//   sin, cos, tan, asin, acos, atan, atan2
//   exp, log, tanh
//   min, max

// ═══════════════════════════════════════════════════════════════════
// Constants
// ═══════════════════════════════════════════════════════════════════

@pure fn PI() -> float { return 3.141592653589793 }
@pure fn TWO_PI() -> float { return 6.283185307179586 }
@pure fn HALF_PI() -> float { return 1.5707963267948966 }
@pure fn E() -> float { return 2.718281828459045 }
@pure fn LN2() -> float { return 0.6931471805599453 }

// ═══════════════════════════════════════════════════════════════════
// Basic
// ═══════════════════════════════════════════════════════════════════

@pure fn math_abs(x: float) -> float {
    if x < 0.0 { return -x }
    return x
}

@pure fn math_min(a: float, b: float) -> float {
    if a < b { return a }
    return b
}

@pure fn math_max(a: float, b: float) -> float {
    if a > b { return a }
    return b
}

@pure fn math_floor(x: float) -> float {
    let i = int_of_float(x)
    let ix = float_of_int(i)
    if ix > x { return ix - 1.0 }
    return ix
}

@pure fn math_ceil(x: float) -> float {
    let i = int_of_float(x)
    let ix = float_of_int(i)
    if ix < x { return ix + 1.0 }
    return ix
}

@pure fn math_round(x: float) -> float {
    if x >= 0.0 { return math_floor(x + 0.5) }
    return math_ceil(x - 0.5)
}

// ═══════════════════════════════════════════════════════════════════
// sqrt — Newton-Raphson, 20 iters
// ═══════════════════════════════════════════════════════════════════

fn math_sqrt(x: float) -> float {
    if x <= 0.0 { return 0.0 }
    let mut g = x * 0.5
    if g == 0.0 { g = 1.0 }
    let mut i = 0
    while i < 20 {
        g = 0.5 * (g + x / g)
        i = i + 1
    }
    return g
}

// ═══════════════════════════════════════════════════════════════════
// exp / log — Taylor series + range reduction
// ═══════════════════════════════════════════════════════════════════

fn math_exp(x: float) -> float {
    // Range-reduce: x = k*ln2 + r, |r| <= ln2/2. Then e^x = 2^k * e^r.
    let k = math_floor(x / LN2() + 0.5)
    let r = x - k * LN2()
    // Taylor for e^r: 1 + r + r^2/2 + ...
    let mut term = 1.0
    let mut sum = 1.0
    let mut i = 1
    while i < 20 {
        term = term * r / float_of_int(i)
        sum = sum + term
        i = i + 1
    }
    // Multiply by 2^k (integer power).
    let kk = int_of_float(k)
    let mut result = sum
    if kk >= 0 {
        let mut j = 0
        while j < kk { result = result * 2.0; j = j + 1 }
    } else {
        let mut j = 0
        while j < -kk { result = result * 0.5; j = j + 1 }
    }
    return result
}

fn math_log(x: float) -> float {
    if x <= 0.0 { return 0.0 }   // undefined; return 0 as stub
    // Range-reduce via x = 2^k * m, 1 <= m < 2. Then log(x) = k*ln2 + log(m).
    let mut k = 0
    let mut m = x
    while m >= 2.0 { m = m * 0.5; k = k + 1 }
    while m < 1.0 { m = m * 2.0; k = k - 1 }
    // log(m) for m in [1,2): use u = (m-1)/(m+1), log(m) = 2*(u + u^3/3 + u^5/5 + ...)
    let u = (m - 1.0) / (m + 1.0)
    let u2 = u * u
    let mut term = u
    let mut sum = 0.0
    let mut i = 1
    while i < 40 {
        sum = sum + term / float_of_int(i)
        term = term * u2
        i = i + 2
    }
    return 2.0 * sum + float_of_int(k) * LN2()
}

fn math_pow(b: float, e: float) -> float {
    if b == 0.0 { return 0.0 }
    // b^e = exp(e * log(b))
    return math_exp(e * math_log(b))
}

// ═══════════════════════════════════════════════════════════════════
// Trig — Taylor via range-reduction
// ═══════════════════════════════════════════════════════════════════

fn math_sin(x: float) -> float {
    // Reduce to [-pi, pi].
    let mut y = x
    while y > PI()  { y = y - TWO_PI() }
    while y < -PI() { y = y + TWO_PI() }
    // Taylor: sin(y) = y - y^3/3! + y^5/5! - ...
    let y2 = y * y
    let mut term = y
    let mut sum = 0.0
    let mut i = 1
    let mut sign = 1.0
    while i < 20 {
        sum = sum + sign * term
        term = term * y2 / (float_of_int(i * 2) * float_of_int(i * 2 + 1))
        sign = -sign
        i = i + 1
    }
    return sum
}

fn math_cos(x: float) -> float {
    return math_sin(HALF_PI() - x)
}

fn math_tan(x: float) -> float {
    let c = math_cos(x)
    if c == 0.0 { return 0.0 }
    return math_sin(x) / c
}

fn math_atan(x: float) -> float {
    // atan(x) for |x| <= 1 via Taylor; for |x| > 1 use atan(x) = pi/2 - atan(1/x).
    if x > 1.0 { return HALF_PI() - math_atan(1.0 / x) }
    if x < -1.0 { return -HALF_PI() - math_atan(1.0 / x) }
    let x2 = x * x
    let mut term = x
    let mut sum = 0.0
    let mut i = 1
    let mut sign = 1.0
    while i < 60 {
        sum = sum + sign * term / float_of_int(i)
        term = term * x2
        sign = -sign
        i = i + 2
    }
    return sum
}

fn math_atan2(y: float, x: float) -> float {
    if x > 0.0 { return math_atan(y / x) }
    if x < 0.0 {
        if y >= 0.0 { return math_atan(y / x) + PI() }
        return math_atan(y / x) - PI()
    }
    if y > 0.0 { return HALF_PI() }
    if y < 0.0 { return -HALF_PI() }
    return 0.0
}

fn math_asin(x: float) -> float {
    if x >= 1.0 { return HALF_PI() }
    if x <= -1.0 { return -HALF_PI() }
    return math_atan(x / math_sqrt(1.0 - x * x))
}

fn math_acos(x: float) -> float {
    return HALF_PI() - math_asin(x)
}

fn math_tanh(x: float) -> float {
    let ep = math_exp(x)
    let en = math_exp(-x)
    return (ep - en) / (ep + en)
}

// ═══════════════════════════════════════════════════════════════════
// Integer helpers — P7-7b slice 1 (pure-hexa, libm-independent)
//
// First integer slice; tested via native_compile_poc (int-only backend).
// These cover the libm surface needed by the compiler/self-host path:
// fabs/fmin/fmax/floor/ceil/round on ints (no FP in hot paths).
// ═══════════════════════════════════════════════════════════════════

@pure fn rt_abs(n: int) -> int {
    if n < 0 { return 0 - n }
    return n
}

@pure fn rt_min(a: int, b: int) -> int {
    if a < b { return a }
    return b
}

@pure fn rt_max(a: int, b: int) -> int {
    if a > b { return a }
    return b
}

// Floor division — rounds toward -inf. For non-negative dividend or
// exact division, == truncated /; otherwise subtract one.
@pure fn rt_floor_div(a: int, b: int) -> int {
    if a >= 0 { return a / b }
    if (a % b) == 0 { return a / b }
    return (a / b) - 1
}

// Ceil division — assumes b > 0.
@pure fn rt_ceil_div(a: int, b: int) -> int {
    return (a + b - 1) / b
}

@pure fn rt_clamp(v: int, lo: int, hi: int) -> int {
    return rt_max(lo, rt_min(hi, v))
}

// ═══════════════════════════════════════════════════════════════════
// Intrinsic shims
// ═══════════════════════════════════════════════════════════════════

@inline fn int_of_float(x: float) -> int { return 0 }
@inline fn float_of_int(n: int) -> float { return 0.0 }
