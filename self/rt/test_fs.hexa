// self/rt/test_fs.hexa — P7-7e smoke test
//
// Opens /tmp, counts entries via rt_list_dir. Pure syscalls — no libc.
//
// Build & run (Mac ARM64):
//   hexa compile --target=darwin-arm64 self/rt/test_fs.hexa -o /tmp/hx_fs
//   /tmp/hx_fs ; echo "exit=$?"    # expect: count=<N>\n  exit=0
//
// Build & run (Linux x86_64):
//   hexa compile --target=linux-x86_64 self/rt/test_fs.hexa -o /tmp/hx_fs
//   /tmp/hx_fs ; echo "exit=$?"    # expect: count=<N>\n  exit=0

use self::rt::syscall
use self::rt::alloc
use self::rt::fs

fn digit_byte(d: int) -> int { return 48 + d }

// Render a small non-negative int into buf (max 20 digits). Returns byte count.
fn write_uint(buf: int, n: int) -> int {
    if n == 0 {
        hexa_ptr_write_byte(buf, 0, digit_byte(0))
        return 1
    }
    // Compute digits in reverse, then flip.
    let mut tmp = hexa_ptr_alloc(24)
    let mut x = n
    let mut k = 0
    while x > 0 {
        hexa_ptr_write_byte(tmp, k, digit_byte(x - (x / 10) * 10))
        x = x / 10
        k = k + 1
    }
    let mut i = 0
    while i < k {
        hexa_ptr_write_byte(buf, i, hexa_ptr_read_byte(tmp, k - 1 - i))
        i = i + 1
    }
    return k
}

fn main() -> int {
    let entries = rt_list_dir("/tmp")
    let count = len(entries)

    // Emit "count=<N>\n"
    let prefix = "count="
    let paddr = hexa_ptr_addr(prefix)
    sys_write(1, paddr, 6)

    let nbuf = hexa_ptr_alloc(24)
    let nlen = write_uint(nbuf, count)
    sys_write(1, nbuf, nlen)

    let nl = hexa_ptr_alloc(1)
    hexa_ptr_write_byte(nl, 0, 10)
    sys_write(1, nl, 1)

    sys_exit(0)
    return 0
}
