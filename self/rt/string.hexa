// self/rt/string.hexa — P7-7b slice 3: string utilities (libc-independent)
//
// Pure-hexa replacements for runtime.c L2406-4428 (hexa_str_* family).
// Seven functions per runtime.c candidate inventory — no strdup/strstr/
// strncmp/memcpy in the lowered path; all work through hexa's intrinsic
// substring/index_of/starts_with/ends_with/char_code primitives.
//
// Semantics mirror runtime.c exactly so codegen_c2 can emit direct calls
// to these rt_str_* symbols once runtime.c stubs are switched off.

// ── starts/ends_with — thin wrapper (runtime.c L2406, L2412) ────────
@pure fn rt_str_starts_with(s: string, prefix: string) -> bool {
    return s.starts_with(prefix)
}

@pure fn rt_str_ends_with(s: string, suffix: string) -> bool {
    return s.ends_with(suffix)
}

// ── len (build_c.hexa static inline; runtime.c uses strlen) ─────────
// Byte length of the string (not codepoint count); matches hexa_str_len
// which C-side is just `strlen(s)`. Host `len(s)` lowers to the same
// intrinsic.
@pure fn rt_str_len(s: string) -> int {
    return len(s)
}

// ── chars (runtime.c L2504) ─────────────────────────────────────────
// Byte-level split into single-char strings. Matches hexa_str_chars
// which iterates HX_STR(s)[i] and pushes a 2-char buf. Non-string input
// returns empty array (runtime.c L2506 guard).
fn rt_str_chars(s: string) -> [string] {
    let n = len(s)
    let mut out = []
    let mut i = 0
    while i < n {
        out.push(s.substring(i, i + 1))
        i = i + 1
    }
    return out
}

// ── lines (runtime.c L3363) ─────────────────────────────────────────
// Split on '\n'. runtime.c thinly wraps hexa_str_split(s, "\n").
fn rt_str_lines(s: string) -> [string] {
    return rt_str_split(s, "\n")
}

// ── substr (runtime.c L5182) — JS-style (start, count) ──────────────
// 3-arg form with an explicit void-sentinel on the count parameter:
// when count is "omitted" (TAG_VOID at the ABI layer), we take the rest
// of the string. This pure-hexa arity is the 2-arg (start, count) —
// the void-sentinel path lives only in the `_v` wrapper where the
// HexaVal inspection is meaningful. Clamps start into [0, slen] and
// count >= 0, matching runtime.c L5186-5194.
fn rt_str_substr(s: string, start: int, count: int) -> string {
    let slen = len(s)
    let mut a = start
    if a < 0 { a = 0 }
    if a > slen { a = slen }
    let mut c = count
    if c < 0 { c = 0 }
    let mut end_idx = a + c
    if end_idx > slen { end_idx = slen }
    return rt_str_substring(s, a, end_idx)
}

// ── center (runtime.c L3622) ────────────────────────────────────────
// Pad both sides so the total width is `width`. Odd remainder goes to
// the right side (total_pad - left_pad). pad="" or width<=slen → s
// unchanged. Iteration count `li = ceil(left_pad/plen)`, `ri =
// ceil(right_pad/plen)`, matching the runtime C integer-math form.
fn rt_str_center(s: string, width: int, pad: string) -> string {
    let slen = len(s)
    let plen = len(pad)
    if slen >= width { return s }
    if plen == 0 { return s }
    let total_pad = width - slen
    let left_pad = total_pad / 2
    let right_pad = total_pad - left_pad
    let mut li = left_pad / plen
    if li * plen < left_pad { li = li + 1 }
    let mut ri = right_pad / plen
    if ri * plen < right_pad { ri = ri + 1 }
    let mut parts = []
    let mut i = 0
    while i < li {
        parts.push(pad)
        i = i + 1
    }
    parts.push(s)
    let mut j = 0
    while j < ri {
        parts.push(pad)
        j = j + 1
    }
    return parts.join("")
}

// ── to_upper / to_lower (runtime.c L3141, L3148) ────────────────────
// ASCII-only fold; runtime.c does the same (no Unicode case table).
fn rt_str_to_upper(s: string) -> string {
    let n = len(s)
    let mut parts = []
    let mut i = 0
    while i < n {
        let c = char_code(s, i)
        if c >= 97 && c <= 122 {
            // 'a'..'z' → subtract 32 → 'A'..'Z'
            parts.push(chr(c - 32))
        } else {
            parts.push(s.substring(i, i + 1))
        }
        i = i + 1
    }
    return parts.join("")
}

fn rt_str_to_lower(s: string) -> string {
    let n = len(s)
    let mut parts = []
    let mut i = 0
    while i < n {
        let c = char_code(s, i)
        if c >= 65 && c <= 90 {
            parts.push(chr(c + 32))
        } else {
            parts.push(s.substring(i, i + 1))
        }
        i = i + 1
    }
    return parts.join("")
}

// ── split (runtime.c L3082) ─────────────────────────────────────────
// strstr-based scan → start-index + substring; O(n*m) like the C version
// but zero strdup/free allocations (arena on the hexa side).
fn rt_str_split(s: string, delim: string) -> [string] {
    let mut out = []
    if len(delim) == 0 {
        out.push(s)
        return out
    }
    let dlen = len(delim)
    let mut start = 0
    let mut i = 0
    while i <= len(s) - dlen {
        if s.substring(i, i + dlen) == delim {
            out.push(s.substring(start, i))
            start = i + dlen
            i = start
        } else {
            i = i + 1
        }
    }
    out.push(s.substring(start, len(s)))
    return out
}

// ── join (runtime.c L3155) ──────────────────────────────────────────
// parts.push/join — avoids the two-pass strlen+malloc+memcpy dance in C.
fn rt_str_join(arr: [string], sep: string) -> string {
    let n = len(arr)
    if n == 0 { return "" }
    let mut parts = []
    parts.push(arr[0])
    let mut i = 1
    while i < n {
        parts.push(sep)
        parts.push(arr[i])
        i = i + 1
    }
    return parts.join("")
}

// ── bytes (runtime.c L4421) ─────────────────────────────────────────
// Returns raw byte values as an int array (UTF-8 byte-level, not codepoint).
fn rt_str_bytes(s: string) -> [int] {
    let n = len(s)
    let mut out = []
    let mut i = 0
    while i < n {
        out.push(char_code(s, i))
        i = i + 1
    }
    return out
}

// ── concat (runtime.c L2494) ────────────────────────────────────────
// ROI-36 empty-string elision mirrored. parts.join("") avoids a manual
// memcpy dance; host arena handles allocation.
@pure fn rt_str_concat(a: string, b: string) -> string {
    if len(a) == 0 { return b }
    if len(b) == 0 { return a }
    let mut parts = []
    parts.push(a)
    parts.push(b)
    return parts.join("")
}

// ── contains (runtime.c L2533) ──────────────────────────────────────
@pure fn rt_str_contains(s: string, sub: string) -> bool {
    return s.contains(sub)
}

// ── eq (runtime.c L2537) ────────────────────────────────────────────
@pure fn rt_str_eq(a: string, b: string) -> bool {
    return a == b
}

// ── substring (runtime.c L2558) ─────────────────────────────────────
// Clamps a<0→0, b>len→len; a>=b → "".
@pure fn rt_str_substring(s: string, start: int, end: int) -> string {
    let n = len(s)
    let mut a = start
    let mut b = end
    if a < 0 { a = 0 }
    if b > n { b = n }
    if a >= b { return "" }
    return s.substring(a, b)
}

// ── slice (runtime.c L4720) ─────────────────────────────────────────
// Byte-based [start,end); differs from substring by clamping a>b → a=b
// rather than returning "". Returns "" only when non-string — always a
// valid (possibly empty) string otherwise.
@pure fn rt_str_slice(s: string, start: int, end: int) -> string {
    let n = len(s)
    let mut a = start
    let mut b = end
    if a < 0 { a = 0 }
    if b > n { b = n }
    if a > b { a = b }
    return s.substring(a, b)
}

// ── trim / trim_start / trim_end (runtime.c L3379, L4705, L4712) ────
// Whitespace = space / tab / LF / CR, matching C ' '\t\n\r set.
@pure fn rt_str_is_ws(c: int) -> bool {
    return c == 32 || c == 9 || c == 10 || c == 13
}

fn rt_str_trim_start(s: string) -> string {
    let n = len(s)
    let mut i = 0
    while i < n && rt_str_is_ws(char_code(s, i)) { i = i + 1 }
    return s.substring(i, n)
}

fn rt_str_trim_end(s: string) -> string {
    let n = len(s)
    let mut j = n
    while j > 0 && rt_str_is_ws(char_code(s, j - 1)) { j = j - 1 }
    return s.substring(0, j)
}

fn rt_str_trim(s: string) -> string {
    return rt_str_trim_end(rt_str_trim_start(s))
}

// ── replace (runtime.c L3389) ───────────────────────────────────────
// strstr-style scan. Empty `old` is a no-op (matches C which would loop
// forever on empty needle — we short-circuit defensively).
fn rt_str_replace(s: string, old: string, new_s: string) -> string {
    let olen = len(old)
    if olen == 0 { return s }
    let n = len(s)
    let mut parts = []
    let mut start = 0
    let mut i = 0
    while i <= n - olen {
        if s.substring(i, i + olen) == old {
            parts.push(s.substring(start, i))
            parts.push(new_s)
            start = i + olen
            i = start
        } else {
            i = i + 1
        }
    }
    parts.push(s.substring(start, n))
    return parts.join("")
}

// ── pad_left / pad_right (runtime.c L3588, L3611) ───────────────────
// Multi-char pad iteration matches hexa_full.hexa:14975-15003 — append
// whole pad token each iter, ceil((width-slen)/plen) times. Returns s
// unchanged if already >= width or pad is empty.
fn rt_str_pad_left(s: string, width: int, pad: string) -> string {
    let slen = len(s)
    let plen = len(pad)
    if slen >= width { return s }
    if plen == 0 { return s }
    let pad_total = width - slen
    let mut iters = pad_total / plen
    if iters * plen < pad_total { iters = iters + 1 }
    let mut parts = []
    let mut i = 0
    while i < iters {
        parts.push(pad)
        i = i + 1
    }
    parts.push(s)
    return parts.join("")
}

fn rt_str_pad_right(s: string, width: int, pad: string) -> string {
    let slen = len(s)
    let plen = len(pad)
    if slen >= width { return s }
    if plen == 0 { return s }
    let pad_total = width - slen
    let mut iters = pad_total / plen
    if iters * plen < pad_total { iters = iters + 1 }
    let mut parts = []
    parts.push(s)
    let mut i = 0
    while i < iters {
        parts.push(pad)
        i = i + 1
    }
    return parts.join("")
}

// ── repeat (runtime.c L3561) ────────────────────────────────────────
// count <= 0 → "".
fn rt_str_repeat(s: string, count: int) -> string {
    if count <= 0 { return "" }
    let mut parts = []
    let mut i = 0
    while i < count {
        parts.push(s)
        i = i + 1
    }
    return parts.join("")
}

// ── index_of (runtime.c L2571) ──────────────────────────────────────
// Returns -1 if not found. Empty needle → 0 (matches strstr).
@pure fn rt_str_index_of(s: string, sub: string) -> int {
    let slen = len(s)
    let sublen = len(sub)
    if sublen == 0 { return 0 }
    let mut i = 0
    while i <= slen - sublen {
        if s.substring(i, i + sublen) == sub { return i }
        i = i + 1
    }
    return -1
}

// ── reverse (not in runtime.c — byte-reverse helper) ────────────────
// Byte-level reverse (not codepoint-aware), consistent with rt_str_bytes
// and rt_str_slice byte semantics.
fn rt_str_reverse(s: string) -> string {
    let n = len(s)
    let mut parts = []
    let mut i = n - 1
    while i >= 0 {
        parts.push(s.substring(i, i + 1))
        i = i - 1
    }
    return parts.join("")
}

// ── char_at / char_code_at (runtime.c L4665 hexa_char_code) ─────────
// Out-of-range → "" / 0, mirroring hexa_char_code.
@pure fn rt_str_char_at(s: string, i: int) -> string {
    let n = len(s)
    if i < 0 { return "" }
    if i >= n { return "" }
    return s.substring(i, i + 1)
}

@pure fn rt_str_char_code_at(s: string, i: int) -> int {
    let n = len(s)
    if i < 0 { return 0 }
    if i >= n { return 0 }
    return char_code(s, i)
}

// ── from_chars — inverse of bytes()/chars() ─────────────────────────
// Takes byte-code array → string. Complements rt_str_bytes.
fn rt_str_from_chars(codes: [int]) -> string {
    let n = len(codes)
    let mut parts = []
    let mut i = 0
    while i < n {
        parts.push(chr(codes[i]))
        i = i + 1
    }
    return parts.join("")
}

// ── parse_int (runtime.c L4688) ─────────────────────────────────────
// Sign + optional 0x/0X hex prefix + digits. Unparseable / non-digit at
// start → 0 (strtoll behavior: stops at first invalid char, returns 0 if
// no digits consumed). Stops at first non-digit; does not error.
@pure fn rt_str_hex_digit(c: int) -> int {
    if c >= 48 && c <= 57 { return c - 48 }          // 0-9
    if c >= 97 && c <= 102 { return c - 97 + 10 }    // a-f
    if c >= 65 && c <= 70 { return c - 65 + 10 }     // A-F
    return -1
}

fn rt_str_parse_int(s: string) -> int {
    let n = len(s)
    let mut i = 0
    let mut neg = 0
    if i < n {
        let c0 = char_code(s, i)
        if c0 == 43 { i = i + 1 }          // '+'
        else if c0 == 45 { neg = 1; i = i + 1 }  // '-'
    }
    let mut base = 10
    if i + 1 < n && char_code(s, i) == 48 {
        let c1 = char_code(s, i + 1)
        if c1 == 120 || c1 == 88 {  // 'x' / 'X'
            base = 16
            i = i + 2
        }
    }
    let mut acc = 0
    let mut any = 0
    while i < n {
        let c = char_code(s, i)
        let d = rt_str_hex_digit(c)
        if d < 0 { break }
        if d >= base { break }
        acc = acc * base + d
        any = 1
        i = i + 1
    }
    if any == 0 { return 0 }
    if neg == 1 { return -acc }
    return acc
}

// ── parse_float (runtime.c L4700) ───────────────────────────────────
// Sign + int-part + optional .frac + optional e[+-]exp. Unparseable → 0.0
// (strtod returns 0.0 when no conversion performed).
fn rt_str_parse_float(s: string) -> float {
    let n = len(s)
    let mut i = 0
    let mut neg = 0
    if i < n {
        let c0 = char_code(s, i)
        if c0 == 43 { i = i + 1 }
        else if c0 == 45 { neg = 1; i = i + 1 }
    }
    let mut acc = 0.0
    let mut any = 0
    // Integer part.
    while i < n {
        let c = char_code(s, i)
        if c < 48 || c > 57 { break }
        acc = acc * 10.0 + float(c - 48)
        any = 1
        i = i + 1
    }
    // Fractional part.
    if i < n && char_code(s, i) == 46 {  // '.'
        i = i + 1
        let mut scale = 0.1
        while i < n {
            let c = char_code(s, i)
            if c < 48 || c > 57 { break }
            acc = acc + float(c - 48) * scale
            scale = scale * 0.1
            any = 1
            i = i + 1
        }
    }
    // Exponent.
    if i < n {
        let ce = char_code(s, i)
        if ce == 101 || ce == 69 {  // 'e' / 'E'
            i = i + 1
            let mut eneg = 0
            if i < n {
                let cs = char_code(s, i)
                if cs == 43 { i = i + 1 }
                else if cs == 45 { eneg = 1; i = i + 1 }
            }
            let mut e = 0
            let mut e_any = 0
            while i < n {
                let c = char_code(s, i)
                if c < 48 || c > 57 { break }
                e = e * 10 + (c - 48)
                e_any = 1
                i = i + 1
            }
            if e_any == 1 {
                let mut k = 0
                while k < e {
                    if eneg == 1 { acc = acc * 0.1 } else { acc = acc * 10.0 }
                    k = k + 1
                }
            }
        }
    }
    if any == 0 { return 0.0 }
    if neg == 1 { return -acc }
    return acc
}

// ── to_string_int / to_string_float — hexa host delegates ───────────
// runtime.c hexa_to_string (L2818) dispatches by tag — int uses %lld,
// float uses %g. Here we use host `to_string()` which lowers to the
// same routine.
@pure fn rt_str_to_string_int(n: int) -> string {
    return to_string(n)
}

@pure fn rt_str_to_string_float(f: float) -> string {
    return to_string(f)
}
