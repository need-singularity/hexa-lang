// self/rt/fmt.hexa — P7-7c-2: pure-hexa printf / formatters
//
// Replaces runtime.c's sprintf/snprintf paths. Lives under rt/ because
// io.hexa depends on it for hexa_to_string. No libc.
//
// Surface:
//   int_to_string(n: int) -> string
//   float_to_string(f: float, prec: int) -> string
//   hex_string(n: int) -> string
//   bin_string(n: int) -> string
//   pad_left(s: string, width: int, pad_char: int) -> string
//   format_simple(fmt: string, args: [any]) -> string    — basic %d/%s/%f

use self::rt::alloc

// ═══════════════════════════════════════════════════════════════════
// int_to_string
// ═══════════════════════════════════════════════════════════════════

fn int_to_string(n: int) -> string {
    if n == 0 { return "0" }
    let mut neg = 0
    let mut x = n
    if x < 0 { neg = 1; x = -x }
    // Collect digits reversed.
    let mut digits = []
    while x > 0 {
        digits = digits.push((x % 10) + 48)  // '0'
        x = x / 10
    }
    // Reverse.
    let mut out = []
    if neg == 1 { out = out.push(45) }  // '-'
    let mut i = len(digits) - 1
    while i >= 0 {
        out = out.push(digits[i])
        i = i - 1
    }
    return bytes_array_to_string(out)
}

// ═══════════════════════════════════════════════════════════════════
// float_to_string — simple power-of-10 fixed-point
// ═══════════════════════════════════════════════════════════════════
//
// Not IEEE-perfect (no ryu), but deterministic and sufficient for
// self-hosting paths. For fixpoint determinism we disallow exponential
// notation in the compiler-side formatter.

fn float_to_string(f: float, prec: int) -> string {
    let mut out = []
    let mut x = f
    if x < 0.0 { out = out.push(45); x = -x }   // '-'
    // Integer part.
    let int_part = int_of(x)
    let int_str = int_to_string(int_part)
    let int_bytes = hexa_str_bytes(int_str)
    let mut i = 0
    while i < len(int_bytes) {
        out = out.push(int_bytes[i])
        i = i + 1
    }
    if prec <= 0 { return bytes_array_to_string(out) }
    out = out.push(46)  // '.'
    // Fractional part: x - int_part, multiply by 10 prec times.
    let mut frac = x - float_of_int(int_part)
    let mut k = 0
    while k < prec {
        frac = frac * 10.0
        let digit = int_of(frac)
        out = out.push(digit + 48)
        frac = frac - float_of_int(digit)
        k = k + 1
    }
    return bytes_array_to_string(out)
}

// ═══════════════════════════════════════════════════════════════════
// Base conversions
// ═══════════════════════════════════════════════════════════════════

fn hex_string(n: int) -> string {
    if n == 0 { return "0x0" }
    let digits = "0123456789abcdef"
    let digits_bytes = hexa_str_bytes(digits)
    let mut out = []
    let mut neg = 0
    let mut x = n
    if x < 0 { neg = 1; x = -x }
    let mut tmp = []
    while x > 0 {
        tmp = tmp.push(digits_bytes[x % 16])
        x = x / 16
    }
    if neg == 1 { out = out.push(45) }
    out = out.push(48).push(120)   // "0x"
    let mut i = len(tmp) - 1
    while i >= 0 {
        out = out.push(tmp[i])
        i = i - 1
    }
    return bytes_array_to_string(out)
}

fn bin_string(n: int) -> string {
    if n == 0 { return "0b0" }
    let mut out = []
    let mut x = n
    let mut tmp = []
    while x > 0 {
        tmp = tmp.push(48 + (x % 2))
        x = x / 2
    }
    out = out.push(48).push(98)   // "0b"
    let mut i = len(tmp) - 1
    while i >= 0 {
        out = out.push(tmp[i])
        i = i - 1
    }
    return bytes_array_to_string(out)
}

// ═══════════════════════════════════════════════════════════════════
// pad_left / pad_right
// ═══════════════════════════════════════════════════════════════════

fn pad_left(s: string, width: int, pad_char: int) -> string {
    let cur = len(s)
    if cur >= width { return s }
    let mut out = []
    let mut i = cur
    while i < width {
        out = out.push(pad_char)
        i = i + 1
    }
    let bytes = hexa_str_bytes(s)
    let mut j = 0
    while j < cur {
        out = out.push(bytes[j])
        j = j + 1
    }
    return bytes_array_to_string(out)
}

fn pad_right(s: string, width: int, pad_char: int) -> string {
    let cur = len(s)
    if cur >= width { return s }
    let bytes = hexa_str_bytes(s)
    let mut out = []
    let mut j = 0
    while j < cur {
        out = out.push(bytes[j])
        j = j + 1
    }
    let mut i = cur
    while i < width {
        out = out.push(pad_char)
        i = i + 1
    }
    return bytes_array_to_string(out)
}

// ═══════════════════════════════════════════════════════════════════
// Basic printf — %d, %s, %f, %x, %%
// ═══════════════════════════════════════════════════════════════════
//
// Deliberately minimal — self-hosting paths use hard-coded format
// calls. Full width/precision spec left for later.

fn format_simple(fmt: string, args: [any]) -> string {
    let bytes = hexa_str_bytes(fmt)
    let mut out = []
    let mut arg_idx = 0
    let mut i = 0
    while i < len(bytes) {
        let b = bytes[i]
        if b == 37 && i + 1 < len(bytes) {   // '%'
            let next = bytes[i + 1]
            if next == 100 {   // 'd'
                let s = int_to_string(int_of(args[arg_idx]))
                append_bytes(out, s)
                arg_idx = arg_idx + 1
                i = i + 2
                continue
            }
            if next == 115 {   // 's'
                append_bytes(out, hexa_to_string(args[arg_idx]))
                arg_idx = arg_idx + 1
                i = i + 2
                continue
            }
            if next == 102 {   // 'f'
                append_bytes(out, float_to_string(float_of(args[arg_idx]), 6))
                arg_idx = arg_idx + 1
                i = i + 2
                continue
            }
            if next == 120 {   // 'x'
                append_bytes(out, hex_string(int_of(args[arg_idx])))
                arg_idx = arg_idx + 1
                i = i + 2
                continue
            }
            if next == 37 {    // '%%'
                out = out.push(37)
                i = i + 2
                continue
            }
        }
        out = out.push(b)
        i = i + 1
    }
    return bytes_array_to_string(out)
}

fn append_bytes(buf: [int], s: string) -> [int] {
    let sb = hexa_str_bytes(s)
    let mut j = 0
    let mut out = buf
    while j < len(sb) {
        out = out.push(sb[j])
        j = j + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════════
// Intrinsic shims
// ═══════════════════════════════════════════════════════════════════

@inline fn bytes_array_to_string(buf: [int]) -> string {
    // Codegen lowers to a zero-copy tagged string from the byte array.
    return __string_from_byte_array(buf)
}

@inline fn float_of_int(n: int) -> float { return __int_to_float(n) }
@inline fn int_of(x) -> int { return 0 }
@inline fn float_of(x) -> float { return 0.0 }
@inline fn __string_from_byte_array(buf: [int]) -> string { return "" }
@inline fn __int_to_float(n: int) -> float { return 0.0 }
