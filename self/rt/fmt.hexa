// self/rt/fmt.hexa — P7-7c-2: pure-hexa printf / formatters
//
// Replaces runtime.c's sprintf/snprintf paths. Lives under rt/ because
// io.hexa depends on it for hexa_to_string. No libc.
//
// Surface:
//   int_to_string(n: int) -> string
//   float_to_string(f: float, prec: int) -> string              — %.Nf
//   float_to_string_sci(f: float, prec: int) -> string          — %.Ne
//   hex_string(n: int) -> string
//   bin_string(n: int) -> string
//   pad_left(s: string, width: int, pad_char: int) -> string
//   pad_right(s: string, width: int, pad_char: int) -> string
//   format_simple(fmt: string, args: [any]) -> string           — %d %s %f %x %%
//   base64_encode(bytes: [int]) -> string
//   base64_decode(s: string) -> [int]

use self::rt::alloc
use self::rt::math

// ═══════════════════════════════════════════════════════════════════
// int_to_string
// ═══════════════════════════════════════════════════════════════════

fn int_to_string(n: int) -> string {
    if n == 0 { return "0" }
    let mut neg = 0
    let mut x = n
    if x < 0 { neg = 1; x = -x }
    // Collect digits reversed.
    let mut digits = []
    while x > 0 {
        digits.push((x % 10) + 48)  // '0'
        x = x / 10
    }
    // Reverse.
    let mut out = []
    if neg == 1 { out.push(45) }  // '-'
    let mut i = len(digits) - 1
    while i >= 0 {
        out.push(digits[i])
        i = i - 1
    }
    return bytes_array_to_string(out)
}

// ═══════════════════════════════════════════════════════════════════
// float_to_string — simple power-of-10 fixed-point
// ═══════════════════════════════════════════════════════════════════
//
// Not IEEE-perfect (no ryu), but deterministic and sufficient for
// self-hosting paths. For fixpoint determinism we disallow exponential
// notation in the compiler-side formatter.

fn float_to_string(f: float, prec: int) -> string {
    let mut out = []
    let mut x = f
    if x < 0.0 { out.push(45); x = -x }   // '-'
    // Integer part.
    let int_part = int_of(x)
    let int_str = int_to_string(int_part)
    let int_bytes = hexa_str_bytes(int_str)
    let mut i = 0
    while i < len(int_bytes) {
        out.push(int_bytes[i])
        i = i + 1
    }
    if prec <= 0 { return bytes_array_to_string(out) }
    out.push(46)  // '.'
    // Fractional part: x - int_part, multiply by 10 prec times.
    let mut frac = x - float_of_int(int_part)
    let mut k = 0
    while k < prec {
        frac = frac * 10.0
        let digit = int_of(frac)
        out.push(digit + 48)
        frac = frac - float_of_int(digit)
        k = k + 1
    }
    return bytes_array_to_string(out)
}

// ═══════════════════════════════════════════════════════════════════
// float_to_string_sci — scientific notation %.Ne
// ═══════════════════════════════════════════════════════════════════
//
// Output shape: "[-]m.dddde[+-]NN" — mantissa in [1.0, 10.0) with `prec`
// fractional digits, then 'e', then signed 2+-digit exponent. Matches
// snprintf("%.*e", prec, v) for the common case. Subnormals / inf / nan
// are NOT handled — those paths stay on the formatter-less IR.

fn float_to_string_sci(f: float, prec: int) -> string {
    let mut out = []
    let mut x = f
    if x < 0.0 { out.push(45); x = -x }   // '-'
    if x == 0.0 {
        // "0.000…e+00"
        out.push(48)                 // '0'
        if prec > 0 {
            out.push(46)             // '.'
            let mut k = 0
            while k < prec { out.push(48); k = k + 1 }
        }
        out.push(101).push(43).push(48).push(48)  // "e+00"
        return bytes_array_to_string(out)
    }
    // Normalise x into [1.0, 10.0) and track exponent.
    let mut exp = 0
    while x >= 10.0 { x = x * 0.1; exp = exp + 1 }
    while x < 1.0 { x = x * 10.0; exp = exp - 1 }
    // Append mantissa with `prec` fractional digits.
    let mantissa = float_to_string(x, prec)
    let mb = hexa_str_bytes(mantissa)
    let mut mi = 0
    while mi < len(mb) { out.push(mb[mi]); mi = mi + 1 }
    // Exponent.
    out.push(101)                    // 'e'
    let mut e_abs = exp
    if e_abs < 0 { out.push(45); e_abs = -e_abs } else { out.push(43) }
    // Two-digit minimum.
    if e_abs < 10 {
        out.push(48)
        out.push(48 + e_abs)
    } else {
        let es = int_to_string(e_abs)
        let eb = hexa_str_bytes(es)
        let mut ei = 0
        while ei < len(eb) { out.push(eb[ei]); ei = ei + 1 }
    }
    return bytes_array_to_string(out)
}

// ═══════════════════════════════════════════════════════════════════
// Base conversions
// ═══════════════════════════════════════════════════════════════════

fn hex_string(n: int) -> string {
    if n == 0 { return "0x0" }
    let digits = "0123456789abcdef"
    let digits_bytes = hexa_str_bytes(digits)
    let mut out = []
    let mut neg = 0
    let mut x = n
    if x < 0 { neg = 1; x = -x }
    let mut tmp = []
    while x > 0 {
        tmp.push(digits_bytes[x % 16])
        x = x / 16
    }
    if neg == 1 { out.push(45) }
    out.push(48).push(120)   // "0x"
    let mut i = len(tmp) - 1
    while i >= 0 {
        out.push(tmp[i])
        i = i - 1
    }
    return bytes_array_to_string(out)
}

fn bin_string(n: int) -> string {
    if n == 0 { return "0b0" }
    let mut out = []
    let mut x = n
    let mut tmp = []
    while x > 0 {
        tmp.push(48 + (x % 2))
        x = x / 2
    }
    out.push(48).push(98)   // "0b"
    let mut i = len(tmp) - 1
    while i >= 0 {
        out.push(tmp[i])
        i = i - 1
    }
    return bytes_array_to_string(out)
}

// ═══════════════════════════════════════════════════════════════════
// pad_left / pad_right
// ═══════════════════════════════════════════════════════════════════

fn pad_left(s: string, width: int, pad_char: int) -> string {
    let cur = len(s)
    if cur >= width { return s }
    let mut out = []
    let mut i = cur
    while i < width {
        out.push(pad_char)
        i = i + 1
    }
    let bytes = hexa_str_bytes(s)
    let mut j = 0
    while j < cur {
        out.push(bytes[j])
        j = j + 1
    }
    return bytes_array_to_string(out)
}

fn pad_right(s: string, width: int, pad_char: int) -> string {
    let cur = len(s)
    if cur >= width { return s }
    let bytes = hexa_str_bytes(s)
    let mut out = []
    let mut j = 0
    while j < cur {
        out.push(bytes[j])
        j = j + 1
    }
    let mut i = cur
    while i < width {
        out.push(pad_char)
        i = i + 1
    }
    return bytes_array_to_string(out)
}

// ═══════════════════════════════════════════════════════════════════
// Basic printf — %d, %s, %f, %x, %%
// ═══════════════════════════════════════════════════════════════════
//
// Deliberately minimal — self-hosting paths use hard-coded format
// calls. Full width/precision spec left for later.

fn format_simple(fmt: string, args: [any]) -> string {
    let bytes = hexa_str_bytes(fmt)
    let mut out = []
    let mut arg_idx = 0
    let mut i = 0
    while i < len(bytes) {
        let b = bytes[i]
        if b == 37 && i + 1 < len(bytes) {   // '%'
            let next = bytes[i + 1]
            if next == 100 {   // 'd'
                out = append_bytes(out, int_to_string(int_of(args[arg_idx])))
                arg_idx = arg_idx + 1
                i = i + 2
                continue
            }
            if next == 115 {   // 's'
                out = append_bytes(out, hexa_to_string(args[arg_idx]))
                arg_idx = arg_idx + 1
                i = i + 2
                continue
            }
            if next == 102 {   // 'f'
                out = append_bytes(out, float_to_string(float_of(args[arg_idx]), 6))
                arg_idx = arg_idx + 1
                i = i + 2
                continue
            }
            if next == 120 {   // 'x'
                out = append_bytes(out, hex_string(int_of(args[arg_idx])))
                arg_idx = arg_idx + 1
                i = i + 2
                continue
            }
            if next == 37 {    // '%%'
                out.push(37)
                i = i + 2
                continue
            }
        }
        out.push(b)
        i = i + 1
    }
    return bytes_array_to_string(out)
}

fn append_bytes(buf: [int], s: string) -> [int] {
    let sb = hexa_str_bytes(s)
    let mut j = 0
    let mut out = buf
    while j < len(sb) {
        out.push(sb[j])
        j = j + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════════════
// Base64 — RFC 4648 standard alphabet, '=' padded
// ═══════════════════════════════════════════════════════════════════
//
// Mirrors runtime.c hexa_base64_encode/decode (which operate on C
// strings). The hexa surface takes [int] byte arrays so we can round-
// trip arbitrary binary without UTF-8 reinterpretation.

@pure fn base64_alphabet() -> string {
    return "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"
}

fn base64_encode(bytes: [int]) -> string {
    let n = len(bytes)
    if n == 0 { return "" }
    let alpha = hexa_str_bytes(base64_alphabet())
    let mut out = []
    let mut i = 0
    while i + 3 <= n {
        let b0 = bytes[i] & 255
        let b1 = bytes[i + 1] & 255
        let b2 = bytes[i + 2] & 255
        let t = (b0 * 65536) + (b1 * 256) + b2
        out.push(alpha[(t / 262144) & 63])
        out.push(alpha[(t / 4096) & 63])
        out.push(alpha[(t / 64) & 63])
        out.push(alpha[t & 63])
        i = i + 3
    }
    let rem = n - i
    if rem > 0 {
        let b0 = bytes[i] & 255
        let mut t = b0 * 65536
        if rem == 2 {
            let b1 = bytes[i + 1] & 255
            t = t + (b1 * 256)
        }
        out.push(alpha[(t / 262144) & 63])
        out.push(alpha[(t / 4096) & 63])
        if rem == 2 {
            out.push(alpha[(t / 64) & 63])
        } else {
            out.push(61)   // '='
        }
        out.push(61)       // '='
    }
    return bytes_array_to_string(out)
}

// Decoder table: ASCII byte → 0..63 or -1. Built lazily via alphabet
// scan (no static init hooks yet). Cost is O(256) per call which is
// fine for the self-hosting path (kilobytes, not megabytes).
fn base64_build_decode_table() -> [int] {
    let mut dec = []
    let mut i = 0
    while i < 256 { dec.push(-1); i = i + 1 }
    let alpha = hexa_str_bytes(base64_alphabet())
    let mut j = 0
    while j < 64 {
        dec[alpha[j]] = j
        j = j + 1
    }
    return dec
}

fn base64_decode(s: string) -> [int] {
    let sb = hexa_str_bytes(s)
    let n = len(sb)
    if n == 0 { return [] }
    let dec = base64_build_decode_table()
    let mut out = []
    let mut bits = 0
    let mut vbits = 0
    let mut i = 0
    while i < n {
        let c = sb[i]
        if c == 61 { break }                // '=' → end of data
        let v = dec[c]
        if v >= 0 {
            bits = (bits * 64) + v
            vbits = vbits + 6
            if vbits >= 8 {
                vbits = vbits - 8
                let shift = pow2(vbits)
                out.push((bits / shift) & 255)
                bits = bits & (shift - 1)
            }
        }
        i = i + 1
    }
    return out
}

@pure fn pow2(k: int) -> int {
    let mut v = 1
    let mut i = 0
    while i < k { v = v * 2; i = i + 1 }
    return v
}

// ═══════════════════════════════════════════════════════════════════
// Intrinsic shims
// ═══════════════════════════════════════════════════════════════════

@inline fn bytes_array_to_string(buf: [int]) -> string {
    // Codegen lowers to a zero-copy tagged string from the byte array.
    return __string_from_byte_array(buf)
}

@inline fn float_of_int(n: int) -> float { return __int_to_float(n) }
@inline fn int_of(x) -> int { return 0 }
@inline fn float_of(x) -> float { return 0.0 }
@inline fn __string_from_byte_array(buf: [int]) -> string { return "" }
@inline fn __int_to_float(n: int) -> float { return 0.0 }
