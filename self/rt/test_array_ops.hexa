// self/rt/test_array_ops.hexa — smoke test for rt/array_ops.hexa
//
// Verifies the rt_array_* wrappers delegate correctly by spot-checking
// five operations. Runs under the interpreter (hexa self/rt/test_array_ops.hexa).
// Each check prints PASS/FAIL; the script exits non-zero if any fail.

use self::rt::array_ops

let mut FAILS = 0

fn check(name, got, expected) {
    if got == expected {
        print("PASS ")
        println(name)
    } else {
        FAILS = FAILS + 1
        print("FAIL ")
        print(name)
        print(" got=")
        print(to_string(got))
        print(" want=")
        println(to_string(expected))
    }
}

// 1. slice — byte-indexed clip with saturating bounds
let s = rt_array_slice([10, 20, 30, 40, 50], 1, 4)
check("slice", to_string(s), "[20, 30, 40]")

// 2. map — double each element
let doubled = rt_array_map([1, 2, 3], |x| x * 2)
check("map", to_string(doubled), "[2, 4, 6]")

// 3. filter — keep only odd
let odd = rt_array_filter([1, 2, 3, 4, 5], |x| (x % 2) == 1)
check("filter", to_string(odd), "[1, 3, 5]")

// 4. fold — sum via accumulator
let total = rt_array_fold([1, 2, 3, 4, 5], 0, |a, x| a + x)
check("fold", total, 15)

// 5. reverse
let rev = rt_array_reverse([1, 2, 3])
check("reverse", to_string(rev), "[3, 2, 1]")

if FAILS == 0 {
    println("all array_ops tests passed")
} else {
    print("array_ops tests failed: ")
    println(to_string(FAILS))
}
