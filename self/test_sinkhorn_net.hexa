// ═══════════════════════════════════════════════════════════════
//  test_sinkhorn_net.hexa — Sinkhorn Network (#280) tests
// ═══════════════════════════════════════════════════════════════

import "ml/sinkhorn_net.hexa"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn approx(a, b, eps) {
    return fabs(a - b) < eps
}

println("═══════════════════════════════════════════════════════")
println("  Sinkhorn Network (#280) Test Suite")
println("═══════════════════════════════════════════════════════")

// ── Test 1: row normalize ─
let M1 = [[1.0, 2.0, 1.0], [0.0, 1.0, 0.0], [2.0, 2.0, 2.0]]
let R = sn_row_normalize(M1)
check("row[0] sums 1", approx(R[0][0] + R[0][1] + R[0][2], 1.0, 1.0e-10))
check("row[1] sums 1", approx(R[1][0] + R[1][1] + R[1][2], 1.0, 1.0e-10))
check("row[2] uniform", approx(R[2][0], 1.0 / 3.0, 1.0e-6))

// ── Test 2: col normalize ─
let C = sn_col_normalize([[1.0, 1.0], [1.0, 3.0]])
check("col[0] sums 1", approx(C[0][0] + C[1][0], 1.0, 1.0e-10))
check("col[1] sums 1", approx(C[0][1] + C[1][1], 1.0, 1.0e-10))

// ── Test 3: forward → doubly stochastic ─
let M2 = [
    [0.1, 0.5, 0.9],
    [0.3, 0.2, 0.7],
    [0.8, 0.6, 0.4]
]
let P = sn_forward(M2, 1.0, 30)
check("P is doubly stochastic (tol 1e-3)", sn_is_doubly_stochastic(P, 1.0e-3))

// ── Test 4: all entries ≥ 0 ─
let mut nonneg = true
for i in 0..3 {
    for j in 0..3 {
        if P[i][j] < 0.0 { nonneg = false }
    }
}
check("P entries ≥ 0", nonneg)

// ── Test 5: total mass = n ─
let total = sn_sum(P)
check("sum(P) = n", approx(total, 3.0, 1.0e-3))

// ── Test 6: low tau → approach hard permutation ─
// M has distinct row maxima for distinct columns
let M3 = [
    [10.0, 0.0, 0.0],
    [0.0, 10.0, 0.0],
    [0.0, 0.0, 10.0]
]
let P_low = sn_forward(M3, 0.5, 30)
// diagonal should dominate
check("P_low diag[0] ~ 1", P_low[0][0] > 0.99)
check("P_low diag[1] ~ 1", P_low[1][1] > 0.99)
check("P_low diag[2] ~ 1", P_low[2][2] > 0.99)

// ── Test 7: high tau → more uniform ─
let P_hi = sn_forward(M3, 100.0, 30)
check("P_hi near uniform", approx(P_hi[0][0], 1.0/3.0, 0.05))

// ── Test 8: greedy assignment ─
let assign = sn_hungarian_from_soft(P_low)
check("assign[0] = 0", assign[0] == 0)
check("assign[1] = 1", assign[1] == 1)
check("assign[2] = 2", assign[2] == 2)

// ── Test 9: permutation loss ─
let P_true = sn_perm_to_matrix([0, 1, 2])
let loss = sn_permutation_loss(P_low, P_true)
check("loss small for correct match", loss < 0.05)
let loss_wrong = sn_permutation_loss(sn_perm_to_matrix([2, 1, 0]), P_true)
check("loss larger for wrong match", loss_wrong > loss)

// ── Test 10: matching score ─
let cost = [
    [0.0, 5.0, 10.0],
    [10.0, 0.0, 5.0],
    [5.0, 10.0, 0.0]
]
let score = sn_matching_score(P_low, cost)
check("matching score near 0 for diag match", score < 1.0)

// ── Test 11: entropy of doubly stochastic positive ─
let h = sn_entropy(P)
check("entropy >= 0", h >= 0.0)
let h_hard = sn_entropy(P_true)
check("hard perm entropy ~ 0", h_hard < 1.0e-6)
check("soft entropy > hard", h > h_hard)

// ── Test 12: more iterations → closer to DS ─
let P_few = sn_forward(M2, 1.0, 2)
let P_many = sn_forward(M2, 1.0, 100)
// check row-sum deviation
fn row_err(matrix) {
    let n = len(matrix)
    let mut e = 0.0
    for i in 0..n {
        let mut s = 0.0
        for j in 0..n { s = s + matrix[i][j] }
        let d = s - 1.0
        if d < 0.0 { e = e - d } else { e = e + d }
    }
    return e
}
check("more iters → less row err", row_err(P_many) <= row_err(P_few) + 1.0e-10)

// ═══════════════════════════════════════════════════════════════
println("")
println("pass=" + to_string(pass_count) + " fail=" + to_string(fail_count))
if fail_count == 0 {
    println("ALL PASS")
} else {
    println("FAILED")
}
