// ── T31: output filter passes clean output ──
let out1 = gr_filter_output("Here is the answer to your question.", cfg)
check("T31 output filter passes clean", out1["pass"] == true)

// ── T32: output filter blocks keyword in output ──
let out2 = gr_filter_output("To hack the system you need to bypass safety", cfg)
check("T32 output filter blocks keyword", out2["pass"] == false)

// ── T33: output filter blocks PII in output ──
let out3 = gr_filter_output("The email is admin@company.com and SSN 123-45-6789", cfg)
check("T33 output filter blocks PII", out3["pass"] == false)

// ── T34: chain short-circuits on first violation ──
let chain_filters = [
    #{"name": "stage1_keywords", "type": "keyword", "blocklist": ["forbidden"]},
    #{"name": "stage2_pii", "type": "pii"},
    #{"name": "stage3_toxicity", "type": "toxicity", "keywords": ["bad"], "threshold": 0.1}
]
let ch1 = gr_chain("This is forbidden content", chain_filters)
check("T34 chain short-circuits on keyword", ch1["pass"] == false)
check("T34b chain stage = stage1_keywords", ch1["stage"] == "stage1_keywords")

// ── T35: chain passes all stages for clean text ──
let ch2 = gr_chain("Hello, how are you?", chain_filters)
check("T35 chain passes all stages", ch2["pass"] == true)
check("T35b chain stage = all_passed", ch2["stage"] == "all_passed")

// ===================================================================
println("")
println("=== guardrails test summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
