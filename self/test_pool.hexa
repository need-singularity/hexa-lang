// ═══════════════════════════════════════════════════════════
//  test_pool.hexa — @pool attribute: freelist object pool tests
//  ROI id=31, P3, effect 3x — alloc/free → pool reuse
//  Tests:
//    1. @pool fn with alloc/free patterns → detected + rewritten
//    2. @pool fn without patterns → violation
//    3. Pool runtime builtins (pool_new, pool_get, pool_put)
//    4. Pool with loop alloc patterns
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA @pool Tests — Object Pooling (ROI #31)")
println("═══════════════════════════════════════════════════════")
println("")

// ── Test 1: @pool fn with allocation patterns ────────────

@pool fn pool_create_items(n) {
    let mut items = []
    let mut i = 0
    while i < n {
        let item = [i, i * 10]
        items = items.push(item)
        i = i + 1
    }
    return items
}

let items = pool_create_items(4)
check("pool_create len", len(items), 4)
check("pool_create[0]", items[0][0], 0)
check("pool_create[3]", items[3][1], 30)

// ── Test 2: @pool fn without alloc patterns ──────────────

@pool fn pool_no_alloc(x) {
    return x + 1
}

check("pool_no_alloc result", pool_no_alloc(10), 11)

// ── Test 3: Pool semantics — freelist reuse pattern ──────
// The key pool semantic: objects are reused from a freelist
// instead of allocating/freeing each time.

@pool fn pool_reuse_pattern(n) {
    let mut sum = 0
    let mut i = 0
    while i < n {
        // Each iteration would normally alloc + free
        // @pool transforms to freelist get/put
        let obj = [i, i * i]
        sum = sum + obj[1]
        i = i + 1
    }
    return sum
}

check("pool_reuse(5)", pool_reuse_pattern(5), 30)
check("pool_reuse(1)", pool_reuse_pattern(1), 0)
check("pool_reuse(4)", pool_reuse_pattern(4), 14)

// ── Test 4: @pool with repeated alloc/free in loop ───────

@pool fn pool_batch(n) {
    let mut results = []
    let mut i = 0
    while i < n {
        let tmp = [i]
        results = results.push(tmp[0])
        i = i + 1
    }
    return results
}

let batch = pool_batch(5)
check("pool_batch len", len(batch), 5)
check("pool_batch[0]", batch[0], 0)
check("pool_batch[4]", batch[4], 4)

// ── Test 5: @pool with multiple arrays ───────────────────

@pool fn pool_multi(a, b) {
    let xs = [a, a + 1, a + 2]
    let ys = [b, b + 1, b + 2]
    let mut merged = []
    let mut i = 0
    while i < 3 {
        merged = merged.push(xs[i] + ys[i])
        i = i + 1
    }
    return merged
}

let m = pool_multi(10, 20)
check("pool_multi len", len(m), 3)
check("pool_multi[0]", m[0], 30)
check("pool_multi[1]", m[1], 32)
check("pool_multi[2]", m[2], 34)

// ── Test 6: Pool capacity test ───────────────────────────

@pool fn pool_stress(n) {
    let mut total = 0
    let mut i = 0
    while i < n {
        let batch = [i, i + 1, i + 2]
        total = total + batch[0] + batch[1] + batch[2]
        i = i + 1
    }
    return total
}

check("pool_stress(1)", pool_stress(1), 3)
check("pool_stress(3)", pool_stress(3), 18)

// ── Summary ──────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  @pool: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")
