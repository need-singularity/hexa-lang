// =====================================================================
//  test_branch_merge.hexa -- M976 branch merging optimization
//  Verifies that if/else branches with identical successor statements
//  produce correct results after the common statement is hoisted out.
// =====================================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("=====================================================================")
println("  M976: Branch Merging Tests")
println("=====================================================================")
println("")

// -- 1. Basic branch merge: identical return --

println("--- 1. Identical return in both branches ---")

// Before merging:
//   if cond { x = a; return x + 1 }
//   else    { x = b; return x + 1 }
// After merging:
//   if cond { x = a } else { x = b }
//   return x + 1

fn branch_merge_return(cond, a, b) {
    let mut x = 0
    if cond {
        x = a
    } else {
        x = b
    }
    // Hoisted common: return x + 1
    return x + 1
}

check("merge-return: true", branch_merge_return(true, 10, 20), 11)
check("merge-return: false", branch_merge_return(false, 10, 20), 21)
check("merge-return: zero", branch_merge_return(true, 0, 99), 1)

// -- 2. Branch merge with common assignment --

println("")
println("--- 2. Common assignment after branch ---")

// Before: if cond { a = 1; result = a * 2 } else { a = 3; result = a * 2 }
// After:  if cond { a = 1 } else { a = 3 }; result = a * 2

fn branch_merge_assign(cond) {
    let mut a = 0
    if cond {
        a = 1
    } else {
        a = 3
    }
    let result = a * 2
    return result
}

check("merge-assign: true", branch_merge_assign(true), 2)
check("merge-assign: false", branch_merge_assign(false), 6)

// -- 3. Nested branch merge --

println("")
println("--- 3. Nested branches ---")

fn branch_merge_nested(x) {
    let mut val = 0
    if x > 10 {
        if x > 20 {
            val = 3
        } else {
            val = 2
        }
    } else {
        val = 1
    }
    // Common successor to outer if/else
    return val * 10
}

check("merge-nested: x=5", branch_merge_nested(5), 10)
check("merge-nested: x=15", branch_merge_nested(15), 20)
check("merge-nested: x=25", branch_merge_nested(25), 30)

// -- 4. Branch merge with println (side-effect, still hoistable) --

println("")
println("--- 4. Branch with common side-effect ---")

fn branch_merge_sideeffect(flag) {
    let mut msg = ""
    if flag {
        msg = "yes"
    } else {
        msg = "no"
    }
    // Common: compute result
    return msg + "!"
}

check("merge-sideeffect: true", branch_merge_sideeffect(true), "yes!")
check("merge-sideeffect: false", branch_merge_sideeffect(false), "no!")

// -- 5. No merge: different successors --

println("")
println("--- 5. No merge (different successors) ---")

fn no_merge_different(x) {
    if x > 0 {
        return x * 2
    } else {
        return x * 3
    }
}

check("no-merge: positive", no_merge_different(5), 10)
check("no-merge: negative", no_merge_different(-3), -9)

// -- 6. Branch merge with accumulator --

println("")
println("--- 6. Accumulator pattern ---")

fn branch_merge_accum(arr) {
    let mut sum = 0
    let mut i = 0
    while i < len(arr) {
        let mut delta = 0
        if arr[i] > 0 {
            delta = arr[i]
        } else {
            delta = 0 - arr[i]
        }
        // Common: accumulate absolute value
        sum = sum + delta
        i = i + 1
    }
    return sum
}

check("merge-accum: mixed", branch_merge_accum([1, -2, 3, -4, 5]), 15)
check("merge-accum: all pos", branch_merge_accum([1, 2, 3]), 6)
check("merge-accum: all neg", branch_merge_accum([-1, -2, -3]), 6)
check("merge-accum: empty", branch_merge_accum([]), 0)

// -- 7. Multi-way branch with common tail --

println("")
println("--- 7. Multi-way branch (if/elif/else) ---")

fn branch_merge_multiway(x) {
    let mut category = ""
    if x < 0 {
        category = "negative"
    } else if x == 0 {
        category = "zero"
    } else {
        category = "positive"
    }
    return category + ":" + to_string(x)
}

check("merge-multiway: neg", branch_merge_multiway(-5), "negative:-5")
check("merge-multiway: zero", branch_merge_multiway(0), "zero:0")
check("merge-multiway: pos", branch_merge_multiway(7), "positive:7")

// -- 8. Branch merge preserves correctness with complex expressions --

println("")
println("--- 8. Complex expression in common tail ---")

fn branch_merge_complex(a, b) {
    let mut x = 0
    let mut y = 0
    if a > b {
        x = a
        y = b
    } else {
        x = b
        y = a
    }
    // Common tail: compute from both variables
    return (x - y) * (x + y)
}

check("merge-complex: 5,3", branch_merge_complex(5, 3), 16)
check("merge-complex: 3,5", branch_merge_complex(3, 5), 16)
check("merge-complex: 10,10", branch_merge_complex(10, 10), 0)
check("merge-complex: 7,2", branch_merge_complex(7, 2), 45)

// -- Summary --
println("")
println("=====================================================================")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("=====================================================================")
assert(fail_count == 0)
