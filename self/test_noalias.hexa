// =====================================================================
//  test_noalias.hexa -- @noalias (return value alias separation) tests
//
//  @noalias guarantees the returned object does NOT alias any input
//  parameter, enabling the optimizer to reorder reads/writes freely.
//  Validates: new-alloc return (OK), scalar return (OK), string return
//  (OK), conditional returns, nested loops, combos with other attrs.
//
//  Run: ./hexa self/test_noalias.hexa
// =====================================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

println("=====================================================")
println("  HEXA @noalias (return value alias separation)")
println("=====================================================")
println("")

// ── 1. Basic: return new array (no alias) ──
println("--- 1. @noalias basic new-alloc return ---")

@noalias fn make_doubled(arr) {
    let mut out = []
    let mut i = 0
    while i < len(arr) {
        out.push(arr[i] * 2)
        i = i + 1
    }
    return out
}

let r1 = make_doubled([1, 2, 3])
check("noalias make_doubled [0]=2", r1[0] == 2)
check("noalias make_doubled [1]=4", r1[1] == 4)
check("noalias make_doubled [2]=6", r1[2] == 6)

// ── 2. Return scalar (never aliases) ──
println("")
println("--- 2. @noalias scalar return ---")

@noalias fn sum_all(arr) {
    let mut s = 0
    let mut i = 0
    while i < len(arr) {
        s = s + arr[i]
        i = i + 1
    }
    return s
}

check("noalias sum_all", sum_all([10, 20, 30]) == 60)

// ── 3. Return string literal (never aliases) ──
println("")
println("--- 3. @noalias string literal return ---")

@noalias fn describe(x) {
    if x > 0 { return "positive" }
    if x < 0 { return "negative" }
    return "zero"
}

check("noalias describe(5)", describe(5) == "positive")
check("noalias describe(-3)", describe(-3) == "negative")
check("noalias describe(0)", describe(0) == "zero")

// ── 4. Return new map (no alias) ──
println("")
println("--- 4. @noalias new map return ---")

@noalias fn make_freq(arr) {
    let mut m = #{}
    let mut i = 0
    while i < len(arr) {
        let key = to_string(arr[i])
        if has_key(m, key) {
            m[key] = m[key] + 1
        } else {
            m[key] = 1
        }
        i = i + 1
    }
    return m
}

let r4 = make_freq([1, 2, 2, 3, 3, 3])
check("noalias freq 1", r4["1"] == 1)
check("noalias freq 2", r4["2"] == 2)
check("noalias freq 3", r4["3"] == 3)

// ── 5. Two params, return new (no alias) ──
println("")
println("--- 5. @noalias two-param zip ---")

@noalias fn zip_add(a, b) {
    let mut out = []
    let mut i = 0
    while i < len(a) {
        out.push(a[i] + b[i])
        i = i + 1
    }
    return out
}

let r5 = zip_add([1, 2], [10, 20])
check("noalias zip_add [0]=11", r5[0] == 11)
check("noalias zip_add [1]=22", r5[1] == 22)

// ── 6. @noalias + @pure combo ──
println("")
println("--- 6. @noalias + @pure combo ---")

@noalias @pure fn pure_product(arr) {
    let mut p = 1
    let mut i = 0
    while i < len(arr) {
        p = p * arr[i]
        i = i + 1
    }
    return p
}

check("noalias+pure product", pure_product([2, 3, 4]) == 24)
check("noalias+pure product2", pure_product([5, 5]) == 25)

// ── 7. @noalias with conditional returns ──
println("")
println("--- 7. @noalias conditional returns ---")

@noalias fn filter_positive(arr) {
    let mut out = []
    let mut i = 0
    while i < len(arr) {
        if arr[i] > 0 {
            out.push(arr[i])
        }
        i = i + 1
    }
    return out
}

let r7 = filter_positive([-1, 2, -3, 4, 5])
check("noalias filter len=3", len(r7) == 3)
check("noalias filter [0]=2", r7[0] == 2)
check("noalias filter [1]=4", r7[1] == 4)
check("noalias filter [2]=5", r7[2] == 5)

// ── 8. @noalias with nested loops ──
println("")
println("--- 8. @noalias nested loop ---")

@noalias fn flatten_2d(matrix) {
    let mut out = []
    let mut i = 0
    while i < len(matrix) {
        let row = matrix[i]
        let mut j = 0
        while j < len(row) {
            out.push(row[j])
            j = j + 1
        }
        i = i + 1
    }
    return out
}

let r8 = flatten_2d([[1, 2], [3, 4], [5]])
check("noalias flatten len=5", len(r8) == 5)
check("noalias flatten [3]=4", r8[3] == 4)

// ── 9. @noalias zero-param (trivially safe) ──
println("")
println("--- 9. @noalias zero-param ---")

@noalias fn make_sequence() {
    return [1, 2, 3, 4, 5]
}

let r9 = make_sequence()
check("noalias zero-param len=5", len(r9) == 5)
check("noalias zero-param [4]=5", r9[4] == 5)

// ── 10. @noalias with string concatenation ──
println("")
println("--- 10. @noalias string concat ---")

@noalias fn join_items(arr, sep) {
    let mut out = ""
    let mut i = 0
    while i < len(arr) {
        if i > 0 { out = out + sep }
        out = out + to_string(arr[i])
        i = i + 1
    }
    return out
}

check("noalias join", join_items([1, 2, 3], "-") == "1-2-3")

// ── 11. @noalias with accumulator pattern ──
println("")
println("--- 11. @noalias accumulator ---")

@noalias fn running_sum(arr) {
    let mut out = []
    let mut total = 0
    let mut i = 0
    while i < len(arr) {
        total = total + arr[i]
        out.push(total)
        i = i + 1
    }
    return out
}

let r11 = running_sum([1, 2, 3, 4])
check("noalias running_sum [0]=1", r11[0] == 1)
check("noalias running_sum [1]=3", r11[1] == 3)
check("noalias running_sum [2]=6", r11[2] == 6)
check("noalias running_sum [3]=10", r11[3] == 10)

// ── 12. @noalias + @restrict combo ──
println("")
println("--- 12. @noalias + @restrict ---")

@noalias @restrict fn vec_sub(a, b) {
    let mut out = []
    let mut i = 0
    while i < len(a) {
        out.push(a[i] - b[i])
        i = i + 1
    }
    return out
}

let r12 = vec_sub([10, 20, 30], [1, 2, 3])
check("noalias+restrict [0]=9", r12[0] == 9)
check("noalias+restrict [2]=27", r12[2] == 27)

// ── 13. @noalias return bool (scalar, safe) ──
println("")
println("--- 13. @noalias bool return ---")

@noalias fn has_negative(arr) {
    let mut i = 0
    while i < len(arr) {
        if arr[i] < 0 { return true }
        i = i + 1
    }
    return false
}

check("noalias has_negative true", has_negative([1, -2, 3]) == true)
check("noalias has_negative false", has_negative([1, 2, 3]) == false)

// ── 14. @noalias with early return ──
println("")
println("--- 14. @noalias early return ---")

@noalias fn find_first_positive(arr) {
    let mut i = 0
    while i < len(arr) {
        if arr[i] > 0 { return arr[i] }
        i = i + 1
    }
    return -1
}

check("noalias find_first_positive", find_first_positive([-5, -3, 7, 2]) == 7)
check("noalias find_first_positive none", find_first_positive([-1, -2]) == -1)

// ── 15. @noalias map values ──
println("")
println("--- 15. @noalias map values ---")

@noalias fn square_all(arr) {
    let mut out = []
    let mut i = 0
    while i < len(arr) {
        out.push(arr[i] * arr[i])
        i = i + 1
    }
    return out
}

let r15 = square_all([1, 2, 3, 4])
check("noalias square [0]=1", r15[0] == 1)
check("noalias square [1]=4", r15[1] == 4)
check("noalias square [3]=16", r15[3] == 16)

// ── 16. @noalias reverse copy ──
println("")
println("--- 16. @noalias reverse copy ---")

@noalias fn reverse_copy(arr) {
    let mut out = []
    let mut i = len(arr) - 1
    while i >= 0 {
        out.push(arr[i])
        i = i - 1
    }
    return out
}

let r16 = reverse_copy([1, 2, 3])
check("noalias reverse [0]=3", r16[0] == 3)
check("noalias reverse [2]=1", r16[2] == 1)

// ── 17. @noalias with multiple arrays ──
println("")
println("--- 17. @noalias merge ---")

@noalias fn merge_arrays(a, b) {
    let mut out = []
    let mut i = 0
    while i < len(a) {
        out.push(a[i])
        i = i + 1
    }
    let mut j = 0
    while j < len(b) {
        out.push(b[j])
        j = j + 1
    }
    return out
}

let r17 = merge_arrays([1, 3, 5], [2, 4])
check("noalias merge len=5", len(r17) == 5)
check("noalias merge [0]=1", r17[0] == 1)
check("noalias merge [4]=4", r17[4] == 4)

// ── 18. @noalias + @optimize combo ──
println("")
println("--- 18. @noalias + @optimize ---")

@noalias @optimize fn optimized_copy(arr) {
    let mut out = []
    let mut i = 0
    while i < len(arr) {
        out.push(arr[i])
        i = i + 1
    }
    return out
}

let r18 = optimized_copy([100, 200, 300])
check("noalias+optimize [0]=100", r18[0] == 100)
check("noalias+optimize [2]=300", r18[2] == 300)

// ── 19. @noalias with arithmetic transform ──
println("")
println("--- 19. @noalias arithmetic transform ---")

@noalias fn normalize(arr) {
    let mut mx = arr[0]
    let mut i = 1
    while i < len(arr) {
        if arr[i] > mx { mx = arr[i] }
        i = i + 1
    }
    let mut out = []
    let mut j = 0
    while j < len(arr) {
        out.push(arr[j] * 100 / mx)
        j = j + 1
    }
    return out
}

let r19 = normalize([25, 50, 100])
check("noalias normalize [0]=25", r19[0] == 25)
check("noalias normalize [1]=50", r19[1] == 50)
check("noalias normalize [2]=100", r19[2] == 100)

// ── 20. @noalias independence: output truly independent ──
println("")
println("--- 20. @noalias independence ---")

@noalias fn independent_copy(src) {
    let mut out = []
    let mut i = 0
    while i < len(src) {
        out.push(src[i])
        i = i + 1
    }
    return out
}

let original = [10, 20, 30]
let copied = independent_copy(original)
check("noalias independence [0]", copied[0] == 10)
check("noalias independence [1]", copied[1] == 20)
check("noalias independence [2]", copied[2] == 30)
check("noalias independence len", len(copied) == len(original))

// ── 21. @noalias with three params ──
println("")
println("--- 21. @noalias three-param ---")

@noalias fn weighted_sum(a, b, weights) {
    let mut out = []
    let mut i = 0
    while i < len(a) {
        out.push(a[i] * weights[0] + b[i] * weights[1])
        i = i + 1
    }
    return out
}

let r21 = weighted_sum([1, 2], [3, 4], [2, 3])
check("noalias weighted [0]=11", r21[0] == 11)
check("noalias weighted [1]=16", r21[1] == 16)

// ── 22. @noalias with empty input ──
println("")
println("--- 22. @noalias empty input ---")

@noalias fn process_empty(arr) {
    let mut out = []
    let mut i = 0
    while i < len(arr) {
        out.push(arr[i])
        i = i + 1
    }
    return out
}

let r22 = process_empty([])
check("noalias empty len=0", len(r22) == 0)

// ── 23. @noalias chained calls ──
println("")
println("--- 23. @noalias chained calls ---")

@noalias fn add_one_all(arr) {
    let mut out = []
    let mut i = 0
    while i < len(arr) {
        out.push(arr[i] + 1)
        i = i + 1
    }
    return out
}

let chain = add_one_all(add_one_all([1, 2, 3]))
check("noalias chain [0]=3", chain[0] == 3)
check("noalias chain [1]=4", chain[1] == 4)

// ── 24. @noalias + @inline combo ──
println("")
println("--- 24. @noalias + @inline ---")

@noalias @inline fn inline_copy(arr) {
    let mut out = []
    let mut i = 0
    while i < len(arr) {
        out.push(arr[i])
        i = i + 1
    }
    return out
}

let r24 = inline_copy([7, 8, 9])
check("noalias+inline [0]=7", r24[0] == 7)
check("noalias+inline [2]=9", r24[2] == 9)

// ── 25. @noalias returning computed string ──
println("")
println("--- 25. @noalias computed string ---")

@noalias fn build_csv(arr) {
    let mut out = ""
    let mut i = 0
    while i < len(arr) {
        if i > 0 { out = out + "," }
        out = out + to_string(arr[i])
        i = i + 1
    }
    return out
}

check("noalias csv", build_csv([1, 2, 3]) == "1,2,3")

// ── 26. @noalias with single-element ──
println("")
println("--- 26. @noalias single element ---")

@noalias fn wrap_single(x) {
    return [x]
}

let r26 = wrap_single(42)
check("noalias single [0]=42", r26[0] == 42)
check("noalias single len=1", len(r26) == 1)

// -- Summary --
println("")
println("=====================================================")
println("  @noalias tests: " + to_string(pass_count) + " PASS, " + to_string(fail_count) + " FAIL")
println("=====================================================")
if fail_count > 0 {
    println("SOME TESTS FAILED")
}
