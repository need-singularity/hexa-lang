// ═══════════════════════════════════════════════════════════
//  test_e2e_pipeline.hexa — End-to-End Self-Hosting C Transpile Pipeline Test
//  .hexa source -> lexer -> parser -> type_check -> codegen_c2 -> .c -> clang -> native binary -> run
// ═══════════════════════════════════════════════════════════

let HEXA = "/Users/ghost/Dev/hexa-lang/hexa"
let SELF_DIR = "/Users/ghost/Dev/hexa-lang/self"
let TMP_DIR = "/tmp/hexa_e2e"

// Ensure temp directory exists
exec("mkdir -p " + TMP_DIR)

let mut pass_count = 0
let mut fail_count = 0

// ── Build combined pipeline source ──────────────────────────
// Concatenate: lexer.hexa + parser.hexa + type_checker.hexa + codegen_c2.hexa
// These define: tokenize(), parse(), type_check(), codegen_c2()

fn build_pipeline_source() {
    let lexer_src = read_file(SELF_DIR + "/lexer.hexa")
    let parser_src = read_file(SELF_DIR + "/parser.hexa")
    let tc_src = read_file(SELF_DIR + "/type_checker.hexa")
    let cg_src = read_file(SELF_DIR + "/codegen_c2.hexa")
    return lexer_src + "\n" + parser_src + "\n" + tc_src + "\n" + cg_src + "\n"
}

let pipeline_src = build_pipeline_source()

// ── Test runner ─────────────────────────────────────────────
// For each test case:
//   1. Build a .hexa driver that lexes/parses/type-checks/codegen_c2 the source
//   2. Write driver to temp file, exec hexa on it -> produces .c file
//   3. Compile .c with clang -> native binary
//   4. Run binary, capture output
//   5. Verify output matches expected

fn run_e2e_test(name, hexa_source, expected_output) {
    println("--- Test: " + name + " ---")

    let c_file = TMP_DIR + "/" + name + ".c"
    let bin_file = TMP_DIR + "/" + name
    let driver_file = TMP_DIR + "/" + name + "_driver.hexa"

    // Build driver: pipeline modules + driver code that generates C
    // We escape the source into the driver via write_file
    let src_file = TMP_DIR + "/" + name + ".hexa"
    write_file(src_file, hexa_source)

    let driver = pipeline_src + "\n" + "let __src = read_file(\"" + src_file + "\")\n" + "let __tokens = tokenize(__src)\n" + "let __ast = parse(__tokens)\n" + "let __errors = type_check(__ast)\n" + "if len(__errors) > 0 {\n" + "  print_type_errors(__errors)\n" + "}\n" + "let __c = codegen_c2(__ast)\n" + "write_file(\"" + c_file + "\", __c)\n" + "println(\"PIPELINE_OK\")\n"

    write_file(driver_file, driver)

    // Step 1: Run pipeline (hexa -> .c)
    let pipeline_result = exec(HEXA + " " + driver_file + " 2>&1")
    if type_of(pipeline_result) == "error" {
        println("  FAIL: pipeline exec error: " + to_string(pipeline_result))
        return false
    }

    // Check pipeline produced output
    let lines = pipeline_result.split("\n")
    let last_line = lines[len(lines) - 1]
    if last_line != "PIPELINE_OK" {
        println("  FAIL: pipeline did not complete successfully")
        println("  output: " + pipeline_result)
        return false
    }
    println("  [1/4] Pipeline OK (lex -> parse -> typecheck -> codegen_c2)")

    // Verify C file exists
    if !file_exists(c_file) {
        println("  FAIL: C file not generated: " + c_file)
        return false
    }

    let c_code = read_file(c_file)
    println("  [2/4] C generated: " + to_string(len(c_code)) + " chars")

    // Step 2: Compile with clang
    let compile_cmd = "clang -O2 -I " + SELF_DIR + " " + c_file + " -o " + bin_file + " -lm 2>&1"
    let compile_result = exec(compile_cmd)
    if type_of(compile_result) == "error" {
        println("  FAIL: clang compile error: " + to_string(compile_result))
        return false
    }
    if len(compile_result) > 0 {
        // clang warnings/errors
        println("  clang output: " + compile_result)
    }
    println("  [3/4] Compiled to native binary: " + bin_file)

    // Step 3: Run the native binary
    let run_result = exec(bin_file + " 2>&1")
    if type_of(run_result) == "error" {
        println("  FAIL: binary execution error: " + to_string(run_result))
        return false
    }
    println("  [4/4] Binary output: \"" + run_result + "\"")

    // Step 4: Verify output
    if run_result == expected_output {
        println("  PASS")
        return true
    } else {
        println("  FAIL: expected \"" + expected_output + "\", got \"" + run_result + "\"")
        return false
    }
}

// ═══════════════════════════════════════════════════════════
//  TEST CASES
// ═══════════════════════════════════════════════════════════

println("═══════════════════════════════════════════════════════")
println("  HEXA Self-Hosting E2E Pipeline Test")
println("  .hexa -> lex -> parse -> typecheck -> C -> clang -> run")
println("═══════════════════════════════════════════════════════")
println("")

// Test 1: Simple println(42)
if run_e2e_test("t1_println", "println(42)", "42") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}
println("")

// Test 2: Function definition and call
let t2_src = "fn add(a, b) {\n  return a + b\n}\nprintln(add(3, 4))"
if run_e2e_test("t2_fn_call", t2_src, "7") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}
println("")

// Test 3: Arithmetic expression
if run_e2e_test("t3_arithmetic", "println(10 * 5 + 2)", "52") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}
println("")

// Test 4: let binding
let t4_src = "let x = 100\nprintln(x)"
if run_e2e_test("t4_let", t4_src, "100") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}
println("")

// Test 5: While loop
let t5_src = "let mut i = 0\nlet mut sum = 0\nwhile i < 5 {\n  i = i + 1\n  sum = sum + i\n}\nprintln(sum)"
if run_e2e_test("t5_while", t5_src, "15") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}
println("")

// Test 6: String println
if run_e2e_test("t6_string", "println(\"hello world\")", "hello world") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}
println("")

// Test 7: Boolean
if run_e2e_test("t7_bool", "println(true)", "true") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}
println("")

// Test 8: Nested function calls
// Note: avoid C reserved names like "double" — codegen does not mangle names
let t8_src = "fn twice(x) {\n  return x * 2\n}\nfn quad(x) {\n  return twice(twice(x))\n}\nprintln(quad(5))"
if run_e2e_test("t8_nested_fn", t8_src, "20") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}
println("")

// Test 9: If-else expression
let t9_src = "let x = 10\nif x > 5 {\n  println(1)\n} else {\n  println(0)\n}"
if run_e2e_test("t9_if_else", t9_src, "1") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}
println("")

// Test 10: Recursive factorial
let t10_src = "fn fact(n) {\n  if n <= 1 {\n    return 1\n  }\n  return n * fact(n - 1)\n}\nprintln(fact(6))"
if run_e2e_test("t10_factorial", t10_src, "720") {
    pass_count = pass_count + 1
} else {
    fail_count = fail_count + 1
}
println("")

// ═══════════════════════════════════════════════════════════
//  SUMMARY
// ═══════════════════════════════════════════════════════════

println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL / " + to_string(pass_count + fail_count) + " total")
if fail_count == 0 {
    println("  ALL TESTS PASSED -- Self-hosting C transpile pipeline verified!")
} else {
    println("  SOME TESTS FAILED")
}
println("═══════════════════════════════════════════════════════")

// Cleanup
exec("rm -rf " + TMP_DIR)
