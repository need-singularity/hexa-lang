// self/std_testing.hexa — HEXA STD_TESTING ported from src/std_testing.rs
//
// Testing builtins for HEXA-LANG.
// Provides:
//   assert_eq(a, b)       -- assert two values are equal
//   assert_ne(a, b)       -- assert two values are not equal
//   assert_true(v)        -- assert value is truthy
//   assert_false(v)       -- assert value is falsy
//   test_run(name, fn)    -- run a test function, return result map
//   test_suite(tests)     -- run array of [name, fn] pairs, return summary
//   bench_fn(name, fn, n) -- benchmark a function N times, return timing map

// ── Value equality ─────────────────────────────────────────

fn values_equal(a, b) -> bool {
    // Leverages Hexa's built-in == for deep equality
    return a == b
}

// ── Truthiness ─────────────────────────────────────────────

fn is_truthy(v) -> bool {
    if v == false { return false }
    if v == 0 { return false }
    if v == 0.0 { return false }
    if v == "" { return false }
    if v == [] { return false }
    if v == void { return false }
    return true
}

// ── assert_eq(a, b) ────────────────────────────────────────

fn testing_assert_eq(a, b) {
    if values_equal(a, b) {
        return true
    }
    print("assert_eq failed: " + str(a) + " != " + str(b))
    return false
}

// ── assert_ne(a, b) ────────────────────────────────────────

fn testing_assert_ne(a, b) {
    if !values_equal(a, b) {
        return true
    }
    print("assert_ne failed: " + str(a) + " == " + str(b))
    return false
}

// ── assert_true(v) ─────────────────────────────────────────

fn testing_assert_true(v) {
    if is_truthy(v) {
        return true
    }
    print("assert_true failed: " + str(v) + " is falsy")
    return false
}

// ── assert_false(v) ────────────────────────────────────────

fn testing_assert_false(v) {
    if !is_truthy(v) {
        return true
    }
    print("assert_false failed: " + str(v) + " is truthy")
    return false
}

// ── test_run(name, func) -> map ────────────────────────────
// Runs a single test function and returns result info.

struct TestResult {
    name: string,
    passed: bool,
    error: string,
    elapsed_ms: float
}

fn test_run(name: string, func) -> TestResult {
    let start = clock()
    let passed = true
    let error_msg = ""
    try {
        func()
    } catch e {
        passed = false
        error_msg = str(e)
    }
    let elapsed = (clock() - start) * 1000.0
    return TestResult {
        name: name,
        passed: passed,
        error: error_msg,
        elapsed_ms: elapsed
    }
}

fn test_result_display(r: TestResult) -> string {
    if r.passed {
        return "[PASS] " + r.name + " (" + str(r.elapsed_ms) + "ms)"
    }
    return "[FAIL] " + r.name + ": " + r.error + " (" + str(r.elapsed_ms) + "ms)"
}

// ── test_suite(tests) -> summary ───────────────────────────
// tests: array of [name, fn] pairs

struct TestSummary {
    total: int,
    passed: int,
    failed: int,
    elapsed_ms: float,
    results: [TestResult]
}

fn test_suite(tests: []) -> TestSummary {
    let results: [TestResult] = []
    let passed = 0
    let failed = 0
    let start = clock()

    let i = 0
    while i < len(tests) {
        let pair = tests[i]
        let name = pair[0]
        let func = pair[1]
        let result = test_run(name, func)
        results = results + [result]
        if result.passed {
            passed = passed + 1
        } else {
            failed = failed + 1
        }
        i = i + 1
    }

    let total_ms = (clock() - start) * 1000.0
    return TestSummary {
        total: passed + failed,
        passed: passed,
        failed: failed,
        elapsed_ms: total_ms,
        results: results
    }
}

fn test_summary_display(s: TestSummary) -> string {
    let out = "Test Suite: " + str(s.passed) + "/" + str(s.total) + " passed"
    if s.failed > 0 {
        out = out + " (" + str(s.failed) + " FAILED)"
    }
    out = out + " in " + str(s.elapsed_ms) + "ms"
    return out
}

// ── bench_fn(name, func, iterations) -> map ────────────────

struct BenchResult {
    name: string,
    iterations: int,
    total_us: float,
    avg_us: float,
    ops_per_sec: float
}

fn bench_fn(name: string, func, iterations: int) -> BenchResult {
    if iterations <= 0 {
        iterations = 1000
    }
    let start = clock()
    let i = 0
    while i < iterations {
        func()
        i = i + 1
    }
    let total_us = (clock() - start) * 1000000.0
    let avg_us = total_us / float(iterations)
    let ops = 0.0
    if avg_us > 0.0 {
        ops = 1000000.0 / avg_us
    }
    return BenchResult {
        name: name,
        iterations: iterations,
        total_us: total_us,
        avg_us: avg_us,
        ops_per_sec: ops
    }
}

fn bench_result_display(b: BenchResult) -> string {
    return b.name + ": " + str(b.iterations) + " iters, avg " + str(b.avg_us) + "us, " + str(b.ops_per_sec) + " ops/s"
}

// ── Tests ──────────────────────────────────────────────────

fn test_values_equal() {
    assert(values_equal(42, 42) == true)
    assert(values_equal(1, 2) == false)
    assert(values_equal("hello", "hello") == true)
    assert(values_equal(3.14, 3.14) == true)
    assert(values_equal(true, true) == true)
    assert(values_equal([1, 2], [1, 2]) == true)
    assert(values_equal([1, 2], [1, 3]) == false)
    print("  PASS: values_equal")
}

fn test_is_truthy() {
    assert(is_truthy(true) == true)
    assert(is_truthy(false) == false)
    assert(is_truthy(1) == true)
    assert(is_truthy(0) == false)
    assert(is_truthy("hi") == true)
    assert(is_truthy("") == false)
    assert(is_truthy([1]) == true)
    assert(is_truthy([]) == false)
    print("  PASS: is_truthy")
}

fn test_assert_eq_pass() {
    assert(testing_assert_eq(42, 42) == true)
    assert(testing_assert_eq("a", "a") == true)
    print("  PASS: assert_eq_pass")
}

fn test_assert_ne_pass() {
    assert(testing_assert_ne(1, 2) == true)
    assert(testing_assert_ne("a", "b") == true)
    print("  PASS: assert_ne_pass")
}

fn test_assert_true_pass() {
    assert(testing_assert_true(true) == true)
    assert(testing_assert_true(1) == true)
    assert(testing_assert_true("hi") == true)
    print("  PASS: assert_true_pass")
}

fn test_assert_false_pass() {
    assert(testing_assert_false(false) == true)
    assert(testing_assert_false(0) == true)
    assert(testing_assert_false("") == true)
    print("  PASS: assert_false_pass")
}

fn test_test_run() {
    let result = test_run("passing_test", fn() { assert(1 == 1) })
    assert(result.passed == true)
    assert(result.name == "passing_test")
    assert(result.elapsed_ms >= 0.0)
    print("  PASS: test_run")
}

fn test_test_result_display() {
    let r = TestResult { name: "mytest", passed: true, error: "", elapsed_ms: 1.5 }
    let s = test_result_display(r)
    assert(len(s) > 0)
    print("  PASS: test_result_display")
}

fn test_bench_result_display() {
    let b = BenchResult { name: "mybench", iterations: 100, total_us: 5000.0, avg_us: 50.0, ops_per_sec: 20000.0 }
    let s = bench_result_display(b)
    assert(len(s) > 0)
    print("  PASS: bench_result_display")
}

// ── Main ───────────────────────────────────────────────────

print("=== std_testing.hexa tests ===")
test_values_equal()
test_is_truthy()
test_assert_eq_pass()
test_assert_ne_pass()
test_assert_true_pass()
test_assert_false_pass()
test_test_run()
test_test_result_display()
test_bench_result_display()
print("All std_testing tests passed.")
