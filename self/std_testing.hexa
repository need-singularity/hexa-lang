// self/std_testing.hexa — HEXA TESTING ported from src/std_testing.rs
//
// Provides:
//   assert_eq(a, b)          — assert two values are equal
//   assert_ne(a, b)          — assert two values are not equal
//   assert_true(v)           — assert value is truthy
//   assert_false(v)          — assert value is falsy
//   test_run(name, fn)       — run a test function, return result map
//   test_suite(tests)        — run array of [name, fn] pairs, return summary
//   bench_fn(name, fn, n)    — benchmark a function N times, return timing map

// -- Value comparison --

fn values_equal(a, b) -> bool {
    // Handles int, float, string, bool, void, array
    if a == b { return true }
    return false
}

fn is_truthy(v) -> bool {
    if v == false { return false }
    if v == 0 { return false }
    if v == 0.0 { return false }
    if v == "" { return false }
    if v == void { return false }
    return true
}

// -- Assertions --

fn assert_eq(a, b) -> bool {
    if values_equal(a, b) {
        return true
    }
    panic("assert_eq failed: " + to_string(a) + " != " + to_string(b))
}

fn assert_ne(a, b) -> bool {
    if values_equal(a, b) == false {
        return true
    }
    panic("assert_ne failed: " + to_string(a) + " == " + to_string(b))
}

fn assert_true(v) -> bool {
    if is_truthy(v) {
        return true
    }
    panic("assert_true failed: " + to_string(v) + " is falsy")
}

fn assert_false(v) -> bool {
    if is_truthy(v) == false {
        return true
    }
    panic("assert_false failed: " + to_string(v) + " is truthy")
}

// -- Test runner --

struct TestResult {
    name: string,
    passed: bool,
    error: string,
    elapsed_ms: float
}

fn test_run(name, func) -> TestResult {
    let start = time_now_ms()
    let passed = true
    let error = ""

    // Try running the test function
    let result = func()
    // If it panics, the runtime will catch it
    // For now we assume success if we reach here
    let elapsed = time_now_ms() - start

    return TestResult {
        name: name,
        passed: true,
        error: "",
        elapsed_ms: elapsed
    }
}

// -- Test suite --

struct SuiteResult {
    total: int,
    passed: int,
    failed: int,
    elapsed_ms: float,
    results: [TestResult]
}

fn test_suite(tests) -> SuiteResult {
    let results = []
    let passed = 0
    let failed = 0
    let total_start = time_now_ms()

    let i = 0
    while i < len(tests) {
        let test = tests[i]
        let name = test[0]
        let func = test[1]

        let start = time_now_ms()
        let test_passed = true
        let test_error = ""

        // Execute the test
        func()
        let elapsed = time_now_ms() - start

        let result = TestResult {
            name: name,
            passed: test_passed,
            error: test_error,
            elapsed_ms: elapsed
        }
        results = array_push(results, result)
        if test_passed { passed = passed + 1 } else { failed = failed + 1 }
        i = i + 1
    }

    let total_elapsed = time_now_ms() - total_start
    return SuiteResult {
        total: passed + failed,
        passed: passed,
        failed: failed,
        elapsed_ms: total_elapsed,
        results: results
    }
}

// -- Benchmark --

struct BenchResult {
    name: string,
    iterations: int,
    total_us: float,
    avg_us: float,
    ops_per_sec: float
}

fn bench_fn(name, func, iterations) -> BenchResult {
    if iterations <= 0 { iterations = 1000 }

    let start = time_now_ms()
    let i = 0
    while i < iterations {
        func()
        i = i + 1
    }
    let total_ms = time_now_ms() - start
    let total_us = total_ms * 1000.0
    let avg_us = total_us / iterations
    let ops = 0.0
    if avg_us > 0.0 { ops = 1000000.0 / avg_us }

    return BenchResult {
        name: name,
        iterations: iterations,
        total_us: total_us,
        avg_us: avg_us,
        ops_per_sec: ops
    }
}
