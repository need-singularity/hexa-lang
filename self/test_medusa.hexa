// ═══════════════════════════════════════════════════════════════
//  test_medusa.hexa — Medusa Heads (speculative decoding) tests
//
//  Tests (30):
//    T1  config creation: vocab/hidden/k
//    T2  config edge case: k=1 single head
//    T3  model creation: correct head count
//    T4  model creation: backbone weight shape
//    T5  model creation: initial counters zero
//    T6  model determinism: same seed same model
//    T7  tree mask shape (k+1 x k+1)
//    T8  tree mask lower-triangular (diagonal=1)
//    T9  tree mask upper-zero
//    T10 tree mask row sums = 1,2,...,k+1
//    T11 tree mask k=1 (2x2 identity lower-tri)
//    T12 backbone output length = hidden
//    T13 backbone determinism
//    T14 backbone values bounded (squash in -1..1)
//    T15 head logits length = vocab
//    T16 head logits differ per head
//    T17 softmax sums to 1
//    T18 softmax all non-negative
//    T19 log_softmax all non-positive
//    T20 CE non-negative
//    T21 predict_k length = k
//    T22 predict_k determinism
//    T23 predict_k tokens in [0, vocab)
//    T24 verify length = drafted length
//    T25 accept_prefix full match
//    T26 accept_prefix partial match (stops at first mismatch)
//    T27 accept_prefix zero match
//    T28 acceptance_rate in [0..100]
//    T29 loss positive
//    T30 loss_per_head length = k
//    T31 train step reduces loss
//    T32 inference loop produces requested token count
//    T33 inference loop accept_log non-empty
//    T34 medusa_step returns 4 components
//    T35 medusa_step row_sums = 1..k+1
//
//  run: ./hexa self/test_medusa.hexa
// ═══════════════════════════════════════════════════════════════

import "ml/medusa.hexa"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn near(a, b, eps) { return fabs(a - b) < eps }

println("=== Medusa Heads Tests ===")

// ── shared fixtures ─────────────────────────────────────────────
let V = 8
let H = 4
let K = 3
let SEED = 42

let cfg = medusa_make_config(V, H, K)
let model = medusa_make_model(cfg, SEED)
let tokens = [1, 3, 0, 5]

// ═══════════════════════════════════════════════════════════════
//  T1-T2: Config creation
// ═══════════════════════════════════════════════════════════════
check("T1 config vocab/hidden/k", cfg.vocab == V && cfg.hidden == H && cfg.k == K)

let cfg1 = medusa_make_config(16, 8, 1)
check("T2 config k=1 single head", cfg1.k == 1)

// ═══════════════════════════════════════════════════════════════
//  T3-T6: Model creation and determinism
// ═══════════════════════════════════════════════════════════════
check("T3 model head count", len(model.heads) == K)
check("T4 backbone weight shape", len(model.backbone_w) == H && len(model.backbone_w[0]) == V)
check("T5 initial counters zero", model.accepted == 0 && model.proposed == 0)

let model2 = medusa_make_model(cfg, SEED)
let h0a = medusa_backbone(model, tokens)
let h0b = medusa_backbone(model2, tokens)
let mut det_ok = true
let mut di = 0
while di < H {
    if fabs(h0a[di] - h0b[di]) > 0.0001 { det_ok = false }
    di = di + 1
}
check("T6 model determinism same seed", det_ok)

// ═══════════════════════════════════════════════════════════════
//  T7-T11: Tree attention mask
// ═══════════════════════════════════════════════════════════════
let mask = medusa_tree_mask(K + 1)
check("T7 tree mask shape", len(mask) == K + 1 && len(mask[0]) == K + 1)

// diagonal should be 1
let mut diag_ok = true
let mut mi = 0
while mi < K + 1 {
    if mask[mi][mi] != 1 { diag_ok = false }
    mi = mi + 1
}
check("T8 tree mask diagonal=1", diag_ok)

// upper triangle should be 0
let mut upper_ok = true
let mut ui = 0
while ui < K + 1 {
    let mut uj = ui + 1
    while uj < K + 1 {
        if mask[ui][uj] != 0 { upper_ok = false }
        uj = uj + 1
    }
    ui = ui + 1
}
check("T9 tree mask upper=0", upper_ok)

// row sums should be 1, 2, 3, ..., k+1
let mut rsum_ok = true
let mut ri = 0
while ri < K + 1 {
    let mut rs = 0
    let mut rj = 0
    while rj < K + 1 {
        rs = rs + mask[ri][rj]
        rj = rj + 1
    }
    if rs != ri + 1 { rsum_ok = false }
    ri = ri + 1
}
check("T10 tree mask row sums 1..k+1", rsum_ok)

// k=1 -> 2x2 mask: [[1,0],[1,1]]
let mask1 = medusa_tree_mask(2)
check("T11 tree mask k=1 shape", mask1[0][0] == 1 && mask1[0][1] == 0 && mask1[1][0] == 1 && mask1[1][1] == 1)

// ═══════════════════════════════════════════════════════════════
//  T12-T14: Backbone
// ═══════════════════════════════════════════════════════════════
let hidden = medusa_backbone(model, tokens)
check("T12 backbone length = hidden", len(hidden) == H)

let hidden2 = medusa_backbone(model, tokens)
let mut bb_det = true
let mut bi = 0
while bi < H {
    if fabs(hidden[bi] - hidden2[bi]) > 0.0001 { bb_det = false }
    bi = bi + 1
}
check("T13 backbone determinism", bb_det)

// squash via s/(1+|s|) is in (-1, 1)
let mut bounded = true
let mut bdi = 0
while bdi < H {
    if hidden[bdi] <= -1.0 { bounded = false }
    if hidden[bdi] >= 1.0 { bounded = false }
    bdi = bdi + 1
}
check("T14 backbone bounded (-1,1)", bounded)

// ═══════════════════════════════════════════════════════════════
//  T15-T16: Head logits
// ═══════════════════════════════════════════════════════════════
let logits0 = medusa_head_logits(model, 0, hidden)
check("T15 head logits length = vocab", len(logits0) == V)

let logits1 = medusa_head_logits(model, 1, hidden)
let mut heads_differ = false
let mut hi2 = 0
while hi2 < V {
    if fabs(logits0[hi2] - logits1[hi2]) > 0.0001 { heads_differ = true }
    hi2 = hi2 + 1
}
check("T16 head logits differ per head", heads_differ)

// ═══════════════════════════════════════════════════════════════
//  T17-T20: Softmax / log_softmax / CE
// ═══════════════════════════════════════════════════════════════
let sm = medusa_softmax(logits0)
let mut sm_sum = 0.0
let mut sm_nonneg = true
let mut si = 0
while si < len(sm) {
    sm_sum = sm_sum + sm[si]
    if sm[si] < 0.0 { sm_nonneg = false }
    si = si + 1
}
check("T17 softmax sums to 1", near(sm_sum, 1.0, 0.001))
check("T18 softmax non-negative", sm_nonneg)

let lsm = medusa_log_softmax(logits0)
let mut lsm_nonpos = true
let mut li = 0
while li < len(lsm) {
    if lsm[li] > 0.001 { lsm_nonpos = false }
    li = li + 1
}
check("T19 log_softmax non-positive", lsm_nonpos)

let ce = medusa_ce(logits0, 0)
check("T20 CE non-negative", ce >= 0.0)

// ═══════════════════════════════════════════════════════════════
//  T21-T23: Draft prediction
// ═══════════════════════════════════════════════════════════════
let pred = medusa_predict_k(model, tokens)
check("T21 predict_k length = k", len(pred) == K)

let pred2 = medusa_predict_k(model, tokens)
let mut pred_det = true
let mut pi = 0
while pi < K {
    if pred[pi] != pred2[pi] { pred_det = false }
    pi = pi + 1
}
check("T22 predict_k determinism", pred_det)

let mut in_range = true
let mut pri = 0
while pri < K {
    if pred[pri] < 0 { in_range = false }
    if pred[pri] >= V { in_range = false }
    pri = pri + 1
}
check("T23 predict_k tokens in [0,vocab)", in_range)

// ═══════════════════════════════════════════════════════════════
//  T24: Verify
// ═══════════════════════════════════════════════════════════════
let verified = medusa_verify(model, tokens, pred, 0)
check("T24 verify length = drafted", len(verified) == len(pred))

// ═══════════════════════════════════════════════════════════════
//  T25-T27: Accept prefix
// ═══════════════════════════════════════════════════════════════
let full_match = medusa_accept_prefix([1, 2, 3], [1, 2, 3])
check("T25 accept_prefix full match", full_match == 3)

let partial = medusa_accept_prefix([1, 2, 3], [1, 9, 3])
check("T26 accept_prefix partial (stops at mismatch)", partial == 1)

let zero_match = medusa_accept_prefix([5, 6, 7], [0, 0, 0])
check("T27 accept_prefix zero match", zero_match == 0)

// ═══════════════════════════════════════════════════════════════
//  T28: Acceptance rate
// ═══════════════════════════════════════════════════════════════
let contexts = [[1, 2, 3], [0, 1, 4], [3, 5, 7]]
let rate = medusa_acceptance_rate(model, contexts, 0)
check("T28 acceptance_rate in [0..100]", rate >= 0 && rate <= 100)

// ═══════════════════════════════════════════════════════════════
//  T29-T30: Loss
// ═══════════════════════════════════════════════════════════════
let targets_k = [0, 1, 2]
let loss = medusa_loss(model, tokens, targets_k)
check("T29 loss positive", loss > 0.0)

let lph = medusa_loss_per_head(model, tokens, targets_k)
check("T30 loss_per_head length = k", len(lph) == K)

// ═══════════════════════════════════════════════════════════════
//  T31: Train step reduces loss
// ═══════════════════════════════════════════════════════════════
let step_result = medusa_train_step(model, tokens, targets_k, 0.5)
let new_loss = step_result[0]
check("T31 train step reduces loss", new_loss < loss)

// ═══════════════════════════════════════════════════════════════
//  T32-T33: Inference loop
// ═══════════════════════════════════════════════════════════════
let max_tok = 6
let inf = medusa_inference_loop(model, tokens, max_tok, 1)
let gen = inf[0]
let accept_log = inf[1]
check("T32 inference loop token count", len(gen) == max_tok)
check("T33 inference loop accept_log non-empty", len(accept_log) > 0)

// ═══════════════════════════════════════════════════════════════
//  T34-T35: medusa_step top-level
// ═══════════════════════════════════════════════════════════════
let step = medusa_step(model, tokens, targets_k, 0)
check("T34 medusa_step returns 4 components", len(step) == 4)

let row_sums = step[3]
let mut rs_ok = true
let mut rsi = 0
while rsi < len(row_sums) {
    if row_sums[rsi] != rsi + 1 { rs_ok = false }
    rsi = rsi + 1
}
check("T35 medusa_step row_sums = 1..k+1", rs_ok)

// ── summary ────────────────────────────────────────────────────
println("")
println("Medusa Heads: " + str(pass_count) + " passed, " + str(fail_count) + " failed")
