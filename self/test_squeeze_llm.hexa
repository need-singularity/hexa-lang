    println("=== test_squeeze_llm.hexa — SqueezeLLM Non-uniform Quantization (ML #100) ===")
    test_hessian_positive()
    test_sensitivity_basic()
    test_sensitivity_with_calib()
    test_kmeans_init_range()
    test_kmeans_step_convergence()
    test_codebook_sorted()
    test_int4_code_range()
    test_int3_code_range()
    test_dequantize_shape()
    test_dequantize_from_codebook()
    test_int4_mse_bounded()
    test_int3_vs_int4_quality()
    test_forward_shape()
    test_forward_matches_dequant()
    test_zero_weights()
    test_constant_weights()
    test_sens_stats()
    test_codebook_covers_range()
    test_nonuniform_advantage()
    test_calib_improves_quality()
    test_error_stats_snr()
    test_larger_matrix_calib()
    test_forward_zero_input()
    test_codebook_k2()
    test_assign_nearest()
    test_sensitivity_weighted_centroids()
    test_empty_calib_fallback()
    println("")
    println("=== RESULT ===")
    println("  PASS: " + str(pass_count))
    println("  FAIL: " + str(fail_count))
    if fail_count == 0 {
        println("=== ALL SQUEEZE_LLM TESTS PASSED ===")
    } else {
        println("=== SOME TESTS FAILED ===")
    }
}

main()
