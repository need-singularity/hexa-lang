// -- inlined from self/ml/multi_node_training.hexa --
// codegen import not wired for test files

// ===================================================================
//  multi_node_training.hexa — Cross-Node Gradient Synchronization
//
//  Pure .hexa CPU simulation of multi-node training with:
//    - Ring AllReduce for bandwidth-optimal gradient averaging
//    - Tree AllReduce for logarithmic latency reduction
//    - Async gradient sync (local SGD with periodic sync)
//    - Topology discovery: auto-select ring vs tree
//
//  Each "node" is simulated as an index into arrays of per-node
//  gradient/parameter vectors. No NCCL, no network.
//
//  ML roadmap #241 — Multi-Node Training
// ===================================================================

// ── Array helpers ────────────────────────────────────────────

fn mnt_zeros(n) {
    let mut out = []
    let mut i = 0
    while i < n {
        out.push(0.0)
        i = i + 1
    }
    out
}

fn mnt_copy(src) {
    let n = len(src)
    let mut out = []
    let mut i = 0
    while i < n {
        out.push(src[i])
        i = i + 1
    }
    out
}

fn mnt_add(a, b) {
    let n = len(a)
    let mut out = []
    let mut i = 0
    while i < n {
        out.push(a[i] + b[i])
        i = i + 1
    }
    out
}

fn mnt_scale(a, s) {
    let n = len(a)
    let mut out = []
    let mut i = 0
    while i < n {
        out.push(a[i] * s)
        i = i + 1
    }
    out
}

fn mnt_sub(a, b) {
    let n = len(a)
    let mut out = []
    let mut i = 0
    while i < n {
        out.push(a[i] - b[i])
        i = i + 1
    }
    out
}

// ── Node configuration ──────────────────────────────────────

struct MntConfig {
    num_nodes: int,
    param_size: int,
    lr: float,
    sync_every: int,
    topology: string
}

fn mnt_config(num_nodes, param_size, lr) {
    MntConfig {
        num_nodes: num_nodes,
        param_size: param_size,
        lr: lr,
        sync_every: 1,
        topology: "ring"
    }
}

fn mnt_config_async(num_nodes, param_size, lr, sync_every) {
    MntConfig {
        num_nodes: num_nodes,
        param_size: param_size,
        lr: lr,
        sync_every: sync_every,
        topology: "ring"
    }
}

// ── Topology discovery ──────────────────────────────────────

// Auto-detect topology: ring for <= 8 nodes, tree for > 8
fn mnt_auto_topology(num_nodes) {
    if num_nodes <= 8 {
        "ring"
    } else {
        "tree"
    }
}

// ═══════════════════════════════════════════════════════════════
//  Ring AllReduce for Gradient Averaging
//
//  Input: per-node gradient arrays (array of arrays)
//  Output: averaged gradient (same on all nodes)
//  Algorithm: naive ring simulation (sum then divide by N)
// ═══════════════════════════════════════════════════════════════

fn mnt_ring_allreduce_avg(grads, num_nodes) {
    let param_size = len(grads[0])

    // Sum all gradients
    let mut summed = mnt_zeros(param_size)
    let mut n = 0
    while n < num_nodes {
        summed = mnt_add(summed, grads[n])
        n = n + 1
    }

    // Average
    let avg = mnt_scale(summed, 1.0 / to_float(num_nodes))

    // Broadcast to all nodes
    let mut result = []
    n = 0
    while n < num_nodes {
        result.push(mnt_copy(avg))
        n = n + 1
    }
    result
}

// Ring allreduce with chunked pipelining (bandwidth-optimal)
fn mnt_ring_allreduce_chunked(grads, num_nodes) {
    let param_size = len(grads[0])
    let num_chunks = num_nodes

    // Chunk boundaries
    let mut chunks = []
    let mut c = 0
    while c < num_chunks {
        let begin = (param_size * c) / num_chunks
        let end = (param_size * (c + 1)) / num_chunks
        chunks.push([begin, end])
        c = c + 1
    }

    // Copy grads
    let mut bufs = []
    let mut r = 0
    while r < num_nodes {
        bufs.push(mnt_copy(grads[r]))
        r = r + 1
    }

    // Phase 1: reduce-scatter (N-1 steps)
    let mut step = 0
    while step < num_nodes - 1 {
        let mut new_bufs = []
        let mut rr = 0
        while rr < num_nodes {
            new_bufs.push(mnt_copy(bufs[rr]))
            rr = rr + 1
        }

        rr = 0
        while rr < num_nodes {
            let chunk_idx = ((rr - step) % num_chunks + num_chunks) % num_chunks
            let recv_rank = (rr + 1) % num_nodes
            let pair = chunks[chunk_idx]
            let begin = pair[0]
            let end = pair[1]
            let mut i = begin
            while i < end {
                new_bufs[recv_rank][i] = new_bufs[recv_rank][i] + bufs[rr][i]
                i = i + 1
            }
            rr = rr + 1
        }
        bufs = new_bufs
        step = step + 1
    }

    // Phase 2: allgather (N-1 steps)
    step = 0
    while step < num_nodes - 1 {
        let mut new_bufs = []
        let mut rr = 0
        while rr < num_nodes {
            new_bufs.push(mnt_copy(bufs[rr]))
            rr = rr + 1
        }

        rr = 0
        while rr < num_nodes {
            let chunk_idx = ((rr - step + 1) % num_chunks + num_chunks) % num_chunks
            let recv_rank = (rr + 1) % num_nodes
            let pair = chunks[chunk_idx]
            let begin = pair[0]
            let end = pair[1]
            let mut i = begin
            while i < end {
                new_bufs[recv_rank][i] = bufs[rr][i]
                i = i + 1
            }
            rr = rr + 1
        }
        bufs = new_bufs
        step = step + 1
    }

    // Divide by N for averaging
    let mut result = []
    r = 0
    while r < num_nodes {
        result.push(mnt_scale(bufs[r], 1.0 / to_float(num_nodes)))
        r = r + 1
    }
    result
}

// ═══════════════════════════════════════════════════════════════
//  Tree AllReduce for Logarithmic Latency
//
//  Binary tree reduction followed by broadcast.
//  Latency: O(log N) vs ring's O(N) steps.
// ═══════════════════════════════════════════════════════════════

fn mnt_tree_allreduce_avg(grads, num_nodes) {
    let param_size = len(grads[0])

    // Copy grads into mutable buffers
    let mut bufs = []
    let mut n = 0
    while n < num_nodes {
        bufs.push(mnt_copy(grads[n]))
        n = n + 1
    }

    // Upward reduction: binary tree, stride doubles each level
    let mut stride = 1
    while stride < num_nodes {
        let mut i = 0
        while i + stride < num_nodes {
            if i % (stride * 2) == 0 {
                bufs[i] = mnt_add(bufs[i], bufs[i + stride])
            }
            i = i + 1
        }
        stride = stride * 2
    }

    // Root (node 0) has the sum. Average it.
    let avg = mnt_scale(bufs[0], 1.0 / to_float(num_nodes))

    // Downward broadcast: reverse tree traversal
    bufs[0] = avg
    stride = stride / 2
    while stride >= 1 {
        let mut i = 0
        while i + stride < num_nodes {
            if i % (stride * 2) == 0 {
                bufs[i + stride] = mnt_copy(bufs[i])
            }
            i = i + 1
        }
        stride = stride / 2
    }

    bufs
}

// ═══════════════════════════════════════════════════════════════
//  Gradient Sync Wrapper — applies allreduce to gradients
//  then updates parameters with SGD.
// ═══════════════════════════════════════════════════════════════

fn mnt_sync_step(params_per_node, grads_per_node, cfg) {
    let num_nodes = cfg.num_nodes

    // AllReduce gradients
    let mut avg_grads = []
    if cfg.topology == "tree" {
        avg_grads = mnt_tree_allreduce_avg(grads_per_node, num_nodes)
    } else {
        avg_grads = mnt_ring_allreduce_avg(grads_per_node, num_nodes)
    }

    // SGD update on each node
    let mut new_params = []
    let mut n = 0
    while n < num_nodes {
        let p = params_per_node[n]
        let g = avg_grads[n]
        let updated = mnt_sub(p, mnt_scale(g, cfg.lr))
        new_params.push(updated)
        n = n + 1
    }
    new_params
}

// ═══════════════════════════════════════════════════════════════
//  Async Gradient Sync — Local SGD with periodic synchronization
//
//  Each node runs K local SGD steps before synchronizing.
//  On sync steps: average all node parameters (not gradients).
// ═══════════════════════════════════════════════════════════════

struct MntAsyncState {
    params: array,
    step_count: int,
    sync_count: int
}

fn mnt_async_init(initial_params, num_nodes) {
    let mut params = []
    let mut n = 0
    while n < num_nodes {
        params.push(mnt_copy(initial_params))
        n = n + 1
    }
    MntAsyncState {
        params: params,
        step_count: 0,
        sync_count: 0
    }
}

// One local SGD step per node with local gradients, sync if step % sync_every == 0
fn mnt_async_step(state, local_grads, cfg) {
    let num_nodes = cfg.num_nodes
    let new_step = state.step_count + 1

    // Local SGD update
    let mut new_params = []
    let mut n = 0
    while n < num_nodes {
        let p = state.params[n]
        let g = local_grads[n]
        let updated = mnt_sub(p, mnt_scale(g, cfg.lr))
        new_params.push(updated)
        n = n + 1
    }

    // Check if sync is needed
    let mut sync_count = state.sync_count
    if new_step % cfg.sync_every == 0 {
        // Average all node parameters
        let param_size = len(new_params[0])
        let mut avg = mnt_zeros(param_size)
        n = 0
        while n < num_nodes {
            avg = mnt_add(avg, new_params[n])
            n = n + 1
        }
        avg = mnt_scale(avg, 1.0 / to_float(num_nodes))

        // Broadcast averaged params to all nodes
        let mut synced = []
        n = 0
        while n < num_nodes {
            synced.push(mnt_copy(avg))
            n = n + 1
        }
        new_params = synced
        sync_count = sync_count + 1
    }

    MntAsyncState {
        params: new_params,
        step_count: new_step,
        sync_count: sync_count
    }
}

// ── Tree latency metric ─────────────────────────────────────

fn mnt_tree_latency_steps(num_nodes) {
    // O(log2 N) for reduce + O(log2 N) for broadcast
    let mut steps = 0
    let mut n = num_nodes
    while n > 1 {
        steps = steps + 1
        n = (n + 1) / 2
    }
    steps * 2
}

fn mnt_ring_latency_steps(num_nodes) {
    2 * (num_nodes - 1)
}

println("[multi_node_training] module loaded — ring/tree allreduce + async SGD ready")


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn mnt_test_fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn mnt_test_approx(a, b, eps) { return mnt_test_fabs(a - b) < eps }

fn check(idx, name, cond) {
    if cond {
        println("[PASS] #" + str(idx) + " " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] #" + str(idx) + " " + name)
        fail_count = fail_count + 1
    }
}

fn mnt_arrays_near(a, b, tol) {
    if len(a) != len(b) { return false }
    let n = len(a)
    let mut i = 0
    while i < n {
        if !mnt_test_approx(a[i], b[i], tol) { return false }
        i = i + 1
    }
    true
}

println("=== Multi-Node Training (#241) Tests ===")

// ── Fixtures ────────────────────────────────────────────────────
let WORLD_SIZE = 4
let PARAM_SIZE = 8

// Per-node gradients: node n has constant value (n+1).0 repeated PARAM_SIZE times
let mut grads = []
let mut n_init = 0
while n_init < WORLD_SIZE {
    let mut g = []
    let mut i = 0
    while i < PARAM_SIZE {
        g.push(to_float(n_init + 1))
        i = i + 1
    }
    grads.push(g)
    n_init = n_init + 1
}

// Expected average: (1+2+3+4)/4 = 2.5
let mut expected_avg = []
let mut i_init = 0
while i_init < PARAM_SIZE {
    expected_avg.push(2.5)
    i_init = i_init + 1
}

// ═══════════════════════════════════════════════════════════════
//  #1-#4 — Array helpers + config
// ═══════════════════════════════════════════════════════════════

let z = mnt_zeros(5)
check(1, "mnt_zeros length and values",
    len(z) == 5 && mnt_test_approx(z[0], 0.0, 1.0e-9) && mnt_test_approx(z[4], 0.0, 1.0e-9))

let cp = mnt_copy([1.0, 2.0, 3.0])
check(2, "mnt_copy makes an equal array",
    len(cp) == 3 && mnt_test_approx(cp[0], 1.0, 1.0e-9) && mnt_test_approx(cp[2], 3.0, 1.0e-9))

let cfg = mnt_config(WORLD_SIZE, PARAM_SIZE, 0.1)
check(3, "mnt_config world size > 1",
    cfg.num_nodes == WORLD_SIZE && cfg.num_nodes > 1)

check(4, "mnt_config default topology is ring, sync_every=1",
    cfg.topology == "ring" && cfg.sync_every == 1)

// ═══════════════════════════════════════════════════════════════
//  #5-#7 — Topology discovery + latency
// ═══════════════════════════════════════════════════════════════

check(5, "auto topology 4 nodes -> ring",
    mnt_auto_topology(4) == "ring")

check(6, "auto topology 16 nodes -> tree",
    mnt_auto_topology(16) == "tree")

// Ring latency = 2*(N-1) steps
check(7, "ring_latency_steps(4) = 6",
    mnt_ring_latency_steps(4) == 6)

// Tree latency should be <= ring latency for large N
check(8, "tree_latency_steps(8) <= ring_latency_steps(8)",
    mnt_tree_latency_steps(8) <= mnt_ring_latency_steps(8))

check(9, "tree_latency_steps(16) < ring_latency_steps(16)",
    mnt_tree_latency_steps(16) < mnt_ring_latency_steps(16))

// ═══════════════════════════════════════════════════════════════
//  #10-#13 — Ring AllReduce gradient averaging
// ═══════════════════════════════════════════════════════════════

let ring_avg = mnt_ring_allreduce_avg(grads, WORLD_SIZE)
check(10, "ring allreduce result length = WORLD_SIZE",
    len(ring_avg) == WORLD_SIZE)

check(11, "ring allreduce rank0 matches expected avg",
    mnt_arrays_near(ring_avg[0], expected_avg, 1.0e-6))

// All ranks identical after allreduce (gradient sync barrier)
let mut sync_ok = true
let mut sr = 1
while sr < WORLD_SIZE {
    if !mnt_arrays_near(ring_avg[sr], ring_avg[0], 1.0e-9) {
        sync_ok = false
    }
    sr = sr + 1
}
check(12, "ring allreduce sync barrier: all ranks identical", sync_ok)

// ═══════════════════════════════════════════════════════════════
//  #13-#15 — Chunked ring allreduce matches naive
// ═══════════════════════════════════════════════════════════════

let chunked = mnt_ring_allreduce_chunked(grads, WORLD_SIZE)
check(13, "chunked ring allreduce rank0 matches naive avg",
    mnt_arrays_near(chunked[0], expected_avg, 1.0e-5))

check(14, "chunked ring allreduce rank3 matches naive avg",
    mnt_arrays_near(chunked[3], expected_avg, 1.0e-5))

// Chunked and non-chunked should agree
check(15, "chunked == non-chunked ring allreduce",
    mnt_arrays_near(chunked[0], ring_avg[0], 1.0e-5))

// ═══════════════════════════════════════════════════════════════
//  #16-#18 — Tree AllReduce equivalence
// ═══════════════════════════════════════════════════════════════

let tree_avg = mnt_tree_allreduce_avg(grads, WORLD_SIZE)
check(16, "tree allreduce rank0 matches expected",
    mnt_arrays_near(tree_avg[0], expected_avg, 1.0e-6))

// All ranks after tree allreduce should hold the same averaged gradient
let mut tree_sync_ok = true
let mut tsr = 0
while tsr < WORLD_SIZE {
    if !mnt_arrays_near(tree_avg[tsr], expected_avg, 1.0e-6) {
        tree_sync_ok = false
    }
    tsr = tsr + 1
}
check(17, "tree allreduce sync: all ranks hold averaged grad", tree_sync_ok)

// Ring and tree should agree numerically for the same input
check(18, "ring allreduce == tree allreduce on rank0",
    mnt_arrays_near(ring_avg[0], tree_avg[0], 1.0e-5))

// ═══════════════════════════════════════════════════════════════
//  #19-#21 — Vector helpers used by SGD
// ═══════════════════════════════════════════════════════════════

let va = [1.0, 2.0, 3.0]
let vb = [0.1, 0.2, 0.3]
let vab = mnt_add(va, vb)
check(19, "mnt_add elementwise",
    mnt_test_approx(vab[0], 1.1, 1.0e-9)
    && mnt_test_approx(vab[1], 2.2, 1.0e-9)
    && mnt_test_approx(vab[2], 3.3, 1.0e-9))

let vsub = mnt_sub(va, vb)
check(20, "mnt_sub elementwise",
    mnt_test_approx(vsub[0], 0.9, 1.0e-9))

let vscale = mnt_scale(va, 0.5)
check(21, "mnt_scale by 0.5",
    mnt_test_approx(vscale[0], 0.5, 1.0e-9)
    && mnt_test_approx(vscale[2], 1.5, 1.0e-9))

// ═══════════════════════════════════════════════════════════════
//  #22-#24 — Sync step (allreduce + SGD update)
// ═══════════════════════════════════════════════════════════════

// Per-node parameters: all start at 10.0
let mut params = []
let mut pn = 0
while pn < WORLD_SIZE {
    let mut p = []
    let mut i = 0
    while i < PARAM_SIZE {
        p.push(10.0)
        i = i + 1
    }
    params.push(p)
    pn = pn + 1
}

let new_params = mnt_sync_step(params, grads, cfg)
check(22, "sync step yields one param vector per node",
    len(new_params) == WORLD_SIZE)

// Expected: p - lr * avg_grad = 10 - 0.1*2.5 = 9.75
check(23, "sync step SGD update value",
    mnt_test_approx(new_params[0][0], 9.75, 1.0e-6)
    && mnt_test_approx(new_params[0][PARAM_SIZE - 1], 9.75, 1.0e-6))

// All nodes hold identical params after sync
let mut sync_eq = true
let mut se = 1
while se < WORLD_SIZE {
    if !mnt_arrays_near(new_params[se], new_params[0], 1.0e-9) {
        sync_eq = false
    }
    se = se + 1
}
check(24, "sync step leaves all nodes with equal params", sync_eq)

// ═══════════════════════════════════════════════════════════════
//  #25-#27 — Tree topology sync step
// ═══════════════════════════════════════════════════════════════

let tree_cfg = MntConfig {
    num_nodes: WORLD_SIZE,
    param_size: PARAM_SIZE,
    lr: 0.1,
    sync_every: 1,
    topology: "tree"
}

let tree_step = mnt_sync_step(params, grads, tree_cfg)
check(25, "tree sync step matches ring sync step",
    mnt_arrays_near(tree_step[0], new_params[0], 1.0e-5))

check(26, "tree sync step all nodes identical",
    mnt_arrays_near(tree_step[0], tree_step[3], 1.0e-9))

// ═══════════════════════════════════════════════════════════════
//  #27-#30 — Async local SGD with periodic sync
// ═══════════════════════════════════════════════════════════════

let initial = [1.0, 1.0, 1.0, 1.0]
let async_cfg = mnt_config_async(WORLD_SIZE, 4, 0.1, 3)  // sync every 3 steps
let state0 = mnt_async_init(initial, WORLD_SIZE)
check(27, "async_init: all nodes hold copy of initial params",
    len(state0.params) == WORLD_SIZE
    && state0.step_count == 0
    && state0.sync_count == 0)

// Per-node local gradients (varied per node so params diverge on non-sync)
let local_grads = [
    [0.1, 0.1, 0.1, 0.1],
    [0.2, 0.2, 0.2, 0.2],
    [0.3, 0.3, 0.3, 0.3],
    [0.4, 0.4, 0.4, 0.4]
]

// Step 1: no sync (1 % 3 != 0) — params diverge
let state1 = mnt_async_step(state0, local_grads, async_cfg)
check(28, "async step 1: step_count incremented, no sync",
    state1.step_count == 1 && state1.sync_count == 0)

// Nodes should be different after local step (since grads differ)
let diverged = !mnt_arrays_near(state1.params[0], state1.params[3], 1.0e-6)
check(29, "async step 1: nodes diverged under different local grads", diverged)

// Step 3 triggers sync (3 % 3 == 0)
let state2 = mnt_async_step(state1, local_grads, async_cfg)
let state3 = mnt_async_step(state2, local_grads, async_cfg)
check(30, "async step 3 triggers sync barrier",
    state3.sync_count == 1
    && mnt_arrays_near(state3.params[0], state3.params[3], 1.0e-9))

// ── summary ─────────────────────────────────────────────────────
println("")
println("=== Multi-Node Training test summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
