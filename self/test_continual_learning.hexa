// ===================================================================
//  test_continual_learning.hexa — Continual Learning tests
//
//  Tests:
//    1.  create_ewc state structure
//    2.  ewc_loss at star weights = 0
//    3.  ewc_loss increases with drift
//    4.  update_fisher
//    5.  create_si
//    6.  si_loss at initial = 0
//    7.  si_pre_update + si_post_update
//    8.  create_replay_buffer
//    9.  replay_add + replay_sample
//   10.  replay buffer circular overwrite
//   11.  detect_boundary spike
//   12.  detect_boundary no spike
//   13.  detect_boundary_window
//   14.  continual_train_step
//
//  Run: hexa self/test_continual_learning.hexa
// ===================================================================
import "ml/continual_learning.hexa"

let mut pass = 0
let mut fail = 0

fn check(name, cond) {
    if cond {
        pass = pass + 1
        println("[PASS] " + name)
    } else {
        fail = fail + 1
        println("[FAIL] " + name)
    }
}

fn abs_f(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

// ── 1. create_ewc ───────────────────────────────────────────────
let weights1 = [1.0, 2.0, 3.0, 4.0]
let fisher1 = [0.5, 1.0, 0.3, 0.8]
let ewc1 = create_ewc(weights1, fisher1, 10.0)
check("create_ewc has star_weights", len(ewc1["star_weights"]) == 4)
check("create_ewc has fisher", len(ewc1["fisher"]) == 4)
check("create_ewc lambda", ewc1["lambda"] == 10.0)

// ── 2. ewc_loss at star weights = 0 ─────────────────────────────
let loss_at_star = ewc_loss(weights1, ewc1)
check("ewc_loss at star = 0", abs_f(loss_at_star) < 0.0001)

// ── 3. ewc_loss increases with drift ────────────────────────────
let drifted = [2.0, 3.0, 4.0, 5.0]
let loss_drifted = ewc_loss(drifted, ewc1)
check("ewc_loss drifted > 0", loss_drifted > 0.0)
// expected: 10/2 * (0.5*1 + 1.0*1 + 0.3*1 + 0.8*1) = 5 * 2.6 = 13.0
check("ewc_loss drifted value", abs_f(loss_drifted - 13.0) < 0.01)

// bigger drift = bigger loss
let big_drift = [5.0, 6.0, 7.0, 8.0]
let loss_big = ewc_loss(big_drift, ewc1)
check("ewc_loss bigger drift > small drift", loss_big > loss_drifted)

// ── 4. update_fisher ────────────────────────────────────────────
let grads1 = [1.0, 0.5, 0.2, 0.8]
let ewc2 = update_fisher(ewc1, grads1, 0.9)
let new_fisher = ewc2["fisher"]
// F_new = 0.9 * F_old + 0.1 * grad^2
// F[0] = 0.9 * 0.5 + 0.1 * 1.0 = 0.55
check("update_fisher value", abs_f(new_fisher[0] - 0.55) < 0.01)

// ── 5. create_si ────────────────────────────────────────────────
let si1 = create_si(weights1, 0.1)
check("create_si has omega", len(si1["omega"]) == 4)
check("create_si omega init 0", abs_f(si1["omega"][0]) < 0.0001)
check("create_si xi", si1["xi"] == 0.1)

// ── 6. si_loss at initial = 0 ───────────────────────────────────
let si_loss1 = si_loss(weights1, si1)
check("si_loss at initial = 0", abs_f(si_loss1) < 0.0001)

// ── 7. si_pre_update + si_post_update ───────────────────────────
let si2 = si_pre_update(si1, [0.5, 0.3, 0.1, 0.2])
let new_weights = [1.5, 2.3, 3.1, 4.2]
let si3 = si_post_update(si2, new_weights)
// after update, omega should be non-zero for params that changed
let omega_sum = si3["omega"][0] + si3["omega"][1] + si3["omega"][2] + si3["omega"][3]
check("si_post_update omega accumulated", omega_sum >= 0.0)

// ── 8. create_replay_buffer ─────────────────────────────────────
let buf1 = create_replay_buffer(5)
check("replay_buffer capacity", buf1["capacity"] == 5)
check("replay_buffer empty", buf1["size"] == 0)

// ── 9. replay_add + replay_sample ───────────────────────────────
let mut buf2 = create_replay_buffer(5)
buf2 = replay_add(buf2, "sample_a")
buf2 = replay_add(buf2, "sample_b")
buf2 = replay_add(buf2, "sample_c")
check("replay_add size", buf2["size"] == 3)

let samples = replay_sample(buf2, 2)
check("replay_sample count", len(samples) == 2)
check("replay_sample first", samples[0] == "sample_a")

// ── 10. replay buffer circular overwrite ────────────────────────
let mut buf3 = create_replay_buffer(3)
buf3 = replay_add(buf3, "a")
buf3 = replay_add(buf3, "b")
buf3 = replay_add(buf3, "c")
buf3 = replay_add(buf3, "d")
check("replay circular size stays at cap", buf3["size"] == 3)
let all_samples = replay_sample(buf3, 3)
check("replay circular has new item", all_samples[0] == "d")

// ── 11. detect_boundary spike ───────────────────────────────────
let loss_hist1 = [1.0, 1.1, 1.0, 0.9, 0.8, 5.0, 4.5, 4.0]
let boundary1 = detect_boundary(loss_hist1, 2.0)
check("detect_boundary found spike", boundary1 == 5)

// ── 12. detect_boundary no spike ────────────────────────────────
let loss_hist2 = [1.0, 1.1, 1.0, 0.9, 0.95, 1.05]
let boundary2 = detect_boundary(loss_hist2, 2.0)
check("detect_boundary no spike = -1", boundary2 == 0 - 1)

// ── 13. detect_boundary_window ──────────────────────────────────
let loss_hist3 = [1.0, 1.0, 1.0, 1.0, 5.0, 5.0, 5.0, 5.0]
let boundary3 = detect_boundary_window(loss_hist3, 2, 2.0)
check("detect_boundary_window found", boundary3 > 0)

// ── 14. continual_train_step ────────────────────────────────────
let mut ct_weights = [1.0, 2.0, 3.0]
let ct_grads = [0.1, 0.2, 0.3]
let ct_fisher = [1.0, 1.0, 1.0]
let ct_ewc = create_ewc([1.0, 2.0, 3.0], ct_fisher, 0.1)
let ct_buf = create_replay_buffer(10)
let updated = continual_train_step(ct_weights, ct_grads, ct_ewc, ct_buf, 0.01)
// weights should change
let ct_diff = abs_f(updated[0] - 1.0)
check("continual_train_step updates weights", ct_diff > 0.0001)

// ── Summary ─────────────────────────────────────────────────────
println("")
println("========================================")
println("  continual_learning tests: " + str(pass) + " passed, " + str(fail) + " failed")
println("========================================")
