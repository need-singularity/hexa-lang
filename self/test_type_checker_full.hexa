// ═══════════════════════════════════════════════════════════
//  test_type_checker_full.hexa — Mega Type Checker Test Suite
//  200+ tests covering the full HEXA type system:
//    1. Primitive types (int, float, string, bool)
//    2. Type inference (let x = expr)
//    3. Type conversions (to_int, to_float, to_string)
//    4. Collections (Array, Map, Tuple, Tensor)
//    5. Struct / Enum types
//    6. Function types (fn, lambda)
//    7. Generic patterns
//    8. type_of() builtin
//    9. Type compatibility (int->float coercion)
//   10. Error types (try/catch/throw)
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_true(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA Mega Type Checker Test Suite")
println("═══════════════════════════════════════════════════════")

// ═══════════════════════════════════════════════════════════
//  1. PRIMITIVE TYPES — type_of for all basic types
// ═══════════════════════════════════════════════════════════

println("")
println("--- 1. Primitive Types ---")

check("T1.01 type_of int literal", type_of(42), "int")
check("T1.02 type_of zero", type_of(0), "int")
check("T1.03 type_of neg int", type_of(-5), "int")
check("T1.04 type_of large int", type_of(999999999), "int")
check("T1.05 type_of float", type_of(3.14), "float")
check("T1.06 type_of float zero", type_of(0.0), "float")
check("T1.07 type_of neg float", type_of(-2.5), "float")
check("T1.08 type_of string", type_of("hello"), "string")
check("T1.09 type_of empty string", type_of(""), "string")
check("T1.10 type_of bool true", type_of(true), "bool")
check("T1.11 type_of bool false", type_of(false), "bool")
check("T1.12 type_of array", type_of([1, 2, 3]), "array")
check("T1.13 type_of empty array", type_of([]), "array")
check("T1.14 type_of map", type_of(#{}), "map")
check("T1.15 type_of map with data", type_of(#{"a": 1}), "map")
check("T1.16 type_of tuple", type_of((1, 2)), "tuple")
check("T1.17 type_of bigint", type_of(bigint("42")), "bigint")

// ═══════════════════════════════════════════════════════════
//  2. TYPE INFERENCE — let bindings infer correct types
// ═══════════════════════════════════════════════════════════

println("")
println("--- 2. Type Inference ---")

let inf_int = 100
check("T2.01 infer int", type_of(inf_int), "int")

let inf_float = 3.14
check("T2.02 infer float", type_of(inf_float), "float")

let inf_str = "world"
check("T2.03 infer string", type_of(inf_str), "string")

let inf_bool = true
check("T2.04 infer bool", type_of(inf_bool), "bool")

let inf_arr = [10, 20, 30]
check("T2.05 infer array", type_of(inf_arr), "array")

let inf_map = #{"key": "val"}
check("T2.06 infer map", type_of(inf_map), "map")

let inf_tuple = (1, "two", true)
check("T2.07 infer tuple", type_of(inf_tuple), "tuple")

// inferred from expression
let inf_add = 3 + 4
check("T2.08 infer int expr", type_of(inf_add), "int")

let inf_fadd = 1.5 + 2.5
check("T2.09 infer float expr", type_of(inf_fadd), "float")

let inf_concat = "a" + "b"
check("T2.10 infer string concat", type_of(inf_concat), "string")

let inf_cmp = 5 > 3
check("T2.11 infer bool from cmp", type_of(inf_cmp), "bool")

let inf_and = true && false
check("T2.12 infer bool from logical", type_of(inf_and), "bool")

let inf_mixed = 3 + 2.5
check("T2.13 infer float from mixed", type_of(inf_mixed), "float")

// mut inference
let mut m_int = 0
m_int = 42
check("T2.14 mut infer int", type_of(m_int), "int")

let mut m_str = ""
m_str = "hello"
check("T2.15 mut infer string", type_of(m_str), "string")

let mut m_bool = false
m_bool = true
check("T2.16 mut infer bool", type_of(m_bool), "bool")

// ═══════════════════════════════════════════════════════════
//  3. TYPE CONVERSIONS — to_int, to_float, to_string
// ═══════════════════════════════════════════════════════════

println("")
println("--- 3. Type Conversions ---")

// to_string
check("T3.01 to_string int", to_string(42), "42")
check("T3.02 to_string neg", to_string(-7), "-7")
check("T3.03 to_string zero", to_string(0), "0")
check("T3.04 to_string float", to_string(3.14), "3.14")
check("T3.05 to_string bool true", to_string(true), "true")
check("T3.06 to_string bool false", to_string(false), "false")
check("T3.07 to_string string passthru", to_string("hello"), "hello")
check("T3.08 to_string array", to_string([1, 2, 3]), "[1, 2, 3]")
check("T3.09 to_string large", to_string(1000000), "1000000")
check("T3.10 to_string empty str", to_string(""), "")

// to_int
check("T3.11 to_int from str", to_int("123"), 123)
check("T3.12 to_int neg str", to_int("-42"), -42)
check("T3.13 to_int zero str", to_int("0"), 0)
check("T3.14 to_int from float", to_int(3.99), 3)
check("T3.15 to_int neg float", to_int(-2.7), -2)
check("T3.16 to_int float zero", to_int(0.0), 0)
check("T3.17 to_int result type", type_of(to_int("5")), "int")

// to_float
check("T3.18 to_float from int", to_float(42), 42.0)
check("T3.19 to_float from str", to_float("3.14"), 3.14)
check("T3.20 to_float neg str", to_float("-2.5"), -2.5)
check("T3.21 to_float from zero", to_float(0), 0.0)
check("T3.22 to_float result type", type_of(to_float(42)), "float")
check("T3.23 to_float int str", to_float("100"), 100.0)

// round-trip conversions
check("T3.24 int->str->int", to_int(to_string(42)), 42)
check("T3.25 str->int->str", to_string(to_int("777")), "777")
check("T3.26 neg roundtrip", to_int(to_string(-99)), -99)

// invalid conversion errors
let mut caught_bad_int = false
try {
    let x = to_int("abc")
} catch e {
    caught_bad_int = true
}
check("T3.27 to_int invalid throws", caught_bad_int, true)

let mut caught_bad_float = false
try {
    let x = to_float("xyz")
} catch e {
    caught_bad_float = true
}
check("T3.28 to_float invalid throws", caught_bad_float, true)

// ═══════════════════════════════════════════════════════════
//  4. COLLECTION TYPES — Array, Map, Tuple, Tensor
// ═══════════════════════════════════════════════════════════

println("")
println("--- 4. Collection Types ---")

// Array
let arr_int = [1, 2, 3, 4, 5]
check("T4.01 int array type", type_of(arr_int), "array")
check("T4.02 int arr elem type", type_of(arr_int[0]), "int")
check("T4.03 int arr len", len(arr_int), 5)

let arr_str = ["a", "b", "c"]
check("T4.04 str arr type", type_of(arr_str), "array")
check("T4.05 str arr elem type", type_of(arr_str[0]), "string")
check("T4.06 str arr len", len(arr_str), 3)

let arr_float = [1.0, 2.5, 3.14]
check("T4.07 float arr type", type_of(arr_float), "array")
check("T4.08 float arr elem type", type_of(arr_float[0]), "float")

let arr_bool = [true, false, true]
check("T4.09 bool arr type", type_of(arr_bool), "array")
check("T4.10 bool arr elem type", type_of(arr_bool[0]), "bool")

let nested_arr = [[1, 2], [3, 4]]
check("T4.11 nested arr type", type_of(nested_arr), "array")
check("T4.12 nested inner type", type_of(nested_arr[0]), "array")
check("T4.13 nested elem type", type_of(nested_arr[0][0]), "int")

let empty_arr = []
check("T4.14 empty arr type", type_of(empty_arr), "array")
check("T4.15 empty arr len", len(empty_arr), 0)

// Map
let m1 = #{"x": 10, "y": 20}
check("T4.16 map type", type_of(m1), "map")
check("T4.17 map access", m1["x"], 10)
check("T4.18 map len", len(m1), 2)
check("T4.19 map elem type int", type_of(m1["x"]), "int")

let m2 = #{"a": 1, "b": "two", "c": true, "d": 3.14}
check("T4.20 map mixed len", len(m2), 4)
check("T4.21 map str val type", type_of(m2["b"]), "string")
check("T4.22 map bool val type", type_of(m2["c"]), "bool")
check("T4.23 map float val type", type_of(m2["d"]), "float")

let m_keys = m1.keys()
check("T4.24 map keys type", type_of(m_keys), "array")
check("T4.25 map keys len", len(m_keys), 2)

let m_vals = m1.values()
check("T4.26 map vals type", type_of(m_vals), "array")
check("T4.27 map vals len", len(m_vals), 2)

check("T4.28 contains_key true", m1.contains_key("x"), true)
check("T4.29 contains_key false", m1.contains_key("z"), false)

let empty_map = #{}
check("T4.30 empty map type", type_of(empty_map), "map")
check("T4.31 empty map len", len(empty_map), 0)

// Tuple
let t1 = (1, "hello", true)
check("T4.32 tuple type", type_of(t1), "tuple")
check("T4.33 tuple[0] type", type_of(t1[0]), "int")
check("T4.34 tuple[1] type", type_of(t1[1]), "string")
check("T4.35 tuple[2] type", type_of(t1[2]), "bool")
check("T4.36 tuple[0] val", t1[0], 1)
check("T4.37 tuple[1] val", t1[1], "hello")
check("T4.38 tuple[2] val", t1[2], true)

let t2 = (3.14, [1, 2])
check("T4.39 tuple float elem", type_of(t2[0]), "float")
check("T4.40 tuple arr elem", type_of(t2[1]), "array")

// Tensor
let tens = tensor([1.0, 2.0, 3.0])
check("T4.41 tensor type", type_of(tens), "tensor")
check("T4.42 tensor len", len(tens), 3)

let tz = tensor_zeros(4)
check("T4.43 tensor_zeros type", type_of(tz), "tensor")
check("T4.44 tensor_zeros len", len(tz), 4)

// ═══════════════════════════════════════════════════════════
//  5. STRUCT / ENUM TYPES
// ═══════════════════════════════════════════════════════════

println("")
println("--- 5. Struct & Enum Types ---")

struct Point {
    x: int,
    y: int
}

let p = Point { x: 3, y: 4 }
check("T5.01 struct type", type_of(p), "Point")
check("T5.02 struct field x", p.x, 3)
check("T5.03 struct field y", p.y, 4)
check("T5.04 field x type", type_of(p.x), "int")
check("T5.05 field y type", type_of(p.y), "int")

struct Person {
    name: string,
    age: int,
    active: bool
}

let alice = Person { name: "Alice", age: 30, active: true }
check("T5.06 person type", type_of(alice), "Person")
check("T5.07 person.name", alice.name, "Alice")
check("T5.08 person.name type", type_of(alice.name), "string")
check("T5.09 person.age type", type_of(alice.age), "int")
check("T5.10 person.active type", type_of(alice.active), "bool")

struct Config {
    ratio: float,
    label: string
}

let cfg = Config { ratio: 0.5, label: "test" }
check("T5.11 config type", type_of(cfg), "Config")
check("T5.12 float field type", type_of(cfg.ratio), "float")

// Impl methods
impl Point {
    fn magnitude_sq(self) {
        return self.x * self.x + self.y * self.y
    }
    fn to_str(self) {
        return "(" + to_string(self.x) + "," + to_string(self.y) + ")"
    }
}

check("T5.13 impl method call", p.magnitude_sq(), 25)
check("T5.14 impl method str", p.to_str(), "(3,4)")
check("T5.15 method result type", type_of(p.magnitude_sq()), "int")
check("T5.16 method str type", type_of(p.to_str()), "string")

// Enum
enum Color { Red, Green, Blue }

let c = Color::Red
check("T5.17 enum type", type_of(c), "Color")

let c2 = Color::Blue
check("T5.18 enum variant", to_string(c2), "Color::Blue")

// Enum with data
enum Shape {
    Circle(Int),
    Square(Int)
}

let s1 = Shape::Circle(5)
check("T5.19 enum data type", type_of(s1), "Shape")
check("T5.20 enum data str", to_string(s1), "Shape::Circle(5)")

let s2 = Shape::Square(4)
check("T5.21 enum data sq", to_string(s2), "Shape::Square(4)")

// Match on enum
let area = match s1 {
    Shape::Circle(r) -> r * r * 3,
    Shape::Square(s) -> s * s
}
check("T5.22 enum match", area, 75)

let area2 = match s2 {
    Shape::Circle(r) -> r * r * 3,
    Shape::Square(s) -> s * s
}
check("T5.23 enum match sq", area2, 16)

// Enum in function
fn shape_name(s) {
    return match s {
        Shape::Circle(_) -> "circle",
        Shape::Square(_) -> "square"
    }
}
check("T5.24 enum fn match", shape_name(s1), "circle")
check("T5.25 enum fn match 2", shape_name(s2), "square")

// ═══════════════════════════════════════════════════════════
//  6. FUNCTION TYPES
// ═══════════════════════════════════════════════════════════

println("")
println("--- 6. Function Types ---")

fn add(a, b) { return a + b }
fn mul(a, b) { return a * b }

check("T6.01 fn type", type_of(add), "fn")
check("T6.02 fn type 2", type_of(mul), "fn")

// lambda
let double = |x| x * 2
check("T6.03 lambda type", type_of(double), "lambda")
check("T6.04 lambda call", double(5), 10)
check("T6.05 lambda result type", type_of(double(5)), "int")

let greet = |name| "Hello, " + name
check("T6.06 lambda str type", type_of(greet), "lambda")
check("T6.07 lambda str result", greet("Bob"), "Hello, Bob")
check("T6.08 lambda str res type", type_of(greet("Bob")), "string")

// Return type preservation
fn identity(x) { return x }
check("T6.09 identity int", type_of(identity(42)), "int")
check("T6.10 identity float", type_of(identity(3.14)), "float")
check("T6.11 identity string", type_of(identity("hi")), "string")
check("T6.12 identity bool", type_of(identity(true)), "bool")
check("T6.13 identity array", type_of(identity([1])), "array")

// fn returning different types
fn type_tag(x) {
    return type_of(x)
}
check("T6.14 type_tag int", type_tag(1), "int")
check("T6.15 type_tag str", type_tag("x"), "string")
check("T6.16 type_tag bool", type_tag(false), "bool")

// Higher-order function
fn apply(f, x) { return f(x) }
check("T6.17 hof apply double", apply(double, 3), 6)
check("T6.18 hof result type", type_of(apply(double, 3)), "int")

fn compose(f, g, x) { return f(g(x)) }
let inc = |x| x + 1
check("T6.19 compose result", compose(double, inc, 4), 10)
check("T6.20 compose type", type_of(compose(double, inc, 4)), "int")

// ═══════════════════════════════════════════════════════════
//  7. GENERIC PATTERNS
// ═══════════════════════════════════════════════════════════

println("")
println("--- 7. Generic Patterns ---")

// Generic-like struct (using dynamic typing)
struct Box {
    value: string
}

fn make_box(v) {
    return Box { value: to_string(v) }
}

let b1 = make_box(42)
check("T7.01 box int", b1.value, "42")
check("T7.02 box type", type_of(b1), "Box")

let b2 = make_box("hello")
check("T7.03 box str", b2.value, "hello")

let b3 = make_box(true)
check("T7.04 box bool", b3.value, "true")

// Pair struct
struct Pair {
    first: string,
    second: string
}

fn make_pair(a, b) {
    return Pair { first: to_string(a), second: to_string(b) }
}

let pair1 = make_pair(1, "x")
check("T7.05 pair first", pair1.first, "1")
check("T7.06 pair second", pair1.second, "x")
check("T7.07 pair type", type_of(pair1), "Pair")

// Generic-like function: works on any type
fn swap_pair(p) {
    return Pair { first: p.second, second: p.first }
}

let swapped = swap_pair(pair1)
check("T7.08 swap first", swapped.first, "x")
check("T7.09 swap second", swapped.second, "1")

// Type-tag pattern
struct Tagged {
    tag: string,
    val: string
}

fn tag_value(v) {
    return Tagged { tag: type_of(v), val: to_string(v) }
}

let tv1 = tag_value(42)
check("T7.10 tagged int tag", tv1.tag, "int")
check("T7.11 tagged int val", tv1.val, "42")

let tv2 = tag_value(3.14)
check("T7.12 tagged float tag", tv2.tag, "float")

let tv3 = tag_value("hi")
check("T7.13 tagged str tag", tv3.tag, "string")

let tv4 = tag_value(true)
check("T7.14 tagged bool tag", tv4.tag, "bool")

// Array of structs — uniform type
let points = [Point { x: 0, y: 0 }, Point { x: 1, y: 1 }]
check("T7.15 struct arr type", type_of(points), "array")
check("T7.16 struct arr elem type", type_of(points[0]), "Point")
check("T7.17 struct arr field", points[1].x, 1)

// ═══════════════════════════════════════════════════════════
//  8. type_of() BUILTIN COMPREHENSIVE
// ═══════════════════════════════════════════════════════════

println("")
println("--- 8. type_of Comprehensive ---")

// Computed expressions
check("T8.01 type_of int+int", type_of(3 + 4), "int")
check("T8.02 type_of int*int", type_of(6 * 7), "int")
check("T8.03 type_of float+float", type_of(1.5 + 2.5), "float")
check("T8.04 type_of int+float", type_of(3 + 2.5), "float")
check("T8.05 type_of float+int", type_of(2.0 + 3), "float")
check("T8.06 type_of str+str", type_of("a" + "b"), "string")
check("T8.07 type_of comparison", type_of(3 > 2), "bool")
check("T8.08 type_of logical and", type_of(true && false), "bool")
check("T8.09 type_of logical or", type_of(true || false), "bool")
check("T8.10 type_of not", type_of(!true), "bool")

// type_of on function results
check("T8.11 type_of fn result", type_of(add(1, 2)), "int")
check("T8.12 type_of fn float", type_of(add(1.0, 2.0)), "float")
check("T8.13 type_of fn str", type_of(add("a", "b")), "string")

// type_of on collection operations
let test_arr = [10, 20, 30]
check("T8.14 type_of arr[0]", type_of(test_arr[0]), "int")

let test_map = #{"k": "v"}
check("T8.15 type_of map val", type_of(test_map["k"]), "string")

// type_of returns string
check("T8.16 type_of returns string", type_of(type_of(42)), "string")

// ═══════════════════════════════════════════════════════════
//  9. TYPE COMPATIBILITY — int->float auto-coercion
// ═══════════════════════════════════════════════════════════

println("")
println("--- 9. Type Compatibility ---")

// int + float -> float
check("T9.01 int+float value", 3 + 2.5, 5.5)
check("T9.02 int+float type", type_of(3 + 2.5), "float")
check("T9.03 float+int value", 2.0 + 3, 5.0)
check("T9.04 float+int type", type_of(2.0 + 3), "float")

// int * float -> float
check("T9.05 int*float value", 10 * 2.0, 20.0)
check("T9.06 int*float type", type_of(10 * 2.0), "float")
check("T9.07 float*int value", 3.5 * 2, 7.0)
check("T9.08 float*int type", type_of(3.5 * 2), "float")

// int - float -> float
check("T9.09 int-float value", 10 - 2.5, 7.5)
check("T9.10 int-float type", type_of(10 - 2.5), "float")
check("T9.11 float-int value", 10.0 - 3, 7.0)
check("T9.12 float-int type", type_of(10.0 - 3), "float")

// int / float -> float
check("T9.13 int/float value", 7 / 2.0, 3.5)
check("T9.14 int/float type", type_of(7 / 2.0), "float")
check("T9.15 float/int value", 9.0 / 2, 4.5)
check("T9.16 float/int type", type_of(9.0 / 2), "float")

// int / int -> int (truncating)
check("T9.17 int div exact", 10 / 2, 5)
check("T9.18 int div truncate", 7 / 2, 3)
check("T9.19 int div type", type_of(10 / 2), "int")

// int comparison
check("T9.20 int comparison type", type_of(5 > 3), "bool")
check("T9.21 float comparison type", type_of(3.14 > 2.0), "bool")
check("T9.22 int eq type", type_of(5 == 5), "bool")

// string concat always string
check("T9.23 str concat type", type_of("hello" + " world"), "string")
check("T9.24 str + to_string", "val=" + to_string(42), "val=42")

// ═══════════════════════════════════════════════════════════
// 10. ERROR TYPES — try/catch/throw
// ═══════════════════════════════════════════════════════════

println("")
println("--- 10. Error Types ---")

// Caught error has type "error"
let mut err_t = ""
try {
    throw "test error"
} catch e {
    err_t = type_of(e)
}
check("T10.01 error type", err_t, "error")

// Error message preserved
let mut err_msg = ""
try {
    throw "my message"
} catch e {
    err_msg = to_string(e)
}
check("T10.02 error msg", err_msg, "Error(my message)")

// Division by zero error
let mut div_err = false
try {
    let x = 10 / 0
} catch e {
    div_err = true
}
check("T10.03 div zero caught", div_err, true)

// Mod by zero error
let mut mod_err = false
try {
    let x = 10 % 0
} catch e {
    mod_err = true
}
check("T10.04 mod zero caught", mod_err, true)

// Function throw
fn must_positive(n) {
    if n < 0 {
        throw "negative"
    }
    return n
}

let mut pos_ok = 0
try {
    pos_ok = must_positive(5)
} catch e {
    pos_ok = -1
}
check("T10.05 fn no throw", pos_ok, 5)

let mut neg_caught = false
try {
    let x = must_positive(-3)
} catch e {
    neg_caught = true
}
check("T10.06 fn throws", neg_caught, true)

// Nested try/catch
let mut outer = 0
try {
    try {
        throw "inner"
    } catch e {
        outer = 1
    }
    outer = outer + 10
} catch e {
    outer = -1
}
check("T10.07 nested try", outer, 11)

// Error in loop
let mut loop_err_count = 0
let mut i = 0
while i < 5 {
    try {
        if i == 2 {
            throw "skip"
        }
    } catch e {
        loop_err_count = loop_err_count + 1
    }
    i = i + 1
}
check("T10.08 error in loop", loop_err_count, 1)

// ═══════════════════════════════════════════════════════════
// 11. ADDITIONAL: BigInt types
// ═══════════════════════════════════════════════════════════

println("")
println("--- 11. BigInt Types ---")

let big1 = bigint("123456789012345678901234567890")
check("T11.01 bigint type", type_of(big1), "bigint")
check("T11.02 bigint to_string", to_string(big1), "123456789012345678901234567890")

let big2 = bigint("10") + bigint("20")
check("T11.03 bigint add", to_string(big2), "30")
check("T11.04 bigint add type", type_of(big2), "bigint")

let big3 = bigint("100") - bigint("30")
check("T11.05 bigint sub", to_string(big3), "70")

let big4 = bigint("10") * bigint("20")
check("T11.06 bigint mul", to_string(big4), "200")

check("T11.07 bigint gt", bigint("100") > bigint("50"), true)
check("T11.08 bigint eq", bigint("42") == bigint("42"), true)
check("T11.09 bigint neq", bigint("42") != bigint("43"), true)

// ═══════════════════════════════════════════════════════════
// 12. ADDITIONAL: Boolean logic & truthiness
// ═══════════════════════════════════════════════════════════

println("")
println("--- 12. Boolean Logic ---")

check("T12.01 true", true, true)
check("T12.02 false", false, false)
check("T12.03 not true", !true, false)
check("T12.04 not false", !false, true)
check("T12.05 double not", !!true, true)
check("T12.06 and TT", true && true, true)
check("T12.07 and TF", true && false, false)
check("T12.08 and FT", false && true, false)
check("T12.09 and FF", false && false, false)
check("T12.10 or TT", true || true, true)
check("T12.11 or TF", true || false, true)
check("T12.12 or FT", false || true, true)
check("T12.13 or FF", false || false, false)
check("T12.14 complex bool", (true && false) || (true && true), true)
check("T12.15 bool type after and", type_of(true && false), "bool")

// ═══════════════════════════════════════════════════════════
// 13. ADDITIONAL: String type operations
// ═══════════════════════════════════════════════════════════

println("")
println("--- 13. String Operations ---")

check("T13.01 empty str len", len(""), 0)
check("T13.02 str len", len("hello"), 5)
check("T13.03 str equality", "abc" == "abc", true)
check("T13.04 str inequality", "abc" != "xyz", true)
check("T13.05 str concat", "hello" + " " + "world", "hello world")
check("T13.06 concat empty", "" + "hi", "hi")
check("T13.07 concat to empty", "hi" + "", "hi")
check("T13.08 str type after concat", type_of("a" + "b"), "string")

// ═══════════════════════════════════════════════════════════
// 14. ADDITIONAL: Struct field arithmetic & method types
// ═══════════════════════════════════════════════════════════

println("")
println("--- 14. Struct Field Arithmetic ---")

check("T14.01 field add", p.x + p.y, 7)
check("T14.02 field mul", p.x * p.y, 12)
check("T14.03 field cmp", p.x < p.y, true)
check("T14.04 field add type", type_of(p.x + p.y), "int")

struct FloatPair {
    a: float,
    b: float
}

let fp = FloatPair { a: 1.5, b: 2.5 }
check("T14.05 float field add", fp.a + fp.b, 4.0)
check("T14.06 float field type", type_of(fp.a + fp.b), "float")

// ═══════════════════════════════════════════════════════════
// 15. ADDITIONAL: Match expression types
// ═══════════════════════════════════════════════════════════

println("")
println("--- 15. Match Expression Types ---")

let mr1 = match 2 {
    1 -> "one",
    2 -> "two",
    _ -> "other"
}
check("T15.01 match int", mr1, "two")
check("T15.02 match result type", type_of(mr1), "string")

let mr2 = match "ko" {
    "en" -> 1,
    "ko" -> 2,
    _ -> 0
}
check("T15.03 match str", mr2, 2)
check("T15.04 match int result type", type_of(mr2), "int")

let mr3 = match true {
    true -> 3.14,
    false -> 0.0
}
check("T15.05 match bool", mr3, 3.14)
check("T15.06 match float result", type_of(mr3), "float")

// ═══════════════════════════════════════════════════════════
// 16. ADDITIONAL: Closure capture types
// ═══════════════════════════════════════════════════════════

println("")
println("--- 16. Closure Capture ---")

let outer_int = 10
let cl1 = |x| x + outer_int
check("T16.01 closure capture int", cl1(5), 15)
check("T16.02 closure result type", type_of(cl1(5)), "int")

let outer_str = "Hello"
let cl2 = |x| outer_str + " " + x
check("T16.03 closure capture str", cl2("World"), "Hello World")
check("T16.04 closure str type", type_of(cl2("World")), "string")

// ═══════════════════════════════════════════════════════════
// 17. ADDITIONAL: Enum Result/Option pattern
// ═══════════════════════════════════════════════════════════

println("")
println("--- 17. Result/Option Pattern ---")

enum Result { Ok(val), Err(msg) }
enum Option { Some(val), None }

let r_ok = Result::Ok(42)
let r_err = Result::Err("fail")
check("T17.01 result ok type", type_of(r_ok), "Result")
check("T17.02 result err type", type_of(r_err), "Result")

let extracted = match r_ok {
    Result::Ok(v) -> v,
    Result::Err(_) -> -1
}
check("T17.03 unwrap ok", extracted, 42)
check("T17.04 unwrap type", type_of(extracted), "int")

let err_val = match r_err {
    Result::Ok(_) -> "ok",
    Result::Err(m) -> m
}
check("T17.05 unwrap err", err_val, "fail")

let opt_some = Option::Some("data")
let opt_none = Option::None
check("T17.06 option some type", type_of(opt_some), "Option")
check("T17.07 option none type", type_of(opt_none), "Option")

let opt_val = match opt_some {
    Option::Some(v) -> v,
    Option::None -> "default"
}
check("T17.08 option unwrap", opt_val, "data")

let none_val = match opt_none {
    Option::Some(_) -> "has",
    Option::None -> "empty"
}
check("T17.09 option none", none_val, "empty")

// ═══════════════════════════════════════════════════════════
// 18. ADDITIONAL: Type in control flow
// ═══════════════════════════════════════════════════════════

println("")
println("--- 18. Type in Control Flow ---")

let mut cf_type = ""
if true {
    cf_type = type_of(42)
} else {
    cf_type = type_of("x")
}
check("T18.01 type in if branch", cf_type, "int")

let mut cf_arr = []
let mut j = 0
while j < 3 {
    cf_arr.push(j * 2)
    j = j + 1
}
check("T18.02 loop build arr", len(cf_arr), 3)
check("T18.03 loop arr type", type_of(cf_arr), "array")
check("T18.04 loop arr elem", cf_arr[0], 0)
check("T18.05 loop arr elem2", cf_arr[2], 4)

// for loop type preservation
let mut for_sum = 0
for item in [10, 20, 30] {
    for_sum = for_sum + item
}
check("T18.06 for loop sum", for_sum, 60)
check("T18.07 for sum type", type_of(for_sum), "int")

