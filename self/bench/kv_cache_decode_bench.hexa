// ═══════════════════════════════════════════════════════════════════
//  self/bench/kv_cache_decode_bench.hexa — ROI #164
//
//  KV-cache continuous-decode tok/s benchmark.
//
//  Why this exists (SSOT = memory/feedback_kvcache_serving_number.md):
//    Single-forward-pass tok/s OVERSTATES real serving throughput.
//    Real deployments decode autoregressively with a KV cache — every
//    new token reuses all previous K/V slots. This bench measures that
//    path end-to-end.
//
//  Why the unit is pinned (SSOT = memory/feedback_bench_unit_check.md):
//    1 forward step = 1 generated token (decode phase).
//    Prefill cost is bucketed separately into ttft_ms / prefill_ms.
//    tok_s here = n_generated / (decode_ms / 1000).
//
//  Model:
//    Self-contained tiny GPT-like transformer (no external weight files).
//    Random deterministic init (seed-driven LCG) so every run is
//    reproducible. Shape is a CLI knob; defaults target a quick smoke
//    (dim=64, n_layers=2, n_heads=4, max_seq=128, vocab=128).
//
//  The goal is NOT SOTA speed — it is a CORRECT harness that reports:
//    - tok_s                 continuous decode tok/s (the serving number)
//    - latency_ms_per_tok    1 / tok_s
//    - ttft_ms               time to FIRST generated token (prefill + 1 decode)
//    - prefill_ms            prefill-only cost for the input prompt
//    - total_ms              wall-clock end to end
//    - kv_cache_mb           KV cache memory footprint
//    - naive_tok_s           same N tokens WITHOUT cache (recompute all) — comparison
//    - speedup_vs_naive      kv-cache / naive ratio
//
//  Output: single-line JSON to stdout. Human-readable lines are [info]
//  prefixed so downstream JSON parsers can filter by first char.
//
//  CLI:
//    hexa run self/bench/kv_cache_decode_bench.hexa \
//        [--prompt "hello"] [--max-new 8] \
//        [--dim 8] [--layers 1] [--heads 2] [--head-dim 4] \
//        [--vocab 16] [--max-seq 16] [--seed 42] [--naive]
//
//  Notes:
//    - Pure hexa arrays; no alloc_raw/FFI — runs under interpreter.
//    - HX4 self-host only, no C shim, no external weights.
//    - KV layout: kv_k[layer][pos][kv_head][d] flattened as 1D array,
//      indexed by alm-style ((layer*max_seq+pos)*n_heads+h)*head_dim+d.
//      (For this smoke model n_kv_heads == n_heads — no GQA.)
//    - Defaults are deliberately tiny (dim=8) because the stage0
//      interpreter's array push path is O(N^2) in RSS (see
//      memory/feedback_interp_push_quadratic.md). Scale up only after
//      HX8 seed-freeze lifts or when running under native/VM.
//    - --naive recompute comparison is OPT-IN (expensive).
// ═══════════════════════════════════════════════════════════════════

// ── Deterministic PRNG (LCG) — reproducible weights ─────────────────
let mut g_rng_state = 42

fn rng_seed(s) {
    g_rng_state = s
}

fn rng_next_u32() {
    // Numerical Recipes LCG: a=1664525, c=1013904223, m=2^32
    g_rng_state = (g_rng_state * 1664525 + 1013904223) % 4294967296
    return g_rng_state
}

fn rng_float() {
    // Uniform [0, 1)
    let u = rng_next_u32()
    return to_float(u) / 4294967296.0
}

fn rng_normal() {
    // Simple box-muller (approx via sum of 6 uniforms - 3; fine for a
    // smoke model's weight init, we don't need full gaussian).
    let mut acc = 0.0
    let mut i = 0
    while i < 12 {
        acc = acc + rng_float()
        i = i + 1
    }
    return acc - 6.0
}

// ── Model config ────────────────────────────────────────────────────
struct TinyCfg {
    dim: int,
    n_layers: int,
    n_heads: int,
    head_dim: int,
    vocab: int,
    max_seq: int,
    rope_base: float,
    rms_eps: float
}

// ── Per-layer weights (flat row-major arrays of floats) ─────────────
struct TinyLayer {
    wq: array,        // [dim*dim]
    wk: array,
    wv: array,
    wo: array,
    w1: array,        // [4*dim * dim]  (FFN up)
    w2: array,        // [dim * 4*dim]  (FFN down)
    attn_norm: array, // [dim]
    ffn_norm: array   // [dim]
}

struct TinyModel {
    cfg: TinyCfg,
    layers: array,        // [TinyLayer]
    tok_emb: array,       // [vocab * dim]
    lm_head: array,       // [vocab * dim]
    final_norm: array     // [dim]
}

// ── KV cache (pure hexa arrays) ─────────────────────────────────────
struct TinyKV {
    keys: array,    // [n_layers * max_seq * n_heads * head_dim]
    values: array,
    seq_len: int,
    cfg: TinyCfg
}

fn tiny_kv_new(cfg) {
    let total = cfg.n_layers * cfg.max_seq * cfg.n_heads * cfg.head_dim
    let mut keys = []
    let mut values = []
    let mut i = 0
    while i < total {
        keys.push(0.0)
        values.push(0.0)
        i = i + 1
    }
    return TinyKV { keys: keys, values: values, seq_len: 0, cfg: cfg }
}

fn tiny_kv_reset(kv) {
    let total = kv.cfg.n_layers * kv.cfg.max_seq * kv.cfg.n_heads * kv.cfg.head_dim
    // In-place zero; avoids O(n) array grow via push which would also
    // stress the interpreter's arena on every decode step of the
    // naive recompute path.
    let mut i = 0
    while i < total {
        kv.keys[i] = 0.0
        kv.values[i] = 0.0
        i = i + 1
    }
    kv.seq_len = 0
}

fn tiny_kv_idx(cfg, layer, pos, h, d) {
    return ((layer * cfg.max_seq + pos) * cfg.n_heads + h) * cfg.head_dim + d
}

fn tiny_kv_bytes(cfg) {
    // 2 caches (k+v), each f32 (4 bytes), fully allocated up to max_seq
    return 2 * cfg.n_layers * cfg.max_seq * cfg.n_heads * cfg.head_dim * 4
}

// ── Init: deterministic tiny model ──────────────────────────────────
fn tiny_init_mat(rows, cols, scale) {
    let mut m = []
    let total = rows * cols
    let mut i = 0
    while i < total {
        m.push(rng_normal() * scale)
        i = i + 1
    }
    return m
}

fn tiny_init_ones(n) {
    let mut m = []
    let mut i = 0
    while i < n {
        m.push(1.0)
        i = i + 1
    }
    return m
}

fn tiny_init_model(cfg, seed) {
    rng_seed(seed)
    let dim = cfg.dim
    let hidden = 4 * dim
    let scale = 1.0 / sqrt(to_float(dim))

    let tok_emb = tiny_init_mat(cfg.vocab, dim, scale)
    let lm_head = tiny_init_mat(cfg.vocab, dim, scale)
    let final_norm = tiny_init_ones(dim)

    let mut layers = []
    let mut li = 0
    while li < cfg.n_layers {
        let lw = TinyLayer {
            wq: tiny_init_mat(dim, dim, scale),
            wk: tiny_init_mat(dim, dim, scale),
            wv: tiny_init_mat(dim, dim, scale),
            wo: tiny_init_mat(dim, dim, scale),
            w1: tiny_init_mat(hidden, dim, scale),
            w2: tiny_init_mat(dim, hidden, 1.0 / sqrt(to_float(hidden))),
            attn_norm: tiny_init_ones(dim),
            ffn_norm: tiny_init_ones(dim)
        }
        layers.push(lw)
        li = li + 1
    }

    return TinyModel {
        cfg: cfg,
        layers: layers,
        tok_emb: tok_emb,
        lm_head: lm_head,
        final_norm: final_norm
    }
}

// ── Math primitives (pure hexa arrays) ──────────────────────────────
fn rms_norm(x, w, dim, eps) {
    let mut ss = 0.0
    let mut i = 0
    while i < dim {
        let v = x[i]
        ss = ss + v * v
        i = i + 1
    }
    let inv_rms = 1.0 / sqrt(ss / to_float(dim) + eps)
    let mut out = []
    i = 0
    while i < dim {
        out.push(x[i] * inv_rms * w[i])
        i = i + 1
    }
    return out
}

fn matvec(mat, vec, rows, cols) {
    // mat is row-major [rows*cols], vec is [cols], output [rows]
    let mut out = []
    let mut r = 0
    while r < rows {
        let base = r * cols
        let mut acc = 0.0
        let mut c = 0
        while c < cols {
            acc = acc + mat[base + c] * vec[c]
            c = c + 1
        }
        out.push(acc)
        r = r + 1
    }
    return out
}

fn apply_rope_inplace(vec, n_heads_rope, head_dim, pos, rope_base) {
    let half = head_dim / 2
    let mut h = 0
    while h < n_heads_rope {
        let base_off = h * head_dim
        let mut p = 0
        while p < half {
            let freq = 1.0 / pow(rope_base, 2.0 * to_float(p) / to_float(head_dim))
            let angle = to_float(pos) * freq
            let cos_a = cos(angle)
            let sin_a = sin(angle)
            let i0 = base_off + 2 * p
            let i1 = base_off + 2 * p + 1
            let x0 = vec[i0]
            let x1 = vec[i1]
            vec[i0] = x0 * cos_a - x1 * sin_a
            vec[i1] = x0 * sin_a + x1 * cos_a
            p = p + 1
        }
        h = h + 1
    }
    return vec
}

fn softmax_inplace(scores, n) {
    let mut mx = scores[0]
    let mut i = 1
    while i < n {
        if scores[i] > mx { mx = scores[i] }
        i = i + 1
    }
    let mut sum_e = 0.0
    i = 0
    while i < n {
        let e = exp(scores[i] - mx)
        scores[i] = e
        sum_e = sum_e + e
        i = i + 1
    }
    let inv = 1.0 / sum_e
    i = 0
    while i < n {
        scores[i] = scores[i] * inv
        i = i + 1
    }
    return scores
}

fn silu_mul(a, b, n) {
    let mut out = []
    let mut i = 0
    while i < n {
        let x = a[i]
        let s = x / (1.0 + exp(0.0 - x))
        out.push(s * b[i])
        i = i + 1
    }
    return out
}

fn add_inplace(dst, src, n) {
    let mut i = 0
    while i < n {
        dst[i] = dst[i] + src[i]
        i = i + 1
    }
    return dst
}

// ── Embedding lookup ────────────────────────────────────────────────
fn embed(tok_emb, token_id, dim) {
    let base = token_id * dim
    let mut x = []
    let mut i = 0
    while i < dim {
        x.push(tok_emb[base + i])
        i = i + 1
    }
    return x
}

// ── KV-cache write ──────────────────────────────────────────────────
fn kv_write(kv, cfg, layer, pos, k_vec, v_vec) {
    let slab = cfg.n_heads * cfg.head_dim
    let base = ((layer * cfg.max_seq + pos) * cfg.n_heads) * cfg.head_dim
    let mut i = 0
    while i < slab {
        kv.keys[base + i] = k_vec[i]
        kv.values[base + i] = v_vec[i]
        i = i + 1
    }
}

// ── Single transformer layer (MHA, no GQA for simplicity) ───────────
fn transformer_layer(model, layer_idx, x, pos, kv) {
    let cfg = model.cfg
    let dim = cfg.dim
    let n_heads = cfg.n_heads
    let head_dim = cfg.head_dim
    let eps = cfg.rms_eps
    let rope_base = cfg.rope_base
    let lw = model.layers[layer_idx]

    // Attention: norm -> q/k/v -> rope -> write kv -> attn -> wo -> res
    let xn = rms_norm(x, lw.attn_norm, dim, eps)
    let q = matvec(lw.wq, xn, dim, dim)
    let k = matvec(lw.wk, xn, dim, dim)
    let v = matvec(lw.wv, xn, dim, dim)

    apply_rope_inplace(q, n_heads, head_dim, pos, rope_base)
    apply_rope_inplace(k, n_heads, head_dim, pos, rope_base)

    kv_write(kv, cfg, layer_idx, pos, k, v)

    let scale = 1.0 / sqrt(to_float(head_dim))
    let ctx_len = pos + 1
    let mut attn_out = []
    let mut ao_i = 0
    while ao_i < dim {
        attn_out.push(0.0)
        ao_i = ao_i + 1
    }

    let mut h = 0
    while h < n_heads {
        let q_base = h * head_dim
        let mut scores = []
        let mut t = 0
        while t < ctx_len {
            let k_base = tiny_kv_idx(cfg, layer_idx, t, h, 0)
            let mut dot = 0.0
            let mut d = 0
            while d < head_dim {
                dot = dot + q[q_base + d] * kv.keys[k_base + d]
                d = d + 1
            }
            scores.push(dot * scale)
            t = t + 1
        }
        softmax_inplace(scores, ctx_len)

        let mut d = 0
        while d < head_dim {
            let mut acc = 0.0
            t = 0
            while t < ctx_len {
                let v_idx = tiny_kv_idx(cfg, layer_idx, t, h, d)
                acc = acc + scores[t] * kv.values[v_idx]
                t = t + 1
            }
            attn_out[q_base + d] = acc
            d = d + 1
        }
        h = h + 1
    }

    let attn_proj = matvec(lw.wo, attn_out, dim, dim)
    add_inplace(x, attn_proj, dim)

    // FFN
    let xn2 = rms_norm(x, lw.ffn_norm, dim, eps)
    let hidden = 4 * dim
    let up = matvec(lw.w1, xn2, hidden, dim)
    let gated = silu_mul(up, up, hidden)  // simple SwiGLU-ish (gate==up for smoke)
    let down = matvec(lw.w2, gated, dim, hidden)
    add_inplace(x, down, dim)

    return x
}

// ── Full forward: token -> logits using (and updating) kv cache ────
fn forward_with_cache(model, token_id, pos, kv) {
    let cfg = model.cfg
    let dim = cfg.dim
    let mut x = embed(model.tok_emb, token_id, dim)
    let mut li = 0
    while li < cfg.n_layers {
        x = transformer_layer(model, li, x, pos, kv)
        li = li + 1
    }
    let xn = rms_norm(x, model.final_norm, dim, cfg.rms_eps)
    let logits = matvec(model.lm_head, xn, cfg.vocab, dim)
    return logits
}

// ── Greedy argmax sampling (deterministic for bench) ───────────────
fn argmax(logits, n) {
    let mut best_i = 0
    let mut best_v = logits[0]
    let mut i = 1
    while i < n {
        if logits[i] > best_v {
            best_v = logits[i]
            best_i = i
        }
        i = i + 1
    }
    return best_i
}

// ── Prompt encode: byte-level fallback ─────────────────────────────
fn encode_prompt(text, vocab) {
    let chars = text.chars()
    let n = len(chars)
    let mut tokens = []
    let mut i = 0
    while i < n {
        let code = char_code(chars[i])
        // Clamp into vocab range for smoke model
        let tok = code % vocab
        tokens.push(tok)
        i = i + 1
    }
    if n == 0 {
        tokens.push(1)  // single bos-ish seed if empty
    }
    return tokens
}

// ── Naive (no-cache) decode: recompute the full prefix every step ──
// For each new token we re-run forward over the WHOLE sequence from
// position 0, throwing away the cache afterwards. This is what
// single-forward-pass tok/s measurements accidentally model if they
// don't track prefill reuse.
fn naive_decode_tok_s(model, prompt_tokens, max_new, cfg) {
    let vocab = cfg.vocab
    let pl = len(prompt_tokens)

    // Allocate scratch KV once (as "scratch pad" for the recompute
    // path — the semantic is still no-cache because we recompute every
    // position from 0 each step). This is purely so init doesn't
    // dominate over the actual FLOPs we want to compare.
    let kv_scratch = tiny_kv_new(cfg)

    let t0 = timestamp()
    let mut seq = []
    let mut i = 0
    while i < pl {
        seq.push(prompt_tokens[i])
        i = i + 1
    }

    let mut generated = 0
    while generated < max_new {
        let total_pos = len(seq)
        if total_pos >= cfg.max_seq {
            generated = max_new
        } else {
            // Reset the cache (mimic no-cache behavior: start every
            // step from a clean slate) then recompute the entire
            // prefix — O(N) per step, O(N^2) total.
            tiny_kv_reset(kv_scratch)
            let mut logits = []
            let mut p = 0
            while p < total_pos {
                logits = forward_with_cache(model, seq[p], p, kv_scratch)
                p = p + 1
            }
            let next_tok = argmax(logits, vocab)
            seq.push(next_tok)
            generated = generated + 1
        }
    }
    let t1 = timestamp()
    let ms = t1 - t0
    let mut tok_s = 0.0
    if ms > 0 {
        tok_s = to_float(generated) / (to_float(ms) / 1000.0)
    }
    let out = #{}
    out["naive_ms"] = ms
    out["naive_tok_s"] = tok_s
    out["naive_generated"] = generated
    return out
}

// ── Continuous (kv-cache) decode: the real serving path ────────────
fn continuous_decode(model, prompt_tokens, max_new, cfg) {
    let kv = tiny_kv_new(cfg)
    let vocab = cfg.vocab

    let t_start = timestamp()

    // Truncate prompt to fit inside max_seq (reserve one slot for the
    // first decoded token). Bench is shape-agnostic; if the caller
    // hands a prompt longer than max_seq, we measure what fits.
    let mut pl_raw = len(prompt_tokens)
    let cap = cfg.max_seq - 1
    let mut pl = pl_raw
    if pl > cap { pl = cap }
    if pl < 1 { pl = 1 }

    // Prefill
    let t_prefill_0 = timestamp()
    let mut last_logits = []
    let mut pos = 0
    while pos < pl {
        last_logits = forward_with_cache(model, prompt_tokens[pos], pos, kv)
        pos = pos + 1
    }
    let t_prefill_1 = timestamp()
    let prefill_ms = t_prefill_1 - t_prefill_0

    // Decode loop
    let t_decode_0 = timestamp()
    let mut ttft_ms = 0
    let mut first = true
    let mut generated = 0
    let mut out_tokens = []
    let mut cur_tok = argmax(last_logits, vocab)
    out_tokens.push(cur_tok)
    let t_first_tok = timestamp()
    if first {
        ttft_ms = t_first_tok - t_start
        first = false
    }
    generated = 1

    while generated < max_new {
        if pos >= cfg.max_seq {
            generated = max_new
        } else {
            let logits = forward_with_cache(model, cur_tok, pos, kv)
            let next_tok = argmax(logits, vocab)
            out_tokens.push(next_tok)
            cur_tok = next_tok
            pos = pos + 1
            generated = generated + 1
        }
    }
    let t_decode_1 = timestamp()
    let decode_ms = t_decode_1 - t_decode_0
    let total_ms = t_decode_1 - t_start

    // Report actual decoded length (early-stop via max_seq may have
    // short-circuited the loop; out_tokens is the source of truth).
    let actual_generated = len(out_tokens)

    let mut tok_s = 0.0
    if decode_ms > 0 {
        tok_s = to_float(actual_generated) / (to_float(decode_ms) / 1000.0)
    }
    let mut latency_ms_per_tok = 0.0
    if actual_generated > 0 {
        latency_ms_per_tok = to_float(decode_ms) / to_float(actual_generated)
    }

    let out = #{}
    out["tok_s"]              = tok_s
    out["latency_ms_per_tok"] = latency_ms_per_tok
    out["ttft_ms"]            = ttft_ms
    out["prefill_ms"]         = prefill_ms
    out["decode_ms"]          = decode_ms
    out["total_ms"]           = total_ms
    out["prompt_tokens"]      = pl
    out["generated"]          = actual_generated
    out["out_tokens"]         = out_tokens
    return out
}

// ── JSON encoding (minimal, avoids relying on json_stringify) ──────
fn jf(x) {
    // float to short string
    return str(x)
}

fn ji(x) {
    return str(x)
}

fn jarr_ints(a) {
    let n = len(a)
    let mut parts = []
    parts.push("[")
    let mut i = 0
    while i < n {
        if i > 0 { parts.push(",") }
        parts.push(str(a[i]))
        i = i + 1
    }
    parts.push("]")
    return parts.join("")
}

fn build_json(r_kv, r_naive, cfg, seed, with_naive) {
    let kv_cache_mb = to_float(tiny_kv_bytes(cfg)) / 1048576.0
    let mut parts = []
    parts.push("{")
    parts.push("\"tok_s\":")               parts.push(jf(r_kv["tok_s"]))
    parts.push(",\"latency_ms_per_tok\":") parts.push(jf(r_kv["latency_ms_per_tok"]))
    parts.push(",\"ttft_ms\":")            parts.push(ji(r_kv["ttft_ms"]))
    parts.push(",\"prefill_ms\":")         parts.push(ji(r_kv["prefill_ms"]))
    parts.push(",\"decode_ms\":")          parts.push(ji(r_kv["decode_ms"]))
    parts.push(",\"total_ms\":")           parts.push(ji(r_kv["total_ms"]))
    parts.push(",\"kv_cache_mb\":")        parts.push(jf(kv_cache_mb))
    parts.push(",\"prompt_tokens\":")      parts.push(ji(r_kv["prompt_tokens"]))
    parts.push(",\"generated\":")          parts.push(ji(r_kv["generated"]))
    parts.push(",\"out_tokens\":")         parts.push(jarr_ints(r_kv["out_tokens"]))

    if with_naive {
        parts.push(",\"naive_tok_s\":")    parts.push(jf(r_naive["naive_tok_s"]))
        parts.push(",\"naive_ms\":")       parts.push(ji(r_naive["naive_ms"]))
        let mut speedup = 0.0
        if r_naive["naive_tok_s"] > 0.0 {
            speedup = r_kv["tok_s"] / r_naive["naive_tok_s"]
        }
        parts.push(",\"speedup_vs_naive\":") parts.push(jf(speedup))
    }

    parts.push(",\"model\":{\"dim\":") parts.push(ji(cfg.dim))
    parts.push(",\"n_layers\":")       parts.push(ji(cfg.n_layers))
    parts.push(",\"n_heads\":")        parts.push(ji(cfg.n_heads))
    parts.push(",\"head_dim\":")       parts.push(ji(cfg.head_dim))
    parts.push(",\"vocab\":")          parts.push(ji(cfg.vocab))
    parts.push(",\"max_seq\":")        parts.push(ji(cfg.max_seq))
    parts.push(",\"seed\":")           parts.push(ji(seed))
    parts.push("}")
    parts.push("}")
    return parts.join("")
}

// ── CLI ─────────────────────────────────────────────────────────────
fn _flag(av, n, key, default_v) {
    let mut i = 0
    while i < n {
        if av[i] == key {
            if (i + 1) < n {
                return av[(i + 1)]
            }
        }
        i = i + 1
    }
    return default_v
}

fn _has(av, n, key) {
    let mut i = 0
    while i < n {
        if av[i] == key { return true }
        i = i + 1
    }
    return false
}

fn _print_help() {
    println("kv-cache continuous-decode tok/s benchmark (ROI #164)")
    println("")
    println("Usage:")
    println("  hexa run self/bench/kv_cache_decode_bench.hexa [flags]")
    println("")
    println("Flags:")
    println("  --prompt <str>    Prompt text (default: \"hello\")")
    println("  --max-new <N>     New tokens to decode (default: 8)")
    println("  --dim <D>         Model dim (default: 8)")
    println("  --layers <L>      Transformer layers (default: 1)")
    println("  --heads <H>       Attention heads (default: 2)")
    println("  --head-dim <D>    Per-head dim (default: 4, dim must == heads*head_dim)")
    println("  --vocab <V>       Vocab size (default: 16)")
    println("  --max-seq <S>     Max sequence length (default: 16)")
    println("  --seed <S>        RNG seed for weights (default: 42)")
    println("  --naive           ALSO run naive-recompute for comparison (opt-in, slow)")
    println("  --help            This help")
    println("")
    println("Defaults are deliberately tiny: stage0 interpreter array push")
    println("is O(N^2) in RSS. Scale up under native/VM only.")
    println("")
    println("Output: one JSON line on stdout.")
    println("Unit: tok_s = generated / (decode_ms / 1000)  — DECODE phase only.")
    println("TTFT includes prefill + first-token decode.")
}

fn main() {
    let av = args()
    let n_av = len(av)

    if _has(av, n_av, "--help") {
        _print_help()
        return
    }

    let prompt   = _flag(av, n_av, "--prompt",   "hello")
    let max_new  = to_int(_flag(av, n_av, "--max-new",  "8"))
    let dim      = to_int(_flag(av, n_av, "--dim",      "8"))
    let n_layers = to_int(_flag(av, n_av, "--layers",   "1"))
    let n_heads  = to_int(_flag(av, n_av, "--heads",    "2"))
    let head_dim = to_int(_flag(av, n_av, "--head-dim", "4"))
    let vocab    = to_int(_flag(av, n_av, "--vocab",    "16"))
    let max_seq  = to_int(_flag(av, n_av, "--max-seq",  "16"))
    let seed     = to_int(_flag(av, n_av, "--seed",     "42"))
    let with_naive = _has(av, n_av, "--naive")

    if dim != n_heads * head_dim {
        println("[info] dim (" + str(dim) + ") must equal n_heads*head_dim (" + str(n_heads * head_dim) + ")")
        return
    }

    let cfg = TinyCfg {
        dim:       dim,
        n_layers:  n_layers,
        n_heads:   n_heads,
        head_dim:  head_dim,
        vocab:     vocab,
        max_seq:   max_seq,
        rope_base: 10000.0,
        rms_eps:   0.000001
    }

    println("[info] init tiny model dim=" + str(dim) + " layers=" + str(n_layers) + " heads=" + str(n_heads) + " vocab=" + str(vocab))
    let model = tiny_init_model(cfg, seed)
    let prompt_tokens = encode_prompt(prompt, vocab)
    let pl = len(prompt_tokens)
    println("[info] prompt=\"" + prompt + "\" tokens=" + str(pl) + " max_new=" + str(max_new))

    // Continuous decode with kv-cache
    println("[info] running continuous decode (kv-cache)...")
    let r_kv = continuous_decode(model, prompt_tokens, max_new, cfg)

    // Naive comparison (opt-in, expensive due to O(N^2) recompute)
    let mut r_naive = #{}
    r_naive["naive_tok_s"] = 0.0
    r_naive["naive_ms"] = 0
    r_naive["naive_generated"] = 0
    if with_naive {
        println("[info] running naive recompute for comparison...")
        r_naive = naive_decode_tok_s(model, prompt_tokens, max_new, cfg)
    }

    let j = build_json(r_kv, r_naive, cfg, seed, with_naive)
    println(j)
}

// Stage0 auto-calls fn main() at end of file; explicit call would
// double-execute, so don't add `main()` here.
