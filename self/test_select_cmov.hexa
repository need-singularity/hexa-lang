// ═══════════════════════════════════════════════════════════
//  test_select_cmov.hexa -- ROI #63 select pattern recognition (cmov)
//  Verifies that simple if/else value selections produce the
//  same results as explicit branchless select(cond, a, b).
//  20+ tests covering: int/bool/string/float selects, nested,
//  comparison-based, identity, boundary, loop-internal, and
//  negative cases (multi-stmt bodies should NOT be converted).
//  Self-contained: no imports from ai_native_pass.hexa.
// ═══════════════════════════════════════════════════════════

// ── AstNode struct (standard 21-field) ───────────────────
struct AstNode {
    kind: string,
    name: string,
    value: string,
    op: string,
    left: string,
    right: string,
    cond: string,
    then_body: string,
    else_body: string,
    params: string,
    body: string,
    args: string,
    fields: string,
    items: string,
    variants: string,
    arms: string,
    iter_expr: string,
    ret_type: string,
    target: string,
    trait_name: string,
    methods: string
}

// ── Helpers from ai_native_pass.hexa ─────────────────────

fn split_attrs_m0(s) {
    let mut out = []
    if s == "" { return out }
    let chars = s.chars()
    let total = len(chars)
    let mut i = 0
    let mut cur = ""
    while i < total {
        let c = to_string(chars[i])
        if c == "," {
            if cur != "" { out.push(cur) }
            cur = ""
        } else {
            cur = cur + c
        }
        i = i + 1
    }
    if cur != "" { out.push(cur) }
    return out
}

fn attr_has(attrs, target) {
    let n = len(attrs)
    let mut i = 0
    while i < n {
        if attrs[i] == target { return true }
        i = i + 1
    }
    return false
}

fn rewrite_fn_with_body(fn_node, new_body) {
    return AstNode {
        kind: "FnDecl", name: fn_node.name, value: fn_node.value, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: fn_node.params, body: new_body, args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: fn_node.ret_type,
        target: "", trait_name: "", methods: ""
    }
}

// ── Milestone counters ───────────────────────────────────
let mut m980_select_detected = 0
let mut m980_select_rewrites = 0

// ── anp_select_* functions ───────────────────────────────

// decreases expr — structural
fn anp_is_select_leaf(expr) {
    if type_of(expr) == "string" { return false }
    let k = expr.kind
    if k == "IntLit" { return true }
    if k == "FloatLit" { return true }
    if k == "BoolLit" { return true }
    if k == "StringLit" { return true }
    if k == "CharLit" { return true }
    if k == "Ident" { return true }
    if k == "BinOp" {
        return anp_is_select_leaf(expr.left) && anp_is_select_leaf(expr.right)
    }
    if k == "UnaryOp" {
        return anp_is_select_leaf(expr.left)
    }
    if k == "Index" {
        return anp_is_select_leaf(expr.left) && anp_is_select_leaf(expr.right)
    }
    if k == "Call" {
        if type_of(expr.left) == "string" { return false }
        if expr.left.kind != "Ident" { return false }
        if type_of(expr.args) != "array" { return true }
        let mut ci = 0
        while ci < len(expr.args) {
            if !anp_is_select_leaf(expr.args[ci]) { return false }
            ci = ci + 1
        }
        return true
    }
    return false
}

fn anp_extract_branch_value(body) {
    if type_of(body) != "array" { return "" }
    if len(body) != 1 { return "" }
    let s = body[0]
    if type_of(s) == "string" { return "" }
    if s.kind == "ReturnStmt" {
        if type_of(s.left) != "string" && anp_is_select_leaf(s.left) { return s.left }
        return ""
    }
    if s.kind == "ExprStmt" {
        if type_of(s.left) != "string" && anp_is_select_leaf(s.left) { return s.left }
        return ""
    }
    if anp_is_select_leaf(s) { return s }
    return ""
}

fn anp_detect_select(stmt) {
    if type_of(stmt) == "string" { return false }
    let k = stmt.kind
    if k == "LetStmt" || k == "LetMutStmt" {
        if type_of(stmt.left) != "string" && stmt.left.kind == "IfExpr" {
            let ie = stmt.left
            if type_of(ie.cond) == "string" { return false }
            let tv = anp_extract_branch_value(ie.then_body)
            let ev = anp_extract_branch_value(ie.else_body)
            if type_of(tv) != "string" && type_of(ev) != "string" { return true }
        }
    }
    if k == "ReturnStmt" {
        if type_of(stmt.left) != "string" && stmt.left.kind == "IfExpr" {
            let ie = stmt.left
            if type_of(ie.cond) == "string" { return false }
            let tv = anp_extract_branch_value(ie.then_body)
            let ev = anp_extract_branch_value(ie.else_body)
            if type_of(tv) != "string" && type_of(ev) != "string" { return true }
        }
    }
    if k == "AssignStmt" {
        if type_of(stmt.right) != "string" && stmt.right.kind == "IfExpr" {
            let ie = stmt.right
            if type_of(ie.cond) == "string" { return false }
            let tv = anp_extract_branch_value(ie.then_body)
            let ev = anp_extract_branch_value(ie.else_body)
            if type_of(tv) != "string" && type_of(ev) != "string" { return true }
        }
    }
    if k == "IfStmt" {
        if type_of(stmt.cond) == "string" { return false }
        if type_of(stmt.then_body) != "array" { return false }
        if type_of(stmt.else_body) != "array" { return false }
        if len(stmt.then_body) != 1 { return false }
        if len(stmt.else_body) != 1 { return false }
        let ts = stmt.then_body[0]
        let es = stmt.else_body[0]
        if type_of(ts) == "string" || type_of(es) == "string" { return false }
        if ts.kind != "AssignStmt" { return false }
        if es.kind != "AssignStmt" { return false }
        if type_of(ts.left) == "string" || type_of(es.left) == "string" { return false }
        if ts.left.kind != "Ident" || es.left.kind != "Ident" { return false }
        if ts.left.name != es.left.name { return false }
        if anp_is_select_leaf(ts.right) && anp_is_select_leaf(es.right) { return true }
    }
    return false
}

fn anp_make_select_call(cond, then_val, else_val) {
    let callee = AstNode {
        kind: "Ident", name: "__select__", value: "", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
    return AstNode {
        kind: "Call", name: "", value: "", op: "",
        left: callee, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: [cond, then_val, else_val], fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn anp_rewrite_select(stmt) {
    if type_of(stmt) == "string" { return stmt }
    let k = stmt.kind
    if k == "LetStmt" || k == "LetMutStmt" {
        if type_of(stmt.left) != "string" && stmt.left.kind == "IfExpr" {
            let ie = stmt.left
            let tv = anp_extract_branch_value(ie.then_body)
            let ev = anp_extract_branch_value(ie.else_body)
            if type_of(tv) != "string" && type_of(ev) != "string" {
                let sel = anp_make_select_call(ie.cond, tv, ev)
                m980_select_rewrites = m980_select_rewrites + 1
                return AstNode {
                    kind: k, name: stmt.name, value: stmt.value, op: stmt.op,
                    left: sel, right: "", cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            }
        }
    }
    if k == "ReturnStmt" {
        if type_of(stmt.left) != "string" && stmt.left.kind == "IfExpr" {
            let ie = stmt.left
            let tv = anp_extract_branch_value(ie.then_body)
            let ev = anp_extract_branch_value(ie.else_body)
            if type_of(tv) != "string" && type_of(ev) != "string" {
                let sel = anp_make_select_call(ie.cond, tv, ev)
                m980_select_rewrites = m980_select_rewrites + 1
                return AstNode {
                    kind: "ReturnStmt", name: "", value: "", op: "",
                    left: sel, right: "", cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            }
        }
    }
    if k == "AssignStmt" {
        if type_of(stmt.right) != "string" && stmt.right.kind == "IfExpr" {
            let ie = stmt.right
            let tv = anp_extract_branch_value(ie.then_body)
            let ev = anp_extract_branch_value(ie.else_body)
            if type_of(tv) != "string" && type_of(ev) != "string" {
                let sel = anp_make_select_call(ie.cond, tv, ev)
                m980_select_rewrites = m980_select_rewrites + 1
                return AstNode {
                    kind: "AssignStmt", name: stmt.name, value: stmt.value, op: stmt.op,
                    left: stmt.left, right: sel, cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            }
        }
    }
    if k == "IfStmt" {
        if type_of(stmt.then_body) == "array" && type_of(stmt.else_body) == "array" {
            if len(stmt.then_body) == 1 && len(stmt.else_body) == 1 {
                let ts = stmt.then_body[0]
                let es = stmt.else_body[0]
                if type_of(ts) != "string" && type_of(es) != "string" {
                    if ts.kind == "AssignStmt" && es.kind == "AssignStmt" {
                        if type_of(ts.left) != "string" && type_of(es.left) != "string" {
                            if ts.left.kind == "Ident" && es.left.kind == "Ident" {
                                if ts.left.name == es.left.name {
                                    if anp_is_select_leaf(ts.right) && anp_is_select_leaf(es.right) {
                                        let sel = anp_make_select_call(stmt.cond, ts.right, es.right)
                                        m980_select_rewrites = m980_select_rewrites + 1
                                        return AstNode {
                                            kind: "AssignStmt", name: "", value: "", op: "",
                                            left: ts.left, right: sel, cond: "", then_body: "", else_body: "",
                                            params: "", body: "", args: "", fields: "", items: "",
                                            variants: "", arms: "", iter_expr: "", ret_type: "",
                                            target: "", trait_name: "", methods: ""
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
    return stmt
}

// decreases body — structural
fn anp_select_body(body) {
    if type_of(body) != "array" { return body }
    let mut out = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if type_of(stmt) != "string" {
            if anp_detect_select(stmt) {
                m980_select_detected = m980_select_detected + 1
                out.push(anp_rewrite_select(stmt))
            } else {
                let k = stmt.kind
                if k == "WhileStmt" || k == "ForStmt" {
                    let inner = anp_select_body(stmt.body)
                    out.push(AstNode {
                        kind: k, name: stmt.name, value: stmt.value, op: stmt.op,
                        left: stmt.left, right: stmt.right, cond: stmt.cond,
                        then_body: stmt.then_body, else_body: stmt.else_body,
                        params: stmt.params, body: inner, args: stmt.args, fields: stmt.fields, items: stmt.items,
                        variants: stmt.variants, arms: stmt.arms, iter_expr: stmt.iter_expr, ret_type: stmt.ret_type,
                        target: stmt.target, trait_name: stmt.trait_name, methods: stmt.methods
                    })
                } else if k == "IfStmt" || k == "IfExpr" {
                    let tb = anp_select_body(stmt.then_body)
                    let eb = if type_of(stmt.else_body) == "array" { anp_select_body(stmt.else_body) } else { stmt.else_body }
                    out.push(AstNode {
                        kind: k, name: stmt.name, value: stmt.value, op: stmt.op,
                        left: stmt.left, right: stmt.right, cond: stmt.cond,
                        then_body: tb, else_body: eb,
                        params: stmt.params, body: stmt.body, args: stmt.args, fields: stmt.fields, items: stmt.items,
                        variants: stmt.variants, arms: stmt.arms, iter_expr: stmt.iter_expr, ret_type: stmt.ret_type,
                        target: stmt.target, trait_name: stmt.trait_name, methods: stmt.methods
                    })
                } else {
                    out.push(stmt)
                }
            }
        } else {
            out.push(stmt)
        }
        i = i + 1
    }
    return out
}

fn anp_select_pass(ast) {
    if type_of(ast) != "array" { return ast }
    let mut out = []
    let n = len(ast)
    let mut i = 0
    while i < n {
        let node = ast[i]
        if type_of(node) != "string" && node.kind == "FnDecl" {
            let attrs = split_attrs_m0(node.value)
            if attr_has(attrs, "optimize") || attr_has(attrs, "hot") || attr_has(attrs, "inline") || attr_has(attrs, "pure") {
                let before = m980_select_rewrites
                let new_body = anp_select_body(node.body)
                if m980_select_rewrites > before {
                    out.push(rewrite_fn_with_body(node, new_body))
                    println("[ai-native] fn " + node.name + " REWRITE: select->cmov " + to_string(m980_select_rewrites - before) + " site(s)")
                } else {
                    out.push(node)
                }
            } else {
                out.push(node)
            }
        } else {
            out.push(node)
        }
        i = i + 1
    }
    return out
}

