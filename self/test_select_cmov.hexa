//  Tests begin here
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  ROI #63: Select Pattern Recognition (cmov) Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── Helper: manual select (branchless semantics) ──────────
fn select_int(cond, a, b) {
    if cond { return a }
    return b
}

fn select_bool(cond, a, b) {
    if cond { return a }
    return b
}

fn select_str(cond, a, b) {
    if cond { return a }
    return b
}

// ── T1: Basic integer select ──────────────────────────────
println("--- T1: Basic integer select ---")

fn t1_branching(x) {
    let v = if x > 0 { 1 } else { 0 }
    return v
}

check("T1 select int positive", t1_branching(5) == 1)
check("T1 select int negative", t1_branching(-3) == 0)
check("T1 select int zero", t1_branching(0) == 0)

// ── T2: Boolean select ────────────────────────────────────
println("")
println("--- T2: Boolean select ---")

fn t2_bool_select(x) {
    let v = if x > 10 { true } else { false }
    return v
}

check("T2 bool select true", t2_bool_select(20) == true)
check("T2 bool select false", t2_bool_select(5) == false)

// ── T3: String select ─────────────────────────────────────
println("")
println("--- T3: String select ---")

fn t3_str_select(x) {
    let v = if x == 0 { "zero" } else { "nonzero" }
    return v
}

check("T3 str select zero", t3_str_select(0) == "zero")
check("T3 str select nonzero", t3_str_select(42) == "nonzero")

// ── T4: Comparison operators ──────────────────────────────
println("")
println("--- T4: Comparison operators ---")

fn t4_lt(a, b) {
    return if a < b { a } else { b }
}

fn t4_ge(a, b) {
    return if a >= b { a } else { b }
}

check("T4 min(3,5)", t4_lt(3, 5) == 3)
check("T4 min(7,2)", t4_lt(7, 2) == 2)
check("T4 max(3,5)", t4_ge(3, 5) == 5)
check("T4 max(7,2)", t4_ge(7, 2) == 7)

// ── T5: Equality check select ─────────────────────────────
println("")
println("--- T5: Equality-based select ---")

fn t5_eq(x) {
    let r = if x == 42 { 1 } else { 0 }
    return r
}

check("T5 eq match", t5_eq(42) == 1)
check("T5 eq no match", t5_eq(99) == 0)

// ── T6: Nested select (inner) ─────────────────────────────
println("")
println("--- T6: Nested select ---")

fn t6_nested(x) {
    let a = if x > 0 { 10 } else { 20 }
    let b = if x > 5 { 100 } else { 200 }
    return a + b
}

check("T6 nested x=10", t6_nested(10) == 110)
check("T6 nested x=3", t6_nested(3) == 210)
check("T6 nested x=-1", t6_nested(-1) == 220)

// ── T7: Select with ident values ──────────────────────────
println("")
println("--- T7: Select with ident values ---")

fn t7_ident(a, b, use_first) {
    let r = if use_first { a } else { b }
    return r
}

check("T7 ident first", t7_ident(10, 20, true) == 10)
check("T7 ident second", t7_ident(10, 20, false) == 20)

// ── T8: Select with expressions ───────────────────────────
println("")
println("--- T8: Select with expressions ---")

fn t8_expr(x) {
    let r = if x > 0 { x * 2 } else { x + 1 }
    return r
}

check("T8 expr positive", t8_expr(5) == 10)
check("T8 expr negative", t8_expr(-3) == -2)
check("T8 expr zero", t8_expr(0) == 1)

// ── T9: Chained select (abs then sign) ────────────────────
println("")
println("--- T9: Chained select ---")

fn t9_abs(x) {
    return if x >= 0 { x } else { 0 - x }
}

fn t9_sign(x) {
    return if x > 0 { 1 } else { 0 }
}

check("T9 abs(5)", t9_abs(5) == 5)
check("T9 abs(-3)", t9_abs(-3) == 3)
check("T9 sign(5)", t9_sign(5) == 1)
check("T9 sign(-3)", t9_sign(-3) == 0)

// ── T10: Select in loop ──────────────────────────────────
println("")
println("--- T10: Select in loop ---")

fn t10_loop_select(n) {
    let mut sum = 0
    let mut i = 0
    while i < n {
        let v = if i % 2 == 0 { i } else { 0 }
        sum = sum + v
        i = i + 1
    }
    return sum
}

check("T10 loop n=6 (0+0+2+0+4+0=6)", t10_loop_select(6) == 6)
check("T10 loop n=1 (0)", t10_loop_select(1) == 0)
check("T10 loop n=0", t10_loop_select(0) == 0)

// ── T11: Select with same value both branches ────────────
println("")
println("--- T11: Identity select ---")

fn t11_identity(x) {
    return if x > 0 { 42 } else { 42 }
}

check("T11 identity positive", t11_identity(1) == 42)
check("T11 identity negative", t11_identity(-1) == 42)

// ── T12: Select used as function argument ────────────────
println("")
println("--- T12: Select as argument ---")

fn t12_double(x) { return x * 2 }

fn t12_select_arg(x) {
    let v = if x > 0 { 5 } else { 10 }
    return t12_double(v)
}

check("T12 select arg positive", t12_select_arg(1) == 10)
check("T12 select arg negative", t12_select_arg(-1) == 20)

// ── T13: Multiple selects in sequence ─────────────────────
println("")
println("--- T13: Multiple selects ---")

fn t13_multi(x) {
    let a = if x > 0 { 1 } else { 0 }
    let b = if x > 10 { 2 } else { 0 }
    let c = if x > 100 { 4 } else { 0 }
    return a + b + c
}

check("T13 multi x=200", t13_multi(200) == 7)
check("T13 multi x=50", t13_multi(50) == 3)
check("T13 multi x=5", t13_multi(5) == 1)
check("T13 multi x=-1", t13_multi(-1) == 0)

// ── T14: leaf detection tests ─────────────────────────────
println("")
println("--- T14: Leaf expression detection ---")

// Test anp_is_select_leaf with various AST node kinds
let leaf_int = AstNode { kind: "IntLit", name: "", value: "42", op: "", left: "", right: "", cond: "", then_body: "", else_body: "", params: "", body: "", args: "", fields: "", items: "", variants: "", arms: "", iter_expr: "", ret_type: "", target: "", trait_name: "", methods: "" }
let leaf_bool = AstNode { kind: "BoolLit", name: "", value: "true", op: "", left: "", right: "", cond: "", then_body: "", else_body: "", params: "", body: "", args: "", fields: "", items: "", variants: "", arms: "", iter_expr: "", ret_type: "", target: "", trait_name: "", methods: "" }
let leaf_ident = AstNode { kind: "Ident", name: "x", value: "", op: "", left: "", right: "", cond: "", then_body: "", else_body: "", params: "", body: "", args: "", fields: "", items: "", variants: "", arms: "", iter_expr: "", ret_type: "", target: "", trait_name: "", methods: "" }
let leaf_str = AstNode { kind: "StringLit", name: "", value: "hello", op: "", left: "", right: "", cond: "", then_body: "", else_body: "", params: "", body: "", args: "", fields: "", items: "", variants: "", arms: "", iter_expr: "", ret_type: "", target: "", trait_name: "", methods: "" }
let leaf_float = AstNode { kind: "FloatLit", name: "", value: "3.14", op: "", left: "", right: "", cond: "", then_body: "", else_body: "", params: "", body: "", args: "", fields: "", items: "", variants: "", arms: "", iter_expr: "", ret_type: "", target: "", trait_name: "", methods: "" }

check("T14 leaf IntLit", anp_is_select_leaf(leaf_int) == true)
check("T14 leaf BoolLit", anp_is_select_leaf(leaf_bool) == true)
check("T14 leaf Ident", anp_is_select_leaf(leaf_ident) == true)
check("T14 leaf StringLit", anp_is_select_leaf(leaf_str) == true)
check("T14 leaf FloatLit", anp_is_select_leaf(leaf_float) == true)
check("T14 non-leaf string", anp_is_select_leaf("not_a_node") == false)

// ── T15: BinOp leaf ──────────────────────────────────────
println("")
println("--- T15: BinOp leaf detection ---")

let binop_leaf = AstNode { kind: "BinOp", name: "", value: "", op: "+", left: leaf_int, right: leaf_ident, cond: "", then_body: "", else_body: "", params: "", body: "", args: "", fields: "", items: "", variants: "", arms: "", iter_expr: "", ret_type: "", target: "", trait_name: "", methods: "" }
check("T15 BinOp leaf", anp_is_select_leaf(binop_leaf) == true)

let unary_leaf = AstNode { kind: "UnaryOp", name: "", value: "", op: "-", left: leaf_int, right: "", cond: "", then_body: "", else_body: "", params: "", body: "", args: "", fields: "", items: "", variants: "", arms: "", iter_expr: "", ret_type: "", target: "", trait_name: "", methods: "" }
check("T15 UnaryOp leaf", anp_is_select_leaf(unary_leaf) == true)

// ── T16: anp_detect_select with LetStmt+IfExpr ──────────
println("")
println("--- T16: Detect select on LetStmt+IfExpr ---")

let cond_node = AstNode { kind: "BinOp", name: "", value: "", op: ">", left: leaf_ident, right: leaf_int, cond: "", then_body: "", else_body: "", params: "", body: "", args: "", fields: "", items: "", variants: "", arms: "", iter_expr: "", ret_type: "", target: "", trait_name: "", methods: "" }
let then_val = AstNode { kind: "IntLit", name: "", value: "1", op: "", left: "", right: "", cond: "", then_body: "", else_body: "", params: "", body: "", args: "", fields: "", items: "", variants: "", arms: "", iter_expr: "", ret_type: "", target: "", trait_name: "", methods: "" }
let else_val = AstNode { kind: "IntLit", name: "", value: "0", op: "", left: "", right: "", cond: "", then_body: "", else_body: "", params: "", body: "", args: "", fields: "", items: "", variants: "", arms: "", iter_expr: "", ret_type: "", target: "", trait_name: "", methods: "" }
let if_expr = AstNode { kind: "IfExpr", name: "", value: "", op: "", left: "", right: "", cond: cond_node, then_body: [then_val], else_body: [else_val], params: "", body: "", args: "", fields: "", items: "", variants: "", arms: "", iter_expr: "", ret_type: "", target: "", trait_name: "", methods: "" }
let let_stmt = AstNode { kind: "LetStmt", name: "v", value: "", op: "", left: if_expr, right: "", cond: "", then_body: "", else_body: "", params: "", body: "", args: "", fields: "", items: "", variants: "", arms: "", iter_expr: "", ret_type: "", target: "", trait_name: "", methods: "" }

check("T16 detect LetStmt+IfExpr", anp_detect_select(let_stmt) == true)

// ── T17: anp_detect_select with ReturnStmt+IfExpr ────────
println("")
println("--- T17: Detect select on ReturnStmt+IfExpr ---")

let ret_stmt = AstNode { kind: "ReturnStmt", name: "", value: "", op: "", left: if_expr, right: "", cond: "", then_body: "", else_body: "", params: "", body: "", args: "", fields: "", items: "", variants: "", arms: "", iter_expr: "", ret_type: "", target: "", trait_name: "", methods: "" }

check("T17 detect ReturnStmt+IfExpr", anp_detect_select(ret_stmt) == true)

// ── T18: anp_detect_select rejects non-select ────────────
println("")
println("--- T18: Reject non-select patterns ---")

let plain_let = AstNode { kind: "LetStmt", name: "x", value: "", op: "", left: leaf_int, right: "", cond: "", then_body: "", else_body: "", params: "", body: "", args: "", fields: "", items: "", variants: "", arms: "", iter_expr: "", ret_type: "", target: "", trait_name: "", methods: "" }
check("T18 reject plain LetStmt", anp_detect_select(plain_let) == false)
check("T18 reject string", anp_detect_select("not_a_node") == false)

// ── T19: anp_rewrite_select produces Call ────────────────
println("")
println("--- T19: Rewrite produces __select__ Call ---")

let rewritten = anp_rewrite_select(let_stmt)
check("T19 rewritten kind still LetStmt", rewritten.kind == "LetStmt")
check("T19 rewritten name preserved", rewritten.name == "v")
check("T19 rewritten init is Call", rewritten.left.kind == "Call")
check("T19 rewritten callee is __select__", rewritten.left.left.name == "__select__")
check("T19 rewritten args count=3", len(rewritten.left.args) == 3)

// ── T20: anp_detect_select IfStmt pattern (d) ────────────
println("")
println("--- T20: Detect IfStmt assign-both-branches ---")

let assign_a = AstNode { kind: "AssignStmt", name: "", value: "", op: "", left: leaf_ident, right: then_val, cond: "", then_body: "", else_body: "", params: "", body: "", args: "", fields: "", items: "", variants: "", arms: "", iter_expr: "", ret_type: "", target: "", trait_name: "", methods: "" }
let assign_b = AstNode { kind: "AssignStmt", name: "", value: "", op: "", left: leaf_ident, right: else_val, cond: "", then_body: "", else_body: "", params: "", body: "", args: "", fields: "", items: "", variants: "", arms: "", iter_expr: "", ret_type: "", target: "", trait_name: "", methods: "" }
let if_stmt_d = AstNode { kind: "IfStmt", name: "", value: "", op: "", left: "", right: "", cond: cond_node, then_body: [assign_a], else_body: [assign_b], params: "", body: "", args: "", fields: "", items: "", variants: "", arms: "", iter_expr: "", ret_type: "", target: "", trait_name: "", methods: "" }

check("T20 detect IfStmt pattern-d", anp_detect_select(if_stmt_d) == true)

// ── T21: IfStmt with different targets -> reject ─────────
println("")
println("--- T21: IfStmt different targets -> reject ---")

let other_ident = AstNode { kind: "Ident", name: "y", value: "", op: "", left: "", right: "", cond: "", then_body: "", else_body: "", params: "", body: "", args: "", fields: "", items: "", variants: "", arms: "", iter_expr: "", ret_type: "", target: "", trait_name: "", methods: "" }
let assign_c = AstNode { kind: "AssignStmt", name: "", value: "", op: "", left: other_ident, right: then_val, cond: "", then_body: "", else_body: "", params: "", body: "", args: "", fields: "", items: "", variants: "", arms: "", iter_expr: "", ret_type: "", target: "", trait_name: "", methods: "" }
let if_stmt_diff = AstNode { kind: "IfStmt", name: "", value: "", op: "", left: "", right: "", cond: cond_node, then_body: [assign_a], else_body: [assign_c], params: "", body: "", args: "", fields: "", items: "", variants: "", arms: "", iter_expr: "", ret_type: "", target: "", trait_name: "", methods: "" }

check("T21 reject different targets", anp_detect_select(if_stmt_diff) == false)

// ── T22: extract branch value ────────────────────────────
println("")
println("--- T22: Branch value extraction ---")

let ret_leaf = AstNode { kind: "ReturnStmt", name: "", value: "", op: "", left: leaf_int, right: "", cond: "", then_body: "", else_body: "", params: "", body: "", args: "", fields: "", items: "", variants: "", arms: "", iter_expr: "", ret_type: "", target: "", trait_name: "", methods: "" }
let extracted = anp_extract_branch_value([ret_leaf])
check("T22 extract from ReturnStmt", type_of(extracted) != "string")
check("T22 extracted is IntLit", extracted.kind == "IntLit")

let empty_extract = anp_extract_branch_value([])
check("T22 empty body returns empty", type_of(empty_extract) == "string")

let multi_extract = anp_extract_branch_value([ret_leaf, ret_leaf])
check("T22 multi-stmt body returns empty", type_of(multi_extract) == "string")

// ── T23: anp_select_pass full integration ────────────────
println("")
println("--- T23: Full pass integration ---")

// Reset counters
m980_select_detected = 0
m980_select_rewrites = 0

// Build a small AST with one FnDecl containing a select pattern
let param_x = AstNode { kind: "Param", name: "x", value: "", op: "", left: "", right: "", cond: "", then_body: "", else_body: "", params: "", body: "", args: "", fields: "", items: "", variants: "", arms: "", iter_expr: "", ret_type: "", target: "", trait_name: "", methods: "" }
let ret_if = AstNode { kind: "ReturnStmt", name: "", value: "", op: "", left: if_expr, right: "", cond: "", then_body: "", else_body: "", params: "", body: "", args: "", fields: "", items: "", variants: "", arms: "", iter_expr: "", ret_type: "", target: "", trait_name: "", methods: "" }
let fn_decl = AstNode { kind: "FnDecl", name: "test_fn", value: "optimize", op: "", left: "", right: "", cond: "", then_body: "", else_body: "", params: [param_x], body: [ret_if], args: "", fields: "", items: "", variants: "", arms: "", iter_expr: "", ret_type: "", target: "", trait_name: "", methods: "" }

let result = anp_select_pass([fn_decl])
check("T23 pass detected >= 1", m980_select_detected >= 1)
check("T23 pass rewrites >= 1", m980_select_rewrites >= 1)
check("T23 result length", len(result) == 1)
check("T23 result is FnDecl", result[0].kind == "FnDecl")

// ── T24: Behavioral equivalence exhaustive ──────────────
println("")
println("--- T24: Behavioral equivalence (cmov semantics) ---")

fn t24_min(a, b) {
    return if a < b { a } else { b }
}

fn t24_max(a, b) {
    return if a > b { a } else { b }
}

fn t24_clamp(x, lo, hi) {
    let v1 = if x < lo { lo } else { x }
    return if v1 > hi { hi } else { v1 }
}

check("T24 min(3,7)=3", t24_min(3, 7) == 3)
check("T24 max(3,7)=7", t24_max(3, 7) == 7)
check("T24 clamp(5,0,10)=5", t24_clamp(5, 0, 10) == 5)
check("T24 clamp(-5,0,10)=0", t24_clamp(-5, 0, 10) == 0)
check("T24 clamp(15,0,10)=10", t24_clamp(15, 0, 10) == 10)

// ═══════════════════════════════════════════════════════════
println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")
