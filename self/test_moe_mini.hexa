fn make_arr() {
    return [10.1, 20.2, 30.3]
}

fn main_test() {
    let r = make_arr()
    println("len=" + to_string(len(r)))
    let v0 = r[0]
    let v1 = r[1]
    let v2 = r[2]
    println("r[0]=" + to_string(v0))
    println("r[1]=" + to_string(v1))
    println("r[2]=" + to_string(v2))

    let mut total = 0.0
    for i in 0..3 {
        total = total + r[i]
    }
    println("total=" + to_string(total))
}

main_test()
