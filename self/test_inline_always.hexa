// ═══════════════════════════════════════════════════════════════════
//  test_inline_always.hexa — #36 @inline_always
//
//  Verifies that functions marked with @inline_always produce correct
//  results. The pass force-inlines small hot functions, eliminating
//  call overhead. codegen_c2 emits `static inline` for these fns.
//
//  Tests:
//    1. Simple @inline_always returning expression
//    2. @inline_always with arithmetic
//    3. @inline_always called multiple times
//    4. Nested @inline_always calls
//    5. @inline_always with two parameters
//    6. @inline_always identity function
//    7. @inline_always constant return
//    8. @inline_always used in larger expression
//    9. @inline_always with comparison
//   10. Regular fn calling @inline_always fn
//   11. @inline_always with subtraction
//   12. Chain of @inline_always calls
//
//  Run: ./hexa test self/test_inline_always.hexa
// ═══════════════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA #36 @inline_always Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Simple inline_always returning doubled value ─────────
@inline_always fn double(x) { return x * 2 }

check("#36-01 double(5)", double(5), 10)
check("#36-02 double(0)", double(0), 0)
check("#36-03 double(-3)", double(-3), -6)

// ── 2. @inline_always with addition ─────────────────────────
@inline_always fn add_one(x) { return x + 1 }

check("#36-04 add_one(0)", add_one(0), 1)
check("#36-05 add_one(99)", add_one(99), 100)

// ── 3. @inline_always with two params ───────────────────────
@inline_always fn add_pair(a, b) { return a + b }

check("#36-06 add_pair(3,4)", add_pair(3, 4), 7)
check("#36-07 add_pair(0,0)", add_pair(0, 0), 0)
check("#36-08 add_pair(-1,1)", add_pair(-1, 1), 0)

// ── 4. @inline_always identity ──────────────────────────────
@inline_always fn identity(x) { return x }

check("#36-09 identity(42)", identity(42), 42)

// ── 5. @inline_always constant ──────────────────────────────
@inline_always fn always_seven() { return 7 }

check("#36-10 always_seven", always_seven(), 7)

// ── 6. Nested @inline_always calls ──────────────────────────
check("#36-11 double(add_one(4))", double(add_one(4)), 10)
check("#36-12 add_one(double(3))", add_one(double(3)), 7)

// ── 7. @inline_always in larger expression ──────────────────
let result1 = double(3) + add_one(4) + add_pair(1, 2)
check("#36-13 compound expr", result1, 14)

// ── 8. @inline_always with multiplication ───────────────────
@inline_always fn square(x) { return x * x }

check("#36-14 square(5)", square(5), 25)
check("#36-15 square(0)", square(0), 0)
check("#36-16 square(-3)", square(-3), 9)

// ── 9. Regular fn using @inline_always ──────────────────────
fn compute(x) {
    let a = double(x)
    let b = add_one(a)
    return square(b)
}

check("#36-17 compute(2)", compute(2), 25)
check("#36-18 compute(0)", compute(0), 1)

// ── 10. @inline_always subtraction ──────────────────────────
@inline_always fn sub_pair(a, b) { return a - b }

check("#36-19 sub_pair(10,3)", sub_pair(10, 3), 7)
check("#36-20 sub_pair(0,5)", sub_pair(0, 5), -5)

// ── Summary ─────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  @inline_always: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")
if fail_count > 0 {
    println("FAIL")
}
