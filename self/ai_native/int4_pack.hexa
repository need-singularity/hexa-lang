// ═══════════════════════════════════════════════════════════════
//  int4_pack.hexa — AI-native ROI #76: int4 weight packing
//
//  4-bit weight packing for GPTQ/AWQ compatible layouts.
//  Two 4-bit values share a single byte:
//    lo nibble = arr[2*i]      (bits 0..3)
//    hi nibble = arr[2*i + 1]  (bits 4..7)
//
//  Odd-length input: trailing hi nibble = 0 (padding).
//  Round-trip: unpack_int4(pack_int4(x)) == x (for original length).
//
//  Memory ratio: original int array vs packed byte array → ~16x
//  (assuming int=64-bit and packed byte=8-bit for 2 nibbles).
//
//  Hexa note:
//    - Surface parser does not accept `<<`, `>>`, `|`, `0x..` literals.
//    - We use arithmetic equivalents (*16, /16) and `&` masking.
//    - Bit OR between non-overlapping nibbles = addition.
// ═══════════════════════════════════════════════════════════════

// pack_int4(arr) → packed bytes
//   Each element of `arr` MUST be in [0..15]; out-of-range inputs
//   are masked with `& 15` (low 4 bits only), matching GPTQ behavior.
//   Negative inputs are rejected (see `int4_validate`).
fn pack_int4(arr) {
    let n = len(arr)
    let packed_len = (n + 1) / 2
    let mut out = []
    let mut i = 0
    while i < packed_len {
        let lo_idx = i * 2
        let hi_idx = lo_idx + 1
        let lo = arr[lo_idx] & 15
        let mut hi = 0
        if hi_idx < n {
            hi = arr[hi_idx] & 15
        }
        // Non-overlapping nibbles → OR is equivalent to sum.
        // hi occupies bits 4..7 → hi * 16.
        let byte_val = (hi * 16) + lo
        out = out + [byte_val]
        i = i + 1
    }
    return out
}

// unpack_int4(packed) → [int]
//   Always returns a sequence of 2 * len(packed) nibbles; if the
//   original length was odd, the last element is a 0 pad. Callers
//   that know the original length should truncate manually.
fn unpack_int4(packed) {
    let m = len(packed)
    let mut out = []
    let mut i = 0
    while i < m {
        let b = packed[i]
        let lo = b & 15
        let hi = (b / 16) & 15
        out = out + [lo]
        out = out + [hi]
        i = i + 1
    }
    return out
}

// int4_validate(arr) → bool
//   true iff every element is in [0..15]. Use to guard before pack.
fn int4_validate(arr) {
    let n = len(arr)
    let mut i = 0
    while i < n {
        let v = arr[i]
        if v < 0 { return false }
        if v > 15 { return false }
        i = i + 1
    }
    return true
}

// int4_packed_len(original_len) → int
//   Exact byte count produced by pack_int4 for an array of this length.
fn int4_packed_len(n) {
    return (n + 1) / 2
}

// int4_compression_ratio_vs_i64(n) → float
//   Informational: how many bytes the packed form saves vs a naïve
//   i64 array. 8 bytes per int → 0.5 bytes per packed nibble = 16x.
fn int4_compression_ratio_vs_i64(n) {
    if n == 0 { return 0.0 }
    let raw_bytes = n * 8
    let packed_bytes = int4_packed_len(n)
    return to_float(raw_bytes) / to_float(packed_bytes)
}
