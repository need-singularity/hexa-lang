{
  "_meta": {
    "purpose": "ai-native algorithm cost model — S-2 foundation",
    "used_by": ["tool/ai_native_hotpath.hexa (future cost-aware suggest)", "self/opt/algorithm_select.hexa (S-2 runtime)", "@select meta-DSL (S-2.2)"],
    "date_started": "2026-04-17",
    "status": "seed — 8 algorithm families. grows as bench data accumulates.",
    "cost_model_notation": "formulas use n = input_size, k = #keys/buckets, d = value_bits. units = ns. measured = empirical on M4 16GB; predicted = formula."
  },

  "families": {
    "sort": {
      "input_shape": "array<T>",
      "output_shape": "array<T> (permuted)",
      "correctness_invariant": "len(out) == len(in) && sorted(out) && multiset(out) == multiset(in)",
      "cost_coefficients_m4": {
        "compare": 3.5,
        "swap": 2.8,
        "cache_miss_penalty": 120
      },
      "candidates": {
        "bubble": {
          "cost_formula": "2.8*n*n + 3.5*n*n",
          "best_for": "n <= 16 (simple + branch-predictable)",
          "worst_for": "n > 100 (quadratic blowup)",
          "stable": true,
          "in_place": true
        },
        "insertion": {
          "cost_formula": "1.4*n*n",
          "best_for": "n <= 32, nearly-sorted input",
          "worst_for": "n > 256 random",
          "stable": true,
          "in_place": true,
          "notes": "beats bubble when mostly-sorted due to inner-loop early-exit"
        },
        "merge": {
          "cost_formula": "8.5*n*log2(n) + 2.8*n",
          "best_for": "n > 64 AND stability required",
          "worst_for": "memory-constrained (O(n) aux)",
          "stable": true,
          "in_place": false,
          "notes": "predictable O(n log n), no worst-case degradation"
        },
        "quick": {
          "cost_formula": "7.0*n*log2(n) + pivot_bad*n*n",
          "best_for": "n > 64 AND random-distributed AND stability not needed",
          "worst_for": "adversarial input (degrades to O(n^2))",
          "stable": false,
          "in_place": true,
          "notes": "fastest for random int on cache-hot data; use median-of-3 pivot"
        },
        "radix": {
          "cost_formula": "6.5*n*d + 4.0*n",
          "best_for": "large n, fixed-width ints (int32/int64)",
          "worst_for": "comparable types / floats / strings > 32 chars",
          "stable": true,
          "in_place": false,
          "notes": "d = digits per key; LSD radix needs O(n+256) aux"
        }
      },
      "select_rules": [
        "if n <= 16 then insertion (cache-hot, tight inner loop)",
        "if n <= 1024 AND type == int32 then radix",
        "if n <= 1024 then quick (median-of-3 pivot)",
        "if n > 1024 AND stable then merge",
        "else quick"
      ]
    },

    "search": {
      "input_shape": "(array<T> sorted, key T) -> index | -1",
      "candidates": {
        "linear": {
          "cost_formula": "5.0*n (avg n/2)",
          "best_for": "n <= 64, unsorted or small",
          "stable": true
        },
        "binary": {
          "cost_formula": "12.0*log2(n)",
          "best_for": "n > 64, already sorted",
          "notes": "12ns per comparison due to branch misprediction on 50/50 path"
        },
        "interpolation": {
          "cost_formula": "8.0*log2(log2(n))",
          "best_for": "uniform-distributed numeric keys AND n > 256",
          "worst_for": "clustered keys (degrades to O(n))"
        },
        "hash_lookup": {
          "cost_formula": "60.0 (avg, amortized)",
          "best_for": "n > 8 AND accessed by key (not index)",
          "requires": "hashable key"
        }
      },
      "select_rules": [
        "if unsorted then linear",
        "if n <= 64 then linear (cache-hot)",
        "if uniform_distributed_numeric AND n > 256 then interpolation",
        "else binary"
      ]
    },

    "matmul": {
      "input_shape": "(A: [M,K], B: [K,N]) -> C: [M,N]",
      "cost_coefficients_m4": {
        "scalar_mul_ns": 1.8,
        "blas_sustained_gflops": 25
      },
      "candidates": {
        "scalar_triple_loop": {
          "cost_formula": "1.8 * M * N * K",
          "best_for": "M,N,K < 16 (cache-fit)",
          "worst_for": "M*N*K > 4096 (no vectorization)"
        },
        "blocked": {
          "cost_formula": "(1.8/3) * M * N * K",
          "best_for": "M,N,K = 32..256",
          "block_size_recommended": 64
        },
        "blas_gemm": {
          "cost_formula": "(2 * M * N * K) / (blas_sustained_gflops * 1e9) * 1e9",
          "best_for": "M,N,K >= 128, contiguous row-major",
          "implemented": "self/ml/* uses cblas_dgemm via runtime.c + accelerate_ffi",
          "ffi_overhead_ns": 450
        }
      },
      "select_rules": [
        "if M*N*K < 512 then scalar_triple_loop (FFI cost > compute)",
        "if M*N*K < 16384 then blocked (no FFI)",
        "else blas_gemm"
      ]
    },

    "map_insert": {
      "input_shape": "(map<K,V>, K, V) -> map<K,V>",
      "candidates": {
        "list_backed": {
          "cost_formula": "8.0*n (linear probe)",
          "best_for": "n <= 8",
          "notes": "hexa current default — from self/core/map.hexa"
        },
        "hash_bucketed_64": {
          "cost_formula": "12.0 + 0.5*n/64",
          "best_for": "n >= 16",
          "implemented": "self/hexa_full.hexa fn_attr_cache + env_cache (ROI-15)"
        }
      },
      "select_rules": [
        "if n <= 8 then list_backed",
        "else hash_bucketed_64"
      ]
    },

    "string_concat": {
      "input_shape": "(pieces: array<string>) -> string",
      "candidates": {
        "naive_loop": {
          "cost_formula": "1.2*n*n (O(n^2) due to realloc per +)",
          "best_for": "n <= 2 (compiler inlines)",
          "worst_for": "n > 10",
          "detected_by": "tool/ai_native_lint.hexa L4 rule"
        },
        "push_join": {
          "cost_formula": "4.0*n + string_total_bytes",
          "best_for": "n > 2",
          "notes": "parts.push(c) + parts.join('') — amortized O(1) push"
        },
        "builder_pattern": {
          "cost_formula": "3.5*total_bytes",
          "best_for": "n > 100 OR large total",
          "implemented": "not yet — stretch goal"
        }
      },
      "select_rules": [
        "if n <= 2 then naive_loop (compiler can still optimize)",
        "else push_join"
      ]
    },

    "reduce": {
      "input_shape": "(array<T>, binop: (T,T)->T) -> T",
      "candidates": {
        "sequential": {
          "cost_formula": "binop_cost*n + 2.5*n (loop overhead)",
          "best_for": "n <= 1024 OR binop non-associative"
        },
        "pairwise_tree": {
          "cost_formula": "binop_cost*n + 1.0*n*log2(n)",
          "best_for": "floating-point sum (better numerical accuracy)",
          "notes": "O(log n) depth for parallelization"
        },
        "parallel_scan": {
          "cost_formula": "binop_cost*n/k + dispatch_overhead",
          "requires": "@parallel + associative binop + k cores",
          "best_for": "n > 10000"
        }
      },
      "select_rules": [
        "if binop is float+ AND n > 256 then pairwise_tree (Kahan)",
        "if n > 10000 AND associative then parallel_scan",
        "else sequential"
      ]
    },

    "argmax": {
      "input_shape": "array<T> -> (index, T)",
      "candidates": {
        "linear_scan": {
          "cost_formula": "3.0*n",
          "best_for": "n <= 65536 (well-predicted branch)"
        },
        "parallel_chunks": {
          "cost_formula": "3.0*n/k + dispatch_overhead",
          "requires": "@parallel",
          "best_for": "n > 65536"
        }
      },
      "select_rules": [
        "if n <= 65536 then linear_scan",
        "else parallel_chunks"
      ]
    },

    "transpose": {
      "input_shape": "[M,N] -> [N,M]",
      "candidates": {
        "row_major_copy": {
          "cost_formula": "M*N*0.8 + M*N*cache_miss_penalty",
          "best_for": "M,N <= 64 (cache-fit)"
        },
        "block_transpose": {
          "cost_formula": "M*N*0.5",
          "best_for": "M,N > 64",
          "block_size_recommended": 32,
          "notes": "reduces cache misses by factor of block_size"
        }
      },
      "select_rules": [
        "if M*N <= 4096 then row_major_copy",
        "else block_transpose"
      ]
    }
  },

  "select_dsl_draft": {
    "syntax": "@select(\"sort\", when={n<=16: \"insertion\", n<=1024: \"quick\", default: \"merge\"})",
    "compile_path": "parser would desugar to if/else on n, inlining chosen algorithm",
    "status": "design only — implementation requires parser extension (S-2.2, bg-dependent)"
  },

  "learning_loop_draft": {
    "producer": "bench runner emits (family, candidate, n, type, ns_per_op) triples",
    "consumer": "self/opt/cost_learner.hexa (TODO) — fits regression per candidate, updates select_rules",
    "status": "infrastructure draft — needs S-0-2 bench harness first"
  }
}
