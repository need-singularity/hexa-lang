// ═══════════════════════════════════════════════════════════════════
//  self/ai_native/grad_checkpoint.hexa — AI-native ROI #103
//
//  @grad_checkpoint — selective activation checkpointing pass.
//  Given a model's layer list, automatically decide which activations
//  to recompute vs store based on a cost model (memory vs compute
//  tradeoff). The naive approach stores every activation; the
//  checkpoint-aware approach stores only boundary activations at
//  segment edges and recomputes mid-segment activations on backward.
//
//  The AI-native pass operates at the AST level: it detects a
//  "store-all-activations" forward pattern and rewrites it into a
//  "segment-boundary-only" pattern, inserting checkpoint markers
//  guided by a cost model.
//
//  Motivation:
//    Training large models is memory-bound. Activation memory grows
//    linearly with depth N. Checkpointing reduces peak memory to
//    O(sqrt(N)) by saving only S boundary activations and recomputing
//    mid-segment tensors on the backward pass. The tradeoff is
//    ~33% extra compute for ~50-70% memory savings.
//
//  Public API
//  ──────────
//      gc_cost_model(layer_info) -> map
//          • layer_info: map with keys "compute" (flops), "memory" (bytes)
//          • returns map #{"ratio": memory/compute, "checkpoint": bool}
//
//      gc_should_checkpoint(compute_cost, memory_cost) -> bool
//          • returns true when memory_cost / compute_cost > threshold
//            (threshold = 1.0: checkpoint when memory dominates compute)
//
//      gc_mark_layers(layers, budget) -> [bool]
//          • layers: [{compute: float, memory: float}, ...]
//          • budget: float — max total memory allowed
//          • returns bool array: true = store activation, false = recompute
//          • greedy: sorts by memory/compute ratio, marks cheapest-to-
//            recompute layers as checkpoint (recompute) first until
//            stored memory fits within budget.
//
//      gc_total_memory(layers, marks) -> float
//          • sum of memory for layers where marks[i] == true (stored)
//
//      gc_total_recompute(layers, marks) -> float
//          • sum of compute for layers where marks[i] == false (recomputed)
//
//      detect_checkpoint_candidate(prog) -> bool
//          • AST-level predicate: returns true iff `prog` is a list of
//            statements containing a "store_all_activations" forward
//            pattern — a for-loop that pushes every layer output to
//            an activation list.
//
//      rewrite_insert_checkpoint(prog) -> Program
//          • If detect_checkpoint_candidate(prog), replaces the
//            store-all node with a "checkpoint_forward" node that
//            only stores segment boundaries. Otherwise returns prog
//            unchanged.
//
//  Numerical contract
//  ──────────────────
//      For any layer list L and budget B:
//        gc_total_memory(L, gc_mark_layers(L, B)) <= B
//          (unless B < min single-layer memory, in which case all
//           layers are marked for recompute).
//      gc_mark_layers with budget >= total memory returns all-true
//        (store everything, no recompute needed).
//      gc_mark_layers with budget <= 0 returns all-false
//        (recompute everything).
//
//  Edge cases
//  ──────────
//      - 0 layers            -> empty marks []
//      - 1 layer             -> [true] if fits budget, [false] otherwise
//      - budget >= total mem -> all stored, no recompute
//      - budget <= 0         -> all recomputed
//      - compute_cost = 0    -> gc_should_checkpoint returns false
//                               (free compute, no reason to recompute)
//
//  Pattern detect / rewrite
//  ────────────────────────
//  The AST uses the same kind-tagged-struct approach as fused_adam.hexa.
//  Stmt.kind in {
//      "store_all_activations", "checkpoint_forward",
//      "backward_recompute", "other"
//  }
//
//  Grammar cautions (HX3 pitfalls)
//  ──────────────────────────────
//      - no struct-literal head inside `if` -> maps/structs returned
//        at tail of arm
//      - no `and`/`or` -> `&&` / `||`
//      - no enum -> string tags
//      - let mut x = 0 for mutable variables
//      - .push() not arr + [x] in loops (O(n^2) avoidance)
//      - range `..` binds tighter than `+` -> parenthesize
//
//  AI-native attrs
//  ───────────────
//      @pure       — all functions are referentially transparent
//      @checkpoint — marker for activation checkpointing semantics
//      @hot        — cost model called per-layer per-step
// ═══════════════════════════════════════════════════════════════════

// ── numeric helpers ────────────────────────────────────────────────

@pure
fn gc103_fabs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

// ═══════════════════════════════════════════════════════════════════
//  gc_should_checkpoint(compute_cost, memory_cost) -> bool
//
//  Decision rule: checkpoint (recompute on backward) when the memory
//  saved outweighs the recompute cost. Threshold ratio = 1.0 means
//  "checkpoint when memory_cost >= compute_cost".
//  Special: if compute_cost <= 0, never checkpoint (free to store).
// ═══════════════════════════════════════════════════════════════════
@pure
pub fn gc_should_checkpoint(compute_cost, memory_cost) {
    if compute_cost <= 0.0 { return false }
    let ratio = memory_cost / compute_cost
    if ratio >= 1.0 { return true }
    return false
}

// ═══════════════════════════════════════════════════════════════════
//  gc_cost_model(layer_info) -> map
//
//  Takes a map with "compute" and "memory" keys, returns a map with
//  the ratio and the checkpoint decision.
// ═══════════════════════════════════════════════════════════════════
@pure @checkpoint
pub fn gc_cost_model(layer_info) {
    let compute = layer_info["compute"]
    let memory = layer_info["memory"]
    let should_ckpt = gc_should_checkpoint(compute, memory)
    if compute <= 0.0 {
        return #{"ratio": 0.0, "checkpoint": should_ckpt}
    }
    let ratio = memory / compute
    return #{"ratio": ratio, "checkpoint": should_ckpt}
}

// ═══════════════════════════════════════════════════════════════════
//  gc_total_memory(layers, marks) -> float
//  Sum of memory for stored layers (marks[i] == true).
// ═══════════════════════════════════════════════════════════════════
@pure
pub fn gc_total_memory(layers, marks) {
    let n = len(layers)
    let mut total = 0.0
    for i in 0..n {
        if marks[i] {
            total = total + layers[i]["memory"]
        }
    }
    return total
}

// ═══════════════════════════════════════════════════════════════════
//  gc_total_recompute(layers, marks) -> float
//  Sum of compute for recomputed layers (marks[i] == false).
// ═══════════════════════════════════════════════════════════════════
@pure
pub fn gc_total_recompute(layers, marks) {
    let n = len(layers)
    let mut total = 0.0
    for i in 0..n {
        if !marks[i] {
            total = total + layers[i]["compute"]
        }
    }
    return total
}

// ═══════════════════════════════════════════════════════════════════
//  gc_mark_layers(layers, budget) -> [bool]
//
//  Greedy budget-aware marking. Each layer has "compute" and "memory".
//  Strategy:
//    1. Start with all layers stored (marks = all true).
//    2. If total memory <= budget, done (no recompute needed).
//    3. Otherwise, sort layers by memory/compute ratio descending
//       (highest ratio = most memory per unit recompute = best to
//       checkpoint first). Flip those to false (recompute) until
//       total stored memory fits within budget.
//
//  Edge: budget <= 0 -> all false. 0 layers -> [].
// ═══════════════════════════════════════════════════════════════════
@pure @checkpoint @hot
pub fn gc_mark_layers(layers, budget) {
    let n = len(layers)
    if n == 0 { return [] }

    // Start: all stored
    let mut marks = []
    let mut total_mem = 0.0
    for i in 0..n {
        marks.push(true)
        total_mem = total_mem + layers[i]["memory"]
    }

    // Budget <= 0: recompute everything
    if budget <= 0.0 {
        let mut all_false = []
        for _i in 0..n {
            all_false.push(false)
        }
        return all_false
    }

    // Already fits
    if total_mem <= budget { return marks }

    // Build index-ratio pairs, sort by ratio descending (highest ratio
    // = most memory per compute unit = best candidate to recompute)
    let mut indices = []
    let mut ratios = []
    for i in 0..n {
        indices.push(i)
        let c = layers[i]["compute"]
        if c <= 0.0 {
            // Zero compute = free to store, never recompute -> ratio 0
            ratios.push(0.0)
        } else {
            ratios.push(layers[i]["memory"] / c)
        }
    }

    // Simple selection sort on ratios descending (n is typically small)
    for i in 0..n {
        let mut best = i
        for j in (i+1)..n {
            if ratios[j] > ratios[best] {
                best = j
            }
        }
        if best != i {
            // Swap ratios
            let tmp_r = ratios[i]
            ratios[i] = ratios[best]
            ratios[best] = tmp_r
            // Swap indices
            let tmp_idx = indices[i]
            indices[i] = indices[best]
            indices[best] = tmp_idx
        }
    }

    // Greedily flip highest-ratio layers to recompute
    for i in 0..n {
        if total_mem <= budget { return marks }
        let idx = indices[i]
        marks[idx] = false
        total_mem = total_mem - layers[idx]["memory"]
    }

    return marks
}

// ═══════════════════════════════════════════════════════════════════
//  AST side — pattern detect / rewrite
//
//  Same kind-tagged-struct approach as fused_adam.hexa.
//  GCStmt.kind in {
//      "store_all_activations"  — naive forward that keeps every act
//      "checkpoint_forward"     — optimized: keeps only boundaries
//      "backward_recompute"     — backward with recompute
//      "other"
//  }
// ═══════════════════════════════════════════════════════════════════
struct GCStmt {
    kind: string
    index: string
    param: string
}

pub fn gc_stmt(kind, index, param) {
    return GCStmt{kind: kind, index: index, param: param}
}

pub fn gc_stmt_store_all(index, param)   { return gc_stmt("store_all_activations", index, param) }
pub fn gc_stmt_checkpoint(index, param)  { return gc_stmt("checkpoint_forward", index, param) }
pub fn gc_stmt_backward(index, param)    { return gc_stmt("backward_recompute", index, param) }
pub fn gc_stmt_other()                   { return gc_stmt("other", "", "") }

// ═══════════════════════════════════════════════════════════════════
//  detect_checkpoint_candidate(prog) -> bool
//
//  Returns true iff prog contains at least one "store_all_activations"
//  statement — indicating a naive forward that stores every activation
//  and could benefit from checkpointing.
// ═══════════════════════════════════════════════════════════════════
@pure
pub fn detect_checkpoint_candidate(prog) {
    let n = len(prog)
    if n == 0 { return false }
    for i in 0..n {
        if prog[i].kind == "store_all_activations" { return true }
    }
    return false
}

// ═══════════════════════════════════════════════════════════════════
//  rewrite_insert_checkpoint(prog) -> Program
//
//  Replaces every "store_all_activations" node with a
//  "checkpoint_forward" node (same index/param). All other nodes
//  pass through unchanged. If no candidate found, returns prog
//  as-is.
// ═══════════════════════════════════════════════════════════════════
@pure
pub fn rewrite_insert_checkpoint(prog) {
    if !detect_checkpoint_candidate(prog) { return prog }
    let n = len(prog)
    let mut out = []
    for i in 0..n {
        let s = prog[i]
        if s.kind == "store_all_activations" {
            out.push(gc_stmt_checkpoint(s.index, s.param))
        } else {
            out.push(s)
        }
    }
    return out
}

// ═══════════════════════════════════════════════════════════════════
//  gc_memory_savings(layers, budget) -> float
//
//  Convenience: returns the fraction of memory saved by checkpointing
//  compared to storing all activations. Range [0.0, 1.0].
// ═══════════════════════════════════════════════════════════════════
@pure
pub fn gc_memory_savings(layers, budget) {
    let n = len(layers)
    if n == 0 { return 0.0 }
    let mut total_mem = 0.0
    for i in 0..n {
        total_mem = total_mem + layers[i]["memory"]
    }
    if total_mem <= 0.0 { return 0.0 }
    let marks = gc_mark_layers(layers, budget)
    let stored = gc_total_memory(layers, marks)
    let saved = total_mem - stored
    if saved <= 0.0 { return 0.0 }
    return saved / total_mem
}

// ═══════════════════════════════════════════════════════════════════
//  Self-verification assertions
// ═══════════════════════════════════════════════════════════════════

fn gc103_assert(cond, msg) {
    if !cond {
        println("[FAIL] " + msg)
    }
}

fn gc103_self_test() {
    // Test 1: gc_should_checkpoint basic
    gc103_assert(gc_should_checkpoint(1.0, 2.0) == true,  "should_ckpt(1,2)")
    gc103_assert(gc_should_checkpoint(2.0, 1.0) == false, "should_ckpt(2,1)")
    gc103_assert(gc_should_checkpoint(1.0, 1.0) == true,  "should_ckpt(1,1)")
    gc103_assert(gc_should_checkpoint(0.0, 5.0) == false, "should_ckpt(0,5)")

    // Test 2: gc_cost_model
    let cm = gc_cost_model(#{"compute": 2.0, "memory": 4.0})
    gc103_assert(cm["ratio"] == 2.0, "cost_model ratio")
    gc103_assert(cm["checkpoint"] == true, "cost_model checkpoint")

    // Test 3: gc_mark_layers with generous budget (all stored)
    let layers3 = [
        #{"compute": 1.0, "memory": 10.0},
        #{"compute": 2.0, "memory": 20.0},
        #{"compute": 3.0, "memory": 30.0}
    ]
    let marks_all = gc_mark_layers(layers3, 100.0)
    gc103_assert(marks_all[0] == true, "generous budget: layer 0 stored")
    gc103_assert(marks_all[1] == true, "generous budget: layer 1 stored")
    gc103_assert(marks_all[2] == true, "generous budget: layer 2 stored")

    // Test 4: gc_mark_layers with zero budget (all recomputed)
    let marks_none = gc_mark_layers(layers3, 0.0)
    gc103_assert(marks_none[0] == false, "zero budget: layer 0 recompute")
    gc103_assert(marks_none[1] == false, "zero budget: layer 1 recompute")
    gc103_assert(marks_none[2] == false, "zero budget: layer 2 recompute")

    // Test 5: detect + rewrite
    let prog = [gc_stmt_store_all("i", "acts"), gc_stmt_other()]
    gc103_assert(detect_checkpoint_candidate(prog) == true, "detect store_all")
    let rewritten = rewrite_insert_checkpoint(prog)
    gc103_assert(rewritten[0].kind == "checkpoint_forward", "rewrite kind")
    gc103_assert(rewritten[1].kind == "other", "rewrite preserves other")

    println("[grad_checkpoint_ai] self-test PASS")
}

gc103_self_test()
println("[grad_checkpoint_ai] loaded — ROI #103 selective activation checkpointing cost model + AST pass")
