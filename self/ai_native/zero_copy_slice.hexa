// ═══════════════════════════════════════════════════════════
//  self/ai_native/zero_copy_slice.hexa
//
//  @zero_copy_slice — view-based slicing over contiguous arrays.
//
//  Motivation: after T1/T2 physical-ceiling breakthrough
//  (project_cpu_ai_native_ceiling_passed.md), tensor slicing remains
//  the dominant source of residual allocation / copy overhead in
//  AI-native hot paths. This module provides a struct-based view
//  (TensorView) that references the original backing array with an
//  offset + length + stride tuple — no heap allocation for the data,
//  and mutations propagate both ways (aliasing).
//
//  Observed semantics (probed 2026-04-16):
//    - hexa arrays have REFERENCE semantics: `let b = a` shares storage
//    - struct fields holding arrays stay shared; mutations propagate
//    - fn parameters alias the caller's array storage as well
//  Therefore TensorView { data_ref: arr, offset, len, stride } is a
//  true zero-copy view with no extra indirection.
//
//  API:
//    view_make(arr)                 -> full-array view (offset=0, stride=1)
//    view_slice(v, start, end)      -> sub-view [start..end) of view v
//    view_slice_arr(arr, a, b)      -> shortcut: slice a raw array
//    view_get(v, i)                 -> element i of the view
//    view_set(v, i, x)              -> write element i of the view
//                                      (propagates to backing array)
//    view_len(v)                    -> length of the view
//    view_materialize(v)            -> copy view into a fresh array
//                                      (only when ownership needed)
//
//  Non-contiguous strides (e.g. from a matrix column slice) are
//  supported for get/set; `view_materialize` is the escape hatch when
//  a contiguous array is required (e.g. BLAS hand-off).
// ═══════════════════════════════════════════════════════════

// TensorView: { data_ref, offset, len, stride }
//   data_ref : backing storage (shared reference — arrays alias)
//   offset   : base index into data_ref
//   len      : number of logical elements in the view
//   stride   : step between consecutive logical elements
pub struct TensorView {
    data_ref: any,
    offset: int,
    len: int,
    stride: int
}

// Build a full-array view (contiguous, stride=1).
pub fn view_make(arr) {
    return TensorView {
        data_ref: arr,
        offset: 0,
        len: len(arr),
        stride: 1
    }
}

// Slice an existing view to [start, end). Offsets and strides compose
// so that `view_slice(view_slice(arr, a, b), c, d)` yields the same
// element addresses as `arr[(a+c) .. (a+d)]` (flat stride=1 case).
pub fn view_slice(v, start, end) {
    let n = v.len
    let mut s = start
    let mut e = end
    if s < 0 { s = 0 }
    if e > n { e = n }
    if e < s { e = s }
    return TensorView {
        data_ref: v.data_ref,
        offset: v.offset + s * v.stride,
        len: e - s,
        stride: v.stride
    }
}

// Shortcut: slice a raw backing array directly.
pub fn view_slice_arr(arr, start, end) {
    let n = len(arr)
    let mut s = start
    let mut e = end
    if s < 0 { s = 0 }
    if e > n { e = n }
    if e < s { e = s }
    return TensorView {
        data_ref: arr,
        offset: s,
        len: e - s,
        stride: 1
    }
}

// Stride-aware view: e.g. column-of-row-major with stride=row_stride.
pub fn view_strided(arr, start, length, stride) {
    return TensorView {
        data_ref: arr,
        offset: start,
        len: length,
        stride: stride
    }
}

// Length of the view (number of logical elements).
pub fn view_len(v) {
    return v.len
}

// Read element i (0-based) of the view.
pub fn view_get(v, i) {
    // index out-of-range is surfaced by the underlying array access
    return v.data_ref[v.offset + i * v.stride]
}

// Write element i; mutation is observable on the backing array.
pub fn view_set(v, i, x) {
    v.data_ref[v.offset + i * v.stride] = x
    return v
}

// True if the view covers a contiguous run of the backing array.
pub fn view_is_contiguous(v) {
    return v.stride == 1
}

// Escape hatch: materialize a (strided) view into a fresh array.
// Only call this when owning storage is actually required —
// zero-copy consumers should prefer view_get/view_set directly.
pub fn view_materialize(v) {
    let mut out = []
    let mut i = 0
    while i < v.len {
        out = out.push(v.data_ref[v.offset + i * v.stride])
        i = i + 1
    }
    return out
}
