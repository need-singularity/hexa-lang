// ═══════════════════════════════════════════════════════════
//  test_nested_closures.hexa — Deep Closure Chain Tests
//  Tests: multi-level nesting, closure factories, closure in loops,
//         closure returning closure, higher-order composition
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA Nested Closure & Deep Capture Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Two-level closure nesting ─────────────────────────

println("--- Two-Level Nesting ---")

let a = 10
let f1 = |x| {
    let inner = |y| x + y + a
    return inner(3)
}
check("2-level nest", f1(5), 18)

let base = 100
let outer = |x| {
    let mid = x * 2
    let inner = |y| mid + y + base
    return inner(10)
}
check("2-level mid capture", outer(5), 120)

// ── 2. Three-level closure nesting ───────────────────────

println("")
println("--- Three-Level Nesting ---")

let c3 = 1000
let level1 = |a| {
    let level2 = |b| {
        let level3 = |c| a + b + c + c3
        return level3(3)
    }
    return level2(20)
}
check("3-level nest", level1(100), 1123)

// ── 3. Closure returning closure (currying) ──────────────

println("")
println("--- Currying ---")

fn make_adder(n) {
    return |x| x + n
}
let add5 = make_adder(5)
let add10 = make_adder(10)
check("curried add5(3)", add5(3), 8)
check("curried add10(3)", add10(3), 13)
check("curried add5(0)", add5(0), 5)

fn make_multiplier(n) {
    return |x| x * n
}
let dbl = make_multiplier(2)
let triple = make_multiplier(3)
check("curried dbl(7)", dbl(7), 14)
check("curried triple(7)", triple(7), 21)

// ── 4. Closure factory chain ─────────────────────────────

println("")
println("--- Factory Chain ---")

fn make_linear(m, b) {
    return |x| m * x + b
}
let line1 = make_linear(2, 3)
let line2 = make_linear(-1, 10)
check("linear 2x+3 at 5", line1(5), 13)
check("linear -x+10 at 3", line2(3), 7)
check("linear 2x+3 at 0", line1(0), 3)

// ── 5. Higher-order: apply twice ─────────────────────────

println("")
println("--- Higher-Order ---")

fn apply_twice(f, x) {
    return f(f(x))
}
check("apply_twice double", apply_twice(dbl, 3), 12)
check("apply_twice add5", apply_twice(add5, 0), 10)
check("apply_twice triple", apply_twice(triple, 2), 18)

// ── 6. Closure composition ───────────────────────────────

println("")
println("--- Composition ---")

fn compose(f, g) {
    return |x| f(g(x))
}
let double_then_add5 = compose(add5, dbl)
let add5_then_double = compose(dbl, add5)
check("double then add5 at 3", double_then_add5(3), 11)
check("add5 then double at 3", add5_then_double(3), 16)

// ── 7. Closures capturing loop index ─────────────────────

println("")
println("--- Closure in Loop ---")

let mut fns = []
let mut idx = 0
while idx < 5 {
    let captured = idx
    fns = fns.push(|x| x + captured)
    idx = idx + 1
}
check("loop closure [0](10)", fns[0](10), 10)
check("loop closure [1](10)", fns[1](10), 11)
check("loop closure [4](10)", fns[4](10), 14)

// ── 8. Closure with string capture ───────────────────────

println("")
println("--- String Capture ---")

fn make_greeter(prefix, suffix) {
    return |name| prefix + name + suffix
}
let hello_g = make_greeter("Hello, ", "!")
let bye_g = make_greeter("Bye, ", ".")
check("greeter hello", hello_g("Alice"), "Hello, Alice!")
check("greeter bye", bye_g("Bob"), "Bye, Bob.")

// ── Summary ──────────────────────────────────────────────

println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    throw "TESTS FAILED: " + to_string(fail_count)
}
