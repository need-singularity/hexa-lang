// ===============================================================
//  test_prefetch.hexa -- @prefetch AI-native attribute tests
//
//  @prefetch = memory prefetch hint for array traversal loops.
//  Detects while loops with array index access (arr[i]) and
//  marks them for prefetch hint insertion (next iteration data
//  loaded ahead of time).
//
//  Static model: ai_native_pass.hexa validates:
//    - @prefetch requires a loop in body
//    - @prefetch requires array index access (arr[i])
//    - No loop or no index access triggers violation
//
//  Codegen: codegen_c2.hexa emits __builtin_prefetch for
//    __prefetch(arr, idx) calls.
// ===============================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("===============================================================")
println("  HEXA @prefetch Memory Prefetch Tests")
println("===============================================================")
println("")

// ── 1. Array sum with prefetch hint ─────────────────────────

println("--- 1. Array sum ---")

@prefetch
fn prefetch_sum(arr) -> int {
    let mut s = 0
    let mut i = 0
    while i < len(arr) {
        s = s + arr[i]
        i = i + 1
    }
    return s
}

let a1 = [1, 2, 3, 4, 5]
check("@prefetch sum [1..5] = 15", prefetch_sum(a1), 15)

let a2 = [10, 20, 30]
check("@prefetch sum [10,20,30] = 60", prefetch_sum(a2), 60)

let a3 = []
check("@prefetch sum [] = 0", prefetch_sum(a3), 0)
println("")

// ── 2. Array max ────────────────────────────────────────────

println("--- 2. Array max ---")

@prefetch
fn prefetch_max(arr) -> int {
    if len(arr) == 0 { return 0 }
    let mut mx = arr[0]
    let mut i = 1
    while i < len(arr) {
        if arr[i] > mx {
            mx = arr[i]
        }
        i = i + 1
    }
    return mx
}

check("@prefetch max [3,1,4,1,5,9] = 9", prefetch_max([3, 1, 4, 1, 5, 9]), 9)
check("@prefetch max [42] = 42", prefetch_max([42]), 42)
check("@prefetch max [-5,-3,-1] = -1", prefetch_max([-5, -3, -1]), -1)
println("")

// ── 3. Array count elements ─────────────────────────────────

println("--- 3. Count elements ---")

@prefetch
fn prefetch_count(arr, target) -> int {
    let mut c = 0
    let mut i = 0
    while i < len(arr) {
        if arr[i] == target {
            c = c + 1
        }
        i = i + 1
    }
    return c
}

check("@prefetch count 3 in [1,3,3,7] = 2", prefetch_count([1, 3, 3, 7], 3), 2)
check("@prefetch count 0 in [1,2,3] = 0", prefetch_count([1, 2, 3], 0), 0)
println("")

// ── 4. Array product ────────────────────────────────────────

println("--- 4. Product ---")

@prefetch
fn prefetch_product(arr) -> int {
    if len(arr) == 0 { return 0 }
    let mut p = 1
    let mut i = 0
    while i < len(arr) {
        p = p * arr[i]
        i = i + 1
    }
    return p
}

check("@prefetch product [1,2,3,4] = 24", prefetch_product([1, 2, 3, 4]), 24)
check("@prefetch product [5,5] = 25", prefetch_product([5, 5]), 25)
println("")

// ── 5. Linear search ────────────────────────────────────────

println("--- 5. Linear search ---")

@prefetch
fn prefetch_find(arr, target) -> int {
    let mut i = 0
    while i < len(arr) {
        if arr[i] == target {
            return i
        }
        i = i + 1
    }
    return -1
}

check("@prefetch find 30 in [10,20,30,40] = 2", prefetch_find([10, 20, 30, 40], 30), 2)
check("@prefetch find 99 in [1,2,3] = -1", prefetch_find([1, 2, 3], 99), -1)
println("")

// ── 6. Sum of squares via array ─────────────────────────────

println("--- 6. Sum of squares ---")

@prefetch
fn prefetch_sq_sum(arr) -> int {
    let mut s = 0
    let mut i = 0
    while i < len(arr) {
        s = s + arr[i] * arr[i]
        i = i + 1
    }
    return s
}

check("@prefetch sq sum [1,2,3] = 14", prefetch_sq_sum([1, 2, 3]), 14)
check("@prefetch sq sum [4,5] = 41", prefetch_sq_sum([4, 5]), 41)
println("")

// ── 7. Dot product ──────────────────────────────────────────

println("--- 7. Dot product ---")

@prefetch
fn prefetch_dot(a, b) -> int {
    let mut s = 0
    let n = len(a)
    let mut i = 0
    while i < n {
        s = s + a[i] * b[i]
        i = i + 1
    }
    return s
}

check("@prefetch dot [1,2,3].[4,5,6] = 32", prefetch_dot([1, 2, 3], [4, 5, 6]), 32)
check("@prefetch dot [1,0].[0,1] = 0", prefetch_dot([1, 0], [0, 1]), 0)
println("")

// ── 8. Determinism ──────────────────────────────────────────

println("--- 8. Determinism ---")

let data = [7, 14, 21, 28, 35]
let r8a = prefetch_sum(data)
let r8b = prefetch_sum(data)
check("@prefetch deterministic sum", r8a == r8b, true)
check("@prefetch deterministic value", r8a, 105)
println("")

// ── 9. Large array ──────────────────────────────────────────

println("--- 9. Large array ---")

let mut big = []
let mut bi = 0
while bi < 100 {
    big.push(bi)
    bi = bi + 1
}
check("@prefetch sum 0..100 = 4950", prefetch_sum(big), 4950)
println("")

// ── 10. Single element ──────────────────────────────────────

println("--- 10. Single element ---")

check("@prefetch sum [42] = 42", prefetch_sum([42]), 42)
check("@prefetch max [99] = 99", prefetch_max([99]), 99)
println("")

// ── Summary ─────────────────────────────────────────────────

println("===============================================================")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("===============================================================")

if fail_count == 0 {
    println("")
    println("=== test_prefetch.hexa: ALL TESTS PASSED ===")
} else {
    println("")
    println("!!! SOME TESTS FAILED !!!")
}
