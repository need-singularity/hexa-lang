// ═══════════════════════════════════════════════════════════
//  test_p2_4_5_match_try.hexa — P2-4 Match + P2-5 Try/Catch Tests
//  Covers: literals, wildcard, binding, guards, enum match,
//          try/catch/throw, nested throw, stack trace
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  P2-4: Pattern Matching + P2-5: Error Handling Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ═══════════════════════════════════════════════════════════
// P2-4: Match — literal patterns
// ═══════════════════════════════════════════════════════════

println("--- Match Int Literals ---")

fn classify_int(x) {
    return match x {
        1 -> "one",
        2 -> "two",
        3 -> "three",
        _ -> "other"
    }
}

check("match int 1", classify_int(1), "one")
check("match int 2", classify_int(2), "two")
check("match int 3", classify_int(3), "three")
check("match int wildcard", classify_int(99), "other")

println("")
println("--- Match String Literals ---")

fn classify_str(s) {
    return match s {
        "hello" -> 1,
        "world" -> 2,
        _ -> 0
    }
}

check("match str hello", classify_str("hello"), 1)
check("match str world", classify_str("world"), 2)
check("match str wildcard", classify_str("xyz"), 0)

println("")
println("--- Match Bool ---")

fn bool_word(b) {
    return match b {
        true -> "yes",
        false -> "no"
    }
}

check("match bool true", bool_word(true), "yes")
check("match bool false", bool_word(false), "no")

// ═══════════════════════════════════════════════════════════
// P2-4: Match — variable binding
// ═══════════════════════════════════════════════════════════

println("")
println("--- Match Variable Binding ---")

fn match_bind(x) {
    return match x {
        0 -> "zero",
        n -> "val:" + to_string(n)
    }
}

check("match bind zero", match_bind(0), "zero")
check("match bind 42", match_bind(42), "val:42")

// ═══════════════════════════════════════════════════════════
// P2-4: Match — block body
// ═══════════════════════════════════════════════════════════

println("")
println("--- Match Block Body ---")

let r_block = match 3 {
    1 -> {
        let a = 10
        a + 1
    },
    3 -> {
        let a = 100
        let b = 200
        a + b
    },
    _ -> 0
}
check("match block body", r_block, 300)

// ═══════════════════════════════════════════════════════════
// P2-4: Match — guard clauses
// ═══════════════════════════════════════════════════════════

println("")
println("--- Match Guard Clauses ---")

fn classify_num(x) {
    return match x {
        n if n > 100 -> "big",
        n if n > 10 -> "medium",
        n if n > 0 -> "small",
        _ -> "non-positive"
    }
}

check("guard big", classify_num(200), "big")
check("guard medium", classify_num(50), "medium")
check("guard small", classify_num(5), "small")
check("guard non-pos", classify_num(-1), "non-positive")
check("guard boundary 100", classify_num(100), "medium")
check("guard boundary 10", classify_num(10), "small")
check("guard boundary 0", classify_num(0), "non-positive")

// ═══════════════════════════════════════════════════════════
// P2-4: Match — enum variants
// ═══════════════════════════════════════════════════════════

println("")
println("--- Match Enum Variants ---")

enum Color {
    Red,
    Green,
    Blue
}

fn color_name(c) {
    return match c {
        Color::Red -> "red",
        Color::Green -> "green",
        Color::Blue -> "blue",
        _ -> "unknown"
    }
}

check("enum Red", color_name(Color::Red), "red")
check("enum Green", color_name(Color::Green), "green")
check("enum Blue", color_name(Color::Blue), "blue")

// ═══════════════════════════════════════════════════════════
// P2-5: try/catch/throw — basic
// ═══════════════════════════════════════════════════════════

println("")
println("--- Try/Catch Basic ---")

let mut r1 = 0
try {
    r1 = 42
} catch e {
    r1 = -1
}
check("try no error", r1, 42)

let mut r2 = 0
try {
    throw "boom"
    r2 = 99
} catch e {
    r2 = -1
}
check("throw caught", r2, -1)

let mut r3 = 0
try {
    r3 = r3 + 10
    r3 = r3 + 20
    throw "stop"
    r3 = r3 + 100
} catch e {
    r3 = r3 + 1
}
check("partial + catch", r3, 31)

// ═══════════════════════════════════════════════════════════
// P2-5: try/catch — nested function throw
// ═══════════════════════════════════════════════════════════

println("")
println("--- Nested Throw ---")

fn safe_div(a, b) {
    if b == 0 {
        throw "division by zero"
    }
    return a / b
}

let mut r4 = 0
try {
    r4 = safe_div(10, 2)
} catch e {
    r4 = -1
}
check("safe_div ok", r4, 5)

let mut r5 = 0
try {
    r5 = safe_div(10, 0)
} catch e {
    r5 = -999
}
check("safe_div throw", r5, -999)

// ═══════════════════════════════════════════════════════════
// P2-5: try/catch — recovery and continue
// ═══════════════════════════════════════════════════════════

println("")
println("--- Error Recovery ---")

let mut sum = 0
let mut i = 0
while i < 5 {
    try {
        if i == 2 {
            throw "skip"
        }
        sum = sum + i
    } catch e {
        // skip this iteration
    }
    i = i + 1
}
check("loop recovery", sum, 8)

// ═══════════════════════════════════════════════════════════
// Summary
// ═══════════════════════════════════════════════════════════

println("")
println("═══════════════════════════════════════════════════════")
println("  PASS: " + to_string(pass_count))
println("  FAIL: " + to_string(fail_count))
println("  TOTAL: " + to_string(pass_count + fail_count))
if fail_count == 0 {
    println("  ALL TESTS PASSED")
} else {
    println("  SOME TESTS FAILED")
}
println("═══════════════════════════════════════════════════════")
