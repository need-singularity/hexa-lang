// ═══════════════════════════════════════════════════════════════════
//  test_tco.hexa — #34 Tail Call Optimization (TCO)
//
//  Verifies that tail-recursive functions produce correct results.
//  The TCO pass converts tail-position self-calls into while loops,
//  preventing stack overflow for deep recursion.
//
//  Tests:
//    1. Factorial via tail recursion
//    2. Sum 1..n via tail recursion
//    3. Fibonacci via tail recursion (accumulator style)
//    4. GCD (Euclidean) via tail recursion
//    5. Power (exponentiation) via tail recursion
//    6. Countdown (base case correctness)
//    7. Length of list via tail recursion
//    8. String repeat via tail recursion
//    9. Deep recursion (would stack overflow without TCO)
//   10. Single-element base case
//   11. Zero-step base case
//   12. Negative input handling
//
//  Run: ./hexa test self/test_tco.hexa
// ═══════════════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA #34 Tail Call Optimization (TCO) Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Factorial (tail-recursive with accumulator) ──────────
// decreases n — structural
fn fact_tail(n, acc) {
    if n <= 1 { return acc }
    return fact_tail(n - 1, n * acc)
}

fn factorial(n) { return fact_tail(n, 1) }

check("#34-01 factorial(0)", factorial(0), 1)
check("#34-02 factorial(1)", factorial(1), 1)
check("#34-03 factorial(5)", factorial(5), 120)
check("#34-04 factorial(10)", factorial(10), 3628800)

// ── 2. Sum 1..n (tail-recursive) ────────────────────────────
// decreases n — structural
fn sum_tail(n, acc) {
    if n <= 0 { return acc }
    return sum_tail(n - 1, acc + n)
}

fn sum_n(n) { return sum_tail(n, 0) }

check("#34-05 sum(0)", sum_n(0), 0)
check("#34-06 sum(1)", sum_n(1), 1)
check("#34-07 sum(10)", sum_n(10), 55)
check("#34-08 sum(100)", sum_n(100), 5050)

// ── 3. Fibonacci (tail-recursive with two accumulators) ─────
// decreases n — structural
fn fib_tail(n, a, b) {
    if n <= 0 { return a }
    return fib_tail(n - 1, b, a + b)
}

fn fib(n) { return fib_tail(n, 0, 1) }

check("#34-09 fib(0)", fib(0), 0)
check("#34-10 fib(1)", fib(1), 1)
check("#34-11 fib(5)", fib(5), 5)
check("#34-12 fib(10)", fib(10), 55)

// ── 4. GCD (Euclidean tail recursion) ───────────────────────
// decreases a — structural
fn gcd(a, b) {
    if b == 0 { return a }
    return gcd(b, a - (a / b) * b)
}

check("#34-13 gcd(12,8)", gcd(12, 8), 4)
check("#34-14 gcd(100,75)", gcd(100, 75), 25)
check("#34-15 gcd(17,13)", gcd(17, 13), 1)

// ── 5. Power (tail-recursive exponentiation) ────────────────
// decreases base — structural
fn pow_tail(base, exp, acc) {
    if exp <= 0 { return acc }
    return pow_tail(base, exp - 1, acc * base)
}

fn power(b, e) { return pow_tail(b, e, 1) }

check("#34-16 power(2,0)", power(2, 0), 1)
check("#34-17 power(2,10)", power(2, 10), 1024)
check("#34-18 power(3,5)", power(3, 5), 243)

// ── 6. Countdown (simple base case) ─────────────────────────
// decreases n — structural
fn countdown(n) {
    if n <= 0 { return 0 }
    return countdown(n - 1)
}

check("#34-19 countdown(0)", countdown(0), 0)
check("#34-20 countdown(100)", countdown(100), 0)

// ── Summary ─────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  TCO: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")
if fail_count > 0 {
    println("FAIL")
}
