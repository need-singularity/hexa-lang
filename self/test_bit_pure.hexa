// ═══════════════════════════════════════════════════════════════════
//  test_bit_pure.hexa — coverage for self/runtime/bit_pure.hexa
//
//  (0b binary literals are not supported by stage0, use hex/decimal)
// ═══════════════════════════════════════════════════════════════════

import "runtime/bit_pure.hexa"

let mut pass = 0
let mut fail = 0

fn check(name, cond) {
    if cond {
        pass = pass + 1
    } else {
        fail = fail + 1
        println("[FAIL] " + name)
    }
}

fn eq(name, actual, expected) {
    let ok = actual == expected
    if ok {
        pass = pass + 1
    } else {
        fail = fail + 1
        println("[FAIL] " + name + " expected=" + to_string(expected) + " got=" + to_string(actual))
    }
}

println("=== bit_pure test suite ===")

// ---- basic bitwise ----
eq("or 10|5=15",   bit_or_pure(10, 5), 15)
eq("and 12&10=8",  bit_and_pure(12, 10), 8)
eq("xor 12^10=6",  bit_xor_pure(12, 10), 6)
eq("shl 1<<5=32",  bit_shl_pure(1, 5), 32)
eq("shr 32>>5=1",  bit_shr_pure(32, 5), 1)
eq("shl 1<<0=1",   bit_shl_pure(1, 0), 1)
eq("shl 7<<3=56",  bit_shl_pure(7, 3), 56)
eq("shr 56>>3=7",  bit_shr_pure(56, 3), 7)
eq("not32 mask",   bit_not_pure(0x00FF00FF, 32), 0xFF00FF00)

// ---- bit test/set/clear/toggle ----
check("test bit 0 of 1", bit_test_pure(1, 0))
check("test bit 3 of 8", bit_test_pure(8, 3))
check("test bit 2 of 10 false", !bit_test_pure(10, 2))
eq("set bit 2 of 0", bit_set_pure(0, 2), 4)
eq("clear bit 2 of 7", bit_clear_pure(7, 2), 3)
eq("toggle bit 1 of 5", bit_toggle_pure(5, 1), 7)
eq("toggle bit 1 of 7", bit_toggle_pure(7, 1), 5)
eq("set bit 4 of 0", bit_set_pure(0, 4), 16)

// ---- popcount ----
eq("popcount 0", popcount_pure(0), 0)
eq("popcount 1", popcount_pure(1), 1)
eq("popcount 15", popcount_pure(15), 4)
eq("popcount 255", popcount_pure(255), 8)
eq("popcount 0xFFFF", popcount_pure(0xFFFF), 16)
eq("popcount 7", popcount_pure(7), 3)

// ---- parity ----
eq("parity 0", parity_pure(0), 0)
eq("parity 1", parity_pure(1), 1)
eq("parity 3", parity_pure(3), 0)
eq("parity 7", parity_pure(7), 1)

// ---- leading/trailing zeros ----
eq("clz 0 (32)", leading_zeros_pure(0, 32), 32)
eq("clz 1 (32)", leading_zeros_pure(1, 32), 31)
eq("clz 0x80000000 (32)", leading_zeros_pure(0x80000000, 32), 0)
eq("clz 0xFF (32)", leading_zeros_pure(0xFF, 32), 24)

eq("ctz 1", trailing_zeros_pure(1), 0)
eq("ctz 2", trailing_zeros_pure(2), 1)
eq("ctz 8", trailing_zeros_pure(8), 3)
eq("ctz 256", trailing_zeros_pure(256), 8)

// ---- rotate (32-bit) ----
eq("rotl 1 by 1 (32)", rotate_left_pure(1, 1, 32), 2)
eq("rotl 0x80000000 by 1 (32)", rotate_left_pure(0x80000000, 1, 32), 1)
eq("rotr 2 by 1 (32)", rotate_right_pure(2, 1, 32), 1)
eq("rotr 1 by 1 (32)", rotate_right_pure(1, 1, 32), 0x80000000)
eq("rotl 0 always 0", rotate_left_pure(0, 7, 32), 0)

// ---- byte swap ----
eq("bswap32 AABBCCDD", byte_swap32_pure(0xAABBCCDD), 0xDDCCBBAA)
eq("bswap32 0x01", byte_swap32_pure(1), 0x01000000)
eq("bswap64 0x01..08", byte_swap64_pure(0x0102030405060708), 0x0807060504030201)

// ---- min/max ----
eq("min(3,5)", min_pure(3, 5), 3)
eq("min(-2,5)", min_pure(-2, 5), -2)
eq("max(3,5)", max_pure(3, 5), 5)
eq("max(-2,-7)", max_pure(-2, -7), -2)

println("===========================================================")
println("  Results: " + to_string(pass) + " passed, " + to_string(fail) + " failed")
println("===========================================================")
if fail == 0 {
    println("ALL PASS")
} else {
    println("SOME FAIL")
}
