// ═══════════════════════════════════════════════════════════════════
//  test_bit_pure.hexa — coverage for self/runtime/bit_pure.hexa
//
//  (0b binary literals are not supported by interp, use hex/decimal)
// ═══════════════════════════════════════════════════════════════════

// ── INLINED from runtime/bit_pure.hexa ──

@pure
fn pow2(n) {
    let mut r = 1
    let mut i = 0
    while i < n {
        r = r * 2
        i = i + 1
    }
    return r
}

@pure
pub fn bit_shl_pure(a, n) {
    if n <= 0 { return a }
    return a * pow2(n)
}

@pure
pub fn bit_shr_pure(a, n) {
    if n <= 0 { return a }
    return a / pow2(n)
}

@pure
pub fn bit_and_pure(a, b) { return a & b }

@pure
pub fn bit_xor_pure(a, b) { return a ^ b }

@pure
pub fn bit_or_pure(a, b) {
    return (a + b) - (a & b)
}

@pure
pub fn bit_not_pure(a, bits) {
    let n = -1 - a
    if bits == 32 {
        return n & 0xFFFFFFFF
    }
    return n
}

@pure
pub fn bit_test_pure(a, i) {
    let m = pow2(i)
    return (a & m) != 0
}

@pure
pub fn bit_set_pure(a, i) {
    let m = pow2(i)
    return bit_or_pure(a, m)
}

@pure
pub fn bit_clear_pure(a, i) {
    let m = pow2(i)
    let inv = bit_not_pure(m, 64)
    return a & inv
}

@pure
pub fn bit_toggle_pure(a, i) {
    let m = pow2(i)
    return a ^ m
}

@pure
pub fn popcount_pure(a) {
    let mut x = a
    if x < 0 { x = x & 0xFFFFFFFFFFFFFFFF }
    let mut c = 0
    while x != 0 {
        c = c + (x & 1)
        x = x / 2
    }
    return c
}

@pure
pub fn parity_pure(a) {
    return popcount_pure(a) & 1
}

@pure
pub fn leading_zeros_pure(a, bits) {
    if a == 0 { return bits }
    let mut c = 0
    let mut i = bits - 1
    while i >= 0 {
        let m = pow2(i)
        if (a & m) != 0 { return c }
        c = c + 1
        i = i - 1
    }
    return bits
}

@pure
pub fn trailing_zeros_pure(a) {
    if a == 0 { return 64 }
    let mut x = a
    let mut c = 0
    while (x & 1) == 0 {
        c = c + 1
        x = x / 2
    }
    return c
}

@pure
pub fn rotate_left_pure(a, n, bits) {
    let mask = if bits == 32 { 0xFFFFFFFF } else { 0xFFFFFFFFFFFFFFFF }
    let shift = n % bits
    if shift == 0 { return a & mask }
    let lo_raw = bit_shl_pure(a, shift)
    let lo = lo_raw & mask
    let hi_raw = a & mask
    let hi = bit_shr_pure(hi_raw, bits - shift)
    let mix = bit_or_pure(lo, hi)
    return mix & mask
}

@pure
pub fn rotate_right_pure(a, n, bits) {
    let mask = if bits == 32 { 0xFFFFFFFF } else { 0xFFFFFFFFFFFFFFFF }
    let shift = n % bits
    if shift == 0 { return a & mask }
    let hi = bit_shr_pure(a & mask, shift)
    let lo_raw = bit_shl_pure(a, bits - shift)
    let lo = lo_raw & mask
    let mix = bit_or_pure(lo, hi)
    return mix & mask
}

@pure
pub fn byte_swap32_pure(a) {
    let b0 = bit_shr_pure(a, 24) & 0xFF
    let b1 = bit_shr_pure(a, 16) & 0xFF
    let b2 = bit_shr_pure(a, 8)  & 0xFF
    let b3 =                 a   & 0xFF
    let s0 = bit_shl_pure(b3, 24)
    let s1 = bit_shl_pure(b2, 16)
    let s2 = bit_shl_pure(b1, 8)
    let p01 = bit_or_pure(s0, s1)
    let p23 = bit_or_pure(s2, b0)
    return bit_or_pure(p01, p23)
}

@pure
pub fn byte_swap64_pure(a) {
    let hi_raw = bit_shr_pure(a, 32) & 0xFFFFFFFF
    let lo_raw = a & 0xFFFFFFFF
    let hi = byte_swap32_pure(hi_raw)
    let lo = byte_swap32_pure(lo_raw)
    let shifted_lo = bit_shl_pure(lo, 32)
    return bit_or_pure(shifted_lo, hi)
}

@pure
pub fn min_pure(a, b) {
    if a < b { return a }
    return b
}

@pure
pub fn max_pure(a, b) {
    if a > b { return a }
    return b
}

// ── END INLINED ──

let mut pass = 0
let mut fail = 0

fn check(name, cond) {
    if cond {
        pass = pass + 1
    } else {
        fail = fail + 1
        println("[FAIL] " + name)
    }
}

fn eq(name, actual, expected) {
    let ok = actual == expected
    if ok {
        pass = pass + 1
    } else {
        fail = fail + 1
        println("[FAIL] " + name + " expected=" + to_string(expected) + " got=" + to_string(actual))
    }
}

println("=== bit_pure test suite ===")

// ---- basic bitwise ----
eq("or 10|5=15",   bit_or_pure(10, 5), 15)
eq("and 12&10=8",  bit_and_pure(12, 10), 8)
eq("xor 12^10=6",  bit_xor_pure(12, 10), 6)
eq("shl 1<<5=32",  bit_shl_pure(1, 5), 32)
eq("shr 32>>5=1",  bit_shr_pure(32, 5), 1)
eq("shl 1<<0=1",   bit_shl_pure(1, 0), 1)
eq("shl 7<<3=56",  bit_shl_pure(7, 3), 56)
eq("shr 56>>3=7",  bit_shr_pure(56, 3), 7)
eq("not32 mask",   bit_not_pure(0x00FF00FF, 32), 0xFF00FF00)

// ---- bit test/set/clear/toggle ----
check("test bit 0 of 1", bit_test_pure(1, 0))
check("test bit 3 of 8", bit_test_pure(8, 3))
check("test bit 2 of 10 false", !bit_test_pure(10, 2))
eq("set bit 2 of 0", bit_set_pure(0, 2), 4)
eq("clear bit 2 of 7", bit_clear_pure(7, 2), 3)
eq("toggle bit 1 of 5", bit_toggle_pure(5, 1), 7)
eq("toggle bit 1 of 7", bit_toggle_pure(7, 1), 5)
eq("set bit 4 of 0", bit_set_pure(0, 4), 16)

// ---- popcount ----
eq("popcount 0", popcount_pure(0), 0)
eq("popcount 1", popcount_pure(1), 1)
eq("popcount 15", popcount_pure(15), 4)
eq("popcount 255", popcount_pure(255), 8)
eq("popcount 0xFFFF", popcount_pure(0xFFFF), 16)
eq("popcount 7", popcount_pure(7), 3)

// ---- parity ----
eq("parity 0", parity_pure(0), 0)
eq("parity 1", parity_pure(1), 1)
eq("parity 3", parity_pure(3), 0)
eq("parity 7", parity_pure(7), 1)

// ---- leading/trailing zeros ----
eq("clz 0 (32)", leading_zeros_pure(0, 32), 32)
eq("clz 1 (32)", leading_zeros_pure(1, 32), 31)
eq("clz 0x80000000 (32)", leading_zeros_pure(0x80000000, 32), 0)
eq("clz 0xFF (32)", leading_zeros_pure(0xFF, 32), 24)

eq("ctz 1", trailing_zeros_pure(1), 0)
eq("ctz 2", trailing_zeros_pure(2), 1)
eq("ctz 8", trailing_zeros_pure(8), 3)
eq("ctz 256", trailing_zeros_pure(256), 8)

// ---- rotate (32-bit) ----
eq("rotl 1 by 1 (32)", rotate_left_pure(1, 1, 32), 2)
eq("rotl 0x80000000 by 1 (32)", rotate_left_pure(0x80000000, 1, 32), 1)
eq("rotr 2 by 1 (32)", rotate_right_pure(2, 1, 32), 1)
eq("rotr 1 by 1 (32)", rotate_right_pure(1, 1, 32), 0x80000000)
eq("rotl 0 always 0", rotate_left_pure(0, 7, 32), 0)

// ---- byte swap ----
eq("bswap32 AABBCCDD", byte_swap32_pure(0xAABBCCDD), 0xDDCCBBAA)
eq("bswap32 0x01", byte_swap32_pure(1), 0x01000000)
eq("bswap64 0x01..08", byte_swap64_pure(0x0102030405060708), 0x0807060504030201)

// ---- min/max ----
eq("min(3,5)", min_pure(3, 5), 3)
eq("min(-2,5)", min_pure(-2, 5), -2)
eq("max(3,5)", max_pure(3, 5), 5)
eq("max(-2,-7)", max_pure(-2, -7), -2)

println("===========================================================")
println("  Results: " + to_string(pass) + " passed, " + to_string(fail) + " failed")
println("===========================================================")
if fail == 0 {
    println("ALL PASS")
} else {
    println("SOME FAIL")
}
