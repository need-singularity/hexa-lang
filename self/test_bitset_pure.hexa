// ═══════════════════════════════════════════════════════════════════
//  test_bitset_pure.hexa — coverage for self/runtime/bitset_pure
// ═══════════════════════════════════════════════════════════════════

// ── inlined from self/runtime/bitset_pure.hexa ─────────────────────
// (import "runtime/bitset_pure.hexa" removed — codegen doesn't resolve
//  runtime/ imports for standalone test files; contents inlined instead)

let BS_WORD_BITS = 32
let BS_WORD_MASK = 0xFFFFFFFF

@pure
fn bs_words_for(nbits) {
    return (nbits + BS_WORD_BITS - 1) / BS_WORD_BITS
}

@pure
fn bs_shl(x, n) {
    let mut r = x
    let mut i = 0
    while i < n {
        r = r * 2
        i = i + 1
    }
    return r
}

@pure
fn bs_shr(x, n) {
    let mut r = x
    let mut i = 0
    while i < n {
        r = r / 2
        i = i + 1
    }
    return r
}

@pure
fn bs_or(a, b) {
    return (a + b) - (a & b)
}

pub fn bitset_new_pure(nbits) {
    let nwords = bs_words_for(nbits)
    let mut words = []
    let mut i = 0
    while i < nwords {
        words = words.push(0)
        i = i + 1
    }
    return #{ "words": words, "nbits": nbits }
}

@pure
fn bs_word_idx(i) {
    return i / BS_WORD_BITS
}

@pure
fn bs_bit_mask(i) {
    let off = i % BS_WORD_BITS
    return bs_shl(1, off)
}

@pure
fn bs_arr_with_at(arr, idx, val) {
    let n = len(arr)
    let mut out = []
    let mut k = 0
    while k < n {
        if k == idx {
            out = out.push(val)
        } else {
            out = out.push(arr[k])
        }
        k = k + 1
    }
    return out
}

pub fn bitset_set_pure(bs, i) {
    if i < 0 || i >= bs["nbits"] { return bs }
    let w = bs_word_idx(i)
    let m = bs_bit_mask(i)
    let words = bs["words"]
    let cur = words[w]
    let new_w = bs_or(cur, m)
    let new_words = bs_arr_with_at(words, w, new_w)
    return #{ "words": new_words, "nbits": bs["nbits"] }
}

pub fn bitset_clear_pure(bs, i) {
    if i < 0 || i >= bs["nbits"] { return bs }
    let w = bs_word_idx(i)
    let m = bs_bit_mask(i)
    let inv_m = (~m) & BS_WORD_MASK
    let words = bs["words"]
    let cur = words[w]
    let new_w = cur & inv_m
    let new_words = bs_arr_with_at(words, w, new_w)
    return #{ "words": new_words, "nbits": bs["nbits"] }
}

pub fn bitset_get_pure(bs, i) {
    if i < 0 || i >= bs["nbits"] { return false }
    let w = bs_word_idx(i)
    let m = bs_bit_mask(i)
    let cur = bs["words"][w]
    return (cur & m) != 0
}

pub fn bitset_flip_pure(bs, i) {
    if bitset_get_pure(bs, i) {
        return bitset_clear_pure(bs, i)
    }
    return bitset_set_pure(bs, i)
}

@pure
fn popcount32(n) {
    let mut x = n & BS_WORD_MASK
    let mut c = 0
    while x != 0 {
        c = c + (x & 1)
        x = bs_shr(x, 1)
    }
    return c
}

pub fn bitset_count_pure(bs) {
    let words = bs["words"]
    let n = len(words)
    let mut total = 0
    let mut i = 0
    while i < n {
        total = total + popcount32(words[i])
        i = i + 1
    }
    return total
}

pub fn bitset_union_pure(a, b) {
    if a["nbits"] != b["nbits"] { return a }
    let aw = a["words"]
    let bw = b["words"]
    let n = len(aw)
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(bs_or(aw[i], bw[i]))
        i = i + 1
    }
    return #{ "words": out, "nbits": a["nbits"] }
}

pub fn bitset_intersect_pure(a, b) {
    if a["nbits"] != b["nbits"] { return a }
    let aw = a["words"]
    let bw = b["words"]
    let n = len(aw)
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(aw[i] & bw[i])
        i = i + 1
    }
    return #{ "words": out, "nbits": a["nbits"] }
}

pub fn bitset_diff_pure(a, b) {
    if a["nbits"] != b["nbits"] { return a }
    let aw = a["words"]
    let bw = b["words"]
    let n = len(aw)
    let mut out = []
    let mut i = 0
    while i < n {
        let inv = (~bw[i]) & BS_WORD_MASK
        out = out.push(aw[i] & inv)
        i = i + 1
    }
    return #{ "words": out, "nbits": a["nbits"] }
}

pub fn bitset_eq_pure(a, b) {
    if a["nbits"] != b["nbits"] { return false }
    let aw = a["words"]
    let bw = b["words"]
    let n = len(aw)
    let mut i = 0
    while i < n {
        if (aw[i] & BS_WORD_MASK) != (bw[i] & BS_WORD_MASK) { return false }
        i = i + 1
    }
    return true
}

// ── end inlined bitset_pure ────────────────────────────────────────

let mut pass = 0
let mut fail = 0

fn check(name, cond) {
    if cond {
        pass = pass + 1
    } else {
        println("[FAIL] " + name)
        fail = fail + 1
    }
}

println("═══ bitset_pure test suite ═══")

// ── new / empty state ──────────────────────────────────────────────
let bs0 = bitset_new_pure(64)
check("empty count = 0", bitset_count_pure(bs0) == 0)
check("empty get(0) = false", !bitset_get_pure(bs0, 0))
check("empty get(63) = false", !bitset_get_pure(bs0, 63))

// ── set / get ──────────────────────────────────────────────────────
let bs1 = bitset_set_pure(bs0, 5)
check("set(5) then get(5)", bitset_get_pure(bs1, 5))
check("set(5) others still 0", !bitset_get_pure(bs1, 4))
check("set(5) others still 0 b", !bitset_get_pure(bs1, 6))
check("set(5) count = 1", bitset_count_pure(bs1) == 1)

// ── set multiple ───────────────────────────────────────────────────
let bs2 = bitset_set_pure(bs1, 10)
let bs3 = bitset_set_pure(bs2, 30)
let bs4 = bitset_set_pure(bs3, 63)
check("4 set bits count = 4", bitset_count_pure(bs4) == 4)
check("bit 5 set", bitset_get_pure(bs4, 5))
check("bit 10 set", bitset_get_pure(bs4, 10))
check("bit 30 set", bitset_get_pure(bs4, 30))
check("bit 63 set", bitset_get_pure(bs4, 63))
check("bit 0 clear", !bitset_get_pure(bs4, 0))

// ── clear ──────────────────────────────────────────────────────────
let bs5 = bitset_clear_pure(bs4, 10)
check("clear(10) then get = false", !bitset_get_pure(bs5, 10))
check("clear(10) count = 3", bitset_count_pure(bs5) == 3)

// ── flip ───────────────────────────────────────────────────────────
let bs6 = bitset_flip_pure(bs0, 7)
check("flip(7) on empty → set", bitset_get_pure(bs6, 7))
let bs7 = bitset_flip_pure(bs6, 7)
check("flip(7) again → cleared", !bitset_get_pure(bs7, 7))

// ── bounds ─────────────────────────────────────────────────────────
let bs_bad = bitset_set_pure(bs0, 100)
check("set OOB no-op count", bitset_count_pure(bs_bad) == 0)
check("get OOB = false", !bitset_get_pure(bs0, 100))
check("get negative = false", !bitset_get_pure(bs0, -1))

// ── cross-word boundary (word 0 / word 1 at bit 32) ───────────────
let bsA = bitset_set_pure(bs0, 31)
let bsB = bitset_set_pure(bsA, 32)
check("bit 31 set", bitset_get_pure(bsB, 31))
check("bit 32 set", bitset_get_pure(bsB, 32))
check("cross-word count = 2", bitset_count_pure(bsB) == 2)

// ── union ──────────────────────────────────────────────────────────
let a1 = bitset_set_pure(bitset_new_pure(16), 1)
let a2 = bitset_set_pure(a1, 2)
let b1 = bitset_set_pure(bitset_new_pure(16), 2)
let b2 = bitset_set_pure(b1, 3)
let u = bitset_union_pure(a2, b2)
check("union has 1", bitset_get_pure(u, 1))
check("union has 2", bitset_get_pure(u, 2))
check("union has 3", bitset_get_pure(u, 3))
check("union not 0", !bitset_get_pure(u, 0))
check("union count = 3", bitset_count_pure(u) == 3)

// ── intersect ──────────────────────────────────────────────────────
let isect = bitset_intersect_pure(a2, b2)
check("isect has 2 only", bitset_get_pure(isect, 2))
check("isect not 1", !bitset_get_pure(isect, 1))
check("isect not 3", !bitset_get_pure(isect, 3))
check("isect count = 1", bitset_count_pure(isect) == 1)

// ── diff (a - b) ───────────────────────────────────────────────────
let d = bitset_diff_pure(a2, b2)
check("diff has 1", bitset_get_pure(d, 1))
check("diff not 2", !bitset_get_pure(d, 2))
check("diff not 3", !bitset_get_pure(d, 3))
check("diff count = 1", bitset_count_pure(d) == 1)

// ── eq ─────────────────────────────────────────────────────────────
let e1 = bitset_set_pure(bitset_set_pure(bitset_new_pure(16), 1), 2)
let e2 = bitset_set_pure(bitset_set_pure(bitset_new_pure(16), 1), 2)
check("eq same bits", bitset_eq_pure(e1, e2))
let e3 = bitset_set_pure(bitset_new_pure(16), 1)
check("eq diff bits = false", !bitset_eq_pure(e1, e3))
let e4 = bitset_new_pure(32)
check("eq diff nbits = false", !bitset_eq_pure(e1, e4))

// ── all-bits pattern ───────────────────────────────────────────────
let mut all = bitset_new_pure(8)
let mut i = 0
while i < 8 {
    all = bitset_set_pure(all, i)
    i = i + 1
}
check("all 8 bits set count = 8", bitset_count_pure(all) == 8)

// ── summary ────────────────────────────────────────────────────────
println("═══════════════════════════════════════════════════════")
println("  PASS: " + to_string(pass))
println("  FAIL: " + to_string(fail))
if fail == 0 {
    println("[ALL PASS] bitset_pure verified")
} else {
    println("[FAIL] bitset_pure has " + to_string(fail) + " failures")
}
