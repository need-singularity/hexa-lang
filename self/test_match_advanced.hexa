// ═══════════════════════════════════════════════════════════
//  test_match_advanced.hexa — Advanced Match Expression Tests
//  Tests: nested match, match in functions, match with computation,
//         match chains, match as expression, match with blocks,
//         match with complex patterns, match and control flow
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA Advanced Match Expression Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Match as expression in let binding ────────────────

println("--- Match as Expression ---")

let x = 3
let label = match x {
    1 -> "one",
    2 -> "two",
    3 -> "three",
    _ -> "many"
}
check("match expr let", label, "three")

let big = match 1000 {
    1 -> "small",
    _ -> "big"
}
check("match expr wildcard", big, "big")

// ── 2. Match with block bodies ───────────────────────────

println("")
println("--- Match Block Body ---")

let val = 2
let result1 = match val {
    1 -> {
        let a = 10
        a + 1
    },
    2 -> {
        let a = 20
        let b = 5
        a + b
    },
    _ -> 0
}
check("match block 2", result1, 25)

let result1b = match 1 {
    1 -> {
        let a = 10
        a + 1
    },
    _ -> 0
}
check("match block 1", result1b, 11)

// ── 3. Nested match expressions ──────────────────────────

println("")
println("--- Nested Match ---")

fn classify(x, y) {
    return match x {
        0 -> match y {
            0 -> "origin",
            _ -> "y-axis"
        },
        _ -> match y {
            0 -> "x-axis",
            _ -> "plane"
        }
    }
}
check("nested origin", classify(0, 0), "origin")
check("nested y-axis", classify(0, 5), "y-axis")
check("nested x-axis", classify(3, 0), "x-axis")
check("nested plane", classify(3, 5), "plane")

// ── 4. Match with computed values ────────────────────────

println("")
println("--- Match Computed ---")

fn grade(score) {
    let tier = score / 10
    return match tier {
        10 -> "A+",
        9 -> "A",
        8 -> "B",
        7 -> "C",
        6 -> "D",
        _ -> "F"
    }
}
check("grade 100", grade(100), "A+")
check("grade 95", grade(95), "A")
check("grade 85", grade(85), "B")
check("grade 75", grade(75), "C")
check("grade 65", grade(65), "D")
check("grade 50", grade(50), "F")

// ── 5. Match in loop ─────────────────────────────────────

println("")
println("--- Match in Loop ---")

let mut counts = #{"fizz": 0, "buzz": 0, "fizzbuzz": 0, "num": 0}
let mut i = 1
while i <= 15 {
    let fb = match i % 15 {
        0 -> "fizzbuzz",
        _ -> match i % 3 {
            0 -> "fizz",
            _ -> match i % 5 {
                0 -> "buzz",
                _ -> "num"
            }
        }
    }
    counts[fb] = counts[fb] + 1
    i = i + 1
}
check("fizzbuzz count", counts["fizzbuzz"], 1)
check("fizz count", counts["fizz"], 4)
check("buzz count", counts["buzz"], 2)
check("num count", counts["num"], 8)

// ── 6. Match returning functions ─────────────────────────

println("")
println("--- Match Returns Fn ---")

fn get_op(name) {
    return match name {
        "add" -> |a, b| a + b,
        "sub" -> |a, b| a - b,
        "mul" -> |a, b| a * b,
        _ -> |a, b| 0
    }
}
let op_add = get_op("add")
let op_sub = get_op("sub")
let op_mul = get_op("mul")
let op_unk = get_op("??")
check("match fn add", op_add(3, 4), 7)
check("match fn sub", op_sub(10, 3), 7)
check("match fn mul", op_mul(6, 7), 42)
check("match fn unk", op_unk(1, 2), 0)

// ── 7. Match with string patterns ────────────────────────

println("")
println("--- Match String Patterns ---")

fn parse_cmd(cmd) {
    return match cmd {
        "quit" -> 0,
        "help" -> 1,
        "list" -> 2,
        "add" -> 3,
        "del" -> 4,
        _ -> -1
    }
}
check("cmd quit", parse_cmd("quit"), 0)
check("cmd help", parse_cmd("help"), 1)
check("cmd list", parse_cmd("list"), 2)
check("cmd unknown", parse_cmd("foo"), -1)

// ── 8. Match with bool ───────────────────────────────────

println("")
println("--- Match Bool Advanced ---")

fn check_sign(n) {
    let pos = n > 0
    let zero = n == 0
    return match pos {
        true -> "+",
        _ -> match zero {
            true -> "0",
            _ -> "-"
        }
    }
}
check("sign +", check_sign(5), "+")
check("sign -", check_sign(-3), "-")
check("sign 0", check_sign(0), "0")

// ── 9. Match chained with computation ────────────────────

println("")
println("--- Match Chain ---")

fn day_type(day) {
    let code = match day {
        "mon" -> 1,
        "tue" -> 2,
        "wed" -> 3,
        "thu" -> 4,
        "fri" -> 5,
        "sat" -> 6,
        "sun" -> 7,
        _ -> 0
    }
    return match code {
        6 -> "weekend",
        7 -> "weekend",
        0 -> "invalid",
        _ -> "weekday"
    }
}
check("day mon", day_type("mon"), "weekday")
check("day sat", day_type("sat"), "weekend")
check("day sun", day_type("sun"), "weekend")
check("day bad", day_type("xyz"), "invalid")

// ── 10. Match as argument ────────────────────────────────

println("")
println("--- Match as Arg ---")

fn double(x) { return x * 2 }

let r10 = double(match 3 {
    3 -> 10,
    _ -> 0
})
check("match as arg", r10, 20)

// ── Summary ──────────────────────────────────────────────

println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    throw "TESTS FAILED: " + to_string(fail_count)
}
