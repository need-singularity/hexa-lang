// self/type_checker.hexa — HEXA type checker written in HEXA (Stage 3 of self-hosting)
// Validates: variable scope, function arity, type mismatches, return consistency.
// Takes AST nodes from parser.hexa and produces errors or a validated AST.

// ══════════════════════════════════════════════════════════════
// Shared structs (same as parser.hexa — inlined until modules exist)
// ══════════════════════════════════════════════════════════════

struct Token {
    kind: string,
    value: string,
    line: int,
    col: int
}

struct AstNode {
    kind: string,
    name: string,
    value: string,
    op: string,
    left: string,
    right: string,
    cond: string,
    then_body: string,
    else_body: string,
    params: string,
    body: string,
    args: string,
    fields: string,
    items: string,
    variants: string,
    arms: string,
    iter_expr: string,
    ret_type: string,
    target: string,
    trait_name: string,
    methods: string
}

// ══════════════════════════════════════════════════════════════
// Type representation — simple string tags
// ══════════════════════════════════════════════════════════════
// Types: "int", "float", "bool", "string", "char", "void", "any", "unknown",
//        "array", "fn", struct names (uppercase)

// ══════════════════════════════════════════════════════════════
// Error collection
// ══════════════════════════════════════════════════════════════

struct TypeError {
    message: string,
    name: string
}

let mut tc_errors = []

fn tc_error(msg) {
    tc_errors = tc_errors.push(TypeError { message: msg, name: "" })
}

fn tc_error_at(name, msg) {
    tc_errors = tc_errors.push(TypeError { message: msg, name: name })
}

// ══════════════════════════════════════════════════════════════
// Scope — variable/function symbol tables
// ══════════════════════════════════════════════════════════════
// We use parallel arrays: scope_names[], scope_types[], scope_depths[]
// A new scope increments tc_depth; leaving a scope pops entries.

let mut scope_names = []
let mut scope_types = []
let mut scope_depths = []
let mut tc_depth = 0

// Function registry: fn_names[], fn_arities[], fn_ret_types[]
let mut fn_names = []
let mut fn_arities = []
let mut fn_ret_types = []

// Struct registry: struct_names[], struct_field_names[], struct_field_types[]
let mut struct_names = []
let mut struct_field_counts = []

fn tc_push_scope() {
    tc_depth = tc_depth + 1
}

fn tc_pop_scope() {
    // Remove all entries at current depth
    let mut new_names = []
    let mut new_types = []
    let mut new_depths = []
    let mut i = 0
    while i < len(scope_names) {
        if scope_depths[i] < tc_depth {
            new_names = new_names.push(scope_names[i])
            new_types = new_types.push(scope_types[i])
            new_depths = new_depths.push(scope_depths[i])
        }
        i = i + 1
    }
    scope_names = new_names
    scope_types = new_types
    scope_depths = new_depths
    tc_depth = tc_depth - 1
}

fn tc_define(name, typ) {
    scope_names = scope_names.push(name)
    scope_types = scope_types.push(typ)
    scope_depths = scope_depths.push(tc_depth)
}

fn tc_lookup(name) {
    // Search from end (most recent scope first)
    let mut i = len(scope_names) - 1
    while i >= 0 {
        if scope_names[i] == name {
            return scope_types[i]
        }
        i = i - 1
    }
    return ""
}

fn tc_register_fn(name, arity, ret_type) {
    fn_names = fn_names.push(name)
    fn_arities = fn_arities.push(arity)
    fn_ret_types = fn_ret_types.push(ret_type)
}

fn tc_lookup_fn_arity(name) {
    let mut i = 0
    while i < len(fn_names) {
        if fn_names[i] == name {
            return fn_arities[i]
        }
        i = i + 1
    }
    return -1
}

fn tc_lookup_fn_ret(name) {
    let mut i = 0
    while i < len(fn_names) {
        if fn_names[i] == name {
            return fn_ret_types[i]
        }
        i = i + 1
    }
    return "unknown"
}

fn tc_register_struct(name, field_count) {
    struct_names = struct_names.push(name)
    struct_field_counts = struct_field_counts.push(field_count)
}

fn tc_lookup_struct(name) {
    let mut i = 0
    while i < len(struct_names) {
        if struct_names[i] == name {
            return struct_field_counts[i]
        }
        i = i + 1
    }
    return -1
}

// ══════════════════════════════════════════════════════════════
// Built-in function registry
// ══════════════════════════════════════════════════════════════

fn tc_register_builtins() {
    // Vararg builtins: arity = -1 means any
    tc_register_fn("println", -1, "void")
    tc_register_fn("print", -1, "void")
    tc_register_fn("format", -1, "string")
    tc_register_fn("len", 1, "int")
    tc_register_fn("to_string", 1, "string")
    tc_register_fn("is_alpha", 1, "bool")
    tc_register_fn("is_digit", 1, "bool")
    tc_register_fn("is_alphanumeric", 1, "bool")
    tc_register_fn("read_file", 1, "string")
    tc_register_fn("type_of", 1, "string")
    tc_register_fn("int", 1, "int")
    tc_register_fn("float", 1, "float")
    tc_register_fn("string", 1, "string")
    tc_register_fn("push", 2, "array")
    tc_register_fn("sigma", 1, "int")
    tc_register_fn("phi", 1, "int")
    tc_register_fn("tau", 1, "int")
}

// ══════════════════════════════════════════════════════════════
// Type annotation parser
// ══════════════════════════════════════════════════════════════

fn annotation_to_type(ann) {
    if ann == "" { return "unknown" }
    if ann == "int" { return "int" }
    if ann == "float" { return "float" }
    if ann == "bool" { return "bool" }
    if ann == "string" { return "string" }
    if ann == "char" { return "char" }
    if ann == "void" { return "void" }
    if ann == "any" { return "any" }
    if ann == "array" { return "array" }
    // Uppercase = struct name
    return ann
}

// ══════════════════════════════════════════════════════════════
// Type compatibility check
// ══════════════════════════════════════════════════════════════

fn types_compatible(expected, actual) {
    if expected == "unknown" { return true }
    if actual == "unknown" { return true }
    if expected == "any" { return true }
    if actual == "any" { return true }
    if expected == actual { return true }
    // int -> float coercion
    if expected == "float" && actual == "int" { return true }
    return false
}

// ══════════════════════════════════════════════════════════════
// Expression type inference
// ══════════════════════════════════════════════════════════════

fn tc_infer_expr(node) {
    if node == "" { return "void" }

    let k = node.kind

    if k == "IntLit" { return "int" }
    if k == "FloatLit" { return "float" }
    if k == "BoolLit" { return "bool" }
    if k == "StringLit" { return "string" }
    if k == "CharLit" { return "char" }
    if k == "Array" { return "array" }
    if k == "Tuple" { return "tuple" }
    if k == "Wildcard" { return "any" }
    if k == "Range" {
        tc_infer_expr(node.left)
        tc_infer_expr(node.right)
        return "range"
    }
    if k == "Lambda" { return "fn" }

    if k == "Ident" {
        let typ = tc_lookup(node.name)
        if typ == "" {
            tc_error("Undeclared variable '" + node.name + "'")
            return "unknown"
        }
        return typ
    }

    if k == "BinOp" {
        let lt = tc_infer_expr(node.left)
        let rt = tc_infer_expr(node.right)
        let op = node.op
        // Comparison operators return bool
        if op == "==" || op == "!=" || op == "<" || op == ">" || op == "<=" || op == ">=" {
            return "bool"
        }
        // Logical operators return bool
        if op == "&&" || op == "||" || op == "^^" {
            if lt != "bool" && lt != "unknown" {
                tc_error("Logical operator '" + op + "' expects bool, got '" + lt + "'")
            }
            if rt != "bool" && rt != "unknown" {
                tc_error("Logical operator '" + op + "' expects bool, got '" + rt + "'")
            }
            return "bool"
        }
        // Arithmetic: + on strings = concatenation
        if op == "+" {
            if lt == "string" || rt == "string" {
                return "string"
            }
        }
        // Arithmetic operators
        if op == "+" || op == "-" || op == "*" || op == "/" || op == "%" || op == "**" {
            if lt == "float" || rt == "float" {
                return "float"
            }
            if lt == "int" && rt == "int" {
                return "int"
            }
            // Check for type mismatch
            if !types_compatible(lt, rt) && lt != "unknown" && rt != "unknown" {
                tc_error("Arithmetic type mismatch: '" + lt + "' " + op + " '" + rt + "'")
            }
            return lt
        }
        return "unknown"
    }

    if k == "UnaryOp" {
        let ot = tc_infer_expr(node.left)
        if node.op == "!" {
            if ot != "bool" && ot != "unknown" {
                tc_error("'!' operator expects bool, got '" + ot + "'")
            }
            return "bool"
        }
        if node.op == "-" {
            return ot
        }
        return ot
    }

    if k == "Call" {
        // Infer callee
        let callee = node.left
        let arg_count = len(node.args)
        // Check each argument
        let mut i = 0
        while i < arg_count {
            tc_infer_expr(node.args[i])
            i = i + 1
        }
        // Direct function call: callee is Ident
        if callee.kind == "Ident" {
            let fn_arity = tc_lookup_fn_arity(callee.name)
            if fn_arity == -1 {
                // Unknown function — might be user-defined later or a method
                return "unknown"
            }
            // -1 arity means vararg
            if fn_arity >= 0 && fn_arity != arg_count {
                tc_error("Function '" + callee.name + "' expects " + to_string(fn_arity) + " args, got " + to_string(arg_count))
            }
            return tc_lookup_fn_ret(callee.name)
        }
        // Method call: callee is Field
        if callee.kind == "Field" {
            tc_infer_expr(callee.left)
            // Method calls are permissive
            return "unknown"
        }
        return "unknown"
    }

    if k == "Field" {
        tc_infer_expr(node.left)
        return "unknown"
    }

    if k == "Index" {
        tc_infer_expr(node.left)
        let idx_type = tc_infer_expr(node.right)
        if idx_type != "int" && idx_type != "unknown" {
            tc_error("Array index must be int, got '" + idx_type + "'")
        }
        return "unknown"
    }

    if k == "IfExpr" {
        let cond_type = tc_infer_expr(node.cond)
        if cond_type != "bool" && cond_type != "unknown" {
            tc_error("If condition must be bool, got '" + cond_type + "'")
        }
        tc_push_scope()
        tc_check_stmts(node.then_body)
        tc_pop_scope()
        if node.else_body != "" && len(node.else_body) > 0 {
            tc_push_scope()
            tc_check_stmts(node.else_body)
            tc_pop_scope()
        }
        return "unknown"
    }

    if k == "MatchExpr" {
        tc_infer_expr(node.left)
        let mut i = 0
        while i < len(node.arms) {
            let arm = node.arms[i]
            tc_push_scope()
            tc_check_stmts(arm.body)
            tc_pop_scope()
            i = i + 1
        }
        return "unknown"
    }

    if k == "StructInit" {
        let sc = tc_lookup_struct(node.name)
        if sc == -1 {
            tc_error("Unknown struct '" + node.name + "'")
        }
        // Check field init expressions
        let mut i = 0
        while i < len(node.fields) {
            tc_infer_expr(node.fields[i].left)
            i = i + 1
        }
        return node.name
    }

    if k == "EnumPath" {
        return node.name
    }

    return "unknown"
}

// ══════════════════════════════════════════════════════════════
// Statement checking
// ══════════════════════════════════════════════════════════════

fn tc_check_stmt(node) {
    let k = node.kind

    if k == "LetStmt" || k == "LetMutStmt" {
        let typ = tc_infer_expr(node.left)
        let ann = annotation_to_type(node.value)
        if ann != "unknown" && !types_compatible(ann, typ) {
            tc_error_at(node.name, "Type mismatch: declared '" + ann + "' but assigned '" + typ + "'")
        }
        if ann != "unknown" {
            tc_define(node.name, ann)
        } else {
            tc_define(node.name, typ)
        }
        return
    }

    if k == "ConstStmt" || k == "StaticStmt" {
        let typ = tc_infer_expr(node.left)
        let ann = annotation_to_type(node.value)
        if ann != "unknown" {
            tc_define(node.name, ann)
        } else {
            tc_define(node.name, typ)
        }
        return
    }

    if k == "FnDecl" {
        let arity = len(node.params)
        let ret = annotation_to_type(node.ret_type)
        tc_register_fn(node.name, arity, ret)
        tc_define(node.name, "fn")
        tc_push_scope()
        // Define parameters
        let mut i = 0
        while i < arity {
            let p = node.params[i]
            let ptype = annotation_to_type(p.value)
            tc_define(p.name, ptype)
            i = i + 1
        }
        // Check body
        tc_check_stmts(node.body)
        tc_pop_scope()
        return
    }

    if k == "StructDecl" {
        tc_register_struct(node.name, len(node.fields))
        tc_define(node.name, "type")
        return
    }

    if k == "EnumDecl" {
        tc_define(node.name, "type")
        return
    }

    if k == "TraitDecl" {
        tc_define(node.name, "type")
        return
    }

    if k == "ImplBlock" {
        tc_push_scope()
        let mut i = 0
        while i < len(node.methods) {
            tc_check_stmt(node.methods[i])
            i = i + 1
        }
        tc_pop_scope()
        return
    }

    if k == "ForStmt" {
        tc_infer_expr(node.iter_expr)
        tc_push_scope()
        tc_define(node.name, "unknown")
        tc_check_stmts(node.body)
        tc_pop_scope()
        return
    }

    if k == "WhileStmt" {
        let cond_type = tc_infer_expr(node.cond)
        if cond_type != "bool" && cond_type != "unknown" {
            tc_error("While condition must be bool, got '" + cond_type + "'")
        }
        tc_push_scope()
        tc_check_stmts(node.body)
        tc_pop_scope()
        return
    }

    if k == "LoopStmt" {
        tc_push_scope()
        tc_check_stmts(node.body)
        tc_pop_scope()
        return
    }

    if k == "ReturnStmt" {
        if node.left != "" {
            tc_infer_expr(node.left)
        }
        return
    }

    if k == "AssignStmt" {
        // Check LHS is declared
        if node.left != "" && node.left.kind == "Ident" {
            let typ = tc_lookup(node.left.name)
            if typ == "" {
                tc_error("Assignment to undeclared variable '" + node.left.name + "'")
            }
        }
        tc_infer_expr(node.left)
        tc_infer_expr(node.right)
        return
    }

    if k == "ExprStmt" {
        tc_infer_expr(node.left)
        return
    }

    if k == "AssertStmt" {
        let t = tc_infer_expr(node.left)
        if t != "bool" && t != "unknown" {
            tc_error("Assert expects bool expression, got '" + t + "'")
        }
        return
    }

    if k == "UseStmt" { return }
    if k == "ModStmt" { return }
    if k == "ProofStmt" {
        tc_push_scope()
        tc_check_stmts(node.body)
        tc_pop_scope()
        return
    }
}

fn tc_check_stmts(stmts) {
    if stmts == "" { return }
    let mut i = 0
    while i < len(stmts) {
        tc_check_stmt(stmts[i])
        i = i + 1
    }
}

// ══════════════════════════════════════════════════════════════
// First pass: collect all top-level declarations
// ══════════════════════════════════════════════════════════════

fn tc_first_pass(stmts) {
    let mut i = 0
    while i < len(stmts) {
        let s = stmts[i]
        if s.kind == "FnDecl" {
            tc_register_fn(s.name, len(s.params), annotation_to_type(s.ret_type))
            tc_define(s.name, "fn")
        }
        if s.kind == "StructDecl" {
            tc_register_struct(s.name, len(s.fields))
            tc_define(s.name, "type")
        }
        if s.kind == "EnumDecl" {
            tc_define(s.name, "type")
        }
        if s.kind == "TraitDecl" {
            tc_define(s.name, "type")
        }
        i = i + 1
    }
}

// ══════════════════════════════════════════════════════════════
// Public API
// ══════════════════════════════════════════════════════════════

fn type_check(stmts) {
    // Reset state
    tc_errors = []
    scope_names = []
    scope_types = []
    scope_depths = []
    tc_depth = 0
    fn_names = []
    fn_arities = []
    fn_ret_types = []
    struct_names = []
    struct_field_counts = []

    // Register builtins
    tc_register_builtins()

    // First pass: collect declarations (allows forward references)
    tc_first_pass(stmts)

    // Second pass: full type checking
    tc_check_stmts(stmts)

    return tc_errors
}

fn type_check_ok(stmts) {
    let errors = type_check(stmts)
    return len(errors) == 0
}

fn print_type_errors(errors) {
    let mut i = 0
    while i < len(errors) {
        let e = errors[i]
        if e.name != "" {
            println(format("  TYPE ERROR [{}]: {}", e.name, e.message))
        } else {
            println(format("  TYPE ERROR: {}", e.message))
        }
        i = i + 1
    }
}
