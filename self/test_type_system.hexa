// ═══════════════════════════════════════════════════════════
//  test_type_system.hexa — Type System Tests
//  Tests: type_of, type coercion, primitives (int, float, string,
//         bool, array, map), conversions, BigInt, null/error handling,
//         heterogeneous collections, map operations
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA Type System Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. type_of for primitives ─────────────────────────────

println("--- type_of Primitives ---")

check("type_of int", type_of(42), "int")
check("type_of zero", type_of(0), "int")
check("type_of neg int", type_of(-5), "int")
check("type_of float", type_of(3.14), "float")
check("type_of float zero", type_of(0.0), "float")
check("type_of neg float", type_of(-2.5), "float")
check("type_of string", type_of("hello"), "string")
check("type_of empty string", type_of(""), "string")
check("type_of bool true", type_of(true), "bool")
check("type_of bool false", type_of(false), "bool")
check("type_of array", type_of([1, 2, 3]), "array")
check("type_of empty array", type_of([]), "array")
check("type_of map", type_of(#{}), "map")
check("type_of map with data", type_of(#{ "a": 1 }), "map")

// ── 2. type_of computed values ────────────────────────────

println("")
println("--- type_of Computed Values ---")

check("type_of int+int", type_of(3 + 4), "int")
check("type_of int*int", type_of(6 * 7), "int")
check("type_of float+float", type_of(1.5 + 2.5), "float")
check("type_of int+float", type_of(3 + 2.5), "float")
check("type_of float+int", type_of(2.0 + 3), "float")
check("type_of str+str", type_of("a" + "b"), "string")
check("type_of comparison", type_of(3 > 2), "bool")
check("type_of logical", type_of(true && false), "bool")

// ── 3. Int-Float coercion ─────────────────────────────────

println("")
println("--- Int-Float Coercion ---")

check("int + float = float", 3 + 2.5, 5.5)
check("float + int = float", 2.0 + 3, 5.0)
check("int * float = float", 10 * 2.0, 20.0)
check("float * int = float", 3.5 * 2, 7.0)
check("int - float = float", 10 - 2.5, 7.5)
check("float - int = float", 10.0 - 3, 7.0)
check("int / float = float", 7 / 2.0, 3.5)
check("float / int = float", 9.0 / 2, 4.5)
check("coerced type is float", type_of(3 + 2.5), "float")
check("coerced mul type", type_of(10 * 2.0), "float")

// ── 4. to_string conversions ──────────────────────────────

println("")
println("--- to_string Conversions ---")

check("to_string int", to_string(42), "42")
check("to_string neg int", to_string(-7), "-7")
check("to_string zero", to_string(0), "0")
check("to_string bool true", to_string(true), "true")
check("to_string bool false", to_string(false), "false")
check("to_string string", to_string("hello"), "hello")
check("to_string float 3.14", to_string(3.14), "3.14")
check("to_string array", to_string([1, 2, 3]), "[1, 2, 3]")

// ── 5. to_int conversions ─────────────────────────────────

println("")
println("--- to_int Conversions ---")

check("to_int from string", to_int("123"), 123)
check("to_int from neg string", to_int("-42"), -42)
check("to_int from zero string", to_int("0"), 0)
check("to_int from float", to_int(3.99), 3)
check("to_int from float neg", to_int(-2.7), -2)
check("to_int from float zero", to_int(0.0), 0)
check("to_int result type", type_of(to_int("5")), "int")

// ── 6. to_float conversions ───────────────────────────────

println("")
println("--- to_float Conversions ---")

check("to_float from int", to_float(42), 42.0)
check("to_float from string", to_float("3.14"), 3.14)
check("to_float from neg string", to_float("-2.5"), -2.5)
check("to_float from zero", to_float(0), 0.0)
check("to_float result type", type_of(to_float(42)), "float")
check("to_float from int string", to_float("100"), 100.0)

// ── 7. Invalid conversion error handling ──────────────────

println("")
println("--- Conversion Error Handling ---")

let mut caught_int = false
try {
    let x = to_int("abc")
} catch e {
    caught_int = true
}
check("to_int invalid catches", caught_int, true)

let mut caught_float = false
try {
    let x = to_float("not_a_number")
} catch e {
    caught_float = true
}
check("to_float invalid catches", caught_float, true)

// ── 8. Array type features ────────────────────────────────

println("")
println("--- Array Types ---")

let arr_int = [1, 2, 3, 4, 5]
check("array of ints type", type_of(arr_int), "array")
check("array element type", type_of(arr_int[0]), "int")

let arr_str = ["a", "b", "c"]
check("array of strings type", type_of(arr_str), "array")
check("array str element type", type_of(arr_str[0]), "string")

// NOTE: Hexa enforces homogeneous arrays — mixed type arrays are a type error
let arr_float = [1.0, 2.5, 3.14]
check("float array type", type_of(arr_float), "array")
check("float arr[0] type", type_of(arr_float[0]), "float")
check("float arr[2] type", type_of(arr_float[2]), "float")

let arr_bool = [true, false, true]
check("bool array type", type_of(arr_bool), "array")
check("bool arr[0] type", type_of(arr_bool[0]), "bool")
check("bool arr[1] type", type_of(arr_bool[1]), "bool")

let nested = [[1, 2], [3, 4]]
check("nested array type", type_of(nested), "array")
check("nested inner type", type_of(nested[0]), "array")
check("nested element type", type_of(nested[0][0]), "int")

// ── 9. Map type features ─────────────────────────────────

println("")
println("--- Map Types ---")

let m = #{ "x": 10, "y": 20, "name": "test" }
check("map type", type_of(m), "map")
check("map access int", m["x"], 10)
check("map access string", m["name"], "test")
check("map len", len(m), 3)
check("map element type int", type_of(m["x"]), "int")
check("map element type str", type_of(m["name"]), "string")

let m2 = #{}
check("empty map type", type_of(m2), "map")
check("empty map len", len(m2), 0)

let m3 = #{ "a": 1, "b": "two", "c": true, "d": 3.14 }
check("map mixed val types", len(m3), 4)
check("map bool val type", type_of(m3["c"]), "bool")
check("map float val type", type_of(m3["d"]), "float")

let keys = m.keys()
check("map keys len", len(keys), 3)
check("map keys type", type_of(keys), "array")

let vals = m.values()
check("map values len", len(vals), 3)
check("map values type", type_of(vals), "array")

check("map contains_key true", m.contains_key("x"), true)
check("map contains_key false", m.contains_key("z"), false)

// ── 10. BigInt type ───────────────────────────────────────

println("")
println("--- BigInt ---")

let big1 = bigint("123456789012345678901234567890")
check("bigint type", type_of(big1), "bigint")
check("bigint to_string", to_string(big1), "123456789012345678901234567890")

let big2 = bigint("987654321098765432109876543210")
let big_sum = big1 + big2
check("bigint add", to_string(big_sum), "1111111110111111111011111111100")
check("bigint add type", type_of(big_sum), "bigint")

let big_mul = bigint("10") * bigint("20")
check("bigint mul", to_string(big_mul), "200")

let big_sub = bigint("100") - bigint("30")
check("bigint sub", to_string(big_sub), "70")

check("bigint zero", to_string(bigint("0")), "0")
check("bigint one", to_string(bigint("1")), "1")

let big_cmp = bigint("100") > bigint("50")
check("bigint compare gt", big_cmp, true)

let big_eq = bigint("42") == bigint("42")
check("bigint equality", big_eq, true)

let big_neq = bigint("42") != bigint("43")
check("bigint inequality", big_neq, true)

// ── 11. Boolean truthiness ────────────────────────────────

println("")
println("--- Boolean Values ---")

check("true is true", true, true)
check("false is false", false, false)
check("not true", !true, false)
check("not false", !false, true)
check("double not true", !!true, true)
check("double not false", !!false, false)
check("bool from comparison", 5 > 3, true)
check("bool from eq", 5 == 5, true)
check("bool from neq", 5 != 5, false)

// ── 12. String type details ───────────────────────────────

println("")
println("--- String Type Details ---")

check("empty string len", len(""), 0)
check("single char len", len("a"), 1)
check("string equality", "hello" == "hello", true)
check("string inequality", "hello" != "world", true)
check("string concat type", type_of("a" + "b"), "string")
check("string with number concat", "count: " + to_string(42), "count: 42")
// NOTE: string < / > not supported in runtime — only == and != work
check("string eq same ref", "test" == "test", true)
check("string neq diff", "aaa" != "bbb", true)

// ── 13. Type preservation through functions ───────────────

println("")
println("--- Type Preservation ---")

fn identity(x) { return x }
check("identity int type", type_of(identity(42)), "int")
check("identity float type", type_of(identity(3.14)), "float")
check("identity string type", type_of(identity("hello")), "string")
check("identity bool type", type_of(identity(true)), "bool")
check("identity array type", type_of(identity([1, 2])), "array")

fn add(a, b) { return a + b }
check("fn int+int type", type_of(add(3, 4)), "int")
check("fn int+float type", type_of(add(3, 4.0)), "float")
check("fn str+str type", type_of(add("a", "b")), "string")

// ── 14. Division type behavior ────────────────────────────

println("")
println("--- Division Types ---")

check("int / int exact", 10 / 2, 5)
check("int / int truncate", 7 / 2, 3)
check("float / float", 7.0 / 2.0, 3.5)
check("int / float = float", 7 / 2.0, 3.5)
check("float / int = float", 7.0 / 2, 3.5)

// ── 15. Division by zero error ────────────────────────────

println("")
println("--- Division by Zero ---")

let mut div_zero_caught = false
try {
    let x = 10 / 0
} catch e {
    div_zero_caught = true
}
check("div by zero caught", div_zero_caught, true)

let mut mod_zero_caught = false
try {
    let x = 10 % 0
} catch e {
    mod_zero_caught = true
}
check("mod by zero caught", mod_zero_caught, true)

// ═══════════════════════════════════════════════════════════
//  SUMMARY
// ═══════════════════════════════════════════════════════════

println("")
println("═══════════════════════════════════════════════════════")
let total = pass_count + fail_count
println("  Results: " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL / " + to_string(total) + " total")
if fail_count == 0 {
    println("  ALL TYPE SYSTEM TESTS PASSED!")
} else {
    println("  SOME TESTS FAILED")
}
println("═══════════════════════════════════════════════════════")
