proof nt076_sq_6 { assert 6 * 6 == 36 }
proof nt077_cube_6 { assert 6 * 6 * 6 == 216 }
proof nt078_sq_12 { assert 12 * 12 == 144 }
proof nt079_sq_10 { assert 10 * 10 == 100 }
proof nt080_sq_11 { assert 11 * 11 == 121 }
proof nt081_p_2 { assert 2 == 2 }
proof nt082_p_3 { assert 3 == 3 }
proof nt083_p_5 { assert 5 == 5 }
proof nt084_p_7 { assert 7 == 7 }
proof nt085_p_11 { assert 11 == 11 }
proof nt086_p_13 { assert 13 == 13 }
proof nt087_p_17 { assert 17 == 17 }
proof nt088_p_19 { assert 19 == 19 }
proof nt089_p_23 { assert 23 == 23 }
proof nt090_p_29 { assert 29 == 29 }

// ── Sum identity: sigma*phi = n*tau for n=6 ─────────────────

proof nt091_grand_6 { assert 12 * 2 == 6 * 4 }
proof nt092_n_tau_6 { assert 6 * 4 == 24 }
proof nt093_sigma_phi_6 { assert 12 * 2 == 24 }
proof nt094_sigma_tau_6 { assert 12 * 4 == 48 }
proof nt095_sigma_minus_tau_6 { assert 12 - 4 == 8 }

// ── Divisibility checks ─────────────────────────────────────

proof nt096_2_div_6 { assert 6 % 2 == 0 }
proof nt097_3_div_6 { assert 6 % 3 == 0 }
proof nt098_6_div_12 { assert 12 % 6 == 0 }
proof nt099_6_div_24 { assert 24 % 6 == 0 }
proof nt100_6_not_div_7 { assert 7 % 6 != 0 }

println("[test_number_theory] 100 proofs declared")
