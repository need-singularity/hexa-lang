// self/compiler.hexa — HEXA bytecode compiler written in HEXA (Stage 4 of self-hosting)
// Takes AST from parser.hexa, generates stack-based bytecodes.
// Target: simple stack-based VM with locals, jumps, calls.

// ══════════════════════════════════════════════════════════════
// Shared structs (inlined until module system exists)
// ══════════════════════════════════════════════════════════════

struct Token {
    kind: string,
    value: string,
    line: int,
    col: int
}

struct AstNode {
    kind: string,
    name: string,
    value: string,
    op: string,
    left: string,
    right: string,
    cond: string,
    then_body: string,
    else_body: string,
    params: string,
    body: string,
    args: string,
    fields: string,
    items: string,
    variants: string,
    arms: string,
    iter_expr: string,
    ret_type: string,
    target: string,
    trait_name: string,
    methods: string
}

// ══════════════════════════════════════════════════════════════
// Bytecode instruction representation
// ══════════════════════════════════════════════════════════════
// Instructions are stored as structs with opcode string + operand.

struct Instruction {
    op: string,
    operand: string
}

fn instr(op, operand) {
    return Instruction { op: op, operand: operand }
}

fn instr_op(op) {
    return Instruction { op: op, operand: "" }
}

// ══════════════════════════════════════════════════════════════
// Compiled function
// ══════════════════════════════════════════════════════════════

struct CompiledFn {
    name: string,
    arity: int,
    param_names: string,
    code: string,
    local_count: int
}

// ══════════════════════════════════════════════════════════════
// Compiler state
// ══════════════════════════════════════════════════════════════

// Current code being emitted (top-level or function body)
let mut c_code = []

// Constant pool: c_const_values[]
let mut c_const_values = []

// Local variables: parallel arrays for scoping
let mut c_local_names = []
let mut c_local_depths = []
let mut c_depth = 0
let mut c_next_local = 0

// Compiled functions registry
let mut c_functions = []

// ══════════════════════════════════════════════════════════════
// Constant pool management
// ══════════════════════════════════════════════════════════════

fn c_add_const(val) {
    // Check for duplicate
    let mut i = 0
    while i < len(c_const_values) {
        if c_const_values[i] == val {
            return i
        }
        i = i + 1
    }
    c_const_values = c_const_values.push(val)
    return len(c_const_values) - 1
}

// ══════════════════════════════════════════════════════════════
// Emit helpers
// ══════════════════════════════════════════════════════════════

fn c_emit(op, operand) {
    c_code = c_code.push(instr(op, operand))
    return len(c_code) - 1
}

fn c_emit_op(op) {
    c_code = c_code.push(instr_op(op))
    return len(c_code) - 1
}

fn c_current_pos() {
    return len(c_code)
}

fn c_patch_jump(pos, target) {
    let old = c_code[pos]
    c_code[pos] = Instruction { op: old.op, operand: to_string(target) }
}

// ══════════════════════════════════════════════════════════════
// Local variable management
// ══════════════════════════════════════════════════════════════

fn c_push_scope() {
    c_depth = c_depth + 1
}

fn c_pop_scope() {
    // Pop locals at current depth
    let mut new_names = []
    let mut new_depths = []
    let mut i = 0
    while i < len(c_local_names) {
        if c_local_depths[i] < c_depth {
            new_names = new_names.push(c_local_names[i])
            new_depths = new_depths.push(c_local_depths[i])
        }
        i = i + 1
    }
    c_local_names = new_names
    c_local_depths = new_depths
    c_depth = c_depth - 1
}

fn c_define_local(name) {
    let slot = c_next_local
    c_local_names = c_local_names.push(name)
    c_local_depths = c_local_depths.push(c_depth)
    c_next_local = c_next_local + 1
    return slot
}

fn c_resolve_local(name) {
    // Search from end for most recent binding
    let mut i = len(c_local_names) - 1
    while i >= 0 {
        if c_local_names[i] == name {
            return i
        }
        i = i - 1
    }
    return -1
}

// ══════════════════════════════════════════════════════════════
// Expression compilation
// ══════════════════════════════════════════════════════════════

fn c_compile_expr(node) {
    if node == "" {
        c_emit_op("VOID")
        return
    }

    let k = node.kind

    if k == "IntLit" {
        let idx = c_add_const(node.value)
        c_emit("CONST", to_string(idx))
        return
    }
    if k == "FloatLit" {
        let idx = c_add_const(node.value)
        c_emit("CONST", to_string(idx))
        return
    }
    if k == "BoolLit" {
        let idx = c_add_const(node.value)
        c_emit("CONST", to_string(idx))
        return
    }
    if k == "StringLit" {
        let idx = c_add_const(node.value)
        c_emit("CONST", to_string(idx))
        return
    }
    if k == "CharLit" {
        let idx = c_add_const(node.value)
        c_emit("CONST", to_string(idx))
        return
    }

    if k == "Ident" {
        let slot = c_resolve_local(node.name)
        if slot >= 0 {
            c_emit("GET_LOCAL", to_string(slot))
        } else {
            c_emit("GET_GLOBAL", node.name)
        }
        return
    }

    if k == "BinOp" {
        c_compile_expr(node.left)
        c_compile_expr(node.right)
        if node.op == "+" { c_emit_op("ADD") }
        if node.op == "-" { c_emit_op("SUB") }
        if node.op == "*" { c_emit_op("MUL") }
        if node.op == "/" { c_emit_op("DIV") }
        if node.op == "%" { c_emit_op("MOD") }
        if node.op == "**" { c_emit_op("POW") }
        if node.op == "==" { c_emit_op("EQ") }
        if node.op == "!=" { c_emit_op("NE") }
        if node.op == "<" { c_emit_op("LT") }
        if node.op == ">" { c_emit_op("GT") }
        if node.op == "<=" { c_emit_op("LE") }
        if node.op == ">=" { c_emit_op("GE") }
        if node.op == "&&" { c_emit_op("AND") }
        if node.op == "||" { c_emit_op("OR") }
        if node.op == "^^" { c_emit_op("XOR") }
        return
    }

    if k == "UnaryOp" {
        c_compile_expr(node.left)
        if node.op == "-" { c_emit_op("NEG") }
        if node.op == "!" { c_emit_op("NOT") }
        if node.op == "~" { c_emit_op("BITNOT") }
        return
    }

    if k == "Call" {
        let callee = node.left
        let arg_count = len(node.args)
        // Compile arguments
        let mut i = 0
        while i < arg_count {
            c_compile_expr(node.args[i])
            i = i + 1
        }
        // Direct function call
        if callee.kind == "Ident" {
            let fname = callee.name
            if fname == "println" {
                c_emit("PRINTLN", to_string(arg_count))
                return
            }
            if fname == "print" {
                c_emit("PRINT", to_string(arg_count))
                return
            }
            if fname == "format" {
                c_emit("BUILTIN", "format:" + to_string(arg_count))
                return
            }
            if fname == "len" {
                c_emit("BUILTIN", "len:1")
                return
            }
            if fname == "to_string" {
                c_emit("BUILTIN", "to_string:1")
                return
            }
            if fname == "is_alpha" {
                c_emit("BUILTIN", "is_alpha:1")
                return
            }
            if fname == "is_digit" {
                c_emit("BUILTIN", "is_digit:1")
                return
            }
            if fname == "is_alphanumeric" {
                c_emit("BUILTIN", "is_alphanumeric:1")
                return
            }
            if fname == "read_file" {
                c_emit("BUILTIN", "read_file:1")
                return
            }
            if fname == "dir_exists" {
                c_emit("BUILTIN", "dir_exists:1")
                return
            }
            if fname == "mkdir" {
                c_emit("BUILTIN", "mkdir:1")
                return
            }
            if fname == "list_dir" {
                c_emit("BUILTIN", "list_dir:1")
                return
            }
            if fname == "type_of" {
                c_emit("BUILTIN", "type_of:1")
                return
            }
            if fname == "int" {
                c_emit("BUILTIN", "int:1")
                return
            }
            if fname == "float" {
                c_emit("BUILTIN", "float:1")
                return
            }
            // User-defined function
            c_emit("CALL", fname + ":" + to_string(arg_count))
            return
        }
        // Method call: callee is Field (obj.method)
        if callee.kind == "Field" {
            c_compile_expr(callee.left)
            c_emit("CALL_METHOD", callee.name + ":" + to_string(arg_count))
            return
        }
        // Fallback
        c_compile_expr(callee)
        c_emit("CALL_INDIRECT", to_string(arg_count))
        return
    }

    if k == "Field" {
        c_compile_expr(node.left)
        c_emit("GET_FIELD", node.name)
        return
    }

    if k == "Index" {
        c_compile_expr(node.left)
        c_compile_expr(node.right)
        c_emit_op("INDEX")
        return
    }

    if k == "Array" {
        let count = len(node.items)
        let mut i = 0
        while i < count {
            c_compile_expr(node.items[i])
            i = i + 1
        }
        c_emit("MAKE_ARRAY", to_string(count))
        return
    }

    if k == "Range" {
        c_compile_expr(node.left)
        c_compile_expr(node.right)
        if node.value == "inclusive" {
            c_emit("MAKE_RANGE", "inclusive")
        } else {
            c_emit("MAKE_RANGE", "exclusive")
        }
        return
    }

    if k == "StructInit" {
        let count = len(node.fields)
        let mut i = 0
        while i < count {
            let f = node.fields[i]
            let name_idx = c_add_const(f.name)
            c_emit("CONST", to_string(name_idx))
            c_compile_expr(f.left)
            i = i + 1
        }
        c_emit("MAKE_STRUCT", node.name + ":" + to_string(count))
        return
    }

    if k == "IfExpr" {
        c_compile_expr(node.cond)
        let jump_false = c_emit("JUMP_IF_FALSE", "0")
        c_compile_stmts(node.then_body)
        if node.else_body != "" && len(node.else_body) > 0 {
            let jump_end = c_emit("JUMP", "0")
            c_patch_jump(jump_false, c_current_pos())
            c_compile_stmts(node.else_body)
            c_patch_jump(jump_end, c_current_pos())
        } else {
            c_patch_jump(jump_false, c_current_pos())
        }
        return
    }

    if k == "MatchExpr" {
        // Compile scrutinee, then generate if/else chain
        c_compile_expr(node.left)
        let arm_count = len(node.arms)
        let mut jump_ends = []
        let mut i = 0
        while i < arm_count {
            let arm = node.arms[i]
            // Duplicate scrutinee for comparison
            c_emit_op("DUP")
            c_compile_expr(arm.left)
            c_emit_op("EQ")
            let jf = c_emit("JUMP_IF_FALSE", "0")
            c_emit_op("POP")
            c_compile_stmts(arm.body)
            jump_ends = jump_ends.push(c_emit("JUMP", "0"))
            c_patch_jump(jf, c_current_pos())
            i = i + 1
        }
        c_emit_op("POP")
        // Patch all end jumps
        let mut j = 0
        while j < len(jump_ends) {
            c_patch_jump(jump_ends[j], c_current_pos())
            j = j + 1
        }
        return
    }

    if k == "Tuple" {
        let count = len(node.items)
        let mut i = 0
        while i < count {
            c_compile_expr(node.items[i])
            i = i + 1
        }
        c_emit("MAKE_ARRAY", to_string(count))
        return
    }

    if k == "Lambda" {
        // Compile lambda as anonymous function
        let saved_code = c_code
        let saved_locals = c_local_names
        let saved_depths = c_local_depths
        let saved_depth = c_depth
        let saved_next = c_next_local
        c_code = []
        c_local_names = []
        c_local_depths = []
        c_depth = 0
        c_next_local = 0
        let param_count = len(node.params)
        let mut i = 0
        while i < param_count {
            c_define_local(node.params[i])
            i = i + 1
        }
        if node.left != "" {
            // Single expression body or block
            c_compile_expr(node.left)
            c_emit_op("RETURN")
        }
        let lambda_code = c_code
        let lambda_locals = c_next_local
        // Restore state
        c_code = saved_code
        c_local_names = saved_locals
        c_local_depths = saved_depths
        c_depth = saved_depth
        c_next_local = saved_next
        // Store as anonymous function
        let lambda_name = "_lambda_" + to_string(len(c_functions))
        let mut pnames = []
        let mut j = 0
        while j < param_count {
            pnames = pnames.push(node.params[j])
            j = j + 1
        }
        c_functions = c_functions.push(CompiledFn {
            name: lambda_name,
            arity: param_count,
            param_names: pnames,
            code: lambda_code,
            local_count: lambda_locals
        })
        c_emit("CLOSURE", lambda_name)
        return
    }

    if k == "EnumPath" {
        let idx = c_add_const(node.name + "::" + node.value)
        c_emit("CONST", to_string(idx))
        return
    }

    // Fallback
    c_emit_op("VOID")
}

// ══════════════════════════════════════════════════════════════
// Statement compilation
// ══════════════════════════════════════════════════════════════

fn c_compile_stmt(node) {
    let k = node.kind

    if k == "LetStmt" || k == "LetMutStmt" {
        c_compile_expr(node.left)
        let slot = c_define_local(node.name)
        c_emit("SET_LOCAL", to_string(slot))
        return
    }

    if k == "ConstStmt" || k == "StaticStmt" {
        c_compile_expr(node.left)
        let slot = c_define_local(node.name)
        c_emit("SET_LOCAL", to_string(slot))
        return
    }

    if k == "FnDecl" {
        // Save compiler state
        let saved_code = c_code
        let saved_locals = c_local_names
        let saved_depths = c_local_depths
        let saved_depth = c_depth
        let saved_next = c_next_local

        // New function scope
        c_code = []
        c_local_names = []
        c_local_depths = []
        c_depth = 0
        c_next_local = 0

        // Define parameters as locals
        let param_count = len(node.params)
        let mut pnames = []
        let mut i = 0
        while i < param_count {
            let pname = node.params[i].name
            pnames = pnames.push(pname)
            c_define_local(pname)
            i = i + 1
        }

        // Compile function body
        c_compile_stmts(node.body)
        // Implicit void return
        c_emit_op("VOID")
        c_emit_op("RETURN")

        let fn_code = c_code
        let fn_locals = c_next_local

        // Restore compiler state
        c_code = saved_code
        c_local_names = saved_locals
        c_local_depths = saved_depths
        c_depth = saved_depth
        c_next_local = saved_next

        // Register compiled function
        c_functions = c_functions.push(CompiledFn {
            name: node.name,
            arity: param_count,
            param_names: pnames,
            code: fn_code,
            local_count: fn_locals
        })
        return
    }

    if k == "StructDecl" {
        // Structs are compile-time only, no runtime code needed
        return
    }

    if k == "EnumDecl" {
        return
    }

    if k == "TraitDecl" {
        return
    }

    if k == "ImplBlock" {
        // Compile each method
        let mut i = 0
        while i < len(node.methods) {
            c_compile_stmt(node.methods[i])
            i = i + 1
        }
        return
    }

    if k == "ReturnStmt" {
        if node.left != "" {
            c_compile_expr(node.left)
        } else {
            c_emit_op("VOID")
        }
        c_emit_op("RETURN")
        return
    }

    if k == "AssignStmt" {
        c_compile_expr(node.right)
        // Simple ident assignment
        if node.left != "" && node.left.kind == "Ident" {
            let slot = c_resolve_local(node.left.name)
            if slot >= 0 {
                c_emit("SET_LOCAL", to_string(slot))
            } else {
                c_emit("SET_GLOBAL", node.left.name)
            }
            return
        }
        // Index assignment: arr[idx] = val
        if node.left != "" && node.left.kind == "Index" {
            c_compile_expr(node.left.left)
            c_compile_expr(node.left.right)
            c_emit_op("INDEX_ASSIGN")
            return
        }
        // Field assignment: obj.field = val
        if node.left != "" && node.left.kind == "Field" {
            c_compile_expr(node.left.left)
            c_emit("SET_FIELD", node.left.name)
            return
        }
        return
    }

    if k == "ExprStmt" {
        c_compile_expr(node.left)
        c_emit_op("POP")
        return
    }

    if k == "WhileStmt" {
        let loop_start = c_current_pos()
        c_compile_expr(node.cond)
        let exit_jump = c_emit("JUMP_IF_FALSE", "0")
        c_push_scope()
        c_compile_stmts(node.body)
        c_pop_scope()
        c_emit("JUMP", to_string(loop_start))
        c_patch_jump(exit_jump, c_current_pos())
        return
    }

    if k == "LoopStmt" {
        let loop_start = c_current_pos()
        c_push_scope()
        c_compile_stmts(node.body)
        c_pop_scope()
        c_emit("JUMP", to_string(loop_start))
        return
    }

    if k == "ForStmt" {
        // for var in iter { body }
        // Compile iter expression
        c_compile_expr(node.iter_expr)
        // Store iterator
        c_push_scope()
        let iter_slot = c_define_local("__iter__")
        c_emit("SET_LOCAL", to_string(iter_slot))
        let idx_slot = c_define_local("__idx__")
        let zero_idx = c_add_const("0")
        c_emit("CONST", to_string(zero_idx))
        c_emit("SET_LOCAL", to_string(idx_slot))
        let var_slot = c_define_local(node.name)

        // Loop start
        let loop_start = c_current_pos()
        // Check: __idx__ < len(__iter__)
        c_emit("GET_LOCAL", to_string(idx_slot))
        c_emit("GET_LOCAL", to_string(iter_slot))
        c_emit("BUILTIN", "len:1")
        c_emit_op("LT")
        let exit_jump = c_emit("JUMP_IF_FALSE", "0")

        // var = __iter__[__idx__]
        c_emit("GET_LOCAL", to_string(iter_slot))
        c_emit("GET_LOCAL", to_string(idx_slot))
        c_emit_op("INDEX")
        c_emit("SET_LOCAL", to_string(var_slot))

        // Body
        c_compile_stmts(node.body)

        // __idx__ = __idx__ + 1
        c_emit("GET_LOCAL", to_string(idx_slot))
        let one_idx = c_add_const("1")
        c_emit("CONST", to_string(one_idx))
        c_emit_op("ADD")
        c_emit("SET_LOCAL", to_string(idx_slot))

        c_emit("JUMP", to_string(loop_start))
        c_patch_jump(exit_jump, c_current_pos())
        c_pop_scope()
        return
    }

    if k == "AssertStmt" {
        c_compile_expr(node.left)
        c_emit_op("ASSERT")
        return
    }

    if k == "BreakStmt" {
        c_emit_op("BREAK")
        return
    }

    if k == "ContinueStmt" {
        c_emit_op("CONTINUE")
        return
    }

    if k == "ThrowStmt" {
        if node.left != "" {
            c_compile_expr(node.left)
        } else {
            let idx = c_add_const("error")
            c_emit("CONST", to_string(idx))
        }
        c_emit_op("THROW")
        return
    }

    if k == "TryCatchStmt" {
        // try { body } catch varname { handler }
        let try_start = c_emit("TRY_BEGIN", "0")
        c_push_scope()
        c_compile_stmts(node.body)
        c_pop_scope()
        let jump_past = c_emit("JUMP", "0")
        // catch handler
        c_patch_jump(try_start, c_current_pos())
        c_emit_op("TRY_END")
        c_push_scope()
        if node.name != "" {
            let slot = c_define_local(node.name)
            c_emit("SET_LOCAL", to_string(slot))
        } else {
            c_emit_op("POP")
        }
        if node.else_body != "" {
            c_compile_stmts(node.else_body)
        }
        c_pop_scope()
        c_patch_jump(jump_past, c_current_pos())
        return
    }

    if k == "SpawnStmt" {
        c_compile_expr(node.left)
        c_emit_op("SPAWN")
        return
    }

    if k == "UseStmt" { return }
    if k == "ModStmt" { return }
    if k == "ImportStmt" { return } // Phase2 C1 — 로더가 이미 처리
    if k == "ProofStmt" {
        // Proofs compile like blocks
        c_push_scope()
        c_compile_stmts(node.body)
        c_pop_scope()
        return
    }
}

fn c_compile_stmts(stmts) {
    if stmts == "" { return }
    let mut i = 0
    while i < len(stmts) {
        c_compile_stmt(stmts[i])
        i = i + 1
    }
}

// ══════════════════════════════════════════════════════════════
// Public API
// ══════════════════════════════════════════════════════════════

fn compile(stmts) {
    // Reset state
    c_code = []
    c_const_values = []
    c_local_names = []
    c_local_depths = []
    c_depth = 0
    c_next_local = 0
    c_functions = []

    // Compile all statements
    c_compile_stmts(stmts)

    // Return compilation result
    return c_code
}

fn get_constants() {
    return c_const_values
}

fn get_functions() {
    return c_functions
}

fn get_local_count() {
    return c_next_local
}

// ══════════════════════════════════════════════════════════════
// Bytecode disassembler (for debugging)
// ══════════════════════════════════════════════════════════════

fn disassemble(code, constants) {
    println("=== Bytecode ===")
    let mut i = 0
    while i < len(code) {
        let ins = code[i]
        if ins.operand != "" {
            println(format("  {:4}  {} {}", i, ins.op, ins.operand))
        } else {
            println(format("  {:4}  {}", i, ins.op))
        }
        i = i + 1
    }
    println("")
    println("=== Constants ===")
    let mut j = 0
    while j < len(constants) {
        println(format("  [{}] {}", j, constants[j]))
        j = j + 1
    }
}

fn disassemble_fn(func) {
    println(format("=== Function: {} (arity={}, locals={}) ===", func.name, func.arity, func.local_count))
    let mut i = 0
    while i < len(func.code) {
        let ins = func.code[i]
        if ins.operand != "" {
            println(format("  {:4}  {} {}", i, ins.op, ins.operand))
        } else {
            println(format("  {:4}  {}", i, ins.op))
        }
        i = i + 1
    }
}

fn disassemble_all(code, constants, functions) {
    disassemble(code, constants)
    println("")
    let mut i = 0
    while i < len(functions) {
        disassemble_fn(functions[i])
        println("")
        i = i + 1
    }
}
