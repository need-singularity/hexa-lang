        target: "", trait_name: "", methods: ""
    },
    mk_let("b", mk_field("s", "x")),
    mk_return(mk_binop("+", mk_ident("a"), mk_ident("b")))
]
let t19_fn = mk_fn("f19", "immutable", [mk_param("s")], t19_body)
let t19_result = anp_detect_immutable(t19_fn)
check_eq("t19 s.x detected", len(t19_result), 1)
check_eq("t19 key", t19_result[0][0], "s.x")

