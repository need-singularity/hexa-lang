// =====================================================================
//  Full pass integration test
// =====================================================================
println("")
println("--- integration: anp_immutable_pass ---")
m980_immutable_ok = 0
m980_immutable_cached = 0
m980_immutable_violations = 0

// Build AST with 3 fns: 2 @immutable (1 with redundant, 1 without), 1 normal
let int_fn1_body = [
    mk_let("a", mk_field("p", "x")),
    mk_return(mk_binop("+", mk_ident("a"), mk_field("p", "x")))
]
let int_fn1 = mk_fn("imm_yes", "immutable", [mk_param("p")], int_fn1_body)

let int_fn2_body = [
    mk_return(mk_field("q", "y"))
]
let int_fn2 = mk_fn("imm_no", "immutable", [mk_param("q")], int_fn2_body)

let int_fn3_body = [
    mk_return(mk_intlit(42))
]
let int_fn3 = mk_fn("normal", "", [], int_fn3_body)

let int_ast = [int_fn1, int_fn2, int_fn3]
let int_out = anp_immutable_pass(int_ast)

check_eq("int: output len", len(int_out), 3)
check_eq("int: immutable_ok=1", m980_immutable_ok, 1)
check_eq("int: immutable_violations=1", m980_immutable_violations, 1)
check("int: cached > 0", m980_immutable_cached > 0)

// Verify the rewritten fn has cache let prepended
let rewritten_fn1 = int_out[0]
check_eq("int: rewritten kind", rewritten_fn1.kind, "FnDecl")
// Body should start with a LetStmt for the cache variable
let first_stmt = rewritten_fn1.body[0]
check_eq("int: cache let kind", first_stmt.kind, "LetStmt")
check_eq("int: cache let name", first_stmt.name, "__imm_p_x")

// Non-immutable fn unchanged
let out_fn3 = int_out[2]
check_eq("int: normal fn unchanged", out_fn3.name, "normal")

// =====================================================================
//  anp_cache_immutable body rewrite test
// =====================================================================
println("")
println("--- cache rewrite body check ---")
m980_immutable_cached = 0
let cache_body = [
    mk_let("a", mk_field("s", "v")),
    mk_let("b", mk_field("s", "v")),
    mk_return(mk_binop("+", mk_ident("a"), mk_ident("b")))
]
let cache_fn = mk_fn("fc", "immutable", [mk_param("s")], cache_body)
let cache_result = anp_cache_immutable(cache_fn)
// Should have: 1 cache let + 3 original stmts = 4
check_eq("cache: body len", len(cache_result), 4)
check_eq("cache: first is LetStmt", cache_result[0].kind, "LetStmt")
check_eq("cache: first name __imm_s_v", cache_result[0].name, "__imm_s_v")
// The original let stmts should now reference __imm_s_v (Ident) instead of s.v (FieldAccess)
let rewritten_let_a = cache_result[1]
check_eq("cache: let a uses ident", rewritten_let_a.left.kind, "Ident")
check_eq("cache: let a uses __imm_s_v", rewritten_let_a.left.name, "__imm_s_v")

// =====================================================================
//  anp_split_dot helper test
// =====================================================================
println("")
println("--- anp_split_dot ---")
let dot1 = anp_split_dot("base.field")
check_eq("split base", dot1[0], "base")
check_eq("split field", dot1[1], "field")
let dot2 = anp_split_dot("nodot")
check_eq("split no dot", dot2[0], "nodot")

// -- Summary --
println("")
println("=====================================================")
println("  @immutable: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("=====================================================")
assert(fail_count == 0)
