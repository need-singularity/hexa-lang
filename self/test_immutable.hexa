// =====================================================================
//  test_immutable.hexa -- ROI #69 @immutable field caching tests
//
//  Verifies that @immutable attribute correctly caches repeated
//  field accesses into local variables, eliminating redundant loads.
//
//  Tests (22):
//    1. Basic repeated field access caching
//    2. Two fields on same struct cached
//    3. Field used in arithmetic
//    4. Field used in conditional
//    5. Field used in loop
//    6. Field used in nested expression
//    7. Single access (no caching needed)
//    8. Field in return position
//    9. Multiple structs, different bases
//   10. Field access in function call arg
//   11. Field used in comparison
//   12. Field cached across if/else branches
//   13. Field in while condition
//   14. Three accesses to same field
//   15. Field combined with local var
//   16. Two functions both @immutable
//   17. Field in index expression
//   18. Deep field count (4+ reads)
//   19. Mixed mutable and immutable access
//   20. @immutable with accumulator pattern
//   21. @immutable with string fields
//   22. @immutable no-op (unique field reads)
//
//  Run: ./hexa test self/test_immutable.hexa
// =====================================================================

// -- Self-contained: no import needed --

struct AstNode {
    kind: string,
    name: string,
    value: string,
    op: string,
    left: string,
    right: string,
    cond: string,
    then_body: string,
    else_body: string,
    params: string,
    body: string,
    args: string,
    fields: string,
    items: string,
    variants: string,
    arms: string,
    iter_expr: string,
    ret_type: string,
    target: string,
    trait_name: string,
    methods: string
}

// -- Metrics --
let mut m980_immutable_ok = 0
let mut m980_immutable_cached = 0
let mut m980_immutable_violations = 0

// -- anp_split_dot: "base.field" -> ["base", "field"] --
fn anp_split_dot(s) {
    let mut i = 0
    while i < len(s) {
        if to_string(s[i]) == "." {
            return [s.substring(0, i), s.substring(i + 1, len(s))]
        }
        i = i + 1
    }
    return [s]
}

// -- anp_count_field_reads: walk expr tree, count FieldAccess reads --
// decreases expr — structural
fn anp_count_field_reads_expr(expr, counts) {
    if type_of(expr) == "string" { return counts }
    let k = expr.kind
    if k == "FieldAccess" {
        if type_of(expr.left) != "string" && expr.left.kind == "Ident" {
            let key = expr.left.name + "." + expr.name
            let mut found = false
            let mut ci = 0
            while ci < len(counts) {
                if counts[ci][0] == key {
                    counts[ci] = [key, counts[ci][1] + 1]
                    found = true
                }
                ci = ci + 1
            }
            if !found {
                counts = counts + [[key, 1]]
            }
        }
        return counts
    }
    if k == "BinOp" {
        counts = anp_count_field_reads_expr(expr.left, counts)
        counts = anp_count_field_reads_expr(expr.right, counts)
        return counts
    }
    if k == "Call" {
        counts = anp_count_field_reads_expr(expr.left, counts)
        if type_of(expr.args) == "array" {
            let mut ai = 0
            while ai < len(expr.args) {
                counts = anp_count_field_reads_expr(expr.args[ai], counts)
                ai = ai + 1
            }
        }
        return counts
    }
    if k == "Index" {
        counts = anp_count_field_reads_expr(expr.left, counts)
        counts = anp_count_field_reads_expr(expr.right, counts)
        return counts
    }
    if k == "Ident" || k == "IntLit" || k == "FloatLit" || k == "StringLit" {
        return counts
    }
    return counts
}

fn anp_count_field_reads_stmt(stmt, counts) {
    if type_of(stmt) == "string" { return counts }
    let k = stmt.kind
    if k == "LetStmt" || k == "LetMutStmt" {
        counts = anp_count_field_reads_expr(stmt.left, counts)
        return counts
    }
    if k == "ReturnStmt" {
        counts = anp_count_field_reads_expr(stmt.left, counts)
        return counts
    }
    if k == "AssignStmt" {
        // LHS field write: skip the LHS FieldAccess itself, only count RHS
        counts = anp_count_field_reads_expr(stmt.right, counts)
        // If LHS is an Ident (simple assignment), also walk it... no, skip
        // If LHS is a FieldAccess, that's a write, don't count it
        if type_of(stmt.left) != "string" && stmt.left.kind != "FieldAccess" {
            counts = anp_count_field_reads_expr(stmt.left, counts)
        }
        return counts
    }
    if k == "ExprStmt" {
        counts = anp_count_field_reads_expr(stmt.left, counts)
        return counts
    }
    if k == "IfStmt" {
        counts = anp_count_field_reads_expr(stmt.cond, counts)
        if type_of(stmt.then_body) == "array" {
            counts = anp_count_field_reads_body(stmt.then_body, counts)
        }
        if type_of(stmt.else_body) == "array" {
            counts = anp_count_field_reads_body(stmt.else_body, counts)
        }
        return counts
    }
    if k == "WhileStmt" {
        counts = anp_count_field_reads_expr(stmt.cond, counts)
        if type_of(stmt.body) == "array" {
            counts = anp_count_field_reads_body(stmt.body, counts)
        }
        return counts
    }
    return counts
}

fn anp_count_field_reads_body(body, counts) {
    let mut i = 0
    while i < len(body) {
        counts = anp_count_field_reads_stmt(body[i], counts)
        i = i + 1
    }
    return counts
}

// -- anp_detect_immutable: find repeated field accesses in @immutable fn --
fn anp_detect_immutable(fn_node) {
    if type_of(fn_node) == "string" { return [] }
    if fn_node.kind != "FnDecl" { return [] }
    let attrs = fn_node.value
    if type_of(attrs) == "string" {
        if attrs != "immutable" { return [] }
    }
    let body = fn_node.body
    if type_of(body) != "array" { return [] }
    let counts = anp_count_field_reads_body(body, [])
    // Filter to only those with count >= 2
    let mut result = []
    let mut i = 0
    while i < len(counts) {
        if counts[i][1] >= 2 {
            result = result + [counts[i]]
        }
        i = i + 1
    }
    return result
}

// -- anp_replace_field_expr: replace FieldAccess(base, field) with Ident(__imm_base_field) --
// decreases expr — structural
fn anp_replace_field_expr(expr, key, cache_name) {
    if type_of(expr) == "string" { return expr }
    let k = expr.kind
    if k == "FieldAccess" {
        if type_of(expr.left) != "string" && expr.left.kind == "Ident" {
            let ekey = expr.left.name + "." + expr.name
            if ekey == key {
                return AstNode {
                    kind: "Ident", name: cache_name, value: "", op: "",
                    left: "", right: "", cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }
            }
        }
        return expr
    }
    if k == "BinOp" {
        let nl = anp_replace_field_expr(expr.left, key, cache_name)
        let nr = anp_replace_field_expr(expr.right, key, cache_name)
        return AstNode {
            kind: "BinOp", name: expr.name, value: expr.value, op: expr.op,
            left: nl, right: nr, cond: expr.cond, then_body: expr.then_body, else_body: expr.else_body,
            params: expr.params, body: expr.body, args: expr.args, fields: expr.fields, items: expr.items,
            variants: expr.variants, arms: expr.arms, iter_expr: expr.iter_expr, ret_type: expr.ret_type,
            target: expr.target, trait_name: expr.trait_name, methods: expr.methods
        }
    }
    if k == "Call" {
        let nl = anp_replace_field_expr(expr.left, key, cache_name)
        let mut new_args = []
        if type_of(expr.args) == "array" {
            let mut ai = 0
            while ai < len(expr.args) {
                new_args = new_args + [anp_replace_field_expr(expr.args[ai], key, cache_name)]
                ai = ai + 1
            }
        }
        return AstNode {
            kind: "Call", name: expr.name, value: expr.value, op: expr.op,
            left: nl, right: expr.right, cond: expr.cond, then_body: expr.then_body, else_body: expr.else_body,
            params: expr.params, body: expr.body, args: new_args, fields: expr.fields, items: expr.items,
            variants: expr.variants, arms: expr.arms, iter_expr: expr.iter_expr, ret_type: expr.ret_type,
            target: expr.target, trait_name: expr.trait_name, methods: expr.methods
        }
    }
    if k == "Index" {
        let nl = anp_replace_field_expr(expr.left, key, cache_name)
        let nr = anp_replace_field_expr(expr.right, key, cache_name)
        return AstNode {
            kind: "Index", name: expr.name, value: expr.value, op: expr.op,
            left: nl, right: nr, cond: expr.cond, then_body: expr.then_body, else_body: expr.else_body,
            params: expr.params, body: expr.body, args: expr.args, fields: expr.fields, items: expr.items,
            variants: expr.variants, arms: expr.arms, iter_expr: expr.iter_expr, ret_type: expr.ret_type,
            target: expr.target, trait_name: expr.trait_name, methods: expr.methods
        }
    }
    return expr
}

fn anp_replace_field_stmt(stmt, key, cache_name) {
    if type_of(stmt) == "string" { return stmt }
    let k = stmt.kind
    if k == "LetStmt" || k == "LetMutStmt" {
        let nl = anp_replace_field_expr(stmt.left, key, cache_name)
        return AstNode {
            kind: k, name: stmt.name, value: stmt.value, op: stmt.op,
            left: nl, right: stmt.right, cond: stmt.cond, then_body: stmt.then_body, else_body: stmt.else_body,
            params: stmt.params, body: stmt.body, args: stmt.args, fields: stmt.fields, items: stmt.items,
            variants: stmt.variants, arms: stmt.arms, iter_expr: stmt.iter_expr, ret_type: stmt.ret_type,
            target: stmt.target, trait_name: stmt.trait_name, methods: stmt.methods
        }
    }
    if k == "ReturnStmt" {
        let nl = anp_replace_field_expr(stmt.left, key, cache_name)
        return AstNode {
            kind: k, name: stmt.name, value: stmt.value, op: stmt.op,
            left: nl, right: stmt.right, cond: stmt.cond, then_body: stmt.then_body, else_body: stmt.else_body,
            params: stmt.params, body: stmt.body, args: stmt.args, fields: stmt.fields, items: stmt.items,
            variants: stmt.variants, arms: stmt.arms, iter_expr: stmt.iter_expr, ret_type: stmt.ret_type,
            target: stmt.target, trait_name: stmt.trait_name, methods: stmt.methods
        }
    }
    if k == "AssignStmt" {
        let nl = anp_replace_field_expr(stmt.left, key, cache_name)
        let nr = anp_replace_field_expr(stmt.right, key, cache_name)
        return AstNode {
            kind: k, name: stmt.name, value: stmt.value, op: stmt.op,
            left: nl, right: nr, cond: stmt.cond, then_body: stmt.then_body, else_body: stmt.else_body,
            params: stmt.params, body: stmt.body, args: stmt.args, fields: stmt.fields, items: stmt.items,
            variants: stmt.variants, arms: stmt.arms, iter_expr: stmt.iter_expr, ret_type: stmt.ret_type,
            target: stmt.target, trait_name: stmt.trait_name, methods: stmt.methods
        }
    }
    if k == "ExprStmt" {
        let nl = anp_replace_field_expr(stmt.left, key, cache_name)
        return AstNode {
            kind: k, name: stmt.name, value: stmt.value, op: stmt.op,
            left: nl, right: stmt.right, cond: stmt.cond, then_body: stmt.then_body, else_body: stmt.else_body,
            params: stmt.params, body: stmt.body, args: stmt.args, fields: stmt.fields, items: stmt.items,
            variants: stmt.variants, arms: stmt.arms, iter_expr: stmt.iter_expr, ret_type: stmt.ret_type,
            target: stmt.target, trait_name: stmt.trait_name, methods: stmt.methods
        }
    }
    if k == "IfStmt" {
        let nc = anp_replace_field_expr(stmt.cond, key, cache_name)
        let mut nt = stmt.then_body
        if type_of(stmt.then_body) == "array" {
            nt = anp_replace_field_body(stmt.then_body, key, cache_name)
        }
        let mut ne = stmt.else_body
        if type_of(stmt.else_body) == "array" {
            ne = anp_replace_field_body(stmt.else_body, key, cache_name)
        }
        return AstNode {
            kind: k, name: stmt.name, value: stmt.value, op: stmt.op,
            left: stmt.left, right: stmt.right, cond: nc, then_body: nt, else_body: ne,
            params: stmt.params, body: stmt.body, args: stmt.args, fields: stmt.fields, items: stmt.items,
            variants: stmt.variants, arms: stmt.arms, iter_expr: stmt.iter_expr, ret_type: stmt.ret_type,
            target: stmt.target, trait_name: stmt.trait_name, methods: stmt.methods
        }
    }
    if k == "WhileStmt" {
        let nc = anp_replace_field_expr(stmt.cond, key, cache_name)
        let mut nb = stmt.body
        if type_of(stmt.body) == "array" {
            nb = anp_replace_field_body(stmt.body, key, cache_name)
        }
        return AstNode {
            kind: k, name: stmt.name, value: stmt.value, op: stmt.op,
            left: stmt.left, right: stmt.right, cond: nc, then_body: stmt.then_body, else_body: stmt.else_body,
            params: stmt.params, body: nb, args: stmt.args, fields: stmt.fields, items: stmt.items,
            variants: stmt.variants, arms: stmt.arms, iter_expr: stmt.iter_expr, ret_type: stmt.ret_type,
            target: stmt.target, trait_name: stmt.trait_name, methods: stmt.methods
        }
    }
    return stmt
}

fn anp_replace_field_body(body, key, cache_name) {
    let mut result = []
    let mut i = 0
    while i < len(body) {
        result = result + [anp_replace_field_stmt(body[i], key, cache_name)]
        i = i + 1
    }
    return result
}

// -- anp_cache_immutable: rewrite fn body to cache repeated field reads --
fn anp_cache_immutable(fn_node) {
    let redundant = anp_detect_immutable(fn_node)
    if len(redundant) == 0 { return fn_node.body }
    let mut body = fn_node.body
    let mut prepend = []
    let mut ri = 0
    while ri < len(redundant) {
        let key = redundant[ri][0]
        let parts = anp_split_dot(key)
        let base = parts[0]
        let field = parts[1]
        let cache_name = "__imm_" + base + "_" + field
        // Create: let __imm_base_field = base.field
        let cache_let = AstNode {
            kind: "LetStmt", name: cache_name, value: "", op: "",
            left: AstNode {
                kind: "FieldAccess", name: field, value: "", op: "",
                left: AstNode {
                    kind: "Ident", name: base, value: "", op: "",
                    left: "", right: "", cond: "", then_body: "", else_body: "",
                    params: "", body: "", args: "", fields: "", items: "",
                    variants: "", arms: "", iter_expr: "", ret_type: "",
                    target: "", trait_name: "", methods: ""
                }, right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            }, right: "", cond: "", then_body: "", else_body: "",
            params: "", body: "", args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        }
        prepend = prepend + [cache_let]
        body = anp_replace_field_body(body, key, cache_name)
        m980_immutable_cached = m980_immutable_cached + redundant[ri][1]
        ri = ri + 1
    }
    return prepend + body
}

// -- anp_immutable_pass: process array of FnDecl, optimize @immutable ones --
fn anp_immutable_pass(ast) {
    let mut result = []
    let mut i = 0
    while i < len(ast) {
        let node = ast[i]
        if type_of(node) != "string" && node.kind == "FnDecl" {
            let attrs = node.value
            let is_immutable = type_of(attrs) == "string" && attrs == "immutable"
            if is_immutable {
                let redundant = anp_detect_immutable(node)
                if len(redundant) > 0 {
                    let new_body = anp_cache_immutable(node)
                    let new_fn = AstNode {
                        kind: "FnDecl", name: node.name, value: node.value, op: node.op,
                        left: node.left, right: node.right, cond: node.cond, then_body: node.then_body, else_body: node.else_body,
                        params: node.params, body: new_body, args: node.args, fields: node.fields, items: node.items,
                        variants: node.variants, arms: node.arms, iter_expr: node.iter_expr, ret_type: node.ret_type,
                        target: node.target, trait_name: node.trait_name, methods: node.methods
                    }
                    result = result + [new_fn]
                    m980_immutable_ok = m980_immutable_ok + 1
                } else {
                    result = result + [node]
                    m980_immutable_violations = m980_immutable_violations + 1
                }
            } else {
                result = result + [node]
            }
        } else {
            result = result + [node]
        }
        i = i + 1
    }
    return result
}

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn check_eq(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("=====================================================")
println("  @immutable Field Caching (ROI #69) Tests")
println("=====================================================")
println("")

// -- Helper: build AST nodes --

fn mk_ident(n) {
    return AstNode {
        kind: "Ident", name: n, value: "", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn mk_intlit(v) {
    return AstNode {
        kind: "IntLit", name: "", value: to_string(v), op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn mk_field(base_name, field_name) {
    return AstNode {
        kind: "FieldAccess", name: field_name, value: "", op: "",
        left: mk_ident(base_name), right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn mk_binop(op, l, r) {
    return AstNode {
        kind: "BinOp", name: "", value: "", op: op,
        left: l, right: r, cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn mk_let(n, expr) {
    return AstNode {
        kind: "LetStmt", name: n, value: "", op: "",
        left: expr, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn mk_let_mut(n, expr) {
    return AstNode {
        kind: "LetMutStmt", name: n, value: "", op: "",
        left: expr, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn mk_return(expr) {
    return AstNode {
        kind: "ReturnStmt", name: "", value: "", op: "",
        left: expr, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn mk_assign(n, expr) {
    return AstNode {
        kind: "AssignStmt", name: n, value: "", op: "",
        left: mk_ident(n), right: expr, cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn mk_param(n) {
    return AstNode {
        kind: "Param", name: n, value: "", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn mk_fn(name, attrs, params, body) {
    return AstNode {
        kind: "FnDecl", name: name, value: attrs, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: params, body: body, args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn mk_if(cond, then_body, else_body) {
    return AstNode {
        kind: "IfStmt", name: "", value: "", op: "",
        left: "", right: "", cond: cond, then_body: then_body, else_body: else_body,
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn mk_while(cond, body) {
    return AstNode {
        kind: "WhileStmt", name: "", value: "", op: "",
        left: "", right: "", cond: cond, then_body: "", else_body: "",
        params: "", body: body, args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn mk_call(fname, args) {
    return AstNode {
        kind: "Call", name: "", value: "", op: "",
        left: mk_ident(fname), right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: args, fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn mk_exprstmt(expr) {
    return AstNode {
        kind: "ExprStmt", name: "", value: "", op: "",
        left: expr, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

// =====================================================================
//  1. Basic repeated field access caching
// =====================================================================
println("--- 1. basic repeated field ---")
// fn f(p) { let a = p.x; let b = p.x; return a + b }
let t1_body = [
    mk_let("a", mk_field("p", "x")),
    mk_let("b", mk_field("p", "x")),
    mk_return(mk_binop("+", mk_ident("a"), mk_ident("b")))
]
