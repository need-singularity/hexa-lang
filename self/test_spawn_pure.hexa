// self/test_spawn_pure.hexa — tests for self/runtime/spawn_pure.hexa

// ── inlined from self/runtime/spawn_pure.hexa ──────────────────
// codegen_c2 import/use resolution for runtime/*_pure.hexa is not wired
// for test files; inline the module contents (same pattern as test_rle_pure).

let mut rt_task_results = []
let mut rt_task_count   = 0

fn rt_spawn(f, arg) {
    let result = f(arg)
    let h = rt_task_count
    rt_task_results = rt_task_results.push(result)
    rt_task_count = rt_task_count + 1
    return h
}

fn rt_spawn2(f, a, b) {
    let result = f(a, b)
    let h = rt_task_count
    rt_task_results = rt_task_results.push(result)
    rt_task_count = rt_task_count + 1
    return h
}

fn rt_spawn3(f, a, b, c) {
    let result = f(a, b, c)
    let h = rt_task_count
    rt_task_results = rt_task_results.push(result)
    rt_task_count = rt_task_count + 1
    return h
}

fn rt_spawn_thunk(f) {
    let result = f()
    let h = rt_task_count
    rt_task_results = rt_task_results.push(result)
    rt_task_count = rt_task_count + 1
    return h
}

fn rt_join(h) {
    if h < 0 { return 0 }
    if h >= rt_task_count { return 0 }
    return rt_task_results[h]
}

fn rt_join_all(handles) {
    let n = len(handles)
    let mut out = []
    let mut i = 0
    while i < n {
        out = out.push(rt_join(handles[i]))
        i = i + 1
    }
    return out
}

fn rt_reset() {
    rt_task_results = []
    rt_task_count = 0
}

// ── test harness ────────────────────────────────────────────────

let mut pass = 0
let mut fail = 0

fn eq(name, a, b) {
    if a == b { pass = pass + 1 } else {
        fail = fail + 1
        println("[FAIL] " + name + " got " + to_string(a) + " want " + to_string(b))
    }
}

fn check(name, cond) {
    if cond { pass = pass + 1 } else {
        fail = fail + 1
        println("[FAIL] " + name)
    }
}

// ── task bodies ─────────────────────────────────────────────────

fn dbl(x) { return x * 2 }
fn add(a, b) { return a + b }
fn triple_sum(a, b, c) { return a + b + c }
fn answer() { return 42 }

println("=== spawn_pure test suite ===")

// NB: rt_reset() intentionally NOT called here — top-level `xs = []`
// reassignment inside a user fn currently disconnects from the module-level
// slot under the current codegen. spawn_pure's rt_reset still works when
// invoked from another fn; this test exercises the happy path only.

// ── 1. rt_spawn (1-arg) ─────────────────────────────────────────
let h0 = rt_spawn(dbl, 5)
eq("spawn1 handle=0", h0, 0)
eq("spawn1 result", rt_join(h0), 10)

let h1 = rt_spawn(dbl, 7)
eq("spawn1 handle=1", h1, 1)
eq("spawn1 result#2", rt_join(h1), 14)

// ── 2. rt_spawn2 (2-arg) ────────────────────────────────────────
let h2 = rt_spawn2(add, 3, 4)
eq("spawn2 handle=2", h2, 2)
eq("spawn2 result", rt_join(h2), 7)

// ── 3. rt_spawn3 (3-arg) ────────────────────────────────────────
let h3 = rt_spawn3(triple_sum, 1, 2, 3)
eq("spawn3 handle=3", h3, 3)
eq("spawn3 result", rt_join(h3), 6)

// ── 4. rt_spawn_thunk (0-arg) ───────────────────────────────────
let h4 = rt_spawn_thunk(answer)
eq("thunk handle=4", h4, 4)
eq("thunk result", rt_join(h4), 42)

// ── 5. rt_join out-of-range safety ──────────────────────────────
eq("join negative", rt_join(0 - 1), 0)
eq("join OOB", rt_join(999), 0)

// ── 6. rt_join_all preserves order ──────────────────────────────
let all = rt_join_all([h0, h1, h2, h3, h4])
eq("join_all length", len(all), 5)
eq("join_all[0]", all[0], 10)
eq("join_all[1]", all[1], 14)
eq("join_all[2]", all[2], 7)
eq("join_all[3]", all[3], 6)
eq("join_all[4]", all[4], 42)

// ── 7. additional handles after initial batch ───────────────────
let h5 = rt_spawn(dbl, 9)
eq("spawn #6 handle=5", h5, 5)
eq("spawn #6 result", rt_join(h5), 18)

// ── Summary ─────────────────────────────────────────────────────
println("")
println("pass: " + to_string(pass) + "  fail: " + to_string(fail))
if fail == 0 {
    println("ALL PASS")
} else {
    println("SOME FAILED")
}
