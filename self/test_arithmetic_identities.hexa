// ═══════════════════════════════════════════════════════════════════
//  test_arithmetic_identities.hexa — core integer/float arithmetic
//  Exhaustive identity coverage for +, -, *, /, %, comparison, bit ops.
//  Last verified: 2026-04-11
// ═══════════════════════════════════════════════════════════════════

// ── Integer addition ────────────────────────────────────────

proof a001_add_zero { assert 5 + 0 == 5 }
proof a002_add_identity { assert 0 + 42 == 42 }
proof a003_add_commut { assert 3 + 7 == 7 + 3 }
proof a004_add_assoc { assert (1 + 2) + 3 == 1 + (2 + 3) }
proof a005_add_neg { assert 10 + (0 - 10) == 0 }
proof a006_add_chain { assert 1 + 2 + 3 + 4 + 5 == 15 }
proof a007_add_large { assert 1000 + 2000 == 3000 }
proof a008_add_negative { assert (0 - 5) + (0 - 3) == 0 - 8 }
proof a009_add_mixed { assert 10 + (0 - 4) == 6 }
proof a010_add_n6 { assert 2 + 3 + 1 == 6 }

// ── Integer subtraction ─────────────────────────────────────

proof a011_sub_zero { assert 5 - 0 == 5 }
proof a012_sub_self { assert 7 - 7 == 0 }
proof a013_sub_negative { assert 3 - 10 == 0 - 7 }
proof a014_sub_chain { assert 100 - 10 - 20 - 30 == 40 }
proof a015_sub_large { assert 5000 - 2500 == 2500 }

// ── Integer multiplication ──────────────────────────────────

proof a016_mul_zero { assert 7 * 0 == 0 }
proof a017_mul_one { assert 42 * 1 == 42 }
proof a018_mul_commut { assert 6 * 4 == 4 * 6 }
proof a019_mul_assoc { assert (2 * 3) * 4 == 2 * (3 * 4) }
proof a020_mul_distrib { assert 2 * (3 + 4) == 2 * 3 + 2 * 4 }
proof a021_mul_powers { assert 2 * 2 * 2 == 8 }
proof a022_mul_n6_sigma { assert 2 * 6 == 12 }
proof a023_mul_n6_tau { assert 3 * 4 == 12 }
proof a024_mul_24 { assert 4 * 6 == 24 }
proof a025_mul_36 { assert 6 * 6 == 36 }

// ── Integer division ────────────────────────────────────────

proof a026_div_by_one { assert 42 / 1 == 42 }
proof a027_div_self { assert 36 / 36 == 1 }
proof a028_div_exact { assert 24 / 6 == 4 }
proof a029_div_sigma { assert 12 / 2 == 6 }
proof a030_div_large { assert 1000 / 10 == 100 }

// ── Modulo ──────────────────────────────────────────────────

proof a031_mod_zero { assert 12 % 6 == 0 }
proof a032_mod_one { assert 5 % 4 == 1 }
proof a033_mod_self { assert 7 % 7 == 0 }
proof a034_mod_less { assert 3 % 10 == 3 }
proof a035_mod_n6 { assert 12 % 6 == 0 }

// ── Comparison ──────────────────────────────────────────────

proof a036_lt { assert 3 < 5 }
proof a037_gt { assert 10 > 2 }
proof a038_le { assert 5 <= 5 }
proof a039_ge { assert 7 >= 7 }
proof a040_eq { assert 6 == 6 }
proof a041_ne { assert 5 != 6 }
proof a042_lt_false { assert !(5 < 3) }
proof a043_gt_false { assert !(2 > 10) }
proof a044_chain { assert 1 < 2 && 2 < 3 }
proof a045_transitive {
    let a = 1
    let b = 2
    let c = 3
    if a < b && b < c { assert a < c } else { assert false }
}

// ── Float arithmetic ────────────────────────────────────────

proof a046_f_add { assert 1.5 + 2.5 == 4.0 }
proof a047_f_sub { assert 5.0 - 1.5 == 3.5 }
proof a048_f_mul { assert 2.0 * 3.5 == 7.0 }
proof a049_f_div { assert 10.0 / 4.0 == 2.5 }
proof a050_f_neg { assert 0.0 - 3.14 == -3.14 }
proof a051_f_zero { assert 0.0 + 0.0 == 0.0 }
proof a052_f_id { assert 5.5 * 1.0 == 5.5 }
proof a053_f_half { assert 1.0 / 2.0 == 0.5 }
proof a054_f_third { assert 6.0 / 2.0 == 3.0 }
proof a055_f_n6 { assert 6.0 * 1.0 == 6.0 }

// ── Unary/absolute ──────────────────────────────────────────

proof a056_neg_pos { assert 0 - 5 < 0 }
proof a057_neg_neg {
    let a = 0 - 5
    let b = 0 - a
    assert b == 5
}
proof a058_double_neg {
    let a = 10
    let b = 0 - (0 - a)
    assert b == a
}
proof a059_add_neg_id {
    let a = 42
    assert a + (0 - a) == 0
}
proof a060_sub_is_add_neg {
    let a = 10
    let b = 3
    assert a - b == a + (0 - b)
}

// ── Power / repeated ops ────────────────────────────────────

proof a061_sq_of_6 { assert 6 * 6 == 36 }
proof a062_cube_of_2 { assert 2 * 2 * 2 == 8 }
proof a063_cube_of_3 { assert 3 * 3 * 3 == 27 }
proof a064_pow_4_2 { assert 4 * 4 == 16 }
proof a065_pow_2_10 { assert 2 * 2 * 2 * 2 * 2 * 2 * 2 * 2 * 2 * 2 == 1024 }

// ── Factorial via loop ──────────────────────────────────────

fn fact(n) {
    let mut result = 1
    let mut i = 1
    while i <= n { result = result * i; i = i + 1 }
    return result
}

proof a066_fact_0 { assert fact(0) == 1 }
proof a067_fact_1 { assert fact(1) == 1 }
proof a068_fact_2 { assert fact(2) == 2 }
proof a069_fact_3 { assert fact(3) == 6 }
proof a070_fact_4 { assert fact(4) == 24 }
proof a071_fact_5 { assert fact(5) == 120 }
proof a072_fact_6 { assert fact(6) == 720 }
proof a073_fact_n6 { assert fact(3) == 6 }  // n = 3! = 6

// ── Fibonacci via loop ──────────────────────────────────────

fn fib(n) {
    if n <= 1 { return n }
    let mut a = 0
    let mut b = 1
    let mut i = 2
    while i <= n {
        let c = a + b
        a = b
        b = c
        i = i + 1
    }
    return b
}

proof a074_fib_0 { assert fib(0) == 0 }
proof a075_fib_1 { assert fib(1) == 1 }
proof a076_fib_2 { assert fib(2) == 1 }
proof a077_fib_3 { assert fib(3) == 2 }
proof a078_fib_4 { assert fib(4) == 3 }
proof a079_fib_5 { assert fib(5) == 5 }
proof a080_fib_6 { assert fib(6) == 8 }
proof a081_fib_7 { assert fib(7) == 13 }
proof a082_fib_8 { assert fib(8) == 21 }
proof a083_fib_10 { assert fib(10) == 55 }

// ── GCD ─────────────────────────────────────────────────────

fn gcd(a, b) {
    let mut x = a
    let mut y = b
    while y != 0 {
        let r = x % y
        x = y
        y = r
    }
    return x
}

proof a084_gcd_6_4 { assert gcd(6, 4) == 2 }
proof a085_gcd_12_8 { assert gcd(12, 8) == 4 }
proof a086_gcd_prime { assert gcd(7, 13) == 1 }
proof a087_gcd_self { assert gcd(6, 6) == 6 }
proof a088_gcd_one { assert gcd(6, 1) == 1 }
proof a089_gcd_zero { assert gcd(6, 0) == 6 }
proof a090_gcd_24_36 { assert gcd(24, 36) == 12 }

// ── Primality ───────────────────────────────────────────────

fn is_prime(n) {
    if n < 2 { return false }
    if n == 2 { return true }
    if n % 2 == 0 { return false }
    let mut i = 3
    while i * i <= n {
        if n % i == 0 { return false }
        i = i + 2
    }
    return true
}

proof a091_prime_2 { assert is_prime(2) }
proof a092_prime_3 { assert is_prime(3) }
proof a093_prime_5 { assert is_prime(5) }
proof a094_prime_7 { assert is_prime(7) }
proof a095_prime_11 { assert is_prime(11) }
proof a096_not_prime_4 { assert !is_prime(4) }
proof a097_not_prime_6 { assert !is_prime(6) }
proof a098_not_prime_9 { assert !is_prime(9) }
proof a099_not_prime_1 { assert !is_prime(1) }
proof a100_prime_97 { assert is_prime(97) }

println("[test_arithmetic_identities] 100 proofs declared — run with --test")
