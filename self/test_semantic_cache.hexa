// ===================================================================
//  test_semantic_cache.hexa — Semantic Cache Tests
//
//  Verifies:
//    1. Empty cache returns miss
//    2. Store + lookup returns hit for identical embedding
//    3. Threshold filtering (similar but below threshold = miss)
//    4. LRU eviction when at capacity
//    5. Hit/miss stats tracking
//    6. cache_clear resets everything
//    7. cache_remove works correctly
//    8. Multiple entries, best match selection
//
//  Run: ./hexa self/test_semantic_cache.hexa
//  Minimum 10 check() statements.
// ===================================================================

// -- inlined from self/ml/semantic_cache.hexa --
// codegen import not wired for test files

// ===================================================================
//  self/ml/semantic_cache.hexa — Semantic Cache (pure Hexa)
//
//  Embedding-based similarity cache for LLM inference.
//  Cache hit when cosine similarity exceeds threshold.
//  LRU eviction on capacity overflow.
//
//  Public API:
//    create_cache(capacity, threshold)
//      Create a cache with max capacity entries and similarity threshold.
//
//    cache_lookup(cache, query_embedding)
//      Search cache for entry similar to query_embedding.
//      Returns [hit, response, similarity] or [false, "", 0.0].
//
//    cache_store(cache, embedding, response)
//      Store a new entry. Evicts LRU if at capacity.
//      Returns updated cache.
//
//    cache_stats(cache)
//      Return [hits, misses, hit_rate, size].
//
//    cache_clear(cache)
//      Clear all entries, reset stats.
//
//    cache_remove(cache, index)
//      Remove entry at index. Returns updated cache.
// ===================================================================

// ===================================================================
//  Vector math (self-contained to avoid circular imports)
// ===================================================================
fn sc_dot(a, b) {
    let n = len(a)
    let mut sum = 0.0
    let mut i = 0
    while i < n {
        sum = sum + a[i] * b[i]
        i = i + 1
    }
    return sum
}

fn sc_norm(v) {
    let mut sum = 0.0
    let n = len(v)
    let mut i = 0
    while i < n {
        sum = sum + v[i] * v[i]
        i = i + 1
    }
    return sqrt(sum)
}

fn sc_cosine(a, b) {
    let d = sc_dot(a, b)
    let na = sc_norm(a)
    let nb = sc_norm(b)
    let denom = na * nb
    if denom < 0.000001 { return 0.0 }
    return d / denom
}

// ===================================================================
//  Cache data structure
//
//  embeddings: array of float arrays (stored embeddings)
//  responses: array of strings (cached responses)
//  access_order: array of ints (access timestamps for LRU)
//  capacity: max entries
//  threshold: cosine similarity threshold for hit
//  hits: total cache hits
//  misses: total cache misses
//  tick: monotonic counter for LRU ordering
// ===================================================================
struct SemanticCache {
    embeddings: array,
    responses: array,
    access_order: array,
    capacity: int,
    threshold: float,
    hits: int,
    misses: int,
    tick: int
}

fn create_cache(capacity, threshold) {
    return SemanticCache {
        embeddings: [],
        responses: [],
        access_order: [],
        capacity: capacity,
        threshold: threshold,
        hits: 0,
        misses: 0,
        tick: 0
    }
}

// ===================================================================
//  cache_lookup: find most similar entry above threshold
//
//  Returns [hit_bool, response_string, similarity_float]
//  Updates access_order on hit, increments hit/miss counters.
// ===================================================================
fn cache_lookup(cache, query_embedding) {
    let n = len(cache.embeddings)
    if n == 0 {
        let new_cache = SemanticCache {
            embeddings: cache.embeddings,
            responses: cache.responses,
            access_order: cache.access_order,
            capacity: cache.capacity,
            threshold: cache.threshold,
            hits: cache.hits,
            misses: cache.misses + 1,
            tick: cache.tick
        }
        return [false, "", 0.0, new_cache]
    }

    // Find best match
    let mut best_idx = -1
    let mut best_sim = -1.0
    let mut i = 0
    while i < n {
        let sim = sc_cosine(query_embedding, cache.embeddings[i])
        if sim > best_sim {
            best_sim = sim
            best_idx = i
        }
        i = i + 1
    }

    if best_sim >= cache.threshold {
        // Cache hit - update access order
        let new_tick = cache.tick + 1
        let mut new_order = []
        i = 0
        while i < n {
            if i == best_idx {
                new_order = new_order + [new_tick]
            } else {
                new_order = new_order + [cache.access_order[i]]
            }
            i = i + 1
        }
        let new_cache = SemanticCache {
            embeddings: cache.embeddings,
            responses: cache.responses,
            access_order: new_order,
            capacity: cache.capacity,
            threshold: cache.threshold,
            hits: cache.hits + 1,
            misses: cache.misses,
            tick: new_tick
        }
        return [true, cache.responses[best_idx], best_sim, new_cache]
    }

    // Cache miss
    let miss_cache = SemanticCache {
        embeddings: cache.embeddings,
        responses: cache.responses,
        access_order: cache.access_order,
        capacity: cache.capacity,
        threshold: cache.threshold,
        hits: cache.hits,
        misses: cache.misses + 1,
        tick: cache.tick
    }
    return [false, "", best_sim, miss_cache]
}

// ===================================================================
//  cache_store: add entry, evict LRU if full
// ===================================================================
fn cache_store(cache, embedding, response) {
    let n = len(cache.embeddings)
    let new_tick = cache.tick + 1

    if n < cache.capacity {
        // Room available, just append
        return SemanticCache {
            embeddings: cache.embeddings + [embedding],
            responses: cache.responses + [response],
            access_order: cache.access_order + [new_tick],
            capacity: cache.capacity,
            threshold: cache.threshold,
            hits: cache.hits,
            misses: cache.misses,
            tick: new_tick
        }
    }

    // Evict LRU (lowest access_order)
    let mut lru_idx = 0
    let mut lru_tick = cache.access_order[0]
    let mut i = 1
    while i < n {
        if cache.access_order[i] < lru_tick {
            lru_tick = cache.access_order[i]
            lru_idx = i
        }
        i = i + 1
    }

    // Build new arrays without the evicted entry, then add new one
    let mut new_emb = []
    let mut new_resp = []
    let mut new_order = []
    i = 0
    while i < n {
        if i != lru_idx {
            new_emb = new_emb + [cache.embeddings[i]]
            new_resp = new_resp + [cache.responses[i]]
            new_order = new_order + [cache.access_order[i]]
        }
        i = i + 1
    }

    return SemanticCache {
        embeddings: new_emb + [embedding],
        responses: new_resp + [response],
        access_order: new_order + [new_tick],
        capacity: cache.capacity,
        threshold: cache.threshold,
        hits: cache.hits,
        misses: cache.misses,
        tick: new_tick
    }
}

// ===================================================================
//  cache_stats: return [hits, misses, hit_rate, size]
// ===================================================================
fn cache_stats(cache) {
    let total = cache.hits + cache.misses
    let mut hit_rate = 0.0
    if total > 0 {
        hit_rate = to_float(cache.hits) / to_float(total)
    }
    let size = len(cache.embeddings)
    return [cache.hits, cache.misses, hit_rate, size]
}

// ===================================================================
//  cache_clear: reset everything
// ===================================================================
fn cache_clear(cache) {
    return create_cache(cache.capacity, cache.threshold)
}

// ===================================================================
//  cache_remove: remove entry at index
// ===================================================================
fn cache_remove(cache, index) {
    let n = len(cache.embeddings)
    if index < 0 { return cache }
    if index >= n { return cache }

    let mut new_emb = []
    let mut new_resp = []
    let mut new_order = []
    let mut i = 0
    while i < n {
        if i != index {
            new_emb = new_emb + [cache.embeddings[i]]
            new_resp = new_resp + [cache.responses[i]]
            new_order = new_order + [cache.access_order[i]]
        }
        i = i + 1
    }

    return SemanticCache {
        embeddings: new_emb,
        responses: new_resp,
        access_order: new_order,
        capacity: cache.capacity,
        threshold: cache.threshold,
        hits: cache.hits,
        misses: cache.misses,
        tick: cache.tick
    }
}

println("[semantic_cache] loaded — embedding-based cache with LRU eviction")


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

println("===================================================================")
println("  Semantic Cache Test Suite")
println("===================================================================")

// Test embeddings (4-dim for simplicity)
let emb_a = [1.0, 0.0, 0.0, 0.0]
let emb_b = [0.0, 1.0, 0.0, 0.0]
let emb_c = [0.0, 0.0, 1.0, 0.0]
let emb_d = [0.0, 0.0, 0.0, 1.0]
let emb_a_close = [0.99, 0.05, 0.02, 0.01]
let emb_a_far = [0.5, 0.5, 0.5, 0.5]

// ===================================================================
//  T1: Empty cache returns miss
// ===================================================================
let cache0 = create_cache(3, 0.9)
let r1 = cache_lookup(cache0, emb_a)
check("T1 empty cache miss", r1[0] == false)

// ===================================================================
//  T2: Store + lookup identical embedding = hit
// ===================================================================
let cache1 = cache_store(cache0, emb_a, "response_a")
let r2 = cache_lookup(cache1, emb_a)
check("T2 identical embedding = hit", r2[0] == true)

// ===================================================================
//  T3: Hit returns correct response
// ===================================================================
check("T3 correct response returned", r2[1] == "response_a")

// ===================================================================
//  T4: Similarity close to 1.0 for identical
// ===================================================================
check("T4 similarity >= threshold for identical", r2[2] >= 0.9)

// ===================================================================
//  T5: Very similar embedding hits cache
// ===================================================================
let r5 = cache_lookup(cache1, emb_a_close)
check("T5 similar embedding = hit", r5[0] == true)

// ===================================================================
//  T6: Orthogonal embedding = miss (below threshold)
// ===================================================================
let r6 = cache_lookup(cache1, emb_b)
check("T6 orthogonal embedding = miss", r6[0] == false)

// ===================================================================
//  T7: LRU eviction when capacity exceeded
//       Cache capacity=3, add 4 entries, oldest should be evicted
// ===================================================================
let cache_lru_0 = create_cache(3, 0.9)
let cache_lru_1 = cache_store(cache_lru_0, emb_a, "resp_a")
let cache_lru_2 = cache_store(cache_lru_1, emb_b, "resp_b")
let cache_lru_3 = cache_store(cache_lru_2, emb_c, "resp_c")
// Cache is now full (3 entries). Add 4th entry => evict LRU (emb_a)
let cache_lru_4 = cache_store(cache_lru_3, emb_d, "resp_d")
let stats_after = cache_stats(cache_lru_4)
check("T7 LRU eviction: size still 3 after 4th insert", stats_after[3] == 3)

// ===================================================================
//  T8: Evicted entry is not found
// ===================================================================
let r8 = cache_lookup(cache_lru_4, emb_a)
check("T8 evicted entry miss", r8[0] == false)

// ===================================================================
//  T9: Non-evicted entries still found
// ===================================================================
let r9 = cache_lookup(cache_lru_4, emb_d)
check("T9 newest entry found", r9[0] == true)

// ===================================================================
//  T10: Hit/miss stats tracking
// ===================================================================
let cache_s0 = create_cache(5, 0.9)
let cache_s1 = cache_store(cache_s0, emb_a, "hello")
let r_miss = cache_lookup(cache_s1, emb_b)
let cache_s2 = r_miss[3]
let r_hit = cache_lookup(cache_s2, emb_a)
let cache_s3 = r_hit[3]
let stats = cache_stats(cache_s3)
check("T10 stats: 1 hit, 1 miss", stats[0] == 1 && stats[1] == 1)

// ===================================================================
//  T11: Hit rate calculation
// ===================================================================
check("T11 hit rate = 0.5", fabs(stats[2] - 0.5) < 0.01)

// ===================================================================
//  T12: cache_clear resets
// ===================================================================
let cache_cleared = cache_clear(cache_s3)
let clear_stats = cache_stats(cache_cleared)
check("T12 cache_clear: size=0, hits=0", clear_stats[3] == 0 && clear_stats[0] == 0)

// ===================================================================
//  T13: cache_remove removes specific entry
// ===================================================================
let cache_rm_0 = create_cache(5, 0.9)
let cache_rm_1 = cache_store(cache_rm_0, emb_a, "ra")
let cache_rm_2 = cache_store(cache_rm_1, emb_b, "rb")
let cache_rm_3 = cache_remove(cache_rm_2, 0)
let rm_stats = cache_stats(cache_rm_3)
check("T13 remove: size 2->1", rm_stats[3] == 1)

// ===================================================================
//  T14: Low threshold accepts dissimilar entries
// ===================================================================
let cache_low = create_cache(5, 0.1)
let cache_low_1 = cache_store(cache_low, emb_a, "low_resp")
let r14 = cache_lookup(cache_low_1, emb_a_far)
check("T14 low threshold: dissimilar hits", r14[0] == true)

// ===================================================================
//  Summary
// ===================================================================
println("")
println("pass=" + to_string(pass_count) + " fail=" + to_string(fail_count))
if fail_count == 0 {
    println("ALL PASS")
} else {
    println("FAILED")
}
println(to_string(pass_count) + " passed")
