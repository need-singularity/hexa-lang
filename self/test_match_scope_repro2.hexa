// Reproduce match scope leakage through the self-hosted interpreter

enum Result {
    Ok(val),
    Err(msg)
}

// Test: match binding 'val' in and_then leaking across calls
fn and_then(r, f) {
    return match r {
        Ok(val) -> f(val),
        Err(e) -> Result::Err(e)
    }
}

// This function uses a variable named 'val'
// If and_then's match leaks 'val', this could be affected
fn process(x) {
    return Result::Ok(x + 100)
}

let r1 = Result::Ok(1)
let r2 = Result::Ok(2)

let out1 = and_then(r1, process)
let out2 = and_then(r2, process)

let v1 = match out1 { Ok(x) -> x, Err(_) -> -1 }
let v2 = match out2 { Ok(x) -> x, Err(_) -> -1 }

println("v1 = " + to_string(v1))
println("v2 = " + to_string(v2))

if v1 == 101 && v2 == 102 {
    println("PASS")
} else {
    println("FAIL: expected 101,102 got " + to_string(v1) + "," + to_string(v2))
}

// Test: match binding leakage when same fn called in a loop
fn unwrap(r) {
    return match r {
        Ok(val) -> val,
        Err(e) -> { throw "error: " + to_string(e) }
    }
}

let mut results = []
let mut i = 0
while i < 5 {
    let r = Result::Ok(i * 10)
    results = results.push(unwrap(r))
    i = i + 1
}
println("results = " + to_string(results))

let mut all_ok = true
i = 0
while i < 5 {
    if results[i] != i * 10 {
        println("FAIL at index " + to_string(i) + ": expected " + to_string(i * 10) + " got " + to_string(results[i]))
        all_ok = false
    }
    i = i + 1
}
if all_ok { println("PASS: loop test") }
