// ═══════════════════════════════════════════════════════════════════
//  test_ccp.hexa — #37 Conditional Constant Propagation (CCP)
//
//  Verifies that constants propagated through branch conditions
//  produce correct results. The CCP pass narrows variable ranges
//  and eliminates dead branches when conditions are known at compile time.
//
//  Tests:
//    1. if true → taken
//    2. if false → not taken (else taken)
//    3. Constant comparison (1 < 2) → true branch
//    4. Constant comparison (5 == 3) → false branch
//    5. Nested if with known conditions
//    6. Variable known to be constant → branch resolved
//    7. Variable reassigned → branch not resolved (stays dynamic)
//    8. Constant propagation across let bindings
//    9. Negation of known bool → resolved
//   10. Chain of constant ifs
//   11. Mixed constant and dynamic conditions
//   12. Arithmetic result used in comparison
//
//  Run: ./hexa test self/test_ccp.hexa
// ═══════════════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA #37 Conditional Constant Propagation (CCP) Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. if true → always taken ───────────────────────────────
fn always_true_branch() {
    if true { return 1 }
    return 0
}
check("#37-01 if true", always_true_branch(), 1)

// ── 2. if false → else taken ────────────────────────────────
fn always_false_branch() {
    if false { return 1 }
    return 0
}
check("#37-02 if false", always_false_branch(), 0)

// ── 3. Constant comparison true (1 < 2) ─────────────────────
fn const_compare_true() {
    let x = 1
    let y = 2
    if x < y { return 10 }
    return 20
}
check("#37-03 1 < 2", const_compare_true(), 10)

// ── 4. Constant comparison false (5 == 3) ───────────────────
fn const_compare_false() {
    let x = 5
    let y = 3
    if x == y { return 10 }
    return 20
}
check("#37-04 5 == 3", const_compare_false(), 20)

// ── 5. Constant greater-than ────────────────────────────────
fn const_gt() {
    let a = 10
    let b = 5
    if a > b { return a }
    return b
}
check("#37-05 10 > 5", const_gt(), 10)

// ── 6. Constant equality true ───────────────────────────────
fn const_eq_true() {
    let v = 42
    if v == 42 { return 1 }
    return 0
}
check("#37-06 42 == 42", const_eq_true(), 1)

// ── 7. Constant not-equal ───────────────────────────────────
fn const_neq() {
    let a = 3
    let b = 4
    if a != b { return 100 }
    return 200
}
check("#37-07 3 != 4", const_neq(), 100)

// ── 8. Dynamic condition (not resolved) ─────────────────────
fn dynamic_branch(x) {
    if x > 0 { return 1 }
    return -1
}
check("#37-08 dynamic(5)", dynamic_branch(5), 1)
check("#37-09 dynamic(-1)", dynamic_branch(-1), -1)

// ── 9. Cascading constants ──────────────────────────────────
fn cascade_const() {
    let a = 10
    let b = 20
    let c = a + b
    // c is not directly propagated (not a literal), so this tests dynamic
    if a < b { return a + b }
    return 0
}
check("#37-10 cascade", cascade_const(), 30)

// ── 10. Boolean variable propagation ────────────────────────
fn bool_prop() {
    let flag = true
    if flag { return 42 }
    return 0
}
check("#37-11 bool prop", bool_prop(), 42)

// ── 11. Boolean false propagation ───────────────────────────
fn bool_false_prop() {
    let flag = false
    if flag { return 42 }
    return 99
}
check("#37-12 bool false", bool_false_prop(), 99)

// ── 12. Constant LE (<=) ────────────────────────────────────
fn const_le() {
    let x = 5
    let y = 5
    if x <= y { return 1 }
    return 0
}
check("#37-13 5 <= 5", const_le(), 1)

// ── 13. Constant GE (>=) ────────────────────────────────────
fn const_ge() {
    let x = 3
    let y = 7
    if x >= y { return 1 }
    return 0
}
check("#37-14 3 >= 7", const_ge(), 0)

// ── 14. Multiple branches with constants ────────────────────
fn multi_branch() {
    let a = 1
    let b = 2
    let mut result = 0
    if a < b { result = result + 10 }
    if a == 1 { result = result + 20 }
    if b == 3 { result = result + 100 }
    return result
}
check("#37-15 multi branch", multi_branch(), 30)

// ── 15. Reassigned variable (not constant after assign) ─────
fn reassigned_var() {
    let mut x = 5
    x = 10
    // After reassignment, x=10 (CCP should track this)
    if x == 10 { return 1 }
    return 0
}
check("#37-16 reassigned", reassigned_var(), 1)

// ── 16. Accumulator in loop (CCP clears at loop boundary) ──
fn loop_sum() {
    let mut s = 0
    let mut i = 0
    while i < 5 {
        s = s + i
        i = i + 1
    }
    return s
}
check("#37-17 loop sum", loop_sum(), 10)

// ── 17. Deeply nested let + comparison ──────────────────────
fn deep_let() {
    let a = 3
    let b = a
    let c = b
    // b and c are copies, but copy-prop is a different pass
    // CCP only tracks literal assignments directly
    if a == 3 { return 1 }
    return 0
}
check("#37-18 deep let", deep_let(), 1)

// ── 18. Zero comparison ─────────────────────────────────────
fn zero_cmp() {
    let x = 0
    if x == 0 { return true }
    return false
}
check("#37-19 zero cmp", zero_cmp(), true)

// ── 19. Negative constant ───────────────────────────────────
fn neg_const() {
    let x = -5
    if x < 0 { return 1 }
    return 0
}
check("#37-20 neg const", neg_const(), 1)

// ── Summary ─────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  CCP: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")
if fail_count > 0 {
    println("FAIL")
}
