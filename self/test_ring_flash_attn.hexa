// ═══════════════════════════════════════════════════════════════
//  test_ring_flash_attn.hexa — Ring-FlashAttention correctness tests
//
//  ML roadmap #221 — Ring Attention + FlashAttention block fusion
//
//  Verifies (32 tests):
//    #1  rfa_exp(0) = 1.0
//    #2  rfa_exp(huge) is finite (clamped)
//    #3  rfa_exp(-huge) is positive (clamped)
//    #4  rfa_row_max basic
//    #5  rfa_row_max single element
//    #6  rfa_row_sum basic
//    #7  rfa_row_sum empty (n=0) returns 0
//    #8  rfa_shard_kv: chunks count == n_ranks
//    #9  rfa_shard_kv: each chunk has seq_len // n_ranks rows
//    #10 rfa_shard_kv: shard contents reassemble to original
//    #11 rfa_rotate_ring: shape preserved
//    #12 rfa_rotate_ring: step=0 is identity
//    #13 rfa_rotate_ring: step=n_ranks full cycle is identity
//    #14 rfa_rotate_ring: step=1 shifts by one
//    #15 rfa_online_softmax_init: m = -inf
//    #16 rfa_online_softmax_init: l = 0
//    #17 rfa_online_softmax_init: out is zeros
//    #18 rfa_compute_block: scores shape [q_len, k_len]
//    #19 rfa_compute_block: weighted shape [q_len, d_head]
//    #20 rfa_finalize_output: divides by l correctly
//    #21 rfa_finalize_output: l=0 yields 0 (no NaN)
//    #22 rfa_causal_mask_block: future positions = -inf
//    #23 rfa_causal_mask_block: causal positions preserved
//    #24 rfa_reference_attention: shape [seq_len, d_head]
//    #25 rfa_reference_attention: rows are convex combinations of V
//    #26 Online softmax merge ≡ full softmax (single-shot)
//    #27 rfa_ring_attention: shape [seq_len, d_head]
//    #28 rfa_ring_attention: matches reference (n_ranks=1)
//    #29 rfa_ring_attention: matches reference (n_ranks=2)
//    #30 rfa_ring_attention: matches reference (n_ranks=4)
//    #31 rfa_ring_attention: n_ranks=2 == n_ranks=4 (same answer)
//    #32 rfa_ring_attention: numerically stable with large scores
//
//  Run: PATH=$HOME/.cargo/bin:$PATH ./hexa self/test_ring_flash_attn.hexa
// ═══════════════════════════════════════════════════════════════

// -- inlined from self/ml/ring_flash_attn.hexa --
// codegen import not wired for test files

// ═══════════════════════════════════════════════════════════════
//  self/ml/ring_flash_attn.hexa — Ring-FlashAttention
//
//  ML roadmap #221 — Ring Attention + FlashAttention block fusion
//
//  Combines two complementary techniques:
//    - Ring Attention   (Liu et al. 2023): K/V sharded across ranks,
//                       rotated ring-wise. Each rank only ever holds
//                       seq_len / n_ranks of the KV at any moment, so
//                       no single rank needs to materialize the full
//                       attention matrix or even the full KV cache.
//    - FlashAttention   (Dao et al. 2022): tiled block compute with
//                       online softmax rescaling. Computes attention
//                       in O(N) memory per block, never materializing
//                       the [N, N] score matrix.
//
//  The fusion gives full-context attention across N ranks where each
//  rank holds only seq_len / n_ranks KV at once, AND each rank's
//  per-tile compute uses online-softmax rescaling so the score tile
//  never has to be kept around — exactly the recipe used by modern
//  long-context training (>1M tokens) systems.
//
//  CPU simulation: ranks are array indices, communication is modeled
//  by KV shard rotation. Real deployment maps each rank to a GPU and
//  rotation to NCCL send/recv. Algorithm is unchanged.
//
//  API (prefix rfa_):
//    rfa_shard_kv(K, V, n_ranks, seq_len, d_head)
//      → [list_of_K_shards, list_of_V_shards]
//
//    rfa_rotate_ring(shards, n_ranks, step)
//      → shards rotated by `step` positions (step=0 identity,
//         step=n_ranks full cycle = identity)
//
//    rfa_online_softmax_init(q_len, d_head)
//      → [m, l, out] with m = -inf, l = 0, out = zeros[q_len, d_head]
//
//    rfa_online_softmax_update(m_old, l_old, out_old,
//                              scores_new, V_new,
//                              q_len, d_head, kv_len)
//      → [m, l, out] merged via the FlashAttention-2 rescale rule
//
//    rfa_compute_block(Q_block, K_block, V_block, q_len, k_len, d_head)
//      → [scores, weighted_sum] for one tile (used by ring loop)
//
//    rfa_finalize_output(m, l, out, q_len, d_head)
//      → final output (divide accumulator by l)
//
//    rfa_ring_attention(Q, K_shards, V_shards, n_ranks, rank,
//                       seq_len, d_head)
//      → per-rank output [seq_len, d_head] (the simulator runs every
//         rank's view in sequence so the full output is observable)
//
//    rfa_reference_attention(Q, K, V, seq_len, d_head)
//      → non-tiled, non-ringed full softmax reference
//
//    rfa_causal_mask_block(scores, q_start, k_start, q_len, k_len)
//      → applies causal mask to a tile in place
//
//  Helpers:
//    rfa_row_max(row, n)         row max
//    rfa_row_sum(row, n)         row sum
//    rfa_exp(x)                  bounded scalar exp
//
//  AI-NATIVE attrs:
//    @hot      — every forward step
//    @parallel — ring step is independent across ranks
//    @fuse     — online softmax fused with KV rotation
//    @pure     — no hidden mutation
// ═══════════════════════════════════════════════════════════════

// ─── numeric helpers ─────────────────────────────────────────

fn rfa_zeros_1d(n) {
    let mut v = []
    for _i in 0..n {
        v = v + [0.0]
    }
    return v
}

fn rfa_zeros_2d(r, c) {
    let mut m = []
    for _i in 0..r {
        let mut row = []
        for _j in 0..c {
            row = row + [0.0]
        }
        m = m + [row]
    }
    return m
}

fn rfa_neg_inf_1d(n) {
    let mut v = []
    for _i in 0..n {
        v = v + [0.0 - 1.0e30]
    }
    return v
}

fn rfa_max_f(a, b) {
    if a > b {
        return a
    }
    return b
}

fn rfa_min_i(a, b) {
    if a < b {
        return a
    }
    return b
}

fn rfa_abs(x) {
    if x < 0.0 {
        return 0.0 - x
    }
    return x
}

// Bounded scalar exp — clamps the argument so very large/very negative
// scores don't overflow the host exp(). Used by every softmax helper.
fn rfa_exp(x) {
    let mut v = x
    if v > 50.0 {
        v = 50.0
    }
    if v < 0.0 - 50.0 {
        v = 0.0 - 50.0
    }
    return exp(v)
}

// Row max over the first n entries.
fn rfa_row_max(row, n) {
    if n <= 0 {
        return 0.0 - 1.0e30
    }
    let mut m = row[0]
    for j in 1..n {
        if row[j] > m {
            m = row[j]
        }
    }
    return m
}

// Row sum over the first n entries.
fn rfa_row_sum(row, n) {
    let mut s = 0.0
    for j in 0..n {
        s = s + row[j]
    }
    return s
}

// ═══════════════════════════════════════════════════════════════
//  Reference (non-tiled, non-ringed) full attention
//
//  Used by tests as the ground truth that ring + flash combined must
//  reproduce within numerical tolerance.
// ═══════════════════════════════════════════════════════════════
fn rfa_reference_attention(Q, K, V, seq_len, d_head) {
    let scale = 1.0 / sqrt(d_head * 1.0)
    let mut out = rfa_zeros_2d(seq_len, d_head)

    for i in 0..seq_len {
        // scores[j] = Q[i] · K[j] * scale
        let mut scores = rfa_zeros_1d(seq_len)
        for j in 0..seq_len {
            let mut dot = 0.0
            for k in 0..d_head {
                dot = dot + Q[i][k] * K[j][k]
            }
            scores[j] = dot * scale
        }

        // numerically stable softmax
        let m = rfa_row_max(scores, seq_len)
        let mut sum_exp = 0.0
        let mut exps = rfa_zeros_1d(seq_len)
        for j in 0..seq_len {
            let e = rfa_exp(scores[j] - m)
            exps[j] = e
            sum_exp = sum_exp + e
        }

        // weighted sum of V
        for k in 0..d_head {
            let mut acc = 0.0
            for j in 0..seq_len {
                acc = acc + exps[j] * V[j][k]
            }
            out[i][k] = acc / sum_exp
        }
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
//  KV sharding — split (K, V) into n_ranks contiguous chunks along
//  the sequence dimension. Each chunk has seq_len / n_ranks rows.
//
//  Returns [K_shards, V_shards] where shards[r] is the [chunk, d_head]
//  slice owned by rank r.
// ═══════════════════════════════════════════════════════════════
fn rfa_shard_kv(K, V, n_ranks, seq_len, d_head) {
    let chunk = seq_len / n_ranks

    let mut K_shards = []
    let mut V_shards = []
    for r in 0..n_ranks {
        let start = r * chunk
        let mut Ks = []
        let mut Vs = []
        for i in 0..chunk {
            let mut krow = []
            let mut vrow = []
            for k in 0..d_head {
                krow = krow + [K[start + i][k]]
                vrow = vrow + [V[start + i][k]]
            }
            Ks = Ks + [krow]
            Vs = Vs + [vrow]
        }
        K_shards = K_shards + [Ks]
        V_shards = V_shards + [Vs]
    }
    return [K_shards, V_shards]
}

// ═══════════════════════════════════════════════════════════════
//  Ring rotation — rotate shards by `step` positions.
//
//  After step=1, rank r holds what rank (r-1) used to hold (i.e. the
//  shards shift one slot toward higher index, wrapping around). With
//  step = n_ranks the rotation is the identity.
// ═══════════════════════════════════════════════════════════════
fn rfa_rotate_ring(shards, n_ranks, step) {
    let s = ((step % n_ranks) + n_ranks) % n_ranks
    let mut out = []
    for r in 0..n_ranks {
        let src = ((r - s) % n_ranks + n_ranks) % n_ranks
        out = out + [shards[src]]
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
//  Online softmax — initial state
//
//  m starts at -inf so that any first observed score wins the running
//  max comparison. l starts at 0 so the first tile_sum is the only
//  contribution. out starts at zeros for the same reason.
//
//  Returns [m, l, out] as a homogeneous list.
// ═══════════════════════════════════════════════════════════════
fn rfa_online_softmax_init(q_len, d_head) {
    let m = rfa_neg_inf_1d(q_len)
    let l = rfa_zeros_1d(q_len)
    let out = rfa_zeros_2d(q_len, d_head)
    return [m, l, out]
}

// ═══════════════════════════════════════════════════════════════
//  Online softmax — merge a new tile (scores_new, V_new) into the
//  running (m_old, l_old, out_old).
//
//  This is the FlashAttention-2 update rule:
//      m_new      = max(m_old, max(scores_new))
//      alpha      = exp(m_old - m_new)
//      tile_sum   = sum_j exp(scores_new[j] - m_new)
//      l_new      = l_old * alpha + tile_sum
//      out_new    = out_old * alpha + sum_j exp(scores_new[j]-m_new) * V_new[j]
//
//  scores_new must be [q_len, kv_len], V_new must be [kv_len, d_head].
// ═══════════════════════════════════════════════════════════════
fn rfa_online_softmax_update(m_old, l_old, out_old,
                             scores_new, V_new,
                             q_len, d_head, kv_len) {
    let mut m_out = rfa_zeros_1d(q_len)
    let mut l_out = rfa_zeros_1d(q_len)
    let mut out_out = rfa_zeros_2d(q_len, d_head)

    for qi in 0..q_len {
        // tile max
        let row = scores_new[qi]
        let mut tile_max = 0.0 - 1.0e30
        for kj in 0..kv_len {
            if row[kj] > tile_max {
                tile_max = row[kj]
            }
        }

        let m_new = rfa_max_f(m_old[qi], tile_max)
        let alpha = rfa_exp(m_old[qi] - m_new)

        // tile_sum + p_row
        let mut tile_sum = 0.0
        let mut p_row = rfa_zeros_1d(kv_len)
        for kj in 0..kv_len {
            let p = rfa_exp(row[kj] - m_new)
            p_row[kj] = p
            tile_sum = tile_sum + p
        }

        let l_new = l_old[qi] * alpha + tile_sum

        // out scale + accumulate
        for k in 0..d_head {
            let scaled = out_old[qi][k] * alpha
            let mut acc = scaled
            for kj in 0..kv_len {
                acc = acc + p_row[kj] * V_new[kj][k]
            }
            out_out[qi][k] = acc
        }

        m_out[qi] = m_new
        l_out[qi] = l_new
    }
    return [m_out, l_out, out_out]
}

// ═══════════════════════════════════════════════════════════════
//  Compute one block — used by the ring inner loop.
//
//  Returns [scores, weighted_sum] where:
//    scores        : [q_len, k_len]   raw QK^T * scale (no softmax)
//    weighted_sum  : [q_len, d_head]  exp(scores - row_max) · V_block
//                                     (NOT yet divided by row_sum;
//                                      that happens in finalize)
//
//  This is enough for callers that already track (m, l) externally —
//  i.e. ring_attention, which folds successive blocks via
//  online_softmax_update.
// ═══════════════════════════════════════════════════════════════
fn rfa_compute_block(Q_block, K_block, V_block, q_len, k_len, d_head) {
    let scale = 1.0 / sqrt(d_head * 1.0)

    let mut scores = rfa_zeros_2d(q_len, k_len)
    for qi in 0..q_len {
        for kj in 0..k_len {
            let mut dot = 0.0
            for k in 0..d_head {
                dot = dot + Q_block[qi][k] * K_block[kj][k]
            }
            scores[qi][kj] = dot * scale
        }
    }

    let mut weighted = rfa_zeros_2d(q_len, d_head)
    for qi in 0..q_len {
        let row = scores[qi]
        let row_max = rfa_row_max(row, k_len)
        for k in 0..d_head {
            let mut acc = 0.0
            for kj in 0..k_len {
                let p = rfa_exp(row[kj] - row_max)
                acc = acc + p * V_block[kj][k]
            }
            weighted[qi][k] = acc
        }
    }
    return [scores, weighted]
}

// ═══════════════════════════════════════════════════════════════
//  Finalize — divide the accumulator by l to obtain the normalized
//  output. Mirrors the trailing reduction in FlashAttention.
// ═══════════════════════════════════════════════════════════════
fn rfa_finalize_output(m, l, out, q_len, d_head) {
    let mut final_out = rfa_zeros_2d(q_len, d_head)
    for qi in 0..q_len {
        let li = l[qi]
        let inv = if li > 0.0 { 1.0 / li } else { 0.0 }
        for k in 0..d_head {
            final_out[qi][k] = out[qi][k] * inv
        }
    }
    return final_out
}

// ═══════════════════════════════════════════════════════════════
//  Apply causal mask in place to a [q_len, k_len] score tile.
//
//  q_start / k_start are the absolute (global) row/col offsets of
//  this tile inside the full attention matrix. A score is masked
//  whenever its global key index is strictly greater than its global
//  query index.
// ═══════════════════════════════════════════════════════════════
fn rfa_causal_mask_block(scores, q_start, k_start, q_len, k_len) {
    let mut out = rfa_zeros_2d(q_len, k_len)
    for qi in 0..q_len {
        for kj in 0..k_len {
            let global_q = q_start + qi
            let global_k = k_start + kj
            if global_k > global_q {
                out[qi][kj] = 0.0 - 1.0e30
            } else {
                out[qi][kj] = scores[qi][kj]
            }
        }
    }
    return out
}

// ═══════════════════════════════════════════════════════════════
//  Ring Attention — full forward pass
//
//  Q is replicated across ranks (every rank holds the full Q for
//  simplicity in the simulator; the production version would shard
//  Q row-wise too). K_shards / V_shards are produced by rfa_shard_kv.
//
//  At each ring step the rank looks at one shard, computes the score
//  tile via rfa_compute_block, and folds it into its running
//  (m, l, out) accumulator with rfa_online_softmax_update. After
//  n_ranks steps every rank has seen every shard exactly once and
//  the accumulator is ready for finalize.
//
//  The `rank` argument is a placeholder for future per-rank Q
//  sharding; in the simulator we always emit the full [seq_len,
//  d_head] output for asserting against the reference.
// ═══════════════════════════════════════════════════════════════
@hot @parallel @fuse
fn rfa_ring_attention(Q, K_shards, V_shards, n_ranks, rank, seq_len, d_head) {
    let chunk = seq_len / n_ranks
    let init = rfa_online_softmax_init(seq_len, d_head)
    let mut m_acc = init[0]
    let mut l_acc = init[1]
    let mut out_acc = init[2]

    let mut K_cur = K_shards
    let mut V_cur = V_shards

    for step in 0..n_ranks {
        // Which original shard is currently sitting at slot 0?
        let src0 = ((0 - step) % n_ranks + n_ranks) % n_ranks
        let K_block = K_cur[0]
        let V_block = V_cur[0]
        let k_start = src0 * chunk

        let block = rfa_compute_block(Q, K_block, V_block, seq_len, chunk, d_head)
        let scores_block = block[0]

        let updated = rfa_online_softmax_update(m_acc, l_acc, out_acc,
                                                scores_block, V_block,
                                                seq_len, d_head, chunk)
        m_acc = updated[0]
        l_acc = updated[1]
        out_acc = updated[2]

        // rotate shards by 1 in preparation for the next step
        K_cur = rfa_rotate_ring(K_cur, n_ranks, 1)
        V_cur = rfa_rotate_ring(V_cur, n_ranks, 1)
    }

    return rfa_finalize_output(m_acc, l_acc, out_acc, seq_len, d_head)
}

println("[ring_flash_attn] module loaded — ring + flash fused attention ready")


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check(id, cond) {
    if cond {
        println("[PASS] #" + to_string(id))
        pass_count = pass_count + 1
    } else {
        println("[FAIL] #" + to_string(id))
        fail_count = fail_count + 1
    }
}

fn t_fabs(x) {
    if x < 0.0 {
        return 0.0 - x
    }
    return x
}

fn vec_close(a, b, eps) {
    if len(a) != len(b) {
        return false
    }
    let mut i = 0

    while i < len(a) {
        if t_fabs(a[i] - b[i]) > eps {
            return false
        }
    }
    return true
}

fn mat_close(A, B, eps) {
    if len(A) != len(B) {
        return false
    }
    let mut i = 0

    while i < len(A) {
        if !vec_close(A[i], B[i], eps) {
            return false
        }
    }
    return true
}

fn mat_max_diff(A, B) {
    let mut mx = 0.0
    let mut i = 0

    while i < len(A) {
        let mut j = 0

        while j < len(A[i]) {
            let d = t_fabs(A[i][j] - B[i][j])
            if d > mx {
                mx = d
            }
        }
    }
    return mx
}

println("=======================================================")
println("  Ring-FlashAttention test suite (#221)")
println("=======================================================")

let eps = 1.0e-5
let big_eps = 1.0e-4

// ─── #1 rfa_exp(0) ────────────────────────────────────────────
let e0 = rfa_exp(0.0)
check(1, t_fabs(e0 - 1.0) < 1.0e-9)

// ─── #2 rfa_exp(huge) finite ──────────────────────────────────
let e_big = rfa_exp(1.0e9)
check(2, e_big > 0.0 && e_big < 1.0e30)

// ─── #3 rfa_exp(-huge) positive (clamped) ────────────────────
let e_small = rfa_exp(0.0 - 1.0e9)
check(3, e_small > 0.0)

// ─── #4 rfa_row_max basic ────────────────────────────────────
let row1 = [1.0, 5.0, 3.0, 2.0]
check(4, t_fabs(rfa_row_max(row1, 4) - 5.0) < 1.0e-9)

// ─── #5 rfa_row_max single element ───────────────────────────
let row1b = [7.5]
check(5, t_fabs(rfa_row_max(row1b, 1) - 7.5) < 1.0e-9)

// ─── #6 rfa_row_sum basic ────────────────────────────────────
let row2 = [1.0, 2.0, 3.0, 4.0]
check(6, t_fabs(rfa_row_sum(row2, 4) - 10.0) < 1.0e-9)

// ─── #7 rfa_row_sum n=0 ──────────────────────────────────────
check(7, t_fabs(rfa_row_sum(row2, 0) - 0.0) < 1.0e-9)

// ─── Build a small fixture: seq_len=4, d_head=3 ──────────────
let Q = [
    [0.10, 0.50, 0.90],
    [0.80, 0.20, 0.40],
    [0.30, 0.70, 0.10],
    [0.60, 0.40, 0.80]
]
let K = [
    [0.20, 0.10, 0.40],
    [0.50, 0.30, 0.20],
    [0.10, 0.60, 0.80],
    [0.90, 0.70, 0.50]
]
let V = [
    [1.00, 0.00, 0.50],
    [0.00, 1.00, 0.50],
    [0.50, 0.50, 1.00],
    [1.00, 1.00, 0.00]
]
let seq_len = 4
let d_head = 3

// ─── #8 rfa_shard_kv: count ──────────────────────────────────
let shards = rfa_shard_kv(K, V, 2, seq_len, d_head)
let K_sh = shards[0]
let V_sh = shards[1]
check(8, len(K_sh) == 2 && len(V_sh) == 2)

// ─── #9 rfa_shard_kv: chunk size ─────────────────────────────
check(9, len(K_sh[0]) == 2 && len(K_sh[1]) == 2 && len(V_sh[0]) == 2 && len(V_sh[1]) == 2)

// ─── #10 rfa_shard_kv: contents ──────────────────────────────
let mut shard_ok = true
let mut r = 0

while r < 2 {
    let mut i = 0

    while i < 2 {
        let global = r * 2 + i
        if !vec_close(K_sh[r][i], K[global], eps) { shard_ok = false }
        if !vec_close(V_sh[r][i], V[global], eps) { shard_ok = false }
    }
}
check(10, shard_ok)

// ─── #11 rfa_rotate_ring: shape preserved ────────────────────
let rot1 = rfa_rotate_ring(K_sh, 2, 1)
check(11, len(rot1) == 2 && len(rot1[0]) == 2 && len(rot1[1]) == 2)

// ─── #12 rfa_rotate_ring: step=0 identity ────────────────────
let rot0 = rfa_rotate_ring(K_sh, 2, 0)
let mut rot0_ok = true
let mut r = 0

while r < 2 {
    let mut i = 0

    while i < 2 {
        if !vec_close(rot0[r][i], K_sh[r][i], eps) { rot0_ok = false }
    }
}
check(12, rot0_ok)

// ─── #13 rfa_rotate_ring: full cycle == identity ─────────────
let K_sh_full = rfa_shard_kv(K, V, 4, seq_len, d_head)[0]
let rot_full = rfa_rotate_ring(K_sh_full, 4, 4)
let mut full_ok = true
let mut r = 0

while r < 4 {
    if !vec_close(rot_full[r][0], K_sh_full[r][0], eps) { full_ok = false }
}
check(13, full_ok)

// ─── #14 rfa_rotate_ring: step=1 shifts by one ───────────────
//   new[r] = old[(r-1+n)%n]   so new[1] = old[0]
let rot_one = rfa_rotate_ring(K_sh_full, 4, 1)
check(14, vec_close(rot_one[1][0], K_sh_full[0][0], eps) &&
          vec_close(rot_one[0][0], K_sh_full[3][0], eps))

// ─── #15 rfa_online_softmax_init: m = -inf ───────────────────
let init = rfa_online_softmax_init(seq_len, d_head)
let m_init = init[0]
let l_init = init[1]
let out_init = init[2]
check(15, m_init[0] < (0.0 - 1.0e29) && m_init[seq_len - 1] < (0.0 - 1.0e29))

// ─── #16 rfa_online_softmax_init: l = 0 ──────────────────────
let mut l_ok = true
let mut i = 0

while i < seq_len {
    if t_fabs(l_init[i] - 0.0) > 1.0e-12 { l_ok = false }
}
check(16, l_ok)

// ─── #17 rfa_online_softmax_init: out zeros ──────────────────
let mut out_zero_ok = true
let mut i = 0

while i < seq_len {
    let mut k = 0

    while k < d_head {
        if t_fabs(out_init[i][k] - 0.0) > 1.0e-12 { out_zero_ok = false }
    }
}
check(17, out_zero_ok)

// ─── #18 rfa_compute_block: scores shape ─────────────────────
let blk = rfa_compute_block(Q, K, V, seq_len, seq_len, d_head)
let blk_scores = blk[0]
let blk_weighted = blk[1]
check(18, len(blk_scores) == seq_len && len(blk_scores[0]) == seq_len)

// ─── #19 rfa_compute_block: weighted shape ───────────────────
check(19, len(blk_weighted) == seq_len && len(blk_weighted[0]) == d_head)

// ─── #20 rfa_finalize_output: divides by l ───────────────────
//   construct hand-built m,l,out and check normalization
let mut m_h = []
let mut l_h = []
let mut out_h = []
let mut i = 0

while i < seq_len {
    m_h = m_h + [0.0]
    l_h = l_h + [2.0]
    out_h = out_h + [[2.0, 4.0, 6.0]]
}
let final_h = rfa_finalize_output(m_h, l_h, out_h, seq_len, d_head)
check(20, vec_close(final_h[0], [1.0, 2.0, 3.0], eps) &&
          vec_close(final_h[seq_len - 1], [1.0, 2.0, 3.0], eps))

// ─── #21 rfa_finalize_output: l=0 yields 0 (no NaN) ─────────
let mut l_z = []
let mut out_z = []
let mut m_z = []
let mut i = 0

while i < seq_len {
    m_z = m_z + [0.0]
    l_z = l_z + [0.0]
    out_z = out_z + [[5.0, 5.0, 5.0]]
}
let fz = rfa_finalize_output(m_z, l_z, out_z, seq_len, d_head)
check(21, t_fabs(fz[0][0] - 0.0) < 1.0e-12)

// ─── #22 rfa_causal_mask_block: future = -inf ────────────────
let mut tile = []
let mut i = 0

while i < 2 {
    let mut r = []
    let mut j = 0

    while j < 2 {
        r = r + [1.0]
    }
    tile = tile + [r]
}
let masked = rfa_causal_mask_block(tile, 0, 0, 2, 2)
// q=0,k=1: future, masked. q=1,k=0: past, kept.
check(22, masked[0][1] < (0.0 - 1.0e29) && t_fabs(masked[1][0] - 1.0) < 1.0e-9)

// ─── #23 rfa_causal_mask_block: diagonal preserved ───────────
check(23, t_fabs(masked[0][0] - 1.0) < 1.0e-9 && t_fabs(masked[1][1] - 1.0) < 1.0e-9)

// ─── #24 rfa_reference_attention: shape ──────────────────────
let ref_out = rfa_reference_attention(Q, K, V, seq_len, d_head)
check(24, len(ref_out) == seq_len && len(ref_out[0]) == d_head)

// ─── #25 rfa_reference_attention: convex combinations ───────
//   each output row component must lie within [min(V[:,k]), max(V[:,k])]
let mut convex_ok = true
let mut k = 0

while k < d_head {
    let mut vmin = V[0][k]
    let mut vmax = V[0][k]
    let mut j = 1

    while j < seq_len {
        if V[j][k] < vmin { vmin = V[j][k] }
        if V[j][k] > vmax { vmax = V[j][k] }
    }
    let mut i = 0

    while i < seq_len {
        let v = ref_out[i][k]
        if v < vmin - 1.0e-6 { convex_ok = false }
        if v > vmax + 1.0e-6 { convex_ok = false }
    }
}
check(25, convex_ok)

// ─── #26 online softmax merge ≡ full softmax ─────────────────
//   Build a single Q row of length 1 against full K,V — split K,V
//   into two halves, run two updates, finalize, compare to reference.
let Q1 = [[0.30, 0.40, 0.50]]
let K_a = [
    [0.20, 0.10, 0.40],
    [0.50, 0.30, 0.20]
]
let V_a = [
    [1.00, 0.00, 0.50],
    [0.00, 1.00, 0.50]
]
let K_b = [
    [0.10, 0.60, 0.80],
    [0.90, 0.70, 0.50]
]
let V_b = [
    [0.50, 0.50, 1.00],
    [1.00, 1.00, 0.00]
]
let init1 = rfa_online_softmax_init(1, 3)
let blk_a = rfa_compute_block(Q1, K_a, V_a, 1, 2, 3)
let upd1 = rfa_online_softmax_update(init1[0], init1[1], init1[2],
                                     blk_a[0], V_a, 1, 3, 2)
let blk_b = rfa_compute_block(Q1, K_b, V_b, 1, 2, 3)
let upd2 = rfa_online_softmax_update(upd1[0], upd1[1], upd1[2],
                                     blk_b[0], V_b, 1, 3, 2)
let merged = rfa_finalize_output(upd2[0], upd2[1], upd2[2], 1, 3)
// Reference: Q1 (1 row) vs full K (4 rows) — inline since reference_attention assumes same seq_len for Q and K
let scale26 = 1.0 / sqrt(3.0)
let mut sc26 = [0.0, 0.0, 0.0, 0.0]
let mut jj = 0

while jj < 4 {
    let mut dd = 0.0
    let mut kk = 0

    while kk < 3 { dd = dd + Q1[0][kk] * K[jj][kk] }
    sc26[jj] = dd * scale26
}
let mx26 = rfa_row_max(sc26, 4)
let mut e26 = rfa_zeros_1d(4)
let mut se26 = 0.0
let mut jj = 0

while jj < 4 { e26[jj] = rfa_exp(sc26[jj] - mx26); se26 = se26 + e26[jj] }
let mut ref26 = rfa_zeros_1d(3)
let mut kk = 0

while kk < 3 {
    let mut ac = 0.0
    let mut jj = 0

    while jj < 4 { ac = ac + e26[jj] * V[jj][kk] }
    ref26[kk] = ac / se26
}
check(26, vec_close(merged[0], ref26, eps))

// ─── #27 ring_attention: shape ───────────────────────────────
let sh2 = rfa_shard_kv(K, V, 2, seq_len, d_head)
let ring_out2 = rfa_ring_attention(Q, sh2[0], sh2[1], 2, 0, seq_len, d_head)
check(27, len(ring_out2) == seq_len && len(ring_out2[0]) == d_head)

// ─── #28 ring_attention(n_ranks=1) == reference ─────────────
let sh1 = rfa_shard_kv(K, V, 1, seq_len, d_head)
let ring_out1 = rfa_ring_attention(Q, sh1[0], sh1[1], 1, 0, seq_len, d_head)
let ref1 = rfa_reference_attention(Q, K, V, seq_len, d_head)
check(28, mat_close(ring_out1, ref1, eps))

// ─── #29 ring_attention(n_ranks=2) == reference ─────────────
let diff2 = mat_max_diff(ring_out2, ref1)
check(29, diff2 < eps)

// ─── #30 ring_attention(n_ranks=4) == reference ─────────────
let sh4 = rfa_shard_kv(K, V, 4, seq_len, d_head)
let ring_out4 = rfa_ring_attention(Q, sh4[0], sh4[1], 4, 0, seq_len, d_head)
let diff4 = mat_max_diff(ring_out4, ref1)
check(30, diff4 < eps)

// ─── #31 ring_attention: n_ranks=2 == n_ranks=4 ─────────────
check(31, mat_close(ring_out2, ring_out4, eps))

// ─── #32 numerically stable with large scores ────────────────
let Q_big = [
    [5.0, 5.0],
    [4.0, 4.0],
    [3.0, 3.0],
    [6.0, 6.0]
]
let K_big = [
    [4.0, 4.0],
    [5.0, 5.0],
    [0.0 - 3.0, 0.0 - 3.0],
    [6.0, 6.0]
]
let V_big = [
    [1.0, 0.0],
    [0.0, 1.0],
    [0.5, 0.5],
    [1.0, 1.0]
]
let ref_big = rfa_reference_attention(Q_big, K_big, V_big, 4, 2)
let sh_big = rfa_shard_kv(K_big, V_big, 2, 4, 2)
let ring_big = rfa_ring_attention(Q_big, sh_big[0], sh_big[1], 2, 0, 4, 2)
check(32, mat_close(ring_big, ref_big, big_eps))

// ─── summary ─────────────────────────────────────────────────
println("")
println("=======================================================")
println("  pass=" + to_string(pass_count) + " fail=" + to_string(fail_count))
if fail_count == 0 {
    println("  ALL PASS")
} else {
    println("  FAILED")
}
println("=======================================================")
println(to_string(pass_count) + " passed")
