// =====================================================================
//  test_swiss_table.hexa -- ROI #44 Swiss Table hash map detection tests
//
//  Verifies hash table operations that the swiss-table pass detects
//  as candidates for SIMD probing optimization.
//
//  Tests (>=12):
//    1. basic hash table put + get
//    2. collision handling
//    3. multiple inserts
//    4. hash function distribution
//    5. overwrite existing key
//    6. missing key returns sentinel
//    7. delete via tombstone
//    8. count active entries
//    9. stress test many inserts
//   10. linear probing chain
//   11. load factor check
//   12. hash map as frequency counter
//
//  Run: ./hexa test self/test_swiss_table.hexa
// =====================================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn check_eq(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("=====================================================")
println("  Swiss Table Hash Map (ROI #44) Tests")
println("=====================================================")
println("")

// Simple hash function for integers
fn simple_hash(key, capacity) {
    let mut h = key
    if h < 0 { h = 0 - h }
    h = h * 2654435761
    if h < 0 { h = 0 - h }
    return h % capacity
}

// Module-level hash table (arrays are mutable at module scope)
let ht_cap = 32
let mut ht_keys = []
let mut ht_vals = []
let mut _hti = 0
while _hti < ht_cap {
    ht_keys.push(-1)
    ht_vals.push(0)
    _hti = _hti + 1
}

fn ht_put(key, val) {
    let mut idx = simple_hash(key, ht_cap)
    let mut probes = 0
    while probes < ht_cap {
        if ht_keys[idx] == -1 || ht_keys[idx] == key {
            ht_keys[idx] = key
            ht_vals[idx] = val
            return probes
        }
        idx = (idx + 1) % ht_cap
        probes = probes + 1
    }
    return -1
}

fn ht_get(key) {
    let mut idx = simple_hash(key, ht_cap)
    let mut probes = 0
    while probes < ht_cap {
        if ht_keys[idx] == -1 { return -1 }
        if ht_keys[idx] == key { return ht_vals[idx] }
        idx = (idx + 1) % ht_cap
        probes = probes + 1
    }
    return -1
}

fn ht_count() {
    let mut c = 0
    let mut i = 0
    while i < ht_cap {
        if ht_keys[i] >= 0 { c = c + 1 }
        i = i + 1
    }
    return c
}

fn ht_delete(key) {
    let mut idx = simple_hash(key, ht_cap)
    let mut probes = 0
    while probes < ht_cap {
        if ht_keys[idx] == -1 { return false }
        if ht_keys[idx] == key {
            ht_keys[idx] = -2
            ht_vals[idx] = 0
            return true
        }
        idx = (idx + 1) % ht_cap
        probes = probes + 1
    }
    return false
}

// -- 1. Basic put + get --
println("--- basic put + get ---")
let p1 = ht_put(42, 100)
check("put first ok", p1 >= 0)
check_eq("get first", ht_get(42), 100)

// -- 2. Collision handling --
println("")
println("--- collisions ---")
ht_put(10, 200)
ht_put(26, 300)
check_eq("get 10", ht_get(10), 200)
check_eq("get 26", ht_get(26), 300)
check_eq("get 42 still ok", ht_get(42), 100)

// -- 3. Multiple inserts --
println("")
println("--- multiple inserts ---")
ht_put(1, 10)
ht_put(2, 20)
ht_put(3, 30)
check_eq("get 1", ht_get(1), 10)
check_eq("get 2", ht_get(2), 20)
check_eq("get 3", ht_get(3), 30)

// -- 4. Hash distribution --
println("")
println("--- hash distribution ---")
fn test_distribution() {
    let n = 20
    let mut collisions = 0
    let mut i = 0
    while i < n {
        let h1 = simple_hash(i, ht_cap)
        let h2 = simple_hash(i + 1, ht_cap)
        if h1 == h2 { collisions = collisions + 1 }
        i = i + 1
    }
    // Good distribution: few collisions
    return collisions < n / 2
}
check("hash distribution ok", test_distribution())

// -- 5. Overwrite existing --
println("")
println("--- overwrite ---")
ht_put(42, 999)
check_eq("overwrite value", ht_get(42), 999)

// -- 6. Missing key --
println("")
println("--- missing key ---")
check_eq("get missing", ht_get(99999), -1)
check_eq("get negative", ht_get(-5), -1)

// -- 7. Delete --
println("")
println("--- delete ---")
ht_put(77, 770)
check_eq("get before delete", ht_get(77), 770)
let del_ok = ht_delete(77)
check("delete ok", del_ok)
check_eq("get after delete", ht_get(77), -1)

// -- 8. Count --
println("")
println("--- count ---")
let cnt = ht_count()
check("count > 0", cnt > 0)
check("count <= cap", cnt <= ht_cap)

// -- 9. Stress test --
println("")
println("--- stress test ---")
// Use a separate table via inline logic
fn stress_test() {
    let mut ok = true
    let mut i = 100
    while i < 120 {
        ht_put(i, i * 10)
        i = i + 1
    }
    let mut j = 100
    while j < 120 {
        let v = ht_get(j)
        if v != j * 10 { ok = false }
        j = j + 1
    }
    return ok
}
check("stress 20 inserts+gets", stress_test())

// -- 10. Linear probing chain --
println("")
println("--- linear probing ---")
fn probe_count_test() {
    // Insert keys that would hash to same bucket
    // Force collisions by using keys with same hash
    let h1 = simple_hash(500, ht_cap)
    let mut found_collision = false
    let mut k = 501
    while k < 600 {
        let h2 = simple_hash(k, ht_cap)
        if h2 == h1 {
            found_collision = true
            ht_put(500, 5000)
            ht_put(k, k * 10)
            // Both should be retrievable
            let v1 = ht_get(500)
            let v2 = ht_get(k)
            return v1 == 5000 && v2 == k * 10
        }
        k = k + 1
    }
    // Even without collision, basic ops work
    ht_put(500, 5000)
    return ht_get(500) == 5000
}
check("linear probing chain", probe_count_test())

// -- 11. Load factor --
println("")
println("--- load factor ---")
let load = ht_count()
let load_pct = (load * 100) / ht_cap
check("load factor < 100%", load_pct < 100)
check("load factor > 0%", load_pct > 0)

// -- 12. Frequency counter --
println("")
println("--- frequency counter ---")
fn freq_count() {
    // Count frequency of values in array using hash table
    let data = [1, 2, 3, 2, 1, 3, 3, 1, 2, 3]
    // Use offset keys to avoid collision with existing entries
    let offset = 10000
    let mut i = 0
    while i < len(data) {
        let key = data[i] + offset
        let existing = ht_get(key)
        if existing == -1 {
            ht_put(key, 1)
        } else {
            ht_put(key, existing + 1)
        }
        i = i + 1
    }
    let f1 = ht_get(1 + offset)
    let f2 = ht_get(2 + offset)
    let f3 = ht_get(3 + offset)
    return f1 == 3 && f2 == 3 && f3 == 4
}
check("frequency counter", freq_count())

// -- Summary --
println("")
println("=====================================================")
println("  Swiss Table: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("=====================================================")
assert(fail_count == 0)
