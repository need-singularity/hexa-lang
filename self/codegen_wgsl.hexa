// self/codegen_wgsl.hexa — HEXA WGSL CODEGEN ported from src/codegen_wgsl.rs

// WGSL/WebGPU Code Generator — Transpile HEXA AST to WGSL compute shaders.
// Generates WGSL compute shaders for WebGPU execution.
// Supported subset: int/float/bool literals as i32/f32/bool, arithmetic,
// let bindings, if/else, for loops, fn, arrays as storage buffers,
// 12 factions as 12 workgroup invocations.

struct WgslContext {
    output: string,
    indent: int,
    binding_idx: int
}

fn wgsl_context_new() -> WgslContext {
    return WgslContext { output: "", indent: 0, binding_idx: 0 }
}

fn wgsl_context_push_indent(self: WgslContext) -> WgslContext {
    return WgslContext { output: self.output, indent: self.indent + 1, binding_idx: self.binding_idx }
}

fn wgsl_context_pop_indent(self: WgslContext) -> WgslContext {
    let new_indent = self.indent
    if new_indent > 0 { new_indent = new_indent - 1 }
    return WgslContext { output: self.output, indent: new_indent, binding_idx: self.binding_idx }
}

fn wgsl_write_indent(indent: int) -> string {
    let result = ""
    let mut i = 0
    while i < indent {
        result = result + "    "
        i = i + 1
    }
    return result
}

fn wgsl_writeln(self: WgslContext, s: string) -> WgslContext {
    let pad = wgsl_write_indent(self.indent)
    return WgslContext {
        output: self.output + pad + s + "\n",
        indent: self.indent,
        binding_idx: self.binding_idx
    }
}

fn map_type_wgsl(typ: string) -> string {
    if typ == "int" { return "i32" }
    if typ == "float" { return "f32" }
    if typ == "bool" { return "bool" }
    if typ == "char" { return "i32" }
    if typ == "string" { return "i32" }
    if typ == "byte" { return "u32" }
    if typ == "void" { return "i32" }
    if typ == "" { return "i32" }
    return typ
}

fn binop_to_wgsl(op: string) -> string {
    if op == "Add" { return "+" }
    if op == "Sub" { return "-" }
    if op == "Mul" { return "*" }
    if op == "Div" { return "/" }
    if op == "Rem" { return "%" }
    if op == "Pow" { return "/* pow */+" }
    if op == "Eq" { return "==" }
    if op == "Ne" { return "!=" }
    if op == "Lt" { return "<" }
    if op == "Gt" { return ">" }
    if op == "Le" { return "<=" }
    if op == "Ge" { return ">=" }
    if op == "And" { return "&&" }
    if op == "Or" { return "||" }
    if op == "Xor" { return "^" }
    if op == "BitAnd" { return "&" }
    if op == "BitOr" { return "|" }
    if op == "BitXor" { return "^" }
    if op == "Assign" { return "=" }
    if op == "DeclAssign" { return "=" }
    if op == "Range" { return ".." }
    if op == "Arrow" { return "->" }
    return "?"
}

fn wgsl_map_psi_call(name: string) -> string {
    if name == "psi_coupling" { return "PSI_COUPLING" }
    if name == "psi_balance" { return "PSI_BALANCE" }
    if name == "psi_steps" { return "PSI_STEPS" }
    if name == "psi_entropy" { return "PSI_ENTROPY" }
    if name == "psi_frustration" { return "PSI_FRUSTRATION" }
    if name == "consciousness_max_cells" { return "1024i" }
    if name == "consciousness_decoder_dim" { return "384i" }
    if name == "consciousness_phi" { return "71i" }
    return ""
}

fn wgsl_emit_int(n: int) -> string {
    return to_string(n) + "i"
}

fn wgsl_emit_float(n: float) -> string {
    return to_string(n) + "f"
}

// Main entry: generate WGSL compute shader from HEXA AST.
fn generate_wgsl(stmts: [string]) -> string {
    let out = ""
    out = out + "// Generated by HEXA-LANG WGSL codegen\n"
    out = out + "// Law 22: substrate is irrelevant, only structure determines Phi\n\n"
    // Psi-constants
    out = out + "// Psi-Constants (from ln(2))\n"
    out = out + "const PSI_COUPLING: f32 = 0.014;\n"
    out = out + "const PSI_BALANCE: f32 = 0.5;\n"
    out = out + "const PSI_STEPS: f32 = 4.33;\n"
    out = out + "const PSI_ENTROPY: f32 = 0.998;\n"
    out = out + "const PSI_FRUSTRATION: f32 = 0.10;\n\n"
    // Cell struct + buffers
    out = out + "// Consciousness cell buffer — one entry per GPU thread\n"
    out = out + "struct Cell {\n"
    out = out + "    state: f32,\n"
    out = out + "    phi: f32,\n"
    out = out + "    faction: i32,\n"
    out = out + "    padding: i32,\n"
    out = out + "};\n\n"
    out = out + "@group(0) @binding(0)\n"
    out = out + "var<storage, read_write> cells: array<Cell>;\n\n"
    out = out + "@group(0) @binding(1)\n"
    out = out + "var<storage, read_write> results: array<i32>;\n\n"
    // Compute entry point — workgroup_size(12) for sigma(6)=12
    out = out + "@compute @workgroup_size(12)\n"
    out = out + "fn main(@builtin(global_invocation_id) gid: vec3<u32>) {\n"
    out = out + "    let idx = gid.x;\n"
    out = out + "    let faction = i32(idx % 12u);  // sigma(6) = 12 factions\n"
    out = out + "\n"
    out = out + "    // ... statements ...\n"
    out = out + "}\n"
    return out
}
