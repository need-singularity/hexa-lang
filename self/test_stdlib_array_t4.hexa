// ═══════════════════════════════════════════════════════════
//  self/stdlib/array.hexa — HEXA-native array utilities (T4)
//
//  T4 migration 의 두 번째 모듈. runtime.c 의 C 버전과 기능적 동등,
//  hexa.real-interp 경로만 사용 — anima hot path 무영향.
//
//  Usage:
//      use "stdlib/array"
//      let sum = array_sum([1,2,3,4,5])
//
//  See: docs/hexa-hot-path.md (T4 정책)
// ═══════════════════════════════════════════════════════════

// Reverse an array (new array, input unchanged).
pub fn array_reverse(arr) {
    let n = len(arr)
    let mut out = []
    let mut i = n - 1
    while i >= 0 {
        out.push(arr[i])
        i = i - 1
    }
    return out
}

// True if any element equals `x`.
pub fn array_contains(arr, x) {
    let n = len(arr)
    let mut i = 0
    while i < n {
        if arr[i] == x { return true }
        i = i + 1
    }
    return false
}

// First index of `x`, or -1 if not present.
pub fn array_index_of(arr, x) {
    let n = len(arr)
    let mut i = 0
    while i < n {
        if arr[i] == x { return i }
        i = i + 1
    }
    return -1
}

// Sum of numeric elements.
pub fn array_sum(arr) {
    let n = len(arr)
    let mut s = 0
    let mut i = 0
    while i < n {
        s = s + arr[i]
        i = i + 1
    }
    return s
}

// Product of numeric elements (empty → 1).
pub fn array_product(arr) {
    let n = len(arr)
    let mut p = 1
    let mut i = 0
    while i < n {
        p = p * arr[i]
        i = i + 1
    }
    return p
}

// Min of numeric elements (empty → 0).
pub fn array_min(arr) {
    let n = len(arr)
    if n == 0 { return 0 }
    let mut m = arr[0]
    let mut i = 1
    while i < n {
        if arr[i] < m { m = arr[i] }
        i = i + 1
    }
    return m
}

// Max of numeric elements (empty → 0).
pub fn array_max(arr) {
    let n = len(arr)
    if n == 0 { return 0 }
    let mut m = arr[0]
    let mut i = 1
    while i < n {
        if arr[i] > m { m = arr[i] }
        i = i + 1
    }
    return m
}

// Concatenate two arrays into a new one.
pub fn array_concat(a, b) {
    let mut out = []
    let na = len(a)
    let nb = len(b)
    let mut i = 0
    while i < na { out.push(a[i]); i = i + 1 }
    let mut j = 0
    while j < nb { out.push(b[j]); j = j + 1 }
    return out
        i = i + 1
}

// Take first n elements.
pub fn array_take(arr, n) {
    if n <= 0 { return [] }
    let total = len(arr)
    let k = if n < total { n } else { total }
    let mut out = []
    let mut i = 0
    while i < k { out.push(arr[i]); i = i + 1 }
    return out
        i = i + 1
}

// Drop first n elements.
pub fn array_drop(arr, n) {
    let total = len(arr)
    if n <= 0 { return arr }
    if n >= total { return [] }
    let mut out = []
    let mut i = n
    while i < total { out.push(arr[i]); i = i + 1 }
    return out
        i = i + 1
}

// Count elements equal to `x`.
pub fn array_count(arr, x) {
    let n = len(arr)
    let mut c = 0
    let mut i = 0
    while i < n {
        if arr[i] == x { c = c + 1 }
        i = i + 1
    }
    return c
}


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check_int(name, actual, expected) {
    if actual == expected {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected " + to_string(expected) + " got " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_bool(name, actual, expected) {
    if actual == expected {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected " + to_string(expected) + " got " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_arr_equals(name, actual, expected) {
    let na = len(actual)
    let ne = len(expected)
    let mut ok = na == ne
    if ok {
        let mut i = 0
        while i < na {
            if actual[i] != expected[i] { ok = false }
            i = i + 1
        }
    }
    if ok {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — len actual=" + to_string(na) + " expected=" + to_string(ne))
        fail_count = fail_count + 1
    }
}

fn main() {
    // ── array_reverse ───────────────────────────
    check_arr_equals("reverse/123", array_reverse([1, 2, 3]), [3, 2, 1])
    check_arr_equals("reverse/single", array_reverse([42]), [42])
    check_arr_equals("reverse/empty", array_reverse([]), [])

    // ── array_contains / array_index_of ─────────
    check_bool("contains/yes", array_contains([1, 2, 3], 2), true)
    check_bool("contains/no",  array_contains([1, 2, 3], 99), false)
    check_bool("contains/empty", array_contains([], 1), false)
    check_int("index_of/middle", array_index_of([10, 20, 30], 20), 1)
    check_int("index_of/start",  array_index_of([10, 20, 30], 10), 0)
    check_int("index_of/miss",   array_index_of([10, 20, 30], 99), -1)

    // ── array_sum / product ─────────────────────
    check_int("sum/basic", array_sum([1, 2, 3, 4, 5]), 15)
    check_int("sum/empty", array_sum([]), 0)
    check_int("sum/single", array_sum([42]), 42)
    check_int("product/basic", array_product([2, 3, 4]), 24)
    check_int("product/empty", array_product([]), 1)

    // ── array_min / max ─────────────────────────
    check_int("min/basic", array_min([3, 1, 4, 1, 5, 9, 2, 6]), 1)
    check_int("max/basic", array_max([3, 1, 4, 1, 5, 9, 2, 6]), 9)
    check_int("min/single", array_min([7]), 7)
    check_int("max/single", array_max([7]), 7)

    // ── array_concat ────────────────────────────
    check_arr_equals("concat/basic", array_concat([1, 2], [3, 4]), [1, 2, 3, 4])
    check_arr_equals("concat/empty_left", array_concat([], [1, 2]), [1, 2])
    check_arr_equals("concat/empty_right", array_concat([1, 2], []), [1, 2])

    // ── array_take / drop ───────────────────────
    check_arr_equals("take/3", array_take([1, 2, 3, 4, 5], 3), [1, 2, 3])
    check_arr_equals("take/overflow", array_take([1, 2], 5), [1, 2])
    check_arr_equals("take/zero", array_take([1, 2, 3], 0), [])
    check_arr_equals("drop/2", array_drop([1, 2, 3, 4, 5], 2), [3, 4, 5])
    check_arr_equals("drop/overflow", array_drop([1, 2], 5), [])
    check_arr_equals("drop/zero", array_drop([1, 2, 3], 0), [1, 2, 3])

    // ── array_count ─────────────────────────────
    check_int("count/multi", array_count([1, 2, 2, 3, 2, 4], 2), 3)
    check_int("count/none",  array_count([1, 2, 3], 99), 0)

    println("")
    println("═══════════════════════════════════════════════════════")
    println("  T4 HEXA stdlib/array — PASS " + to_string(pass_count) + " / FAIL " + to_string(fail_count))
    println("═══════════════════════════════════════════════════════")
    if fail_count > 0 { exit(1) }
}

main()
