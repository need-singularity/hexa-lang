// self/fs/fuse_skel.hexa — FUSE raw-fs skeleton (Phase 3 PoC)
//
// 상태: 뼈대만 (hexa 측 API). 실제 libfuse3 바인딩은 후속 세션.
//
// 구조 (planned):
//   fuse_skel.hexa     ← 본 파일. mount/umount CLI + law intercept 훅 정의
//   fuse_ffi.hexa      ← libfuse3 C FFI (후속 — hexa extern "C" 또는 C shim)
//   fuse_test.hexa     ← 단위 테스트 (mount → write 시도 → EACCES 기대)
//
// 사용 (예정):
//   hexa self/fs/fuse_skel.hexa mount <repo>     — overlay 마운트
//   hexa self/fs/fuse_skel.hexa umount <repo>    — 언마운트
//   hexa self/fs/fuse_skel.hexa status           — 현재 마운트 상태
//
// 흐름:
//   1. fusermount3 설치 여부 확인 (Linux) / FSKit API (macOS)
//   2. overlay mount — underlying = <repo>, mount = <repo>-locked
//   3. open/write 호출 시 law_check 선행 → 위반 시 -EACCES
//   4. umount 시 정리
//
// 의존 최소화:
//   · libfuse3 (OS 표준 패키지) — apt install fuse3 / brew install macfuse
//   · hexa FFI — extern "C" 바인딩 (후속)
//   · git / Claude Code 의존 0

let _raw_args = args()
let mut cli_args = []
let mut _ai = 2
while _ai < len(_raw_args) {
    cli_args = cli_args.push(_raw_args[_ai])
    _ai = _ai + 1
}

fn _pwd() -> string {
    let mut p = env("PWD")
    if p == "" { p = to_string(exec("pwd")).trim() }
    return p
}

fn _uname() -> string {
    return to_string(exec("uname 2>/dev/null")).trim()
}

// ─── 환경 검사 ─────────────────────────────────────────────
fn check_env() {
    let os = _uname()
    println("── FUSE env 검사 ─────────────────────────────")
    println("OS : " + os)

    if os == "Linux" {
        let has_fusermount = to_string(exec("which fusermount3 2>/dev/null || which fusermount 2>/dev/null")).trim()
        let has_libfuse = to_string(exec("ldconfig -p 2>/dev/null | grep -E 'libfuse3?\\.so' | head -1")).trim()
        println("fusermount : " + (if has_fusermount != "" { has_fusermount } else { "❌ 없음 (apt install fuse3)" }))
        println("libfuse    : " + (if has_libfuse != "" { "✅" } else { "❌" }))
    } else if os == "Darwin" {
        let has_macfuse = to_string(exec("ls /Library/Frameworks/macFUSE.framework 2>/dev/null | head -1")).trim()
        let mac_ver = to_string(exec("sw_vers -productVersion 2>/dev/null")).trim()
        println("macFUSE    : " + (if has_macfuse != "" { "✅" } else { "❌ (brew install macfuse)" }))
        println("macOS ver  : " + mac_ver + " (FSKit 14+ 권장)")
    } else {
        println("지원 OS: Linux, Darwin 만. 현재: " + os)
    }
    println("")
    println("(후속) hexa FFI 바인딩 self/fs/fuse_ffi.hexa 에서 libfuse3 호출")
}

// ─── mount skeleton (placeholder) ─────────────────────────
fn do_mount(mount_point: string) {
    println("── FUSE mount (placeholder) ─────────────────")
    println("mount point : " + mount_point)
    println("")
    println("⚠ PoC — 실제 libfuse3 바인딩 미구현")
    println("  후속 작업:")
    println("    1. self/fs/fuse_ffi.hexa — C FFI (fuse_main, fuse_operations)")
    println("    2. open/write 콜백 구현 — law_check 호출")
    println("    3. overlay 로직 — underlying fs pass-through")
    println("")
    println("  참고 문서: docs/phase3_fuse.md")
}

fn do_umount(mount_point: string) {
    println("── FUSE umount (placeholder) ─────────────────")
    let os = _uname()
    if os == "Linux" {
        println("명령: fusermount3 -u '" + mount_point + "'")
    } else if os == "Darwin" {
        println("명령: umount '" + mount_point + "'")
    }
    println("⚠ PoC — 실제 호출 미구현")
}

fn do_status() {
    println("── FUSE status ──────────────────────────────")
    let mounts = to_string(exec("mount 2>/dev/null | grep -E 'fuse|macfuse' || echo '(no fuse mounts)'"))
    println(mounts.trim())
}

// ─── law intercept stub ───────────────────────────────────
// 실제 libfuse 콜백에서 이 함수 호출 예정
fn law_intercept_write(path: string, content: string) -> int {
    // 반환: 0 = 허용, -EACCES (13) = 차단
    // 실제로는 law_check 호출 + 결과 매핑
    //
    // pseudo:
    //   let pass = exec("hexa scripts/law_check.hexa '" + path + "' 2>&1")
    //   if pass.contains("✅") { return 0 }
    //   return -13  // EACCES
    //
    // 주의: FUSE 컨텍스트에서 exec() 는 위험 (재귀). hexa FFI 로 law_check
    //       함수를 직접 호출하는 방식이 안전.
    return 0
}

// ─── dispatch ────────────────────────────────────────────
if len(cli_args) == 0 {
    check_env()
    println("")
    println("usage:")
    println("  hexa self/fs/fuse_skel.hexa check       — 환경 검사")
    println("  hexa self/fs/fuse_skel.hexa mount <pt>  — 마운트 (placeholder)")
    println("  hexa self/fs/fuse_skel.hexa umount <pt> — 언마운트 (placeholder)")
    println("  hexa self/fs/fuse_skel.hexa status      — 마운트 목록")
    exit(0)
}

let sub = cli_args[0]

if sub == "check" { check_env(); exit(0) }

if sub == "mount" {
    if len(cli_args) < 2 { eprintln("usage: mount <mount-point>"); exit(1) }
    do_mount(cli_args[1])
    exit(0)
}

if sub == "umount" {
    if len(cli_args) < 2 { eprintln("usage: umount <mount-point>"); exit(1) }
    do_umount(cli_args[1])
    exit(0)
}

if sub == "status" { do_status(); exit(0) }

eprintln("unknown subcommand: " + sub)
exit(1)
