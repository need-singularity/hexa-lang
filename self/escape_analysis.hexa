// self/escape_analysis.hexa — HEXA escape analysis ported from src/escape_analysis.rs
// Walks the AST before JIT compilation and classifies each variable as
// Stack, Heap, or Unknown. Non-escaping values (structs, arrays, enums)
// that stay within the declaring scope can be stack-allocated.
//
// A value "escapes" when it is:
//   - returned from the function
//   - stored into a data structure (struct field, array element)
//   - captured by a closure / lambda
//   - passed as an argument to a call that is not inlined

// ── Allocation kind ────────────────────────────────────────────

// "Stack" = safe to place on stack (no escape)
// "Heap"  = must be heap-allocated (escapes scope)
// "Unknown" = could not determine -- fall back to heap

// ── Escape info ────────────────────────────────────────────────

struct EscapeInfo {
    allocations: [AllocEntry]
}

struct AllocEntry {
    name: string,
    kind: string
}

fn escape_info_get(self: EscapeInfo, name: string) -> string {
    for entry in self.allocations {
        if entry.name == name {
            return entry.kind
        }
    }
    return "Heap"
}

// ── Analysis context ───────────────────────────────────────────

struct EscapeCtx {
    allocations: [AllocEntry],
    aggregates: [string]
}

fn escape_ctx_new() -> EscapeCtx {
    return EscapeCtx { allocations: [], aggregates: [] }
}

fn escape_ctx_set(ctx: EscapeCtx, name: string, kind: string) {
    for entry in ctx.allocations {
        if entry.name == name {
            entry.kind = kind
            return
        }
    }
    ctx.allocations.push(AllocEntry { name: name, kind: kind })
}

fn escape_ctx_is_aggregate(ctx: EscapeCtx, name: string) -> bool {
    for agg in ctx.aggregates {
        if agg == name { return true }
    }
    return false
}

// ── Entry point ────────────────────────────────────────────────

fn analyze_escapes(params: [string], body_lets: [LetInfo], body_returns: [string], body_calls: [CallInfo]) -> EscapeInfo {
    let ctx = escape_ctx_new()

    // Parameters are conservatively Unknown
    for p in params {
        escape_ctx_set(ctx, p, "Unknown")
    }

    // Pass 1: discover let bindings that create aggregate values
    for let_info in body_lets {
        if let_info.is_aggregate {
            escape_ctx_set(ctx, let_info.name, "Stack")
            ctx.aggregates.push(let_info.name)
        }
    }

    // Pass 2: find escaping uses
    let mut escaped = []

    // Returned aggregates escape
    for ret_name in body_returns {
        if escape_ctx_is_aggregate(ctx, ret_name) {
            escaped = escaped.push(ret_name)
        }
    }

    // Call arguments escape (conservative)
    for ci in body_calls {
        for arg in ci.args {
            if escape_ctx_is_aggregate(ctx, arg) {
                escaped = escaped.push(arg)
            }
        }
    }

    // Apply escape set: promote to Heap
    for name in escaped {
        escape_ctx_set(ctx, name, "Heap")
    }

    return EscapeInfo { allocations: ctx.allocations }
}

// ── Helper structs ─────────────────────────────────────────────

struct LetInfo {
    name: string,
    is_aggregate: bool
}

struct CallInfo {
    callee: string,
    args: [string]
}

// ── Program-level analysis ─────────────────────────────────────

struct ProgramEscapeMap {
    entries: [ProgramEscapeEntry]
}

struct ProgramEscapeEntry {
    fn_name: string,
    info: EscapeInfo
}

fn analyze_program_escapes(fn_decls: [FnDeclInfo]) -> ProgramEscapeMap {
    let mut entries = []
    for decl in fn_decls {
        let info = analyze_escapes(decl.params, decl.lets, decl.returns, decl.calls)
        entries = entries.push(ProgramEscapeEntry { fn_name: decl.name, info: info })
    }
    return ProgramEscapeMap { entries: entries }
}

struct FnDeclInfo {
    name: string,
    params: [string],
    lets: [LetInfo],
    returns: [string],
    calls: [CallInfo]
}

fn program_escape_map_get(self: ProgramEscapeMap, fn_name: string) -> EscapeInfo {
    for entry in self.entries {
        if entry.fn_name == fn_name {
            return entry.info
        }
    }
    return EscapeInfo { allocations: [] }
}

// ── Aggregate expression check ─────────────────────────────────

fn is_aggregate_expr(kind: string) -> bool {
    if kind == "StructInit" { return true }
    if kind == "Array" { return true }
    if kind == "EnumPath" { return true }
    return false
}

// ── Collect escaping names from expression ─────────────────────

fn collect_escaping_names(expr_idents: [string], aggregates: [string]) -> [string] {
    let mut escaped = []
    for name in expr_idents {
        for agg in aggregates {
            if name == agg {
                escaped = escaped.push(name)
            }
        }
    }
    return escaped
}
