// ═══════════════════════════════════════════════════════════
//  test_strength_reduction.hexa — M480/M978 strength reduction extensions
//  ROI id=13, P2, effect 2x
//
//  Tests:
//   M480: pow2 strength reduction correctness
//         x*2 -> x<<1, x/2 -> x>>1, x%2 -> x&1
//         (these are AST-level rewrites, verified by equivalence)
//   M978: loop index multiply -> accumulate (i*stride -> acc += stride)
//         (hand-written fused version mirrors AST rewrite output)
//
//  Note: << and >> are internal AST ops (generated by ai_native_pass);
//  tests verify semantic equivalence without using shift syntax.
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA test_strength_reduction — M480/M978")
println("═══════════════════════════════════════════════════════")
println("")

// ────────────────────────────────────────────────────────────
//  SECTION 1: M480 — x*2 equivalence (x*2 == x+x)
//  The pass rewrites x*2 -> x<<1 at AST level.
//  We verify x*2 == x+x for correctness.
// ────────────────────────────────────────────────────────────
println("--- M480: x*2 correctness ---")

fn mul2(x) { return x * 2 }
fn add_self(x) { return x + x }

check("mul2(5)", mul2(5), 10)
check("mul2(0)", mul2(0), 0)
check("mul2(100)", mul2(100), 200)
check("mul2==add_self 5", mul2(5), add_self(5))
check("mul2==add_self 17", mul2(17), add_self(17))
check("mul2==add_self 0", mul2(0), add_self(0))

// ────────────────────────────────────────────────────────────
//  SECTION 2: M480 — x/2 correctness (integer division)
// ────────────────────────────────────────────────────────────
println("")
println("--- M480: x/2 correctness ---")

fn div2(x) { return x / 2 }

check("div2(10)", div2(10), 5)
check("div2(7)", div2(7), 3)
check("div2(0)", div2(0), 0)
check("div2(1)", div2(1), 0)
check("div2(255)", div2(255), 127)

// ────────────────────────────────────────────────────────────
//  SECTION 3: M480 — x%2 correctness (even/odd check)
// ────────────────────────────────────────────────────────────
println("")
println("--- M480: x%2 correctness ---")

fn mod2(x) { return x % 2 }

check("mod2(5)", mod2(5), 1)
check("mod2(4)", mod2(4), 0)
check("mod2(0)", mod2(0), 0)
check("mod2(1)", mod2(1), 1)
check("mod2(255)", mod2(255), 1)

// ────────────────────────────────────────────────────────────
//  SECTION 4: M480 — larger powers of 2
//  x*4 -> x<<2, x/8 -> x>>3, x%16 -> x&15
// ────────────────────────────────────────────────────────────
println("")
println("--- M480: larger pow2 ---")

fn mul4(x) { return x * 4 }
check("mul4(3)", mul4(3), 12)
check("mul4(0)", mul4(0), 0)
check("mul4(25)", mul4(25), 100)

fn div8(x) { return x / 8 }
check("div8(64)", div8(64), 8)
check("div8(15)", div8(15), 1)
check("div8(8)", div8(8), 1)

fn mod16(x) { return x % 16 }
check("mod16(17)", mod16(17), 1)
check("mod16(32)", mod16(32), 0)
check("mod16(15)", mod16(15), 15)

// ────────────────────────────────────────────────────────────
//  SECTION 5: M480 — combined pow2 expressions
// ────────────────────────────────────────────────────────────
println("")
println("--- M480: combined expressions ---")

fn combined_pow2(x) {
    let a = x * 2
    let b = x / 2
    let c = x % 2
    return a + b + c
}

// x=10: 20+5+0 = 25
check("combined(10)", combined_pow2(10), 25)
// x=7: 14+3+1 = 18
check("combined(7)", combined_pow2(7), 18)
// x=0: 0+0+0 = 0
check("combined(0)", combined_pow2(0), 0)

// ────────────────────────────────────────────────────────────
//  SECTION 6: M978 — loop index multiply -> accumulate
//  Original: let offset = i * stride  (inside while loop)
//  Rewritten: let mut __sr_acc = 0 (before loop)
//             let offset = __sr_acc  (inside loop)
//             __sr_acc = __sr_acc + stride  (before i = i + 1)
//  Verifies orig and fused produce identical results.
// ────────────────────────────────────────────────────────────
println("")
println("--- M978: loop stride -> accumulate ---")

// Original: i * 4 in a loop
fn stride_orig(n) {
    let mut result = 0
    let mut i = 0
    while i < n {
        let offset = i * 4
        result = result + offset
        i = i + 1
    }
    return result
}

// Rewritten by M978: accumulator replaces multiply
fn stride_fused(n) {
    let mut result = 0
    let mut __sr_acc0 = 0
    let mut i = 0
    while i < n {
        let offset = __sr_acc0
        result = result + offset
        __sr_acc0 = __sr_acc0 + 4
        i = i + 1
    }
    return result
}

// 0 + 4 + 8 + 12 + 16 = 40
check("stride*4 n=5 orig", stride_orig(5), 40)
check("stride*4 n=5 fused", stride_fused(5), 40)
check("stride*4 n=0 equiv", stride_orig(0), stride_fused(0))
check("stride*4 n=1 equiv", stride_orig(1), stride_fused(1))
// 0 + 4 + 8 = 12
check("stride*4 n=3 equiv", stride_orig(3), stride_fused(3))

// Stride of 10
fn stride10_orig(n) {
    let mut sum = 0
    let mut i = 0
    while i < n {
        let pos = i * 10
        sum = sum + pos
        i = i + 1
    }
    return sum
}

fn stride10_fused(n) {
    let mut sum = 0
    let mut __sr_acc0 = 0
    let mut i = 0
    while i < n {
        let pos = __sr_acc0
        sum = sum + pos
        __sr_acc0 = __sr_acc0 + 10
        i = i + 1
    }
    return sum
}

// 0 + 10 + 20 + 30 = 60
check("stride*10 n=4 orig", stride10_orig(4), 60)
check("stride*10 n=4 fused", stride10_fused(4), 60)
check("stride*10 n=0 equiv", stride10_orig(0), stride10_fused(0))

// Commutative: stride * i (instead of i * stride)
fn stride_comm_orig(n) {
    let mut result = 0
    let mut i = 0
    while i < n {
        let offset = 3 * i
        result = result + offset
        i = i + 1
    }
    return result
}

fn stride_comm_fused(n) {
    let mut result = 0
    let mut __sr_acc0 = 0
    let mut i = 0
    while i < n {
        let offset = __sr_acc0
        result = result + offset
        __sr_acc0 = __sr_acc0 + 3
        i = i + 1
    }
    return result
}

// 0 + 3 + 6 + 9 + 12 = 30
check("stride*3 comm n=5 orig", stride_comm_orig(5), 30)
check("stride*3 comm n=5 fused", stride_comm_fused(5), 30)
check("stride*3 comm n=0 equiv", stride_comm_orig(0), stride_comm_fused(0))

// ────────────────────────────────────────────────────────────
//  SECTION 7: M978 — large stride for real-world scenario
//  Simulating array-of-structs offset calculation
// ────────────────────────────────────────────────────────────
println("")
println("--- M978: array-of-structs stride ---")

fn struct_offset_orig(n) {
    let mut sum = 0
    let mut i = 0
    while i < n {
        let byte_offset = i * 64
        sum = sum + byte_offset
        i = i + 1
    }
    return sum
}

fn struct_offset_fused(n) {
    let mut sum = 0
    let mut __sr_acc0 = 0
    let mut i = 0
    while i < n {
        let byte_offset = __sr_acc0
        sum = sum + byte_offset
        __sr_acc0 = __sr_acc0 + 64
        i = i + 1
    }
    return sum
}

// n=4: 0 + 64 + 128 + 192 = 384
check("struct*64 n=4 orig", struct_offset_orig(4), 384)
check("struct*64 n=4 fused", struct_offset_fused(4), 384)
check("struct*64 n=1 equiv", struct_offset_orig(1), struct_offset_fused(1))

// ────────────────────────────────────────────────────────────
//  Summary
// ────────────────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  RESULT: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")
