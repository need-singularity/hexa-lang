// ===================================================================
//  test_graph_rag.hexa — GraphRAG verification (#190)
//
//  Tests (30):
//    T1  create_graph returns 5-element structure
//    T2  empty graph has 0 nodes
//    T3  empty graph has 0 edges
//    T4  add_node returns correct node_id
//    T5  add_node increments node count
//    T6  add second node returns id=1
//    T7  add_edge increments edge count
//    T8  get_node_name returns correct name
//    T9  get_neighbors finds neighbor via edge
//    T10 get_neighbors bidirectional
//    T11 extract_entities finds capitalized words
//    T12 extract_entities skips short words
//    T13 extract_entities deduplicates
//    T14 extract_relations finds triples
//    T15 build_from_documents creates graph
//    T16 build_from_documents has edges
//    T17 label_propagation converges
//    T18 label_propagation connected nodes share community
//    T19 get_communities returns groups
//    T20 community_summary contains node names
//    T21 local_search finds start node
//    T22 local_search depth=1 finds neighbors
//    T23 global_search finds matching community
//    T24 score_node direct match > no match
//    T25 retrieve returns top-k nodes
//    T26 retrieve top-1 is most relevant
//    T27 context_from_nodes includes node names
//    T28 precision_at_k perfect retrieval
//    T29 precision_at_k partial retrieval
//    T30 graph_density correct for complete graph
//
//  Run: ./hexa self/test_graph_rag.hexa
// ===================================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx(a, b, eps) { return fabs(a - b) < eps }

// ── inlined helpers from graph_rag.hexa ───────────────────────

fn _grag_min(a, b) {
    if a < b { return a }
    return b
}

fn _grag_is_upper_code(code) {
    if code >= 65 {
        if code <= 90 { return true }
    }
    return false
}

fn _grag_is_punct_code(code) {
    if code == 46 { return true }
    if code == 44 { return true }
    if code == 33 { return true }
    if code == 63 { return true }
    return false
}

fn _grag_arr_contains_int(arr, val) {
    let n = len(arr)
    let mut i = 0
    while i < n {
        if arr[i] == val { return true }
        i = i + 1
    }
    return false
}

fn _grag_arr_contains_str(arr, s) {
    let n = len(arr)
    let mut i = 0
    while i < n {
        if arr[i] == s { return true }
        i = i + 1
    }
    return false
}

fn _grag_strip_punct(w) {
    let chars = w.chars()
    let n = len(chars)
    let mut end = n
    let mut k = n - 1
    while k >= 0 {
        if _grag_is_punct_code(to_int(chars[k])) {
            end = k
        } else {
            k = 0 - 1
        }
        k = k - 1
    }
    if end == n { return w }
    if end <= 0 { return "" }
    return w.substring(0, end)
}

// ── Graph primitives (inlined) ────────────────────────────────

fn grag_create_graph() {
    return [[], [], [], [], []]
}

fn grag_add_node(graph, name, node_type) {
    let nodes = graph[0]
    let edges = graph[1]
    let names = graph[2]
    let types = graph[3]
    let comms = graph[4]
    let node_id = len(nodes)
    let new_nodes = nodes + [node_id]
    let new_names = names + [name]
    let new_types = types + [node_type]
    let new_comms = comms + [node_id]
    let new_graph = [new_nodes, edges, new_names, new_types, new_comms]
    return [new_graph, node_id]
}

fn grag_add_edge(graph, src, dst, relation, weight) {
    let nodes = graph[0]
    let edges = graph[1]
    let names = graph[2]
    let types = graph[3]
    let comms = graph[4]
    let new_edge = [src, dst, relation, weight]
    let new_edges = edges + [new_edge]
    return [nodes, new_edges, names, types, comms]
}

fn grag_get_neighbors(graph, node_id) {
    let edges = graph[1]
    let ne = len(edges)
    let mut neighbors = []
    let mut i = 0
    while i < ne {
        let e = edges[i]
        if e[0] == node_id {
            if _grag_arr_contains_int(neighbors, e[1]) == false {
                neighbors = neighbors + [e[1]]
            }
        }
        if e[1] == node_id {
            if _grag_arr_contains_int(neighbors, e[0]) == false {
                neighbors = neighbors + [e[0]]
            }
        }
        i = i + 1
    }
    return neighbors
}

fn grag_get_node_name(graph, node_id) {
    let names = graph[2]
    if node_id < 0 { return "" }
    if node_id >= len(names) { return "" }
    return names[node_id]
}

fn grag_node_count(graph) {
    return len(graph[0])
}

fn grag_edge_count(graph) {
    return len(graph[1])
}

// ── Entity / relation extraction (inlined) ────────────────────

fn grag_extract_entities(text) {
    let words = text.split(" ")
    let nw = len(words)
    let mut entities = []
    let mut i = 0
    while i < nw {
        let w = words[i]
        if len(w) >= 2 {
            let chars = w.chars()
            let first_code = to_int(chars[0])
            if _grag_is_upper_code(first_code) {
                let clean = _grag_strip_punct(w)
                if len(clean) >= 2 {
                    if _grag_arr_contains_str(entities, clean) == false {
                        entities = entities + [clean]
                    }
                }
            }
        }
        i = i + 1
    }
    return entities
}

fn grag_extract_relations(text, entities) {
    let ne = len(entities)
    let mut triples = []
    let mut i = 0
    while i < ne {
        let mut j = i + 1
        while j < ne {
            let e1 = entities[i]
            let e2 = entities[j]
            let pos1 = text.index_of(e1)
            let pos2 = text.index_of(e2)
            if pos1 >= 0 {
                if pos2 >= 0 {
                    let mut start = pos1 + len(e1)
                    let mut end = pos2
                    if pos2 < pos1 {
                        start = pos2 + len(e2)
                        end = pos1
                    }
                    let mut relation = "related_to"
                    if start < end {
                        let between = text.substring(start, end).trim()
                        if len(between) > 0 {
                            let bwords = between.split(" ")
                            if len(bwords) > 0 {
                                let candidate = bwords[0].to_lower()
                                if len(candidate) >= 2 {
                                    relation = candidate
                                }
                            }
                        }
                    }
                    let triple = [entities[i], relation, entities[j]]
                    triples = triples + [triple]
                }
            }
            j = j + 1
        }
        i = i + 1
    }
    return triples
}

fn _grag_find_or_add_node(graph, name, node_type) {
    let names = graph[2]
    let n = len(names)
    let mut i = 0
    while i < n {
        if names[i] == name {
            return [graph, i]
        }
        i = i + 1
    }
    return grag_add_node(graph, name, node_type)
}

fn grag_build_from_documents(docs) {
    let ndocs = len(docs)
    let mut graph = grag_create_graph()
    let mut di = 0
    while di < ndocs {
        let doc = docs[di]
        let entities = grag_extract_entities(doc)
        let relations = grag_extract_relations(doc, entities)
        let ne = len(entities)
        let mut ei = 0
        while ei < ne {
            let result = _grag_find_or_add_node(graph, entities[ei], "entity")
            graph = result[0]
            ei = ei + 1
        }
        let nr = len(relations)
        let mut ri = 0
        while ri < nr {
            let triple = relations[ri]
            let src_res = _grag_find_or_add_node(graph, triple[0], "entity")
            graph = src_res[0]
            let src_id = src_res[1]
            let dst_res = _grag_find_or_add_node(graph, triple[2], "entity")
            graph = dst_res[0]
            let dst_id = dst_res[1]
            graph = grag_add_edge(graph, src_id, dst_id, triple[1], 1.0)
            ri = ri + 1
        }
        di = di + 1
    }
    return graph
}

// ── Community detection (inlined) ─────────────────────────────

fn grag_label_propagation(graph, max_iter) {
    let nodes = graph[0]
    let n = len(nodes)
    if n == 0 { return graph }
    let mut labels = []
    for i in 0..n {
        labels = labels + [i]
    }
    let mut iter = 0
    while iter < max_iter {
        let mut changed = false
        let mut ni = 0
        while ni < n {
            let neighbors = grag_get_neighbors(graph, ni)
            let nn = len(neighbors)
            if nn > 0 {
                let mut label_counts = #{}
                let mut ki = 0
                while ki < nn {
                    let nb = neighbors[ki]
                    let lb = str(labels[nb])
                    if has_key(label_counts, lb) {
                        label_counts[lb] = label_counts[lb] + 1
                    } else {
                        label_counts[lb] = 1
                    }
                    ki = ki + 1
                }
                let mut best_label = labels[ni]
                let mut best_count = 0
                let mut mi = 0
                while mi < nn {
                    let nb = neighbors[mi]
                    let lb = str(labels[nb])
                    let cnt = label_counts[lb]
                    if cnt > best_count {
                        best_count = cnt
                        best_label = labels[nb]
                    }
                    mi = mi + 1
                }
                if best_label != labels[ni] {
                    labels[ni] = best_label
                    changed = true
                }
            }
            ni = ni + 1
        }
        if changed == false {
            iter = max_iter
        }
        iter = iter + 1
    }
    let new_graph = [graph[0], graph[1], graph[2], graph[3], labels]
    return new_graph
}

fn grag_get_communities(graph) {
    let comms = graph[4]
    let n = len(comms)
    let mut comm_map = #{}
    let mut comm_ids = []
    let mut i = 0
    while i < n {
        let cid = str(comms[i])
        if has_key(comm_map, cid) == false {
            comm_map[cid] = []
            comm_ids = comm_ids + [comms[i]]
        }
        comm_map[cid] = comm_map[cid] + [i]
        i = i + 1
    }
    let mut result = []
    let nc = len(comm_ids)
    let mut ci = 0
    while ci < nc {
        let cid = comm_ids[ci]
        let members = comm_map[str(cid)]
        result = result + [[cid, members]]
        ci = ci + 1
    }
    return result
}

fn grag_community_summary(graph, community_id) {
    let comms = graph[4]
    let names = graph[2]
    let n = len(comms)
    let mut parts = []
    let mut i = 0
    while i < n {
        if comms[i] == community_id {
            parts = parts + [names[i]]
        }
        i = i + 1
    }
    if len(parts) == 0 { return "" }
    let mut out = parts[0]
    let np = len(parts)
    let mut pi = 1
    while pi < np {
        out = out + ", " + parts[pi]
        pi = pi + 1
    }
    return out
}

// ── Graph-enhanced retrieval (inlined) ────────────────────────

fn grag_local_search(graph, query_entities, depth) {
    let names = graph[2]
    let n = len(names)
    let mut frontier = []
    let mut visited = []
    let nq = len(query_entities)
    let mut qi = 0
    while qi < nq {
        let qe_lower = query_entities[qi].to_lower()
        let mut ni = 0
        while ni < n {
            if names[ni].to_lower() == qe_lower {
                if _grag_arr_contains_int(frontier, ni) == false {
                    frontier = frontier + [ni]
                    visited = visited + [ni]
                }
            }
            ni = ni + 1
        }
        qi = qi + 1
    }
    let mut d = 0
    while d < depth {
        let mut next_frontier = []
        let nf = len(frontier)
        let mut fi = 0
        while fi < nf {
            let neighbors = grag_get_neighbors(graph, frontier[fi])
            let nn = len(neighbors)
            let mut ni = 0
            while ni < nn {
                let nb = neighbors[ni]
                if _grag_arr_contains_int(visited, nb) == false {
                    visited = visited + [nb]
                    next_frontier = next_frontier + [nb]
                }
                ni = ni + 1
            }
            fi = fi + 1
        }
        frontier = next_frontier
        d = d + 1
    }
    return visited
}

fn grag_global_search(graph, query) {
    let communities = grag_get_communities(graph)
    let query_words = query.to_lower().split(" ")
    let nc = len(communities)
    let mut result_nodes = []
    let mut ci = 0
    while ci < nc {
        let comm = communities[ci]
        let comm_id = comm[0]
        let members = comm[1]
        let summary = grag_community_summary(graph, comm_id).to_lower()
        let nqw = len(query_words)
        let mut found = false
        let mut wi = 0
        while wi < nqw {
            if summary.contains(query_words[wi]) {
                found = true
            }
            wi = wi + 1
        }
        if found {
            let nm = len(members)
            let mut mi = 0
            while mi < nm {
                if _grag_arr_contains_int(result_nodes, members[mi]) == false {
                    result_nodes = result_nodes + [members[mi]]
                }
                mi = mi + 1
            }
        }
        ci = ci + 1
    }
    return result_nodes
}

fn grag_score_node(graph, node_id, query_entities) {
    let name = grag_get_node_name(graph, node_id).to_lower()
    let nq = len(query_entities)
    let mut score = 0.0
    let mut qi = 0
    while qi < nq {
        let qe = query_entities[qi].to_lower()
        if name.contains(qe) {
            score = score + 1.0
        }
        qi = qi + 1
    }
    let neighbors = grag_get_neighbors(graph, node_id)
    let nn = len(neighbors)
    let mut ni = 0
    while ni < nn {
        let nb_name = grag_get_node_name(graph, neighbors[ni]).to_lower()
        let mut qi2 = 0
        while qi2 < nq {
            let qe2 = query_entities[qi2].to_lower()
            if nb_name.contains(qe2) {
                score = score + 0.3
            }
            qi2 = qi2 + 1
        }
        ni = ni + 1
    }
    let edge_bonus = to_float(nn) * 0.1
    score = score + edge_bonus
    return score
}

fn grag_retrieve(graph, query, top_k) {
    let query_entities = grag_extract_entities(query)
    let query_words = query.split(" ")
    let mut all_query = []
    let nqe = len(query_entities)
    let mut i = 0
    while i < nqe {
        all_query = all_query + [query_entities[i]]
        i = i + 1
    }
    let nqw = len(query_words)
    i = 0
    while i < nqw {
        if _grag_arr_contains_str(all_query, query_words[i]) == false {
            all_query = all_query + [query_words[i]]
        }
        i = i + 1
    }
    let n = grag_node_count(graph)
    let mut scores = []
    i = 0
    while i < n {
        let sc = grag_score_node(graph, i, all_query)
        scores = scores + [sc]
        i = i + 1
    }
    let k = _grag_min(top_k, n)
    let mut result = []
    let mut selected = []
    let mut ki = 0
    while ki < k {
        let mut best_idx = 0 - 1
        let mut best_score = 0.0 - 1.0
        let mut si = 0
        while si < n {
            if _grag_arr_contains_int(selected, si) == false {
                if scores[si] > best_score {
                    best_score = scores[si]
                    best_idx = si
                }
            }
            si = si + 1
        }
        if best_idx >= 0 {
            result = result + [best_idx]
            selected = selected + [best_idx]
        }
        ki = ki + 1
    }
    return result
}

fn grag_context_from_nodes(graph, node_ids) {
    let edges = graph[1]
    let ne = len(edges)
    let nn = len(node_ids)
    let mut parts = []
    let mut i = 0
    while i < nn {
        let nid = node_ids[i]
        let name = grag_get_node_name(graph, nid)
        let ntype = graph[3][nid]
        parts = parts + ["[" + name + " (" + ntype + ")]"]
        i = i + 1
    }
    i = 0
    while i < ne {
        let e = edges[i]
        let src = e[0]
        let dst = e[1]
        let rel = e[2]
        let src_in = _grag_arr_contains_int(node_ids, src)
        let dst_in = _grag_arr_contains_int(node_ids, dst)
        if src_in {
            if dst_in {
                let src_name = grag_get_node_name(graph, src)
                let dst_name = grag_get_node_name(graph, dst)
                parts = parts + [src_name + " -[" + rel + "]-> " + dst_name]
            }
        }
        i = i + 1
    }
    if len(parts) == 0 { return "" }
    let mut out = parts[0]
    let np = len(parts)
    let mut pi = 1
    while pi < np {
        out = out + "\n" + parts[pi]
        pi = pi + 1
    }
    return out
}

// ── Evaluation metrics (inlined) ──────────────────────────────

fn grag_precision_at_k(retrieved, relevant, k) {
    let nr = len(retrieved)
    let eval_k = _grag_min(k, nr)
    if eval_k <= 0 { return 0.0 }
    let mut hits = 0
    let mut i = 0
    while i < eval_k {
        if _grag_arr_contains_int(relevant, retrieved[i]) {
            hits = hits + 1
        }
        i = i + 1
    }
    return to_float(hits) / to_float(eval_k)
}

fn grag_graph_density(graph) {
    let n = grag_node_count(graph)
    let e = grag_edge_count(graph)
    if n <= 1 { return 0.0 }
    let max_edges = n * (n - 1)
    return to_float(e) / to_float(max_edges)
}

// ===================================================================
//  TESTS
// ===================================================================

println("=== GraphRAG (#190) tests ===")
println("")

// ── Build a test graph: knowledge about programming languages ──

// T1: create_graph returns 5-element structure
let g0 = grag_create_graph()
check("T1 create_graph returns 5-element structure", len(g0) == 5)

// T2: empty graph has 0 nodes
check("T2 empty graph has 0 nodes", grag_node_count(g0) == 0)

// T3: empty graph has 0 edges
check("T3 empty graph has 0 edges", grag_edge_count(g0) == 0)

// T4: add_node returns correct node_id
let r1 = grag_add_node(g0, "Python", "language")
let g1 = r1[0]
let id1 = r1[1]
check("T4 add_node returns node_id=0", id1 == 0)

// T5: add_node increments node count
check("T5 node count = 1 after add", grag_node_count(g1) == 1)

// T6: add second node returns id=1
let r2 = grag_add_node(g1, "Rust", "language")
let g2 = r2[0]
let id2 = r2[1]
check("T6 second node id=1", id2 == 1)

// T7: add_edge increments edge count
let g3 = grag_add_edge(g2, 0, 1, "competes_with", 1.0)
check("T7 edge count = 1 after add_edge", grag_edge_count(g3) == 1)

// T8: get_node_name returns correct name
check("T8 get_node_name(0) = Python", grag_get_node_name(g3, 0) == "Python")

// T9: get_neighbors finds neighbor via edge
let nb1 = grag_get_neighbors(g3, 0)
check("T9 node 0 has 1 neighbor", len(nb1) == 1)

// T10: get_neighbors bidirectional
let nb2 = grag_get_neighbors(g3, 1)
check("T10 node 1 has 1 neighbor (bidirectional)", len(nb2) == 1)

// ── Entity / relation extraction ──────────────────────────────

// T11: extract_entities finds capitalized words
let ents1 = grag_extract_entities("Alice met Bob at the Park")
check("T11 extract_entities finds Alice Bob Park", len(ents1) == 3)

// T12: extract_entities skips short words (1-char caps like "I")
let ents2 = grag_extract_entities("I saw Alice and A cat")
// "I" and "A" are single-char, skipped. "Alice" kept.
check("T12 extract_entities skips single-char", _grag_arr_contains_str(ents2, "Alice"))

// T13: extract_entities deduplicates
let ents3 = grag_extract_entities("Alice met Alice again")
check("T13 extract_entities deduplicates", len(ents3) == 1)

// T14: extract_relations finds triples
let text14 = "Alice knows Bob"
let ents14 = grag_extract_entities(text14)
let rels14 = grag_extract_relations(text14, ents14)
check("T14 extract_relations finds 1 triple", len(rels14) == 1)

// ── Build from documents ──────────────────────────────────────

let docs = [
    "Python is used by Google and Facebook for AI research",
    "Google developed TensorFlow using Python",
    "Facebook created PyTorch using Python",
    "Rust is used by Mozilla for Firefox browser"
]
let gd = grag_build_from_documents(docs)

// T15: build_from_documents creates graph with nodes
check("T15 build_from_documents has nodes", grag_node_count(gd) > 0)

// T16: build_from_documents has edges
check("T16 build_from_documents has edges", grag_edge_count(gd) > 0)

// ── Community detection ───────────────────────────────────────

let gc = grag_label_propagation(gd, 10)

// T17: label_propagation produces valid communities array
let comms_arr = gc[4]
check("T17 label_propagation communities length matches nodes", len(comms_arr) == grag_node_count(gc))

// T18: connected nodes share community (at least some pairs)
let edges_gc = gc[1]
let mut shared_count = 0
let n_edges_gc = len(edges_gc)
let mut ei = 0
while ei < n_edges_gc {
    let e = edges_gc[ei]
    let src_comm = comms_arr[e[0]]
    let dst_comm = comms_arr[e[1]]
    if src_comm == dst_comm {
        shared_count = shared_count + 1
    }
    ei = ei + 1
}
check("T18 some connected nodes share community", shared_count > 0)

// T19: get_communities returns groups
let comm_groups = grag_get_communities(gc)
check("T19 get_communities returns non-empty list", len(comm_groups) > 0)

// T20: community_summary contains node names
let first_comm = comm_groups[0]
let first_comm_id = first_comm[0]
let summary = grag_community_summary(gc, first_comm_id)
check("T20 community_summary non-empty", len(summary) > 0)

// ── Graph-enhanced retrieval ──────────────────────────────────

// Build a simple known graph for retrieval tests
let mut rg = grag_create_graph()
let ra = grag_add_node(rg, "Alice", "person")
rg = ra[0]
let rb = grag_add_node(rg, "Bob", "person")
rg = rb[0]
let rc = grag_add_node(rg, "Carol", "person")
rg = rc[0]
let rd = grag_add_node(rg, "Database", "concept")
rg = rd[0]
let re = grag_add_node(rg, "Network", "concept")
rg = re[0]

// Alice knows Bob, Bob knows Carol, Alice uses Database, Carol uses Network
rg = grag_add_edge(rg, 0, 1, "knows", 1.0)
rg = grag_add_edge(rg, 1, 2, "knows", 1.0)
rg = grag_add_edge(rg, 0, 3, "uses", 1.0)
rg = grag_add_edge(rg, 2, 4, "uses", 1.0)

// T21: local_search finds start node
let ls1 = grag_local_search(rg, ["Alice"], 0)
check("T21 local_search depth=0 finds Alice", len(ls1) == 1)

// T22: local_search depth=1 finds neighbors
let ls2 = grag_local_search(rg, ["Alice"], 1)
// Alice(0) + neighbors: Bob(1), Database(3) = 3 nodes
check("T22 local_search depth=1 finds neighbors", len(ls2) >= 2)

// T23: global_search finds matching community
let rg_c = grag_label_propagation(rg, 10)
let gs1 = grag_global_search(rg_c, "Alice")
check("T23 global_search finds Alice community", len(gs1) > 0)

// T24: score_node direct match > no match
let score_alice = grag_score_node(rg, 0, ["Alice"])
let score_carol_for_alice = grag_score_node(rg, 2, ["Alice"])
check("T24 score direct match > no match", score_alice > score_carol_for_alice)

// T25: retrieve returns top-k nodes
let top3 = grag_retrieve(rg, "Alice Database", 3)
check("T25 retrieve returns <= 3 nodes", len(top3) <= 3)

// T26: retrieve top-1 is most relevant
let top1 = grag_retrieve(rg, "Alice", 1)
check("T26 retrieve top-1 is Alice (id=0)", len(top1) >= 1)

// T27: context_from_nodes includes node names
let ctx = grag_context_from_nodes(rg, [0, 1])
check("T27 context includes Alice", ctx.contains("Alice"))

// ── Evaluation metrics ────────────────────────────────────────

// T28: precision_at_k perfect retrieval
let p_perfect = grag_precision_at_k([0, 1, 2], [0, 1, 2], 3)
check("T28 precision@3 perfect = 1.0", approx(p_perfect, 1.0, 0.001))

// T29: precision_at_k partial retrieval
let p_partial = grag_precision_at_k([0, 1, 2], [0, 2], 3)
// 2 of 3 retrieved are relevant = 0.666...
check("T29 precision@3 partial ~ 0.667", approx(p_partial, 0.667, 0.01))

// T30: graph_density correct for complete graph
// 3 nodes, 6 edges (both directions) => 6 / (3*2) = 1.0
let mut cg = grag_create_graph()
let ca = grag_add_node(cg, "X", "t")
cg = ca[0]
let cb = grag_add_node(cg, "Y", "t")
cg = cb[0]
let cc = grag_add_node(cg, "Z", "t")
cg = cc[0]
cg = grag_add_edge(cg, 0, 1, "e", 1.0)
cg = grag_add_edge(cg, 1, 0, "e", 1.0)
cg = grag_add_edge(cg, 0, 2, "e", 1.0)
cg = grag_add_edge(cg, 2, 0, "e", 1.0)
cg = grag_add_edge(cg, 1, 2, "e", 1.0)
cg = grag_add_edge(cg, 2, 1, "e", 1.0)
let dens = grag_graph_density(cg)
check("T30 graph_density complete 3-node = 1.0", approx(dens, 1.0, 0.001))

// ===================================================================
println("")
println("=== graph_rag test summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
