// -- inlined from self/runtime/topo_sort_pure.hexa --
// codegen import not wired for test files

// ═══════════════════════════════════════════════════════════════════
//  self/runtime/topo_sort_pure.hexa — Kahn's topological sort (ROI #125)
//
//  Pure-Hexa Kahn's algorithm for topological sorting of DAGs.
//  O(V + E) time and space. No C deps, no FFI, no syscalls.
//
//  Public API:
//      topo_sort(num_nodes, edges)            — sorted array or [] if cycle
//      has_cycle(num_nodes, edges)            — true if cycle exists
//      in_degree(num_nodes, edges)            — in-degree per node
//      adjacency_list(num_nodes, edges)       — build adj list from edges
//      all_topo_sorts(num_nodes, edges)       — all valid orderings (small graphs)
//      is_valid_topo_order(order, edges)      — verify ordering correctness
//
//  edges = [[from, to], ...] where from/to are 0-based node indices.
//
//  Pitfalls honored: P1 no semicolons, P15 let mut, P29 push rebind,
//  P39 no 0b literals, arr[(i+1)..j] needs parens
//  `handle` is reserved — never used as param name
// ═══════════════════════════════════════════════════════════════════

// ── _set_at — pure helper: return new array with arr[idx] = val ──
fn _set_at(arr, idx, val) {
    let n = len(arr)
    let mut out = []
    let mut i = 0
    while i < n {
        if i == idx {
            out.push(val)
        } else {
            out.push(arr[i])
        }
        i = i + 1
    }
    return out
}

// ── adjacency_list ─────────────────────────────────────────────────
// Build an adjacency list from (num_nodes, edges).
// Returns array of arrays: adj[u] = [v1, v2, ...] for each edge u->v.
pub fn adjacency_list(num_nodes, edges) {
    let mut adj = []
    let mut i = 0
    while i < num_nodes {
        adj.push([])
        i = i + 1
    }
    let ne = len(edges)
    let mut ei = 0
    while ei < ne {
        let edge = edges[ei]
        let u = edge[0]
        let v = edge[1]
        if u >= 0 && u < num_nodes && v >= 0 && v < num_nodes {
            let old_list = adj[u]
            adj = _set_at(adj, u, old_list.push(v))
        }
        ei = ei + 1
    }
    adj
}

// ── in_degree ──────────────────────────────────────────────────────
// Returns an array of in-degrees indexed by node id.
pub fn in_degree(num_nodes, edges) {
    let mut deg = []
    let mut i = 0
    while i < num_nodes {
        deg.push(0)
        i = i + 1
    }
    let ne = len(edges)
    let mut ei = 0
    while ei < ne {
        let edge = edges[ei]
        let v = edge[1]
        if v >= 0 && v < num_nodes {
            deg = _set_at(deg, v, deg[v] + 1)
        }
        ei = ei + 1
    }
    deg
}

// ── topo_sort ──────────────────────────────────────────────────────
// Kahn's algorithm: BFS-based topological sort.
// Returns a valid topological ordering, or empty array if a cycle
// exists. num_nodes = number of nodes, edges = [[from, to], ...].
// Legacy alias topo_sort_pure also exported for backward compat.
pub fn topo_sort(num_nodes, edges) {
    if num_nodes <= 0 { return [] }

    // Build in-degree array and adjacency list
    let mut in_deg = in_degree(num_nodes, edges)
    let adj = adjacency_list(num_nodes, edges)

    // Initialize queue with all nodes of in-degree 0
    let mut queue = []
    let mut i = 0
    while i < num_nodes {
        if in_deg[i] == 0 {
            queue.push(i)
        }
        i = i + 1
    }

    let mut result = []
    let mut front = 0

    while front < len(queue) {
        let node = queue[front]
        front = front + 1
        result.push(node)

        // For each neighbor of node, decrement in-degree
        let neighbors = adj[node]
        let nn = len(neighbors)
        let mut ni = 0
        while ni < nn {
            let nb = neighbors[ni]
            let new_val = in_deg[nb] - 1
            in_deg = _set_at(in_deg, nb, new_val)
            if new_val == 0 {
                queue.push(nb)
            }
            ni = ni + 1
        }
    }

    // If not all nodes are in result, there is a cycle
    if len(result) != num_nodes { return [] }
    return result
}

// ── topo_sort_pure — backward-compat alias ─────────────────────
pub fn topo_sort_pure(n, edges) {
    return topo_sort(n, edges)
}

// ── has_cycle ──────────────────────────────────────────────────────
// Returns true if the directed graph contains a cycle.
pub fn has_cycle(num_nodes, edges) {
    if num_nodes <= 0 { return false }
    let sorted = topo_sort(num_nodes, edges)
    return len(sorted) == 0
}

// ── topo_has_cycle_pure — backward-compat alias ────────────────
pub fn topo_has_cycle_pure(n, edges) {
    return has_cycle(n, edges)
}

// ── is_valid_topo_order ────────────────────────────────────────────
// Verify that `order` is a valid topological ordering for the given
// edge set. Every edge (u, v) must have u appear before v in order.
pub fn is_valid_topo_order(order, edges) {
    let n = len(order)
    if n == 0 { return len(edges) == 0 }

    // Find max node id to size the position array
    let mut max_node = 0
    let mut oi = 0
    while oi < n {
        if order[oi] > max_node { max_node = order[oi] }
        oi = oi + 1
    }

    // Build position map: pos[node] = index in order
    let mut pos = []
    let mut pi = 0
    while pi <= max_node {
        pos.push(-1)
        pi = pi + 1
    }

    let mut si = 0
    while si < n {
        let node = order[si]
        if node >= 0 && node <= max_node {
            pos = _set_at(pos, node, si)
        }
        si = si + 1
    }

    // Check every edge: from must appear before to
    let ne = len(edges)
    let mut ei = 0
    while ei < ne {
        let edge = edges[ei]
        let u = edge[0]
        let v = edge[1]
        if u < 0 || u > max_node || v < 0 || v > max_node { return false }
        let pu = pos[u]
        let pv = pos[v]
        if pu < 0 || pv < 0 { return false }
        if pu >= pv { return false }
        ei = ei + 1
    }
    return true
}

// ── all_topo_sorts ─────────────────────────────────────────────────
// Returns all valid topological orderings via backtracking.
// Only suitable for small graphs (exponential worst case).
pub fn all_topo_sorts(num_nodes, edges) {
    if num_nodes <= 0 { return [[]] }
    let adj = adjacency_list(num_nodes, edges)
    let mut deg = in_degree(num_nodes, edges)

    // Mark which nodes are already placed
    let mut visited = []
    let mut vi = 0
    while vi < num_nodes {
        visited.push(false)
        vi = vi + 1
    }

    let mut current = []
    let mut results = []
    results = _all_topo_bt(num_nodes, adj, deg, visited, current, results)
    return results
}

// ── _arr_copy — shallow-copy an array (isolate from push mutation) ──
fn _arr_copy(arr) {
    let n = len(arr)
    let mut out = []
    let mut i = 0
    while i < n {
        out.push(arr[i])
        i = i + 1
    }
    return out
}

// ── _all_topo_bt ───────────────────────────────────────────────────
// Backtracking helper for all_topo_sorts.
// NOTE: Hexa arrays are reference types and .push() mutates in-place,
// so we must build fresh copies before recursing to avoid corruption.
fn _all_topo_bt(num_nodes, adj, deg, visited, current, results) {
    if len(current) == num_nodes {
        // Copy current path into results
        let copy = _arr_copy(current)
        results.push(copy)
        return results
    }

    let mut u = 0
    while u < num_nodes {
        if visited[u] == false && deg[u] == 0 {
            // Choose u — build a fresh next_current instead of mutating current
            let next_visited = _set_at(visited, u, true)
            let mut next_current = _arr_copy(current)
            next_current.push(u)

            // Reduce in-degree of neighbors
            let neighbors = adj[u]
            let nn = len(neighbors)
            let mut next_deg = deg
            let mut ni = 0
            while ni < nn {
                let nb = neighbors[ni]
                next_deg = _set_at(next_deg, nb, next_deg[nb] - 1)
                ni = ni + 1
            }

            results = _all_topo_bt(num_nodes, adj, next_deg, next_visited, next_current, results)
            // No undo needed — deg, visited, current are unchanged in this scope
        }
        u = u + 1
    }

    return results
}


// -- end inlined --

let mut pass = 0
let mut fail = 0

fn check(name, cond) {
    if cond {
        pass = pass + 1
    } else {
        fail = fail + 1
        println("[FAIL] " + name)
    }
}

fn eq(name, actual, expected) {
    if actual == expected {
        pass = pass + 1
    } else {
        fail = fail + 1
        println("[FAIL] " + name + " expected=" + to_string(expected) + " got=" + to_string(actual))
    }
}

fn eq_arr(name, actual, expected) {
    let n = len(actual)
    if n != len(expected) {
        fail = fail + 1
        println("[FAIL] " + name + " len expected=" + to_string(len(expected)) + " got=" + to_string(n))
        return void
    }
    let mut i = 0
    let mut ok = true
    while i < n {
        if actual[i] != expected[i] { ok = false }
        i = i + 1
    }
    if ok {
        pass = pass + 1
    } else {
        fail = fail + 1
        println("[FAIL] " + name + " content mismatch actual=" + to_string(actual) + " expected=" + to_string(expected))
    }
}

println("=== topo_sort_pure test suite ===")

// ================================================================
//  1. Diamond DAG: 0->1, 0->2, 1->3, 2->3
// ================================================================
let diamond_edges = [[0, 1], [0, 2], [1, 3], [2, 3]]
let diamond_result = topo_sort(4, diamond_edges)
eq("diamond len", len(diamond_result), 4)
eq("diamond first", diamond_result[0], 0)
eq("diamond last", diamond_result[3], 3)
check("diamond valid order", is_valid_topo_order(diamond_result, diamond_edges))

// ================================================================
//  2. Linear chain: 0->1->2->3
// ================================================================
let chain_edges = [[0, 1], [1, 2], [2, 3]]
let chain_result = topo_sort(4, chain_edges)
eq_arr("chain order", chain_result, [0, 1, 2, 3])
check("chain valid order", is_valid_topo_order(chain_result, chain_edges))

// ================================================================
//  3. Cycle detection: 0->1->2->0
// ================================================================
let cycle_edges = [[0, 1], [1, 2], [2, 0]]
let cycle_result = topo_sort(3, cycle_edges)
eq_arr("cycle returns empty", cycle_result, [])
check("has_cycle true", has_cycle(3, cycle_edges))

// ================================================================
//  4. Disconnected graph: 0->1, 2->3
// ================================================================
let disc_edges = [[0, 1], [2, 3]]
let disc_result = topo_sort(4, disc_edges)
eq("disconnected len", len(disc_result), 4)
check("disconnected valid", is_valid_topo_order(disc_result, disc_edges))
check("disconnected no cycle", !has_cycle(4, disc_edges))

// ================================================================
//  5. Single node, no edges
// ================================================================
let single_result = topo_sort(1, [])
eq_arr("single node", single_result, [0])
check("single no cycle", !has_cycle(1, []))

// ================================================================
//  6. is_valid_topo_order — correct ordering
// ================================================================
check("valid order diamond [0,1,2,3]", is_valid_topo_order([0, 1, 2, 3], diamond_edges))
check("valid order diamond [0,2,1,3]", is_valid_topo_order([0, 2, 1, 3], diamond_edges))

// ================================================================
//  7. is_valid_topo_order — incorrect orderings
// ================================================================
check("invalid order [3,0,1,2]", !is_valid_topo_order([3, 0, 1, 2], diamond_edges))
check("invalid order [1,0,2,3]", !is_valid_topo_order([1, 0, 2, 3], diamond_edges))
check("invalid order [0,3,1,2]", !is_valid_topo_order([0, 3, 1, 2], diamond_edges))

// ================================================================
//  8. in_degree function
// ================================================================
let diamond_deg = in_degree(4, diamond_edges)
eq("in_degree node 0", diamond_deg[0], 0)
eq("in_degree node 1", diamond_deg[1], 1)
eq("in_degree node 2", diamond_deg[2], 1)
eq("in_degree node 3", diamond_deg[3], 2)

let chain_deg = in_degree(4, chain_edges)
eq("in_degree chain 0", chain_deg[0], 0)
eq("in_degree chain 1", chain_deg[1], 1)
eq("in_degree chain 2", chain_deg[2], 1)
eq("in_degree chain 3", chain_deg[3], 1)

let empty_deg = in_degree(3, [])
eq("in_degree empty 0", empty_deg[0], 0)
eq("in_degree empty 1", empty_deg[1], 0)
eq("in_degree empty 2", empty_deg[2], 0)

// ================================================================
//  9. adjacency_list function
// ================================================================
let diamond_adj = adjacency_list(4, diamond_edges)
eq("adj len", len(diamond_adj), 4)
eq("adj[0] len", len(diamond_adj[0]), 2)
eq("adj[0][0]", diamond_adj[0][0], 1)
eq("adj[0][1]", diamond_adj[0][1], 2)
eq("adj[1] len", len(diamond_adj[1]), 1)
eq("adj[1][0]", diamond_adj[1][0], 3)
eq("adj[2] len", len(diamond_adj[2]), 1)
eq("adj[2][0]", diamond_adj[2][0], 3)
eq("adj[3] len", len(diamond_adj[3]), 0)

let empty_adj = adjacency_list(2, [])
eq("adj empty[0]", len(empty_adj[0]), 0)
eq("adj empty[1]", len(empty_adj[1]), 0)

// ================================================================
//  10. all_topo_sorts — diamond DAG
// ================================================================
let all_diamond = all_topo_sorts(4, diamond_edges)
eq("all_topo diamond count", len(all_diamond), 2)
// Both orderings must be valid
let mut ati = 0
while ati < len(all_diamond) {
    check("all_topo diamond[" + to_string(ati) + "] valid", is_valid_topo_order(all_diamond[ati], diamond_edges))
    ati = ati + 1
}

// ================================================================
//  11. all_topo_sorts — linear chain (only 1 ordering)
// ================================================================
let all_chain = all_topo_sorts(4, chain_edges)
eq("all_topo chain count", len(all_chain), 1)
eq_arr("all_topo chain[0]", all_chain[0], [0, 1, 2, 3])

// ================================================================
//  12. all_topo_sorts — no edges, 3 nodes (3! = 6 orderings)
// ================================================================
let all_none = all_topo_sorts(3, [])
eq("all_topo no-edges count", len(all_none), 6)

// ================================================================
//  13. Backward-compat aliases
// ================================================================
let alias_result = topo_sort_pure(4, diamond_edges)
eq("alias topo_sort_pure len", len(alias_result), 4)
eq("alias topo_sort_pure first", alias_result[0], 0)
eq("alias topo_has_cycle_pure true", topo_has_cycle_pure(3, cycle_edges), true)
eq("alias topo_has_cycle_pure false", topo_has_cycle_pure(4, diamond_edges), false)

// ================================================================
//  14. Two-node cycle: 0->1, 1->0
// ================================================================
let two_cycle_edges = [[0, 1], [1, 0]]
eq_arr("two-node cycle empty", topo_sort(2, two_cycle_edges), [])
check("two-node has cycle", has_cycle(2, two_cycle_edges))

// ================================================================
//  15. Self-loop: 0->0
// ================================================================
let self_loop_edges = [[0, 0]]
eq_arr("self-loop empty", topo_sort(1, self_loop_edges), [])
check("self-loop has cycle", has_cycle(1, self_loop_edges))

// ================================================================
//  16. n=0 edge case
// ================================================================
eq_arr("n=0 empty", topo_sort(0, []), [])
check("n=0 no cycle", !has_cycle(0, []))

// ================================================================
//  17. Longer chain: 0->1->2->3->4
// ================================================================
let long_chain_edges = [[0, 1], [1, 2], [2, 3], [3, 4]]
let long_chain_result = topo_sort(5, long_chain_edges)
eq_arr("long chain order", long_chain_result, [0, 1, 2, 3, 4])
check("long chain valid", is_valid_topo_order(long_chain_result, long_chain_edges))

// ================================================================
//  18. Partial cycle: 0->1, 1->2, 2->1, 2->3
// ================================================================
let partial_cycle_edges = [[0, 1], [1, 2], [2, 1], [2, 3]]
eq_arr("partial cycle empty", topo_sort(4, partial_cycle_edges), [])
check("partial cycle detected", has_cycle(4, partial_cycle_edges))

// ================================================================
//  19. is_valid_topo_order with empty edges
// ================================================================
check("valid order empty edges", is_valid_topo_order([0, 1, 2], []))
check("valid order single node", is_valid_topo_order([0], []))

// ================================================================
//  20. all_topo_sorts with cycle returns empty
// ================================================================
let all_cycle = all_topo_sorts(3, cycle_edges)
eq("all_topo cycle count", len(all_cycle), 0)

println("===========================================================")
println("  Results: " + to_string(pass) + " passed, " + to_string(fail) + " failed")
println("===========================================================")
if fail == 0 { println("ALL PASS") } else { println("SOME FAILED") }
