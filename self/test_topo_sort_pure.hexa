// ===================================================================
//  test_topo_sort_pure.hexa -- coverage for self/runtime/topo_sort_pure.hexa
//
//  Pitfalls honored: P1 no semicolons, P15 let mut, P29 push rebind,
//  P39 no 0b literals, while loops only
// ===================================================================

import "runtime/topo_sort_pure.hexa"

let mut pass = 0
let mut fail = 0

fn check(name, cond) {
    if cond {
        pass = pass + 1
    } else {
        fail = fail + 1
        println("[FAIL] " + name)
    }
}

fn eq(name, actual, expected) {
    if actual == expected {
        pass = pass + 1
    } else {
        fail = fail + 1
        println("[FAIL] " + name + " expected=" + to_string(expected) + " got=" + to_string(actual))
    }
}

fn eq_arr(name, actual, expected) {
    let n = len(actual)
    if n != len(expected) {
        fail = fail + 1
        println("[FAIL] " + name + " len expected=" + to_string(len(expected)) + " got=" + to_string(n))
        return void
    }
    let mut i = 0
    let mut ok = true
    while i < n {
        if actual[i] != expected[i] { ok = false }
        i = i + 1
    }
    if ok {
        pass = pass + 1
    } else {
        fail = fail + 1
        println("[FAIL] " + name + " content mismatch actual=" + to_string(actual) + " expected=" + to_string(expected))
    }
}

// Helper: check that result is a valid topological ordering
fn is_valid_topo(name, result, n, edges) {
    if len(result) != n {
        fail = fail + 1
        println("[FAIL] " + name + " result length " + to_string(len(result)) + " != " + to_string(n))
        return void
    }
    // Build position map: pos[node] = index in result
    let mut pos = []
    let mut i = 0
    while i < n {
        pos = pos.push(-1)
        i = i + 1
    }
    i = 0
    while i < n {
        let node = result[i]
        // Rebuild pos with updated entry
        let mut new_pos = []
        let mut pi = 0
        while pi < n {
            if pi == node {
                new_pos = new_pos.push(i)
            } else {
                new_pos = new_pos.push(pos[pi])
            }
            pi = pi + 1
        }
        pos = new_pos
        i = i + 1
    }
    // Check every edge: from must appear before to
    let num_edges = len(edges)
    let mut ei = 0
    let mut ok = true
    while ei < num_edges {
        let edge = edges[ei]
        let from_node = edge[0]
        let to_node = edge[1]
        if pos[from_node] >= pos[to_node] {
            ok = false
        }
        ei = ei + 1
    }
    if ok {
        pass = pass + 1
    } else {
        fail = fail + 1
        println("[FAIL] " + name + " invalid ordering")
    }
}

println("=== topo_sort_pure test suite ===")

// ================================================================
//  simple DAG: 0 -> 1 -> 2
// ================================================================
let simple_edges = [[0, 1], [1, 2]]
let simple_result = topo_sort_pure(3, simple_edges)
is_valid_topo("simple DAG valid", simple_result, 3, simple_edges)
eq_arr("simple DAG order", simple_result, [0, 1, 2])

// ================================================================
//  diamond: 0 -> 1, 0 -> 2, 1 -> 3, 2 -> 3
// ================================================================
let diamond_edges = [[0, 1], [0, 2], [1, 3], [2, 3]]
let diamond_result = topo_sort_pure(4, diamond_edges)
is_valid_topo("diamond valid", diamond_result, 4, diamond_edges)
// Node 0 must be first, node 3 must be last
eq("diamond first", diamond_result[0], 0)
eq("diamond last", diamond_result[3], 3)

// ================================================================
//  cycle detection: 0 -> 1 -> 2 -> 0
// ================================================================
let cycle_edges = [[0, 1], [1, 2], [2, 0]]
let cycle_result = topo_sort_pure(3, cycle_edges)
eq_arr("cycle returns empty", cycle_result, [])
eq("has_cycle true", topo_has_cycle_pure(3, cycle_edges), true)

// ================================================================
//  no cycle check
// ================================================================
eq("has_cycle false simple", topo_has_cycle_pure(3, simple_edges), false)
eq("has_cycle false diamond", topo_has_cycle_pure(4, diamond_edges), false)

// ================================================================
//  single node, no edges
// ================================================================
let single_result = topo_sort_pure(1, [])
eq_arr("single node", single_result, [0])
eq("single no cycle", topo_has_cycle_pure(1, []), false)

// ================================================================
//  disconnected graph: 0->1, 2->3 (no cross-edges)
// ================================================================
let disc_edges = [[0, 1], [2, 3]]
let disc_result = topo_sort_pure(4, disc_edges)
is_valid_topo("disconnected valid", disc_result, 4, disc_edges)

// ================================================================
//  two-node cycle: 0 -> 1, 1 -> 0
// ================================================================
let two_cycle_edges = [[0, 1], [1, 0]]
eq_arr("two-node cycle empty", topo_sort_pure(2, two_cycle_edges), [])
eq("two-node has cycle", topo_has_cycle_pure(2, two_cycle_edges), true)

// ================================================================
//  self-loop: 0 -> 0
// ================================================================
let self_loop_edges = [[0, 0]]
eq_arr("self-loop empty", topo_sort_pure(1, self_loop_edges), [])
eq("self-loop has cycle", topo_has_cycle_pure(1, self_loop_edges), true)

// ================================================================
//  no edges, multiple nodes
// ================================================================
let no_edge_result = topo_sort_pure(3, [])
eq("no edges len", len(no_edge_result), 3)
eq("no edges no cycle", topo_has_cycle_pure(3, []), false)

// ================================================================
//  n=0 edge case
// ================================================================
eq_arr("n=0 empty", topo_sort_pure(0, []), [])
eq("n=0 no cycle", topo_has_cycle_pure(0, []), false)

// ================================================================
//  longer chain: 0->1->2->3->4
// ================================================================
let chain_edges = [[0, 1], [1, 2], [2, 3], [3, 4]]
let chain_result = topo_sort_pure(5, chain_edges)
eq_arr("chain order", chain_result, [0, 1, 2, 3, 4])
is_valid_topo("chain valid", chain_result, 5, chain_edges)

// ================================================================
//  partial cycle: 0->1, 1->2, 2->1, 2->3
// ================================================================
let partial_cycle_edges = [[0, 1], [1, 2], [2, 1], [2, 3]]
eq_arr("partial cycle empty", topo_sort_pure(4, partial_cycle_edges), [])
eq("partial cycle detected", topo_has_cycle_pure(4, partial_cycle_edges), true)

println("===========================================================")
println("  Results: " + to_string(pass) + " passed, " + to_string(fail) + " failed")
println("===========================================================")
if fail == 0 { println("ALL PASS") } else { println("SOME FAILED") }
