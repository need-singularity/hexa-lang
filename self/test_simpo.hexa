let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx(a, b, eps) { return fabs(a - b) < eps }

// ── inline SimPO functions (self-contained test) ─────────────────

fn sp_exp(x) {
    let mut v = x
    if v > 20.0 { v = 20.0 }
    if v < -20.0 { v = -20.0 }
    let mut result = 1.0
    let mut term = 1.0
    let mut i = 1

    while i < 30 {
        term = term * v / to_float(i)
        result = result + term
    }
    if result < 0.0 { return 0.0 }
    return result
}

fn sp_log(x) {
    if x <= 0.0 { return -30.0 }
    let mut v = x
    let mut count = 0
    while v > 2.0 {
        v = v / 2.718281828
        count = count + 1
    }
    while v < 0.5 {
        v = v * 2.718281828
        count = count - 1
    }
    let d = v - 1.0
    let ln_v = d - d * d / 2.0 + d * d * d / 3.0 - d * d * d * d / 4.0
    return to_float(count) + ln_v
}

fn sp_sqrt(x) {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    let mut _i = 0

    while _i < 30 {
        g = (g + x / g) / 2.0
    }
    return g
}

fn simpo_sigmoid(x) {
    if x > 20.0 { return 1.0 }
    if x < -20.0 { return 0.0 }
    return 1.0 / (1.0 + sp_exp(0.0 - x))
}

fn simpo_log_sigmoid(x) {
    let neg_x = 0.0 - x
    if neg_x > 20.0 { return 0.0 - neg_x }
    if neg_x < -20.0 { return 0.0 }
    return 0.0 - sp_log(1.0 + sp_exp(neg_x))
}

fn simpo_softplus(x) {
    if x > 20.0 { return x }
    if x < -20.0 { return 0.0 }
    return sp_log(1.0 + sp_exp(x))
}

fn simpo_length_normalize(log_p, length) {
    if length <= 0 { return log_p }
    return log_p / to_float(length)
}

fn simpo_reward(log_p, length, beta) {
    return beta * simpo_length_normalize(log_p, length)
}

fn simpo_loss(log_p_w, log_p_l, len_w, len_l, beta, gamma) {
    let r_w = simpo_reward(log_p_w, len_w, beta)
    let r_l = simpo_reward(log_p_l, len_l, beta)
    let margin = r_w - r_l - gamma
    return 0.0 - simpo_log_sigmoid(margin)
}

fn simpo_loss_grad_lp_w(log_p_w, log_p_l, len_w, len_l, beta, gamma) {
    let r_w = simpo_reward(log_p_w, len_w, beta)
    let r_l = simpo_reward(log_p_l, len_l, beta)
    let margin = r_w - r_l - gamma
    let s = simpo_sigmoid(margin)
    if len_w <= 0 { return 0.0 }
    return 0.0 - (1.0 - s) * beta / to_float(len_w)
}

fn simpo_loss_grad_lp_l(log_p_w, log_p_l, len_w, len_l, beta, gamma) {
    let r_w = simpo_reward(log_p_w, len_w, beta)
    let r_l = simpo_reward(log_p_l, len_l, beta)
    let margin = r_w - r_l - gamma
    let s = simpo_sigmoid(margin)
    if len_l <= 0 { return 0.0 }
    return (1.0 - s) * beta / to_float(len_l)
}

fn simpo_reward_margin(log_p_w, log_p_l, len_w, len_l, beta) {
    let r_w = simpo_reward(log_p_w, len_w, beta)
    let r_l = simpo_reward(log_p_l, len_l, beta)
    return r_w - r_l
}

fn simpo_preference_accuracy(log_p_w, log_p_l, len_w, len_l) {
    let lp_w = simpo_length_normalize(log_p_w, len_w)
    let lp_l = simpo_length_normalize(log_p_l, len_l)
    if lp_w > lp_l { return 1.0 }
    return 0.0
}

fn simpo_batch_loss(batch, beta, gamma) {
    let n = len(batch)
    if n == 0 { return 0.0 }
    let mut total = 0.0
    let mut i = 0

    while i < n {
        let item = batch[i]
        total = total + simpo_loss(item[0], item[1], item[2], item[3], beta, gamma)
    }
    return total / to_float(n)
}

fn simpo_train_step(log_p_w, log_p_l, len_w, len_l, beta, gamma, lr) {
    let loss = simpo_loss(log_p_w, log_p_l, len_w, len_l, beta, gamma)
    let g_w = simpo_loss_grad_lp_w(log_p_w, log_p_l, len_w, len_l, beta, gamma)
    let g_l = simpo_loss_grad_lp_l(log_p_w, log_p_l, len_w, len_l, beta, gamma)
    let new_lp_w = log_p_w - lr * g_w
    let new_lp_l = log_p_l - lr * g_l
    return [loss, new_lp_w, new_lp_l]
}

fn simpo_train(batch, n_steps, lr, beta, gamma) {
    let mut lp_w = batch[0]
    let mut lp_l = batch[1]
    let len_w = batch[2]
    let len_l = batch[3]
    let mut last_loss = 0.0
    let mut step = 0
    while step < n_steps {
        let r = simpo_train_step(lp_w, lp_l, len_w, len_l, beta, gamma, lr)
        last_loss = r[0]
        lp_w = r[1]
        lp_l = r[2]
        step = step + 1
    }
    return [last_loss, lp_w, lp_l]
}

fn simpo_dpo_vs_simpo(log_p_w, log_p_l, ref_w, ref_l, len_w, len_l, beta, gamma) {
    let log_ratio_w = log_p_w - ref_w
    let log_ratio_l = log_p_l - ref_l
    let dpo_logit = beta * (log_ratio_w - log_ratio_l)
    let dpo_l = 0.0 - simpo_log_sigmoid(dpo_logit)
    let simpo_l = simpo_loss(log_p_w, log_p_l, len_w, len_l, beta, gamma)
    return [dpo_l, simpo_l]
}

// ── #124 new functions ───────────────────────────────────────────

fn simpo_make_config(beta, gamma, lr) {
    return [beta, gamma, lr]
}

fn simpo_config_beta(cfg) { return cfg[0] }
fn simpo_config_gamma(cfg) { return cfg[1] }
fn simpo_config_lr(cfg) { return cfg[2] }

fn simpo_make_pair(lp_w, lp_l, len_w, len_l) {
    return [lp_w, lp_l, len_w, len_l]
}

fn simpo_pair_lp_w(pair) { return pair[0] }
fn simpo_pair_lp_l(pair) { return pair[1] }
fn simpo_pair_len_w(pair) { return pair[2] }
fn simpo_pair_len_l(pair) { return pair[3] }

fn simpo_make_dataset(pairs) { return pairs }
fn simpo_dataset_len(ds) { return len(ds) }
fn simpo_dataset_get(ds, i) { return ds[i] }

fn simpo_dataset_stats(ds, beta) {
    let n = len(ds)
    if n == 0 { return [0.0, 0.0, 0.0, 0.0] }
    let mut sum_rw = 0.0
    let mut sum_rl = 0.0
    let mut sum_margin = 0.0
    let mut correct = 0
    let mut i = 0

    while i < n {
        let p = ds[i]
        let rw = simpo_reward(p[0], p[2], beta)
        let rl = simpo_reward(p[1], p[3], beta)
        sum_rw = sum_rw + rw
        sum_rl = sum_rl + rl
        sum_margin = sum_margin + (rw - rl)
        if rw > rl { correct = correct + 1 }
    }
    let nf = to_float(n)
    return [sum_rw / nf, sum_rl / nf, sum_margin / nf, to_float(correct) / nf]
}

fn simpo_dataset_shuffle(ds, seed) {
    let n = len(ds)
    if n <= 1 { return ds }
    let mut indices = []
    let mut i = 0

    while i < n { indices = indices + [i] }
    let mut s = seed
    let mut i = n - 1
    while i > 0 {
        s = (s * 1103515245 + 12345) % 2147483647
        if s < 0 { s = 0 - s }
        let j = s % (i + 1)
        let tmp = indices[i]
        indices[i] = indices[j]
        indices[j] = tmp
        i = i - 1
    }
    let mut result = []
    let mut i = 0

    while i < n {
        result = result + [ds[indices[i]]]
    }
    return result
}

fn simpo_dataset_split_train(ds, train_ratio) {
    let n = len(ds)
    let split_idx = to_int(to_float(n) * train_ratio)
    let mut train = []
    let mut i = 0

    while i < split_idx {
        train = train + [ds[i]]
    }
    return train
}

fn simpo_dataset_split_val(ds, train_ratio) {
    let n = len(ds)
    let split_idx = to_int(to_float(n) * train_ratio)
    let mut val = []
    let mut i = split_idx

    while i < n {
        val = val + [ds[i]]
    }
    return val
}

fn simpo_softmax(logits) {
    let n = len(logits)
    let mut mx = logits[0]
    let mut i = 1

    while i < n {
        if logits[i] > mx { mx = logits[i] }
    }
    let mut exps = []
    let mut z = 0.0
    let mut i = 0

    while i < n {
        let e = sp_exp(logits[i] - mx)
        exps = exps + [e]
        z = z + e
    }
    let mut out = []
    let mut i = 0

    while i < n {
        out = out + [exps[i] / z]
    }
    return out
}

fn simpo_token_log_prob(logits, token_id) {
    let probs = simpo_softmax(logits)
    let p = probs[token_id]
    return sp_log(p)
}

fn simpo_avg_token_log_prob(token_log_probs) {
    let n = len(token_log_probs)
    if n == 0 { return 0.0 }
    let mut total = 0.0
    let mut i = 0

    while i < n {
        total = total + token_log_probs[i]
    }
    return total / to_float(n)
}

fn simpo_train_epoch_loss(ds, beta, gamma, lr) {
    let n = len(ds)
    if n == 0 { return 0.0 }
    let mut total_loss = 0.0
    let mut i = 0

    while i < n {
        let p = ds[i]
        let loss = simpo_loss(p[0], p[1], p[2], p[3], beta, gamma)
        total_loss = total_loss + loss
    }
    return total_loss / to_float(n)
}

fn simpo_train_epoch_update(ds, beta, gamma, lr) {
    let n = len(ds)
    if n == 0 { return ds }
    let mut updated = []
    let mut i = 0

    while i < n {
        let p = ds[i]
        let r = simpo_train_step(p[0], p[1], p[2], p[3], beta, gamma, lr)
        updated = updated + [[r[1], r[2], p[2], p[3]]]
    }
    return updated
}

fn simpo_train_loop_losses(ds, n_epochs, beta, gamma, lr) {
    let mut current_ds = ds
    let mut losses = []
    let mut _e = 0

    while _e < n_epochs {
        let loss = simpo_train_epoch_loss(current_ds, beta, gamma, lr)
        losses = losses + [loss]
        current_ds = simpo_train_epoch_update(current_ds, beta, gamma, lr)
    }
    return losses
}

fn simpo_reward_tracker_new() {
    return [0.0, 0.0, 0]
}

fn simpo_reward_tracker_record(tracker, rw, rl) {
    return [tracker[0] + rw, tracker[1] + rl, tracker[2] + 1]
}

fn simpo_reward_tracker_stats(tracker) {
    let count = tracker[2]
    if count == 0 { return [0.0, 0.0, 0.0, 0] }
    let nf = to_float(count)
    let avg_rw = tracker[0] / nf
    let avg_rl = tracker[1] / nf
    let avg_margin = avg_rw - avg_rl
    return [avg_rw, avg_rl, avg_margin, count]
}

fn simpo_dpo_loss_ref(lp_w, lp_l, ref_w, ref_l, beta) {
    let log_ratio_w = lp_w - ref_w
    let log_ratio_l = lp_l - ref_l
    let logit = beta * (log_ratio_w - log_ratio_l)
    return 0.0 - simpo_log_sigmoid(logit)
}

fn simpo_compare_dpo_simpo(pair, ref_w, ref_l, beta, gamma) {
    let lp_w = pair[0]
    let lp_l = pair[1]
    let len_w = pair[2]
    let len_l = pair[3]
    let d = simpo_dpo_loss_ref(lp_w, lp_l, ref_w, ref_l, beta)
    let s = simpo_loss(lp_w, lp_l, len_w, len_l, beta, gamma)
    let diff = d - s
    let mut abs_diff = diff
    if abs_diff < 0.0 { abs_diff = 0.0 - abs_diff }
    return [d, s, abs_diff]
}

fn simpo_batch_accuracy(ds, beta) {
    let n = len(ds)
    if n == 0 { return 0.0 }
    let mut correct = 0
    let mut i = 0

    while i < n {
        let p = ds[i]
        let rw = simpo_reward(p[0], p[2], beta)
        let rl = simpo_reward(p[1], p[3], beta)
        if rw > rl { correct = correct + 1 }
    }
    return to_float(correct) / to_float(n)
}

fn simpo_grad_norm(lp_w, lp_l, len_w, len_l, beta, gamma) {
    let gw = simpo_loss_grad_lp_w(lp_w, lp_l, len_w, len_l, beta, gamma)
    let gl = simpo_loss_grad_lp_l(lp_w, lp_l, len_w, len_l, beta, gamma)
    return sp_sqrt(gw * gw + gl * gl)
}

fn simpo_train_step_clipped(lp_w, lp_l, len_w, len_l, beta, gamma, lr, max_grad) {
    let loss = simpo_loss(lp_w, lp_l, len_w, len_l, beta, gamma)
    let mut gw = simpo_loss_grad_lp_w(lp_w, lp_l, len_w, len_l, beta, gamma)
    let mut gl = simpo_loss_grad_lp_l(lp_w, lp_l, len_w, len_l, beta, gamma)
    let gnorm = sp_sqrt(gw * gw + gl * gl)
    if gnorm > max_grad {
        let scale = max_grad / gnorm
        gw = gw * scale
        gl = gl * scale
    }
    return [loss, lp_w - lr * gw, lp_l - lr * gl]
}

fn simpo_margin_exceeds_target(lp_w, lp_l, len_w, len_l, beta, gamma) {
    let margin = simpo_reward_margin(lp_w, lp_l, len_w, len_l, beta)
    if margin > gamma { return 1.0 }
    return 0.0
}

fn simpo_loss_smooth(lp_w, lp_l, len_w, len_l, beta, gamma, epsilon) {
    let r_w = simpo_reward(lp_w, len_w, beta)
    let r_l = simpo_reward(lp_l, len_l, beta)
    let margin = r_w - r_l - gamma
    let loss_main = 0.0 - simpo_log_sigmoid(margin)
    let loss_flip = 0.0 - simpo_log_sigmoid(0.0 - margin)
    return (1.0 - epsilon) * loss_main + epsilon * loss_flip
}

// ═══════════════════════════════════════════════════════════════════
//  TESTS
// ═══════════════════════════════════════════════════════════════════

println("=== SimPO #124 Tests ===")

// ── T01-T03: sigmoid ──────────────────────────────────────────────
check("T01 sigmoid pos saturates near 1", simpo_sigmoid(5.0) > 0.99)
check("T02 sigmoid neg saturates near 0", simpo_sigmoid(-5.0) < 0.01)
check("T03 sigmoid(0) = 0.5", approx(simpo_sigmoid(0.0), 0.5, 0.01))

// ── T04-T05: log_sigmoid ─────────────────────────────────────────
let ls1 = simpo_log_sigmoid(1.0)
check("T04 log_sigmoid always negative", ls1 < 0.0)
let ls0 = simpo_log_sigmoid(0.0)
check("T05 log_sigmoid(0) approx log(0.5)", approx(ls0, sp_log(0.5), 0.1))

// ── T06-T07: softplus ────────────────────────────────────────────
check("T06 softplus always positive", simpo_softplus(1.0) > 0.0)
let sp0 = simpo_softplus(0.0)
check("T07 softplus(0) = log(2)", approx(sp0, sp_log(2.0), 0.1))

// ── T08-T09: length normalize ────────────────────────────────────
let n1 = simpo_length_normalize(-10.0, 5)
check("T08 length_normalize(-10, 5) = -2", approx(n1, -2.0, 0.001))
let n0 = simpo_length_normalize(-10.0, 0)
check("T09 length_normalize zero guard", approx(n0, -10.0, 0.001))

// ── T10: reward scales ───────────────────────────────────────────
let r1 = simpo_reward(-10.0, 5, 1.0)
let r2 = simpo_reward(-10.0, 5, 2.0)
check("T10 reward scales with beta", approx(r2, 2.0 * r1, 0.001))

// ── T11-T13: loss behavior ───────────────────────────────────────
let l_zero = simpo_loss(-5.0, -5.0, 4, 4, 2.0, 0.5)
check("T11 loss positive no separation", l_zero > 0.0)

let l_good = simpo_loss(-2.0, -10.0, 4, 4, 2.0, 0.5)
let l_bad  = simpo_loss(-10.0, -2.0, 4, 4, 2.0, 0.5)
check("T12 loss smaller chosen preferred", l_good < l_bad)
check("T13 loss larger rejected preferred", l_bad > l_good)

// ── T14: gamma effect ────────────────────────────────────────────
let l_g0 = simpo_loss(-4.0, -6.0, 4, 4, 2.0, 0.0)
let l_g1 = simpo_loss(-4.0, -6.0, 4, 4, 2.0, 1.0)
check("T14 gamma raises loss bar", l_g1 > l_g0)

// ── T15-T16: gradient directions ─────────────────────────────────
let gw = simpo_loss_grad_lp_w(-5.0, -5.0, 4, 4, 2.0, 0.5)
check("T15 grad_w negative", gw < 0.0)
let gl = simpo_loss_grad_lp_l(-5.0, -5.0, 4, 4, 2.0, 0.5)
check("T16 grad_l positive", gl > 0.0)

// ── T17: single train step ───────────────────────────────────────
let l_before = simpo_loss(-5.0, -5.0, 4, 4, 2.0, 0.5)
let step_r = simpo_train_step(-5.0, -5.0, 4, 4, 2.0, 0.5, 1.0)
let l_after = simpo_loss(step_r[1], step_r[2], 4, 4, 2.0, 0.5)
check("T17 train step decreases loss", l_after < l_before)

// ── T18: multi-step convergence ──────────────────────────────────
let batch0 = [-4.0, -6.0, 4, 4]
let t1 = simpo_train(batch0, 1, 1.0, 2.0, 0.5)
let t20 = simpo_train(batch0, 20, 1.0, 2.0, 0.5)
check("T18 multi-step converges", t20[0] < t1[0])

// ── T19-T20: preference accuracy ─────────────────────────────────
check("T19 pref acc correct", approx(simpo_preference_accuracy(-2.0, -8.0, 4, 4), 1.0, 0.001))
check("T20 pref acc wrong", approx(simpo_preference_accuracy(-8.0, -2.0, 4, 4), 0.0, 0.001))

// ── T21-T22: reward margin ───────────────────────────────────────
let rm_pos = simpo_reward_margin(-2.0, -8.0, 4, 4, 2.0)
check("T21 reward margin pos", rm_pos > 0.0)
let rm_neg = simpo_reward_margin(-8.0, -2.0, 4, 4, 2.0)
check("T22 reward margin neg", rm_neg < 0.0)

// ── T23: batch loss ──────────────────────────────────────────────
let batch = [[-2.0, -6.0, 4, 4], [-3.0, -7.0, 4, 4], [-1.0, -5.0, 4, 4]]
let bl = simpo_batch_loss(batch, 2.0, 0.5)
let m1 = simpo_loss(-2.0, -6.0, 4, 4, 2.0, 0.5)
let m2 = simpo_loss(-3.0, -7.0, 4, 4, 2.0, 0.5)
let m3 = simpo_loss(-1.0, -5.0, 4, 4, 2.0, 0.5)
let manual_avg = (m1 + m2 + m3) / 3.0
check("T23 batch loss matches manual avg", approx(bl, manual_avg, 0.001))

// ── T24: DPO vs SimPO ────────────────────────────────────────────
let cmp = simpo_dpo_vs_simpo(-2.0, -6.0, -4.0, -4.0, 4, 4, 2.0, 0.5)
check("T24 DPO and SimPO both finite positive", cmp[0] > 0.0 && cmp[1] > 0.0)

// ── T25: length bias ─────────────────────────────────────────────
let lb = simpo_preference_accuracy(-10.0, -10.0, 2, 10)
check("T25 length bias aware", approx(lb, 0.0, 0.001))

// ── T26: config builder ──────────────────────────────────────────
let cfg = simpo_make_config(2.5, 1.0, 0.01)
check("T26 config round-trip", approx(simpo_config_beta(cfg), 2.5, 0.001) && approx(simpo_config_gamma(cfg), 1.0, 0.001) && approx(simpo_config_lr(cfg), 0.01, 0.001))

// ── T27: pair constructor ────────────────────────────────────────
let pair = simpo_make_pair(-3.0, -7.0, 5, 8)
check("T27 pair round-trip", approx(simpo_pair_lp_w(pair), -3.0, 0.001) && simpo_pair_len_w(pair) == 5 && simpo_pair_len_l(pair) == 8)

// ── T28: dataset ─────────────────────────────────────────────────
let ds = simpo_make_dataset([
    [-2.0, -6.0, 4, 4],
    [-3.0, -7.0, 5, 5],
    [-1.5, -5.5, 3, 3],
    [-4.0, -8.0, 6, 6]
])
check("T28 dataset len and get", simpo_dataset_len(ds) == 4 && simpo_dataset_get(ds, 0)[0] == -2.0)

// ── T29: dataset stats ───────────────────────────────────────────
let stats = simpo_dataset_stats(ds, 2.0)
check("T29 dataset stats accuracy=1", approx(stats[3], 1.0, 0.001))

// ── T30: shuffle deterministic ───────────────────────────────────
let shuf1 = simpo_dataset_shuffle(ds, 42)
let shuf2 = simpo_dataset_shuffle(ds, 42)
let mut shuf_match = true
let mut i = 0

while i < simpo_dataset_len(ds) {
    if shuf1[i][0] != shuf2[i][0] { shuf_match = false }
}
check("T30 shuffle deterministic", shuf_match)

// ── T31: split ratio ────────────────────────────────────────────
let train_ds = simpo_dataset_split_train(ds, 0.75)
let val_ds = simpo_dataset_split_val(ds, 0.75)
check("T31 split ratio 75/25", len(train_ds) == 3 && len(val_ds) == 1)

// ── T32: train epoch loss finite ─────────────────────────────────
let epoch_loss = simpo_train_epoch_loss(ds, 2.0, 0.5, 1.0)
check("T32 epoch loss finite positive", epoch_loss > 0.0)

// ── T33: train epoch update changes lp_w ─────────────────────────
let ds_updated = simpo_train_epoch_update(ds, 2.0, 0.5, 1.0)
let orig_lp_w = ds[0][0]
let new_lp_w = ds_updated[0][0]
check("T33 epoch update changes lp_w", fabs(new_lp_w - orig_lp_w) > 0.001)

// ── T34: train loop losses monotone ──────────────────────────────
let loss_hist = simpo_train_loop_losses(ds, 5, 2.0, 0.5, 1.0)
let mut monotone = true
let mut i = 1

while i < len(loss_hist) {
    if loss_hist[i] > loss_hist[i - 1] + 0.001 { monotone = false }
}
check("T34 train loop monotone decreasing", monotone)

// ── T35: reward tracker ──────────────────────────────────────────
let mut tracker = simpo_reward_tracker_new()
tracker = simpo_reward_tracker_record(tracker, 2.0, -1.0)
tracker = simpo_reward_tracker_record(tracker, 4.0, -3.0)
let tr_stats = simpo_reward_tracker_stats(tracker)
check("T35 tracker count=2 avg_rw=3 avg_rl=-2", tr_stats[3] == 2 && approx(tr_stats[0], 3.0, 0.001) && approx(tr_stats[1], -2.0, 0.001))

// ── T36: DPO reference loss ──────────────────────────────────────
let dpo_l = simpo_dpo_loss_ref(-2.0, -6.0, -4.0, -4.0, 2.0)
check("T36 DPO ref loss finite positive", dpo_l > 0.0)

// ── T37: DPO vs SimPO comparison ─────────────────────────────────
let cmp2 = simpo_compare_dpo_simpo([-2.0, -6.0, 4, 4], -4.0, -4.0, 2.0, 0.5)
check("T37 compare returns finite diff", cmp2[2] >= 0.0 && cmp2[0] > 0.0 && cmp2[1] > 0.0)

// ── T38: grad norm ───────────────────────────────────────────────
let gn = simpo_grad_norm(-5.0, -5.0, 4, 4, 2.0, 0.5)
check("T38 grad norm positive", gn > 0.0)

// ── T39: clipped train step ──────────────────────────────────────
let clip_r = simpo_train_step_clipped(-5.0, -5.0, 4, 4, 2.0, 0.5, 1.0, 0.1)
let unclip_r = simpo_train_step(-5.0, -5.0, 4, 4, 2.0, 0.5, 1.0)
let clipped_delta_w = fabs(clip_r[1] - (-5.0))
let unclipped_delta_w = fabs(unclip_r[1] - (-5.0))
check("T39 clipped step smaller update", clipped_delta_w <= unclipped_delta_w + 0.001)

// ── T40: margin exceeds target after training ────────────────────
let trained = simpo_train([-4.0, -6.0, 4, 4], 50, 1.0, 2.0, 0.5)
let met = simpo_margin_exceeds_target(trained[1], trained[2], 4, 4, 2.0, 0.5)
check("T40 margin exceeds target after training", approx(met, 1.0, 0.001))

// ── T41: label smoothing ─────────────────────────────────────────
let loss_plain = simpo_loss(-4.0, -6.0, 4, 4, 2.0, 0.5)
let loss_smooth = simpo_loss_smooth(-4.0, -6.0, 4, 4, 2.0, 0.5, 0.1)
check("T41 smooth loss >= plain loss", loss_smooth >= loss_plain - 0.001)

// ── T42: token log prob from logits ──────────────────────────────
let logits = [2.0, 1.0, 0.5, 0.1]
let tlp = simpo_token_log_prob(logits, 0)
let tlp2 = simpo_token_log_prob(logits, 3)
check("T42 token log prob highest logit", tlp > tlp2)

// ── T43: avg token log prob ──────────────────────────────────────
let token_lps = [-1.0, -2.0, -3.0]
let avg_lp = simpo_avg_token_log_prob(token_lps)
check("T43 avg token log prob", approx(avg_lp, -2.0, 0.001))

// ── T44: batch accuracy ──────────────────────────────────────────
let good_ds = [[-2.0, -6.0, 4, 4], [-1.0, -5.0, 3, 3], [-3.0, -9.0, 5, 5]]
let ba = simpo_batch_accuracy(good_ds, 2.0)
check("T44 batch accuracy all correct", approx(ba, 1.0, 0.001))

// ═══════════════════════════════════════════════════════════════════
println("")
println("=== SimPO #124 summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
