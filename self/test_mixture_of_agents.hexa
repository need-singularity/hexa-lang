// ===================================================================
let pfns = [proposer_alpha, proposer_beta, proposer_gamma]
let props21 = moa_propose("what is X?", "", pfns, 0)
check("T21 propose returns 3 proposals", len(props21) == 3)

// ===================================================================
//  T22: moa_propose — source tags correct
// ===================================================================
check("T22 proposal[0] source=proposer_0", props21[0]["source"] == "proposer_0")

// ===================================================================
//  T23: moa_score_all — scores applied
// ===================================================================
let scored23 = moa_score_all(props21, mock_scorer, "q")
check("T23 score_all scores > 0", scored23[0]["score"] > 0.0)

// ===================================================================
//  T24: moa_aggregate_best — picks highest-scored text
// ===================================================================
let mut pa24 = moa_score_proposal(moa_new_proposal(0, "short", "m0", 0), 2.0)
let mut pb24 = moa_score_proposal(moa_new_proposal(1, "winner text", "m1", 0), 10.0)
let mut pc24 = moa_score_proposal(moa_new_proposal(2, "middle", "m2", 0), 5.0)
let agg24 = moa_aggregate_best([pa24, pb24, pc24])
check("T24 aggregate_best picks highest", agg24 == "winner text")

// ===================================================================
//  T25: moa_aggregate_concat — joins all texts
// ===================================================================
let agg25 = moa_aggregate_concat([pa24, pb24, pc24])
check("T25 aggregate_concat has pipe", agg25.contains(" | "))

// ===================================================================
//  T26: moa_aggregate_weighted — picks highest weight text
// ===================================================================
let agg26 = moa_aggregate_weighted([pa24, pb24, pc24])
check("T26 aggregate_weighted picks winner", agg26 == "winner text")

// ===================================================================
//  T27: moa_aggregate dispatch — "best" strategy
// ===================================================================
let agg27 = moa_aggregate([pa24, pb24, pc24], "best")
check("T27 aggregate dispatch best", agg27 == "winner text")

// ===================================================================
//  T28: moa_diversity_scores — identical texts => low diversity
// ===================================================================
let ident_a = moa_new_proposal(0, "same words here", "m0", 0)
let ident_b = moa_new_proposal(1, "same words here", "m1", 0)
let divs28 = moa_diversity_scores([ident_a, ident_b])
check("T28 identical texts diversity=0", approx(divs28[0], 0.0, 0.01))

// ===================================================================
//  T29: moa_diversity_scores — different texts => higher diversity
// ===================================================================
let diff_a = moa_new_proposal(0, "cats dogs fish", "m0", 0)
let diff_b = moa_new_proposal(1, "apples oranges grapes", "m1", 0)
let divs29 = moa_diversity_scores([diff_a, diff_b])
check("T29 different texts diversity>0", divs29[0] > 0.5)

// ===================================================================
//  T30: moa_apply_diversity_bonus — scores increase
// ===================================================================
let mut bonus_a = moa_score_proposal(moa_new_proposal(0, "alpha idea", "m0", 0), 5.0)
let mut bonus_b = moa_score_proposal(moa_new_proposal(1, "totally different thing", "m1", 0), 5.0)
let boosted = moa_apply_diversity_bonus([bonus_a, bonus_b], 1.0)
check("T30 diversity bonus increases scores", boosted[0]["score"] > 5.0)

// ===================================================================
//  T31: moa_top_k — returns k items sorted by score
// ===================================================================
let tk_a = moa_score_proposal(moa_new_proposal(0, "a", "m0", 0), 1.0)
let tk_b = moa_score_proposal(moa_new_proposal(1, "b", "m1", 0), 9.0)
let tk_c = moa_score_proposal(moa_new_proposal(2, "c", "m2", 0), 5.0)
let top2 = moa_top_k([tk_a, tk_b, tk_c], 2)
check("T31 top_k returns 2", len(top2) == 2)

// ===================================================================
//  T32: moa_avg_score — correct average
// ===================================================================
let avg32 = moa_avg_score([tk_a, tk_b, tk_c])
check("T32 avg_score=5.0", approx(avg32, 5.0, 0.01))

// ===================================================================
//  T33: moa_run — full multi-round session completes
// ===================================================================
let run_cfg = moa_config(3, 2, "best")
let sess33 = moa_run("What is 2+2?", pfns, biased_scorer, run_cfg)
check("T33 moa_run status=done", moa_session_status(sess33) == "done")

// ===================================================================
//  T34: moa_run — session has correct round count
// ===================================================================
check("T34 moa_run n_rounds=2", moa_session_num_rounds(sess33) == 2)

// ===================================================================
//  T35: moa_session_stats — total_proposals correct
// ===================================================================
let stats35 = moa_session_stats(sess33)
check("T35 stats total_proposals=6 (3 per round x 2)", stats35["total_proposals"] == 6)

// ===================================================================
println("")
println("=== mixture_of_agents test summary ===")
println("PASS: " + to_string(pass_count))
println("FAIL: " + to_string(fail_count))
println("TOTAL: " + to_string(pass_count + fail_count))
