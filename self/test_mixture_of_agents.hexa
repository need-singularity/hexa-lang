//  test_mixture_of_agents.hexa — Mixture of Agents (ML #162) tests
//
//  Tests (35 checks):
//    T01. moa_default_config: num_proposers = 3
//    T02. moa_default_config: num_rounds = 2
//    T03. moa_default_config: aggregation_strategy = "best"
//    T04. moa_config: custom values applied
//    T05. moa_config_set: overrides key
//    T06. moa_new_proposal: fields correct
//    T07. moa_new_proposal: initial score = 0
//    T08. moa_score_proposal: score updated
//    T09. moa_new_round: starts with 0 proposals
//    T10. moa_round_add_proposal: increments count
//    T11. moa_round_add_proposal: second proposal counted
//    T12. moa_round_set_aggregate: stores text
//    T13. moa_round_best: returns highest-scored proposal
//    T14. moa_round_scores: returns score array
//    T15. moa_new_session: status = "pending"
//    T16. moa_new_session: query stored
//    T17. moa_session_add_round: round count grows
//    T18. moa_session_add_round: status = "running"
//    T19. moa_session_set_answer: stores answer
//    T20. moa_session_set_answer: status = "done"
//    T21. moa_propose: returns N proposals
//    T22. moa_propose: source tags correct
//    T23. moa_score_all: scores applied
//    T24. moa_aggregate_best: picks highest-scored text
//    T25. moa_aggregate_concat: joins all texts
//    T26. moa_aggregate_weighted: picks highest weight text
//    T27. moa_aggregate dispatch: "best" strategy
//    T28. moa_diversity_scores: identical texts => low diversity
//    T29. moa_diversity_scores: different texts => higher diversity
//    T30. moa_apply_diversity_bonus: scores increase
//    T31. moa_top_k: returns k items sorted by score
//    T32. moa_avg_score: correct average
//    T33. moa_run: full multi-round session completes
//    T34. moa_run: session has correct round count
//    T35. moa_session_stats: total_proposals correct
//
//  Run: cargo run --release -- self/test_mixture_of_agents.hexa
// ===================================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx(a, b, eps) { return fabs(a - b) < eps }

// ═══════════ mixture_of_agents.hexa inlined ═══════════════════════

fn _moa_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn _moa_max_f(a, b) {
    if a > b { return a }
    return b
}

fn _moa_min_f(a, b) {
    if a < b { return a }
    return b
}

fn _moa_sqrt(x) {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    let mut _i = 0

    while _i < 20 {
        g = (g + x / g) / 2.0
    }
    return g
}

fn _moa_zeros(n) {
    let mut v = []
    let mut _i = 0

    while _i < n { v = v + [0.0] }
    return v
}

fn _moa_hash(seed, i) {
    let h = ((seed * 2654435761 + i * 1315423911 + 7919) % 100003)
    if h < 0 { return 0 - h }
    return h
}

fn _moa_token_overlap(a, b) {
    let ta = a.split(" ")
    let tb = b.split(" ")
    let na = len(ta)
    let nb = len(tb)
    if na == 0 { return 0.0 }
    if nb == 0 { return 0.0 }
    let set_b = #{}
    let mut i = 0

    while i < nb {
        set_b[tb[i]] = true
    }
    let mut shared = 0
    let mut i = 0

    while i < na {
        if has_key(set_b, ta[i]) {
            shared = shared + 1
        }
    }
    let union_size = na + nb - shared
    if union_size == 0 { return 0.0 }
    return to_float(shared) / to_float(union_size)
}

fn moa_default_config() {
    let cfg = #{}
    cfg["num_proposers"] = 3
    cfg["num_rounds"] = 2
    cfg["aggregation_strategy"] = "best"
    cfg["diversity_weight"] = 0.1
    cfg["temperature"] = 0.7
    cfg["top_k"] = 3
    return cfg
}

fn moa_config(num_proposers, num_rounds, strategy) {
    let cfg = moa_default_config()
    cfg["num_proposers"] = num_proposers
    cfg["num_rounds"] = num_rounds
    cfg["aggregation_strategy"] = strategy
    return cfg
}

fn moa_config_set(cfg, key, val) {
    cfg[key] = val
    return cfg
}

fn moa_config_get(cfg, key) {
    return cfg[key]
}

fn moa_new_proposal(id, text, source, round) {
    let p = #{}
    p["id"] = id
    p["text"] = text
    p["source"] = source
    p["score"] = 0.0
    p["round"] = round
    return p
}

fn moa_score_proposal(proposal, score) {
    proposal["score"] = score
    return proposal
}

fn moa_proposal_text(p) { return p["text"] }
fn moa_proposal_score(p) { return p["score"] }
fn moa_proposal_source(p) { return p["source"] }
fn moa_proposal_id(p) { return p["id"] }

fn moa_new_round(round_idx) {
    let r = #{}
    r["round_idx"] = round_idx
    r["proposals"] = []
    r["aggregate"] = ""
    r["scores"] = []
    r["n_proposals"] = 0
    return r
}

fn moa_round_add_proposal(round, proposal) {
    let mut props = round["proposals"]
    props = props + [proposal]
    round["proposals"] = props
    round["n_proposals"] = len(props)
    let mut scores = round["scores"]
    scores = scores + [proposal["score"]]
    round["scores"] = scores
    return round
}

fn moa_round_set_aggregate(round, text) {
    round["aggregate"] = text
    return round
}

fn moa_round_num_proposals(round) {
    return round["n_proposals"]
}

fn moa_round_get_aggregate(round) {
    return round["aggregate"]
}

fn moa_round_scores(round) {
    let props = round["proposals"]
    let n = len(props)
    let mut out = _moa_zeros(n)
    let mut i = 0

    while i < n {
        out[i] = props[i]["score"]
    }
    return out
}

fn moa_round_best(round) {
    let props = round["proposals"]
    let n = len(props)
    if n == 0 {
        return moa_new_proposal(0, "", "none", 0)
    }
    let mut best_idx = 0
    let mut best_score = props[0]["score"]
    let mut i = 1
    while i < n {
        if props[i]["score"] > best_score {
            best_score = props[i]["score"]
            best_idx = i
        }
        i = i + 1
    }
    return props[best_idx]
}

fn moa_new_session(query, config) {
    let s = #{}
    s["query"] = query
    s["rounds"] = []
    s["config"] = config
    s["final_answer"] = ""
    s["status"] = "pending"
    s["n_rounds"] = 0
    return s
}

fn moa_session_add_round(session, round) {
    let mut rounds = session["rounds"]
    rounds = rounds + [round]
    session["rounds"] = rounds
    session["n_rounds"] = len(rounds)
    session["status"] = "running"
    return session
}

fn moa_session_set_answer(session, answer) {
    session["final_answer"] = answer
    session["status"] = "done"
    return session
}

fn moa_session_query(session) { return session["query"] }
fn moa_session_status(session) { return session["status"] }
fn moa_session_answer(session) { return session["final_answer"] }
fn moa_session_num_rounds(session) { return session["n_rounds"] }

fn moa_session_last_round(session) {
    let rounds = session["rounds"]
    let n = len(rounds)
    if n == 0 { return moa_new_round(0) }
    return rounds[n - 1]
}

fn moa_propose(query, context, proposer_fns, round_idx) {
    let n = len(proposer_fns)
    let mut proposals = []
    let mut i = 0

    while i < n {
        let pfn = proposer_fns[i]
        let text = pfn(query, context)
        let p = moa_new_proposal(i, text, "proposer_" + to_string(i), round_idx)
        proposals = proposals + [p]
    }
    return proposals
}

fn moa_score_all(proposals, scorer_fn, query) {
    let n = len(proposals)
    let mut scored = []
    let mut i = 0

    while i < n {
        let s = scorer_fn(query, proposals[i]["text"])
        let mut p = proposals[i]
        p["score"] = s
        scored = scored + [p]
    }
    return scored
}

fn moa_diversity_scores(proposals) {
    let n = len(proposals)
    let mut divs = _moa_zeros(n)
    if n <= 1 { return divs }
    let mut i = 0

    while i < n {
        let mut total_dissim = 0.0
        let mut count = 0
        let mut j = 0

        while j < n {
            if i != j {
                let overlap = _moa_token_overlap(proposals[i]["text"],
                                                  proposals[j]["text"])
                total_dissim = total_dissim + (1.0 - overlap)
                count = count + 1
            }
        }
        if count > 0 {
            divs[i] = total_dissim / to_float(count)
        }
    }
    return divs
}

fn moa_apply_diversity_bonus(proposals, diversity_weight) {
    let divs = moa_diversity_scores(proposals)
    let n = len(proposals)
    let mut out = []
    let mut i = 0

    while i < n {
        let mut p = proposals[i]
        p["score"] = p["score"] + diversity_weight * divs[i]
        out = out + [p]
    }
    return out
}

fn moa_aggregate_best(proposals) {
    let n = len(proposals)
    if n == 0 { return "" }
    let mut best_idx = 0
    let mut best_score = proposals[0]["score"]
    let mut i = 1
    while i < n {
        if proposals[i]["score"] > best_score {
            best_score = proposals[i]["score"]
            best_idx = i
        }
        i = i + 1
    }
    return proposals[best_idx]["text"]
}

fn moa_aggregate_concat(proposals) {
    let n = len(proposals)
    let mut parts = []
    let mut i = 0

    while i < n {
        parts = parts + [proposals[i]["text"]]
    }
    return parts.join(" | ")
}

fn moa_aggregate_weighted(proposals) {
    let n = len(proposals)
    if n == 0 { return "" }
    let mut total_score = 0.0
    let mut i = 0

    while i < n {
        total_score = total_score + _moa_max_f(proposals[i]["score"], 0.0)
    }
    if total_score <= 0.0 { return moa_aggregate_best(proposals) }
    let mut best_idx = 0
    let mut best_w = 0.0
    let mut i = 0

    while i < n {
        let w = _moa_max_f(proposals[i]["score"], 0.0) / total_score
        if w > best_w {
            best_w = w
            best_idx = i
        }
    }
    return proposals[best_idx]["text"]
}

fn moa_aggregate_rank_merge(proposals, top_k) {
    let n = len(proposals)
    if n == 0 { return "" }
    let mut indices = []
    let mut i = 0

    while i < n { indices = indices + [i] }
    let mut i = 0

    while i < n {
        let mut max_j = i
        let mut j = i + 1
        while j < n {
            if proposals[indices[j]]["score"] > proposals[indices[max_j]]["score"] {
                max_j = j
            }
            j = j + 1
        }
        if max_j != i {
            let tmp = indices[i]
            indices[i] = indices[max_j]
            indices[max_j] = tmp
        }
    }
    let k = _moa_min_f(to_float(top_k), to_float(n))
    let ki = to_int(k)
    let mut parts = []
    let mut i = 0

    while i < ki {
        parts = parts + [proposals[indices[i]]["text"]]
    }
    return parts.join(" | ")
}

fn moa_aggregate(proposals, strategy) {
    if strategy == "best" { return moa_aggregate_best(proposals) }
    if strategy == "concat" { return moa_aggregate_concat(proposals) }
    if strategy == "weighted" { return moa_aggregate_weighted(proposals) }
    if strategy == "rank_merge" { return moa_aggregate_rank_merge(proposals, 3) }
    return moa_aggregate_best(proposals)
}

fn moa_top_k(proposals, k) {
    let n = len(proposals)
    let mut indices = []
    let mut i = 0

    while i < n { indices = indices + [i] }
    let mut i = 0

    while i < n {
        let mut max_j = i
        let mut j = i + 1
        while j < n {
            if proposals[indices[j]]["score"] > proposals[indices[max_j]]["score"] {
                max_j = j
            }
            j = j + 1
        }
        if max_j != i {
            let tmp = indices[i]
            indices[i] = indices[max_j]
            indices[max_j] = tmp
        }
    }
    let limit = to_int(_moa_min_f(to_float(k), to_float(n)))
    let mut out = []
    let mut i = 0

    while i < limit {
        out = out + [proposals[indices[i]]]
    }
    return out
}

fn moa_avg_score(proposals) {
    let n = len(proposals)
    if n == 0 { return 0.0 }
    let mut total = 0.0
    let mut i = 0

    while i < n {
        total = total + proposals[i]["score"]
    }
    return total / to_float(n)
}

fn moa_max_score(proposals) {
    let n = len(proposals)
    if n == 0 { return 0.0 }
    let mut mx = proposals[0]["score"]
    let mut i = 1

    while i < n {
        if proposals[i]["score"] > mx {
            mx = proposals[i]["score"]
        }
    }
    return mx
}

fn moa_score_variance(proposals) {
    let n = len(proposals)
    if n <= 1 { return 0.0 }
    let avg = moa_avg_score(proposals)
    let mut ss = 0.0
    let mut i = 0

    while i < n {
        let d = proposals[i]["score"] - avg
        ss = ss + d * d
    }
    return ss / to_float(n)
}

fn moa_run_round(query, context, proposer_fns, scorer_fn, strategy,
                 round_idx, diversity_weight) {
    let mut proposals = moa_propose(query, context, proposer_fns, round_idx)
    proposals = moa_score_all(proposals, scorer_fn, query)
    if diversity_weight > 0.0 {
        proposals = moa_apply_diversity_bonus(proposals, diversity_weight)
    }
    let mut round = moa_new_round(round_idx)
    let np = len(proposals)
    let mut i = 0

    while i < np {
        round = moa_round_add_proposal(round, proposals[i])
    }
    let agg_text = moa_aggregate(proposals, strategy)
    round = moa_round_set_aggregate(round, agg_text)
    return round
}

fn moa_run(query, proposer_fns, scorer_fn, config) {
    let num_rounds = config["num_rounds"]
    let strategy = config["aggregation_strategy"]
    let diversity_weight = config["diversity_weight"]
    let mut session = moa_new_session(query, config)
    let mut context = ""
    let mut r = 0
    while r < num_rounds {
        let round = moa_run_round(query, context, proposer_fns, scorer_fn,
                                  strategy, r, diversity_weight)
        session = moa_session_add_round(session, round)
        context = moa_round_get_aggregate(round)
        r = r + 1
    }
    session = moa_session_set_answer(session, context)
    return session
}

fn moa_session_summary(session) {
    let mut out = "Query: " + session["query"] + "\n"
    let rounds = session["rounds"]
    let n = len(rounds)
    let mut i = 0

    while i < n {
        let r = rounds[i]
        out = out + "--- Round " + to_string(r["round_idx"]) + " ---\n"
        let props = r["proposals"]
        let np = len(props)
        let mut j = 0

        while j < np {
            let p = props[j]
            out = out + "  [" + p["source"] + "] score="
            out = out + to_string(p["score"]) + ": " + p["text"] + "\n"
        }
        out = out + "  Aggregate: " + r["aggregate"] + "\n"
    }
    out = out + "Final: " + session["final_answer"] + "\n"
    out = out + "Status: " + session["status"] + "\n"
    return out
}

fn moa_session_stats(session) {
    let stats = #{}
    stats["n_rounds"] = session["n_rounds"]
    stats["status"] = session["status"]
    stats["has_answer"] = len(session["final_answer"]) > 0
    let rounds = session["rounds"]
    let nr = len(rounds)
    let mut total_proposals = 0
    let mut total_score = 0.0
    let mut best_score = 0.0
    let mut i = 0

    while i < nr {
        let props = rounds[i]["proposals"]
        let np = len(props)
        total_proposals = total_proposals + np
        let mut j = 0

        while j < np {
            let s = props[j]["score"]
            total_score = total_score + s
            if s > best_score { best_score = s }
        }
    }
    stats["total_proposals"] = total_proposals
    stats["best_score"] = best_score
    if total_proposals > 0 {
        stats["avg_score"] = total_score / to_float(total_proposals)
    } else {
        stats["avg_score"] = 0.0
    }
    return stats
}

