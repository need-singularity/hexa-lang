// ── Mock proposer functions ────────────────────────────────────────

fn proposer_alpha(query, context) {
    return "Alpha says the answer is 42"
}

fn proposer_beta(query, context) {
    return "Beta believes the result is approximately 40"
}

fn proposer_gamma(query, context) {
    return "Gamma computes a completely different perspective on X"
}

// ── Mock scorer ────────────────────────────────────────────────────

fn mock_scorer(query, text) {
    // Score by text length (simple deterministic scorer)
    return to_float(len(text))
}

fn biased_scorer(query, text) {
    // Always scores "Alpha" highest
    if text.contains("Alpha") { return 9.0 }
    if text.contains("Beta") { return 5.0 }
    return 3.0
}

