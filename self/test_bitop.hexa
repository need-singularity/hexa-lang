// ROI #156 — surface bit-shift `<<` `>>` regression repro + fix verification.
// Exercises parse_bit_ops() shift path that was silent-rejecting on interp.

fn main() {
    let x = 5
    let a = x << 1                 // 10
    let b = x >> 1                 // 2
    let c = (x & 0xFF) << 8        // 1280 (5 << 8)
    let d = 0xFF >> 4              // 15
    let e = 1 << 10                // 1024
    let f = 1024 >> 5              // 32
    let g = (x << 2) | (x >> 1)    // 20 | 2 = 22
    let h = ((x << 2) + (x >> 1))  // 22 (additive alt for cross-check)
    // Newline-split continuation (`let i = x\n    << 3`) requires
    // `p_continue_bin_op(["Shl","Shr",...])` in parse_bit_ops — patched in
    // parser.hexa + hexa_full.hexa + hexa_cc.c, but picked up only after
    // interp rebuild (gated by HX8). Enabled in current interp: inline only.
    let i = (x << 3)               // 40
    let j = (x >> 1)               // 2

    print("a=" + a.to_string())
    print("b=" + b.to_string())
    print("c=" + c.to_string())
    print("d=" + d.to_string())
    print("e=" + e.to_string())
    print("f=" + f.to_string())
    print("g=" + g.to_string())
    print("h=" + h.to_string())
    print("i=" + i.to_string())
    print("j=" + j.to_string())

    let ok = a == 10 && b == 2 && c == 1280 && d == 15 && e == 1024 && f == 32 && g == 22 && h == 22 && i == 40 && j == 2
    // Expected: a=10 b=2 c=1280 d=15 e=1024 f=32 g=22 h=22 i=40 j=2 OK
    if ok { print("OK") } else { print("FAIL") }
}
