// self/error.hexa — HEXA ERROR ported from src/error.rs
// Error types, diagnostics, and name suggestion (Levenshtein).

// ── sopfr(6) = 5 error classes ──────────────────────────

let ERR_SYNTAX  = "Syntax"    // 1: Lex/parse errors
let ERR_TYPE    = "Type"      // 2: Type mismatch
let ERR_NAME    = "Name"      // 3: Undefined name
let ERR_RUNTIME = "Runtime"   // 4: Runtime errors
let ERR_LOGIC   = "Logic"     // 5: Proof/assert failure

// ── Error struct ────────────────────────────────────────

struct HexaError {
    class: string,
    message: string,
    line: int,
    col: int,
    hint: string       // "" means no hint
}

fn hexa_error(class: string, message: string, line: int, col: int) -> HexaError {
    return HexaError { class: class, message: message, line: line, col: col, hint: "" }
}

fn hexa_error_with_hint(class: string, message: string, line: int, col: int, hint: string) -> HexaError {
    return HexaError { class: class, message: message, line: line, col: col, hint: hint }
}

fn hexa_error_display(err: HexaError) -> string {
    let result = ""
    if err.line > 0 {
        result = "[" + err.class + "] line " + to_string(err.line) + ":" + to_string(err.col) + ": " + err.message
    } else {
        result = "[" + err.class + "] " + err.message
    }
    if err.hint != "" {
        result = result + "\n  = help: " + err.hint
    }
    return result
}

// ── Diagnostic formatter ────────────────────────────────

struct Diagnostic {
    error: HexaError,
    source_lines: [string],
    file_name: string
}

fn diagnostic_format(diag: Diagnostic) -> string {
    let out = "error[" + diag.error.class + "]: " + diag.error.message + "\n"

    if diag.error.line > 0 {
        if len(diag.source_lines) > 0 {
            let line_idx = diag.error.line - 1
            if line_idx < len(diag.source_lines) {
                let source_line = diag.source_lines[line_idx]
                let line_num = diag.error.line
                let line_str = to_string(line_num)
                let width = len(line_str)

                // Location arrow
                out = out + " --> " + diag.file_name + ":" + to_string(line_num) + ":" + to_string(diag.error.col) + "\n"
                // Blank pipe
                out = out + "  |\n"
                // Source line
                out = out + to_string(line_num) + " | " + source_line + "\n"
                // Underline caret
                let col = diag.error.col - 1
                if col < 0 { col = 0 }
                let underline_len = estimate_span_len(source_line, col)
                if underline_len < 1 { underline_len = 1 }
                let spaces = ""
                let i = 0
                while i < col {
                    spaces = spaces + " "
                    i = i + 1
                }
                let carets = ""
                i = 0
                while i < underline_len {
                    carets = carets + "^"
                    i = i + 1
                }
                out = out + "  | " + spaces + carets + "\n"
            }
        }
    }

    if diag.error.hint != "" {
        out = out + "  = help: " + diag.error.hint + "\n"
    }

    return out
}

// ── Span length estimation ──────────────────────────────

fn estimate_span_len(line: string, col: int) -> int {
    if col >= len(line) {
        return 1
    }
    let ch = line[col]
    // String literal: find matching quote
    if ch == "\"" {
        let i = col + 1
        while i < len(line) {
            if line[i] == "\"" {
                return i - col + 1
            }
            i = i + 1
        }
        return len(line) - col
    }
    // Alphanumeric token
    if is_alphanumeric(ch) {
        let i = col
        while i < len(line) {
            if !is_alphanumeric(line[i]) {
                break
            }
            i = i + 1
        }
        return i - col
    }
    return 1
}

// ── Levenshtein edit distance ───────────────────────────

fn levenshtein(a: string, b: string) -> int {
    let m = len(a)
    let n = len(b)
    // Build (m+1) x (n+1) matrix using flat array
    let dp = []
    let i = 0
    while i <= m {
        let j = 0
        while j <= n {
            if i == 0 {
                dp = dp + [j]
            } else if j == 0 {
                dp = dp + [i]
            } else {
                dp = dp + [0]
            }
            j = j + 1
        }
        i = i + 1
    }

    i = 1
    while i <= m {
        let j = 1
        while j <= n {
            let cost = 1
            if a[i - 1] == b[j - 1] {
                cost = 0
            }
            let del = dp[(i - 1) * (n + 1) + j] + 1
            let ins = dp[i * (n + 1) + (j - 1)] + 1
            let sub = dp[(i - 1) * (n + 1) + (j - 1)] + cost
            let best = del
            if ins < best { best = ins }
            if sub < best { best = sub }
            dp[i * (n + 1) + j] = best
            j = j + 1
        }
        i = i + 1
    }

    return dp[m * (n + 1) + n]
}

// ── Name suggestion ─────────────────────────────────────

fn suggest_name(unknown: string, known: [string]) -> string {
    // Returns closest name with edit distance <= 2, or "" if none found.
    let best_name = ""
    let best_dist = 3  // threshold: must be <= 2

    let i = 0
    while i < len(known) {
        let dist = levenshtein(unknown, known[i])
        if dist > 0 {
            if dist < best_dist {
                best_dist = dist
                best_name = known[i]
            }
        }
        i = i + 1
    }

    return best_name
}
