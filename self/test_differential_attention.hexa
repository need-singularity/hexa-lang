// ===================================================================
//  test_differential_attention.hexa — Differential Attention tests
//
//  Covers:
//    T01  Config creation and field values
//    T02  Weights init: w_q dimension
//    T03  Weights init: w_k dimension
//    T04  Weights init: w_v dimension (half_dim per head)
//    T05  Weights init: w_o dimension
//    T06  Weights init: lambda arrays length = n_heads
//    T07  Weights init: group norm gamma length = half_dim
//    T08  Effective lambda near lambda_init at initialization
//    T09  Softmax sums to 1.0
//    T10  Softmax max element gets highest weight
//    T11  Group norm output has zero mean (beta=0)
//    T12  Group norm output has unit variance (gamma=1, beta=0)
//    T13  Forward output dimension = d_model
//    T14  Forward output non-zero
//    T15  Cache seq_len advances after forward
//    T16  Cache stores correct K vectors
//    T17  Dual softmax: A1 sums to 1, A2 sums to 1
//    T18  Differential cancellation: A1 - lambda*A2 sums to ~(1-lambda)
//    T19  Noise suppression with uniform keys
//    T20  Different positions produce different outputs
//    T21  Deterministic: same input, same output
//    T22  Prefill output count matches input count
//    T23  Prefill output dimensions correct
//    T24  Prefill cache seq_len matches input length
//    T25  Multi-token context changes output vs single token
//    T26  Lambda stats: min <= mean <= max
//    T27  Noise ratio with lambda=1 is 0 (full cancel)
//    T28  Noise ratio with lambda=0 is 1 (no cancel)
//    T29  L2 loss positive for non-zero input
//    T30  da_slice extracts correct sub-array
//
//  Run: ./hexa self/test_differential_attention.hexa
// ===================================================================

// -- inlined from self/ml/differential_attention.hexa --
// codegen import not wired for test files

// ===================================================================
//  self/ml/differential_attention.hexa — Differential Attention
//
//  Microsoft Research "Differential Transformer" (2024):
//  Cancels attention noise by computing the *difference* of two
//  softmax distributions — one captures signal, the other captures
//  the noise floor. The residual is a cleaner attention map.
//
//  Core formula (per head pair h):
//    Q -> [Q1, Q2]  via split along head_dim
//    K -> [K1, K2]  via split along head_dim
//    A1 = softmax(Q1 * K1^T / sqrt(d/2))
//    A2 = softmax(Q2 * K2^T / sqrt(d/2))
//    A_diff = A1 - lambda * A2       (noise cancellation)
//    head_out = GroupNorm( A_diff * V )
//    output = concat(all heads) * W_o
//
//  Lambda is a learnable scalar per head pair, initialized ~0.5 via
//    lambda = exp(lambda1) - exp(lambda2) + lambda_init
//  so that the init is near 0.5 and gradient flows through exp().
//
//  Architecture:
//    DiffAttnConfig     — hyperparams (d_model, n_heads, head_dim)
//    DiffAttnWeights    — W_q, W_k, W_v, W_o, lambda params, group norm
//    diff_attn_forward  — full multi-head differential attention pass
//
//  Reference: Ye et al., "Differential Transformer" (2024),
//             arXiv:2410.05258
//
//  AI-NATIVE attrs:
//    @pure     — no side effects in math helpers
//    @hot      — called every forward step
//    @parallel — head loop independent
// ===================================================================

// ── Config struct ────────────────────────────────────────────────
struct DiffAttnConfig {
    d_model: int,
    n_heads: int,
    head_dim: int,
    lambda_init: float,
    group_norm_eps: float
}

// ── Weight struct ────────────────────────────────────────────────
// W_q, W_k, W_v: [n_heads * head_dim, d_model]  (stored as 2D)
// W_o:           [d_model, n_heads * (head_dim / 2)]
// lambda1, lambda2: [n_heads] each  (scalar per head pair)
// gn_gamma, gn_beta: [head_dim / 2] group norm affine per sub-head
struct DiffAttnWeights {
    w_q: array,
    w_k: array,
    w_v: array,
    w_o: array,
    lambda1: array,
    lambda2: array,
    gn_gamma: array,
    gn_beta: array
}

// ===================================================================
//  Helpers (prefixed da_ to avoid collision)
// ===================================================================

fn da_zeros(n) {
    let mut v = []
    for _i in 0..n {
        v = v + [0.0]
    }
    return v
}

fn da_zeros_2d(r, c) {
    let mut m = []
    for _i in 0..r {
        let mut row = []
        for _j in 0..c {
            row = row + [0.0]
        }
        m = m + [row]
    }
    return m
}

fn da_fabs(x) {
    if x < 0.0 {
        return 0.0 - x
    }
    return x
}

fn da_max_f(a, b) {
    if a > b {
        return a
    }
    return b
}

// Deterministic PRNG (LCG) for weight init
let mut _da_rng_state = 77777

fn da_rand_f() {
    _da_rng_state = (_da_rng_state * 1664525 + 1013904223) % 2147483648
    return to_float(_da_rng_state) / 2147483648.0 - 0.5
}

fn da_rand_seed(s) {
    _da_rng_state = s
}

// ===================================================================
//  Matrix-vector multiply: W [rows, cols] * vec [cols] -> y [rows]
// ===================================================================
@hot
fn da_matvec(W, vec, rows, cols) {
    let mut out = []
    let mut i = 0
    while i < rows {
        let mut dot = 0.0
        let mut j = 0
        while j < cols {
            dot = dot + W[i][j] * vec[j]
            j = j + 1
        }
        out = out + [dot]
        i = i + 1
    }
    return out
}

// ===================================================================
//  Dot product of two arrays (equal length)
// ===================================================================
@pure
fn da_dot(a, b, n) {
    let mut s = 0.0
    let mut i = 0
    while i < n {
        s = s + a[i] * b[i]
        i = i + 1
    }
    return s
}

// ===================================================================
//  Softmax over 1D array of length n
// ===================================================================
@pure
fn da_softmax(scores, n) {
    let mut mx = scores[0]
    let mut i = 1
    while i < n {
        if scores[i] > mx {
            mx = scores[i]
        }
        i = i + 1
    }
    let mut exps = []
    let mut sum_e = 0.0
    i = 0
    while i < n {
        let e = exp(scores[i] - mx)
        exps = exps + [e]
        sum_e = sum_e + e
        i = i + 1
    }
    let inv = 1.0 / sum_e
    let mut result = []
    i = 0
    while i < n {
        result = result + [exps[i] * inv]
        i = i + 1
    }
    return result
}

// ===================================================================
//  Group normalization on a 1D vector of length n
//  gn(x) = gamma * (x - mean) / sqrt(var + eps) + beta
// ===================================================================
@pure
fn da_group_norm(x, gamma, beta, n, eps) {
    // Compute mean
    let mut sum_v = 0.0
    let mut i = 0
    while i < n {
        sum_v = sum_v + x[i]
        i = i + 1
    }
    let mean_v = sum_v / to_float(n)

    // Compute variance
    let mut var_v = 0.0
    i = 0
    while i < n {
        let diff = x[i] - mean_v
        var_v = var_v + diff * diff
        i = i + 1
    }
    var_v = var_v / to_float(n)

    let inv_std = 1.0 / sqrt(var_v + eps)

    let mut out = []
    i = 0
    while i < n {
        out = out + [gamma[i] * (x[i] - mean_v) * inv_std + beta[i]]
        i = i + 1
    }
    return out
}

// ===================================================================
//  Random matrix init (Kaiming-like scale)
// ===================================================================
fn da_rand_matrix(rows, cols) {
    let scale = sqrt(2.0 / to_float(cols))
    let mut M = []
    let mut i = 0
    while i < rows {
        let mut row = []
        let mut j = 0
        while j < cols {
            row = row + [da_rand_f() * scale]
            j = j + 1
        }
        M = M + [row]
        i = i + 1
    }
    return M
}

// ===================================================================
//  Create default DiffAttn config
//  head_dim must be even (split into two halves for Q1/Q2, K1/K2)
// ===================================================================
fn diff_attn_config_new(d_model, n_heads, head_dim) {
    return DiffAttnConfig {
        d_model: d_model,
        n_heads: n_heads,
        head_dim: head_dim,
        lambda_init: 0.8,
        group_norm_eps: 1.0e-5
    }
}

// ===================================================================
//  Initialize random DiffAttn weights
//  lambda1, lambda2 init: small values so exp(l1)-exp(l2)+init ~ init
// ===================================================================
fn diff_attn_weights_init(cfg: DiffAttnConfig) {
    let total_qk = cfg.n_heads * cfg.head_dim
    let half_dim = cfg.head_dim / 2
    let total_v = cfg.n_heads * half_dim

    // lambda1, lambda2 initialized near 0 so effective lambda ~ lambda_init
    let mut l1 = []
    let mut l2 = []
    for _h in 0..cfg.n_heads {
        l1 = l1 + [0.1 * da_rand_f()]
        l2 = l2 + [0.1 * da_rand_f()]
    }

    // Group norm: gamma=1, beta=0
    let mut gn_g = []
    let mut gn_b = []
    for _i in 0..half_dim {
        gn_g = gn_g + [1.0]
        gn_b = gn_b + [0.0]
    }

    return DiffAttnWeights {
        w_q: da_rand_matrix(total_qk, cfg.d_model),
        w_k: da_rand_matrix(total_qk, cfg.d_model),
        w_v: da_rand_matrix(total_v, cfg.d_model),
        w_o: da_rand_matrix(cfg.d_model, total_v),
        lambda1: l1,
        lambda2: l2,
        gn_gamma: gn_g,
        gn_beta: gn_b
    }
}

// ===================================================================
//  Compute effective lambda for head h:
//    lambda_h = exp(lambda1[h]) - exp(lambda2[h]) + lambda_init
//  This ensures gradient flows through exp and init is ~lambda_init.
// ===================================================================
@pure
fn diff_attn_lambda(weights: DiffAttnWeights, h, lambda_init) {
    return exp(weights.lambda1[h]) - exp(weights.lambda2[h]) + lambda_init
}

// ===================================================================
//  Slice helper: extract sub-array a[start..start+len]
// ===================================================================
fn da_slice(a, start, length) {
    let mut out = []
    let mut i = 0
    while i < length {
        out = out + [a[start + i]]
        i = i + 1
    }
    return out
}

// ===================================================================
//  Single-head differential attention scores
//
//  Given Q [head_dim], K_cache [ctx_len][head_dim], V_cache [ctx_len][half_dim]:
//    Split Q -> Q1 [half], Q2 [half]
//    For each cached K_t [head_dim]: split -> K1_t [half], K2_t [half]
//    A1 = softmax( [Q1 . K1_t / scale] for t )
//    A2 = softmax( [Q2 . K2_t / scale] for t )
//    A_diff = A1 - lambda * A2
//    out = A_diff * V -> [half_dim]
//
//  Returns: attention output [half_dim]
// ===================================================================
@hot
fn diff_attn_head(q_vec, k_cache, v_cache, ctx_len, half_dim, lambda_val) {
    let scale = 1.0 / sqrt(to_float(half_dim))

    // Split Q into Q1, Q2
    let q1 = da_slice(q_vec, 0, half_dim)
    let q2 = da_slice(q_vec, half_dim, half_dim)

    // Compute scores for A1 (Q1*K1) and A2 (Q2*K2)
    let mut scores1 = []
    let mut scores2 = []
    let mut t = 0
    while t < ctx_len {
        let k_t = k_cache[t]
        // K1 = first half, K2 = second half
        let mut dot1 = 0.0
        let mut dot2 = 0.0
        let mut d = 0
        while d < half_dim {
            dot1 = dot1 + q1[d] * k_t[d]
            dot2 = dot2 + q2[d] * k_t[half_dim + d]
            d = d + 1
        }
        scores1 = scores1 + [dot1 * scale]
        scores2 = scores2 + [dot2 * scale]
        t = t + 1
    }

    // Two softmax distributions
    let a1 = da_softmax(scores1, ctx_len)
    let a2 = da_softmax(scores2, ctx_len)

    // Differential: A_diff = A1 - lambda * A2
    let mut a_diff = []
    t = 0
    while t < ctx_len {
        a_diff = a_diff + [a1[t] - lambda_val * a2[t]]
        t = t + 1
    }

    // Weighted sum over V: out[d] = sum_t a_diff[t] * V_cache[t][d]
    let mut out = []
    let mut d = 0
    while d < half_dim {
        let mut acc = 0.0
        t = 0
        while t < ctx_len {
            acc = acc + a_diff[t] * v_cache[t][d]
            t = t + 1
        }
        out = out + [acc]
        d = d + 1
    }
    return out
}

// ===================================================================
//  Compute raw differential attention scores (A1 - lambda * A2)
//  Exposed for testing/analysis. Returns array [ctx_len].
// ===================================================================
fn diff_attn_scores(q_vec, k_cache, ctx_len, half_dim, lambda_val) {
    let scale = 1.0 / sqrt(to_float(half_dim))
    let q1 = da_slice(q_vec, 0, half_dim)
    let q2 = da_slice(q_vec, half_dim, half_dim)

    let mut scores1 = []
    let mut scores2 = []
    let mut t = 0
    while t < ctx_len {
        let k_t = k_cache[t]
        let mut dot1 = 0.0
        let mut dot2 = 0.0
        let mut d = 0
        while d < half_dim {
            dot1 = dot1 + q1[d] * k_t[d]
            dot2 = dot2 + q2[d] * k_t[half_dim + d]
            d = d + 1
        }
        scores1 = scores1 + [dot1 * scale]
        scores2 = scores2 + [dot2 * scale]
        t = t + 1
    }

    let a1 = da_softmax(scores1, ctx_len)
    let a2 = da_softmax(scores2, ctx_len)

    let mut a_diff = []
    t = 0
    while t < ctx_len {
        a_diff = a_diff + [a1[t] - lambda_val * a2[t]]
        t = t + 1
    }
    return a_diff
}

// ===================================================================
//  KV cache: stores per-position K [head_dim] and V [half_dim] per head
//  Layout: k_cache[head][pos] = array [head_dim]
//          v_cache[head][pos] = array [half_dim]
// ===================================================================
struct DiffAttnCache {
    k_data: array,
    v_data: array,
    seq_len: int,
    max_len: int,
    n_heads: int
}

fn diff_attn_cache_new(max_len, n_heads) {
    let mut kd = []
    let mut vd = []
    for _h in 0..n_heads {
        let mut kh = []
        let mut vh = []
        for _p in 0..max_len {
            kh = kh + [[]]
            vh = vh + [[]]
        }
        kd = kd + [kh]
        vd = vd + [vh]
    }
    return DiffAttnCache {
        k_data: kd,
        v_data: vd,
        seq_len: 0,
        max_len: max_len,
        n_heads: n_heads
    }
}

// ===================================================================
//  Cache append: write K,V for all heads at position pos
//  k_heads: [n_heads][head_dim], v_heads: [n_heads][half_dim]
//
//  Note: complex index assignment (a[i][j]=v) not supported in hexa,
//  so we rebuild the affected rows.
// ===================================================================
fn diff_attn_cache_write(cache: DiffAttnCache, pos, k_heads, v_heads) {
    let n_heads = cache.n_heads
    let max_len = cache.max_len

    let mut new_kd = []
    let mut new_vd = []
    let mut h = 0
    while h < n_heads {
        // rebuild k_data[h]: replace row at pos
        let mut new_kh = []
        let mut p = 0
        while p < max_len {
            if p == pos {
                new_kh = new_kh + [k_heads[h]]
            } else {
                new_kh = new_kh + [cache.k_data[h][p]]
            }
            p = p + 1
        }
        new_kd = new_kd + [new_kh]

        // rebuild v_data[h]: replace row at pos
        let mut new_vh = []
        p = 0
        while p < max_len {
            if p == pos {
                new_vh = new_vh + [v_heads[h]]
            } else {
                new_vh = new_vh + [cache.v_data[h][p]]
            }
            p = p + 1
        }
        new_vd = new_vd + [new_vh]
        h = h + 1
    }

    let mut new_seq = cache.seq_len
    if pos + 1 > new_seq {
        new_seq = pos + 1
    }

    return DiffAttnCache {
        k_data: new_kd,
        v_data: new_vd,
        seq_len: new_seq,
        max_len: max_len,
        n_heads: n_heads
    }
}

// ===================================================================
//  Full Differential Attention forward pass (single token at pos)
//
//  x:       input [d_model]
//  pos:     sequence position
//  cache:   DiffAttnCache
//  weights: DiffAttnWeights
//  cfg:     DiffAttnConfig
//
//  Returns: [output [d_model], updated_cache]
// ===================================================================
@hot @parallel
fn diff_attn_forward(x, pos, cache: DiffAttnCache, weights: DiffAttnWeights, cfg: DiffAttnConfig) {
    let n_heads = cfg.n_heads
    let head_dim = cfg.head_dim
    let half_dim = head_dim / 2
    let d_model = cfg.d_model
    let total_qk = n_heads * head_dim
    let total_v = n_heads * half_dim

    // -- Q, K, V projections --
    let q_flat = da_matvec(weights.w_q, x, total_qk, d_model)
    let k_flat = da_matvec(weights.w_k, x, total_qk, d_model)
    let v_flat = da_matvec(weights.w_v, x, total_v, d_model)

    // -- Split per head and store in cache --
    let mut k_heads = []
    let mut v_heads = []
    let mut h = 0
    while h < n_heads {
        k_heads = k_heads + [da_slice(k_flat, h * head_dim, head_dim)]
        v_heads = v_heads + [da_slice(v_flat, h * half_dim, half_dim)]
        h = h + 1
    }

    let updated_cache = diff_attn_cache_write(cache, pos, k_heads, v_heads)
    let ctx_len = pos + 1

    // -- Per-head differential attention --
    let mut concat_out = []
    h = 0
    while h < n_heads {
        // Extract Q for this head
        let q_h = da_slice(q_flat, h * head_dim, head_dim)

        // Gather K cache and V cache for this head up to ctx_len
        let mut kc = []
        let mut vc = []
        let mut t = 0
        while t < ctx_len {
            kc = kc + [updated_cache.k_data[h][t]]
            vc = vc + [updated_cache.v_data[h][t]]
            t = t + 1
        }

        // Compute effective lambda
        let lam = diff_attn_lambda(weights, h, cfg.lambda_init)

        // Differential attention for this head
        let head_out_raw = diff_attn_head(q_h, kc, vc, ctx_len, half_dim, lam)

        // Group normalization per head
        let head_out = da_group_norm(head_out_raw, weights.gn_gamma, weights.gn_beta, half_dim, cfg.group_norm_eps)

        // Concat
        concat_out = concat_out + head_out
        h = h + 1
    }

    // -- Output projection --
    let out = da_matvec(weights.w_o, concat_out, d_model, total_v)

    return [out, updated_cache]
}

// ===================================================================
//  Prefill: multiple tokens at once
//  xs: array of input vectors [d_model], length seq_len
//  Returns: [outputs array, updated_cache]
// ===================================================================
@hot
fn diff_attn_prefill(xs, cache: DiffAttnCache, weights: DiffAttnWeights, cfg: DiffAttnConfig) {
    let seq_len = len(xs)
    let mut cur_cache = cache
    let mut outputs = []
    let mut t = 0
    while t < seq_len {
        let result = diff_attn_forward(xs[t], t, cur_cache, weights, cfg)
        outputs = outputs + [result[0]]
        cur_cache = result[1]
        t = t + 1
    }
    return [outputs, cur_cache]
}

// ===================================================================
//  L2 loss: sum of squares (for gradient checking)
// ===================================================================
@pure
fn da_l2_loss(output) {
    let n = len(output)
    let mut s = 0.0
    let mut i = 0
    while i < n {
        s = s + output[i] * output[i]
        i = i + 1
    }
    return s
}

// ===================================================================
//  Noise reduction ratio: measures how much the differential
//  mechanism suppresses uniform attention (noise floor).
//  For uniform K (all same): A1==A2==uniform, so A_diff ~ (1-lambda)*uniform
//  vs standard attention which gives 1*uniform. Ratio = 1-lambda.
//
//  Returns ratio in [0,1] where lower = more noise suppressed.
// ===================================================================
@pure
fn diff_attn_noise_ratio(lambda_val) {
    return da_fabs(1.0 - lambda_val)
}

// ===================================================================
//  Effective lambda stats across all heads
//  Returns: [min_lambda, max_lambda, mean_lambda]
// ===================================================================
fn diff_attn_lambda_stats(weights: DiffAttnWeights, cfg: DiffAttnConfig) {
    let n = cfg.n_heads
    let mut mn = 1.0e30
    let mut mx = 0.0 - 1.0e30
    let mut sm = 0.0
    let mut h = 0
    while h < n {
        let lam = diff_attn_lambda(weights, h, cfg.lambda_init)
        if lam < mn { mn = lam }
        if lam > mx { mx = lam }
        sm = sm + lam
        h = h + 1
    }
    return [mn, mx, sm / to_float(n)]
}

// ===================================================================
//  Sum of differential attention weights (should be ~1-lambda for
//  well-behaved heads, can be negative/positive).
//  Useful for verifying the cancellation property.
// ===================================================================
@pure
fn da_attn_weight_sum(a_diff, ctx_len) {
    let mut s = 0.0
    let mut i = 0
    while i < ctx_len {
        s = s + a_diff[i]
        i = i + 1
    }
    return s
}


// -- end inlined --

let mut PASS = 0
let mut FAIL = 0

fn check(label, cond) {
    if cond {
        PASS = PASS + 1
        println("[PASS] " + label)
    } else {
        FAIL = FAIL + 1
        println("[FAIL] " + label)
    }
}

fn t_abs(x) {
    if x < 0.0 {
        return 0.0 - x
    }
    return x
}

fn t_vec_norm(v) {
    let mut s = 0.0
    let mut i = 0
    while i < len(v) {
        s = s + v[i] * v[i]
        i = i + 1
    }
    return sqrt(s)
}

fn t_vec_close(a, b, eps) {
    if len(a) != len(b) {
        return false
    }
    let mut i = 0
    while i < len(a) {
        if t_abs(a[i] - b[i]) > eps {
            return false
        }
        i = i + 1
    }
    return true
}

fn t_vec_sum(v) {
    let mut s = 0.0
    let mut i = 0
    while i < len(v) {
        s = s + v[i]
        i = i + 1
    }
    return s
}

fn t_vec_mean(v) {
    return t_vec_sum(v) / to_float(len(v))
}

fn t_vec_var(v) {
    let m = t_vec_mean(v)
    let mut s = 0.0
    let mut i = 0
    while i < len(v) {
        let d = v[i] - m
        s = s + d * d
        i = i + 1
    }
    return s / to_float(len(v))
}

println("===================================================================")
println("  Differential Attention Test Suite")
println("===================================================================")

// ── Setup ────────────────────────────────────────────────────────
let d_model = 16
let n_heads = 2
let head_dim = 8
let half_dim = head_dim / 2
let total_qk = n_heads * head_dim
let total_v = n_heads * half_dim

da_rand_seed(42)
let cfg = diff_attn_config_new(d_model, n_heads, head_dim)
let weights = diff_attn_weights_init(cfg)

// Deterministic input vector
let mut x = []
let mut i = 0

while i < d_model {
    x = x + [0.1 * to_float(i + 1)]
}

// ── T01: Config creation ─────────────────────────────────────────
check("T01 config d_model", cfg.d_model == d_model)

// ── T02: w_q dimension [n_heads*head_dim, d_model] ──────────────
check("T02 w_q rows = n_heads*head_dim", len(weights.w_q) == total_qk)

// ── T03: w_k dimension ──────────────────────────────────────────
check("T03 w_k rows = n_heads*head_dim", len(weights.w_k) == total_qk)

// ── T04: w_v dimension (half_dim per head) ──────────────────────
check("T04 w_v rows = n_heads*half_dim", len(weights.w_v) == total_v)

// ── T05: w_o dimension ──────────────────────────────────────────
check("T05 w_o rows = d_model", len(weights.w_o) == d_model)

// ── T06: lambda arrays length = n_heads ─────────────────────────
check("T06 lambda1 len = n_heads", len(weights.lambda1) == n_heads)

// ── T07: group norm gamma length = half_dim ─────────────────────
check("T07 gn_gamma len = half_dim", len(weights.gn_gamma) == half_dim)

// ── T08: effective lambda near lambda_init ──────────────────────
// With small random init of lambda1,lambda2 near 0:
// exp(~0) - exp(~0) + 0.8 ~ 0.8
let lam0 = diff_attn_lambda(weights, 0, cfg.lambda_init)
check("T08 lambda[0] near lambda_init (0.8)", t_abs(lam0 - 0.8) < 0.3)

// ── T09: Softmax sums to 1.0 ───────────────────────────────────
let test_scores = [1.0, 2.0, 3.0, 0.5]
let sm = da_softmax(test_scores, 4)
let sm_sum = t_vec_sum(sm)
check("T09 softmax sums to 1.0", t_abs(sm_sum - 1.0) < 1.0e-10)

// ── T10: Softmax max element gets highest weight ────────────────
// scores[2]=3.0 is largest -> sm[2] should be largest
let mut sm_max_idx = 0
let mut sm_max_val = sm[0]
let mut i = 1

while i < 4 {
    if sm[i] > sm_max_val {
        sm_max_val = sm[i]
        sm_max_idx = i
    }
}
check("T10 softmax argmax = index of max score", sm_max_idx == 2)

// ── T11: Group norm output has ~zero mean (beta=0, gamma=1) ────
let gn_input = [1.0, 3.0, 5.0, 7.0]
let gn_gamma = [1.0, 1.0, 1.0, 1.0]
let gn_beta = [0.0, 0.0, 0.0, 0.0]
let gn_out = da_group_norm(gn_input, gn_gamma, gn_beta, 4, 1.0e-5)
let gn_mean = t_vec_mean(gn_out)
check("T11 group_norm mean ~0 (beta=0)", t_abs(gn_mean) < 1.0e-6)

// ── T12: Group norm output has ~unit variance ──────────────────
let gn_var = t_vec_var(gn_out)
check("T12 group_norm var ~1 (gamma=1)", t_abs(gn_var - 1.0) < 0.01)

// ── T13: Forward output dimension = d_model ─────────────────────
let cache0 = diff_attn_cache_new(32, n_heads)
let result0 = diff_attn_forward(x, 0, cache0, weights, cfg)
let out0 = result0[0]
check("T13 forward output dim = d_model", len(out0) == d_model)

// ── T14: Forward output non-zero ────────────────────────────────
let out0_norm = t_vec_norm(out0)
check("T14 forward output non-zero", out0_norm > 1.0e-8)

// ── T15: Cache seq_len advances ─────────────────────────────────
let cache1 = result0[1]
check("T15 cache seq_len=1 after pos=0", cache1.seq_len == 1)

// ── T16: Cache stores correct K ─────────────────────────────────
// Recompute K projection manually and compare with cached K[0][0]
let k_flat = da_matvec(weights.w_k, x, total_qk, d_model)
let k_h0_expected = da_slice(k_flat, 0, head_dim)
let k_h0_cached = cache1.k_data[0][0]
check("T16 cache stores correct K[h=0]", t_vec_close(k_h0_cached, k_h0_expected, 1.0e-10))

// ── T17: Dual softmax: A1 sums to 1, A2 sums to 1 ──────────────
// Build Q and K for head 0, compute scores manually
let q_flat_manual = da_matvec(weights.w_q, x, total_qk, d_model)
let q_h0 = da_slice(q_flat_manual, 0, head_dim)
let q1 = da_slice(q_h0, 0, half_dim)
let q2 = da_slice(q_h0, half_dim, half_dim)
// With single token, both A1 and A2 should be [1.0]
// Use 2 tokens to be more interesting
let mut x2 = []
let mut i = 0

while i < d_model {
    x2 = x2 + [0.2 * to_float(i + 3)]
}
let cache2a = diff_attn_cache_new(32, n_heads)
let r2a = diff_attn_forward(x, 0, cache2a, weights, cfg)
let r2b = diff_attn_forward(x2, 1, r2a[1], weights, cfg)
let cache_2tok = r2b[1]

// Gather K for head 0
let k0_t0 = cache_2tok.k_data[0][0]
let k0_t1 = cache_2tok.k_data[0][1]
let k_cache_h0 = [k0_t0, k0_t1]

// Build Q for head 0 on x2
let q_flat2 = da_matvec(weights.w_q, x2, total_qk, d_model)
let q_h0_2 = da_slice(q_flat2, 0, head_dim)
let q1_2 = da_slice(q_h0_2, 0, half_dim)
let q2_2 = da_slice(q_h0_2, half_dim, half_dim)

// Compute A1, A2 manually
let scale_val = 1.0 / sqrt(to_float(half_dim))
let mut s1 = []
let mut s2 = []
let mut t = 0

while t < 2 {
    let kt = k_cache_h0[t]
    let mut d1 = 0.0
    let mut d2_val = 0.0
    let mut d = 0

    while d < half_dim {
        d1 = d1 + q1_2[d] * kt[d]
        d2_val = d2_val + q2_2[d] * kt[half_dim + d]
    }
    s1 = s1 + [d1 * scale_val]
    s2 = s2 + [d2_val * scale_val]
}
let a1 = da_softmax(s1, 2)
let a2 = da_softmax(s2, 2)
let a1_sum = t_vec_sum(a1)
let a2_sum = t_vec_sum(a2)
check("T17 A1 sums to 1 AND A2 sums to 1", t_abs(a1_sum - 1.0) < 1.0e-10 && t_abs(a2_sum - 1.0) < 1.0e-10)

// ── T18: Differential A1 - lambda*A2 sums to ~(1 - lambda) ─────
let lam_h0 = diff_attn_lambda(weights, 0, cfg.lambda_init)
let a_diff_manual = [a1[0] - lam_h0 * a2[0], a1[1] - lam_h0 * a2[1]]
let a_diff_sum = t_vec_sum(a_diff_manual)
let expected_sum = 1.0 - lam_h0
check("T18 A_diff sums to ~(1-lambda)", t_abs(a_diff_sum - expected_sum) < 1.0e-8)

// ── T19: Noise suppression with uniform keys ────────────────────
// When all keys are identical, A1==A2==uniform -> A_diff = (1-lambda)*uniform
// With lambda~0.8, noise ratio ~ 0.2 (80% suppression)
let nr = diff_attn_noise_ratio(lam_h0)
check("T19 noise ratio < 0.5 (lambda near 0.8)", nr < 0.5)

// ── T20: Different inputs at pos=1 (2-token context) differ ─────
// With 2+ tokens, softmax is non-trivial and different Q/K/V create
// genuinely different attention patterns via the differential mechanism.
let cache_pa = diff_attn_cache_new(32, n_heads)
let rpa0 = diff_attn_forward(x, 0, cache_pa, weights, cfg)
let rpa1 = diff_attn_forward(x2, 1, rpa0[1], weights, cfg)
let out_pa = rpa1[0]

let mut x3 = []
let mut i = 0

while i < d_model {
    x3 = x3 + [0.5 * to_float(i + 7)]
}
let cache_pb = diff_attn_cache_new(32, n_heads)
let rpb0 = diff_attn_forward(x, 0, cache_pb, weights, cfg)
let rpb1 = diff_attn_forward(x3, 1, rpb0[1], weights, cfg)
let out_pb = rpb1[0]

let mut inp_diff = false
let mut i = 0

while i < d_model {
    if t_abs(out_pa[i] - out_pb[i]) > 1.0e-10 {
        inp_diff = true
    }
}
check("T20 different inputs at pos=1 -> different outputs", inp_diff)

// ── T21: Deterministic: same input, same output ─────────────────
let cache_d1 = diff_attn_cache_new(32, n_heads)
let cache_d2 = diff_attn_cache_new(32, n_heads)
let rd1 = diff_attn_forward(x, 0, cache_d1, weights, cfg)
let rd2 = diff_attn_forward(x, 0, cache_d2, weights, cfg)
check("T21 deterministic forward", t_vec_close(rd1[0], rd2[0], 1.0e-12))

// ── T22: Prefill output count ───────────────────────────────────
let mut xs = []
let mut i = 0

while i < 4 {
    let mut xi = []
    let mut j = 0

    while j < d_model {
        xi = xi + [0.1 * to_float(i * d_model + j + 1)]
    }
    xs = xs + [xi]
}
let cache_pf = diff_attn_cache_new(32, n_heads)
let pf_result = diff_attn_prefill(xs, cache_pf, weights, cfg)
let pf_outs = pf_result[0]
check("T22 prefill output count = 4", len(pf_outs) == 4)

// ── T23: Prefill output dimensions ──────────────────────────────
let mut pf_dims_ok = true
let mut i = 0

while i < 4 {
    if len(pf_outs[i]) != d_model {
        pf_dims_ok = false
    }
}
check("T23 prefill outputs all dim=d_model", pf_dims_ok)

// ── T24: Prefill cache seq_len ──────────────────────────────────
let pf_cache = pf_result[1]
check("T24 prefill cache seq_len=4", pf_cache.seq_len == 4)

// ── T25: Multi-token context changes attention distribution ──────
// At pos=2 with [x, x2, x] vs pos=2 with [x3, x2, x], the output
// differs because the cached K/V at pos=0 changes the softmax weights.
let cache_mt_a = diff_attn_cache_new(32, n_heads)
let rmt_a0 = diff_attn_forward(x, 0, cache_mt_a, weights, cfg)
let rmt_a1 = diff_attn_forward(x2, 1, rmt_a0[1], weights, cfg)
let rmt_a2 = diff_attn_forward(x, 2, rmt_a1[1], weights, cfg)
let out_ctx_a = rmt_a2[0]

let mut x3b = []
let mut i = 0

while i < d_model {
    x3b = x3b + [0.9 * to_float(i + 2)]
}
let cache_mt_b = diff_attn_cache_new(32, n_heads)
let rmt_b0 = diff_attn_forward(x3b, 0, cache_mt_b, weights, cfg)
let rmt_b1 = diff_attn_forward(x2, 1, rmt_b0[1], weights, cfg)
let rmt_b2 = diff_attn_forward(x, 2, rmt_b1[1], weights, cfg)
let out_ctx_b = rmt_b2[0]

let mut ctx_diff = false
let mut i = 0

while i < d_model {
    if t_abs(out_ctx_a[i] - out_ctx_b[i]) > 1.0e-10 {
        ctx_diff = true
    }
}
check("T25 different context history -> different outputs", ctx_diff)

// ── T26: Lambda stats: min <= mean <= max ───────────────────────
let lstats = diff_attn_lambda_stats(weights, cfg)
let lam_min = lstats[0]
let lam_max = lstats[1]
let lam_mean = lstats[2]
check("T26 lambda: min <= mean <= max", lam_min <= lam_mean && lam_mean <= lam_max)

// ── T27: Noise ratio with lambda=1 is 0 (full cancellation) ────
let nr1 = diff_attn_noise_ratio(1.0)
check("T27 noise_ratio(lambda=1) = 0", t_abs(nr1) < 1.0e-10)

// ── T28: Noise ratio with lambda=0 is 1 (no cancellation) ──────
let nr0 = diff_attn_noise_ratio(0.0)
check("T28 noise_ratio(lambda=0) = 1", t_abs(nr0 - 1.0) < 1.0e-10)

// ── T29: L2 loss positive for non-zero input ────────────────────
let loss_val = da_l2_loss(out0)
check("T29 L2 loss > 0 for non-zero output", loss_val > 0.0)

// ── T30: da_slice extracts correct sub-array ────────────────────
let test_arr = [10.0, 20.0, 30.0, 40.0, 50.0]
let sliced = da_slice(test_arr, 1, 3)
check("T30 da_slice([10..50], 1, 3) = [20,30,40]", len(sliced) == 3 && t_abs(sliced[0] - 20.0) < 1.0e-10 && t_abs(sliced[1] - 30.0) < 1.0e-10 && t_abs(sliced[2] - 40.0) < 1.0e-10)

// ===================================================================
println("")
println("pass=" + to_string(PASS) + " fail=" + to_string(FAIL))
if FAIL == 0 {
    println("ALL PASS")
} else {
    println("SOME TESTS FAILED")
}
println(to_string(PASS) + " passed")
