// ═══════════════════════════════════════════════════════════
//  test_rc_memory.hexa — Reference Counting Memory Management Tests
//  Tests: rc_alloc, rc_retain, rc_release, rc_deref, rc_stats, slot reuse
// ═══════════════════════════════════════════════════════════

// ── RC system (standalone copy for direct testing) ───────

let mut rc_values = []
let mut rc_counts = []
let mut rc_alive  = []
let mut rc_total_allocs = 0
let mut rc_total_frees  = 0

fn rc_alloc(value) {
    let mut i = 0
    while i < len(rc_values) {
        if rc_alive[i] == false {
            rc_values[i] = value
            rc_counts[i] = 1
            rc_alive[i] = true
            rc_total_allocs = rc_total_allocs + 1
            return i
        }
        i = i + 1
    }
    let idx = len(rc_values)
    rc_values.push(value)
    rc_counts.push(1)
    rc_alive.push(true)
    rc_total_allocs = rc_total_allocs + 1
    return idx
}

fn rc_retain(h) {
    if h < 0 || h >= len(rc_values) { return }
    if rc_alive[h] == false { return }
    rc_counts[h] = rc_counts[h] + 1
}

fn rc_release(h) {
    if h < 0 || h >= len(rc_values) { return }
    if rc_alive[h] == false { return }
    rc_counts[h] = rc_counts[h] - 1
    if rc_counts[h] <= 0 {
        rc_alive[h] = false
        rc_values[h] = ""
        rc_counts[h] = 0
        rc_total_frees = rc_total_frees + 1
    }
}

fn rc_deref(h) {
    if h < 0 || h >= len(rc_values) { return "" }
    if rc_alive[h] == false { return "" }
    return rc_values[h]
}

fn rc_refcount(h) {
    if h < 0 || h >= len(rc_values) { return 0 }
    if rc_alive[h] == false { return 0 }
    return rc_counts[h]
}

fn rc_is_alive(h) {
    if h < 0 || h >= len(rc_values) { return false }
    return rc_alive[h]
}

fn rc_stats() {
    let live = rc_total_allocs - rc_total_frees
    return [rc_total_allocs, rc_total_frees, live]
}

fn rc_reset() {
    rc_values = []
    rc_counts = []
    rc_alive = []
    rc_total_allocs = 0
    rc_total_frees = 0
}

// ── Test harness ─────────────────────────────────────────

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA P3-3: Reference Counting Memory Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Basic allocation ──────────────────────────────────

println("--- Basic Allocation ---")

let h1 = rc_alloc("hello")
check("alloc returns handle 0", h1, 0)
check("deref returns value", rc_deref(h1), "hello")
check("initial refcount is 1", rc_refcount(h1), 1)
check("handle is alive", rc_is_alive(h1), true)

let h2 = rc_alloc("world")
check("second alloc returns handle 1", h2, 1)
check("deref second handle", rc_deref(h2), "world")

println("")

// ── 2. Retain / Release ──────────────────────────────────

println("--- Retain / Release ---")

rc_retain(h1)
check("after retain, refcount is 2", rc_refcount(h1), 2)

rc_retain(h1)
check("after second retain, refcount is 3", rc_refcount(h1), 3)

rc_release(h1)
check("after release, refcount is 2", rc_refcount(h1), 2)

rc_release(h1)
check("after second release, refcount is 1", rc_refcount(h1), 1)
check("still alive at refcount 1", rc_is_alive(h1), true)

rc_release(h1)
check("after final release, refcount is 0", rc_refcount(h1), 0)
check("handle is dead after release to 0", rc_is_alive(h1), false)
check("deref dead handle returns empty", rc_deref(h1), "")

println("")

// ── 3. GC stats ──────────────────────────────────────────

println("--- GC Stats ---")

let stats1 = rc_stats()
check("total allocs so far", stats1[0], 2)
check("total frees so far", stats1[1], 1)
check("live objects", stats1[2], 1)

println("")

// ── 4. Slot reuse ────────────────────────────────────────

println("--- Slot Reuse ---")

// h1 (slot 0) is freed, new alloc should reuse it
let h3 = rc_alloc("reused")
check("freed slot 0 is reused", h3, 0)
check("reused slot has correct value", rc_deref(h3), "reused")
check("reused slot refcount is 1", rc_refcount(h3), 1)

println("")

// ── 5. Multiple types ────────────────────────────────────

println("--- Multiple Value Types ---")

let h_int = rc_alloc(42)
check("alloc int", rc_deref(h_int), 42)

let h_arr = rc_alloc([1, 2, 3])
check("alloc array", to_string(rc_deref(h_arr)), to_string([1, 2, 3]))

let h_bool = rc_alloc(true)
check("alloc bool", rc_deref(h_bool), true)

let h_float = rc_alloc(3.14)
check("alloc float", rc_deref(h_float), 3.14)

println("")

// ── 6. Release all, verify stats ─────────────────────────

println("--- Bulk Release ---")

rc_release(h2)
rc_release(h3)
rc_release(h_int)
rc_release(h_arr)
rc_release(h_bool)
rc_release(h_float)

let stats2 = rc_stats()
check("all freed: total allocs", stats2[0], 7)
check("all freed: total frees", stats2[1], 7)
check("all freed: live count is 0", stats2[2], 0)

println("")

// ── 7. Reset ─────────────────────────────────────────────

println("--- Reset ---")

rc_reset()
let stats3 = rc_stats()
check("after reset: allocs is 0", stats3[0], 0)
check("after reset: frees is 0", stats3[1], 0)
check("after reset: live is 0", stats3[2], 0)

// Allocate after reset
let h_post = rc_alloc("fresh")
check("post-reset alloc works", rc_deref(h_post), "fresh")
check("post-reset handle is 0", h_post, 0)

println("")

// ── 8. Edge cases ────────────────────────────────────────

println("--- Edge Cases ---")

check("deref invalid handle -1", rc_deref(-1), "")
check("refcount invalid handle", rc_refcount(999), 0)
check("is_alive invalid handle", rc_is_alive(-1), false)

// Double release should not crash
rc_release(h_post)
check("released post handle", rc_is_alive(h_post), false)
rc_release(h_post)
check("double release is safe (no crash)", rc_is_alive(h_post), false)

println("")

// ── Summary ──────────────────────────────────────────────

println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    println("SOME TESTS FAILED")
} else {
    println("ALL TESTS PASSED")
}
