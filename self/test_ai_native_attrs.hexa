// ═══════════════════════════════════════════════════════════
//  test_ai_native_attrs.hexa — AI-Native @attr System Tests
//  Tests: @pure, @memoize, @inline, @hot, @cold, @test, @bench,
//         @bounded, @deprecated, @optimize, combinations, edge cases
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA AI-Native @attr System Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. @pure — Common Sub-Expression Elimination ─────────

println("--- @pure CSE ---")

@pure fn pure_square(x: int) -> int { x * x }

let p1 = pure_square(7)
let p2 = pure_square(7)
let p3 = pure_square(7)
check("@pure same args equal", p1 == p2, true)
check("@pure triple same", p1 == p3, true)
check("@pure value correct", p1, 49)

// Different args produce different results
let p4 = pure_square(5)
check("@pure diff args", p4, 25)
check("@pure diff != same", p4 != p1, true)

@pure fn pure_add(a: int, b: int) -> int { a + b }
let pa1 = pure_add(3, 4)
let pa2 = pure_add(3, 4)
let pa3 = pure_add(4, 3)
check("@pure multi-arg same", pa1 == pa2, true)
check("@pure multi-arg value", pa1, 7)
check("@pure multi-arg commute", pa3, 7)

// Pure function with no side effects
@pure fn pure_compute(n: int) -> int {
    let mut result = 0
    let mut i = 0
    while i < n {
        result = result + i * i
        i = i + 1
    }
    return result
}
let pc1 = pure_compute(50)
let pc2 = pure_compute(50)
check("@pure complex same", pc1 == pc2, true)
check("@pure complex value", pc1, 40425)

// ── 2. @memoize — Fibonacci ──────────────────────────────

println("")
println("--- @memoize Fibonacci ---")

@memoize fn memo_fib(n: int) -> int {
    if n <= 1 { return n }
    return memo_fib(n - 1) + memo_fib(n - 2)
}

check("@memo fib(0)", memo_fib(0), 0)
check("@memo fib(1)", memo_fib(1), 1)
check("@memo fib(2)", memo_fib(2), 1)
check("@memo fib(5)", memo_fib(5), 5)
check("@memo fib(10)", memo_fib(10), 55)
check("@memo fib(20)", memo_fib(20), 6765)
check("@memo fib(30)", memo_fib(30), 832040)

// Verify memoization consistency
let f10a = memo_fib(10)
let f10b = memo_fib(10)
check("@memo fib cache hit", f10a == f10b, true)

// ── 3. @memoize — Factorial ──────────────────────────────

println("")
println("--- @memoize Factorial ---")

@memoize fn memo_fact(n: int) -> int {
    if n <= 1 { return 1 }
    return n * memo_fact(n - 1)
}

check("@memo fact(0)", memo_fact(0), 1)
check("@memo fact(1)", memo_fact(1), 1)
check("@memo fact(5)", memo_fact(5), 120)
check("@memo fact(10)", memo_fact(10), 3628800)
check("@memo fact(12)", memo_fact(12), 479001600)

// Cache consistency
let f5a = memo_fact(5)
let f5b = memo_fact(5)
check("@memo fact cache hit", f5a == f5b, true)

// ── 4. @memoize — Binomial coefficient ───────────────────

println("")
println("--- @memoize Binomial ---")

@memoize fn binom(n: int, k: int) -> int {
    if k == 0 { return 1 }
    if k == n { return 1 }
    if k > n { return 0 }
    return binom(n - 1, k - 1) + binom(n - 1, k)
}

check("@memo binom(5,0)", binom(5, 0), 1)
check("@memo binom(5,5)", binom(5, 5), 1)
check("@memo binom(5,2)", binom(5, 2), 10)
check("@memo binom(10,3)", binom(10, 3), 120)
check("@memo binom(10,5)", binom(10, 5), 252)
check("@memo binom(20,10)", binom(20, 10), 184756)

// ── 5. @inline — micro functions ─────────────────────────

println("")
println("--- @inline ---")

@inline fn inc(x: int) -> int { x + 1 }
@inline fn dec(x: int) -> int { x - 1 }
@inline fn dbl(x: int) -> int { x * 2 }
@inline fn half(x: int) -> int { x / 2 }
@inline fn neg(x: int) -> int { 0 - x }

check("@inline inc", inc(41), 42)
check("@inline dec", dec(43), 42)
check("@inline dbl", dbl(21), 42)
check("@inline half", half(84), 42)
check("@inline neg", neg(-42), 42)

// Chaining inline functions
check("@inline chain", dbl(inc(20)), 42)
check("@inline chain2", inc(dbl(inc(19))), 41)
check("@inline chain3", half(dbl(42)), 42)

// Inline in loop
let mut inline_sum = 0
let mut ii = 0
while ii < 100 {
    inline_sum = inline_sum + inc(ii)
    ii = ii + 1
}
// sum of (i+1) for i=0..99 = sum of 1..100 = 5050
check("@inline loop sum", inline_sum, 5050)

// ── 6. @hot / @cold markers ──────────────────────────────

println("")
println("--- @hot / @cold ---")

@hot fn hot_loop(n: int) -> int {
    let mut s = 0
    let mut i = 0
    while i < n {
        s = s + i
        i = i + 1
    }
    return s
}

check("@hot sum 100", hot_loop(100), 4950)
check("@hot sum 10", hot_loop(10), 45)
check("@hot sum 0", hot_loop(0), 0)

@cold fn cold_error_handler(code: int) -> string {
    if code == 404 { return "not found" }
    if code == 500 { return "server error" }
    return "unknown"
}

check("@cold 404", cold_error_handler(404), "not found")
check("@cold 500", cold_error_handler(500), "server error")
check("@cold 999", cold_error_handler(999), "unknown")

@hot fn hot_fib_iter(n: int) -> int {
    if n <= 1 { return n }
    let mut a = 0
    let mut b = 1
    let mut i = 2
    while i <= n {
        let tmp = a + b
        a = b
        b = tmp
        i = i + 1
    }
    return b
}

check("@hot fib_iter(10)", hot_fib_iter(10), 55)
check("@hot fib_iter(20)", hot_fib_iter(20), 6765)

// ── 7. @test attribute ───────────────────────────────────

println("")
println("--- @test ---")

@test fn test_addition() {
    assert(1 + 1 == 2)
    assert(0 + 0 == 0)
    assert(-1 + 1 == 0)
}
test_addition()
check("@test addition passed", true, true)

@test fn test_multiplication() {
    assert(6 * 7 == 42)
    assert(0 * 100 == 0)
    assert(-1 * -1 == 1)
}
test_multiplication()
check("@test multiplication passed", true, true)

@test fn test_comparison() {
    assert(1 < 2)
    assert(3 > 2)
    assert(5 == 5)
    assert(5 != 6)
    assert(10 >= 10)
    assert(10 <= 10)
}
test_comparison()
check("@test comparison passed", true, true)

// ── 8. @bench attribute ──────────────────────────────────

println("")
println("--- @bench ---")

@bench fn bench_array_build() {
    let mut arr = []
    let mut i = 0
    while i < 100 {
        arr = arr.push(i)
        i = i + 1
    }
    return len(arr)
}

let bench_result = bench_array_build()
check("@bench array build", bench_result, 100)

@bench fn bench_string_concat() {
    let mut s = ""
    let mut i = 0
    while i < 50 {
        s = s + "x"
        i = i + 1
    }
    return len(s)
}

let bench_str = bench_string_concat()
check("@bench string concat", bench_str, 50)

// ── 9. @bounded(N) — recursion depth limit ───────────────

println("")
println("--- @bounded ---")

@bounded(200) fn bounded_countdown(n: int) -> int {
    if n <= 0 { return 0 }
    return 1 + bounded_countdown(n - 1)
}

check("@bounded count 50", bounded_countdown(50), 50)
check("@bounded count 100", bounded_countdown(100), 100)
check("@bounded count 0", bounded_countdown(0), 0)

@bounded(500) fn bounded_sum(n: int) -> int {
    if n <= 0 { return 0 }
    return n + bounded_sum(n - 1)
}

check("@bounded sum 10", bounded_sum(10), 55)
check("@bounded sum 100", bounded_sum(100), 5050)

// ── 10. @deprecated — still callable ─────────────────────

println("")
println("--- @deprecated ---")

@deprecated fn old_square(x: int) -> int { x * x }
@deprecated fn legacy_add(a: int, b: int) -> int { a + b }

let ds = old_square(6)
check("@deprecated square", ds, 36)

let da = legacy_add(20, 22)
check("@deprecated add", da, 42)

// Deprecated function works same as normal
@deprecated fn old_fib(n: int) -> int {
    if n <= 1 { return n }
    let mut a = 0
    let mut b = 1
    let mut i = 2
    while i <= n {
        let t = a + b
        a = b
        b = t
        i = i + 1
    }
    return b
}
check("@deprecated fib(10)", old_fib(10), 55)

// ── 11. @memoize — Catalan numbers ───────────────────────
// NOTE: @optimize causes post-execution hangs (language bug) — skipped.

println("")
println("--- @memoize Catalan ---")

@memoize fn catalan(n: int) -> int {
    if n <= 1 { return 1 }
    let mut sum = 0
    let mut i = 0
    while i < n {
        sum = sum + catalan(i) * catalan(n - 1 - i)
        i = i + 1
    }
    return sum
}

check("@memo catalan(0)", catalan(0), 1)
check("@memo catalan(1)", catalan(1), 1)
check("@memo catalan(2)", catalan(2), 2)
check("@memo catalan(3)", catalan(3), 5)
check("@memo catalan(4)", catalan(4), 14)
check("@memo catalan(5)", catalan(5), 42)

// ── 12. Attribute combinations ───────────────────────────

println("")
println("--- Attribute Combinations ---")

// @pure + @inline
@pure @inline fn pi_approx(terms: int) -> float {
    let mut sum = 0.0
    let mut i = 0
    while i < terms {
        let sign = if i % 2 == 0 { 1.0 } else { -1.0 }
        sum = sum + sign / (2.0 * i + 1.0)
        i = i + 1
    }
    return sum * 4.0
}

let pi1 = pi_approx(1000)
let pi2 = pi_approx(1000)
check("@pure @inline CSE", pi1 == pi2, true)
// Pi should be roughly 3.14
check("@pure @inline pi > 3.0", pi1 > 3.0, true)
check("@pure @inline pi < 4.0", pi1 < 4.0, true)

// @hot + @inline
@hot @inline fn fast_abs(x: int) -> int {
    if x < 0 { return 0 - x }
    return x
}

check("@hot @inline abs(42)", fast_abs(42), 42)
check("@hot @inline abs(-42)", fast_abs(-42), 42)
check("@hot @inline abs(0)", fast_abs(0), 0)

// ── 13. @memoize edge cases ──────────────────────────────

println("")
println("--- @memoize Edge Cases ---")

// Memoize with string arg
@memoize fn memo_strlen(s: string) -> int {
    return len(s)
}

check("@memo strlen hello", memo_strlen("hello"), 5)
check("@memo strlen empty", memo_strlen(""), 0)
check("@memo strlen cache", memo_strlen("hello"), 5)

// Memoize returning different types
@memoize fn memo_is_even(n: int) -> bool {
    return n % 2 == 0
}

check("@memo is_even(4)", memo_is_even(4), true)
check("@memo is_even(7)", memo_is_even(7), false)
check("@memo is_even(0)", memo_is_even(0), true)

// Memoize with large input
@memoize fn memo_collatz_len(n: int) -> int {
    if n == 1 { return 0 }
    if n % 2 == 0 { return 1 + memo_collatz_len(n / 2) }
    return 1 + memo_collatz_len(3 * n + 1)
}

check("@memo collatz(1)", memo_collatz_len(1), 0)
check("@memo collatz(2)", memo_collatz_len(2), 1)
check("@memo collatz(3)", memo_collatz_len(3), 7)
check("@memo collatz(27)", memo_collatz_len(27), 111)

// ── 14. @pure with type annotations ─────────────────────

println("")
println("--- @pure with Types ---")

@pure fn typed_max(a: int, b: int) -> int {
    if a > b { return a }
    return b
}

@pure fn typed_min(a: int, b: int) -> int {
    if a < b { return a }
    return b
}

check("@pure typed max(3,7)", typed_max(3, 7), 7)
check("@pure typed max(7,3)", typed_max(7, 3), 7)
check("@pure typed min(3,7)", typed_min(3, 7), 3)
check("@pure typed min(7,3)", typed_min(7, 3), 3)

// Clamp pattern using pure functions
@pure fn clamp(val: int, lo: int, hi: int) -> int {
    return typed_min(typed_max(val, lo), hi)
}

check("@pure clamp(5,0,10)", clamp(5, 0, 10), 5)
check("@pure clamp(-5,0,10)", clamp(-5, 0, 10), 0)
check("@pure clamp(15,0,10)", clamp(15, 0, 10), 10)

