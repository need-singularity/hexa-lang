// ═══════════════════════════════════════════════════════════
//  test_walrus_guard_with.hexa — Tests for G24, G27, G28
//  G24: Walrus operator := (assignment expression)
//  G27: with statement (context manager)
//  G28: guard clause (early exit)
//
//  Tests self-hosted lexer keyword recognition.
//  The new parse/interp nodes are tested through the
//  self-hosted pipeline (import parser.hexa + interpreter.hexa).
// ═══════════════════════════════════════════════════════════

let mut pass = 0
let mut fail = 0

fn check(name, cond) {
    if cond {
        pass = pass + 1
        println("  [PASS] " + name)
    } else {
        fail = fail + 1
        println("  [FAIL] " + name)
    }
}

// ═══════════════════════════════════════════════════════════
//  Part A: Lexer keyword recognition (inline from lexer.hexa)
// ═══════════════════════════════════════════════════════════

fn is_kw(word) {
    if word == "if" { return true }
    if word == "else" { return true }
    if word == "for" { return true }
    if word == "while" { return true }
    if word == "let" { return true }
    if word == "fn" { return true }
    if word == "return" { return true }
    if word == "struct" { return true }
    if word == "scope" { return true }
    if word == "guard" { return true }
    if word == "with" { return true }
    if word == "as" { return true }
    return false
}

println("=== Part A: Keyword Recognition ===")

check("A1: guard is keyword", is_kw("guard"))
check("A2: with is keyword", is_kw("with"))
check("A3: as is keyword", is_kw("as"))
check("A4: existing keywords preserved", is_kw("if") && is_kw("for") && is_kw("while"))
check("A5: non-keywords still false", !is_kw("foo") && !is_kw("bar"))

// ═══════════════════════════════════════════════════════════
//  Part B: Guard clause semantics (host-level equivalent)
// ═══════════════════════════════════════════════════════════
println("")
println("=== Part B: Guard Clause Semantics ===")

fn guard_positive(n) {
    // Equivalent to: guard n > 0 else { return -1 }
    if !(n > 0) { return -1 }
    return n * 2
}
check("B1: guard truthy path", guard_positive(5) == 10)
check("B2: guard falsy path (early exit)", guard_positive(-3) == -1)
check("B3: guard zero (falsy)", guard_positive(0) == -1)

fn guard_let_check(val) {
    // Equivalent to: guard let x = val else { return "none" }
    if val == 0 { return "none" }
    let x = val
    return "got: " + to_string(x)
}
check("B4: guard let bind", guard_let_check(42) == "got: 42")
check("B5: guard let early exit", guard_let_check(0) == "none")

// ═══════════════════════════════════════════════════════════
//  Part C: Walrus operator semantics
// ═══════════════════════════════════════════════════════════
println("")
println("=== Part C: Walrus Operator Semantics ===")

let arr = [1, 2, 3, 4, 5]
let n = len(arr)
check("C1: walrus assign+use", n == 5 && n > 0)

let mut words = ["alpha", "beta", ""]
let mut i = 0
let mut result = []
let mut w = words[0]
while w != "" {
    result.push(w)
    i = i + 1
    w = words[i]
}
check("C2: walrus while pattern", len(result) == 2)
check("C3: walrus collected values", result[0] == "alpha" && result[1] == "beta")

// ═══════════════════════════════════════════════════════════
//  Part D: With statement semantics
// ═══════════════════════════════════════════════════════════
println("")
println("=== Part D: With Statement Semantics ===")

let resource = [10, 20, 30]
let mut total = 0
for r in resource {
    total = total + r
}
check("D1: with-like resource binding", total == 60)

let mut closed = false
closed = true
check("D2: with cleanup semantic", closed == true)

// ═══════════════════════════════════════════════════════════
//  Summary
// ═══════════════════════════════════════════════════════════
println("")
println("═══════════════════════════════════════════════")
println("  G24/G27/G28 Test Summary")
println("  PASS: " + to_string(pass))
println("  FAIL: " + to_string(fail))
if fail == 0 {
    println("  STATUS: ALL PASS")
} else {
    println("  STATUS: SOME FAILED")
}
println("═══════════════════════════════════════════════")
