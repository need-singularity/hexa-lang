// test_map_ext_pure.hexa — tests for self/runtime/map_ext_pure.hexa
// 5 functions × 6+ cases each = 30+ assertions
//
// Covers: empty map, single entry, collision, missing key,
//         update-existing, key ordering preservation.

// ─── inlined from self/runtime/map_ext_pure.hexa ───
// (codegen import not wired for test files — follows test_map_pure.hexa pattern)

@pure
pub fn map_partition_pure(m, pred) {
    let mut yes = #{}
    let mut no = #{}
    let ks = keys(m)
    let n = len(ks)
    let mut i = 0
    while i < n {
        let k = ks[i]
        let v = m[k]
        if pred(k, v) {
            yes[k] = v
        } else {
            no[k] = v
        }
        i = i + 1
    }
    return [yes, no]
}

@pure
pub fn map_min_by_pure(m, f) {
    let ks = keys(m)
    let n = len(ks)
    if n == 0 { return void }
    let mut best_k = ks[0]
    let mut best_v = f(best_k, m[best_k])
    let mut i = 1
    while i < n {
        let k = ks[i]
        let v = f(k, m[k])
        if v < best_v {
            best_k = k
            best_v = v
        }
        i = i + 1
    }
    return best_k
}

@pure
pub fn map_max_by_pure(m, f) {
    let ks = keys(m)
    let n = len(ks)
    if n == 0 { return void }
    let mut best_k = ks[0]
    let mut best_v = f(best_k, m[best_k])
    let mut i = 1
    while i < n {
        let k = ks[i]
        let v = f(k, m[k])
        if v > best_v {
            best_k = k
            best_v = v
        }
        i = i + 1
    }
    return best_k
}

@pure
pub fn map_count_by_pure(arr, f) {
    let mut out = #{}
    let n = len(arr)
    let mut i = 0
    while i < n {
        let k = f(arr[i])
        if has_key(out, k) {
            out[k] = out[k] + 1
        } else {
            out[k] = 1
        }
        i = i + 1
    }
    return out
}

@pure
pub fn map_invert_multi_pure(m) {
    let mut out = #{}
    let ks = keys(m)
    let n = len(ks)
    let mut i = 0
    while i < n {
        let k = ks[i]
        let vkey = to_string(m[k])
        if has_key(out, vkey) {
            out[vkey] = out[vkey].push(k)
        } else {
            let init = []
            out[vkey] = init.push(k)
        }
        i = i + 1
    }
    return out
}

// ── small helpers reused from test_map_pure.hexa ──
@pure
pub fn map_size_pure(m) {
    return len(keys(m))
}

@pure
pub fn map_eq_pure(a, b) {
    let ka = keys(a)
    let kb = keys(b)
    if len(ka) != len(kb) { return false }
    let n = len(ka)
    let mut i = 0
    while i < n {
        let k = ka[i]
        if !has_key(b, k) { return false }
        if a[k] != b[k] { return false }
        i = i + 1
    }
    return true
}

// ─── end inlined ───

let mut pass = 0
let mut fail = 0

fn check(name, cond) {
    if cond { pass = pass + 1 } else {
        fail = fail + 1
        println("[FAIL] " + name)
    }
}

fn eq(name, a, b) {
    let both_void = type_of(a) == "void" && type_of(b) == "void"
    if both_void || a == b { pass = pass + 1 } else {
        fail = fail + 1
        println("[FAIL] " + name + " got " + to_string(a) + " want " + to_string(b))
    }
}

println("=== map_ext_pure test suite ===")

// ════════════════════════════════════════════════════════════
// 1. map_partition_pure — split by predicate
// ════════════════════════════════════════════════════════════
let mp1 = #{"a": 1, "b": 2, "c": 3, "d": 4}
let part1 = map_partition_pure(mp1, fn(k, v) { return v > 2 })
eq("partition yes size", map_size_pure(part1[0]), 2)
eq("partition no size",  map_size_pure(part1[1]), 2)
check("partition c in yes", has_key(part1[0], "c"))
check("partition d in yes", has_key(part1[0], "d"))
check("partition a in no",  has_key(part1[1], "a"))
check("partition b in no",  has_key(part1[1], "b"))

// empty map -> [#{}, #{}]
let pempty = map_partition_pure(#{}, fn(k, v) { return true })
eq("partition empty yes", map_size_pure(pempty[0]), 0)
eq("partition empty no",  map_size_pure(pempty[1]), 0)

// single entry, predicate true -> all in yes
let psingle_t = map_partition_pure(#{"x": 5}, fn(k, v) { return v > 0 })
eq("partition single yes", map_size_pure(psingle_t[0]), 1)
eq("partition single no empty", map_size_pure(psingle_t[1]), 0)

// single entry, predicate false -> all in no
let psingle_f = map_partition_pure(#{"x": 5}, fn(k, v) { return v > 100 })
eq("partition single-f yes empty", map_size_pure(psingle_f[0]), 0)
eq("partition single-f no", map_size_pure(psingle_f[1]), 1)

// predicate on key
let pbyk = map_partition_pure(mp1, fn(k, v) { return k == "a" || k == "c" })
eq("partition by-key yes", map_size_pure(pbyk[0]), 2)
eq("partition by-key no",  map_size_pure(pbyk[1]), 2)

// totals preserved
eq("partition total", map_size_pure(part1[0]) + map_size_pure(part1[1]), map_size_pure(mp1))

// ════════════════════════════════════════════════════════════
// 2. map_min_by_pure — key with min f(k, v)
// ════════════════════════════════════════════════════════════
let mm = #{"a": 30, "b": 10, "c": 20}
eq("min_by value",      map_min_by_pure(mm, fn(k, v) { return v }), "b")
eq("min_by negated",    map_min_by_pure(mm, fn(k, v) { return -v }), "a")
eq("min_by by-key-len", map_min_by_pure(#{"xx": 1, "yyy": 2, "z": 3}, fn(k, v) { return len(k) }), "z")

// empty map -> void
let min_empty = map_min_by_pure(#{}, fn(k, v) { return v })
check("min_by empty -> void", type_of(min_empty) == "void")

// single entry
eq("min_by single", map_min_by_pure(#{"only": 42}, fn(k, v) { return v }), "only")

// ties -> first in keys(m) order (stability contract)
let mmt = #{"a": 5, "b": 5, "c": 5}
let min_tie = map_min_by_pure(mmt, fn(k, v) { return v })
check("min_by tie is in map", has_key(mmt, min_tie))

// collision on values — still returns some valid key
let mmc = #{"p": 1, "q": 1}
let min_c = map_min_by_pure(mmc, fn(k, v) { return v })
check("min_by collision key valid", has_key(mmc, min_c))

// ════════════════════════════════════════════════════════════
// 3. map_max_by_pure — key with max f(k, v)
// ════════════════════════════════════════════════════════════
eq("max_by value",   map_max_by_pure(mm, fn(k, v) { return v }), "a")
eq("max_by negated", map_max_by_pure(mm, fn(k, v) { return -v }), "b")

// empty -> void
let max_empty = map_max_by_pure(#{}, fn(k, v) { return v })
check("max_by empty -> void", type_of(max_empty) == "void")

// single
eq("max_by single", map_max_by_pure(#{"only": 7}, fn(k, v) { return v }), "only")

// missing key — conceptually N/A (map has no key means lookup fails),
// but we exercise: new map grown via update-existing path
let mm2 = #{"a": 1}
mm2["b"] = 100
mm2["c"] = 50
eq("max_by after update", map_max_by_pure(mm2, fn(k, v) { return v }), "b")

// collision / ties
let max_tie = map_max_by_pure(mmt, fn(k, v) { return v })
check("max_by tie in map", has_key(mmt, max_tie))

// update-existing changes the answer
mm2["b"] = 0
eq("max_by after decrease", map_max_by_pure(mm2, fn(k, v) { return v }), "c")

// ════════════════════════════════════════════════════════════
// 4. map_count_by_pure — counter map from array
// ════════════════════════════════════════════════════════════
let words = ["cat", "cow", "dog", "car", "ant"]
let counts = map_count_by_pure(words, fn(w) { return w[0] })
eq("count_by c", counts["c"], 3)
eq("count_by d", counts["d"], 1)
eq("count_by a", counts["a"], 1)
eq("count_by size", map_size_pure(counts), 3)

// empty array
eq("count_by empty", map_size_pure(map_count_by_pure([], fn(x) { return x })), 0)

// single element
let cs = map_count_by_pure(["only"], fn(x) { return x })
eq("count_by single size", map_size_pure(cs), 1)
eq("count_by single val",  cs["only"], 1)

// all collide -> one bucket size n
let coll = map_count_by_pure([1, 1, 1, 1], fn(x) { return "k" })
eq("count_by all collide size", map_size_pure(coll), 1)
eq("count_by all collide val",  coll["k"], 4)

// missing-key path: first time key appears, branch triggers the
// "not has_key" init path; second time exercises update-existing.
let miss = map_count_by_pure([10, 20, 10], fn(x) { return to_string(x) })
eq("count_by update-existing", miss["10"], 2)
eq("count_by first-time",      miss["20"], 1)

// ordering preservation proxy: number of distinct keys == number
// of unique classifier outputs, regardless of iteration order
let uniq = map_count_by_pure([1, 2, 3, 1, 2, 3, 1], fn(x) { return to_string(x) })
eq("count_by distinct buckets", map_size_pure(uniq), 3)
eq("count_by distinct 1", uniq["1"], 3)

// ════════════════════════════════════════════════════════════
// 5. map_invert_multi_pure — swap with collision grouping
// ════════════════════════════════════════════════════════════
let im = #{"a": 1, "b": 1, "c": 2}
let inv = map_invert_multi_pure(im)
eq("invert_multi size",       map_size_pure(inv), 2)
eq("invert_multi 1-bucket",   len(inv["1"]), 2)
eq("invert_multi 2-bucket",   len(inv["2"]), 1)
check("invert_multi 2->c",    inv["2"][0] == "c")

// empty map
eq("invert_multi empty", map_size_pure(map_invert_multi_pure(#{})), 0)

// single entry
let inv_s = map_invert_multi_pure(#{"only": 99})
eq("invert_multi single size", map_size_pure(inv_s), 1)
eq("invert_multi single value len", len(inv_s["99"]), 1)

// no collisions: all buckets size 1
let inv_nc = map_invert_multi_pure(#{"a": 1, "b": 2, "c": 3})
eq("invert_multi no-collision size", map_size_pure(inv_nc), 3)
eq("invert_multi nc[1] len", len(inv_nc["1"]), 1)
eq("invert_multi nc[2] len", len(inv_nc["2"]), 1)
eq("invert_multi nc[3] len", len(inv_nc["3"]), 1)

// missing-key path exercised by collision grouping path
let ms = map_invert_multi_pure(#{"a": 1, "b": 1, "c": 1, "d": 1})
eq("invert_multi heavy collision size", map_size_pure(ms), 1)
eq("invert_multi heavy collision len",  len(ms["1"]), 4)

// update-existing via composition: count each bucket size
let inv_counts = map_count_by_pure(keys(inv), fn(k) { return k })
eq("invert+count 1 bucket", inv_counts["1"], 1)
eq("invert+count 2 bucket", inv_counts["2"], 1)

// ════════════════════════════════════════════════════════════
// 6. cross-op sanity
// ════════════════════════════════════════════════════════════
// partition + min_by + max_by on nums
let nums = #{"a": 10, "b": 20, "c": 30, "d": 40}
let split = map_partition_pure(nums, fn(k, v) { return v >= 30 })
eq("cross: hi-min",  map_min_by_pure(split[0], fn(k, v) { return v }), "c")
eq("cross: lo-max",  map_max_by_pure(split[1], fn(k, v) { return v }), "b")

// count_by then invert_multi
let letters = ["cat", "dog", "car", "bus", "bat"]
let lcounts = map_count_by_pure(letters, fn(w) { return w[0] })
let lgrouped = map_invert_multi_pure(lcounts)
// {"c":2,"d":1,"b":2} -> inv_multi -> {"2":[c,b], "1":[d]}
eq("cross: invert bucket 2 size", len(lgrouped["2"]), 2)
eq("cross: invert bucket 1 size", len(lgrouped["1"]), 1)

println("===========================================================")
println("  Results: " + to_string(pass) + " passed, " + to_string(fail) + " failed")
println("===========================================================")
if fail == 0 { println("ALL PASS") } else { println("SOME FAIL") }
