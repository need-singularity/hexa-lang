// ===================================================================
//  test_reward_model.hexa — Reward Model (Bradley-Terry) 검증
//
//  검증:
//    1. reward_forward 스칼라 출력
//    2. sigmoid 범위 [0,1]
//    3. bradley_terry_loss >= 0
//    4. BT loss: r_chosen > r_rejected → lower loss
//    5. preference pair loss 계산
//    6. batch BT loss 평균
//    7. reward accuracy 계산
//    8. rank_by_reward 정렬 검증
//    9. margin_loss = 0 when satisfied
//   10. training step reduces loss
//   11. BT loss symmetry: swap → higher loss
//   12. reward model 초기화 검증
//
//  실행: ./hexa self/test_reward_model.hexa
// ===================================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx(a, b, eps) { return fabs(a - b) < eps }

// ── Vector utils ────────────────────────────────────────────

fn rm_dot(a, b) {
    let n = len(a)
    let mut sum = 0.0
    let mut i = 0
    while i < n { sum = sum + a[i] * b[i]; i = i + 1 }
    return sum
}

fn rm_vec_zeros(dim) {
    let mut out = []
    let mut i = 0
    while i < dim { out = out + [0.0]; i = i + 1 }
    return out
}

fn rm_vec_scale(v, s) {
    let n = len(v)
    let mut out = []
    let mut i = 0
    while i < n { out = out + [v[i] * s]; i = i + 1 }
    return out
}

// ── Reward Model ────────────────────────────────────────────

struct RewardModel {
    hidden_dim: int,
    W: array,
    b: float
}

fn create_reward_model(hidden_dim) {
    let scale = 1.0 / sqrt(to_float(hidden_dim))
    let mut W = []
    let mut i = 0
    while i < hidden_dim {
        let val = sin(to_float(i * 137 + 7)) * scale
        W = W + [val]
        i = i + 1
    }
    return RewardModel { hidden_dim: hidden_dim, W: W, b: 0.0 }
}

fn reward_forward(model, hidden) {
    return rm_dot(model.W, hidden) + model.b
}

fn sigmoid(x) {
    if x > 20.0 { return 1.0 }
    if x < -20.0 { return 0.0 }
    return 1.0 / (1.0 + exp(0.0 - x))
}

fn bradley_terry_loss(r_chosen, r_rejected) {
    let diff = r_chosen - r_rejected
    if diff > 20.0 { return exp(0.0 - diff) }
    if diff < -20.0 { return 0.0 - diff }
    return log(1.0 + exp(0.0 - diff))
}

struct PreferencePair {
    chosen: array,
    rejected: array
}

fn create_preference_pair(chosen, rejected) {
    return PreferencePair { chosen: chosen, rejected: rejected }
}

fn preference_pair_loss(model, pair) {
    let r_c = reward_forward(model, pair.chosen)
    let r_r = reward_forward(model, pair.rejected)
    let loss = bradley_terry_loss(r_c, r_r)
    return [r_c, r_r, loss]
}

fn batch_bt_loss(model, pairs) {
    let n = len(pairs)
    let mut total = 0.0
    let mut i = 0
    while i < n {
        let result = preference_pair_loss(model, pairs[i])
        total = total + result[2]
        i = i + 1
    }
    return total / to_float(n)
}

fn reward_accuracy(model, pairs) {
    let n = len(pairs)
    let mut correct = 0
    let mut i = 0
    while i < n {
        let r_c = reward_forward(model, pairs[i].chosen)
        let r_r = reward_forward(model, pairs[i].rejected)
        if r_c > r_r { correct = correct + 1 }
        i = i + 1
    }
    return to_float(correct) / to_float(n)
}

fn rank_by_reward(model, hiddens) {
    let n = len(hiddens)
    let mut scores = []
    let mut indices = []
    let mut i = 0
    while i < n {
        scores = scores + [reward_forward(model, hiddens[i])]
        indices = indices + [i]
        i = i + 1
    }
    let mut changed = true
    while changed {
        changed = false
        let mut j = 0
        while j < n - 1 {
            if scores[j] < scores[j + 1] {
                let tmp_s = scores[j]
                scores[j] = scores[j + 1]
                scores[j + 1] = tmp_s
                let tmp_i = indices[j]
                indices[j] = indices[j + 1]
                indices[j + 1] = tmp_i
                changed = true
            }
            j = j + 1
        }
    }
    return indices
}

fn margin_loss(r_chosen, r_rejected, margin) {
    let diff = r_chosen - r_rejected
    let loss = margin - diff
    if loss < 0.0 { return 0.0 }
    return loss
}

fn _perturb_vec(v, idx, val) {
    let n = len(v)
    let mut out = []
    let mut i = 0
    while i < n {
        if i == idx { out = out + [val] } else { out = out + [v[i]] }
        i = i + 1
    }
    return out
}

fn reward_train_step(model, pairs, lr) {
    let dim = model.hidden_dim
    let eps = 1.0e-4
    let base_loss = batch_bt_loss(model, pairs)
    let mut new_W = []
    let mut i = 0
    while i < dim {
        let orig = model.W[i]
        let pert_W = _perturb_vec(model.W, i, orig + eps)
        let pert_model = RewardModel { hidden_dim: dim, W: pert_W, b: model.b }
        let loss_plus = batch_bt_loss(pert_model, pairs)
        let grad = (loss_plus - base_loss) / eps
        let updated = orig - lr * grad
        new_W = new_W + [updated]
        i = i + 1
    }
    let orig_b = model.b
    let model2 = RewardModel { hidden_dim: dim, W: model.W, b: orig_b + eps }
    let loss_b = batch_bt_loss(model2, pairs)
    let grad_b = (loss_b - base_loss) / eps
    let new_b = orig_b - lr * grad_b
    return RewardModel { hidden_dim: dim, W: new_W, b: new_b }
}

// ═══════════ TEST DATA ═══════════════════════════════════════

let dim = 4
let model = create_reward_model(dim)

// Chosen: high reward signal, rejected: low reward signal
let h_good = [1.0, 0.5, 0.3, 0.1]
let h_bad  = [-1.0, -0.5, -0.3, -0.1]
let h_mid  = [0.0, 0.0, 0.0, 0.0]

// ── T1: reward_forward returns scalar ───────────────────────
let r1 = reward_forward(model, h_good)
check("reward_forward finite scalar", fabs(r1) < 1.0e6)

// ── T2: sigmoid range [0, 1] ────────────────────────────────
check("sigmoid(0) = 0.5", approx(sigmoid(0.0), 0.5, 1.0e-9))
check("sigmoid(100) = 1.0", approx(sigmoid(100.0), 1.0, 1.0e-9))
check("sigmoid(-100) = 0.0", approx(sigmoid(-100.0), 0.0, 1.0e-9))

// ── T3: BT loss >= 0 ───────────────────────────────────────
let bt1 = bradley_terry_loss(2.0, 1.0)
check("BT loss >= 0", bt1 >= 0.0)

// ── T4: larger margin → lower BT loss ──────────────────────
let bt_big = bradley_terry_loss(5.0, 0.0)
let bt_small = bradley_terry_loss(1.0, 0.0)
check("larger margin -> lower BT loss", bt_big < bt_small)

// ── T5: preference pair loss ────────────────────────────────
let pair = create_preference_pair(h_good, h_bad)
let result = preference_pair_loss(model, pair)
check("pair loss >= 0", result[2] >= 0.0)

// ── T6: batch BT loss ──────────────────────────────────────
let pairs = [create_preference_pair(h_good, h_bad), create_preference_pair(h_good, h_mid)]
let bl = batch_bt_loss(model, pairs)
check("batch loss > 0", bl > 0.0)

// ── T7: reward accuracy ────────────────────────────────────
let r_good = reward_forward(model, h_good)
let r_bad = reward_forward(model, h_bad)
let known_pairs = [create_preference_pair(h_good, h_bad)]
let acc = reward_accuracy(model, known_pairs)
if r_good > r_bad {
    check("accuracy reflects correct order", approx(acc, 1.0, 1.0e-9))
} else {
    check("accuracy reflects correct order", approx(acc, 0.0, 1.0e-9))
}

// ── T8: rank_by_reward ──────────────────────────────────────
let hiddens = [h_bad, h_good, h_mid]
let ranked = rank_by_reward(model, hiddens)
let r_ranked_0 = reward_forward(model, hiddens[ranked[0]])
let r_ranked_2 = reward_forward(model, hiddens[ranked[2]])
check("rank: first >= last", r_ranked_0 >= r_ranked_2)

// ── T9: margin loss = 0 when satisfied ──────────────────────
let ml = margin_loss(5.0, 1.0, 2.0)
check("margin loss 0 when diff > margin", approx(ml, 0.0, 1.0e-9))

// ── T10: margin loss > 0 when not satisfied ─────────────────
let ml2 = margin_loss(1.0, 0.5, 2.0)
check("margin loss > 0 when diff < margin", ml2 > 0.0)

// ── T11: BT loss symmetry check ────────────────────────────
let bt_fwd = bradley_terry_loss(3.0, 1.0)
let bt_rev = bradley_terry_loss(1.0, 3.0)
check("BT swap gives higher loss", bt_rev > bt_fwd)

// ── T12: training reduces loss ──────────────────────────────
let train_model = create_reward_model(dim)
let train_pairs = [create_preference_pair(h_good, h_bad), create_preference_pair(h_good, h_mid)]
let loss_before = batch_bt_loss(train_model, train_pairs)
let trained = reward_train_step(train_model, train_pairs, 0.5)
let loss_after = batch_bt_loss(trained, train_pairs)
check("train step reduces loss", loss_after < loss_before)

// ── 결과 ────────────────────────────────────────────────────
println("")
println("=== Reward Model test summary ===")
println("PASS: " + to_string(pass_count))
println("FAIL: " + to_string(fail_count))
if fail_count == 0 {
    println("ALL GREEN — Reward Model OK")
}
println(to_string(pass_count) + " passed")
