// G43: Test for-in tuple destructuring
let pairs = [[1, "a"], [2, "b"], [3, "c"]]
let mut results = []
for (num, letter) in pairs {
    results = results.push(to_string(num) + ":" + letter)
}
if results[0] == "1:a" && results[1] == "2:b" && results[2] == "3:c" {
    println("PASS: for (a, b) in pairs — basic")
} else {
    println("FAIL: for (a, b) in pairs — basic, got: " + to_string(results))
}

// Test 3-element destructuring
let triples = [[10, 20, 30], [40, 50, 60]]
let mut sums = []
for (a, b, c) in triples {
    sums = sums.push(a + b + c)
}
if sums[0] == 60 && sums[1] == 150 {
    println("PASS: for (a, b, c) in triples")
} else {
    println("FAIL: for (a, b, c) in triples, got: " + to_string(sums))
}

// Test with break
let items = [[1, "x"], [2, "y"], [3, "z"]]
let mut found = ""
for (idx, val) in items {
    if idx == 2 {
        found = val
        break
    }
}
if found == "y" {
    println("PASS: for destruct with break")
} else {
    println("FAIL: for destruct with break, got: " + found)
}

// Test with continue
let data = [[1, true], [2, false], [3, true]]
let mut kept = []
for (n, flag) in data {
    if !flag { continue }
    kept = kept.push(n)
}
if len(kept) == 2 && kept[0] == 1 && kept[1] == 3 {
    println("PASS: for destruct with continue")
} else {
    println("FAIL: for destruct with continue, got: " + to_string(kept))
}

println("All for-destruct tests done")
