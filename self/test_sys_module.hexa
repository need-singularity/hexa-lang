// self/test_sys_module.hexa — S-NEW-SYS acceptance smoke
//
// Self-contained: inline the stdlib/sys.hexa surface (same pattern as
// other module tests) so this validates without needing I2-IMPORT-PATH.

let mut pass_count = 0
let mut total_count = 0
let mut failed_name = ""

fn check(name, cond) {
    total_count = total_count + 1
    if cond {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name)
    }
}

// ── inline mirror ──────────────────────────────────────────────────────

fn shell_quote(s) {
    let mut out = []
    out.push("'")
    let mut i = 0
    while i < len(s) {
        let c = s[i]
        if c == '\'' { out.push("'\"'\"'") } else { out.push(s.substring(i, i + 1)) }
        i = i + 1
    }
    out.push("'")
    return out.join("")
}

fn sys_argv() { return args() }
fn sys_platform() {
    let raw = exec("uname -s 2>/dev/null").trim()
    if raw == "Darwin" { return "darwin" }
    if raw == "Linux"  { return "linux"  }
    return raw
}
fn sys_env(name) {
    let v = exec("printenv " + shell_quote(name) + " 2>/dev/null")
    return v.trim()
}
fn sys_version() { return "hexa-lang 0.1.0 (mk2)" }

// ── tests ──────────────────────────────────────────────────────────────

fn main() {
    // argv: at minimum has the script path.
    let av = sys_argv()
    check("argv non-empty", len(av) >= 1)

    // platform: darwin or linux on supported hosts (CI may differ).
    let plat = sys_platform()
    check("platform darwin/linux", plat == "darwin" || plat == "linux")

    // env: PATH is virtually guaranteed to be set on any POSIX shell.
    let p = sys_env("PATH")
    check("env PATH non-empty", len(p) > 0)

    // env: a synthetic unset name returns "".
    let unset = sys_env("ZZZ_NEVER_SET_88K77")
    check("env missing returns empty", unset == "")

    // version: stable string check.
    let v = sys_version()
    check("version contains hexa-lang", v.contains("hexa-lang"))

    // shell_quote: round-trip with single quote inside.
    let q = shell_quote("a'b")
    check("shell_quote handles inner '", q == "'a'\"'\"'b'")

    println("PASS " + to_string(pass_count) + "/" + to_string(total_count))
    if failed_name != "" {
        println("first fail: " + failed_name)
        exit(1)
    }
}
