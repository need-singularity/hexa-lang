// self/attr_cli.hexa — @attr 통합 CLI
// usage:
//   hexa attr_cli.hexa                     — 카테고리별 attr 표
//   hexa attr_cli.hexa show <name>         — 단일 attr 상세
//   hexa attr_cli.hexa missing             — meta 미작성 attr 감지 (self-audit)
//   hexa attr_cli.hexa lint <file.hexa>    — 파일 전체 attr check() 실행
//   hexa attr_cli.hexa lint-names          — 모든 등록 attr 이름을 _naming 규칙 대조
//   hexa attr_cli.hexa audit <name>        — 신규 @attr 7-point 체크리스트 (file+registry×4+catalog+naming)

use "self/attrs/core"
use "self/attrs/policy"
use "self/attrs/forbid"
use "self/attrs/nonblock"
use "self/attrs/sealed"
use "self/attrs/generated"
use "self/attrs/_registry"

let _raw_args = args()
let mut cli_args = []
let mut _ai = 2
while _ai < len(_raw_args) {
    cli_args = cli_args.push(_raw_args[_ai])
    _ai = _ai + 1
}

fn print_header() {
    println("─ @attr 카탈로그 ─────────────────────────────────────")
}

fn print_all() {
    print_header()
    let cats = ["contract", "performance", "safety", "evolution",
                "rewrite", "memory", "ml", "hint", "meta", "execution"]
    let names = all_attr_names()
    for cat in cats {
        let mut rows = []
        for n in names {
            let m = meta_by_name(n)
            if m.category == cat { rows = rows.push(n) }
        }
        if len(rows) == 0 { continue }
        println("")
        println("[" + cat + "]")
        for n in rows {
            let m = meta_by_name(n)
            let impl_tag = if m.implemented { " ✓" } else { "" }
            let name_pad = _pad_right("@" + n, 14)
            println("  " + name_pad + impl_tag + "  " + m.purpose)
        }
    }
    println("")
    println("총 " + to_string(len(names)) + "개 — 상세: `hexa attr_cli.hexa show <name>`")
}

fn _pad_right(s: string, n: int) -> string {
    let mut r = s
    while len(r) < n { r = r + " " }
    return r
}

fn print_show(name: string) {
    let m = meta_by_name(name)
    if m.name == "" {
        eprintln("unknown @attr: " + name)
        let hint = _suggest_closest(name, all_attr_names())
        if hint != "" { eprintln("did you mean: @" + hint + " ?") }
        exit(1)
    }
    println("─ @" + m.name + " ─────────────────────────────────────")
    println("category    : " + m.category)
    println("purpose     : " + m.purpose)
    if m.cost_rule   != "" { println("cost_rule   : " + m.cost_rule) }
    if m.side_effect != "" { println("side_effect : " + m.side_effect) }
    if m.requires    != "" { println("requires    : " + m.requires) }
    if m.auto_test   != "" { println("auto_test   : " + m.auto_test) }
    if m.synonym_of  != "" { println("synonym_of  : @" + m.synonym_of) }
    println("implemented : " + if m.implemented { "yes" } else { "no (stub check)" })
    if m.example != "" {
        println("example     :")
        let elines = split(m.example, "\n")
        for el in elines { println("  " + el) }
    }
}

fn print_lint_names() {
    let viol = check_naming_all()
    let names = all_attr_names()
    if len(viol) == 0 {
        println("naming lint clean — " + to_string(len(names)) + " attrs pass _naming rules")
        return
    }
    println("naming lint FAIL — " + to_string(len(viol)) + " violation(s):")
    println("")
    for v in viol {
        let n = v[0]
        let r = v[1]
        println("  @" + n + " — " + r)
    }
    println("")
    println("rule SSOT: self/attrs/_naming.hexa")
    println("  form        : " + naming_form())
    println("  max length  : " + to_string(naming_length_max()))
    exit(1)
}

fn print_missing() {
    let names = all_attr_names()
    let mut missing = []
    for n in names {
        let m = meta_by_name(n)
        if m.purpose == "" || m.name == "" { missing = missing.push(n) }
    }
    if len(missing) == 0 {
        println("모든 " + to_string(len(names)) + "개 attr 에 meta 작성 완료")
    } else {
        println("meta 누락 attr " + to_string(len(missing)) + "개:")
        for n in missing { println("  @" + n) }
    }
}

// ── audit: 신규 @attr 7-point 체크리스트 ─────────────────
// SSOT for checklist: self/attrs/_naming.hexa naming_process() +
//                     (this file) 7 probes 를 강제 동기화

fn _audit_read(path: string) -> string {
    let mut raw = ""
    try { raw = to_string(read_file(path)) } catch e { return "" }
    return raw
}

fn _audit_exists(path: string) -> bool {
    // read_file 은 missing 에 throw 없이 "" 반환 — len 기반 판정
    // (empty attr 파일은 실무상 부재와 동치)
    return len(_audit_read(path)) > 0
}

fn _audit_grep(path: string, needle: string) -> bool {
    let raw = _audit_read(path)
    if raw == "" { return false }
    return raw.contains(needle)
}

fn _audit_in_names(name: string) -> bool {
    for n in all_attr_names() { if n == name { return true } }
    return false
}

fn _audit_mark(ok: bool) -> string {
    return if ok { "✓" } else { "✗" }
}

fn audit_attr(name: string) {
    println("─ @" + name + " audit (7-point) ─────────────────────")

    let reason = naming_reason(name)
    let p1 = reason == ""
    println("  [" + _audit_mark(p1) + "] 1. _naming       : "
        + (if p1 { "ok" } else { reason }))

    let attr_path = "self/attrs/" + name + ".hexa"
    let p2 = _audit_exists(attr_path)
    println("  [" + _audit_mark(p2) + "] 2. attr file     : " + attr_path)

    let reg_path = "self/attrs/_registry.hexa"
    let p3 = _audit_grep(reg_path, "use \"self/attrs/" + name + "\"")
    println("  [" + _audit_mark(p3) + "] 3. registry use  : use \"self/attrs/" + name + "\"")

    let p4 = _audit_in_names(name)
    println("  [" + _audit_mark(p4) + "] 4. all_attr_names: \"" + name + "\" in list")

    let p5 = _audit_grep(reg_path, "return meta_" + name + "()")
    println("  [" + _audit_mark(p5) + "] 5. meta_by_name  : return meta_" + name + "()")

    let p6 = _audit_grep(reg_path, "return check_" + name + "(source, lines)")
    println("  [" + _audit_mark(p6) + "] 6. check_by_name : return check_" + name + "(source, lines)")

    let cat_path = "shared/hexa-lang/attrs.json"
    let p7 = _audit_grep(cat_path, "\"" + name + "\":")
    println("  [" + _audit_mark(p7) + "] 7. catalog       : " + cat_path)

    let mut pass = 0
    if p1 { pass = pass + 1 }
    if p2 { pass = pass + 1 }
    if p3 { pass = pass + 1 }
    if p4 { pass = pass + 1 }
    if p5 { pass = pass + 1 }
    if p6 { pass = pass + 1 }
    if p7 { pass = pass + 1 }
    let fail = 7 - pass

    println("")
    println(to_string(pass) + "/7 pass, " + to_string(fail) + " fail")
    if fail > 0 {
        println("")
        println("fix order (self/attrs/_naming.hexa naming_process):")
        println("  · meta_<name>() + check_<name>() → self/attrs/<name>.hexa")
        println("  · use/names/meta_by_name/check_by_name → self/attrs/_registry.hexa")
        println("  · catalog entry → shared/hexa-lang/attrs.json")
    }
    return pass
}

// format 결정 — CLI flag (--json / --human) 우선, 없으면 env HEXA_ATTR_FMT, default=human
fn _lint_fmt_mode() -> string {
    for a in cli_args {
        if a == "--json" { return "json" }
        if a == "--human" { return "human" }
    }
    let mut env_mode = ""
    try { env_mode = env_var("HEXA_ATTR_FMT") } catch e { env_mode = "" }
    if env_mode == "json" { return "json" }
    return "human"
}

fn run_lint(path: string) {
    let mut source = ""
    try {
        source = to_string(read_file(path))
    } catch e {
        eprintln("error: cannot read " + path)
        exit(1)
    }
    let lines = split(source, "\n")
    let policy = parse_lint_header(lines)
    let used = attrs_used_in(lines)

    // readme 전용: 파일 경로를 env 로 전파해 find_readme_rules 가 md 위치 기반으로 탐색
    try { exec("true") } catch e {}
    let mut all_msgs = []
    for name in used {
        if name == "readme" {
            try { write_file("/tmp/.hexa_readme_lint_target", path) } catch e {}
        }
        let msgs = check_by_name(name, source, lines)
        for mm in msgs { all_msgs = all_msgs.push(mm) }
    }
    // unknown @xxx 힌트
    let unknowns = unknown_attrs_in(lines)
    for u in unknowns {
        let ln = to_int(u[0])
        let nm = u[1]
        let hint = u[2]
        let extra = if hint != "" { " — did you mean @" + hint + "?" } else { "" }
        all_msgs = all_msgs.push(mk_msg_k("unknown", "warn", path, ln,
            "unknown attr @" + nm + extra, "unknown_attr"))
    }

    let raw_final = apply_policy(all_msgs, policy)
    let fmt_mode = _lint_fmt_mode()

    // check 함수들이 source 인자로 **파일 내용**을 받는 경우가 있어 m.path 가 내용으로
    // 오염될 수 있음. attr_cli 레벨에서 실제 파일 경로로 균일화.
    let mut final_msgs = []
    for m in raw_final {
        let mut mm = m
        // path 가 비어있거나 내용 덩어리 (줄바꿈 포함) 이면 실제 path 로 덮어씀
        if mm.path == "" || mm.path.contains("\n") {
            mm.path = path
        }
        final_msgs = final_msgs.push(mm)
    }

    // exit code: error >= 1 → 1, warn only → 0, clean → 0
    let mut err_count = 0
    let mut warn_count = 0
    for m in final_msgs {
        if m.level == "error" { err_count = err_count + 1 }
        else if m.level == "warn" { warn_count = warn_count + 1 }
    }

    if fmt_mode == "json" {
        for m in final_msgs { println(fmt_msg_json(m)) }
        eprintln("summary: errors=" + to_string(err_count)
                 + " warnings=" + to_string(warn_count)
                 + " scanned=" + to_string(len(used))
                 + " file=" + path)
        if err_count > 0 { exit(1) }
        return
    }

    // human 포맷
    if len(final_msgs) == 0 {
        println(path + " -- clean (" + to_string(len(used)) + " attrs scanned)")
        return
    }
    for m in final_msgs {
        println(fmt_msg_human(m))
    }
    println("")
    println(to_string(err_count) + " error(s), " + to_string(warn_count) + " warning(s)")
    if err_count > 0 { exit(1) }
}

// ── policy: .hexa-attrs walk up + forbid/allow 매칭 ─────
fn _dirname(path: string) {
    return to_string(exec("dirname '" + path + "'")).trim()
}

fn _find_project_attrs(target_path: string) {
    // target_path 가 디렉토리면 자기 자신부터, 파일이면 dirname 부터
    let mut dir = target_path
    let is_dir = to_string(exec("test -d '" + target_path + "' && echo y || echo n")).trim()
    if is_dir != "y" {
        dir = _dirname(target_path)
    }
    let mut depth = 0
    while depth < 20 {
        let candidate = dir + "/.hexa-attrs"
        let exists = to_string(exec("test -f '" + candidate + "' && echo y || echo n")).trim()
        if exists == "y" { return candidate }
        if dir == "/" || dir == "" || dir == "." { return "" }
        let parent = _dirname(dir)
        if parent == dir { return "" }
        dir = parent
        depth = depth + 1
    }
    return ""
}

fn _parse_attrs_file(path: string) {
    let mut forbids = []
    let mut allows = []
    let mut nonblocks = []
    let mut seals = []
    let mut raw = ""
    try {
        raw = to_string(read_file(path))
    } catch e { return [forbids, allows, nonblocks, seals] }
    let lines = split(raw, "\n")
    for line in lines {
        let t = line.trim()
        if t == "" { continue }
        if t.starts_with("#") { continue }
        let eq = t.index_of("=")
        if eq < 0 { continue }
        let key = t.substring(0, eq).trim()
        let value = t.substring(eq + 1, len(t)).trim()
        let toks = split(value, ",")
        let mut list = []
        for tok in toks {
            let tt = tok.trim()
            if tt != "" { list = list.push(tt) }
        }
        if key == "forbid" { forbids = list }
        else if key == "allow" { allows = list }
        else if key == "nonblock" { nonblocks = list }
        else if key == "seal" { seals = list }
    }
    return [forbids, allows, nonblocks, seals]
}

// .hexa-attrs seal 토큰 → 실제 파일 경로 리스트 (glob 지원)
// 토큰이 `*` 포함하면 find, 아니면 literal path (존재 검증)
fn _expand_seal_tokens(root: string, tokens) {
    let mut paths = []
    for tok in tokens {
        if tok.contains("*") {
            // shell glob via find — 루트 기준 상대 경로
            let cmd = "cd '" + root + "' && find . -type f -path './" + tok + "' 2>/dev/null"
            let out = to_string(exec(cmd)).trim()
            if out != "" {
                for p in split(out, "\n") {
                    let pt = p.trim()
                    if pt == "" { continue }
                    let rel = if pt.starts_with("./") { pt.substring(2, len(pt)) } else { pt }
                    paths = paths.push(root + "/" + rel)
                }
            }
        } else {
            let abs = root + "/" + tok
            let exists = to_string(exec("test -f '" + abs + "' && echo y || echo n")).trim()
            if exists == "y" { paths = paths.push(abs) }
        }
    }
    return paths
}

// allow = ["hook:shared/harness/*", "skill:experiments/**"]
// target_path 가 해당 scope 에 포함되면 true
fn _allow_exempts(allows, token: string, target_path: string) {
    for a in allows {
        let colon = a.index_of(":")
        let mut a_token = a
        let mut a_scope = ""
        if colon >= 0 {
            a_token = a.substring(0, colon).trim()
            a_scope = a.substring(colon + 1, len(a)).trim()
        }
        if a_token != token { continue }
        if a_scope == "" { return true }   // scope 없으면 전역 면제
        // scope 는 glob-like: 단순 prefix 매칭 ( /* /** 무시하고 prefix 만 )
        let mut prefix = a_scope
        if prefix.ends_with("/**") { prefix = prefix.substring(0, len(prefix) - 3) }
        else if prefix.ends_with("/*") { prefix = prefix.substring(0, len(prefix) - 2) }
        if target_path.contains(prefix) { return true }
    }
    return false
}

fn run_policy(target_path: string) {
    let attrs_path = _find_project_attrs(target_path)
    if attrs_path == "" {
        // 정책 파일 없으면 조용히 통과
        exit(0)
    }
    let parsed = _parse_attrs_file(attrs_path)
    let forbids = parsed[0]
    let allows = parsed[1]
    if len(forbids) == 0 { exit(0) }

    let mut violations = []
    for token in forbids {
        if _allow_exempts(allows, token, target_path) { continue }
        let hits = forbid_match(token, target_path)
        if len(hits) > 0 {
            violations = violations.push([token, hits])
        }
    }
    if len(violations) == 0 { exit(0) }

    // 유도 메시지
    println("REJECT: .hexa-attrs forbid 위반")
    println("")
    println("정책 파일 : " + attrs_path)
    println("대상 경로 : " + target_path)
    println("")
    for v in violations {
        let token = v[0]
        let hits = v[1]
        println("─ @forbid(" + token + ") ─────────────")
        println("  탐지 패턴 :")
        for h in hits {
            println("    - " + h[0] + ": " + h[1])
        }
        println("  사유      : " + _forbid_doc_for(token))
        println("  대체 경로 :")
        let alts = _forbid_alternates_for(token)
        let mut idx = 0
        for a in alts {
            idx = idx + 1
            println("    " + to_string(idx) + ". " + a)
        }
        println("  우회 토큰 : " + _forbid_bypass_for(token))
        println("")
    }
    exit(1)
}

// ── compile: .hexa-attrs → native config 코드젠 ─────────
// 각 forbid token 에 대해 compile_claude_permissions_for() + compile_git_precommit_for()
// 호출해 target 파일에 누적 emit. @generated 헤더 자동 주입.

fn _project_root_from(target_path: string) {
    let attrs = _find_project_attrs(target_path)
    if attrs == "" { return "" }
    return _dirname(attrs)
}

fn _ensure_dir(path: string) {
    try { exec("mkdir -p '" + path + "'") } catch e {}
}

fn _write_generated(path: string, source: string, comment_prefix: string, body: string) {
    let header = generated_header(source, comment_prefix)
    let content = header + "\n" + body + "\n"
    try {
        write_file(path, content)
    } catch e {
        eprintln("error: cannot write " + path)
    }
}

fn compile_claude_permissions_deny(root: string, forbids) {
    let mut entries = []
    for token in forbids {
        let token_entries = compile_claude_permissions_for(token)
        for e in token_entries {
            entries = entries.push("    \"" + e + "\"")
        }
    }
    if len(entries) == 0 { return }
    let body = "{\n" +
               "  \"_source\": \".hexa-attrs\",\n" +
               "  \"_merge_into\": \".claude/settings.json#/permissions/deny\",\n" +
               "  \"permissions_deny\": [\n" +
               join(entries, ",\n") + "\n" +
               "  ]\n" +
               "}"
    let out_dir = root + "/.attr-generated"
    _ensure_dir(out_dir)
    let out_path = out_dir + "/claude_permissions_deny.json"
    _write_generated(out_path, ".hexa-attrs", "//", body)
    println("emitted: " + out_path + " (" + to_string(len(entries)) + " deny entries)")
}

fn compile_git_precommit(root: string, forbids) {
    let mut stanzas = []
    for token in forbids {
        let s = compile_git_precommit_for(token)
        if s != "" { stanzas = stanzas.push("# [@forbid(" + token + ")]\n" + s) }
    }
    if len(stanzas) == 0 { return }
    let body = "#!/bin/bash\nset -e\n\n" + join(stanzas, "\n\n") + "\n"
    let out_dir = root + "/.attr-generated"
    _ensure_dir(out_dir)
    let out_path = out_dir + "/pre-commit.sh"
    _write_generated(out_path, ".hexa-attrs", "#", body)
    try { exec("chmod +x '" + out_path + "'") } catch e {}
    println("emitted: " + out_path + " (" + to_string(len(stanzas)) + " stanzas)")
}

fn compile_nonblock(root: string, nonblocks) {
    if len(nonblocks) == 0 { return }
    let hook_body = compile_nonblock_pretool_hook(nonblocks)
    let out_dir = root + "/.attr-generated"
    _ensure_dir(out_dir)
    let hook_path = out_dir + "/pre_tool_nonblock.sh"
    _write_generated(hook_path, ".hexa-attrs", "#", hook_body)
    try { exec("chmod +x '" + hook_path + "'") } catch e {}
    println("emitted: " + hook_path + " (" + to_string(len(nonblocks)) + " tool guards)")

    let entry = compile_nonblock_settings_entry(nonblocks)
    let entry_path = out_dir + "/claude_pretool_nonblock.json"
    _write_generated(entry_path, ".hexa-attrs", "//", entry)
    println("emitted: " + entry_path + " (PreToolUse merge entry)")
}

fn run_compile(target: string) {
    // 현재 작업 디렉토리 기준 (env PWD 우선, 없으면 exec pwd)
    let mut pwd = env("PWD")
    if pwd == "" { pwd = to_string(exec("pwd")).trim() }
    let attrs_path = _find_project_attrs(pwd)
    if attrs_path == "" {
        eprintln("error: no .hexa-attrs found upward from " + pwd)
        exit(1)
    }
    let root = _dirname(attrs_path)
    let parsed = _parse_attrs_file(attrs_path)
    let forbids = parsed[0]
    let nonblocks = if len(parsed) > 2 { parsed[2] } else { [] }
    if len(forbids) == 0 && len(nonblocks) == 0 {
        println("no forbid/nonblock tokens in " + attrs_path + " — nothing to compile")
        exit(0)
    }

    println("─ attr_cli compile ─────────────────────────────────")
    println("source    : " + attrs_path)
    println("root      : " + root)
    println("forbids   : " + join(forbids, ", "))
    println("nonblocks : " + join(nonblocks, ", "))
    println("")

    let mut do_claude = false
    let mut do_git = false
    let mut do_nonblock = false
    if target == "" || target == "all" { do_claude = true; do_git = true; do_nonblock = true }
    else if target == "claude"   { do_claude = true }
    else if target == "git"      { do_git = true }
    else if target == "nonblock" { do_nonblock = true }
    else {
        eprintln("unknown target: " + target + " (valid: claude|git|nonblock|all)")
        exit(1)
    }

    if do_claude   { compile_claude_permissions_deny(root, forbids) }
    if do_git      { compile_git_precommit(root, forbids) }
    if do_nonblock { compile_nonblock(root, nonblocks) }

    println("")
    println("done — manual step:")
    println("  (1) review " + root + "/.attr-generated/")
    println("  (2) merge into target natives:")
    println("      - .claude/settings.json permissions.deny")
    println("      - .claude/settings.json hooks.PreToolUse (nonblock)")
    println("      - .git/hooks/pre-commit (chmod +x)")
}

// ── seal / unseal / seal-status — OS-level raw gate ─────────
// .hexa-attrs `seal = ...` 토큰 → fs_seal/fs_unseal 적용 (hook 없음)
// 외부 의존 = chmod/chattr/chflags 표준 OS 유틸 (hexa-native 자체해결).

fn _seal_setup(target_path: string) {
    let attrs_path = _find_project_attrs(target_path)
    if attrs_path == "" {
        eprintln("error: no .hexa-attrs found upward from " + target_path)
        exit(1)
    }
    let root = _dirname(attrs_path)
    let parsed = _parse_attrs_file(attrs_path)
    let seals = if len(parsed) > 3 { parsed[3] } else { [] }
    if len(seals) == 0 {
        println("no `seal = ...` tokens in " + attrs_path + " — nothing to do")
        exit(0)
    }
    return [root, seals, attrs_path]
}

fn run_seal(target_path: string) {
    let ctx = _seal_setup(target_path)
    let root = ctx[0]
    let seals = ctx[1]
    let attrs_path = ctx[2]
    let paths = _expand_seal_tokens(root, seals)

    println("─ attr_cli seal — OS raw gate 적용 ─────────────────")
    println("source : " + attrs_path)
    println("tokens : " + join(seals, ", "))
    println("files  : " + to_string(len(paths)))
    println("")

    let mut ok = 0
    for p in paths {
        fs_seal(p)
        let sealed = fs_is_sealed(p)
        if sealed {
            println("  ✔ sealed  " + p)
            ok = ok + 1
        } else {
            println("  ✗ failed  " + p + " (mode check didn't confirm)")
        }
    }
    println("")
    println("done — " + to_string(ok) + "/" + to_string(len(paths)) + " files sealed")
    println("      Edit/Write tool → OS EACCES (hook 0, settings 0)")
}

fn run_unseal(target_path: string) {
    let ctx = _seal_setup(target_path)
    let root = ctx[0]
    let seals = ctx[1]
    let paths = _expand_seal_tokens(root, seals)

    println("─ attr_cli unseal — seal 해제 ─────────────────────")
    println("files  : " + to_string(len(paths)))
    println("")

    for p in paths {
        fs_unseal(p)
        let sealed = fs_is_sealed(p)
        if !sealed {
            println("  ✔ unsealed  " + p)
        } else {
            println("  ✗ still sealed  " + p + " (chattr/chflags 권한 부족?)")
        }
    }
}

fn run_seal_status(target_path: string) {
    let ctx = _seal_setup(target_path)
    let root = ctx[0]
    let seals = ctx[1]
    let paths = _expand_seal_tokens(root, seals)

    println("─ attr_cli seal-status ───────────────────────────")
    println("")
    let mut sealed_n = 0
    let mut open_n = 0
    for p in paths {
        if fs_is_sealed(p) {
            println("  [SEALED] " + p)
            sealed_n = sealed_n + 1
        } else {
            println("  [OPEN  ] " + p)
            open_n = open_n + 1
        }
    }
    println("")
    println("total=" + to_string(len(paths)) +
            "  sealed=" + to_string(sealed_n) +
            "  open=" + to_string(open_n))
    if open_n > 0 { exit(1) }
    exit(0)
}

// ── CLI dispatch ──────────────────────────────────────────
if len(cli_args) == 0 {
    print_all()
    exit(0)
}

let sub = cli_args[0]

if sub == "show" {
    if len(cli_args) < 2 { eprintln("usage: show <name>"); exit(1) }
    let mut n = cli_args[1]
    if n.starts_with("@") { n = n.substring(1, len(n)) }
    print_show(n)
    exit(0)
}

if sub == "missing" {
    print_missing()
    exit(0)
}

if sub == "audit" {
    if len(cli_args) < 2 { eprintln("usage: audit <name>"); exit(1) }
    let mut an = cli_args[1]
    if an.starts_with("@") { an = an.substring(1, len(an)) }
    let audit_pass = audit_attr(an)
    if audit_pass < 7 { exit(1) }
    exit(0)
}

if sub == "lint-names" {
    print_lint_names()
    exit(0)
}

if sub == "lint" {
    if len(cli_args) < 2 { eprintln("usage: lint <file.hexa>"); exit(1) }
    run_lint(cli_args[1])
    exit(0)
}

if sub == "policy" || sub == "precheck" {
    if len(cli_args) < 2 { eprintln("usage: policy <target_path>"); exit(1) }
    run_policy(cli_args[1])
    exit(0)
}

if sub == "compile" {
    let mut t = "all"
    if len(cli_args) >= 2 {
        let a2 = cli_args[1]
        if a2.starts_with("--target=") { t = a2.substring(9, len(a2)) }
        else { t = a2 }
    }
    run_compile(t)
    exit(0)
}

if sub == "seal" {
    let mut pwd = env("PWD")
    if pwd == "" { pwd = to_string(exec("pwd")).trim() }
    run_seal(pwd)
    exit(0)
}

if sub == "unseal" {
    let mut pwd = env("PWD")
    if pwd == "" { pwd = to_string(exec("pwd")).trim() }
    run_unseal(pwd)
    exit(0)
}

if sub == "seal-status" {
    let mut pwd = env("PWD")
    if pwd == "" { pwd = to_string(exec("pwd")).trim() }
    run_seal_status(pwd)
    exit(0)
}

// 직접 이름 전달 시 show 대체 (예: `hexa attr_cli.hexa pure`)
let mut n2 = sub
if n2.starts_with("@") { n2 = n2.substring(1, len(n2)) }
let m = meta_by_name(n2)
if m.name != "" { print_show(n2); exit(0) }

eprintln("usage:")
eprintln("  hexa attr_cli.hexa")
eprintln("  hexa attr_cli.hexa show <name>")
eprintln("  hexa attr_cli.hexa missing")
eprintln("  hexa attr_cli.hexa audit <name>")
eprintln("  hexa attr_cli.hexa lint <file.hexa>")
eprintln("  hexa attr_cli.hexa lint-names")
eprintln("  hexa attr_cli.hexa compile [claude|git|nonblock|all]")
eprintln("  hexa attr_cli.hexa seal          — .hexa-attrs seal= 파일 전부 OS-level 차단")
eprintln("  hexa attr_cli.hexa unseal        — 차단 해제")
eprintln("  hexa attr_cli.hexa seal-status   — 현재 seal 상태 리포트")
exit(1)
