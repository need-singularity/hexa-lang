// self/attr_cli.hexa — @attr 통합 CLI
// usage:
//   hexa attr_cli.hexa                     — 카테고리별 attr 표
//   hexa attr_cli.hexa show <name>         — 단일 attr 상세
//   hexa attr_cli.hexa missing             — meta 미작성 attr 감지 (self-audit)
//   hexa attr_cli.hexa lint <file.hexa>    — 파일 전체 attr check() 실행

use "self/attrs/core"
use "self/attrs/policy"
use "self/attrs/_registry"

let _raw_args = args()
let mut cli_args = []
let mut _ai = 2
while _ai < len(_raw_args) {
    cli_args = cli_args.push(_raw_args[_ai])
    _ai = _ai + 1
}

fn print_header() {
    println("─ @attr 카탈로그 ─────────────────────────────────────")
}

fn print_all() {
    print_header()
    let cats = ["contract", "performance", "safety", "evolution",
                "rewrite", "memory", "ml", "hint", "meta", "execution"]
    let names = all_attr_names()
    for cat in cats {
        let mut rows = []
        for n in names {
            let m = meta_by_name(n)
            if m.category == cat { rows = rows.push(n) }
        }
        if len(rows) == 0 { continue }
        println("")
        println("[" + cat + "]")
        for n in rows {
            let m = meta_by_name(n)
            let impl_tag = if m.implemented { " ✓" } else { "" }
            let name_pad = _pad_right("@" + n, 14)
            println("  " + name_pad + impl_tag + "  " + m.purpose)
        }
    }
    println("")
    println("총 " + to_string(len(names)) + "개 — 상세: `hexa attr_cli.hexa show <name>`")
}

fn _pad_right(s: string, n: int) -> string {
    let mut r = s
    while len(r) < n { r = r + " " }
    return r
}

fn print_show(name: string) {
    let m = meta_by_name(name)
    if m.name == "" {
        eprintln("unknown @attr: " + name)
        let hint = _suggest_closest(name, all_attr_names())
        if hint != "" { eprintln("did you mean: @" + hint + " ?") }
        exit(1)
    }
    println("─ @" + m.name + " ─────────────────────────────────────")
    println("category    : " + m.category)
    println("purpose     : " + m.purpose)
    if m.cost_rule   != "" { println("cost_rule   : " + m.cost_rule) }
    if m.side_effect != "" { println("side_effect : " + m.side_effect) }
    if m.requires    != "" { println("requires    : " + m.requires) }
    if m.auto_test   != "" { println("auto_test   : " + m.auto_test) }
    if m.synonym_of  != "" { println("synonym_of  : @" + m.synonym_of) }
    println("implemented : " + if m.implemented { "yes" } else { "no (stub check)" })
    if m.example != "" {
        println("example     :")
        let elines = split(m.example, "\n")
        for el in elines { println("  " + el) }
    }
}

fn print_missing() {
    let names = all_attr_names()
    let mut missing = []
    for n in names {
        let m = meta_by_name(n)
        if m.purpose == "" || m.name == "" { missing = missing.push(n) }
    }
    if len(missing) == 0 {
        println("모든 " + to_string(len(names)) + "개 attr 에 meta 작성 완료")
    } else {
        println("meta 누락 attr " + to_string(len(missing)) + "개:")
        for n in missing { println("  @" + n) }
    }
}

fn run_lint(path: string) {
    let mut source = ""
    try {
        source = to_string(read_file(path))
    } catch e {
        eprintln("error: cannot read " + path)
        exit(1)
    }
    let lines = split(source, "\n")
    let policy = parse_lint_header(lines)
    let used = attrs_used_in(lines)

    let mut all_msgs = []
    for name in used {
        let msgs = check_by_name(name, source, lines)
        for mm in msgs { all_msgs = all_msgs.push(mm) }
    }
    // unknown @xxx 힌트
    let unknowns = unknown_attrs_in(lines)
    for u in unknowns {
        let ln = to_int(u[0])
        let nm = u[1]
        let hint = u[2]
        let extra = if hint != "" { " — did you mean @" + hint + "?" } else { "" }
        all_msgs = all_msgs.push(mk_msg("unknown", "warn", ln,
            "unknown attr @" + nm + extra))
    }

    let final_msgs = apply_policy(all_msgs, policy)

    if len(final_msgs) == 0 {
        println(path + " -- clean (" + to_string(len(used)) + " attrs scanned)")
        return
    }
    let mut err_count = 0
    let mut warn_count = 0
    for m in final_msgs {
        println(path + ": " + fmt_msg(m))
        if m.level == "error" { err_count = err_count + 1 }
        else { warn_count = warn_count + 1 }
    }
    println("")
    println(to_string(err_count) + " error(s), " + to_string(warn_count) + " warning(s)")
    if err_count > 0 { exit(1) }
}

// ── policy: .hexa-attrs walk up + forbid/allow 매칭 ─────
fn _dirname(path: string) {
    return to_string(exec("dirname '" + path + "'")).trim()
}

fn _find_project_attrs(target_path: string) {
    let mut dir = target_path
    // 디렉토리인지 파일인지 모르니 dirname 시작
    dir = _dirname(dir)
    let mut depth = 0
    while depth < 20 {
        let candidate = dir + "/.hexa-attrs"
        let exists = to_string(exec("test -f '" + candidate + "' && echo y || echo n")).trim()
        if exists == "y" { return candidate }
        if dir == "/" || dir == "" || dir == "." { return "" }
        let parent = _dirname(dir)
        if parent == dir { return "" }
        dir = parent
        depth = depth + 1
    }
    return ""
}

fn _parse_attrs_file(path: string) {
    let mut forbids = []
    let mut allows = []
    let mut raw = ""
    try {
        raw = to_string(read_file(path))
    } catch e { return [forbids, allows] }
    let lines = split(raw, "\n")
    for line in lines {
        let t = trim(line)
        if t == "" { continue }
        if starts_with(t, "#") { continue }
        let eq = t.index_of("=")
        if eq < 0 { continue }
        let key = trim(t.substring(0, eq))
        let value = trim(t.substring(eq + 1, len(t)))
        let toks = split(value, ",")
        let mut list = []
        for tok in toks {
            let tt = trim(tok)
            if tt != "" { list = list.push(tt) }
        }
        if key == "forbid" { forbids = list }
        else if key == "allow" { allows = list }
    }
    return [forbids, allows]
}

// allow = ["hook:shared/harness/*", "skill:experiments/**"]
// target_path 가 해당 scope 에 포함되면 true
fn _allow_exempts(allows, token: string, target_path: string) {
    for a in allows {
        let colon = a.index_of(":")
        let mut a_token = a
        let mut a_scope = ""
        if colon >= 0 {
            a_token = trim(a.substring(0, colon))
            a_scope = trim(a.substring(colon + 1, len(a)))
        }
        if a_token != token { continue }
        if a_scope == "" { return true }   // scope 없으면 전역 면제
        // scope 는 glob-like: 단순 prefix 매칭 ( /* /** 무시하고 prefix 만 )
        let mut prefix = a_scope
        if ends_with(prefix, "/**") { prefix = prefix.substring(0, len(prefix) - 3) }
        else if ends_with(prefix, "/*") { prefix = prefix.substring(0, len(prefix) - 2) }
        if contains(target_path, prefix) { return true }
    }
    return false
}

fn run_policy(target_path: string) {
    let attrs_path = _find_project_attrs(target_path)
    if attrs_path == "" {
        // 정책 파일 없으면 조용히 통과
        exit(0)
    }
    let parsed = _parse_attrs_file(attrs_path)
    let forbids = parsed[0]
    let allows = parsed[1]
    if len(forbids) == 0 { exit(0) }

    let mut violations = []
    for token in forbids {
        if _allow_exempts(allows, token, target_path) { continue }
        let hits = forbid_match(token, target_path)
        if len(hits) > 0 {
            violations = violations.push([token, hits])
        }
    }
    if len(violations) == 0 { exit(0) }

    // 유도 메시지
    println("REJECT: .hexa-attrs forbid 위반")
    println("")
    println("정책 파일 : " + attrs_path)
    println("대상 경로 : " + target_path)
    println("")
    for v in violations {
        let token = v[0]
        let hits = v[1]
        println("─ @forbid(" + token + ") ─────────────")
        println("  탐지 패턴 :")
        for h in hits {
            println("    - " + h[0] + ": " + h[1])
        }
        println("  사유      : " + _forbid_doc_for(token))
        println("  대체 경로 :")
        let alts = _forbid_alternates_for(token)
        let mut idx = 0
        for a in alts {
            idx = idx + 1
            println("    " + to_string(idx) + ". " + a)
        }
        println("  우회 토큰 : " + _forbid_bypass_for(token))
        println("")
    }
    exit(1)
}

// ── CLI dispatch ──────────────────────────────────────────
if len(cli_args) == 0 {
    print_all()
    exit(0)
}

let sub = cli_args[0]

if sub == "show" {
    if len(cli_args) < 2 { eprintln("usage: show <name>"); exit(1) }
    let mut n = cli_args[1]
    if starts_with(n, "@") { n = n.substring(1, len(n)) }
    print_show(n)
    exit(0)
}

if sub == "missing" {
    print_missing()
    exit(0)
}

if sub == "lint" {
    if len(cli_args) < 2 { eprintln("usage: lint <file.hexa>"); exit(1) }
    run_lint(cli_args[1])
    exit(0)
}

if sub == "policy" || sub == "precheck" {
    if len(cli_args) < 2 { eprintln("usage: policy <target_path>"); exit(1) }
    run_policy(cli_args[1])
    exit(0)
}

// 직접 이름 전달 시 show 대체 (예: `hexa attr_cli.hexa pure`)
let mut n2 = sub
if starts_with(n2, "@") { n2 = n2.substring(1, len(n2)) }
let m = meta_by_name(n2)
if m.name != "" { print_show(n2); exit(0) }

eprintln("usage:")
eprintln("  hexa attr_cli.hexa")
eprintln("  hexa attr_cli.hexa show <name>")
eprintln("  hexa attr_cli.hexa missing")
eprintln("  hexa attr_cli.hexa lint <file.hexa>")
exit(1)
