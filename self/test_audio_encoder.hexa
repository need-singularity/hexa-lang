check("T16 stft_frame returns 2 arrays", len(frame_ri) == 2)
check("T16b re length = n_fft/2+1", len(frame_ri[0]) == 9)

// ═══════════════════════════════════════════════════════════════
//  T17: stft output shape correct
// ═══════════════════════════════════════════════════════════════
let test_sig17 = make_sine_wave(160, 440.0, 16000)
