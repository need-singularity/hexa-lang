// ═══════════════════════════════════════════════════════════════
//  T24: conv1d output shape correct
// ═══════════════════════════════════════════════════════════════
// input: [10 frames, 4 channels], kernel=3, stride=1, out_ch=8
let conv_in = ae_zeros_2d(10, 4)
let mut i = 0

while i < 10 {
    let mut j = 0

    while j < 4 {
        conv_in[i][j] = to_float(i * 4 + j) * 0.1
    }
}
let w24 = ae_init_weights(3 * 4 * 8, 999)
let b24 = ae_zeros(8)
let conv_out24 = ae_conv1d(conv_in, 3, 4, 8, 1, w24, b24)
let expected_out_frames = (10 - 3) / 1 + 1
check("T24 conv1d out frames = 8", len(conv_out24) == expected_out_frames)
check("T24b conv1d out channels = 8", len(conv_out24[0]) == 8)

// ═══════════════════════════════════════════════════════════════
//  T25: conv frontend output has d_model channels
// ═══════════════════════════════════════════════════════════════
// use small log_mel: [20 frames, 8 mels]
let lm25 = ae_zeros_2d(20, 8)
let mut f = 0

while f < 20 {
    let mut m = 0

    while m < 8 {
        lm25[f][m] = to_float(f * 8 + m) * 0.01
    }
}
let d_model_25 = 16
let frontend_out = ae_conv_frontend(lm25, 8, d_model_25)
check("T25 conv frontend out channels = d_model", len(frontend_out[0]) == d_model_25)
check("T25b conv frontend out frames > 0", len(frontend_out) > 0)

// ═══════════════════════════════════════════════════════════════
//  T26: sinusoidal PE shape correct
// ═══════════════════════════════════════════════════════════════
let pe26 = ae_sinusoidal_pe(10, 8)
check("T26 PE rows = max_len", len(pe26) == 10)
check("T26b PE cols = d_model", len(pe26[0]) == 8)

// ═══════════════════════════════════════════════════════════════
//  T27: sinusoidal PE varies across positions
// ═══════════════════════════════════════════════════════════════
let mut pe_differs = false
let mut j = 0

while j < 8 {
    if t_abs(pe26[0][j] - pe26[5][j]) > 0.001 {
        pe_differs = true
    }
}
check("T27 PE differs across positions", pe_differs)

// ═══════════════════════════════════════════════════════════════
//  T28: layer norm zero mean
// ═══════════════════════════════════════════════════════════════
let v28 = [1.0, 3.0, 5.0, 7.0]
let ln28 = ae_layer_norm(v28, 1.0e-5)
let mut mean28 = 0.0
let mut i = 0

while i < len(ln28) { mean28 = mean28 + ln28[i] }
mean28 = mean28 / to_float(len(ln28))
check("T28 layer norm mean ~ 0", t_abs(mean28) < 0.01)

// ═══════════════════════════════════════════════════════════════
//  T29: layer norm unit variance
// ═══════════════════════════════════════════════════════════════
let mut var29 = 0.0
let mut i = 0

while i < len(ln28) {
    var29 = var29 + (ln28[i] - mean28) * (ln28[i] - mean28)
}
var29 = var29 / to_float(len(ln28))
check("T29 layer norm variance ~ 1", t_abs(var29 - 1.0) < 0.1)

// ═══════════════════════════════════════════════════════════════
//  T30: softmax sums to 1
// ═══════════════════════════════════════════════════════════════
let logits30 = [1.0, 2.0, 3.0, 0.5]
let sm30 = ae_softmax(logits30)
let mut sm_sum = 0.0
let mut i = 0

while i < len(sm30) { sm_sum = sm_sum + sm30[i] }
check("T30 softmax sums to 1", approx(sm_sum, 1.0, 0.001))

// ═══════════════════════════════════════════════════════════════
//  T31: encoder block preserves shape
// ═══════════════════════════════════════════════════════════════
let d31 = 8
let seq31 = 4
let x31 = ae_zeros_2d(seq31, d31)
let mut i = 0

while i < seq31 {
    let mut j = 0

    while j < d31 {
        x31[i][j] = to_float(i * d31 + j) * 0.01
    }
}
let enc_block_out = ae_encoder_block(x31, d31, 2, 16)
check("T31 encoder block rows preserved", len(enc_block_out) == seq31)
check("T31b encoder block cols preserved", len(enc_block_out[0]) == d31)

// ═══════════════════════════════════════════════════════════════
//  T32: encoder stacked layers preserves shape
// ═══════════════════════════════════════════════════════════════
let enc32 = ae_encoder(x31, 2, d31, 2, 16)
check("T32 encoder rows preserved", len(enc32) == seq31)
check("T32b encoder cols preserved", len(enc32[0]) == d31)

// ═══════════════════════════════════════════════════════════════
//  T33: projection changes dimension
// ═══════════════════════════════════════════════════════════════
let proj33 = ae_project(x31, d31, 4)
check("T33 projection rows preserved", len(proj33) == seq31)
check("T33b projection cols = d_out", len(proj33[0]) == 4)

// ═══════════════════════════════════════════════════════════════
//  T34: full pipeline produces output
// ═══════════════════════════════════════════════════════════════
// Use small config for speed
let small_cfg = ae_make_config(4, 16, 8, 8, 2, 1, 16, 4, 16000)
let test_audio = make_sine_wave(256, 440.0, 16000)
let pipeline_out = ae_full_pipeline(test_audio, small_cfg)
check("T34 pipeline output frames > 0", len(pipeline_out) > 0)
check("T34b pipeline output dim = proj_dim", len(pipeline_out[0]) == 4)

// ═══════════════════════════════════════════════════════════════
//  T35: audio duration calculation correct
// ═══════════════════════════════════════════════════════════════
let dur = ae_audio_duration_sec(16000, 16000)
check("T35 1s audio duration", approx(dur, 1.0, 0.001))

// ═══════════════════════════════════════════════════════════════
//  Summary
// ═══════════════════════════════════════════════════════════════
println("")
println("=== audio_encoder test summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
