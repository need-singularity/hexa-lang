// ═══════════════════════════════════════════════════════════════
let win = ae_hann_window(16)
check("T13 hann window length=16", len(win) == 16)

// ═══════════════════════════════════════════════════════════════
//  T14: hann window endpoints near zero
// ═══════════════════════════════════════════════════════════════
check("T14 hann window[0] near 0", t_abs(win[0]) < 0.01)

// ═══════════════════════════════════════════════════════════════
//  T15: hann window peak at center
// ═══════════════════════════════════════════════════════════════
let mid = len(win) / 2
check("T15 hann window peak at center", win[mid] > 0.9)

// ═══════════════════════════════════════════════════════════════
