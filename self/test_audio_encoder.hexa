let resampled_down = ae_resample(sig6, 16000, 8000)
check("T6 downsample len ~ half", len(resampled_down) == 50)

// ═══════════════════════════════════════════════════════════════
//  T7: resample upsampling preserves length ratio
// ═══════════════════════════════════════════════════════════════
