let resampled_up = ae_resample(sig7, 8000, 16000)
check("T7 upsample len ~ double", len(resampled_up) == 100)

// ═══════════════════════════════════════════════════════════════
//  T8: pad_or_trim pads short signal
// ═══════════════════════════════════════════════════════════════
let short_sig = [1.0, 2.0, 3.0]
let padded = ae_pad_or_trim(short_sig, 6)
check("T8 padded length=6", len(padded) == 6)
check("T8b padded[0] preserved", approx(padded[0], 1.0, 0.001))
check("T8c padded[5] = 0", approx(padded[5], 0.0, 0.001))

// ═══════════════════════════════════════════════════════════════
//  T9: pad_or_trim trims long signal
