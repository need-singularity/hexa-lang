// ═══════════════════════════════════════════════════════════════
//  T21: log_mel applies log transform
// ═══════════════════════════════════════════════════════════════
let lm21 = ae_log_mel(mel20)
check("T21 log_mel same num frames", len(lm21) == len(mel20))
check("T21b log_mel same n_mels", len(lm21[0]) == len(mel20[0]))
// log of values >= 0 should have some negative values (log < 0 for x < 1)
let mut has_negative = false
let mut f = 0

while f < len(lm21) {
    let mut m = 0

    while m < len(lm21[f]) {
        if lm21[f][m] < 0.0 { has_negative = true }
    }
}
check("T21c log_mel has negative values (log of small numbers)", has_negative)

// ═══════════════════════════════════════════════════════════════
