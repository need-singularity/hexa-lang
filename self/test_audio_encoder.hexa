let n_bins_17 = 32 / 2 + 1
let expected_frames_17 = (160 - 32) / 16 + 1
check("T17 stft num_frames correct", len(stft_out) == expected_frames_17)
check("T17b stft n_bins correct", len(stft_out[0]) == n_bins_17)

// ═══════════════════════════════════════════════════════════════
//  T18: mel filterbank shape correct
// ═══════════════════════════════════════════════════════════════
let fb = ae_mel_filterbank(8, 32, 16000)
check("T18 filterbank rows = n_mels", len(fb) == 8)
check("T18b filterbank cols = n_fft/2+1", len(fb[0]) == 17)

// ═══════════════════════════════════════════════════════════════
//  T19: mel filterbank row sums non-negative
// ═══════════════════════════════════════════════════════════════
let mut all_nonneg = true
let mut m = 0

while m < len(fb) {
    let mut row_sum = 0.0
    let mut k = 0

    while k < len(fb[m]) {
        if fb[m][k] < 0.0 { all_nonneg = false }
        row_sum = row_sum + fb[m][k]
    }
}
check("T19 filterbank all values >= 0", all_nonneg)

// ═══════════════════════════════════════════════════════════════
//  T20: mel spectrogram shape correct
// ═══════════════════════════════════════════════════════════════
