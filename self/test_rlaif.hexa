// ═══════════════════════════════════════════════════════════════
//  test_rlaif.hexa — RLAIF verification
//
//  Tests:
//    1. default criteria names structure
//    2. default criteria weights structure
//    3. judge prompt generation format
//    4. score_response weighted scoring
//    5. generate_preference margin positive
//    6. generate_preference picks higher score
//    7. collect_scores pairwise generation
//    8. quality_filter keeps high-margin only
//    9. stats avg computation
//   10. custom criteria scoring
//   11. constitutional filter removes harmful
//   12. self_play generates correct pair count
//   13. collect_chosen returns string arrays
//   14. extract_margins correct length
//
//  실행: ./hexa self/test_rlaif.hexa
// ═══════════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx(a, b, eps) { return fabs(a - b) < eps }

// ── inlined from rlaif.hexa ──────────────────────────────────

fn rlaif_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn rlaif_zeros(n) {
    let mut v = []
    for _i in 0..n { v = v + [0.0] }
    return v
}

fn rlaif_default_crit_names() {
    return ["helpfulness", "accuracy", "harmlessness", "conciseness"]
}

fn rlaif_default_crit_weights() {
    return [0.3, 0.3, 0.2, 0.2]
}

fn rlaif_make_judge_prompt(prompt, response_a, response_b, crit_names, crit_weights) {
    let mut text = "[JUDGE EVALUATION]\n"
    text = text + "=== User Prompt ===\n"
    text = text + prompt + "\n"
    text = text + "=== Response A ===\n"
    text = text + response_a + "\n"
    text = text + "=== Response B ===\n"
    text = text + response_b + "\n"
    text = text + "=== Criteria ===\n"
    let n_crit = len(crit_names)
    for i in 0..n_crit {
        text = text + "- " + crit_names[i] + " (weight: " + str(crit_weights[i]) + ")\n"
    }
    text = text + "=== Task ===\nCompare Response A and Response B.\n"
    return text
}

fn rlaif_score_response(prompt, response, crit_names, crit_weights, judge_fn) {
    let n_crit = len(crit_names)
    let mut total = 0.0
    let mut weight_sum = 0.0
    for i in 0..n_crit {
        let score = judge_fn(prompt, response, crit_names[i])
        total = total + crit_weights[i] * score
        weight_sum = weight_sum + crit_weights[i]
    }
    if weight_sum > 0.0 { return total / weight_sum }
    return 0.0
}

fn generate_preference(prompt, response_a, response_b, judge_fn) {
    let cn = rlaif_default_crit_names()
    let cw = rlaif_default_crit_weights()
    let score_a = rlaif_score_response(prompt, response_a, cn, cw, judge_fn)
    let score_b = rlaif_score_response(prompt, response_b, cn, cw, judge_fn)
    let margin = rlaif_abs(score_a - score_b)
    return [score_a, score_b, margin]
}

fn generate_preference_custom(prompt, response_a, response_b, judge_fn, cn, cw) {
    let score_a = rlaif_score_response(prompt, response_a, cn, cw, judge_fn)
    let score_b = rlaif_score_response(prompt, response_b, cn, cw, judge_fn)
    let margin = rlaif_abs(score_a - score_b)
    return [score_a, score_b, margin]
}

fn rlaif_collect_scores(prompts, responses, judge_fn) {
    let n_prompts = len(prompts)
    let mut scores = []
    for p in 0..n_prompts {
        let prompt = prompts[p]
        let resps = responses[p]
        let n_resp = len(resps)
        for i in 0..(n_resp - 1) {
            for j in (i + 1)..n_resp {
                let pref = generate_preference(prompt, resps[i], resps[j], judge_fn)
                scores = scores + [pref]
            }
        }
    }
    return scores
}

fn rlaif_collect_chosen(prompts, responses, judge_fn) {
    let n_prompts = len(prompts)
    let mut chosen = []
    let mut rejected = []
    for p in 0..n_prompts {
        let prompt = prompts[p]
        let resps = responses[p]
        let n_resp = len(resps)
        for i in 0..(n_resp - 1) {
            for j in (i + 1)..n_resp {
                let pref = generate_preference(prompt, resps[i], resps[j], judge_fn)
                if pref[0] >= pref[1] {
                    chosen = chosen + [resps[i]]
                    rejected = rejected + [resps[j]]
                } else {
                    chosen = chosen + [resps[j]]
                    rejected = rejected + [resps[i]]
                }
            }
        }
    }
    return [chosen, rejected]
}

fn rlaif_quality_filter_margins(margins, min_margin) {
    let n = len(margins)
    let mut kept = []
    for i in 0..n {
        if margins[i] >= min_margin { kept = kept + [i] }
    }
    return kept
}

fn rlaif_extract_margins(score_triples) {
    let n = len(score_triples)
    let mut margins = rlaif_zeros(n)
    for i in 0..n { margins[i] = score_triples[i][2] }
    return margins
}

fn rlaif_self_play(prompts, generate_fn, judge_fn, n_responses) {
    let n_prompts = len(prompts)
    let mut all_responses = []
    for p in 0..n_prompts {
        let mut resps = []
        for r in 0..n_responses { resps = resps + [generate_fn(prompts[p])] }
        all_responses = all_responses + [resps]
    }
    return rlaif_collect_scores(prompts, all_responses, judge_fn)
}

fn rlaif_constitutional_filter(harm_scores, threshold) {
    let n = len(harm_scores)
    let mut safe = []
    for i in 0..n {
        if harm_scores[i] < threshold { safe = safe + [i] }
    }
    return safe
}

fn rlaif_stats(margins) {
    let n = len(margins)
    if n == 0 { return [0.0, 0.0, 0.0, 0.0] }
    let mut sum_m = 0.0
    let mut min_m = margins[0]
    let mut max_m = margins[0]
    for i in 0..n {
        let m = margins[i]
        sum_m = sum_m + m
        if m < min_m { min_m = m }
        if m > max_m { max_m = m }
    }
    return [to_float(n), sum_m / to_float(n), min_m, max_m]
}

// ── mock judge: longer response = better ──────────────────────
fn mock_judge(prompt, response, criterion) {
    let score = to_float(len(response)) / 20.0
    if score > 1.0 { return 1.0 }
    return score
}

// ── mock generator ────────────────────────────────────────────
let mut gen_counter = 0
fn mock_generate(prompt) {
    gen_counter = gen_counter + 1
    let r = gen_counter % 3
    if r == 0 { return "short" }
    if r == 1 { return "medium response here" }
    return "a much longer detailed response text"
}

// ═══════════════════════════════════════════════════════════════
//  TESTS
// ═══════════════════════════════════════════════════════════════

// T1: default criteria names
let cn = rlaif_default_crit_names()
check("default crit names has 4 items", len(cn) == 4)
check("first criterion is helpfulness", cn[0] == "helpfulness")

// T2: default criteria weights
let cw = rlaif_default_crit_weights()
check("default crit weights has 4 items", len(cw) == 4)
check("weights sum to 1.0", approx(cw[0] + cw[1] + cw[2] + cw[3], 1.0, 0.01))

// T3: judge prompt format
let jp = rlaif_make_judge_prompt("What is 2+2?", "It is 4", "It is 5", cn, cw)
check("judge prompt is non-empty", len(jp) > 50)

// T4: score_response weighted
let score_long = rlaif_score_response("q", "a long detailed answer here", cn, cw, mock_judge)
let score_short = rlaif_score_response("q", "short", cn, cw, mock_judge)
check("longer response scores higher", score_long > score_short)

// T5: generate_preference margin positive
let pref1 = generate_preference("q", "short", "a much longer answer here", mock_judge)
check("preference margin >= 0", pref1[2] >= 0.0)

// T6: generate_preference picks higher score
check("score_a < score_b for short vs long", pref1[0] < pref1[1])

// T7: collect_scores pairwise
let prompts = ["q1"]
let responses = [["short", "medium text", "long detailed answer"]]
let scores = rlaif_collect_scores(prompts, responses, mock_judge)
check("3 responses -> 3 pairs (C(3,2))", len(scores) == 3)

// T8: quality filter
let margins = rlaif_extract_margins(scores)
let kept = rlaif_quality_filter_margins(margins, 0.3)
check("filter keeps some pairs", len(kept) <= len(scores))

// T9: stats avg computation
let stats = rlaif_stats(margins)
check("stats count correct", approx(stats[0], to_float(len(margins)), 0.01))
check("stats avg_margin > 0", stats[1] >= 0.0)

// T10: custom criteria scoring
let custom_cn = ["quality"]
let custom_cw = [1.0]
let pref_c = generate_preference_custom("q", "hi", "hello world response", mock_judge, custom_cn, custom_cw)
check("custom criteria margin >= 0", pref_c[2] >= 0.0)

// T11: constitutional filter
let harm_scores = [0.1, 0.9, 0.2, 0.8]
let safe = rlaif_constitutional_filter(harm_scores, 0.5)
check("constitutional filter keeps safe pairs", len(safe) == 2)

// T12: self_play generates correct count
gen_counter = 0
let sp_scores = rlaif_self_play(["prompt1"], mock_generate, mock_judge, 3)
check("self_play 3 responses -> 3 pairs", len(sp_scores) == 3)

// T13: collect_chosen returns string arrays
let cr = rlaif_collect_chosen(["q1"], [["short", "long answer text"]], mock_judge)
check("collect_chosen returns 2 arrays", len(cr) == 2)
check("chosen array has 1 entry", len(cr[0]) == 1)

// T14: extract_margins correct length
let test_triples = [[0.5, 0.3, 0.2], [0.8, 0.1, 0.7]]
let ext_m = rlaif_extract_margins(test_triples)
check("extract_margins length correct", len(ext_m) == 2)
check("extract_margins values correct", approx(ext_m[0], 0.2, 0.01))

// ═══════════════════════════════════════════════════════════════
println("")
println("=== rlaif test summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
