// ═══════════════════════════════════════════════════════════════════
//  test_autograd.hexa — @grad (autograd) tape prototype tests
//  ROI id=189 (attr_semantics): reverse-mode AD via Wengert tape
//
//  Strategy: inline autograd tape API (self/attrs/autograd.hexa) 와 동일
//  시맨틱을 테스트 파일에서 재정의해 codegen import 없이 검증.
//  test_memoize_grad.hexa 와 같은 inline 패턴.
// ═══════════════════════════════════════════════════════════════════

// ── inlined from self/attrs/autograd.hexa ─────────────────────────
// tape = [records, vals]
//   records: [[op_code, out_id, lhs_id, rhs_id], ...]
//   op_code: 0=leaf, 1=add, 2=mul

fn mk_tape() {
    return [[], []]
}

fn tape_leaf(tape, x) {
    let records = tape[0]
    let vals = tape[1]
    let id = len(vals)
    let mut new_records = []
    let mut i = 0
    while i < len(records) { new_records.push(records[i]); i = i + 1 }
    new_records.push([0, id, -1, -1])
    let mut new_vals = []
    let mut j = 0
    while j < len(vals) { new_vals.push(vals[j]); j = j + 1 }
    new_vals.push(x)
    return [[new_records, new_vals], id]
}

fn tape_add(tape, a_id, b_id) {
    let records = tape[0]
    let vals = tape[1]
    let out_id = len(vals)
    let mut new_records = []
    let mut i = 0
    while i < len(records) { new_records.push(records[i]); i = i + 1 }
    new_records.push([1, out_id, a_id, b_id])
    let mut new_vals = []
    let mut j = 0
    while j < len(vals) { new_vals.push(vals[j]); j = j + 1 }
    new_vals.push(vals[a_id] + vals[b_id])
    return [[new_records, new_vals], out_id]
}

fn tape_mul(tape, a_id, b_id) {
    let records = tape[0]
    let vals = tape[1]
    let out_id = len(vals)
    let mut new_records = []
    let mut i = 0
    while i < len(records) { new_records.push(records[i]); i = i + 1 }
    new_records.push([2, out_id, a_id, b_id])
    let mut new_vals = []
    let mut j = 0
    while j < len(vals) { new_vals.push(vals[j]); j = j + 1 }
    new_vals.push(vals[a_id] * vals[b_id])
    return [[new_records, new_vals], out_id]
}

fn tape_value(tape, id) {
    let vals = tape[1]
    return vals[id]
}

fn tape_backward(tape, out_id) {
    let records = tape[0]
    let vals = tape[1]
    let n = len(vals)
    let mut grad = []
    let mut i = 0
    while i < n { grad.push(0.0); i = i + 1 }
    grad[out_id] = 1.0
    let nr = len(records)
    let mut k = nr - 1
    while k >= 0 {
        let rec = records[k]
        let op = rec[0]
        let oid = rec[1]
        let a = rec[2]
        let b = rec[3]
        let g_out = grad[oid]
        if op == 1 {
            grad[a] = grad[a] + g_out
            grad[b] = grad[b] + g_out
        } else if op == 2 {
            grad[a] = grad[a] + vals[b] * g_out
            grad[b] = grad[b] + vals[a] * g_out
        }
        k = k - 1
    }
    return grad
}

// ── end inlined ──────────────────────────────────────────────────

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

// float 비교 (tape_backward 는 정수 계수만 곱하므로 정확 비교 가능)
fn approx(x, y, tol) {
    let d = if x > y { x - y } else { y - x }
    return d <= tol
}

fn check_close(name, actual, expected, tol) {
    if approx(actual, expected, tol) {
        println("[PASS] " + name + " (" + to_string(actual) + " ≈ " + to_string(expected) + ")")
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════════")
println("  @grad (autograd) tape prototype — ROI #189")
println("═══════════════════════════════════════════════════════════")
println("")

// ══════════════════════════════════════════════════════════════
//  SECTION 1: Leaf + simple forward
// ══════════════════════════════════════════════════════════════

println("--- Section 1: Leaf + forward ---")

let t0 = mk_tape()
let r_a = tape_leaf(t0, 3.0)
let t1 = r_a[0]
let a_id = r_a[1]

let r_b = tape_leaf(t1, 4.0)
let t2 = r_b[0]
let b_id = r_b[1]

check("leaf a id", a_id, 0)
check("leaf b id", b_id, 1)
check_close("leaf a value", tape_value(t2, a_id), 3.0, 0.0001)
check_close("leaf b value", tape_value(t2, b_id), 4.0, 0.0001)

println("")

// ══════════════════════════════════════════════════════════════
//  SECTION 2: y = a + b,  dy/da = 1,  dy/db = 1
// ══════════════════════════════════════════════════════════════

println("--- Section 2: y = a + b ---")

let r_y = tape_add(t2, a_id, b_id)
let t3 = r_y[0]
let y_id = r_y[1]

check_close("y = a + b forward", tape_value(t3, y_id), 7.0, 0.0001)

let g_add = tape_backward(t3, y_id)
check_close("dy/da (add) = 1", g_add[a_id], 1.0, 0.0001)
check_close("dy/db (add) = 1", g_add[b_id], 1.0, 0.0001)

println("")

// ══════════════════════════════════════════════════════════════
//  SECTION 3: y = a * b,  dy/da = b,  dy/db = a
// ══════════════════════════════════════════════════════════════

println("--- Section 3: y = a * b ---")

let tm = mk_tape()
let rm_a = tape_leaf(tm, 3.0)
let tm1 = rm_a[0]
let ma = rm_a[1]
let rm_b = tape_leaf(tm1, 4.0)
let tm2 = rm_b[0]
let mb = rm_b[1]
let rm_y = tape_mul(tm2, ma, mb)
let tm3 = rm_y[0]
let my = rm_y[1]

check_close("y = a*b forward", tape_value(tm3, my), 12.0, 0.0001)

let g_mul = tape_backward(tm3, my)
check_close("dy/da (mul) = b = 4", g_mul[ma], 4.0, 0.0001)
check_close("dy/db (mul) = a = 3", g_mul[mb], 3.0, 0.0001)

println("")

// ══════════════════════════════════════════════════════════════
//  SECTION 4: y = a * b + c  — mixed graph
//    ∂y/∂a = b,  ∂y/∂b = a,  ∂y/∂c = 1
//    with (a,b,c) = (2, 5, 7) → y = 17, grads = (5, 2, 1)
// ══════════════════════════════════════════════════════════════

println("--- Section 4: y = a*b + c ---")

let s0 = mk_tape()
let s1 = tape_leaf(s0, 2.0)
let t_s1 = s1[0]; let ia = s1[1]
let s2 = tape_leaf(t_s1, 5.0)
let t_s2 = s2[0]; let ib = s2[1]
let s3 = tape_leaf(t_s2, 7.0)
let t_s3 = s3[0]; let ic = s3[1]

let s4 = tape_mul(t_s3, ia, ib)             // m = a*b
let t_s4 = s4[0]; let im = s4[1]
let s5 = tape_add(t_s4, im, ic)             // y = m + c
let t_s5 = s5[0]; let iy = s5[1]

check_close("y = a*b + c forward = 17", tape_value(t_s5, iy), 17.0, 0.0001)

let g = tape_backward(t_s5, iy)
check_close("∂y/∂a = b = 5", g[ia], 5.0, 0.0001)
check_close("∂y/∂b = a = 2", g[ib], 2.0, 0.0001)
check_close("∂y/∂c = 1",     g[ic], 1.0, 0.0001)

println("")

// ══════════════════════════════════════════════════════════════
//  SECTION 5: shared subexpression  y = a*a + a
//    dy/da = 2a + 1  — a 가 세 곳에서 쓰여도 누산이 정답이어야
//    with a = 3 → y = 12,  dy/da = 7
// ══════════════════════════════════════════════════════════════

println("--- Section 5: shared var y = a*a + a ---")

let u0 = mk_tape()
let u1 = tape_leaf(u0, 3.0)
let t_u1 = u1[0]; let ua = u1[1]

let u2 = tape_mul(t_u1, ua, ua)             // a*a
let t_u2 = u2[0]; let um = u2[1]
let u3 = tape_add(t_u2, um, ua)             // + a
let t_u3 = u3[0]; let uy = u3[1]

check_close("y = a*a + a forward (a=3) = 12", tape_value(t_u3, uy), 12.0, 0.0001)

let gu = tape_backward(t_u3, uy)
check_close("dy/da = 2a+1 = 7", gu[ua], 7.0, 0.0001)

println("")

// ══════════════════════════════════════════════════════════════
//  SECTION 6: Finite-difference cross-check
//    Numerical gradient ≈ (f(a+ε) - f(a-ε)) / 2ε  should match autograd.
//    f(a) = a * a + a  at a = 3, ε = 1e-3  → ~7
// ══════════════════════════════════════════════════════════════

println("--- Section 6: finite-diff cross-check ---")

fn eval_aa_plus_a(a) {
    return a * a + a
}

let eps = 0.001
let a_val = 3.0
let fd = (eval_aa_plus_a(a_val + eps) - eval_aa_plus_a(a_val - eps)) / (2.0 * eps)
// autograd says 7.0; finite-diff with eps=1e-3 should be within 1e-3
check_close("finite-diff vs autograd", fd, 7.0, 0.01)

// Re-run autograd for the same f(a) to be explicit about the match
let v0 = mk_tape()
let v1 = tape_leaf(v0, a_val)
let tv1 = v1[0]; let va = v1[1]
let v2 = tape_mul(tv1, va, va); let tv2 = v2[0]; let vm = v2[1]
let v3 = tape_add(tv2, vm, va); let tv3 = v3[0]; let vy = v3[1]
let gv = tape_backward(tv3, vy)
check_close("autograd and finite-diff agree", gv[va], fd, 0.01)

println("")

// ══════════════════════════════════════════════════════════════
//  Summary
// ══════════════════════════════════════════════════════════════
println("═══════════════════════════════════════════════════════════")
println("  @grad autograd prototype: " + to_string(pass_count) + " PASS, " + to_string(fail_count) + " FAIL")
println("═══════════════════════════════════════════════════════════")

if fail_count > 0 {
    println("SOME TESTS FAILED")
}
