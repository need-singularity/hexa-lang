// test_trie_pure.hexa — comprehensive tests for self/runtime/trie_pure.hexa (ROI #122)

import "runtime/trie_pure.hexa"

let mut pass = 0
let mut fail = 0

fn check(name, cond) {
    if cond { pass = pass + 1 } else {
        fail = fail + 1
        println("[FAIL] " + name)
    }
}

fn eq(name, a, b) {
    let both_void = type_of(a) == "void" && type_of(b) == "void"
    if both_void || a == b { pass = pass + 1 } else {
        fail = fail + 1
        println("[FAIL] " + name + " got " + to_string(a) + " want " + to_string(b))
    }
}

// helper: check if array contains a value
fn arr_contains(arr, val) {
    let n = len(arr)
    let mut i = 0
    while i < n {
        if arr[i] == val { return true }
        i = i + 1
    }
    return false
}

println("=== trie_pure test suite ===")

// ────────────────────────────────────────────────────────────
// 1. char_to_index
// ────────────────────────────────────────────────────────────
eq("char_to_index a", char_to_index("a"), 0)
eq("char_to_index z", char_to_index("z"), 25)
eq("char_to_index m", char_to_index("m"), 12)
eq("char_to_index invalid", char_to_index("1"), -1)

// ────────────────────────────────────────────────────────────
// 2. Empty trie
// ────────────────────────────────────────────────────────────
let t0 = trie_new_pure()
eq("empty count", trie_count_pure(t0), 0)
check("empty lookup", !trie_lookup_pure(t0, "hello"))
check("empty starts_with h", !trie_starts_with_pure(t0, "h"))
eq("empty collect", len(trie_collect_pure(t0, "")), 0)
eq("empty words", len(trie_words_pure(t0)), 0)

// ────────────────────────────────────────────────────────────
// 3. Insert + lookup single word
// ────────────────────────────────────────────────────────────
let mut t1 = trie_new_pure()
t1 = trie_insert_pure(t1, "hello")
check("lookup hello", trie_lookup_pure(t1, "hello"))
check("lookup hell false", !trie_lookup_pure(t1, "hell"))
check("lookup helloworld false", !trie_lookup_pure(t1, "helloworld"))
eq("count after 1 insert", trie_count_pure(t1), 1)

// ────────────────────────────────────────────────────────────
// 4. Insert multiple words
// ────────────────────────────────────────────────────────────
let mut t2 = trie_new_pure()
t2 = trie_insert_pure(t2, "apple")
t2 = trie_insert_pure(t2, "app")
t2 = trie_insert_pure(t2, "application")
t2 = trie_insert_pure(t2, "banana")
t2 = trie_insert_pure(t2, "band")
eq("count 5", trie_count_pure(t2), 5)
check("lookup apple", trie_lookup_pure(t2, "apple"))
check("lookup app", trie_lookup_pure(t2, "app"))
check("lookup application", trie_lookup_pure(t2, "application"))
check("lookup banana", trie_lookup_pure(t2, "banana"))
check("lookup band", trie_lookup_pure(t2, "band"))
check("lookup ap false", !trie_lookup_pure(t2, "ap"))
check("lookup ban false", !trie_lookup_pure(t2, "ban"))

// ────────────────────────────────────────────────────────────
// 5. Prefix search (starts_with)
// ────────────────────────────────────────────────────────────
check("starts_with a", trie_starts_with_pure(t2, "a"))
check("starts_with ap", trie_starts_with_pure(t2, "ap"))
check("starts_with app", trie_starts_with_pure(t2, "app"))
check("starts_with appl", trie_starts_with_pure(t2, "appl"))
check("starts_with ban", trie_starts_with_pure(t2, "ban"))
check("starts_with z false", !trie_starts_with_pure(t2, "z"))
check("starts_with xyz false", !trie_starts_with_pure(t2, "xyz"))
check("starts_with empty true", trie_starts_with_pure(t2, ""))

// ────────────────────────────────────────────────────────────
// 6. Collect words with prefix
// ────────────────────────────────────────────────────────────
let coll_app = trie_collect_pure(t2, "app")
eq("collect app count", len(coll_app), 3)
check("collect has apple", arr_contains(coll_app, "apple"))
check("collect has app", arr_contains(coll_app, "app"))
check("collect has application", arr_contains(coll_app, "application"))

let coll_ban = trie_collect_pure(t2, "ban")
eq("collect ban count", len(coll_ban), 2)
check("collect has banana", arr_contains(coll_ban, "banana"))
check("collect has band", arr_contains(coll_ban, "band"))

let coll_z = trie_collect_pure(t2, "z")
eq("collect z empty", len(coll_z), 0)

// ────────────────────────────────────────────────────────────
// 7. Collect all words (empty prefix)
// ────────────────────────────────────────────────────────────
let all_words = trie_collect_pure(t2, "")
eq("collect all count", len(all_words), 5)
check("all has apple", arr_contains(all_words, "apple"))
check("all has banana", arr_contains(all_words, "banana"))

// ────────────────────────────────────────────────────────────
// 8. trie_words_pure
// ────────────────────────────────────────────────────────────
let words = trie_words_pure(t2)
eq("words count", len(words), 5)
check("words has app", arr_contains(words, "app"))
check("words has band", arr_contains(words, "band"))

// ────────────────────────────────────────────────────────────
// 9. Single-character words
// ────────────────────────────────────────────────────────────
let mut t3 = trie_new_pure()
t3 = trie_insert_pure(t3, "a")
t3 = trie_insert_pure(t3, "b")
t3 = trie_insert_pure(t3, "c")
eq("single char count", trie_count_pure(t3), 3)
check("single char lookup a", trie_lookup_pure(t3, "a"))
check("single char lookup b", trie_lookup_pure(t3, "b"))
check("single char lookup c", trie_lookup_pure(t3, "c"))
check("single char d false", !trie_lookup_pure(t3, "d"))

// ────────────────────────────────────────────────────────────
// 10. Duplicate insert (idempotent)
// ────────────────────────────────────────────────────────────
let mut t4 = trie_new_pure()
t4 = trie_insert_pure(t4, "dog")
t4 = trie_insert_pure(t4, "dog")
t4 = trie_insert_pure(t4, "dog")
eq("dup insert count", trie_count_pure(t4), 1)
check("dup insert lookup", trie_lookup_pure(t4, "dog"))

// ────────────────────────────────────────────────────────────
// 11. Words sharing long prefix
// ────────────────────────────────────────────────────────────
let mut t5 = trie_new_pure()
t5 = trie_insert_pure(t5, "test")
t5 = trie_insert_pure(t5, "testing")
t5 = trie_insert_pure(t5, "tested")
t5 = trie_insert_pure(t5, "tester")
let coll_test = trie_collect_pure(t5, "test")
eq("shared prefix count", len(coll_test), 4)
check("shared has test", arr_contains(coll_test, "test"))
check("shared has testing", arr_contains(coll_test, "testing"))
check("shared has tested", arr_contains(coll_test, "tested"))
check("shared has tester", arr_contains(coll_test, "tester"))

// ────────────────────────────────────────────────────────────
// 12. Remove word
// ────────────────────────────────────────────────────────────
let mut t6 = trie_new_pure()
t6 = trie_insert_pure(t6, "cat")
t6 = trie_insert_pure(t6, "car")
t6 = trie_insert_pure(t6, "card")
eq("before remove count", trie_count_pure(t6), 3)
t6 = trie_remove_pure(t6, "car")
eq("after remove count", trie_count_pure(t6), 2)
check("removed car false", !trie_lookup_pure(t6, "car"))
check("cat still exists", trie_lookup_pure(t6, "cat"))
check("card still exists", trie_lookup_pure(t6, "card"))

// ────────────────────────────────────────────────────────────
// 13. Remove non-existent word (no-op)
// ────────────────────────────────────────────────────────────
let mut t7 = trie_new_pure()
t7 = trie_insert_pure(t7, "fox")
t7 = trie_remove_pure(t7, "xyz")
eq("remove nonexistent count", trie_count_pure(t7), 1)
check("fox still there", trie_lookup_pure(t7, "fox"))

// ────────────────────────────────────────────────────────────
// 14. Remove then re-insert
// ────────────────────────────────────────────────────────────
let mut t8 = trie_new_pure()
t8 = trie_insert_pure(t8, "go")
t8 = trie_remove_pure(t8, "go")
check("removed go", !trie_lookup_pure(t8, "go"))
eq("after remove count 0", trie_count_pure(t8), 0)
t8 = trie_insert_pure(t8, "go")
check("reinserted go", trie_lookup_pure(t8, "go"))
eq("reinsert count 1", trie_count_pure(t8), 1)

// ────────────────────────────────────────────────────────────
// 15. Exact prefix match (prefix is a word itself)
// ────────────────────────────────────────────────────────────
let coll_exact = trie_collect_pure(t2, "apple")
eq("exact prefix count", len(coll_exact), 1)
check("exact prefix has apple", arr_contains(coll_exact, "apple"))

// ────────────────────────────────────────────────────────────
// 16. Long word
// ────────────────────────────────────────────────────────────
let mut t10 = trie_new_pure()
let long_word = "abcdefghijklmnopqrstuvwxyz"
t10 = trie_insert_pure(t10, long_word)
check("long word lookup", trie_lookup_pure(t10, long_word))
check("long word prefix", trie_starts_with_pure(t10, "abcdefghij"))
check("long word partial false", !trie_lookup_pure(t10, "abcdefghij"))

// ────────────────────────────────────────────────────────────
// 17. Mixed single and multi char
// ────────────────────────────────────────────────────────────
let mut t12 = trie_new_pure()
t12 = trie_insert_pure(t12, "a")
t12 = trie_insert_pure(t12, "ab")
t12 = trie_insert_pure(t12, "abc")
let coll_a = trie_collect_pure(t12, "a")
eq("mixed a collect", len(coll_a), 3)
check("mixed has a", arr_contains(coll_a, "a"))
check("mixed has ab", arr_contains(coll_a, "ab"))
check("mixed has abc", arr_contains(coll_a, "abc"))

// ────────────────────────────────────────────────────────────
// 18. Disjoint branches
// ────────────────────────────────────────────────────────────
let mut t13 = trie_new_pure()
t13 = trie_insert_pure(t13, "x")
t13 = trie_insert_pure(t13, "y")
t13 = trie_insert_pure(t13, "z")
let coll_x = trie_collect_pure(t13, "x")
eq("disjoint x collect", len(coll_x), 1)
let coll_y = trie_collect_pure(t13, "y")
eq("disjoint y collect", len(coll_y), 1)
eq("disjoint total", trie_count_pure(t13), 3)

// ────────────────────────────────────────────────────────────
// 19. Remove prefix word, child words survive
// ────────────────────────────────────────────────────────────
let mut t14 = trie_new_pure()
t14 = trie_insert_pure(t14, "he")
t14 = trie_insert_pure(t14, "hello")
t14 = trie_insert_pure(t14, "help")
t14 = trie_remove_pure(t14, "he")
check("prefix removed", !trie_lookup_pure(t14, "he"))
check("hello survives", trie_lookup_pure(t14, "hello"))
check("help survives", trie_lookup_pure(t14, "help"))
eq("after prefix remove count", trie_count_pure(t14), 2)
check("starts_with he still true", trie_starts_with_pure(t14, "he"))

// ────────────────────────────────────────────────────────────
// 20. Large batch insert
// ────────────────────────────────────────────────────────────
let mut t15 = trie_new_pure()
let batch = ["aa", "ab", "ac", "ba", "bb", "bc", "ca", "cb", "cc"]
let nb = len(batch)
let mut bi = 0
while bi < nb {
    t15 = trie_insert_pure(t15, batch[bi])
    bi = bi + 1
}
eq("batch count", trie_count_pure(t15), 9)
let coll_b = trie_collect_pure(t15, "b")
eq("batch collect b", len(coll_b), 3)

// ────────────────────────────────────────────────────────────
// 21. Non-alpha characters
// ────────────────────────────────────────────────────────────
let mut t16 = trie_new_pure()
t16 = trie_insert_pure(t16, "hello world")
t16 = trie_insert_pure(t16, "hello!")
check("space in word", trie_lookup_pure(t16, "hello world"))
check("bang in word", trie_lookup_pure(t16, "hello!"))
eq("non-alpha count", trie_count_pure(t16), 2)

println("===========================================================")
println("  Results: " + to_string(pass) + " passed, " + to_string(fail) + " failed")
println("===========================================================")
if fail == 0 { println("ALL PASS") } else { println("SOME FAIL") }
