// ═══════════════════════════════════════════════════════════════════
//  self/test_trie_pure.hexa — tests for trie_pure
// ═══════════════════════════════════════════════════════════════════

import "runtime/trie_pure.hexa"

let mut pass = 0
let mut fail = 0

fn check(name, got, expected) {
    if got == expected {
        println("  PASS  " + name)
        pass = pass + 1
    } else {
        println("  FAIL  " + name + " — got " + to_string(got) + ", expected " + to_string(expected))
        fail = fail + 1
    }
}

// ── build trie ──────────────────────────────────────────────────────
let mut t = trie_new()
t = trie_insert(t, "apple")
t = trie_insert(t, "app")
t = trie_insert(t, "application")
t = trie_insert(t, "banana")
t = trie_insert(t, "band")
t = trie_insert(t, "bat")

// ── search exact ────────────────────────────────────────────────────
check("search apple", trie_search(t, "apple"), true)
check("search app", trie_search(t, "app"), true)
check("search application", trie_search(t, "application"), true)
check("search banana", trie_search(t, "banana"), true)
check("search band", trie_search(t, "band"), true)
check("search bat", trie_search(t, "bat"), true)
check("search ap (not inserted)", trie_search(t, "ap"), false)
check("search bane (not inserted)", trie_search(t, "bane"), false)
check("search empty", trie_search(t, ""), false)
check("search xyz (not inserted)", trie_search(t, "xyz"), false)

// ── starts_with ─────────────────────────────────────────────────────
check("prefix a", trie_starts_with(t, "a"), true)
check("prefix ap", trie_starts_with(t, "ap"), true)
check("prefix app", trie_starts_with(t, "app"), true)
check("prefix ban", trie_starts_with(t, "ban"), true)
check("prefix xyz", trie_starts_with(t, "xyz"), false)
check("prefix empty", trie_starts_with(t, ""), true)

// ── count ───────────────────────────────────────────────────────────
check("count total", trie_count(t), 6)

// ── collect (autocomplete) ──────────────────────────────────────────
let app_words = trie_collect(t, "app")
check("collect app count", len(app_words), 3)
check("collect app contains apple", app_words.contains("apple"), true)
check("collect app contains app", app_words.contains("app"), true)
check("collect app contains application", app_words.contains("application"), true)

let ban_words = trie_collect(t, "ban")
check("collect ban count", len(ban_words), 2)
check("collect ban contains banana", ban_words.contains("banana"), true)
check("collect ban contains band", ban_words.contains("band"), true)

let xyz_words = trie_collect(t, "xyz")
check("collect xyz empty", len(xyz_words), 0)

let all_words = trie_collect(t, "")
check("collect all count", len(all_words), 6)

// ── insert duplicate ────────────────────────────────────────────────
t = trie_insert(t, "apple")
check("count after dup insert", trie_count(t), 6)
check("search after dup", trie_search(t, "apple"), true)

// ── summary ─────────────────────────────────────────────────────────
println("")
println("trie_pure: " + to_string(pass) + " passed, " + to_string(fail) + " failed")
if fail > 0 {
    println("SOME TESTS FAILED")
}
