// self/codegen_c_min.hexa — N1 walking skeleton
// AI-native sequence step N1: AST → C 직접 emit (VM 우회)
//
// 현 단계 지원 범위 (degenerate skeleton, 의도적으로 최소):
//   - top-level `println("string literal")` 만 지원
// 목적: 파이프라인(.hexa → .c → clang → native) 자체를 그린으로 만든다.

fn ch(s, i) {
    // chars()[i] is Char (not == comparable to string per README limitation)
    // substring(i, i+1) returns 1-char string that compares correctly.
    return s.substring(i, i + 1)
}

fn extract_println_arg(line) {
    let n = len(line)
    let mut i = 0
    while i < n && ch(line, i) != "\"" { i = i + 1 }
    if i >= n { return "" }
    let start = i + 1
    let mut j = start
    while j < n && ch(line, j) != "\"" { j = j + 1 }
    if j >= n { return "" }
    return line.substring(start, j)
}

fn is_blank_or_comment(line) {
    let n = len(line)
    let mut i = 0
    while i < n && (ch(line, i) == " " || ch(line, i) == "\t") { i = i + 1 }
    if i >= n { return true }
    if i + 1 < n && ch(line, i) == "/" && ch(line, i + 1) == "/" { return true }
    return false
}

fn emit_c(source) {
    let lines = source.split("\n")
    let mut out = "#include <stdio.h>\n\nint main(void) {\n"
    let mut i = 0
    while i < len(lines) {
        let line = lines[i]
        if !is_blank_or_comment(line) {
            let arg = extract_println_arg(line)
            out = out + "    printf(\"" + arg + "\\n\");\n"
        }
        i = i + 1
    }
    out = out + "    return 0;\n}\n"
    return out
}

let input_path = "examples/hello_min.hexa"
let output_path = "build/hello_min.c"

let src = read_file(input_path)
let c_src = emit_c(src)
write_file(output_path, c_src)
println("[N1] wrote", output_path, len(c_src), "bytes")
