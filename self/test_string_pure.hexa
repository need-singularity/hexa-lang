// ═══════════════════════════════════════════════════════════════════
//  test_string_pure.hexa — Tests for self/runtime/string_pure.hexa
//  Covers: contains, starts_with, ends_with, index_of, replace,
//          split, substring, trim_start, trim_end, repeat, join,
//          to_upper, to_lower, trim
// ═══════════════════════════════════════════════════════════════════

use "runtime/string_pure"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  Pure-Hexa String Operations Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. str_contains_pure ────────────────────────────────────

println("--- str_contains_pure ---")

check("contains basic", str_contains_pure("hello world", "world"), true)
check("contains prefix", str_contains_pure("hello world", "hello"), true)
check("contains missing", str_contains_pure("hello world", "xyz"), false)
check("contains empty needle", str_contains_pure("hello", ""), true)
check("contains empty haystack", str_contains_pure("", "x"), false)
check("contains both empty", str_contains_pure("", ""), true)
check("contains single char", str_contains_pure("abc", "b"), true)
check("contains full match", str_contains_pure("abc", "abc"), true)
check("contains not string", str_contains_pure(42, "x"), false)

// ── 2. str_starts_with_pure ─────────────────────────────────

println("")
println("--- str_starts_with_pure ---")

check("starts_with yes", str_starts_with_pure("hello world", "hello"), true)
check("starts_with no", str_starts_with_pure("hello world", "world"), false)
check("starts_with empty prefix", str_starts_with_pure("hello", ""), true)
check("starts_with full", str_starts_with_pure("abc", "abc"), true)
check("starts_with too long", str_starts_with_pure("ab", "abc"), false)
check("starts_with single", str_starts_with_pure("x", "x"), true)

// ── 3. str_ends_with_pure ───────────────────────────────────

println("")
println("--- str_ends_with_pure ---")

check("ends_with yes", str_ends_with_pure("hello world", "world"), true)
check("ends_with no", str_ends_with_pure("hello world", "hello"), false)
check("ends_with empty suffix", str_ends_with_pure("hello", ""), true)
check("ends_with full", str_ends_with_pure("abc", "abc"), true)
check("ends_with too long", str_ends_with_pure("ab", "abc"), false)
check("ends_with single", str_ends_with_pure("z", "z"), true)

// ── 4. str_index_of_pure ────────────────────────────────────

println("")
println("--- str_index_of_pure ---")

check("index_of found", str_index_of_pure("hello world", "world"), 6)
check("index_of start", str_index_of_pure("hello world", "hello"), 0)
check("index_of not found", str_index_of_pure("hello world", "xyz"), -1)
check("index_of empty needle", str_index_of_pure("hello", ""), 0)
check("index_of single", str_index_of_pure("abcdef", "d"), 3)
check("index_of first occurrence", str_index_of_pure("abcabc", "bc"), 1)
check("index_of too long", str_index_of_pure("ab", "abc"), -1)

// ── 5. str_replace_pure ─────────────────────────────────────

println("")
println("--- str_replace_pure ---")

check("replace single", str_replace_pure("hello world", "world", "hexa"), "hello hexa")
check("replace all", str_replace_pure("aaa", "a", "bb"), "bbbbbb")
check("replace none", str_replace_pure("hello", "xyz", "abc"), "hello")
check("replace empty old", str_replace_pure("hello", "", "x"), "hello")
check("replace with empty", str_replace_pure("hello world", "world", ""), "hello ")
check("replace first", str_replace_pure("abab", "ab", "x"), "xx")
check("replace middle", str_replace_pure("axbxc", "x", "-"), "a-b-c")

// ── 6. str_split_pure ───────────────────────────────────────

println("")
println("--- str_split_pure ---")

let sp1 = str_split_pure("a,b,c", ",")
check("split count", len(sp1), 3)
check("split[0]", sp1[0], "a")
check("split[1]", sp1[1], "b")
check("split[2]", sp1[2], "c")

let sp2 = str_split_pure("hello", ",")
check("split no delim", len(sp2), 1)
check("split no delim[0]", sp2[0], "hello")

let sp3 = str_split_pure("a::b::c", "::")
check("split multi-char delim", len(sp3), 3)
check("split multi[0]", sp3[0], "a")
check("split multi[2]", sp3[2], "c")

let sp4 = str_split_pure(",a,", ",")
check("split leading delim", len(sp4), 3)
check("split leading[0] empty", sp4[0], "")
check("split trailing[2] empty", sp4[2], "")

// ── 7. str_substring_pure ───────────────────────────────────

println("")
println("--- str_substring_pure ---")

check("substring basic", str_substring_pure("hello world", 0, 5), "hello")
check("substring mid", str_substring_pure("hello world", 6, 11), "world")
check("substring clamp start", str_substring_pure("hello", -1, 3), "hel")
check("substring clamp end", str_substring_pure("hello", 2, 100), "llo")
check("substring empty range", str_substring_pure("hello", 3, 3), "")
check("substring reversed", str_substring_pure("hello", 5, 2), "")

// ── 8. str_trim_start_pure / str_trim_end_pure ──────────────

println("")
println("--- str_trim_start_pure ---")

check("trim_start spaces", str_trim_start_pure("  hello"), "hello")
check("trim_start none", str_trim_start_pure("hello"), "hello")
check("trim_start all ws", str_trim_start_pure("   "), "")
check("trim_start tab", str_trim_start_pure("\thello"), "hello")
check("trim_start preserves trail", str_trim_start_pure("  hello  "), "hello  ")

println("")
println("--- str_trim_end_pure ---")

check("trim_end spaces", str_trim_end_pure("hello  "), "hello")
check("trim_end none", str_trim_end_pure("hello"), "hello")
check("trim_end all ws", str_trim_end_pure("   "), "")
check("trim_end tab", str_trim_end_pure("hello\t"), "hello")
check("trim_end preserves lead", str_trim_end_pure("  hello  "), "  hello")

// ── 9. str_repeat_pure ──────────────────────────────────────

println("")
println("--- str_repeat_pure ---")

check("repeat 3", str_repeat_pure("ab", 3), "ababab")
check("repeat 1", str_repeat_pure("x", 1), "x")
check("repeat 0", str_repeat_pure("x", 0), "")
check("repeat neg", str_repeat_pure("x", -1), "")
check("repeat empty", str_repeat_pure("", 5), "")

// ── 10. str_join_pure ───────────────────────────────────────

println("")
println("--- str_join_pure ---")

check("join basic", str_join_pure(["a", "b", "c"], ","), "a,b,c")
check("join single", str_join_pure(["hello"], ","), "hello")
check("join empty arr", str_join_pure([], ","), "")
check("join empty sep", str_join_pure(["a", "b"], ""), "ab")
check("join multi sep", str_join_pure(["x", "y", "z"], "::"), "x::y::z")

// ── 11. str_trim_pure ───────────────────────────────────────

println("")
println("--- str_trim_pure ---")

check("trim both", str_trim_pure("  hello  "), "hello")
check("trim none", str_trim_pure("hello"), "hello")
check("trim left only", str_trim_pure("  hello"), "hello")
check("trim right only", str_trim_pure("hello  "), "hello")
check("trim all ws", str_trim_pure("   "), "")
check("trim empty", str_trim_pure(""), "")
check("trim mixed ws", str_trim_pure("\t hello \n"), "hello")

// ── 12. str_to_upper_ascii / str_to_lower_ascii ─────────────

println("")
println("--- str_to_upper_ascii ---")

check("upper basic", str_to_upper_ascii("hello"), "HELLO")
check("upper mixed", str_to_upper_ascii("Hello World"), "HELLO WORLD")
check("upper already", str_to_upper_ascii("ABC"), "ABC")
check("upper empty", str_to_upper_ascii(""), "")
check("upper digits", str_to_upper_ascii("abc123"), "ABC123")

println("")
println("--- str_to_lower_ascii ---")

check("lower basic", str_to_lower_ascii("HELLO"), "hello")
check("lower mixed", str_to_lower_ascii("Hello World"), "hello world")
check("lower already", str_to_lower_ascii("abc"), "abc")
check("lower empty", str_to_lower_ascii(""), "")
check("lower digits", str_to_lower_ascii("ABC123"), "abc123")

// ── 13. is_error_pure ───────────────────────────────────────

println("")
println("--- is_error_pure ---")

check("is_error yes", is_error_pure("ERR:something"), true)
check("is_error no", is_error_pure("hello"), false)
check("is_error short", is_error_pure("ER"), false)
check("is_error int", is_error_pure(42), false)

// ── 14. pad_left_pure / pad_right_pure ──────────────────────

println("")
println("--- pad_left_pure / pad_right_pure ---")

check("pad_left width>len", pad_left_pure("hi", 5), "   hi")
check("pad_left width==len", pad_left_pure("hello", 5), "hello")
check("pad_left width<len", pad_left_pure("hello", 3), "hello")
check("pad_left width 0", pad_left_pure("x", 0), "x")
check("pad_left empty str width 3", pad_left_pure("", 3), "   ")

check("pad_right width>len", pad_right_pure("hi", 5), "hi   ")
check("pad_right width==len", pad_right_pure("hello", 5), "hello")
check("pad_right width<len", pad_right_pure("hello", 3), "hello")
check("pad_right width 0", pad_right_pure("x", 0), "x")
check("pad_right empty str width 3", pad_right_pure("", 3), "   ")

check("pad_left int to string", pad_left_pure(42, 5), "   42")
check("pad_right int to string", pad_right_pure(42, 5), "42   ")

// ── Summary ─────────────────────────────────────────────────

println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    println("FAIL")
    exit(1)
}
println("ALL PASS")
