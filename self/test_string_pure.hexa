check("contains missing", str_contains_pure("hello world", "xyz"), false)
check("contains empty needle", str_contains_pure("hello", ""), true)
check("contains empty haystack", str_contains_pure("", "x"), false)
check("contains both empty", str_contains_pure("", ""), true)
check("contains single char", str_contains_pure("abc", "b"), true)
check("contains full match", str_contains_pure("abc", "abc"), true)
