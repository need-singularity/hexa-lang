// ═══════════════════════════════════════════════════════════
//  test_ai_native_v4.hexa — AI-native v4 vector tests
//  #20 @algebraic  (M970) — commutative/associative reordering
//  #19 @approximate (M971) — fast math approximation detection
//  #15 @compact     (M972) — SoA transform detection
//  #7  @optimize sliding-window (M973) — DP lookback detection
//
//  Runtime-neutral: @attr annotations are recognized by parser
//  + ai_native_pass; runtime behavior identical to unannotated.
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA AI-Native v4 Tests (M970/M971/M972/M973)")
println("  @algebraic @approximate @compact @optimize(sliding)")
println("═══════════════════════════════════════════════════════")
println("")

// ════════════════════════════════════════════════════════════
//  1. @algebraic — commutative/associative reordering (M970)
// ════════════════════════════════════════════════════════════

println("--- @algebraic (M970) ---")

// Commutative: addition is order-independent
@algebraic fn alg_add(a: int, b: int) -> int { return a + b }
@algebraic fn alg_mul(a: int, b: int) -> int { return a * b }

check("@algebraic add(3,5)", alg_add(3, 5), 8)
check("@algebraic add(5,3)", alg_add(5, 3), 8)
check("@algebraic add commutativity", alg_add(3, 5) == alg_add(5, 3), true)
check("@algebraic mul(4,7)", alg_mul(4, 7), 28)
check("@algebraic mul commutativity", alg_mul(4, 7) == alg_mul(7, 4), true)

// Associative: (a + b) + c == a + (b + c)
@algebraic fn alg_assoc(a: int, b: int, c: int) -> int {
    return (a + b) + c
}
@algebraic fn alg_assoc2(a: int, b: int, c: int) -> int {
    return a + (b + c)
}

check("@algebraic assoc(1,2,3)", alg_assoc(1, 2, 3), 6)
check("@algebraic assoc equiv", alg_assoc(1, 2, 3) == alg_assoc2(1, 2, 3), true)

// Constant folding via reordering: x + 3 + 5 should fold to x + 8
@algebraic fn alg_const_fold(x: int) -> int {
    return (x + 3) + 5
}

check("@algebraic const-fold(10)", alg_const_fold(10), 18)
check("@algebraic const-fold(0)", alg_const_fold(0), 8)

// Multiplicative associative: (x * 2) * 3 should fold to x * 6
@algebraic fn alg_mul_assoc(x: int) -> int {
    return (x * 2) * 3
}

check("@algebraic mul-assoc(5)", alg_mul_assoc(5), 30)
check("@algebraic mul-assoc(7)", alg_mul_assoc(7), 42)

// Distributive: x*a + x*b == x*(a+b)
@algebraic fn alg_distrib(x: int) -> int {
    return x * 3 + x * 4
}

check("@algebraic distrib(10)", alg_distrib(10), 70)
check("@algebraic distrib(1)", alg_distrib(1), 7)

// Mixed: multiple commutative+associative
@algebraic fn alg_mixed(a: int, b: int) -> int {
    let x = a + b
    let y = b + a
    return x + y
}

check("@algebraic mixed(3,4)", alg_mixed(3, 4), 14)

// Identity: x + 0 stays x, x * 1 stays x
@algebraic fn alg_identity(x: int) -> int {
    return x + 0 + x * 1
}

check("@algebraic identity(5)", alg_identity(5), 10)
check("@algebraic identity(0)", alg_identity(0), 0)

// ════════════════════════════════════════════════════════════
//  2. @approximate — fast math approximation (M971)
// ════════════════════════════════════════════════════════════

println("")
println("--- @approximate (M971) ---")

// Division-heavy: reciprocal approximation candidate
@approximate fn approx_reciprocal(x: int) -> int {
    if x == 0 { return 0 }
    return 100 / x
}

check("@approximate reciprocal(5)", approx_reciprocal(5), 20)
check("@approximate reciprocal(10)", approx_reciprocal(10), 10)
check("@approximate reciprocal(1)", approx_reciprocal(1), 100)

// Division in loop: expensive pattern
@approximate fn approx_div_loop(n: int) -> int {
    let mut sum = 0
    let mut i = 1
    while i <= n {
        sum = sum + 1000 / i
        i = i + 1
    }
    return sum
}

check("@approximate div-loop(1)", approx_div_loop(1), 1000)
check("@approximate div-loop(3)", approx_div_loop(3), 1000 + 500 + 333)
check("@approximate div-loop(5)", approx_div_loop(5), 1000 + 500 + 333 + 250 + 200)

// Multiple division sites
@approximate fn approx_multi_div(a: int, b: int) -> int {
    let x = a / 3
    let y = b / 7
    return x + y
}

check("@approximate multi-div(30,70)", approx_multi_div(30, 70), 20)
check("@approximate multi-div(9,14)", approx_multi_div(9, 14), 5)

// Average (division)
@approximate fn approx_avg(a: int, b: int, c: int) -> int {
    return (a + b + c) / 3
}

check("@approximate avg(3,6,9)", approx_avg(3, 6, 9), 6)
check("@approximate avg(10,20,30)", approx_avg(10, 20, 30), 20)

// No expensive math (violation test — fn with no math ops)
@approximate fn approx_no_math(x: int) -> int { return x + 1 }

check("@approximate no-math(5)", approx_no_math(5), 6)

// ════════════════════════════════════════════════════════════
//  3. @compact — SoA transform detection (M972)
// ════════════════════════════════════════════════════════════

println("")
println("--- @compact (M972) ---")

// Struct for testing AoS patterns
struct Point { x: int, y: int }

// Simple struct usage (no AoS pattern — no arr[i].field)
@compact fn compact_single(p: Point) -> int {
    return p.x + p.y
}

let p1 = Point { x: 3, y: 4 }
check("@compact single(3,4)", compact_single(p1), 7)

// Array of structs — sum all x fields (typical AoS → SoA candidate)
// Note: without actual arr[i].field syntax in AST, we test struct field access
@compact fn compact_sum_x(arr) -> int {
    let mut sum = 0
    let mut i = 0
    let n = len(arr)
    while i < n {
        let p = arr[i]
        sum = sum + p.x
        i = i + 1
    }
    return sum
}

let points = [Point { x: 1, y: 10 }, Point { x: 2, y: 20 }, Point { x: 3, y: 30 }]
check("@compact sum-x", compact_sum_x(points), 6)

// Distance-like computation (AoS pattern)
@compact fn compact_dist_sum(arr) -> int {
    let mut sum = 0
    let mut i = 0
    let n = len(arr)
    while i < n {
        let p = arr[i]
        sum = sum + p.x * p.x + p.y * p.y
        i = i + 1
    }
    return sum
}

check("@compact dist-sum", compact_dist_sum(points), 1 + 100 + 4 + 400 + 9 + 900)

// Empty array edge case
check("@compact empty", compact_sum_x([]), 0)

// ════════════════════════════════════════════════════════════
//  4. @optimize sliding-window — DP lookback (M973)
// ════════════════════════════════════════════════════════════

println("")
println("--- @optimize sliding-window (M973) ---")

// Classic Fibonacci via DP array: dp[i] = dp[i-1] + dp[i-2]
// This is the exact pattern sliding-window should detect
@optimize fn sw_fib(n: int) -> int {
    if n <= 1 { return n }
    let mut dp = [0, 1]
    let mut i = 2
    while i <= n {
        let next = dp[i - 1] + dp[i - 2]
        dp = dp.push(next)
        i = i + 1
    }
    return dp[n]
}

check("@optimize sw-fib(0)", sw_fib(0), 0)
check("@optimize sw-fib(1)", sw_fib(1), 1)
check("@optimize sw-fib(5)", sw_fib(5), 5)
check("@optimize sw-fib(10)", sw_fib(10), 55)

// Already-sliding-window: only uses 2 vars (should NOT be detected)
@optimize fn sw_fib_optimal(n: int) -> int {
    if n <= 1 { return n }
    let mut a = 0
    let mut b = 1
    let mut i = 2
    while i <= n {
        let temp = a + b
        a = b
        b = temp
        i = i + 1
    }
    return b
}

check("@optimize sw-optimal(10)", sw_fib_optimal(10), 55)
check("@optimize sw-optimal(5)", sw_fib_optimal(5), 5)

// Climbing stairs: dp[i] = dp[i-1] + dp[i-2] (same pattern)
@optimize fn sw_climb(n: int) -> int {
    if n <= 2 { return n }
    let mut dp = [0, 1, 2]
    let mut i = 3
    while i <= n {
        let next = dp[i - 1] + dp[i - 2]
        dp = dp.push(next)
        i = i + 1
    }
    return dp[n]
}

check("@optimize sw-climb(1)", sw_climb(1), 1)
check("@optimize sw-climb(2)", sw_climb(2), 2)
check("@optimize sw-climb(5)", sw_climb(5), 8)
check("@optimize sw-climb(10)", sw_climb(10), 89)

// Tribonacci: dp[i] = dp[i-1] + dp[i-2] + dp[i-3]
@optimize fn sw_tribo(n: int) -> int {
    if n == 0 { return 0 }
    if n <= 2 { return 1 }
    let mut dp = [0, 1, 1]
    let mut i = 3
    while i <= n {
        let next = dp[i - 1] + dp[i - 2] + dp[i - 3]
        dp = dp.push(next)
        i = i + 1
    }
    return dp[n]
}

check("@optimize sw-tribo(4)", sw_tribo(4), 4)
check("@optimize sw-tribo(7)", sw_tribo(7), 24)

// ════════════════════════════════════════════════════════════
//  Summary
// ════════════════════════════════════════════════════════════

println("")
println("═══════════════════════════════════════════════════════")
println("  v4 Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    println("[FAIL] " + to_string(fail_count) + " test(s) failed!")
} else {
    println("[ALL PASS] " + to_string(pass_count) + " tests passed!")
}
