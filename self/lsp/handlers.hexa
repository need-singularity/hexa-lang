// self/lsp/handlers.hexa — LSP 핸들러 (Phase 4 Step 2)
//
// raw law 를 LSP diagnostic/willSave 차단으로 연결.
// 실제 구현은 law_check.hexa 호출 → 결과 파싱 → LSP 형식 변환.

use "self/lsp/protocol"
use "self/lsp/raw_diagnostics"

// ─── URI / 경로 헬퍼 ───────────────────────────────────
fn _uri_to_path(uri: string) -> string {
    // file:///absolute/path → /absolute/path
    if uri.starts_with("file://") {
        return uri.substring(7, len(uri))
    }
    return uri
}

fn _law_check_path(path: string) -> bool {
    let cmd = "LAW_CHECK_DONE=1 hexa tool/law_check.hexa '" + path + "' 2>&1"
    let out = to_string(exec(cmd))
    if out.contains("🚫") || out.contains("compile 차단") { return false }
    return true
}

fn _law_violations(path: string) -> string {
    // law_check 출력에서 위반 섹션 추출 — stub 수준
    let cmd = "LAW_CHECK_DONE=1 hexa tool/law_check.hexa '" + path + "' 2>&1"
    let out = to_string(exec(cmd))
    return out
}

// ─── initialize ─────────────────────────────────────────
pub fn handle_initialize(msg: string) -> string {
    let id = extract_id(msg)
    if id == "" { return "" }
    return jsonrpc_response(id, init_capabilities())
}

// ─── didOpen — 문서 등록 + 초기 diagnostics ────────────
pub fn handle_did_open(msg: string) {
    let uri = extract_uri(msg)
    if uri == "" { return }
    let path = _uri_to_path(uri)

    // law_check 실행
    let pass = _law_check_path(path)
    if pass {
        // 위반 없음 — 빈 diagnostics
        let params = publish_diagnostics_params(uri, "[]")
        println(jsonrpc_notification("textDocument/publishDiagnostics", params))
    } else {
        // 위반 있음 — 파일 첫 줄에 diagnostic
        let diag = diagnostic(0, 0, 0, 0, 1, "raw", "law violation detected (run hexa tool/law_check.hexa for detail)")
        let params = publish_diagnostics_params(uri, "[" + diag + "]")
        println(jsonrpc_notification("textDocument/publishDiagnostics", params))
    }
}

// ─── didChange — 문서 상태 갱신 ────────────────────────
// Step 2 는 full-sync (sync=1) 기본. incremental 은 Step 3+
pub fn handle_did_change(msg: string) {
    // 현재 스켈레톤에서는 diagnostic 만 재발행
    let uri = extract_uri(msg)
    if uri == "" { return }
    let path = _uri_to_path(uri)
    let pass = _law_check_path(path)
    let diags = if pass { "[]" } else {
        "[" + diagnostic(0, 0, 0, 0, 1, "raw", "law violation") + "]"
    }
    let params = publish_diagnostics_params(uri, diags)
    println(jsonrpc_notification("textDocument/publishDiagnostics", params))
}

// ─── willSave — 저장 전 알림 (request/notif 겸용) ──────
pub fn handle_will_save(msg: string) -> string {
    // LSP: willSave 는 notification (응답 없음). request 가 아님.
    // willSaveWaitUntil 이 edit array 반환으로 block/modify 가능.
    return ""
}

// ─── willSaveWaitUntil — 저장 전 law gate ─────────────
// 위반 시 edit array 를 반환해 내용 대체 / 또는 에러로 편집자에게 통보
pub fn handle_will_save_wait_until(msg: string) -> string {
    let id = extract_id(msg)
    if id == "" { return "" }

    let uri = extract_uri(msg)
    let path = _uri_to_path(uri)
    let pass = _law_check_path(path)

    if pass {
        // 법 통과 — edit array 비어있음 (변경 없음)
        return jsonrpc_response(id, "[]")
    }

    // 위반 — LSP 는 willSaveWaitUntil 로 저장 차단 직접 지원 안 함.
    // 대신 TextEdit[] 로 내용 강제 변경 가능. Step 2 에서는 빈 edit + error msg.
    // 차후: edit array 에 "(* LAW VIOLATION *)" prefix 삽입 등 visible cue.
    return jsonrpc_response(id, "[]")
}

// ─── didSave — 저장 후 최종 점검 ───────────────────────
// P3-1 (2026-04-20): fold raw#9/#11/#12 enforcer output into LSP Diagnostics
// so editors (VSCode extension etc.) show squiggles inline instead of
// surfacing violations only at commit. See self/lsp/raw_diagnostics.hexa.
pub fn handle_did_save(msg: string) {
    let uri = extract_uri(msg)
    if uri == "" { return }
    let path = _uri_to_path(uri)

    // Legacy high-level law gate (still honored for coarse block/pass signal).
    let pass = _law_check_path(path)
    let legacy = if pass { [] } else {
        [diagnostic(0, 0, 0, 0, 1, "raw", "저장된 파일 law 위반 — 수정 필요")]
    }

    // Per-rule granular diagnostics (raw#9 + raw#11 + raw#12).
    // Fail-open: collect_for_file returns [] on any spawn/parse failure.
    let granular = collect_for_file(path)

    let mut all = []
    for d in legacy   { all.push(d) }
    for d in granular { all.push(d) }

    let mut body = "[]"
    if len(all) > 0 {
        let body_parts = ["[", all.join(","), "]"]
        body = body_parts.join("")
    }
    let params = publish_diagnostics_params(uri, body)
    println(jsonrpc_notification("textDocument/publishDiagnostics", params))
}

// ─── shutdown ─────────────────────────────────────────
pub fn handle_shutdown(msg: string) -> string {
    let id = extract_id(msg)
    if id == "" { return "" }
    return jsonrpc_response(id, "null")
}
