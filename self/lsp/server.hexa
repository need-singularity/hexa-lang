// self/lsp/server.hexa — LSP server (Phase 4 Step 2)
//
// 상태: 스켈레톤. JSON-RPC 2.0 message loop + 주요 handler 뼈대.
//   실제 stdin frame 읽기 (Content-Length 헤더 + N bytes) 는 hexa stdin
//   primitive 제약으로 단순화됨 (후속 세션에 proper I/O 리팩터).
//
// 지원 LSP 메시지 (Step 2 범위):
//   · initialize             (request)   — capabilities 응답
//   · initialized            (notif)     — no-op
//   · textDocument/didOpen   (notif)     — 문서 등록 + law_check → diagnostics
//   · textDocument/didChange (notif)     — 문서 상태 갱신 (diff 적용은 단순화)
//   · textDocument/willSave  (request)   — law gate check → WillSaveWaitUntil 응답
//   · textDocument/didSave   (notif)     — 저장 후 final check + diagnostics
//   · shutdown / exit                    — 정리
//
// 후속 (Step 3+):
//   · willSaveWaitUntilResponse — 법 위반 시 edit array 로 수정 제안 주입
//   · completion / hover / goto — IDE 편의 기능
//   · server capabilities 확장
//
// 실행:
//   hexa self/lsp/server.hexa
//   (IDE 는 stdin/stdout 을 JSON-RPC 으로 통신)

use "self/lsp/protocol"
use "self/lsp/handlers"

// ─── 문서 상태 저장소 ─────────────────────────────────────
// uri → content 맵. Step 2 에서는 단일 #{} 사용.
let mut doc_store = #{}

fn doc_get(uri: string) -> string {
    if doc_store[uri] != null { return doc_store[uri] }
    return ""
}

fn doc_put(uri: string, content: string) {
    doc_store[uri] = content
}

fn doc_remove(uri: string) {
    doc_store[uri] = ""
}

// ─── 메인 루프 ────────────────────────────────────────────
// LSP 표준 framing: Content-Length: N\r\n\r\n<N bytes JSON>
// 단순화: 스켈레톤은 stdin 한 번 read 후 parse (실제 server 는 stream).
// 후속: fd-level read + partial buffer 관리 필요.

fn read_message() -> string {
    // placeholder — 전체 stdin read
    let raw = to_string(exec("cat"))
    // Content-Length 헤더 제거
    let idx = raw.index_of("\r\n\r\n")
    if idx >= 0 {
        return raw.substring(idx + 4, len(raw))
    }
    let idx2 = raw.index_of("\n\n")
    if idx2 >= 0 {
        return raw.substring(idx2 + 2, len(raw))
    }
    return raw
}

fn write_message(body: string) {
    // LSP response 는 Content-Length framing 필수
    let cl = "Content-Length: " + to_string(len(body)) + "\r\n\r\n"
    print(cl + body)
}

fn dispatch(msg: string) -> string {
    // 간이 method 감지 — "method":"<name>" 부분 문자열 매칭
    let method = extract_method(msg)

    if method == "initialize" {
        return handle_initialize(msg)
    }
    if method == "initialized" {
        return ""  // notification, no response
    }
    if method == "textDocument/didOpen" {
        handle_did_open(msg)
        return ""
    }
    if method == "textDocument/didChange" {
        handle_did_change(msg)
        return ""
    }
    if method == "textDocument/willSave" {
        return handle_will_save(msg)
    }
    if method == "textDocument/willSaveWaitUntil" {
        return handle_will_save_wait_until(msg)
    }
    if method == "textDocument/didSave" {
        handle_did_save(msg)
        return ""
    }
    if method == "shutdown" {
        return handle_shutdown(msg)
    }
    if method == "exit" {
        exit(0)
    }

    // Unknown method — 에러 응답 (request 인 경우만)
    let id = extract_id(msg)
    if id != "" {
        return jsonrpc_error(id, -32601, "Method not found: " + method)
    }
    return ""
}

// ─── 스켈레톤 모드 ─────────────────────────────────────────
// Step 2 는 단발성 — 한 메시지 읽고 처리 후 종료.
// 진짜 LSP server 는 exit notif 까지 무한 루프.

fn run_once() {
    let msg = read_message()
    if len(msg) == 0 { exit(0) }
    let resp = dispatch(msg)
    if len(resp) > 0 { write_message(resp) }
}

// CLI entry
let _raw_args = args()
let mut cli_args = []
let mut _ai = 2
while _ai < len(_raw_args) {
    cli_args.push(_raw_args[_ai])
    _ai = _ai + 1
}

if len(cli_args) > 0 && cli_args[0] == "--help" {
    eprintln("hexa LSP server — Phase 4 Step 2 skeleton")
    eprintln("")
    eprintln("usage:")
    eprintln("  hexa self/lsp/server.hexa           — stdin/stdout LSP loop (단발)")
    eprintln("  hexa self/lsp/server.hexa --test    — self-test (한 메시지 echo)")
    eprintln("")
    eprintln("지원 메시지:")
    eprintln("  initialize, initialized")
    eprintln("  textDocument/didOpen, didChange, didSave")
    eprintln("  textDocument/willSave, willSaveWaitUntil")
    eprintln("  shutdown, exit")
    eprintln("")
    eprintln("후속:")
    eprintln("  · proper stdin frame reading (Content-Length 재귀)")
    eprintln("  · JSON full parser/serializer (현재 단순 regex)")
    eprintln("  · completion / hover / goto 확장")
    exit(0)
}

if len(cli_args) > 0 && cli_args[0] == "--test" {
    // 자체 테스트 — initialize 메시지 모의
    let probe = "{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"initialize\",\"params\":{}}"
    println(dispatch(probe))
    exit(0)
}

run_once()
