// self/lsp/test/test_import_surface.hexa — LP4-IMPORT-SURFACE smoke
//
// Exercises self/lsp/import_diagnostics:
//   1. File with no imports → []
//   2. File with valid imports → []
//   3. File with one bad import → [diagnostic at correct line]
//
// We construct fixture .hexa files in /tmp/ to avoid polluting the repo.

use "self/lsp/import_diagnostics"

let mut pass_count = 0
let mut total_count = 0
let mut failed_name = ""

fn check(name, cond) {
    total_count = total_count + 1
    if cond {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name)
    }
}

fn write_fixture(path, content) {
    write_file(path, content)
}

fn main() {
    // ── case 1: no imports ─────────────────────────────────────
    let p1 = "/tmp/_lsp_lp4_no_imp.hexa"
    write_fixture(p1, "println(\"hi\")\n")
    let d1 = collect_imports_for_file(p1)
    check("no imports → empty", len(d1) == 0)

    // ── case 2: valid stdlib import ────────────────────────────
    let p2 = "/tmp/_lsp_lp4_valid.hexa"
    write_fixture(p2, "import \"stdlib/path.hexa\"\nlet x = 1\n")
    let d2 = collect_imports_for_file(p2)
    check("valid import → empty", len(d2) == 0)

    // ── case 3: bogus import ───────────────────────────────────
    let p3 = "/tmp/_lsp_lp4_bogus.hexa"
    write_fixture(p3, "import \"stdlib/this_does_not_exist_zzz\"\nlet x = 1\n")
    let d3 = collect_imports_for_file(p3)
    check("bogus import → 1 diagnostic", len(d3) == 1)
    if len(d3) == 1 {
        let body = d3[0]
        check("diagnostic mentions module name", body.contains("stdlib/this_does_not_exist_zzz"))
        check("diagnostic source is rfc016", body.contains("\"source\":\"rfc016\""))
    }

    // ── case 4: bogus from-import ──────────────────────────────
    let p4 = "/tmp/_lsp_lp4_bogus_from.hexa"
    write_fixture(p4, "from \"stdlib/non_existent_yyy\" import foo\nlet x = 1\n")
    let d4 = collect_imports_for_file(p4)
    check("bogus from-import → 1 diagnostic", len(d4) == 1)

    // cleanup
    exec("rm -f " + p1 + " " + p2 + " " + p3 + " " + p4)

    println("PASS " + to_string(pass_count) + "/" + to_string(total_count))
    if failed_name != "" {
        println("first fail: " + failed_name)
        exit(1)
    }
}
