// ═══════════════════════════════════════════════════════════════════
//  test_contrastive_search.hexa — @contrastive_search verification
//
//  Tests:
//    1. cs_softmax sums to 1 and is positive
//    2. cs_softmax handles extreme temp (near-zero guard)
//    3. cs_top_k_indices returns indices in descending-score order
//    4. cs_top_k_indices clamps when k > n
//    5. cs_cosine_sim self == 1.0
//    6. cs_cosine_sim orthogonal == 0.0
//    7. cs_degeneration_penalty empty prev == 0
//    8. cs_degeneration_penalty self-hit == 1
//    9. cs_token_score alpha=0 → model confidence
//   10. cs_token_score alpha=1 → -penalty
//   11. cs_pick_next returns valid topk index and token
//   12. contrastive_generate produces exactly max_new tokens
//   13. contrastive_generate is reproducible (deterministic)
//   14. alpha>0 suppresses repetition vs alpha=0 (rep_rate drops)
//   15. k>vocab clamps safely (no crash, correct length)
//   16. cs_repetition_rate all-same = 1, all-different = 0
//
//  Run: ./hexa self/test_contrastive_search.hexa
// ═══════════════════════════════════════════════════════════════════

// -- inlined from self/ml/contrastive_search.hexa --
// codegen import not wired for test files

// ═══════════════════════════════════════════════════════════════════
//  self/ml/contrastive_search.hexa — Contrastive Search Decoding
//
//  Reference: Su et al. 2022 "A Contrastive Framework for Neural Text
//  Generation". Pick next token from top-k candidates using:
//
//      score(v) = (1 - alpha) * p_model(v)
//              -       alpha  * max_{h in H_prev} cos(h_v, h)
//
//  The first term rewards model confidence; the second punishes
//  "degeneration" — that is, hidden states too similar to a previous
//  token's hidden state. High alpha ⇒ more repetition suppression.
//
//  This module is pure-.hexa and self-contained: mock logits and
//  mock hidden-state embeddings are deterministic hashes so every
//  test is reproducible. No GPU, no I/O, no random.
//
//  Public API:
//    cs_softmax(logits, temp)               -> [float]
//    cs_top_k_indices(scores, k)            -> [int]
//    cs_cosine_sim(a, b)                    -> float
//    cs_degeneration_penalty(h_v, prev_hs)  -> float
//    cs_token_score(p_v, pen_v, alpha)      -> float
//    cs_mock_logits(ctx, vocab)             -> [float]
//    cs_mock_hidden(ctx, token, dim)        -> [float]
//    cs_pick_next(ctx, alpha, k, vocab, dim, prev_hs) -> [int]
//    cs_repetition_rate(tokens)             -> float
//    @contrastive_search
//    contrastive_generate(ctx, max_new, alpha, k, vocab, dim) -> result
// ═══════════════════════════════════════════════════════════════════

// ── tiny math ──────────────────────────────────────────────────────

fn cs_fabs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn cs_max_f(a, b) {
    if a > b { return a }
    return b
}

fn cs_min_f(a, b) {
    if a < b { return a }
    return b
}

// Guarded exp so huge/tiny arguments don't blow up interp math.
fn cs_exp(x) {
    let mut v = x
    if v > 40.0 { v = 40.0 }
    if v < 0.0 - 40.0 { v = 0.0 - 40.0 }
    return exp(v)
}

fn cs_zeros(n) {
    let mut out = []
    let mut i = 0
    while i < n {
        out = out + [0.0]
        i = i + 1
    }
    return out
}

// ── softmax ────────────────────────────────────────────────────────

fn cs_softmax(logits, temp) {
    let n = len(logits)
    let mut t = temp
    if t < 1.0e-6 { t = 1.0e-6 }
    // Subtract max for numerical stability.
    let mut m = logits[0] / t
    let mut i = 1
    while i < n {
        let v = logits[i] / t
        if v > m { m = v }
        i = i + 1
    }
    let mut exps = cs_zeros(n)
    let mut z = 0.0
    let mut j = 0
    while j < n {
        let e = cs_exp(logits[j] / t - m)
        exps[j] = e
        z = z + e
        j = j + 1
    }
    if z < 1.0e-12 { z = 1.0e-12 }
    let mut out = cs_zeros(n)
    let mut k = 0
    while k < n {
        out[k] = exps[k] / z
        k = k + 1
    }
    return out
}

// ── top-k indices by descending score ─────────────────────────────
// Straightforward selection: O(n·k). Returns indices into `scores`.
fn cs_top_k_indices(scores, k) {
    let n = len(scores)
    let mut kk = k
    if kk > n { kk = n }
    let mut used = []
    let mut i = 0
    while i < n {
        used = used + [0]
        i = i + 1
    }
    let mut out = []
    let mut r = 0
    while r < kk {
        let mut best = 0 - 1
        let mut best_v = 0.0 - 1.0e30
        let mut j = 0
        while j < n {
            if used[j] == 0 {
                if scores[j] > best_v {
                    best_v = scores[j]
                    best = j
                }
            }
            j = j + 1
        }
        if best < 0 { return out }
        used[best] = 1
        out = out + [best]
        r = r + 1
    }
    return out
}

// ── cosine similarity (plain float vectors) ───────────────────────

fn cs_cosine_sim(a, b) {
    let n = len(a)
    let mut dot = 0.0
    let mut na = 0.0
    let mut nb = 0.0
    let mut i = 0
    while i < n {
        dot = dot + a[i] * b[i]
        na = na + a[i] * a[i]
        nb = nb + b[i] * b[i]
        i = i + 1
    }
    let denom = sqrt(na) * sqrt(nb)
    if denom < 1.0e-8 { return 0.0 }
    return dot / denom
}

// ── degeneration penalty ──────────────────────────────────────────
// max cosine similarity between candidate hidden state h_v and any
// previous hidden state. Empty prev_hs ⇒ no penalty.
fn cs_degeneration_penalty(h_v, prev_hs) {
    let m = len(prev_hs)
    if m == 0 { return 0.0 }
    let mut best = 0.0 - 1.0
    let mut i = 0
    while i < m {
        let s = cs_cosine_sim(h_v, prev_hs[i])
        if s > best { best = s }
        i = i + 1
    }
    return best
}

// ── contrastive token score ───────────────────────────────────────
// (1 - alpha) * model_confidence - alpha * degeneration_penalty
fn cs_token_score(p_v, pen_v, alpha) {
    let mut a = alpha
    if a < 0.0 { a = 0.0 }
    if a > 1.0 { a = 1.0 }
    return (1.0 - a) * p_v - a * pen_v
}

// ── deterministic mock logits over a vocab ─────────────────────────
// Hash the tail of ctx to a per-token score; higher score means
// "model likes this token more" for the current context.
fn cs_ctx_tail_hash(ctx) {
    let n = len(ctx)
    let mut start = 0
    if n > 6 { start = n - 6 }
    let mut h = 2166136261
    let mut i = start
    while i < n {
        h = (h ^ (ctx[i] + 131)) * 16777619
        h = h % 2147483647
        if h < 0 { h = h + 2147483647 }
        i = i + 1
    }
    return h
}

fn cs_mock_logits(ctx, vocab) {
    let h = cs_ctx_tail_hash(ctx)
    let mut out = cs_zeros(vocab)
    let mut v = 0
    while v < vocab {
        // A smooth-ish distribution over vocab: logit = -|v - pref| / s
        let pref = (h + v * 1315423911) % vocab
        let mut d = v - pref
        if d < 0 { d = 0 - d }
        // Sharper peak so top-k is meaningful.
        out[v] = 0.0 - to_float(d) * 0.35
        v = v + 1
    }
    return out
}

// ── deterministic mock hidden state for (ctx, token) ──────────────
// Returns a `dim`-length float vector in [-1, 1]-ish range.
fn cs_mock_hidden(ctx, token, dim) {
    let h = cs_ctx_tail_hash(ctx)
    let mut out = cs_zeros(dim)
    let mut i = 0
    while i < dim {
        let k = (h + token * 2654435761 + i * 40503) % 1000003
        // Map to [-1, 1] via sin for smoothness.
        out[i] = sin(to_float(k) * 0.0001)
        i = i + 1
    }
    return out
}

// ── pick_next: rank top-k by contrastive score ────────────────────
// Returns [picked_token, picked_index_in_topk, topk_len].
fn cs_pick_next(ctx, alpha, k, vocab, dim, prev_hs) {
    let logits = cs_mock_logits(ctx, vocab)
    let probs = cs_softmax(logits, 1.0)
    let topk = cs_top_k_indices(probs, k)
    let tlen = len(topk)
    let mut best_idx = 0
    let mut best_score = 0.0 - 1.0e30
    let mut i = 0
    while i < tlen {
        let tok = topk[i]
        let p_v = probs[tok]
        let h_v = cs_mock_hidden(ctx, tok, dim)
        let pen_v = cs_degeneration_penalty(h_v, prev_hs)
        let score = cs_token_score(p_v, pen_v, alpha)
        if score > best_score {
            best_score = score
            best_idx = i
        }
        i = i + 1
    }
    let picked = topk[best_idx]
    return [picked, best_idx, tlen]
}

// ── repetition rate: fraction of tokens that repeat a prior one ───
fn cs_repetition_rate(tokens) {
    let n = len(tokens)
    if n <= 1 { return 0.0 }
    let mut rep = 0
    let mut i = 1
    while i < n {
        let mut j = 0
        let mut hit = 0
        while j < i {
            if tokens[j] == tokens[i] {
                hit = 1
                j = i
            } else {
                j = j + 1
            }
        }
        if hit == 1 { rep = rep + 1 }
        i = i + 1
    }
    return to_float(rep) / to_float(n - 1)
}

// ── @contrastive_search: full generate loop ───────────────────────
// Inputs:
//   ctx       — prompt tokens (int array)
//   max_new   — how many new tokens to produce
//   alpha     — degeneration weight (0..1)
//   k         — top-k candidate pool size
//   vocab     — vocabulary size for mock model
//   dim       — hidden dimension for mock embeddings
//
// Returns: [generated_tokens, [rep_rate_x10000], [avg_topk_len]]
@contrastive_search
fn contrastive_generate(ctx, max_new, alpha, k, vocab, dim) {
    // local copy of ctx so we don't mutate the caller's array
    let mut cur = []
    let mut c = 0
    while c < len(ctx) {
        cur = cur + [ctx[c]]
        c = c + 1
    }
    let mut prev_hs = []
    let mut generated = []
    let mut sum_topk = 0
    let mut steps = 0
    while steps < max_new {
        let picked = cs_pick_next(cur, alpha, k, vocab, dim, prev_hs)
        let tok = picked[0]
        let tlen = picked[2]
        sum_topk = sum_topk + tlen
        // commit token
        generated = generated + [tok]
        cur = cur + [tok]
        // remember its hidden state for future degeneration penalty.
        let h_new = cs_mock_hidden(cur, tok, dim)
        prev_hs = prev_hs + [h_new]
        steps = steps + 1
    }
    let rr = cs_repetition_rate(generated)
    let rr_x = to_int(rr * 10000.0)
    let mut avg = 0
    if steps > 0 { avg = sum_topk / steps }
    return [generated, [rr_x], [avg]]
}


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx(a, b, eps) { return fabs(a - b) < eps }

// ── 1. softmax sums to ~1 ─────────────────────────────────────────
let logits_a = [1.0, 2.0, 3.0, 4.0]
let probs_a = cs_softmax(logits_a, 1.0)
let mut sum_a = 0.0
let mut i1 = 0
while i1 < len(probs_a) {
    sum_a = sum_a + probs_a[i1]
    i1 = i1 + 1
}
check("softmax sums to 1", approx(sum_a, 1.0, 1.0e-6))

// all entries > 0
let mut all_pos = 1
let mut i1b = 0
while i1b < len(probs_a) {
    if probs_a[i1b] <= 0.0 { all_pos = 0 }
    i1b = i1b + 1
}
check("softmax all-positive", all_pos == 1)

// ── 2. softmax tolerates near-zero temperature ────────────────────
let probs_b = cs_softmax([1.0, 5.0, 2.0], 1.0e-12)
let mut sum_b = 0.0
let mut i2 = 0
while i2 < len(probs_b) {
    sum_b = sum_b + probs_b[i2]
    i2 = i2 + 1
}
check("softmax temp-guard sums to 1", approx(sum_b, 1.0, 1.0e-6))

// ── 3. top-k indices ranked descending ────────────────────────────
let scores = [0.1, 0.5, 0.2, 0.9, 0.3]
let tk = cs_top_k_indices(scores, 3)
check("top_k len = 3", len(tk) == 3)
check("top_k[0] picks 0.9", tk[0] == 3)
check("top_k[1] picks 0.5", tk[1] == 1)
check("top_k[2] picks 0.3", tk[2] == 4)

// ── 4. top-k clamps when k > n ────────────────────────────────────
let tk_clamp = cs_top_k_indices([0.7, 0.2], 5)
check("top_k clamp to n", len(tk_clamp) == 2)

// ── 5. cosine self-similarity = 1 ─────────────────────────────────
let v = [0.3, 0.5, 0.1, 0.8]
check("cosine self = 1", approx(cs_cosine_sim(v, v), 1.0, 1.0e-6))

// ── 6. cosine orthogonal = 0 ──────────────────────────────────────
let ox = [1.0, 0.0, 0.0]
let oy = [0.0, 1.0, 0.0]
check("cosine orthogonal = 0", approx(cs_cosine_sim(ox, oy), 0.0, 1.0e-6))

// ── 7. degeneration penalty with empty prev = 0 ───────────────────
let pen_empty = cs_degeneration_penalty([0.1, 0.2, 0.3], [])
check("pen empty = 0", approx(pen_empty, 0.0, 1.0e-6))

// ── 8. degeneration penalty self-hit = 1 ──────────────────────────
let h0 = cs_mock_hidden([1, 2, 3], 5, 6)
let pen_self = cs_degeneration_penalty(h0, [h0])
check("pen self = 1", approx(pen_self, 1.0, 1.0e-6))

// ── 9. token_score alpha=0 → p_v ──────────────────────────────────
check("score alpha=0", approx(cs_token_score(0.4, 0.9, 0.0), 0.4, 1.0e-9))

// ── 10. token_score alpha=1 → -pen ───────────────────────────────
check("score alpha=1", approx(cs_token_score(0.4, 0.9, 1.0), 0.0 - 0.9, 1.0e-9))

// alpha clamp
check("score alpha>1 clamped", approx(cs_token_score(0.4, 0.9, 2.0), 0.0 - 0.9, 1.0e-9))
check("score alpha<0 clamped", approx(cs_token_score(0.4, 0.9, 0.0 - 1.0), 0.4, 1.0e-9))

// ── 11. pick_next returns [token, topk_idx, topk_len] ─────────────
let picked = cs_pick_next([1, 2], 0.5, 4, 8, 4, [])
check("pick_next has 3 fields", len(picked) == 3)
check("pick_next topk_len = 4", picked[2] == 4)
check("pick_next idx in range", picked[1] >= 0)
check("pick_next idx < topk_len", picked[1] < picked[2])
check("pick_next token in vocab", picked[0] >= 0)
check("pick_next token < 8", picked[0] < 8)

// ── 12. contrastive_generate length = max_new ─────────────────────
let g = contrastive_generate([1, 2, 3], 8, 0.5, 4, 16, 6)
check("generate len = max_new", len(g[0]) == 8)
check("generate has 3 fields", len(g) == 3)
check("generate rep field is array", len(g[1]) == 1)
check("generate avg_topk field is array", len(g[2]) == 1)

// ── 13. reproducibility (same inputs → same outputs) ──────────────
let r1 = contrastive_generate([1, 2, 3], 10, 0.6, 4, 16, 6)
let r2 = contrastive_generate([1, 2, 3], 10, 0.6, 4, 16, 6)
let mut same = 1
let mut ri = 0
while ri < len(r1[0]) {
    if r1[0][ri] != r2[0][ri] { same = 0 }
    ri = ri + 1
}
check("reproducible across runs", same == 1)
check("reproducible rep rate", r1[1][0] == r2[1][0])

// ── 14. alpha > 0 suppresses repetition vs alpha = 0 ──────────────
let ga = contrastive_generate([1, 2, 3], 32, 0.0, 5, 20, 8)
let gb = contrastive_generate([1, 2, 3], 32, 0.7, 5, 20, 8)
let rep_no_pen = ga[1][0]
let rep_with_pen = gb[1][0]
println("rep_alpha_0_x10000=" + to_string(rep_no_pen))
println("rep_alpha_0.7_x10000=" + to_string(rep_with_pen))
check("alpha>0 lowers rep rate", rep_with_pen < rep_no_pen)

// pick_next with prev hidden states differs from no-prev pick
let pick_none = cs_pick_next([1, 2], 0.9, 3, 8, 4, [])
let hp = cs_mock_hidden([1, 2], pick_none[0], 4)
let pick_prev = cs_pick_next([1, 2], 0.9, 3, 8, 4, [hp])
check("prev hs changes pick", pick_prev[0] != pick_none[0])

// ── 15. k > vocab safely clamped ──────────────────────────────────
let gk = contrastive_generate([1], 5, 0.5, 100, 8, 4)
check("k>vocab produces max_new", len(gk[0]) == 5)

// ── 16. repetition rate endpoints ─────────────────────────────────
check("rep rate all-same = 1", approx(cs_repetition_rate([3, 3, 3, 3]), 1.0, 1.0e-9))
check("rep rate all-diff = 0", approx(cs_repetition_rate([1, 2, 3, 4]), 0.0, 1.0e-9))
check("rep rate singleton = 0", approx(cs_repetition_rate([7]), 0.0, 1.0e-9))

// ── deterministic smoke values (guards against silent regression) ──
let det = contrastive_generate([1, 2, 3], 8, 0.5, 4, 16, 6)
println("det_tokens=" + to_string(det[0]))
println("det_rep_x=" + to_string(det[1][0]))
println("det_avg_topk=" + to_string(det[2][0]))
check("det first token = 1", det[0][0] == 1)
check("det avg_topk = 4", det[2][0] == 4)

println("")
println("pass=" + to_string(pass_count) + " fail=" + to_string(fail_count))
if fail_count == 0 {
    println("ALL PASS")
} else {
    println("FAILED")
}
println(to_string(pass_count) + " passed")
