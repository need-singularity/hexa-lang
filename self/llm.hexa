// self/llm.hexa — HEXA LLM ported from src/llm.rs
// LLM backend for `generate` and `optimize` keywords.
// Resolution order: Cache -> Claude API -> Local Ollama -> Offline fallback.
// Results cached in .hexa-cache/ keyed by hash of prompt.

// ── Cache ───────────────────────────────────────────────────

fn hash_prompt(prompt: string) -> string {
    // FNV-1a style hash -> string key
    let h = 14695981039346656037
    let i = 0
    while i < len(prompt) {
        h = h ^ to_int(prompt[i])
        h = h * 1099511628211
        i = i + 1
    }
    return to_string(h)
}

fn cache_path(key: string) -> string {
    return ".hexa-cache/" + key + ".hexa"
}

fn cache_get(prompt: string) -> string {
    // Check cache for a previous result
    // In full runtime: read_file(cache_path(hash_prompt(prompt)))
    // Returns "" on miss
    return ""
}

fn cache_put(prompt: string, code: string) {
    // Store result in cache
    // In full runtime:
    //   let key = hash_prompt(prompt)
    //   let path = cache_path(key)
    //   write_file(path, code)
}

// ── Prompt builders ─────────────────────────────────────────

fn build_generate_prompt(description: string, type_hint: string) -> string {
    let prompt = "You are a code generator for HEXA, a programming language similar to Rust.\n"
    prompt = prompt + "HEXA syntax rules:\n"
    prompt = prompt + "- Variables: let x = expr\n"
    prompt = prompt + "- Functions: fn name(a: type, b: type) -> ret_type { body }\n"
    prompt = prompt + "- Control: if/else, for x in iter { }, while cond { }, match\n"
    prompt = prompt + "- Return: return expr\n"
    prompt = prompt + "- Types: int, float, str, bool, [T] (array)\n"
    prompt = prompt + "- Builtins: print(), println(), len(), to_string(), to_int()\n\n"
    prompt = prompt + "Generate ONLY the function body (statements inside { }), no fn signature.\n"
    prompt = prompt + "Output raw HEXA code only, no markdown fences, no comments, no explanation.\n\n"
    if len(type_hint) > 0 {
        prompt = prompt + "Type signature: " + type_hint + "\n"
    }
    prompt = prompt + "Description: " + description + "\n\nHEXA code:"
    return prompt
}

fn build_optimize_prompt(original: string, fn_name: string) -> string {
    let prompt = "You are a code optimizer for HEXA, a programming language similar to Rust.\n"
    prompt = prompt + "Optimize the following HEXA function for performance (reduce time complexity, "
    prompt = prompt + "use iteration instead of recursion where possible, add memoization if helpful).\n"
    prompt = prompt + "Keep the same function name and signature. Keep the same behavior.\n"
    prompt = prompt + "Output ONLY the complete optimized function as valid HEXA code.\n"
    prompt = prompt + "No markdown fences, no comments, no explanation.\n\n"
    prompt = prompt + "Function to optimize (name: " + fn_name + "):\n" + original + "\n\nOptimized HEXA code:"
    return prompt
}

// ── Code extraction ─────────────────────────────────────────

fn extract_code(text: string) -> string {
    // Strip markdown code fences if present
    let trimmed = string_trim(text)
    if string_starts_with(trimmed, "```") {
        let without_opening = ""
        if string_starts_with(trimmed, "```hexa") {
            without_opening = string_slice(trimmed, 7, len(trimmed))
        } else {
            if string_starts_with(trimmed, "```rust") {
                without_opening = string_slice(trimmed, 7, len(trimmed))
            } else {
                without_opening = string_slice(trimmed, 3, len(trimmed))
            }
        }
        let wo = string_trim(without_opening)
        if string_ends_with(wo, "```") {
            return string_trim(string_slice(wo, 0, len(wo) - 3))
        }
        return string_trim(wo)
    }
    return trimmed
}

// ── Offline fallback ────────────────────────────────────────

fn offline_generate_fallback(description: string, type_hint: string) -> string {
    // Return a stub that panics at runtime with the description
    if len(type_hint) == 0 {
        return "panic(\"LLM not available: " + description + "\")"
    }
    return "panic(\"LLM not available: " + description + " (expected: " + type_hint + ")\")"
}

// ── Generate code via LLM ───────────────────────────────────

fn generate_code(description: string, type_hint: string) -> string {
    let prompt = build_generate_prompt(description, type_hint)

    // 1. Check cache
    let cached = cache_get(prompt)
    if len(cached) > 0 {
        return cached
    }

    // 2. Try Claude API (requires ANTHROPIC_API_KEY env var)
    // In full runtime: call HTTP POST to api.anthropic.com/v1/messages
    // with model "claude-sonnet-4-20250514", max_tokens 1024

    // 3. Try local Ollama at localhost:11434
    // In full runtime: call HTTP POST to localhost:11434/api/generate
    // with model "codellama", stream false

    // 4. Offline fallback
    return offline_generate_fallback(description, type_hint)
}

// ── Optimize code via LLM ───────────────────────────────────

fn optimize_code(original: string, fn_name: string) -> string {
    let prompt = build_optimize_prompt(original, fn_name)

    // 1. Check cache
    let cached = cache_get(prompt)
    if len(cached) > 0 {
        return cached
    }

    // 2. Try Claude API / Ollama (same resolution order as generate)
    // Skipped in self-hosted port

    // 3. Offline: return original unchanged
    return original
}

// ── LLM backend configuration ───────────────────────────────

struct LLMConfig {
    provider: string,
    model: string,
    api_key: string,
    base_url: string,
    max_tokens: int
}

fn llm_config_claude() -> LLMConfig {
    return LLMConfig {
        provider: "claude",
        model: "claude-sonnet-4-20250514",
        api_key: "",
        base_url: "https://api.anthropic.com/v1/messages",
        max_tokens: 1024
    }
}

fn llm_config_ollama() -> LLMConfig {
    return LLMConfig {
        provider: "ollama",
        model: "codellama",
        api_key: "",
        base_url: "http://localhost:11434/api/generate",
        max_tokens: 1024
    }
}

fn llm_available(config: LLMConfig) -> bool {
    if config.provider == "claude" {
        return len(config.api_key) > 0
    }
    if config.provider == "ollama" {
        // Would check localhost:11434 connectivity
        return false
    }
    return false
}

fn llm_resolve_provider() -> string {
    // Resolution order: claude (if key), ollama (if reachable), offline
    // In full runtime would check env vars and network
    return "offline"
}
