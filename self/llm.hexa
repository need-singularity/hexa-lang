// self/llm.hexa — HEXA LLM ported from src/llm.rs
// LLM backend for `generate` and `optimize` keywords.
// Resolution: 1) Cache  2) Claude API  3) Ollama  4) Offline fallback
// Results cached in .hexa-cache/ keyed by hash of prompt.

// ── Cache ───────────────────────────────────────────────

fn cache_hash(prompt: string) -> string {
    // Simple hash using FNV-1a style
    let h = 14695981039346656037
    let i = 0
    while i < len(prompt) {
        h = h + to_int(prompt[i])
        h = h * 1099511628211
        i = i + 1
    }
    return to_string(h)
}

fn cache_path(key: string) -> string {
    return ".hexa-cache/" + key + ".hexa"
}

fn cache_get(prompt: string) -> string {
    // Returns cached code or "" on miss
    let key = cache_hash(prompt)
    let path = cache_path(key)
    if file_exists(path) {
        return read_file(path)
    }
    return ""
}

fn cache_put(prompt: string, code: string) {
    let key = cache_hash(prompt)
    let path = cache_path(key)
    write_file(path, code)
}

// ── Prompt builders ─────────────────────────────────────

fn build_generate_prompt(description: string, type_hint: string) -> string {
    let prompt = "You are a code generator for HEXA, a programming language similar to Rust.\n"
    prompt = prompt + "HEXA syntax rules:\n"
    prompt = prompt + "- Variables: let x = expr\n"
    prompt = prompt + "- Functions: fn name(a: type, b: type) -> ret_type { body }\n"
    prompt = prompt + "- Control: if/else, for x in iter { }, while cond { }, match\n"
    prompt = prompt + "- Return: return expr\n"
    prompt = prompt + "- Types: int, float, str, bool, [T] (array)\n"
    prompt = prompt + "- Builtins: print(), println(), len(), to_string(), to_int()\n\n"
    prompt = prompt + "Generate ONLY the function body (statements inside { }), no fn signature.\n"
    prompt = prompt + "Output raw HEXA code only, no markdown fences, no comments, no explanation.\n\n"
    if type_hint != "" {
        prompt = prompt + "Type signature: " + type_hint + "\n"
    }
    prompt = prompt + "Description: " + description + "\n\nHEXA code:"
    return prompt
}

fn build_optimize_prompt(original: string, fn_name: string) -> string {
    let prompt = "You are a code optimizer for HEXA, a programming language similar to Rust.\n"
    prompt = prompt + "Optimize the following HEXA function for performance (reduce time complexity, "
    prompt = prompt + "use iteration instead of recursion where possible, add memoization if helpful).\n"
    prompt = prompt + "Keep the same function name and signature. Keep the same behavior.\n"
    prompt = prompt + "Output ONLY the complete optimized function as valid HEXA code.\n"
    prompt = prompt + "No markdown fences, no comments, no explanation.\n\n"
    prompt = prompt + "Function to optimize (name: " + fn_name + "):\n" + original + "\n\nOptimized HEXA code:"
    return prompt
}

// ── Code extraction ─────────────────────────────────────

fn extract_code(text: string) -> string {
    let trimmed = trim(text)
    // Remove markdown code fences if present
    if starts_with(trimmed, "```") {
        // Strip opening fence
        let without_opening = ""
        if starts_with(trimmed, "```hexa") {
            without_opening = slice(trimmed, 7, len(trimmed))
        } else if starts_with(trimmed, "```rust") {
            without_opening = slice(trimmed, 7, len(trimmed))
        } else {
            without_opening = slice(trimmed, 3, len(trimmed))
        }
        // Strip closing fence
        let without_closing = trim(without_opening)
        if ends_with(without_closing, "```") {
            without_closing = slice(without_closing, 0, len(without_closing) - 3)
        }
        return trim(without_closing)
    }
    return trimmed
}

// ── Generate code ───────────────────────────────────────

fn generate_code(description: string, type_hint: string) -> string {
    let prompt = build_generate_prompt(description, type_hint)

    // 1. Check cache
    let cached = cache_get(prompt)
    if cached != "" {
        return cached
    }

    // 2. Try Claude API (via env var)
    let api_key = env_var("ANTHROPIC_API_KEY")
    if api_key != "" {
        let body = "{\"model\":\"claude-sonnet-4-20250514\",\"max_tokens\":1024,\"messages\":[{\"role\":\"user\",\"content\":\"" + escape_prompt(prompt) + "\"}]}"
        let resp = http_post("https://api.anthropic.com/v1/messages", body)
        if resp != "" {
            let code = extract_code(resp)
            if code != "" {
                cache_put(prompt, code)
                return code
            }
        }
    }

    // 3. Try local Ollama
    let ollama_body = "{\"model\":\"codellama\",\"prompt\":\"" + escape_prompt(prompt) + "\",\"stream\":false}"
    let ollama_resp = http_post("http://localhost:11434/api/generate", ollama_body)
    if ollama_resp != "" {
        let code = extract_code(ollama_resp)
        if code != "" {
            cache_put(prompt, code)
            return code
        }
    }

    // 4. Offline fallback
    return offline_generate_fallback(description, type_hint)
}

// ── Optimize code ───────────────────────────────────────

fn optimize_code(original: string, fn_name: string) -> string {
    let prompt = build_optimize_prompt(original, fn_name)

    // 1. Check cache
    let cached = cache_get(prompt)
    if cached != "" {
        return cached
    }

    // 2. Try Claude API
    let api_key = env_var("ANTHROPIC_API_KEY")
    if api_key != "" {
        let body = "{\"model\":\"claude-sonnet-4-20250514\",\"max_tokens\":1024,\"messages\":[{\"role\":\"user\",\"content\":\"" + escape_prompt(prompt) + "\"}]}"
        let resp = http_post("https://api.anthropic.com/v1/messages", body)
        if resp != "" {
            let code = extract_code(resp)
            if code != "" {
                cache_put(prompt, code)
                return code
            }
        }
    }

    // 3. Try local Ollama
    let ollama_body = "{\"model\":\"codellama\",\"prompt\":\"" + escape_prompt(prompt) + "\",\"stream\":false}"
    let ollama_resp = http_post("http://localhost:11434/api/generate", ollama_body)
    if ollama_resp != "" {
        let code = extract_code(ollama_resp)
        if code != "" {
            cache_put(prompt, code)
            return code
        }
    }

    // 4. Offline: return original unchanged
    return original
}

// ── Offline fallback ────────────────────────────────────

fn offline_generate_fallback(description: string, type_hint: string) -> string {
    if type_hint == "" {
        return "panic(\"LLM not available: " + description + "\")"
    }
    return "panic(\"LLM not available: " + description + " (expected: " + type_hint + ")\")"
}

// ── Helpers ─────────────────────────────────────────────

fn escape_prompt(s: string) -> string {
    let out = ""
    let i = 0
    while i < len(s) {
        let ch = s[i]
        if ch == "\"" { out = out + "\\\"" }
        else if ch == "\\" { out = out + "\\\\" }
        else if ch == "\n" { out = out + "\\n" }
        else if ch == "\r" { out = out + "\\r" }
        else if ch == "\t" { out = out + "\\t" }
        else { out = out + ch }
        i = i + 1
    }
    return out
}
