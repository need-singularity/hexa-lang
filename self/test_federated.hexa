// ===================================================================
//  test_federated.hexa — Federated Learning tests
//
//  Tests:
//    1.  create_federation
//    2.  select_clients fraction
//    3.  select_clients different rounds -> different selections
//    4.  create_client_data
//    5.  local_train updates weights
//    6.  fed_avg equal weights
//    7.  fed_avg weighted
//    8.  clip_gradients under norm
//    9.  clip_gradients over norm
//   10.  add_dp_noise adds noise
//   11.  compute_epsilon
//   12.  run_federation_round
//   13.  run_federation multi-round
//
//  Run: hexa self/test_federated.hexa
// ===================================================================
import "ml/federated.hexa"

let mut pass = 0
let mut fail = 0

fn check(name, cond) {
    if cond {
        pass = pass + 1
        println("[PASS] " + name)
    } else {
        fail = fail + 1
        println("[FAIL] " + name)
    }
}

fn abs_f(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn sqrt_f(x) {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    let mut i = 0
    while i < 15 {
        g = (g + x / g) / 2.0
        i = i + 1
    }
    return g
}

// ── 1. create_federation ────────────────────────────────────────
let fed1 = create_federation(10, 0.3)
check("create_federation num_clients", fed1["num_clients"] == 10)
check("create_federation fraction", fed1["fraction"] == 0.3)
check("create_federation round 0", fed1["round"] == 0)

// ── 2. select_clients fraction ──────────────────────────────────
let sel1 = select_clients(fed1, 0)
check("select_clients returns array", len(sel1) > 0)
check("select_clients ~30%", len(sel1) == 3)

// ── 3. select_clients different rounds ──────────────────────────
let sel2 = select_clients(fed1, 1)
let sel3 = select_clients(fed1, 2)
// at least one selection should differ (different seeds)
let mut any_diff = false
if len(sel2) > 0 {
    if len(sel3) > 0 {
        if sel2[0] != sel3[0] {
            any_diff = true
        }
    }
}
check("select_clients varies by round", any_diff)

// ── 4. create_client_data ───────────────────────────────────────
let inputs = [[1.0, 0.0], [0.0, 1.0]]
let targets = [[1.0], [0.0]]
let cd1 = create_client_data(inputs, targets)
check("client_data has inputs", len(cd1["inputs"]) == 2)
check("client_data has targets", len(cd1["targets"]) == 2)
check("client_data size", cd1["size"] == 2)

// ── 5. local_train updates weights ──────────────────────────────
let model1 = [0.5, 0.5]
let trained = local_train(cd1, model1, 5, 0.1)
check("local_train returns weights", len(trained) == 2)
let diff1 = abs_f(trained[0] - model1[0]) + abs_f(trained[1] - model1[1])
check("local_train changes weights", diff1 > 0.001)

// ── 6. fed_avg equal weights ────────────────────────────────────
let m1 = [1.0, 2.0, 3.0]
let m2 = [3.0, 4.0, 5.0]
let avg1 = fed_avg([m1, m2], [1.0, 1.0])
check("fed_avg equal w[0]", abs_f(avg1[0] - 2.0) < 0.001)
check("fed_avg equal w[1]", abs_f(avg1[1] - 3.0) < 0.001)
check("fed_avg equal w[2]", abs_f(avg1[2] - 4.0) < 0.001)

// ── 7. fed_avg weighted ─────────────────────────────────────────
let avg2 = fed_avg([m1, m2], [3.0, 1.0])
// weighted avg[0] = (1*3 + 3*1) / 4 = 6/4 = 1.5
check("fed_avg weighted w[0]", abs_f(avg2[0] - 1.5) < 0.001)
// avg[1] = (2*3 + 4*1) / 4 = 10/4 = 2.5
check("fed_avg weighted w[1]", abs_f(avg2[1] - 2.5) < 0.001)

// ── 8. clip_gradients under norm ────────────────────────────────
let grad1 = [0.1, 0.2, 0.1]
let clipped1 = clip_gradients(grad1, 10.0)
check("clip under norm unchanged[0]", abs_f(clipped1[0] - 0.1) < 0.001)
check("clip under norm unchanged[1]", abs_f(clipped1[1] - 0.2) < 0.001)

// ── 9. clip_gradients over norm ─────────────────────────────────
let grad2 = [3.0, 4.0]
let clipped2 = clip_gradients(grad2, 1.0)
// norm = 5, should clip to 1/5
let clipped_norm = sqrt_f(clipped2[0] * clipped2[0] + clipped2[1] * clipped2[1])
check("clip over norm = clip_norm", abs_f(clipped_norm - 1.0) < 0.01)

// ── 10. add_dp_noise ────────────────────────────────────────────
let grad3 = [1.0, 2.0, 3.0]
let noisy = add_dp_noise(grad3, 0.5, 10.0)
check("dp_noise same length", len(noisy) == 3)
// noise should make at least one value differ
let mut noise_diff = 0.0
let mut ni = 0
while ni < 3 {
    noise_diff = noise_diff + abs_f(noisy[ni] - grad3[ni])
    ni = ni + 1
}
check("dp_noise adds perturbation", noise_diff > 0.001)

// ── 11. compute_epsilon ─────────────────────────────────────────
let eps1 = compute_epsilon(1.0, 0.00001, 100)
check("compute_epsilon positive", eps1 > 0.0)
// higher sigma -> lower epsilon (more private)
let eps2 = compute_epsilon(10.0, 0.00001, 100)
check("higher sigma -> lower epsilon", eps2 < eps1)

// ── 12. run_federation_round ────────────────────────────────────
let mut fed2 = create_federation(3, 0.67)
let cd_list = [
    create_client_data([[1.0, 0.0]], [[1.0]]),
    create_client_data([[0.0, 1.0]], [[0.0]]),
    create_client_data([[1.0, 1.0]], [[1.0]])
]
let global_model = [0.0, 0.0]
let round_result = run_federation_round(fed2, cd_list, global_model, 1, 0.1)
check("federation_round returns model", len(round_result["model"]) == 2)
check("federation_round has selected", len(round_result["selected"]) > 0)

// ── 13. run_federation multi-round ──────────────────────────────
let mut fed3 = create_federation(3, 0.67)
let fed_result = run_federation(fed3, cd_list, global_model, 3, 2, 0.1)
check("multi-round model exists", len(fed_result["model"]) == 2)
// model should have changed from [0,0]
let fed_diff = abs_f(fed_result["model"][0]) + abs_f(fed_result["model"][1])
check("multi-round model updated", fed_diff > 0.001)

// ── Summary ─────────────────────────────────────────────────────
println("")
println("========================================")
println("  federated tests: " + str(pass) + " passed, " + str(fail) + " failed")
println("========================================")
