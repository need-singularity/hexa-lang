// ═══════════════════════════════════════════════════════════════════
//  Test 15 — full 3D merged step (TP=2, PP=2, DP=2, ZeRO-1) == reference
// ═══════════════════════════════════════════════════════════════════
fn test_merged_full_3d_zero1() {
    println("[test] 15. merged step full 3D (2,2,2,ZeRO1) == ref")
    let cfg = p3d_init(2, 2, 2, 4, 4, 4, 6, 1)
    let stack = make_stack(cfg.num_layers, cfg.dim, cfg.hidden)
    let X = tp_mat_range(cfg.global_batch, cfg.dim, 0.05, 0.011)
    let flat_params = [0.01, 0.02, 0.03, 0.04]
    let syn_grads = [0.1, 0.1, 0.1, 0.1]
    let res = p3d_step(cfg, X, stack, flat_params, syn_grads, 0.01)
    let Y_ref = p3d_reference_forward(cfg, X, stack)
    let Y_merged = p3d_concat_outputs(res.outputs, p3d_dp_batch_size(cfg), cfg.dim)
    check("full 3D ZeRO-1 match", max_abs_diff3d(Y_ref, Y_merged, cfg.global_batch * cfg.dim) < 0.000001)
    check("world_size == 8", cfg.world_size == 8)
    check("mesh valid", res.mesh_valid)
}

// ═══════════════════════════════════════════════════════════════════
//  Test 16 — full 3D merged step with ZeRO-3
// ═══════════════════════════════════════════════════════════════════
fn test_merged_full_3d_zero3() {
    println("[test] 16. merged step full 3D (2,2,2,ZeRO3) == ref")
    let cfg = p3d_init(2, 2, 2, 4, 4, 4, 6, 3)
    let stack = make_stack(cfg.num_layers, cfg.dim, cfg.hidden)
    let X = tp_mat_range(cfg.global_batch, cfg.dim, 0.05, 0.011)
    let flat_params = [0.01, 0.02, 0.03, 0.04]
    let syn_grads = [0.1, 0.1, 0.1, 0.1]
    let res = p3d_step(cfg, X, stack, flat_params, syn_grads, 0.01)
    let Y_ref = p3d_reference_forward(cfg, X, stack)
    let Y_merged = p3d_concat_outputs(res.outputs, p3d_dp_batch_size(cfg), cfg.dim)
    check("full 3D ZeRO-3 match", max_abs_diff3d(Y_ref, Y_merged, cfg.global_batch * cfg.dim) < 0.000001)
    check("ZeRO-3 stage", res.opt_ctx.stage == 3)
}

// ═══════════════════════════════════════════════════════════════════
//  Test 17 — optimizer context advanced after step
// ═══════════════════════════════════════════════════════════════════
fn test_opt_t_advanced() {
    println("[test] 17. optimizer t incremented after merged step")
    let cfg = p3d_init(2, 2, 2, 4, 4, 4, 6, 1)
    let stack = make_stack(cfg.num_layers, cfg.dim, cfg.hidden)
    let X = tp_mat_range(cfg.global_batch, cfg.dim, 0.05, 0.011)
    let flat_params = [0.01, 0.02, 0.03, 0.04]
    let syn_grads = [0.1, 0.1, 0.1, 0.1]
    let res = p3d_step(cfg, X, stack, flat_params, syn_grads, 0.01)
    check("t == 1", res.opt_ctx.t == 1)
}

// ═══════════════════════════════════════════════════════════════════
//  Test 18 — memory sharding: ZeRO-3 rank cost < ZeRO-0 cost
// ═══════════════════════════════════════════════════════════════════
fn test_memory_zero3_lt_zero0() {
    println("[test] 18. p3d_memory_per_rank ZeRO-3 < ZeRO-0")
    let cfg_zero0 = p3d_init(2, 2, 2, 4, 4, 4, 6, 0)
    let cfg_zero3 = p3d_init(2, 2, 2, 4, 4, 4, 6, 3)
    let m_z0 = p3d_memory_per_rank(cfg_zero0, 0)
    let m_z3 = p3d_memory_per_rank(cfg_zero3, 0)
    check("ZeRO-3 < ZeRO-0", m_z3 < m_z0)
    let base = p3d_memory_baseline(cfg_zero3)
    check("baseline > ZeRO-3 rank", base > m_z3)
}

// ═══════════════════════════════════════════════════════════════════
//  Test 19 — bubble_steps matches expected formula
// ═══════════════════════════════════════════════════════════════════
fn test_bubble_steps() {
    println("[test] 19. bubble_steps == 2*(pp_size-1)")
    // PP=1 → bubble 0
    let cfg1 = p3d_init(1, 1, 1, 2, 2, 4, 6, 0)
    let stack1 = make_stack(cfg1.num_layers, cfg1.dim, cfg1.hidden)
    let X1 = tp_mat_range(cfg1.global_batch, cfg1.dim, 0.05, 0.011)
    let res1 = p3d_step(cfg1, X1, stack1, [0.01, 0.02], [0.1, 0.1], 0.01)
    check("PP=1 bubble=0", res1.bubble_steps == 0)
    // PP=2 → bubble 2
    let cfg2 = p3d_init(1, 2, 1, 4, 2, 4, 6, 1)
    let stack2 = make_stack(cfg2.num_layers, cfg2.dim, cfg2.hidden)
    let X2 = tp_mat_range(cfg2.global_batch, cfg2.dim, 0.05, 0.011)
    let res2 = p3d_step(cfg2, X2, stack2, [0.01, 0.02, 0.03, 0.04], [0.1, 0.1, 0.1, 0.1], 0.01)
    check("PP=2 bubble=2", res2.bubble_steps == 2)
}

// ═══════════════════════════════════════════════════════════════════
//  Runner
// ═══════════════════════════════════════════════════════════════════
fn run_all() {
    println("============================================================")
    println("  3D Parallelism Tests (TP x PP x ZeRO/DP)  — ML #96")
    println("============================================================")
    test_init()
    test_coord_roundtrip()
    test_mesh_build()
    test_layer_ranges_balanced()
    test_load_imbalance_zero()
    test_load_imbalance_nonzero()
    test_ffn_tp1()
    test_ffn_tp2()
    test_split_batch_roundtrip()
    test_grad_allreduce()
    test_merged_trivial()
    test_merged_tp_only()
    test_merged_pp_only()
    test_merged_dp_only()
    test_merged_full_3d_zero1()
    test_merged_full_3d_zero3()
    test_opt_t_advanced()
    test_memory_zero3_lt_zero0()
    test_bubble_steps()

    println("")
    println("============================================================")
    let total = pass_count + fail_count
    println("  Results: " + str(pass_count) + "/" + str(total) + " passed")
    if fail_count > 0 {
        println("  FAILED: " + str(fail_count) + " tests")
    } else {
        println("  ALL PASSED")
    }
    println("============================================================")
}

run_all()
