// ═══════════════════════════════════════════════════════════
//  test_bigint_edge.hexa — BigInt Edge Cases
//  Tests: arbitrary precision, boundary, signed, ops chain,
//         equality, string round-trip, comparisons, zero/one
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA BigInt Edge Case Tests")
println("═══════════════════════════════════════════════════════")

// ── 1. Construction & type ───────────────────────────────
check("bigint 0 type", type_of(bigint("0")), "bigint")
check("bigint huge type", type_of(bigint("999999999999999999999999")), "bigint")
check("bigint 0 str", to_string(bigint("0")), "0")
check("bigint 1 str", to_string(bigint("1")), "1")
check("bigint neg str", to_string(bigint("-1")), "-1")
check("bigint 42 str", to_string(bigint("42")), "42")

// ── 2. Boundary crossings (i64 max = 9223372036854775807) ─
let near = bigint("9223372036854775807")
check("i64 max", to_string(near), "9223372036854775807")
let over = near + bigint("1")
check("i64 max + 1", to_string(over), "9223372036854775808")
let over2 = near + bigint("1000")
check("i64 max + 1000", to_string(over2), "9223372036854776807")

// ── 3. 30-digit add ──────────────────────────────────────
let a30 = bigint("123456789012345678901234567890")
let b30 = bigint("987654321098765432109876543210")
check("30d add", to_string(a30 + b30), "1111111110111111111011111111100")
check("30d sub", to_string(b30 - a30), "864197532086419753208641975320")

// ── 4. Repeated doubling ─────────────────────────────────
let mut p = bigint("1")
p = p + p
p = p + p
p = p + p
p = p + p
p = p + p
p = p + p
p = p + p
p = p + p
p = p + p
p = p + p  // 2^10 = 1024
check("doubled 10x", to_string(p), "1024")

// ── 5. Multiplication chain ──────────────────────────────
let m = bigint("2") * bigint("3") * bigint("5") * bigint("7") * bigint("11")
check("2*3*5*7*11", to_string(m), "2310")
let m2 = bigint("100") * bigint("100") * bigint("100")
check("100^3", to_string(m2), "1000000")

// ── 6. Zero arithmetic ───────────────────────────────────
check("0 + 0", to_string(bigint("0") + bigint("0")), "0")
check("0 + 5", to_string(bigint("0") + bigint("5")), "5")
check("7 * 0", to_string(bigint("7") * bigint("0")), "0")
check("0 - 5", to_string(bigint("0") - bigint("5")), "-5")
check("x - x", to_string(bigint("99") - bigint("99")), "0")

// ── 7. Signed arithmetic ─────────────────────────────────
check("-5 + 3", to_string(bigint("-5") + bigint("3")), "-2")
check("-5 + 5", to_string(bigint("-5") + bigint("5")), "0")
check("-5 * -5", to_string(bigint("-5") * bigint("-5")), "25")
check("-2 * 3", to_string(bigint("-2") * bigint("3")), "-6")

// ── 8. Comparisons ───────────────────────────────────────
check("big > small", bigint("1000000000000") > bigint("999"), true)
check("big == big", bigint("42") == bigint("42"), true)
check("big != big", bigint("42") != bigint("43"), true)
check("big < neg", bigint("-1") < bigint("0"), true)
check("big >= eq", bigint("5") >= bigint("5"), true)
check("big <= eq", bigint("5") <= bigint("5"), true)
check("huge eq", bigint("12345678901234567890") == bigint("12345678901234567890"), true)

// ── 9. String round-trip ─────────────────────────────────
let huge = "314159265358979323846264338327950288419716939937510"
check("round trip huge", to_string(bigint(huge)), huge)
let neg_huge = "-271828182845904523536028747135266249775724709369995"
check("round trip neg huge", to_string(bigint(neg_huge)), neg_huge)

// ── 10. Factorial (iterative) ────────────────────────────
let mut fact = bigint("1")
let mut i = 1
while i <= 20 {
    fact = fact * bigint(to_string(i))
    i = i + 1
}
check("20!", to_string(fact), "2432902008176640000")

let mut fact25 = bigint("1")
let mut j = 1
while j <= 25 {
    fact25 = fact25 * bigint(to_string(j))
    j = j + 1
}
check("25!", to_string(fact25), "15511210043330985984000000")

// ── 11. Power of 2 ────────────────────────────────────────
let mut pw = bigint("1")
let mut k = 0
while k < 64 {
    pw = pw * bigint("2")
    k = k + 1
}
check("2^64", to_string(pw), "18446744073709551616")

// ── 12. Carry propagation ────────────────────────────────
check("9+1", to_string(bigint("9") + bigint("1")), "10")
check("99+1", to_string(bigint("99") + bigint("1")), "100")
check("999999999+1", to_string(bigint("999999999") + bigint("1")), "1000000000")

println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")
