// ═══════════════════════════════════════════════════════════
//  test_sibling_call.hexa -- ROI #64 @sibling_call optimization
//  Verifies that tail-position calls to OTHER functions (mutual
//  recursion) are detected and rewritten to SiblingTailCall markers.
//  Self-contained: no imports from ai_native_pass.hexa.
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

// ── AstNode struct (standard 21-field) ───────────────────
struct AstNode {
    kind: string,
    name: string,
    value: string,
    op: string,
    left: string,
    right: string,
    cond: string,
    then_body: string,
    else_body: string,
    params: string,
    body: string,
    args: string,
    fields: string,
    items: string,
    variants: string,
    arms: string,
    iter_expr: string,
    ret_type: string,
    target: string,
    trait_name: string,
    methods: string
}

// ── check helpers ────────────────────────────────────────
fn check(name, cond_val) {
    if cond_val {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn check_eq(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_arr_eq(name, actual, expected) {
    if len(actual) != len(expected) {
        println("[FAIL] " + name + " -- len mismatch: " + to_string(len(actual)) + " vs " + to_string(len(expected)))
        fail_count = fail_count + 1
        return
    }
    let mut ok = true
    let mut i = 0
    while i < len(actual) {
        if to_string(actual[i]) != to_string(expected[i]) { ok = false }
        i = i + 1
    }
    if ok {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- actual: " + to_string(actual) + ", expected: " + to_string(expected))
        fail_count = fail_count + 1
    }
}

// ── mk_ helpers ──────────────────────────────────────────

fn mk_ident(n) {
    return AstNode {
        kind: "Ident", name: n, value: "", op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn mk_int(v) {
    return AstNode {
        kind: "IntLit", name: "", value: to_string(v), op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn mk_call(callee_name, call_args) {
    return AstNode {
        kind: "Call", name: "", value: "", op: "",
        left: mk_ident(callee_name), right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: call_args, fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn mk_return(expr) {
    return AstNode {
        kind: "ReturnStmt", name: "", value: "", op: "",
        left: expr, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn mk_if(cond_expr, then_stmts, else_stmts) {
    return AstNode {
        kind: "IfStmt", name: "", value: "", op: "",
        left: "", right: "", cond: cond_expr, then_body: "", else_body: else_stmts,
        params: "", body: then_stmts, args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn mk_binop(op, l, r) {
    return AstNode {
        kind: "BinOp", name: "", value: "", op: op,
        left: l, right: r, cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn mk_bool(v) {
    return AstNode {
        kind: "BoolLit", name: "", value: to_string(v), op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn mk_fn(fn_name, fn_params, fn_body, fn_attrs) {
    return AstNode {
        kind: "FnDecl", name: fn_name, value: fn_attrs, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: fn_params, body: fn_body, args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn mk_expr_stmt(expr) {
    return AstNode {
        kind: "ExprStmt", name: "", value: "", op: "",
        left: expr, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

fn mk_let(var_name, init) {
    return AstNode {
        kind: "LetStmt", name: var_name, value: "", op: "",
        left: init, right: "", cond: "", then_body: "", else_body: "",
        params: "", body: "", args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: "",
        target: "", trait_name: "", methods: ""
    }
}

// ── Copied helpers from ai_native_pass.hexa ──────────────

fn split_attrs_m0(s) {
    let mut out = []
    if s == "" { return out }
    let chars = s.chars()
    let total = len(chars)
    let mut i = 0
    let mut cur = ""
    while i < total {
        let c = to_string(chars[i])
        if c == "," {
            if cur != "" { out.push(cur) }
            cur = ""
        } else {
            cur = cur + c
        }
        i = i + 1
    }
    if cur != "" { out.push(cur) }
    return out
}

fn attr_has(attrs, target) {
    let n = len(attrs)
    let mut i = 0
    while i < n {
        if attrs[i] == target { return true }
        i = i + 1
    }
    return false
}

fn rewrite_fn_with_body(fn_node, new_body) {
    return AstNode {
        kind: "FnDecl", name: fn_node.name, value: fn_node.value, op: "",
        left: "", right: "", cond: "", then_body: "", else_body: "",
        params: fn_node.params, body: new_body, args: "", fields: "", items: "",
        variants: "", arms: "", iter_expr: "", ret_type: fn_node.ret_type,
        target: "", trait_name: "", methods: ""
    }
}

// ── Milestone counters ───────────────────────────────────
let mut m980_sibling_detected = 0
let mut m980_sibling_rewrites = 0

// ══════════════════════════════════════════════════════════
//  Sibling call functions (copied from ai_native_pass.hexa)
// ══════════════════════════════════════════════════════════

fn get_sibling_callee(expr, self_name) {
    if type_of(expr) == "string" { return "" }
    if expr.kind == "Call" {
        let callee = expr.left
        if type_of(callee) != "string" {
            if callee.kind == "Ident" {
                if callee.name != self_name && callee.name != "println" && callee.name != "print" && callee.name != "len" && callee.name != "type_of" && callee.name != "to_string" && callee.name != "push" && callee.name != "chars" {
                    return callee.name
                }
            }
        }
    }
    return ""
}

fn detect_sibling_in_tail(body, self_name) {
    let mut found = []
    if type_of(body) != "array" { return found }
    let n = len(body)
    if n == 0 { return found }
    let last = body[n - 1]
    if type_of(last) == "string" { return found }
    if last.kind == "ReturnStmt" {
        let callee = get_sibling_callee(last.left, self_name)
        if callee != "" {
            found.push(callee)
        }
    }
    if last.kind == "IfStmt" {
        let then_found = detect_sibling_in_tail(last.body, self_name)
        let else_found = detect_sibling_in_tail(last.else_body, self_name)
        let mut ti = 0
        while ti < len(then_found) {
            found.push(then_found[ti])
            ti = ti + 1
        }
        let mut ei = 0
        while ei < len(else_found) {
            found.push(else_found[ei])
            ei = ei + 1
        }
    }
    return found
}

fn anp_detect_sibling_call(fn_node) {
    let self_name = fn_node.name
    let body = fn_node.body
    let mut found = []
    if type_of(body) != "array" { return found }
    let n = len(body)
    if n == 0 { return found }
    found = detect_sibling_in_tail(body, self_name)
    return found
}

fn join_sibling_names(arr) {
    let mut out = ""
    let n = len(arr)
    let mut i = 0
    while i < n {
        if i > 0 { out = out + ", " }
        out = out + arr[i]
        i = i + 1
    }
    return out
}

fn rewrite_sibling_body(body, self_name) {
    if type_of(body) != "array" { return body }
    let n = len(body)
    if n == 0 { return body }
    let mut out = []
    let mut i = 0
    while i < n - 1 {
        out.push(body[i])
        i = i + 1
    }
    let last = body[n - 1]
    if type_of(last) == "string" {
        out.push(last)
        return out
    }
    if last.kind == "ReturnStmt" {
        let callee = get_sibling_callee(last.left, self_name)
        if callee != "" {
            let marker = AstNode {
                kind: "SiblingTailCall", name: callee, value: "", op: "",
                left: last.left, right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: last.left.args, fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            }
            out.push(AstNode {
                kind: "ReturnStmt", name: "", value: "", op: "",
                left: marker, right: "", cond: "", then_body: "", else_body: "",
                params: "", body: "", args: "", fields: "", items: "",
                variants: "", arms: "", iter_expr: "", ret_type: "",
                target: "", trait_name: "", methods: ""
            })
            return out
        }
        out.push(last)
        return out
    }
    if last.kind == "IfStmt" {
        let new_then = rewrite_sibling_body(last.body, self_name)
        let new_else = rewrite_sibling_body(last.else_body, self_name)
        out.push(AstNode {
            kind: "IfStmt", name: "", value: "", op: "",
            left: "", right: "", cond: last.cond, then_body: "", else_body: new_else,
            params: "", body: new_then, args: "", fields: "", items: "",
            variants: "", arms: "", iter_expr: "", ret_type: "",
            target: "", trait_name: "", methods: ""
        })
        return out
    }
    out.push(last)
    return out
}

fn anp_rewrite_sibling_call(fn_node) {
    let self_name = fn_node.name
    let siblings = anp_detect_sibling_call(fn_node)
    if len(siblings) == 0 { return fn_node }
    let new_body = rewrite_sibling_body(fn_node.body, self_name)
    m980_sibling_rewrites = m980_sibling_rewrites + 1
    let callee_list = join_sibling_names(siblings)
    println("[ai-native] fn " + fn_node.name + " REWRITE: @sibling_call -> " + callee_list)
    return rewrite_fn_with_body(fn_node, new_body)
}

fn anp_sibling_call_pass(ast) {
    if type_of(ast) != "array" { return ast }
    let n = len(ast)
    let mut out = []
    let mut i = 0
    while i < n {
        let node = ast[i]
        if type_of(node) != "string" && node.kind == "FnDecl" {
            let attrs = split_attrs_m0(node.value)
            if attr_has(attrs, "sibling_call") {
                let siblings = anp_detect_sibling_call(node)
                if len(siblings) > 0 {
                    m980_sibling_detected = m980_sibling_detected + len(siblings)
                    let rewritten = anp_rewrite_sibling_call(node)
                    out.push(rewritten)
                    i = i + 1
                    continue
                }
            }
            out.push(node)
        } else {
            out.push(node)
        }
        i = i + 1
    }
    if m980_sibling_rewrites > 0 {
        println("[ai-native] @sibling_call: " + to_string(m980_sibling_detected) + " sibling tail-call(s) detected, " + to_string(m980_sibling_rewrites) + " fn(s) rewritten")
    }
    return out
}

// ══════════════════════════════════════════════════════════
//  TESTS
// ══════════════════════════════════════════════════════════

println("═══════════════════════════════════════════════════════")
println("  ROI #64: @sibling_call optimization tests")
println("═══════════════════════════════════════════════════════")

// ── T1: get_sibling_callee basics ────────────────────────
println("")
println("--- T1: get_sibling_callee ---")

// Call to 'odd' from 'even' -> sibling
let t1_call_odd = mk_call("odd", [mk_ident("n")])
check_eq("T1a callee=odd from even", get_sibling_callee(t1_call_odd, "even"), "odd")

// Call to 'even' from itself -> not sibling (self-recursive)
let t1_call_self = mk_call("even", [mk_ident("n")])
check_eq("T1b self-recursive returns empty", get_sibling_callee(t1_call_self, "even"), "")

// Call to 'println' -> excluded builtin
let t1_call_println = mk_call("println", [mk_ident("x")])
check_eq("T1c println excluded", get_sibling_callee(t1_call_println, "even"), "")

// Call to 'len' -> excluded builtin
let t1_call_len = mk_call("len", [mk_ident("arr")])
check_eq("T1d len excluded", get_sibling_callee(t1_call_len, "foo"), "")

// Call to 'print' -> excluded
let t1_call_print = mk_call("print", [mk_ident("x")])
check_eq("T1e print excluded", get_sibling_callee(t1_call_print, "bar"), "")

// Call to 'type_of' -> excluded
let t1_call_typeof = mk_call("type_of", [mk_ident("x")])
check_eq("T1f type_of excluded", get_sibling_callee(t1_call_typeof, "bar"), "")

// Call to 'to_string' -> excluded
let t1_call_tostr = mk_call("to_string", [mk_ident("x")])
check_eq("T1g to_string excluded", get_sibling_callee(t1_call_tostr, "bar"), "")

// Call to 'push' -> excluded
let t1_call_push = mk_call("push", [mk_ident("x")])
check_eq("T1h push excluded", get_sibling_callee(t1_call_push, "bar"), "")

// Call to 'chars' -> excluded
let t1_call_chars = mk_call("chars", [mk_ident("x")])
check_eq("T1i chars excluded", get_sibling_callee(t1_call_chars, "bar"), "")

// String expr -> empty
check_eq("T1j string expr returns empty", get_sibling_callee("hello", "foo"), "")

// Non-Call node -> empty
let t1_ident = mk_ident("x")
check_eq("T1k non-Call returns empty", get_sibling_callee(t1_ident, "foo"), "")

// ── T2: detect_sibling_in_tail ───────────────────────────
println("")
println("--- T2: detect_sibling_in_tail ---")

// return odd(n-1) in body -> detects "odd"
let t2_body_ret = [mk_return(mk_call("odd", [mk_binop("-", mk_ident("n"), mk_int(1))]))]
let t2_found = detect_sibling_in_tail(t2_body_ret, "even")
check_eq("T2a return sibling detected", len(t2_found), 1)
check_eq("T2b return sibling name", t2_found[0], "odd")

// return even(n-1) from even -> self-recursive, not sibling
let t2_body_self = [mk_return(mk_call("even", [mk_binop("-", mk_ident("n"), mk_int(1))]))]
let t2_self = detect_sibling_in_tail(t2_body_self, "even")
check_eq("T2c self-recursive not detected", len(t2_self), 0)

// empty body -> nothing
let t2_empty = detect_sibling_in_tail([], "foo")
check_eq("T2d empty body", len(t2_empty), 0)

// non-array body -> nothing
let t2_nonarr = detect_sibling_in_tail("not-array", "foo")
check_eq("T2e non-array body", len(t2_nonarr), 0)

// if/else with siblings in both branches
let t2_if_body = [mk_if(
    mk_binop("==", mk_ident("n"), mk_int(0)),
    [mk_return(mk_bool(true))],
    [mk_return(mk_call("odd", [mk_binop("-", mk_ident("n"), mk_int(1))]))]
)]
let t2_if_found = detect_sibling_in_tail(t2_if_body, "even")
check_eq("T2f if/else sibling in else", len(t2_if_found), 1)
check_eq("T2g if/else sibling name", t2_if_found[0], "odd")

// if/else with siblings in BOTH branches
let t2_both = [mk_if(
    mk_binop(">", mk_ident("n"), mk_int(0)),
    [mk_return(mk_call("pos_handler", [mk_ident("n")]))],
    [mk_return(mk_call("neg_handler", [mk_ident("n")]))]
)]
let t2_both_found = detect_sibling_in_tail(t2_both, "dispatch")
check_eq("T2h siblings in both branches count", len(t2_both_found), 2)
check_eq("T2i first sibling", t2_both_found[0], "pos_handler")
check_eq("T2j second sibling", t2_both_found[1], "neg_handler")

// body with multiple stmts, only last matters
let t2_multi = [mk_let("x", mk_int(5)), mk_return(mk_call("bar", [mk_ident("x")]))]
let t2_multi_found = detect_sibling_in_tail(t2_multi, "foo")
check_eq("T2k multi-stmt body last return", len(t2_multi_found), 1)
check_eq("T2l multi-stmt callee", t2_multi_found[0], "bar")

// last stmt is not return/if -> nothing
let t2_expr = [mk_expr_stmt(mk_call("bar", [mk_ident("x")]))]
let t2_expr_found = detect_sibling_in_tail(t2_expr, "foo")
check_eq("T2m expr stmt not detected", len(t2_expr_found), 0)

// ── T3: anp_detect_sibling_call ──────────────────────────
println("")
println("--- T3: anp_detect_sibling_call ---")

// fn even(n) { ... return odd(n-1) }
let t3_fn = mk_fn("even", ["n"], [
    mk_if(
        mk_binop("==", mk_ident("n"), mk_int(0)),
        [mk_return(mk_bool(true))],
        [mk_return(mk_call("odd", [mk_binop("-", mk_ident("n"), mk_int(1))]))]
    )
], "sibling_call")
let t3_detected = anp_detect_sibling_call(t3_fn)
check_eq("T3a detect on fn even", len(t3_detected), 1)
check_eq("T3b detected name is odd", t3_detected[0], "odd")

// fn with no body -> nothing
let t3_nobody = mk_fn("foo", [], "", "sibling_call")
let t3_nobody_r = anp_detect_sibling_call(t3_nobody)
check_eq("T3c no body returns empty", len(t3_nobody_r), 0)

// fn with empty body -> nothing
let t3_emptybody = mk_fn("foo", [], [], "sibling_call")
let t3_emptybody_r = anp_detect_sibling_call(t3_emptybody)
check_eq("T3d empty body returns empty", len(t3_emptybody_r), 0)

// ── T4: join_sibling_names ───────────────────────────────
println("")
println("--- T4: join_sibling_names ---")

check_eq("T4a empty array", join_sibling_names([]), "")
check_eq("T4b single name", join_sibling_names(["odd"]), "odd")
check_eq("T4c two names", join_sibling_names(["odd", "even"]), "odd, even")
check_eq("T4d three names", join_sibling_names(["a", "b", "c"]), "a, b, c")

// ── T5: rewrite_sibling_body ─────────────────────────────
println("")
println("--- T5: rewrite_sibling_body ---")

// return odd(n-1) -> SiblingTailCall marker
let t5_body = [mk_return(mk_call("odd", [mk_binop("-", mk_ident("n"), mk_int(1))]))]
let t5_rewritten = rewrite_sibling_body(t5_body, "even")
check_eq("T5a rewritten length", len(t5_rewritten), 1)
check_eq("T5b outer is ReturnStmt", t5_rewritten[0].kind, "ReturnStmt")
let t5_inner = t5_rewritten[0].left
check_eq("T5c inner is SiblingTailCall", t5_inner.kind, "SiblingTailCall")
check_eq("T5d inner name is odd", t5_inner.name, "odd")

// return even(n-1) from even -> self-recursive, NOT rewritten
let t5_self_body = [mk_return(mk_call("even", [mk_ident("n")]))]
let t5_self_rw = rewrite_sibling_body(t5_self_body, "even")
check_eq("T5e self-recursive not rewritten", t5_self_rw[0].kind, "ReturnStmt")
// inner should still be a Call, not SiblingTailCall
let t5_self_inner = t5_self_rw[0].left
check_eq("T5f self-recursive stays Call", t5_self_inner.kind, "Call")

// if/else rewrite
let t5_if_body = [mk_if(
    mk_binop("==", mk_ident("n"), mk_int(0)),
    [mk_return(mk_bool(true))],
    [mk_return(mk_call("odd", [mk_binop("-", mk_ident("n"), mk_int(1))]))]
)]
let t5_if_rw = rewrite_sibling_body(t5_if_body, "even")
check_eq("T5g if rewritten kind", t5_if_rw[0].kind, "IfStmt")
// else branch should have SiblingTailCall
let t5_else_branch = t5_if_rw[0].else_body
check_eq("T5h else branch rewritten", t5_else_branch[0].kind, "ReturnStmt")
let t5_else_inner = t5_else_branch[0].left
check_eq("T5i else inner is SiblingTailCall", t5_else_inner.kind, "SiblingTailCall")
check_eq("T5j else inner name", t5_else_inner.name, "odd")

// non-array body -> returned as-is
let t5_nonarr = rewrite_sibling_body("not-array", "foo")
check_eq("T5k non-array returned as-is", t5_nonarr, "not-array")

// empty body -> returned as-is
let t5_empty = rewrite_sibling_body([], "foo")
check_eq("T5l empty body returned as-is", len(t5_empty), 0)

// body with string last element -> preserved
let t5_str = rewrite_sibling_body(["hello"], "foo")
check_eq("T5m string element preserved", t5_str[0], "hello")

// body with non-return, non-if last stmt -> preserved
let t5_let_body = [mk_let("x", mk_int(5))]
let t5_let_rw = rewrite_sibling_body(t5_let_body, "foo")
check_eq("T5n let stmt preserved", t5_let_rw[0].kind, "LetStmt")

// ── T6: anp_rewrite_sibling_call (full fn rewrite) ──────
println("")
println("--- T6: anp_rewrite_sibling_call ---")

// Reset counters
m980_sibling_rewrites = 0
m980_sibling_detected = 0

let t6_fn = mk_fn("even", ["n"], [
    mk_if(
        mk_binop("==", mk_ident("n"), mk_int(0)),
        [mk_return(mk_bool(true))],
        [mk_return(mk_call("odd", [mk_binop("-", mk_ident("n"), mk_int(1))]))]
    )
], "sibling_call")

let t6_result = anp_rewrite_sibling_call(t6_fn)
check_eq("T6a result is FnDecl", t6_result.kind, "FnDecl")
check_eq("T6b result name", t6_result.name, "even")
check("T6c rewrite counter incremented", m980_sibling_rewrites >= 1)

// fn with no siblings -> returned unchanged
m980_sibling_rewrites = 0
let t6_no_sib = mk_fn("foo", [], [mk_return(mk_int(42))], "sibling_call")
let t6_no_sib_r = anp_rewrite_sibling_call(t6_no_sib)
check_eq("T6d no siblings returns same name", t6_no_sib_r.name, "foo")
check_eq("T6e no siblings rewrite counter unchanged", m980_sibling_rewrites, 0)

// ── T7: anp_sibling_call_pass (full AST pass) ───────────
println("")
println("--- T7: anp_sibling_call_pass ---")

// Reset counters
m980_sibling_rewrites = 0
m980_sibling_detected = 0

let t7_even = mk_fn("even", ["n"], [
    mk_if(
        mk_binop("==", mk_ident("n"), mk_int(0)),
        [mk_return(mk_bool(true))],
        [mk_return(mk_call("odd", [mk_binop("-", mk_ident("n"), mk_int(1))]))]
    )
], "sibling_call")

let t7_odd = mk_fn("odd", ["n"], [
    mk_if(
        mk_binop("==", mk_ident("n"), mk_int(0)),
        [mk_return(mk_bool(false))],
        [mk_return(mk_call("even", [mk_binop("-", mk_ident("n"), mk_int(1))]))]
    )
], "sibling_call")

let t7_ast = [t7_even, t7_odd]
let t7_result = anp_sibling_call_pass(t7_ast)
check_eq("T7a result length", len(t7_result), 2)
check_eq("T7b first fn name", t7_result[0].name, "even")
check_eq("T7c second fn name", t7_result[1].name, "odd")
check("T7d detected count >= 2", m980_sibling_detected >= 2)
check("T7e rewrite count >= 2", m980_sibling_rewrites >= 2)

// non-array input -> returned as-is
let t7_nonarr = anp_sibling_call_pass("not-array")
check_eq("T7f non-array pass returns as-is", t7_nonarr, "not-array")

// ── T8: Edge case - no @sibling_call attr ────────────────
println("")
println("--- T8: Edge cases ---")

m980_sibling_rewrites = 0
m980_sibling_detected = 0

// fn WITHOUT sibling_call attr should NOT be rewritten
let t8_no_attr = mk_fn("even", ["n"], [
    mk_return(mk_call("odd", [mk_ident("n")]))
], "optimize")

let t8_result = anp_sibling_call_pass([t8_no_attr])
check_eq("T8a no @sibling_call attr -> no rewrite", m980_sibling_rewrites, 0)
check_eq("T8b no @sibling_call attr -> no detect", m980_sibling_detected, 0)

// fn with empty attr -> no rewrite
let t8_empty_attr = mk_fn("foo", ["n"], [
    mk_return(mk_call("bar", [mk_ident("n")]))
], "")
let t8_empty_r = anp_sibling_call_pass([t8_empty_attr])
check_eq("T8c empty attr -> no detect", m980_sibling_detected, 0)

// fn with sibling_call but only self-recursion -> no rewrite
m980_sibling_rewrites = 0
m980_sibling_detected = 0
let t8_self_only = mk_fn("foo", ["n"], [
    mk_return(mk_call("foo", [mk_binop("-", mk_ident("n"), mk_int(1))]))
], "sibling_call")
let t8_self_r = anp_sibling_call_pass([t8_self_only])
check_eq("T8d self-recursive only -> no detect", m980_sibling_detected, 0)
check_eq("T8e self-recursive only -> no rewrite", m980_sibling_rewrites, 0)

// fn with sibling_call but no tail call at all
m980_sibling_rewrites = 0
m980_sibling_detected = 0
let t8_no_tail = mk_fn("foo", ["n"], [
    mk_let("x", mk_call("bar", [mk_ident("n")])),
    mk_return(mk_ident("x"))
], "sibling_call")
let t8_no_tail_r = anp_sibling_call_pass([t8_no_tail])
check_eq("T8f no tail call -> no detect", m980_sibling_detected, 0)

// mixed AST: some with attr, some without
m980_sibling_rewrites = 0
m980_sibling_detected = 0
let t8_mix_a = mk_fn("helper", [], [mk_return(mk_int(1))], "")
let t8_mix_b = mk_fn("dispatch", ["n"], [
    mk_return(mk_call("worker", [mk_ident("n")]))
], "sibling_call")
let t8_mix_c = mk_fn("worker", ["n"], [mk_return(mk_ident("n"))], "")
let t8_mix_result = anp_sibling_call_pass([t8_mix_a, t8_mix_b, t8_mix_c])
check_eq("T8g mixed AST length preserved", len(t8_mix_result), 3)
check("T8h mixed AST rewrites=1", m980_sibling_rewrites == 1)
check("T8i mixed AST detected=1", m980_sibling_detected == 1)

// ── T9: multi-attr with sibling_call ─────────────────────
println("")
println("--- T9: multi-attr ---")

m980_sibling_rewrites = 0
m980_sibling_detected = 0
let t9_fn = mk_fn("even", ["n"], [
    mk_return(mk_call("odd", [mk_ident("n")]))
], "optimize,sibling_call")
let t9_result = anp_sibling_call_pass([t9_fn])
check("T9a multi-attr with sibling_call detected", m980_sibling_detected >= 1)
check("T9b multi-attr with sibling_call rewritten", m980_sibling_rewrites >= 1)

// ── T10: behavioral equivalence (mutual recursion) ──────
println("")
println("--- T10: behavioral equivalence ---")

fn t10_is_even(n) {
    if n == 0 { return true }
    return t10_is_odd(n - 1)
}

fn t10_is_odd(n) {
    if n == 0 { return false }
    return t10_is_even(n - 1)
}

check_eq("T10a even(0)=true", t10_is_even(0), true)
check_eq("T10b even(1)=false", t10_is_even(1), false)
check_eq("T10c even(4)=true", t10_is_even(4), true)
check_eq("T10d even(7)=false", t10_is_even(7), false)
check_eq("T10e odd(0)=false", t10_is_odd(0), false)
check_eq("T10f odd(1)=true", t10_is_odd(1), true)
check_eq("T10g odd(5)=true", t10_is_odd(5), true)
check_eq("T10h odd(10)=false", t10_is_odd(10), false)

