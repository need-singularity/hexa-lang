// self/test_path_pure.hexa -- Tests for self/runtime/path_pure.hexa

fn _last_idx_of(s, target) {
    let n = len(s)
    let m = len(target)
    if m == 0 { return n }
    let mut i = n - m
    while i >= 0 {
        if s.substring(i, i + m) == target { return i }
        i = i - 1
    }
    -1
}

fn basename_pure(path) {
    if type_of(path) != "string" { return "" }
    let mut n = len(path)
    while n > 0 && path.substring(n - 1, n) == "/" {
        n = n - 1
    }
    let trimmed = path.substring(0, n)
    let idx = _last_idx_of(trimmed, "/")
    if idx < 0 { return trimmed }
    trimmed.substring(idx + 1, len(trimmed))
}

fn dirname_pure(path) {
    if type_of(path) != "string" { return "" }
    let idx = _last_idx_of(path, "/")
    if idx < 0 { return "" }
    if idx == 0 { return "/" }
    path.substring(0, idx)
}

fn ext_pure(path) {
    if type_of(path) != "string" { return "" }
    let base = basename_pure(path)
    let dot = _last_idx_of(base, ".")
    if dot <= 0 { return "" }
    base.substring(dot + 1, len(base))
}

fn stem_pure(path) {
    if type_of(path) != "string" { return "" }
    let base = basename_pure(path)
    let dot = _last_idx_of(base, ".")
    if dot <= 0 { return base }
    base.substring(0, dot)
}

fn join_path_pure(a, b) {
    if type_of(a) != "string" { return b }
    if type_of(b) != "string" { return a }
    if len(a) == 0 { return b }
    if len(b) == 0 { return a }
    let mut alen = len(a)
    while alen > 0 && a.substring(alen - 1, alen) == "/" {
        alen = alen - 1
    }
    let mut bstart = 0
    while bstart < len(b) && b.substring(bstart, bstart + 1) == "/" {
        bstart = bstart + 1
    }
    if alen == 0 {
        return "/" + b.substring(bstart, len(b))
    }
    a.substring(0, alen) + "/" + b.substring(bstart, len(b))
}

fn is_absolute_pure(path) {
    if type_of(path) != "string" { return false }
    if len(path) == 0 { return false }
    path.substring(0, 1) == "/"
}

// ── test harness ───────────────────────────────────────────────────

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  path_pure.hexa — test runner")
println("═══════════════════════════════════════════════════════")

// ── basename ────────────────────────────────────────────────
println("")
println("--- basename_pure ---")
check("abs path", basename_pure("/a/b/c"), "c")
check("trailing slash", basename_pure("/a/b/c/"), "c")
check("multi trailing", basename_pure("/a/b/c///"), "c")
check("bare name", basename_pure("foo.hexa"), "foo.hexa")
check("root", basename_pure("/"), "")
check("empty", basename_pure(""), "")
check("dot file", basename_pure("/a/.env"), ".env")
check("non-string", basename_pure(42), "")

// ── dirname ─────────────────────────────────────────────────
println("")
println("--- dirname_pure ---")
check("deep", dirname_pure("/a/b/c"), "/a/b")
check("root child", dirname_pure("/a"), "/")
check("bare name", dirname_pure("foo.hexa"), "")
check("empty", dirname_pure(""), "")
check("relative", dirname_pure("a/b"), "a")
check("non-string", dirname_pure(42), "")

// ── ext ─────────────────────────────────────────────────────
println("")
println("--- ext_pure ---")
check("simple ext", ext_pure("foo.hexa"), "hexa")
check("double ext last wins", ext_pure("a/b/c.tar.gz"), "gz")
check("dot-file no ext", ext_pure(".env"), "")
check("no ext", ext_pure("no_ext"), "")
check("empty", ext_pure(""), "")

// ── stem ────────────────────────────────────────────────────
println("")
println("--- stem_pure ---")
check("simple stem", stem_pure("foo.hexa"), "foo")
check("double ext stem", stem_pure("a/b/c.tar.gz"), "c.tar")
check("dot-file stem", stem_pure(".env"), ".env")
check("no ext stem", stem_pure("no_ext"), "no_ext")
check("empty stem", stem_pure(""), "")

// ── join_path ───────────────────────────────────────────────
println("")
println("--- join_path_pure ---")
check("plain join", join_path_pure("a", "b"), "a/b")
check("trailing left", join_path_pure("a/", "b"), "a/b")
check("leading right", join_path_pure("a", "/b"), "a/b")
check("both slashed", join_path_pure("a/", "/b"), "a/b")
check("empty left", join_path_pure("", "b"), "b")
check("empty right", join_path_pure("a", ""), "a")
check("absolute left", join_path_pure("/tmp", "x"), "/tmp/x")
check("root left", join_path_pure("/", "b"), "/b")

// ── is_absolute ─────────────────────────────────────────────
println("")
println("--- is_absolute_pure ---")
check("abs", is_absolute_pure("/foo"), true)
check("relative", is_absolute_pure("foo"), false)
check("empty", is_absolute_pure(""), false)
check("non-string", is_absolute_pure(42), false)

// ── Summary ─────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    println("FAIL")
    exit(1)
}
println("ALL PASS")
