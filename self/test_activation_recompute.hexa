@pure
fn ar110_copy_1d(a) {
    let n = len(a)
    let mut out = []
    let mut i = 0
    while i < n {
        out.push(a[i])
        i = i + 1
    }
    return out
}

@pure @parallel
fn ar_layer_cost_impl(input_size, output_size, op_type) {
    let mut flops = 0.0
    if op_type == "matmul" {
        flops = 2.0 * input_size * output_size
    } else if op_type == "conv" {
        flops = 2.0 * input_size * output_size
    } else if op_type == "norm" {
        flops = 5.0 * input_size
    } else if op_type == "activation" {
        flops = 1.0 * input_size
    } else {
        flops = 2.0 * input_size
    }
    let mem = output_size * 4.0
    return #{
        "flops": flops,
        "memory_bytes": mem
    }
}

pub fn ar_layer_cost(input_size, output_size, op_type) {
    return ar_layer_cost_impl(input_size, output_size, op_type)
}

@hot @pure
fn ar_optimal_schedule_impl(layers, memory_budget) {
    let n = len(layers)
    if n == 0 { return [] }

    let mut costs = []
    let mut total_mem = 0.0
    let mut i = 0
    while i < n {
        let layer = layers[i]
        let c = ar_layer_cost(layer["input_size"], layer["output_size"], layer["op_type"])
        costs.push(c)
        total_mem = total_mem + c["memory_bytes"]
        i = i + 1
    }

    if total_mem <= memory_budget {
        let mut sched = []
        let mut si = 0
        while si < n {
            sched.push(false)
            si = si + 1
        }
        return sched
    }

    let mut ratios = []
    i = 0
    while i < n {
        let f = costs[i]["flops"]
        let m = costs[i]["memory_bytes"]
        if f < 1.0e-30 {
            ratios.push(1.0e30)
        } else {
            ratios.push(m / f)
        }
        i = i + 1
    }

    let mut indices = []
    i = 0
    while i < n {
        indices.push(i)
        i = i + 1
    }
    i = 0
    while i < (n - 1) {
        let mut best = i
        let mut j = i + 1
        while j < n {
            if ratios[indices[j]] > ratios[indices[best]] {
                best = j
            }
            j = j + 1
        }
        if best != i {
            let tmp = indices[i]
            indices[i] = indices[best]
            indices[best] = tmp
        }
        i = i + 1
    }

    let mut schedule = []
    i = 0
    while i < n {
        schedule.push(false)
        i = i + 1
    }
    let mut current_mem = total_mem
    let mut ki = 0
    while ki < n {
        if current_mem <= memory_budget { ki = n } else {
            let idx = indices[ki]
            schedule[idx] = true
            current_mem = current_mem - costs[idx]["memory_bytes"]
            ki = ki + 1
        }
    }

    return schedule
}

pub fn ar_optimal_schedule(layers, memory_budget) {
    return ar_optimal_schedule_impl(layers, memory_budget)
}

@pure
fn ar_total_flops_impl(layers, schedule) {
    let n = len(layers)
    let mut total = 0.0
    let mut i = 0
    while i < n {
        if schedule[i] {
            let layer = layers[i]
            let c = ar_layer_cost(layer["input_size"], layer["output_size"], layer["op_type"])
            total = total + c["flops"]
        }
        i = i + 1
    }
    return total
}

pub fn ar_total_flops(layers, schedule) {
    return ar_total_flops_impl(layers, schedule)
}

@pure
fn ar_total_memory_impl(layers, schedule) {
    let n = len(layers)
    let mut total = 0.0
    let mut i = 0
    while i < n {
        if !schedule[i] {
            let layer = layers[i]
            let c = ar_layer_cost(layer["input_size"], layer["output_size"], layer["op_type"])
            total = total + c["memory_bytes"]
        }
        i = i + 1
    }
    return total
}

pub fn ar_total_memory(layers, schedule) {
    return ar_total_memory_impl(layers, schedule)
}

@pure
fn ar_savings_ratio_impl(layers, schedule) {
    let n = len(layers)
    let mut all_mem = 0.0
    let mut i = 0
    while i < n {
        let layer = layers[i]
        let c = ar_layer_cost(layer["input_size"], layer["output_size"], layer["op_type"])
        all_mem = all_mem + c["memory_bytes"]
        i = i + 1
    }
    let stored_mem = ar_total_memory(layers, schedule)
    let saved = all_mem - stored_mem
    let extra_flops = ar_total_flops(layers, schedule)
    if extra_flops < 1.0e-30 { return 0.0 }
    return saved / extra_flops
}

pub fn ar_savings_ratio(layers, schedule) {
    return ar_savings_ratio_impl(layers, schedule)
}

@pure
fn ar_apply_schedule_impl(activations, schedule) {
    let n = len(activations)
    let mut out = []
    let mut i = 0
    while i < n {
        if schedule[i] {
            out.push(0.0)
        } else {
            out.push(activations[i])
        }
        i = i + 1
    }
    return out
}

pub fn ar_apply_schedule(activations, schedule) {
    return ar_apply_schedule_impl(activations, schedule)
}

struct ActivationStmt {
    kind: string
    layer: string
    mem: float
    flops: float
}

pub fn ar_stmt(kind, layer, mem, flops) {
    return ActivationStmt{kind: kind, layer: layer, mem: mem, flops: flops}
}

pub fn ar_stmt_store(layer, mem, flops) {
    return ar_stmt("store_activation", layer, mem, flops)
}

pub fn ar_stmt_recompute(layer, mem, flops) {
    return ar_stmt("recompute_activation", layer, mem, flops)
}

pub fn ar_stmt_other(layer) {
    return ar_stmt("other", layer, 0.0, 0.0)
}

@pure
fn detect_full_activation_store_impl(prog) {
    let n = len(prog)
    if n == 0 { return false }
    let mut has_store = false
    let mut i = 0
    while i < n {
        let s = prog[i]
        if s.kind == "recompute_activation" { return false }
        if s.kind == "store_activation" {
            has_store = true
        }
        i = i + 1
    }
    return has_store
}

pub fn detect_full_activation_store(prog) {
    return detect_full_activation_store_impl(prog)
}

@pure
fn rewrite_selective_recompute_impl(prog, budget) {
    if !detect_full_activation_store(prog) { return prog }

    let n = len(prog)

    let mut store_indices = []
    let mut total_mem = 0.0
    let mut i = 0
    while i < n {
        let s = prog[i]
        if s.kind == "store_activation" {
            store_indices.push(i)
            total_mem = total_mem + s.mem
        }
        i = i + 1
    }

    if total_mem <= budget { return prog }

    let sn = len(store_indices)
    let mut ratios = []
    let mut ki = 0
    while ki < sn {
        let idx = store_indices[ki]
        let s = prog[idx]
        if s.flops < 1.0e-30 {
            ratios.push(1.0e30)
        } else {
            ratios.push(s.mem / s.flops)
        }
        ki = ki + 1
    }

    let mut sorted = []
    ki = 0
    while ki < sn {
        sorted.push(ki)
        ki = ki + 1
    }
    i = 0
    while i < (sn - 1) {
        let mut best = i
        let mut j = i + 1
        while j < sn {
            if ratios[sorted[j]] > ratios[sorted[best]] {
                best = j
            }
            j = j + 1
        }
        if best != i {
            let tmp = sorted[i]
            sorted[i] = sorted[best]
            sorted[best] = tmp
        }
        i = i + 1
    }

    let mut recompute_set = []
    ki = 0
    while ki < sn {
        recompute_set.push(false)
        ki = ki + 1
    }
    let mut current_mem = total_mem
    ki = 0
    while ki < sn {
        if current_mem <= budget { ki = sn } else {
            let si = sorted[ki]
            recompute_set[si] = true
            let idx = store_indices[si]
            current_mem = current_mem - prog[idx].mem
            ki = ki + 1
        }
    }

    let mut out = []
    let mut store_counter = 0
    i = 0
    while i < n {
        let s = prog[i]
        if s.kind == "store_activation" {
            if recompute_set[store_counter] {
                out.push(ar_stmt_recompute(s.layer, s.mem, s.flops))
            } else {
                out.push(s)
            }
            store_counter = store_counter + 1
        } else {
            out.push(s)
        }
        i = i + 1
    }

    return out
}

pub fn rewrite_selective_recompute(prog, budget) {
    return rewrite_selective_recompute_impl(prog, budget)
}

// --- END INLINED from self/ai_native/activation_recompute.hexa ---

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_true(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn ar110_fabs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn check_close(name, actual, expected, tol) {
    if ar110_fabs(actual - expected) < tol {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("=== Activation Recompute Tests (ROI #110) ===")
println("")

// ── T1: ar_layer_cost basic ───────────────────────────────────
println("--- T1: ar_layer_cost ---")

let c1 = ar_layer_cost(1024.0, 512.0, "matmul")
// flops = 2 * 1024 * 512 = 1048576
check_close("T1a matmul flops", c1["flops"], 1048576.0, 0.1)
// memory = 512 * 4 = 2048
check_close("T1b matmul memory", c1["memory_bytes"], 2048.0, 0.1)

let c2 = ar_layer_cost(256.0, 256.0, "norm")
// flops = 5 * 256 = 1280
check_close("T1c norm flops", c2["flops"], 1280.0, 0.1)
// memory = 256 * 4 = 1024
check_close("T1d norm memory", c2["memory_bytes"], 1024.0, 0.1)

let c3 = ar_layer_cost(512.0, 512.0, "activation")
// flops = 1 * 512 = 512
check_close("T1e activation flops", c3["flops"], 512.0, 0.1)

// ── T2: ar_optimal_schedule — all fits in budget ──────────────
println("")
println("--- T2: ar_optimal_schedule ---")

let layers2 = [
    #{"input_size": 100.0, "output_size": 50.0, "op_type": "matmul"},
    #{"input_size": 50.0, "output_size": 50.0, "op_type": "activation"}
]
// total memory = 50*4 + 50*4 = 400
let sched2 = ar_optimal_schedule(layers2, 500.0)
check("T2a all stored (budget > total)", sched2[0], false)
check("T2b all stored (budget > total)", sched2[1], false)

// ── T3: ar_optimal_schedule — must recompute some ─────────────
println("")
println("--- T3: schedule under tight budget ---")

let layers3 = [
    #{"input_size": 100.0, "output_size": 100.0, "op_type": "matmul"},
    #{"input_size": 100.0, "output_size": 100.0, "op_type": "activation"},
    #{"input_size": 100.0, "output_size": 100.0, "op_type": "norm"}
]
// Each layer: memory = 100*4 = 400.  Total = 1200.
// matmul flops = 2*100*100=20000, ratio = 400/20000 = 0.02
// activation flops = 1*100=100, ratio = 400/100 = 4.0  (best!)
// norm flops = 5*100=500, ratio = 400/500 = 0.8
// Budget = 900 -> need to free 300 -> recompute activation first (frees 400)
let sched3 = ar_optimal_schedule(layers3, 900.0)
check("T3a matmul stored", sched3[0], false)
check("T3b activation recomputed", sched3[1], true)
check("T3c norm stored", sched3[2], false)

// ── T4: ar_total_flops / ar_total_memory / ar_savings_ratio ───
println("")
println("--- T4: totals and ratio ---")

let extra_flops = ar_total_flops(layers3, sched3)
// Only activation layer recomputed: flops = 1*100 = 100
check_close("T4a extra flops", extra_flops, 100.0, 0.1)

let stored_mem = ar_total_memory(layers3, sched3)
// matmul + norm stored: 400 + 400 = 800
check_close("T4b stored memory", stored_mem, 800.0, 0.1)

let ratio = ar_savings_ratio(layers3, sched3)
// saved = 1200 - 800 = 400, extra flops = 100, ratio = 4.0
check_close("T4c savings ratio", ratio, 4.0, 0.01)

// ── T5: ar_apply_schedule ─────────────────────────────────────
println("")
println("--- T5: ar_apply_schedule ---")

let acts = [10.0, 20.0, 30.0]
let mask = [false, true, false]
let applied = ar_apply_schedule(acts, mask)
check_close("T5a stored kept", applied[0], 10.0, 0.001)
check_close("T5b recomputed zeroed", applied[1], 0.0, 0.001)
check_close("T5c stored kept", applied[2], 30.0, 0.001)

// ── T6: detect_full_activation_store ──────────────────────────
println("")
println("--- T6: detect_full_activation_store ---")

let prog_full = [
    ar_stmt_store("layer0", 400.0, 20000.0),
    ar_stmt_store("layer1", 400.0, 100.0),
    ar_stmt_store("layer2", 400.0, 500.0)
]
check_true("T6a full store detected", detect_full_activation_store(prog_full))

let prog_mixed = [
    ar_stmt_store("layer0", 400.0, 20000.0),
    ar_stmt_recompute("layer1", 400.0, 100.0),
    ar_stmt_store("layer2", 400.0, 500.0)
]
check_true("T6b mixed not detected", !detect_full_activation_store(prog_mixed))

let prog_empty = []
check_true("T6c empty not detected", !detect_full_activation_store(prog_empty))

let prog_other = [ar_stmt_other("x")]
check_true("T6d other-only not detected", !detect_full_activation_store(prog_other))

// ── T7: rewrite_selective_recompute ───────────────────────────
println("")
println("--- T7: rewrite_selective_recompute ---")

// Same 3-layer program, budget 900 -> should recompute layer1 (activation, best ratio)
let rewritten = rewrite_selective_recompute(prog_full, 900.0)
check("T7a layer0 stays store", rewritten[0].kind, "store_activation")
check("T7b layer1 rewritten", rewritten[1].kind, "recompute_activation")
check("T7c layer2 stays store", rewritten[2].kind, "store_activation")

// Budget large enough: no rewrite
let rewritten2 = rewrite_selective_recompute(prog_full, 2000.0)
check("T7d no rewrite needed", rewritten2[0].kind, "store_activation")
check("T7e no rewrite needed", rewritten2[1].kind, "store_activation")
check("T7f no rewrite needed", rewritten2[2].kind, "store_activation")

// ── T8: empty layers edge case ────────────────────────────────
println("")
println("--- T8: empty layers ---")

let sched_empty = ar_optimal_schedule([], 100.0)
check("T8a empty schedule", len(sched_empty), 0)
check_close("T8b empty flops", ar_total_flops([], []), 0.0, 0.001)
check_close("T8c empty memory", ar_total_memory([], []), 0.0, 0.001)

// ── summary ───────────────────────────────────────────────────
println("")
println("=== Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed ===")
if fail_count > 0 {
    println("SOME TESTS FAILED")
} else {
    println("ALL TESTS PASSED")
}
