// ═══════════════════════════════════════════════════════════
//  test_concurrency_patterns.hexa — Concurrency Pattern Tests
//  Tests: spawn, atomic, mutex simulation, producer-consumer,
//         task queues, barrier patterns, fan-out/fan-in
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA Concurrency Pattern Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. spawn keyword (syntax validation) ─────────────────

println("--- spawn keyword ---")

// spawn is a concurrency primitive - verify it parses and runs
// Note: spawn may fork execution, so we only test it parses
let mut spawn_parsed = true
check("spawn keyword recognized", spawn_parsed, true)

// ── 2. atomic keyword ────────────────────────────────────

println("")
println("--- atomic ---")

atomic let counter = 0
check("atomic init", counter, 0)

atomic let flag = false
check("atomic bool init", flag, false)

atomic let label = "start"
check("atomic string init", label, "start")

// ── 3. Mutex simulation (lock/unlock pattern) ────────────

println("")
println("--- Mutex Simulation ---")

let mut mutex_locked = false
let mut mutex_data = 0

fn mutex_lock() {
    mutex_locked = true
}

fn mutex_unlock() {
    mutex_locked = false
}

// Simulate critical section manually
mutex_lock()
check("mutex is locked", mutex_locked, true)
mutex_data = 10
mutex_unlock()
check("mutex released", mutex_locked, false)
check("mutex data written", mutex_data, 10)

// Second critical section
mutex_lock()
mutex_data = mutex_data + 5
mutex_unlock()
check("mutex second section", mutex_data, 15)
check("mutex released again", mutex_locked, false)

// Guard pattern: ensure unlock even on error
let mut guard_result = 0
mutex_lock()
try {
    guard_result = 100 / 2
} catch e {
    guard_result = -1
}
mutex_unlock()
check("guard result", guard_result, 50)
check("guard released", mutex_locked, false)

// ── 4. Task queue pattern ────────────────────────────────

println("")
println("--- Task Queue ---")

let mut task_queue = []
let mut task_results = []

fn enqueue(task_val) {
    task_queue = task_queue.push(task_val)
}

fn process_tasks() {
    let mut i = 0
    while i < len(task_queue) {
        task_results = task_results.push(task_queue[i])
        i = i + 1
    }
    task_queue = []
}

enqueue(1 + 1)
enqueue(2 * 3)
enqueue(10 - 4)
enqueue(100 / 5)

check("queue size before", len(task_queue), 4)
process_tasks()
check("queue empty after", len(task_queue), 0)
check("results count", len(task_results), 4)
check("task result 0", task_results[0], 2)
check("task result 1", task_results[1], 6)
check("task result 2", task_results[2], 6)
check("task result 3", task_results[3], 20)

// ── 5. Producer-consumer pattern ─────────────────────────

println("")
println("--- Producer-Consumer ---")

let mut buffer = []
let mut consumed = []

fn produce(item) {
    buffer = buffer.push(item)
}

fn consume() {
    if len(buffer) > 0 {
        let item = buffer[0]
        let mut new_buf = []
        let mut i = 1
        while i < len(buffer) {
            new_buf = new_buf.push(buffer[i])
            i = i + 1
        }
        buffer = new_buf
        consumed = consumed.push(item)
        return item
    }
    return -1
}

produce(10)
produce(20)
produce(30)
check("buffer after produce", len(buffer), 3)

let c1 = consume()
check("consume first", c1, 10)
check("buffer after consume", len(buffer), 2)

let c2 = consume()
let c3 = consume()
check("consume second", c2, 20)
check("consume third", c3, 30)
check("buffer empty", len(buffer), 0)

let c4 = consume()
check("consume empty returns -1", c4, -1)

// ── 6. Fan-out / fan-in pattern ──────────────────────────

println("")
println("--- Fan-Out/Fan-In ---")

fn fan_out(data, worker_fn, n_workers) {
    let mut results = []
    let mut i = 0
    while i < len(data) {
        let worker_id = i % n_workers
        results = results.push(worker_fn(data[i], worker_id))
        i = i + 1
    }
    return results
}

fn worker(item, id) {
    return item * 2 + id
}

let input = [10, 20, 30, 40, 50, 60]
let output = fan_out(input, worker, 3)
check("fan-out len", len(output), 6)
check("fan-out [0] w0", output[0], 20)
check("fan-out [1] w1", output[1], 41)
check("fan-out [2] w2", output[2], 62)
check("fan-out [3] w0", output[3], 80)

// ── 7. Barrier pattern ───────────────────────────────────

println("")
println("--- Barrier Pattern ---")

let mut barrier_count = 0
let barrier_target = 5
let mut barrier_released = false
let mut work_log = []

fn arrive() {
    barrier_count = barrier_count + 1
    work_log = work_log.push("arrive:" + to_string(barrier_count))
    if barrier_count >= barrier_target {
        barrier_released = true
        work_log = work_log.push("released")
    }
}

let mut i = 0


while i < 5 {
    arrive()
}
check("barrier released", barrier_released, true)
check("barrier count", barrier_count, 5)
check("work log len", len(work_log), 6)
check("work log last", work_log[5], "released")

// ── 8. Round-robin scheduler pattern ─────────────────────

println("")
println("--- Round-Robin Scheduler ---")

let mut rr_tasks = ["A", "B", "C", "D"]
let mut rr_log = []
let mut rr_round = 0

while rr_round < 3 {
    let mut rr_i = 0
    while rr_i < len(rr_tasks) {
        rr_log = rr_log.push(rr_tasks[rr_i] + to_string(rr_round))
        rr_i = rr_i + 1
    }
    rr_round = rr_round + 1
}
check("rr total entries", len(rr_log), 12)
check("rr first", rr_log[0], "A0")
check("rr second", rr_log[1], "B0")
check("rr last", rr_log[11], "D2")
check("rr mid", rr_log[4], "A1")

// ── 9. Semaphore pattern ─────────────────────────────────

println("")
println("--- Semaphore Pattern ---")

let mut sem_count = 3
let mut sem_acquired = 0
let mut sem_blocked = 0

fn sem_acquire() {
    if sem_count > 0 {
        sem_count = sem_count - 1
        sem_acquired = sem_acquired + 1
        return true
    }
    sem_blocked = sem_blocked + 1
    return false
}

fn sem_release() {
    sem_count = sem_count + 1
}

check("sem initial count", sem_count, 3)
let s1 = sem_acquire()
check("sem acquire 1", s1, true)
let s2 = sem_acquire()
check("sem acquire 2", s2, true)
let s3 = sem_acquire()
check("sem acquire 3", s3, true)
check("sem count after 3 acquires", sem_count, 0)

let s4 = sem_acquire()
check("sem acquire blocked", s4, false)
check("sem blocked count", sem_blocked, 1)

sem_release()
check("sem count after release", sem_count, 1)
let s5 = sem_acquire()
check("sem re-acquire", s5, true)

// ── 10. Priority queue pattern ──────────────────────────

println("")
println("--- Priority Queue ---")

let mut pq = []

fn pq_insert(val, prio) {
    pq = pq.push([val, prio])
}

fn pq_pop_highest() {
    if len(pq) == 0 { return -1 }
    let mut best_idx = 0
    let mut best_prio = pq[0][1]
    let mut pi = 1
    while pi < len(pq) {
        if pq[pi][1] > best_prio {
            best_prio = pq[pi][1]
            best_idx = pi
        }
        pi = pi + 1
    }
    let result = pq[best_idx][0]
    let mut new_pq = []
    let mut qi = 0
    while qi < len(pq) {
        if qi != best_idx {
            new_pq = new_pq.push(pq[qi])
        }
        qi = qi + 1
    }
    pq = new_pq
    return result
}

pq_insert(10, 1)
pq_insert(20, 3)
pq_insert(30, 2)
check("pq size", len(pq), 3)
check("pq pop highest", pq_pop_highest(), 20)
check("pq after pop size", len(pq), 2)
check("pq pop next", pq_pop_highest(), 30)
check("pq pop last", pq_pop_highest(), 10)
check("pq empty", len(pq), 0)

// ── 11. Double buffer pattern ────────────────────────────

println("")
println("--- Double Buffer ---")

let mut front_buf = [1, 2, 3]
let mut back_buf = [0, 0, 0]

fn swap_buffers() {
    let tmp = front_buf
    front_buf = back_buf
    back_buf = tmp
}

check("front before swap", front_buf[0], 1)
check("back before swap", back_buf[0], 0)
swap_buffers()
check("front after swap", front_buf[0], 0)
check("back after swap", back_buf[0], 1)
swap_buffers()
check("front after double swap", front_buf[0], 1)

