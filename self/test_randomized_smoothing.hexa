// ═══════════════════════════════════════════════════════════════════
//  test_randomized_smoothing.hexa — Randomized Smoothing (#258)
//
//  Run: PATH=/Users/ghost/.cargo/bin:$PATH ./hexa self/test_randomized_smoothing.hexa
// ═══════════════════════════════════════════════════════════════════

import "ml/randomized_smoothing.hexa"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs_(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx_(a, b, eps) { return fabs_(a - b) < eps }

println("=== Randomized Smoothing (#258) Tests ===")

// ── T1 linear_predict picks argmax ──────────────────────────────
let W1 = [
    [1.0, 0.0],   // class 0
    [0.0, 1.0],   // class 1
    [0.6, 0.6]    // class 2 (wins when x=(1,1))
]
check("T1 x=(1,0) -> class0", rs_linear_predict(W1, [1.0, 0.0]) == 0)
check("T1 x=(0,1) -> class1", rs_linear_predict(W1, [0.0, 1.0]) == 1)
check("T1 x=(1,1) -> class2", rs_linear_predict(W1, [1.0, 1.0]) == 2)

// ── T2 norm_cdf(0) = 0.5 ────────────────────────────────────────
check("T2 cdf(0)=0.5", approx_(rs_norm_cdf(0.0), 0.5, 1.0e-3))

// ── T3 norm_cdf symmetry ────────────────────────────────────────
let c_neg = rs_norm_cdf(-1.0)
let c_pos = rs_norm_cdf(1.0)
check("T3 cdf(-1)+cdf(1)=1", approx_(c_neg + c_pos, 1.0, 1.0e-3))

// ── T4 norm_ppf round-trip ──────────────────────────────────────
let p4 = 0.75
let z4 = rs_norm_ppf(p4)
let c4 = rs_norm_cdf(z4)
check("T4 round-trip ppf/cdf", approx_(c4, p4, 0.01))

// ── T5 norm_ppf(0.5) = 0 ────────────────────────────────────────
check("T5 ppf(0.5)=0", approx_(rs_norm_ppf(0.5), 0.0, 1.0e-3))

// ── T6 lower_bound shrinks p_hat ────────────────────────────────
let p_lo6 = rs_lower_bound(90, 100, 0.05)
check("T6 lower bound < 0.9", p_lo6 < 0.9)
check("T6 lower bound >= 0", p_lo6 >= 0.0)

// ── T7 lower_bound grows with n ────────────────────────────────
let p_lo_small = rs_lower_bound(18, 20, 0.05)
let p_lo_big   = rs_lower_bound(900, 1000, 0.05)
check("T7 bigger n -> tighter bound", p_lo_big > p_lo_small)

// ── T8 counts_under_noise shape ─────────────────────────────────
let x8 = [5.0, -5.0]   // strong class 0 signal
let counts8 = rs_counts_under_noise(W1, x8, 0.5, 100, 42)
check("T8 counts length", len(counts8) == 3)
let mut total8 = 0
for i in 0..3 { total8 = total8 + counts8[i] }
check("T8 counts sum = n", total8 == 100)

// ── T9 high-signal x -> dominant class ──────────────────────────
check("T9 class0 dominates", counts8[0] > counts8[1] && counts8[0] > counts8[2])

// ── T10 majority class picks largest ────────────────────────────
let counts10 = [10, 50, 30]
check("T10 majority=1", rs_majority_class(counts10) == 1)

// ── T11 certify high-signal -> non-zero radius ─────────────────
let cert = rs_certify(W1, x8, 0.5, 200, 0.05, 123)
check("T11 certified class0", cert["class"] == 0)
check("T11 radius > 0", cert["radius"] > 0.0)
check("T11 pA_lo > 0.5", cert["pA_lo"] > 0.5)

// ── T12 certify ambiguous x -> abstain ─────────────────────────
// x=(0.01,0.01) has tiny signal — with very large sigma Monte Carlo
// should split roughly evenly across classes.
let x_amb = [0.01, 0.01]
let cert_amb = rs_certify(W1, x_amb, 3.0, 200, 0.05, 7)
check("T12 abstain radius=0", cert_amb["radius"] == 0.0 || cert_amb["pA_lo"] <= 0.5)

// ── T13 larger sigma -> smaller cert p (noisier) ───────────────
let cert_hi_sigma = rs_certify(W1, x8, 5.0, 200, 0.05, 13)
let cert_lo_sigma = rs_certify(W1, x8, 0.1, 200, 0.05, 13)
check("T13 higher sigma -> lower pA_lo", cert_hi_sigma["pA_lo"] < cert_lo_sigma["pA_lo"])

println("")
println("=== Randomized Smoothing test summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
