// ═══════════════════════════════════════════════════════════════════
//  test_date_time_pure.hexa — coverage for self/runtime/date_time_pure
//
//  Tests: day_of_year_pure, days_between_pure, julian_day_pure,
//         add_days_pure, format_duration_ms_pure
//
//  (codegen import not wired for test files; inline the module body,
//   same pattern as test_bitops_pure.hexa / test_datetime_pure.hexa.)
// ═══════════════════════════════════════════════════════════════════

// ── INLINED from self/runtime/date_time_pure.hexa ──

@pure
fn _dt_is_leap(year) {
    if (year % 4) != 0 { return false }
    if (year % 100) != 0 { return true }
    if (year % 400) != 0 { return false }
    return true
}

@pure
fn _dt_days_in_month(year, month) {
    if month == 1  { return 31 }
    if month == 3  { return 31 }
    if month == 5  { return 31 }
    if month == 7  { return 31 }
    if month == 8  { return 31 }
    if month == 10 { return 31 }
    if month == 12 { return 31 }
    if month == 4  { return 30 }
    if month == 6  { return 30 }
    if month == 9  { return 30 }
    if month == 11 { return 30 }
    if month == 2 {
        if _dt_is_leap(year) { return 29 }
        return 28
    }
    return 0
}

@pure
fn day_of_year_impl(year, month, day) {
    let mut total = 0
    let mut mm = 1
    while mm < month {
        total = total + _dt_days_in_month(year, mm)
        mm = mm + 1
    }
    return total + day
}

pub fn day_of_year_pure(year, month, day) {
    return day_of_year_impl(year, month, day)
}

@pure
fn julian_day_impl(year, month, day) {
    let a = (14 - month) / 12
    let yp = year + 4800 - a
    let mp = month + 12 * a - 3
    let jdn = day + (153 * mp + 2) / 5
            + 365 * yp + yp / 4 - yp / 100 + yp / 400 - 32045
    return jdn
}

pub fn julian_day_pure(year, month, day) {
    return julian_day_impl(year, month, day)
}

@pure
fn days_between_impl(y1, m1, d1, y2, m2, d2) {
    let a = julian_day_impl(y1, m1, d1)
    let b = julian_day_impl(y2, m2, d2)
    return b - a
}

pub fn days_between_pure(y1, m1, d1, y2, m2, d2) {
    return days_between_impl(y1, m1, d1, y2, m2, d2)
}

@pure
fn add_days_impl(year, month, day, n) {
    let mut y = year
    let mut m = month
    let mut d = day
    let mut k = n
    while k > 0 {
        let dim = _dt_days_in_month(y, m)
        if d < dim {
            d = d + 1
        } else {
            d = 1
            if m < 12 {
                m = m + 1
            } else {
                m = 1
                y = y + 1
            }
        }
        k = k - 1
    }
    while k < 0 {
        if d > 1 {
            d = d - 1
        } else {
            if m > 1 {
                m = m - 1
            } else {
                m = 12
                y = y - 1
            }
            d = _dt_days_in_month(y, m)
        }
        k = k + 1
    }
    let result = []
    return result.push(y).push(m).push(d)
}

pub fn add_days_pure(year, month, day, n) {
    return add_days_impl(year, month, day, n)
}

@pure
fn _dt_pad2(n) {
    if n < 0 || n >= 100 { return to_string(n) }
    if n < 10 { return "0" + to_string(n) }
    return to_string(n)
}

@pure
fn _dt_pad3(n) {
    if n < 0 || n >= 1000 { return to_string(n) }
    if n < 10   { return "00" + to_string(n) }
    if n < 100  { return "0"  + to_string(n) }
    return to_string(n)
}

@pure
fn format_duration_ms_impl(ms) {
    let mut neg = false
    let mut total = ms
    if total < 0 {
        neg = true
        total = 0 - total
    }
    let h = total / 3600000
    let rem1 = total % 3600000
    let m = rem1 / 60000
    let rem2 = rem1 % 60000
    let s = rem2 / 1000
    let milli = rem2 % 1000

    let mut out = ""
    if neg { out = "-" }
    if h > 0 {
        out = out + to_string(h) + "h " + _dt_pad2(m) + "m " + _dt_pad2(s) + "." + _dt_pad3(milli) + "s"
        return out
    }
    if m > 0 {
        out = out + to_string(m) + "m " + _dt_pad2(s) + "." + _dt_pad3(milli) + "s"
        return out
    }
    out = out + to_string(s) + "." + _dt_pad3(milli) + "s"
    return out
}

pub fn format_duration_ms_pure(ms) {
    return format_duration_ms_impl(ms)
}

// ── END inlined ────────────────────────────────────────────────────

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_arr3(name, actual, ey, em, ed) {
    let exp = "[" + to_string(ey) + ", " + to_string(em) + ", " + to_string(ed) + "]"
    let got = to_string(actual)
    if got == exp {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + exp + ", got: " + got)
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  Pure-Hexa Date/Time Calendar Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── day_of_year_pure ──────────────────────────────────────────────
println("--- day_of_year_pure ---")
check("doy 2026-01-01",   day_of_year_pure(2026, 1, 1),   1)
check("doy 2026-01-31",   day_of_year_pure(2026, 1, 31),  31)
check("doy 2026-02-01",   day_of_year_pure(2026, 2, 1),   32)
check("doy 2026-03-01",   day_of_year_pure(2026, 3, 1),   60)    // non-leap
check("doy 2024-03-01",   day_of_year_pure(2024, 3, 1),   61)    // leap +1
check("doy 2024-02-29",   day_of_year_pure(2024, 2, 29),  60)    // leap Feb 29
check("doy 2026-04-17",   day_of_year_pure(2026, 4, 17),  107)
check("doy 2026-12-31",   day_of_year_pure(2026, 12, 31), 365)   // non-leap
check("doy 2024-12-31",   day_of_year_pure(2024, 12, 31), 366)   // leap
check("doy 1900-12-31",   day_of_year_pure(1900, 12, 31), 365)   // 1900 NOT leap
check("doy 2000-12-31",   day_of_year_pure(2000, 12, 31), 366)   // 2000 IS leap

// ── julian_day_pure ───────────────────────────────────────────────
//   Reference JDNs (UT noon):
//     2000-01-01  = 2451545
//     1970-01-01  = 2440588
//     2026-04-17  = 2461148
//     1900-01-01  = 2415021
println("")
println("--- julian_day_pure ---")
check("jdn 2000-01-01", julian_day_pure(2000, 1, 1),  2451545)
check("jdn 1970-01-01", julian_day_pure(1970, 1, 1),  2440588)
check("jdn 2026-04-17", julian_day_pure(2026, 4, 17), 2461148)
check("jdn 1900-01-01", julian_day_pure(1900, 1, 1),  2415021)
check("jdn 2024-02-29", julian_day_pure(2024, 2, 29), 2460370)

// ── days_between_pure ─────────────────────────────────────────────
println("")
println("--- days_between_pure ---")
check("dbw same day",       days_between_pure(2026, 4, 17, 2026, 4, 17), 0)
check("dbw +1",             days_between_pure(2026, 4, 17, 2026, 4, 18), 1)
check("dbw -1",             days_between_pure(2026, 4, 18, 2026, 4, 17), -1)
check("dbw cross-year 365", days_between_pure(2025, 4, 17, 2026, 4, 17), 365)  // 2025 non-leap
check("dbw cross-leap 366", days_between_pure(2024, 2, 29, 2025, 2, 28), 365)
check("dbw 30-year span",   days_between_pure(1970, 1, 1,  2000, 1, 1),  10957) // 30y: 23*365+7*366
check("dbw century 1900-2000", days_between_pure(1900, 1, 1, 2000, 1, 1), 36524)

// ── add_days_pure ─────────────────────────────────────────────────
println("")
println("--- add_days_pure ---")
check_arr3("add 0 days",         add_days_pure(2026, 4, 17, 0),   2026, 4, 17)
check_arr3("add +1 day",         add_days_pure(2026, 4, 17, 1),   2026, 4, 18)
check_arr3("add -1 day",         add_days_pure(2026, 4, 17, -1),  2026, 4, 16)
check_arr3("add cross-month",    add_days_pure(2026, 4, 30, 1),   2026, 5, 1)
check_arr3("add cross-year",     add_days_pure(2026, 12, 31, 1),  2027, 1, 1)
check_arr3("sub cross-year",     add_days_pure(2026, 1, 1, -1),   2025, 12, 31)
check_arr3("leap Feb28 +1",      add_days_pure(2024, 2, 28, 1),   2024, 2, 29)
check_arr3("non-leap Feb28 +1",  add_days_pure(2025, 2, 28, 1),   2025, 3, 1)
check_arr3("leap Feb29 +1",      add_days_pure(2024, 2, 29, 1),   2024, 3, 1)
check_arr3("add 365 leap",       add_days_pure(2024, 1, 1, 366),  2025, 1, 1)
check_arr3("add 365 non-leap",   add_days_pure(2025, 1, 1, 365),  2026, 1, 1)

// ── format_duration_ms_pure ───────────────────────────────────────
println("")
println("--- format_duration_ms_pure ---")
check("dur 0",          format_duration_ms_pure(0),        "0.000s")
check("dur 1",          format_duration_ms_pure(1),        "0.001s")
check("dur 999",        format_duration_ms_pure(999),      "0.999s")
check("dur 1000",       format_duration_ms_pure(1000),     "1.000s")
check("dur 1234",       format_duration_ms_pure(1234),     "1.234s")
check("dur 59999",      format_duration_ms_pure(59999),    "59.999s")
check("dur 60000",      format_duration_ms_pure(60000),    "1m 00.000s")
check("dur 65000",      format_duration_ms_pure(65000),    "1m 05.000s")
check("dur 125500",     format_duration_ms_pure(125500),   "2m 05.500s")
check("dur 3600000",    format_duration_ms_pure(3600000),  "1h 00m 00.000s")
check("dur 3661500",    format_duration_ms_pure(3661500),  "1h 01m 01.500s")
check("dur -2500",      format_duration_ms_pure(-2500),    "-2.500s")
check("dur -65000",     format_duration_ms_pure(-65000),   "-1m 05.000s")

println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    println("FAIL")
    exit(1)
}
println("ALL PASS")
