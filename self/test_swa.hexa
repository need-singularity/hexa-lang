// ═══════════════════════════════════════════════════════════════════
//  test_swa.hexa — ROI #109 correctness suite
//
//  Validates self/ai_native/swa.hexa:
//    T1   single snapshot = original weights
//    T2   2 identical snapshots → avg = same
//    T3   3 different snapshots → correct weighted average
//    T4   should_snapshot timing logic: before start
//    T5   should_snapshot timing logic: on start
//    T6   should_snapshot timing logic: on-cycle
//    T7   should_snapshot timing logic: off-cycle
//    T8   running average numerical precision (10 snapshots)
//    T9   get_weights returns copy (not alias)
//    T10  bn_update running mean over batches
//    T11  AST detect_no_swa POS (no swa nodes)
//    T12  AST detect_no_swa NEG (has swa_update)
//    T13  AST rewrite inserts swa_snapshot after optimizer_step
//    T14  AST rewrite is identity when SWA already present
//    T15  AST rewrite is identity when no optimizer_step
// ═══════════════════════════════════════════════════════════════════

import "ai_native/swa.hexa"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs_t(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn vec_close(a, b, eps) {
    if len(a) != len(b) { return false }
    for i in 0..len(a) {
        if fabs_t(a[i] - b[i]) > eps { return false }
    }
    return true
}

// ══════════════════════════════════════════════════════════════════
println("═══════════════════════════════════════════════════════")
println("  ROI #109 Stochastic Weight Averaging — correctness")
println("═══════════════════════════════════════════════════════")

let tol = 1.0e-9

// ── T1  single snapshot = original weights ───────────────────────
let w1 = [1.0, 2.0, 3.0, 4.0]
let s1 = swa_init(w1)
check("T1 single snapshot avg == original",
      vec_close(swa_get_weights(s1), w1, tol))
check("T1 single snapshot count == 1", s1["count"] == 1)

// ── T2  2 identical snapshots → avg = same ───────────────────────
let w2 = [5.0, 10.0, 15.0]
let s2a = swa_init(w2)
let s2b = swa_update(s2a, w2)
check("T2 two identical snapshots avg unchanged",
      vec_close(swa_get_weights(s2b), w2, tol))
check("T2 count == 2", s2b["count"] == 2)

// ── T3  3 different snapshots → correct weighted average ─────────
// snap1 = [1, 2, 3], snap2 = [4, 5, 6], snap3 = [7, 8, 9]
// avg = [(1+4+7)/3, (2+5+8)/3, (3+6+9)/3] = [4, 5, 6]
let snap1 = [1.0, 2.0, 3.0]
let snap2 = [4.0, 5.0, 6.0]
let snap3 = [7.0, 8.0, 9.0]
let s3a = swa_init(snap1)
let s3b = swa_update(s3a, snap2)
let s3c = swa_update(s3b, snap3)
let expected3 = [4.0, 5.0, 6.0]
check("T3 three snapshots correct average",
      vec_close(swa_get_weights(s3c), expected3, tol))
check("T3 count == 3", s3c["count"] == 3)

// ── T4  should_snapshot: before start → false ────────────────────
check("T4 step < start_step → false",
      !swa_should_snapshot(5, 10, 3))

// ── T5  should_snapshot: on start → true ─────────────────────────
check("T5 step == start_step → true",
      swa_should_snapshot(10, 10, 3))

// ── T6  should_snapshot: on-cycle → true ─────────────────────────
// start=10, period=5 → next hits at 15, 20, 25 ...
check("T6a step=15 on-cycle",  swa_should_snapshot(15, 10, 5))
check("T6b step=20 on-cycle",  swa_should_snapshot(20, 10, 5))
check("T6c step=100 on-cycle", swa_should_snapshot(100, 10, 5))

// ── T7  should_snapshot: off-cycle → false ───────────────────────
check("T7a step=11 off-cycle", !swa_should_snapshot(11, 10, 5))
check("T7b step=12 off-cycle", !swa_should_snapshot(12, 10, 5))
check("T7c step=14 off-cycle", !swa_should_snapshot(14, 10, 5))

// ── T8  running average numerical precision (10 snapshots) ───────
// Accumulate snapshots [k, k, k, k] for k = 1..10
// Expected avg = mean(1..10) = 5.5 for each element.
let mut s8 = swa_init([1.0, 1.0, 1.0, 1.0])
for k in 2..11 {
    let val = k * 1.0
    s8 = swa_update(s8, [val, val, val, val])
}
let expected8 = [5.5, 5.5, 5.5, 5.5]
check("T8 10-snapshot running avg == 5.5",
      vec_close(swa_get_weights(s8), expected8, tol))
check("T8 count == 10", s8["count"] == 10)

// ── T9  get_weights returns copy ─────────────────────────────────
let w9 = [1.0, 2.0]
let s9 = swa_init(w9)
let got9 = swa_get_weights(s9)
// Mutating the returned array should not affect internal state.
got9[0] = 999.0
let got9b = swa_get_weights(s9)
check("T9 get_weights returns independent copy",
      fabs_t(got9b[0] - 1.0) < tol)

// ── T10  bn_update running mean over batches ─────────────────────
let avg_w = [0.0, 0.0, 0.0]
let batches = [
    [1.0, 2.0, 3.0],
    [3.0, 4.0, 5.0],
    [5.0, 6.0, 7.0]
]
let bn_out = swa_bn_update(avg_w, batches)
// mean = [(1+3+5)/3, (2+4+6)/3, (3+5+7)/3] = [3, 4, 5]
let expected_bn = [3.0, 4.0, 5.0]
check("T10 bn_update running mean correct",
      vec_close(bn_out, expected_bn, tol))

// ── T11  AST detect_no_swa POS ───────────────────────────────────
let prog_no_swa = [
    swa_stmt_optimizer_step(),
    swa_stmt_other()
]
check("T11 detect_no_swa POS (no swa nodes)", detect_no_swa(prog_no_swa))

// ── T12  AST detect_no_swa NEG ───────────────────────────────────
let prog_has_swa = [
    swa_stmt_optimizer_step(),
    swa_stmt_swa_update(),
    swa_stmt_other()
]
check("T12 detect_no_swa NEG (has swa_update)", !detect_no_swa(prog_has_swa))

// ── T13  AST rewrite inserts swa_snapshot ────────────────────────
let prog_rw = rewrite_add_swa(prog_no_swa, 100, 5)
check("T13a rewrite increases length", len(prog_rw) == 3)
check("T13b first node still optimizer_step",
      prog_rw[0].kind == "optimizer_step")
check("T13c inserted node is swa_snapshot",
      prog_rw[1].kind == "swa_snapshot")
check("T13d snapshot start_step == 100",
      prog_rw[1].start_step == 100)
check("T13e snapshot period == 5",
      prog_rw[1].period == 5)
check("T13f last node still other",
      prog_rw[2].kind == "other")

// ── T14  AST rewrite is identity when SWA already present ────────
let prog_already = [
    swa_stmt_optimizer_step(),
    swa_stmt_swa_update()
]
let prog_rw14 = rewrite_add_swa(prog_already, 50, 10)
check("T14 rewrite identity when swa present",
      len(prog_rw14) == 2)

// ── T15  AST rewrite is identity when no optimizer_step ──────────
let prog_no_opt = [
    swa_stmt_other(),
    swa_stmt_other()
]
let prog_rw15 = rewrite_add_swa(prog_no_opt, 50, 10)
check("T15 rewrite identity when no optimizer_step",
      len(prog_rw15) == 2)

// ══════════════════════════════════════════════════════════════════
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " PASS / "
        + to_string(fail_count) + " FAIL")
println("═══════════════════════════════════════════════════════")

if fail_count == 0 {
    println("[ALL PASS] ROI #109 swa verified")
}
