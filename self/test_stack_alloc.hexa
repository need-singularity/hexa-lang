// ═══════════════════════════════════════════════════════════
//  test_stack_alloc.hexa — #47 @stack_alloc pass validation
//
//  Verifies that bounded-size arrays are correctly identified
//  as stack allocation candidates. The @stack_alloc attribute
//  signals the compiler to use alloca instead of heap malloc
//  for arrays with known upper bounds.
//
//  실행: ./hexa test self/test_stack_alloc.hexa
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn check_eq(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_arr(name, actual, expected) {
    if len(actual) != len(expected) {
        println("[FAIL] " + name + " — len mismatch: " + to_string(len(actual)) + " vs " + to_string(len(expected)))
        fail_count = fail_count + 1
        return
    }
    let mut ok = true
    let mut i = 0
    while i < len(actual) {
        if actual[i] != expected[i] { ok = false }
        i = i + 1
    }
    if ok {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — actual: " + to_string(actual) + ", expected: " + to_string(expected))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  #47 @stack_alloc Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Basic bounded array — push N known elements
fn build_small_array() {
    let mut arr = []
    arr.push(1)
    arr.push(2)
    arr.push(3)
    return arr
}

check_arr("basic: 3 pushes", build_small_array(), [1, 2, 3])

// ── 2. Fixed-size collection from loop with known bound
fn build_bounded_loop(n) {
    let mut arr = []
    let mut i = 0
    while i < n {
        arr.push(i * i)
        i = i + 1
    }
    return arr
}

check_arr("bounded loop: 5", build_bounded_loop(5), [0, 1, 4, 9, 16])
check_arr("bounded loop: 0", build_bounded_loop(0), [])
check_arr("bounded loop: 1", build_bounded_loop(1), [0])

// ── 3. Stack-friendly filter — bounded output
fn filter_positives(src) {
    let mut out = []
    let mut i = 0
    while i < len(src) {
        if src[i] > 0 {
            out.push(src[i])
        }
        i = i + 1
    }
    return out
}

check_arr("filter: [3,-1,4,-5,2]", filter_positives([3, -1, 4, -5, 2]), [3, 4, 2])
check_arr("filter: all neg", filter_positives([-1, -2, -3]), [])
check_arr("filter: all pos", filter_positives([1, 2, 3]), [1, 2, 3])

// ── 4. Transform + collect (bounded by input size)
fn double_all(src) {
    let mut result = []
    let mut i = 0
    while i < len(src) {
        result.push(src[i] * 2)
        i = i + 1
    }
    return result
}

check_arr("double: [1,2,3]", double_all([1, 2, 3]), [2, 4, 6])
check_arr("double: empty", double_all([]), [])

// ── 5. Multiple bounded arrays in one function
fn split_even_odd(src) {
    let mut evens = []
    let mut odds = []
    let mut i = 0
    while i < len(src) {
        if src[i] % 2 == 0 {
            evens.push(src[i])
        } else {
            odds.push(src[i])
        }
        i = i + 1
    }
    return [len(evens), len(odds)]
}

check_arr("split: [1,2,3,4,5,6]", split_even_odd([1, 2, 3, 4, 5, 6]), [3, 3])
check_arr("split: all even", split_even_odd([2, 4, 6]), [3, 0])

// ── 6. Nested bounded collection
fn collect_pairs(n) {
    let mut pairs = []
    let mut i = 0
    while i < n {
        pairs.push(i)
        pairs.push(i + 100)
        i = i + 1
    }
    return pairs
}

check_arr("pairs: 3", collect_pairs(3), [0, 100, 1, 101, 2, 102])
check_eq("pairs: len", len(collect_pairs(4)), 8)

// ── 7. Accumulate with known upper bound
fn take_first_n(src, n) {
    let mut out = []
    let mut i = 0
    let limit = n
    if limit > len(src) { limit = len(src) }
    while i < limit {
        out.push(src[i])
        i = i + 1
    }
    return out
}

check_arr("take: first 3 of [10,20,30,40,50]", take_first_n([10, 20, 30, 40, 50], 3), [10, 20, 30])
check_arr("take: first 10 of [1,2]", take_first_n([1, 2], 10), [1, 2])

// ── 8. Stack alloc in inner scope (while body)
fn collect_in_loop(outer_n) {
    let mut total = 0
    let mut k = 0
    while k < outer_n {
        let mut inner = []
        inner.push(k)
        inner.push(k + 1)
        total = total + len(inner)
        k = k + 1
    }
    return total
}

check_eq("inner scope: 3 iters", collect_in_loop(3), 6)
check_eq("inner scope: 0 iters", collect_in_loop(0), 0)

// ── 9. Verify correctness after hypothetical alloca (semantic equivalence)
fn sum_array(arr) {
    let mut s = 0
    let mut i = 0
    while i < len(arr) {
        s = s + arr[i]
        i = i + 1
    }
    return s
}

fn build_and_sum(n) {
    let mut arr = []
    let mut i = 1
    while i <= n {
        arr.push(i)
        i = i + 1
    }
    return sum_array(arr)
}

check_eq("build+sum: 10", build_and_sum(10), 55)
check_eq("build+sum: 0", build_and_sum(0), 0)
check_eq("build+sum: 1", build_and_sum(1), 1)

// ── 10. Reverse via bounded temp array
fn reverse_arr(src) {
    let mut rev = []
    let mut i = len(src) - 1
    while i >= 0 {
        rev.push(src[i])
        i = i - 1
    }
    return rev
}

check_arr("reverse: [1,2,3]", reverse_arr([1, 2, 3]), [3, 2, 1])
check_arr("reverse: [42]", reverse_arr([42]), [42])
check_arr("reverse: empty", reverse_arr([]), [])

// ── Summary
println("")
println("═══════════════════════════════════════════════════════")
println("  #47 @stack_alloc: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")
assert(fail_count == 0)
