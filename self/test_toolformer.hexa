// ===================================================================
//  test_toolformer.hexa — Toolformer self-supervised tool learning
//
//  Tests (≥12):
//    1.  tf_hash deterministic
//    2.  tf_rand01 in [0,1)
//    3.  tf_sample_positions picks above-threshold positions
//    4.  tf_sample_positions honors max_pos cap
//    5.  tf_sample_calls generates k candidates
//    6.  tf_execute_candidate dispatches to executor
//    7.  tf_perplexity_with uses tool result context
//    8.  tf_perplexity_without uses bare context
//    9.  tf_perplexity_gain positive when tool helps
//   10.  tf_filter_candidates keeps gain >= tau
//   11.  tf_filter_candidates drops gain < tau
//   12.  tf_top_per_position picks best per position
//   13.  tf_build_training_example splices tags at position
//   14.  tf_build_incontext_dataset end-to-end kept count
//   15.  tf_has_trigger_token finds explicit marker
//   16.  tf_inference_should_trigger via trigger token
//   17.  tf_inference_should_trigger via lm_score threshold
//   18.  tf_inference_step no-fire branch
//   19.  tf_inference_step fire branch splices tags
//   20.  parse_tool_calls roundtrips built training example
//
//  Run: hexa self/test_toolformer.hexa
// ===================================================================
// -- inlined from self/ml/toolformer.hexa --
// codegen import not wired for test files

// ===================================================================
//  self/ml/toolformer.hexa — Toolformer self-supervised tool learning
//
//  Pure Hexa implementation of Toolformer (Schick et al., 2023).
//  Base module: self/ml/function_calling.hexa (tool definitions,
//  <tool_call>/<tool_result> tags, parser, executor, loop runner).
//
//  Pipeline (self-supervised):
//    1. sample_api_positions(text) -> candidate positions (P(t) > thresh)
//    2. sample_api_calls(text, pos, tool, k) -> k candidate (name,args) pairs
//    3. execute_candidate(call, executor) -> result string
//    4. perplexity_with(prefix, call, result, suffix) -> ppl (lower=better)
//    5. perplexity_without(prefix, suffix) -> baseline ppl
//    6. filter_by_ppl_gain(candidates, tau) -> kept list
//    7. build_incontext_dataset(text, kept) -> training example with
//       inlined <tool_call>...</tool_call><tool_result>...</tool_result>
//    8. inference_trigger(partial_text) -> bool (should fire tool call)
//
//  Public API:
//    tf_sample_positions(text, prob_fn, threshold, max_pos)
//    tf_sample_calls(text, position, tool, k_samples, args_gen)
//    tf_execute_candidate(call, executor)
//    tf_perplexity_with(prefix, call, result, suffix, target, lm_score_fn)
//    tf_perplexity_without(prefix, suffix, target, lm_score_fn)
//    tf_filter_candidates(candidates, tau)
//    tf_build_training_example(text, call, result, position)
//    tf_build_incontext_dataset(texts, tools, k, tau, prob_fn,
//                               args_gen, executor, lm_score_fn)
//    tf_inference_should_trigger(partial_text, trigger_tokens, lm_score_fn,
//                                threshold)
//    tf_inference_step(partial_text, tools, args_gen, executor, lm_score_fn,
//                      threshold)
//
//  Conventions:
//    - Re-uses <tool_call>/<tool_result> tags from function_calling.hexa
//    - All randomness comes from seed-based pseudo-hash (deterministic tests)
//    - Perplexity is a surrogate: caller-supplied lm_score_fn(prefix, target)
//      returns a non-negative float (higher = worse/surprise). For tests we
//      use a deterministic mock score.
//    - HX3 pitfalls: no semicolons, no {k:v} inside if blocks,
//      flag-variable break pattern, absolute-path-free relative imports.
// ===================================================================

import "ml/function_calling.hexa"

// ── deterministic PRNG (avoid random() nondeterminism in tests) ────

fn tf_hash(seed, i) {
    let h = ((seed * 2654435761 + i * 1315423911 + 731) % 100003)
    if h < 0 { return 0 - h }
    return h
}

fn tf_rand01(seed, i) {
    return to_float(tf_hash(seed, i)) / 100003.0
}

// ───────────────────────────────────────────────────────────────────
//  1. Candidate position sampling
//
//  Given a text and a "trigger probability" function prob_fn(text, pos),
//  return up to max_pos positions where prob_fn(...) >= threshold.
//  prob_fn is typically the LM's P("<API>" | prefix) head; for tests we
//  pass a deterministic mock.
// ───────────────────────────────────────────────────────────────────
fn tf_sample_positions(text, prob_fn, threshold, max_pos) {
    let n = len(text)
    let mut out = []
    let mut i = 0
    while i < n {
        if len(out) >= max_pos {
            i = n
        } else {
            let p = prob_fn(text, i)
            if p >= threshold {
                out = out + [i]
            }
            i = i + 1
        }
    }
    return out
}

// ───────────────────────────────────────────────────────────────────
//  2. Candidate API call sampling
//
//  Generate k candidate calls at a given text position for a given tool.
//  args_gen is fn(text, pos, tool, sample_index) -> arguments_json (str).
//  Each returned call is a map compatible with function_calling parser:
//    { "name": str, "arguments": str(json), "position": int, "sample": int }
// ───────────────────────────────────────────────────────────────────
fn tf_sample_calls(text, position, tool, k_samples, args_gen) {
    let mut out = []
    let mut s = 0
    while s < k_samples {
        let args = args_gen(text, position, tool, s)
        let call = #{}
        call["name"] = tool["name"]
        call["arguments"] = args
        call["position"] = position
        call["sample"] = s
        out = out + [call]
        s = s + 1
    }
    return out
}

// ───────────────────────────────────────────────────────────────────
//  3. Execute a candidate via the user-supplied executor from
//     function_calling.hexa. Returns the string result.
// ───────────────────────────────────────────────────────────────────
fn tf_execute_candidate(call, executor) {
    return executor(call["name"], call["arguments"])
}

// ───────────────────────────────────────────────────────────────────
//  4. Perplexity surrogate with tool result inlined
//
//  In Toolformer the filter is:
//     L_i(with)   = sum_j w_j * -log p(x_j | prefix · e(c_i, r_i))
//     L_i(without)= sum_j w_j * -log p(x_j | prefix)
//     keep if  L_i(without) - L_i(with)  >= tau
//
//  We delegate -log p to lm_score_fn(context_str, target_str) so the same
//  module can plug into a real LM later without code changes.
// ───────────────────────────────────────────────────────────────────
fn tf_perplexity_with(prefix, call, result, suffix, target, lm_score_fn) {
    // Build the "weighted conditioning context":
    //   prefix + <tool_call>{name,arguments}</tool_call><tool_result>...</tool_result> + suffix
    let call_tag = "<tool_call>{\"name\": \"" + call["name"]
    let call_tag2 = call_tag + "\", \"arguments\": " + call["arguments"] + "}</tool_call>"
    let res_tag = format_tool_result(call["name"], result)
    let ctx = prefix + call_tag2 + res_tag + suffix
    return lm_score_fn(ctx, target)
}

fn tf_perplexity_without(prefix, suffix, target, lm_score_fn) {
    let ctx = prefix + suffix
    return lm_score_fn(ctx, target)
}

// Compute gain = ppl_without - ppl_with. Higher gain = tool helps more.
fn tf_perplexity_gain(prefix, call, result, suffix, target, lm_score_fn) {
    let with_ppl = tf_perplexity_with(prefix, call, result, suffix, target, lm_score_fn)
    let without_ppl = tf_perplexity_without(prefix, suffix, target, lm_score_fn)
    return without_ppl - with_ppl
}

// ───────────────────────────────────────────────────────────────────
//  5. Filter candidates by perplexity gain >= tau
//
//  candidates: array of maps with keys
//    name, arguments, position, sample, result, ppl_with, ppl_without
//  tau: minimum improvement to keep
// ───────────────────────────────────────────────────────────────────
fn tf_filter_candidates(candidates, tau) {
    let n = len(candidates)
    let mut out = []
    let mut i = 0
    while i < n {
        let c = candidates[i]
        let gain = c["ppl_without"] - c["ppl_with"]
        if gain >= tau {
            let kept = #{}
            kept["name"] = c["name"]
            kept["arguments"] = c["arguments"]
            kept["position"] = c["position"]
            kept["sample"] = c["sample"]
            kept["result"] = c["result"]
            kept["gain"] = gain
            out = out + [kept]
        }
        i = i + 1
    }
    return out
}

// Keep only the best (max-gain) candidate per unique position
fn tf_top_per_position(filtered) {
    let n = len(filtered)
    let mut best_by_pos = #{}
    let mut i = 0
    while i < n {
        let c = filtered[i]
        let key = to_string(c["position"])
        if has_key(best_by_pos, key) {
            let prev = best_by_pos[key]
            if c["gain"] > prev["gain"] {
                best_by_pos[key] = c
            }
        } else {
            best_by_pos[key] = c
        }
        i = i + 1
    }
    let ks = keys(best_by_pos)
    let kn = len(ks)
    let mut out = []
    let mut j = 0
    while j < kn {
        out = out + [best_by_pos[ks[j]]]
        j = j + 1
    }
    return out
}

// ───────────────────────────────────────────────────────────────────
//  6. Build a single in-context training example by inlining the kept
//  call + result at the kept position of the original text.
// ───────────────────────────────────────────────────────────────────
fn tf_build_training_example(text, call, result, position) {
    let n = len(text)
    let mut p = position
    if p < 0 { p = 0 }
    if p > n { p = n }
    let prefix = text.substring(0, p)
    let suffix = text.substring(p, n)
    let call_tag = "<tool_call>{\"name\": \"" + call["name"]
    let call_tag2 = call_tag + "\", \"arguments\": " + call["arguments"] + "}</tool_call>"
    let res_tag = format_tool_result(call["name"], result)
    return prefix + call_tag2 + res_tag + suffix
}

// ───────────────────────────────────────────────────────────────────
//  7. End-to-end dataset builder
//
//  For each text in texts, for each tool in tools:
//    - sample candidate positions
//    - at each position sample k candidate calls
//    - execute each via executor
//    - score with/without via lm_score_fn
//    - filter by tau
//    - keep best per position
//    - emit in-context training example(s)
//
//  Returns an array of training examples (strings).
// ───────────────────────────────────────────────────────────────────
fn tf_build_incontext_dataset(texts, tools, k_samples, tau, prob_fn,
                              args_gen, executor, lm_score_fn,
                              pos_threshold, max_pos) {
    let nt = len(texts)
    let ntools = len(tools)
    let mut dataset = []
    let mut stats = #{}
    let mut n_candidates = 0
    let mut n_kept = 0

    let mut ti = 0
    while ti < nt {
        let text = texts[ti]
        let tlen = len(text)

        let positions = tf_sample_positions(text, prob_fn, pos_threshold, max_pos)
        let np = len(positions)

        let mut tool_i = 0
        while tool_i < ntools {
            let tool = tools[tool_i]

            let mut pi = 0
            while pi < np {
                let pos = positions[pi]
                let candidates = tf_sample_calls(text, pos, tool, k_samples, args_gen)
                let nc = len(candidates)

                let prefix = text.substring(0, pos)
                let suffix = text.substring(pos, tlen)
                let target = suffix

                // Score and annotate each candidate
                let mut scored = []
                let mut ci = 0
                while ci < nc {
                    let call = candidates[ci]
                    let result = tf_execute_candidate(call, executor)
                    let ppl_with = tf_perplexity_with(prefix, call, result,
                                                     suffix, target, lm_score_fn)
                    let ppl_without = tf_perplexity_without(prefix, suffix,
                                                           target, lm_score_fn)
                    let annotated = #{}
                    annotated["name"] = call["name"]
                    annotated["arguments"] = call["arguments"]
                    annotated["position"] = pos
                    annotated["sample"] = call["sample"]
                    annotated["result"] = result
                    annotated["ppl_with"] = ppl_with
                    annotated["ppl_without"] = ppl_without
                    scored = scored + [annotated]
                    n_candidates = n_candidates + 1
                    ci = ci + 1
                }

                let kept = tf_filter_candidates(scored, tau)
                let best = tf_top_per_position(kept)
                let nb = len(best)
                let mut bi = 0
                while bi < nb {
                    let b = best[bi]
                    let example = tf_build_training_example(text, b,
                                                            b["result"],
                                                            b["position"])
                    dataset = dataset + [example]
                    n_kept = n_kept + 1
                    bi = bi + 1
                }

                pi = pi + 1
            }

            tool_i = tool_i + 1
        }

        ti = ti + 1
    }

    stats["n_candidates"] = n_candidates
    stats["n_kept"] = n_kept
    stats["n_examples"] = len(dataset)

    let out = #{}
    out["dataset"] = dataset
    out["stats"] = stats
    return out
}

// ───────────────────────────────────────────────────────────────────
//  8. Inference-time tool-call trigger
//
//  During generation we check if the most recent tokens look like an
//  "I should call a tool" signal. Two strategies:
//    (a) explicit trigger tokens (e.g. "<API>" or "[TOOL]")
//    (b) lm_score_fn threshold on the "<tool_call>" continuation
// ───────────────────────────────────────────────────────────────────
fn tf_has_trigger_token(partial_text, trigger_tokens) {
    let n = len(trigger_tokens)
    let mut i = 0
    let mut hit = false
    while i < n {
        if partial_text.contains(trigger_tokens[i]) {
            hit = true
            i = n
        } else {
            i = i + 1
        }
    }
    return hit
}

fn tf_inference_should_trigger(partial_text, trigger_tokens,
                               lm_score_fn, threshold) {
    if tf_has_trigger_token(partial_text, trigger_tokens) {
        return true
    }
    // Fallback: LM score says "<tool_call>" is highly likely continuation
    let score = lm_score_fn(partial_text, "<tool_call>")
    return score <= threshold
}

// ───────────────────────────────────────────────────────────────────
//  9. Single inference step — if trigger fires, sample one call per tool,
//     rank by LM score (lower = more expected), execute the best, and
//     splice the <tool_call>...</tool_call><tool_result>...</tool_result>
//     into the partial text.
// ───────────────────────────────────────────────────────────────────
fn tf_inference_step(partial_text, tools, args_gen, executor,
                     lm_score_fn, trigger_tokens, threshold) {
    let fire = tf_inference_should_trigger(partial_text, trigger_tokens,
                                           lm_score_fn, threshold)
    if fire == false {
        let out = #{}
        out["fired"] = false
        out["text"] = partial_text
        out["call"] = #{}
        out["result"] = ""
        return out
    }

    let nt = len(tools)
    let pos = len(partial_text)
    let mut best_call = #{}
    let mut best_score = 1.0e18
    let mut has_best = false
    let mut i = 0
    while i < nt {
        let tool = tools[i]
        let args = args_gen(partial_text, pos, tool, 0)
        let cand = #{}
        cand["name"] = tool["name"]
        cand["arguments"] = args
        let ctx = partial_text + "<tool_call>{\"name\": \"" + cand["name"] + "\", \"arguments\": " + cand["arguments"] + "}</tool_call>"
        let score = lm_score_fn(ctx, "")
        if score < best_score {
            best_score = score
            best_call = cand
            has_best = true
        }
        i = i + 1
    }

    if has_best == false {
        let out = #{}
        out["fired"] = false
        out["text"] = partial_text
        out["call"] = #{}
        out["result"] = ""
        return out
    }

    let result = executor(best_call["name"], best_call["arguments"])
    let call_tag = "<tool_call>{\"name\": \"" + best_call["name"]
    let call_tag2 = call_tag + "\", \"arguments\": " + best_call["arguments"] + "}</tool_call>"
    let res_tag = format_tool_result(best_call["name"], result)
    let new_text = partial_text + call_tag2 + res_tag

    let out = #{}
    out["fired"] = true
    out["text"] = new_text
    out["call"] = best_call
    out["result"] = result
    return out
}

println("[toolformer] module loaded")


// -- end inlined --

let mut pass = 0
let mut fail = 0

fn tcheck(name, cond) {
    if cond {
        pass = pass + 1
        println("[PASS] " + name)
    } else {
        fail = fail + 1
        println("[FAIL] " + name)
    }
}

// ── Mock LM score helpers (hoisted so fn lookup is unambiguous) ────
fn tf_test_never_low(ctx, tgt) { return 999.0 }
fn tf_test_always_zero(ctx, tgt) { return 0.0 }

// ── 1. tf_hash is deterministic ────────────────────────────────────
tcheck("tf_hash determinism", tf_hash(42, 7) == tf_hash(42, 7))
tcheck("tf_hash nonneg", tf_hash(123, 456) >= 0)

// ── 2. tf_rand01 bounded ───────────────────────────────────────────
let r = tf_rand01(11, 3)
tcheck("tf_rand01 lower", r >= 0.0)
tcheck("tf_rand01 upper", r < 1.0)

// ── Mock probability: prob high at even positions ──────────────────
fn mock_prob(text, pos) {
    if pos % 3 == 0 { return 0.9 }
    return 0.1
}

// ── 3. sample_positions picks above threshold ──────────────────────
let txt = "Hello world this is a test string"
let positions = tf_sample_positions(txt, mock_prob, 0.5, 100)
tcheck("sample_positions nonempty", len(positions) > 0)
let mut all_mod3 = true
let mut pi = 0
while pi < len(positions) {
    if positions[pi] % 3 != 0 { all_mod3 = false }
    pi = pi + 1
}
tcheck("sample_positions only above thresh", all_mod3)

// ── 4. max_pos caps output ─────────────────────────────────────────
let capped = tf_sample_positions(txt, mock_prob, 0.5, 2)
tcheck("sample_positions max_pos cap", len(capped) == 2)

// ── Mock tool + args generator ─────────────────────────────────────
let calc_tool = define_tool("calc", "Math calculator",
    [define_param("expr", "string", "Expression", true)])
let qa_tool = define_tool("qa", "Question answering",
    [define_param("q", "string", "Question", true)])
let tools = [calc_tool, qa_tool]

fn mock_args(text, pos, tool, sample_i) {
    if tool["name"] == "calc" {
        return "{\"expr\": \"2+" + to_string(sample_i) + "\"}"
    }
    return "{\"q\": \"what at " + to_string(pos) + "\"}"
}

// ── 5. sample_calls generates k candidates ─────────────────────────
let cand = tf_sample_calls(txt, 5, calc_tool, 3, mock_args)
tcheck("sample_calls count", len(cand) == 3)
tcheck("sample_calls name", cand[0]["name"] == "calc")
tcheck("sample_calls position", cand[2]["position"] == 5)
tcheck("sample_calls arguments contains sample_i",
       cand[1]["arguments"].contains("2+1"))

// ── Mock executor: calc returns numeric string, qa returns "answer:N"
fn mock_exec(name, args) {
    if name == "calc" {
        return "7"
    }
    if name == "qa" {
        return "answer:42"
    }
    return ""
}

// ── 6. execute_candidate dispatches ────────────────────────────────
let exec_res = tf_execute_candidate(cand[0], mock_exec)
tcheck("execute_candidate dispatches", exec_res == "7")

// ── Mock LM score: returns higher (worse) for shorter contexts,
//   lower (better) when the context contains "tool_result". This makes
//   tool-augmented prefixes strictly more helpful.
fn mock_lm_score(ctx, target) {
    let base = to_float(50)
    let len_ctx = len(ctx)
    let mut score = base - to_float(len_ctx) * 0.01
    if ctx.contains("<tool_result>") {
        score = score - 5.0
    }
    if ctx.contains("answer:42") {
        score = score - 3.0
    }
    if score < 0.0 { return 0.0 }
    return score
}

// ── 7-9. perplexity_with / without / gain ──────────────────────────
let prefix = "The answer is"
let suffix = " after computing."
let target = "7"
let mock_call_a = #{}
mock_call_a["name"] = "calc"
mock_call_a["arguments"] = "{\"expr\": \"2+5\"}"
let ppl_with = tf_perplexity_with(prefix, mock_call_a, "7", suffix,
                                  target, mock_lm_score)
let ppl_without = tf_perplexity_without(prefix, suffix, target, mock_lm_score)
tcheck("perplexity_with is finite", ppl_with >= 0.0)
tcheck("perplexity_without is finite", ppl_without >= 0.0)
tcheck("perplexity_gain positive (tool helps)",
       tf_perplexity_gain(prefix, mock_call_a, "7", suffix, target, mock_lm_score) > 0.0)

// ── 10-11. filter_candidates ────────────────────────────────────────
let good = #{}
good["name"] = "calc"
good["arguments"] = "{\"expr\":\"1+1\"}"
good["position"] = 0
good["sample"] = 0
good["result"] = "2"
good["ppl_with"] = 10.0
good["ppl_without"] = 15.0

let bad = #{}
bad["name"] = "calc"
bad["arguments"] = "{\"expr\":\"x\"}"
bad["position"] = 3
bad["sample"] = 0
bad["result"] = "err"
bad["ppl_with"] = 20.0
bad["ppl_without"] = 20.5

let filtered = tf_filter_candidates([good, bad], 1.0)
tcheck("filter keeps high gain", len(filtered) == 1)
tcheck("filter keeps the right one", filtered[0]["name"] == "calc")
tcheck("filter records gain", filtered[0]["gain"] >= 4.9)

let filtered_strict = tf_filter_candidates([good, bad], 100.0)
tcheck("filter rejects below tau", len(filtered_strict) == 0)

// ── 12. top_per_position ────────────────────────────────────────────
let c1 = #{}
c1["name"] = "a"
c1["position"] = 5
c1["gain"] = 2.0
c1["arguments"] = "{}"
c1["sample"] = 0
c1["result"] = "r1"
let c2 = #{}
c2["name"] = "b"
c2["position"] = 5
c2["gain"] = 5.0
c2["arguments"] = "{}"
c2["sample"] = 1
c2["result"] = "r2"
let c3 = #{}
c3["name"] = "c"
c3["position"] = 8
c3["gain"] = 1.0
c3["arguments"] = "{}"
c3["sample"] = 0
c3["result"] = "r3"
let top = tf_top_per_position([c1, c2, c3])
tcheck("top_per_position dedupes positions", len(top) == 2)
// best at position 5 should be c2 (gain 5.0)
let mut found5 = false
let mut best5_name = ""
let mut ti = 0
while ti < len(top) {
    if top[ti]["position"] == 5 {
        found5 = true
        best5_name = top[ti]["name"]
    }
    ti = ti + 1
}
tcheck("top_per_position keeps max-gain", found5 && best5_name == "b")

// ── 13. build_training_example ──────────────────────────────────────
let ex_call = #{}
ex_call["name"] = "calc"
ex_call["arguments"] = "{\"expr\": \"2+5\"}"
let ex = tf_build_training_example("The answer is after computing.",
                                   ex_call, "7", 14)
tcheck("training_example has call tag", ex.contains("<tool_call>"))
tcheck("training_example has result tag", ex.contains("<tool_result>"))
tcheck("training_example has prefix", ex.contains("The answer is"))
tcheck("training_example has suffix", ex.contains("after computing."))

// ── 14. end-to-end dataset builder ──────────────────────────────────
let corpus = ["The cost is 3 dollars per kg today.",
              "Tokyo population grows steadily each year."]
let ds = tf_build_incontext_dataset(corpus, tools, 2, 1.0,
                                    mock_prob, mock_args, mock_exec,
                                    mock_lm_score, 0.5, 3)
tcheck("dataset has stats", has_key(ds, "stats"))
tcheck("dataset has dataset arr", has_key(ds, "dataset"))
tcheck("dataset n_candidates > 0", ds["stats"]["n_candidates"] > 0)
tcheck("dataset n_kept > 0", ds["stats"]["n_kept"] > 0)
tcheck("dataset examples > 0", len(ds["dataset"]) > 0)

// All kept examples should contain the tool_call tag
let mut all_have_tag = true
let mut di = 0
while di < len(ds["dataset"]) {
    if ds["dataset"][di].contains("<tool_call>") == false {
        all_have_tag = false
    }
    di = di + 1
}
tcheck("every kept example has <tool_call>", all_have_tag)

// ── 15. has_trigger_token ───────────────────────────────────────────
tcheck("has_trigger_token hit", tf_has_trigger_token("foo [TOOL] bar", ["[TOOL]"]))
tcheck("has_trigger_token miss", tf_has_trigger_token("plain text", ["[TOOL]"]) == false)

// ── 16. inference_should_trigger via token ──────────────────────────
let trg = ["[TOOL]"]
tcheck("should_trigger explicit token",
       tf_inference_should_trigger("hi [TOOL] now", trg, tf_test_never_low, 0.1))

// ── 17. inference_should_trigger via score threshold ────────────────
let dbg_az_direct = tf_test_always_zero("plain", "<tool_call>")
println("  DBG always_zero direct: " + to_string(dbg_az_direct))
let dbg_has = tf_has_trigger_token("plain", trg)
println("  DBG has_trigger: " + to_string(dbg_has))
let dbg_ret = tf_inference_should_trigger("plain", trg, tf_test_always_zero, 0.5)
println("  DBG ret: " + to_string(dbg_ret))
tcheck("should_trigger score threshold", dbg_ret)
tcheck("should_not_trigger when score high",
       tf_inference_should_trigger("plain", trg, tf_test_never_low, 0.5) == false)

// ── 18. inference_step no-fire branch ───────────────────────────────
let no_fire = tf_inference_step("plain", tools, mock_args, mock_exec,
                                tf_test_never_low, trg, 0.1)
tcheck("no_fire returns fired=false", no_fire["fired"] == false)
tcheck("no_fire keeps text", no_fire["text"] == "plain")

// ── 19. inference_step fire branch splices tags ─────────────────────
let fire = tf_inference_step("Tell me 2+5: [TOOL]", tools, mock_args,
                             mock_exec, mock_lm_score, trg, 1000.0)
tcheck("fire returns fired=true", fire["fired"] == true)
tcheck("fire text has <tool_call>", fire["text"].contains("<tool_call>"))
tcheck("fire text has <tool_result>", fire["text"].contains("<tool_result>"))
tcheck("fire picks one of our tools",
       fire["call"]["name"] == "calc" || fire["call"]["name"] == "qa")

// ── 20. parse_tool_calls should roundtrip the spliced example ───────
let rt_calls = parse_tool_calls(fire["text"])
tcheck("roundtrip parse finds call", len(rt_calls) == 1)
tcheck("roundtrip name matches",
       rt_calls[0]["name"] == fire["call"]["name"])

// ── summary ────────────────────────────────────────────────────────
println("")
println("pass=" + to_string(pass) + " fail=" + to_string(fail))
if fail == 0 {
    println("ALL PASS")
} else {
    println("FAILED")
}
println(to_string(pass) + " passed")
