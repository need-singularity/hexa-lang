// self/compile_factorial.hexa — P7-7 factorial native Mach-O emitter.
//
// End-to-end ARM64 Mach-O emission for a real arithmetic + control-flow
// program, exercising MOVZ/MOVK/MUL/SUB-imm/CMP-imm/B.gt/SVC encoders.
// Emitted .text (conceptual):
//     MOVZ x0, #1                 ; acc = 1
//     MOVZ x1, #N                 ; counter = N
//   loop:
//     MUL  x0, x0, x1             ; acc *= counter
//     SUB  x1, x1, #1             ; counter -= 1
//     CMP  x1, #0                 ; flags from counter
//     B.gt loop                   ; back-edge if counter > 0
//     MOVZ x16, #0x0001
//     MOVK x16, #0x0200, LSL #16  ; x16 = 0x2000001 (SYS_exit)
//     SVC  #0x80                  ; exit(acc)
//
// Produces three binaries:
//   /tmp/hexa_fact3_native   fact(3) = 6      exit 6
//   /tmp/hexa_fact5_native   fact(5) = 120    exit 120
//   /tmp/hexa_fact7_native   fact(7) = 5040   exit 5040 & 0xFF = 176
// macOS exit codes are uint8_t so fact(7) wraps: 5040 mod 256 = 176 (0xB0).
//
// Zero clang / as / ld / llvm. Pure Hexa → bytes → xxd → codesign → run.

// ═══════════════════════════════════════════════════════════
//  Inline ARM64 encoders (self-contained; mirrors compile_hello.hexa
//  style so this file runs standalone under hexa_stage0).
// ═══════════════════════════════════════════════════════════

fn emit32_le(code: [int], instr: int) -> [int] {
    let b0 = instr % 256
    let b1 = (instr / 256) % 256
    let b2 = (instr / 65536) % 256
    let b3 = (instr / 16777216) % 256
    return code.push(b0).push(b1).push(b2).push(b3)
}

// MOVZ Xd, #imm16, LSL #0
fn enc_movz(rd: int, imm16: int) -> int {
    return 0xd2800000 + (imm16 * 32) + rd
}

// MOVK Xd, #imm16, LSL #hw*16
fn enc_movk(rd: int, imm16: int, hw: int) -> int {
    return 0xf2800000 + (hw * 2097152) + (imm16 * 32) + rd
}

// SVC #imm16
fn enc_svc(imm16: int) -> int {
    return 0xd4000001 + (imm16 * 32)
}

// MUL Xd, Xn, Xm   (64-bit, Ra = XZR (31))
//   0x9B007C00 | (Rm << 16) | (Ra=31 << 10) | (Rn << 5) | Rd
fn enc_mul(rd: int, rn: int, rm: int) -> int {
    return 0x9b007c00 + (rm * 65536) + (rn * 32) + rd
}

// SUB (immediate) Xd, Xn, #imm12  (shift=0)
//   0xD1000000 | (imm12 << 10) | (Rn << 5) | Rd
fn enc_sub_imm(rd: int, rn: int, imm12: int) -> int {
    return 0xd1000000 + (imm12 * 1024) + (rn * 32) + rd
}

// CMP (immediate) Xn, #imm12  == SUBS XZR, Xn, #imm12
//   0xF1000000 | (imm12 << 10) | (Rn << 5) | 31
fn enc_cmp_imm(rn: int, imm12: int) -> int {
    return 0xf1000000 + (imm12 * 1024) + (rn * 32) + 31
}

// B.cond <label>
//   0x54000000 | ((imm19 & 0x7FFFF) << 5) | cond4
//   imm19 is signed instruction-count offset.  cond=0xC for GT.
fn enc_bcond(cond: int, disp_bytes: int) -> int {
    // disp_bytes is target_byte - current_byte (can be negative).
    let mut imm19 = disp_bytes / 4
    if imm19 < 0 { imm19 = imm19 + 524288 }  // sign-extend fit into 19 bits
    return 0x54000000 + ((imm19 % 524288) * 32) + (cond % 16)
}

fn cond_gt() -> int { return 12 }  // B.GT = 0b1100

// ═══════════════════════════════════════════════════════════
//  Build the .text for fact(N):
//    0:  MOVZ x0, #1
//    4:  MOVZ x1, #N
//    8:  MUL  x0, x0, x1    <- loop label
//   12:  SUB  x1, x1, #1
//   16:  CMP  x1, #0
//   20:  B.gt loop   (disp = 8 - 20 = -12 bytes)
//   24:  MOVZ x16, #0x0001
//   28:  MOVK x16, #0x0200, LSL #16
//   32:  SVC  #0x80
//  (36 bytes total; pad to 4-byte alignment already OK)
// ═══════════════════════════════════════════════════════════

fn build_text_section(n: int) -> [int] {
    let loop_off = 8
    let branch_off = 20
    let disp = loop_off - branch_off  // -12

    let mut insts = []
    insts = insts.push(enc_movz(0, 1))              // 0: acc = 1
    insts = insts.push(enc_movz(1, n))              // 4: counter = N
    insts = insts.push(enc_mul(0, 0, 1))            // 8: acc *= counter
    insts = insts.push(enc_sub_imm(1, 1, 1))        // 12: counter -= 1
    insts = insts.push(enc_cmp_imm(1, 0))           // 16: cmp counter, 0
    insts = insts.push(enc_bcond(cond_gt(), disp))  // 20: b.gt loop
    insts = insts.push(enc_movz(16, 1))             // 24: movz x16, #1
    insts = insts.push(enc_movk(16, 0x200, 1))      // 28: movk x16, #0x200, LSL #16
    insts = insts.push(enc_svc(0x80))               // 32: svc #0x80

    let mut bytes = []
    let mut i = 0
    while i < len(insts) {
        bytes = emit32_le(bytes, insts[i])
        i = i + 1
    }

    while len(bytes) % 4 != 0 {
        bytes = bytes.push(0)
    }
    return bytes
}

// ═══════════════════════════════════════════════════════════
//  Mach-O MH_EXECUTE wrapper — same structure as compile_hello.hexa
//  (kept self-contained rather than imported; compile_hello.hexa is the
//  baseline and we must not touch it).
// ═══════════════════════════════════════════════════════════

fn u32_to_hex(v: int, h: string) -> string {
    let mut parts = []
    parts.push(h[(v % 256) / 16])
    parts.push(h[(v % 256) % 16])
    parts.push(h[((v / 256) % 256) / 16])
    parts.push(h[((v / 256) % 256) % 16])
    parts.push(h[((v / 65536) % 256) / 16])
    parts.push(h[((v / 65536) % 256) % 16])
    parts.push(h[((v / 16777216) % 256) / 16])
    parts.push(h[((v / 16777216) % 256) % 16])
    return parts.join("")
}

fn u64_to_hex(v: int, h: string) -> string {
    let lo = v % 4294967296
    let hi = v / 4294967296
    return u32_to_hex(lo, h) + u32_to_hex(hi, h)
}

fn byte_to_hex(b: int, h: string) -> string {
    let mut parts = []
    parts.push(h[b / 16])
    parts.push(h[b % 16])
    return parts.join("")
}

fn build_macho_hex(text_bytes: [int]) -> string {
    let HEX = "0123456789abcdef"
    let MH_MAGIC_64 = 4277009103
    let CPU_ARM64   = 16777228
    let MH_EXECUTE  = 2
    let HDR_FLAGS   = 2097285
    let NCMDS       = 11
    let SIZEOFCMDS  = 576
    let PAGE        = 16384
    let CODE_OFF    = 768

    let code_bytes = len(text_bytes)
    let mut text_size_aligned = code_bytes
    if text_size_aligned % 4 != 0 {
        text_size_aligned = text_size_aligned + (4 - text_size_aligned % 4)
    }

    let mut parts = []
    let hdr_u32 = [MH_MAGIC_64, CPU_ARM64, 0, MH_EXECUTE, NCMDS, SIZEOFCMDS, HDR_FLAGS, 0]
    let mut hi = 0
    while hi < len(hdr_u32) {
        parts.push(u32_to_hex(hdr_u32[hi], HEX))
        hi = hi + 1
    }

    // LC_SEGMENT_64 __PAGEZERO
    parts.push("19000000" + "48000000")
    parts.push("5f5f504147455a45524f0000000000" + "00")
    parts.push("0000000000000000")
    parts.push("0000000001000000")
    parts.push("0000000000000000")
    parts.push("0000000000000000")
    parts.push("00000000" + "00000000" + "00000000" + "00000000")

    // LC_SEGMENT_64 __TEXT
    parts.push("19000000" + "98000000")
    parts.push("5f5f54455854000000000000000000" + "00")
    parts.push("0000000001000000")
    parts.push("0040000000000000")
    parts.push("0000000000000000")
    parts.push("0040000000000000")
    parts.push("05000000")
    parts.push("05000000")
    parts.push("01000000")
    parts.push("00000000")

    // section __text
    parts.push("5f5f74657874000000000000000000" + "00")
    parts.push("5f5f54455854000000000000000000" + "00")
    parts.push(u64_to_hex(4294967296 + CODE_OFF, HEX))
    parts.push(u64_to_hex(text_size_aligned, HEX))
    parts.push(u32_to_hex(CODE_OFF, HEX))
    parts.push("02000000")
    parts.push("00000000" + "00000000")
    parts.push("00040080")
    parts.push("00000000" + "00000000" + "00000000")

    // LC_SEGMENT_64 __LINKEDIT
    parts.push("19000000" + "48000000")
    parts.push("5f5f4c494e4b45444954000000000000")
    parts.push("0040000001000000")
    parts.push("0040000000000000")
    parts.push("0040000000000000")
    parts.push("3100000000000000")
    parts.push("01000000" + "01000000")
    parts.push("00000000" + "00000000")

    // LC_DYLD_CHAINED_FIXUPS
    parts.push("34000080" + "10000000" + "00400000" + "30000000")

    // LC_SYMTAB
    parts.push("02000000" + "18000000")
    parts.push("30400000")
    parts.push("00000000")
    parts.push("30400000")
    parts.push("01000000")

    // LC_DYSYMTAB
    parts.push("0b000000" + "50000000")
    let mut dyz_parts = []
    let mut dyz = 0
    while dyz < 72 {
        dyz_parts.push("00")
        dyz = dyz + 1
    }
    parts.push(dyz_parts.join(""))

    // LC_LOAD_DYLINKER
    parts.push("0e000000" + "20000000" + "0c000000")
    parts.push("2f7573722f6c69622f64796c6400")
    parts.push("000000000000")

    // LC_UUID
    parts.push("1b000000" + "18000000")
    parts.push("48455841414243444546303132333435")

    // LC_BUILD_VERSION
    parts.push("32000000" + "18000000")
    parts.push("01000000")
    parts.push("00000e00")
    parts.push("00000e00")
    parts.push("00000000")

    // LC_MAIN
    parts.push("28000080" + "18000000")
    parts.push(u64_to_hex(CODE_OFF, HEX))
    parts.push("0000000000000000")

    // LC_LOAD_DYLIB libSystem
    parts.push("0c000000" + "38000000")
    parts.push("18000000")
    parts.push("02000000")
    parts.push("00000100")
    parts.push("00000100")
    parts.push("2f7573722f6c69622f6c69625379737465")
    parts.push("6d2e422e64796c696200000000000000")

    let mut s = parts.join("")

    while (len(s) / 2) < CODE_OFF {
        s = s + "00"
    }

    let mut bi = 0
    while bi < len(text_bytes) {
        s = s + byte_to_hex(text_bytes[bi], HEX)
        bi = bi + 1
    }

    while (len(s) / 2) < PAGE {
        s = s + "00"
    }

    s = s + "00000000"
    s = s + "20000000"
    s = s + "00000000"
    s = s + "00000000"
    s = s + "00000000"
    s = s + "01000000"
    s = s + "00000000"
    s = s + "00000000"
    s = s + "03000000"
    s = s + "00000000" + "00000000" + "00000000"
    s = s + "00"

    return s
}

// ═══════════════════════════════════════════════════════════
//  Per-variant driver.
// ═══════════════════════════════════════════════════════════

fn fact_ref(n: int) -> int {
    let mut r = 1
    let mut i = n
    while i > 0 {
        r = r * i
        i = i - 1
    }
    return r
}

fn build_and_run(n: int, out_path: string) -> [int] {
    // returns [macho_size, exit_code]
    let text = build_text_section(n)
    let hex_data = build_macho_hex(text)
    let macho_size = len(hex_data) / 2

    exec("printf '%s' '" + hex_data + "' | xxd -r -p > " + out_path)
    exec("chmod +x " + out_path)
    let cs = exec_with_status("codesign --force --sign - " + out_path + " 2>&1")
    if cs[1] != 0 {
        println("  WARN codesign rc=" + to_string(cs[1]) + ": " + cs[0].trim())
    }
    let r = exec_with_status(out_path + " 2>&1")
    return [macho_size, r[1]]
}

// ═══════════════════════════════════════════════════════════
//  Driver
// ═══════════════════════════════════════════════════════════

println("=== P7-7 compile_factorial: native fact(N) Mach-O ===")
println("")
println("source (conceptual):")
println("  fn fact(n: int) -> int {")
println("    let mut r = 1; let mut i = n")
println("    while i > 0 { r = r * i; i = i - 1 }")
println("    return r  // exit status")
println("  }")
println("")

let variants = [3, 5, 7]
let paths = ["/tmp/hexa_fact3_native", "/tmp/hexa_fact5_native", "/tmp/hexa_fact7_native"]
let expected_rcs = [6, 120, 176]   // fact(7)=5040 -> 5040 % 256 = 176

let mut all_pass = true
let mut vi = 0
while vi < len(variants) {
    let n = variants[vi]
    let path = paths[vi]
    let want_rc = expected_rcs[vi]
    let want_full = fact_ref(n)

    println("--- fact(" + to_string(n) + ") = " + to_string(want_full) + " (exit byte = " + to_string(want_full % 256) + ") ---")
    let res = build_and_run(n, path)
    let macho_size = res[0]
    let rc = res[1]
    println("  macho bytes : " + to_string(macho_size))
    println("  exit code   : " + to_string(rc))
    if rc == want_rc {
        println("  [PASS] exit == " + to_string(want_rc))
    } else {
        println("  [FAIL] exit " + to_string(rc) + " != " + to_string(want_rc))
        all_pass = false
    }
    println("")
    vi = vi + 1
}

println("=== summary ===")
if all_pass {
    println("PASS — fact(3)/fact(5)/fact(7) all emitted and executed natively.")
    println("       exit codes: 6 / 120 / 176  (7! wraps: 5040 mod 256 = 176)")
    println("       B.gt backwards branch patched inline (disp = -12 bytes, imm19 = -3).")
} else {
    println("FAIL — see above.")
}
