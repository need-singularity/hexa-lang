// ═══════════════════════════════════════════════════════════════════
//  test_string_ext_pure.hexa — Tests for 5 NEW pure-Hexa string
//  search/transform functions added to self/runtime/string_pure.hexa:
//
//    1. str_starts_with_any_pure  — any-of-many prefix test
//    2. str_ends_with_any_pure    — any-of-many suffix test
//    3. str_strip_prefix_pure     — remove prefix if present
//    4. str_strip_suffix_pure     — remove suffix if present
//    5. str_replace_first_pure    — replace only first occurrence
//
//  Follows the test_string_pure.hexa / test_map_ext_pure.hexa
//  convention: inline the function bodies (codegen import is not
//  wired for test files on stage0) + a simple check(name, actual,
//  expected) harness + pass/fail summary with exit(1) on failure.
// ═══════════════════════════════════════════════════════════════════

// ─── inlined from self/runtime/string_pure.hexa ───

pub fn str_starts_with_pure(s, prefix) {
    if type_of(s) != "string" { return false }
    if type_of(prefix) != "string" { return false }
    let sn = len(s)
    let pn = len(prefix)
    if pn > sn { return false }
    s.substring(0, pn) == prefix
}

pub fn str_ends_with_pure(s, suffix) {
    if type_of(s) != "string" { return false }
    if type_of(suffix) != "string" { return false }
    let sn = len(s)
    let sfn = len(suffix)
    if sfn > sn { return false }
    s.substring(sn - sfn, sn) == suffix
}

pub fn str_index_of_pure(s, sub) {
    if type_of(s) != "string" { return -1 }
    if type_of(sub) != "string" { return -1 }
    let sn = len(s)
    let mn = len(sub)
    if mn == 0 { return 0 }
    if mn > sn { return -1 }
    let limit = sn - mn + 1
    let mut i = 0
    while i < limit {
        if s.substring(i, i + mn) == sub {
            return i
        }
        i = i + 1
    }
    -1
}

pub fn str_starts_with_any_pure(s, prefixes) {
    if type_of(s) != "string" { return false }
    if type_of(prefixes) != "array" { return false }
    let n = len(prefixes)
    let mut i = 0
    while i < n {
        let p = prefixes[i]
        if type_of(p) == "string" {
            if str_starts_with_pure(s, p) { return true }
        }
        i = i + 1
    }
    false
}

pub fn str_ends_with_any_pure(s, suffixes) {
    if type_of(s) != "string" { return false }
    if type_of(suffixes) != "array" { return false }
    let n = len(suffixes)
    let mut i = 0
    while i < n {
        let sfx = suffixes[i]
        if type_of(sfx) == "string" {
            if str_ends_with_pure(s, sfx) { return true }
        }
        i = i + 1
    }
    false
}

pub fn str_strip_prefix_pure(s, prefix) {
    if type_of(s) != "string" { return s }
    if type_of(prefix) != "string" { return s }
    let pn = len(prefix)
    if pn == 0 { return s }
    if str_starts_with_pure(s, prefix) {
        return s.substring(pn, len(s))
    }
    s
}

pub fn str_strip_suffix_pure(s, suffix) {
    if type_of(s) != "string" { return s }
    if type_of(suffix) != "string" { return s }
    let sn = len(s)
    let sfn = len(suffix)
    if sfn == 0 { return s }
    if str_ends_with_pure(s, suffix) {
        return s.substring(0, sn - sfn)
    }
    s
}

pub fn str_replace_first_pure(s, old_s, new_s) {
    if type_of(s) != "string" { return s }
    if type_of(old_s) != "string" { return s }
    if type_of(new_s) != "string" { return s }
    let old_len = len(old_s)
    if old_len == 0 { return s }
    let idx = str_index_of_pure(s, old_s)
    if idx < 0 { return s }
    let sn = len(s)
    s.substring(0, idx) + new_s + s.substring(idx + old_len, sn)
}

// ─── end inlined ───

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  Pure-Hexa String Extension Tests (5 new functions)")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. str_starts_with_any_pure ─────────────────────────────────
println("--- str_starts_with_any_pure ---")

check("any prefix first",      str_starts_with_any_pure("hello world", ["hello", "world"]), true)
check("any prefix second",     str_starts_with_any_pure("foobar",      ["xxx", "foo"]),     true)
check("any prefix none",       str_starts_with_any_pure("foobar",      ["xxx", "yyy"]),     false)
check("any prefix empty list", str_starts_with_any_pure("foobar",      []),                 false)
check("any prefix single",     str_starts_with_any_pure("abc",         ["abc"]),            true)
check("any prefix empty s",    str_starts_with_any_pure("",            ["x"]),              false)
check("any prefix empty needle in list", str_starts_with_any_pure("x", ["", "y"]),          true)
check("any prefix non-string s",       str_starts_with_any_pure(42,   ["x"]),               false)
check("any prefix non-array prefixes", str_starts_with_any_pure("x",  "x"),                 false)
check("any prefix too long",   str_starts_with_any_pure("ab",          ["abc", "abcd"]),    false)
check("any prefix mixed types skip", str_starts_with_any_pure("hello", [42, "hel"]),        true)
check("any prefix full match", str_starts_with_any_pure("http://",     ["https://", "http://"]), true)

// ── 2. str_ends_with_any_pure ───────────────────────────────────
println("")
println("--- str_ends_with_any_pure ---")

check("any suffix first",      str_ends_with_any_pure("hello.txt",  [".txt", ".md"]), true)
check("any suffix second",     str_ends_with_any_pure("README.md",  [".txt", ".md"]), true)
check("any suffix none",       str_ends_with_any_pure("image.png",  [".txt", ".md"]), false)
check("any suffix empty list", str_ends_with_any_pure("file",       []),              false)
check("any suffix single",     str_ends_with_any_pure("done.log",   [".log"]),        true)
check("any suffix empty s",    str_ends_with_any_pure("",           [".x"]),          false)
check("any suffix empty needle in list", str_ends_with_any_pure("x", ["", "y"]),      true)
check("any suffix non-string s",       str_ends_with_any_pure(42,  [".x"]),           false)
check("any suffix non-array suffixes", str_ends_with_any_pure("x", ".x"),             false)
check("any suffix too long",   str_ends_with_any_pure("ab",        ["xab", "yab"]),   false)
check("any suffix multi match first wins", str_ends_with_any_pure("abc.tar.gz", [".gz", ".tar.gz"]), true)

// ── 3. str_strip_prefix_pure ────────────────────────────────────
println("")
println("--- str_strip_prefix_pure ---")

check("strip prefix present",    str_strip_prefix_pure("hello world", "hello "), "world")
check("strip prefix absent",     str_strip_prefix_pure("hello world", "xxx"),    "hello world")
check("strip prefix empty",      str_strip_prefix_pure("hello",       ""),       "hello")
check("strip prefix full match", str_strip_prefix_pure("abc",         "abc"),    "")
check("strip prefix too long",   str_strip_prefix_pure("ab",          "abc"),    "ab")
check("strip prefix empty s",    str_strip_prefix_pure("",            "x"),      "")
check("strip prefix non-string s",      str_strip_prefix_pure(42,      "x"),     42)
check("strip prefix non-string prefix", str_strip_prefix_pure("hello", 42),      "hello")
check("strip prefix repeated once",     str_strip_prefix_pure("abab",  "ab"),    "ab")
check("strip prefix url scheme",  str_strip_prefix_pure("http://x.io", "http://"), "x.io")

// ── 4. str_strip_suffix_pure ────────────────────────────────────
println("")
println("--- str_strip_suffix_pure ---")

check("strip suffix present",    str_strip_suffix_pure("hello world", " world"), "hello")
check("strip suffix absent",     str_strip_suffix_pure("hello world", "xxx"),    "hello world")
check("strip suffix empty",      str_strip_suffix_pure("hello",       ""),       "hello")
check("strip suffix full match", str_strip_suffix_pure("abc",         "abc"),    "")
check("strip suffix too long",   str_strip_suffix_pure("ab",          "xab"),    "ab")
check("strip suffix empty s",    str_strip_suffix_pure("",            "x"),      "")
check("strip suffix non-string s",      str_strip_suffix_pure(42,      "x"),     42)
check("strip suffix non-string suffix", str_strip_suffix_pure("hello", 42),      "hello")
check("strip suffix repeated once",     str_strip_suffix_pure("abab",  "ab"),    "ab")
check("strip suffix file ext",    str_strip_suffix_pure("main.hexa",   ".hexa"), "main")

// ── 5. str_replace_first_pure ───────────────────────────────────
println("")
println("--- str_replace_first_pure ---")

check("replace_first basic",     str_replace_first_pure("hello world", "world", "hexa"),  "hello hexa")
check("replace_first only first",str_replace_first_pure("aaa",         "a",     "bb"),    "bbaa")
check("replace_first not found", str_replace_first_pure("hello",       "xyz",   "abc"),   "hello")
check("replace_first empty old", str_replace_first_pure("hello",       "",      "x"),     "hello")
check("replace_first with empty",str_replace_first_pure("hello world", "world", ""),      "hello ")
check("replace_first middle",    str_replace_first_pure("axbxc",       "x",     "-"),     "a-bxc")
check("replace_first at start",  str_replace_first_pure("hello",       "he",    "HE"),    "HEllo")
check("replace_first at end",    str_replace_first_pure("hello",       "llo",   "LLO"),   "heLLO")
check("replace_first non-overlap", str_replace_first_pure("abcabc",    "abc",   "Z"),     "Zabc")
check("replace_first same result", str_replace_first_pure("aaa",       "a",     "a"),     "aaa")
check("replace_first longer new",  str_replace_first_pure("ab",        "a",     "xyz"),   "xyzb")
check("replace_first non-string s",str_replace_first_pure(42,          "x",     "y"),     42)

// ── Summary ─────────────────────────────────────────────────────

println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    println("FAIL")
    exit(1)
}
println("ALL PASS")
