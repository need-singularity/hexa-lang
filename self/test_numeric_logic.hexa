// ═══════════════════════════════════════════════════════════
//  test_numeric_logic.hexa — Numeric Operations & Logic Tests
//  Tests: integer arithmetic edge cases, float precision,
//         bitwise-like patterns, complex boolean logic,
//         numeric conversions, overflow behavior,
//         mathematical algorithms, accumulation patterns
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA Numeric & Logic Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Integer arithmetic patterns ───────────────────────

println("--- Integer Arithmetic ---")

check("large mul", 1000 * 1000, 1000000)
check("large add", 999999 + 1, 1000000)
check("neg mul neg", -5 * -5, 25)
check("neg mul pos", -5 * 3, -15)
check("div truncate", 7 / 2, 3)
check("div exact", 8 / 2, 4)
check("mod positive", 10 % 3, 1)
check("mod zero result", 9 % 3, 0)
check("chain ops", 2 + 3 * 4 - 1, 13)
check("parens chain", (2 + 3) * (4 - 1), 15)

// ── 2. Float operations ──────────────────────────────────

println("")
println("--- Float Operations ---")

check("float add", 0.1 + 0.2 + 0.7, 1.0)
check("float sub", 5.5 - 2.3, 3.2)
check("float mul", 2.5 * 4.0, 10.0)
check("float div", 10.0 / 4.0, 2.5)
check("float neg", -3.5 + 1.0, -2.5)
check("int to float", to_float(5), 5.0)
check("float to int", to_int(3.7), 3)
check("float to int neg", to_int(-2.9), -2)

// ── 3. Power / exponentiation via loop ───────────────────

println("")
println("--- Power Function ---")

fn power(base, exp) {
    let mut result = 1
    let mut i = 0
    while i < exp {
        result = result * base
        i = i + 1
    }
    return result
}
check("2^0", power(2, 0), 1)
check("2^1", power(2, 1), 2)
check("2^10", power(2, 10), 1024)
check("3^4", power(3, 4), 81)
check("5^3", power(5, 3), 125)
check("1^100", power(1, 100), 1)

// ── 4. GCD / LCM ────────────────────────────────────────

println("")
println("--- GCD / LCM ---")

fn gcd(a, b) {
    let mut x = a
    let mut y = b
    while y != 0 {
        let temp = y
        y = x % y
        x = temp
    }
    return x
}
check("gcd(12,8)", gcd(12, 8), 4)
check("gcd(15,5)", gcd(15, 5), 5)
check("gcd(7,13)", gcd(7, 13), 1)
check("gcd(100,75)", gcd(100, 75), 25)

fn lcm(a, b) {
    return a * b / gcd(a, b)
}
check("lcm(4,6)", lcm(4, 6), 12)
check("lcm(3,7)", lcm(3, 7), 21)

// ── 5. Boolean logic combinations ────────────────────────

println("")
println("--- Boolean Logic ---")

check("de morgan 1", !(true && false), !true || !false)
check("de morgan 2", !(true || false), !true && !false)
check("triple and", true && true && true, true)
check("triple and false", true && true && false, false)
check("triple or", false || false || true, true)
check("triple or false", false || false || false, false)
check("mixed logic 1", (true || false) && (false || true), true)
check("mixed logic 2", (true && false) || (false && true), false)

// ── 6. Comparison chains ─────────────────────────────────

println("")
println("--- Comparisons ---")

fn in_range(x, lo, hi) {
    return x >= lo && x <= hi
}
check("in range mid", in_range(5, 1, 10), true)
check("in range lo", in_range(1, 1, 10), true)
check("in range hi", in_range(10, 1, 10), true)
check("below range", in_range(0, 1, 10), false)
check("above range", in_range(11, 1, 10), false)

fn max2(a, b) {
    if a > b { return a }
    return b
}
fn min2(a, b) {
    if a < b { return a }
    return b
}
check("max(3,7)", max2(3, 7), 7)
check("max(7,3)", max2(7, 3), 7)
check("min(3,7)", min2(3, 7), 3)
check("max(-1,-5)", max2(-1, -5), -1)

// ── 7. Fibonacci ─────────────────────────────────────────

println("")
println("--- Fibonacci ---")

fn fib(n) {
    if n <= 1 { return n }
    let mut a = 0
    let mut b = 1
    let mut i = 2
    while i <= n {
        let temp = a + b
        a = b
        b = temp
        i = i + 1
    }
    return b
}
check("fib(0)", fib(0), 0)
check("fib(1)", fib(1), 1)
check("fib(5)", fib(5), 5)
check("fib(10)", fib(10), 55)
check("fib(15)", fib(15), 610)

// ── 8. Factorial ─────────────────────────────────────────

println("")
println("--- Factorial ---")

fn factorial(n) {
    if n <= 1 { return 1 }
    let mut result = 1
    let mut i = 2
    while i <= n {
        result = result * i
        i = i + 1
    }
    return result
}
check("0!", factorial(0), 1)
check("1!", factorial(1), 1)
check("5!", factorial(5), 120)
check("7!", factorial(7), 5040)
check("10!", factorial(10), 3628800)

// ── 9. Digit operations ─────────────────────────────────

println("")
println("--- Digit Ops ---")

fn count_digits(n) {
    let mut x = abs(n)
    if x == 0 { return 1 }
    let mut count = 0
    while x > 0 {
        count = count + 1
        x = x / 10
    }
    return count
}
check("digits(0)", count_digits(0), 1)
check("digits(5)", count_digits(5), 1)
check("digits(42)", count_digits(42), 2)
check("digits(1000)", count_digits(1000), 4)
check("digits(-99)", count_digits(-99), 2)

fn sum_digits(n) {
    let mut x = abs(n)
    let mut s = 0
    while x > 0 {
        s = s + x % 10
        x = x / 10
    }
    return s
}
check("sum_digits(123)", sum_digits(123), 6)
check("sum_digits(999)", sum_digits(999), 27)
check("sum_digits(100)", sum_digits(100), 1)

// ── 10. Primality test ───────────────────────────────────

println("")
println("--- Primality ---")

fn is_prime(n) {
    if n < 2 { return false }
    if n == 2 { return true }
    if n % 2 == 0 { return false }
    let mut i = 3
    while i * i <= n {
        if n % i == 0 { return false }
        i = i + 2
    }
    return true
}
check("prime 2", is_prime(2), true)
check("prime 3", is_prime(3), true)
check("prime 4", is_prime(4), false)
check("prime 17", is_prime(17), true)
check("prime 25", is_prime(25), false)
check("prime 97", is_prime(97), true)
check("prime 1", is_prime(1), false)

// ── Summary ──────────────────────────────────────────────

println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    throw "TESTS FAILED: " + to_string(fail_count)
}
