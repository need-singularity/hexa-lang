// Runs test_p2_6_enum_variant.hexa through self-hosted pipeline
let _hexa_root = if len(env_var("HEXA_LANG")) > 0 { env_var("HEXA_LANG") } else { "." }
let SELF_DIR = _hexa_root + "/self"
let TMP_DIR = "/tmp/hexa_p26"
exec("mkdir -p " + TMP_DIR)

let lexer_src = read_file(SELF_DIR + "/lexer.hexa")
let parser_src = read_file(SELF_DIR + "/parser.hexa")
let interp_src = read_file(SELF_DIR + "/interpreter.hexa")
let pipeline_src = lexer_src + "\n" + parser_src + "\n" + interp_src + "\n"

let test_src = read_file(SELF_DIR + "/test_p2_6_enum_variant.hexa")
let src_file = TMP_DIR + "/src.hexa"
write_file(src_file, test_src)

let MARKER = "___P26_MARK___"
let driver_code = pipeline_src + "\n" + "println(\"" + MARKER + "\")\n" + "let __test_src = read_file(\"" + src_file + "\")\n" + "let __tokens = tokenize(__test_src)\n" + "let __ast = parse(__tokens)\n" + "interpret(__ast)\n" + "println(\"" + MARKER + "\")\n"

let driver_file = TMP_DIR + "/driver.hexa"
write_file(driver_file, driver_code)

let HEXA = _hexa_root + "/hexa"
let out = exec(HEXA + " " + driver_file + " 2>&1")

// Extract between markers
let parts = out.split(MARKER)
if len(parts) >= 2 {
    println("=== OUTPUT ===")
    println(parts[1])
    println("=== END ===")
    println("1 passed")
} else {
    println("=== RAW ===")
    println(out)
    println("0 passed")
}
