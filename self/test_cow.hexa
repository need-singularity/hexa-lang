// =====================================================================
//  test_cow.hexa -- M974 @cow (copy-on-write) semantics validation
//  Verifies that COW defers copy until mutation and that shared
//  references remain intact until a write occurs.
// =====================================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_arr(name, actual, expected) {
    if len(actual) != len(expected) {
        println("[FAIL] " + name + " -- len mismatch: " + to_string(len(actual)) + " vs " + to_string(len(expected)))
        fail_count = fail_count + 1
        return
    }
    let mut ok = true
    let mut i = 0
    while i < len(actual) {
        if actual[i] != expected[i] { ok = false }
        i = i + 1
    }
    if ok {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- actual: " + to_string(actual) + ", expected: " + to_string(expected))
        fail_count = fail_count + 1
    }
}

println("=====================================================================")
println("  M974: @cow (copy-on-write) Tests")
println("=====================================================================")
println("")

// -- 1. Basic COW: shared array, mutate one copy --

println("--- 1. Basic COW array sharing ---")

fn cow_array_share() {
    let original = [1, 2, 3, 4, 5]
    // Simulate sharing: both point to same data
    let shared = original
    // No mutation yet: both should be identical
    return [original, shared]
}

let shared_result = cow_array_share()
check_arr("cow: original intact", shared_result[0], [1, 2, 3, 4, 5])
check_arr("cow: shared identical", shared_result[1], [1, 2, 3, 4, 5])

// -- 2. COW: mutate the copy, original unchanged --

println("")
println("--- 2. COW mutation triggers copy ---")

fn cow_mutate_copy(arr) {
    let mut copy = []
    let mut i = 0
    while i < len(arr) {
        copy = copy.push(arr[i])
        i = i + 1
    }
    // Mutate the copy (COW: this is the write that triggers copy)
    copy[0] = 99
    return [arr, copy]
}

let mut_result = cow_mutate_copy([10, 20, 30])
check_arr("cow: original unchanged after copy mutation", mut_result[0], [10, 20, 30])
check("cow: copy[0] mutated", mut_result[1][0], 99)
check("cow: copy[1] preserved", mut_result[1][1], 20)
check("cow: copy[2] preserved", mut_result[1][2], 30)

// -- 3. COW with nested structures --

println("")
println("--- 3. COW nested data ---")

fn cow_nested_share() {
    let data = [[1, 2], [3, 4], [5, 6]]
    // Share the outer array
    let shared = data
    // Both should have same content
    return [len(data), len(shared), data[0][0], shared[0][0]]
}

let nested_result = cow_nested_share()
check("cow: nested original len", nested_result[0], 3)
check("cow: nested shared len", nested_result[1], 3)
check("cow: nested original[0][0]", nested_result[2], 1)
check("cow: nested shared[0][0]", nested_result[3], 1)

// -- 4. COW deferred copy: no mutation = no copy --

println("")
println("--- 4. COW read-only sharing (no copy needed) ---")

fn cow_read_only(arr) {
    // Share the data, only read
    let shared = arr
    let mut sum = 0
    let mut i = 0
    while i < len(shared) {
        sum = sum + shared[i]
        i = i + 1
    }
    return sum
}

check("cow: read-only sum [1,2,3,4,5]", cow_read_only([1, 2, 3, 4, 5]), 15)
check("cow: read-only sum [10,20]", cow_read_only([10, 20]), 30)
check("cow: read-only sum empty", cow_read_only([]), 0)

// -- 5. Multiple COW forks --

println("")
println("--- 5. Multiple COW forks ---")

fn cow_multi_fork(arr) {
    let mut fork1 = []
    let mut fork2 = []
    let mut i = 0
    while i < len(arr) {
        fork1 = fork1.push(arr[i])
        fork2 = fork2.push(arr[i] * 2)
        i = i + 1
    }
    return [arr, fork1, fork2]
}

let fork_result = cow_multi_fork([5, 10, 15])
check_arr("cow: original after multi-fork", fork_result[0], [5, 10, 15])
check_arr("cow: fork1 (copy)", fork_result[1], [5, 10, 15])
check_arr("cow: fork2 (doubled)", fork_result[2], [10, 20, 30])

// -- 6. COW pass detection: @cow annotation --

println("")
println("--- 6. @cow pass detection ---")

// Simulate what the ai_native_pass would detect:
// A function with @cow that has mutation sites (arr[i] = ...)
fn cow_detected_fn(arr) {
    let mut result = []
    let mut i = 0
    while i < len(arr) {
        result = result.push(arr[i])
        i = i + 1
    }
    // Mutation site: this would trigger COW
    if len(result) > 0 {
        result[0] = result[0] + 1
    }
    return result
}

check_arr("cow: detected fn [3,6,9]", cow_detected_fn([3, 6, 9]), [4, 6, 9])
check_arr("cow: detected fn empty", cow_detected_fn([]), [])
check_arr("cow: detected fn single", cow_detected_fn([100]), [101])

// -- Summary --
println("")
println("=====================================================================")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("=====================================================================")
assert(fail_count == 0)
