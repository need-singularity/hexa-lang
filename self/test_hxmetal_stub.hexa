// self/test_hxmetal_stub.hexa — ROI #147 scaffold test
//
// Exercises the 9-function Metal FFI surface declared by
// self/runtime/hxmetal_stub.hexa. Verifies:
//   - version stability (ABI lock)
//   - handle round-trips and non-zero sentinels
//   - nbytes propagation through hxm_buffer → hxm_buffer_bytes
//   - null-propagation contract (0 in → 0 out)
//   - error-return contract for hxm_dispatch
//   - release idempotence (including null-release)
//   - distinct device/queue/library/pipeline handle classes
//
// Does NOT require a Metal framework. Runs on Linux and macOS identically
// because the stub has no native calls. The live-dispatch counterpart
// lives under HXMETAL_FFI_LIVE gating in a follow-up test file.
//
// Run:
//   hexa self/test_hxmetal_stub.hexa
// Expected: all checks "ok", exit 0.

use self::runtime::hxmetal_stub

let mut PASS = 0
let mut FAIL = 0

fn check(label: string, cond: bool) -> int {
    if cond {
        PASS = PASS + 1
        println("ok: " + label)
    } else {
        FAIL = FAIL + 1
        println("FAIL: " + label)
    }
    return 0
}

fn main() -> int {
    // ── version ────────────────────────────────────────────
    // ABI lock: bump HXMETAL_ABI_VERSION only on intentional signature
    // changes. This assertion trips any silent drift.
    let v = hxm_version()
    // ABI v2 introduced by ROI #157: adds hxm_buffer_contents + hxm_dispatch3 + hxm_live.
    check("hxm_version() == 2 (abi lock v2)", v == 2)

    // ── device ─────────────────────────────────────────────
    let dev_a = hxm_device_default()
    let dev_b = hxm_device_default()
    check("hxm_device_default != 0", dev_a != 0)
    check("hxm_device_default stable across calls", dev_a == dev_b)

    // ── queue ──────────────────────────────────────────────
    let q = hxm_queue(dev_a)
    check("hxm_queue(dev) != 0", q != 0)
    check("hxm_queue(0) == 0 (null-propagation)", hxm_queue(0) == 0)
    check("queue handle != device handle (distinct class)", q != dev_a)

    // ── buffer ─────────────────────────────────────────────
    // nbytes propagation: the stub encodes nbytes in the handle so
    // hxm_buffer_bytes can recover it. This is the test that will
    // fail first if a future refactor drops the nbytes round-trip.
    let nb_small = 64
    let nb_large = 4096
    let buf_s = hxm_buffer(dev_a, nb_small)
    let buf_l = hxm_buffer(dev_a, nb_large)
    check("hxm_buffer(dev, 64) != 0", buf_s != 0)
    check("hxm_buffer(dev, 4096) != 0", buf_l != 0)
    check("hxm_buffer_bytes round-trip 64", hxm_buffer_bytes(buf_s) == nb_small)
    check("hxm_buffer_bytes round-trip 4096", hxm_buffer_bytes(buf_l) == nb_large)
    check("hxm_buffer(0, 64) == 0 (null dev)", hxm_buffer(0, nb_small) == 0)
    check("hxm_buffer(dev, 0) == 0 (zero nbytes)", hxm_buffer(dev_a, 0) == 0)
    check("hxm_buffer(dev, -1) == 0 (negative nbytes)", hxm_buffer(dev_a, -1) == 0)
    check("hxm_buffer_bytes(0) == 0 (null handle)", hxm_buffer_bytes(0) == 0)
    // Distinct-sized buffers should have distinct handles (nbytes in bits).
    check("distinct nbytes → distinct buffer handles", buf_s != buf_l)

    // ── library + pipeline ─────────────────────────────────
    let src = "kernel void vadd() {}"
    let lib = hxm_library_from_source(dev_a, src)
    check("hxm_library_from_source != 0 on non-empty src", lib != 0)
    check("hxm_library_from_source(0, src) == 0", hxm_library_from_source(0, src) == 0)
    check("hxm_library_from_source(dev, \"\") == 0", hxm_library_from_source(dev_a, "") == 0)

    let pipe = hxm_pipeline(lib, "vadd")
    check("hxm_pipeline(lib, name) != 0", pipe != 0)
    check("hxm_pipeline(0, name) == 0 (null lib)", hxm_pipeline(0, "vadd") == 0)
    check("hxm_pipeline(lib, \"\") == 0 (empty name)", hxm_pipeline(lib, "") == 0)
    check("lib handle != pipeline handle (distinct class)", lib != pipe)

    // ── dispatch ───────────────────────────────────────────
    // Success path: all non-null handles + positive nthreads.
    let rc_ok = hxm_dispatch(pipe, buf_s, buf_l, nb_small)
    check("hxm_dispatch success returns 0", rc_ok == 0)

    // Error paths: any null handle or non-positive nthreads.
    check("hxm_dispatch null pipe → -1", hxm_dispatch(0, buf_s, buf_l, nb_small) == -1)
    check("hxm_dispatch null buf_in → -1", hxm_dispatch(pipe, 0, buf_l, nb_small) == -1)
    check("hxm_dispatch null buf_out → -1", hxm_dispatch(pipe, buf_s, 0, nb_small) == -1)
    check("hxm_dispatch nthreads=0 → -1", hxm_dispatch(pipe, buf_s, buf_l, 0) == -1)
    check("hxm_dispatch nthreads=-1 → -1", hxm_dispatch(pipe, buf_s, buf_l, -1) == -1)

    // ── release ────────────────────────────────────────────
    // Release must tolerate null (defensive double-release in callers)
    // and always return 0.
    check("hxm_release(dev) == 0", hxm_release(dev_a) == 0)
    check("hxm_release(q) == 0", hxm_release(q) == 0)
    check("hxm_release(buf_s) == 0", hxm_release(buf_s) == 0)
    check("hxm_release(buf_l) == 0", hxm_release(buf_l) == 0)
    check("hxm_release(lib) == 0", hxm_release(lib) == 0)
    check("hxm_release(pipe) == 0", hxm_release(pipe) == 0)
    check("hxm_release(0) == 0 (null-safe)", hxm_release(0) == 0)
    // Idempotent (stub is no-op so double-release is trivially safe).
    check("hxm_release(dev) double-release == 0", hxm_release(dev_a) == 0)

    // ── handle class distinctness ──────────────────────────
    // Ensure no two resource classes share a sentinel by accident.
    check("dev != queue", dev_a != q)
    check("dev != lib", dev_a != lib)
    check("dev != pipe", dev_a != pipe)
    check("queue != lib", q != lib)
    check("queue != pipe", q != pipe)
    check("lib != pipe", lib != pipe)

    // ── summary ────────────────────────────────────────────
    println("")
    println("hxmetal_stub: PASS=" + to_string(PASS) + " FAIL=" + to_string(FAIL))
    if FAIL == 0 {
        return 0
    }
    return 1
}
