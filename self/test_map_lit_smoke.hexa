// Smoke test: #{} Map literal → C codegen (P5-1)
let m = #{"a": 1, "b": 2}
println(m["a"])
println(m["b"])

let m2 = #{"name": "hexa", "ver": "2.0"}
println(m2["name"])
println(m2["ver"])

// Empty map + mutate
let mut m3 = #{}
m3["x"] = 10
m3["y"] = 20
println(m3["x"])
println(m3["y"])
println(len(m3))

// Nested
let nested = #{"outer": #{"inner": 42}}
println(nested["outer"]["inner"])
