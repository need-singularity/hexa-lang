// ===================================================================
//  test_benchmark_suite.hexa — Benchmark Suite verification
//
//  Tests:
//    1. MMLU JSONL format parsing + accuracy calculation
//    2. HumanEval pass@k formula verification
//    3. MT-Bench multi-turn processing
//    4. Report format + JSONL output
//    5. Edge cases (empty data, perfect score, zero score)
//
//  Run: ./hexa self/test_benchmark_suite.hexa
// ===================================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn approx(a, b, eps) { return fabs(a - b) < eps }

// ── inline benchmark_suite functions for testing ────────────────

// C(n, k) combination
fn comb(n: int, k: int) -> float {
    if k > n { return 0.0 }
    if k == 0 { return 1.0 }
    if k == n { return 1.0 }
    let mut kk = k
    if kk > n - kk { kk = n - kk }
    let mut result = 1.0
    let mut i = 0
    while i < kk {
        result = result * to_float(n - i) / to_float(i + 1)
        i = i + 1
    }
    return result
}

fn compute_pass_at_k(n: int, c: int, k: int) -> float {
    if n < k { return 0.0 }
    if c == 0 { return 0.0 }
    if c >= n { return 1.0 }
    let numerator = comb(n - c, k)
    let denominator = comb(n, k)
    if denominator == 0.0 { return 0.0 }
    let ratio = numerator / denominator
    return 1.0 - ratio
}

fn bench_min_int(a: int, b: int) -> int {
    if a < b { return a }
    return b
}

fn tokenize_words(text) {
    let parts = text.split(" ")
    let mut tokens = []
    let mut i = 0
    while i < len(parts) {
        let w = parts[i].trim()
        if len(w) > 0 {
            tokens = tokens + [w.to_lower()]
        }
        i = i + 1
    }
    return tokens
}

fn word_overlap_f1(hyp_text, ref_text) -> float {
    let hyp_words = tokenize_words(hyp_text)
    let ref_words = tokenize_words(ref_text)
    let h_len = len(hyp_words)
    let r_len = len(ref_words)
    if h_len == 0 { return 0.0 }
    if r_len == 0 { return 0.0 }

    let mut used = []
    let mut ri = 0
    while ri < r_len {
        used = used + [false]
        ri = ri + 1
    }

    let mut matches = 0
    let mut hi = 0
    while hi < h_len {
        let mut rj = 0
        while rj < r_len {
            if used[rj] == false {
                if hyp_words[hi] == ref_words[rj] {
                    matches = matches + 1
                    used[rj] = true
                    rj = r_len
                }
            }
            rj = rj + 1
        }
        hi = hi + 1
    }

    if matches == 0 { return 0.0 }
    let precision = to_float(matches) / to_float(h_len)
    let recall = to_float(matches) / to_float(r_len)
    return 2.0 * precision * recall / (precision + recall)
}

fn format_mmlu_choices(choices) -> string {
    let labels = ["A", "B", "C", "D"]
    let mut s = ""
    let mut i = 0
    let n = len(choices)
    while i < n {
        if i < len(labels) {
            s = s + labels[i] + ". " + to_string(choices[i]) + "\n"
        }
        i = i + 1
    }
    return s
}

fn build_mmlu_prompt(question, choices, few_shot_examples) -> string {
    let mut prompt = ""
    let num_shots = len(few_shot_examples)
    let mut si = 0
    while si < num_shots {
        let ex = few_shot_examples[si]
        let ex_q = ex["question"]
        let ex_choices = ex["choices"]
        let ex_answer = ex["answer"]
        prompt = prompt + "Question: " + to_string(ex_q) + "\n"
        prompt = prompt + format_mmlu_choices(ex_choices)
        prompt = prompt + "Answer: " + to_string(ex_answer) + "\n\n"
        si = si + 1
    }
    prompt = prompt + "Question: " + to_string(question) + "\n"
    prompt = prompt + format_mmlu_choices(choices)
    prompt = prompt + "Answer:"
    return prompt
}

fn pad_right(s, width: int) -> string {
    let mut result = s
    while len(result) < width {
        result = result + " "
    }
    return result
}

println("===================================================================")
println("  HEXA Benchmark Suite Tests")
println("===================================================================")
println("")

// ═══════════════════════════════════════════════════════════
//  1. MMLU — format parsing + accuracy
// ═══════════════════════════════════════════════════════════
println("--- MMLU Tests ---")

// Test 1: choices formatting
let choices1 = ["Paris", "London", "Berlin", "Madrid"]
let fmt1 = format_mmlu_choices(choices1)
check("mmlu_choices_format contains A", fmt1.contains("A. Paris"))

// Test 2: prompt building with few-shot
let fs_ex = [#{"question": "1+1=?", "choices": ["1", "2", "3", "4"], "answer": "B"}]
let prompt1 = build_mmlu_prompt("capital of France?", choices1, fs_ex)
check("mmlu_prompt_has_fewshot", prompt1.contains("1+1=?"))

// Test 3: prompt ends with Answer:
check("mmlu_prompt_ends_answer", prompt1.ends_with("Answer:"))

// Test 4: MMLU accuracy — mock model always returns correct answer
//   We simulate by building records and a model that echoes the answer
let mmlu_records = [
    #{"question": "1+1", "choices": ["1", "2", "3", "4"], "answer": "B", "subject": "math"},
    #{"question": "2+2", "choices": ["2", "3", "4", "5"], "answer": "C", "subject": "math"},
    #{"question": "color of sky", "choices": ["red", "green", "blue", "yellow"], "answer": "C", "subject": "science"},
    #{"question": "H2O is", "choices": ["fire", "water", "air", "earth"], "answer": "B", "subject": "science"}
]

// perfect model: always returns correct answer letter
fn perfect_mmlu_model(prompt) {
    // parse: last question's answer from our test data
    // For testing: we know the pattern — return the correct letter
    if prompt.contains("1+1") { return "B" }
    if prompt.contains("2+2") { return "C" }
    if prompt.contains("color of sky") { return "C" }
    if prompt.contains("H2O is") { return "B" }
    return "A"
}

// manually compute: model gets all 4 correct
let mut manual_correct = 0
let mut mi = 0
while mi < 4 {
    let rec = mmlu_records[mi]
    let ans = to_string(rec["answer"])
    let model_ans = perfect_mmlu_model("Question: " + to_string(rec["question"]))
    let trimmed = model_ans.trim()
    if len(trimmed) > 0 {
        let first = trimmed.substring(0, 1)
        if first == ans { manual_correct = manual_correct + 1 }
    }
    mi = mi + 1
}
let manual_acc = to_float(manual_correct) / 4.0
check("mmlu_perfect_acc=1.0", approx(manual_acc, 1.0, 0.001))

// Test 5: MMLU with wrong model — accuracy = 0
fn wrong_mmlu_model(prompt) { return "Z" }

let mut wrong_correct = 0
let mut wi = 0
while wi < 4 {
    let rec = mmlu_records[wi]
    let ans = to_string(rec["answer"])
    let model_ans = wrong_mmlu_model("")
    let trimmed = model_ans.trim()
    if len(trimmed) > 0 {
        let first = trimmed.substring(0, 1)
        if first == ans { wrong_correct = wrong_correct + 1 }
    }
    wi = wi + 1
}
check("mmlu_wrong_acc=0.0", wrong_correct == 0)

// ═══════════════════════════════════════════════════════════
//  2. HumanEval — pass@k formula
// ═══════════════════════════════════════════════════════════
println("")
println("--- HumanEval pass@k Tests ---")

// Test 6: comb(n, k) — basic combinatorics
check("comb(5,2)=10", approx(comb(5, 2), 10.0, 0.001))

// Test 7: comb(10,0) = 1
check("comb(10,0)=1", approx(comb(10, 0), 1.0, 0.001))

// Test 8: pass@1 when all correct: should be 1.0
let p1_all = compute_pass_at_k(10, 10, 1)
check("pass@1_all_correct=1.0", approx(p1_all, 1.0, 0.001))

// Test 9: pass@1 when none correct: should be 0.0
let p1_none = compute_pass_at_k(10, 0, 1)
check("pass@1_none_correct=0.0", approx(p1_none, 0.0, 0.001))

// Test 10: pass@1 with n=10, c=5
// pass@1 = 1 - C(5,1)/C(10,1) = 1 - 5/10 = 0.5
let p1_half = compute_pass_at_k(10, 5, 1)
check("pass@1_half=0.5", approx(p1_half, 0.5, 0.001))

// Test 11: pass@5 with n=10, c=5
// pass@5 = 1 - C(5,5)/C(10,5) = 1 - 1/252 ≈ 0.996
let p5_half = compute_pass_at_k(10, 5, 5)
check("pass@5_n10_c5≈0.996", approx(p5_half, 0.99603, 0.01))

// Test 12: pass@k when k > n returns 0
let p_over = compute_pass_at_k(3, 2, 5)
check("pass@k_k>n=0", approx(p_over, 0.0, 0.001))

// ═══════════════════════════════════════════════════════════
//  3. MT-Bench — multi-turn + scoring
// ═══════════════════════════════════════════════════════════
println("")
println("--- MT-Bench Tests ---")

// Test 13: word overlap F1 — identical strings
let f1_same = word_overlap_f1("hello world foo", "hello world foo")
check("f1_identical=1.0", approx(f1_same, 1.0, 0.001))

// Test 14: word overlap F1 — no overlap
let f1_none = word_overlap_f1("alpha beta", "gamma delta")
check("f1_no_overlap=0.0", approx(f1_none, 0.0, 0.001))

// Test 15: word overlap F1 — partial overlap
// hyp: "the cat sat", ref: "the dog sat on mat"
// overlap: "the", "sat" -> 2 matches
// precision = 2/3, recall = 2/5
// F1 = 2 * (2/3) * (2/5) / ((2/3) + (2/5)) = 2 * 0.2667 / 1.0667 ≈ 0.5
let f1_partial = word_overlap_f1("the cat sat", "the dog sat on mat")
check("f1_partial≈0.5", approx(f1_partial, 0.5, 0.05))

// Test 16: multi-turn context building
// Simulate: model echoes back part of the prompt to test context accumulation
fn echo_model(prompt) { return "The answer is 42" }

let mt_score = word_overlap_f1("The answer is 42", "The correct answer is 42")
// overlap: "the", "answer", "is", "42" = 4 of 4 hyp words, 4 of 5 ref words
// P=1.0, R=0.8, F1=2*1.0*0.8/1.8 ≈ 0.888
check("mt_turn_score_reasonable", mt_score > 0.5)

// ═══════════════════════════════════════════════════════════
//  4. Report format
// ═══════════════════════════════════════════════════════════
println("")
println("--- Report Format Tests ---")

// Test 17: pad_right
let padded = pad_right("hello", 10)
check("pad_right_len=10", len(padded) == 10)

// Test 18: pad_right no-op when already wide
let padded2 = pad_right("very long string here", 5)
check("pad_right_noop", len(padded2) >= 5)

// ═══════════════════════════════════════════════════════════
//  5. Edge cases
// ═══════════════════════════════════════════════════════════
println("")
println("--- Edge Cases ---")

// Test 19: comb symmetry: C(n,k) == C(n, n-k)
check("comb_symmetry", approx(comb(8, 3), comb(8, 5), 0.001))

// Test 20: pass@k monotonicity: pass@5 >= pass@1
let mono_p1 = compute_pass_at_k(10, 3, 1)
let mono_p5 = compute_pass_at_k(10, 3, 5)
check("pass@k_monotone", mono_p5 >= mono_p1)

// Test 21: word_overlap empty strings
let f1_empty = word_overlap_f1("", "hello")
check("f1_empty_hyp=0", approx(f1_empty, 0.0, 0.001))

// Test 22: tokenize_words
let tw = tokenize_words("Hello World")
check("tokenize_lowercase", tw[0] == "hello")

// ═══════════════════════════════════════════════════════════
