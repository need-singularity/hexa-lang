// ═══════════════════════════════════════════════════════════
//  test_interp_match.hexa — P2-4: Pattern Matching Tests
//  Tests match expression execution in the self-hosted interpreter
//  Run: ./hexa self/test_interp_match.hexa
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(label, actual, expected) {
    if actual == expected {
        println("[PASS] " + label)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + label + "  expected: " + to_string(expected) + "  got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  P2-4: Pattern Matching Execution Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Basic int pattern match ──────────────────────────
println("--- 1. Basic Int Match ---")

let x = 2
let r1 = match x {
    1 -> "one",
    2 -> "two",
    3 -> "three",
    _ -> "other"
}
check("match int 2", r1, "two")

let r2 = match 99 {
    1 -> "one",
    _ -> "default"
}
check("match int wildcard", r2, "default")

let r3 = match 1 {
    1 -> "one",
    _ -> "other"
}
check("match int 1", r3, "one")

// ── 2. String pattern match ─────────────────────────────
println("")
println("--- 2. String Match ---")

fn greet(lang) {
    return match lang {
        "en" -> "hello",
        "ko" -> "annyeong",
        "jp" -> "konnichiwa",
        _ -> "hi"
    }
}
check("match str en", greet("en"), "hello")
check("match str ko", greet("ko"), "annyeong")
check("match str jp", greet("jp"), "konnichiwa")
check("match str other", greet("fr"), "hi")

// ── 3. Bool pattern match ───────────────────────────────
println("")
println("--- 3. Bool Match ---")

fn bool_word(b) {
    return match b {
        true -> "yes",
        false -> "no"
    }
}
check("match bool true", bool_word(true), "yes")
check("match bool false", bool_word(false), "no")

// ── 4. Block body match ─────────────────────────────────
println("")
println("--- 4. Block Body Match ---")

let r4 = match 3 {
    1 -> { 100 },
    2 -> { 200 },
    3 -> {
        let a = 10
        let b = 20
        a + b + 270
    },
    _ -> { 0 }
}
check("match block body", r4, 300)

// ── 5. Variable binding pattern ─────────────────────────
println("")
println("--- 5. Variable Binding ---")

let r5 = match 42 {
    n -> n * 2
}
check("match var bind", r5, 84)

// ── 6. Match in function ────────────────────────────────
println("")
println("--- 6. Match in Function ---")

fn classify(n) {
    return match n {
        0 -> "zero",
        1 -> "one",
        _ -> "many"
    }
}
check("classify 0", classify(0), "zero")
check("classify 1", classify(1), "one")
check("classify 5", classify(5), "many")

// ── 7. Nested match ─────────────────────────────────────
println("")
println("--- 7. Nested Match ---")

fn nested(x, y) {
    return match x {
        1 -> match y {
            1 -> "both one",
            _ -> "x is one"
        },
        _ -> "x is not one"
    }
}
check("nested 1,1", nested(1, 1), "both one")
check("nested 1,2", nested(1, 2), "x is one")
check("nested 2,1", nested(2, 1), "x is not one")

// ── 8. Enum variant match ───────────────────────────────
println("")
println("--- 8. Enum Variant Match ---")

enum Color {
    Red,
    Green,
    Blue
}

let c = Color::Green
let r6 = match c {
    Color::Red -> "red",
    Color::Green -> "green",
    Color::Blue -> "blue",
    _ -> "unknown"
}
check("match enum Color::Green", r6, "green")

let c2 = Color::Red
let r7 = match c2 {
    Color::Red -> "red",
    Color::Green -> "green",
    Color::Blue -> "blue",
    _ -> "unknown"
}
check("match enum Color::Red", r7, "red")

// ── 9. Enum with data destructuring ─────────────────────
println("")
println("--- 9. Enum Data Destructuring ---")

enum Option {
    Some(value),
    None
}

let opt1 = Option::Some(42)
let r8 = match opt1 {
    Option::Some(x) -> x + 1,
    Option::None -> 0
}
check("match Some(42) -> 43", r8, 43)

let opt2 = Option::None
let r9 = match opt2 {
    Option::Some(x) -> x,
    Option::None -> -1
}
check("match None -> -1", r9, -1)

// ── 10. Match with computation ──────────────────────────
println("")
println("--- 10. Match + Computation ---")

fn fib_class(n) {
    return match n {
        0 -> "zero",
        1 -> "one",
        2 -> "two",
        _ -> "many"
    }
}
check("fib_class 0", fib_class(0), "zero")
check("fib_class 1", fib_class(1), "one")
check("fib_class 2", fib_class(2), "two")
check("fib_class 10", fib_class(10), "many")

// ── 11. Match returning from loop ───────────────────────
println("")
println("--- 11. Match in Loop ---")

let mut results = []
let mut i = 0
while i < 5 {
    let label = match i {
        0 -> "zero",
        1 -> "one",
        2 -> "two",
        _ -> "many"
    }
    results = results.push(label)
    i = i + 1
}
check("loop match[0]", results[0], "zero")
check("loop match[1]", results[1], "one")
check("loop match[2]", results[2], "two")
check("loop match[3]", results[3], "many")
check("loop match[4]", results[4], "many")

// ── 12. Enum data with string ───────────────────────────
println("")
println("--- 12. Enum Data String ---")

enum Message {
    Text(content),
    Number(val)
}

let m1 = Message::Text("hello world")
let r10 = match m1 {
    Message::Text(s) -> "got: " + s,
    Message::Number(n) -> "num: " + to_string(n),
    _ -> "unknown"
}
check("match Message::Text", r10, "got: hello world")

let m2 = Message::Number(99)
let r11 = match m2 {
    Message::Text(s) -> "got: " + s,
    Message::Number(n) -> "num: " + to_string(n),
    _ -> "unknown"
}
check("match Message::Number", r11, "num: 99")

// ── 13. Float pattern match ─────────────────────────────
println("")
println("--- 13. Float Match ---")

let f = 3.14
let r12 = match f {
    3.14 -> "pi",
    2.72 -> "e",
    _ -> "other"
}
check("match float pi", r12, "pi")

// ── 14. Negative literal pattern ────────────────────────
println("")
println("--- 14. Negative Literal ---")

let neg = -1
let r13 = match neg {
    -1 -> "minus one",
    0 -> "zero",
    1 -> "one",
    _ -> "other"
}
check("match -1", r13, "minus one")

// ── 15. Match with zero ─────────────────────────────────
println("")
println("--- 15. Match Zero ---")

let r_zero = match 0 {
    0 -> "zero",
    1 -> "one",
    _ -> "other"
}
check("match zero literal", r_zero, "zero")

// ── 16. Match large int ─────────────────────────────────
println("")
println("--- 16. Match Large Int ---")

fn classify_range(x) {
    return match x {
        1000 -> "thousand",
        999 -> "nine-nine-nine",
        _ -> "unknown"
    }
}
check("match 1000", classify_range(1000), "thousand")
check("match 999", classify_range(999), "nine-nine-nine")
check("match 500", classify_range(500), "unknown")

// ── 17. Match expression as argument ────────────────────
println("")
println("--- 17. Match as Argument ---")

fn identity(x) { return x }

let r_arg = identity(match 2 {
    1 -> "a",
    2 -> "b",
    _ -> "c"
})
check("match as fn arg", r_arg, "b")

// ── 18. Match returning number computations ─────────────
println("")
println("--- 18. Match Numeric Results ---")

fn compute(op, a, b) {
    return match op {
        "add" -> a + b,
        "sub" -> a - b,
        "mul" -> a * b,
        _ -> 0
    }
}
check("compute add", compute("add", 3, 4), 7)
check("compute sub", compute("sub", 10, 3), 7)
check("compute mul", compute("mul", 5, 6), 30)
check("compute unknown", compute("div", 1, 1), 0)

// ── 19. Match with boolean result ───────────────────────
println("")
println("--- 19. Match Bool Result ---")

fn is_primary(c) {
    return match c {
        "red" -> true,
        "blue" -> true,
        "yellow" -> true,
        _ -> false
    }
}
check("primary red", is_primary("red"), true)
check("primary blue", is_primary("blue"), true)
check("primary green", is_primary("green"), false)

// ── 20. Sequential match expressions ────────────────────
println("")
println("--- 20. Sequential Match ---")

let seq1 = match 1 { 1 -> "a", _ -> "z" }
let seq2 = match 2 { 2 -> "b", _ -> "z" }
let seq3 = match 3 { 3 -> "c", _ -> "z" }
check("seq match 1", seq1, "a")
check("seq match 2", seq2, "b")
check("seq match 3", seq3, "c")
check("seq match concat", seq1 + seq2 + seq3, "abc")

// ── 21. Match in while loop accumulator ─────────────────
println("")
println("--- 21. Match Loop Accumulator ---")

let mut acc = 0
let mut li = 0
while li < 5 {
    acc = acc + match li {
        0 -> 1,
        1 -> 2,
        2 -> 4,
        3 -> 8,
        _ -> 16
    }
    li = li + 1
}
check("match loop accum", acc, 31)

// ── 22. Match returning array ───────────────────────────
println("")
println("--- 22. Match Return Array ---")

fn get_pair(key) {
    return match key {
        "a" -> [1, 2],
        "b" -> [3, 4],
        _ -> [0, 0]
    }
}
check("pair a[0]", get_pair("a")[0], 1)
check("pair a[1]", get_pair("a")[1], 2)
check("pair b[0]", get_pair("b")[0], 3)
check("pair default", get_pair("z")[0], 0)

// ── Summary ─────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL / " + to_string(pass_count + fail_count) + " total")
if fail_count == 0 {
    println("  ALL P2-4 MATCH TESTS PASSED!")
} else {
    println("  SOME TESTS FAILED")
}
println("═══════════════════════════════════════════════════════")
