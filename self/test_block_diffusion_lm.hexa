// ===================================================================
//  test_block_diffusion_lm.hexa — Block Diffusion LM tests (#205)
//
//  Tests (35+):
//    #1  cosine_schedule prob[0] ~ 1.0
//    #2  cosine_schedule prob[total_t] ~ 0.0
//    #3  cosine_schedule monotonically decreasing
//    #4  cosine_schedule intermediate in (0,1)
//    #5  cosine_schedule total_t=0 defensive
//    #6  mask_block preserves non-masked tokens
//    #7  mask_block masked positions = mask_id
//    #8  mask_block mask_prob=0 no masking
//    #9  mask_block mask_prob=1 all block masked
//    #10 mask_block different seeds -> different masks
//    #11 mask_block seed determinism (same seed -> same mask)
//    #12 noise_sample length correct
//    #13 noise_sample values in [0, vocab)
//    #14 noise_sample seed determinism
//    #15 time_embedding dim correct
//    #16 time_embedding varies with t
//    #17 create_denoiser fields present
//    #18 create_denoiser embed shape [V,D]
//    #19 create_denoiser unembed shape [V,D]
//    #20 denoiser_forward output shape [n, vocab]
//    #21 denoiser_forward deterministic
//    #22 softmax sums to 1.0 per row
//    #23 softmax all non-negative
//    #24 argmax_row picks largest
//    #25 compute_loss positive for untrained denoiser
//    #26 compute_loss zero when no masked positions
//    #27 reveal_top_k picks k positions
//    #28 reveal_top_k picks highest-confidence positions
//    #29 reveal_top_k handles k > masked
//    #30 bdlm_step reveals at least one position
//    #31 bdlm_step preserves non-masked tokens
//    #32 mask_predict_sample reveals all positions (none left masked)
//    #33 mask_predict_sample length = seq_len
//    #34 mask_predict_sample tokens in [0, vocab)
//    #35 block_parallel_generate length = seq_len
//    #36 block_parallel_generate tokens in [0, vocab)
//    #37 block_parallel_generate seed determinism
//    #38 param_count > 0
//
//  Run: ./hexa self/test_block_diffusion_lm.hexa
// ===================================================================

import "ml/block_diffusion_lm.hexa"

let mut pass_count = 0
let mut fail_count = 0

fn check(idx, name, cond) {
    if cond {
        println("[PASS] #" + str(idx) + " " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] #" + str(idx) + " " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx(a, b, eps) { return fabs(a - b) < eps }

println("=== Block Diffusion LM Tests ===")

// ── shared fixtures ─────────────────────────────────────────────
let VOCAB = 12
let DIM = 6
let SEQ = 8
let BLOCK = 4
let TOTAL_T = 4
let SEED = 1234

let denoiser = bdlm_create_denoiser(VOCAB, DIM)

// ===================================================================
//  #1-#5 Cosine schedule
// ===================================================================

let p0 = bdlm_cosine_schedule(0, TOTAL_T)
check(1, "cosine_schedule prob[0] ~ 1.0", approx(p0, 1.0, 0.001))

let pT = bdlm_cosine_schedule(TOTAL_T, TOTAL_T)
check(2, "cosine_schedule prob[total_t] ~ 0.0", approx(pT, 0.0, 0.001))

let mut mono_ok = true
let mut prev = bdlm_cosine_schedule(0, TOTAL_T)
let mut t = 1

while t < (TOTAL_T + 1) {
    let cur = bdlm_cosine_schedule(t, TOTAL_T)
    if cur > prev + 0.0001 { mono_ok = false }
    prev = cur
}
check(3, "cosine_schedule monotone decreasing", mono_ok)

let p_mid = bdlm_cosine_schedule(TOTAL_T / 2, TOTAL_T)
check(4, "cosine_schedule intermediate in (0,1)", p_mid > 0.01 && p_mid < 0.99)

let p_def = bdlm_cosine_schedule(0, 0)
check(5, "cosine_schedule total_t=0 defensive", p_def >= 0.0 && p_def <= 1.0)

// ===================================================================
//  #6-#11 Mask block
// ===================================================================

let clean = [1, 2, 3, 4, 5, 6, 7, 8]
let MASK_ID = VOCAB - 1

let r_half = bdlm_mask_block(clean, 2, 6, 0.5, MASK_ID, SEED)
let masked_half = r_half[0]
let mpos_half = r_half[1]

// Non-block positions should equal original
let mut non_block_preserved = true
let mut i = 0

while i < len(clean) {
    if i < 2 || i >= 6 {
        if masked_half[i] != clean[i] { non_block_preserved = false }
    }
}
check(6, "mask_block preserves non-block tokens", non_block_preserved)

// Where mpos==1, token==MASK_ID
let mut mask_correct = true
let mut i = 0

while i < len(masked_half) {
    if mpos_half[i] == 1 {
        if masked_half[i] != MASK_ID { mask_correct = false }
    }
}
check(7, "mask_block masked positions use mask_id", mask_correct)

let r_none = bdlm_mask_block(clean, 2, 6, 0.0, MASK_ID, SEED)
let mn = r_none[0]
let mut none_masked = true
let mut i = 0

while i < len(clean) {
    if mn[i] != clean[i] { none_masked = false }
}
check(8, "mask_block mask_prob=0 no masking", none_masked)

let r_all = bdlm_mask_block(clean, 2, 6, 1.0, MASK_ID, SEED)
let mall = r_all[0]
let mall_pos = r_all[1]
let mut all_block_masked = true
let mut i = 2

while i < 6 {
    if mall[i] != MASK_ID { all_block_masked = false }
    if mall_pos[i] != 1 { all_block_masked = false }
}
check(9, "mask_block mask_prob=1 all block masked", all_block_masked)

let r_seed_a = bdlm_mask_block(clean, 0, 8, 0.5, MASK_ID, 11)
let r_seed_b = bdlm_mask_block(clean, 0, 8, 0.5, MASK_ID, 99)
let mut diff_seed = false
let mut i = 0

while i < len(clean) {
    if r_seed_a[1][i] != r_seed_b[1][i] { diff_seed = true }
}
check(10, "mask_block different seeds -> different masks", diff_seed)

let r_same_a = bdlm_mask_block(clean, 0, 8, 0.5, MASK_ID, 77)
let r_same_b = bdlm_mask_block(clean, 0, 8, 0.5, MASK_ID, 77)
let mut same_seed_ok = true
let mut i = 0

while i < len(clean) {
    if r_same_a[0][i] != r_same_b[0][i] { same_seed_ok = false }
    if r_same_a[1][i] != r_same_b[1][i] { same_seed_ok = false }
}
check(11, "mask_block seed determinism", same_seed_ok)

// ===================================================================
//  #12-#14 Noise sample
// ===================================================================

let ns = bdlm_noise_sample(VOCAB, 10, 42)
check(12, "noise_sample length correct", len(ns) == 10)

let mut ns_in_range = true
let mut i = 0

while i < len(ns) {
    if ns[i] < 0 || ns[i] >= VOCAB { ns_in_range = false }
}
check(13, "noise_sample values in [0, vocab)", ns_in_range)

let ns2 = bdlm_noise_sample(VOCAB, 10, 42)
let mut ns_det = true
let mut i = 0

while i < 10 {
    if ns[i] != ns2[i] { ns_det = false }
}
check(14, "noise_sample seed determinism", ns_det)

// ===================================================================
//  #15-#16 Time embedding
// ===================================================================

let te0 = bdlm_time_embedding(0, TOTAL_T, DIM)
check(15, "time_embedding dim correct", len(te0) == DIM)

let te1 = bdlm_time_embedding(2, TOTAL_T, DIM)
let mut te_diff = false
let mut i = 0

while i < DIM {
    if fabs(te0[i] - te1[i]) > 1.0e-6 { te_diff = true }
}
check(16, "time_embedding varies with t", te_diff)

// ===================================================================
//  #17-#19 Denoiser creation
// ===================================================================

check(17, "create_denoiser has fields", denoiser["vocab"] == VOCAB && denoiser["dim"] == DIM)

let emb = denoiser["embed"]
check(18, "create_denoiser embed shape [V,D]", len(emb) == VOCAB && len(emb[0]) == DIM)

let un = denoiser["unembed"]
check(19, "create_denoiser unembed shape [V,D]", len(un) == VOCAB && len(un[0]) == DIM)

// ===================================================================
//  #20-#21 Denoiser forward
// ===================================================================

let ntoks = [0, 1, 2, 3, 4]
let te_fwd = bdlm_time_embedding(1, TOTAL_T, DIM)
let logits = bdlm_denoiser_forward(denoiser, ntoks, te_fwd)
check(20, "denoiser_forward output shape [n,vocab]", len(logits) == 5 && len(logits[0]) == VOCAB)

let logits2 = bdlm_denoiser_forward(denoiser, ntoks, te_fwd)
let mut fwd_det = true
let mut i = 0

while i < 5 {
    let mut j = 0

    while j < VOCAB {
        if fabs(logits[i][j] - logits2[i][j]) > 1.0e-9 { fwd_det = false }
    }
}
check(21, "denoiser_forward deterministic", fwd_det)

// ===================================================================
//  #22-#24 Softmax / argmax
// ===================================================================

let sm = bdlm_softmax(logits[0], VOCAB)
let mut sm_sum = 0.0
let mut sm_nonneg = true
let mut i = 0

while i < VOCAB {
    sm_sum = sm_sum + sm[i]
    if sm[i] < 0.0 { sm_nonneg = false }
}
check(22, "softmax sums to 1.0", approx(sm_sum, 1.0, 0.001))
check(23, "softmax non-negative", sm_nonneg)

let am_in = [0.1, 0.5, 0.9, 0.3, 0.7]
check(24, "argmax_row picks index 2", bdlm_argmax_row(am_in, 5) == 2)

// ===================================================================
//  #25-#26 Compute loss
// ===================================================================

let clean_tokens = [0, 1, 2, 3]
let mask_pos_loss = [0, 1, 1, 0]
let loss = bdlm_compute_loss(denoiser, clean_tokens, mask_pos_loss, VOCAB)
check(25, "compute_loss > 0 for untrained denoiser", loss > 0.0)

let zero_mask = [0, 0, 0, 0]
let loss_zero = bdlm_compute_loss(denoiser, clean_tokens, zero_mask, VOCAB)
check(26, "compute_loss zero when no masked positions", approx(loss_zero, 0.0, 1.0e-9))

// ===================================================================
//  #27-#29 Reveal top-k
// ===================================================================

// Build synthetic logits where position 0 is very confident (large max),
// position 1 is moderate, position 2 is flat, position 3 is moderate.
let mut synth = []
let mut i = 0

while i < 4 {
    let mut row = []
    let mut j = 0

    while j < VOCAB {
        if i == 0 && j == 3 { row = row + [100.0] }
        else { if i == 1 && j == 5 { row = row + [5.0] }
               else { if i == 3 && j == 2 { row = row + [2.0] }
                      else { row = row + [0.0] } } }
    }
    synth = synth + [row]
}
let all_masked = [1, 1, 1, 1]
let picks2 = bdlm_reveal_top_k(synth, all_masked, 2)
check(27, "reveal_top_k length = k", len(picks2) == 2)

// position 0 should definitely be picked first (max logit 100)
let mut has0 = false
let mut p = 0

while p < len(picks2) {
    if picks2[p] == 0 { has0 = true }
}
check(28, "reveal_top_k picks highest-confidence (position 0)", has0)

let picks_big = bdlm_reveal_top_k(synth, all_masked, 99)
check(29, "reveal_top_k handles k > masked", len(picks_big) == 4)

// ===================================================================
//  #30-#31 bdlm_step
// ===================================================================

let mut partial = [MASK_ID, MASK_ID, MASK_ID, MASK_ID]
let mpos_step = [1, 1, 1, 1]
let step_res = bdlm_step(denoiser, partial, mpos_step, 1, 4, 4, VOCAB, 7)
let new_seq = step_res[0]
let new_mp = step_res[1]
let mut revealed = 0
let mut i = 0

while i < 4 {
    if new_mp[i] == 0 { revealed = revealed + 1 }
}
check(30, "bdlm_step reveals at least one position", revealed >= 1)

// Pre-seed a visible token; step must not overwrite it.
let mixed = [5, MASK_ID, MASK_ID, MASK_ID]
let mixed_mp = [0, 1, 1, 1]
let step_mix = bdlm_step(denoiser, mixed, mixed_mp, 1, 4, 4, VOCAB, 9)
check(31, "bdlm_step preserves non-masked tokens", step_mix[0][0] == 5)

// ===================================================================
//  #32-#34 mask_predict_sample
// ===================================================================

let gen = bdlm_mask_predict_sample(denoiser, SEQ, TOTAL_T, BLOCK, VOCAB, SEED)
check(32, "mask_predict_sample length = seq_len", len(gen) == SEQ)

let mut gen_in_range = true
let mut i = 0

while i < SEQ {
    if gen[i] < 0 || gen[i] >= VOCAB { gen_in_range = false }
}
check(33, "mask_predict_sample tokens in [0,vocab)", gen_in_range)

// After sampling, none of the tokens should remain == MASK_ID unless the
// denoiser genuinely argmax'd MASK_ID (unlikely for random weights). We
// check the weaker condition: all positions are deterministic.
let gen_again = bdlm_mask_predict_sample(denoiser, SEQ, TOTAL_T, BLOCK, VOCAB, SEED)
let mut gen_det = true
let mut i = 0

while i < SEQ {
    if gen[i] != gen_again[i] { gen_det = false }
}
check(34, "mask_predict_sample deterministic", gen_det)

// ===================================================================
//  #35-#37 block_parallel_generate
// ===================================================================

let bp = bdlm_block_parallel_generate(denoiser, SEQ, BLOCK, VOCAB, SEED)
check(35, "block_parallel_generate length = seq_len", len(bp) == SEQ)

let mut bp_in_range = true
let mut i = 0

while i < SEQ {
    if bp[i] < 0 || bp[i] >= VOCAB { bp_in_range = false }
}
check(36, "block_parallel_generate tokens in [0,vocab)", bp_in_range)

let bp2 = bdlm_block_parallel_generate(denoiser, SEQ, BLOCK, VOCAB, SEED)
let mut bp_det = true
let mut i = 0

while i < SEQ {
    if bp[i] != bp2[i] { bp_det = false }
}
check(37, "block_parallel_generate seed determinism", bp_det)

// ===================================================================
//  #38 param count
// ===================================================================

let pc = bdlm_param_count(denoiser)
check(38, "param_count > 0", pc > 0)

// ── summary ─────────────────────────────────────────────────────
println("")
println("=== Block Diffusion LM test summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
