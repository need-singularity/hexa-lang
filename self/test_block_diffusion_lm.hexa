//    #4  cosine_schedule intermediate in (0,1)
//    #5  cosine_schedule total_t=0 defensive
//    #6  mask_block preserves non-masked tokens
//    #7  mask_block masked positions = mask_id
//    #8  mask_block mask_prob=0 no masking
//    #9  mask_block mask_prob=1 all block masked
//    #10 mask_block different seeds -> different masks
//    #11 mask_block seed determinism (same seed -> same mask)
//    #12 noise_sample length correct
//    #13 noise_sample values in [0, vocab)
//    #14 noise_sample seed determinism
//    #15 time_embedding dim correct
//    #16 time_embedding varies with t
//    #17 create_denoiser fields present
