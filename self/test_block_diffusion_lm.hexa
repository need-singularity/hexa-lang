// -- inlined from self/ml/block_diffusion_lm.hexa --
// codegen import not wired for test files

// ===================================================================
//  self/ml/block_diffusion_lm.hexa — Block Diffusion LM (#205)
//
//  Block-wise discrete diffusion language model. Instead of next-token
//  autoregression, we denoise whole BLOCKS of tokens in parallel. Each
//  block of length `block_size` is partially masked (with probability
//  p(t) from a cosine schedule), a light-weight denoiser predicts the
//  masked positions from the currently visible context, and the most
//  confident predictions are revealed in each mask-predict step. Once
//  a block is fully denoised we slide forward and repeat.
//
//  Components:
//    1. Cosine noise schedule       — mask prob per step t
//    2. Block masking               — deterministic masking inside a block
//    3. Noise sampler               — deterministic random token id
//    4. Denoiser                    — embed + time-bias + unembed
//    5. Time embedding              — simple scalar-broadcast t/T
//    6. Masked cross-entropy loss   — loss only over masked positions
//    7. Mask-predict sampling       — iterative top-k reveal
//    8. Block-parallel generation   — slide over seq_len in blocks
//
//  AI-NATIVE attrs:
//    @pure  — no side effects
//    @hot   — inner loops
//
//  All ops are pure .hexa. Deterministic: same seed → same output.
// ===================================================================

// ===================================================================
//  Math helpers
// ===================================================================

@pure
fn bdlm_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

@pure
fn bdlm_max(a, b) {
    if a > b { return a }
    return b
}

@pure
fn bdlm_min(a, b) {
    if a < b { return a }
    return b
}

@pure
fn bdlm_sqrt(x) {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    let mut _i = 0
    while _i < 30 {
    return g
        _i = _i + 1
}

@pure
fn bdlm_exp(x) {
    let mut v = x
    if v > 20.0 { v = 20.0 }
    if v < -20.0 { v = -20.0 }
    let mut result = 1.0
    let mut term = 1.0
    let mut i = 1
    while i < 30 {
        term = term * v / to_float(i)
        result = result + term
        i = i + 1
    }
    if result < 0.0 { return 0.0 }
    return result
}

@pure
fn bdlm_log(x) {
    if x <= 0.0 { return -20.0 }
    let mut y = 0.0
    let t = (x - 1.0) / (x + 1.0)
    let t2 = t * t
    let mut term = t
    let mut i = 0
    while i < 15 {
        y = y + term / to_float(2 * i + 1)
        term = term * t2
        i = i + 1
    }
    return 2.0 * y
}

// Taylor cosine on [0, pi/2]
@pure
fn bdlm_cos(x) {
    let mut v = x
    if v < 0.0 { v = 0.0 - v }
    let two_pi = 6.283185307179586
    while v > two_pi { v = v - two_pi }
    let mut sign = 1.0
    let pi = 3.141592653589793
    if v > pi {
        v = two_pi - v
    }
    if v > pi / 2.0 {
        v = pi - v
        sign = -1.0
    }
    let x2 = v * v
    let x4 = x2 * x2
    let x6 = x4 * x2
    let x8 = x6 * x2
    let c = 1.0 - x2 / 2.0 + x4 / 24.0 - x6 / 720.0 + x8 / 40320.0
    return sign * c
}

// ===================================================================
//  Deterministic PRNG (LCG, 31-bit unsigned range)
// ===================================================================

@pure
fn bdlm_lcg_step(state) {
    let a = 1103515245
    let c = 12345
    let m = 2147483648
    let mut s = (state * a + c) % m
    if s < 0 { s = s + m }
    return s
}

// returns [u01, new_state]
@pure
fn bdlm_rand_u01(state) {
    let ns = bdlm_lcg_step(state)
    let f = to_float(ns % 1000000) / 1000000.0
    return [f, ns]
}

// returns [int in [0, n), new_state]
@pure
fn bdlm_rand_int(state, n) {
    let ns = bdlm_lcg_step(state)
    let mut v = ns % n
    if v < 0 { v = v + n }
    return [v, ns]
}

// ===================================================================
//  Vector / matrix utilities
// ===================================================================

@pure
fn bdlm_zeros(n) {
    let mut v = []
    let mut _i = 0
    while _i < n {
    return v
        _i = _i + 1
}

@pure
fn bdlm_zeros_int(n) {
    let mut v = []
    let mut _i = 0
    while _i < n {
    return v
        _i = _i + 1
}

@pure
fn bdlm_ones(n) {
    let mut v = []
    let mut _i = 0
    while _i < n {
    return v
        _i = _i + 1
}

@pure
fn bdlm_mat_zeros(rows, cols) {
    let mut m = []
    let mut _r = 0
    while _r < rows {
    return m
        _r = _r + 1
}

// Deterministic weight init: small range around 0
@pure
fn bdlm_init_weight(rows, cols, seed) {
    let scale = 1.0 / bdlm_sqrt(to_float(cols))
    let mut m = []
    let mut r = 0
    while r < rows {
        let mut row = []
        for c in 0..cols {
            let h = (r * 137 + c * 311 + seed * 7919) % 10007
            let val = (to_float(h) / 10007.0 - 0.5) * 2.0 * scale
            row = row + [val]
        }
        m = m + [row]
        r = r + 1
    }
    return m
}

@pure
fn bdlm_matvec(mat, v) {
    let rows = len(mat)
    let cols = len(v)
    let mut out = []
    let mut r = 0
    while r < rows {
        let mut s = 0.0
        for c in 0..cols { s = s + mat[r][c] * v[c] }
        out = out + [s]
        r = r + 1
    }
    return out
}

@pure
fn bdlm_vec_add(a, b) {
    let n = len(a)
    let mut out = []
    let mut i = 0
    while i < n {
    return out
        i = i + 1
}

// ===================================================================
//  Softmax / argmax / cross-entropy
// ===================================================================

@pure @hot
fn bdlm_softmax(logits, vocab) {
    let mut mx = logits[0]
    let mut i = 1
    while i < vocab {
        if logits[i] > mx { mx = logits[i] }
        i = i + 1
    }
    let mut exps = []
    let mut z = 0.0
    let mut i = 0
    while i < vocab {
        let e = bdlm_exp(logits[i] - mx)
        exps = exps + [e]
        z = z + e
        i = i + 1
    }
    if z < 1.0e-10 { z = 1.0e-10 }
    let mut out = []
    let mut i = 0
    while i < vocab {
    return out
        i = i + 1
}

@pure
fn bdlm_argmax_row(logits, vocab) {
    let mut best = 0
    let mut bv = logits[0]
    let mut i = 1
    while i < vocab {
        if logits[i] > bv {
            bv = logits[i]
            best = i
        }
        i = i + 1
    }
    return best
}

// Cross-entropy over a single row (ignore_index = -1)
@pure
fn bdlm_cross_entropy_row(logits, target, vocab) {
    if target < 0 { return 0.0 }
    let sm = bdlm_softmax(logits, vocab)
    let p = sm[target]
    let mut pp = p
    if pp < 1.0e-10 { pp = 1.0e-10 }
    return 0.0 - bdlm_log(pp)
}

// ===================================================================
//  Cosine noise schedule
//
//  p(t) = (1 - cos(pi/2 * t/T))  (grows monotonically in t)
//  mask_prob = 1 - p(t)          so mask_prob(0)=1, mask_prob(T)=0
//
//  This matches "from fully masked at step 0 → fully revealed at step T".
// ===================================================================

@pure
fn bdlm_cosine_schedule(t, total_t) {
    if total_t <= 0 { return 0.0 }
    let mut ti = t
    if ti < 0 { ti = 0 }
    if ti > total_t { ti = total_t }
    let pi = 3.141592653589793
    let frac = to_float(ti) / to_float(total_t)
    let c = bdlm_cos(pi / 2.0 * frac)
    // p_visible = 1 - c   (actually we use c directly as "mask kept")
    // We want mask_prob so that at t=0 → 1.0, at t=total → 0.0.
    // cos(pi/2 * 0) = 1, cos(pi/2 * 1) = 0
    if c < 0.0 { return 0.0 }
    if c > 1.0 { return 1.0 }
    return c
}

// ===================================================================
//  Time embedding — simple scalar-broadcast time as a "dim"-vector.
//  Even dims get sin-like (via cos(...)*2-1), odd dims get cos-like.
//  Tests only rely on dim correctness.
// ===================================================================

@pure
fn bdlm_time_embedding(t, total_t, dim) {
    let mut v = []
    if total_t <= 0 {
        let mut _i = 0
        while _i < dim {
        return v
            _i = _i + 1
    }
    let frac = to_float(t) / to_float(total_t)
    let pi = 3.141592653589793
    let mut i = 0
    while i < dim {
        let freq = to_float(i + 1)
        let phase = 2.0 * pi * frac * freq / to_float(dim + 1)
        v = v + [bdlm_cos(phase)]
        i = i + 1
    }
    return v
}

// ===================================================================
//  Mask block
//
//  Replaces each token position in [block_start, block_end) with
//  `mask_id` with probability `mask_prob` using a deterministic LCG.
//  Returns [new_tokens, mask_positions] where mask_positions[i]==1
//  means position i was masked.
// ===================================================================

@pure
fn bdlm_mask_block(tokens, block_start, block_end, mask_prob, mask_id, seed) {
    let n = len(tokens)
    let mut out = []
    let mut i = 0
    while i < n {
    let mut mask_pos = bdlm_zeros_int(n)
    let mut state = seed + block_start * 7919 + block_end * 1315
    if state < 0 { state = 0 - state }
    for i in block_start..block_end {
        let r = bdlm_rand_u01(state)
        state = r[1]
        if r[0] < mask_prob {
            out[i] = mask_id
            mask_pos[i] = 1
        }
    }
    let res = [out, mask_pos]
    return res
        i = i + 1
}

// ===================================================================
//  Noise sample — n random token ids in [0, vocab)
// ===================================================================

@pure
fn bdlm_noise_sample(vocab, n, seed) {
    let mut out = []
    let mut state = seed + 9173
    if state < 0 { state = 0 - state }
    let mut _i = 0
    while _i < n {
        let r = bdlm_rand_int(state, vocab)
        out = out + [r[0]]
        state = r[1]
        _i = _i + 1
    }
    return out
}

// ===================================================================
//  Denoiser — lookup embed[token] + time_bias, project via unembed.
//
//  denoiser = #{
//    "vocab": V,
//    "dim":   D,
//    "embed": [[float]] shape [V][D]
//    "unembed": [[float]] shape [V][D]  (used as logits = W·h)
//  }
// ===================================================================

fn bdlm_create_denoiser(vocab, dim) {
    let seed = vocab * 131 + dim * 17 + 41
    let emb = bdlm_init_weight(vocab, dim, seed + 1)
    let un = bdlm_init_weight(vocab, dim, seed + 2)
    let d = #{
        "vocab": vocab,
        "dim": dim,
        "embed": emb,
        "unembed": un
    }
    return d
}

// Forward: returns logits [n][vocab].
// For each token, hidden = embed[token] + time_embed (broadcast add).
// logits_row = unembed @ hidden.
@pure
fn bdlm_denoiser_forward(denoiser, noisy_tokens, time_embed) {
    let V = denoiser["vocab"]
    let D = denoiser["dim"]
    let E = denoiser["embed"]
    let U = denoiser["unembed"]
    let n = len(noisy_tokens)
    let mut out = []
    let mut i = 0
    while i < n {
        let tok = noisy_tokens[i]
        let mut h = []
        // embed[tok] may be out of range defensively
        let mut tix = tok
        if tix < 0 { tix = 0 }
        if tix >= V { tix = V - 1 }
        let row = E[tix]
        for d in 0..D {
            h = h + [row[d] + time_embed[d]]
        }
        let logits = bdlm_matvec(U, h)
        out = out + [logits]
        i = i + 1
    }
    return out
}

// ===================================================================
//  Loss — masked cross-entropy
//
//  Only positions where mask_positions[i]==1 contribute. Returns the
//  MEAN over the masked positions (0.0 if no masked positions).
// ===================================================================

@pure
fn bdlm_compute_loss(denoiser, clean_tokens, mask_positions, vocab) {
    let n = len(clean_tokens)
    let D = denoiser["dim"]
    let t_emb = bdlm_zeros(D)
    let logits = bdlm_denoiser_forward(denoiser, clean_tokens, t_emb)
    let mut total = 0.0
    let mut count = 0
    let mut i = 0
    while i < n {
        if mask_positions[i] == 1 {
            let ce = bdlm_cross_entropy_row(logits[i], clean_tokens[i], vocab)
            total = total + ce
            count = count + 1
        }
        i = i + 1
    }
    if count == 0 { return 0.0 }
    return total / to_float(count)
}

// ===================================================================
//  Top-K reveal
//
//  Given per-position logits [n][vocab] and the set of currently
//  masked positions (1 = masked, 0 = visible), return the indices of
//  the top-k masked positions with the highest prediction confidence
//  (max softmax probability).
// ===================================================================

@pure
fn bdlm_reveal_top_k(denoiser_logits, masked_positions, k) {
    let n = len(masked_positions)
    let vocab = if n > 0 { len(denoiser_logits[0]) } else { 0 }
    // confidence for each masked position
    let mut cands = []
    let mut i = 0
    while i < n {
        if masked_positions[i] == 1 {
            let sm = bdlm_softmax(denoiser_logits[i], vocab)
            let mut mx = sm[0]
            for j in 1..vocab {
                if sm[j] > mx { mx = sm[j] }
            }
            cands = cands + [[i, mx]]
        }
        i = i + 1
    }
    // Simple selection sort: pick top k by confidence (descending).
    let mut picked = []
    let mut pool = cands
    let want = if k > len(pool) { len(pool) } else { k }
    let mut _s = 0
    while _s < want {
        let mut bi = 0
        let mut bv = 0.0 - 1.0
        for j in 0..len(pool) {
            let c = pool[j][1]
            if c > bv {
                bv = c
                bi = j
            }
        }
        picked = picked + [pool[bi][0]]
        let mut new_pool = []
        for j in 0..len(pool) {
            if j != bi { new_pool = new_pool + [pool[j]] }
        }
        pool = new_pool
        _s = _s + 1
    }
    return picked
}

// ===================================================================
//  One mask-predict step
//
//  Given a partial sequence (with mask_id at masked positions) and a
//  mask_positions vector, compute the denoiser prediction, reveal the
//  top-k most confident positions (k depends on schedule progress),
//  and return the updated [partial, mask_positions].
// ===================================================================

fn bdlm_step(denoiser, partial, mask_positions, t, total_t, block_size, vocab, seed) {
    let D = denoiser["dim"]
    let t_emb = bdlm_time_embedding(t, total_t, D)
    let logits = bdlm_denoiser_forward(denoiser, partial, t_emb)
    // how many to reveal this step? roughly block_size / total_t, at least 1
    let mut k = block_size / total_t
    if k < 1 { k = 1 }
    let reveal = bdlm_reveal_top_k(logits, mask_positions, k)
    let mut new_partial = partial
    let mut new_mask = mask_positions
    let mut r = 0
    while r < len(reveal) {
        let idx = reveal[r]
        let pred = bdlm_argmax_row(logits[idx], vocab)
        new_partial[idx] = pred
        new_mask[idx] = 0
        r = r + 1
    }
    // seed is accepted for API symmetry (determinism already wired).
    let _drop_seed = seed
    let res = [new_partial, new_mask]
    return res
}

// ===================================================================
//  Mask-predict sampling — fully generate a sequence
//
//  Starts from a fully masked sequence, runs n_steps reveal passes,
//  and guarantees all positions are revealed at the end.
// ===================================================================

fn bdlm_mask_predict_sample(denoiser, seq_len, n_steps, block_size, vocab, seed) {
    let mask_id = vocab - 1
    // start: all positions masked
    let mut seq = []
    let mut _i = 0
    while _i < seq_len {
    let mut mask_pos = []
    for _i in 0..seq_len { mask_pos = mask_pos + [1] }
    let mut total = n_steps
    if total < 1 { total = 1 }
    for t in 0..total {
        let t_step = total - t
        let res = bdlm_step(denoiser, seq, mask_pos, t_step, total, seq_len, vocab, seed + t)
        seq = res[0]
        mask_pos = res[1]
    }
    // Safety: if any positions still masked (shouldn't happen after n_steps
    // >= seq_len), greedy-fill them.
    let D = denoiser["dim"]
    let t_emb = bdlm_zeros(D)
    let logits = bdlm_denoiser_forward(denoiser, seq, t_emb)
    for i in 0..seq_len {
        if mask_pos[i] == 1 {
            seq[i] = bdlm_argmax_row(logits[i], vocab)
            mask_pos[i] = 0
        }
    }
    return seq
        _i = _i + 1
}

// ===================================================================
//  Block-parallel generation
//
//  Walk the sequence in blocks of `block_size` and denoise each block
//  independently. Returns a full sequence of length seq_len.
// ===================================================================

fn bdlm_block_parallel_generate(denoiser, seq_len, block_size, vocab, seed) {
    let bs = if block_size < 1 { 1 } else { block_size }
    let mask_id = vocab - 1
    let mut seq = []
    let mut _i = 0
    while _i < seq_len {
    let mut pos = 0
    let mut blk = 0
    while pos < seq_len {
        let mut end = pos + bs
        if end > seq_len { end = seq_len }
        let n_steps = bs
        // denoise this block in isolation: treat seq[pos..end] as fully
        // masked and fill it using the denoiser.
        let mut block_seq = []
        for i in pos..end { block_seq = block_seq + [seq[i]] }
        let gen = bdlm_mask_predict_sample(denoiser, len(block_seq), n_steps, bs, vocab, seed + blk * 101)
        for i in 0..len(gen) { seq[pos + i] = gen[i] }
        pos = end
        blk = blk + 1
    }
    return seq
        _i = _i + 1
}

// ===================================================================
//  Param count (for sanity / diagnostics)
// ===================================================================

@pure
fn bdlm_param_count(denoiser) {
    let V = denoiser["vocab"]
    let D = denoiser["dim"]
    return 2 * V * D
}


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check(idx, name, cond) {
    if cond {
        println("[PASS] #" + str(idx) + " " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] #" + str(idx) + " " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx(a, b, eps) { return fabs(a - b) < eps }

println("=== Block Diffusion LM Tests ===")

// ── shared fixtures ─────────────────────────────────────────────
let VOCAB = 12
let DIM = 6
let SEQ = 8
let BLOCK = 4
let TOTAL_T = 4
let SEED = 1234

let denoiser = bdlm_create_denoiser(VOCAB, DIM)

// ===================================================================
//  #1-#5 Cosine schedule
// ===================================================================

let p0 = bdlm_cosine_schedule(0, TOTAL_T)
check(1, "cosine_schedule prob[0] ~ 1.0", approx(p0, 1.0, 0.001))

let pT = bdlm_cosine_schedule(TOTAL_T, TOTAL_T)
check(2, "cosine_schedule prob[total_t] ~ 0.0", approx(pT, 0.0, 0.001))

let mut mono_ok = true
let mut prev = bdlm_cosine_schedule(0, TOTAL_T)
let mut t = 1

while t < (TOTAL_T + 1) {
    let cur = bdlm_cosine_schedule(t, TOTAL_T)
    if cur > prev + 0.0001 { mono_ok = false }
    prev = cur
}
check(3, "cosine_schedule monotone decreasing", mono_ok)

let p_mid = bdlm_cosine_schedule(TOTAL_T / 2, TOTAL_T)
check(4, "cosine_schedule intermediate in (0,1)", p_mid > 0.01 && p_mid < 0.99)

let p_def = bdlm_cosine_schedule(0, 0)
check(5, "cosine_schedule total_t=0 defensive", p_def >= 0.0 && p_def <= 1.0)

// ===================================================================
//  #6-#11 Mask block
// ===================================================================

let clean = [1, 2, 3, 4, 5, 6, 7, 8]
let MASK_ID = VOCAB - 1

let r_half = bdlm_mask_block(clean, 2, 6, 0.5, MASK_ID, SEED)
let masked_half = r_half[0]
let mpos_half = r_half[1]

// Non-block positions should equal original
let mut non_block_preserved = true
let mut i = 0

while i < len(clean) {
    if i < 2 || i >= 6 {
        if masked_half[i] != clean[i] { non_block_preserved = false }
    }
}
check(6, "mask_block preserves non-block tokens", non_block_preserved)

// Where mpos==1, token==MASK_ID
let mut mask_correct = true
let mut i = 0

while i < len(masked_half) {
    if mpos_half[i] == 1 {
        if masked_half[i] != MASK_ID { mask_correct = false }
    }
}
check(7, "mask_block masked positions use mask_id", mask_correct)

let r_none = bdlm_mask_block(clean, 2, 6, 0.0, MASK_ID, SEED)
let mn = r_none[0]
let mut none_masked = true
let mut i = 0

while i < len(clean) {
    if mn[i] != clean[i] { none_masked = false }
}
check(8, "mask_block mask_prob=0 no masking", none_masked)

let r_all = bdlm_mask_block(clean, 2, 6, 1.0, MASK_ID, SEED)
let mall = r_all[0]
let mall_pos = r_all[1]
let mut all_block_masked = true
let mut i = 2

while i < 6 {
    if mall[i] != MASK_ID { all_block_masked = false }
    if mall_pos[i] != 1 { all_block_masked = false }
}
check(9, "mask_block mask_prob=1 all block masked", all_block_masked)

let r_seed_a = bdlm_mask_block(clean, 0, 8, 0.5, MASK_ID, 11)
let r_seed_b = bdlm_mask_block(clean, 0, 8, 0.5, MASK_ID, 99)
let mut diff_seed = false
let mut i = 0

while i < len(clean) {
    if r_seed_a[1][i] != r_seed_b[1][i] { diff_seed = true }
}
check(10, "mask_block different seeds -> different masks", diff_seed)

let r_same_a = bdlm_mask_block(clean, 0, 8, 0.5, MASK_ID, 77)
let r_same_b = bdlm_mask_block(clean, 0, 8, 0.5, MASK_ID, 77)
let mut same_seed_ok = true
let mut i = 0

while i < len(clean) {
    if r_same_a[0][i] != r_same_b[0][i] { same_seed_ok = false }
    if r_same_a[1][i] != r_same_b[1][i] { same_seed_ok = false }
}
check(11, "mask_block seed determinism", same_seed_ok)

// ===================================================================
//  #12-#14 Noise sample
// ===================================================================

let ns = bdlm_noise_sample(VOCAB, 10, 42)
check(12, "noise_sample length correct", len(ns) == 10)

let mut ns_in_range = true
let mut i = 0

while i < len(ns) {
    if ns[i] < 0 || ns[i] >= VOCAB { ns_in_range = false }
}
check(13, "noise_sample values in [0, vocab)", ns_in_range)

let ns2 = bdlm_noise_sample(VOCAB, 10, 42)
let mut ns_det = true
let mut i = 0

while i < 10 {
    if ns[i] != ns2[i] { ns_det = false }
}
check(14, "noise_sample seed determinism", ns_det)

// ===================================================================
//  #15-#16 Time embedding
// ===================================================================

let te0 = bdlm_time_embedding(0, TOTAL_T, DIM)
check(15, "time_embedding dim correct", len(te0) == DIM)

let te1 = bdlm_time_embedding(2, TOTAL_T, DIM)
let mut te_diff = false
let mut i = 0

while i < DIM {
    if fabs(te0[i] - te1[i]) > 1.0e-6 { te_diff = true }
}
check(16, "time_embedding varies with t", te_diff)

// ===================================================================
//  #17-#19 Denoiser creation
// ===================================================================

check(17, "create_denoiser has fields", denoiser["vocab"] == VOCAB && denoiser["dim"] == DIM)

let emb = denoiser["embed"]
check(18, "create_denoiser embed shape [V,D]", len(emb) == VOCAB && len(emb[0]) == DIM)

let un = denoiser["unembed"]
check(19, "create_denoiser unembed shape [V,D]", len(un) == VOCAB && len(un[0]) == DIM)

// ===================================================================
//  #20-#21 Denoiser forward
// ===================================================================

let ntoks = [0, 1, 2, 3, 4]
let te_fwd = bdlm_time_embedding(1, TOTAL_T, DIM)
let logits = bdlm_denoiser_forward(denoiser, ntoks, te_fwd)
check(20, "denoiser_forward output shape [n,vocab]", len(logits) == 5 && len(logits[0]) == VOCAB)

let logits2 = bdlm_denoiser_forward(denoiser, ntoks, te_fwd)
let mut fwd_det = true
let mut i = 0

while i < 5 {
    let mut j = 0

    while j < VOCAB {
        if fabs(logits[i][j] - logits2[i][j]) > 1.0e-9 { fwd_det = false }
    }
}
check(21, "denoiser_forward deterministic", fwd_det)

// ===================================================================
//  #22-#24 Softmax / argmax
// ===================================================================

let sm = bdlm_softmax(logits[0], VOCAB)
let mut sm_sum = 0.0
let mut sm_nonneg = true
let mut i = 0

while i < VOCAB {
    sm_sum = sm_sum + sm[i]
    if sm[i] < 0.0 { sm_nonneg = false }
}
check(22, "softmax sums to 1.0", approx(sm_sum, 1.0, 0.001))
check(23, "softmax non-negative", sm_nonneg)

let am_in = [0.1, 0.5, 0.9, 0.3, 0.7]
check(24, "argmax_row picks index 2", bdlm_argmax_row(am_in, 5) == 2)

// ===================================================================
//  #25-#26 Compute loss
// ===================================================================

let clean_tokens = [0, 1, 2, 3]
let mask_pos_loss = [0, 1, 1, 0]
let loss = bdlm_compute_loss(denoiser, clean_tokens, mask_pos_loss, VOCAB)
check(25, "compute_loss > 0 for untrained denoiser", loss > 0.0)

let zero_mask = [0, 0, 0, 0]
let loss_zero = bdlm_compute_loss(denoiser, clean_tokens, zero_mask, VOCAB)
check(26, "compute_loss zero when no masked positions", approx(loss_zero, 0.0, 1.0e-9))

// ===================================================================
//  #27-#29 Reveal top-k
// ===================================================================

// Build synthetic logits where position 0 is very confident (large max),
// position 1 is moderate, position 2 is flat, position 3 is moderate.
let mut synth = []
let mut i = 0

while i < 4 {
    let mut row = []
    let mut j = 0

    while j < VOCAB {
        if i == 0 && j == 3 { row = row + [100.0] }
        else { if i == 1 && j == 5 { row = row + [5.0] }
               else { if i == 3 && j == 2 { row = row + [2.0] }
                      else { row = row + [0.0] } } }
    }
    synth = synth + [row]
}
let all_masked = [1, 1, 1, 1]
let picks2 = bdlm_reveal_top_k(synth, all_masked, 2)
check(27, "reveal_top_k length = k", len(picks2) == 2)

// position 0 should definitely be picked first (max logit 100)
let mut has0 = false
let mut p = 0

while p < len(picks2) {
    if picks2[p] == 0 { has0 = true }
}
check(28, "reveal_top_k picks highest-confidence (position 0)", has0)

let picks_big = bdlm_reveal_top_k(synth, all_masked, 99)
check(29, "reveal_top_k handles k > masked", len(picks_big) == 4)

// ===================================================================
//  #30-#31 bdlm_step
// ===================================================================

let mut partial = [MASK_ID, MASK_ID, MASK_ID, MASK_ID]
let mpos_step = [1, 1, 1, 1]
let step_res = bdlm_step(denoiser, partial, mpos_step, 1, 4, 4, VOCAB, 7)
let new_seq = step_res[0]
let new_mp = step_res[1]
let mut revealed = 0
let mut i = 0

while i < 4 {
    if new_mp[i] == 0 { revealed = revealed + 1 }
}
check(30, "bdlm_step reveals at least one position", revealed >= 1)

// Pre-seed a visible token; step must not overwrite it.
let mixed = [5, MASK_ID, MASK_ID, MASK_ID]
let mixed_mp = [0, 1, 1, 1]
let step_mix = bdlm_step(denoiser, mixed, mixed_mp, 1, 4, 4, VOCAB, 9)
check(31, "bdlm_step preserves non-masked tokens", step_mix[0][0] == 5)

// ===================================================================
//  #32-#34 mask_predict_sample
// ===================================================================

let gen = bdlm_mask_predict_sample(denoiser, SEQ, TOTAL_T, BLOCK, VOCAB, SEED)
check(32, "mask_predict_sample length = seq_len", len(gen) == SEQ)

let mut gen_in_range = true
let mut i = 0

while i < SEQ {
    if gen[i] < 0 || gen[i] >= VOCAB { gen_in_range = false }
}
check(33, "mask_predict_sample tokens in [0,vocab)", gen_in_range)

// After sampling, none of the tokens should remain == MASK_ID unless the
// denoiser genuinely argmax'd MASK_ID (unlikely for random weights). We
// check the weaker condition: all positions are deterministic.
let gen_again = bdlm_mask_predict_sample(denoiser, SEQ, TOTAL_T, BLOCK, VOCAB, SEED)
let mut gen_det = true
let mut i = 0

while i < SEQ {
    if gen[i] != gen_again[i] { gen_det = false }
}
check(34, "mask_predict_sample deterministic", gen_det)

// ===================================================================
//  #35-#37 block_parallel_generate
// ===================================================================

let bp = bdlm_block_parallel_generate(denoiser, SEQ, BLOCK, VOCAB, SEED)
check(35, "block_parallel_generate length = seq_len", len(bp) == SEQ)

let mut bp_in_range = true
let mut i = 0

while i < SEQ {
    if bp[i] < 0 || bp[i] >= VOCAB { bp_in_range = false }
}
check(36, "block_parallel_generate tokens in [0,vocab)", bp_in_range)

let bp2 = bdlm_block_parallel_generate(denoiser, SEQ, BLOCK, VOCAB, SEED)
let mut bp_det = true
let mut i = 0

while i < SEQ {
    if bp[i] != bp2[i] { bp_det = false }
}
check(37, "block_parallel_generate seed determinism", bp_det)

// ===================================================================
//  #38 param count
// ===================================================================

let pc = bdlm_param_count(denoiser)
check(38, "param_count > 0", pc > 0)

// ── summary ─────────────────────────────────────────────────────
println("")
println("=== Block Diffusion LM test summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
