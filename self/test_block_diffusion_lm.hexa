//    #21 denoiser_forward deterministic
//    #22 softmax sums to 1.0 per row
//    #23 softmax all non-negative
//    #24 argmax_row picks largest
//    #25 compute_loss positive for untrained denoiser
//    #26 compute_loss zero when no masked positions
//    #27 reveal_top_k picks k positions
//    #28 reveal_top_k picks highest-confidence positions
