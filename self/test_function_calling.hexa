// ===================================================================
//  self/ml/function_calling.hexa — Function Calling / Tool Use
//
//  Pure Hexa implementation of LLM function calling (tool use).
//
//  Pipeline:
//    1. Define tools (name, description, JSON schema params)
//    2. Format tool definitions into system prompt
//    3. Generate model output
//    4. Parse <tool_call>...</tool_call> blocks from output
//    5. Execute tools via user-supplied executor
//    6. Inject results back into conversation
//    7. Loop until model produces final response (no tool calls)
//
//  Public API:
//    define_tool(name, desc, params)         -> Tool (map)
//    define_param(name, type_str, desc, req) -> Param (map)
//    format_tools_prompt(tools)              -> str
//    parse_tool_calls(text)                  -> array of ToolCall
//    inject_tool_result(conversation, call, result) -> conversation
//    run_tool_loop(generate_fn, tools, executor, prompt, max_rounds) -> str
//
//  Conventions:
//    - Tool call format: <tool_call>{"name":"...", "arguments":{...}}</tool_call>
//    - Tool result format: <tool_result>{"name":"...", "result":"..."}</tool_result>
//    - Uses #{} map literals (no {k:v} inside if blocks)
// ===================================================================

// ===================================================================
//  Tool & Param structs (as maps)
// ===================================================================

fn define_param(name, type_str, description, required) {
    let p = #{}
    p["name"] = name
    p["type"] = type_str
    p["description"] = description
    p["required"] = required
    return p
}

fn define_tool(name, description, params) {
    let t = #{}
    t["name"] = name
    t["description"] = description
    t["parameters"] = params
    return t
}

// ===================================================================
//  Format a single parameter as JSON schema string
// ===================================================================
fn format_param_json(param) {
    let mut s = "\"" + param["name"] + "\": "
    s = s + "{\"type\": \"" + param["type"] + "\""
    s = s + ", \"description\": \"" + param["description"] + "\""
    s = s + "}"
    return s
}

// ===================================================================
//  Format a single tool definition as JSON string
// ===================================================================
fn format_tool_json(tool) {
    let mut s = "{\n"
    s = s + "  \"name\": \"" + tool["name"] + "\",\n"
    s = s + "  \"description\": \"" + tool["description"] + "\",\n"
    s = s + "  \"parameters\": {\n"
    s = s + "    \"type\": \"object\",\n"
    s = s + "    \"properties\": {\n"

    let params = tool["parameters"]
    let n = len(params)
    let mut i = 0
    while i < n {
        s = s + "      " + format_param_json(params[i])
        if i < n - 1 {
            s = s + ","
        }
        s = s + "\n"
        i = i + 1
    }

    s = s + "    },\n"

    // required list
    s = s + "    \"required\": ["
    let mut req_parts = []
    i = 0
    while i < n {
        if params[i]["required"] {
            req_parts = req_parts + ["\"" + params[i]["name"] + "\""]
        }
        i = i + 1
    }
    s = s + req_parts.join(", ")
    s = s + "]\n"

    s = s + "  }\n"
    s = s + "}"
    return s
}

// ===================================================================
//  Format all tools into a system prompt section
// ===================================================================
fn format_tools_prompt(tools) {
    let mut s = "You have access to the following tools:\n\n"
    let n = len(tools)
    let mut i = 0
    while i < n {
        s = s + format_tool_json(tools[i])
        if i < n - 1 {
            s = s + "\n\n"
        }
        i = i + 1
    }
    s = s + "\n\nTo use a tool, respond with:\n"
    s = s + "<tool_call>{\"name\": \"tool_name\", \"arguments\": {\"arg\": \"value\"}}</tool_call>\n"
    s = s + "You may make multiple tool calls in a single response.\n"
    s = s + "After receiving tool results, provide your final answer."
    return s
}

// ===================================================================
//  String search helpers (self-contained, no import needed)
// ===================================================================
fn _fc_index_of(s, needle, start) {
    let sn = len(s)
    let nn = len(needle)
    if nn == 0 { return start }
    if nn > sn { return 0 - 1 }
    let limit = sn - nn
    let mut i = start
    while i <= limit {
        let mut j = 0
        let mut ok = true
        while j < nn {
            if s[i + j] != needle[j] {
                ok = false
                j = nn
            }
            j = j + 1
        }
        if ok { return i }
        i = i + 1
    }
    return 0 - 1
}

fn _fc_contains(s, needle) {
    return _fc_index_of(s, needle, 0) >= 0
}

// ===================================================================
//  Minimal JSON value extractor
//  Extract string value for a given key from a flat JSON object
//  NOTE: break inside if does not work in hexa — use flag variables
// ===================================================================
fn _fc_extract_json_str(json_str, key) {
    let search = "\"" + key + "\""
    let idx = _fc_index_of(json_str, search, 0)
    if idx < 0 { return "" }

    let after_key = idx + len(search)
    let sn = len(json_str)

    // find first colon position after the key
    let mut colon_pos = 0 - 1
    let mut ci = after_key
    while ci < sn {
        if json_str[ci] == ':' {
            if colon_pos < 0 { colon_pos = ci }
        }
        ci = ci + 1
    }
    if colon_pos < 0 { return "" }

    // skip whitespace after colon
    let mut vi = colon_pos + 1
    while vi < sn {
        if json_str[vi] != ' ' { return _fc_read_quoted(json_str, vi, sn) }
        vi = vi + 1
    }
    return ""
}

// Read a quoted string starting at position pos (char literals for comparison)
fn _fc_read_quoted(s, pos, sn) {
    if pos >= sn { return "" }
    if s[pos] != '"' { return "" }
    let start = pos + 1
    let mut ei = start
    while ei < sn {
        if s[ei] == '"' {
            return s.substring(start, ei)
        }
        ei = ei + 1
    }
    return ""
}

// ===================================================================
//  Extract the JSON object substring for "arguments" key
// ===================================================================
fn _fc_extract_arguments(json_str) {
    let search = "\"arguments\""
    let idx = _fc_index_of(json_str, search, 0)
    if idx < 0 { return "{}" }

    let after_key = idx + len(search)
    let sn = len(json_str)

    // find first colon position after the key
    let mut colon_pos = 0 - 1
    let mut ci = after_key
    while ci < sn {
        if json_str[ci] == ':' {
            if colon_pos < 0 { colon_pos = ci }
        }
        ci = ci + 1
    }
    if colon_pos < 0 { return "{}" }

    // skip whitespace after colon
    let mut vi = colon_pos + 1
    while vi < sn {
        if json_str[vi] != ' ' { return _fc_read_object(json_str, vi, sn) }
        vi = vi + 1
    }
    return "{}"
}

// Read a JSON object {...} starting at position pos, with brace matching
fn _fc_read_object(s, pos, sn) {
    if pos >= sn { return "{}" }
    if s[pos] != '{' { return "{}" }
    let start = pos
    let mut depth = 0
    let mut ei = pos
    while ei < sn {
        if s[ei] == '{' { depth = depth + 1 }
        if s[ei] == '}' { depth = depth - 1 }
        if depth == 0 {
            return s.substring(start, ei + 1)
        }
        ei = ei + 1
    }
    return "{}"
}

// ===================================================================
//  Parse tool calls from model output text
//  Looks for <tool_call>...</tool_call> blocks
//  Returns array of maps with "name" and "arguments" keys
// ===================================================================
fn parse_tool_calls(text) {
    let open_tag = "<tool_call>"
    let close_tag = "</tool_call>"
    let open_len = len(open_tag)
    let close_len = len(close_tag)
    let text_len = len(text)

    let mut calls = []
    let mut pos = 0

    while pos < text_len {
        let start = _fc_index_of(text, open_tag, pos)
        if start < 0 {
            pos = text_len
        } else {
            let content_start = start + open_len
            let end = _fc_index_of(text, close_tag, content_start)
            if end < 0 {
                pos = text_len
            } else {
                let json_body = text.substring(content_start, end).trim()
                let name = _fc_extract_json_str(json_body, "name")
                let arguments = _fc_extract_arguments(json_body)

                let call = #{}
                call["name"] = name
                call["arguments"] = arguments
                call["raw"] = json_body
                calls = calls + [call]

                pos = end + close_len
            }
        }
    }

    return calls
}

// ===================================================================
//  Check if text contains any tool call
// ===================================================================
fn has_tool_calls(text) {
    return _fc_contains(text, "<tool_call>")
}

// ===================================================================
//  Extract non-tool-call text (the "thinking" or final answer part)
// ===================================================================
fn extract_text_outside_calls(text) {
    let open_tag = "<tool_call>"
    let close_tag = "</tool_call>"
    let close_len = len(close_tag)
    let text_len = len(text)

    let mut parts = []
    let mut pos = 0

    while pos < text_len {
        let start = _fc_index_of(text, open_tag, pos)
        if start < 0 {
            // rest of string is plain text
            parts = parts + [text.substring(pos, text_len)]
            pos = text_len
        } else {
            // text before the tool call
            if start > pos {
                parts = parts + [text.substring(pos, start)]
            }
            let end = _fc_index_of(text, close_tag, start)
            if end < 0 {
                pos = text_len
            } else {
                pos = end + close_len
            }
        }
    }

    return parts.join("").trim()
}

// ===================================================================
//  Build a tool result message
// ===================================================================
fn format_tool_result(call_name, result_str) {
    let mut s = "<tool_result>"
    s = s + "{\"name\": \"" + call_name + "\""
    s = s + ", \"result\": \"" + result_str + "\"}"
    s = s + "</tool_result>"
    return s
}

// ===================================================================
//  Inject tool result into conversation
//  conversation: array of maps with "role" and "content"
//  Returns new conversation array with assistant message + tool result
// ===================================================================
fn inject_tool_result(conversation, assistant_text, call, result_str) {
    let mut conv = conversation

    // Add assistant message (the model's output that contained tool calls)
    let asst_msg = #{}
    asst_msg["role"] = "assistant"
    asst_msg["content"] = assistant_text
    conv = conv + [asst_msg]

    // Add tool result as a "tool" role message
    let tool_msg = #{}
    tool_msg["role"] = "tool"
    tool_msg["content"] = format_tool_result(call["name"], result_str)
    conv = conv + [tool_msg]

    return conv
}

// ===================================================================
//  Build conversation into a single prompt string
//  Simple format: [system]\n...\n[user]\n...\n[assistant]\n...
// ===================================================================
fn conversation_to_prompt(conversation) {
    let n = len(conversation)
    let mut parts = []
    let mut i = 0
    while i < n {
        let msg = conversation[i]
        let role = msg["role"]
        let content = msg["content"]
        parts = parts + ["[" + role + "]\n" + content]
        i = i + 1
    }
    return parts.join("\n\n")
}

// ===================================================================
//  Run tool call loop
//
//  generate_fn: fn(prompt) -> str  (generates model response)
//  tools:       array of Tool maps
//  executor:    fn(name, arguments_json) -> str  (executes a tool)
//  prompt:      initial user prompt string
//  max_rounds:  maximum tool call rounds before forced stop
//
//  Returns the final response text (after all tools resolved)
// ===================================================================
fn run_tool_loop(generate_fn, tools, executor, prompt, max_rounds) {
    let system_prompt = format_tools_prompt(tools)

    // Build initial conversation
    let sys_msg = #{}
    sys_msg["role"] = "system"
    sys_msg["content"] = system_prompt

    let user_msg = #{}
    user_msg["role"] = "user"
    user_msg["content"] = prompt

    let mut conversation = [sys_msg, user_msg]

    let mut round = 0
    while round < max_rounds {
        let full_prompt = conversation_to_prompt(conversation)
        let response = generate_fn(full_prompt)

        if has_tool_calls(response) {
            let calls = parse_tool_calls(response)
            let n_calls = len(calls)

            // Execute each tool call and inject results
            let mut ci = 0
            while ci < n_calls {
                let call = calls[ci]
                let result = executor(call["name"], call["arguments"])
                conversation = inject_tool_result(conversation, response, call, result)
                ci = ci + 1
            }
        } else {
            // No tool calls — this is the final response
            return response
        }

        round = round + 1
    }

    // Max rounds exceeded — return last generation
    let last_prompt = conversation_to_prompt(conversation)
    return generate_fn(last_prompt)
}

// ===================================================================
//  Validate tool call against defined tools
//  Returns true if tool name exists in the tools array
// ===================================================================
fn validate_tool_call(call, tools) {
    let call_name = call["name"]
    let n = len(tools)
    let mut i = 0
    while i < n {
        if tools[i]["name"] == call_name {
            return true
        }
        i = i + 1
    }
    return false
}

// ===================================================================
//  Find tool by name
// ===================================================================
fn find_tool(name, tools) {
    let n = len(tools)
    let mut i = 0
    while i < n {
        if tools[i]["name"] == name {
            return tools[i]
        }
        i = i + 1
    }
    let empty = #{}
    return empty
}

// Check if a find_tool result is a valid (non-empty) tool
fn is_tool_found(result) {
    return len(keys(result)) > 0
}

println("[function_calling] module loaded")


// -- end inlined --

let mut pass = 0
let mut fail = 0

fn check(name, cond) {
    if cond {
        pass = pass + 1
        println("[PASS] " + name)
    } else {
        fail = fail + 1
        println("[FAIL] " + name)
    }
}

// ── 1. define_param creates correct map ───────────────────────
let p1 = define_param("city", "string", "The city name", true)
check("define_param name", p1["name"] == "city")
check("define_param type", p1["type"] == "string")
check("define_param required", p1["required"] == true)

// ── 2. define_tool creates correct map ────────────────────────
let weather_params = [
    define_param("city", "string", "City name", true),
    define_param("unit", "string", "C or F", false)
]
let weather_tool = define_tool("get_weather", "Get current weather for a city", weather_params)
check("define_tool name", weather_tool["name"] == "get_weather")
check("define_tool desc", weather_tool["description"] == "Get current weather for a city")
check("define_tool params len", len(weather_tool["parameters"]) == 2)

// ── 3. format_tools_prompt contains tool name and structure ───
let calc_tool = define_tool("calculate", "Evaluate a math expression", [
    define_param("expression", "string", "Math expression", true)
])
let tools = [weather_tool, calc_tool]
let prompt = format_tools_prompt(tools)
check("format_prompt has get_weather", prompt.contains("get_weather"))
check("format_prompt has calculate", prompt.contains("calculate"))
check("format_prompt has tool_call tag", prompt.contains("<tool_call>"))
check("format_prompt has properties", prompt.contains("properties"))

// ── 4. parse single tool call ─────────────────────────────────
let single_input = "I will check the weather.\n<tool_call>{\"name\": \"get_weather\", \"arguments\": {\"city\": \"Seoul\"}}</tool_call>\nDone."
let calls1 = parse_tool_calls(single_input)
check("parse single call count", len(calls1) == 1)
check("parse single call name", calls1[0]["name"] == "get_weather")
check("parse single call args has city", calls1[0]["arguments"].contains("Seoul"))

// ── 5. parse multiple tool calls ──────────────────────────────
let multi_input = "Let me look up both.\n<tool_call>{\"name\": \"get_weather\", \"arguments\": {\"city\": \"Tokyo\"}}</tool_call>\nAlso:\n<tool_call>{\"name\": \"calculate\", \"arguments\": {\"expression\": \"2+2\"}}</tool_call>"
let calls2 = parse_tool_calls(multi_input)
check("parse multi call count", len(calls2) == 2)
check("parse multi call 1 name", calls2[0]["name"] == "get_weather")
check("parse multi call 2 name", calls2[1]["name"] == "calculate")

// ── 6. parse empty / no tool calls ────────────────────────────
let no_call = "The answer is 42. No tools needed."
let calls3 = parse_tool_calls(no_call)
check("parse no calls", len(calls3) == 0)

// ── 7. parse malformed (unclosed tag) ─────────────────────────
let bad_input = "Here is a broken <tool_call>{\"name\": \"oops\"} without closing tag"
let calls4 = parse_tool_calls(bad_input)
check("parse malformed returns empty", len(calls4) == 0)

// ── 8. has_tool_calls detection ───────────────────────────────
check("has_tool_calls true", has_tool_calls(single_input) == true)
check("has_tool_calls false", has_tool_calls(no_call) == false)

// ── 9. extract_text_outside_calls ─────────────────────────────
let mixed = "Hello <tool_call>{\"name\":\"x\",\"arguments\":{}}</tool_call> World"
let outside = extract_text_outside_calls(mixed)
check("extract outside text", outside == "Hello  World")

// ── 10. format_tool_result ────────────────────────────────────
let result_str = format_tool_result("get_weather", "Sunny 25C")
check("format_result has name", result_str.contains("get_weather"))
check("format_result has result", result_str.contains("Sunny 25C"))
check("format_result has tags", result_str.contains("<tool_result>"))

// ── 11. inject_tool_result builds conversation ────────────────
let sys = #{}
sys["role"] = "system"
sys["content"] = "You are helpful."
let usr = #{}
usr["role"] = "user"
usr["content"] = "What is the weather?"
let conv0 = [sys, usr]

let mock_call = #{}
mock_call["name"] = "get_weather"
mock_call["arguments"] = "{\"city\": \"Seoul\"}"

let conv1 = inject_tool_result(conv0, "Let me check.", mock_call, "Clear 22C")
check("inject adds 2 messages", len(conv1) == 4)
check("inject asst role", conv1[2]["role"] == "assistant")
check("inject tool role", conv1[3]["role"] == "tool")
check("inject tool content has result", conv1[3]["content"].contains("Clear 22C"))

// ── 12. validate_tool_call ────────────────────────────────────
let valid_call = #{}
valid_call["name"] = "get_weather"
check("validate known tool", validate_tool_call(valid_call, tools) == true)

let invalid_call = #{}
invalid_call["name"] = "nonexistent_tool"
check("validate unknown tool", validate_tool_call(invalid_call, tools) == false)

// ── 13. find_tool ─────────────────────────────────────────────
let found = find_tool("calculate", tools)
check("find_tool exists", is_tool_found(found))
check("find_tool name", found["name"] == "calculate")

let not_found = find_tool("bogus", tools)
check("find_tool empty for bogus", is_tool_found(not_found) == false)

// ── 14. conversation_to_prompt ────────────────────────────────
let prompt_out = conversation_to_prompt(conv0)
check("conv_to_prompt has system", prompt_out.contains("[system]"))
check("conv_to_prompt has user", prompt_out.contains("[user]"))
check("conv_to_prompt has content", prompt_out.contains("What is the weather?"))

// ── 15. run_tool_loop with mock generate + executor ───────────
let mut loop_call_count = 0

fn mock_generate(p) {
    loop_call_count = loop_call_count + 1
    if loop_call_count == 1 {
        return "<tool_call>{\"name\": \"calculate\", \"arguments\": {\"expression\": \"3+4\"}}</tool_call>"
    }
    return "The answer is 7."
}

fn mock_executor(name, args) {
    if name == "calculate" {
        return "7"
    }
    return "unknown"
}

let final_resp = run_tool_loop(mock_generate, tools, mock_executor, "What is 3+4?", 5)
check("run_tool_loop final answer", final_resp == "The answer is 7.")
check("run_tool_loop called generate twice", loop_call_count == 2)

