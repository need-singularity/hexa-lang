//  Tests: sorting, searching, mathematical algorithms, data structures
//  Validates HEXA can express real-world algorithms correctly
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_arr(name, actual, expected) {
    if len(actual) != len(expected) {
        println("[FAIL] " + name + " — len mismatch: " + to_string(len(actual)) + " vs " + to_string(len(expected)))
        fail_count = fail_count + 1
        return
    }
    let mut ok = true
    let mut i = 0
    while i < len(actual) {
        if actual[i] != expected[i] {
            ok = false
        }
        i = i + 1
    }
    if ok {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — actual: " + to_string(actual) + ", expected: " + to_string(expected))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA Algorithm Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Bubble Sort ────────────────────────────────────────

println("--- Bubble Sort ---")

fn bubble_sort(arr) {
    let mut a = []
    for x in arr { a = a.push(x) }
    let n = len(a)
    let mut i = 0
    while i < n {
        let mut j = 0
        while j < n - 1 - i {
            if a[j] > a[j + 1] {
                let tmp = a[j]
                a[j] = a[j + 1]
                a[j + 1] = tmp
            }
            j = j + 1
        }
        i = i + 1
    }
    return a
}

check_arr("sort empty", bubble_sort([]), [])
check_arr("sort single", bubble_sort([5]), [5])
check_arr("sort already", bubble_sort([1, 2, 3]), [1, 2, 3])
check_arr("sort reverse", bubble_sort([5, 4, 3, 2, 1]), [1, 2, 3, 4, 5])
check_arr("sort mixed", bubble_sort([3, 1, 4, 1, 5, 9, 2, 6]), [1, 1, 2, 3, 4, 5, 6, 9])

// ── 2. Selection Sort ─────────────────────────────────────

println("")
println("--- Selection Sort ---")

fn selection_sort(arr) {
    let mut a = []
    for x in arr { a = a.push(x) }
    let n = len(a)
    let mut i = 0
    while i < n {
        let mut min_idx = i
        let mut j = i + 1
        while j < n {
            if a[j] < a[min_idx] {
                min_idx = j
            }
            j = j + 1
        }
        if min_idx != i {
            let tmp = a[i]
            a[i] = a[min_idx]
            a[min_idx] = tmp
        }
        i = i + 1
    }
    return a
}

check_arr("sel sort", selection_sort([64, 25, 12, 22, 11]), [11, 12, 22, 25, 64])
check_arr("sel sort neg", selection_sort([3, -1, 4, -1, 5]), [-1, -1, 3, 4, 5])

// ── 3. Binary Search ──────────────────────────────────────

println("")
println("--- Binary Search ---")

fn binary_search(arr, target) {
    let mut lo = 0
    let mut hi = len(arr) - 1
    while lo <= hi {
        let mid = (lo + hi) / 2
        if arr[mid] == target {
            return mid
        }
        if arr[mid] < target {
            lo = mid + 1
        } else {
            hi = mid - 1
        }
    }
    return -1
}

let sorted = [2, 5, 8, 12, 16, 23, 38, 56, 72, 91]
check("bsearch 23", binary_search(sorted, 23), 5)
check("bsearch 2", binary_search(sorted, 2), 0)
check("bsearch 91", binary_search(sorted, 91), 9)
check("bsearch miss", binary_search(sorted, 50), -1)

// ── 4. GCD & Egyptian Fraction ────────────────────────────

println("")
println("--- Number Theory Algorithms ---")

fn gcd(a, b) {
    let mut x = a
    let mut y = b
    while y != 0 {
        let t = y
        y = x % y
        x = t
    }
    return x
}

check("gcd(48,18)", gcd(48, 18), 6)
check("gcd(100,75)", gcd(100, 75), 25)
check("gcd(7,13)", gcd(7, 13), 1)
check("gcd(0,5)", gcd(0, 5), 5)

// Egyptian fraction: greedy algorithm
fn egyptian_fraction(num, den) {
    let mut n = num
    let mut d = den
    let mut parts = []
    while n > 0 {
        let unit = (d + n - 1) / n
        parts = parts.push(unit)
        n = n * unit - d
        d = d * unit
        let g = gcd(n, d)
        if g > 1 {
            n = n / g
            d = d / g
        }
    }
    return parts
}

let ef = egyptian_fraction(3, 7)
check("egypt 3/7 len", len(ef), 3)
check("egypt 3/7[0]", ef[0], 3)

// ── 5. Stack data structure ───────────────────────────────

println("")
println("--- Stack ---")

fn stack_new() { return [] }
fn stack_push(s, val) { return s.push(val) }
fn stack_peek(s) { return s[len(s) - 1] }
fn stack_pop(s) {
    let mut out = []
    let mut i = 0
    while i < len(s) - 1 {
        out = out.push(s[i])
        i = i + 1
    }
    return out
}
fn stack_empty(s) { return len(s) == 0 }

let mut stk = stack_new()
check("stack empty", stack_empty(stk), true)
stk = stack_push(stk, 10)
stk = stack_push(stk, 20)
stk = stack_push(stk, 30)
check("stack peek", stack_peek(stk), 30)
check("stack size", len(stk), 3)
stk = stack_pop(stk)
check("stack after pop", stack_peek(stk), 20)
check("stack size after pop", len(stk), 2)

// ── 6. Queue data structure (two-stack) ───────────────────

println("")
println("--- Queue ---")

fn queue_new() { return [[], []] }
fn queue_enqueue(q, val) {
    return [q[0].push(val), q[1]]
}
fn queue_transfer(q) {
    let mut inbox = q[0]
    let mut outbox = q[1]
    while len(inbox) > 0 {
        outbox = outbox.push(inbox[len(inbox) - 1])
        let mut new_inbox = []
        let mut i = 0
        while i < len(inbox) - 1 {
            new_inbox = new_inbox.push(inbox[i])
            i = i + 1
        }
        inbox = new_inbox
    }
    return [inbox, outbox]
}
fn queue_peek(q) {
    if len(q[1]) == 0 {
        q = queue_transfer(q)
    }
    return q[1][len(q[1]) - 1]
}

let mut q = queue_new()
q = queue_enqueue(q, "first")
q = queue_enqueue(q, "second")
q = queue_enqueue(q, "third")
check("queue peek", queue_peek(q), "first")

// ── 7. Matrix operations ─────────────────────────────────

println("")
println("--- Matrix ---")

fn mat_add(a, b) {
    let mut result = []
    let mut i = 0
    while i < len(a) {
        let mut row = []
        let mut j = 0
        while j < len(a[i]) {
            row = row.push(a[i][j] + b[i][j])
            j = j + 1
        }
        result = result.push(row)
        i = i + 1
    }
    return result
}

let m1 = [[1, 2], [3, 4]]
let m2 = [[5, 6], [7, 8]]
let sum = mat_add(m1, m2)
check("mat_add[0][0]", sum[0][0], 6)
check("mat_add[0][1]", sum[0][1], 8)
check("mat_add[1][0]", sum[1][0], 10)
check("mat_add[1][1]", sum[1][1], 12)

fn mat_trace(m) {
    let mut t = 0
    let mut i = 0
    while i < len(m) {
        t = t + m[i][i]
        i = i + 1
    }
    return t
}
check("trace [[1,2],[3,4]]", mat_trace(m1), 5)

// ── 8. String algorithms ─────────────────────────────────

println("")
println("--- String Algorithms ---")

fn is_palindrome(s) {
    let n = len(s)
    let mut i = 0
    while i < n / 2 {
        if s[i] != s[n - 1 - i] {
            return false
        }
        i = i + 1
    }
    return true
}

check("palindrome aba", is_palindrome("aba"), true)
check("palindrome abcba", is_palindrome("abcba"), true)
check("palindrome abc", is_palindrome("abc"), false)
check("palindrome a", is_palindrome("a"), true)
check("palindrome empty", is_palindrome(""), true)

fn count_char(s, ch) {
    let mut count = 0
    for c in s.chars() {
        if c == ch { count = count + 1 }
    }
    return count
}
check("count e in hello", count_char("hello", 'l'), 2)
check("count a in banana", count_char("banana", 'a'), 3)

// ── 9. Fibonacci variations ───────────────────────────────

println("")
println("--- Fibonacci Variations ---")

// Tribonacci
fn tribonacci(n) {
    if n <= 0 { return 0 }
    if n == 1 { return 0 }
    if n == 2 { return 1 }
    let mut a = 0
    let mut b = 0
    let mut c = 1
    let mut i = 3
    while i <= n {
        let next = a + b + c
        a = b
        b = c
        c = next
        i = i + 1
    }
    return c
}
check("tribonacci(1)", tribonacci(1), 0)
check("tribonacci(2)", tribonacci(2), 1)
check("tribonacci(5)", tribonacci(5), 4)
check("tribonacci(8)", tribonacci(8), 24)

// ── 10. Two-sum problem ───────────────────────────────────

println("")
println("--- Two Sum ---")

fn two_sum(arr, target) {
    let mut i = 0
    while i < len(arr) {
        let mut j = i + 1
        while j < len(arr) {
            if arr[i] + arr[j] == target {
                return [i, j]
            }
            j = j + 1
        }
        i = i + 1
    }
    return [-1, -1]
}

let result = two_sum([2, 7, 11, 15], 9)
check("two_sum[0]", result[0], 0)
check("two_sum[1]", result[1], 1)

let result2 = two_sum([3, 2, 4], 6)
check("two_sum2[0]", result2[0], 1)
check("two_sum2[1]", result2[1], 2)

let result3 = two_sum([1, 2, 3], 99)
check("two_sum miss[0]", result3[0], -1)

