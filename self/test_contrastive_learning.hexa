// ═══════════════════════════════════════════════════════════════
//  test_contrastive_learning.hexa — Contrastive Learning (#171)
//
//  Tests (>= 30):
//    T1  cl_dot product correctness
//    T2  cl_norm of unit vector = 1
//    T3  cl_normalize produces unit vector
//    T4  cl_cosine_sim identical vectors = 1
//    T5  cl_cosine_sim orthogonal vectors = 0
//    T6  cl_exp(0) = 1
//    T7  cl_log(1) ~ 0
//    T8  cl_relu positive passthrough
//    T9  cl_relu negative clipped to 0
//    T10 cl_linear correctness
//    T11 cl_projection_head output is normalized
//    T12 cl_augment produces different output
//    T13 cl_augment preserves approximate magnitude
//    T14 cl_make_positive_pair returns two views
//    T15 positive pair views are similar
//    T16 cl_infonce_loss positive > 0
//    T17 cl_infonce_loss lower for closer positive
//    T18 cl_infonce_batch returns positive loss
//    T19 cl_infonce_batch loss decreases with temperature
//    T20 cl_hard_negatives returns correct count
//    T21 cl_hard_negatives picks most similar
//    T22 cl_infonce_hard returns positive loss
//    T23 cl_in_batch_negatives correct count
//    T24 cl_cross_modal_loss > 0
//    T25 cl_cross_modal_loss symmetric (A,B) ~ (B,A)
//    T26 cl_ntxent_loss equals infonce
//    T27 cl_grad_temperature finite
//    T28 cl_contrastive_accuracy perfect pairs = 1.0
//    T29 cl_alignment_score identical = 1.0
//    T30 cl_uniformity_score finite
//    T31 cl_contrastive_prob in (0,1)
//    T32 cl_margin_loss same class > 0
//    T33 cl_margin_loss different class beyond margin = 0
//    T34 cl_triplet_loss correct
//    T35 cl_sim_matrix diagonal = 1/tau
//    T36 cl_softmax sums to 1
//    T37 cl_scale correctness
//    T38 temperature affects loss magnitude
//
//  Run: cargo run --release -- self/test_contrastive_learning.hexa
// ═══════════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx(a, b, eps) { return fabs(a - b) < eps }

// ── inlined helpers from contrastive_learning.hexa ──────────

fn cl_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn cl_sqrt(x) {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    let mut _i = 0

    while _i < 30 { g = (g + x / g) / 2.0 }
    return g
}

fn cl_exp(x) {
    let mut v = x
    if v > 20.0 { v = 20.0 }
    if v < -20.0 { v = -20.0 }
    let mut result = 1.0
    let mut term = 1.0
    let mut i = 1

    while i < 30 {
        term = term * v / to_float(i)
        result = result + term
    }
    if result < 0.0 { return 0.0 }
    return result
}

fn cl_log(x) {
    if x <= 0.0 { return -20.0 }
    let mut y = 0.0
    if x > 1.0 { y = x / 2.0 }
    if x > 10.0 { y = 2.3 }
    let mut _i = 0

    while _i < 60 {
        let ey = cl_exp(y)
        if ey < 1.0e-15 { y = y + 1.0 } else {
            y = y + (x - ey) / ey
        }
    }
    return y
}

fn cl_zeros(n) {
    let mut v = []
    let mut _i = 0

    while _i < n { v = v + [0.0] }
    return v
}

fn cl_zeros_int(n) {
    let mut v = []
    let mut _i = 0

    while _i < n { v = v + [0] }
    return v
}

fn cl_dot(a, b) {
    let n = len(a)
    let mut s = 0.0
    let mut i = 0

    while i < n { s = s + a[i] * b[i] }
    return s
}

fn cl_norm(v) {
    return cl_sqrt(cl_dot(v, v))
}

fn cl_normalize(v) {
    let n = len(v)
    let nrm = cl_norm(v)
    if nrm < 1.0e-12 { return cl_zeros(n) }
    let mut out = cl_zeros(n)
    let mut i = 0

    while i < n { out[i] = v[i] / nrm }
    return out
}

fn cl_scale(v, s) {
    let n = len(v)
    let mut out = cl_zeros(n)
    let mut i = 0

    while i < n { out[i] = v[i] * s }
    return out
}

fn cl_add(a, b) {
    let n = len(a)
    let mut out = cl_zeros(n)
    let mut i = 0

    while i < n { out[i] = a[i] + b[i] }
    return out
}

fn cl_sub(a, b) {
    let n = len(a)
    let mut out = cl_zeros(n)
    let mut i = 0

    while i < n { out[i] = a[i] - b[i] }
    return out
}

fn cl_cosine_sim(a, b) {
    let d = cl_dot(a, b)
    let na = cl_norm(a)
    let nb = cl_norm(b)
    let denom = na * nb
    if denom < 1.0e-12 { return 0.0 }
    return d / denom
}

fn cl_relu(x) {
    if x > 0.0 { return x }
    return 0.0
}

fn cl_linear(x, w, b) {
    let in_dim = len(x)
    let out_dim = len(b)
    let mut out = cl_zeros(out_dim)
    let mut i = 0

    while i < out_dim {
        let mut s = b[i]
        let mut j = 0

        while j < in_dim { s = s + w[i * in_dim + j] * x[j] }
        out[i] = s
    }
    return out
}

fn cl_projection_head(x, w1, b1, w2, b2) {
    let hidden = cl_linear(x, w1, b1)
    let h_dim = len(b1)
    let mut activated = cl_zeros(h_dim)
    let mut i = 0

    while i < h_dim { activated[i] = cl_relu(hidden[i]) }
    let out = cl_linear(activated, w2, b2)
    return cl_normalize(out)
}

fn cl_augment(x, seed) {
    let n = len(x)
    let mut out = cl_zeros(n)
    let mut i = 0

    while i < n {
        let mut h = (seed + 1) * 2654435761 + (i + 1) * 1315423911
        h = h % 1000003
        if h < 0 { h = 0 - h }
        let noise = (to_float(h % 1000) / 1000.0 - 0.5) * 0.1
        out[i] = x[i] + noise
    }
    return out
}

fn cl_make_positive_pair(x, seed1, seed2) {
    let v1 = cl_augment(x, seed1)
    let v2 = cl_augment(x, seed2)
    return [v1, v2]
}

fn cl_sim_matrix(embeddings, tau) {
    let n = len(embeddings)
    let mut mat = []
    let mut i = 0

    while i < n {
        let mut row = cl_zeros(n)
        let mut j = 0

        while j < n {
            row[j] = cl_cosine_sim(embeddings[i], embeddings[j]) / tau
        }
        mat = mat + [row]
    }
    return mat
}

fn cl_infonce_loss(anchor, positive, negatives, tau) {
    let pos_sim = cl_cosine_sim(anchor, positive) / tau
    let pos_exp = cl_exp(pos_sim)
    let mut denom = pos_exp
    let n_neg = len(negatives)
    let mut i = 0

    while i < n_neg {
        let neg_sim = cl_cosine_sim(anchor, negatives[i]) / tau
        denom = denom + cl_exp(neg_sim)
    }
    if denom < 1.0e-15 { return 20.0 }
    let loss = 0.0 - cl_log(pos_exp / denom)
    return loss
}

fn cl_in_batch_negatives(embeddings, idx) {
    let n = len(embeddings)
    let mut negs = []
    let mut i = 0

    while i < n {
        if i != idx { negs = negs + [embeddings[i]] }
    }
    return negs
}

fn cl_infonce_batch(embeddings, tau) {
    let n = len(embeddings)
    let n_pairs = n / 2
    if n_pairs < 1 { return 0.0 }
    let mut total_loss = 0.0
    let mut count = 0
    let mut p = 0

    while p < n_pairs {
        let i = p * 2
        let j = p * 2 + 1
        let negs_i = cl_in_batch_negatives(embeddings, i)
        let mut filtered_negs = []
        let mut k = 0

        while k < len(negs_i) {
            let mut orig_idx = k
            if k >= i { orig_idx = k + 1 }
            if orig_idx != j {
                filtered_negs = filtered_negs + [negs_i[k]]
            }
        }
        let loss_i = cl_infonce_loss(embeddings[i], embeddings[j], filtered_negs, tau)
        total_loss = total_loss + loss_i
        count = count + 1
        let negs_j = cl_in_batch_negatives(embeddings, j)
        let mut filtered_negs_j = []
        let mut k = 0

        while k < len(negs_j) {
            let mut orig_idx2 = k
            if k >= j { orig_idx2 = k + 1 }
            if orig_idx2 != i {
                filtered_negs_j = filtered_negs_j + [negs_j[k]]
            }
        }
        let loss_j = cl_infonce_loss(embeddings[j], embeddings[i], filtered_negs_j, tau)
        total_loss = total_loss + loss_j
        count = count + 1
    }
    if count == 0 { return 0.0 }
    return total_loss / to_float(count)
}

fn cl_grad_temperature(anchor, positive, negatives, tau) {
    let eps = 0.001
    let loss_hi = cl_infonce_loss(anchor, positive, negatives, tau + eps)
    let loss_lo = cl_infonce_loss(anchor, positive, negatives, tau - eps)
    return (loss_hi - loss_lo) / (2.0 * eps)
}

fn cl_hard_negatives(anchor, negatives, k) {
    let n = len(negatives)
    let mut sims = cl_zeros(n)
    let mut indices = cl_zeros_int(n)
    let mut i = 0

    while i < n { sims[i] = cl_cosine_sim(anchor, negatives[i]) }
    let mut i = 0

    while i < n { indices[i] = i }
    let mut topk = k
    if topk > n { topk = n }
    let mut i = 0

    while i < topk {
        let mut best = i
        let mut j = (i + 1)

        while j < n {
            if sims[j] > sims[best] { best = j }
        }
        if best != i {
            let tmp_s = sims[i]
            sims[i] = sims[best]
            sims[best] = tmp_s
            let tmp_idx = indices[i]
            indices[i] = indices[best]
            indices[best] = tmp_idx
        }
    }
    let mut result = []
    let mut i = 0

    while i < topk { result = result + [indices[i]] }
    return result
}

fn cl_infonce_hard(anchor, positive, negatives, tau, k) {
    let hard_idx = cl_hard_negatives(anchor, negatives, k)
    let mut hard_negs = []
    let mut i = 0

    while i < len(hard_idx) { hard_negs = hard_negs + [negatives[hard_idx[i]]] }
    return cl_infonce_loss(anchor, positive, hard_negs, tau)
}

fn cl_cross_modal_loss(emb_a, emb_b, tau) {
    let n = len(emb_a)
    if n < 2 { return 0.0 }
    let mut total = 0.0
    let mut i = 0

    while i < n {
        let mut negs = []
        let mut j = 0

        while j < n {
            if j != i { negs = negs + [emb_b[j]] }
        }
        total = total + cl_infonce_loss(emb_a[i], emb_b[i], negs, tau)
    }
    let mut i = 0

    while i < n {
        let mut negs = []
        let mut j = 0

        while j < n {
            if j != i { negs = negs + [emb_a[j]] }
        }
        total = total + cl_infonce_loss(emb_b[i], emb_a[i], negs, tau)
    }
    return total / to_float(2 * n)
}

fn cl_ntxent_loss(z_i, z_j, negatives, tau) {
    return cl_infonce_loss(z_i, z_j, negatives, tau)
}

fn cl_contrastive_accuracy(embeddings) {
    let n = len(embeddings)
    let n_pairs = n / 2
    if n_pairs < 1 { return 0.0 }
    let mut correct = 0
    let mut p = 0

    while p < n_pairs {
        let i = p * 2
        let j = p * 2 + 1
        let pos_sim = cl_cosine_sim(embeddings[i], embeddings[j])
        let mut is_best = true
        let mut k = 0

        while k < n {
            if k != i {
                if k != j {
                    let neg_sim = cl_cosine_sim(embeddings[i], embeddings[k])
                    if neg_sim >= pos_sim { is_best = false }
                }
            }
        }
        if is_best { correct = correct + 1 }
    }
    return to_float(correct) / to_float(n_pairs)
}

fn cl_alignment_score(pairs) {
    let n = len(pairs)
    if n == 0 { return 0.0 }
    let mut total = 0.0
    let mut i = 0

    while i < n {
        let pair = pairs[i]
        total = total + cl_cosine_sim(pair[0], pair[1])
    }
    return total / to_float(n)
}

fn cl_uniformity_score(embeddings, t) {
    let n = len(embeddings)
    if n < 2 { return 0.0 }
    let mut total = 0.0
    let mut count = 0
    let mut i = 0

    while i < n {
        let mut j = (i + 1)

        while j < n {
            let diff = cl_sub(embeddings[i], embeddings[j])
            let sq_dist = cl_dot(diff, diff)
            total = total + cl_exp(0.0 - t * sq_dist)
            count = count + 1
        }
    }
    if count == 0 { return 0.0 }
    let mean_val = total / to_float(count)
    return cl_log(mean_val)
}

fn cl_softmax(scores) {
    let n = len(scores)
    let mut mx = scores[0]
    let mut i = 1

    while i < n {
        if scores[i] > mx { mx = scores[i] }
    }
    let mut exps = cl_zeros(n)
    let mut z = 0.0
    let mut i = 0

    while i < n {
        exps[i] = cl_exp(scores[i] - mx)
        z = z + exps[i]
    }
    let mut out = cl_zeros(n)
    let mut i = 0

    while i < n { out[i] = exps[i] / z }
    return out
}

fn cl_contrastive_prob(anchor, positive, negatives, tau) {
    let pos_sim = cl_cosine_sim(anchor, positive) / tau
    let mut all_sims = [pos_sim]
    let n_neg = len(negatives)
    let mut i = 0

    while i < n_neg {
        all_sims = all_sims + [cl_cosine_sim(anchor, negatives[i]) / tau]
    }
    let probs = cl_softmax(all_sims)
    return probs[0]
}

fn cl_margin_loss(a, b, is_negative, margin) {
    let diff = cl_sub(a, b)
    let dist = cl_sqrt(cl_dot(diff, diff))
    if is_negative == 0 {
        return 0.5 * dist * dist
    }
    let gap = margin - dist
    if gap < 0.0 { return 0.0 }
    return 0.5 * gap * gap
}

fn cl_triplet_loss(anchor, positive, negative, margin) {
    let dp = cl_sub(anchor, positive)
    let dn = cl_sub(anchor, negative)
    let dist_pos = cl_sqrt(cl_dot(dp, dp))
    let dist_neg = cl_sqrt(cl_dot(dn, dn))
    let loss = dist_pos - dist_neg + margin
    if loss < 0.0 { return 0.0 }
    return loss
}

// ═══════════════════════════════════════════════════════════════
//  TEST DATA
// ═══════════════════════════════════════════════════════════════

// 4-dimensional test vectors
let v1 = [1.0, 0.0, 0.0, 0.0]
let v2 = [0.0, 1.0, 0.0, 0.0]
let v3 = [1.0, 1.0, 0.0, 0.0]
let v4 = [0.5, 0.5, 0.5, 0.5]
let v5 = [0.9, 0.1, 0.0, 0.0]
let v6 = [0.0, 0.0, 1.0, 0.0]
let v7 = [0.0, 0.0, 0.0, 1.0]
let v8 = [0.3, 0.4, 0.5, 0.6]

// ═══════════════════════════════════════════════════════════════
//  TESTS
// ═══════════════════════════════════════════════════════════════

// T1: dot product
check("T1 dot product [1,0,0,0].[0,1,0,0]=0", approx(cl_dot(v1, v2), 0.0, 0.001))

// T2: norm of unit vector
check("T2 norm of [1,0,0,0] = 1", approx(cl_norm(v1), 1.0, 0.001))

// T3: normalize produces unit vector
let nv3 = cl_normalize(v3)
check("T3 normalized vector has norm ~1", approx(cl_norm(nv3), 1.0, 0.001))

// T4: cosine sim of identical vectors = 1
check("T4 cosine_sim(v1,v1) = 1", approx(cl_cosine_sim(v1, v1), 1.0, 0.001))

// T5: cosine sim of orthogonal vectors = 0
check("T5 cosine_sim(v1,v2) = 0", approx(cl_cosine_sim(v1, v2), 0.0, 0.001))

// T6: exp(0) = 1
check("T6 exp(0) = 1", approx(cl_exp(0.0), 1.0, 0.001))

// T7: log(1) ~ 0
check("T7 log(1) ~ 0", approx(cl_log(1.0), 0.0, 0.01))

// T8: relu positive
check("T8 relu(3.0) = 3.0", approx(cl_relu(3.0), 3.0, 0.001))

// T9: relu negative
check("T9 relu(-2.0) = 0.0", approx(cl_relu(-2.0), 0.0, 0.001))

// T10: linear layer
// W = identity 2x2 flattened, b = [0.1, 0.2]
let w_id = [1.0, 0.0, 0.0, 1.0]
let b_test = [0.1, 0.2]
let x_test = [3.0, 4.0]
let lin_out = cl_linear(x_test, w_id, b_test)
check("T10 linear [3,4] with identity+bias = [3.1, 4.2]", approx(lin_out[0], 3.1, 0.001) && approx(lin_out[1], 4.2, 0.001))

// T11: projection head output is normalized (norm ~1)
// in_dim=4, hidden_dim=2, proj_dim=2
// w1: 2x4, b1: 2, w2: 2x2, b2: 2
let w1_test = [0.5, 0.3, 0.1, 0.2, 0.4, 0.6, 0.2, 0.1]
let b1_test = [0.0, 0.0]
let w2_test = [0.3, 0.7, 0.8, 0.2]
let b2_test = [0.0, 0.0]
let proj_out = cl_projection_head(v4, w1_test, b1_test, w2_test, b2_test)
check("T11 projection head output norm ~1", approx(cl_norm(proj_out), 1.0, 0.01))

// T12: augment produces different output
let aug1 = cl_augment(v4, 42)
let mut any_diff = false
let mut i = 0

while i < 4 {
    if fabs(aug1[i] - v4[i]) > 0.001 { any_diff = true }
}
check("T12 augment produces different output", any_diff)

// T13: augment preserves approximate magnitude
let orig_norm = cl_norm(v4)
let aug_norm = cl_norm(aug1)
check("T13 augment preserves approx magnitude", fabs(orig_norm - aug_norm) < 0.5)

// T14: make_positive_pair returns two views
let pair = cl_make_positive_pair(v4, 10, 20)
check("T14 positive pair has 2 views", len(pair) == 2)

// T15: positive pair views are similar (high cosine sim)
let pair_sim = cl_cosine_sim(pair[0], pair[1])
check("T15 positive pair views are similar", pair_sim > 0.9)

// T16: infonce loss > 0
let negs_16 = [v2, v6, v7]
let loss_16 = cl_infonce_loss(v1, v5, negs_16, 0.5)
check("T16 infonce loss > 0", loss_16 > 0.0)

// T17: infonce loss lower for closer positive
let loss_close = cl_infonce_loss(v1, v5, negs_16, 0.5)
let loss_far = cl_infonce_loss(v1, v2, [v5, v6, v7], 0.5)
check("T17 closer positive => lower loss", loss_close < loss_far)

// T18: infonce batch returns positive loss
// Create 2 pairs: v1/v5 (similar), v2/v6 (orthogonal but paired)
let batch_embs = [v1, v5, v2, v8]
let batch_loss = cl_infonce_batch(batch_embs, 0.5)
check("T18 infonce batch loss > 0", batch_loss > 0.0)

// T19: higher temperature smooths loss (changes magnitude)
let loss_cold = cl_infonce_loss(v1, v5, negs_16, 0.1)
let loss_warm = cl_infonce_loss(v1, v5, negs_16, 2.0)
check("T19 different temperatures produce different losses", fabs(loss_cold - loss_warm) > 0.01)

// T20: hard negatives returns correct count
let negs_20 = [v2, v3, v4, v6, v7]
let hard_idx = cl_hard_negatives(v1, negs_20, 2)
check("T20 hard_negatives returns k=2 indices", len(hard_idx) == 2)

// T21: hard negatives picks most similar to anchor
// v3 = [1,1,0,0] and v4 = [0.5,0.5,0.5,0.5] are most similar to v1=[1,0,0,0]
let sim_hard0 = cl_cosine_sim(v1, negs_20[hard_idx[0]])
let sim_hard1 = cl_cosine_sim(v1, negs_20[hard_idx[1]])
// Both hard negatives should have higher sim than the easiest negatives
let sim_v6 = cl_cosine_sim(v1, v6)
check("T21 hard neg[0] more similar than easy neg", sim_hard0 > sim_v6)

// T22: infonce with hard negatives
let loss_hard = cl_infonce_hard(v1, v5, negs_20, 0.5, 3)
check("T22 infonce_hard > 0", loss_hard > 0.0)

// T23: in-batch negatives count
let batch5 = [v1, v2, v3, v4, v5]
let negs_23 = cl_in_batch_negatives(batch5, 0)
check("T23 in-batch negatives count = N-1", len(negs_23) == 4)

// T24: cross-modal loss > 0
let mod_a = [cl_normalize(v1), cl_normalize(v3), cl_normalize(v4)]
let mod_b = [cl_normalize(v5), cl_normalize(v8), cl_normalize(v2)]
let cm_loss = cl_cross_modal_loss(mod_a, mod_b, 0.5)
check("T24 cross-modal loss > 0", cm_loss > 0.0)

// T25: cross-modal loss is symmetric
let cm_loss_rev = cl_cross_modal_loss(mod_b, mod_a, 0.5)
check("T25 cross-modal loss symmetric", approx(cm_loss, cm_loss_rev, 0.01))

// T26: ntxent_loss equals infonce_loss
let ntx_loss = cl_ntxent_loss(v1, v5, negs_16, 0.5)
check("T26 ntxent = infonce", approx(ntx_loss, loss_16, 0.001))

// T27: grad_temperature is finite
let grad_t = cl_grad_temperature(v1, v5, negs_16, 0.5)
check("T27 grad_temperature finite", cl_abs(grad_t) < 1000.0)

// T28: contrastive accuracy with clearly separable pairs
// pair1: v1 ~ v5 (both x-axis heavy), pair2: v2 ~ v8 (v8=[0.3,0.4,0.5,0.6], closest to v2)
// Use pairs that are clearly nearest neighbors
let acc_embs = [cl_normalize([1.0, 0.0, 0.0, 0.0]), cl_normalize([0.95, 0.05, 0.0, 0.0]), cl_normalize([0.0, 0.0, 1.0, 0.0]), cl_normalize([0.0, 0.0, 0.95, 0.05])]
let acc = cl_contrastive_accuracy(acc_embs)
check("T28 contrastive accuracy = 1.0 for clear pairs", approx(acc, 1.0, 0.001))

// T29: alignment score for identical pairs
let id_pairs = [[v1, v1], [v2, v2], [v3, v3]]
let align = cl_alignment_score(id_pairs)
check("T29 alignment score identical = 1.0", approx(align, 1.0, 0.001))

// T30: uniformity score is finite and negative for spread vectors
let unif_embs = [cl_normalize(v1), cl_normalize(v2), cl_normalize(v6), cl_normalize(v7)]
let unif = cl_uniformity_score(unif_embs, 2.0)
check("T30 uniformity score is finite", cl_abs(unif) < 100.0)

// T31: contrastive probability in (0,1)
let prob = cl_contrastive_prob(v1, v5, [v2, v6, v7], 0.5)
check("T31 contrastive prob in (0,1)", prob > 0.0 && prob < 1.0)

// T32: margin loss same class > 0 (non-zero distance)
let ml_same = cl_margin_loss(v1, v3, 0, 1.0)
check("T32 margin loss same class > 0", ml_same > 0.0)

// T33: margin loss different class beyond margin = 0
// v1=[1,0,0,0] vs v7=[0,0,0,1]: distance = sqrt(2) ~ 1.414
// with margin=1.0, gap = 1.0 - 1.414 < 0, so loss = 0
let ml_diff = cl_margin_loss(v1, v7, 1, 1.0)
check("T33 margin loss different class beyond margin = 0", approx(ml_diff, 0.0, 0.01))

// T34: triplet loss
// anchor=v1, positive=v5 (close), negative=v7 (far)
// dist(v1,v5) < dist(v1,v7), so with small margin loss should be 0
let tl = cl_triplet_loss(v1, v5, v7, 0.1)
check("T34 triplet loss correct (close pos, far neg)", approx(tl, 0.0, 0.01))
// But with reversed: positive=v7(far), negative=v5(close) => loss > 0
let tl_rev = cl_triplet_loss(v1, v7, v5, 0.1)
check("T34b triplet loss > 0 when pos far, neg close", tl_rev > 0.0)

// T35: sim matrix diagonal = 1/tau (self-sim=1, scaled by 1/tau)
let sm_embs = [cl_normalize(v1), cl_normalize(v2), cl_normalize(v3)]
let sm = cl_sim_matrix(sm_embs, 0.5)
check("T35 sim_matrix diagonal = 1/tau = 2.0", approx(sm[0][0], 2.0, 0.01))

// T36: softmax sums to 1
let scores = [1.0, 2.0, 3.0, 0.5]
let sm_out = cl_softmax(scores)
let mut sm_sum = 0.0
let mut i = 0

while i < 4 { sm_sum = sm_sum + sm_out[i] }
check("T36 softmax sums to 1", approx(sm_sum, 1.0, 0.001))

// T37: scale correctness
let scaled = cl_scale(v4, 2.0)
check("T37 scale [0.5,0.5,0.5,0.5]*2 = [1,1,1,1]", approx(scaled[0], 1.0, 0.001) && approx(scaled[3], 1.0, 0.001))

// T38: temperature affects loss magnitude
let loss_t01 = cl_infonce_loss(v1, v5, [v2, v6], 0.1)
let loss_t10 = cl_infonce_loss(v1, v5, [v2, v6], 10.0)
check("T38 different tau => different loss", fabs(loss_t01 - loss_t10) > 0.01)

// ═══════════════════════════════════════════════════════════════
println("")
println("=== contrastive learning test summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
