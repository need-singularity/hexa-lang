// test_zero_shard.hexa — ZeRO shard 수치 동치 검증
// single-rank SGD == N=4 ZeRO shard + all-reduce + all-gather

import "ml/zero_shard.hexa"

fn abs_f(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

println("=== ZeRO shard numerical equivalence ===")

let d = 12
let lr = 0.1

let mut params = []
let mut target = []
for i in 0..d {
    params = params + [to_float(i) * 0.5 + 1.0]
    target = target + [to_float(i) * 0.25]
}

// single rank baseline
let single = single_rank_step(params, target, lr, d)

// N=4 ZeRO shard
let sharded4 = zero_shard_step(params, target, lr, d, 4)

// N=1 sanity
let sharded1 = zero_shard_step(params, target, lr, d, 1)

// N=3 uneven split
let sharded3 = zero_shard_step(params, target, lr, d, 3)

let diff4 = l2_diff(single, sharded4, d)
let diff1 = l2_diff(single, sharded1, d)
let diff3 = l2_diff(single, sharded3, d)

println("L2 diff (single vs N=1): " + to_string(diff1))
println("L2 diff (single vs N=4): " + to_string(diff4))
println("L2 diff (single vs N=3): " + to_string(diff3))

let eps = 0.000001
let mut pass = 0
let mut fail = 0

if abs_f(diff1) < eps { pass = pass + 1 } else { fail = fail + 1; println("FAIL N=1") }
if abs_f(diff4) < eps { pass = pass + 1 } else { fail = fail + 1; println("FAIL N=4") }
if abs_f(diff3) < eps { pass = pass + 1 } else { fail = fail + 1; println("FAIL N=3") }

// 원소별 점검 N=4
let mut elem_ok = true
for i in 0..d {
    if abs_f(single[i] - sharded4[i]) >= eps {
        elem_ok = false
        println("elem mismatch at " + to_string(i))
    }
}
if elem_ok { pass = pass + 1 } else { fail = fail + 1 }

// shard 경계 sanity
if shard_begin(12, 4, 0) == 0 { pass = pass + 1 } else { fail = fail + 1 }
if shard_end(12, 4, 3) == 12 { pass = pass + 1 } else { fail = fail + 1 }

println("=== PASS " + to_string(pass) + " / FAIL " + to_string(fail) + " ===")
if fail == 0 {
    println("ZERO_SHARD: ALL PASS")
} else {
    println("ZERO_SHARD: FAILED")
}
