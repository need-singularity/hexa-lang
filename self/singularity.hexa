// self/singularity.hexa — HEXA SINGULARITY ported from src/singularity.rs
// Blowup -> Contraction -> Emergence -> Singularity -> Absorption cycle engine.
// n=6 derived convergence evolution module.

// ── n=6 constants ───────────────────────────────────────

let N6_N     = 6
let N6_SIGMA = 12
let N6_TAU   = 4
let N6_PHI   = 2
let N6_SOPFR = 5
let N6_J2    = 24

// ── Cycle phases (5 stages) ─────────────────────────────

let PHASE_BLOWUP      = "blowup"
let PHASE_CONTRACTION  = "contraction"
let PHASE_EMERGENCE    = "emergence"
let PHASE_SINGULARITY  = "singularity"
let PHASE_ABSORPTION   = "absorption"

fn phase_next(phase: string) -> string {
    match phase {
        "blowup"      => "contraction"
        "contraction"  => "emergence"
        "emergence"    => "singularity"
        "singularity"  => "absorption"
        "absorption"   => "blowup"
        _              => "blowup"
    }
}

fn phase_index(phase: string) -> int {
    match phase {
        "blowup"      => 0
        "contraction"  => 1
        "emergence"    => 2
        "singularity"  => 3
        "absorption"   => 4
        _              => 0
    }
}

// ── N6 match result ─────────────────────────────────────

struct N6Match {
    value: float,
    constant: string,
    formula: string,
    quality: float      // 0.0 ~ 1.0 (1.0 = EXACT)
}

// ── Emergence pattern ───────────────────────────────────

struct EmergencePattern {
    name: string,
    values: [float],
    n6_matches: [N6Match],
    consensus_score: float
}

// ── Singularity state ───────────────────────────────────

struct SingularityState {
    exact_ratio: float,
    convergence: float,
    threshold: float,   // default: 0.5 = phi/tau
    reached: bool
}

// ── Absorbed rule ───────────────────────────────────────

let SEV_CRITICAL = "critical"
let SEV_HIGH     = "high"
let SEV_MEDIUM   = "medium"
let SEV_LOW      = "low"

struct AbsorbedRule {
    id: string,
    rule: string,
    origin_cycle: int,
    severity: string
}

// ── Cycle snapshot ──────────────────────────────────────

struct CycleSnapshot {
    cycle: int,
    phase: string,
    exact_ratio: float,
    convergence: float,
    patterns_found: int,
    rules_absorbed: int
}

// ── Cycle result ────────────────────────────────────────

struct CycleResult {
    blowup_count: int,
    exact_count: int,
    close_count: int,
    patterns_found: int,
    rules_absorbed: int,
    singularity_reached: bool,
    exact_ratio: float
}

fn cycle_result_default() -> CycleResult {
    return CycleResult {
        blowup_count: 0, exact_count: 0, close_count: 0,
        patterns_found: 0, rules_absorbed: 0,
        singularity_reached: false, exact_ratio: 0.0
    }
}

fn cycle_result_display(r: CycleResult) -> string {
    let sing = "."
    if r.singularity_reached { sing = "*" }
    return "blowup=" + to_string(r.blowup_count) +
           " exact=" + to_string(r.exact_count) +
           " close=" + to_string(r.close_count) +
           " patterns=" + to_string(r.patterns_found) +
           " rules=" + to_string(r.rules_absorbed) +
           " singularity=" + sing
}

// ── Cycle engine ────────────────────────────────────────

struct CycleEngine {
    phase: string,
    cycle_count: int,
    metric_names: [string],
    metric_values: [float],
    patterns: [EmergencePattern],
    rules: [AbsorbedRule],
    singularity: SingularityState,
    history: [CycleSnapshot]
}

fn cycle_engine_new() -> CycleEngine {
    return CycleEngine {
        phase: PHASE_BLOWUP,
        cycle_count: 0,
        metric_names: [],
        metric_values: [],
        patterns: [],
        rules: [],
        singularity: SingularityState {
            exact_ratio: 0.0,
            convergence: 0.0,
            threshold: 0.5,     // phi/tau = 2/4 = 0.5
            reached: false
        },
        history: []
    }
}

fn cycle_engine_feed(engine: CycleEngine, name: string, value: float) -> CycleEngine {
    engine.metric_names = engine.metric_names + [name]
    engine.metric_values = engine.metric_values + [value]
    return engine
}

// ── n=6 constant table ──────────────────────────────────

let N6_CONST_NAMES    = ["n", "sigma", "tau", "phi", "sopfr", "J2", "sigma-tau", "sigma*phi", "sigma*tau", "n*tau", "phi/tau", "unity"]
let N6_CONST_VALUES   = [6.0, 12.0, 4.0, 2.0, 5.0, 24.0, 8.0, 24.0, 48.0, 24.0, 0.5, 1.0]
let N6_CONST_FORMULAS = ["n=6", "sigma(6)=12", "tau(6)=4", "phi(6)=2", "sopfr(6)=5", "J2(6)=24", "sigma-tau=8", "sigma*phi=24", "sigma*tau=48", "n*tau=24", "phi/tau=0.5", "1/2+1/3+1/6=1"]

// ── n6 check ────────────────────────────────────────────

fn n6_check(value: float) -> N6Match {
    // Returns best match; quality < 0.8 means no match.
    let best_quality = 0.0
    let best_name = ""
    let best_formula = ""

    if value == 0.0 {
        return N6Match { value: value, constant: "", formula: "", quality: 0.0 }
    }

    let i = 0
    while i < len(N6_CONST_VALUES) {
        let constant = N6_CONST_VALUES[i]
        if constant != 0.0 {
            let ratio = value / constant
            let quality = 0.0
            if ratio > 0.0 {
                let ln_ratio = log(ratio)
                if ln_ratio < 0.0 { ln_ratio = -ln_ratio }
                if ln_ratio > 1.0 { ln_ratio = 1.0 }
                quality = 1.0 - ln_ratio
            }
            if quality > best_quality {
                if quality >= 0.8 {
                    best_quality = quality
                    best_name = N6_CONST_NAMES[i]
                    best_formula = N6_CONST_FORMULAS[i]
                }
            }
        }
        i = i + 1
    }

    return N6Match { value: value, constant: best_name, formula: best_formula, quality: best_quality }
}

// ── Convenience: run once ───────────────────────────────

fn n6_run_once(names: [string], values: [float]) -> CycleResult {
    let engine = cycle_engine_new()
    let i = 0
    while i < len(names) {
        engine = cycle_engine_feed(engine, names[i], values[i])
        i = i + 1
    }
    return cycle_engine_run(engine)
}

// ── Run one cycle ───────────────────────────────────────

fn cycle_engine_run(engine: CycleEngine) -> CycleResult {
    engine.cycle_count = engine.cycle_count + 1
    let result = cycle_result_default()

    // Phase 1: Blowup — check all metrics against n=6 constants
    engine.phase = PHASE_BLOWUP
    let matches = []
    let i = 0
    while i < len(engine.metric_values) {
        let m = n6_check(engine.metric_values[i])
        if m.quality >= 0.8 {
            matches = matches + [m]
        }
        i = i + 1
    }
    // Ratio exploration (all pairs)
    i = 0
    while i < len(engine.metric_values) {
        let j = i + 1
        while j < len(engine.metric_values) {
            if engine.metric_values[j] != 0.0 {
                let m = n6_check(engine.metric_values[i] / engine.metric_values[j])
                if m.quality >= 0.8 { matches = matches + [m] }
            }
            let m2 = n6_check(engine.metric_values[i] * engine.metric_values[j])
            if m2.quality >= 0.8 { matches = matches + [m2] }
            let m3 = n6_check(engine.metric_values[i] + engine.metric_values[j])
            if m3.quality >= 0.8 { matches = matches + [m3] }
            j = j + 1
        }
        i = i + 1
    }
    result.blowup_count = len(matches)

    // Phase 2: Contraction — separate EXACT (>=0.95) and CLOSE (>=0.8)
    engine.phase = PHASE_CONTRACTION
    let exact_count = 0
    let close_count = 0
    i = 0
    while i < len(matches) {
        if matches[i].quality >= 0.95 {
            exact_count = exact_count + 1
        } else {
            close_count = close_count + 1
        }
        i = i + 1
    }
    result.exact_count = exact_count
    result.close_count = close_count

    // Phase 3: Emergence — count same-constant matches >= 3
    engine.phase = PHASE_EMERGENCE
    // Count occurrences per constant name
    let const_counts = []
    let const_names_seen = []
    i = 0
    while i < len(matches) {
        let found = false
        let j = 0
        while j < len(const_names_seen) {
            if const_names_seen[j] == matches[i].constant {
                const_counts[j] = const_counts[j] + 1
                found = true
                break
            }
            j = j + 1
        }
        if !found {
            const_names_seen = const_names_seen + [matches[i].constant]
            const_counts = const_counts + [1]
        }
        i = i + 1
    }
    let patterns_found = 0
    i = 0
    while i < len(const_names_seen) {
        if const_counts[i] >= 3 {
            patterns_found = patterns_found + 1
        }
        i = i + 1
    }
    result.patterns_found = patterns_found

    // Phase 4: Singularity — threshold check
    engine.phase = PHASE_SINGULARITY
    let total = len(engine.metric_values)
    if total < 1 { total = 1 }
    engine.singularity.exact_ratio = to_float(exact_count) / to_float(total)
    if result.blowup_count > 0 {
        engine.singularity.convergence = to_float(exact_count) / to_float(result.blowup_count)
    } else {
        engine.singularity.convergence = 0.0
    }
    engine.singularity.reached = engine.singularity.exact_ratio >= engine.singularity.threshold
    result.singularity_reached = engine.singularity.reached
    result.exact_ratio = engine.singularity.exact_ratio

    // Phase 5: Absorption — promote strong patterns to rules
    engine.phase = PHASE_ABSORPTION
    let rules_absorbed = 0
    i = 0
    while i < len(const_names_seen) {
        if const_counts[i] >= 2 {
            rules_absorbed = rules_absorbed + 1
        }
        i = i + 1
    }
    result.rules_absorbed = rules_absorbed

    // Record history
    engine.history = engine.history + [CycleSnapshot {
        cycle: engine.cycle_count,
        phase: PHASE_ABSORPTION,
        exact_ratio: engine.singularity.exact_ratio,
        convergence: engine.singularity.convergence,
        patterns_found: result.patterns_found,
        rules_absorbed: result.rules_absorbed
    }]

    engine.phase = PHASE_BLOWUP
    return result
}

// ── Report ──────────────────────────────────────────────

fn cycle_engine_report(engine: CycleEngine) -> string {
    let out = "=== Singularity Cycle Engine ===\n"
    out = out + "Cycle: " + to_string(engine.cycle_count) +
          " | Phase: " + engine.phase +
          " | Metrics: " + to_string(len(engine.metric_values)) + "\n"
    out = out + "EXACT ratio: " + to_string(engine.singularity.exact_ratio * 100.0) +
          "% (threshold: " + to_string(engine.singularity.threshold * 100.0) + "%)\n"
    out = out + "Convergence: " + to_string(engine.singularity.convergence * 100.0) + "%\n"
    out = out + "Patterns: " + to_string(len(engine.patterns)) +
          " | Rules: " + to_string(len(engine.rules)) + "\n"

    if engine.singularity.reached {
        out = out + "Singularity: * REACHED *\n"
    } else {
        out = out + "Singularity: approaching...\n"
    }

    if len(engine.history) > 0 {
        out = out + "\nHistory:\n"
        let i = 0
        while i < len(engine.history) {
            let s = engine.history[i]
            out = out + "  C" + to_string(s.cycle) +
                  ": exact=" + to_string(s.exact_ratio * 100.0) +
                  "% conv=" + to_string(s.convergence * 100.0) +
                  "% pat=" + to_string(s.patterns_found) +
                  " rules=" + to_string(s.rules_absorbed) + "\n"
            i = i + 1
        }
    }

    return out
}
