// self/singularity.hexa — HEXA SINGULARITY ported from src/singularity.rs
// Blowup -> Contraction -> Emergence -> Singularity -> Absorption cycle engine.
// n=6 derived convergence evolution module. 5-phase ouroboros cycle.

// ── n=6 constants ───────────────────────────────────────────

let N6_N = 6
let N6_SIGMA = 12
let N6_TAU = 4
let N6_PHI = 2
let N6_SOPFR = 5
let N6_J2 = 24

// ── Phase ───────────────────────────────────────────────────

struct Phase {
    index: int,
    name: string
}

fn phase_blowup() -> Phase { return Phase { index: 0, name: "blowup" } }
fn phase_contraction() -> Phase { return Phase { index: 1, name: "contraction" } }
fn phase_emergence() -> Phase { return Phase { index: 2, name: "emergence" } }
fn phase_singularity() -> Phase { return Phase { index: 3, name: "singularity" } }
fn phase_absorption() -> Phase { return Phase { index: 4, name: "absorption" } }

fn phase_next(p: Phase) -> Phase {
    match p.index {
        0 => { return phase_contraction() }
        1 => { return phase_emergence() }
        2 => { return phase_singularity() }
        3 => { return phase_absorption() }
        4 => { return phase_blowup() }
        _ => { return phase_blowup() }
    }
}

fn phase_from_index(i: int) -> Phase {
    match i {
        0 => { return phase_blowup() }
        1 => { return phase_contraction() }
        2 => { return phase_emergence() }
        3 => { return phase_singularity() }
        4 => { return phase_absorption() }
        _ => { return phase_blowup() }
    }
}

// ── n=6 match result ────────────────────────────────────────

struct N6Match {
    value: float,
    constant_name: string,
    formula: string,
    quality: float
}

// ── Emergence pattern ───────────────────────────────────────

struct EmergencePattern {
    name: string,
    match_count: int,
    consensus_score: float
}

// ── Absorbed rule ───────────────────────────────────────────

struct AbsorbedRule {
    id: string,
    rule: string,
    origin_cycle: int,
    severity: string
}

// ── Cycle snapshot ──────────────────────────────────────────

struct CycleSnapshot {
    cycle: int,
    phase_name: string,
    exact_ratio: float,
    convergence: float,
    patterns_found: int,
    rules_absorbed: int
}

// ── Cycle result ────────────────────────────────────────────

struct CycleResult {
    blowup_count: int,
    exact_count: int,
    close_count: int,
    patterns_found: int,
    rules_absorbed: int,
    singularity_reached: bool,
    exact_ratio: float
}

fn cycle_result_new() -> CycleResult {
    return CycleResult {
        blowup_count: 0,
        exact_count: 0,
        close_count: 0,
        patterns_found: 0,
        rules_absorbed: 0,
        singularity_reached: false,
        exact_ratio: 0.0
    }
}

fn cycle_result_to_string(r: CycleResult) -> string {
    let star = "."
    if r.singularity_reached { star = "*" }
    return "blowup=" + to_string(r.blowup_count) + " exact=" + to_string(r.exact_count) + " close=" + to_string(r.close_count) + " patterns=" + to_string(r.patterns_found) + " rules=" + to_string(r.rules_absorbed) + " singularity=" + star
}

// ── n=6 constants table ─────────────────────────────────────

struct N6Constant {
    name: string,
    value: float,
    formula: string
}

fn get_n6_constants() -> [N6Constant] {
    return [
        N6Constant { name: "n", value: 6.0, formula: "n=6" },
        N6Constant { name: "sigma", value: 12.0, formula: "sigma(6)=12" },
        N6Constant { name: "tau", value: 4.0, formula: "tau(6)=4" },
        N6Constant { name: "phi", value: 2.0, formula: "phi(6)=2" },
        N6Constant { name: "sopfr", value: 5.0, formula: "sopfr(6)=5" },
        N6Constant { name: "J2", value: 24.0, formula: "J2(6)=24" },
        N6Constant { name: "sigma-tau", value: 8.0, formula: "sigma-tau=8" },
        N6Constant { name: "sigma*phi", value: 24.0, formula: "sigma*phi=24" },
        N6Constant { name: "tau2/sigma", value: 1.333, formula: "tau^2/sigma=4/3" },
        N6Constant { name: "n+1", value: 7.0, formula: "n+1=7" },
        N6Constant { name: "unity", value: 1.0, formula: "1/2+1/3+1/6=1" },
        N6Constant { name: "sigma*tau", value: 48.0, formula: "sigma*tau=48" },
        N6Constant { name: "n*tau", value: 24.0, formula: "n*tau=24" },
        N6Constant { name: "phi/tau", value: 0.5, formula: "phi/tau=0.5" },
        N6Constant { name: "1/n", value: 0.1667, formula: "1/n=1/6" },
        N6Constant { name: "1/sigma", value: 0.0833, formula: "1/sigma=1/12" }
    ]
}

// ── n6_check: value against n=6 constants ───────────────────

fn n6_check(value: float) -> N6Match {
    if value == 0.0 {
        return N6Match { value: 0.0, constant_name: "", formula: "", quality: 0.0 }
    }

    let constants = get_n6_constants()
    let best_name = ""
    let best_formula = ""
    let best_quality = 0.0

    let i = 0
    while i < len(constants) {
        let c = constants[i]
        if c.value != 0.0 {
            let ratio = value / c.value
            let quality = 0.0
            if ratio > 0.0 {
                // Approximate |ln(ratio)| using |ratio - 1| for small deviations
                let ln_abs = ratio - 1.0
                if ln_abs < 0.0 { ln_abs = 0.0 - ln_abs }
                if ln_abs > 1.0 { ln_abs = 1.0 }
                quality = 1.0 - ln_abs
            }
            if quality > best_quality {
                if quality >= 0.8 {
                    best_quality = quality
                    best_name = c.name
                    best_formula = c.formula
                }
            }
        }
        i = i + 1
    }

    return N6Match {
        value: value,
        constant_name: best_name,
        formula: best_formula,
        quality: best_quality
    }
}

// ── Cycle engine ────────────────────────────────────────────

struct CycleEngine {
    phase: string,
    cycle_count: int,
    metrics: string,
    metric_count: int,
    pattern_count: int,
    rule_count: int,
    exact_ratio: float,
    convergence: float,
    threshold: float,
    reached: bool,
    history: string
}

fn cycle_engine_new() -> CycleEngine {
    return CycleEngine {
        phase: "blowup",
        cycle_count: 0,
        metrics: "",
        metric_count: 0,
        pattern_count: 0,
        rule_count: 0,
        exact_ratio: 0.0,
        convergence: 0.0,
        threshold: 0.5,
        reached: false,
        history: ""
    }
}

fn cycle_engine_feed(engine: CycleEngine, name: string, value: float) {
    let entry = name + "=" + to_string(value)
    if len(engine.metrics) > 0 {
        engine.metrics = engine.metrics + ";" + entry
    } else {
        engine.metrics = entry
    }
    engine.metric_count = engine.metric_count + 1
}

fn cycle_engine_run_cycle(engine: CycleEngine) -> CycleResult {
    engine.cycle_count = engine.cycle_count + 1
    let result = cycle_result_new()

    // Phase 1: Blowup -- check all metrics against n=6 constants
    engine.phase = "blowup"
    let entries = string_split(engine.metrics, ";")
    let exact_count = 0
    let close_count = 0
    let blowup_count = 0
    let values = []

    let i = 0
    while i < len(entries) {
        let entry = entries[i]
        let eq_pos = string_find(entry, "=")
        if eq_pos > 0 {
            let val = to_float(string_slice(entry, eq_pos + 1, len(entry)))
            values = values + [val]
            let m = n6_check(val)
            if m.quality >= 0.8 {
                blowup_count = blowup_count + 1
                if m.quality >= 0.95 {
                    exact_count = exact_count + 1
                } else {
                    close_count = close_count + 1
                }
            }
        }
        i = i + 1
    }

    // Also check ratios and products (all pairs)
    i = 0
    while i < len(values) {
        let j = i + 1
        while j < len(values) {
            if values[j] != 0.0 {
                let ratio_m = n6_check(values[i] / values[j])
                if ratio_m.quality >= 0.8 {
                    blowup_count = blowup_count + 1
                    if ratio_m.quality >= 0.95 { exact_count = exact_count + 1 }
                    else { close_count = close_count + 1 }
                }
            }
            let prod_m = n6_check(values[i] * values[j])
            if prod_m.quality >= 0.8 {
                blowup_count = blowup_count + 1
                if prod_m.quality >= 0.95 { exact_count = exact_count + 1 }
                else { close_count = close_count + 1 }
            }
            let sum_m = n6_check(values[i] + values[j])
            if sum_m.quality >= 0.8 {
                blowup_count = blowup_count + 1
                if sum_m.quality >= 0.95 { exact_count = exact_count + 1 }
                else { close_count = close_count + 1 }
            }
            j = j + 1
        }
        i = i + 1
    }

    result.blowup_count = blowup_count
    result.exact_count = exact_count
    result.close_count = close_count

    // Phase 2: Contraction -- filter EXACT and CLOSE
    engine.phase = "contraction"

    // Phase 3: Emergence -- 3+ matches to same constant = emergence pattern
    engine.phase = "emergence"
    if exact_count + close_count >= 3 {
        result.patterns_found = 1
    }
    engine.pattern_count = engine.pattern_count + result.patterns_found

    // Phase 4: Singularity -- check threshold
    engine.phase = "singularity"
    let total = engine.metric_count
    if total < 1 { total = 1 }
    engine.exact_ratio = to_float(exact_count) / to_float(total)
    if blowup_count > 0 {
        engine.convergence = to_float(exact_count) / to_float(blowup_count)
    } else {
        engine.convergence = 0.0
    }
    engine.reached = engine.exact_ratio >= engine.threshold
    result.singularity_reached = engine.reached
    result.exact_ratio = engine.exact_ratio

    // Phase 5: Absorption -- promote strong patterns to rules
    engine.phase = "absorption"
    if exact_count >= 2 {
        result.rules_absorbed = 1
        engine.rule_count = engine.rule_count + 1
    }

    // History snapshot
    let snap = "C" + to_string(engine.cycle_count) + ": exact=" + to_string(engine.exact_ratio * 100.0) + "% conv=" + to_string(engine.convergence * 100.0) + "% pat=" + to_string(result.patterns_found) + " rules=" + to_string(result.rules_absorbed)
    if len(engine.history) > 0 {
        engine.history = engine.history + "\n  " + snap
    } else {
        engine.history = "  " + snap
    }

    // Reset to blowup for next cycle
    engine.phase = "blowup"
    return result
}

fn cycle_engine_report(engine: CycleEngine) -> string {
    let out = "=== Singularity Cycle Engine ===\n"
    out = out + "Cycle: " + to_string(engine.cycle_count) + " | Phase: " + engine.phase + " | Metrics: " + to_string(engine.metric_count) + "\n"
    out = out + "EXACT ratio: " + to_string(engine.exact_ratio * 100.0) + "% (threshold: " + to_string(engine.threshold * 100.0) + "%)\n"
    out = out + "Convergence: " + to_string(engine.convergence * 100.0) + "%\n"
    out = out + "Patterns: " + to_string(engine.pattern_count) + " | Rules: " + to_string(engine.rule_count) + "\n"
    if engine.reached {
        out = out + "Singularity: * REACHED *\n"
    } else {
        out = out + "Singularity: approaching...\n"
    }
    if len(engine.history) > 0 {
        out = out + "\nHistory:\n" + engine.history + "\n"
    }
    return out
}

// ── Convenience: single cycle ───────────────────────────────

fn run_once(metrics: string) -> CycleResult {
    let engine = cycle_engine_new()
    let entries = string_split(metrics, ";")
    let i = 0
    while i < len(entries) {
        let entry = entries[i]
        let eq_pos = string_find(entry, "=")
        if eq_pos > 0 {
            let name = string_slice(entry, 0, eq_pos)
            let val = to_float(string_slice(entry, eq_pos + 1, len(entry)))
            cycle_engine_feed(engine, name, val)
        }
        i = i + 1
    }
    return cycle_engine_run_cycle(engine)
}

// ── Convenience: run until singularity ──────────────────────

fn run_until_singularity(metrics: string, max_cycles: int) -> string {
    let engine = cycle_engine_new()
    let entries = string_split(metrics, ";")
    let i = 0
    while i < len(entries) {
        let entry = entries[i]
        let eq_pos = string_find(entry, "=")
        if eq_pos > 0 {
            let name = string_slice(entry, 0, eq_pos)
            let val = to_float(string_slice(entry, eq_pos + 1, len(entry)))
            cycle_engine_feed(engine, name, val)
        }
        i = i + 1
    }

    let c = 0
    while c < max_cycles {
        let result = cycle_engine_run_cycle(engine)
        if result.singularity_reached {
            return cycle_engine_report(engine)
        }
        c = c + 1
    }
    return cycle_engine_report(engine)
}
