// ═══════════════════════════════════════════════════════════════════
//  test_steerlm.hexa — SteerLM verification (#192)
//
//  Attribute-Conditioned Generation with multi-dimensional rewards:
//  helpfulness / correctness / coherence / complexity / verbosity
//
//  Tests (35+):
//    #1  steer_abs positive
//    #2  steer_abs negative
//    #3  steer_sqrt basic
//    #4  steer_sqrt zero/neg
//    #5  steer_exp(0) = 1
//    #6  steer_exp monotonic
//    #7  steer_log(1) = 0
//    #8  steer_log(e) ~ 1
//    #9  steer_zeros length + values
//    #10 steer_hash deterministic
//    #11 steer_hash non-negative
//    #12 steer_attr_names length 5
//    #13 steer_attr_names values
//    #14 steer_default_attrs [4,4,4,2,2]
//    #15 steer_safety_attrs [4,4,4,1,1]
//    #16 steer_creative_attrs [3,3,3,4,3]
//    #17 steer_encode_attributes maps to [0,1]
//    #18 steer_encode_attributes bounds clamp
//    #19 steer_create_model shape
//    #20 steer_create_model weights init range
//    #21 steer_attribute_embedding output dim
//    #22 steer_attribute_embedding deterministic
//    #23 steer_conditioned_logits output vocab
//    #24 steer_conditioned_logits different attrs -> different logits
//    #25 steer_softmax sums to 1.0
//    #26 steer_softmax non-negative
//    #27 steer_argmax picks max
//    #28 steer_reward_model output n_attrs
//    #29 steer_regression_loss zero at match
//    #30 steer_regression_loss positive on mismatch
//    #31 steer_train_reward_step returns loss
//    #32 steer_train_reward_step loss decreases
//    #33 steer_generate produces max_tokens
//    #34 steer_generate deterministic
//    #35 steer_score_response output in [0,4]
//    #36 steer_preference_pair returns 0 or 1
//    #37 steer_preference_pair symmetric
//
//  Rules: pure .hexa, no Rust, HX3 pitfalls honored.
//  Run: ./hexa self/test_steerlm.hexa
// ═══════════════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx(a, b, eps) { return fabs(a - b) < eps }

// ═══════════════════════════════════════════════════════════════════
//  Inlined SteerLM implementation (mirror of self/ml/steerlm.hexa)
// ═══════════════════════════════════════════════════════════════════

// -- numeric helpers --

fn steer_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn steer_sqrt(x) {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    let mut _i = 0

    while _i < 30 {
        g = (g + x / g) / 2.0
    }
    return g
}

fn steer_exp(x) {
    let mut v = x
    if v > 20.0 { v = 20.0 }
    if v < -20.0 { v = -20.0 }
    let mut result = 1.0
    let mut term = 1.0
    let mut i = 1

    while i < 30 {
        term = term * v / to_float(i)
        result = result + term
    }
    if result < 0.0 { return 0.0 }
    return result
}

fn steer_log(x) {
    if x <= 0.0 { return -30.0 }
    let mut v = x
    let mut count = 0
    while v > 2.0 {
        v = v / 2.718281828
        count = count + 1
    }
    while v < 0.5 {
        v = v * 2.718281828
        count = count - 1
    }
    let d = v - 1.0
    let ln_v = d - d * d / 2.0 + d * d * d / 3.0 - d * d * d * d / 4.0
    return to_float(count) + ln_v
}

// -- array constructors --

fn steer_zeros(n) {
    let mut v = []
    let mut _i = 0

    while _i < n { v = v + [0.0] }
    return v
}

fn steer_zeros_int(n) {
    let mut v = []
    let mut _i = 0

    while _i < n { v = v + [0] }
    return v
}

// deterministic hash PRNG
fn steer_hash(seed, i) {
    let h = ((seed * 2654435761 + i * 1315423911 + 731) % 10007)
    if h < 0 { return 0 - h }
    return h
}

fn steer_hash_float(seed, i) {
    let h = steer_hash(seed, i)
    return to_float(h % 1000) / 1000.0
}

// -- constants --
let STEER_N_ATTRS      = 5
let STEER_MAX_SCORE    = 4
let STEER_ATTR_HELP    = 0
let STEER_ATTR_CORRECT = 1
let STEER_ATTR_COHERE  = 2
let STEER_ATTR_COMPLEX = 3
let STEER_ATTR_VERBOSE = 4

fn steer_attr_names() {
    return ["helpfulness", "correctness", "coherence", "complexity", "verbosity"]
}

fn steer_default_attrs() {
    return [4, 4, 4, 2, 2]
}

fn steer_safety_attrs() {
    return [4, 4, 4, 1, 1]
}

fn steer_creative_attrs() {
    return [3, 3, 3, 4, 3]
}

fn steer_encode_attributes(attrs, n_attrs) {
    let mut encoded = steer_zeros(n_attrs)
    let mut i = 0

    while i < n_attrs {
        let mut val = to_float(attrs[i]) / to_float(STEER_MAX_SCORE)
        if val < 0.0 { val = 0.0 }
        if val > 1.0 { val = 1.0 }
        encoded[i] = val
    }
    return encoded
}

fn steer_create_model(vocab, dim, n_attrs) {
    let attr_size = n_attrs * dim
    let proj_size = dim * vocab
    let score_size = dim * n_attrs

    let mut w_attr = steer_zeros(attr_size)
    let mut i = 0

    while i < attr_size {
        w_attr[i] = (steer_hash_float(42, i) - 0.5) * 0.2
    }

    let mut w_proj = steer_zeros(proj_size)
    let mut i = 0

    while i < proj_size {
        w_proj[i] = (steer_hash_float(137, i) - 0.5) * 0.2
    }

    let mut w_score = steer_zeros(score_size)
    let mut i = 0

    while i < score_size {
        w_score[i] = (steer_hash_float(271, i) - 0.5) * 0.2
    }

    return #{
        "w_attr": w_attr,
        "w_proj": w_proj,
        "w_score": w_score,
        "vocab": vocab,
        "dim": dim,
        "n_attrs": n_attrs
    }
}

fn steer_attribute_embedding(model, attrs) {
    let n_attrs = model["n_attrs"]
    let dim = model["dim"]
    let w_attr = model["w_attr"]
    let encoded = steer_encode_attributes(attrs, n_attrs)

    let mut embed = steer_zeros(dim)
    let mut j = 0

    while j < dim {
        let mut sum = 0.0
        let mut i = 0

        while i < n_attrs {
            sum = sum + w_attr[i * dim + j] * encoded[i]
        }
        embed[j] = sum
    }
    return embed
}

fn steer_conditioned_logits(model, hidden, attrs, vocab, dim) {
    let w_proj = model["w_proj"]
    let attr_embed = steer_attribute_embedding(model, attrs)

    let mut conditioned = steer_zeros(dim)
    let mut j = 0

    while j < dim {
        conditioned[j] = hidden[j] + attr_embed[j]
    }

    let mut logits = steer_zeros(vocab)
    let mut v = 0

    while v < vocab {
        let mut sum = 0.0
        let mut j = 0

        while j < dim {
            sum = sum + w_proj[j * vocab + v] * conditioned[j]
        }
        logits[v] = sum
    }
    return logits
}

fn steer_softmax(logits) {
    let n = len(logits)
    let mut mx = logits[0]
    let mut i = 1

    while i < n {
        if logits[i] > mx { mx = logits[i] }
    }
    let mut exps = steer_zeros(n)
    let mut z = 0.0
    let mut i = 0

    while i < n {
        exps[i] = steer_exp(logits[i] - mx)
        z = z + exps[i]
    }
    let mut out = steer_zeros(n)
    let mut i = 0

    while i < n {
        out[i] = exps[i] / z
    }
    return out
}

fn steer_argmax(logits) {
    let n = len(logits)
    let mut best = 0
    let mut best_v = logits[0]
    let mut i = 1

    while i < n {
        if logits[i] > best_v {
            best_v = logits[i]
            best = i
        }
    }
    return best
}

fn steer_reward_model(model, response, attrs, n_tokens, dim) {
    let n_attrs = model["n_attrs"]
    let w_score = model["w_score"]

    let mut pooled = steer_zeros(dim)
    let mut t = 0

    while t < n_tokens {
        let mut j = 0

        while j < dim {
            pooled[j] = pooled[j] + response[t * dim + j]
        }
    }
    if n_tokens > 0 {
        let inv_n = 1.0 / to_float(n_tokens)
        let mut j = 0

        while j < dim {
            pooled[j] = pooled[j] * inv_n
        }
    }

    let mut scores = steer_zeros(n_attrs)
    let mut a = 0

    while a < n_attrs {
        let mut sum = 0.0
        let mut j = 0

        while j < dim {
            sum = sum + w_score[j * n_attrs + a] * pooled[j]
        }
        scores[a] = sum
    }
    return scores
}

fn steer_regression_loss(predicted, target, n_attrs) {
    let mut mse = 0.0
    let mut i = 0

    while i < n_attrs {
        let diff = predicted[i] - target[i]
        mse = mse + diff * diff
    }
    return mse / to_float(n_attrs)
}

fn steer_train_reward_step(model, responses, labels, n, dim, lr) {
    let n_attrs = model["n_attrs"]
    let w_score = model["w_score"]
    let score_size = dim * n_attrs

    let mut total_loss = 0.0
    let mut b = 0

    while b < n {
        let resp = responses[b]
        let lab = labels[b]
        let n_tok = len(resp) / dim
        let pred = steer_reward_model(model, resp, lab, n_tok, dim)
        let encoded_lab = steer_encode_attributes(lab, n_attrs)
        let loss = steer_regression_loss(pred, encoded_lab, n_attrs)
        total_loss = total_loss + loss
    }
    let avg_loss = total_loss / to_float(n)

    let eps = 0.001
    let mut grad = steer_zeros(score_size)
    let mut p = 0

    while p < score_size {
        let orig = w_score[p]
        w_score[p] = orig + eps
        let mut loss_plus = 0.0
        let mut b = 0

        while b < n {
            let resp = responses[b]
            let lab = labels[b]
            let n_tok = len(resp) / dim
            let pred = steer_reward_model(model, resp, lab, n_tok, dim)
            let encoded_lab = steer_encode_attributes(lab, n_attrs)
            loss_plus = loss_plus + steer_regression_loss(pred, encoded_lab, n_attrs)
        }
        w_score[p] = orig
        grad[p] = (loss_plus / to_float(n) - avg_loss) / eps
    }

    let mut p = 0


    while p < score_size {
        w_score[p] = w_score[p] - lr * grad[p]
    }

    return avg_loss
}

fn steer_generate(model, prompt_hidden, attrs, max_tokens, vocab, dim) {
    let mut tokens = steer_zeros_int(max_tokens)
    let mut hidden = steer_zeros(dim)
    let mut j = 0

    while j < dim {
        hidden[j] = prompt_hidden[j]
    }

    let mut t = 0


    while t < max_tokens {
        let logits = steer_conditioned_logits(model, hidden, attrs, vocab, dim)
        let tok = steer_argmax(logits)
        tokens[t] = tok

        let mut j = 0


        while j < dim {
            let w_val = model["w_proj"][j * vocab + tok]
            hidden[j] = hidden[j] * 0.9 + w_val * 0.1
        }
    }
    return tokens
}

fn steer_score_response(model, response, n_tokens, dim) {
    let n_attrs = model["n_attrs"]
    let raw = steer_reward_model(model, response, [], n_tokens, dim)
    let mut scores = steer_zeros(n_attrs)
    let mut i = 0

    while i < n_attrs {
        let mut s = raw[i] * to_float(STEER_MAX_SCORE)
        if s < 0.0 { s = 0.0 }
        if s > to_float(STEER_MAX_SCORE) { s = to_float(STEER_MAX_SCORE) }
        scores[i] = s
    }
    return scores
}

fn steer_preference_pair(model, resp_a, resp_b, n_a, n_b, dim) {
    let n_attrs = model["n_attrs"]
    let scores_a = steer_score_response(model, resp_a, n_a, dim)
    let scores_b = steer_score_response(model, resp_b, n_b, dim)

    let mut sum_a = 0.0
    let mut sum_b = 0.0
    let mut i = 0

    while i < n_attrs {
        sum_a = sum_a + scores_a[i]
        sum_b = sum_b + scores_b[i]
    }

    if sum_b > sum_a { return 1 }
    return 0
}

// ═══════════════════════════════════════════════════════════════════
//  Tests
// ═══════════════════════════════════════════════════════════════════

let VOCAB = 12
let DIM = 8
let N_ATTRS = 5

// --- #1 steer_abs positive ---
check("#1 steer_abs(3.5) = 3.5", approx(steer_abs(3.5), 3.5, 1.0e-9))

// --- #2 steer_abs negative ---
check("#2 steer_abs(-2.7) = 2.7", approx(steer_abs(-2.7), 2.7, 1.0e-9))

// --- #3 steer_sqrt basic ---
check("#3 steer_sqrt(4) = 2", approx(steer_sqrt(4.0), 2.0, 1.0e-6))

// --- #4 steer_sqrt zero/neg ---
check("#4a steer_sqrt(0) = 0", approx(steer_sqrt(0.0), 0.0, 1.0e-9))
check("#4b steer_sqrt(-1) = 0", approx(steer_sqrt(-1.0), 0.0, 1.0e-9))

// --- #5 steer_exp(0) = 1 ---
check("#5 steer_exp(0) = 1", approx(steer_exp(0.0), 1.0, 1.0e-6))

// --- #6 steer_exp monotonic ---
check("#6 steer_exp(1) > steer_exp(0)", steer_exp(1.0) > steer_exp(0.0))

// --- #7 steer_log(1) = 0 ---
check("#7 steer_log(1) = 0", approx(steer_log(1.0), 0.0, 1.0e-3))

// --- #8 steer_log(e) ~ 1 ---
check("#8 steer_log(e) ~ 1", approx(steer_log(2.718281828), 1.0, 1.0e-2))

// --- #9 steer_zeros length + values ---
let z5 = steer_zeros(5)
let mut z_ok = len(z5) == 5
let mut i = 0

while i < 5 {
    if !approx(z5[i], 0.0, 1.0e-9) { z_ok = false }
}
check("#9 steer_zeros(5) length=5 and all zero", z_ok)

// --- #10 steer_hash deterministic ---
let h1 = steer_hash(42, 7)
let h2 = steer_hash(42, 7)
check("#10 steer_hash deterministic", h1 == h2)

// --- #11 steer_hash non-negative ---
let mut h_nonneg = true
let mut i = 0

while i < 20 {
    if steer_hash(42, i) < 0 { h_nonneg = false }
}
check("#11 steer_hash non-negative", h_nonneg)

// --- #12 steer_attr_names length 5 ---
let names = steer_attr_names()
check("#12 steer_attr_names length 5", len(names) == 5)

// --- #13 steer_attr_names values ---
check("#13a helpfulness at 0", names[0] == "helpfulness")
check("#13b correctness at 1", names[1] == "correctness")
check("#13c coherence at 2", names[2] == "coherence")
check("#13d complexity at 3", names[3] == "complexity")
check("#13e verbosity at 4", names[4] == "verbosity")

// --- #14 steer_default_attrs [4,4,4,2,2] ---
let def_attrs = steer_default_attrs()
check("#14 default_attrs = [4,4,4,2,2]",
    len(def_attrs) == 5 &&
    def_attrs[0] == 4 && def_attrs[1] == 4 && def_attrs[2] == 4 &&
    def_attrs[3] == 2 && def_attrs[4] == 2)

// --- #15 steer_safety_attrs [4,4,4,1,1] ---
let saf_attrs = steer_safety_attrs()
check("#15 safety_attrs = [4,4,4,1,1]",
    len(saf_attrs) == 5 &&
    saf_attrs[0] == 4 && saf_attrs[1] == 4 && saf_attrs[2] == 4 &&
    saf_attrs[3] == 1 && saf_attrs[4] == 1)

// --- #16 steer_creative_attrs [3,3,3,4,3] ---
let cre_attrs = steer_creative_attrs()
check("#16 creative_attrs = [3,3,3,4,3]",
    len(cre_attrs) == 5 &&
    cre_attrs[0] == 3 && cre_attrs[1] == 3 && cre_attrs[2] == 3 &&
    cre_attrs[3] == 4 && cre_attrs[4] == 3)

// --- #17 steer_encode_attributes maps to [0,1] ---
let enc = steer_encode_attributes([4, 2, 0, 4, 1], 5)
check("#17a enc[0] = 1.0 (4/4)", approx(enc[0], 1.0, 1.0e-9))
check("#17b enc[1] = 0.5 (2/4)", approx(enc[1], 0.5, 1.0e-9))
check("#17c enc[2] = 0.0 (0/4)", approx(enc[2], 0.0, 1.0e-9))
check("#17d enc[3] = 1.0 (4/4)", approx(enc[3], 1.0, 1.0e-9))
check("#17e enc[4] = 0.25 (1/4)", approx(enc[4], 0.25, 1.0e-9))

// --- #18 steer_encode_attributes bounds clamp ---
// out-of-range values get clamped to [0,1]
let enc_clamp = steer_encode_attributes([8, 0 - 2, 4, 0, 2], 5)
check("#18a clamp upper to 1.0", approx(enc_clamp[0], 1.0, 1.0e-9))
check("#18b clamp lower to 0.0", approx(enc_clamp[1], 0.0, 1.0e-9))

// --- #19 steer_create_model shape ---
let model = steer_create_model(VOCAB, DIM, N_ATTRS)
check("#19a model vocab", model["vocab"] == VOCAB)
check("#19b model dim", model["dim"] == DIM)
check("#19c model n_attrs", model["n_attrs"] == N_ATTRS)
check("#19d w_attr size = n_attrs * dim", len(model["w_attr"]) == N_ATTRS * DIM)
check("#19e w_proj size = dim * vocab", len(model["w_proj"]) == DIM * VOCAB)
check("#19f w_score size = dim * n_attrs", len(model["w_score"]) == DIM * N_ATTRS)

// --- #20 steer_create_model weights init range ---
// Expected initial range is [-0.1, 0.1]
let w_attr = model["w_attr"]
let mut in_range = true
let mut i = 0

while i < len(w_attr) {
    if w_attr[i] < -0.11 { in_range = false }
    if w_attr[i] > 0.11 { in_range = false }
}
check("#20 w_attr weights in [-0.1,0.1]", in_range)

// --- #21 steer_attribute_embedding output dim ---
let embed = steer_attribute_embedding(model, steer_default_attrs())
check("#21 attr_embedding dim = model dim", len(embed) == DIM)

// --- #22 steer_attribute_embedding deterministic ---
let embed2 = steer_attribute_embedding(model, steer_default_attrs())
let mut det_ok = true
let mut j = 0

while j < DIM {
    if !approx(embed[j], embed2[j], 1.0e-12) { det_ok = false }
}
check("#22 attr_embedding deterministic", det_ok)

// --- #23 steer_conditioned_logits output vocab ---
let mut hidden = steer_zeros(DIM)
let mut j = 0

while j < DIM { hidden[j] = to_float(j) * 0.1 - 0.3 }
let logits_def = steer_conditioned_logits(model, hidden, steer_default_attrs(), VOCAB, DIM)
check("#23 conditioned_logits length = vocab", len(logits_def) == VOCAB)

// --- #24 steer_conditioned_logits different attrs -> different logits ---
let logits_saf = steer_conditioned_logits(model, hidden, steer_safety_attrs(), VOCAB, DIM)
let mut any_diff = false
let mut v = 0

while v < VOCAB {
    if !approx(logits_def[v], logits_saf[v], 1.0e-9) { any_diff = true }
}
check("#24 different attrs -> different logits", any_diff)

// --- #25 steer_softmax sums to 1.0 ---
let sm = steer_softmax([1.0, 2.0, 0.5, 3.0, 1.5])
let mut sm_sum = 0.0
let mut i = 0

while i < 5 { sm_sum = sm_sum + sm[i] }
check("#25 softmax sums to 1.0", approx(sm_sum, 1.0, 1.0e-3))

// --- #26 steer_softmax non-negative ---
let mut sm_nonneg = true
let mut i = 0

while i < 5 {
    if sm[i] < 0.0 { sm_nonneg = false }
}
check("#26 softmax non-negative", sm_nonneg)

// --- #27 steer_argmax picks max ---
check("#27a argmax picks index 3", steer_argmax([1.0, 2.0, 0.5, 3.0, 1.5]) == 3)
check("#27b argmax picks index 0 when first is largest",
    steer_argmax([5.0, 2.0, 0.5, 3.0, 1.5]) == 0)

// --- #28 steer_reward_model output n_attrs ---
// Build a synthetic response [n_tokens * dim]
let N_TOK = 3
let mut resp = steer_zeros(N_TOK * DIM)
let mut t = 0

while t < N_TOK {
    let mut j = 0

    while j < DIM {
        resp[t * DIM + j] = to_float(t + j) * 0.01
    }
}
let rm_scores = steer_reward_model(model, resp, [], N_TOK, DIM)
check("#28 reward_model output len = n_attrs", len(rm_scores) == N_ATTRS)

// --- #29 steer_regression_loss zero at match ---
let tgt = [0.5, 0.5, 0.5, 0.5, 0.5]
let pred = [0.5, 0.5, 0.5, 0.5, 0.5]
check("#29 regression_loss 0 at match", approx(steer_regression_loss(pred, tgt, 5), 0.0, 1.0e-12))

// --- #30 steer_regression_loss positive on mismatch ---
let pred2 = [0.0, 1.0, 0.5, 0.5, 0.5]
check("#30 regression_loss > 0 on mismatch", steer_regression_loss(pred2, tgt, 5) > 0.0)

// --- #31 steer_train_reward_step returns loss ---
// Build a small batch: 2 responses of 3 tokens each, with labels
let mut resp_a = steer_zeros(N_TOK * DIM)
let mut t = 0

while t < N_TOK {
    let mut j = 0

    while j < DIM {
        resp_a[t * DIM + j] = to_float(t + j) * 0.02
    }
}
let mut resp_b = steer_zeros(N_TOK * DIM)
let mut t = 0

while t < N_TOK {
    let mut j = 0

    while j < DIM {
        resp_b[t * DIM + j] = to_float(t * 2 + j) * 0.015
    }
}
let responses = [resp_a, resp_b]
let labels = [[4, 4, 4, 2, 2], [1, 1, 1, 1, 1]]
let loss0 = steer_train_reward_step(model, responses, labels, 2, DIM, 0.05)
check("#31 train_reward_step returns loss >= 0", loss0 >= 0.0)

// --- #32 steer_train_reward_step loss decreases ---
// Run several steps and confirm overall trend is down (start vs end)
let mut loss_start = loss0
let mut loss_end = loss0
let mut _step = 0

while _step < 10 {
    loss_end = steer_train_reward_step(model, responses, labels, 2, DIM, 0.05)
}
check("#32 train_reward_step loss trends down", loss_end <= loss_start)

// --- #33 steer_generate produces max_tokens ---
let model33 = steer_create_model(VOCAB, DIM, N_ATTRS)
let mut prompt_h = steer_zeros(DIM)
let mut j = 0

while j < DIM { prompt_h[j] = to_float(j) * 0.05 }
let gen_tokens = steer_generate(model33, prompt_h, steer_default_attrs(), 6, VOCAB, DIM)
check("#33 generate produces 6 tokens", len(gen_tokens) == 6)

// --- #34 steer_generate deterministic ---
let gen_tokens2 = steer_generate(model33, prompt_h, steer_default_attrs(), 6, VOCAB, DIM)
let mut gen_match = true
let mut i = 0

while i < 6 {
    if gen_tokens[i] != gen_tokens2[i] { gen_match = false }
}
check("#34 generate deterministic", gen_match)

// --- #35 steer_score_response output in [0,4] ---
let model35 = steer_create_model(VOCAB, DIM, N_ATTRS)
let mut resp35 = steer_zeros(N_TOK * DIM)
let mut t = 0

while t < N_TOK {
    let mut j = 0

    while j < DIM {
        resp35[t * DIM + j] = to_float(t + j) * 0.03
    }
}
let sc = steer_score_response(model35, resp35, N_TOK, DIM)
let mut sc_ok = len(sc) == N_ATTRS
let mut i = 0

while i < N_ATTRS {
    if sc[i] < 0.0 { sc_ok = false }
    if sc[i] > 4.0 { sc_ok = false }
}
check("#35 score_response in [0,4] range", sc_ok)

// --- #36 steer_preference_pair returns 0 or 1 ---
let mut resp_x = steer_zeros(N_TOK * DIM)
let mut t = 0

while t < N_TOK {
    let mut j = 0

    while j < DIM {
        resp_x[t * DIM + j] = to_float(t + j) * 0.02
    }
}
let mut resp_y = steer_zeros(N_TOK * DIM)
let mut t = 0

while t < N_TOK {
    let mut j = 0

    while j < DIM {
        resp_y[t * DIM + j] = to_float(t + j) * 0.04
    }
}
let pref = steer_preference_pair(model35, resp_x, resp_y, N_TOK, N_TOK, DIM)
check("#36 preference_pair returns 0 or 1", pref == 0 || pref == 1)

// --- #37 steer_preference_pair reflects score sums ---
// Compute sums manually and cross-check
let sa = steer_score_response(model35, resp_x, N_TOK, DIM)
let sb = steer_score_response(model35, resp_y, N_TOK, DIM)
let mut sum_a = 0.0
let mut sum_b = 0.0
let mut i = 0

while i < N_ATTRS {
    sum_a = sum_a + sa[i]
    sum_b = sum_b + sb[i]
}
let expected = if sum_b > sum_a { 1 } else { 0 }
check("#37 preference_pair matches score sums", pref == expected)

// ═══════════════════════════════════════════════════════════════════
println("")
println("=== SteerLM test summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
