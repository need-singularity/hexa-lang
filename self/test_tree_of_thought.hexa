// ===================================================================
//  test_tree_of_thought.hexa — Tree of Thought verification (#137)
//
//  Tests (35):
//    T1  make_node creates node with correct id
//    T2  make_node has correct parent_id
//    T3  make_node has correct depth
//    T4  make_node has empty children list
//    T5  make_node stores state
//    T6  make_node stores thought text
//    T7  make_node stores score
//    T8  make_tree creates tree with one root node
//    T9  make_tree root has depth 0
//    T10 make_tree root parent is -1
//    T11 add_child increases node count
//    T12 add_child parent's children list updated
//    T13 add_child child has correct parent_id
//    T14 add_child child has depth = parent + 1
//    T15 get_children returns correct children
//    T16 evaluate_node updates score
//    T17 vote_evaluate averages scores
//    T18 generate_thoughts returns up to k results
//    T19 prune_topk keeps k best nodes
//    T20 prune_topk preserves order by score
//    T21 is_dead_end detects low score
//    T22 is_dead_end passes high score
//    T23 budget_check within budget
//    T24 budget_check over budget
//    T25 backtrack returns parent
//    T26 backtrack from root returns root
//    T27 extract_path from root is [0]
//    T28 extract_path multi-level correct
//    T29 best_leaf finds highest-scored leaf
//    T30 bfs expands tree to correct depth
//    T31 bfs prunes to beam width
//    T32 dfs respects budget limit
//    T33 dfs explores depth-first
//    T34 multi_step chains reasoning steps
//    T35 update_score changes node score
//
//  Run: cargo run --release -- self/test_tree_of_thought.hexa
// ===================================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn approx(a, b, eps) {
    return fabs(a - b) < eps
}

// ===================================================================
//  Inlined from tree_of_thought.hexa
// ===================================================================

fn tot_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn tot_max_float(a, b) {
    if a >= b { return a }
    return b
}

fn tot_min_int(a, b) {
    if a <= b { return a }
    return b
}

struct ThoughtNode {
    id: int,
    parent_id: int,
    depth: int,
    state: array,
    thought: string,
    score: float,
    children: array
}

@pure
fn tot_make_node(id, parent_id, depth, state, thought, score) {
    return ThoughtNode {
        id: id,
        parent_id: parent_id,
        depth: depth,
        state: state,
        thought: thought,
        score: score,
        children: []
    }
}

struct ThoughtTree {
    nodes: array,
    next_id: int
}

fn tot_make_tree(root_state) {
    let root = tot_make_node(0, -1, 0, root_state, "root", 0.0)
    return ThoughtTree {
        nodes: [root],
        next_id: 1
    }
}

@pure @hot
fn tot_get_node(tree, node_id) {
    return tree.nodes[node_id]
}

@pure
fn tot_get_children(tree, node_id) {
    let node = tree.nodes[node_id]
    let mut result = []
    for i in 0..len(node.children) {
        let cid = node.children[i]
        result = result + [tree.nodes[cid]]
    }
    return result
}

fn tot_node_count(tree) {
    return len(tree.nodes)
}

fn tot_add_child(tree, parent_id, state, thought, score) {
    let nid = tree.next_id
    let parent = tree.nodes[parent_id]
    let child = tot_make_node(nid, parent_id, parent.depth + 1, state, thought, score)

    let mut new_nodes = []
    for i in 0..len(tree.nodes) {
        if i == parent_id {
            let p = tree.nodes[i]
            let updated_parent = ThoughtNode {
                id: p.id,
                parent_id: p.parent_id,
                depth: p.depth,
                state: p.state,
                thought: p.thought,
                score: p.score,
                children: p.children + [nid]
            }
            new_nodes = new_nodes + [updated_parent]
        } else {
            new_nodes = new_nodes + [tree.nodes[i]]
        }
    }
    new_nodes = new_nodes + [child]

    let new_tree = ThoughtTree {
        nodes: new_nodes,
        next_id: nid + 1
    }
    return [new_tree, nid]
}

@pure
fn tot_evaluate_node(node, eval_fn) {
    let s = eval_fn(node.state)
    return ThoughtNode {
        id: node.id,
        parent_id: node.parent_id,
        depth: node.depth,
        state: node.state,
        thought: node.thought,
        score: s,
        children: node.children
    }
}

@pure
fn tot_vote_evaluate(node, eval_fns) {
    let n = len(eval_fns)
    if n == 0 { return node }
    let mut total = 0.0
    for i in 0..n {
        let f = eval_fns[i]
        total = total + f(node.state)
    }
    let avg = total / to_float(n)
    return ThoughtNode {
        id: node.id,
        parent_id: node.parent_id,
        depth: node.depth,
        state: node.state,
        thought: node.thought,
        score: avg,
        children: node.children
    }
}

@pure
fn tot_generate_thoughts(state, gen_fn, k) {
    let all = gen_fn(state)
    let n = len(all)
    let limit = tot_min_int(k, n)
    let mut result = []
    for i in 0..limit {
        result = result + [all[i]]
    }
    return result
}

@pure
fn tot_prune_topk(nodes, k) {
    let n = len(nodes)
    if n <= k { return nodes }

    let mut selected = []
    let mut used = []
    for _i in 0..n {
        used = used + [0]
    }

    let limit = tot_min_int(k, n)
    for _step in 0..limit {
        let mut best_idx = -1
        let mut best_score = -999999.0
        for j in 0..n {
            if used[j] == 0 {
                if nodes[j].score > best_score {
                    best_score = nodes[j].score
                    best_idx = j
                }
            }
        }
        if best_idx >= 0 {
            used[best_idx] = 1
            selected = selected + [nodes[best_idx]]
        }
    }
    return selected
}

@pure
fn tot_is_dead_end(node, threshold) {
    return node.score < threshold
}

@pure
fn tot_budget_check(budget, used) {
    return used < budget
}

@pure
fn tot_backtrack(tree, node_id) {
    let node = tree.nodes[node_id]
    if node.parent_id < 0 { return node }
    return tree.nodes[node.parent_id]
}

@pure
fn tot_extract_path(tree, node_id) {
    let mut path = []
    let mut cur = node_id
    let mut steps = 0
    let max_steps = len(tree.nodes) + 1
    while cur >= 0 {
        if steps >= max_steps { break }
        path = path + [cur]
        let node = tree.nodes[cur]
        cur = node.parent_id
        steps = steps + 1
    }
    let n = len(path)
    let mut reversed = []
    for i in 0..n {
        reversed = reversed + [path[n - 1 - i]]
    }
    return reversed
}

@pure
fn tot_best_leaf(tree) {
    let n = len(tree.nodes)
    let mut best_id = 0
    let mut best_score = -999999.0
    for i in 0..n {
        let node = tree.nodes[i]
        if len(node.children) == 0 {
            if node.score > best_score {
                best_score = node.score
                best_id = i
            }
        }
    }
    return tree.nodes[best_id]
}

fn tot_bfs(tree, gen_fn, eval_fn, max_depth, beam_width) {
    let mut t = tree
    let mut frontier = [0]

    for _d in 0..max_depth {
        let mut candidates = []
        let mut candidate_parents = []

        for fi in 0..len(frontier) {
            let pid = frontier[fi]
            let parent = tot_get_node(t, pid)
            let thoughts = tot_generate_thoughts(parent.state, gen_fn, beam_width)
            for ti in 0..len(thoughts) {
                let triple = thoughts[ti]
                candidates = candidates + [triple]
                candidate_parents = candidate_parents + [pid]
            }
        }

        if len(candidates) == 0 { break }

        let mut scored = []
        for ci in 0..len(candidates) {
            let cand = candidates[ci]
            let s = eval_fn(cand[0])
            scored = scored + [s]
        }

        let nc = len(candidates)
        let limit = tot_min_int(beam_width, nc)
        let mut used = []
        for _i in 0..nc {
            used = used + [0]
        }

        let mut new_frontier = []
        for _step in 0..limit {
            let mut best_idx = -1
            let mut best_s = -999999.0
            for j in 0..nc {
                if used[j] == 0 {
                    if scored[j] > best_s {
                        best_s = scored[j]
                        best_idx = j
                    }
                }
            }
            if best_idx < 0 { break }
            used[best_idx] = 1

            let cand = candidates[best_idx]
            let pid = candidate_parents[best_idx]
            let result = tot_add_child(t, pid, cand[0], cand[1], best_s)
            t = result[0]
            let nid = result[1]
            new_frontier = new_frontier + [nid]
        }

        frontier = new_frontier
    }
    return t
}

fn tot_dfs(tree, gen_fn, eval_fn, max_depth, budget) {
    let mut t = tree
    let mut stack = [0]
    let mut used_budget = 0

    while len(stack) > 0 {
        if used_budget >= budget { break }

        let top = stack[len(stack) - 1]
        let mut new_stack = []
        for si in 0..(len(stack) - 1) {
            new_stack = new_stack + [stack[si]]
        }
        stack = new_stack

        let node = tot_get_node(t, top)

        if node.depth >= max_depth { continue }

        let thoughts = tot_generate_thoughts(node.state, gen_fn, 3)
        for ti in 0..len(thoughts) {
            if used_budget >= budget { break }
            let triple = thoughts[ti]
            let s = eval_fn(triple[0])
            let result = tot_add_child(t, top, triple[0], triple[1], s)
            t = result[0]
            let nid = result[1]
            used_budget = used_budget + 1

            if s >= 0.0 {
                stack = stack + [nid]
            }
        }
    }
    return t
}

fn tot_multi_step(tree, gen_fn, eval_fn, steps, beam) {
    let mut t = tree
    for _s in 0..steps {
        let n = len(t.nodes)
        let mut frontier = []
        for i in 0..n {
            let node = t.nodes[i]
            if len(node.children) == 0 {
                frontier = frontier + [i]
            }
        }

        if len(frontier) == 0 { break }

        let mut frontier_nodes = []
        for fi in 0..len(frontier) {
            frontier_nodes = frontier_nodes + [t.nodes[frontier[fi]]]
        }
        let pruned = tot_prune_topk(frontier_nodes, beam)

        for pi in 0..len(pruned) {
            let pnode = pruned[pi]
            let thoughts = tot_generate_thoughts(pnode.state, gen_fn, beam)
            for ti in 0..len(thoughts) {
                let triple = thoughts[ti]
                let s = eval_fn(triple[0])
                let result = tot_add_child(t, pnode.id, triple[0], triple[1], s)
                t = result[0]
            }
        }
    }
    return t
}

fn tot_update_score(tree, node_id, new_score) {
    let mut new_nodes = []
    for i in 0..len(tree.nodes) {
        if i == node_id {
            let old = tree.nodes[i]
            let updated = ThoughtNode {
                id: old.id,
                parent_id: old.parent_id,
                depth: old.depth,
                state: old.state,
                thought: old.thought,
                score: new_score,
                children: old.children
            }
            new_nodes = new_nodes + [updated]
        } else {
            new_nodes = new_nodes + [tree.nodes[i]]
        }
    }
    return ThoughtTree {
        nodes: new_nodes,
        next_id: tree.next_id
    }
}

@pure
fn tot_max_depth(tree) {
    let n = len(tree.nodes)
    let mut mx = 0
    for i in 0..n {
        if tree.nodes[i].depth > mx {
            mx = tree.nodes[i].depth
        }
    }
    return mx
}

@pure
fn tot_leaf_count(tree) {
    let n = len(tree.nodes)
    let mut count = 0
    for i in 0..n {
        if len(tree.nodes[i].children) == 0 {
            count = count + 1
        }
    }
    return count
}

@pure
fn tot_avg_score(tree) {
    let n = len(tree.nodes)
    if n == 0 { return 0.0 }
    let mut total = 0.0
    for i in 0..n {
        total = total + tree.nodes[i].score
    }
    return total / to_float(n)
}

// ===================================================================
//  Mock functions for testing
// ===================================================================

// gen_fn: given a state, produce candidate thoughts
// state is array of ints; each thought extends the state
fn mock_gen(state) {
    let n = len(state)
    let base = 0
    if n > 0 { let base = state[n - 1] }
    // produce 3 candidates
    let s1 = state + [n * 10 + 1]
    let s2 = state + [n * 10 + 2]
    let s3 = state + [n * 10 + 3]
    return [
        [s1, "thought_a", 0.0],
        [s2, "thought_b", 0.0],
        [s3, "thought_c", 0.0]
    ]
}

// eval_fn: score = sum of state values (higher sum = better)
fn mock_eval(state) {
    let mut s = 0.0
    for i in 0..len(state) {
        s = s + to_float(state[i])
    }
    return s
}

// eval variant: penalizes long states
fn mock_eval_short(state) {
    let mut s = 0.0
    for i in 0..len(state) {
        s = s + to_float(state[i])
    }
    return s - to_float(len(state)) * 5.0
}

// eval variant: constant evaluator
fn mock_eval_const(state) {
    return 42.0
}

// eval variant: returns negative for even-length states
fn mock_eval_parity(state) {
    let n = len(state)
    if n % 2 == 0 { return -1.0 }
    return 1.0
}

// ===================================================================
//  TESTS
// ===================================================================

// T1: make_node creates node with correct id
let n1 = tot_make_node(5, 2, 3, [1, 2], "step", 0.8)
check("T1 make_node id correct", n1.id == 5)

// T2: make_node parent_id
check("T2 make_node parent_id correct", n1.parent_id == 2)

// T3: make_node depth
check("T3 make_node depth correct", n1.depth == 3)

// T4: make_node empty children
check("T4 make_node children empty", len(n1.children) == 0)

// T5: make_node state stored
check("T5 make_node state stored", len(n1.state) == 2)
check("T5b make_node state[0]", n1.state[0] == 1)

// T6: make_node thought text
check("T6 make_node thought text", n1.thought == "step")

// T7: make_node score
check("T7 make_node score", fabs(n1.score - 0.8) < 0.001)

// T8: make_tree has one root
let tree1 = tot_make_tree([0])
check("T8 make_tree has 1 node", tot_node_count(tree1) == 1)

// T9: root depth is 0
let root1 = tot_get_node(tree1, 0)
check("T9 root depth is 0", root1.depth == 0)

// T10: root parent is -1
check("T10 root parent_id is -1", root1.parent_id == -1)

// T11: add_child increases count
let r11 = tot_add_child(tree1, 0, [1], "child1", 1.0)
let tree2 = r11[0]
check("T11 add_child count=2", tot_node_count(tree2) == 2)

// T12: parent's children list updated
let parent_after = tot_get_node(tree2, 0)
check("T12 parent children has 1 entry", len(parent_after.children) == 1)

// T13: child has correct parent_id
let child1 = tot_get_node(tree2, 1)
check("T13 child parent_id = 0", child1.parent_id == 0)

// T14: child depth = parent + 1
check("T14 child depth = 1", child1.depth == 1)

// T15: get_children returns correct children
let children = tot_get_children(tree2, 0)
check("T15 get_children count = 1", len(children) == 1)
check("T15b get_children[0].id = 1", children[0].id == 1)

// T16: evaluate_node updates score
let n16 = tot_make_node(0, -1, 0, [10, 20], "test", 0.0)
let evaluated = tot_evaluate_node(n16, mock_eval)
check("T16 evaluate_node score = 30.0", fabs(evaluated.score - 30.0) < 0.001)

// T17: vote_evaluate with single evaluator
let n17 = tot_make_node(0, -1, 0, [5], "vote_test", 0.0)
let voted = tot_vote_evaluate(n17, [mock_eval])
// mock_eval([5]) = 5.0, single fn avg = 5.0
check("T17 vote_evaluate single fn avg", fabs(voted.score - 5.0) < 0.001)

// T18: generate_thoughts returns up to k results
let thoughts_3 = tot_generate_thoughts([0], mock_gen, 3)
check("T18 generate_thoughts returns 3", len(thoughts_3) == 3)
let thoughts_2 = tot_generate_thoughts([0], mock_gen, 2)
check("T18b generate_thoughts capped at 2", len(thoughts_2) == 2)

// T19: prune_topk keeps k best
let prune_nodes = [
    tot_make_node(0, -1, 0, [0], "a", 1.0),
    tot_make_node(1, -1, 0, [0], "b", 5.0),
    tot_make_node(2, -1, 0, [0], "c", 3.0),
    tot_make_node(3, -1, 0, [0], "d", 2.0),
    tot_make_node(4, -1, 0, [0], "e", 4.0)
]
let pruned = tot_prune_topk(prune_nodes, 3)
check("T19 prune_topk keeps 3", len(pruned) == 3)

// T20: prune_topk top scores are 5.0, 4.0, 3.0
check("T20 prune_topk[0] score=5.0", fabs(pruned[0].score - 5.0) < 0.001)
check("T20b prune_topk[1] score=4.0", fabs(pruned[1].score - 4.0) < 0.001)
check("T20c prune_topk[2] score=3.0", fabs(pruned[2].score - 3.0) < 0.001)

// T21: is_dead_end detects low score
let dead_node = tot_make_node(0, -1, 0, [0], "dead", -5.0)
check("T21 is_dead_end for score -5.0", tot_is_dead_end(dead_node, 0.0))

// T22: is_dead_end passes high score
let alive_node = tot_make_node(0, -1, 0, [0], "alive", 10.0)
check("T22 is_dead_end false for score 10.0", tot_is_dead_end(alive_node, 0.0) == false)

// T23: budget_check within budget
check("T23 budget_check 5 < 10", tot_budget_check(10, 5))

// T24: budget_check over budget
check("T24 budget_check 10 >= 10 false", tot_budget_check(10, 10) == false)

// T25: backtrack returns parent
let r25a = tot_add_child(tree1, 0, [1], "c", 1.0)
let tree25 = r25a[0]
let bt = tot_backtrack(tree25, 1)
check("T25 backtrack returns parent id=0", bt.id == 0)

// T26: backtrack from root returns root
let bt_root = tot_backtrack(tree25, 0)
check("T26 backtrack root returns root", bt_root.id == 0)

// T27: extract_path from root
let path_root = tot_extract_path(tree25, 0)
check("T27 extract_path root = [0]", len(path_root) == 1)
check("T27b path[0] = 0", path_root[0] == 0)

// T28: extract_path multi-level
// Build: root(0) -> child(1) -> grandchild(2)
let r28a = tot_add_child(tree1, 0, [1], "c1", 1.0)
let tree28 = r28a[0]
let r28b = tot_add_child(tree28, 1, [2], "c2", 2.0)
let tree28b = r28b[0]
let path28 = tot_extract_path(tree28b, 2)
check("T28 extract_path length 3", len(path28) == 3)
check("T28b path = [0,1,2]", path28[0] == 0 && path28[1] == 1 && path28[2] == 2)

// T29: best_leaf finds highest-scored leaf
let r29a = tot_add_child(tree1, 0, [1], "low", 1.0)
let t29 = r29a[0]
let r29b = tot_add_child(t29, 0, [2], "high", 9.0)
let t29b = r29b[0]
let best = tot_best_leaf(t29b)
check("T29 best_leaf score = 9.0", fabs(best.score - 9.0) < 0.001)

// T30: BFS expands tree
let bfs_tree = tot_make_tree([0])
let bfs_result = tot_bfs(bfs_tree, mock_gen, mock_eval, 2, 2)
// After 2 levels of BFS with beam=2, tree should have root + some children
check("T30 bfs tree has more than 1 node", tot_node_count(bfs_result) > 1)
let bfs_depth = tot_max_depth(bfs_result)
check("T30b bfs max depth >= 1", bfs_depth >= 1)

// T31: BFS prunes to beam width
// At each level, at most beam_width nodes should be added
// With beam=2 and depth=1, we expect root + 2 children = 3 nodes max at depth 1
let bfs_small = tot_make_tree([0])
let bfs_s1 = tot_bfs(bfs_small, mock_gen, mock_eval, 1, 2)
// Root + at most 2 children at depth 1
let d1_count_31 = tot_node_count(bfs_s1) - 1
check("T31 bfs beam=2 adds <= 2 per level", d1_count_31 <= 2)

// T32: DFS respects budget
let dfs_tree = tot_make_tree([0])
let dfs_result = tot_dfs(dfs_tree, mock_gen, mock_eval, 5, 6)
// Budget=6 means at most 6 nodes added (plus root = 7 total max)
check("T32 dfs budget=6 total <= 7", tot_node_count(dfs_result) <= 7)

// T33: DFS explores depth-first (max depth should be > 1 with enough budget)
let dfs_deep = tot_make_tree([0])
let dfs_d = tot_dfs(dfs_deep, mock_gen, mock_eval, 4, 12)
let dfs_max_d = tot_max_depth(dfs_d)
check("T33 dfs explores depth > 1", dfs_max_d > 1)

// T34: multi-step chains reasoning
let ms_tree = tot_make_tree([0])
let ms_result = tot_multi_step(ms_tree, mock_gen, mock_eval, 2, 2)
check("T34 multi_step adds nodes", tot_node_count(ms_result) > 1)
let ms_depth = tot_max_depth(ms_result)
check("T34b multi_step depth >= 2", ms_depth >= 2)

// T35: update_score changes node score
let us_tree = tot_make_tree([10])
let us_updated = tot_update_score(us_tree, 0, 99.0)
let us_node = tot_get_node(us_updated, 0)
check("T35 update_score changes score", fabs(us_node.score - 99.0) < 0.001)

// ===================================================================
println("")
println("=== tree_of_thought test summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
