// self/formatter.hexa — HEXA Code Formatter ported from src/formatter.rs
// Stage: P6 self-hosting skeleton (shapes only, bodies TODO)
//
// Pretty-prints HEXA source code:
//   - 4-space indentation
//   - Normalized whitespace
//   - Aligned `=` in consecutive let statements
//   - One blank line between functions
//   - No trailing whitespace
//
// Public API:
//   format_source(source)  -> string | error   driver: lex -> parse -> format
//   check_format(source)   -> bool             true iff already formatted
//
// AST shape: this port consumes the Map-based AstNode used by self/parser.hexa
// (kind discriminator + optional fields). See parser.hexa constructors.

// ══════════════════════════════════════════════════════════════
// Driver
// ══════════════════════════════════════════════════════════════

fn format_source(source) {
    // TODO: let tokens  = tokenize(source)
    // TODO: let stmts   = parse(tokens)
    // TODO: return format_stmts(stmts, 0)
    return ""
}

fn check_format(source) {
    // TODO: let formatted = format_source(source)
    // TODO: return trim_end(source) == trim_end(formatted)
    return false
}

// ══════════════════════════════════════════════════════════════
// Indentation helper
// ══════════════════════════════════════════════════════════════

fn ind(level) {
    // TODO: return "    " repeated `level` times
    let mut s = ""
    let mut i = 0
    while i < level {
        s = s + "    "
        i = i + 1
    }
    return s
}

// ══════════════════════════════════════════════════════════════
// Statement list — handles let alignment + blank line between fns
// ══════════════════════════════════════════════════════════════

fn format_stmts(stmts, indent) {
    // TODO: iterate stmts
    //   1. group consecutive Let stmts → align `=` column
    //   2. insert blank line before FnDecl/AsyncFnDecl (except first)
    //   3. dispatch each stmt through format_stmt
    //   4. strip double trailing newlines
    return ""
}

fn format_let_group_aligned(stmts, group_idx_list, indent) {
    // TODO: compute max(name + ann) width, emit padded `let name[: T] = rhs`
    return ""
}

// ══════════════════════════════════════════════════════════════
// Statement dispatcher — one branch per AstNode "kind"
// ══════════════════════════════════════════════════════════════

fn format_stmt(stmt, indent) {
    let prefix = ind(indent)
    let k = stmt.kind

    // ── bindings ───────────────────────────────────────────
    if k == "LetStmt" {
        // TODO: "let NAME[: T][ = EXPR]"
        return prefix + "let"
    }
    if k == "ConstStmt" {
        // TODO: "const NAME[: T] = EXPR"
        return prefix + "const"
    }
    if k == "StaticStmt" {
        // TODO: "static NAME[: T] = EXPR"
        return prefix + "static"
    }
    if k == "AtomicLet" {
        // TODO: "atomic let NAME[: T][ = EXPR]"
        return prefix + "atomic let"
    }
    if k == "TypeAlias" {
        // TODO: "type NAME = TARGET"
        return prefix + "type"
    }

    // ── assignment / expression / return ───────────────────
    if k == "AssignStmt" {
        // TODO: "LHS = RHS"
        return prefix
    }
    if k == "ExprStmt" {
        // TODO: format_expr(stmt.expr)
        return prefix
    }
    if k == "ReturnStmt" {
        // TODO: "return [EXPR]"
        return prefix + "return"
    }

    // ── declarations ───────────────────────────────────────
    if k == "FnDecl" {
        return format_fn_decl(stmt, indent, false)
    }
    if k == "AsyncFnDecl" {
        return format_fn_decl(stmt, indent, true)
    }
    if k == "ExternFnDecl" {
        // TODO: "[@link(\"L\") ]extern fn NAME(params) -> T"
        return prefix + "extern fn"
    }
    if k == "ComptimeFnDecl" {
        // TODO: format_fn_decl then prefix "comptime "
        return prefix + "comptime fn"
    }
    if k == "StructDecl" {
        // TODO: "struct NAME { field: T, ... }"
        return prefix + "struct"
    }
    if k == "EnumDecl" {
        // TODO: "enum NAME { Variant[(T,...)], ... }"
        return prefix + "enum"
    }
    if k == "TraitDecl" {
        // TODO: "trait NAME { fn ... }"
        return prefix + "trait"
    }
    if k == "ImplBlock" {
        // TODO: "impl [TRAIT for ]TARGET { methods }"
        return prefix + "impl"
    }
    if k == "MacroDef" {
        return prefix + "macro! " + stmt.name + " { ... }"
    }
    if k == "DeriveDecl" {
        // TODO: "derive(T1, T2) for TARGET"
        return prefix + "derive"
    }
    if k == "EffectDecl" {
        return prefix + "effect { ... }"
    }

    // ── control flow ───────────────────────────────────────
    if k == "ForStmt" {
        // TODO: "for VAR in ITER BLOCK"
        return prefix + "for"
    }
    if k == "WhileStmt" {
        // TODO: "while COND BLOCK"
        return prefix + "while"
    }
    if k == "LoopStmt" {
        // TODO: "loop BLOCK"
        return prefix + "loop"
    }
    if k == "BreakStmt" { return prefix + "break" }
    if k == "ContinueStmt" { return prefix + "continue" }

    // ── errors / concurrency ───────────────────────────────
    if k == "TryCatch" {
        // TODO: "try BLOCK (catch|recover) NAME BLOCK"
        return prefix + "try"
    }
    if k == "ThrowStmt" {
        // TODO: "throw EXPR"
        return prefix + "throw"
    }
    if k == "PanicStmt" {
        // TODO: "panic EXPR"
        return prefix + "panic"
    }
    if k == "SpawnStmt" {
        // TODO: "spawn [\"NAME\" ]BLOCK"
        return prefix + "spawn"
    }
    if k == "DropStmt" {
        return prefix + "drop " + stmt.name
    }
    if k == "SelectStmt" {
        // TODO: "select { arm from RECV => BLOCK, timeout(MS) => BLOCK }"
        return prefix + "select"
    }
    if k == "ScopeStmt" {
        // TODO: "scope BLOCK"
        return prefix + "scope"
    }

    // ── proofs / intents / verification ────────────────────
    if k == "ProofStmt" {
        // TODO: "proof NAME BLOCK"
        return prefix + "proof"
    }
    if k == "AssertStmt" {
        // TODO: "assert EXPR"
        return prefix + "assert"
    }
    if k == "IntentStmt" {
        // TODO: "intent \"DESC\" { k: v, ... }"
        return prefix + "intent"
    }
    if k == "VerifyStmt" {
        // TODO: "verify \"NAME\" BLOCK"
        return prefix + "verify"
    }
    if k == "TheoremStmt" {
        return prefix + "theorem " + stmt.name + " { ... }"
    }
    if k == "GenerateStmt" {
        return prefix + "generate { ... }"
    }
    if k == "OptimizeFnStmt" {
        return prefix + "optimize fn " + stmt.name
    }
    if k == "EvolveFn" {
        return prefix + "@evolve fn " + stmt.name
    }
    if k == "ConsciousnessBlock" {
        return prefix + "consciousness \"" + stmt.name + "\" { ... }"
    }

    // ── modules ────────────────────────────────────────────
    if k == "ModStmt" {
        // TODO: "mod NAME { stmts }"
        return prefix + "mod"
    }
    if k == "UseStmt" {
        // TODO: "use a::b::c"
        return prefix + "use"
    }

    // ── tuples ─────────────────────────────────────────────
    if k == "LetTuple" {
        // TODO: "let (a, b, c) = EXPR"
        return prefix + "let"
    }

    // Fallback: unknown kind
    return prefix + "/* unknown stmt: " + k + " */"
}

// ══════════════════════════════════════════════════════════════
// Fn decl / block helpers
// ══════════════════════════════════════════════════════════════

fn format_fn_decl(decl, indent, is_async) {
    let prefix = ind(indent)
    // TODO: build "ASYNC fn NAME(p: T, ...) -> R  BLOCK"
    let async_prefix = ""
    if is_async { async_prefix = "async " }
    return prefix + async_prefix + "fn " + decl.name + "() {}"
}

fn format_block(stmts, indent) {
    // TODO: "{}" if empty, else "{\n" + format_stmts(stmts, indent+1) + ind(indent) + "}"
    if len(stmts) == 0 { return "{}" }
    return "{}"
}

// ══════════════════════════════════════════════════════════════
// Expression dispatcher
// ══════════════════════════════════════════════════════════════

fn format_expr(expr) {
    let k = expr.kind

    // ── literals ───────────────────────────────────────────
    if k == "IntLit"    { return to_string(expr.int_value) }
    if k == "FloatLit"  { return to_string(expr.float_value) }
    if k == "BoolLit"   { return to_string(expr.bool_value) }
    if k == "StringLit" {
        // TODO: escape \\ and "
        return "\"" + expr.string_value + "\""
    }
    if k == "CharLit" {
        return "'" + expr.string_value + "'"
    }
    if k == "Ident"     { return expr.name }
    if k == "Wildcard"  { return "_" }

    // ── operators ──────────────────────────────────────────
    if k == "BinOp" {
        // TODO: format_expr(left) + " " + binop_str(op) + " " + format_expr(right)
        return ""
    }
    if k == "UnaryOp" {
        // TODO: prefix - / ! / ~  + format_expr(operand)
        return ""
    }
    if k == "Range" {
        // TODO: start + (".." | "..=") + end
        return ""
    }

    // ── calls / members ────────────────────────────────────
    if k == "Call" {
        // TODO: callee(arg, ...)
        return ""
    }
    if k == "Field" {
        // TODO: obj.field
        return ""
    }
    if k == "Index" {
        // TODO: obj[idx]
        return ""
    }
    if k == "MacroInvoc" {
        return expr.name + "!(...)"
    }

    // ── collections / literals ─────────────────────────────
    if k == "Array" {
        // TODO: "[" + join(items, ", ") + "]"
        return "[]"
    }
    if k == "Tuple" {
        // TODO: "(" + join(items, ", ") + ")"
        return "()"
    }
    if k == "MapLit" {
        // TODO: "{k: v, ...}"
        return "{}"
    }
    if k == "StructInit" {
        // TODO: "NAME { f: v, ... }"
        return expr.name + " {}"
    }
    if k == "EnumPath" {
        // TODO: "ENUM::VARIANT[(DATA)]"
        return ""
    }
    if k == "ArrayPattern" {
        // TODO: "[p, p, ...rest]"
        return "[]"
    }

    // ── control-flow exprs ─────────────────────────────────
    if k == "Lambda" {
        // TODO: "|p, ...| BODY"
        return "|| {}"
    }
    if k == "IfExpr" {
        // TODO: "if COND BLOCK [else BLOCK]"
        return "if {}"
    }
    if k == "MatchExpr" {
        // TODO: "match SCR {\n    PAT [if G] -> { body },\n}"
        return "match {}"
    }
    if k == "Block" {
        return format_block(expr.stmts, 0)
    }

    // ── ownership / async / effects ────────────────────────
    if k == "Own"      { return "own "    + format_expr(expr.operand) }
    if k == "Move"     { return "move "   + format_expr(expr.operand) }
    if k == "Borrow"   { return "borrow " + format_expr(expr.operand) }
    if k == "Await"    { return "await "  + format_expr(expr.operand) }
    if k == "Yield"    { return "yield "  + format_expr(expr.operand) }
    if k == "Comptime" { return "comptime " + format_expr(expr.operand) }
    if k == "Resume"   { return "resume(" + format_expr(expr.operand) + ")" }
    if k == "DynCast" {
        // TODO: "dyn TRAIT(EXPR)"
        return "dyn"
    }
    if k == "HandleWith" { return "handle { ... } with { ... }" }
    if k == "EffectCall" {
        // TODO: "EFFECT.OP(...)"
        return ""
    }
    if k == "Template"   { return "<template>" }
    if k == "TryCatchExpr" {
        // TODO: "try { ... } (catch|recover) NAME { ... }"
        return "try { ... } catch { ... }"
    }

    return "/* unknown expr: " + k + " */"
}

// ══════════════════════════════════════════════════════════════
// BinOp → string
// ══════════════════════════════════════════════════════════════

fn binop_str(op) {
    if op == "Add"        { return "+" }
    if op == "Sub"        { return "-" }
    if op == "Mul"        { return "*" }
    if op == "Div"        { return "/" }
    if op == "Rem"        { return "%" }
    if op == "Pow"        { return "**" }
    if op == "Eq"         { return "==" }
    if op == "Ne"         { return "!=" }
    if op == "Lt"         { return "<" }
    if op == "Gt"         { return ">" }
    if op == "Le"         { return "<=" }
    if op == "Ge"         { return ">=" }
    if op == "And"        { return "&&" }
    if op == "Or"         { return "||" }
    if op == "Xor"        { return "^^" }
    if op == "BitAnd"     { return "&" }
    if op == "BitOr"      { return "|" }
    if op == "BitXor"     { return "^" }
    if op == "Assign"     { return "=" }
    if op == "DeclAssign" { return ":=" }
    if op == "Range"      { return ".." }
    if op == "Arrow"      { return "->" }
    return "?"
}

// ══════════════════════════════════════════════════════════════
// Entrypoint smoke
// ══════════════════════════════════════════════════════════════

// TODO(P6): wire into hexa CLI (`hexa fmt <file>`)
let _smoke = format_source("")
