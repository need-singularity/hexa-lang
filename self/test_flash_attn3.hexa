// ===================================================================
//  test_flash_attn3.hexa — Flash Attention 3 (#211) verification
//
//  ML roadmap #211 — FA3 async Q/KV pipeline + FP8 softmax
//  simulation. Correctness invariant: fa3_fa3_forward matches
//  fa3_reference_sdpa within FP8 tolerance.
//
//  Tests (30+):
//    T1  fa3_zeros_1d correct length
//    T2  fa3_zeros_2d shape [r][c]
//    T3  fa3_row_max picks true max
//    T4  fa3_row_sum correct total
//    T5  fa3_row_amax ignores sign
//    T6  fa3_e4m3_max = 448.0
//    T7  fa3_fp8_quantize_row scale > 0
//    T8  fa3_fp8_quantize_row sign preserved
//    T9  fa3_fp8_dequantize_row round-trip bounded relative error (<0.05)
//    T10 fa3_fp8_dequantize_row zero input -> zero output
//    T11 fa3_softmax_fp8 sums to 1 ± 0.01
//    T12 fa3_softmax_fp8 uniform input -> uniform output
//    T13 fa3_softmax_fp8 picks peak on argmax
//    T14 fa3_causal_mask_score(score,1,2) < -1e20  (mask)
//    T15 fa3_causal_mask_score(score,2,1) unchanged (no mask)
//    T16 fa3_create_config has all fields
//    T17 fa3_create_config stores q_block, kv_block, causal
//    T18 fa3_count_tiles basic
//    T19 fa3_count_tiles q_block larger than q_len -> 1 tile along q
//    T20 fa3_count_tiles kv_block larger than k_len -> 1 tile along k
//    T21 fa3_pipeline_block output triple shape
//    T22 fa3_pipeline_block sums exps match direct computation
//    T23 fa3_rescale_online identical input/output (m_old == m_new, etc.)
//    T24 fa3_rescale_online combining two blocks matches full softmax concat
//    T25 fa3_reference_sdpa output shape [q_len, d]
//    T26 fa3_reference_sdpa rows are probability-weighted V (sum of weights ~ 1)
//    T27 fa3_fa3_forward output shape [q_len, d]
//    T28 fa3_fa3_forward ≈ reference SDPA within 1e-2
//    T29 fa3_fa3_forward single-tile (q_block=q_len, kv_block=k_len) == reference
//    T30 fa3_fa3_forward q_block > q_len yields one Q tile, output still matches
//    T31 fa3_fa3_forward very small kv_block still matches reference
//    T32 Zero Q -> uniform V average (non-causal manual softmax check)
//    T33 fa3_fa3_forward causal-like via pipeline_block: q_pos 0 uses only V[0]
//    T34 fa3_softmax_fp8 handles n=1 correctly (returns [1.0])
//    T35 fa3_fp8_quantize_row preserves max magnitude within e4m3 range
//
//  Run: PATH=/Users/ghost/.cargo/bin:$PATH ./hexa self/test_flash_attn3.hexa
// ===================================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx(a, b, eps) { return fabs(a - b) < eps }

// ===================================================================
//  Inlined Flash Attention 3 implementation
// ===================================================================

fn fa3_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn fa3_max(a, b) {
    if a > b { return a }
    return b
}

fn fa3_min(a, b) {
    if a < b { return a }
    return b
}

fn fa3_sqrt(x) {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    for _i in 0..30 {
        g = (g + x / g) / 2.0
    }
    return g
}

fn fa3_round(x) {
    if x >= 0.0 {
        return to_float(to_int(x + 0.5))
    }
    return to_float(to_int(x - 0.5))
}

fn fa3_clamp(x, lo, hi) {
    if x < lo { return lo }
    if x > hi { return hi }
    return x
}

fn fa3_exp(x) {
    let mut v = x
    if v > 20.0 { v = 20.0 }
    if v < -20.0 { v = -20.0 }
    let mut result = 1.0
    let mut term = 1.0
    for i in 1..30 {
        term = term * v / to_float(i)
        result = result + term
    }
    if result < 0.0 { return 0.0 }
    return result
}

fn fa3_zeros_1d(n) {
    let mut v = []
    for _i in 0..n { v = v + [0.0] }
    return v
}

fn fa3_zeros_2d(r, c) {
    let mut m = []
    for _i in 0..r {
        let mut row = []
        for _j in 0..c { row = row + [0.0] }
        m = m + [row]
    }
    return m
}

fn fa3_neg_inf() {
    return -1.0e30
}

fn fa3_e4m3_max() {
    return 448.0
}

fn fa3_row_max(row, n) {
    if n <= 0 { return 0.0 }
    let mut m = row[0]
    for i in 1..n {
        if row[i] > m { m = row[i] }
    }
    return m
}

fn fa3_row_sum(row, n) {
    let mut s = 0.0
    for i in 0..n {
        s = s + row[i]
    }
    return s
}

fn fa3_row_amax(row, n) {
    let mut mx = 0.0
    for i in 0..n {
        let a = fa3_abs(row[i])
        if a > mx { mx = a }
    }
    return mx
}

fn fa3_fp8_quantize_row(row, n, e4m3_max) {
    let amax = fa3_row_amax(row, n)
    let mut scale = amax / e4m3_max
    if scale < 1.0e-12 { scale = 1.0e-12 }
    let mut q = fa3_zeros_1d(n)
    for i in 0..n {
        let scaled = row[i] / scale
        let r = fa3_round(scaled)
        q[i] = fa3_clamp(r, 0.0 - e4m3_max, e4m3_max)
    }
    return [q, scale]
}

fn fa3_fp8_dequantize_row(q_row, scale, n) {
    let mut out = fa3_zeros_1d(n)
    for i in 0..n {
        out[i] = q_row[i] * scale
    }
    return out
}

fn fa3_softmax_fp8(scores_row, n) {
    if n <= 0 { return [] }
    let m = fa3_row_max(scores_row, n)
    let mut exps = fa3_zeros_1d(n)
    let mut z = 0.0
    for i in 0..n {
        let e = fa3_exp(scores_row[i] - m)
        exps[i] = e
        z = z + e
    }
    let mut probs = fa3_zeros_1d(n)
    let inv_z = 1.0 / z
    for i in 0..n {
        probs[i] = exps[i] * inv_z
    }
    let qpair = fa3_fp8_quantize_row(probs, n, fa3_e4m3_max())
    let q = qpair[0]
    let scale = qpair[1]
    let deq = fa3_fp8_dequantize_row(q, scale, n)
    let mut s = 0.0
    for i in 0..n { s = s + deq[i] }
    if s < 1.0e-12 { s = 1.0e-12 }
    let inv_s = 1.0 / s
    let mut out = fa3_zeros_1d(n)
    for i in 0..n {
        out[i] = deq[i] * inv_s
    }
    return out
}

fn fa3_causal_mask_score(score, q_pos, k_pos) {
    if k_pos > q_pos {
        return fa3_neg_inf()
    }
    return score
}

fn fa3_rescale_online(m_old, m_new, l_old, l_new, out_old, new_block, d) {
    let m_star = fa3_max(m_old, m_new)
    let alpha = fa3_exp(m_old - m_star)
    let beta = fa3_exp(m_new - m_star)
    let l_star = alpha * l_old + beta * l_new
    let mut out_star = fa3_zeros_1d(d)
    for k in 0..d {
        out_star[k] = alpha * out_old[k] + beta * new_block[k]
    }
    return [m_star, l_star, out_star]
}

fn fa3_count_tiles(q_len, k_len, q_block, kv_block) {
    let mut qb = q_block
    let mut kb = kv_block
    if qb < 1 { qb = 1 }
    if kb < 1 { kb = 1 }
    if qb > q_len { qb = q_len }
    if kb > k_len { kb = k_len }
    let nq = (q_len + qb - 1) / qb
    let nk = (k_len + kb - 1) / kb
    return nq * nk
}

fn fa3_create_config(q_block, kv_block, causal) {
    return #{
        "q_block": q_block,
        "kv_block": kv_block,
        "causal": causal,
        "fp8": true,
        "e4m3_max": fa3_e4m3_max()
    }
}

fn fa3_reference_sdpa(Q, K, V, q_len, k_len, d) {
    let scale = 1.0 / fa3_sqrt(to_float(d))
    let mut out = fa3_zeros_2d(q_len, d)
    for i in 0..q_len {
        let mut scores = fa3_zeros_1d(k_len)
        for j in 0..k_len {
            let mut dot = 0.0
            for k in 0..d {
                dot = dot + Q[i][k] * K[j][k]
            }
            scores[j] = dot * scale
        }
        let m = fa3_row_max(scores, k_len)
        let mut exps = fa3_zeros_1d(k_len)
        let mut z = 0.0
        for j in 0..k_len {
            let e = fa3_exp(scores[j] - m)
            exps[j] = e
            z = z + e
        }
        let inv_z = 1.0 / z
        for k in 0..d {
            let mut acc = 0.0
            for j in 0..k_len {
                acc = acc + exps[j] * inv_z * V[j][k]
            }
            out[i][k] = acc
        }
    }
    return out
}

fn fa3_pipeline_block(Q_block, K_block, V_block, q_len, k_len, d) {
    let scale = 1.0 / fa3_sqrt(to_float(d))
    let mut results = []
    for i in 0..q_len {
        let mut scores = fa3_zeros_1d(k_len)
        for j in 0..k_len {
            let mut dot = 0.0
            for k in 0..d {
                dot = dot + Q_block[i][k] * K_block[j][k]
            }
            scores[j] = dot * scale
        }
        let m_row = fa3_row_max(scores, k_len)
        let mut l_row = 0.0
        let mut out_row = fa3_zeros_1d(d)
        for j in 0..k_len {
            let p = fa3_exp(scores[j] - m_row)
            l_row = l_row + p
            for k in 0..d {
                out_row[k] = out_row[k] + p * V_block[j][k]
            }
        }
        results = results + [[m_row, l_row, out_row]]
    }
    return results
}

fn fa3_fa3_forward(Q, K, V, q_len, k_len, d, q_block, kv_block) {
    let mut qb = q_block
    let mut kb = kv_block
    if qb < 1 { qb = 1 }
    if kb < 1 { kb = 1 }
    if qb > q_len { qb = q_len }
    if kb > k_len { kb = k_len }

    let nq_tiles = (q_len + qb - 1) / qb
    let nk_tiles = (k_len + kb - 1) / kb

    let mut out = fa3_zeros_2d(q_len, d)

    for qi in 0..nq_tiles {
        let q_start = qi * qb
        let mut q_end = q_start + qb
        if q_end > q_len { q_end = q_len }
        let q_rows = q_end - q_start

        let mut Q_block = fa3_zeros_2d(q_rows, d)
        for i in 0..q_rows {
            for k in 0..d {
                Q_block[i][k] = Q[q_start + i][k]
            }
        }

        let mut m_state = fa3_zeros_1d(q_rows)
        let mut l_state = fa3_zeros_1d(q_rows)
        let mut O_state = fa3_zeros_2d(q_rows, d)
        for i in 0..q_rows { m_state[i] = fa3_neg_inf() }

        for kj in 0..nk_tiles {
            let k_start = kj * kb
            let mut k_end = k_start + kb
            if k_end > k_len { k_end = k_len }
            let k_rows = k_end - k_start

            let mut K_block = fa3_zeros_2d(k_rows, d)
            let mut V_block = fa3_zeros_2d(k_rows, d)
            for j in 0..k_rows {
                for k in 0..d {
                    K_block[j][k] = K[k_start + j][k]
                    V_block[j][k] = V[k_start + j][k]
                }
            }

            let tile = fa3_pipeline_block(Q_block, K_block, V_block, q_rows, k_rows, d)

            for i in 0..q_rows {
                let part = tile[i]
                let m_new = part[0]
                let l_new = part[1]
                let out_new = part[2]
                let merged = fa3_rescale_online(m_state[i], m_new, l_state[i], l_new, O_state[i], out_new, d)
                m_state[i] = merged[0]
                l_state[i] = merged[1]
                let on = merged[2]
                for k in 0..d {
                    O_state[i][k] = on[k]
                }
            }
        }

        for i in 0..q_rows {
            let mut inv_l = 1.0 / l_state[i]
            if l_state[i] < 1.0e-30 { inv_l = 0.0 }
            for k in 0..d {
                out[q_start + i][k] = O_state[i][k] * inv_l
            }
        }
    }

    return out
}

// ===================================================================
//  TEST DATA
// ===================================================================

let Q_LEN = 4
let K_LEN = 6
let D = 4
let Q_BLOCK = 2
let KV_BLOCK = 3

fn make_matrix(rows, cols, seed) {
    let mut m = []
    for i in 0..rows {
        let mut row = []
        for j in 0..cols {
            let h = (i * 311 + j * 137 + seed * 7 + 13) % 10007
            let v = (to_float(h) / 10007.0 - 0.5) * 2.0
            row = row + [v]
        }
        m = m + [row]
    }
    return m
}

let Q_mat = make_matrix(Q_LEN, D, 1)
let K_mat = make_matrix(K_LEN, D, 2)
let V_mat = make_matrix(K_LEN, D, 3)

// ===================================================================
//  TESTS
// ===================================================================

// T1 fa3_zeros_1d correct length
let z1 = fa3_zeros_1d(5)
check("T1 fa3_zeros_1d length", len(z1) == 5)

// T2 fa3_zeros_2d shape [r][c]
let z2 = fa3_zeros_2d(3, 4)
check("T2 fa3_zeros_2d shape", len(z2) == 3 && len(z2[0]) == 4 && approx(z2[1][2], 0.0, 1.0e-9))

// T3 fa3_row_max picks true max
let rmax_input = [1.0, 3.5, -2.0, 7.2, 0.5]
check("T3 fa3_row_max", approx(fa3_row_max(rmax_input, 5), 7.2, 1.0e-9))

// T4 fa3_row_sum correct total
let rsum_input = [0.5, 1.5, 2.0, -0.5]
check("T4 fa3_row_sum", approx(fa3_row_sum(rsum_input, 4), 3.5, 1.0e-9))

// T5 fa3_row_amax ignores sign
let amax_input = [-5.5, 2.0, -1.0, 3.0]
check("T5 fa3_row_amax", approx(fa3_row_amax(amax_input, 4), 5.5, 1.0e-9))

// T6 fa3_e4m3_max = 448.0
check("T6 fa3_e4m3_max == 448", approx(fa3_e4m3_max(), 448.0, 1.0e-9))

// T7 fa3_fp8_quantize_row scale > 0
let qtest_input = [0.1, -0.25, 0.5, -0.75, 1.0]
let qtest_pair = fa3_fp8_quantize_row(qtest_input, 5, fa3_e4m3_max())
let qtest_q = qtest_pair[0]
let qtest_scale = qtest_pair[1]
check("T7 fa3_fp8_quantize_row scale > 0", qtest_scale > 0.0)

// T8 fa3_fp8_quantize_row sign preserved
let mut signs_ok = true
for i in 0..5 {
    let a = qtest_input[i]
    let b = qtest_q[i]
    if a > 0.0 && b < 0.0 { signs_ok = false }
    if a < 0.0 && b > 0.0 { signs_ok = false }
}
check("T8 fa3_fp8_quantize_row sign preserved", signs_ok)

// T9 fa3_fp8_dequantize_row round-trip bounded relative error (<0.05)
let dq = fa3_fp8_dequantize_row(qtest_q, qtest_scale, 5)
let mut max_rel = 0.0
for i in 0..5 {
    let orig = qtest_input[i]
    let rec = dq[i]
    let denom = fabs(orig)
    if denom > 1.0e-6 {
        let rel = fabs(orig - rec) / denom
        if rel > max_rel { max_rel = rel }
    }
}
check("T9 FP8 round-trip relative error < 0.05", max_rel < 0.05)

// T10 fa3_fp8_dequantize_row zero input -> zero output
let zpair = fa3_fp8_quantize_row(fa3_zeros_1d(5), 5, fa3_e4m3_max())
let zq = zpair[0]
let zscale = zpair[1]
let zdq = fa3_fp8_dequantize_row(zq, zscale, 5)
let mut all_zero = true
for i in 0..5 {
    if fabs(zdq[i]) > 1.0e-9 { all_zero = false }
}
check("T10 FP8 zero in -> zero out", all_zero)

// T11 fa3_softmax_fp8 sums to 1 ± 0.01
let sm_scores = [1.2, 0.3, -0.5, 2.1, 0.0, -1.4]
let sm_out = fa3_softmax_fp8(sm_scores, 6)
let mut sm_sum = 0.0
for i in 0..6 { sm_sum = sm_sum + sm_out[i] }
check("T11 softmax_fp8 sums to 1 ± 0.01", approx(sm_sum, 1.0, 0.01))

// T12 fa3_softmax_fp8 uniform input -> uniform output
let uni_scores = [2.0, 2.0, 2.0, 2.0]
let uni_out = fa3_softmax_fp8(uni_scores, 4)
let mut uni_ok = true
for i in 0..4 {
    if !approx(uni_out[i], 0.25, 0.01) { uni_ok = false }
}
check("T12 softmax_fp8 uniform -> 0.25", uni_ok)

// T13 fa3_softmax_fp8 picks peak on argmax
let peak_scores = [0.1, 0.2, 5.0, 0.3, 0.05]
let peak_out = fa3_softmax_fp8(peak_scores, 5)
let mut peak_idx = 0
let mut peak_val = peak_out[0]
for i in 1..5 {
    if peak_out[i] > peak_val { peak_val = peak_out[i]; peak_idx = i }
}
check("T13 softmax_fp8 peak at index 2", peak_idx == 2 && peak_val > 0.9)

// T14 fa3_causal_mask_score(score,1,2) < -1e20  (mask)
let masked = fa3_causal_mask_score(0.5, 1, 2)
check("T14 causal mask future", masked < -1.0e20)

// T15 fa3_causal_mask_score(score,2,1) unchanged (no mask)
let unmasked = fa3_causal_mask_score(0.5, 2, 1)
check("T15 causal mask past untouched", approx(unmasked, 0.5, 1.0e-9))

// T16 fa3_create_config has all fields
let cfg = fa3_create_config(4, 8, true)
check("T16 config fields", has_key(cfg, "q_block") && has_key(cfg, "kv_block") && has_key(cfg, "causal") && has_key(cfg, "fp8") && has_key(cfg, "e4m3_max"))

// T17 fa3_create_config stores q_block, kv_block, causal
check("T17 config stores values", cfg["q_block"] == 4 && cfg["kv_block"] == 8 && cfg["causal"] == true)

// T18 fa3_count_tiles basic
check("T18 count_tiles basic", fa3_count_tiles(4, 6, 2, 3) == 4)

// T19 fa3_count_tiles q_block larger than q_len -> 1 tile along q
check("T19 count_tiles big q_block", fa3_count_tiles(4, 6, 100, 3) == 2)

// T20 fa3_count_tiles kv_block larger than k_len -> 1 tile along k
check("T20 count_tiles big kv_block", fa3_count_tiles(4, 6, 2, 100) == 2)

// T21 fa3_pipeline_block output triple shape
let pb_result = fa3_pipeline_block(Q_mat, K_mat, V_mat, Q_LEN, K_LEN, D)
check("T21 pipeline_block shape", len(pb_result) == Q_LEN && len(pb_result[0]) == 3 && len(pb_result[0][2]) == D)

// T22 fa3_pipeline_block sums exps match direct computation
let pb_row0 = pb_result[0]
let pb_l0 = pb_row0[1]
let pb_m0 = pb_row0[0]
// recompute directly
let scale_d = 1.0 / fa3_sqrt(to_float(D))
let mut direct_scores = fa3_zeros_1d(K_LEN)
for j in 0..K_LEN {
    let mut dot = 0.0
    for k in 0..D {
        dot = dot + Q_mat[0][k] * K_mat[j][k]
    }
    direct_scores[j] = dot * scale_d
}
let direct_m = fa3_row_max(direct_scores, K_LEN)
let mut direct_l = 0.0
for j in 0..K_LEN {
    direct_l = direct_l + fa3_exp(direct_scores[j] - direct_m)
}
check("T22 pipeline_block l_row matches direct", approx(pb_l0, direct_l, 1.0e-6) && approx(pb_m0, direct_m, 1.0e-9))

// T23 fa3_rescale_online identical input/output (no-op merge with empty new block)
let old_out = [0.5, 1.0, 1.5, 2.0]
let empty_new = fa3_zeros_1d(D)
// m_new = -inf, l_new = 0, new_block = 0 -> should return (m_old, l_old, out_old)
let merged = fa3_rescale_online(2.0, fa3_neg_inf(), 3.0, 0.0, old_out, empty_new, D)
let mm = merged[0]
let ml = merged[1]
let mo = merged[2]
let mut r23_ok = approx(mm, 2.0, 1.0e-6) && approx(ml, 3.0, 1.0e-6)
for k in 0..D {
    if !approx(mo[k], old_out[k], 1.0e-6) { r23_ok = false }
}
check("T23 rescale_online no-op merge with -inf", r23_ok)

// T24 fa3_rescale_online combining two blocks matches full softmax concat
// Build two halves of a score set, run pipeline_block on each half vs one block on the union,
// fold the two halves via rescale_online and verify final normalized out matches the full block.
let T24_Q = [Q_mat[0]]
let T24_K1 = [K_mat[0], K_mat[1], K_mat[2]]
let T24_V1 = [V_mat[0], V_mat[1], V_mat[2]]
let T24_K2 = [K_mat[3], K_mat[4], K_mat[5]]
let T24_V2 = [V_mat[3], V_mat[4], V_mat[5]]
let T24_Kall = [K_mat[0], K_mat[1], K_mat[2], K_mat[3], K_mat[4], K_mat[5]]
let T24_Vall = [V_mat[0], V_mat[1], V_mat[2], V_mat[3], V_mat[4], V_mat[5]]

let t24a = fa3_pipeline_block(T24_Q, T24_K1, T24_V1, 1, 3, D)
let t24b = fa3_pipeline_block(T24_Q, T24_K2, T24_V2, 1, 3, D)
let t24full = fa3_pipeline_block(T24_Q, T24_Kall, T24_Vall, 1, 6, D)

let a_row = t24a[0]
let b_row = t24b[0]
let full_row = t24full[0]
let m_a = a_row[0]
let l_a = a_row[1]
let o_a = a_row[2]
let m_b = b_row[0]
let l_b = b_row[1]
let o_b = b_row[2]
// start from -inf, l=0, out=0 then merge a then merge b
let merge1 = fa3_rescale_online(fa3_neg_inf(), m_a, 0.0, l_a, fa3_zeros_1d(D), o_a, D)
let merge2 = fa3_rescale_online(merge1[0], m_b, merge1[1], l_b, merge1[2], o_b, D)
let m_merged = merge2[0]
let l_merged = merge2[1]
let o_merged = merge2[2]
// finalize
let mut final_online = fa3_zeros_1d(D)
for k in 0..D { final_online[k] = o_merged[k] / l_merged }
let m_full = full_row[0]
let l_full = full_row[1]
let o_full = full_row[2]
let mut final_direct = fa3_zeros_1d(D)
for k in 0..D { final_direct[k] = o_full[k] / l_full }
let mut max_r24_diff = 0.0
for k in 0..D {
    let dd = fabs(final_online[k] - final_direct[k])
    if dd > max_r24_diff { max_r24_diff = dd }
}
check("T24 online merge == full block (diff < 1e-6)", max_r24_diff < 1.0e-6)

// T25 fa3_reference_sdpa output shape [q_len, d]
let ref_out = fa3_reference_sdpa(Q_mat, K_mat, V_mat, Q_LEN, K_LEN, D)
check("T25 reference_sdpa shape", len(ref_out) == Q_LEN && len(ref_out[0]) == D)

// T26 fa3_reference_sdpa: for zero Q all rows identical to uniform V average
let zero_Q = fa3_zeros_2d(Q_LEN, D)
let uni_ref = fa3_reference_sdpa(zero_Q, K_mat, V_mat, Q_LEN, K_LEN, D)
// uniform softmax over zeros -> each weight 1/K_LEN
let mut expected_avg = fa3_zeros_1d(D)
for j in 0..K_LEN {
    for k in 0..D {
        expected_avg[k] = expected_avg[k] + V_mat[j][k] / to_float(K_LEN)
    }
}
let mut t26_ok = true
for i in 0..Q_LEN {
    for k in 0..D {
        if !approx(uni_ref[i][k], expected_avg[k], 1.0e-6) { t26_ok = false }
    }
}
check("T26 zero Q -> uniform V avg (non-causal)", t26_ok)

// T27 fa3_fa3_forward output shape [q_len, d]
let fa3_out = fa3_fa3_forward(Q_mat, K_mat, V_mat, Q_LEN, K_LEN, D, Q_BLOCK, KV_BLOCK)
check("T27 fa3_fa3_forward shape", len(fa3_out) == Q_LEN && len(fa3_out[0]) == D)

// T28 fa3_fa3_forward ≈ reference SDPA within 1e-2
let mut max_diff_t28 = 0.0
for i in 0..Q_LEN {
    for k in 0..D {
        let dd = fabs(fa3_out[i][k] - ref_out[i][k])
        if dd > max_diff_t28 { max_diff_t28 = dd }
    }
}
check("T28 FA3 ≈ reference (max_diff < 1e-2)", max_diff_t28 < 1.0e-2)

// T29 fa3_fa3_forward single-tile (q_block=q_len, kv_block=k_len) == reference
let single_tile_out = fa3_fa3_forward(Q_mat, K_mat, V_mat, Q_LEN, K_LEN, D, Q_LEN, K_LEN)
let mut max_diff_t29 = 0.0
for i in 0..Q_LEN {
    for k in 0..D {
        let dd = fabs(single_tile_out[i][k] - ref_out[i][k])
        if dd > max_diff_t29 { max_diff_t29 = dd }
    }
}
check("T29 single tile == reference (max_diff < 1e-6)", max_diff_t29 < 1.0e-6)

// T30 fa3_fa3_forward q_block > q_len yields one Q tile, output still matches
let big_q_out = fa3_fa3_forward(Q_mat, K_mat, V_mat, Q_LEN, K_LEN, D, 999, 2)
let mut max_diff_t30 = 0.0
for i in 0..Q_LEN {
    for k in 0..D {
        let dd = fabs(big_q_out[i][k] - ref_out[i][k])
        if dd > max_diff_t30 { max_diff_t30 = dd }
    }
}
check("T30 big q_block -> 1 Q tile matches reference", max_diff_t30 < 1.0e-2)

// T31 fa3_fa3_forward very small kv_block still matches reference
let tiny_kv_out = fa3_fa3_forward(Q_mat, K_mat, V_mat, Q_LEN, K_LEN, D, 2, 1)
let mut max_diff_t31 = 0.0
for i in 0..Q_LEN {
    for k in 0..D {
        let dd = fabs(tiny_kv_out[i][k] - ref_out[i][k])
        if dd > max_diff_t31 { max_diff_t31 = dd }
    }
}
check("T31 kv_block=1 matches reference", max_diff_t31 < 1.0e-2)

// T32 Zero Q -> uniform V average (non-causal) via fa3_fa3_forward
let zero_fa3_out = fa3_fa3_forward(zero_Q, K_mat, V_mat, Q_LEN, K_LEN, D, Q_BLOCK, KV_BLOCK)
let mut t32_ok = true
for i in 0..Q_LEN {
    for k in 0..D {
        if !approx(zero_fa3_out[i][k], expected_avg[k], 1.0e-6) { t32_ok = false }
    }
}
check("T32 zero Q -> uniform V avg via FA3", t32_ok)

// T33 Causal position 0 uses only V[0]
// Manually build a 1-query attention with q_pos=0 and apply causal mask:
// scores[j] = -inf for j > 0, so softmax weight on V[0] = 1.
let T33_Q = [Q_mat[0]]
let T33_K = [K_mat[0], K_mat[1], K_mat[2], K_mat[3]]
let T33_V = [V_mat[0], V_mat[1], V_mat[2], V_mat[3]]
// Run pipeline_block with causal mask applied to scores manually
let t33_scale = 1.0 / fa3_sqrt(to_float(D))
let mut t33_scores = fa3_zeros_1d(4)
for j in 0..4 {
    let mut dot = 0.0
    for k in 0..D { dot = dot + T33_Q[0][k] * T33_K[j][k] }
    t33_scores[j] = fa3_causal_mask_score(dot * t33_scale, 0, j)
}
// softmax + weighted sum
let t33_m = fa3_row_max(t33_scores, 4)
let mut t33_exps = fa3_zeros_1d(4)
let mut t33_z = 0.0
for j in 0..4 {
    let e = fa3_exp(t33_scores[j] - t33_m)
    t33_exps[j] = e
    t33_z = t33_z + e
}
let mut t33_out = fa3_zeros_1d(D)
for k in 0..D {
    let mut acc = 0.0
    for j in 0..4 { acc = acc + t33_exps[j] * T33_V[j][k] / t33_z }
    t33_out[k] = acc
}
let mut t33_ok = true
for k in 0..D {
    if !approx(t33_out[k], V_mat[0][k], 1.0e-6) { t33_ok = false }
}
check("T33 causal q_pos=0 -> only V[0]", t33_ok)

// T34 fa3_softmax_fp8 handles n=1 correctly
let single_sm = fa3_softmax_fp8([5.0], 1)
check("T34 softmax_fp8 n=1 -> [1.0]", len(single_sm) == 1 && approx(single_sm[0], 1.0, 0.01))

// T35 fa3_fp8_quantize_row preserves max magnitude within e4m3 range
let t35_input = [12.0, -50.0, 100.0, -200.0, 300.0]
let t35_pair = fa3_fp8_quantize_row(t35_input, 5, fa3_e4m3_max())
let t35_q = t35_pair[0]
let t35_max_q = fa3_row_amax(t35_q, 5)
check("T35 quantized magnitude <= e4m3_max", t35_max_q <= fa3_e4m3_max() + 1.0e-6)

// ===================================================================
println("")
println("=== Flash Attention 3 test summary ===")
println("PASS: " + to_string(pass_count))
println("FAIL: " + to_string(fail_count))
println("TOTAL: " + to_string(pass_count + fail_count))
