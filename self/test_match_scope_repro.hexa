// Minimal reproduction of match scope leakage

enum Result {
    Ok(val),
    Err(msg)
}

// Test 1: Does match binding leak to outer scope?
fn test_leak() {
    let r = Result::Ok(42)
    let result = match r {
        Ok(x) -> x * 2,
        Err(e) -> 0
    }
    // x should NOT be visible here
    // If it leaks, referencing x would give 42
    println("result = " + to_string(result))
}

test_leak()

// Test 2: Sequential matches with same binding name
fn test_sequential() {
    let r1 = Result::Ok(10)
    let v1 = match r1 {
        Ok(val) -> val,
        Err(_) -> 0
    }

    let r2 = Result::Ok(20)
    let v2 = match r2 {
        Ok(val) -> val,
        Err(_) -> 0
    }

    println("v1 = " + to_string(v1) + ", v2 = " + to_string(v2))
    if v1 == 10 && v2 == 20 {
        println("PASS: sequential matches independent")
    } else {
        println("FAIL: sequential matches - v1=" + to_string(v1) + " v2=" + to_string(v2))
    }
}

test_sequential()

// Test 3: Higher-order function with match called multiple times
fn and_then(r, f) {
    return match r {
        Ok(val) -> f(val),
        Err(e) -> Result::Err(e)
    }
}

fn double_ok(x) {
    return Result::Ok(x * 2)
}

fn test_higher_order() {
    let r1 = Result::Ok(5)
    let result1 = and_then(r1, double_ok)

    let r2 = Result::Ok(7)
    let result2 = and_then(r2, double_ok)

    let v1 = match result1 {
        Ok(x) -> x,
        Err(_) -> -1
    }
    let v2 = match result2 {
        Ok(x) -> x,
        Err(_) -> -1
    }

    println("v1 = " + to_string(v1) + ", v2 = " + to_string(v2))
    if v1 == 10 && v2 == 14 {
        println("PASS: higher-order match independent")
    } else {
        println("FAIL: higher-order - v1=" + to_string(v1) + " v2=" + to_string(v2))
    }
}

test_higher_order()

// Test 4: Match binding should not be visible after match
fn test_no_leak_after() {
    let r = Result::Ok(99)
    let _ = match r {
        Ok(leaked) -> leaked,
        Err(_) -> 0
    }
    // Try to access 'leaked' - it should not exist
    let mut found_leak = false
    try {
        let check = leaked
        found_leak = true
        println("FAIL: 'leaked' is visible after match, value = " + to_string(check))
    } catch e {
        println("PASS: 'leaked' not visible after match")
    }
}

test_no_leak_after()
