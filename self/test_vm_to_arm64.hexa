// self/test_vm_to_arm64.hexa — Phase 7 P7-8
// Tests for self/codegen/vm_to_arm64.hexa (VM bytecode → ARM64).
//
// Strategy:
//   1. Four tests assert the emitted ARM64 byte pattern against the
//      expected encoding (self-contained, runs anywhere).
//   2. The first test (test_load_ret) additionally executes end-to-end
//      by patching the bytes into a Mach-O template that
//      self/codegen_native.hexa produces at /tmp/hexa_native_t1. If
//      that template file is absent we skip the native-exec assertion
//      (still count as pass so CI without Apple Silicon doesn't fail).
//
// (The transpiler source is inlined at the top of this file because
//  self-host .hexa has no `import`/`use` yet. When the module system
//  lands this file will simply `use self/codegen/vm_to_arm64`.)

// ─────────────────────────────────────────────────────────────────
// BEGIN inlined copy of self/codegen/vm_to_arm64.hexa
// (kept byte-identical with the source file — update together).
// ─────────────────────────────────────────────────────────────────

fn vma_op_const() -> int            { return 0 }
fn vma_op_pop() -> int              { return 2 }
fn vma_op_add() -> int              { return 4 }
fn vma_op_sub() -> int              { return 5 }
fn vma_op_mul() -> int              { return 6 }
fn vma_op_eq() -> int               { return 13 }
fn vma_op_lt() -> int               { return 15 }
fn vma_op_jump() -> int             { return 26 }
fn vma_op_jump_if_false() -> int    { return 27 }
fn vma_op_return() -> int           { return 31 }

fn vma_operand_bytes(op: int) -> int {
    if op == vma_op_const()         { return 1 }
    if op == vma_op_jump()          { return 1 }
    if op == vma_op_jump_if_false() { return 1 }
    return 0
}

fn vma_enc_movz(rd: int, imm: int) -> int {
    return 3531603968 + imm * 32 + rd
}
fn vma_enc_add(rd: int, rn: int, rm: int) -> int {
    return 2332033024 + rm * 65536 + rn * 32 + rd
}
fn vma_enc_sub(rd: int, rn: int, rm: int) -> int {
    return 3405774848 + rm * 65536 + rn * 32 + rd
}
fn vma_enc_mul(rd: int, rn: int, rm: int) -> int {
    return 2600500224 + rm * 65536 + rn * 32 + rd
}
fn vma_enc_mov_reg(rd: int, rm: int) -> int {
    return 2852127712 + rm * 65536 + rd
}
fn vma_enc_cmp(rn: int, rm: int) -> int {
    return 3942645791 + rm * 65536 + rn * 32
}
fn vma_enc_cset(rd: int, cond: int) -> int {
    if cond == 0  { return 2594113504 + 1  * 4096 + rd }
    if cond == 1  { return 2594113504 + 0  * 4096 + rd }
    if cond == 10 { return 2594113504 + 11 * 4096 + rd }
    if cond == 11 { return 2594113504 + 10 * 4096 + rd }
    if cond == 12 { return 2594113504 + 13 * 4096 + rd }
    if cond == 13 { return 2594113504 + 12 * 4096 + rd }
    return 2594113504 + rd
}
fn vma_enc_b(off26: int) -> int {
    let mut o = off26
    if o < 0 { o = o + 67108864 }
    return 335544320 + o
}
fn vma_enc_bcond(cond: int, off19: int) -> int {
    let mut o = off19
    if o < 0 { o = o + 524288 }
    return 1409286144 + o * 32 + cond
}
fn vma_enc_svc() -> int { return 3556773889 }

fn vma_push_u32_le(bytes: [int], v: int) -> [int] {
    let mut b = bytes
    b = b.push(v % 256)
    b = b.push((v / 256) % 256)
    b = b.push((v / 65536) % 256)
    b = b.push((v / 16777216) % 256)
    return b
}

fn vma_slot_to_reg(slot: int) -> int { return slot + 1 }
fn vma_max_depth() -> int { return 3 }

fn vma_build_offset_map(bc: [int]) -> [int] {
    let mut map = []
    let n = len(bc)
    let mut i = 0
    let mut arm = 0
    let mut k = 0
    while k <= n {
        map = map.push(-1)
        k = k + 1
    }
    while i < n {
        map[i] = arm
        let op = bc[i]
        let ob = vma_operand_bytes(op)
        let mut emits = 0
        if op == vma_op_const()         { emits = 1 }
        if op == vma_op_pop()           { emits = 0 }
        if op == vma_op_add()           { emits = 1 }
        if op == vma_op_sub()           { emits = 1 }
        if op == vma_op_mul()           { emits = 1 }
        if op == vma_op_eq()            { emits = 2 }
        if op == vma_op_lt()            { emits = 2 }
        if op == vma_op_jump()          { emits = 1 }
        if op == vma_op_jump_if_false() { emits = 2 }
        if op == vma_op_return()        { emits = 3 }
        arm = arm + emits * 4
        i = i + 1 + ob
    }
    map[n] = arm
    return map
}

fn transpile_bytecode(bytecode: [int]) -> [int] {
    let offset_map = vma_build_offset_map(bytecode)
    let n = len(bytecode)
    let mut out = []
    let mut i = 0
    let mut depth = 0

    while i < n {
        let op = bytecode[i]
        let here_arm = len(out)

        if op == vma_op_const() {
            let imm = bytecode[i + 1]
            if depth >= vma_max_depth() {
                println("transpile_bytecode: stack overflow (depth > 3) at pc=" + to_string(i))
                return out
            }
            let rd = vma_slot_to_reg(depth)
            out = vma_push_u32_le(out, vma_enc_movz(rd, imm))
            depth = depth + 1
            i = i + 2
        } else if op == vma_op_pop() {
            if depth <= 0 {
                println("transpile_bytecode: stack underflow on POP")
                return out
            }
            depth = depth - 1
            i = i + 1
        } else if op == vma_op_add() {
            if depth < 2 { println("stack underflow ADD"); return out }
            let rb = vma_slot_to_reg(depth - 1)
            let ra = vma_slot_to_reg(depth - 2)
            out = vma_push_u32_le(out, vma_enc_add(ra, ra, rb))
            depth = depth - 1
            i = i + 1
        } else if op == vma_op_sub() {
            if depth < 2 { println("stack underflow SUB"); return out }
            let rb = vma_slot_to_reg(depth - 1)
            let ra = vma_slot_to_reg(depth - 2)
            out = vma_push_u32_le(out, vma_enc_sub(ra, ra, rb))
            depth = depth - 1
            i = i + 1
        } else if op == vma_op_mul() {
            if depth < 2 { println("stack underflow MUL"); return out }
            let rb = vma_slot_to_reg(depth - 1)
            let ra = vma_slot_to_reg(depth - 2)
            out = vma_push_u32_le(out, vma_enc_mul(ra, ra, rb))
            depth = depth - 1
            i = i + 1
        } else if op == vma_op_eq() {
            if depth < 2 { println("stack underflow EQ"); return out }
            let rb = vma_slot_to_reg(depth - 1)
            let ra = vma_slot_to_reg(depth - 2)
            out = vma_push_u32_le(out, vma_enc_cmp(ra, rb))
            out = vma_push_u32_le(out, vma_enc_cset(ra, 0))
            depth = depth - 1
            i = i + 1
        } else if op == vma_op_lt() {
            if depth < 2 { println("stack underflow LT"); return out }
            let rb = vma_slot_to_reg(depth - 1)
            let ra = vma_slot_to_reg(depth - 2)
            out = vma_push_u32_le(out, vma_enc_cmp(ra, rb))
            out = vma_push_u32_le(out, vma_enc_cset(ra, 11))
            depth = depth - 1
            i = i + 1
        } else if op == vma_op_jump() {
            let mut delta = bytecode[i + 1]
            if delta >= 128 { delta = delta - 256 }
            let tgt_bc = i + 2 + delta
            let tgt_arm = offset_map[tgt_bc]
            let rel_insns = (tgt_arm - here_arm) / 4
            out = vma_push_u32_le(out, vma_enc_b(rel_insns))
            i = i + 2
        } else if op == vma_op_jump_if_false() {
            if depth < 1 { println("stack underflow JIF"); return out }
            let rtop = vma_slot_to_reg(depth - 1)
            depth = depth - 1
            let mut delta = bytecode[i + 1]
            if delta >= 128 { delta = delta - 256 }
            let tgt_bc = i + 2 + delta
            let tgt_arm = offset_map[tgt_bc]
            out = vma_push_u32_le(out, vma_enc_cmp(rtop, 31))
            let after_cmp_arm = len(out)
            let rel_insns = (tgt_arm - after_cmp_arm) / 4
            out = vma_push_u32_le(out, vma_enc_bcond(0, rel_insns))
            i = i + 2
        } else if op == vma_op_return() {
            if depth < 1 { println("stack underflow RET"); return out }
            let rtop = vma_slot_to_reg(depth - 1)
            out = vma_push_u32_le(out, vma_enc_mov_reg(0, rtop))
            out = vma_push_u32_le(out, vma_enc_movz(16, 1))
            out = vma_push_u32_le(out, vma_enc_svc())
            depth = depth - 1
            i = i + 1
        } else {
            println("transpile_bytecode: unsupported op " + to_string(op))
            return out
        }
    }
    return out
}

// ─────────────────────────────────────────────────────────────────
// END inlined copy
// ─────────────────────────────────────────────────────────────────

let mut pass_count = 0
let mut fail_count = 0

fn record(name: string, ok: bool) {
    if ok {
        pass_count = pass_count + 1
        println("  PASS  " + name)
    } else {
        fail_count = fail_count + 1
        println("  FAIL  " + name)
    }
}

// Compare two int arrays for equality.
fn bytes_eq(a: [int], b: [int]) -> bool {
    if len(a) != len(b) { return false }
    let mut i = 0
    while i < len(a) {
        if a[i] != b[i] { return false }
        i = i + 1
    }
    return true
}

fn hex_byte(v: int) -> string {
    let HEX = "0123456789abcdef"
    return HEX[(v / 16) % 16] + HEX[v % 16]
}

fn bytes_hex(a: [int]) -> string {
    let mut parts = []
    let mut i = 0
    while i < len(a) {
        parts.push(hex_byte(a[i]))
        i = i + 1
    }
    return parts.join(" ")
}

// Emit the same bytes the transpiler should have produced, as an
// independent reference, by hand-building the expected instruction
// stream from the vm_a encoders.
fn ref_mov_ret(imm: int) -> [int] {
    let mut out = []
    out = vma_push_u32_le(out, vma_enc_movz(1, imm))          // MOVZ x1, #imm
    out = vma_push_u32_le(out, vma_enc_mov_reg(0, 1))         // MOV  x0, x1
    out = vma_push_u32_le(out, vma_enc_movz(16, 1))           // MOVZ x16, #1
    out = vma_push_u32_le(out, vma_enc_svc())                 // SVC
    return out
}

fn ref_add() -> [int] {
    // LOAD 3, LOAD 4, ADD, RET
    let mut out = []
    out = vma_push_u32_le(out, vma_enc_movz(1, 3))            // MOVZ x1, #3
    out = vma_push_u32_le(out, vma_enc_movz(2, 4))            // MOVZ x2, #4
    out = vma_push_u32_le(out, vma_enc_add(1, 1, 2))          // ADD  x1, x1, x2
    out = vma_push_u32_le(out, vma_enc_mov_reg(0, 1))         // MOV  x0, x1
    out = vma_push_u32_le(out, vma_enc_movz(16, 1))
    out = vma_push_u32_le(out, vma_enc_svc())
    return out
}

fn ref_mul_chain() -> [int] {
    // LOAD 3, LOAD 4, MUL, LOAD 2, ADD, RET → 3*4+2 = 14
    let mut out = []
    out = vma_push_u32_le(out, vma_enc_movz(1, 3))            // MOVZ x1, #3
    out = vma_push_u32_le(out, vma_enc_movz(2, 4))            // MOVZ x2, #4
    out = vma_push_u32_le(out, vma_enc_mul(1, 1, 2))          // MUL  x1, x1, x2   (depth: 2→1)
    out = vma_push_u32_le(out, vma_enc_movz(2, 2))            // MOVZ x2, #2       (depth: 1→2)
    out = vma_push_u32_le(out, vma_enc_add(1, 1, 2))          // ADD  x1, x1, x2   (depth: 2→1)
    out = vma_push_u32_le(out, vma_enc_mov_reg(0, 1))         // MOV  x0, x1
    out = vma_push_u32_le(out, vma_enc_movz(16, 1))
    out = vma_push_u32_le(out, vma_enc_svc())
    return out
}

// ─────────────────────────────────────────────────────────────────
// Mach-O wrapping + native execution (optional — reuses the template
// produced by self/codegen_native.hexa at /tmp/hexa_native_t1).
// ─────────────────────────────────────────────────────────────────

fn try_exec_macho(code_bytes: [int], path: string) -> int {
    // Returns the observed exit code, or -1 if the template is missing
    // (in which case we skip the native-exec check).
    let template = "/tmp/hexa_native_t1"
    let check = exec_with_status("test -f " + template + " && echo yes || echo no")
    let line = check[0].trim()
    if line != "yes" {
        println("    (skip native exec: " + template + " missing — run self/codegen_native.hexa first)")
        return -1
    }
    let base = read_file_bytes(template)
    let base_len = len(base)
    let patch_off = 768      // 0x300 — standard __text offset in codegen_native Mach-O
    let old_code_len = 44    // size of the template's original instruction sequence

    let mut patched = []
    let mut i = 0
    while i < patch_off {
        patched = patched.push(base[i])
        i = i + 1
    }
    let mut j = 0
    while j < len(code_bytes) {
        patched = patched.push(code_bytes[j])
        j = j + 1
    }
    // Pad if the new code is shorter than old_code_len so we preserve
    // downstream file offsets exactly.
    while len(patched) < patch_off + old_code_len {
        patched = patched.push(0)
    }
    let mut k = patch_off + old_code_len
    while k < base_len {
        patched = patched.push(base[k])
        k = k + 1
    }
    write_bytes(path, patched)
    exec("chmod +x " + path)
    exec("codesign --force --sign - " + path + " 2>&1")
    let r = exec_with_status(path)
    return r[1]
}

// ── Tests ────────────────────────────────────────────────────────

// test_load_ret: [OP_CONST 42, OP_RETURN] → exit 42
fn test_load_ret() {
    let bc = [vma_op_const(), 42, vma_op_return()]
    let got = transpile_bytecode(bc)
    let expect = ref_mov_ret(42)
    let ok = bytes_eq(got, expect)
    record("test_load_ret bytes", ok)
    if !ok {
        println("    got:    " + bytes_hex(got))
        println("    expect: " + bytes_hex(expect))
    }
    let rc = try_exec_macho(got, "/tmp/vm2arm_load_ret")
    if rc >= 0 {
        let native_ok = rc == 42
        record("test_load_ret native exec (exit=" + to_string(rc) + ")", native_ok)
    }
}

// test_add: [CONST 3, CONST 4, ADD, RETURN] → exit 7
fn test_add() {
    let bc = [vma_op_const(), 3, vma_op_const(), 4, vma_op_add(), vma_op_return()]
    let got = transpile_bytecode(bc)
    let expect = ref_add()
    let ok = bytes_eq(got, expect)
    record("test_add bytes", ok)
    if !ok {
        println("    got:    " + bytes_hex(got))
        println("    expect: " + bytes_hex(expect))
    }
    let rc = try_exec_macho(got, "/tmp/vm2arm_add")
    if rc >= 0 {
        let native_ok = rc == 7
        record("test_add native exec (exit=" + to_string(rc) + ")", native_ok)
    }
}

// test_cmp_jump:
//   [CONST 5, CONST 5, EQ, JUMP_IF_FALSE +3, CONST 1, RETURN, CONST 0, RETURN]
//   The EQ produces 1 (true). JUMP_IF_FALSE will NOT branch, so we fall
//   through to [CONST 1, RETURN] → exit 1.
//   (JUMP_IF_FALSE branches when top==0; here top==1.)
//
// Bytecode layout (indices):
//   0 CONST  1  (op)
//   1          (operand=5)
//   2 CONST  1
//   3          (operand=5)
//   4 EQ
//   5 JUMP_IF_FALSE
//   6          (operand=+3 → target pc = 7+3 = 10 → 'CONST 0')
//   7 CONST
//   8          (operand=1)
//   9 RETURN
//  10 CONST
//  11          (operand=0)
//  12 RETURN
fn test_cmp_jump() {
    let bc = [
        vma_op_const(), 5,
        vma_op_const(), 5,
        vma_op_eq(),
        vma_op_jump_if_false(), 3,
        vma_op_const(), 1,
        vma_op_return(),
        vma_op_const(), 0,
        vma_op_return()
    ]
    let got = transpile_bytecode(bc)
    // Byte-level sanity: must be non-empty and a multiple of 4.
    let shape_ok = len(got) > 0 && (len(got) % 4) == 0
    record("test_cmp_jump shape (len=" + to_string(len(got)) + ")", shape_ok)
    let rc = try_exec_macho(got, "/tmp/vm2arm_cmp_jump")
    if rc >= 0 {
        let native_ok = rc == 1
        record("test_cmp_jump native exec (exit=" + to_string(rc) + ")", native_ok)
    }
}

// test_mul_chain: [CONST 3, CONST 4, MUL, CONST 2, ADD, RETURN] → exit 14
fn test_mul_chain() {
    let bc = [
        vma_op_const(), 3,
        vma_op_const(), 4,
        vma_op_mul(),
        vma_op_const(), 2,
        vma_op_add(),
        vma_op_return()
    ]
    let got = transpile_bytecode(bc)
    let expect = ref_mul_chain()
    let ok = bytes_eq(got, expect)
    record("test_mul_chain bytes", ok)
    if !ok {
        println("    got:    " + bytes_hex(got))
        println("    expect: " + bytes_hex(expect))
    }
    let rc = try_exec_macho(got, "/tmp/vm2arm_mul_chain")
    if rc >= 0 {
        let native_ok = rc == 14
        record("test_mul_chain native exec (exit=" + to_string(rc) + ")", native_ok)
    }
}

// Stack-depth limit is enforced: 4 CONSTs should abort after emitting
// 3 MOVZ and leaving the 4th un-emitted. We verify the emitted length
// equals exactly 3×4 = 12 bytes.
fn test_depth_limit() {
    let bc = [
        vma_op_const(), 1,
        vma_op_const(), 2,
        vma_op_const(), 3,
        vma_op_const(), 4,
        vma_op_return()
    ]
    let got = transpile_bytecode(bc)
    let ok = len(got) == 12
    record("test_depth_limit bails at depth>3 (emitted " + to_string(len(got)) + " bytes)", ok)
}

// ── Driver ──────────────────────────────────────────────────────

println("=== self/codegen/vm_to_arm64 — P7-8 tests ===")
test_load_ret()
test_add()
test_cmp_jump()
test_mul_chain()
test_depth_limit()

println("")
println("Results: " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL")
if fail_count == 0 {
    println("OVERALL: PASS")
} else {
    println("OVERALL: FAIL")
}
