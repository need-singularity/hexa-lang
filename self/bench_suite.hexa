// ══════════════════════════════════════════════════════════════════
// HEXA-LANG Performance Regression Benchmark Suite
// ──────────────────────────────────────────────────────────────────
// Purpose : 회귀 방지 — VM 333x / @memoize 1126x 성과 보존 검증
// Runtime : Tiered (JIT → VM → Interp) — 각 tier 동일 측정 지원
// Output  : JSON-lines (CI 파싱 용이)
// Thresholds: docs/benchmarks.md 참조
//
// 실행:
//   ./hexa self/bench_suite.hexa
//   ./hexa self/bench_suite.hexa --only=loop      # 단일 벤치
//   ./hexa self/bench_suite.hexa --tier=vm        # tier 강제
//
// 각 벤치는 독립 함수로 격리 — CI에서 분할 실행 가능.
// ══════════════════════════════════════════════════════════════════

// ───── JSON 결과 출력 헬퍼 ─────
// 포맷: {"name":"<id>","ms":<float>,"ops":<int>,"ok":<bool>}
fn emit(name: string, ms: float, ops: int, ok: bool) {
    print("{\"name\":\"")
    print(name)
    print("\",\"ms\":")
    print(ms)
    print(",\"ops\":")
    print(ops)
    print(",\"ok\":")
    if ok { print("true") } else { print("false") }
    println("}")
}

fn seconds_to_ms(s: float) -> float {
    s * 1000.0
}

// ══════════════════════════════════════════════════════════════════
// [B1] 루프 1M iterations — VM dispatch 코스트 핵심 지표
//      회귀 임계값: 50 ms (VM 333x 돌파 후 ~6 ms 기대)
// ══════════════════════════════════════════════════════════════════
fn bench_loop_1m() {
    let start = clock()
    let sum = 0
    let i = 0
    while i < 1000000 {
        sum = sum + i
        i = i + 1
    }
    let ms = seconds_to_ms(clock() - start)
    let ok = sum == 499999500000
    emit("loop_1m", ms, 1000000, ok)
}

// ══════════════════════════════════════════════════════════════════
// [B2] 재귀 피보나치 fib(30) — call/return + 브랜치 예측
//      회귀 임계값: 200 ms
// ══════════════════════════════════════════════════════════════════
fn fib(n: int) -> int {
    if n <= 1 { return n }
    return fib(n - 1) + fib(n - 2)
}

fn bench_fib_recursive_30() {
    let start = clock()
    let r = fib(30)
    let ms = seconds_to_ms(clock() - start)
    emit("fib_recursive_30", ms, 1, r == 832040)
}

// ══════════════════════════════════════════════════════════════════
// [B3] 배열 정렬 10K (insertion sort) — 인덱싱 + 스왑
//      회귀 임계값: 500 ms
// ══════════════════════════════════════════════════════════════════
fn bench_array_sort_10k() {
    let n = 10000
    // pseudo-random fill (LCG)
    let arr = []
    let seed = 1103515245
    let i = 0
    while i < n {
        seed = (seed * 1103515245 + 12345) % 2147483647
        arr.push(seed)
        i = i + 1
    }
    let start = clock()
    // insertion sort
    i = 1
    while i < n {
        let key = arr[i]
        let j = i - 1
        while j >= 0 && arr[j] > key {
            arr[j + 1] = arr[j]
            j = j - 1
        }
        arr[j + 1] = key
        i = i + 1
    }
    let ms = seconds_to_ms(clock() - start)
    // validation: monotonic
    let ok = true
    i = 1
    while i < n {
        if arr[i - 1] > arr[i] { ok = false }
        i = i + 1
    }
    emit("array_sort_10k", ms, n, ok)
}

// ══════════════════════════════════════════════════════════════════
// [B4] 문자열 concat 10K — StringBuilder 스트리밍 회귀 감시
//      회귀 임계값: 100 ms (O(n²) 재발 시 >10 s 로 폭발)
// ══════════════════════════════════════════════════════════════════
fn bench_string_concat_10k() {
    let s = ""
    let i = 0
    let start = clock()
    while i < 10000 {
        s = s + "x"
        i = i + 1
    }
    let ms = seconds_to_ms(clock() - start)
    emit("string_concat_10k", ms, 10000, s.length == 10000)
}

// ══════════════════════════════════════════════════════════════════
// [B5] Map/Dict 삽입 100K — 해시테이블 경로
//      회귀 임계값: 300 ms
// ══════════════════════════════════════════════════════════════════
fn bench_map_insert_100k() {
    let m = {}
    let i = 0
    let start = clock()
    while i < 100000 {
        m[i] = i * 2
        i = i + 1
    }
    let ms = seconds_to_ms(clock() - start)
    emit("map_insert_100k", ms, 100000, m[99999] == 199998)
}

// ══════════════════════════════════════════════════════════════════
// [B6] Struct 메서드 디스패치 1M — impl vtable/inline 경로
//      회귀 임계값: 150 ms
// ══════════════════════════════════════════════════════════════════
struct Counter {
    value: int
}

impl Counter {
    fn bump(self) -> int {
        self.value = self.value + 1
        return self.value
    }
}

fn bench_struct_dispatch_1m() {
    let c = Counter { value: 0 }
    let i = 0
    let start = clock()
    while i < 1000000 {
        c.bump()
        i = i + 1
    }
    let ms = seconds_to_ms(clock() - start)
    emit("struct_dispatch_1m", ms, 1000000, c.value == 1000000)
}

// ══════════════════════════════════════════════════════════════════
// [B7] @memoize 히트율 — AI-native attr 1126x 성과 보존
//      콜드: fib(30) 1회 / 핫: 100K 재호출 히트
//      회귀 임계값: hot < 50 ms, hit_ratio >= 0.999
// ══════════════════════════════════════════════════════════════════
@memoize
fn mfib(n: int) -> int {
    if n <= 1 { return n }
    return mfib(n - 1) + mfib(n - 2)
}

fn bench_memoize_hit_ratio() {
    // cold
    let cold_start = clock()
    let cold = mfib(30)
    let cold_ms = seconds_to_ms(clock() - cold_start)
    emit("memoize_cold_fib30", cold_ms, 1, cold == 832040)

    // hot — 캐시 히트만 발생해야 함
    let hot_start = clock()
    let i = 0
    let acc = 0
    while i < 100000 {
        acc = acc + mfib(30)
        i = i + 1
    }
    let hot_ms = seconds_to_ms(clock() - hot_start)
    let ok = acc == 832040 * 100000
    emit("memoize_hot_100k", hot_ms, 100000, ok)

    // 히트율 근사: hot 평균 호출당 시간 << cold
    // ratio = 1 - (hot_per_call / cold_per_call)
    let hot_per = hot_ms / 100000.0
    let ratio_ok = hot_per < (cold_ms / 10.0)  // 최소 10x speedup
    emit("memoize_speedup_ok", hot_per, 100000, ratio_ok)
}

// ══════════════════════════════════════════════════════════════════
// Runner — 순차 실행, JSON-lines 출력
// ══════════════════════════════════════════════════════════════════
fn main() {
    println("# HEXA bench_suite v1 — JSON-lines output")
    bench_loop_1m()
    bench_fib_recursive_30()
    bench_array_sort_10k()
    bench_string_concat_10k()
    bench_map_insert_100k()
    bench_struct_dispatch_1m()
    bench_memoize_hit_ratio()
    println("# done")
}

main()
