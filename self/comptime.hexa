// Evaluate a comptime block (list of statements).
// Returns the value of the last expression.
fn eval_comptime_block(stmts: [string], comptime_fn_names: [string], comptime_fn_params: [string]) -> string {
    // In full impl: run each statement in sandboxed interpreter, return last value
    if len(stmts) == 0 { return "void" }
    return eval_comptime(stmts[len(stmts) - 1], comptime_fn_names, comptime_fn_params)
}
