// G12: multiline call args + G13: slicing — selfhost verify
fn add3(a: int, b: int, c: int) -> int {
    return a + b + c
}

fn main() {
    // G12: multiline call args
    let r = add3(
        10,
        20,
        30
    )
    assert(r == 60)
    println("G12 multiline call OK: " + to_string(r))

    // G13: array slice exclusive
    let xs = [10, 20, 30, 40, 50]
    let sub = xs[1..4]
    assert(len(sub) == 3)
    assert(sub[0] == 20)
    assert(sub[2] == 40)
    println("G13 array slice exclusive OK")

    // G13: array slice inclusive
    let sub2 = xs[1..=3]
    assert(len(sub2) == 3)
    assert(sub2[0] == 20)
    assert(sub2[2] == 40)
    println("G13 array slice inclusive OK")

    // G13: string slice exclusive
    let s = "hello"[1..4]
    assert(s == "ell")
    println("G13 string slice exclusive OK: " + s)

    // G13: string slice inclusive
    let s2 = "hello"[1..=3]
    assert(s2 == "ell")
    println("G13 string slice inclusive OK: " + s2)

    println("ALL G12/G13 selfhost tests PASS")
}

main()
