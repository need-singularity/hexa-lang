// self/raws/silent_error.hexa — raw #10: silent error 금지
//
// rule:
//   (a) exit(N≠0) — 선행 5줄 내 stderr/println + (error|fail|err:) 토큰 없으면 block
//   (c) empty catch body — `catch e { }` 또는 catch body 가 주석/공백 만으로 구성 시 block
//   (b) let _ = <error-return fn>()  — 타입 정보 필요, deferred (Tier 2)
//
// 보완: @allow-silent-exit 마커 (self/attrs/allow_silent_exit.hexa) 있으면 skip —
//       의도적 silent exit (예: stdout-prefix 프로토콜) 은 attr 로 선언.
//
// 참고: ROI #149 fix(import) deep use-chain silent exit — Claude 의 default drift
//       (학습 데이터 C/Python 편향) 으로 가장 자주 발생하는 패턴.

use "self/attrs/core"
use "self/attrs/allow_silent_exit"

fn meta_silent_error() -> AttrMeta {
    let mut m = empty_meta()
    m.name        = "silent_error"
    m.category    = "raw"
    m.purpose     = "exit / empty-catch 로 error 조용히 삼키는 패턴 차단"
    m.cost_rule   = ".hexa line-scan — exit(N≠0) 선행 5줄 err msg 없으면 reject + empty catch body reject"
    m.side_effect = "enforce() 는 LintMsg 배열 반환. tool/error_propagation_lint.hexa 실행 시 violation>0 이면 exit 1"
    m.requires    = "self/attrs/core (mk_msg), self/attrs/allow_silent_exit (marker 감지)"
    m.auto_test   = "tests/raws/silent_error_cases.hexa (추후)"
    m.example     = "eprintln(\"error: <reason>\"); exit(1)"
    m.implemented = true
    return m
}

// ─── (a) silent exit 감지 ─────────────────────────────────────
// exit(N) 에서 N != 0 이고, 선행 5줄 내에 eprintln/println/stderr + error|fail|err 없으면 violation
fn _scan_silent_exit(path: string, lines: [string]) {
    let mut out = []
    let mut i = 0
    let n = len(lines)
    while i < n {
        let t = lines[i].trim()
        if t.starts_with("//") { i = i + 1; continue }

        let p = t.index_of("exit(")
        if p < 0 { i = i + 1; continue }

        // skip `exit(` as part of identifier (e.g. `_scan_silent_exit(`)
        if p > 0 {
            let prev = t.substring(p - 1, p)
            let pc = char_code(prev, 0)
            let is_alpha = (pc >= 97 && pc <= 122) || (pc >= 65 && pc <= 90)
            let is_digit = pc >= 48 && pc <= 57
            let is_under = pc == 95
            if is_alpha || is_digit || is_under { i = i + 1; continue }
        }

        // skip `exit(` inside string literal — 앞까지 `"` 홀수면 문자열 내부
        let before = t.substring(0, p)
        let mut quote_cnt = 0
        let chars_before = before.chars()
        let mut escaped = false
        for ch in chars_before {
            if escaped { escaped = false; continue }
            if ch == '\\' { escaped = true; continue }
            if ch == '"' { quote_cnt = quote_cnt + 1 }
        }
        if quote_cnt % 2 == 1 { i = i + 1; continue }

        let after = t.substring(p + 5, len(t))
        let cp = after.index_of(")")
        if cp <= 0 { i = i + 1; continue }

        let arg = after.substring(0, cp).trim()
        if arg == "0" || arg == "" { i = i + 1; continue }

        // skip non-numeric args in string-interpolated context
        // (heuristic: arg 에 `"` 포함 시 문자열 조립 중 → skip)
        if arg.contains("\"") { i = i + 1; continue }

        // @allow-silent-exit 마커 검사 — 선행 주석 블록
        // 해당 exit 을 포함하는 fn 의 시그니처 찾아서 marker 확인
        let fn_line = _enclosing_fn_line(lines, i)
        if fn_line > 0 && _has_silent_exit_marker(lines, fn_line) { i = i + 1; continue }

        // 선행 5줄 내 error msg 검사
        let mut has_msg = false
        let back = if i >= 5 { i - 5 } else { 0 }
        let mut j = back
        while j < i {
            let pt = lines[j].trim()
            let has_print = pt.contains("eprintln") || pt.contains("stderr") || pt.contains("println")
            let has_err = pt.contains("error") || pt.contains("Error")
                       || pt.contains("fail") || pt.contains("Fail")
                       || pt.contains("err:")
            if has_print && has_err { has_msg = true; break }
            j = j + 1
        }

        if !has_msg {
            out.push(mk_msg(
                "silent_error", "error", path, i + 1, 0,
                "silent exit — 선행 5줄 내 error msg 없음 (exit(" + arg + "))",
                "eprintln 으로 exit 사유 명시 후 exit",
                "eprintln(\"error: <reason>\"); exit(" + arg + ")",
                "raw #10 / self/raws/silent_error.hexa"))
        }
        i = i + 1
    }
    return out
}

// i 인덱스 (0-based) 를 감싸는 가장 가까운 fn 시그니처 라인 (1-based) 리턴. 없으면 -1.
fn _enclosing_fn_line(lines: [string], i: int) -> int {
    let mut k = i
    while k >= 0 {
        let t = lines[k].trim()
        if t.starts_with("fn ") || t.starts_with("pub fn ") { return k + 1 }
        k = k - 1
    }
    return -1
}

// ─── (c) empty catch 감지 ─────────────────────────────────────
fn _scan_empty_catch(path: string, lines: [string]) {
    let mut out = []
    let mut i = 0
    let n = len(lines)
    while i < n {
        let t = lines[i].trim()
        if t.starts_with("//") { i = i + 1; continue }

        // `catch ` 토큰 + `{` 존재
        let has_catch = t.contains("catch ") || t.contains("catch\t")
        if !has_catch { i = i + 1; continue }

        let open = t.index_of("{")
        if open < 0 { i = i + 1; continue }

        let after = t.substring(open + 1, len(t)).trim()

        // 같은 줄에 `} ` 닫힘
        if after == "}" {
            out.push(mk_msg(
                "silent_error", "error", path, i + 1, 0,
                "empty catch — error 조용히 삼킴",
                "최소 eprintln 으로 error 표시, 또는 재전파",
                "catch e { eprintln(\"warn: \" + e.msg) }",
                "raw #10 / self/raws/silent_error.hexa"))
            i = i + 1
            continue
        }

        // 같은 줄에 body 없이 열린 경우 → 다음 줄 부터 `}` 까지 비어있는지
        if after == "" {
            let mut k = i + 1
            let mut empty = true
            while k < n {
                let nt = lines[k].trim()
                if nt == "}" { break }
                if nt != "" && !nt.starts_with("//") { empty = false; break }
                k = k + 1
            }
            if empty && k < n {
                out.push(mk_msg(
                    "silent_error", "error", path, i + 1, 0,
                    "empty catch body — error 조용히 삼킴",
                    "최소 eprintln 으로 error 표시, 또는 재전파",
                    "catch e { eprintln(\"warn: \" + e.msg) }",
                    "raw #10 / self/raws/silent_error.hexa"))
            }
        }
        i = i + 1
    }
    return out
}

// ─── 파일 단위 scan ───────────────────────────────────────────
pub fn silent_error_scan_file(path: string) {
    let mut msgs = []
    let src = to_string(exec("cat '" + path + "' 2>/dev/null"))
    if src == "" { return msgs }
    let lines = split(src, "\n")

    let a = _scan_silent_exit(path, lines)
    for m in a { msgs.push(m) }

    let c = _scan_empty_catch(path, lines)
    for m in c { msgs.push(m) }

    return msgs
}

// ─── 여러 파일 enforce ────────────────────────────────────────
pub fn silent_error_enforce(paths: [string]) {
    let mut all = []
    for p in paths {
        let msgs = silent_error_scan_file(p)
        for m in msgs { all.push(m) }
    }
    return all
}

// ─── induce stub ──────────────────────────────────────────────
// 현 단계: git-hook / 명시적 `hexa tool/error_propagation_lint.hexa` 실행이 enforce 경로.
// 추후: hexa_stage0 preflight 에 induce_all() 연결 (전 raw 모듈 패턴 확정 후).
pub fn silent_error_induce() -> string {
    return "raw #10 silent_error — scan via `hexa tool/error_propagation_lint.hexa [path...]`. " +
           "opt-out: @allow-silent-exit marker on fn signature (see self/attrs/allow_silent_exit.hexa)."
}
