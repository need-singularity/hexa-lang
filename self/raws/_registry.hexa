// self/raws/_registry.hexa — raw 모듈 dispatch SSOT (mirrors self/attrs/_registry.hexa 패턴)
//
// 각 raw = 1 .hexa 모듈 = meta_<name>() + <name>_scan_file() + <name>_enforce() + <name>_induce()
// (attrs 의 meta/check 대칭 — raw 는 enforce/induce 2가지)
//
// Phase 1 (현재): silent_error (raw #10) 단독. 기존 raw #3/#4/#5/#6/#7/#8/#9 는 여전히
//                 도구/ + git-hook 에 분산. Phase 2/3/4 로 점진 이전 예정.
//
// 대응 규칙: /.raw (L0 universal) + /.own (L1 project-local) — SSOT.
// 이 파일은 hexa 모듈 간 dispatch 진입점 역할.
// 파서: self/raw_loader.hexa (hexa-directive format, not JSON).
// NOTE (raw-migration 2026-04-19): legacy shared/hexa-lang/raw.json 대체.

use "self/raws/silent_error"
use "self/raws/hexa_only"
use "self/raws/ai_native_algo"

pub fn all_raw_names() {
    return [
        "hexa_only",
        "silent_error",
        "ai_native_algo"
    ]
}

pub fn meta_of(name: string) {
    if name == "hexa_only"      { return meta_hexa_only() }
    if name == "silent_error"   { return meta_silent_error() }
    if name == "ai_native_algo" { return meta_ai_native_algo() }
    return #{}
}

pub fn enforce_of(name: string, paths: [string]) {
    if name == "hexa_only"      { return hexa_only_enforce(paths) }
    if name == "silent_error"   { return silent_error_enforce(paths) }
    if name == "ai_native_algo" { return ai_native_algo_enforce(paths) }
    return []
}

pub fn induce_of(name: string) -> string {
    if name == "hexa_only"      { return hexa_only_induce() }
    if name == "silent_error"   { return silent_error_induce() }
    if name == "ai_native_algo" { return ai_native_algo_induce() }
    return ""
}

// 전체 induce — 추후 hexa_stage0 preflight 에서 호출 예정 (env HEXA_RAWS_PREFLIGHT=1 재귀 방지)
pub fn induce_all() {
    let mut out = []
    for n in all_raw_names() {
        out = out.push(induce_of(n))
    }
    return out
}
