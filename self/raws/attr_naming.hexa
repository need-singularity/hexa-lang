// self/raws/attr_naming.hexa — raw #3: @attr 네이밍 컨벤션 강제
//
// rule:
//   신규 @attr 이름은 self/attrs/_naming.hexa 규칙 준수 (SSOT).
//     · single lowercase English word (verb or adjective)
//     · max 13 chars
//     · no hyphen / underscore / digit / camelCase
//     · 예약어 충돌 금지
//
// enforcement:
//   기존 (git-hook 스탠자): hexa build/hexa_stage0 self/attr_cli.hexa lint <staged> |
//                            grep -E 'naming violation|attr_naming'
//   본 모듈 (Phase 3 이관): attr_naming_enforce(paths) → LintMsg[]
//     · 각 path (.hexa file) 를 읽고 check_naming_all() 로 전 registry 검사
//     · + source 내 attr-like declaration (`pub fn meta_<name>()`) 이름을 스캔해서
//       _naming 규칙 위반 시 파일-레벨 violation 추가
//
// SSOT: self/attrs/_naming.hexa (naming_reason) + self/attrs/_registry.hexa (check_naming_all)
// 포팅 범위: 기존 enforcer 는 CLI 출력 문자열 grep 에 의존 — 본 모듈은 같은 _naming 규칙을
//            LintMsg 로 리턴 (인용 포팅, 재구현 최소).

use "self/attrs/core"
use "self/attrs/_naming"
use "self/attrs/_registry"

fn meta_attr_naming() -> AttrMeta {
    let mut m = empty_meta()
    m.name        = "attr_naming"
    m.category    = "raw"
    m.purpose     = "신규 @attr 이름이 _naming 규칙 (단일 소문자 영단어 13자 이내) 위반 시 block"
    m.cost_rule   = "registry self-audit (check_naming_all) + per-file meta_<name> 스캔"
    m.side_effect = "enforce() 는 LintMsg 배열 반환. git-hook 은 attr_cli.hexa lint 경유"
    m.requires    = "self/attrs/_naming.hexa (naming_reason SSOT), self/attrs/_registry.hexa (check_naming_all)"
    m.auto_test   = "viol name 삽입 시 naming_reason != \"\" 확인"
    m.example     = "@approximate (valid), @approx_fast (invalid — underscore)"
    m.implemented = true
    return m
}

// ─── registry self-audit — 전체 등록 attr 이름 스캔 ─────────────
// 파일 경로 무관 — 1회 호출로 모든 registry 위반 리턴
pub fn attr_naming_audit_registry() {
    let mut out = []
    let viol = check_naming_all()  // [[name, reason], ...]
    for v in viol {
        let nm = v[0]
        let reason = v[1]
        out = out.push(mk_msg(
            "attr_naming", "error", "self/attrs/_registry.hexa", 0, 0,
            "@" + nm + " 네이밍 위반: " + reason,
            "self/attrs/_naming.hexa naming_form() 참고 — 단일 소문자 영단어 13자",
            "@attr 이름 재선정 후 self/attrs/<new>.hexa + _registry.hexa 양쪽 동시 갱신",
            "raw #3 / self/raws/attr_naming.hexa"))
    }
    return out
}

// ─── per-file scan — `fn meta_<name>()` 선언에서 <name> 추출 후 _naming 검사 ────
// 신규 @attr 파일이 스테이지되는 순간 이름 위반 캐치 (registry 등록 전에도)
pub fn attr_naming_scan_file(path: string) {
    let mut out = []
    let src = to_string(exec("cat '" + path + "' 2>/dev/null"))
    if src == "" { return out }
    let lines = split(src, "\n")
    let mut i = 0
    let n = len(lines)
    while i < n {
        let t = lines[i].trim()
        if t.starts_with("//") { i = i + 1; continue }

        // `fn meta_<name>()` 또는 `pub fn meta_<name>()` 매칭
        let mut rest = ""
        if t.starts_with("fn meta_")         { rest = t.substring(8, len(t)) }
        else if t.starts_with("pub fn meta_") { rest = t.substring(12, len(t)) }
        else { i = i + 1; continue }

        // name 끝: `(` 직전까지
        let paren = rest.index_of("(")
        if paren <= 0 { i = i + 1; continue }
        let name = rest.substring(0, paren)
        if name == "" { i = i + 1; continue }

        let reason = naming_reason(name)
        if reason != "" {
            out = out.push(mk_msg(
                "attr_naming", "error", path, i + 1, 0,
                "@" + name + " 네이밍 위반: " + reason,
                "self/attrs/_naming.hexa naming_form() — 단일 소문자 영단어 13자",
                "이름 재선정 후 self/attrs/<new>.hexa + _registry.hexa 동시 갱신",
                "raw #3 / self/raws/attr_naming.hexa"))
        }
        i = i + 1
    }
    return out
}

// ─── enforce — staged/explicit 파일 리스트 + registry self-audit ─
pub fn attr_naming_enforce(paths: [string]) {
    let mut all = []

    // 1) registry self-audit — paths 무관 1회
    let reg = attr_naming_audit_registry()
    for m in reg { all = all.push(m) }

    // 2) per-file scan — self/attrs/*.hexa 에 대해서만 스캔 (다른 .hexa 는 meta_ 선언 없음)
    for p in paths {
        if !p.contains("self/attrs/") { continue }
        let msgs = attr_naming_scan_file(p)
        for m in msgs { all = all.push(m) }
    }
    return all
}

pub fn attr_naming_induce() -> string {
    return "raw #3 attr_naming — self/attrs/_naming.hexa 규칙 (단일 소문자 영단어 13자). " +
           "scan via `hexa self/attr_cli.hexa lint <file>` or attr_naming_enforce(paths). " +
           "registry self-audit: check_naming_all() in self/attrs/_registry.hexa."
}
