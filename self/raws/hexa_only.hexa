// self/raws/hexa_only.hexa — raw #7: HEXA-ONLY (.rs/.toml/.py/.sh 금지)
//
// rule: 프로젝트 트리에 .rs/.toml/.py/.sh 확장자 금지. SELF-HOST FIRST (HX4).
// exempt: tests/fixtures/*, third_party/*, *.hexanoport (명시 마커)
//
// enforcement:
//   git-hook (.git/hooks/pre-commit#raw7) — staged diff 에서 차단 (기존)
//   + self/raws/ 모듈 (본 파일) — induce path 탐색 후 block
//
// induce: `hexa self/raws/_registry.hexa induce_all()` 시 전체 트리 스캔
//         (staged 외 git tracked 전체) → 위반 시 stderr + violation 리턴.
//         hexa_interp preflight 통합은 Phase 2+ 로 연기.

use "self/attrs/core"

fn meta_hexa_only() -> AttrMeta {
    let mut m = empty_meta()
    m.name        = "hexa_only"
    m.category    = "raw"
    m.purpose     = "SELF-HOST FIRST — .rs/.toml/.py/.sh 차단, 모든 코드 .hexa"
    m.cost_rule   = "git tracked file scan — forbidden ext 발견 시 violation"
    m.side_effect = "enforce() 는 LintMsg 배열 반환. git-hook + 수동 호출 양쪽 지원"
    m.requires    = "git (tracked file 조회)"
    m.auto_test   = "foo.rs 임시 stage → enforce 가 violation 잡음 확인"
    m.example     = "SELF-HOST: .hexa 로 작성. 프리젠 C only 는 .hexanoport 마커."
    m.implemented = true
    return m
}

fn _forbidden_exts() {
    return [".rs", ".toml", ".py", ".sh"]
}

fn _is_exempt(path: string) -> bool {
    // exempt: tests/fixtures/, third_party/, vendor/, node_modules/
    if path.contains("tests/fixtures/") { return true }
    if path.contains("third_party/") { return true }
    if path.contains("vendor/") { return true }
    if path.contains("node_modules/") { return true }
    // .hexanoport — 프리젠 C 예외 마커
    if path.ends_with(".hexanoport") { return true }
    return false
}

fn _has_forbidden_ext(path: string) -> string {
    let exts = _forbidden_exts()
    for e in exts {
        if path.ends_with(e) { return e }
    }
    return ""
}

pub fn hexa_only_scan_paths(paths: [string]) {
    let mut out = []
    for p in paths {
        if _is_exempt(p) { continue }
        let ext = _has_forbidden_ext(p)
        if ext == "" { continue }
        out.push(mk_msg(
            "hexa_only", "error", p, 0, 0,
            "HEXA-ONLY 위반 — 금지 확장자 " + ext,
            ".hexa 로 재작성 (SELF-HOST FIRST). 프리젠 C 는 .hexanoport 마커 추가",
            "mv " + p + " " + p + ".hexanoport  # 예외인 경우만",
            "raw #7 / self/raws/hexa_only.hexa"))
    }
    return out
}

pub fn hexa_only_enforce(paths: [string]) {
    return hexa_only_scan_paths(paths)
}

// git tracked 전체 스캔 — induce 시점 기본 동작
pub fn hexa_only_scan_tracked() {
    let out = to_string(exec("git ls-files 2>/dev/null")).trim()
    let mut paths = []
    if out != "" {
        let parts = split(out, "\n")
        for p in parts {
            let t = p.trim()
            if t != "" { paths.push(t) }
        }
    }
    return hexa_only_scan_paths(paths)
}

pub fn hexa_only_induce() -> string {
    return "raw #7 hexa_only — git ls-files 스캔, .rs/.toml/.py/.sh 발견 시 block. " +
           "exempt: tests/fixtures, third_party, vendor, node_modules, *.hexanoport marker."
}
