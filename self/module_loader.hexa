// self/module_loader.hexa — concat-based HEXA module loader (Phase2 C1)
//
// 목적: bootstrap.hexa 1,945줄 모놀리스 해체.
//   - 지시문: 첫 non-space 토큰이 `import "path.hexa"` 또는 `use "path.hexa"` 인 라인
//   - 재귀적으로 파일 내용을 인라인 병합 (concat).
//   - 순환 import 감지 (visited list).
//   - 경로는 현재 파일의 디렉토리 상대로 해석.
//
// 이 로더는 parser/lexer/interpreter 와 독립적인 소스 전처리기다.
// 전처리된 문자열을 parser 에 넘기면 모듈 지원이 사실상 완성된다.
//
// API:
//   load_module(path)                  -> string   (preprocessed source)
//   ml_resolve(src, base_dir, vs)      -> string   (internal helper)
//   ml_resolve_path(path)              -> string   (.hexa 확장자 폴백)
//
// CLI:
//   stage0 self/module_loader.hexa               → 자체 스모크 테스트
//   stage0 self/module_loader.hexa <in> <out>    → imports/uses 전개 후 <out> 기록
//
// 의존: read_file / write_file / file_exists 빌트인, 기본 string api.

fn ml_dirname(path) {
    // T36 fix: char-by-char parts.push + join was O(n²) per line and blew
    // memory to 143GB when expanding multi-use files (bc_emitter 1349 lines
    // + bc_vm 719 lines). substring() on the host path stays O(n).
    let n = len(path)
    let mut i = n - 1
    while i >= 0 {
        if path[i] == '/' {
            return path.substring(0, i)
        }
        i = i - 1
    }
    return "."
}

fn ml_join_path(dir, rel) {
    if len(rel) > 0 {
        if rel[0] == '/' { return rel }
    }
    if len(dir) == 0 { return rel }
    return dir + "/" + rel
}

fn ml_trim_left(s) {
    // T36 fix: host builtin trim_start replaces the O(n²) char-array
    // accumulator (parts.push + join) that blew memory to 143GB when
    // expanding multi-use files (bc_emitter 1349 + bc_vm 719 lines).
    return s.trim_start()
}

fn ml_starts_with(s, prefix) {
    let pn = len(prefix)
    let sn = len(s)
    if pn > sn { return false }
    let mut i = 0
    while i < pn {
        if s[i] != prefix[i] { return false }
        i = i + 1
    }
    return true
}

fn ml_split_lines(s) {
    // T36 fix: host builtin split replaces char-by-char parts.push + join.
    return s.split("\n")
}

fn ml_contains(list, needle) {
    let n = len(list)
    let mut i = 0
    while i < n {
        if list[i] == needle { return true }
        i = i + 1
    }
    return false
}

fn ml_parse_import(line) {
    // T36 fix: substring in place of char-by-char parts.push + join.
    let trimmed = ml_trim_left(line)
    let mut prefix_len = 0
    if ml_starts_with(trimmed, "import ") {
        prefix_len = 7
    } else if ml_starts_with(trimmed, "use ") {
        prefix_len = 4
    } else {
        return ""
    }
    let n = len(trimmed)
    if prefix_len >= n { return "" }
    let rest = ml_trim_left(trimmed.substring(prefix_len, n))
    let rn = len(rest)
    if rn < 2 { return "" }
    if rest[0] != '"' { return "" }
    let mut i = 1
    while i < rn {
        if rest[i] == '"' {
            return rest.substring(1, i)
        }
        i = i + 1
    }
    return ""
}

fn ml_resolve_path(full) {
    if file_exists(full) { return full }
    let with_ext = full + ".hexa"
    if file_exists(with_ext) { return with_ext }
    return full
}

// HX-stdlib-fallback: if `use "stdlib/foo"` (relative to caller dir) fails,
// try well-known hexa-lang stdlib location: $HEXA_LANG/self/<imp>.hexa.
// Enables consumers anywhere on disk to `use "stdlib/string"` and find the
// HEXA-native string helpers (T4 migration target).
fn ml_resolve_stdlib(imp) {
    if !ml_starts_with(imp, "stdlib/") { return "" }
    let hl = env_var("HEXA_LANG")
    if len(hl) == 0 { return "" }
    let cand = hl + "/self/" + imp + ".hexa"
    if file_exists(cand) { return cand }
    return ""
}

// Strip `pub ` visibility prefix from top-level declarations.
// After module inlining everything is in a single TU; the stage0
// parser (pre-G39 binary) chokes on `@attr pub fn` sequences.
// Stripping `pub ` at the source level is safe — codegen ignores
// visibility anyway (single translation unit).
fn ml_strip_pub(src) {
    // Fast exit: no `pub ` in source at all
    if src.index_of("pub ") < 0 { return src }
    let lines = ml_split_lines(src)
    let n = len(lines)
    let mut out = []
    let mut i = 0
    while i < n {
        let line = lines[i]
        let t = ml_trim_left(line)
        if ml_starts_with(t, "pub fn ") || ml_starts_with(t, "pub struct ") || ml_starts_with(t, "pub enum ") || ml_starts_with(t, "pub let ") || ml_starts_with(t, "pub const ") {
            // Compute leading whitespace length
            let tlen = len(t)
            let llen = len(line)
            let ws = line.substring(0, llen - tlen)
            // Remove "pub " (4 chars) from the trimmed line
            out = out.push(ws + t.substring(4, tlen))
        } else {
            out = out.push(line)
        }
        i = i + 1
    }
    return out.join("\n")
}

fn ml_resolve(src, base_dir, visited) {
    let lines = ml_split_lines(src)
    let mut out_parts = []
    let n = len(lines)
    let mut i = 0
    while i < n {
        let line = lines[i]
        let imp = ml_parse_import(line)
        if imp == "" {
            out_parts = out_parts.push(line)
            out_parts = out_parts.push("\n")
        } else {
            let raw_full = ml_join_path(base_dir, imp)
            let mut full = ml_resolve_path(raw_full)
            // HX-stdlib-fallback: if local resolve missed, try stdlib/<imp>.
            if !file_exists(full) {
                let std_full = ml_resolve_stdlib(imp)
                if len(std_full) > 0 { full = std_full }
            }
            if ml_contains(visited, full) {
                out_parts = out_parts.push("// [module_loader] cycle skipped: " + full)
                out_parts = out_parts.push("\n")
            } else {
                let vs2 = visited.push(full)
                let child_src = read_file(full)
                let child_dir = ml_dirname(full)
                let expanded = ml_resolve(child_src, child_dir, vs2)
                let cleaned = ml_strip_pub(expanded)
                out_parts = out_parts.push("// [module_loader] begin: " + full)
                out_parts = out_parts.push("\n")
                out_parts = out_parts.push(cleaned)
                out_parts = out_parts.push("// [module_loader] end: " + full)
                out_parts = out_parts.push("\n")
            }
        }
        i = i + 1
    }
    return out_parts.join("")
}

fn load_module(path) {
    let src = read_file(path)
    let dir = ml_dirname(path)
    let visited = [path]
    return ml_resolve(src, dir, visited)
}

let __ml_av = args()
if len(__ml_av) >= 4 {
    let expanded = load_module(__ml_av[2])
    write_file(__ml_av[3], expanded)
} else {
    println("[module_loader] helpers ready")
    assert ml_dirname("a/b/c.hexa") == "a/b"
    assert ml_dirname("foo.hexa") == "."
    assert ml_join_path("a/b", "c.hexa") == "a/b/c.hexa"
    assert ml_join_path("a", "/abs/x.hexa") == "/abs/x.hexa"
    assert ml_starts_with("import \"x\"", "import ")
    assert ml_parse_import("import \"lexer.hexa\"") == "lexer.hexa"
    assert ml_parse_import("  import \"a/b.hexa\"") == "a/b.hexa"
    assert ml_parse_import("use \"mod_a.hexa\"") == "mod_a.hexa"
    assert ml_parse_import("  use \"a/b.hexa\"") == "a/b.hexa"
    assert ml_parse_import("let x = 1") == ""
    assert ml_parse_import("// import \"x\"") == ""
    let ls = ml_split_lines("a\nb\nc")
    assert len(ls) == 3
    assert ls[0] == "a"
    assert ls[2] == "c"
    println("[module_loader] self-test PASS")
}
