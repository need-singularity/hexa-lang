// ===================================================================
//  test_conv_pure.hexa -- coverage for self/runtime/conv_pure.hexa
//
//  Pitfalls honored: P1 no semicolons, P15 let mut, P29 push rebind,
//  P39 no 0b literals, P12 handle reserved, while loops only
// ===================================================================

// ── INLINED from runtime/conv_pure.hexa ──

@pure
pub fn parse_int_pure(s) {
    if type_of(s) != "string" { return 0 }
    let n = len(s)
    if n == 0 { return 0 }
    let mut i = 0
    while i < n {
        let ch = s.substring(i, i + 1)
        if ch == " " || ch == "\t" || ch == "\n" || ch == "\r" {
            i = i + 1
        } else {
            break
        }
    }
    if i >= n { return 0 }
    let mut sign = 1
    let ch0 = s.substring(i, i + 1)
    if ch0 == "+" {
        i = i + 1
    } else if ch0 == "-" {
        sign = 0 - 1
        i = i + 1
    }
    let mut base = 10
    if (i + 1) < n {
        let p0 = s.substring(i, i + 1)
        let p1 = s.substring(i + 1, i + 2)
        if p0 == "0" && (p1 == "x" || p1 == "X") {
            base = 16
            i = i + 2
        }
    }
    let ord0 = ord("0")
    let ord9 = ord("9")
    let orda = ord("a")
    let ordf = ord("f")
    let ordA = ord("A")
    let ordF = ord("F")
    let mut val = 0
    let mut consumed = false
    while i < n {
        let c = ord(s.substring(i, i + 1))
        let mut digit = 0 - 1
        if c >= ord0 && c <= ord9 {
            digit = c - ord0
        }
        if base == 16 && digit < 0 {
            if c >= orda && c <= ordf {
                digit = c - orda + 10
            } else if c >= ordA && c <= ordF {
                digit = c - ordA + 10
            }
        }
        if digit < 0 { break }
        if digit >= base { break }
        val = val * base + digit
        consumed = true
        i = i + 1
    }
    if consumed == false { return 0 }
    val * sign
}

@pure
pub fn parse_float_pure(s) {
    if type_of(s) != "string" { return 0.0 }
    let n = len(s)
    if n == 0 { return 0.0 }
    let mut i = 0
    while i < n {
        let ch = s.substring(i, i + 1)
        if ch == " " || ch == "\t" || ch == "\n" || ch == "\r" {
            i = i + 1
        } else {
            break
        }
    }
    if i >= n { return 0.0 }
    let mut sign = 1.0
    let ch0 = s.substring(i, i + 1)
    if ch0 == "+" {
        i = i + 1
    } else if ch0 == "-" {
        sign = 0.0 - 1.0
        i = i + 1
    }
    let ord0 = ord("0")
    let ord9 = ord("9")
    let mut val = 0.0
    let mut consumed = false
    while i < n {
        let c = ord(s.substring(i, i + 1))
        if c < ord0 || c > ord9 { break }
        val = val * 10.0 + to_float(c - ord0)
        consumed = true
        i = i + 1
    }
    if i < n {
        let dot = s.substring(i, i + 1)
        if dot == "." {
            i = i + 1
            let mut pw = 0.1
            while i < n {
                let cf = ord(s.substring(i, i + 1))
                if cf < ord0 || cf > ord9 { break }
                val = val + to_float(cf - ord0) * pw
                pw = pw / 10.0
                consumed = true
                i = i + 1
            }
        }
    }
    if consumed == false { return 0.0 }
    if i < n {
        let ce = s.substring(i, i + 1)
        if ce == "e" || ce == "E" {
            let mut j = i + 1
            let mut exp_sign = 1
            if j < n {
                let cs = s.substring(j, j + 1)
                if cs == "+" {
                    j = j + 1
                } else if cs == "-" {
                    exp_sign = 0 - 1
                    j = j + 1
                }
            }
            let mut exp_val = 0
            let mut exp_seen = false
            while j < n {
                let cd = ord(s.substring(j, j + 1))
                if cd < ord0 || cd > ord9 { break }
                exp_val = exp_val * 10 + (cd - ord0)
                exp_seen = true
                j = j + 1
            }
            if exp_seen {
                let mut k = 0
                if exp_sign > 0 {
                    while k < exp_val {
                        val = val * 10.0
                        k = k + 1
                    }
                } else {
                    while k < exp_val {
                        val = val / 10.0
                        k = k + 1
                    }
                }
            }
        }
    }
    val * sign
}

@pure
pub fn int_to_hex_pure(n) {
    if type_of(n) != "int" { return "0" }
    if n == 0 { return "0" }
    let digits = "0123456789abcdef"
    let mut v = n
    let mut neg = false
    if v < 0 {
        neg = true
        v = 0 - v
    }
    let mut out = ""
    while v > 0 {
        let d = v % 16
        out = digits.substring(d, d + 1) + out
        v = v / 16
    }
    if neg { return "-" + out }
    out
}

@pure
pub fn int_to_bin_pure(n) {
    if type_of(n) != "int" { return "0" }
    if n == 0 { return "0" }
    let mut v = n
    let mut neg = false
    if v < 0 {
        neg = true
        v = 0 - v
    }
    let mut out = ""
    while v > 0 {
        let bit = v % 2
        if bit == 0 { out = "0" + out } else { out = "1" + out }
        v = v / 2
    }
    if neg { return "-" + out }
    out
}

@pure
pub fn int_to_oct_pure(n) {
    if type_of(n) != "int" { return "0" }
    if n == 0 { return "0" }
    let digits = "01234567"
    let mut v = n
    let mut neg = false
    if v < 0 {
        neg = true
        v = 0 - v
    }
    let mut out = ""
    while v > 0 {
        let d = v % 8
        out = digits.substring(d, d + 1) + out
        v = v / 8
    }
    if neg { return "-" + out }
    out
}

@pure
pub fn to_int_pure(v) {
    let t = type_of(v)
    if t == "int" { return v }
    if t == "float" {
        if v >= 0.0 {
            let mut result = 0
            let mut remaining = v
            let mut power = 1
            while to_float(power) * 10.0 <= remaining {
                power = power * 10
            }
            while power >= 1 {
                let d = 0
                let fp = to_float(power)
                let mut digit = 0
                while to_float(digit + 1) * fp <= remaining {
                    digit = digit + 1
                }
                result = result + digit * power
                remaining = remaining - to_float(digit) * fp
                power = power / 10
            }
            return result
        } else {
            let pos = 0.0 - v
            let mut result = 0
            let mut remaining = pos
            let mut power = 1
            while to_float(power) * 10.0 <= remaining {
                power = power * 10
            }
            while power >= 1 {
                let mut digit = 0
                let fp = to_float(power)
                while to_float(digit + 1) * fp <= remaining {
                    digit = digit + 1
                }
                result = result + digit * power
                remaining = remaining - to_float(digit) * fp
                power = power / 10
            }
            return 0 - result
        }
    }
    if t == "bool" {
        if v { return 1 }
        return 0
    }
    if t == "string" { return parse_int_pure(v) }
    0
}

@pure
pub fn to_float_pure(v) {
    let t = type_of(v)
    if t == "float" { return v }
    if t == "int" { return v + 0.0 }
    if t == "bool" {
        if v { return 1.0 }
        return 0.0
    }
    if t == "string" { return parse_float_pure(v) }
    0.0
}

@pure
pub fn to_bool_pure(v) {
    let t = type_of(v)
    if t == "void" { return false }
    if t == "bool" { return v }
    if t == "int" { return v != 0 }
    if t == "float" { return v != 0.0 }
    if t == "string" { return len(v) > 0 }
    if t == "array" { return len(v) > 0 }
    if t == "map" {
        let ks = keys(v)
        return len(ks) > 0
    }
    true
}

@pure
pub fn char_to_int_pure(c) {
    if type_of(c) != "string" { return 0 }
    if len(c) == 0 { return 0 }
    ord(c.substring(0, 1))
}

@pure
pub fn int_to_char_pure(n) {
    if type_of(n) != "int" { return "" }
    if n < 0 { return "" }
    if n > 127 { return "" }
    from_char_code(n)
}

@pure
pub fn digit_to_char_pure(d) {
    if type_of(d) != "int" { return "" }
    if d < 0 { return "" }
    let digits = "0123456789abcdefghijklmnopqrstuvwxyz"
    if d >= 36 { return "" }
    digits.substring(d, d + 1)
}

@pure
pub fn char_to_digit_pure(c) {
    if type_of(c) != "string" { return -1 }
    if len(c) == 0 { return -1 }
    let o = ord(c.substring(0, 1))
    if o >= 48 && o <= 57 { return o - 48 }
    if o >= 97 && o <= 102 { return o - 97 + 10 }
    if o >= 65 && o <= 70 { return o - 65 + 10 }
    -1
}

@pure
pub fn int_to_base_pure(n, base) {
    if type_of(n) != "int" { return "0" }
    if base < 2 || base > 36 { return "0" }
    if n == 0 { return "0" }
    let mut v = n
    let mut neg = false
    if v < 0 {
        neg = true
        v = 0 - v
    }
    let mut out = ""
    while v > 0 {
        let d = v % base
        out = digit_to_char_pure(d) + out
        v = v / base
    }
    if neg { return "-" + out }
    out
}

@pure
pub fn is_int_string_pure(s) {
    if type_of(s) != "string" { return false }
    let n = len(s)
    if n == 0 { return false }
    let mut i = 0
    while i < n {
        let ch = s.substring(i, i + 1)
        if ch == " " || ch == "\t" || ch == "\n" || ch == "\r" {
            i = i + 1
        } else {
            break
        }
    }
    if i >= n { return false }
    let ch0 = s.substring(i, i + 1)
    if ch0 == "+" || ch0 == "-" { i = i + 1 }
    if i >= n { return false }
    let c = ord(s.substring(i, i + 1))
    c >= 48 && c <= 57
}

@pure
pub fn is_float_string_pure(s) {
    if type_of(s) != "string" { return false }
    let n = len(s)
    let mut i = 0
    let mut has_dot = false
    let mut has_e = false
    let mut has_digit = false
    while i < n {
        let ch = s.substring(i, i + 1)
        if ch == "." { has_dot = true }
        if ch == "e" || ch == "E" { has_e = true }
        let o = ord(ch)
        if o >= 48 && o <= 57 { has_digit = true }
        i = i + 1
    }
    has_digit && (has_dot || has_e)
}

@pure
pub fn clamp_int_pure(v, lo, hi) {
    if v < lo { return lo }
    if v > hi { return hi }
    v
}

@pure
pub fn clamp_float_pure(v, lo, hi) {
    if v < lo { return lo }
    if v > hi { return hi }
    v
}

// ── END INLINED ──

let mut pass = 0
let mut fail = 0

fn check(name, cond) {
    if cond {
        pass = pass + 1
    } else {
        fail = fail + 1
        println("[FAIL] " + name)
    }
}

fn eq(name, actual, expected) {
    if actual == expected {
        pass = pass + 1
    } else {
        fail = fail + 1
        println("[FAIL] " + name + " expected=" + to_string(expected) + " got=" + to_string(actual))
    }
}

