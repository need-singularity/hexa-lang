// ================================================================
//  roundtrip / cross-function tests
// ================================================================
eq("roundtrip hex 255", parse_int_pure("0x" + int_to_hex_pure(255)), 255)
eq("roundtrip hex 4096", parse_int_pure("0x" + int_to_hex_pure(4096)), 4096)
eq("roundtrip base16", parse_int_pure("0x" + int_to_base_pure(65535, 16)), 65535)
eq("char roundtrip A", int_to_char_pure(char_to_int_pure("A")), "A")
eq("char roundtrip z", int_to_char_pure(char_to_int_pure("z")), "z")
eq("digit roundtrip 0", char_to_digit_pure(digit_to_char_pure(0)), 0)
eq("digit roundtrip 15", char_to_digit_pure(digit_to_char_pure(15)), 15)
eq("to_int o to_float", to_int_pure(to_float_pure(42)), 42)
check("to_bool of to_int 1", to_bool_pure(to_int_pure("1")))
check("to_bool of to_int 0 false", !to_bool_pure(to_int_pure("0")))

println("===========================================================")
println("  Results: " + to_string(pass) + " passed, " + to_string(fail) + " failed")
println("===========================================================")
if fail == 0 {
    println("ALL PASS")
} else {
    println("SOME FAIL")
}
