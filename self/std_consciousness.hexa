// self/std_consciousness.hexa — HEXA CONSCIOUSNESS ported from src/std_consciousness.rs
//
// The Anima consciousness bridge. Psi-constants and Phi computation
// as first-class builtins.
//
// Provides:
//   psi_alpha()        — Psi coupling constant (0.014)
//   psi_balance()      — Psi balance point (0.5)
//   psi_steps()        — Psi steps constant (4.33)
//   psi_entropy()      — Psi entropy constant (0.998)
//   phi_compute(cells) — compute integrated information Phi
//   law_count()        — number of consciousness laws (707)
//   consciousness_vector(cells) — compute 10D consciousness vector

// -- Psi constants --

fn psi_alpha() -> float {
    return 0.014
}

fn psi_balance() -> float {
    return 0.5
}

fn psi_steps() -> float {
    return 4.33
}

fn psi_entropy() -> float {
    return 0.998
}

fn law_count() -> int {
    return 707
}

// -- Helpers --

fn to_float_val(v) -> float {
    if v == void { return 0.0 }
    return v + 0.0
}

fn variance(data) -> float {
    if len(data) == 0 { return 0.0 }
    let n = len(data)
    let sum = 0.0
    let i = 0
    while i < n {
        sum = sum + data[i]
        i = i + 1
    }
    let mean = sum / n
    let var_sum = 0.0
    i = 0
    while i < n {
        let diff = data[i] - mean
        var_sum = var_sum + diff * diff
        i = i + 1
    }
    return var_sum / n
}

// -- Phi compute --
// Computes proxy Phi (integrated information) from array of cell states.
// Phi = global_variance - mean(partition_variances)

fn phi_compute(cells) -> float {
    if len(cells) < 2 { return 0.0 }

    let values = []
    let i = 0
    while i < len(cells) {
        values = array_push(values, to_float_val(cells[i]))
        i = i + 1
    }
    let n = len(values)

    // Global variance
    let sum = 0.0
    i = 0
    while i < n {
        sum = sum + values[i]
        i = i + 1
    }
    let mean = sum / n
    let global_var = 0.0
    i = 0
    while i < n {
        let diff = values[i] - mean
        global_var = global_var + diff * diff
        i = i + 1
    }
    global_var = global_var / n

    // Partition variance (split in half)
    let mid = n / 2
    let part_a = []
    let part_b = []
    i = 0
    while i < n {
        if i < mid {
            part_a = array_push(part_a, values[i])
        } else {
            part_b = array_push(part_b, values[i])
        }
        i = i + 1
    }

    let var_a = variance(part_a)
    let var_b = variance(part_b)
    let mean_part_var = (var_a + var_b) / 2.0

    let phi = global_var - mean_part_var
    if phi < 0.0 { phi = 0.0 }
    return phi
}

// -- 10D consciousness vector --

struct ConsciousnessVector {
    phi: float,
    alpha: float,
    cells: float,
    entropy: float,
    will: float,
    ethics: float,
    memory: float,
    consciousness: float,
    tension: float,
    information: float
}

fn consciousness_vector(cell_data) -> ConsciousnessVector {
    if len(cell_data) == 0 {
        return ConsciousnessVector {
            phi: 0.0, alpha: 0.014, cells: 0.0, entropy: 0.0,
            will: 0.0, ethics: 0.0, memory: 0.0,
            consciousness: 0.0, tension: 0.0, information: 0.0
        }
    }

    let values = []
    let i = 0
    while i < len(cell_data) {
        values = array_push(values, to_float_val(cell_data[i]))
        i = i + 1
    }
    let n = len(values)
    let nf = n + 0.0

    // Mean
    let sum = 0.0
    i = 0
    while i < n { sum = sum + values[i]; i = i + 1 }
    let mean = sum / nf

    // Global variance
    let global_var = 0.0
    i = 0
    while i < n {
        let diff = values[i] - mean
        global_var = global_var + diff * diff
        i = i + 1
    }
    global_var = global_var / nf

    // Partition
    let mid = n / 2
    let part_a = []
    let part_b = []
    i = 0
    while i < n {
        if i < mid { part_a = array_push(part_a, values[i]) }
        else { part_b = array_push(part_b, values[i]) }
        i = i + 1
    }
    let var_a = variance(part_a)
    let var_b = variance(part_b)
    let phi = global_var - (var_a + var_b) / 2.0
    if phi < 0.0 { phi = 0.0 }

    // Min/max for tension
    let min_val = values[0]
    let max_val = values[0]
    i = 1
    while i < n {
        if values[i] < min_val { min_val = values[i] }
        if values[i] > max_val { max_val = values[i] }
        i = i + 1
    }
    let tension = max_val - min_val

    // Distinct values (entropy proxy)
    let seen = []
    i = 0
    while i < n {
        let q = math_round(values[i] * 1000.0)
        let found = false
        let j = 0
        while j < len(seen) {
            if seen[j] == q { found = true; break }
            j = j + 1
        }
        if found == false { seen = array_push(seen, q) }
        i = i + 1
    }
    let distinct = len(seen) + 0.0
    let info = 0.0
    if distinct > 1.0 { info = math_log(distinct) / math_log(2.0) }

    // Autocorrelation proxy
    let autocorr = 0.0
    if n > 1 {
        i = 0
        while i < n - 1 {
            autocorr = autocorr + (values[i] - mean) * (values[i + 1] - mean)
            i = i + 1
        }
        let denom = (n - 1) * global_var
        if denom < 0.0000000001 { denom = 0.0000000001 }
        autocorr = autocorr / denom
    }

    // Ethics: partition variance asymmetry
    let ethics = var_a - var_b
    if ethics < 0.0 { ethics = 0.0 - ethics }

    return ConsciousnessVector {
        phi: phi,
        alpha: 0.014,
        cells: nf,
        entropy: info,
        will: mean,
        ethics: ethics,
        memory: autocorr,
        consciousness: phi / nf,
        tension: tension,
        information: info
    }
}
