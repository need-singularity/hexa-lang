// self/test_module_import.hexa — Phase2 C1 module loader 테스트
//
// 검증 항목:
//   1. ml_parse_import: import 지시문 파싱
//   2. ml_dirname / ml_join_path: 경로 해석
//   3. ml_split_lines: 라인 분할
//   4. load_module: 실제 파일 재귀 로드
//   5. 순환 import 감지
//   6. bootstrap_modular.hexa 확장 결과 줄 수 sanity check
//
// 주의: 이 파일은 module_loader.hexa 를 "스크립트 인라인" 으로 가져온다.
//       로더 자체가 자기참조라 부트 문제 회피 목적으로 복제가 아니라
//       직접 import 지시문을 쓴다 (interpreter 에서는 실행 전에
//       외부 전처리기로 풀어줘야 함 — README 참조).

import "module_loader.hexa"

println("=== test_module_import ===")

// ── 1. import 지시문 파싱 ──────────────────────────────────
println("[1] ml_parse_import")
assert ml_parse_import("import \"foo.hexa\"") == "foo.hexa"
assert ml_parse_import("   import \"dir/bar.hexa\"") == "dir/bar.hexa"
assert ml_parse_import("// import \"ignored.hexa\"") == ""
assert ml_parse_import("let x = 1") == ""
assert ml_parse_import("") == ""
assert ml_parse_import("import") == ""
println("  PASS")

// ── 2. 경로 해석 ──────────────────────────────────────────
println("[2] ml_dirname / ml_join_path")
assert ml_dirname("/a/b/c.hexa") == "/a/b"
assert ml_dirname("x.hexa") == "."
assert ml_join_path("/a/b", "c.hexa") == "/a/b/c.hexa"
assert ml_join_path("/a", "/abs.hexa") == "/abs.hexa"
println("  PASS")

// ── 3. 라인 분할 ──────────────────────────────────────────
println("[3] ml_split_lines")
let lines = ml_split_lines("a\nb\nimport \"x.hexa\"\nc")
assert len(lines) == 4
assert lines[2] == "import \"x.hexa\""
println("  PASS")

// ── 4. 실제 파일 로드 (boot_structs.hexa) ─────────────────
println("[4] load_module real file")
let s = load_module("/Users/ghost/Dev/hexa-lang/self/modules/boot_structs.hexa")
assert len(s) > 100
// struct 키워드가 반드시 포함돼야 함
let mut found_struct = false
let mut i = 0
let sn = len(s)
while i + 6 < sn {
    if s[i] == 's' && s[i+1] == 't' && s[i+2] == 'r' && s[i+3] == 'u' && s[i+4] == 'c' && s[i+5] == 't' {
        found_struct = true
        i = sn
    }
    i = i + 1
}
assert found_struct
println("  PASS (len=" + to_string(len(s)) + ")")

// ── 5. 순환 감지 ──────────────────────────────────────────
println("[5] cycle detection")
// visited 에 이미 있는 경로를 주입해서 재호출
let dummy_src = "import \"modules/boot_structs.hexa\"\nlet ok = 1\n"
let visited = ["/Users/ghost/Dev/hexa-lang/self/modules/boot_structs.hexa"]
let expanded = ml_resolve(dummy_src, "/Users/ghost/Dev/hexa-lang/self", visited)
// "cycle skipped" 문자열이 결과에 들어가야 함
let mut found_cycle = false
let en = len(expanded)
let needle = "cycle skipped"
let nn = len(needle)
let mut j = 0
while j + nn <= en {
    let mut k = 0
    let mut ok = true
    while k < nn {
        if expanded[j+k] != needle[k] { ok = false; k = nn }
        k = k + 1
    }
    if ok { found_cycle = true; j = en }
    j = j + 1
}
assert found_cycle
println("  PASS")

// ── 6. bootstrap_modular.hexa 확장 ────────────────────────
// SKIPPED: bootstrap_modular.hexa 및 하위 모듈에 multi-byte UTF-8 문자(한글, ═ 등)가
// 있어 len()/index byte/char 불일치 버그에 걸림. 인터프리터 수정 후 재활성화.
println("[6] load bootstrap_modular — SKIPPED (UTF-8 len/index mismatch)")

println("=== test_module_import: ALL PASS ===")
println("5 passed")
