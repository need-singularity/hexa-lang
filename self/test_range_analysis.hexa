// ═══════════════════════════════════════════════════════════════
//  test_range_analysis.hexa — ROI #61 Constant Range Analysis
//
//  Tests: range init, const, predicates, meet, join, arithmetic,
//         comparison, BOT propagation, edge cases — 55 tests
//
//  Self-contained: inlines all range functions to avoid import
//  race conditions with concurrent agents modifying ai_native_pass.
//
//  실행: ./hexa self/test_range_analysis.hexa
// ═══════════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

// ═══════════════════════════════════════════════════════════════
//  Inline range analysis functions (mirror of ai_native_pass.hexa)
// ═══════════════════════════════════════════════════════════════

let RANGE_MIN = -999999999
let RANGE_MAX = 999999999

fn anp_range_init() {
    return [RANGE_MIN, RANGE_MAX]
}

fn anp_range_const(v) {
    return [v, v]
}

fn anp_range_lo(r) { return r[0] }
fn anp_range_hi(r) { return r[1] }

fn anp_range_is_top(r) {
    return r[0] == RANGE_MIN && r[1] == RANGE_MAX
}

fn anp_range_is_bot(r) {
    return r[0] > r[1]
}

fn anp_range_contains(r, v) {
    if anp_range_is_bot(r) { return false }
    return v >= r[0] && v <= r[1]
}

fn anp_range_width(r) {
    if anp_range_is_bot(r) { return 0 }
    return r[1] - r[0] + 1
}

fn anp_range_eq(r1, r2) {
    return r1[0] == r2[0] && r1[1] == r2[1]
}

fn anp_range_meet(r1, r2) {
    let lo1 = r1[0]
    let hi1 = r1[1]
    let lo2 = r2[0]
    let hi2 = r2[1]
    let mut new_lo = lo1
    let mut new_hi = hi1
    if lo2 > new_lo { new_lo = lo2 }
    if hi2 < new_hi { new_hi = hi2 }
    if new_lo > new_hi { return [1, 0] }
    return [new_lo, new_hi]
}

fn anp_range_join(r1, r2) {
    if anp_range_is_bot(r1) { return r2 }
    if anp_range_is_bot(r2) { return r1 }
    let lo1 = r1[0]
    let hi1 = r1[1]
    let lo2 = r2[0]
    let hi2 = r2[1]
    let mut new_lo = lo1
    let mut new_hi = hi1
    if lo2 < new_lo { new_lo = lo2 }
    if hi2 > new_hi { new_hi = hi2 }
    return [new_lo, new_hi]
}

fn anp_range_add(r1, r2) {
    if anp_range_is_bot(r1) || anp_range_is_bot(r2) { return [1, 0] }
    return [r1[0] + r2[0], r1[1] + r2[1]]
}

fn anp_range_sub(r1, r2) {
    if anp_range_is_bot(r1) || anp_range_is_bot(r2) { return [1, 0] }
    return [r1[0] - r2[1], r1[1] - r2[0]]
}

fn anp_range_mul(r1, r2) {
    if anp_range_is_bot(r1) || anp_range_is_bot(r2) { return [1, 0] }
    let a = r1[0] * r2[0]
    let b = r1[0] * r2[1]
    let c = r1[1] * r2[0]
    let d = r1[1] * r2[1]
    let mut lo = a
    if b < lo { lo = b }
    if c < lo { lo = c }
    if d < lo { lo = d }
    let mut hi = a
    if b > hi { hi = b }
    if c > hi { hi = c }
    if d > hi { hi = d }
    return [lo, hi]
}

fn anp_range_neg(r) {
    if anp_range_is_bot(r) { return [1, 0] }
    return [0 - r[1], 0 - r[0]]
}

fn anp_range_cmp_ge(r, v) {
    if anp_range_is_bot(r) { return "unknown" }
    if r[0] >= v { return "true" }
    if r[1] < v { return "false" }
    return "unknown"
}

fn anp_range_cmp_le(r, v) {
    if anp_range_is_bot(r) { return "unknown" }
    if r[1] <= v { return "true" }
    if r[0] > v { return "false" }
    return "unknown"
}

fn anp_range_cmp_gt(r, v) {
    if anp_range_is_bot(r) { return "unknown" }
    if r[0] > v { return "true" }
    if r[1] <= v { return "false" }
    return "unknown"
}

fn anp_range_cmp_lt(r, v) {
    if anp_range_is_bot(r) { return "unknown" }
    if r[1] < v { return "true" }
    if r[0] >= v { return "false" }
    return "unknown"
}

fn anp_range_cmp_eq(r, v) {
    if anp_range_is_bot(r) { return "unknown" }
    if r[0] == v && r[1] == v { return "true" }
    if v < r[0] || v > r[1] { return "false" }
    return "unknown"
}

fn anp_range_cmp_ne(r, v) {
    if anp_range_is_bot(r) { return "unknown" }
    if r[0] == v && r[1] == v { return "false" }
    if v < r[0] || v > r[1] { return "true" }
    return "unknown"
}

// decreases expr — structural
fn anp_range_eval_expr(expr, var_names, var_ranges) {
    if type_of(expr) == "string" { return anp_range_init() }
    let k = expr.kind
    if k == "IntLit" {
        return anp_range_const(expr.value)
    }
    if k == "Ident" {
        let name = expr.name
        let mut i = 0
        while i < len(var_names) {
            if var_names[i] == name { return var_ranges[i] }
            i = i + 1
        }
        return anp_range_init()
    }
    if k == "BinOp" {
        let lr = anp_range_eval_expr(expr.left, var_names, var_ranges)
        let rr = anp_range_eval_expr(expr.right, var_names, var_ranges)
        if expr.op == "+" || expr.op == "Add" { return anp_range_add(lr, rr) }
        if expr.op == "-" || expr.op == "Sub" { return anp_range_sub(lr, rr) }
        if expr.op == "*" || expr.op == "Mul" { return anp_range_mul(lr, rr) }
        return anp_range_init()
    }
    if k == "UnaryOp" {
        if expr.op == "-" || expr.op == "Neg" {
            let inner = anp_range_eval_expr(expr.operand, var_names, var_ranges)
            return anp_range_neg(inner)
        }
    }
    return anp_range_init()
}

fn anp_range_transfer(stmt, var_names, var_ranges) {
    let k = stmt.kind
    if k == "LetStmt" || k == "LetMutStmt" {
        let name = stmt.name
        let r = anp_range_eval_expr(stmt.value, var_names, var_ranges)
        let new_names = var_names + [name]
        let new_ranges = var_ranges + [r]
        return [new_names, new_ranges]
    }
    if k == "AssignStmt" {
        if type_of(stmt.target) != "string" {
            if stmt.target.kind == "Ident" {
                let name = stmt.target.name
                let r = anp_range_eval_expr(stmt.value, var_names, var_ranges)
                let mut new_ranges = []
                let mut found = false
                let mut idx = 0
                while idx < len(var_names) {
                    if var_names[idx] == name {
                        new_ranges = new_ranges + [r]
                        found = true
                    } else {
                        new_ranges = new_ranges + [var_ranges[idx]]
                    }
                    idx = idx + 1
                }
                if !found {
                    return [var_names + [name], var_ranges + [r]]
                }
                return [var_names, new_ranges]
            }
        }
    }
    return [var_names, var_ranges]
}

fn anp_range_analyze_body(body, var_names, var_ranges) {
    if type_of(body) != "array" { return [var_names, var_ranges] }
    let mut names = var_names
    let mut ranges = var_ranges
    let mut i = 0
    while i < len(body) {
        let result = anp_range_transfer(body[i], names, ranges)
        names = result[0]
        ranges = result[1]
        i = i + 1
    }
    return [names, ranges]
}

fn anp_range_eval_cmp(cmp_expr, var_names, var_ranges) {
    if type_of(cmp_expr) == "string" { return "unknown" }
    if cmp_expr.kind != "BinOp" { return "unknown" }
    let op = cmp_expr.op
    let lr = anp_range_eval_expr(cmp_expr.left, var_names, var_ranges)
    let rr = anp_range_eval_expr(cmp_expr.right, var_names, var_ranges)
    if op == ">=" || op == "Ge" {
        if lr[0] >= rr[1] { return "true" }
        if lr[1] < rr[0] { return "false" }
        return "unknown"
    }
    if op == "<=" || op == "Le" {
        if lr[1] <= rr[0] { return "true" }
        if lr[0] > rr[1] { return "false" }
        return "unknown"
    }
    if op == ">" || op == "Gt" {
        if lr[0] > rr[1] { return "true" }
        if lr[1] <= rr[0] { return "false" }
        return "unknown"
    }
    if op == "<" || op == "Lt" {
        if lr[1] < rr[0] { return "true" }
        if lr[0] >= rr[1] { return "false" }
        return "unknown"
    }
    if op == "==" || op == "Eq" {
        if lr[0] == lr[1] && rr[0] == rr[1] && lr[0] == rr[0] { return "true" }
        if lr[1] < rr[0] || rr[1] < lr[0] { return "false" }
        return "unknown"
    }
    if op == "!=" || op == "Ne" {
        if lr[1] < rr[0] || rr[1] < lr[0] { return "true" }
        if lr[0] == lr[1] && rr[0] == rr[1] && lr[0] == rr[0] { return "false" }
        return "unknown"
    }
    return "unknown"
}

fn anp_range_lookup(name, var_names, var_ranges) {
    let mut i = 0
    while i < len(var_names) {
        if var_names[i] == name { return var_ranges[i] }
        i = i + 1
    }
    return anp_range_init()
}

fn anp_range_analysis_pass(ast) {
    if type_of(ast) != "array" { return ast }
    let mut results = []
    let mut i = 0
    while i < len(ast) {
        let node = ast[i]
        if type_of(node) != "string" && node.kind == "FnDecl" {
            let mut names = []
            let mut ranges = []
            let mut pi = 0
            while pi < len(node.params) {
                names = names + [node.params[pi].name]
                ranges = ranges + [anp_range_init()]
                pi = pi + 1
            }
            let env = anp_range_analyze_body(node.body, names, ranges)
            let final_names = env[0]
            let final_ranges = env[1]
            let mut si = 0
            while si < len(node.body) {
                let stmt = node.body[si]
                if type_of(stmt) != "string" {
                    if stmt.kind == "IfStmt" {
                        let verdict = anp_range_eval_cmp(stmt.cond, final_names, final_ranges)
                        if verdict == "true" || verdict == "false" {
                            println("[range-analysis] dead branch detected in fn")
                        }
                    }
                }
                si = si + 1
            }
            results = results + [node]
        } else {
            results = results + [node]
        }
        i = i + 1
    }
    return results
}

// ═══════════════════════════════════════════════════════════════
//  TESTS
// ═══════════════════════════════════════════════════════════════

println("═══════════════════════════════════════════════════════")
println("  HEXA Constant Range Analysis Tests (ROI #61)")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Range Init & Const ──────────────────────────────────
println("--- Range Init & Const ---")

let top = anp_range_init()
check("#1 init lo = RANGE_MIN", anp_range_lo(top) == RANGE_MIN)
check("#2 init hi = RANGE_MAX", anp_range_hi(top) == RANGE_MAX)

let c5 = anp_range_const(5)
check("#3 const(5) lo=5", anp_range_lo(c5) == 5)
check("#4 const(5) hi=5", anp_range_hi(c5) == 5)

// ── 2. Predicates ──────────────────────────────────────────
println("")
println("--- Predicates ---")

check("#5 is_top(TOP)=true", anp_range_is_top(top))
check("#6 is_top(const5)=false", !anp_range_is_top(c5))
let bot = [1, 0]
check("#7 is_bot(BOT)=true", anp_range_is_bot(bot))
check("#8 is_bot(const5)=false", !anp_range_is_bot(c5))

// ── 3. Contains & Width ────────────────────────────────────
println("")
println("--- Contains & Width ---")

let r_0_100 = [0, 100]
check("#9 contains(0..100, 50)=true", anp_range_contains(r_0_100, 50))
check("#10 contains(0..100, 200)=false", !anp_range_contains(r_0_100, 200))
check("#11 width(0..100)=101", anp_range_width(r_0_100) == 101)
check("#12 width(const5)=1", anp_range_width(c5) == 1)
check("#13 width(BOT)=0", anp_range_width(bot) == 0)

// ── 4. Equality ────────────────────────────────────────────
println("")
println("--- Equality ---")

check("#14 eq([3,7],[3,7])=true", anp_range_eq([3, 7], [3, 7]))
check("#15 eq([3,7],[3,8])=false", !anp_range_eq([3, 7], [3, 8]))

// ── 5. Meet (intersection) ─────────────────────────────────
println("")
println("--- Meet (Intersection) ---")

let m1 = anp_range_meet([1, 10], [5, 15])
check("#16 meet([1,10],[5,15])=[5,10]", anp_range_eq(m1, [5, 10]))

let m2 = anp_range_meet([1, 3], [5, 7])
check("#17 meet([1,3],[5,7])=BOT", anp_range_is_bot(m2))

let m3 = anp_range_meet([0, 100], [20, 50])
check("#18 meet([0,100],[20,50])=[20,50]", anp_range_eq(m3, [20, 50]))

// ── 6. Join (union) ────────────────────────────────────────
println("")
println("--- Join (Union) ---")

let j1 = anp_range_join([1, 5], [3, 8])
check("#19 join([1,5],[3,8])=[1,8]", anp_range_eq(j1, [1, 8]))

let j2 = anp_range_join([1, 3], [7, 9])
check("#20 join([1,3],[7,9])=[1,9]", anp_range_eq(j2, [1, 9]))

let j3 = anp_range_join(bot, [4, 6])
check("#21 join(BOT,[4,6])=[4,6]", anp_range_eq(j3, [4, 6]))

let j4 = anp_range_join([4, 6], bot)
check("#22 join([4,6],BOT)=[4,6]", anp_range_eq(j4, [4, 6]))

// ── 7. Arithmetic ──────────────────────────────────────────
println("")
println("--- Arithmetic ---")

let a1 = anp_range_add([1, 3], [2, 4])
check("#23 add([1,3],[2,4])=[3,7]", anp_range_eq(a1, [3, 7]))

let s1 = anp_range_sub([5, 10], [1, 3])
check("#24 sub([5,10],[1,3])=[2,9]", anp_range_eq(s1, [2, 9]))

let mul1 = anp_range_mul([2, 3], [4, 5])
check("#25 mul([2,3],[4,5])=[8,15]", anp_range_eq(mul1, [8, 15]))

let mul2 = anp_range_mul([-2, 3], [1, 4])
check("#26 mul([-2,3],[1,4])=[-8,12]", anp_range_eq(mul2, [-8, 12]))

let n1 = anp_range_neg([2, 5])
check("#27 neg([2,5])=[-5,-2]", anp_range_eq(n1, [-5, -2]))

let n2 = anp_range_neg([-3, 7])
check("#28 neg([-3,7])=[-7,3]", anp_range_eq(n2, [-7, 3]))

// ── 8. Comparison vs Constant ──────────────────────────────
println("")
println("--- Comparison vs Constant ---")

check("#29 cmp_ge([10,20],5)=true", anp_range_cmp_ge([10, 20], 5) == "true")
check("#30 cmp_ge([10,20],25)=false", anp_range_cmp_ge([10, 20], 25) == "false")
check("#31 cmp_ge([10,20],15)=unknown", anp_range_cmp_ge([10, 20], 15) == "unknown")

check("#32 cmp_lt([1,5],10)=true", anp_range_cmp_lt([1, 5], 10) == "true")
check("#33 cmp_lt([1,5],3)=unknown", anp_range_cmp_lt([1, 5], 3) == "unknown")

check("#34 cmp_eq([7,7],7)=true", anp_range_cmp_eq([7, 7], 7) == "true")
check("#35 cmp_eq([1,5],10)=false", anp_range_cmp_eq([1, 5], 10) == "false")
check("#36 cmp_eq([1,5],3)=unknown", anp_range_cmp_eq([1, 5], 3) == "unknown")

check("#37 cmp_ne([1,3],10)=true", anp_range_cmp_ne([1, 3], 10) == "true")
check("#38 cmp_ne([5,5],5)=false", anp_range_cmp_ne([5, 5], 5) == "false")

check("#39 cmp_le([1,5],10)=true", anp_range_cmp_le([1, 5], 10) == "true")
check("#40 cmp_le([1,5],3)=unknown", anp_range_cmp_le([1, 5], 3) == "unknown")

check("#41 cmp_gt([10,20],5)=true", anp_range_cmp_gt([10, 20], 5) == "true")
check("#42 cmp_gt([10,20],25)=false", anp_range_cmp_gt([10, 20], 25) == "false")

// ── 9. BOT propagation ─────────────────────────────────────
println("")
println("--- BOT Propagation ---")

let bot_add = anp_range_add(bot, [1, 2])
check("#43 add(BOT,x)=BOT", anp_range_is_bot(bot_add))

let bot_sub = anp_range_sub([1, 2], bot)
check("#44 sub(x,BOT)=BOT", anp_range_is_bot(bot_sub))

let bot_mul = anp_range_mul(bot, bot)
check("#45 mul(BOT,BOT)=BOT", anp_range_is_bot(bot_mul))

let bot_neg = anp_range_neg(bot)
check("#46 neg(BOT)=BOT", anp_range_is_bot(bot_neg))

// ── 10. Edge cases ─────────────────────────────────────────
println("")
println("--- Edge Cases ---")

let zw = anp_range_const(0)
check("#47 const(0) width=1", anp_range_width(zw) == 1)
check("#48 const(0) contains 0", anp_range_contains(zw, 0))
check("#49 const(0) !contains 1", !anp_range_contains(zw, 1))

let self_meet = anp_range_meet([3, 7], [3, 7])
check("#50 meet(r,r)=r", anp_range_eq(self_meet, [3, 7]))

let self_join = anp_range_join([3, 7], [3, 7])
check("#51 join(r,r)=r", anp_range_eq(self_join, [3, 7]))

let add_zero = anp_range_add([5, 10], [0, 0])
check("#52 add(r,[0,0])=r", anp_range_eq(add_zero, [5, 10]))

let mul_zero = anp_range_mul([5, 10], [0, 0])
check("#53 mul(r,[0,0])=[0,0]", anp_range_eq(mul_zero, [0, 0]))

let mul_one = anp_range_mul([5, 10], [1, 1])
check("#54 mul(r,[1,1])=r", anp_range_eq(mul_one, [5, 10]))

let neg_neg = anp_range_mul([-5, -2], [-4, -1])
check("#55 mul([-5,-2],[-4,-1])=[2,20]", anp_range_eq(neg_neg, [2, 20]))

// ── 11. Lookup helper ──────────────────────────────────────
println("")
println("--- Lookup ---")

let lk_names = ["x", "y", "z"]
let lk_ranges = [[0, 10], [20, 30], [100, 200]]
let lk_x = anp_range_lookup("x", lk_names, lk_ranges)
check("#56 lookup(x)=[0,10]", anp_range_eq(lk_x, [0, 10]))
let lk_z = anp_range_lookup("z", lk_names, lk_ranges)
check("#57 lookup(z)=[100,200]", anp_range_eq(lk_z, [100, 200]))
let lk_w = anp_range_lookup("w", lk_names, lk_ranges)
check("#58 lookup(w)=TOP", anp_range_is_top(lk_w))

// ── 12. Chained arithmetic ─────────────────────────────────
println("")
println("--- Chained Arithmetic ---")

// (x + y) - z where x=[1,3], y=[2,4], z=[1,1] -> [2,6]
let ch1 = anp_range_sub(anp_range_add([1, 3], [2, 4]), [1, 1])
check("#59 (add then sub)=[2,6]", anp_range_eq(ch1, [2, 6]))

// neg(neg([3,7])) = [3,7]
let ch2 = anp_range_neg(anp_range_neg([3, 7]))
check("#60 neg(neg(r))=r", anp_range_eq(ch2, [3, 7]))

// ── 13. Meet/Join identity laws ────────────────────────────
println("")
println("--- Lattice Laws ---")

let top2 = anp_range_init()
let meet_top = anp_range_meet(top2, [5, 10])
check("#61 meet(TOP,[5,10])=[5,10]", anp_range_eq(meet_top, [5, 10]))

let join_bot = anp_range_join(bot, bot)
check("#62 join(BOT,BOT)=BOT", anp_range_is_bot(join_bot))

// ── 14. Additional comparison edge cases ───────────────────
println("")
println("--- Comparison Edge Cases ---")

check("#63 cmp_ge([0,0],0)=true", anp_range_cmp_ge([0, 0], 0) == "true")
check("#64 cmp_le([0,0],0)=true", anp_range_cmp_le([0, 0], 0) == "true")
check("#65 cmp_gt([0,0],0)=false", anp_range_cmp_gt([0, 0], 0) == "false")
check("#66 cmp_lt([0,0],0)=false", anp_range_cmp_lt([0, 0], 0) == "false")
check("#67 cmp_eq([0,0],0)=true", anp_range_cmp_eq([0, 0], 0) == "true")
check("#68 cmp_ne([0,0],0)=false", anp_range_cmp_ne([0, 0], 0) == "false")

// boundary: range touching the comparison value
check("#69 cmp_ge([5,10],5)=true", anp_range_cmp_ge([5, 10], 5) == "true")
check("#70 cmp_le([5,10],10)=true", anp_range_cmp_le([5, 10], 10) == "true")

// ── Summary ────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("range_analysis: " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL")
println("═══════════════════════════════════════════════════════")
