// ═══════════════════════════════════════════════════════════════════
//  self/test_beam_search.hexa — ROI #170 @beam_search scaffold test
//
//  Scope (scaffold — min viable):
//    (A) beam_meta exposes attr identity
//    (B) bs_init seeds a single-beam state
//    (C) bs_step widens up to `width` with the dummy expander
//    (D) bs_best returns the highest-score hypothesis
//    (E) bs_decode runs the driving loop for max_steps
//
//  File is self-contained — the production source in
//  self/ai_native/beam_search.hexa is mirrored inline because the
//  stage0 interpreter runs tests without module-loader wiring (same
//  idiom as test_kv_cache.hexa / test_speculative_decode_attr.hexa).
// ═══════════════════════════════════════════════════════════════════

// ── inlined from self/ai_native/beam_search.hexa ───────────────────

struct Hypothesis {
    tokens: array,
    score:  float,
    done:   bool
}

struct BeamState {
    beams:     array,
    width:     int,
    step_idx:  int
}

struct BeamAttrMeta {
    name:        string,
    category:    string,
    purpose:     string,
    requires:    string,
    implemented: bool
}

@pure
fn beam_meta() {
    return BeamAttrMeta {
        name:        "beam_search",
        category:    "ai_native",
        purpose:     "빔 탐색 디코딩 — top-k partial hypotheses, prune to width per step",
        requires:    "expand_fn: Hypothesis -> [Hypothesis]; width > 0",
        implemented: false
    }
}

fn bs_init(width, start_token) {
    let seed = Hypothesis {
        tokens: [start_token],
        score:  0.0,
        done:   false
    }
    return BeamState {
        beams:    [seed],
        width:    width,
        step_idx: 0
    }
}

@pure
fn bs_sort_desc(hyps) {
    let n = len(hyps)
    let mut out = hyps
    let mut i = 1
    while i < n {
        let cur = out[i]
        let mut j = i
        let mut stop = false
        while j > 0 {
            if stop {
            } else {
                let prev = out[j - 1]
                if prev.score < cur.score {
                    out[j] = prev
                    j = j - 1
                } else {
                    stop = true
                }
            }
        }
        out[j] = cur
        i = i + 1
    }
    return out
}

@pure
fn bs_take(hyps, width) {
    let n = len(hyps)
    let mut out = []
    let mut i = 0
    let cap = width
    while i < n {
        if i < cap { out = out + [hyps[i]] }
        i = i + 1
    }
    return out
}

@pure
fn bs_dummy_expand(hyp) {
    if hyp.done { return [hyp] }
    let last = hyp.tokens[len(hyp.tokens) - 1]
    let a_tokens = hyp.tokens + [last + 1]
    let b_tokens = hyp.tokens + [last + 2]
    let a = Hypothesis {
        tokens: a_tokens,
        score:  hyp.score - 0.1,
        done:   false
    }
    let b = Hypothesis {
        tokens: b_tokens,
        score:  hyp.score - 0.3,
        done:   false
    }
    return [a, b]
}

@hot
fn bs_step(state: BeamState, expand_fn) {
    let mut merged = []
    let n = len(state.beams)
    let mut i = 0
    while i < n {
        let succ = expand_fn(state.beams[i])
        let m = len(succ)
        let mut k = 0
        while k < m {
            merged = merged + [succ[k]]
            k = k + 1
        }
        i = i + 1
    }
    let ranked = bs_sort_desc(merged)
    let pruned = bs_take(ranked, state.width)
    return BeamState {
        beams:    pruned,
        width:    state.width,
        step_idx: state.step_idx + 1
    }
}

@pure
fn bs_best(state: BeamState) {
    let n = len(state.beams)
    if n == 0 {
        return Hypothesis { tokens: [], score: 0.0, done: true }
    }
    let ranked = bs_sort_desc(state.beams)
    return ranked[0]
}

fn bs_decode(state: BeamState, expand_fn, max_steps) {
    let mut cur = state
    let mut s = 0
    while s < max_steps {
        cur = bs_step(cur, expand_fn)
        s = s + 1
    }
    return bs_best(cur)
}

// ── end inlined ────────────────────────────────────────────────────

// ── test harness (shared idiom) ────────────────────────────────────

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn abs_f(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn is_close(a, b) {
    return abs_f(a - b) < 0.00001
}

println("═══════════════════════════════════════════════════════")
println("  ROI #170 — self/ai_native/beam_search.hexa scaffold")
println("═══════════════════════════════════════════════════════")

// ── (A) attr meta surface ─────────────────────────────────────────

let meta = beam_meta()
check("meta.name = beam_search",     meta.name == "beam_search")
check("meta.category = ai_native",   meta.category == "ai_native")
check("meta.implemented = false",    meta.implemented == false)

// ── (B) bs_init single-beam seed ──────────────────────────────────

let s0 = bs_init(3, 42)
check("bs_init width",          s0.width == 3)
check("bs_init step_idx = 0",   s0.step_idx == 0)
check("bs_init one beam",       len(s0.beams) == 1)
check("bs_init start token",    s0.beams[0].tokens[0] == 42)
check("bs_init score = 0.0",    is_close(s0.beams[0].score, 0.0))
check("bs_init done = false",   s0.beams[0].done == false)

// ── (C) bs_step widens + prunes ───────────────────────────────────

let s1 = bs_step(s0, bs_dummy_expand)
check("bs_step step_idx = 1",        s1.step_idx == 1)
check("bs_step beams <= width",      len(s1.beams) <= s1.width)
check("bs_step beams >= 1",          len(s1.beams) >= 1)
// after one expansion of a single seed, we get 2 successors → kept both
check("bs_step from 1 seed → 2 beams (width=3)", len(s1.beams) == 2)

let s2 = bs_step(s1, bs_dummy_expand)
// 2 beams * 2 successors = 4 merged → pruned to width=3
check("bs_step from 2 beams → prune to width=3", len(s2.beams) == 3)
check("bs_step step_idx = 2",        s2.step_idx == 2)

// ── (D) bs_best returns highest score ─────────────────────────────
//  best path follows the -0.1 edge each step: score == -0.1 * step_idx

let best2 = bs_best(s2)
check("bs_best tokens length = step_idx + 1", len(best2.tokens) == s2.step_idx + 1)
check("bs_best score = -0.2", is_close(best2.score, 0.0 - 0.2))

// best against every other beam — head of sorted list must dominate
let mut dom_ok = true
let mut i = 1
while i < len(s2.beams) {
    if s2.beams[i].score > best2.score { dom_ok = false }
    i = i + 1
}
check("bs_best dominates remaining beams", dom_ok)

// ── (E) bs_decode loop hook ───────────────────────────────────────

let s0b   = bs_init(4, 0)
let final = bs_decode(s0b, bs_dummy_expand, 5)
check("bs_decode tokens length = 1 + max_steps", len(final.tokens) == 6)
check("bs_decode best score = -0.5", is_close(final.score, 0.0 - 0.5))

// greedy chain is +1 per step starting from 0 → 0,1,2,3,4,5
let mut chain_ok = true
let mut t = 0
while t < len(final.tokens) {
    if final.tokens[t] != t { chain_ok = false }
    t = t + 1
}
check("bs_decode greedy chain tokens = 0..5", chain_ok)

// ── summary ───────────────────────────────────────────────────────

println("")
println("═══════════════════════════════════════════════════════")
println("  PASS " + to_string(pass_count) + " / FAIL " + to_string(fail_count))
println("═══════════════════════════════════════════════════════")

if fail_count == 0 {
    println("ROI #170 beam_search scaffold: ALL GREEN")
} else {
    println("ROI #170 beam_search scaffold: FAIL (see above)")
}
