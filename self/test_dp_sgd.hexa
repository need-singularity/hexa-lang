// ═══════════════════════════════════════════════════════════════════
//  test_dp_sgd.hexa — DP-SGD (#257)
//
//  Run: PATH=/Users/ghost/.cargo/bin:$PATH ./hexa self/test_dp_sgd.hexa
// ═══════════════════════════════════════════════════════════════════

import "ml/dp_sgd.hexa"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs_(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx_(a, b, eps) { return fabs_(a - b) < eps }

println("=== DP-SGD (#257) Tests ===")

// ── T1 l2_norm of zero matrix = 0 ───────────────────────────────
let Z1 = [[0.0, 0.0], [0.0, 0.0]]
check("T1 zero l2 = 0", approx_(dps_l2_norm(Z1), 0.0, 1.0e-6))

// ── T2 l2_norm of identity = sqrt(2) ────────────────────────────
let I2 = [[1.0, 0.0], [0.0, 1.0]]
check("T2 I2 l2 = sqrt(2)", approx_(dps_l2_norm(I2), 1.4142135, 1.0e-3))

// ── T3 per-sample grad shape ────────────────────────────────────
let W3 = [[0.0, 0.0], [0.0, 0.0]]
let x3 = [1.0, 2.0]
let y3 = [1.0, 1.0]
let g3 = dps_per_sample_grad(W3, x3, y3)
check("T3 grad shape", len(g3) == 2 && len(g3[0]) == 2)
// y_hat = 0, err = -1, grad = -x = [[-1,-2],[-1,-2]]
check("T3 grad val 00", approx_(g3[0][0], -1.0, 1.0e-6))
check("T3 grad val 11", approx_(g3[1][1], -2.0, 1.0e-6))

// ── T4 clip_grad preserves small ────────────────────────────────
let small = [[0.1, 0.1]]
let clipped_small = dps_clip_grad(small, 10.0)
check("T4 small unchanged", approx_(clipped_small[0][0], 0.1, 1.0e-6))

// ── T5 clip_grad shrinks large ──────────────────────────────────
let big = [[3.0, 4.0]]   // norm = 5
let clipped_big = dps_clip_grad(big, 1.0)
let norm_after = dps_l2_norm(clipped_big)
check("T5 big clipped to C", approx_(norm_after, 1.0, 1.0e-3))

// ── T6 Gaussian noise has reasonable magnitude ─────────────────
let N6 = dps_gauss_noise_2d(20, 20, 1.0, 7)
// Expected l2 norm ~ sqrt(400) = 20.0 within 3x
let n6 = dps_l2_norm(N6)
check("T6 noise roughly sigma scaled", n6 > 5.0 && n6 < 60.0)

// ── T7 Gaussian noise scales with sigma ─────────────────────────
let N7a = dps_gauss_noise_2d(20, 20, 0.01, 7)
let N7b = dps_gauss_noise_2d(20, 20, 10.0, 7)
check("T7 sigma=0.01 << sigma=10", dps_l2_norm(N7a) < dps_l2_norm(N7b))

// ── T8 determinism: same seed -> same noise ─────────────────────
let N8a = dps_gauss_noise_2d(5, 5, 1.0, 42)
let N8b = dps_gauss_noise_2d(5, 5, 1.0, 42)
let mut same = true
for i in 0..5 {
    for j in 0..5 {
        if !approx_(N8a[i][j], N8b[i][j], 1.0e-9) { same = false }
    }
}
check("T8 determinism", same)

// ── T9 Train step decreases loss on toy regression (no noise) ──
// Target: identity mapping y=x
let W9 = [[0.0, 0.0], [0.0, 0.0]]
let X9 = [
    [1.0, 0.0],
    [0.0, 1.0],
    [1.0, 1.0]
]
let Y9 = [
    [1.0, 0.0],
    [0.0, 1.0],
    [1.0, 1.0]
]
let loss0 = dps_loss_mse(W9, X9, Y9)
let mut Wk = W9
let mut s = 0
while s < 50 {
    Wk = dps_train_step(Wk, X9, Y9, 0.1, 10.0, 0.0, 1)
    s = s + 1
}
let loss1 = dps_loss_mse(Wk, X9, Y9)
check("T9 loss decreases without noise", loss1 < loss0)

// ── T10 Noise makes loss higher than noise-free ────────────────
let mut Wn = W9
let mut s2 = 0
while s2 < 50 {
    Wn = dps_train_step(Wn, X9, Y9, 0.1, 1.0, 2.0, 1)
    s2 = s2 + 1
}
let loss_noisy = dps_loss_mse(Wn, X9, Y9)
// Both should be above 0, noisy may or may not converge — just check it's finite and >=0.
check("T10 noisy loss non-negative finite", loss_noisy >= 0.0)

// ── T11 RDP ε increases with steps ─────────────────────────────
let eps_a = dps_rdp_eps(0.01, 1.0, 10, 1.0e-5)
let eps_b = dps_rdp_eps(0.01, 1.0, 1000, 1.0e-5)
check("T11 eps steps monotone", eps_b > eps_a)

// ── T12 RDP ε decreases with sigma ─────────────────────────────
let eps_lo = dps_rdp_eps(0.01, 0.5, 100, 1.0e-5)
let eps_hi = dps_rdp_eps(0.01, 5.0, 100, 1.0e-5)
check("T12 eps sigma monotone", eps_lo > eps_hi)

// ── T13 Clipping bound: after clip, norm never exceeds C ───────
let huge = [[100.0, 200.0], [300.0, 400.0]]
let clipped_h = dps_clip_grad(huge, 5.0)
check("T13 clip ceiling", dps_l2_norm(clipped_h) <= 5.0 + 1.0e-3)

println("")
println("=== DP-SGD test summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
