// self/test_rle_pure.hexa -- Tests for self/runtime/rle_pure.hexa

// ── inlined from self/runtime/rle_pure.hexa ─────────────────────

fn _digit_char(d) {
    let digits = "0123456789"
    digits.substring(d, d + 1)
}

fn _int_to_str(n) {
    if n == 0 { return "0" }
    let mut v = n
    let mut parts = []
    while v > 0 {
        parts = parts.push(_digit_char(v % 10))
        v = v / 10
    }
    let mut rev = []
    let mut i = len(parts) - 1
    while i >= 0 {
        rev = rev.push(parts[i])
        i = i - 1
    }
    rev.join("")
}

fn _is_digit_ch(ch) {
    let digits = "0123456789"
    let mut k = 0
    while k < 10 {
        if digits.substring(k, k + 1) == ch { return true }
        k = k + 1
    }
    false
}

fn _digit_val(ch) {
    let digits = "0123456789"
    let mut k = 0
    while k < 10 {
        if digits.substring(k, k + 1) == ch { return k }
        k = k + 1
    }
    0
}

fn rle_encode(data) {
    let n = len(data)
    if n == 0 { return [] }
    let mut out = []
    let mut i = 0
    while i < n {
        let cur = data[i]
        let mut count = 1
        while i + count < n && data[i + count] == cur {
            count = count + 1
        }
        out = out.push([cur, count])
        i = i + count
    }
    out
}

fn rle_decode(runs) {
    let n = len(runs)
    if n == 0 { return [] }
    let mut out = []
    let mut i = 0
    while i < n {
        let pair = runs[i]
        let val = pair[0]
        let count = pair[1]
        let mut j = 0
        while j < count {
            out = out.push(val)
            j = j + 1
        }
        i = i + 1
    }
    out
}

fn rle_encode_str(s) {
    if type_of(s) != "string" { return "" }
    let n = len(s)
    if n == 0 { return "" }
    let mut parts = []
    let mut i = 0
    while i < n {
        let cur = s.substring(i, i + 1)
        let mut count = 1
        while i + count < n && s.substring(i + count, i + count + 1) == cur {
            count = count + 1
        }
        parts = parts.push(cur)
        parts = parts.push(_int_to_str(count))
        i = i + count
    }
    parts.join("")
}

fn rle_decode_str(s) {
    if type_of(s) != "string" { return "" }
    let n = len(s)
    if n == 0 { return "" }
    let mut parts = []
    let mut i = 0
    while i < n {
        let ch = s.substring(i, i + 1)
        i = i + 1
        let mut count = 0
        while i < n && _is_digit_ch(s.substring(i, i + 1)) {
            count = count * 10 + _digit_val(s.substring(i, i + 1))
            i = i + 1
        }
        if count == 0 { count = 1 }
        let mut j = 0
        while j < count {
            parts = parts.push(ch)
            j = j + 1
        }
    }
    parts.join("")
}

// ── end inlined ───────────────────────────────────────────────────

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn arrays_equal(a, b) {
    if len(a) != len(b) { return false }
    let mut i = 0
    while i < len(a) {
        if to_string(a[i]) != to_string(b[i]) { return false }
        i = i + 1
    }
    true
}

println("═══════════════════════════════════════════════════════")
println("  rle_pure.hexa — test runner")
println("═══════════════════════════════════════════════════════")

// ── array: empty input ──────────────────────────────────────────
println("")
println("--- rle_encode / rle_decode: empty input ---")
check("encode empty", len(rle_encode([])), 0)
check("decode empty", len(rle_decode([])), 0)

// ── array: single element ───────────────────────────────────────
println("")
println("--- array: single element ---")
let enc1 = rle_encode([42])
check("encode single len", len(enc1), 1)
check("encode single val", enc1[0][0], 42)
check("encode single count", enc1[0][1], 1)
check("roundtrip single", arrays_equal(rle_decode(rle_encode([42])), [42]), true)

// ── array: all same ─────────────────────────────────────────────
println("")
println("--- array: all same ---")
let enc_same = rle_encode([7, 7, 7, 7, 7])
check("encode all-same len", len(enc_same), 1)
check("encode all-same val", enc_same[0][0], 7)
check("encode all-same count", enc_same[0][1], 5)
check("roundtrip all-same", arrays_equal(rle_decode(enc_same), [7, 7, 7, 7, 7]), true)

// ── array: all different ────────────────────────────────────────
println("")
println("--- array: all different ---")
let enc_diff = rle_encode([1, 2, 3, 4])
check("encode all-diff len", len(enc_diff), 4)
check("encode all-diff pair0 count", enc_diff[0][1], 1)
check("encode all-diff pair1 count", enc_diff[1][1], 1)
check("roundtrip all-diff", arrays_equal(rle_decode(enc_diff), [1, 2, 3, 4]), true)

// ── array: mixed runs ───────────────────────────────────────────
println("")
println("--- array: mixed runs ---")
let mixed = [1, 1, 1, 2, 2, 3]
let enc_mix = rle_encode(mixed)
check("encode mixed len", len(enc_mix), 3)
check("encode mixed pair0", enc_mix[0][0], 1)
check("encode mixed pair0 count", enc_mix[0][1], 3)
check("encode mixed pair1", enc_mix[1][0], 2)
check("encode mixed pair1 count", enc_mix[1][1], 2)
check("encode mixed pair2", enc_mix[2][0], 3)
check("encode mixed pair2 count", enc_mix[2][1], 1)
check("roundtrip mixed", arrays_equal(rle_decode(enc_mix), mixed), true)

// ── array: large run ────────────────────────────────────────────
println("")
println("--- array: large run ---")
let mut long_arr = []
let mut li = 0
while li < 300 {
    long_arr = long_arr.push(9)
    li = li + 1
}
let enc_long = rle_encode(long_arr)
check("encode 300x9 single pair", len(enc_long), 1)
check("encode 300x9 count", enc_long[0][1], 300)
check("roundtrip 300", arrays_equal(rle_decode(enc_long), long_arr), true)

// ── string: empty input ─────────────────────────────────────────
println("")
println("--- rle_encode_str / rle_decode_str: empty ---")
check("encode_str empty", rle_encode_str(""), "")
check("decode_str empty", rle_decode_str(""), "")

// ── string: single char ─────────────────────────────────────────
println("")
println("--- string: single char ---")
check("encode_str single", rle_encode_str("a"), "a1")
check("decode_str single", rle_decode_str("a1"), "a")
check("roundtrip str single", rle_decode_str(rle_encode_str("a")), "a")

// ── string: all same ────────────────────────────────────────────
println("")
println("--- string: all same ---")
check("encode_str all-same", rle_encode_str("aaaaa"), "a5")
check("decode_str all-same", rle_decode_str("a5"), "aaaaa")
check("roundtrip str all-same", rle_decode_str(rle_encode_str("aaaaa")), "aaaaa")

// ── string: all different ───────────────────────────────────────
println("")
println("--- string: all different ---")
check("encode_str all-diff", rle_encode_str("abcd"), "a1b1c1d1")
check("decode_str all-diff", rle_decode_str("a1b1c1d1"), "abcd")
check("roundtrip str all-diff", rle_decode_str(rle_encode_str("abcd")), "abcd")

// ── string: mixed runs ──────────────────────────────────────────
println("")
println("--- string: mixed runs ---")
check("encode_str aaabbc", rle_encode_str("aaabbc"), "a3b2c1")
check("decode_str a3b2c1", rle_decode_str("a3b2c1"), "aaabbc")
check("roundtrip str mixed", rle_decode_str(rle_encode_str("aaabbc")), "aaabbc")

// ── string: multi-digit counts ──────────────────────────────────
println("")
println("--- string: multi-digit counts ---")
let mut big_parts = []
let mut bj = 0
while bj < 12 {
    big_parts = big_parts.push("z")
    bj = bj + 1
}
let big_str = big_parts.join("")
check("encode_str 12xz", rle_encode_str(big_str), "z12")
check("decode_str z12", rle_decode_str("z12"), big_str)
check("roundtrip str multi-digit", rle_decode_str(rle_encode_str(big_str)), big_str)

// ── string: non-string input ────────────────────────────────────
println("")
println("--- string: non-string input ---")
check("encode_str nil", rle_encode_str(nil), "")
check("encode_str int", rle_encode_str(42), "")

// ── compression ratio sanity ────────────────────────────────────
println("")
println("--- compression ratio sanity ---")
check("all-same compresses", len(rle_encode([5, 5, 5, 5, 5])) < 5, true)
check("str all-same compresses", len(rle_encode_str("aaaaa")) < 5, true)

// ── Summary ─────────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    println("FAIL")
    exit(1)
}
println("ALL PASS")
