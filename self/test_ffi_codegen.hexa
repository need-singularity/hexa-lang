// self/test_ffi_codegen.hexa — P4-3 FFI static C declaration codegen tests
// Tests that extern fn declarations produce correct C declarations.
// Builds a driver that loads the lexer + parser + codegen pipeline,
// then runs codegen tests against it.

use "self/core/law_io"

let _hexa_root = if len(env_var("HEXA_LANG")) > 0 { env_var("HEXA_LANG") } else { "." }
let _home = env_var("HOME")
let HEXA = _home + "/.hx/bin/hexa"
let SELF_DIR = _hexa_root + "/self"
let TMP_DIR = "/tmp/hexa_ffi_test"

exec("mkdir -p " + TMP_DIR)

// Build pipeline source
let lexer_src = read_file(SELF_DIR + "/lexer.hexa")
let parser_src = read_file(SELF_DIR + "/parser.hexa")
let cg_src = read_file(SELF_DIR + "/codegen_c2.hexa")

let pipeline_src = lexer_src + "\n" + parser_src + "\n" + cg_src + "\n"

let mut pass_count = 0
let mut fail_count = 0

fn run_test(name, driver_code) {
    let driver_file = TMP_DIR + "/" + name + ".hexa"
    let full = pipeline_src + "\n" + driver_code
    safe_write_file(driver_file, full)
    let result = exec(HEXA + " " + driver_file + " 2>&1")
    let lines = result.split("\n")
    // Check last non-empty line
    let mut last = ""
    let mut i = len(lines) - 1
    while i >= 0 {
        if lines[i] != "" {
            last = lines[i]
            i = -1
        }
        i = i - 1
    }
    if last == "PASS" {
        println("  PASS: " + name)
        pass_count = pass_count + 1
    } else {
        println("  FAIL: " + name)
        println("    output: " + result)
        fail_count = fail_count + 1
    }
}

println("=== P4-3: FFI Static C Declaration Codegen Tests ===")
println("")

// ── Test 1: Type mapping ────────────────────────────────────
println("Test 1: gen2_static_c_type mapping")
run_test("type_map", "let ok = gen2_static_c_type(\"Int\") == \"long long\" && gen2_static_c_type(\"i64\") == \"long long\" && gen2_static_c_type(\"i32\") == \"int\" && gen2_static_c_type(\"Float\") == \"double\" && gen2_static_c_type(\"f64\") == \"double\" && gen2_static_c_type(\"f32\") == \"float\" && gen2_static_c_type(\"str\") == \"char*\" && gen2_static_c_type(\"String\") == \"char*\" && gen2_static_c_type(\"Bool\") == \"int\" && gen2_static_c_type(\"bool\") == \"int\" && gen2_static_c_type(\"Void\") == \"void\" && gen2_static_c_type(\"void\") == \"void\" && gen2_static_c_type(\"\") == \"void\" && gen2_static_c_type(\"*Void\") == \"void*\"\nif ok { println(\"PASS\") } else { println(\"FAIL\") }
")
println("")

// ── Test 2: Simple extern fn declaration ────────────────────
println("Test 2: extern fn getpid() -> Int")
run_test("simple_decl", "
let ast = parse(tokenize(\"extern fn getpid() -> Int\"))
let decl = gen2_extern_static_decl(ast[0])
let ok = decl.contains(\"extern\") && decl.contains(\"long long\") && decl.contains(\"getpid\") && decl.contains(\"(void)\") && decl.contains(\");\")
if ok { println(\"PASS\") } else { println(\"FAIL: \" + decl) }
")
println("")

// ── Test 3: Typed params ────────────────────────────────────
println("Test 3: extern fn with typed params")
run_test("typed_params", "
let ast = parse(tokenize(\"extern fn write(fd: Int, buf: str, n: Int) -> Int\"))
let decl = gen2_extern_static_decl(ast[0])
let ok = decl.contains(\"long long fd\") && decl.contains(\"char* buf\") && decl.contains(\"long long n\") && decl.contains(\"extern long long\")
if ok { println(\"PASS\") } else { println(\"FAIL: \" + decl) }
")
println("")

// ── Test 4: Float params ────────────────────────────────────
println("Test 4: extern fn with Float params")
run_test("float_params", "
let ast = parse(tokenize(\"extern fn pow(base: Float, exp: Float) -> Float\"))
let decl = gen2_extern_static_decl(ast[0])
let ok = decl.contains(\"double base\") && decl.contains(\"double exp\") && decl.contains(\"extern double\")
if ok { println(\"PASS\") } else { println(\"FAIL: \" + decl) }
")
println("")

// ── Test 5: @symbol alias ───────────────────────────────────
println("Test 5: @symbol alias uses C name")
run_test("symbol_alias", "
let src = \"@symbol(\\\"cosf\\\")\" + \"\\n\" + \"extern fn my_cos(x: Float) -> Float\"
let ast = parse(tokenize(src))
let decl = gen2_extern_static_decl(ast[0])
let ok = decl.contains(\"cosf(\") && !decl.contains(\"my_cos\")
if ok { println(\"PASS\") } else { println(\"FAIL: \" + decl) }
")
println("")

// ── Test 6: @link library comment ───────────────────────────
println("Test 6: @link library comment")
run_test("link_comment", "
let src = \"@link(\\\"libm\\\")\" + \"\\n\" + \"extern fn sin(x: Float) -> Float\"
let ast = parse(tokenize(src))
let decl = gen2_extern_static_decl(ast[0])
let ok = decl.contains(\"// link: -llibm\") && decl.contains(\"extern double sin(double x);\")
if ok { println(\"PASS\") } else { println(\"FAIL: \" + decl) }
")
println("")

// ── Test 7: void return ─────────────────────────────────────
println("Test 7: extern fn with void return")
run_test("void_return", "
let ast = parse(tokenize(\"extern fn free(ptr: *Void)\"))
let decl = gen2_extern_static_decl(ast[0])
let ok = decl.contains(\"extern void free\") && decl.contains(\"void* ptr\")
if ok { println(\"PASS\") } else { println(\"FAIL: \" + decl) }
")
println("")

// ── Test 8: #include generation ─────────────────────────────
println("Test 8: gen2_extern_includes")
run_test("includes", "
let src = \"@link(\\\"libm\\\")\" + \"\\n\" + \"extern fn cos(x: Float) -> Float\" + \"\\n\" + \"extern fn strlen(s: str) -> Int\"
let ast = parse(tokenize(src))
let inc = gen2_extern_includes(ast)
let ok = inc.contains(\"#include <stdint.h>\") && inc.contains(\"#include <math.h>\") && inc.contains(\"#include <string.h>\")
if ok { println(\"PASS\") } else { println(\"FAIL: \" + inc) }
")
println("")

// ── Test 9: Full FFI block ──────────────────────────────────
println("Test 9: gen2_static_ffi_block")
run_test("ffi_block", "
let src = \"@link(\\\"m\\\")\" + \"\\n\" + \"extern fn cos(x: Float) -> Float\" + \"\\n\" + \"extern fn getpid() -> Int\"
let ast = parse(tokenize(src))
let block = gen2_static_ffi_block(ast)
let ok = block.contains(\"// ── FFI declarations ──\") && block.contains(\"extern double cos(double x);\") && block.contains(\"extern long long getpid(void);\") && block.contains(\"#include <math.h>\")
if ok { println(\"PASS\") } else { println(\"FAIL: \" + block) }
")
println("")

// ── Test 10: No extern → empty block ────────────────────────
println("Test 10: no extern -> empty block")
run_test("no_extern", "
let ast = parse(tokenize(\"fn foo() { return 42 }\"))
let block = gen2_static_ffi_block(ast)
if block == \"\" { println(\"PASS\") } else { println(\"FAIL: \" + block) }
")
println("")

// ── Summary ─────────────────────────────────────────────────
println("=== Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed ===")
if fail_count > 0 {
    println("SOME TESTS FAILED")
} else {
    println("ALL TESTS PASSED")
}
