// ═══════════════════════════════════════════════════════════════════
//  test_synthetic_data.hexa — Synthetic Data Generation 검증
//
//  검증:
//    1. 템플릿 생성
//    2. 템플릿 채우기
//    3. seed 기반 변형 생성
//    4. 길이 점수
//    5. 다양성 점수
//    6. 일관성 점수
//    7. 종합 품질 점수
//    8. 필터링
//    9. 텍스트 해싱
//   10. 중복 제거
//   11. 파이프라인 통합
//   12. 품질 통계
//
//  실행: ./hexa self/test_synthetic_data.hexa
// ═══════════════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx(a, b, eps) { return fabs(a - b) < eps }

// ── inline helpers ──────────────────────────────────────────────

fn sd_min(a, b) {
    if a < b { return a }
    return b
}

fn sd_hash_int(seed, i) {
    return (seed * 2654435761 + i * 1315423911 + 731) % 1000003
}

fn sd_create_template(pattern, slots) {
    return [pattern, slots]
}

fn sd_fill_template(template, values) {
    let pattern = template[0]
    let slots = template[1]
    let mut result = pattern
    for i in 0..slots {
        let placeholder = "{" + str(i) + "}"
        let val = values[i]
        let mut new_result = ""
        let plen = len(placeholder)
        let rlen = len(result)
        let mut pos = 0
        while pos < rlen {
            let mut found = true
            if pos + plen > rlen {
                found = false
            } else {
                for c in 0..plen {
                    if result[pos + c] != placeholder[c] { found = false }
                }
            }
            if found {
                new_result = new_result + val
                pos = pos + plen
            } else {
                new_result = new_result + result[pos]
                pos = pos + 1
            }
        }
        result = new_result
    }
    return result
}

fn sd_generate_from_seed(seed, n_variants, rng_seed) {
    let mut variants = []
    for v in 0..n_variants {
        let h = sd_hash_int(rng_seed, v)
        let prefix_idx = h % 5
        let mut prefix = ""
        if prefix_idx == 0 { prefix = "Explain: " }
        if prefix_idx == 1 { prefix = "Describe: " }
        if prefix_idx == 2 { prefix = "Analyze: " }
        if prefix_idx == 3 { prefix = "Summarize: " }
        if prefix_idx == 4 { prefix = "Discuss: " }
        let suffix_idx = (h / 5) % 4
        let mut suffix = ""
        if suffix_idx == 0 { suffix = " in detail." }
        if suffix_idx == 1 { suffix = " briefly." }
        if suffix_idx == 2 { suffix = " with examples." }
        if suffix_idx == 3 { suffix = " step by step." }
        let variant = prefix + seed + suffix
        variants = variants + [variant]
    }
    return variants
}

fn sd_score_length(text, min_len, max_len) {
    let l = len(text)
    let lf = to_float(l)
    if lf >= to_float(min_len) {
        if lf <= to_float(max_len) { return 1.0 }
    }
    if lf < to_float(min_len) { return lf / to_float(min_len) }
    return to_float(max_len) / lf
}

fn sd_score_diversity(text) {
    let n = len(text)
    if n == 0 { return 0.0 }
    let mut seen = []
    let mut unique = 0
    for i in 0..n {
        let c = text[i]
        let mut found = false
        for j in 0..len(seen) {
            if seen[j] == c { found = true }
        }
        if !found {
            seen = seen + [c]
            unique = unique + 1
        }
    }
    let ratio = to_float(unique) / to_float(n)
    return sd_min(ratio * 3.0, 1.0)
}

fn sd_score_coherence(text) {
    let n = len(text)
    if n == 0 { return 0.0 }
    let mut spaces = 0
    let mut non_space = 0
    let s = str(text)
    for i in 0..n {
        let c = s[i]
        if c == " " {
            spaces = spaces + 1
        } else {
            non_space = non_space + 1
        }
    }
    let space_ratio = to_float(spaces) / to_float(n)
    let non_space_ratio = to_float(non_space) / to_float(n)
    let space_score = sd_min(space_ratio * 6.0, 1.0)
    let word_score = sd_min(non_space_ratio * 1.2, 1.0)
    return (space_score + word_score) / 2.0
}

fn sd_quality_score(text, min_len, max_len) {
    let s_len = sd_score_length(text, min_len, max_len)
    let s_div = sd_score_diversity(text)
    let s_coh = sd_score_coherence(text)
    return 0.3 * s_len + 0.3 * s_div + 0.4 * s_coh
}

fn sd_filter(examples, threshold, min_len, max_len) {
    let mut kept = []
    for i in 0..len(examples) {
        let score = sd_quality_score(examples[i], min_len, max_len)
        if score >= threshold { kept = kept + [examples[i]] }
    }
    return kept
}

fn sd_hash_text(text) {
    let n = len(text)
    let mut h = 5381
    for i in 0..n {
        let mut cv = i % 256
        h = ((h * 33) + cv) % 1000000007
    }
    return h
}

fn sd_dedup(examples) {
    let mut seen_hashes = []
    let mut unique = []
    for i in 0..len(examples) {
        let h = sd_hash_text(examples[i])
        let mut dup = false
        for j in 0..len(seen_hashes) {
            if seen_hashes[j] == h { dup = true }
        }
        if !dup {
            seen_hashes = seen_hashes + [h]
            unique = unique + [examples[i]]
        }
    }
    return unique
}

fn sd_quality_stats(examples, min_len, max_len) {
    let n = len(examples)
    if n == 0 { return [0.0, 0.0, 0.0] }
    let mut total = 0.0
    let mut mn = 999.0
    let mut mx = -999.0
    for i in 0..n {
        let s = sd_quality_score(examples[i], min_len, max_len)
        total = total + s
        if s < mn { mn = s }
        if s > mx { mx = s }
    }
    let avg = total / to_float(n)
    return [avg, mn, mx]
}

fn sd_pipeline(seeds, n_variants, threshold, rng_seed) {
    let min_len = 10
    let max_len = 200
    let mut all_examples = []
    for i in 0..len(seeds) {
        let variants = sd_generate_from_seed(seeds[i], n_variants, rng_seed + i)
        for j in 0..len(variants) {
            all_examples = all_examples + [variants[j]]
        }
    }
    let filtered = sd_filter(all_examples, threshold, min_len, max_len)
    let deduped = sd_dedup(filtered)
    return deduped
}

// ═══════════════════════════════════════════════════════════════════
//  Tests
// ═══════════════════════════════════════════════════════════════════

println("=== Synthetic Data Tests ===")

// 1. Template creation
let tmpl = sd_create_template("Hello {0}, welcome to {1}", 2)
check("template_pattern", tmpl[0] == "Hello {0}, welcome to {1}")
check("template_slots", tmpl[1] == 2)

// 2. Template filling
let filled = sd_fill_template(tmpl, ["World", "Hexa"])
check("fill_template", filled == "Hello World, welcome to Hexa")

// 3. Seed-based generation
let variants = sd_generate_from_seed("machine learning", 3, 42)
check("gen_count", len(variants) == 3)
check("gen_nonempty", len(variants[0]) > 0)

// 4. Length score — within range
let ls_in = sd_score_length("Hello World", 5, 50)
check("length_in_range", approx(ls_in, 1.0, 0.001))

// 5. Length score — too short
let ls_short = sd_score_length("Hi", 10, 50)
check("length_short", ls_short < 1.0)

// 6. Diversity score — varied text
let div = sd_score_diversity("abcdefghij")
check("diversity_pos", div > 0.0)

// 7. Diversity score — repeated
let div_low = sd_score_diversity("aaaaaaaaaa")
check("diversity_low", div_low < div)

// 8. Coherence score — natural text
let coh = sd_score_coherence("Hello World this is a test")
check("coherence_pos", coh > 0.0)

// 9. Combined quality score range
let qs = sd_quality_score("Explain machine learning in detail", 10, 200)
check("quality_range", qs > 0.0)
check("quality_max", qs <= 1.0)

// 10. Filtering
let examples = ["short", "This is a much longer sentence for testing purposes here", "A good example with proper words and spacing"]
let filtered = sd_filter(examples, 0.3, 10, 200)
check("filter_keeps_some", len(filtered) > 0)
check("filter_removes", len(filtered) <= len(examples))

// 11. Hash consistency
let h1 = sd_hash_text("hello")
let h2 = sd_hash_text("hello")
check("hash_consistent", h1 == h2)
let h3 = sd_hash_text("hello world longer text")
check("hash_different_len", h1 != h3)

// 12. Dedup
let dups = ["Hello World", "Hello World", "Different text"]
let deduped = sd_dedup(dups)
check("dedup_removes", len(deduped) < len(dups))

// 13. Quality stats
let stats = sd_quality_stats(["Hello World test", "Another example here"], 5, 200)
check("stats_avg", stats[0] > 0.0)
check("stats_min_le_max", stats[1] <= stats[2])

// 14. Pipeline integration
let seeds = ["neural networks", "deep learning"]
let result = sd_pipeline(seeds, 3, 0.1, 42)
check("pipeline_output", len(result) > 0)

// ── summary ──────────────────────────────────────────────────────
println("")
println("Synthetic Data: " + str(pass_count) + " passed, " + str(fail_count) + " failed")
