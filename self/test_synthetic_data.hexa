let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx(a, b, eps) { return fabs(a - b) < eps }

// ── inlined from synthetic_data.hexa ────────────────────────────

fn sd_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn sd_min(a, b) {
    if a < b { return a }
    return b
}

fn sd_max(a, b) {
    if a > b { return a }
    return b
}

fn sd_clamp(x, lo, hi) {
    if x < lo { return lo }
    if x > hi { return hi }
    return x
}

fn sd_hash(seed, i) {
    let mut h = (seed + 1) * 2654435761 + i * 1315423911 + 7919
    h = h % 1000003
    if h < 0 { h = 0 - h }
    return h
}

fn sd_hash2(a, b) {
    let mut h = (a + 1) * 31 + (b + 1) * 1315423911 + 997
    h = h % 1000003
    if h < 0 { h = 0 - h }
    return h
}

// 1. Seed Task Pool
fn sd_create_seed_pool(seeds) {
    let mut pool = []
    for i in 0..len(seeds) {
        pool = pool + [seeds[i]]
    }
    return pool
}

fn sd_add_seed(pool, seed) {
    return pool + [seed]
}

fn sd_pool_size(pool) {
    return len(pool)
}

fn sd_get_seed(pool, idx) {
    return pool[idx]
}

fn sd_sample_seeds(pool, n, rng_seed) {
    let pool_n = len(pool)
    if pool_n == 0 { return [] }
    let mut result = []
    for i in 0..n {
        let idx = sd_hash(rng_seed, i) % pool_n
        result = result + [pool[idx]]
    }
    return result
}

// 2. Instruction Generation
fn sd_template_prefix(template_id) {
    if template_id == 0 { return "Combine: " }
    if template_id == 1 { return "Rephrase: " }
    if template_id == 2 { return "Extend: " }
    if template_id == 3 { return "Specialize: " }
    return "Task: "
}

fn sd_template_suffix(rng_seed) {
    let pick = rng_seed % 5
    if pick == 0 { return " with examples" }
    if pick == 1 { return " step by step" }
    if pick == 2 { return " in detail" }
    if pick == 3 { return " concisely" }
    return " and explain"
}

fn sd_generate_instruction(pool, template_id, rng_seed) {
    let n = len(pool)
    if n == 0 { return "empty pool" }
    let idx = sd_hash(rng_seed, template_id) % n
    let base = pool[idx]
    let prefix = sd_template_prefix(template_id)
    let suffix = sd_template_suffix(rng_seed)
    return prefix + base + suffix
}

fn sd_generate_batch(pool, n, rng_seed) {
    let mut batch = []
    for i in 0..n {
        let tid = i % 4
        let inst = sd_generate_instruction(pool, tid, sd_hash(rng_seed, i))
        batch = batch + [inst]
    }
    return batch
}

// 3. Instance Generation
fn sd_input_template(rng_seed) {
    let pick = rng_seed % 4
    if pick == 0 { return "Given the task: " }
    if pick == 1 { return "Please complete: " }
    if pick == 2 { return "Following the instruction: " }
    return "Input for: "
}

fn sd_output_template(rng_seed) {
    let pick = rng_seed % 4
    if pick == 0 { return "The answer is: " }
    if pick == 1 { return "Completed: " }
    if pick == 2 { return "Result: " }
    return "Output: "
}

fn sd_generate_instance(instruction, rng_seed) {
    let input_prefix = sd_input_template(rng_seed)
    let output_prefix = sd_output_template(sd_hash(rng_seed, 1))
    let input_text = input_prefix + instruction
    let output_text = output_prefix + instruction + " done"
    return [input_text, output_text]
}

fn sd_generate_instances(instructions, rng_seed) {
    let n = len(instructions)
    let mut instances = []
    for i in 0..n {
        let inst = sd_generate_instance(instructions[i], sd_hash(rng_seed, i))
        instances = instances + [inst]
    }
    return instances
}

// 4. Quality Filter
fn sd_score_length(text, min_len, max_len) {
    let l = len(text)
    let lf = to_float(l)
    if lf >= to_float(min_len) {
        if lf <= to_float(max_len) { return 1.0 }
    }
    if lf < to_float(min_len) {
        return lf / to_float(min_len)
    }
    return to_float(max_len) / lf
}

fn sd_score_diversity(text) {
    let n = len(text)
    if n == 0 { return 0.0 }
    let mut seen = []
    let mut unique = 0
    for i in 0..n {
        let c = text[i]
        let mut found = false
        for j in 0..len(seen) {
            if seen[j] == c { found = true }
        }
        if !found {
            seen = seen + [c]
            unique = unique + 1
        }
    }
    let ratio = to_float(unique) / to_float(n)
    return sd_min(ratio * 3.0, 1.0)
}

fn sd_score_coherence(text) {
    let n = len(text)
    if n == 0 { return 0.0 }
    let mut spaces = 0
    let mut non_space = 0
    let s = str(text)
    for i in 0..n {
        let c = s[i]
        if c == " " {
            spaces = spaces + 1
        } else {
            non_space = non_space + 1
        }
    }
    let space_ratio = to_float(spaces) / to_float(n)
    let non_space_ratio = to_float(non_space) / to_float(n)
    let space_score = sd_min(space_ratio * 6.0, 1.0)
    let word_score = sd_min(non_space_ratio * 1.2, 1.0)
    return (space_score + word_score) / 2.0
}

fn sd_quality_score(text, min_len, max_len) {
    let s_len = sd_score_length(text, min_len, max_len)
    let s_div = sd_score_diversity(text)
    let s_coh = sd_score_coherence(text)
    return 0.3 * s_len + 0.3 * s_div + 0.4 * s_coh
}

fn sd_filter_quality(examples, threshold) {
    let mut kept = []
    for i in 0..len(examples) {
        let score = sd_quality_score(examples[i], 10, 500)
        if score >= threshold {
            kept = kept + [examples[i]]
        }
    }
    return kept
}

// 5. Diversity Filter
fn sd_tokenize(text) {
    return text.split(" ")
}

fn sd_ngram_extract(words, n) {
    let nw = len(words)
    if nw < n { return [] }
    let mut ngrams = []
    for i in 0..(nw - n + 1) {
        let mut h = 0
        for j in 0..n {
            let w = words[i + j]
            let wchars = w.chars()
            let wlen = len(wchars)
            for k in 0..wlen {
                h = h * 31 + to_int(wchars[k])
                h = h % 999983
            }
            h = h * 131 + j
            h = h % 999983
        }
        if h < 0 { h = 0 - h }
        ngrams = ngrams + [h]
    }
    return ngrams
}

fn sd_ngram_overlap(a_words, b_words, n) {
    let a_ng = sd_ngram_extract(a_words, n)
    let b_ng = sd_ngram_extract(b_words, n)
    let na = len(a_ng)
    let nb = len(b_ng)
    if na == 0 { return 0.0 }
    let mut matches = 0
    for i in 0..na {
        for j in 0..nb {
            if a_ng[i] == b_ng[j] {
                matches = matches + 1
                break
            }
        }
    }
    return to_float(matches) / to_float(na)
}

fn sd_diversity_filter(items, max_overlap) {
    let n = len(items)
    if n == 0 { return [] }
    let mut accepted = [items[0]]
    for i in 1..n {
        let words_i = sd_tokenize(items[i])
        let mut too_similar = false
        for j in 0..len(accepted) {
            let words_j = sd_tokenize(accepted[j])
            let overlap = sd_ngram_overlap(words_i, words_j, 2)
            if overlap > max_overlap {
                too_similar = true
                break
            }
        }
        if !too_similar {
            accepted = accepted + [items[i]]
        }
    }
    return accepted
}

// 6. Evol-Instruct
fn sd_evol_deepen(instruction, rng_seed) {
    let pick = rng_seed % 3
    if pick == 0 { return "Analyze step by step: " + instruction }
    if pick == 1 { return "Provide detailed reasoning for: " + instruction }
    return "Think critically about: " + instruction
}

fn sd_evol_broaden(instruction, rng_seed) {
    let pick = rng_seed % 3
    if pick == 0 { return "Generalize to multiple domains: " + instruction }
    if pick == 1 { return "Extend to broader context: " + instruction }
    return "Apply more widely: " + instruction
}

fn sd_evol_constrain(instruction, rng_seed) {
    let pick = rng_seed % 4
    if pick == 0 { return instruction + " (limit to 100 words)" }
    if pick == 1 { return instruction + " (use formal language)" }
    if pick == 2 { return instruction + " (include examples)" }
    return instruction + " (explain for beginners)"
}

fn sd_evol_step(instruction, rng_seed, mode) {
    if mode == 0 { return sd_evol_deepen(instruction, rng_seed) }
    if mode == 1 { return sd_evol_broaden(instruction, rng_seed) }
    if mode == 2 { return sd_evol_constrain(instruction, rng_seed) }
    return instruction
}

fn sd_evol_multi(instruction, n_steps, rng_seed) {
    let mut current = instruction
    for i in 0..n_steps {
        let mode = i % 3
        let step_seed = sd_hash(rng_seed, i)
        current = sd_evol_step(current, step_seed, mode)
    }
    return current
}

fn sd_evol_batch(instructions, n_steps, rng_seed) {
    let n = len(instructions)
    let mut results = []
    for i in 0..n {
        let evolved = sd_evol_multi(instructions[i], n_steps, sd_hash(rng_seed, i))
        results = results + [evolved]
    }
    return results
}

// 7. Self-Play
fn sd_self_play_user_turn(context, rng_seed) {
    let pick = rng_seed % 4
    if pick == 0 { return "Can you help me with " + context }
    if pick == 1 { return "Tell me more about " + context }
    if pick == 2 { return "How would you approach " + context }
    return "What is the best way to handle " + context
}

fn sd_self_play_assistant_turn(context, rng_seed) {
    let pick = rng_seed % 4
    if pick == 0 { return "Sure, regarding " + context + " I would suggest" }
    if pick == 1 { return "Great question about " + context + " here is my approach" }
    if pick == 2 { return "For " + context + " the key consideration is" }
    return "Let me explain about " + context + " in detail"
}

fn sd_self_play_turn(context, role, rng_seed) {
    if role == 0 { return sd_self_play_user_turn(context, rng_seed) }
    return sd_self_play_assistant_turn(context, rng_seed)
}

fn sd_self_play(topic, n_turns, rng_seed) {
    let mut conversation = []
    let mut context = topic
    for i in 0..n_turns {
        let role = i % 2
        let turn_seed = sd_hash(rng_seed, i)
        let text = sd_self_play_turn(context, role, turn_seed)
        conversation = conversation + [[role, text]]
        context = text
    }
    return conversation
}

// 8. Decontamination
fn sd_is_contaminated(item, test_set, threshold) {
    let item_words = sd_tokenize(item)
    let n_test = len(test_set)
    for i in 0..n_test {
        let test_words = sd_tokenize(test_set[i])
        let overlap = sd_ngram_overlap(item_words, test_words, 2)
        if overlap > threshold {
            return true
        }
    }
    return false
}

fn sd_decontaminate(items, test_set, threshold) {
    let n = len(items)
    let mut clean = []
    for i in 0..n {
        if !sd_is_contaminated(items[i], test_set, threshold) {
            clean = clean + [items[i]]
        }
    }
    return clean
}

fn sd_contamination_count(items, test_set, threshold) {
    let n = len(items)
    let mut count = 0
    for i in 0..n {
        if sd_is_contaminated(items[i], test_set, threshold) {
            count = count + 1
        }
    }
    return count
}

// 9. Pipeline
fn sd_pipeline(seeds, n_gen, n_evol_steps, rng_seed) {
    let pool = sd_create_seed_pool(seeds)
    let raw_instructions = sd_generate_batch(pool, n_gen, rng_seed)
    let n_generated = len(raw_instructions)
    let evolved = sd_evol_batch(raw_instructions, n_evol_steps, sd_hash(rng_seed, 100))
    let quality_filtered = sd_filter_quality(evolved, 0.3)
    let n_after_quality = len(quality_filtered)
    let diverse = sd_diversity_filter(quality_filtered, 0.9)
    let n_after_diversity = len(diverse)
    let instances = sd_generate_instances(diverse, sd_hash(rng_seed, 200))
    let stats = [n_generated, n_after_quality, n_after_diversity, len(instances)]
    return [diverse, instances, stats]
}

fn sd_pipeline_decontaminated(seeds, n_gen, n_evol_steps, rng_seed, test_set) {
    let result = sd_pipeline(seeds, n_gen, n_evol_steps, rng_seed)
    let instructions = result[0]
    let stats = result[2]
    let clean_instructions = sd_decontaminate(instructions, test_set, 0.5)
    let n_final = len(clean_instructions)
    let clean_instances = sd_generate_instances(clean_instructions, sd_hash(rng_seed, 300))
    let final_stats = [stats[0], stats[1], stats[2], n_final]
    return [clean_instructions, clean_instances, final_stats]
}

// ═══════════════════════════════════════════════════════════════
//  TESTS
// ═══════════════════════════════════════════════════════════════

println("=== Synthetic Data Tests ===")

let SEEDS = ["Write a summary of machine learning", "Explain neural network architectures", "Describe reinforcement learning basics", "Compare supervised and unsupervised learning"]

// ── 1. Seed Task Pool ───────────────────────────────────────

let pool = sd_create_seed_pool(SEEDS)
check("T1 create seed pool correct size", sd_pool_size(pool) == 4)

check("T2 get seed from pool", sd_get_seed(pool, 0) == "Write a summary of machine learning")

let pool2 = sd_add_seed(pool, "New instruction about transformers")
check("T3 add seed grows pool", sd_pool_size(pool2) == 5)

let sampled = sd_sample_seeds(pool, 3, 42)
check("T4 sample seeds returns correct count", len(sampled) == 3)

let sampled2 = sd_sample_seeds(pool, 3, 42)
check("T5 sample seeds deterministic", sampled[0] == sampled2[0])

// ── 2. Instruction Generation ───────────────────────────────

let inst1 = sd_generate_instruction(pool, 0, 42)
check("T6 generate instruction non-empty", len(inst1) > 0)

check("T7 generate instruction uses prefix", inst1.starts_with("Combine: "))

let has_suffix = inst1.ends_with("with examples") || inst1.ends_with("step by step") || inst1.ends_with("in detail") || inst1.ends_with("concisely") || inst1.ends_with("and explain")
check("T8 generate instruction uses suffix", has_suffix)

let batch = sd_generate_batch(pool, 8, 42)
check("T9 generate batch correct count", len(batch) == 8)

let mut all_nonempty = true
for i in 0..len(batch) {
    if len(batch[i]) == 0 { all_nonempty = false }
}
check("T10 generate batch all non-empty", all_nonempty)

// ── 3. Instance Generation ──────────────────────────────────

let pair = sd_generate_instance("Explain gradient descent", 42)
check("T11 generate instance returns pair", len(pair) == 2)

check("T12 generate instance input non-empty", len(pair[0]) > 0)

check("T13 generate instance output non-empty", len(pair[1]) > 0)

let insts_for_gen = ["Task A instruction", "Task B instruction", "Task C instruction"]
let instances = sd_generate_instances(insts_for_gen, 42)
check("T14 generate instances batch correct count", len(instances) == 3)

// ── 4. Quality Filter ───────────────────────────────────────

let ls_good = sd_score_length("This is a valid sentence with enough words", 10, 200)
check("T15 score length in range = 1.0", approx(ls_good, 1.0, 0.01))

let ls_short = sd_score_length("Hi", 10, 200)
check("T16 score length too short < 1.0", ls_short < 1.0)

let ls_long = sd_score_length("x".repeat(300), 10, 50)
check("T17 score length too long < 1.0", ls_long < 1.0)

let div_varied = sd_score_diversity("abcdefghijklmno")
let div_repeated = sd_score_diversity("aaaaaaaaaa")
check("T18 score diversity varied > repeated", div_varied > div_repeated)

let coh = sd_score_coherence("This is a properly spaced sentence with words")
check("T19 score coherence natural text > 0", coh > 0.0)

let qs = sd_quality_score("Explain the concept of backpropagation in detail", 10, 200)
check("T20 quality score in [0, 1]", qs > 0.0 && qs <= 1.0)

let mixed = ["x", "This is a good quality instruction about machine learning", "Another reasonable sentence with content"]
let filtered = sd_filter_quality(mixed, 0.6)
check("T21 filter quality removes low-quality", len(filtered) < len(mixed))

// ── 5. Diversity Filter ─────────────────────────────────────

let words1 = sd_tokenize("the quick brown fox jumps")
let ng = sd_ngram_extract(words1, 2)
check("T22 ngram extract non-empty for valid input", len(ng) > 0)

let words_short = sd_tokenize("hello")
let ng_short = sd_ngram_extract(words_short, 3)
check("T23 ngram extract empty for short input", len(ng_short) == 0)

let words_a = sd_tokenize("the cat sat on the mat")
let words_b = sd_tokenize("the cat sat on the mat")
let overlap_same = sd_ngram_overlap(words_a, words_b, 2)
check("T24 ngram overlap identical = 1.0", approx(overlap_same, 1.0, 0.01))

let words_c = sd_tokenize("a completely different sentence about dogs")
let overlap_diff = sd_ngram_overlap(words_a, words_c, 2)
check("T25 ngram overlap different < 1.0", overlap_diff < 1.0)

let dup_items = ["the cat sat on the mat", "the cat sat on the mat again", "a dog ran through the park"]
let div_filtered = sd_diversity_filter(dup_items, 0.5)
check("T26 diversity filter removes duplicates", len(div_filtered) < len(dup_items))

let diverse_items = ["machine learning is about patterns", "biology studies living organisms", "astronomy explores the universe"]
let div_kept = sd_diversity_filter(diverse_items, 0.5)
check("T27 diversity filter keeps diverse items", len(div_kept) == len(diverse_items))

// ── 6. Evol-Instruct ────────────────────────────────────────

let base_inst = "Explain gradient descent"
let deepened = sd_evol_deepen(base_inst, 0)
check("T28 evol deepen adds prefix", deepened.contains("step by step"))

let broadened = sd_evol_broaden(base_inst, 0)
check("T29 evol broaden adds prefix", broadened.contains("Generalize"))

let constrained = sd_evol_constrain(base_inst, 0)
check("T30 evol constrain adds suffix", constrained.contains("100 words"))

let evolved = sd_evol_multi(base_inst, 3, 42)
check("T31 evol multi grows instruction length", len(evolved) > len(base_inst))

let batch_for_evol = ["Task A", "Task B", "Task C"]
let evol_batch = sd_evol_batch(batch_for_evol, 2, 42)
check("T32 evol batch processes all items", len(evol_batch) == 3)

// ── 7. Self-Play ────────────────────────────────────────────

let convo = sd_self_play("machine learning", 4, 42)
check("T33 self-play correct turn count", len(convo) == 4)

let turn0_role = convo[0][0]
let turn1_role = convo[1][0]
check("T34 self-play alternates roles", turn0_role == 0 && turn1_role == 1)

let mut all_turns_nonempty = true
for i in 0..len(convo) {
    if len(convo[i][1]) == 0 { all_turns_nonempty = false }
}
check("T35 self-play turns non-empty", all_turns_nonempty)

// ── 8. Decontamination ──────────────────────────────────────

let test_set = ["the cat sat on the mat for a long time"]
let item_contaminated = "the cat sat on the mat for testing"
let is_cont = sd_is_contaminated(item_contaminated, test_set, 0.3)
check("T36 is_contaminated detects overlap", is_cont)

let items_to_clean = ["the cat sat on the mat for testing", "a completely novel instruction about dogs and parks"]
let cleaned = sd_decontaminate(items_to_clean, test_set, 0.3)
check("T37 decontaminate removes contaminated", len(cleaned) < len(items_to_clean))

let cont_count = sd_contamination_count(items_to_clean, test_set, 0.3)
check("T38 contamination count correct", cont_count >= 1)

// ── 9. Pipeline ─────────────────────────────────────────────

let pipe_seeds = ["Write about neural networks", "Explain deep learning concepts", "Describe transformer architecture"]
let pipe_result = sd_pipeline(pipe_seeds, 6, 1, 42)
check("T39 pipeline returns three components", len(pipe_result) == 3)

let pipe_stats = pipe_result[2]
check("T40 pipeline stats consistent", pipe_stats[0] == 6)

let pipe_instances = pipe_result[1]
check("T41 pipeline generates instances", len(pipe_instances) > 0)

let pipe_decon = sd_pipeline_decontaminated(pipe_seeds, 6, 1, 42, ["completely unrelated test set sentence about quantum physics"])
check("T42 decontaminated pipeline produces output", len(pipe_decon) == 3)

// ═══════════════════════════════════════════════════════════════
println("")
println("=== synthetic_data test summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
