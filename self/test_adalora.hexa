// ═══════════════════════════════════════════════════════════════
//  test_adalora.hexa — AdaLoRA verification (#123)
//
//  Tests (35):
//    T1  zeros1 correct length
//    T2  zeros2 correct shape
//    T3  ones1 all ones
//    T4  kaiming deterministic (same seed = same result)
//    T5  ortho_init produces near-orthogonal rows
//    T6  matvec dimension correct
//    T7  matmul dimension correct
//    T8  transpose involution (A^T^T == A)
//    T9  diag_scale_rows scales correctly
//    T10 adapter creation correct dimensions
//    T11 adapter mask all active initially
//    T12 SVD delta has correct shape
//    T13 forward produces d-dimensional output
//    T14 forward with zero lambda = base output
//    T15 forward changes output vs base
//    T16 importance scores all positive for active
//    T17 importance of pruned entry is 0
//    T18 importance_with_grad adds gradient contribution
//    T19 global_scores length = sum of ranks
//    T20 allocate_ranks respects budget
//    T21 active_rank counts correctly
//    T22 cubic_schedule returns b_init before t_start
//    T23 cubic_schedule returns b_final after t_end
//    T24 cubic_schedule monotonically decreasing
//    T25 linear_schedule interpolates
//    T26 budget_controller tracks step
//    T27 budget_step prunes ranks
//    T28 ortho_loss_p near zero for ortho init
//    T29 ortho_loss_q near zero for ortho init
//    T30 ortho_loss total with coefficient
//    T31 merge produces correct shape
//    T32 merge verify: adapter forward == merged forward
//    T33 layer-wise rank config with different ranks
//    T34 rank_report shows correct active counts
//    T35 prune_n removes correct number of ranks
//
//  Run: cargo run --release -- self/test_adalora.hexa
// ═══════════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx(a, b, eps) { return fabs(a - b) < eps }

// ══════════════════════════════════════════════════════════════
//  Inline implementation (self-contained test file)
// ══════════════════════════════════════════════════════════════

fn ada_zeros1(n) {
    let mut v = []
    for _i in 0..n { v = v + [0.0] }
    return v
}

fn ada_zeros2(rows, cols) {
    let mut r = []
    for _i in 0..rows { r = r + [ada_zeros1(cols)] }
    return r
}

fn ada_ones1(n) {
    let mut v = []
    for _i in 0..n { v = v + [1.0] }
    return v
}

fn ada_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn ada_kaiming(rows, cols, seed) {
    let mut s = seed
    let scale = 1.0 / sqrt(to_float(cols))
    let mut r = []
    for _i in 0..rows {
        let mut row = []
        for _j in 0..cols {
            s = (s * 1103515245 + 12345) % 2147483647
            let v = (to_float(s % 2000) - 1000.0) / 1000.0 * scale
            row = row + [v]
        }
        r = r + [row]
    }
    return r
}

fn ada_ortho_init(rows, cols, seed) {
    let raw = ada_kaiming(rows, cols, seed)
    let mut result = []
    for i in 0..rows {
        let mut v = []
        for j in 0..cols { v = v + [raw[i][j]] }
        for k in 0..i {
            let mut dot_vr = 0.0
            let mut dot_rr = 0.0
            for j in 0..cols {
                dot_vr = dot_vr + v[j] * result[k][j]
                dot_rr = dot_rr + result[k][j] * result[k][j]
            }
            if dot_rr > 1.0e-12 {
                let sc = dot_vr / dot_rr
                let mut v2 = []
                for j in 0..cols {
                    v2 = v2 + [v[j] - sc * result[k][j]]
                }
                v = v2
            }
        }
        let mut norm = 0.0
        for j in 0..cols { norm = norm + v[j] * v[j] }
        norm = sqrt(norm + 1.0e-12)
        let mut normed = []
        for j in 0..cols { normed = normed + [v[j] / norm] }
        result = result + [normed]
    }
    return result
}

@pure
fn ada_matvec(w, x, m, n) {
    let mut y = []
    for i in 0..m {
        let mut s = 0.0
        for j in 0..n { s = s + w[i][j] * x[j] }
        y = y + [s]
    }
    return y
}

@pure
fn ada_matmul(a, b, m, k, n) {
    let mut c = []
    for i in 0..m {
        let mut row = []
        for j in 0..n {
            let mut s = 0.0
            for p in 0..k { s = s + a[i][p] * b[p][j] }
            row = row + [s]
        }
        c = c + [row]
    }
    return c
}

@pure
fn ada_transpose(a, m, n) {
    let mut r = []
    for j in 0..n {
        let mut row = []
        for i in 0..m { row = row + [a[i][j]] }
        r = r + [row]
    }
    return r
}

@pure
fn ada_diag_scale_rows(lambda, mat, r, cols) {
    let mut out = []
    for i in 0..r {
        let mut row = []
        for j in 0..cols {
            row = row + [lambda[i] * mat[i][j]]
        }
        out = out + [row]
    }
    return out
}

@pure
fn ada_diag_scale_cols(mat, lambda, rows, r) {
    let mut out = []
    for i in 0..rows {
        let mut row = []
        for j in 0..r {
            row = row + [mat[i][j] * lambda[j]]
        }
        out = out + [row]
    }
    return out
}

@pure
fn ada_frob_norm(mat, rows, cols) {
    let mut s = 0.0
    for i in 0..rows {
        for j in 0..cols {
            s = s + mat[i][j] * mat[i][j]
        }
    }
    return sqrt(s)
}

@pure
fn ada_row_norms(mat, rows, cols) {
    let mut norms = []
    for i in 0..rows {
        let mut s = 0.0
        for j in 0..cols { s = s + mat[i][j] * mat[i][j] }
        norms = norms + [sqrt(s + 1.0e-12)]
    }
    return norms
}

// ── AdaLoRA adapter ────────────────────────────────────────────

struct AdaLoraAdapter {
    p: array,
    lambda: array,
    q: array,
    mask: array,
    d: int,
    k: int,
    r: int
}

fn make_adalora_adapter(d, k, r, seed) {
    // P [d x r]: orthogonal columns (left singular vectors)
    let p_rows = ada_ortho_init(r, d, seed)
    let p = ada_transpose(p_rows, r, d)
    // Q [r x k]: orthogonal rows (right singular vectors)
    let q = ada_ortho_init(r, k, seed + 1000)
    let lambda = ada_ones1(r)
    let mut mask = []
    for _i in 0..r { mask = mask + [1] }
    AdaLoraAdapter {
        p: p,
        lambda: lambda,
        q: q,
        mask: mask,
        d: d,
        k: k,
        r: r
    }
}

@pure @hot
fn adalora_delta(adapter: AdaLoraAdapter) {
    let r = adapter.r
    let d = adapter.d
    let k = adapter.k
    let mut eff_lambda = []
    for i in 0..r {
        eff_lambda = eff_lambda + [to_float(adapter.mask[i]) * adapter.lambda[i]]
    }
    let scaled_q = ada_diag_scale_rows(eff_lambda, adapter.q, r, k)
    let delta_w = ada_matmul(adapter.p, scaled_q, d, r, k)
    return delta_w
}

@pure @hot
fn adalora_forward(w, adapter: AdaLoraAdapter, x, alpha) {
    let d = adapter.d
    let k = adapter.k
    let r = adapter.r
    let scale = to_float(alpha) / to_float(r)
    let y_base = ada_matvec(w, x, d, k)
    let delta_w = adalora_delta(adapter)
    let y_delta = ada_matvec(delta_w, x, d, k)
    let mut y = []
    for i in 0..d {
        y = y + [y_base[i] + scale * y_delta[i]]
    }
    return y
}

@pure
fn adalora_importance(adapter: AdaLoraAdapter) {
    let r = adapter.r
    let d = adapter.d
    let k = adapter.k
    let mut scores = []
    for i in 0..r {
        let mut pn = 0.0
        for row in 0..d {
            pn = pn + adapter.p[row][i] * adapter.p[row][i]
        }
        pn = sqrt(pn + 1.0e-12)
        let mut qn = 0.0
        for col in 0..k {
            qn = qn + adapter.q[i][col] * adapter.q[i][col]
        }
        qn = sqrt(qn + 1.0e-12)
        let s = ada_abs(adapter.lambda[i]) * pn * qn * to_float(adapter.mask[i])
        scores = scores + [s]
    }
    return scores
}

@pure
fn adalora_importance_with_grad(adapter: AdaLoraAdapter, grad_lambda) {
    let base = adalora_importance(adapter)
    let r = adapter.r
    let mut scores = []
    for i in 0..r {
        scores = scores + [base[i] + ada_abs(grad_lambda[i])]
    }
    return scores
}

@pure
fn adalora_global_scores(adapters) {
    let n_layers = len(adapters)
    let mut all_scores = []
    for l in 0..n_layers {
        let scores = adalora_importance(adapters[l])
        let r = len(scores)
        for i in 0..r {
            all_scores = all_scores + [scores[i]]
        }
    }
    return all_scores
}

@pure
fn ada_kth_largest(arr, k) {
    let n = len(arr)
    if k <= 0 { return 999999.0 }
    if k >= n { return -1.0 }
    let mut sorted = []
    for i in 0..n { sorted = sorted + [arr[i]] }
    for i in 0..n {
        for j in 0..(n - 1) {
            if sorted[j] < sorted[j + 1] {
                let tmp = sorted[j]
                let mut new_sorted = []
                for x in 0..n {
                    if x == j {
                        new_sorted = new_sorted + [sorted[j + 1]]
                    } else {
                        if x == j + 1 {
                            new_sorted = new_sorted + [tmp]
                        } else {
                            new_sorted = new_sorted + [sorted[x]]
                        }
                    }
                }
                sorted = new_sorted
            }
        }
    }
    return sorted[k - 1]
}

fn adalora_allocate_ranks(adapters, budget) {
    let n_layers = len(adapters)
    let all_scores = adalora_global_scores(adapters)
    let total = len(all_scores)
    let mut actual_budget = budget
    if actual_budget > total { actual_budget = total }
    let threshold = ada_kth_largest(all_scores, actual_budget)
    let mut updated = []
    for l in 0..n_layers {
        let ad = adapters[l]
        let scores = adalora_importance(ad)
        let r = ad.r
        let mut new_mask = []
        for i in 0..r {
            if scores[i] >= threshold {
                new_mask = new_mask + [1]
            } else {
                new_mask = new_mask + [0]
            }
        }
        let new_ad = AdaLoraAdapter {
            p: ad.p,
            lambda: ad.lambda,
            q: ad.q,
            mask: new_mask,
            d: ad.d,
            k: ad.k,
            r: ad.r
        }
        updated = updated + [new_ad]
    }
    return updated
}

@pure
fn adalora_active_rank(adapter: AdaLoraAdapter) {
    let mut count = 0
    for i in 0..adapter.r {
        if adapter.mask[i] == 1 { count = count + 1 }
    }
    return count
}

@pure
fn adalora_total_active(adapters) {
    let n = len(adapters)
    let mut total = 0
    for i in 0..n {
        total = total + adalora_active_rank(adapters[i])
    }
    return total
}

@pure
fn adalora_cubic_schedule(step, t_start, t_end, b_init, b_final) {
    if step < t_start { return b_init }
    if step >= t_end { return b_final }
    let progress = to_float(step - t_start) / to_float(t_end - t_start)
    let remaining = 1.0 - progress
    let cubic = remaining * remaining * remaining
    let budget_f = to_float(b_final) + (to_float(b_init) - to_float(b_final)) * cubic
    return to_int(budget_f)
}

@pure
fn adalora_linear_schedule(step, t_start, t_end, b_init, b_final) {
    if step < t_start { return b_init }
    if step >= t_end { return b_final }
    let progress = to_float(step - t_start) / to_float(t_end - t_start)
    let budget_f = to_float(b_init) + (to_float(b_final) - to_float(b_init)) * progress
    return to_int(budget_f)
}

struct BudgetController {
    b_init: int,
    b_final: int,
    t_start: int,
    t_end: int,
    current_step: int
}

fn make_budget_controller(b_init, b_final, t_start, t_end) {
    BudgetController {
        b_init: b_init,
        b_final: b_final,
        t_start: t_start,
        t_end: t_end,
        current_step: 0
    }
}

fn budget_get_current(ctrl: BudgetController) {
    return adalora_cubic_schedule(
        ctrl.current_step, ctrl.t_start, ctrl.t_end,
        ctrl.b_init, ctrl.b_final
    )
}

fn budget_step(ctrl: BudgetController, adapters) {
    let new_step = ctrl.current_step + 1
    let new_ctrl = BudgetController {
        b_init: ctrl.b_init,
        b_final: ctrl.b_final,
        t_start: ctrl.t_start,
        t_end: ctrl.t_end,
        current_step: new_step
    }
    let budget = budget_get_current(new_ctrl)
    let updated_adapters = adalora_allocate_ranks(adapters, budget)
    return [new_ctrl, updated_adapters]
}

@pure
fn adalora_param_count(adapter: AdaLoraAdapter) {
    let active = adalora_active_rank(adapter)
    return adapter.d * active + active + active * adapter.k
}

@pure
fn adalora_total_params(adapters) {
    let n = len(adapters)
    let mut total = 0
    for i in 0..n {
        total = total + adalora_param_count(adapters[i])
    }
    return total
}

@pure
fn adalora_ortho_loss_p(adapter: AdaLoraAdapter) {
    let d = adapter.d
    let r = adapter.r
    let mut loss = 0.0
    for i in 0..r {
        for j in 0..r {
            let mut dot = 0.0
            for kk in 0..d {
                dot = dot + adapter.p[kk][i] * adapter.p[kk][j]
            }
            let mut target = 0.0
            if i == j { target = 1.0 }
            let diff = dot - target
            loss = loss + diff * diff
        }
    }
    return loss
}

@pure
fn adalora_ortho_loss_q(adapter: AdaLoraAdapter) {
    let r = adapter.r
    let k = adapter.k
    let mut loss = 0.0
    for i in 0..r {
        for j in 0..r {
            let mut dot = 0.0
            for c in 0..k {
                dot = dot + adapter.q[i][c] * adapter.q[j][c]
            }
            let mut target = 0.0
            if i == j { target = 1.0 }
            let diff = dot - target
            loss = loss + diff * diff
        }
    }
    return loss
}

@pure
fn adalora_ortho_loss(adapter: AdaLoraAdapter, coeff) {
    let lp = adalora_ortho_loss_p(adapter)
    let lq = adalora_ortho_loss_q(adapter)
    return coeff * (lp + lq)
}

@pure
fn adalora_merge(w, adapter: AdaLoraAdapter, alpha) {
    let d = adapter.d
    let k = adapter.k
    let r = adapter.r
    let scale = to_float(alpha) / to_float(r)
    let delta_w = adalora_delta(adapter)
    let mut merged = []
    for i in 0..d {
        let mut row = []
        for j in 0..k {
            row = row + [w[i][j] + scale * delta_w[i][j]]
        }
        merged = merged + [row]
    }
    return merged
}

@pure
fn adalora_verify_merge(w, adapter: AdaLoraAdapter, x, alpha) {
    let y_adapter = adalora_forward(w, adapter, x, alpha)
    let w_merged = adalora_merge(w, adapter, alpha)
    let d = adapter.d
    let k = adapter.k
    let y_merged = ada_matvec(w_merged, x, d, k)
    let mut max_diff = 0.0
    for i in 0..d {
        let diff = ada_abs(y_adapter[i] - y_merged[i])
        if diff > max_diff { max_diff = diff }
    }
    return max_diff
}

fn make_adalora_layers(n_layers, d, k, ranks, seed) {
    let mut adapters = []
    for l in 0..n_layers {
        let r = ranks[l]
        let ad = make_adalora_adapter(d, k, r, seed + l * 100)
        adapters = adapters + [ad]
    }
    return adapters
}

@pure
fn adalora_rank_report(adapters) {
    let n = len(adapters)
    let mut report = []
    for i in 0..n {
        let total = adapters[i].r
        let active = adalora_active_rank(adapters[i])
        report = report + [[total, active]]
    }
    return report
}

fn adalora_set_mask(adapter: AdaLoraAdapter, new_mask) {
    return AdaLoraAdapter {
        p: adapter.p,
        lambda: adapter.lambda,
        q: adapter.q,
        mask: new_mask,
        d: adapter.d,
        k: adapter.k,
        r: adapter.r
    }
}

fn adalora_prune_n(adapter: AdaLoraAdapter, n_prune) {
    let scores = adalora_importance(adapter)
    let r = adapter.r
    let mut pruned = 0
    let mut new_mask = []
    for i in 0..r { new_mask = new_mask + [adapter.mask[i]] }
    for _p in 0..n_prune {
        let mut min_score = 999999.0
        let mut min_idx = -1
        for i in 0..r {
            if new_mask[i] == 1 {
                if scores[i] < min_score {
                    min_score = scores[i]
                    min_idx = i
                }
            }
        }
        if min_idx >= 0 {
            let mut updated_mask = []
            for i in 0..r {
                if i == min_idx {
                    updated_mask = updated_mask + [0]
                } else {
                    updated_mask = updated_mask + [new_mask[i]]
                }
            }
            new_mask = updated_mask
            pruned = pruned + 1
        }
    }
    return adalora_set_mask(adapter, new_mask)
}

// train_step: returns loss only (adapter update returned separately)
fn adalora_train_step_loss(w, adapter: AdaLoraAdapter, x, target, alpha) {
    let d = adapter.d
    let k = adapter.k
    let y = adalora_forward(w, adapter, x, alpha)
    let mut loss = 0.0
    for i in 0..d {
        let diff = y[i] - target[i]
        loss = loss + diff * diff
    }
    return loss / to_float(d)
}

fn adalora_train_update(adapter: AdaLoraAdapter, w, x, target, lr, alpha) {
    let d = adapter.d
    let k = adapter.k
    let r = adapter.r
    let y = adalora_forward(w, adapter, x, alpha)
    let mut grad_y = []
    for i in 0..d {
        grad_y = grad_y + [y[i] - target[i]]
    }
    let scale = to_float(alpha) / to_float(r)
    let mut new_lambda = []
    for i in 0..r {
        if adapter.mask[i] == 1 {
            let mut p_dot = 0.0
            for row in 0..d {
                p_dot = p_dot + adapter.p[row][i] * grad_y[row]
            }
            let mut q_dot = 0.0
            for col in 0..k {
                q_dot = q_dot + adapter.q[i][col] * x[col]
            }
            let g = scale * p_dot * q_dot
            new_lambda = new_lambda + [adapter.lambda[i] - lr * g]
        } else {
            new_lambda = new_lambda + [adapter.lambda[i]]
        }
    }
    return AdaLoraAdapter {
        p: adapter.p,
        lambda: new_lambda,
        q: adapter.q,
        mask: adapter.mask,
        d: adapter.d,
        k: adapter.k,
        r: adapter.r
    }
}

// ═══════════════════════════════════════════════════════════════
//  TEST SETUP
// ═══════════════════════════════════════════════════════════════

let D = 6
let K = 4
let R = 3
let SEED = 42
let ALPHA = 8

// Create test weight matrix
let W = ada_kaiming(D, K, 777)

// Create test input
let x_test = [1.0, 0.5, -0.3, 0.8]

// Create adapter
let ad = make_adalora_adapter(D, K, R, SEED)

// ═══════════════════════════════════════════════════════════════
//  TESTS
// ═══════════════════════════════════════════════════════════════

// T1: zeros1 correct length
let z1 = ada_zeros1(5)
check("T1 zeros1 length=5", len(z1) == 5)

// T2: zeros2 correct shape
let z2 = ada_zeros2(3, 4)
check("T2 zeros2 3x4 rows=3", len(z2) == 3)
check("T2b zeros2 3x4 cols=4", len(z2[0]) == 4)

// T3: ones1 all ones
let o1 = ada_ones1(4)
let mut all_one = true
for i in 0..4 {
    if fabs(o1[i] - 1.0) > 0.001 { all_one = false }
}
check("T3 ones1 all ones", all_one)

// T4: kaiming deterministic
let k1 = ada_kaiming(3, 4, 42)
let k2 = ada_kaiming(3, 4, 42)
let mut kaiming_same = true
for i in 0..3 {
    for j in 0..4 {
        if fabs(k1[i][j] - k2[i][j]) > 1.0e-10 { kaiming_same = false }
    }
}
check("T4 kaiming deterministic (same seed)", kaiming_same)

// T5: ortho_init produces near-orthogonal rows
let orth = ada_ortho_init(3, 5, 42)
// Check dot product of row 0 and row 1 is near 0
let mut dot01 = 0.0
for j in 0..5 { dot01 = dot01 + orth[0][j] * orth[1][j] }
check("T5 ortho_init rows nearly orthogonal", fabs(dot01) < 0.01)

// T6: matvec correct dimension
let mv = ada_matvec(W, x_test, D, K)
check("T6 matvec output dim = D", len(mv) == D)

// T7: matmul correct dimension
let a_mat = ada_kaiming(3, 4, 1)
let b_mat = ada_kaiming(4, 2, 2)
let c_mat = ada_matmul(a_mat, b_mat, 3, 4, 2)
check("T7 matmul rows correct", len(c_mat) == 3)
check("T7b matmul cols correct", len(c_mat[0]) == 2)

// T8: transpose involution
let m_orig = ada_kaiming(3, 4, 99)
let mt = ada_transpose(m_orig, 3, 4)
let mtt = ada_transpose(mt, 4, 3)
let mut trans_ok = true
for i in 0..3 {
    for j in 0..4 {
        if fabs(m_orig[i][j] - mtt[i][j]) > 1.0e-10 { trans_ok = false }
    }
}
check("T8 transpose involution (A^T^T == A)", trans_ok)

// T9: diag_scale_rows
let lam = [2.0, 3.0]
let small_mat = [[1.0, 0.5], [0.3, 0.7]]
let scaled = ada_diag_scale_rows(lam, small_mat, 2, 2)
check("T9 diag_scale_rows [0][0]=2.0", fabs(scaled[0][0] - 2.0) < 0.001)
check("T9b diag_scale_rows [1][1]=2.1", fabs(scaled[1][1] - 2.1) < 0.001)

// T10: adapter creation dimensions
check("T10 adapter P shape d x r", len(ad.p) == D)
check("T10b adapter P cols = r", len(ad.p[0]) == R)
check("T10c adapter Q shape r x k", len(ad.q) == R)
check("T10d adapter Q cols = k", len(ad.q[0]) == K)
check("T10e adapter lambda len = r", len(ad.lambda) == R)

// T11: adapter mask all active initially
let mut all_active = true
for i in 0..R {
    if ad.mask[i] != 1 { all_active = false }
}
check("T11 all mask entries = 1 initially", all_active)

// T12: SVD delta correct shape
let delta = adalora_delta(ad)
check("T12 delta shape d x k rows", len(delta) == D)
check("T12b delta shape d x k cols", len(delta[0]) == K)

// T13: forward produces d-dim output
let y_fwd = adalora_forward(W, ad, x_test, ALPHA)
check("T13 forward output dim = D", len(y_fwd) == D)

// T14: forward with zero lambda = base output
let mut zero_lambda = []
for _i in 0..R { zero_lambda = zero_lambda + [0.0] }
let ad_zero = AdaLoraAdapter {
    p: ad.p,
    lambda: zero_lambda,
    q: ad.q,
    mask: ad.mask,
    d: D,
    k: K,
    r: R
}
let y_zero = adalora_forward(W, ad_zero, x_test, ALPHA)
let y_base = ada_matvec(W, x_test, D, K)
let mut base_match = true
for i in 0..D {
    if fabs(y_zero[i] - y_base[i]) > 1.0e-6 { base_match = false }
}
check("T14 zero lambda => base output", base_match)

// T15: forward changes output vs base
let mut any_diff = false
for i in 0..D {
    if fabs(y_fwd[i] - y_base[i]) > 1.0e-6 { any_diff = true }
}
check("T15 adapter forward differs from base", any_diff)

// T16: importance scores all positive for active
let imp = adalora_importance(ad)
let mut all_pos = true
for i in 0..R {
    if imp[i] <= 0.0 { all_pos = false }
}
check("T16 importance all positive for active", all_pos)

// T17: importance of pruned entry is 0
let mut pruned_mask = []
for i in 0..R {
    if i == 0 {
        pruned_mask = pruned_mask + [0]
    } else {
        pruned_mask = pruned_mask + [1]
    }
}
let ad_pruned = adalora_set_mask(ad, pruned_mask)
let imp_pruned = adalora_importance(ad_pruned)
check("T17 pruned entry importance = 0", fabs(imp_pruned[0]) < 1.0e-12)

// T18: importance_with_grad adds gradient
let grad_lam = [0.5, 0.1, 0.3]
let imp_grad = adalora_importance_with_grad(ad, grad_lam)
check("T18 importance_with_grad > base for positive grad", imp_grad[0] > imp[0])

// T19: global_scores length = sum of ranks
let ad2 = make_adalora_adapter(D, K, 2, SEED + 50)
let adapters_2 = [ad, ad2]
let gs = adalora_global_scores(adapters_2)
check("T19 global_scores length = 3 + 2", len(gs) == 5)

// T20: allocate_ranks respects budget
let alloc = adalora_allocate_ranks(adapters_2, 3)
let total_active = adalora_total_active(alloc)
check("T20 allocate_ranks budget=3 => active<=3", total_active <= 3)

// T21: active_rank counts correctly
check("T21 active_rank full adapter = R", adalora_active_rank(ad) == R)
check("T21b active_rank pruned = R-1", adalora_active_rank(ad_pruned) == R - 1)

// T22: cubic schedule before t_start
let cb = adalora_cubic_schedule(0, 10, 100, 20, 5)
check("T22 cubic before t_start = b_init", cb == 20)

// T23: cubic schedule after t_end
let ca = adalora_cubic_schedule(200, 10, 100, 20, 5)
check("T23 cubic after t_end = b_final", ca == 5)

// T24: cubic schedule monotonically decreasing
let c_mid1 = adalora_cubic_schedule(30, 10, 100, 20, 5)
let c_mid2 = adalora_cubic_schedule(60, 10, 100, 20, 5)
let c_mid3 = adalora_cubic_schedule(90, 10, 100, 20, 5)
check("T24 cubic monotone: step30 >= step60", c_mid1 >= c_mid2)
check("T24b cubic monotone: step60 >= step90", c_mid2 >= c_mid3)

// T25: linear schedule interpolates
let ls_mid = adalora_linear_schedule(55, 10, 100, 20, 2)
check("T25 linear mid-point in range", ls_mid >= 2)
check("T25b linear mid-point in range", ls_mid <= 20)

// T26: budget_controller tracks step
let ctrl = make_budget_controller(10, 3, 5, 50)
check("T26 budget_controller initial step=0", ctrl.current_step == 0)
let b0 = budget_get_current(ctrl)
check("T26b budget at step 0 = b_init", b0 == 10)

// T27: budget_step prunes ranks
let layers_3 = make_adalora_layers(3, D, K, [R, R, R], SEED)
let total_before = adalora_total_active(layers_3)
// set controller to force pruning (step right at t_end)
let ctrl2 = BudgetController {
    b_init: 9,
    b_final: 4,
    t_start: 0,
    t_end: 2,
    current_step: 1
}
let step_result = budget_step(ctrl2, layers_3)
let ctrl_after = step_result[0]
let layers_after = step_result[1]
let total_after = adalora_total_active(layers_after)
check("T27 budget_step reduces active ranks", total_after <= total_before)
check("T27b controller step incremented", ctrl_after.current_step == 2)

// T28: ortho_loss_p near zero for ortho init
let lp = adalora_ortho_loss_p(ad)
check("T28 ortho_loss_p small for ortho init", lp < 1.0)

// T29: ortho_loss_q near zero for ortho init
let lq = adalora_ortho_loss_q(ad)
check("T29 ortho_loss_q small for ortho init", lq < 1.0)

// T30: ortho_loss total with coefficient
let lo = adalora_ortho_loss(ad, 0.1)
check("T30 ortho_loss = coeff * (lp + lq)", fabs(lo - 0.1 * (lp + lq)) < 1.0e-8)

// T31: merge produces correct shape
let w_merged = adalora_merge(W, ad, ALPHA)
check("T31 merge shape rows = D", len(w_merged) == D)
check("T31b merge shape cols = K", len(w_merged[0]) == K)

// T32: merge verify: adapter forward == merged forward
let merge_diff = adalora_verify_merge(W, ad, x_test, ALPHA)
check("T32 merge verify max_diff < 1e-6", merge_diff < 1.0e-6)

// T33: layer-wise rank config with different ranks
let diff_ranks = [2, 4, 3]
let layers_diff = make_adalora_layers(3, D, K, diff_ranks, SEED)
check("T33 layer 0 rank = 2", layers_diff[0].r == 2)
check("T33b layer 1 rank = 4", layers_diff[1].r == 4)
check("T33c layer 2 rank = 3", layers_diff[2].r == 3)

// T34: rank_report shows correct active counts
let report = adalora_rank_report(layers_diff)
check("T34 rank_report layer 0 = [2,2]", report[0][0] == 2)
check("T34b rank_report layer 0 active = 2", report[0][1] == 2)

// T35: prune_n removes correct number
let ad_p2 = adalora_prune_n(ad, 2)
check("T35 prune_n(2) leaves R-2 active", adalora_active_rank(ad_p2) == R - 2)

// ═══════════════════════════════════════════════════════════════
//  SUMMARY
// ═══════════════════════════════════════════════════════════════
println("")
println("=== AdaLoRA test summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
