// self/nanbox.hexa — HEXA NaN-boxing ported from src/nanbox.rs
// NaN-Boxing: encodes all primitive values in a single 64-bit f64.
//
// IEEE 754 double-precision NaN has 52 mantissa bits. By using quiet NaN
// bit patterns with tag bits, we can store ints, bools, pointers, and void
// in 8 bytes instead of the ~64+ bytes of a full Value enum.
//
// Layout:
//   Float:  any bit pattern where (bits & QNAN) != QNAN  (normal f64)
//   Int:    QNAN | TAG_INT  | (lower 48 bits of i64)
//   Bool:   QNAN | TAG_BOOL | (0 or 1)
//   Void:   QNAN | TAG_VOID
//   Ptr:    QNAN | TAG_PTR  | (48-bit pointer to heap Value)

// Constants (as hex integers)
let QNAN = 0x7FFC000000000000
let TAG_INT = 0x0001000000000000
let TAG_BOOL = 0x0002000000000000
let TAG_VOID = 0x0003000000000000
let TAG_PTR = 0x0000000000000000
let PAYLOAD_MASK = 0x0000FFFFFFFFFFFF

// ── NanBoxed value ─────────────────────────────────────────────

struct NanBoxed {
    bits: int
}

// ── Constructors ───────────────────────────────────────────────

fn nanboxed_from_float(f: float) -> NanBoxed {
    // Store raw f64 bits
    return NanBoxed { bits: float_to_bits(f) }
}

fn nanboxed_from_int(i: int) -> NanBoxed {
    return NanBoxed { bits: QNAN | TAG_INT | (i & PAYLOAD_MASK) }
}

fn nanboxed_from_bool(b: bool) -> NanBoxed {
    let v = 0
    if b { v = 1 }
    return NanBoxed { bits: QNAN | TAG_BOOL | v }
}

fn nanboxed_from_void() -> NanBoxed {
    return NanBoxed { bits: QNAN | TAG_VOID }
}

// ── Type checks ────────────────────────────────────────────────

fn nanboxed_is_float(self: NanBoxed) -> bool {
    return (self.bits & QNAN) != QNAN
}

fn nanboxed_is_int(self: NanBoxed) -> bool {
    return (self.bits & (QNAN | TAG_INT | TAG_BOOL | TAG_VOID)) == (QNAN | TAG_INT)
}

fn nanboxed_is_bool(self: NanBoxed) -> bool {
    return (self.bits & (QNAN | TAG_INT | TAG_BOOL | TAG_VOID)) == (QNAN | TAG_BOOL)
}

fn nanboxed_is_void(self: NanBoxed) -> bool {
    return self.bits == (QNAN | TAG_VOID)
}

fn nanboxed_is_ptr(self: NanBoxed) -> bool {
    if (self.bits & QNAN) != QNAN { return false }
    if nanboxed_is_int(self) { return false }
    if nanboxed_is_bool(self) { return false }
    if nanboxed_is_void(self) { return false }
    return true
}

// ── Extractors ─────────────────────────────────────────────────

fn nanboxed_as_float(self: NanBoxed) -> float {
    return bits_to_float(self.bits)
}

fn nanboxed_as_int(self: NanBoxed) -> int {
    let raw = self.bits & PAYLOAD_MASK
    // Sign-extend from 48 bits
    if (raw & (1 << 47)) != 0 {
        return raw | (~PAYLOAD_MASK)
    }
    return raw
}

fn nanboxed_as_bool(self: NanBoxed) -> bool {
    return (self.bits & 1) != 0
}

// ── Truthy check ───────────────────────────────────────────────

fn nanboxed_is_truthy(self: NanBoxed) -> bool {
    if nanboxed_is_void(self) { return false }
    if nanboxed_is_bool(self) { return nanboxed_as_bool(self) }
    if nanboxed_is_int(self) { return nanboxed_as_int(self) != 0 }
    if nanboxed_is_float(self) { return nanboxed_as_float(self) != 0.0 }
    return true
}

// ── Arithmetic (fast path for primitives) ──────────────────────

struct NanBoxedResult {
    value: NanBoxed,
    ok: bool
}

fn nanboxed_try_add(a: NanBoxed, b: NanBoxed) -> NanBoxedResult {
    if nanboxed_is_int(a) && nanboxed_is_int(b) {
        return NanBoxedResult { value: nanboxed_from_int(nanboxed_as_int(a) + nanboxed_as_int(b)), ok: true }
    }
    if nanboxed_is_float(a) && nanboxed_is_float(b) {
        return NanBoxedResult { value: nanboxed_from_float(nanboxed_as_float(a) + nanboxed_as_float(b)), ok: true }
    }
    if nanboxed_is_int(a) && nanboxed_is_float(b) {
        return NanBoxedResult { value: nanboxed_from_float(nanboxed_as_int(a) + nanboxed_as_float(b)), ok: true }
    }
    if nanboxed_is_float(a) && nanboxed_is_int(b) {
        return NanBoxedResult { value: nanboxed_from_float(nanboxed_as_float(a) + nanboxed_as_int(b)), ok: true }
    }
    return NanBoxedResult { value: nanboxed_from_void(), ok: false }
}

fn nanboxed_try_sub(a: NanBoxed, b: NanBoxed) -> NanBoxedResult {
    if nanboxed_is_int(a) && nanboxed_is_int(b) {
        return NanBoxedResult { value: nanboxed_from_int(nanboxed_as_int(a) - nanboxed_as_int(b)), ok: true }
    }
    if nanboxed_is_float(a) && nanboxed_is_float(b) {
        return NanBoxedResult { value: nanboxed_from_float(nanboxed_as_float(a) - nanboxed_as_float(b)), ok: true }
    }
    if nanboxed_is_int(a) && nanboxed_is_float(b) {
        return NanBoxedResult { value: nanboxed_from_float(nanboxed_as_int(a) - nanboxed_as_float(b)), ok: true }
    }
    if nanboxed_is_float(a) && nanboxed_is_int(b) {
        return NanBoxedResult { value: nanboxed_from_float(nanboxed_as_float(a) - nanboxed_as_int(b)), ok: true }
    }
    return NanBoxedResult { value: nanboxed_from_void(), ok: false }
}

fn nanboxed_try_mul(a: NanBoxed, b: NanBoxed) -> NanBoxedResult {
    if nanboxed_is_int(a) && nanboxed_is_int(b) {
        return NanBoxedResult { value: nanboxed_from_int(nanboxed_as_int(a) * nanboxed_as_int(b)), ok: true }
    }
    if nanboxed_is_float(a) && nanboxed_is_float(b) {
        return NanBoxedResult { value: nanboxed_from_float(nanboxed_as_float(a) * nanboxed_as_float(b)), ok: true }
    }
    if nanboxed_is_int(a) && nanboxed_is_float(b) {
        return NanBoxedResult { value: nanboxed_from_float(nanboxed_as_int(a) * nanboxed_as_float(b)), ok: true }
    }
    if nanboxed_is_float(a) && nanboxed_is_int(b) {
        return NanBoxedResult { value: nanboxed_from_float(nanboxed_as_float(a) * nanboxed_as_int(b)), ok: true }
    }
    return NanBoxedResult { value: nanboxed_from_void(), ok: false }
}

fn nanboxed_try_lt(a: NanBoxed, b: NanBoxed) -> NanBoxedResult {
    if nanboxed_is_int(a) && nanboxed_is_int(b) {
        return NanBoxedResult { value: nanboxed_from_bool(nanboxed_as_int(a) < nanboxed_as_int(b)), ok: true }
    }
    if nanboxed_is_float(a) && nanboxed_is_float(b) {
        return NanBoxedResult { value: nanboxed_from_bool(nanboxed_as_float(a) < nanboxed_as_float(b)), ok: true }
    }
    return NanBoxedResult { value: nanboxed_from_void(), ok: false }
}

fn nanboxed_try_eq(a: NanBoxed, b: NanBoxed) -> NanBoxedResult {
    if nanboxed_is_int(a) && nanboxed_is_int(b) {
        return NanBoxedResult { value: nanboxed_from_bool(nanboxed_as_int(a) == nanboxed_as_int(b)), ok: true }
    }
    if nanboxed_is_float(a) && nanboxed_is_float(b) {
        return NanBoxedResult { value: nanboxed_from_bool(nanboxed_as_float(a) == nanboxed_as_float(b)), ok: true }
    }
    if nanboxed_is_bool(a) && nanboxed_is_bool(b) {
        return NanBoxedResult { value: nanboxed_from_bool(nanboxed_as_bool(a) == nanboxed_as_bool(b)), ok: true }
    }
    if nanboxed_is_void(a) && nanboxed_is_void(b) {
        return NanBoxedResult { value: nanboxed_from_bool(true), ok: true }
    }
    return NanBoxedResult { value: nanboxed_from_void(), ok: false }
}

// ── NanBoxed Stack ─────────────────────────────────────────────

struct NanStack {
    data: [NanBoxed]
}

fn nan_stack_new(capacity: int) -> NanStack {
    return NanStack { data: [] }
}

fn nan_stack_push(self: NanStack, val: NanBoxed) {
    self.data.push(val)
}

fn nan_stack_pop(self: NanStack) -> NanBoxed {
    return self.data.pop()
}

fn nan_stack_last(self: NanStack) -> NanBoxed {
    return self.data[self.data.length() - 1]
}

fn nan_stack_len(self: NanStack) -> int {
    return self.data.length()
}

fn nan_stack_truncate(self: NanStack, len: int) {
    while self.data.length() > len {
        self.data.pop()
    }
}

fn nan_stack_get(self: NanStack, idx: int) -> NanBoxed {
    return self.data[idx]
}

// ── Bit conversion helpers (runtime intrinsics) ────────────────

fn float_to_bits(f: float) -> int {
    // Runtime intrinsic: reinterpret f64 as i64
    return 0
}

fn bits_to_float(bits: int) -> float {
    // Runtime intrinsic: reinterpret i64 as f64
    return 0.0
}
