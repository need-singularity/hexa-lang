// self/lib/fraction.hexa — Int-pair Fraction (I15 우회)
//
// No native Fraction type → use [num, den] as 2-element list.
// All ops return reduced form (gcd-normalized, positive den).
//
// 사용법:
//   let a = frac(1, 2)    // 1/2
//   let b = frac(1, 3)    // 1/3
//   let c = frac_add(a, b) // [5, 6]
//   frac_eq(c, frac(5, 6)) // true

fn frac_gcd(a, b) {
    let mut x = a
    let mut y = b
    if x < 0 { x = 0 - x }
    if y < 0 { y = 0 - y }
    while y != 0 {
        let t = y
        y = x - (x / y) * y
        x = t
    }
    return x
}

fn frac_reduce(f) {
    let mut num = f[0]
    let mut den = f[1]
    if den < 0 {
        num = 0 - num
        den = 0 - den
    }
    if num == 0 { return [0, 1] }
    let g = frac_gcd(num, den)
    return [num / g, den / g]
}

fn frac(n, d) {
    return frac_reduce([n, d])
}

fn frac_add(a, b) {
    let num = a[0] * b[1] + b[0] * a[1]
    let den = a[1] * b[1]
    return frac_reduce([num, den])
}

fn frac_sub(a, b) {
    let num = a[0] * b[1] - b[0] * a[1]
    let den = a[1] * b[1]
    return frac_reduce([num, den])
}

fn frac_mul(a, b) {
    return frac_reduce([a[0] * b[0], a[1] * b[1]])
}

fn frac_div(a, b) {
    return frac_reduce([a[0] * b[1], a[1] * b[0]])
}

fn frac_neg(a) {
    return [0 - a[0], a[1]]
}

fn frac_eq(a, b) {
    // both reduced → direct compare
    return a[0] == b[0] && a[1] == b[1]
}

fn frac_cmp(a, b) {
    // returns -1, 0, 1  — cross-multiply (dens always positive after reduce)
    let l = a[0] * b[1]
    let r = b[0] * a[1]
    if l < r { return 0 - 1 }
    if l > r { return 1 }
    return 0
}

fn frac_to_float(a) {
    return (a[0] + 0.0) / (a[1] + 0.0)
}

fn frac_str(a) {
    // display helper: "num/den"
    return "frac"
}

// ----- tests -----
println("Test: frac(2,4) → [1,2]")
let a = frac(2, 4)
assert a[0] == 1
assert a[1] == 2
println("  PASS")

println("Test: 1/2 + 1/3 = 5/6")
let r1 = frac_add(frac(1, 2), frac(1, 3))
assert r1[0] == 5
assert r1[1] == 6
println("  PASS")

println("Test: 1/2 - 1/3 = 1/6")
let r2 = frac_sub(frac(1, 2), frac(1, 3))
assert r2[0] == 1
assert r2[1] == 6
println("  PASS")

println("Test: 2/3 * 3/4 = 1/2")
let r3 = frac_mul(frac(2, 3), frac(3, 4))
assert r3[0] == 1
assert r3[1] == 2
println("  PASS")

println("Test: (1/2) / (1/4) = 2/1")
let r4 = frac_div(frac(1, 2), frac(1, 4))
assert r4[0] == 2
assert r4[1] == 1
println("  PASS")

println("Test: neg 3/7 = -3/7")
let r5 = frac_neg(frac(3, 7))
assert r5[0] == 0 - 3
assert r5[1] == 7
println("  PASS")

println("Test: frac_eq(1/2, 2/4) = true")
assert frac_eq(frac(1, 2), frac(2, 4))
println("  PASS")

println("Test: frac_cmp(1/3, 1/2) = -1")
assert frac_cmp(frac(1, 3), frac(1, 2)) == 0 - 1
println("  PASS")

println("Test: negative den normalized")
let r6 = frac(1, 0 - 2)
assert r6[0] == 0 - 1
assert r6[1] == 2
println("  PASS")

println("")
println("=== fraction.hexa: ALL TESTS PASSED ===")
