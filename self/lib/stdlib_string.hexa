// self/lib/stdlib_string.hexa — I4 stdlib string utilities
//
// Extends HEXA string ops beyond builtins (.split, .join, .trim,
// .contains, .replace, .starts_with, .ends_with, .to_upper, .to_lower,
// .chars, .repeat, .index_of, .pad_left, .pad_right).
//
// This module adds: str_split, str_join, str_trim, str_trim_start,
// str_trim_end, str_contains, str_replace, str_replace_all,
// str_count, str_reverse, str_slice, str_insert, str_remove,
// str_is_digit, str_is_alpha, str_is_alnum, str_pad_left, str_pad_right,
// str_to_upper, str_to_lower, str_lines, str_words.
//
// All functions are pure and use only builtins + char indexing.

// ── Trim helpers ───────────────────────────────────────────

fn _is_whitespace(ch) {
    return ch == ' ' || ch == '\t' || ch == '\n' || ch == '\r'
}

fn str_trim(s) {
    return s.trim()
}

fn str_trim_start(s) {
    let n = len(s)
    let mut i = 0
    while i < n {
        if !_is_whitespace(s[i]) {
            // Build result from i to end
            let mut parts = []
            let mut j = i
            while j < n {
                parts = parts.push(s[j])
                j = j + 1
            }
            return parts.join("")
        }
        i = i + 1
    }
    return ""
}

fn str_trim_end(s) {
    let n = len(s)
    let mut last = n - 1
    while last >= 0 {
        if !_is_whitespace(s[last]) {
            let mut parts = []
            let mut j = 0
            while j <= last {
                parts = parts.push(s[j])
                j = j + 1
            }
            return parts.join("")
        }
        last = last - 1
    }
    return ""
}

// ── Split / Join ───────────────────────────────────────────

fn str_split(s, delim) {
    return s.split(delim)
}

fn str_join(arr, sep) {
    return arr.join(sep)
}

// ── Search / Replace ───────────────────────────────────────

fn str_index_of(s, needle) {
    return s.index_of(needle)
}

fn str_contains(s, needle) {
    return s.contains(needle)
}

fn str_replace(s, old_str, new_str) {
    return s.replace(old_str, new_str)
}

fn str_replace_all(s, old_str, new_str) {
    // Repeatedly replace until no more occurrences
    let mut result = s
    let old_len = len(old_str)
    if old_len == 0 { return result }
    let mut idx = result.index_of(old_str)
    while idx >= 0 {
        // Build: prefix + new_str + suffix
        let mut prefix_parts = []
        let mut i = 0
        while i < idx {
            prefix_parts = prefix_parts.push(result[i])
            i = i + 1
        }
        let prefix = prefix_parts.join("")
        let suffix_start = idx + old_len
        let mut suffix_parts = []
        let mut j = suffix_start
        while j < len(result) {
            suffix_parts = suffix_parts.push(result[j])
            j = j + 1
        }
        let suffix = suffix_parts.join("")
        result = prefix + new_str + suffix
        // Search again from after the replacement
        let search_from = idx + len(new_str)
        // Manual index_of from position
        let mut found = false
        let rlen = len(result)
        let olen = len(old_str)
        if search_from + olen > rlen {
            idx = 0 - 1
        } else {
            let mut k = search_from
            idx = 0 - 1
            while k <= rlen - olen {
                let mut match_ok = true
                let mut m = 0
                while m < olen {
                    if result[k + m] != old_str[m] {
                        match_ok = false
                        m = olen
                    }
                    m = m + 1
                }
                if match_ok {
                    idx = k
                    k = rlen  // break
                }
                k = k + 1
            }
        }
    }
    return result
}

fn str_count(s, needle) {
    let nn = len(needle)
    if nn == 0 { return 0 }
    let sn = len(s)
    let mut count = 0
    let mut i = 0
    while i <= sn - nn {
        let mut match_ok = true
        let mut j = 0
        while j < nn {
            if s[i + j] != needle[j] {
                match_ok = false
                j = nn
            }
            j = j + 1
        }
        if match_ok {
            count = count + 1
            i = i + nn  // non-overlapping
        } else {
            i = i + 1
        }
    }
    return count
}

// ── Slice / Insert / Remove ────────────────────────────────

fn str_slice(s, start, end_idx) {
    let n = len(s)
    let mut lo = start
    let mut hi = end_idx
    if lo < 0 { lo = 0 }
    if hi > n { hi = n }
    let mut parts = []
    let mut i = lo
    while i < hi {
        parts = parts.push(s[i])
        i = i + 1
    }
    return parts.join("")
}

fn str_insert(s, pos, sub) {
    let prefix = str_slice(s, 0, pos)
    let suffix = str_slice(s, pos, len(s))
    return prefix + sub + suffix
}

fn str_remove(s, start, end_idx) {
    let prefix = str_slice(s, 0, start)
    let suffix = str_slice(s, end_idx, len(s))
    return prefix + suffix
}

// ── Reverse ────────────────────────────────────────────────

fn str_reverse(s) {
    let n = len(s)
    let mut parts = []
    let mut i = n - 1
    while i >= 0 {
        parts = parts.push(s[i])
        i = i - 1
    }
    return parts.join("")
}

// ── Case helpers ───────────────────────────────────────────

fn str_to_upper(s) {
    return s.to_upper()
}

fn str_to_lower(s) {
    return s.to_lower()
}

// ── Char classification ────────────────────────────────────

fn str_is_digit(ch) {
    return ch == "0" || ch == "1" || ch == "2" || ch == "3" || ch == "4" || ch == "5" || ch == "6" || ch == "7" || ch == "8" || ch == "9"
}

fn str_is_alpha(ch) {
    let upper = to_string(ch).to_upper()
    let lower = to_string(ch).to_lower()
    // If upper != lower, it's a letter
    if upper != lower { return true }
    // Edge case: single char that's already upper or lower but same
    // Check a-z A-Z explicitly via ASCII range test
    let c = to_string(ch)
    if len(c) != 1 { return false }
    // Use builtin comparison: letters have distinct upper/lower
    return false
}

fn str_is_alnum(ch) {
    return str_is_digit(to_string(ch)) || str_is_alpha(ch)
}

// ── Padding ────────────────────────────────────────────────

fn str_pad_left(s, target_len, pad_char) {
    return s.pad_left(target_len, pad_char)
}

fn str_pad_right(s, target_len, pad_char) {
    return s.pad_right(target_len, pad_char)
}

// ── Line / Word splitting ──────────────────────────────────

fn str_lines(s) {
    return s.split("\n")
}

fn str_words(s) {
    // Split by whitespace, filter empties
    let raw = s.split(" ")
    let mut result = []
    for part in raw {
        if len(part) > 0 {
            result = result.push(part)
        }
    }
    return result
}

// ── Starts / Ends with ────────────────────────────────────

fn str_starts_with(s, prefix) {
    return s.starts_with(prefix)
}

fn str_ends_with(s, suffix) {
    return s.ends_with(suffix)
}

// ── Repeat ─────────────────────────────────────────────────

fn str_repeat(s, n) {
    return s.repeat(n)
}
