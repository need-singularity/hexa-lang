// self/lib/str_utils.hexa — string helpers (B4, I12 우회)
//
// hexa 빌트인 string api는 제한적.
// 이 라이브러리는 len(s)/s[i]를 사용한 공통 패턴을 정식화.

fn str_chars(s) {
    // Returns list of single-char strings
    let mut out = []
    let n = len(s)
    let mut i = 0
    while i < n {
        out = out.push(s[i])
        i = i + 1
    }
    return out
}

fn str_slice(s, a, b) {
    // Returns s[a..b] (half-open, like Python)
    // perf: chunks.push + join — avoid O(n²) string concat
    let mut parts = []
    let n = len(s)
    let mut lo = a
    let mut hi = b
    if lo < 0 { lo = 0 }
    if hi > n { hi = n }
    let mut i = lo
    while i < hi {
        parts = parts.push(s[i])
        i = i + 1
    }
    return parts.join("")
}

fn str_get(s, i) {
    // Safe single-char access. Returns "" if out-of-bounds.
    let n = len(s)
    if i < 0 { return "" }
    if i >= n { return "" }
    return s[i]
}

fn str_startswith(s, prefix) {
    let pn = len(prefix)
    let sn = len(s)
    if pn > sn { return false }
    let mut i = 0
    while i < pn {
        if s[i] != prefix[i] { return false }
        i = i + 1
    }
    return true
}

fn str_endswith(s, suffix) {
    let sn = len(s)
    let qn = len(suffix)
    if qn > sn { return false }
    let off = sn - qn
    let mut i = 0
    while i < qn {
        if s[off + i] != suffix[i] { return false }
        i = i + 1
    }
    return true
}

fn str_contains(s, needle) {
    let sn = len(s)
    let nn = len(needle)
    if nn == 0 { return true }
    if nn > sn { return false }
    let limit = sn - nn
    let mut i = 0
    while i <= limit {
        let mut j = 0
        let mut ok = true
        while j < nn {
            if s[i + j] != needle[j] {
                ok = false
                j = nn
            }
            j = j + 1
        }
        if ok { return true }
        i = i + 1
    }
    return false
}

fn str_index_of(s, needle) {
    // Returns first index or -1
    let sn = len(s)
    let nn = len(needle)
    if nn == 0 { return 0 }
    if nn > sn { return 0 - 1 }
    let limit = sn - nn
    let mut i = 0
    while i <= limit {
        let mut j = 0
        let mut ok = true
        while j < nn {
            if s[i + j] != needle[j] {
                ok = false
                j = nn
            }
            j = j + 1
        }
        if ok { return i }
        i = i + 1
    }
    return 0 - 1
}

fn str_repeat(s, n) {
    // perf: chunks.push + join — avoid O(n²) string concat
    let mut parts = []
    let mut i = 0
    while i < n {
        parts = parts.push(s)
        i = i + 1
    }
    return parts.join("")
}

// ----- tests -----
println("Test: str_chars")
let cs = str_chars("abc")
assert len(cs) == 3
assert cs[0] == 'a'
assert cs[2] == 'c'
println("  PASS")

println("Test: str_slice")
assert str_slice("hello", 1, 4) == "ell"
assert str_slice("hello", 0, 5) == "hello"
assert str_slice("hello", 0, 100) == "hello"
println("  PASS")

println("Test: str_get bounds")
assert str_get("abc", 0) == 'a'
assert str_get("abc", 10) == ""
assert str_get("abc", 0 - 1) == ""
println("  PASS")

println("Test: str_startswith/endswith")
assert str_startswith("hello world", "hello")
assert !str_startswith("hello", "world")
assert str_endswith("hello world", "world")
assert !str_endswith("hello", "world")
println("  PASS")

println("Test: str_contains")
assert str_contains("hello world", "lo wo")
assert !str_contains("hello", "xyz")
assert str_contains("abc", "")
println("  PASS")

println("Test: str_index_of")
assert str_index_of("hello world", "world") == 6
assert str_index_of("abc", "xyz") == 0 - 1
println("  PASS")

println("Test: str_repeat")
assert str_repeat("ab", 3) == "ababab"
assert str_repeat("x", 0) == ""
println("  PASS")

println("")
println("=== str_utils.hexa: ALL TESTS PASSED ===")
