// self/lib/nan_sentinel.hexa — NaN/Inf 대체 sentinel (B1 우회)
//
// hexa 런타임은 0.0/0.0 → panic, IEEE 754 NaN/Inf 미지원.
// Workaround: sentinel 상수 사용 + 명시적 체크.
//
// NAN = 1e308 (f64 max 근처, 실제 값과 구분됨)
// POS_INF = 1e307
// NEG_INF = 0.0 - 1e307
//
// 사용법:
//   let x = safe_div(a, b)
//   if is_nan(x) { handle_error() }

fn nan_value() {
    return 1e308
}

fn pos_inf() {
    return 1e307
}

fn neg_inf() {
    return 0.0 - 1e307
}

fn is_nan(x) {
    // NaN sentinel = 1e308
    if x > 9e307 {
        if x < 1.1e308 { return true }
    }
    return false
}

fn is_pos_inf(x) {
    if x > 9e306 {
        if x < 1.1e307 { return true }
    }
    return false
}

fn is_neg_inf(x) {
    if x < 0.0 - 9e306 {
        if x > 0.0 - 1.1e307 { return true }
    }
    return false
}

fn is_finite(x) {
    if is_nan(x) { return false }
    if is_pos_inf(x) { return false }
    if is_neg_inf(x) { return false }
    return true
}

fn safe_div(a, b) {
    if b == 0.0 {
        if a > 0.0 { return pos_inf() }
        if a < 0.0 { return neg_inf() }
        return nan_value()
    }
    return a / b
}

fn safe_div_int(a, b) {
    // integer div with fallback
    if b == 0 { return 0 }
    return a / b
}

// ----- tests -----
println("Test: nan/inf sentinels")
let n = nan_value()
let pi = pos_inf()
let ni = neg_inf()
assert is_nan(n)
assert is_pos_inf(pi)
assert is_neg_inf(ni)
assert !is_nan(pi)
assert !is_pos_inf(n)
println("  PASS")

println("Test: is_finite")
assert is_finite(3.14)
assert is_finite(0.0 - 100.0)
assert !is_finite(n)
assert !is_finite(pi)
println("  PASS")

println("Test: safe_div normal")
let r = safe_div(10.0, 2.0)
assert r == 5.0
println("  PASS")

println("Test: safe_div 1/0 = +inf")
assert is_pos_inf(safe_div(1.0, 0.0))
println("  PASS")

println("Test: safe_div -1/0 = -inf")
assert is_neg_inf(safe_div(0.0 - 1.0, 0.0))
println("  PASS")

println("Test: safe_div 0/0 = nan")
assert is_nan(safe_div(0.0, 0.0))
println("  PASS")

println("Test: safe_div_int 10/0 = 0 (fallback)")
assert safe_div_int(10, 0) == 0
println("  PASS")

println("")
println("=== nan_sentinel.hexa: ALL TESTS PASSED ===")
