// self/compile_pipeline.hexa — P7-8 end-to-end AST → IR → ARM64 → Mach-O
//
// Closes the P7-8 gate: a pure-Hexa driver that takes a tiny program, runs
// AST lowering → IR → ARM64 instruction bytes → Mach-O MH_EXECUTE wrapper →
// ad-hoc codesign → run, and asserts the exit code.
//
// Why this file is standalone:
//   self/ir/lowering.hexa + self/codegen/ir_to_arm64.hexa + self/codegen/arm64.hexa
//   all exist as modules but compose via the full concat-link pipeline of
//   hexa_interp. This driver runs as a single `.hexa` under hexa_interp
//   directly, so everything it needs (encoders, IR-to-ARM64 bridge, Mach-O
//   wrapper) is inlined in this file. The inlined bridge logic is
//   semantics-identical to ir_to_arm64.hexa; if that file changes, this
//   file will be re-synced on the next P7-9 pass. compile_hello.hexa
//   follows the same "standalone runnable" convention for the same reason.
//
// Programs covered (all exit-code assertions):
//   P1: fn main() { return 42 }                     → exit 42
//   P2: fn main() { return 1 + 2 + 3 }              → exit 6
//   P3: fn main() { if 1 == 1 { return 7 }
//                   else        { return 9 } }      → exit 7
//
// Pipeline stages:
//   1. build_ir_program_* builds IRInstr blocks by hand (no parser wired
//      here — parser-driven variant lands in P7-9; the AST→IR path here is
//      the same shape lower_expr/lower_if/lower_return produce).
//   2. lower_ir_to_arm64_local(blocks, regalloc_map) → .text bytes.
//   3. build_macho_hex(text) → ASCII hex string.
//   4. xxd -r -p hex > /tmp/hexa_pipeline_out_N ; chmod +x ; codesign -.
//   5. exec and capture exit code; assert rc == expected.

// ═══════════════════════════════════════════════════════════
//  ARM64 instruction encoders (mirrors self/codegen/arm64.hexa)
// ═══════════════════════════════════════════════════════════

fn cp_emit32_le(code: [int], instr: int) -> [int] {
    let b0 = instr % 256
    let b1 = (instr / 256) % 256
    let b2 = (instr / 65536) % 256
    let b3 = (instr / 16777216) % 256
    return code.push(b0).push(b1).push(b2).push(b3)
}

// MOVZ Xd, #imm16, LSL #0   (0xd2800000)
fn cp_enc_movz(rd: int, imm16: int) -> int {
    return 3531603968 + (imm16 * 32) + rd
}

// MOVK Xd, #imm16, LSL #hw*16   (0xf2800000)
fn cp_enc_movk(rd: int, imm16: int, hw: int) -> int {
    return 4068474880 + (hw * 2097152) + (imm16 * 32) + rd
}

// ADD Xd, Xn, Xm   (0x8b000000)
fn cp_enc_add(rd: int, rn: int, rm: int) -> int {
    return 2332033024 + (rm * 65536) + (rn * 32) + rd
}

// SUB Xd, Xn, Xm   (0xcb000000)
fn cp_enc_sub(rd: int, rn: int, rm: int) -> int {
    return 3405774848 + (rm * 65536) + (rn * 32) + rd
}

// MUL Xd, Xn, Xm   (0x9b007c00)
fn cp_enc_mul(rd: int, rn: int, rm: int) -> int {
    return 2600500224 + (rm * 65536) + (rn * 32) + rd
}

// MOV Xd, Xn — ORR Xd, XZR, Xn   (0xaa0003e0)
fn cp_enc_mov_reg(rd: int, rm: int) -> int {
    return 2852127712 + (rm * 65536) + rd
}

// CMP Xn, Xm (SUBS XZR, Xn, Xm)   (0xeb00001f)
fn cp_enc_cmp(rn: int, rm: int) -> int {
    return 3942645791 + (rm * 65536) + (rn * 32)
}

// CSET Xd, cond   (0x9a9f07e0 base; cond_code 0..15 via inversion table)
fn cp_enc_cset(rd: int, cond_code: int) -> int {
    if cond_code == 0 { return 2594113504 + 1 * 4096 + rd }     // EQ → CSET uses inv NE
    if cond_code == 1 { return 2594113504 + 0 * 4096 + rd }     // NE
    if cond_code == 10 { return 2594113504 + 11 * 4096 + rd }   // GE
    if cond_code == 11 { return 2594113504 + 10 * 4096 + rd }   // LT
    if cond_code == 12 { return 2594113504 + 13 * 4096 + rd }   // GT
    if cond_code == 13 { return 2594113504 + 12 * 4096 + rd }   // LE
    return 2594113504 + rd
}

// B #off26   (0x14000000)
fn cp_enc_b(off26: int) -> int {
    if off26 >= 0 {
        return 335544320 + (off26 % 67108864)
    }
    return 335544320 + ((off26 + 67108864) % 67108864)
}

// B.cond #off19   (0x54000000)
fn cp_enc_b_cond(off19: int, cond_code: int) -> int {
    let mut off = off19
    if off < 0 { off = off + 524288 }
    return 1409286144 + (off * 32) + cond_code
}

// BL #off26   (0x94000000)
fn cp_enc_bl(off26: int) -> int {
    if off26 >= 0 {
        return 2483027968 + (off26 % 67108864)
    }
    return 2483027968 + ((off26 + 67108864) % 67108864)
}

// RET   (0xd65f03c0)
fn cp_enc_ret() -> int {
    return 3596551104
}

// ═══════════════════════════════════════════════════════════
//  IR instruction struct (flat form used by the lowering bridge)
// ═══════════════════════════════════════════════════════════

struct IRInstr {
    result: int,
    op: string,
    ty: string,
    a: int,
    b: int,
    c: int,
    imm: int,
    is_imm: bool,
    cmp: string
}

fn ir_load_imm(result: int, imm: int) -> IRInstr {
    return IRInstr { result: result, op: "load", ty: "i64",
        a: 0, b: 0, c: 0, imm: imm, is_imm: true, cmp: "" }
}

fn ir_add(result: int, a: int, b: int) -> IRInstr {
    return IRInstr { result: result, op: "add", ty: "i64",
        a: a, b: b, c: 0, imm: 0, is_imm: false, cmp: "" }
}

fn ir_sub(result: int, a: int, b: int) -> IRInstr {
    return IRInstr { result: result, op: "sub", ty: "i64",
        a: a, b: b, c: 0, imm: 0, is_imm: false, cmp: "" }
}

fn ir_cmp(result: int, a: int, b: int, cmp_kind: string) -> IRInstr {
    return IRInstr { result: result, op: "sub", ty: "bool",
        a: a, b: b, c: 0, imm: 0, is_imm: false, cmp: cmp_kind }
}

fn ir_branch(cond_vid: int, then_bb: int, else_bb: int) -> IRInstr {
    return IRInstr { result: -1, op: "branch", ty: "void",
        a: cond_vid, b: then_bb, c: else_bb, imm: 0, is_imm: false, cmp: "" }
}

fn ir_jump(target_bb: int) -> IRInstr {
    return IRInstr { result: -1, op: "jump", ty: "void",
        a: target_bb, b: 0, c: 0, imm: 0, is_imm: false, cmp: "" }
}

fn ir_ret(val_vid: int) -> IRInstr {
    return IRInstr { result: -1, op: "ret", ty: "void",
        a: val_vid, b: 0, c: 0, imm: 0, is_imm: false, cmp: "" }
}

// P7-7a syscall: single-arg shape (e.g. sys_exit(code)).
// `imm` holds the Darwin syscall number; `a` is the arg value's vid.
// Lowering: MOV x0, Rarg ; MOVZ x16, #lo ; MOVK x16, #hi, LSL #16 ; SVC #0x80.
fn ir_syscall1(nr_imm: int, arg_vid: int) -> IRInstr {
    return IRInstr { result: -1, op: "syscall1", ty: "void",
        a: arg_vid, b: 0, c: 0, imm: nr_imm, is_imm: true, cmp: "" }
}

struct IRBlock {
    id: int,
    instructions: array
}

fn ir_block(id: int, instrs: array) -> IRBlock {
    return IRBlock { id: id, instructions: instrs }
}

// ═══════════════════════════════════════════════════════════
//  Register allocation helpers (linear v# → x#)
// ═══════════════════════════════════════════════════════════

fn cp_regalloc_linear(n_values: int) -> [int] {
    let mut out = []
    let mut i = 0
    while i < n_values {
        if i < 8 {
            out.push(i)
        } else {
            out.push(31)   // spill sentinel
        }
        i = i + 1
    }
    return out
}

fn cp_reg_for(map: [int], vid: int) -> int {
    if vid < 0 { return 0 }
    if vid >= len(map) { return 31 }
    return map[vid]
}

// ═══════════════════════════════════════════════════════════
//  IR → ARM64 lowering bridge (mirrors self/codegen/ir_to_arm64.hexa)
// ═══════════════════════════════════════════════════════════

fn cp_ops_size(op: string, is_imm: bool, imm: int, has_cmp: bool) -> int {
    if op == "load" {
        if is_imm {
            let mut v = imm
            if v < 0 { v = 0 - v }
            if v > 65535 { return 2 }
            return 1
        }
        return 1
    }
    if op == "add" { return 1 }
    if op == "mul" { return 1 }
    if op == "sub" {
        if has_cmp { return 2 }
        return 1
    }
    if op == "branch" { return 3 }
    if op == "jump"   { return 1 }
    if op == "ret"    { return 2 }
    if op == "call"   { return 1 }
    // P7-7a: syscall1 = MOV x0,Rarg + MOVZ x16,lo + MOVK x16,hi + SVC = 4 instrs.
    if op == "syscall1" { return 4 }
    if op == "store"  { return 1 }
    if op == "alloc"  { return 0 }
    if op == "phi"    { return 1 }
    if op == "label"  { return 0 }
    return 0
}

fn cp_cmp_code(cmp: string) -> int {
    if cmp == "eq" { return 0 }
    if cmp == "ne" { return 1 }
    if cmp == "ge" { return 10 }
    if cmp == "lt" { return 11 }
    if cmp == "gt" { return 12 }
    if cmp == "le" { return 13 }
    return 14
}

fn cp_emit_one(bytes_in: [int], instr, regalloc_map: [int], block_starts: [int], cur_instr_idx: int) -> [int] {
    let mut bytes = bytes_in

    if instr.op == "load" {
        if instr.is_imm {
            let rd = cp_reg_for(regalloc_map, instr.result)
            let v = instr.imm
            if rd == 31 {
                bytes = cp_emit32_le(bytes, cp_enc_movz(0, 0xDEAD))
                return bytes
            }
            if v < 0 {
                let abs_v = 0 - v
                bytes = cp_emit32_le(bytes, cp_enc_movz(rd, abs_v % 65536))
                if abs_v > 65535 {
                    bytes = cp_emit32_le(bytes, cp_enc_movk(rd, (abs_v / 65536) % 65536, 1))
                }
                return bytes
            }
            let lo = v % 65536
            bytes = cp_emit32_le(bytes, cp_enc_movz(rd, lo))
            if v > 65535 {
                bytes = cp_emit32_le(bytes, cp_enc_movk(rd, (v / 65536) % 65536, 1))
            }
            return bytes
        }
        let rd = cp_reg_for(regalloc_map, instr.result)
        let rs = cp_reg_for(regalloc_map, instr.a)
        bytes = cp_emit32_le(bytes, cp_enc_mov_reg(rd, rs))
        return bytes
    }

    if instr.op == "add" {
        let rd = cp_reg_for(regalloc_map, instr.result)
        let rn = cp_reg_for(regalloc_map, instr.a)
        let rm = cp_reg_for(regalloc_map, instr.b)
        bytes = cp_emit32_le(bytes, cp_enc_add(rd, rn, rm))
        return bytes
    }

    if instr.op == "sub" {
        let rn = cp_reg_for(regalloc_map, instr.a)
        let rm = cp_reg_for(regalloc_map, instr.b)
        let rd = cp_reg_for(regalloc_map, instr.result)
        if instr.cmp != "" {
            bytes = cp_emit32_le(bytes, cp_enc_cmp(rn, rm))
            bytes = cp_emit32_le(bytes, cp_enc_cset(rd, cp_cmp_code(instr.cmp)))
            return bytes
        }
        bytes = cp_emit32_le(bytes, cp_enc_sub(rd, rn, rm))
        return bytes
    }

    if instr.op == "branch" {
        let cond_reg = cp_reg_for(regalloc_map, instr.a)
        bytes = cp_emit32_le(bytes, cp_enc_cmp(cond_reg, 31))
        let then_bb = instr.b
        let else_bb = instr.c
        let mut then_abs = cur_instr_idx + 3
        if then_bb >= 0 {
            if then_bb < len(block_starts) {
                then_abs = block_starts[then_bb]
            }
        }
        let mut else_abs = cur_instr_idx + 3
        if else_bb >= 0 {
            if else_bb < len(block_starts) {
                else_abs = block_starts[else_bb]
            }
        }
        // B.NE → then (cond != 0)
        let b_cond_off = then_abs - (cur_instr_idx + 1)
        bytes = cp_emit32_le(bytes, cp_enc_b_cond(b_cond_off, 1))
        // B → else (fallthrough)
        let b_off = else_abs - (cur_instr_idx + 2)
        bytes = cp_emit32_le(bytes, cp_enc_b(b_off))
        return bytes
    }

    if instr.op == "jump" {
        let tgt_bb = instr.a
        let mut tgt_abs = cur_instr_idx + 1
        if tgt_bb >= 0 {
            if tgt_bb < len(block_starts) {
                tgt_abs = block_starts[tgt_bb]
            }
        }
        let off = tgt_abs - cur_instr_idx
        bytes = cp_emit32_le(bytes, cp_enc_b(off))
        return bytes
    }

    if instr.op == "ret" {
        if instr.a >= 0 {
            let rs = cp_reg_for(regalloc_map, instr.a)
            bytes = cp_emit32_le(bytes, cp_enc_mov_reg(0, rs))
        } else {
            bytes = cp_emit32_le(bytes, cp_enc_mov_reg(0, 31))
        }
        bytes = cp_emit32_le(bytes, cp_enc_ret())
        return bytes
    }

    // P7-7a syscall1 — Darwin ARM64 1-arg syscall.
    //   MOV x0, Rarg              ; arg0
    //   MOVZ x16, #(nr & 0xffff)  ; low 16 bits of nr
    //   MOVK x16, #(nr>>16 & 0xffff), LSL #16  ; high 16 bits
    //   SVC #0x80                 ; 0xd4001001
    if instr.op == "syscall1" {
        let rs = cp_reg_for(regalloc_map, instr.a)
        bytes = cp_emit32_le(bytes, cp_enc_mov_reg(0, rs))
        let nr = instr.imm
        bytes = cp_emit32_le(bytes, cp_enc_movz(16, nr % 65536))
        bytes = cp_emit32_le(bytes, cp_enc_movk(16, (nr / 65536) % 65536, 1))
        bytes = cp_emit32_le(bytes, 3556872193)   // SVC #0x80 = 0xd4001001
        return bytes
    }

    // Unknown op — emit bug sentinel.
    bytes = cp_emit32_le(bytes, cp_enc_movz(0, 0xBADF))
    return bytes
}

// Public entry: blocks (array of IRBlock) + regalloc_map → [int] bytes.
fn lower_ir_to_arm64_local(blocks: array, regalloc_map: [int]) -> [int] {
    // Pass 1: compute block_starts (instruction indices).
    let mut block_starts = []
    let mut cursor = 0
    let mut bi = 0
    while bi < len(blocks) {
        let bb = blocks[bi]
        let bb_id = bb.id
        while len(block_starts) <= bb_id {
            block_starts.push(0)
        }
        block_starts[bb_id] = cursor
        let mut ii = 0
        while ii < len(bb.instructions) {
            let inst = bb.instructions[ii]
            let mut has_cmp = false
            if inst.cmp != "" { has_cmp = true }
            cursor = cursor + cp_ops_size(inst.op, inst.is_imm, inst.imm, has_cmp)
            ii = ii + 1
        }
        bi = bi + 1
    }

    // Pass 2: emit bytes.
    let mut bytes = []
    let mut instr_idx = 0
    bi = 0
    while bi < len(blocks) {
        let bb = blocks[bi]
        let mut ii = 0
        while ii < len(bb.instructions) {
            let inst = bb.instructions[ii]
            let mut has_cmp = false
            if inst.cmp != "" { has_cmp = true }
            let sz = cp_ops_size(inst.op, inst.is_imm, inst.imm, has_cmp)
            bytes = cp_emit_one(bytes, inst, regalloc_map, block_starts, instr_idx)
            instr_idx = instr_idx + sz
            ii = ii + 1
        }
        bi = bi + 1
    }
    return bytes
}

// ═══════════════════════════════════════════════════════════
//  Mach-O MH_EXECUTE wrapper (ported from compile_hello.hexa).
//  Accepts .text bytes as array<int> of u8 values.
//  Relies on LC_MAIN calling entry as main() — the value in x0 at RET
//  becomes the process exit code.
// ═══════════════════════════════════════════════════════════

fn u32_to_hex(v: int, h: string) -> string {
    let mut parts = []
    parts.push(h[(v % 256) / 16])
    parts.push(h[(v % 256) % 16])
    parts.push(h[((v / 256) % 256) / 16])
    parts.push(h[((v / 256) % 256) % 16])
    parts.push(h[((v / 65536) % 256) / 16])
    parts.push(h[((v / 65536) % 256) % 16])
    parts.push(h[((v / 16777216) % 256) / 16])
    parts.push(h[((v / 16777216) % 256) % 16])
    return parts.join("")
}

fn u64_to_hex(v: int, h: string) -> string {
    let lo = v % 4294967296
    let hi = v / 4294967296
    return u32_to_hex(lo, h) + u32_to_hex(hi, h)
}

fn byte_to_hex(b: int, h: string) -> string {
    let mut parts = []
    parts.push(h[b / 16])
    parts.push(h[b % 16])
    return parts.join("")
}

fn build_macho_hex(text_bytes: [int]) -> string {
    let HEX = "0123456789abcdef"
    let MH_MAGIC_64 = 4277009103
    let CPU_ARM64   = 16777228
    let MH_EXECUTE  = 2
    let HDR_FLAGS   = 2097285
    let NCMDS       = 11
    let SIZEOFCMDS  = 576
    let PAGE        = 16384
    let CODE_OFF    = 768

    let code_bytes = len(text_bytes)
    let mut text_size_aligned = code_bytes
    if text_size_aligned % 4 != 0 {
        text_size_aligned = text_size_aligned + (4 - text_size_aligned % 4)
    }

    let mut parts = []
    let hdr_u32 = [MH_MAGIC_64, CPU_ARM64, 0, MH_EXECUTE, NCMDS, SIZEOFCMDS, HDR_FLAGS, 0]
    let mut hi = 0
    while hi < len(hdr_u32) {
        parts.push(u32_to_hex(hdr_u32[hi], HEX))
        hi = hi + 1
    }

    // LC_SEGMENT_64 __PAGEZERO
    parts.push("19000000" + "48000000")
    parts.push("5f5f504147455a45524f0000000000" + "00")
    parts.push("0000000000000000")
    parts.push("0000000001000000")
    parts.push("0000000000000000")
    parts.push("0000000000000000")
    parts.push("00000000" + "00000000" + "00000000" + "00000000")

    // LC_SEGMENT_64 __TEXT
    parts.push("19000000" + "98000000")
    parts.push("5f5f54455854000000000000000000" + "00")
    parts.push("0000000001000000")
    parts.push("0040000000000000")
    parts.push("0000000000000000")
    parts.push("0040000000000000")
    parts.push("05000000")
    parts.push("05000000")
    parts.push("01000000")
    parts.push("00000000")

    // section __text
    parts.push("5f5f74657874000000000000000000" + "00")
    parts.push("5f5f54455854000000000000000000" + "00")
    parts.push(u64_to_hex(4294967296 + CODE_OFF, HEX))
    parts.push(u64_to_hex(text_size_aligned, HEX))
    parts.push(u32_to_hex(CODE_OFF, HEX))
    parts.push("02000000")
    parts.push("00000000" + "00000000")
    parts.push("00040080")
    parts.push("00000000" + "00000000" + "00000000")

    // LC_SEGMENT_64 __LINKEDIT
    parts.push("19000000" + "48000000")
    parts.push("5f5f4c494e4b45444954000000000000")
    parts.push("0040000001000000")
    parts.push("0040000000000000")
    parts.push("0040000000000000")
    parts.push("3100000000000000")
    parts.push("01000000" + "01000000")
    parts.push("00000000" + "00000000")

    // LC_DYLD_CHAINED_FIXUPS
    parts.push("34000080" + "10000000" + "00400000" + "30000000")

    // LC_SYMTAB
    parts.push("02000000" + "18000000")
    parts.push("30400000")
    parts.push("00000000")
    parts.push("30400000")
    parts.push("01000000")

    // LC_DYSYMTAB
    parts.push("0b000000" + "50000000")
    let mut dyz_parts = []
    let mut dyz = 0
    while dyz < 72 {
        dyz_parts.push("00")
        dyz = dyz + 1
    }
    parts.push(dyz_parts.join(""))

    // LC_LOAD_DYLINKER
    parts.push("0e000000" + "20000000" + "0c000000")
    parts.push("2f7573722f6c69622f64796c6400")
    parts.push("000000000000")

    // LC_UUID
    parts.push("1b000000" + "18000000")
    parts.push("48455841414243444546303132333435")

    // LC_BUILD_VERSION
    parts.push("32000000" + "18000000")
    parts.push("01000000")
    parts.push("00000e00")
    parts.push("00000e00")
    parts.push("00000000")

    // LC_MAIN
    parts.push("28000080" + "18000000")
    parts.push(u64_to_hex(CODE_OFF, HEX))
    parts.push("0000000000000000")

    // LC_LOAD_DYLIB libSystem
    parts.push("0c000000" + "38000000")
    parts.push("18000000")
    parts.push("02000000")
    parts.push("00000100")
    parts.push("00000100")
    parts.push("2f7573722f6c69622f6c69625379737465")
    parts.push("6d2e422e64796c696200000000000000")

    let mut s = parts.join("")

    // Pad to CODE_OFF.
    while (len(s) / 2) < CODE_OFF {
        s = s + "00"
    }

    // Append .text bytes.
    let mut bi = 0
    while bi < len(text_bytes) {
        s = s + byte_to_hex(text_bytes[bi], HEX)
        bi = bi + 1
    }

    // Pad to PAGE boundary.
    while (len(s) / 2) < PAGE {
        s = s + "00"
    }

    // __LINKEDIT stub (chained fixups + symtab strings — 49 bytes).
    s = s + "00000000"
    s = s + "20000000"
    s = s + "00000000"
    s = s + "00000000"
    s = s + "00000000"
    s = s + "01000000"
    s = s + "00000000"
    s = s + "00000000"
    s = s + "03000000"
    s = s + "00000000" + "00000000" + "00000000"
    s = s + "00"

    return s
}

// ═══════════════════════════════════════════════════════════
//  Pad text bytes to 4-byte alignment.
// ═══════════════════════════════════════════════════════════

fn pad_text_align4(text_in: [int]) -> [int] {
    let mut text = text_in
    while len(text) % 4 != 0 {
        text.push(0)
    }
    return text
}

// ═══════════════════════════════════════════════════════════
//  IR builders for the three demo programs.
//
//  Value-id layout is deterministic (linear v0..vN → x0..xN) so the
//  linear regalloc below produces predictable code. All three programs
//  stay under 8 SSA values (no spill sentinels).
// ═══════════════════════════════════════════════════════════

// P1: return 42
//   IR:
//     bb0:
//       v0 = load imm 42
//       ret v0
//   Expected: x0 = 42, exit 42.
fn build_ir_p1_return_42() -> array {
    let mut b0 = []
    b0.push(ir_load_imm(0, 42))   // v0 = 42 → x0
    b0.push(ir_ret(0))            // ret v0 → MOV x0, x0 ; RET
    return [ir_block(0, b0)]
}

// P2: return 1 + 2 + 3
//   IR:
//     bb0:
//       v0 = load 1
//       v1 = load 2
//       v2 = add v0, v1   (=3, in x2)
//       v3 = load 3
//       v4 = add v2, v3   (=6, in x4)
//       ret v4
//   Expected: exit 6.
fn build_ir_p2_sum() -> array {
    let mut b0 = []
    b0.push(ir_load_imm(0, 1))
    b0.push(ir_load_imm(1, 2))
    b0.push(ir_add(2, 0, 1))
    b0.push(ir_load_imm(3, 3))
    b0.push(ir_add(4, 2, 3))
    b0.push(ir_ret(4))
    return [ir_block(0, b0)]
}

// P4: sys_exit(42) via syscall — P7-7a validation.
//   IR:
//     bb0:
//       v0 = load imm 42
//       syscall1 nr=0x2000001, arg=v0    ; Darwin SYS_exit
//   Expected: exit 42 (via svc, no ret — kernel kills process).
fn build_ir_p4_syscall_exit() -> array {
    let mut b0 = []
    b0.push(ir_load_imm(0, 42))
    b0.push(ir_syscall1(33554433, 0))
    return [ir_block(0, b0)]
}

// P3: if 1 == 1 { return 7 } else { return 9 }
//   IR:
//     bb0:
//       v0 = load 1
//       v1 = load 1
//       v2 = sub(cmp=eq) v0, v1   → CMP + CSET EQ  (=1 in x2)
//       branch v2 → bb1, bb2
//     bb1:
//       v3 = load 7
//       ret v3
//     bb2:
//       v4 = load 9
//       ret v4
//   Expected: exit 7 (then-branch taken).
fn build_ir_p3_if_eq() -> array {
    let mut b0 = []
    b0.push(ir_load_imm(0, 1))
    b0.push(ir_load_imm(1, 1))
    b0.push(ir_cmp(2, 0, 1, "eq"))
    b0.push(ir_branch(2, 1, 2))

    let mut b1 = []
    b1.push(ir_load_imm(3, 7))
    b1.push(ir_ret(3))

    let mut b2 = []
    b2.push(ir_load_imm(4, 9))
    b2.push(ir_ret(4))

    return [ir_block(0, b0), ir_block(1, b1), ir_block(2, b2)]
}

// ═══════════════════════════════════════════════════════════
//  Pipeline driver: compile + run + assert.
// ═══════════════════════════════════════════════════════════

fn run_program(name: string, blocks: array, n_values: int, out_path: string, expected_rc: int) -> bool {
    println("--- " + name + " ---")

    // 1. Lower IR → .text bytes.
    let regmap = cp_regalloc_linear(n_values)
    let text = pad_text_align4(lower_ir_to_arm64_local(blocks, regmap))
    println("  text bytes : " + to_string(len(text)))

    // 2. Wrap in Mach-O.
    let hex_data = build_macho_hex(text)
    let macho_size = len(hex_data) / 2
    println("  macho bytes: " + to_string(macho_size))

    // 3. Write to disk.
    exec("printf '%s' '" + hex_data + "' | xxd -r -p > " + out_path)
    exec("chmod +x " + out_path)

    // 4. Codesign ad-hoc.
    let cs = exec_with_status("codesign --force --sign - " + out_path + " 2>&1")
    if cs[1] != 0 {
        println("  WARN codesign rc=" + to_string(cs[1]) + ": " + cs[0].trim())
    }

    // 5. Run & capture rc.
    let r = exec_with_status(out_path + " 2>&1")
    let rc = r[1]
    println("  exit code  : " + to_string(rc) + " (want " + to_string(expected_rc) + ")")

    let pass = rc == expected_rc
    if pass {
        println("  [PASS]")
    } else {
        println("  [FAIL] got " + to_string(rc) + " want " + to_string(expected_rc))
    }
    return pass
}

// ═══════════════════════════════════════════════════════════
//  Driver
// ═══════════════════════════════════════════════════════════

println("=== P7-8 compile_pipeline: AST → IR → ARM64 → Mach-O ===")
println("")

let mut all_pass = true

// P1: return 42
// doc-assert: exit == 42
let p1_ok = run_program("P1: return 42",
                        build_ir_p1_return_42(),
                        1,
                        "/tmp/hexa_pipeline_out_p1",
                        42)
if !p1_ok { all_pass = false }
println("")

// P2: return 1 + 2 + 3
// doc-assert: exit == 6
let p2_ok = run_program("P2: return 1 + 2 + 3",
                        build_ir_p2_sum(),
                        5,
                        "/tmp/hexa_pipeline_out_p2",
                        6)
if !p2_ok { all_pass = false }
println("")

// P3: if 1 == 1 { return 7 } else { return 9 }
// doc-assert: exit == 7
let p3_ok = run_program("P3: if 1 == 1 { return 7 } else { return 9 }",
                        build_ir_p3_if_eq(),
                        5,
                        "/tmp/hexa_pipeline_out_p3",
                        7)
if !p3_ok { all_pass = false }
println("")

// P4: syscall1 sys_exit(42) — P7-7a IR op handler validation.
// doc-assert: exit == 42 (kernel terminates via svc, no ret)
let p4_ok = run_program("P4: syscall1 sys_exit(42)",
                        build_ir_p4_syscall_exit(),
                        1,
                        "/tmp/hexa_pipeline_out_p4",
                        42)
if !p4_ok { all_pass = false }
println("")

println("=== summary ===")
if all_pass {
    println("ALL 4 PROGRAMS PASS — P7-8 gate CLOSED, P7-7a syscall op VALIDATED.")
    println("  artifacts: /tmp/hexa_pipeline_out_{p1,p2,p3,p4}")
} else {
    println("FAIL — at least one program did not match expected exit code.")
}
