// ═══════════════════════════════════════════════════════════
//  test_scev.hexa — #68 Scalar Evolution (SCEV) Analysis
//
//  Verifies that loop induction variables can be identified
//  and their closed-form expressions correctly derived.
//  Tests cover linear, geometric, negative step, commutative,
//  multi-IV, derived IV, trip count, and summation.
//
//  Source: self/ai_native_pass.hexa (anp_scev_* functions)
//  Run:   ./hexa self/test_scev.hexa
// ═══════════════════════════════════════════════════════════

// ── SCEV functions (mirrored from ai_native_pass.hexa #68) ──

let mut m979_scev_ivs_found = 0
let mut m979_scev_closed_forms = 0
let mut m979_scev_loops_analyzed = 0

fn anp_scev_name_not_in(name, lst) {
    let n = len(lst)
    let mut i = 0
    while i < n {
        if lst[i] == name { return false }
        i = i + 1
    }
    return true
}

fn anp_scev_analyze(loop_node) {
    let body = loop_node.body
    if type_of(body) != "array" { return [] }
    let mut ivs = []
    let mut seen_names = []
    let n = len(body)
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if type_of(stmt) != "string" && stmt.kind == "AssignStmt" {
            let vname = stmt.name
            let rhs = stmt.right
            if type_of(rhs) != "string" && rhs.kind == "BinOp" {
                if rhs.op == "+" {
                    if type_of(rhs.left) != "string" && rhs.left.kind == "Ident" && rhs.left.name == vname {
                        if type_of(rhs.right) != "string" && rhs.right.kind == "IntLit" {
                            let step_val = to_int(rhs.right.value)
                            if anp_scev_name_not_in(vname, seen_names) {
                                seen_names.push(vname)
                                ivs.push(#{"name": vname, "base": 0, "step": step_val, "kind": "linear", "op": "+"})
                            }
                        }
                    }
                    if type_of(rhs.right) != "string" && rhs.right.kind == "Ident" && rhs.right.name == vname {
                        if type_of(rhs.left) != "string" && rhs.left.kind == "IntLit" {
                            let step_val = to_int(rhs.left.value)
                            if anp_scev_name_not_in(vname, seen_names) {
                                seen_names.push(vname)
                                ivs.push(#{"name": vname, "base": 0, "step": step_val, "kind": "linear", "op": "+"})
                            }
                        }
                    }
                }
                if rhs.op == "-" {
                    if type_of(rhs.left) != "string" && rhs.left.kind == "Ident" && rhs.left.name == vname {
                        if type_of(rhs.right) != "string" && rhs.right.kind == "IntLit" {
                            let step_val = to_int(rhs.right.value)
                            if anp_scev_name_not_in(vname, seen_names) {
                                seen_names.push(vname)
                                ivs.push(#{"name": vname, "base": 0, "step": 0 - step_val, "kind": "linear", "op": "-"})
                            }
                        }
                    }
                }
                if rhs.op == "*" {
                    if type_of(rhs.left) != "string" && rhs.left.kind == "Ident" && rhs.left.name == vname {
                        if type_of(rhs.right) != "string" && rhs.right.kind == "IntLit" {
                            let step_val = to_int(rhs.right.value)
                            if anp_scev_name_not_in(vname, seen_names) {
                                seen_names.push(vname)
                                ivs.push(#{"name": vname, "base": 0, "step": step_val, "kind": "geometric", "op": "*"})
                            }
                        }
                    }
                    if type_of(rhs.right) != "string" && rhs.right.kind == "Ident" && rhs.right.name == vname {
                        if type_of(rhs.left) != "string" && rhs.left.kind == "IntLit" {
                            let step_val = to_int(rhs.left.value)
                            if anp_scev_name_not_in(vname, seen_names) {
                                seen_names.push(vname)
                                ivs.push(#{"name": vname, "base": 0, "step": step_val, "kind": "geometric", "op": "*"})
                            }
                        }
                    }
                }
            }
        }
        i = i + 1
    }
    m979_scev_ivs_found = m979_scev_ivs_found + len(ivs)
    return ivs
}

fn anp_scev_find_init(pre_stmts, varname) {
    if type_of(pre_stmts) != "array" { return 0 }
    let n = len(pre_stmts)
    let mut i = 0
    while i < n {
        let stmt = pre_stmts[i]
        if type_of(stmt) != "string" {
            if stmt.kind == "LetMutStmt" || stmt.kind == "LetStmt" {
                if stmt.name == varname {
                    if type_of(stmt.left) != "string" && stmt.left.kind == "IntLit" {
                        return to_int(stmt.left.value)
                    }
                }
            }
        }
        i = i + 1
    }
    return 0
}

fn anp_scev_closed_form(iv) {
    let name = iv["name"]
    let base = iv["base"]
    let step = iv["step"]
    let kind = iv["kind"]
    if kind == "linear" {
        let cf = to_string(base) + " + " + to_string(step) + "*i"
        m979_scev_closed_forms = m979_scev_closed_forms + 1
        return #{"name": name, "base": base, "step": step, "kind": "linear", "closed_form": cf}
    }
    if kind == "geometric" {
        let cf = to_string(base) + " * " + to_string(step) + "^i"
        m979_scev_closed_forms = m979_scev_closed_forms + 1
        return #{"name": name, "base": base, "step": step, "kind": "geometric", "closed_form": cf}
    }
    return #{"name": name, "base": base, "step": step, "kind": "unknown", "closed_form": "unknown"}
}

fn anp_scev_eval_linear(base, step, iter) {
    return base + step * iter
}

fn anp_scev_eval_geometric(base, step, iter) {
    let mut result = base
    let mut j = 0
    while j < iter {
        result = result * step
        j = j + 1
    }
    return result
}

fn anp_scev_trace_linear(base, step, n) {
    let mut out = []
    let mut i = 0
    while i < n {
        out.push(base + step * i)
        i = i + 1
    }
    return out
}

fn anp_scev_trace_geometric(base, step, n) {
    let mut out = []
    let mut val = base
    let mut i = 0
    while i < n {
        out.push(val)
        val = val * step
        i = i + 1
    }
    return out
}

fn anp_scev_analyze_in_context(pre_stmts, loop_node) {
    let ivs = anp_scev_analyze(loop_node)
    let mut results = []
    let n = len(ivs)
    let mut i = 0
    while i < n {
        let iv = ivs[i]
        let base = anp_scev_find_init(pre_stmts, iv["name"])
        let iv_with_base = #{"name": iv["name"], "base": base, "step": iv["step"], "kind": iv["kind"], "op": iv["op"]}
        let cf = anp_scev_closed_form(iv_with_base)
        results.push(cf)
        i = i + 1
    }
    return results
}

fn anp_scev_pass(ast) {
    m979_scev_ivs_found = 0
    m979_scev_closed_forms = 0
    m979_scev_loops_analyzed = 0
    if type_of(ast) != "array" { return ast }
    let n = len(ast)
    let mut i = 0
    while i < n {
        let node = ast[i]
        if type_of(node) != "string" {
            if node.kind == "FnDecl" {
                anp_scev_pass_body(node.body)
            }
        }
        i = i + 1
    }
    if m979_scev_ivs_found > 0 {
        println("[ai-native] SCEV: " + to_string(m979_scev_loops_analyzed) + " loop(s) analyzed, " + to_string(m979_scev_ivs_found) + " IV(s) found, " + to_string(m979_scev_closed_forms) + " closed-form(s)")
    }
    return ast
}

// decreases body — structural
fn anp_scev_pass_body(body) {
    if type_of(body) != "array" { return }
    let n = len(body)
    let mut pre_stmts = []
    let mut i = 0
    while i < n {
        let stmt = body[i]
        if type_of(stmt) != "string" {
            if stmt.kind == "WhileStmt" {
                m979_scev_loops_analyzed = m979_scev_loops_analyzed + 1
                anp_scev_analyze_in_context(pre_stmts, stmt)
                anp_scev_pass_body(stmt.body)
            } else if stmt.kind == "IfStmt" {
                anp_scev_pass_body(stmt.body)
                if type_of(stmt.else_body) == "array" {
                    anp_scev_pass_body(stmt.else_body)
                }
            } else {
                pre_stmts.push(stmt)
            }
        }
        i = i + 1
    }
}

fn anp_scev_lookup_iv(expr, known_ivs) {
    if type_of(expr) == "string" { return "" }
    if expr.kind != "Ident" { return "" }
    let name = expr.name
    let n = len(known_ivs)
    let mut i = 0
    while i < n {
        if known_ivs[i]["name"] == name { return known_ivs[i] }
        i = i + 1
    }
    return ""
}

fn anp_scev_detect_derived(loop_body, known_ivs) {
    if type_of(loop_body) != "array" { return [] }
    let mut derived = []
    let n = len(loop_body)
    let mut i = 0
    while i < n {
        let stmt = loop_body[i]
        if type_of(stmt) != "string" {
            if stmt.kind == "LetStmt" || stmt.kind == "LetMutStmt" {
                let vname = stmt.name
                let init = stmt.left
                if type_of(init) != "string" && init.kind == "BinOp" {
                    if init.op == "*" {
                        let base_iv_info = anp_scev_lookup_iv(init.left, known_ivs)
                        if base_iv_info != "" {
                            if type_of(init.right) != "string" && init.right.kind == "IntLit" {
                                let c = to_int(init.right.value)
                                let derived_step = base_iv_info["step"] * c
                                derived.push(#{"name": vname, "base": 0, "step": derived_step, "kind": "linear", "derived_from": base_iv_info["name"]})
                            }
                        }
                        let base_iv_info2 = anp_scev_lookup_iv(init.right, known_ivs)
                        if base_iv_info2 != "" {
                            if type_of(init.left) != "string" && init.left.kind == "IntLit" {
                                let c = to_int(init.left.value)
                                let derived_step = base_iv_info2["step"] * c
                                derived.push(#{"name": vname, "base": 0, "step": derived_step, "kind": "linear", "derived_from": base_iv_info2["name"]})
                            }
                        }
                    }
                    if init.op == "+" {
                        let base_iv_info = anp_scev_lookup_iv(init.left, known_ivs)
                        if base_iv_info != "" {
                            if type_of(init.right) != "string" && init.right.kind == "IntLit" {
                                let c = to_int(init.right.value)
                                derived.push(#{"name": vname, "base": base_iv_info["base"] + c, "step": base_iv_info["step"], "kind": "linear", "derived_from": base_iv_info["name"]})
                            }
                        }
                    }
                }
            }
        }
        i = i + 1
    }
    return derived
}

fn anp_scev_trip_count(loop_cond, iv_base, iv_step) {
    if type_of(loop_cond) == "string" { return -1 }
    if loop_cond.kind != "BinOp" { return -1 }
    if loop_cond.op != "<" && loop_cond.op != "<=" { return -1 }
    if type_of(loop_cond.right) == "string" { return -1 }
    if loop_cond.right.kind != "IntLit" { return -1 }
    let limit = to_int(loop_cond.right.value)
    if iv_step == 0 { return -1 }
    if iv_step > 0 {
        if iv_base >= limit { return 0 }
        let range = limit - iv_base
        if loop_cond.op == "<" {
            let trips = (range + iv_step - 1) / iv_step
            return trips
        }
        if loop_cond.op == "<=" {
            let range2 = limit - iv_base + 1
            let trips = (range2 + iv_step - 1) / iv_step
            return trips
        }
    }
    return -1
}

fn anp_scev_sum_linear(base, step, n) {
    return n * base + step * (n * (n - 1) / 2)
}

// ── Test infrastructure ──

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn check_eq(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_arr(name, actual, expected) {
    if len(actual) != len(expected) {
        println("[FAIL] " + name + " — len mismatch: " + to_string(len(actual)) + " vs " + to_string(len(expected)))
        fail_count = fail_count + 1
        return
    }
    let mut ok = true
    let mut i = 0
    while i < len(actual) {
        if actual[i] != expected[i] { ok = false }
        i = i + 1
    }
    if ok {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — actual: " + to_string(actual) + ", expected: " + to_string(expected))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  #68 Scalar Evolution (SCEV) Analysis Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Linear eval: base=0, step=1 ──
check_eq("linear eval b=0 s=1 i=0", anp_scev_eval_linear(0, 1, 0), 0)
check_eq("linear eval b=0 s=1 i=5", anp_scev_eval_linear(0, 1, 5), 5)
check_eq("linear eval b=0 s=1 i=10", anp_scev_eval_linear(0, 1, 10), 10)

// ── 2. Linear eval: base=0, step=2 ──
check_eq("linear eval b=0 s=2 i=0", anp_scev_eval_linear(0, 2, 0), 0)
check_eq("linear eval b=0 s=2 i=3", anp_scev_eval_linear(0, 2, 3), 6)
check_eq("linear eval b=0 s=2 i=5", anp_scev_eval_linear(0, 2, 5), 10)

// ── 3. Linear eval with non-zero base ──
check_eq("linear eval b=10 s=3 i=0", anp_scev_eval_linear(10, 3, 0), 10)
check_eq("linear eval b=10 s=3 i=4", anp_scev_eval_linear(10, 3, 4), 22)

// ── 4. Linear eval with negative step ──
check_eq("linear eval b=100 s=-5 i=0", anp_scev_eval_linear(100, -5, 0), 100)
check_eq("linear eval b=100 s=-5 i=3", anp_scev_eval_linear(100, -5, 3), 85)
check_eq("linear eval b=100 s=-5 i=20", anp_scev_eval_linear(100, -5, 20), 0)

// ── 5. Geometric eval: base=1, step=2 (powers of 2) ──
check_eq("geometric eval b=1 s=2 i=0", anp_scev_eval_geometric(1, 2, 0), 1)
check_eq("geometric eval b=1 s=2 i=3", anp_scev_eval_geometric(1, 2, 3), 8)
check_eq("geometric eval b=1 s=2 i=5", anp_scev_eval_geometric(1, 2, 5), 32)

// ── 6. Geometric eval: base=3, step=3 ──
check_eq("geometric eval b=3 s=3 i=0", anp_scev_eval_geometric(3, 3, 0), 3)
check_eq("geometric eval b=3 s=3 i=2", anp_scev_eval_geometric(3, 3, 2), 27)
check_eq("geometric eval b=3 s=3 i=4", anp_scev_eval_geometric(3, 3, 4), 243)

// ── 7. Trace linear: verify sequence ──
check_arr("trace linear b=0 s=1 n=5", anp_scev_trace_linear(0, 1, 5), [0, 1, 2, 3, 4])
check_arr("trace linear b=0 s=2 n=4", anp_scev_trace_linear(0, 2, 4), [0, 2, 4, 6])
check_arr("trace linear b=5 s=3 n=4", anp_scev_trace_linear(5, 3, 4), [5, 8, 11, 14])
check_arr("trace linear b=10 s=-2 n=3", anp_scev_trace_linear(10, -2, 3), [10, 8, 6])

// ── 8. Trace geometric: verify sequence ──
check_arr("trace geom b=1 s=2 n=5", anp_scev_trace_geometric(1, 2, 5), [1, 2, 4, 8, 16])
check_arr("trace geom b=2 s=3 n=4", anp_scev_trace_geometric(2, 3, 4), [2, 6, 18, 54])

// ── 9. Trace empty (n=0) ──
check_arr("trace linear n=0", anp_scev_trace_linear(0, 1, 0), [])
check_arr("trace geom n=0", anp_scev_trace_geometric(1, 2, 0), [])

// ── 10. Closed-form derivation: linear ──
let cf_lin = anp_scev_closed_form(#{"name": "i", "base": 0, "step": 1, "kind": "linear"})
check_eq("closed_form linear name", cf_lin["name"], "i")
check_eq("closed_form linear kind", cf_lin["kind"], "linear")
check_eq("closed_form linear base", cf_lin["base"], 0)
check_eq("closed_form linear step", cf_lin["step"], 1)
check_eq("closed_form linear cf", cf_lin["closed_form"], "0 + 1*i")

// ── 11. Closed-form: linear step=2, base=5 ──
let cf_lin2 = anp_scev_closed_form(#{"name": "x", "base": 5, "step": 2, "kind": "linear"})
check_eq("closed_form lin2 cf", cf_lin2["closed_form"], "5 + 2*i")

// ── 12. Closed-form: geometric ──
let cf_geo = anp_scev_closed_form(#{"name": "pow", "base": 1, "step": 2, "kind": "geometric"})
check_eq("closed_form geo kind", cf_geo["kind"], "geometric")
check_eq("closed_form geo cf", cf_geo["closed_form"], "1 * 2^i")

// ── 13. Closed-form: unknown kind ──
let cf_unk = anp_scev_closed_form(#{"name": "q", "base": 0, "step": 0, "kind": "unknown"})
check_eq("closed_form unknown kind", cf_unk["kind"], "unknown")
check_eq("closed_form unknown cf", cf_unk["closed_form"], "unknown")

// ── 14. Sum of linear IV: sum(0+1*i, i=0..5) = 10 ──
check_eq("sum linear b=0 s=1 n=5", anp_scev_sum_linear(0, 1, 5), 10)

// ── 15. Sum of linear IV: sum(0+2*i, i=0..5) = 20 ──
check_eq("sum linear b=0 s=2 n=5", anp_scev_sum_linear(0, 2, 5), 20)

// ── 16. Sum with base: sum(10+1*i, i=0..4) = 46 ──
check_eq("sum linear b=10 s=1 n=4", anp_scev_sum_linear(10, 1, 4), 46)

// ── 17. Sum with n=0 ──
check_eq("sum linear n=0", anp_scev_sum_linear(0, 1, 0), 0)

// ── 18. Sum with n=1 ──
check_eq("sum linear n=1", anp_scev_sum_linear(5, 3, 1), 5)

// ── 19. Semantic: loop sum == closed-form sum ──
fn loop_sum_manual(base, step, n) {
    let mut total = 0
    let mut val = base
    let mut i = 0
    while i < n {
        total = total + val
        val = val + step
        i = i + 1
    }
    return total
}
check_eq("semantic sum b=0 s=3 n=10", loop_sum_manual(0, 3, 10), anp_scev_sum_linear(0, 3, 10))
check_eq("semantic sum b=5 s=2 n=7", loop_sum_manual(5, 2, 7), anp_scev_sum_linear(5, 2, 7))

// ── 20. Semantic: loop trace == scev trace ──
fn loop_trace_manual(base, step, n) {
    let mut out = []
    let mut val = base
    let mut i = 0
    while i < n {
        out.push(val)
        val = val + step
        i = i + 1
    }
    return out
}
check_arr("semantic trace b=0 s=2 n=5", loop_trace_manual(0, 2, 5), anp_scev_trace_linear(0, 2, 5))
check_arr("semantic trace b=3 s=4 n=4", loop_trace_manual(3, 4, 4), anp_scev_trace_linear(3, 4, 4))

// ── 21. Verify geometric trace against manual loop ──
fn loop_trace_geom_manual(base, factor, n) {
    let mut out = []
    let mut val = base
    let mut i = 0
    while i < n {
        out.push(val)
        val = val * factor
        i = i + 1
    }
    return out
}
check_arr("semantic geom b=1 s=2 n=6", loop_trace_geom_manual(1, 2, 6), anp_scev_trace_geometric(1, 2, 6))
check_arr("semantic geom b=5 s=3 n=4", loop_trace_geom_manual(5, 3, 4), anp_scev_trace_geometric(5, 3, 4))

// ── 22. Final iteration value ──
check_eq("final val step=1 n=100", anp_scev_eval_linear(0, 1, 100), 100)
check_eq("final val step=7 n=10", anp_scev_eval_linear(0, 7, 10), 70)

// ── 23. Large step ──
check_eq("large step s=1000 i=1000", anp_scev_eval_linear(0, 1000, 1000), 1000000)

// ── 24. Negative base + positive step ──
check_eq("neg base b=-10 s=3 i=5", anp_scev_eval_linear(-10, 3, 5), 5)

// ── 25. name_not_in helper ──
check("name_not_in empty", anp_scev_name_not_in("x", []))
check("name_not_in absent", anp_scev_name_not_in("x", ["a", "b", "c"]))
check("name_not_in present", anp_scev_name_not_in("b", ["a", "b", "c"]) == false)

// ── 26. Counter check ──
m979_scev_closed_forms = 0
let dummy_cf1 = anp_scev_closed_form(#{"name": "a", "base": 0, "step": 1, "kind": "linear"})
let dummy_cf2 = anp_scev_closed_form(#{"name": "b", "base": 0, "step": 2, "kind": "geometric"})
let dummy_cf3 = anp_scev_closed_form(#{"name": "c", "base": 0, "step": 0, "kind": "unknown"})
check_eq("counter after 3 calls", m979_scev_closed_forms, 2)

// ── Summary
