#!hexa lax
// =====================================================================
//  self/test_crosscompile.hexa  --  ROI #179
//
//  Tests the cross-compile scaffold from self/crosscompile.hexa.
//
//  Convention: like self/test_path_pure.hexa and friends, this file
//  inlines the scaffold's public surface so it can be run as a
//  single-file test via:  ./hexa test self/test_crosscompile.hexa
//
//  Coverage:
//    1. triple_make round-trip
//    2. parse_triple happy paths + arch normalization
//    3. parse_triple malformed input
//    4. host/target triple constants
//    5. OS / arch branch helpers
//    6. obj_format mapping
//    7. sysroot env override + default
//    8. linker_for per target
//    9. build_link_argv shape for linux-x86_64
//   10. build_link_argv shape for darwin-arm64
//   11. cross_plan success path (darwin-arm64 → linux-x86_64)
//   12. cross_plan failure on invalid target
//   13. cross_plan_describe formatting
// =====================================================================

// ── inlined scaffold (mirrors self/crosscompile.hexa) ──────────────

struct Triple {
    arch: string,
    vendor: string,
    os: string,
    abi: string
}

fn triple_make(arch, vendor, os, abi) -> Triple {
    return Triple{ arch: arch, vendor: vendor, os: os, abi: abi }
}

fn host_triple() -> Triple {
    return triple_make("arm64", "apple", "darwin", "")
}

fn linux_x86_64_triple() -> Triple {
    return triple_make("x86_64", "unknown", "linux", "gnu")
}

fn triple_to_string(t: Triple) -> string {
    let base = t.arch + "-" + t.vendor + "-" + t.os
    if len(t.abi) == 0 { return base }
    return base + "-" + t.abi
}

fn _normalize_arch(a) -> string {
    if a == "aarch64" { return "arm64" }
    if a == "amd64"   { return "x86_64" }
    if a == "x64"     { return "x86_64" }
    return a
}

fn parse_triple(s) -> Triple {
    if type_of(s) != "string" { return triple_make("", "", "", "") }
    if len(s) == 0             { return triple_make("", "", "", "") }
    let parts = s.split("-")
    if len(parts) < 3 { return triple_make("", "", "", "") }
    let arch   = _normalize_arch(parts[0])
    let vendor = parts[1]
    let os     = parts[2]
    let mut i = 3
    let mut abi_parts = []
    while i < len(parts) {
        abi_parts.push(parts[i])
        i = i + 1
    }
    let mut abi = ""
    if len(abi_parts) > 0 {
        abi = abi_parts.join("-")
    }
    return triple_make(arch, vendor, os, abi)
}

fn triple_is_valid(t: Triple) -> bool {
    if len(t.arch)   == 0 { return false }
    if len(t.vendor) == 0 { return false }
    if len(t.os)     == 0 { return false }
    return true
}

fn triple_is_darwin(t: Triple) -> bool { return t.os == "darwin" }
fn triple_is_linux(t: Triple)  -> bool { return t.os == "linux" }
fn triple_is_arm64(t: Triple)  -> bool { return t.arch == "arm64" }
fn triple_is_x86_64(t: Triple) -> bool { return t.arch == "x86_64" }

fn triple_obj_format(t: Triple) -> string {
    if triple_is_darwin(t) { return "macho" }
    if triple_is_linux(t)  { return "elf" }
    return "unknown"
}

fn triple_exe_suffix(t: Triple) -> string { return "" }

fn _env_or(name, dflt) -> string {
    let v = env(name)
    if type_of(v) != "string" { return dflt }
    if len(v) == 0 { return dflt }
    return v
}

fn sysroot_env_name(t: Triple) -> string {
    if triple_is_linux(t)  { return "HEXA_SYSROOT_LINUX" }
    if triple_is_darwin(t) { return "HEXA_SYSROOT_DARWIN" }
    return "HEXA_SYSROOT"
}

fn default_sysroot(t: Triple) -> string {
    if triple_is_darwin(t) { return "" }
    let home = _env_or("HOME", "/tmp")
    return home + "/.hexa/sysroots/" + triple_to_string(t)
}

fn resolve_sysroot(t: Triple) -> string {
    let name = sysroot_env_name(t)
    return _env_or(name, default_sysroot(t))
}

struct CrossPlan {
    host: Triple,
    target: Triple,
    linker: string,
    sysroot: string,
    argv: [string],
    ok: bool,
    reason: string
}

fn _cross_plan_fail(host, target, reason) -> CrossPlan {
    return CrossPlan{
        host: host,
        target: target,
        linker: "",
        sysroot: "",
        argv: [],
        ok: false,
        reason: reason
    }
}

fn linker_for(t: Triple) -> string {
    if triple_is_linux(t)  { return "ld.lld" }
    if triple_is_darwin(t) { return "ld64.lld" }
    return ""
}

fn build_link_argv(target: Triple, sysroot, input_obj, output_exe) -> [string] {
    let mut argv = []
    argv.push(linker_for(target))
    if triple_is_linux(target) && triple_is_x86_64(target) {
        argv.push("-m")
        argv.push("elf_x86_64")
    }
    if triple_is_linux(target) && triple_is_arm64(target) {
        argv.push("-m")
        argv.push("aarch64linux")
    }
    if triple_is_darwin(target) {
        argv.push("-arch")
        if triple_is_arm64(target)  { argv.push("arm64")  }
        if triple_is_x86_64(target) { argv.push("x86_64") }
    }
    if len(sysroot) > 0 {
        argv.push("--sysroot=" + sysroot)
    }
    argv.push("-o")
    argv.push(output_exe + triple_exe_suffix(target))
    argv.push(input_obj)
    if triple_is_linux(target) {
        argv.push("-lc")
    }
    return argv
}

fn cross_plan(host: Triple, target: Triple, input_obj, output_exe) -> CrossPlan {
    if !triple_is_valid(host) {
        return _cross_plan_fail(host, target, "invalid host triple")
    }
    if !triple_is_valid(target) {
        return _cross_plan_fail(host, target, "invalid target triple")
    }
    let lk = linker_for(target)
    if len(lk) == 0 {
        return _cross_plan_fail(host, target, "no linker for target os=" + target.os)
    }
    let sr   = resolve_sysroot(target)
    let argv = build_link_argv(target, sr, input_obj, output_exe)
    return CrossPlan{
        host: host,
        target: target,
        linker: lk,
        sysroot: sr,
        argv: argv,
        ok: true,
        reason: ""
    }
}

fn plan_darwin_arm64_to_linux_x86_64(input_obj, output_exe) -> CrossPlan {
    return cross_plan(host_triple(), linux_x86_64_triple(), input_obj, output_exe)
}

fn cross_plan_describe(p: CrossPlan) -> string {
    if !p.ok {
        return "cross: FAIL (" + p.reason + ")"
    }
    return "cross: " + triple_to_string(p.host) + " -> " + triple_to_string(p.target)
        + " via " + p.linker
        + " argc=" + to_string(len(p.argv))
}

// ── tiny helper: does argv contain token? ──────────────────────────
fn _argv_has(argv, tok) -> bool {
    let mut i = 0
    while i < len(argv) {
        if argv[i] == tok { return true }
        i = i + 1
    }
    return false
}

// ── tiny helper: index of token in argv (-1 on miss) ───────────────
fn _argv_idx(argv, tok) -> int {
    let mut i = 0
    while i < len(argv) {
        if argv[i] == tok { return i }
        i = i + 1
    }
    return -1
}

// ── test harness ───────────────────────────────────────────────────

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

fn check_true(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

println("=====================================================")
println("  crosscompile.hexa  (ROI #179)  — darwin-arm64 -> linux-x86_64")
println("=====================================================")

// ── 1. triple_make round-trip ──────────────────────────────────────
println("")
println("--- 1. triple_make round-trip ---")
let t1 = triple_make("arm64", "apple", "darwin", "")
check("no abi stringify", triple_to_string(t1), "arm64-apple-darwin")
let t1b = triple_make("x86_64", "unknown", "linux", "gnu")
check("with abi stringify", triple_to_string(t1b), "x86_64-unknown-linux-gnu")

// ── 2. parse_triple happy paths + arch normalization ──────────────
println("")
println("--- 2. parse_triple ---")
let p1 = parse_triple("arm64-apple-darwin")
check("parse arch",   p1.arch,   "arm64")
check("parse vendor", p1.vendor, "apple")
check("parse os",     p1.os,     "darwin")
check("parse abi empty", p1.abi, "")

let p2 = parse_triple("aarch64-apple-darwin")
check("aarch64 → arm64", p2.arch, "arm64")

let p3 = parse_triple("amd64-unknown-linux-gnu")
check("amd64 → x86_64", p3.arch, "x86_64")
check("tail abi",       p3.abi,  "gnu")

let p4 = parse_triple("x86_64-unknown-linux-musl")
check("abi musl", p4.abi, "musl")

let p5 = parse_triple("aarch64-linux-android-androideabi-v7a")
check("multi-segment abi", p5.abi, "androideabi-v7a")

// ── 3. parse_triple malformed ─────────────────────────────────────
println("")
println("--- 3. parse_triple malformed ---")
let p_empty = parse_triple("")
check_true("empty invalid", !triple_is_valid(p_empty))
let p_short = parse_triple("arm64-apple")
check_true("too-short invalid", !triple_is_valid(p_short))
let p_nonstr = parse_triple(42)
check_true("non-string invalid", !triple_is_valid(p_nonstr))

// ── 4. host / target constants ────────────────────────────────────
println("")
println("--- 4. host/target constants ---")
check("host triple", triple_to_string(host_triple()), "arm64-apple-darwin")
check("linux x86_64 triple", triple_to_string(linux_x86_64_triple()),
      "x86_64-unknown-linux-gnu")

// ── 5. OS / arch branch helpers ───────────────────────────────────
println("")
println("--- 5. branch helpers ---")
let h = host_triple()
let tgt = linux_x86_64_triple()
check_true("host is darwin",     triple_is_darwin(h))
check_true("host is arm64",      triple_is_arm64(h))
check_true("target is linux",    triple_is_linux(tgt))
check_true("target is x86_64",   triple_is_x86_64(tgt))
check_true("host is not linux",  !triple_is_linux(h))
check_true("target is not arm64", !triple_is_arm64(tgt))

// ── 6. obj_format mapping ─────────────────────────────────────────
println("")
println("--- 6. obj_format ---")
check("darwin -> macho", triple_obj_format(h),   "macho")
check("linux  -> elf",   triple_obj_format(tgt), "elf")
let weird = triple_make("arm64", "apple", "windows", "")
check("unknown -> unknown", triple_obj_format(weird), "unknown")

// ── 7. sysroot resolution ─────────────────────────────────────────
println("")
println("--- 7. sysroot ---")
check("env name linux",  sysroot_env_name(tgt), "HEXA_SYSROOT_LINUX")
check("env name darwin", sysroot_env_name(h),   "HEXA_SYSROOT_DARWIN")
// darwin host → "" (use system)
check("darwin default sysroot", default_sysroot(h), "")
// linux default → <HOME>/.hexa/sysroots/<triple>
let linux_sr_default = default_sysroot(tgt)
check_true("linux default non-empty", len(linux_sr_default) > 0)
check_true("linux default ends with triple",
    linux_sr_default.substring(
        len(linux_sr_default) - len("x86_64-unknown-linux-gnu"),
        len(linux_sr_default)
    ) == "x86_64-unknown-linux-gnu")

// resolve_sysroot for linux returns the env override if set, else default.
let resolved_linux_sr = resolve_sysroot(tgt)
check_true("resolve linux sysroot non-empty", len(resolved_linux_sr) > 0)

// ── 8. linker_for ─────────────────────────────────────────────────
println("")
println("--- 8. linker_for ---")
check("linker linux",  linker_for(tgt), "ld.lld")
check("linker darwin", linker_for(h),   "ld64.lld")
check("linker unknown", linker_for(weird), "")

// ── 9. build_link_argv for linux-x86_64 ───────────────────────────
println("")
println("--- 9. build_link_argv linux-x86_64 ---")
let argv_lx = build_link_argv(tgt, "/opt/sysroot", "hello.o", "hello")
check_true("argv[0]=ld.lld", argv_lx[0] == "ld.lld")
check_true("has -m elf_x86_64",
    _argv_has(argv_lx, "-m") && _argv_has(argv_lx, "elf_x86_64"))
check_true("has --sysroot=/opt/sysroot",
    _argv_has(argv_lx, "--sysroot=/opt/sysroot"))
check_true("has -o hello",
    _argv_idx(argv_lx, "-o") >= 0
    && argv_lx[_argv_idx(argv_lx, "-o") + 1] == "hello")
check_true("has input hello.o", _argv_has(argv_lx, "hello.o"))
check_true("links libc (-lc)", _argv_has(argv_lx, "-lc"))
check_true("no -arch (that's darwin)", !_argv_has(argv_lx, "-arch"))

// ── 10. build_link_argv for darwin-arm64 ──────────────────────────
println("")
println("--- 10. build_link_argv darwin-arm64 ---")
let argv_d = build_link_argv(h, "", "a.o", "a.out")
check_true("argv[0]=ld64.lld", argv_d[0] == "ld64.lld")
check_true("has -arch arm64",
    _argv_idx(argv_d, "-arch") >= 0
    && argv_d[_argv_idx(argv_d, "-arch") + 1] == "arm64")
check_true("no sysroot when empty", !_argv_has(argv_d, "--sysroot="))
check_true("no -lc on darwin host", !_argv_has(argv_d, "-lc"))
check_true("has -o a.out",
    _argv_idx(argv_d, "-o") >= 0
    && argv_d[_argv_idx(argv_d, "-o") + 1] == "a.out")

// ── 11. cross_plan darwin-arm64 -> linux-x86_64 (happy) ───────────
println("")
println("--- 11. cross_plan happy ---")
let plan = plan_darwin_arm64_to_linux_x86_64("prog.o", "prog")
check_true("plan ok", plan.ok)
check("plan linker",  plan.linker, "ld.lld")
check("plan host",    triple_to_string(plan.host),   "arm64-apple-darwin")
check("plan target",  triple_to_string(plan.target), "x86_64-unknown-linux-gnu")
check_true("plan argv non-empty", len(plan.argv) > 0)
check_true("plan argv starts with linker", plan.argv[0] == "ld.lld")
check_true("plan emits -m elf_x86_64",
    _argv_has(plan.argv, "-m") && _argv_has(plan.argv, "elf_x86_64"))
check_true("plan emits -lc", _argv_has(plan.argv, "-lc"))
check_true("plan reason empty on ok", len(plan.reason) == 0)

// ── 12. cross_plan failure path ───────────────────────────────────
println("")
println("--- 12. cross_plan failure ---")
let bad_target = parse_triple("arm64-apple")   // malformed: missing os
let bad_plan = cross_plan(host_triple(), bad_target, "x.o", "x")
check_true("bad plan not ok", !bad_plan.ok)
check("bad plan reason", bad_plan.reason, "invalid target triple")

let no_linker_target = triple_make("arm64", "apple", "windows", "")
let nl_plan = cross_plan(host_triple(), no_linker_target, "x.o", "x")
check_true("no-linker plan not ok", !nl_plan.ok)
check_true("no-linker reason mentions os",
    nl_plan.reason.substring(0, len("no linker")) == "no linker")

// ── 13. cross_plan_describe formatting ────────────────────────────
println("")
println("--- 13. describe ---")
let desc_ok = cross_plan_describe(plan)
check_true("describe mentions host",
    _last_idx_of_str(desc_ok, "arm64-apple-darwin") >= 0)
check_true("describe mentions target",
    _last_idx_of_str(desc_ok, "x86_64-unknown-linux-gnu") >= 0)
check_true("describe mentions linker",
    _last_idx_of_str(desc_ok, "ld.lld") >= 0)

let desc_bad = cross_plan_describe(bad_plan)
check_true("describe FAIL path",
    desc_bad.substring(0, len("cross: FAIL")) == "cross: FAIL")

// substring-contains helper (tiny, only used above)
// Declared after use is fine — definitions hoist, but for safety we
// alias via an upfront fn; keep implementation here for clarity.
// (noop: _last_idx_of_str below)

fn _last_idx_of_str(s, target) -> int {
    let n = len(s)
    let m = len(target)
    if m == 0 { return n }
    let mut i = n - m
    while i >= 0 {
        if s.substring(i, i + m) == target { return i }
        i = i - 1
    }
    return -1
}

// ── Summary ───────────────────────────────────────────────────────
println("")
println("=====================================================")
println("  crosscompile (ROI #179): " + to_string(pass_count)
        + " passed, " + to_string(fail_count) + " failed")
println("=====================================================")
assert(fail_count == 0)
