// ═══════════════════════════════════════════════════════════════════
//  test_math_extended.hexa — extended math proofs (geometry, series)
//  Last verified: 2026-04-11
// ═══════════════════════════════════════════════════════════════════

fn sum_arr(arr) {
    let mut s = 0
    for v in arr { s = s + v }
    return s
}

fn sum_range(a, b) {
    let mut s = 0
    let mut i = a
    while i < b { s = s + i; i = i + 1 }
    return s
        i = i + 1
}

// ── Triangular numbers T_n = n(n+1)/2 ───────────────────────

proof m001_T_1 { assert 1 * 2 / 2 == 1 }
proof m002_T_2 { assert 2 * 3 / 2 == 3 }
proof m003_T_3 { assert 3 * 4 / 2 == 6 }
proof m004_T_4 { assert 4 * 5 / 2 == 10 }
proof m005_T_5 { assert 5 * 6 / 2 == 15 }
proof m006_T_6 { assert 6 * 7 / 2 == 21 }
proof m007_T_7 { assert 7 * 8 / 2 == 28 }
proof m008_T_8 { assert 8 * 9 / 2 == 36 }
proof m009_T_10 { assert 10 * 11 / 2 == 55 }
proof m010_T_100 { assert 100 * 101 / 2 == 5050 }

// ── Square numbers ──────────────────────────────────────────

proof m011_sq_1 { assert 1 * 1 == 1 }
proof m012_sq_2 { assert 2 * 2 == 4 }
proof m013_sq_3 { assert 3 * 3 == 9 }
proof m014_sq_4 { assert 4 * 4 == 16 }
proof m015_sq_5 { assert 5 * 5 == 25 }
proof m016_sq_6 { assert 6 * 6 == 36 }
proof m017_sq_10 { assert 10 * 10 == 100 }
proof m018_sq_12 { assert 12 * 12 == 144 }
proof m019_sq_15 { assert 15 * 15 == 225 }
proof m020_sq_20 { assert 20 * 20 == 400 }

// ── Sum of first n squares = n(n+1)(2n+1)/6 ─────────────────

proof m021_ss_1 { assert 1 * 2 * 3 / 6 == 1 }
proof m022_ss_2 { assert 2 * 3 * 5 / 6 == 5 }
proof m023_ss_3 { assert 3 * 4 * 7 / 6 == 14 }
proof m024_ss_4 { assert 4 * 5 * 9 / 6 == 30 }
proof m025_ss_5 { assert 5 * 6 * 11 / 6 == 55 }
proof m026_ss_6 { assert 6 * 7 * 13 / 6 == 91 }
proof m027_ss_10 { assert 10 * 11 * 21 / 6 == 385 }
proof m028_ss_6_arr { assert sum_arr([1, 4, 9, 16, 25, 36]) == 91 }
proof m029_ss_10_arr { assert sum_arr([1, 4, 9, 16, 25, 36, 49, 64, 81, 100]) == 385 }
proof m030_ss_4_arr { assert sum_arr([1, 4, 9, 16]) == 30 }

// ── Sum of first n cubes = T_n^2 ────────────────────────────

proof m031_cb_1 { assert 1 * 1 == 1 }
proof m032_cb_2 { assert 3 * 3 == 9 }         // (1+8) = T_2^2 = 9
proof m033_cb_3 { assert 6 * 6 == 36 }        // 1+8+27 = 36
proof m034_cb_4 { assert 10 * 10 == 100 }     // 1+8+27+64 = 100
proof m035_cb_5 { assert 15 * 15 == 225 }
proof m036_cb_6 { assert 21 * 21 == 441 }
proof m037_cb_6_arr { assert sum_arr([1, 8, 27, 64, 125, 216]) == 441 }
proof m038_cb_3_arr { assert sum_arr([1, 8, 27]) == 36 }
proof m039_cb_4_arr { assert sum_arr([1, 8, 27, 64]) == 100 }
proof m040_cb_1_arr { assert sum_arr([1]) == 1 }

// ── Powers of 2 ─────────────────────────────────────────────

proof m041_p2_0 { assert 1 == 1 }
proof m042_p2_1 { assert 2 == 2 }
proof m043_p2_2 { assert 2 * 2 == 4 }
proof m044_p2_3 { assert 2 * 2 * 2 == 8 }
proof m045_p2_4 { assert 2 * 2 * 2 * 2 == 16 }
proof m046_p2_5 { assert 2 * 2 * 2 * 2 * 2 == 32 }
proof m047_p2_6 { assert 2 * 2 * 2 * 2 * 2 * 2 == 64 }
proof m048_p2_8 { assert 256 == 2 * 2 * 2 * 2 * 2 * 2 * 2 * 2 }
proof m049_p2_10 { assert 1024 == 2 * 2 * 2 * 2 * 2 * 2 * 2 * 2 * 2 * 2 }
proof m050_p2_sum_7 { assert 1 + 2 + 4 + 8 + 16 + 32 + 64 == 127 }

// ── Powers of 3 ─────────────────────────────────────────────

proof m051_p3_0 { assert 1 == 1 }
proof m052_p3_1 { assert 3 == 3 }
proof m053_p3_2 { assert 3 * 3 == 9 }
proof m054_p3_3 { assert 3 * 3 * 3 == 27 }
proof m055_p3_4 { assert 3 * 3 * 3 * 3 == 81 }
proof m056_p3_5 { assert 3 * 3 * 3 * 3 * 3 == 243 }
proof m057_p3_6 { assert 3 * 3 * 3 * 3 * 3 * 3 == 729 }
proof m058_p3_sum { assert 1 + 3 + 9 + 27 == 40 }
proof m059_p3_7 { assert 729 * 3 == 2187 }
proof m060_p3_sum_5 { assert 1 + 3 + 9 + 27 + 81 == 121 }

// ── Geometric series sum ────────────────────────────────────

proof m061_gs_2_6 {
    // 1+2+4+8+16+32 = 2^6 - 1 = 63
    assert 1 + 2 + 4 + 8 + 16 + 32 == 63
}
proof m062_gs_3_5 {
    // 1+3+9+27+81 = (3^5-1)/2 = 121
    assert 1 + 3 + 9 + 27 + 81 == 121
}
proof m063_gs_2_10 {
    // 1+2+...+512 = 2^10-1 = 1023
    assert 1 + 2 + 4 + 8 + 16 + 32 + 64 + 128 + 256 + 512 == 1023
}
proof m064_gs_half {
    // 1 + 1/2 + 1/4 + 1/8 → 15/8 (partial)
    let s = 1.0 + 0.5 + 0.25 + 0.125
    assert s == 1.875
}
proof m065_gs_third {
    let s = 1.0 + (1.0/3.0) + (1.0/9.0)
    // = 13/9 ≈ 1.4444
    assert s > 1.44 && s < 1.45
}

// ── Modular arithmetic ──────────────────────────────────────

proof m066_mod_6_n { assert 12 % 6 == 0 }
proof m067_mod_6_7 { assert 7 % 6 == 1 }
proof m068_mod_6_8 { assert 8 % 6 == 2 }
proof m069_mod_6_9 { assert 9 % 6 == 3 }
proof m070_mod_6_10 { assert 10 % 6 == 4 }
proof m071_mod_6_11 { assert 11 % 6 == 5 }
proof m072_mod_7_10 { assert 10 % 7 == 3 }
proof m073_mod_24_5 { assert 24 % 5 == 4 }
proof m074_mod_36_7 { assert 36 % 7 == 1 }
proof m075_mod_self { assert 6 % 6 == 0 }

// ── Ranges and sums ─────────────────────────────────────────

proof m076_range_0_1 { assert sum_range(0, 1) == 0 }
proof m077_range_0_2 { assert sum_range(0, 2) == 1 }
proof m078_range_0_3 { assert sum_range(0, 3) == 3 }
proof m079_range_0_6 { assert sum_range(0, 6) == 15 }
proof m080_range_0_7 { assert sum_range(0, 7) == 21 }
proof m081_range_0_10 { assert sum_range(0, 10) == 45 }
proof m082_range_0_11 { assert sum_range(0, 11) == 55 }
proof m083_range_1_7 { assert sum_range(1, 7) == 21 }
proof m084_range_5_11 { assert sum_range(5, 11) == 45 }
proof m085_range_offset { assert sum_range(100, 106) == 615 }

// ── Boolean logic ───────────────────────────────────────────

proof m086_true { assert true }
proof m087_not_false { assert !false }
proof m088_and_tt { assert true && true }
proof m089_and_tf { assert !(true && false) }
proof m090_or_tf { assert true || false }
proof m091_or_ff { assert !(false || false) }
proof m092_xor_emulate { assert (true || false) && !(true && false) }
proof m093_de_morgan_1 { assert !(true && false) == (!true || !false) }
proof m094_de_morgan_2 { assert !(false || false) == (!false && !false) }
proof m095_double_neg { assert !!true == true }

// ── Conditional expressions ─────────────────────────────────

proof m096_if_true {
    let x = if true { 6 } else { 0 }
    assert x == 6
}
proof m097_if_false {
    let x = if false { 0 } else { 12 }
    assert x == 12
}
proof m098_if_chain {
    let n = 6
    let cls = if n < 5 { "small" } else { if n < 10 { "mid" } else { "big" } }
    assert cls == "mid"
}
proof m099_if_nested {
    let a = 6
    let b = 12
    let max = if a > b { a } else { b }
    assert max == 12
}
proof m100_if_n6 {
    let n = 6
    let is_perfect = if 1 + 2 + 3 == n { true } else { false }
    assert is_perfect
}

println("[test_math_extended] 100 proofs declared — run with --test")
