// ===================================================================
//  test_data_dedup.hexa — Data Deduplication (MinHash/LSH) 검증
//
//  검증:
//    1. k_shingle 길이 정확
//    2. k_shingle 중복 제거
//    3. simple_hash 결정론적
//    4. minhash_signature 길이 = n_hashes
//    5. 동일 문서 minhash_jaccard = 1.0
//    6. 유사 문서 jaccard > 다른 문서 jaccard
//    7. lsh_buckets 길이 = bands
//    8. lsh_candidates: 동일 쌍 후보로 선출
//    9. cluster_near_duplicates: 중복 같은 클러스터
//   10. dedup_filter: 중복 제거 후 개수 감소
//   11. jaccard_similarity: 자기자신 = 1.0
//   12. count_clusters 정확
//
//  실행: ./hexa self/test_data_dedup.hexa
// ===================================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx(a, b, eps) { return fabs(a - b) < eps }

// ── Hash functions ──────────────────────────────────────────

fn simple_hash(s) {
    let n = len(s)
    let mut h = 5381
    let mut i = 0
    while i < n {
        let c = char_code(s, i)
        h = h * 33 + c
        if h > 1000000000 { h = h % 1000000007 }
        if h < -1000000000 { h = (0 - h) % 1000000007 }
        i = i + 1
    }
    if h < 0 { h = 0 - h }
    return h
}

fn hash_family(shingle_hash, seed) {
    let a = seed * 1103515245 + 12345
    let b = seed * 214013 + 2531011
    let p = 1000000007
    let mut h = a * shingle_hash + b
    if h < 0 { h = 0 - h }
    h = h % p
    return h
}

// ── K-shingling ─────────────────────────────────────────────

fn k_shingle(text, k) {
    let n = len(text)
    let mut shingles = []
    if n < k { return [text] }
    let mut i = 0
    while i < n - k + 1 {
        let mut s = ""
        let mut j = 0
        while j < k {
            let ch = text[i + j]
            s = s + ch
            j = j + 1
        }
        let mut found = false
        let mut si = 0
        while si < len(shingles) {
            if shingles[si] == s { found = true }
            si = si + 1
        }
        if !found { shingles = shingles + [s] }
        i = i + 1
    }
    return shingles
}

// ── MinHash ─────────────────────────────────────────────────

fn minhash_signature(shingles, n_hashes) {
    let n_sh = len(shingles)
    let mut sig = []
    let mut hi = 0
    while hi < n_hashes {
        let mut min_val = 2000000000
        let mut si = 0
        while si < n_sh {
            let sh = simple_hash(shingles[si])
            let hv = hash_family(sh, hi + 1)
            if hv < min_val { min_val = hv }
            si = si + 1
        }
        sig = sig + [min_val]
        hi = hi + 1
    }
    return sig
}

// ── Jaccard ─────────────────────────────────────────────────

fn jaccard_similarity(set_a, set_b) {
    let na = len(set_a)
    let nb = len(set_b)
    let mut inter = 0
    let mut i = 0
    while i < na {
        let mut j = 0
        while j < nb {
            if set_a[i] == set_b[j] { inter = inter + 1 }
            j = j + 1
        }
        i = i + 1
    }
    let union_count = na + nb - inter
    if union_count == 0 { return 1.0 }
    return to_float(inter) / to_float(union_count)
}

fn minhash_jaccard(sig_a, sig_b) {
    let n = len(sig_a)
    let mut agree = 0
    let mut i = 0
    while i < n { if sig_a[i] == sig_b[i] { agree = agree + 1 }; i = i + 1 }
    return to_float(agree) / to_float(n)
        i = i + 1
}

// ── LSH ─────────────────────────────────────────────────────

fn lsh_band_key(sig, band_idx, rows) {
    let start = band_idx * rows
    let mut h = 0
    let mut i = 0
    while i < rows {
        let idx = start + i
        if idx < len(sig) {
            h = h * 31 + sig[idx]
            if h > 1000000000 { h = h % 1000000007 }
            if h < -1000000000 { h = (0 - h) % 1000000007 }
        }
        i = i + 1
    }
    if h < 0 { h = 0 - h }
    return h
}

fn lsh_buckets(sig, bands, rows) {
    let mut keys = []
    let mut b = 0
    while b < bands { keys = keys + [lsh_band_key(sig, b, rows)]; b = b + 1 }
    return keys
        b = b + 1
}

fn lsh_candidates(sigs, bands, rows) {
    let n = len(sigs)
    let mut all_keys = []
    let mut i = 0
    while i < n { all_keys = all_keys + [lsh_buckets(sigs[i], bands, rows)]; i = i + 1 }
    let mut pairs = []
    i = 0
    while i < n {
        let mut j = i + 1
        while j < n {
            let mut match_found = false
            let mut b = 0
            while b < bands {
                if all_keys[i][b] == all_keys[j][b] { match_found = true }
                b = b + 1
            }
            if match_found { pairs = pairs + [[i, j]] }
            j = j + 1
        }
        i = i + 1
    }
    return pairs
}

// ── Union-Find ──────────────────────────────────────────────

fn uf_find(parent, x) {
    let mut cur = x
    while parent[cur] != cur { cur = parent[cur] }
    return cur
}

fn uf_union(parent, a, b) {
    let ra = uf_find(parent, a)
    let rb = uf_find(parent, b)
    if ra != rb {
        if ra < rb { parent[rb] = ra } else { parent[ra] = rb }
    }
    return parent
}

fn cluster_near_duplicates(texts, k, n_hashes, bands, rows, threshold) {
    let n = len(texts)
    let mut shingle_sets = []
    let mut i = 0
    while i < n { shingle_sets = shingle_sets + [k_shingle(texts[i], k)]; i = i + 1 }
    let mut sigs = []
    i = 0
    while i < n { sigs = sigs + [minhash_signature(shingle_sets[i], n_hashes)]; i = i + 1 }
    let candidates = lsh_candidates(sigs, bands, rows)
    let mut parent = []
    i = 0
    while i < n { parent = parent + [i]; i = i + 1 }
    let n_cand = len(candidates)
    i = 0
    while i < n_cand {
        let a = candidates[i][0]
        let b = candidates[i][1]
        let sim = minhash_jaccard(sigs[a], sigs[b])
        if sim >= threshold { parent = uf_union(parent, a, b) }
        i = i + 1
    }
    let mut clusters = []
    i = 0
    while i < n { clusters = clusters + [uf_find(parent, i)]; i = i + 1 }
    return clusters
}

fn dedup_filter(texts, k, n_hashes, bands, rows, threshold) {
    let clusters = cluster_near_duplicates(texts, k, n_hashes, bands, rows, threshold)
    let n = len(texts)
    let mut seen = []
    let mut result = []
    let mut i = 0
    while i < n {
        let cid = clusters[i]
        let mut found = false
        let mut j = 0
        while j < len(seen) { if seen[j] == cid { found = true }; j = j + 1 }
        if !found { seen = seen + [cid]; result = result + [texts[i]] }
        i = i + 1
    }
    return result
}

fn count_clusters(clusters) {
    let n = len(clusters)
    let mut unique = []
    let mut i = 0
    while i < n {
        let mut found = false
        let mut j = 0
        while j < len(unique) { if unique[j] == clusters[i] { found = true }; j = j + 1 }
        if !found { unique = unique + [clusters[i]] }
        i = i + 1
    }
    return len(unique)
}

// ═══════════ TEST DATA ═══════════════════════════════════════

let t1 = "the quick brown fox jumps over the lazy dog"
let t2 = "the quick brown fox jumps over the lazy cat"
let t3 = "lorem ipsum dolor sit amet consectetur adipiscing"
let t4 = "the quick brown fox jumps over the lazy dog"

// ── T1: k_shingle length ────────────────────────────────────
let sh1 = k_shingle(t1, 3)
check("k_shingle non-empty", len(sh1) > 0)
check("k_shingle length <= n-k+1", len(sh1) <= len(t1) - 3 + 1)

// ── T2: k_shingle dedup ────────────────────────────────────
let sh_dup = k_shingle("aaaa", 2)
check("k_shingle deduped (aaaa,k=2)", len(sh_dup) == 1)

// ── T3: simple_hash deterministic ───────────────────────────
let h1 = simple_hash("hello")
let h2 = simple_hash("hello")
check("hash deterministic", h1 == h2)
let h3 = simple_hash("world")
check("different strings different hash", h1 != h3)

// ── T4: minhash_signature length ────────────────────────────
let sig1 = minhash_signature(sh1, 20)
check("minhash sig length = 20", len(sig1) == 20)

// ── T5: identical documents → minhash jaccard = 1.0 ─────────
let sh4 = k_shingle(t4, 3)
let sig4 = minhash_signature(sh4, 20)
let mj_same = minhash_jaccard(sig1, sig4)
check("identical docs minhash_jaccard = 1.0", approx(mj_same, 1.0, 1.0e-9))

// ── T6: similar > different in jaccard ──────────────────────
let sh2 = k_shingle(t2, 3)
let sh3 = k_shingle(t3, 3)
let j_sim = jaccard_similarity(sh1, sh2)
let j_diff = jaccard_similarity(sh1, sh3)
check("similar jaccard > different", j_sim > j_diff)

// ── T7: lsh_buckets length = bands ──────────────────────────
let bk = lsh_buckets(sig1, 5, 4)
check("lsh_buckets length = 5", len(bk) == 5)

// ── T8: lsh_candidates finds identical pair ─────────────────
let sigs = [sig1, minhash_signature(sh2, 20), minhash_signature(sh3, 20), sig4]
let cands = lsh_candidates(sigs, 5, 4)
// Pair (0, 3) should be a candidate (identical docs)
let mut found_03 = false
let nc = len(cands)
let mut ci = 0
while ci < nc {
    if cands[ci][0] == 0 {
        if cands[ci][1] == 3 { found_03 = true }
    }
    ci = ci + 1
}
check("lsh_candidates finds identical pair (0,3)", found_03)

// ── T9: cluster_near_duplicates ─────────────────────────────
let texts = [t1, t2, t3, t4]
let clusters = cluster_near_duplicates(texts, 3, 20, 5, 4, 0.5)
check("identical docs same cluster", clusters[0] == clusters[3])

// ── T10: dedup_filter reduces count ─────────────────────────
let deduped = dedup_filter(texts, 3, 20, 5, 4, 0.5)
check("dedup reduces count", len(deduped) < len(texts))

// ── T11: jaccard self-similarity = 1.0 ──────────────────────
let j_self = jaccard_similarity(sh1, sh1)
check("jaccard self = 1.0", approx(j_self, 1.0, 1.0e-9))

// ── T12: count_clusters ─────────────────────────────────────
let nc2 = count_clusters(clusters)
check("count_clusters <= n_texts", nc2 <= len(texts))
check("count_clusters >= 1", nc2 >= 1)

// ── 결과 ────────────────────────────────────────────────────
println("")
println("=== Data Deduplication test summary ===")
println("PASS: " + to_string(pass_count))
println("FAIL: " + to_string(fail_count))
if fail_count == 0 {
    println("ALL GREEN — Data Deduplication OK")
}
println(to_string(pass_count) + " passed")
