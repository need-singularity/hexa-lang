// self/test_crc32_pure.hexa -- Tests for self/runtime/crc32_pure.hexa
//
// Reference values from python3 -c "import binascii; binascii.crc32(b'...')"
// (standard CRC-32 / IEEE 802.3 / PKZIP / gzip / PNG).

// ── inlined from self/runtime/crc32_pure.hexa ─────────────────────

let CRC32_POLY     = 3988292384
let CRC32_INIT     = 4294967295
let CRC32_MOD      = 4294967296
let CRC32_XOR_OUT  = 4294967295

fn _crc32_update_byte(crc, byte) {
    let mut c = crc ^ byte
    let mut k = 0
    while k < 8 {
        let lsb = c & 1
        if lsb != 0 {
            c = (c / 2) ^ CRC32_POLY
        } else {
            c = c / 2
        }
        k = k + 1
    }
    c
}

fn crc32_pure(s, n) {
    if type_of(s) != "string" { return 0 }
    let mut crc = CRC32_INIT
    let mut i = 0
    let lim = if n < len(s) { n } else { len(s) }
    while i < lim {
        let b = ord(s.substring(i, i + 1))
        crc = _crc32_update_byte(crc, b)
        i = i + 1
    }
    (crc ^ CRC32_XOR_OUT) & (CRC32_MOD - 1)
}

fn crc32_str_pure(s) {
    crc32_pure(s, len(s))
}

fn crc32_combine_pure(prev_crc, next) {
    if type_of(next) != "string" { return prev_crc }
    let mut crc = (prev_crc ^ CRC32_XOR_OUT) & (CRC32_MOD - 1)
    let mut i = 0
    let n = len(next)
    while i < n {
        let b = ord(next.substring(i, i + 1))
        crc = _crc32_update_byte(crc, b)
        i = i + 1
    }
    (crc ^ CRC32_XOR_OUT) & (CRC32_MOD - 1)
}

// ── end inlined ───────────────────────────────────────────────────

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  crc32_pure.hexa — test runner")
println("═══════════════════════════════════════════════════════")

// ── crc32_str_pure — known vectors ─────────────────────────────
println("")
println("--- crc32_str_pure (known vectors) ---")
check("empty string",    crc32_str_pure(""),            0)
check("single 'a'",      crc32_str_pure("a"),           3904355907)
check("'foo'",           crc32_str_pure("foo"),         2356372769)
check("'hello'",         crc32_str_pure("hello"),       907060870)
check("'hello world'",   crc32_str_pure("hello world"), 222957957)
check("'123456789'",     crc32_str_pure("123456789"),   3421780262)
check("'abc'",           crc32_str_pure("abc"),         891568578)
check("pangram",         crc32_str_pure("The quick brown fox jumps over the lazy dog"), 1095738169)

// ── crc32_pure — length-bounded ─────────────────────────────────
println("")
println("--- crc32_pure (length-bounded) ---")
check("hash 0 bytes",             crc32_pure("anything", 0), 0)
check("hash full (lim clip)",     crc32_pure("abc", 999), crc32_str_pure("abc"))
check("hash prefix 3",            crc32_pure("abcdef", 3), crc32_str_pure("abc"))
check("hash prefix 0 == empty",   crc32_pure("abcdef", 0), crc32_str_pure(""))
check("non-string returns 0",     crc32_pure(42, 5), 0)
check("nil arg returns 0",        crc32_pure(nil, 3), 0)

// ── determinism ──────────────────────────────────────────────────
println("")
println("--- determinism ---")
check("same input same hash", crc32_str_pure("abc") == crc32_str_pure("abc"), true)
check("different inputs differ", crc32_str_pure("a") != crc32_str_pure("b"), true)
check("case sensitive", crc32_str_pure("ABC") != crc32_str_pure("abc"), true)
check("ordering matters", crc32_str_pure("ab") != crc32_str_pure("ba"), true)

// ── crc32_combine_pure — streaming ─────────────────────────────
println("")
println("--- crc32_combine_pure (chunked == whole) ---")
check("combine ''+'abc'",        crc32_combine_pure(crc32_str_pure(""),  "abc"),        crc32_str_pure("abc"))
check("combine 'abc'+''",        crc32_combine_pure(crc32_str_pure("abc"), ""),          crc32_str_pure("abc"))
check("combine 'a'+'b'+'c'",     crc32_combine_pure(crc32_combine_pure(crc32_str_pure("a"), "b"), "c"), crc32_str_pure("abc"))
check("combine 'hello'+' '+'world'", crc32_combine_pure(crc32_combine_pure(crc32_str_pure("hello"), " "), "world"), crc32_str_pure("hello world"))
check("combine non-string noop", crc32_combine_pure(42, nil), 42)
check("combine 3 chunks pangram",
    crc32_combine_pure(crc32_combine_pure(crc32_str_pure("The quick "), "brown fox "), "jumps over the lazy dog"),
    crc32_str_pure("The quick brown fox jumps over the lazy dog"))

// ── range / type sanity ─────────────────────────────────────────
println("")
println("--- range / type sanity ---")
check("result non-negative 1",   crc32_str_pure("x") >= 0, true)
check("result non-negative 2",   crc32_str_pure("") >= 0, true)
check("result fits 32-bit 1",    crc32_str_pure("hello world") < CRC32_MOD, true)
check("result fits 32-bit 2",    crc32_str_pure("123456789") < CRC32_MOD, true)
check("result fits 32-bit 3",    crc32_str_pure("The quick brown fox jumps over the lazy dog") < CRC32_MOD, true)

// ── distinctness across similar inputs ──────────────────────────
println("")
println("--- distinctness of similar inputs ---")
check("'abc' vs 'abd'",  crc32_str_pure("abc") != crc32_str_pure("abd"), true)
check("'foo' vs 'Foo'",  crc32_str_pure("foo") != crc32_str_pure("Foo"), true)
check("'a'   vs 'aa'",   crc32_str_pure("a")   != crc32_str_pure("aa"),  true)

// ── Summary ─────────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    println("FAIL")
    exit(1)
}
println("ALL PASS")
