// =====================================================================
//  test_nonnull.hexa -- ROI #45 @nonnull null check elimination tests
//
//  Verifies that @nonnull attribute correctly eliminates redundant
//  null/nil checks on paths where values are proven non-null.
//
//  Tests (>=12):
//    1. @nonnull fn returns correct value
//    2. @nonnull with arithmetic
//    3. @nonnull string operations
//    4. @nonnull array operations
//    5. @nonnull with conditional logic
//    6. @nonnull loop pattern
//    7. @nonnull multi-parameter
//    8. @nonnull nested calls
//    9. @nonnull accumulator
//   10. @nonnull with map operations
//   11. @nonnull factorial
//   12. @nonnull fibonacci
//
//  Run: ./hexa test self/test_nonnull.hexa
// =====================================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn check_eq(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " -- expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("=====================================================")
println("  @nonnull Null Check Elimination (ROI #45) Tests")
println("=====================================================")
println("")

// -- 1. Basic @nonnull fn --
println("--- basic nonnull ---")
@nonnull fn nn_identity(x) {
    return x
}
check_eq("nn identity(42)", nn_identity(42), 42)
check_eq("nn identity(hello)", nn_identity("hello"), "hello")

// -- 2. Arithmetic --
println("")
println("--- arithmetic ---")
@nonnull fn nn_add(a, b) {
    return a + b
}
check_eq("nn add(3,4)", nn_add(3, 4), 7)
check_eq("nn add(100,200)", nn_add(100, 200), 300)

// -- 3. String operations --
println("")
println("--- string ops ---")
@nonnull fn nn_concat(a, b, sep) {
    return a + sep + b
}
check_eq("nn concat", nn_concat("hello", "world", " "), "hello world")

// -- 4. Array operations --
println("")
println("--- array ops ---")
@nonnull fn nn_array_sum(arr) {
    let mut sum = 0
    let mut i = 0
    while i < len(arr) {
        sum = sum + arr[i]
        i = i + 1
    }
    return sum
}
check_eq("nn array_sum [1,2,3]", nn_array_sum([1, 2, 3]), 6)
check_eq("nn array_sum [10,20]", nn_array_sum([10, 20]), 30)

// -- 5. Conditional logic --
println("")
println("--- conditional ---")
@nonnull fn nn_clamp(val, lo, hi) {
    if val < lo { return lo }
    if val > hi { return hi }
    return val
}
check_eq("nn clamp(5,1,10)", nn_clamp(5, 1, 10), 5)
check_eq("nn clamp(-5,1,10)", nn_clamp(-5, 1, 10), 1)
check_eq("nn clamp(15,1,10)", nn_clamp(15, 1, 10), 10)

// -- 6. Loop pattern --
println("")
println("--- loop pattern ---")
@nonnull fn nn_count_positive(arr) {
    let mut count = 0
    let mut i = 0
    while i < len(arr) {
        if arr[i] > 0 { count = count + 1 }
        i = i + 1
    }
    return count
}
check_eq("nn count_pos [1,-2,3,-4,5]", nn_count_positive([1, -2, 3, -4, 5]), 3)

// -- 7. Multi-parameter --
println("")
println("--- multi param ---")
@nonnull fn nn_weighted_sum(vals, weights) {
    let mut sum = 0
    let mut i = 0
    let n = len(vals)
    while i < n {
        sum = sum + vals[i] * weights[i]
        i = i + 1
    }
    return sum
}
check_eq("nn weighted_sum", nn_weighted_sum([1, 2, 3], [10, 20, 30]), 140)

// -- 8. Nested calls --
println("")
println("--- nested calls ---")
@nonnull fn nn_double(x) { return x * 2 }
@nonnull fn nn_triple(x) { return x * 3 }
@nonnull fn nn_compose(x) { return nn_double(nn_triple(x)) }
check_eq("nn compose(5)", nn_compose(5), 30)
check_eq("nn compose(10)", nn_compose(10), 60)

// -- 9. Accumulator --
println("")
println("--- accumulator ---")
@nonnull fn nn_product(arr) {
    let mut prod = 1
    let mut i = 0
    while i < len(arr) {
        prod = prod * arr[i]
        i = i + 1
    }
    return prod
}
check_eq("nn product [2,3,4]", nn_product([2, 3, 4]), 24)
check_eq("nn product [1,1,1]", nn_product([1, 1, 1]), 1)

// -- 10. Map-like operations --
println("")
println("--- map ops ---")
@nonnull fn nn_scale(arr, factor) {
    let mut out = []
    let mut i = 0
    while i < len(arr) {
        out.push(arr[i] * factor)
        i = i + 1
    }
    return out
}
let scaled = nn_scale([1, 2, 3], 10)
check_eq("nn scale len", len(scaled), 3)
check_eq("nn scale[0]", scaled[0], 10)
check_eq("nn scale[2]", scaled[2], 30)

// -- 11. Factorial --
println("")
println("--- factorial ---")
@nonnull fn nn_fact(n) {
    let mut result = 1
    let mut i = 2
    while i <= n {
        result = result * i
        i = i + 1
    }
    return result
}
check_eq("nn fact(5)", nn_fact(5), 120)
check_eq("nn fact(10)", nn_fact(10), 3628800)

// -- 12. Fibonacci --
println("")
println("--- fibonacci ---")
@nonnull fn nn_fib(n) {
    if n <= 1 { return n }
    let mut a = 0
    let mut b = 1
    let mut i = 2
    while i <= n {
        let t = a + b
        a = b
        b = t
        i = i + 1
    }
    return b
}
check_eq("nn fib(10)", nn_fib(10), 55)
check_eq("nn fib(20)", nn_fib(20), 6765)

// -- Summary --
println("")
println("=====================================================")
println("  @nonnull: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("=====================================================")
assert(fail_count == 0)
