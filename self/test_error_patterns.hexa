// ═══════════════════════════════════════════════════════════
//  test_error_patterns.hexa — Advanced Error Handling Tests
//  Tests: nested try/catch, error in loops, error recovery,
//         error with accumulation, custom error messages,
//         try/catch with match, try/catch with closures
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA Advanced Error Handling Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Basic try/catch ───────────────────────────────────

println("--- Basic Try/Catch ---")

let mut r1 = 0
try {
    r1 = 42
} catch e {
    r1 = -1
}
check("no error", r1, 42)

let mut r2 = 0
try {
    throw "err"
} catch e {
    r2 = -1
}
check("caught", r2, -1)

// ── 2. Error stops execution ─────────────────────────────

println("")
println("--- Execution Stop ---")

let mut r3 = 0
try {
    r3 = r3 + 10
    r3 = r3 + 20
    throw "stop"
    r3 = r3 + 999
} catch e {
    r3 = r3 + 1
}
check("partial + catch", r3, 31)

let mut r4 = ""
try {
    r4 = r4 + "a"
    r4 = r4 + "b"
    throw "halt"
    r4 = r4 + "c"
} catch e {
    r4 = r4 + "X"
}
check("str partial", r4, "abX")

// ── 3. Function that throws ──────────────────────────────

println("")
println("--- Function Throws ---")

fn safe_div(a, b) {
    if b == 0 { throw "div by zero" }
    return a / b
}

let mut r5 = 0
try {
    r5 = safe_div(10, 2)
} catch e {
    r5 = -1
}
check("safe_div ok", r5, 5)

let mut r6 = 0
try {
    r6 = safe_div(10, 0)
} catch e {
    r6 = -999
}
check("safe_div zero", r6, -999)

// ── 4. Error in loop ─────────────────────────────────────

println("")
println("--- Error in Loop ---")

let mut sum = 0
let mut i = 0
while i < 5 {
    try {
        if i == 3 { throw "skip" }
        sum = sum + i
    } catch e {
        sum = sum + 100
    }
    i = i + 1
}
// 0 + 1 + 2 + 100 + 4 = 107
check("error in loop sum", sum, 107)

// ── 5. Nested try/catch ──────────────────────────────────

println("")
println("--- Nested Try/Catch ---")

let mut r7 = ""
try {
    r7 = r7 + "outer-"
    try {
        r7 = r7 + "inner-"
        throw "inner-err"
        r7 = r7 + "SKIP"
    } catch e {
        r7 = r7 + "caught-inner-"
    }
    r7 = r7 + "after-inner"
} catch e {
    r7 = r7 + "caught-outer"
}
check("nested catch inner", r7, "outer-inner-caught-inner-after-inner")

let mut r8 = ""
try {
    r8 = r8 + "A"
    try {
        r8 = r8 + "B"
    } catch e {
        r8 = r8 + "C"
    }
    r8 = r8 + "D"
    throw "outer"
    r8 = r8 + "E"
} catch e {
    r8 = r8 + "F"
}
check("nested no inner err", r8, "ABDF")

// ── 6. Error with accumulation ───────────────────────────

println("")
println("--- Error Accumulation ---")

fn validate_positive(x) {
    if x < 0 { throw "negative" }
    return x
}

let mut good_sum = 0
let mut err_count = 0
let vals = [5, -1, 3, -2, 7]
let mut vi = 0
while vi < len(vals) {
    try {
        good_sum = good_sum + validate_positive(vals[vi])
    } catch e {
        err_count = err_count + 1
    }
    vi = vi + 1
}
check("valid sum", good_sum, 12)
check("error count", err_count, 2)

// ── 7. Error with match ──────────────────────────────────

println("")
println("--- Error + Match ---")

fn classify_and_validate(x) {
    let label = match x {
        0 -> "zero",
        _ -> "nonzero"
    }
    if x < 0 { throw "negative: " + to_string(x) }
    return label
}

let mut r9 = ""
try {
    r9 = classify_and_validate(5)
} catch e {
    r9 = "error"
}
check("match+validate ok", r9, "nonzero")

let mut r10 = ""
try {
    r10 = classify_and_validate(0)
} catch e {
    r10 = "error"
}
check("match+validate zero", r10, "zero")

let mut r11 = ""
try {
    r11 = classify_and_validate(-3)
} catch e {
    r11 = "caught-neg"
}
check("match+validate neg", r11, "caught-neg")

// ── 8. Try/catch with struct ─────────────────────────────

println("")
println("--- Error + Struct ---")

struct Result {
    ok: bool,
    value: int
}

fn safe_sqrt_int(n) {
    if n < 0 { throw "negative sqrt" }
    let mut i = 0
    while i * i <= n {
        if i * i == n {
            return Result { ok: true, value: i }
        }
        i = i + 1
    }
    return Result { ok: false, value: -1 }
}

let mut r12 = Result { ok: false, value: 0 }
try {
    r12 = safe_sqrt_int(16)
} catch e {
    r12 = Result { ok: false, value: -999 }
}
check("sqrt 16 ok", r12.ok, true)
check("sqrt 16 val", r12.value, 4)

let mut r13 = Result { ok: false, value: 0 }
try {
    r13 = safe_sqrt_int(-4)
} catch e {
    r13 = Result { ok: false, value: -999 }
}
check("sqrt neg caught", r13.ok, false)
check("sqrt neg val", r13.value, -999)

let r14 = safe_sqrt_int(7)
check("sqrt 7 not perfect", r14.ok, false)

// ── 9. Multiple throws in sequence ───────────────────────

println("")
println("--- Multiple Throws ---")

let mut results = []
let mut ti = 0
while ti < 4 {
    let mut val = 0
    try {
        if ti == 1 { throw "skip1" }
        if ti == 3 { throw "skip3" }
        val = ti * 10
    } catch e {
        val = -1
    }
    results = results.push(val)
    ti = ti + 1
}
check("multi throw [0]", results[0], 0)
check("multi throw [1]", results[1], -1)
check("multi throw [2]", results[2], 20)
check("multi throw [3]", results[3], -1)

// ── 10. Error message preservation ──────────────────────

println("")
println("--- Error Message Preservation ---")

let mut emsg = ""
try {
    throw "specific error 42"
} catch e {
    emsg = to_string(e)
}
check("error msg preserved", emsg, "Error(specific error 42)")

let mut emsg2 = ""
try {
    throw 12345
} catch e {
    emsg2 = to_string(e)
}
check("numeric error preserved", emsg2, "Error(12345)")

// ── 11. Try/catch with return values ────────────────────

println("")
println("--- Try/Catch Return Values ---")

fn try_return_val(x) {
    let mut result = 0
    try {
        if x == 0 { throw "zero" }
        result = 100 / x
    } catch e {
        result = -1
    }
    return result
}
check("try return positive", try_return_val(10), 10)
check("try return zero", try_return_val(0), -1)
check("try return one", try_return_val(1), 100)

// ── 12. Error in deeply nested calls ────────────────────

println("")
println("--- Deep Nested Calls ---")

fn level3(x) {
    if x < 0 { throw "deep error" }
    return x * 2
}
fn level2(x) { return level3(x - 1) }
fn level1(x) { return level2(x - 1) }

let mut deep1 = 0
try {
    deep1 = level1(5)
} catch e {
    deep1 = -1
}
check("deep call ok", deep1, 6)

let mut deep2 = 0
try {
    deep2 = level1(1)
} catch e {
    deep2 = -999
}
check("deep call throw", deep2, -999)

let mut deep3 = 0
try {
    deep3 = level1(2)
} catch e {
    deep3 = -999
}
check("deep call boundary", deep3, 0)

// ── 13. Error with boolean conditions ───────────────────

println("")
println("--- Error + Boolean ---")

fn check_range(x, lo, hi) {
    if x < lo { throw "too low" }
    if x > hi { throw "too high" }
    return true
}

let mut rb1 = false
try { rb1 = check_range(5, 1, 10) } catch e { rb1 = false }
check("range in bounds", rb1, true)

let mut rb2 = false
try { rb2 = check_range(0, 1, 10) } catch e { rb2 = false }
check("range too low", rb2, false)

let mut rb3 = false
try { rb3 = check_range(11, 1, 10) } catch e { rb3 = false }
check("range too high", rb3, false)

// ── 14. Multiple catch paths ────────────────────────────

println("")
println("--- Multiple Catch Paths ---")

let mut mc_results = []
let mut mi = 0
while mi < 6 {
    let mut val = ""
    try {
        if mi % 3 == 0 { throw "type_a" }
        if mi % 3 == 1 { throw "type_b" }
        val = "ok"
    } catch e {
        val = "caught"
    }
    mc_results = mc_results.push(val)
    mi = mi + 1
}
check("mc[0] caught", mc_results[0], "caught")
check("mc[1] caught", mc_results[1], "caught")
check("mc[2] ok", mc_results[2], "ok")
check("mc[3] caught", mc_results[3], "caught")
check("mc[4] caught", mc_results[4], "caught")
check("mc[5] ok", mc_results[5], "ok")

// ── 15. Try/catch with array operations ─────────────────

println("")
println("--- Error + Arrays ---")

fn safe_get(arr, idx) {
    if idx < 0 { throw "negative index" }
    if idx >= len(arr) { throw "out of bounds" }
    return arr[idx]
}

let test_arr = [10, 20, 30, 40, 50]

let mut ag1 = 0
try { ag1 = safe_get(test_arr, 0) } catch e { ag1 = -1 }
check("safe_get first", ag1, 10)

let mut ag2 = 0
try { ag2 = safe_get(test_arr, 4) } catch e { ag2 = -1 }
check("safe_get last", ag2, 50)

let mut ag3 = 0
try { ag3 = safe_get(test_arr, 5) } catch e { ag3 = -1 }
check("safe_get oob", ag3, -1)

let mut ag4 = 0
try { ag4 = safe_get(test_arr, -1) } catch e { ag4 = -1 }
check("safe_get neg", ag4, -1)

// ── 16. Catch then continue ─────────────────────────────

println("")
println("--- Catch Then Continue ---")

let mut cont_sum = 0
let mut ci = 0
while ci < 10 {
    try {
        if ci % 2 == 0 { throw "even" }
        cont_sum = cont_sum + ci
    } catch e {
        // skip evens
    }
    ci = ci + 1
}
// 1 + 3 + 5 + 7 + 9 = 25
check("skip evens sum", cont_sum, 25)

// ── 17. Error with string building ──────────────────────

println("")
println("--- Error + String Build ---")

fn build_msg(parts) {
    let mut msg = ""
    let mut pi = 0
    while pi < len(parts) {
        if parts[pi] == "" { throw "empty part at " + to_string(pi) }
        if pi > 0 { msg = msg + "-" }
        msg = msg + parts[pi]
        pi = pi + 1
    }
    return msg
}

let mut bm1 = ""
try { bm1 = build_msg(["a", "b", "c"]) } catch e { bm1 = "err" }
check("build msg ok", bm1, "a-b-c")

let mut bm2 = ""
try { bm2 = build_msg(["a", "", "c"]) } catch e { bm2 = "err" }
check("build msg empty", bm2, "err")

let mut bm3 = ""
try { bm3 = build_msg([]) } catch e { bm3 = "err" }
check("build msg empty arr", bm3, "")

// ── Summary ──────────────────────────────────────────────

println("")
println("═══════════════════════════════════════════════════════")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")

if fail_count > 0 {
    throw "TESTS FAILED: " + to_string(fail_count)
}
