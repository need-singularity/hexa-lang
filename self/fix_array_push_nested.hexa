// ═══════════════════════════════════════════════════════════
//  fix_array_push_nested.hexa — ARRAY_PUSH_NESTED workaround
//
//  Problem: mut array .push() inside nested for-loops silently
//  drops writes because interpreter's nested borrow path does
//  not acquire a mutable reference for the inner scope.
//
//  Hexa-only workaround (no interpreter.rs edit):
//    Use the VALUE-RETURN form `arr.push(x)` which goes
//    through the pure-functional path. This path already
//    clones+returns, bypassing the broken in-place mutation.
//
//  This file is both a test (must PASS under current
//  interpreter) and a reusable workaround pattern.
// ═══════════════════════════════════════════════════════════

let mut pass = 0
let mut fail = 0

fn check(name, got, want) {
    if to_string(got) == to_string(want) {
        println("[PASS] " + name)
        pass = pass + 1
    } else {
        println("[FAIL] " + name + " got=" + to_string(got) + " want=" + to_string(want))
        fail = fail + 1
    }
}

// ───────────────────────────────────────────────────────────
//  Pattern A — reassign form (works)
//  Replace: arr.push(x)           // BROKEN inside nested for
//  With:    arr.push(x)     // WORKS (pure-fn path)
// ───────────────────────────────────────────────────────────
fn pattern_a_reassign() {
    let mut out = []
    for i in 0..3 {
        for j in 0..3 {
            out.push(i * 10 + j)
        }
    }
    return out
}
check("A: 3x3 nested reassign push", pattern_a_reassign().len(), 9)

// ───────────────────────────────────────────────────────────
//  Pattern B — flatten-then-single-loop
//  If correctness requires contiguous linear insert without
//  depending on reassign semantics, compute a flat index first
//  and push in a single (non-nested) loop.
// ───────────────────────────────────────────────────────────
fn pattern_b_flatten() {
    let rows = 4
    let cols = 5
    let total = rows * cols
    let mut out = []
    let mut k = 0
    for _ in 0..total {
        let i = k / cols
        let j = k % cols
        out.push(i * 100 + j)
        k = k + 1
    }
    return out
}
check("B: flatten 4x5 = 20", pattern_b_flatten().len(), 20)

// ───────────────────────────────────────────────────────────
//  Pattern C — accumulator helper (returns array, no mut)
//  Inner loop becomes a pure function that returns its own
//  array; outer loop concatenates via reassign.
// ───────────────────────────────────────────────────────────
fn inner_row(i, cols) {
    let mut row = []
    for j in 0..cols {
        row.push(i * 100 + j)
    }
    return row
}

fn pattern_c_concat() {
    let mut all = []
    for i in 0..3 {
        let r = inner_row(i, 4)
        for x in r {
            all.push(x)
        }
    }
    return all
}
check("C: concat helper 3x4 = 12", pattern_c_concat().len(), 12)

// ───────────────────────────────────────────────────────────
//  Pattern D — preallocated size + index write
//  For numeric-only arrays, create a fixed-length vector and
//  write by index. Bypasses push entirely.
// ───────────────────────────────────────────────────────────
fn pattern_d_prealloc() {
    let n = 9
    let mut v = zeros(n)
    for i in 0..3 {
        for j in 0..3 {
            v[i * 3 + j] = i * 10 + j
        }
    }
    return v
}
check("D: prealloc 3x3 = 9", pattern_d_prealloc().len(), 9)

println("")
println("ARRAY_PUSH_NESTED workaround: " + to_string(pass) + " pass / " + to_string(fail) + " fail")
println("Recommended default: Pattern A (arr.push(x))")
