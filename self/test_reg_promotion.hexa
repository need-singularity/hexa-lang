// ═══════════════════════════════════════════════════════════
//  test_reg_promotion.hexa — Register Promotion Tests
//  M975: Detect loop-hot variables (>= 3 accesses in while loops)
//  and mark them for C `register` storage class in codegen.
//  Tests verify correctness of the underlying algorithms whose
//  loop variables would be register-promoted by the AI-native pass.
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA Register Promotion Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Simple loop counter — hot variable (acc, i accessed >= 3x) ──

println("--- Hot loop counter ---")

// M975 would promote `acc` and `i` — both accessed >= 3 times in loop
fn sum_to_n(n) {
    let mut acc = 0
    let mut i = 0
    while i < n {
        acc = acc + i
        i = i + 1
    }
    return acc
}

check("reg sum_to_n(0)", sum_to_n(0), 0)
check("reg sum_to_n(5)", sum_to_n(5), 10)
check("reg sum_to_n(10)", sum_to_n(10), 45)
check("reg sum_to_n(100)", sum_to_n(100), 4950)

// ── 2. Nested loop with hot inner variable ───────────────

println("")
println("--- Nested loop hot vars ---")

// M975 would promote total, i, j — all hot across nested loops
fn matrix_sum(n) {
    let mut total = 0
    let mut i = 0
    while i < n {
        let mut j = 0
        while j < n {
            total = total + i + j
            j = j + 1
        }
        i = i + 1
    }
    return total
}

check("reg matrix_sum(1)", matrix_sum(1), 0)
check("reg matrix_sum(3)", matrix_sum(3), 18)
check("reg matrix_sum(5)", matrix_sum(5), 100)

// ── 3. Multiple hot variables in single loop ─────────────

println("")
println("--- Multiple hot vars ---")

fn dot_product_sim(n) {
    let mut sum = 0
    let mut i = 0
    while i < n {
        let mut a = i * 2
        let mut b = i * 3
        sum = sum + a * b
        i = i + 1
    }
    return sum
}

check("reg dot_product(0)", dot_product_sim(0), 0)
check("reg dot_product(3)", dot_product_sim(3), 30)
check("reg dot_product(5)", dot_product_sim(5), 180)

// ── 4. Variable NOT hot (accessed only once in loop) ─────

println("")
println("--- Non-hot variable (no promote) ---")

fn single_access(n) {
    let mut result = 0
    let mut i = 0
    while i < n {
        result = result + 1
        i = i + 1
    }
    return result
}

check("reg single_access(10)", single_access(10), 10)

// ── 5. Hot accumulator pattern ───────────────────────────

println("")
println("--- Hot accumulator ---")

fn hot_accumulator(n) {
    let mut acc = 0
    let mut i = 0
    while i < n {
        acc = acc + i * i
        i = i + 1
    }
    return acc
}

check("hot acc(0)", hot_accumulator(0), 0)
check("hot acc(5)", hot_accumulator(5), 30)
check("hot acc(10)", hot_accumulator(10), 285)

// ── 6. Countdown loop ────────────────────────────────────

println("")
println("--- Countdown loop ---")

fn countdown_sum(n) {
    let mut acc = 0
    let mut i = n
    while i > 0 {
        acc = acc + i
        i = i - 1
    }
    return acc
}

check("reg countdown(5)", countdown_sum(5), 15)
check("reg countdown(10)", countdown_sum(10), 55)

// ── 7. Loop with array indexing ──────────────────────────

println("")
println("--- Loop with array indexing ---")

fn arr_sum(arr) {
    let mut sum = 0
    let mut i = 0
    while i < len(arr) {
        sum = sum + arr[i]
        i = i + 1
    }
    return sum
}

check("reg arr_sum empty", arr_sum([]), 0)
check("reg arr_sum [1,2,3]", arr_sum([1, 2, 3]), 6)
check("reg arr_sum [10,20,30]", arr_sum([10, 20, 30]), 60)

// ── 8. While loop with compound expression ───────────────

println("")
println("--- Compound expression in loop ---")

fn polynomial_eval(x, n) {
    let mut result = 0
    let mut power = 1
    let mut i = 0
    while i <= n {
        result = result + power
        power = power * x
        i = i + 1
    }
    return result
}

check("reg poly(2,0)", polynomial_eval(2, 0), 1)
check("reg poly(2,3)", polynomial_eval(2, 3), 15)
check("reg poly(3,2)", polynomial_eval(3, 2), 13)

// ── Summary ──────────────────────────────────────────────

println("")
println("═══════════════════════════════════════════════════════")
println("  Register Promotion Tests: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")
if fail_count > 0 {
    println("SOME TESTS FAILED")
}
