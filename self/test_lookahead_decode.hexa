// test_lookahead_decode.hexa — @lookahead_decode mock verification
import "ml/lookahead_decode.hexa"

let mut pass = 0
let mut fail = 0

fn check(name, cond) {
    if cond {
        pass = pass + 1
        println("PASS " + name)
    } else {
        fail = fail + 1
        println("FAIL " + name)
    }
}

// ── Test 1: lad_ctx_hash deterministic ─────────────────────────
let h1 = lad_ctx_hash([1, 2, 3, 4])
let h1b = lad_ctx_hash([1, 2, 3, 4])
check("ctx_hash deterministic", h1 == h1b)

// ── Test 2: lad_draft returns 0..15 ────────────────────────────
let d = lad_draft([7, 3, 1, 5])
check("draft in 0..15", d >= 0 && d < 16)

// ── Test 3: lad_target agrees with draft when (h%5)!=0 ─────────
let ctxA = [2, 2, 2, 2]
let dA = lad_draft(ctxA)
let tA = lad_target(ctxA)
let hA = lad_ctx_hash(ctxA)
let expect_match = (hA % 5) != 0
check("target agrees on non-mismatch hash",
      (expect_match && dA == tA) || (!expect_match && dA != tA))

// ── Test 4: jacobi_refine length = window ──────────────────────
let j1 = jacobi_refine([1, 2, 3, 4], 5, 3)
check("jacobi len=window=5", len(j1) == 5)

// ── Test 5: jacobi_refine fixpoint (idempotent after conv) ─────
let j2 = jacobi_refine([1, 2, 3, 4], 4, 4)
let j3 = jacobi_refine([1, 2, 3, 4], 4, 8)
let mut same = true
let mut i = 0
while i < 4 {
    if j2[i] != j3[i] {
        same = false
    }
    i = i + 1
}
check("jacobi fixpoint", same)

// ── Test 6: ngram_key deterministic ────────────────────────────
let seq = [5, 6, 7, 8, 9]
let k1 = ngram_key(seq, 0, 3)
let k2 = ngram_key(seq, 0, 3)
check("ngram_key deterministic", k1 == k2)

// ── Test 7: ngram_key differs on different windows ─────────────
let k3 = ngram_key(seq, 1, 3)
check("ngram_key differs", k1 != k3)

// ── Test 8: ngram store+lookup round-trip ──────────────────────
let mut cache = #{}
cache = ngram_store(cache, 42, 7)
check("ngram lookup hit", ngram_lookup(cache, 42) == 7)
check("ngram lookup miss", ngram_lookup(cache, 99) == -1)

// ── Test 9: ngram_record fills cache ───────────────────────────
let full = ngram_record(#{}, [1, 2, 3, 4, 5, 6], 2)
let kk = ngram_key([1, 2, 3, 4, 5, 6], 0, 2)
check("ngram_record stored first", ngram_lookup(full, kk) == 3)

// ── Test 10: lad_verify length matches proposal ────────────────
let prop = [3, 1, 4, 1]
let ver = lad_verify([7, 3, 1, 5], prop)
check("verify len matches proposal", len(ver) == len(prop))

// ── Test 11: lad_accept identical = full length ────────────────
check("accept identical = k", lad_accept(prop, prop) == 4)

// ── Test 12: lad_accept first mismatch ─────────────────────────
let a = [1, 2, 3, 4]
let b = [1, 2, 9, 4]
check("accept first mismatch at 2", lad_accept(a, b) == 2)

// ── Test 13: full lookahead_step — window=4, ngram=2, max=16 ──
let ctx = [7, 3, 1, 5]
let result = lookahead_step(ctx, 4, 2, 16)
let out = result[0]
let tp = result[1][0]
let ta = result[2][0]
let st = result[3][0]
let nh = result[4][0]

println("out_len=" + to_string(len(out)))
println("total_proposed=" + to_string(tp))
println("total_accepted=" + to_string(ta))
println("steps=" + to_string(st))
println("ngram_hits=" + to_string(nh))

let mut ratio_x100 = 0
if tp > 0 {
    ratio_x100 = (ta * 100) / tp
}
println("accept_ratio_pct=" + to_string(ratio_x100))

check("produced >= 16 tokens", len(out) >= 16)
check("proposed > 0", tp > 0)
check("accepted <= proposed", ta <= tp)
check("steps > 0", st > 0)

// ── Test 17: multi-token advance (avg per step > 1 when any
//           accepted tokens exist) ──────────────────────────────
let mut avg_ok = true
if ta > 0 {
    // steps * 1 ≤ produced ≤ steps * window
    if len(out) < st {
        avg_ok = false
    }
}
check("multi-token advance consistent", avg_ok)

// ── Test 18: window=1 degenerates to 1-token-per-step max ──────
let r2 = lookahead_step([1, 1, 1, 1], 1, 2, 4)
let out2 = r2[0]
check("window=1 produces max_tokens", len(out2) == 4)

println("")
println("pass=" + to_string(pass) + " fail=" + to_string(fail))
if fail == 0 {
    println("ALL PASS")
} else {
    println("FAILED")
}
println(to_string(pass) + " passed")
