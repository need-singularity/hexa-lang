println("")
println("=== Linear Attention test summary ===")
println("PASS: " + to_string(pass_count))
println("FAIL: " + to_string(fail_count))
println("TOTAL: " + to_string(pass_count + fail_count))
if fail_count == 0 {
    println("ALL PASS")
} else {
    println("FAILED")
}
