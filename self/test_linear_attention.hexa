// ===================================================================
let mut causal_diff = 0.0
let mut i = 0

while i < S {
    let mut j = 0

    while j < dv {
        let dd = tfabs(c_out[i][j] - nc_out[i][j])
        if dd > causal_diff { causal_diff = dd }
    }
}
check("T16 causal != noncausal (S>1)", causal_diff > 1.0e-6)

// ===================================================================
