check("T2 phi_elu_plus1(0) = 1.0", approx(phi_z[0], 1.0, 1.0e-6) && approx(phi_z[1], 1.0, 1.0e-6))

// ===================================================================
//  T3: phi_relu non-negative
// ===================================================================
