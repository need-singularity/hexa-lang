let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn tfabs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn approx(a, b, eps) {
    return tfabs(a - b) < eps
}

fn mat_frob(A) {
    let rows = len(A)
    let mut acc = 0.0
    let mut i = 0

    while i < rows {
        let cols = len(A[i])
        let mut j = 0

        while j < cols { acc = acc + A[i][j] * A[i][j] }
    }
    return sqrt(acc)
}

fn mat_rel_diff(A, B) {
    let denom = mat_frob(A)
    let num = la_frob_diff(A, B)
    if denom < 1.0e-12 { return num }
    return num / denom
}

fn vec_max_diff(a, b) {
    let n = len(a)
    let mut mx = 0.0
    let mut i = 0

    while i < n {
        let d = tfabs(a[i] - b[i])
        if d > mx { mx = d }
    }
    return mx
}

