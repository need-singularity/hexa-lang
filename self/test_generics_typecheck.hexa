check("T12 — Box<T> and Pair<K,V> coexist", e12_box == 1 && e12_pair == 2)

// ── T13: Generic fn return type uses type param ──────────────

let ftp13 = [type_param_node("T", "")]
let fp13 = [param_node("x", "T")]
