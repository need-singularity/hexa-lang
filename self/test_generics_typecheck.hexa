check("T10 — NumBox<T: Num> accepted", len(e10) == 0)
let b10 = tc_get_generic_struct_bounds("NumBox")
check("T10 — bound is 'Num'", len(b10) > 0 && b10[0] == "Num")

// ── T11: Generic fn with bounded type param ──────────────────

let ftp11 = [type_param_node("T", "Ord")]
let fp11 = [param_node("a", "T"), param_node("b", "T")]
let fb11 = [ret_stmt(nd("Ident", "a"))]
