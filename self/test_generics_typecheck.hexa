// ── T31: Generic struct field type is typeparam in scope ─────

// When inside a generic fn that has T as a type param,
// and we access a struct field typed T, it should resolve
let ftp31 = [type_param_node("T", "")]
let fp31 = [param_node("b", "Box")]
// Access b.value — field type is "T", which should be in scope as typeparam
let fb31 = [
    let_stmt("v", field_node(nd("Ident", "b"), "value"))
]
let fd31 = fn_decl_generic("get_val", ftp31, fp31, fb31, "T")
let e31 = type_check([sd1, fd31])
check("T31 — accessing T-typed field in generic fn context accepted", len(e31) == 0)

// ── T32: Forward reference to generic struct ─────────────────

// Use Box before declaring it (first pass should register it)
let fi32 = [field_init_node("value", lit("IntLit", "99"))]
let si32 = struct_init_node("Box", fi32)
let e32 = type_check([let_stmt("b32", si32), sd1])
check("T32 — forward reference to generic struct Box works", !type_errors_has(e32, "Unknown struct"))

// ── T33: Deeply nested generics — generic struct with generic fn ─

let ftp33 = [type_param_node("T", "")]
let fp33 = [param_node("val", "T")]
let fb33 = [
    let_stmt("boxed", struct_init_node("Box", [field_init_node("value", nd("Ident", "val"))])),
    ret_stmt(nd("Ident", "boxed"))
]
let fd33 = fn_decl_generic("make_box", ftp33, fp33, fb33, "Box")
let e33 = type_check([sd1, fd33])
let e33_real = len(e33) - type_warnings_count(e33)
check("T33 — fn make_box<T>(val: T) -> Box accepted (no hard errors)", e33_real == 0)

// ── T34: Type param names are case-sensitive ─────────────────

let ftp34a = [type_param_node("T", "")]
let ftp34b = [type_param_node("t", "")]
let fd34a = fn_decl_generic("fa", ftp34a, [], [ret_stmt(lit("IntLit", "1"))], "int")
let fd34b = fn_decl_generic("fb", ftp34b, [], [ret_stmt(lit("IntLit", "1"))], "int")
type_check([fd34a, fd34b])
let gpa = tc_get_generic_fn_params("fa")
let gpb = tc_get_generic_fn_params("fb")
let t34_ok = len(gpa) == 1 && gpa[0] == "T" && len(gpb) == 1 && gpb[0] == "t"
check("T34 — T and t are different type params", t34_ok)

// ── Summary ──────────────────────────────────────────────────

println("")
println("=======================================================")
println("  Results: " + to_string(test_pass) + " passed, " + to_string(test_fail) + " failed")
println("  Total assertions: " + to_string(test_pass + test_fail))
println("=======================================================")

if test_fail > 0 {
    println("SOME TESTS FAILED!")
} else {
    println("ALL TESTS PASSED!")
}
