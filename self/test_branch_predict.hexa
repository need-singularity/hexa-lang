// ═══════════════════════════════════════════════════════════
//  test_branch_predict.hexa — @branch_predict attribute tests
//  ROI id=32, P3, effect 1.5x — likely/unlikely branch hints
//  Tests:
//    1. @branch_predict fn with if-branches → detected
//    2. @branch_predict fn without branches → violation
//    3. Nested branch detection
//    4. Branch in while loop
//    5. Multiple branches in single fn
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA @branch_predict Tests — Branch Hints (ROI #32)")
println("═══════════════════════════════════════════════════════")
println("")

// ── Test 1: @branch_predict with single if ───────────────

@branch_predict fn classify(x) {
    if x > 0 {
        return "positive"
    } else {
        return "non-positive"
    }
}

check("branch_predict positive", classify(5), "positive")
check("branch_predict zero", classify(0), "non-positive")
check("branch_predict negative", classify(-3), "non-positive")

// ── Test 2: @branch_predict with no branches (violation) ─

@branch_predict fn no_branch(x) {
    return x * 2
}

check("branch_predict no_branch", no_branch(7), 14)

// ── Test 3: @branch_predict with nested if ───────────────

@branch_predict fn nested_classify(x) {
    if x > 100 {
        return "large"
    } else {
        if x > 10 {
            return "medium"
        } else {
            return "small"
        }
    }
}

check("branch_predict large", nested_classify(200), "large")
check("branch_predict medium", nested_classify(50), "medium")
check("branch_predict small", nested_classify(5), "small")

// ── Test 4: @branch_predict in while loop ────────────────

@branch_predict fn count_above(arr, threshold) {
    let mut count = 0
    let mut i = 0
    while i < len(arr) {
        if arr[i] > threshold {
            count = count + 1
        }
        i = i + 1
    }
    return count
}

check("branch_predict count_above", count_above([1, 5, 3, 8, 2, 7], 4), 3)
check("branch_predict count_above none", count_above([1, 2, 3], 10), 0)
check("branch_predict count_above all", count_above([5, 6, 7], 0), 3)

// ── Test 5: Multiple branches in one fn ──────────────────

@branch_predict fn multi_branch(a, b) {
    let mut result = 0
    if a > 0 {
        result = result + a
    }
    if b > 0 {
        result = result + b
    }
    if a > b {
        result = result * 2
    }
    return result
}

check("branch_predict multi 5,3", multi_branch(5, 3), 16)
check("branch_predict multi 0,0", multi_branch(0, 0), 0)
check("branch_predict multi 1,2", multi_branch(1, 2), 3)

// ── Test 6: @branch_predict with error-path pattern ──────
// Common pattern: check error first (unlikely), proceed normally

@branch_predict fn safe_divide(a, b) {
    if b == 0 {
        return -1
    }
    return a / b
}

check("branch_predict safe_divide 10/2", safe_divide(10, 2), 5)
check("branch_predict safe_divide 7/0", safe_divide(7, 0), -1)
check("branch_predict safe_divide 0/3", safe_divide(0, 3), 0)

// ── Test 7: @branch_predict with return-if pattern ───────

@branch_predict fn early_return(x) {
    if x < 0 { return 0 }
    return x * x
}

check("branch_predict early_return pos", early_return(4), 16)
check("branch_predict early_return neg", early_return(-1), 0)
check("branch_predict early_return zero", early_return(0), 0)

// ── Summary ──────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  @branch_predict: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")
