// ===============================================================
//  test_dce_extended.hexa -- Extended DCE (Dead Code Elimination)
//  M975: Unused let bindings + unused imports removal
//  ROI id=8, P3, effect 1.5x
// ===============================================================

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("===============================================================")
println("  HEXA DCE Extended Tests -- Unused Let/Import Elimination")
println("===============================================================")
println("")

// ================================================================
//  SECTION 1: Unused let bindings -- runtime correctness
//  Functions with unused variables should still produce correct results.
//  The AI-native pass drops dead lets but preserves semantics.
// ================================================================

println("--- Section 1: Unused let binding elimination ---")

// Function with an unused let binding
@pure fn compute_sum(n) {
    let unused_temp = 42
    let mut total = 0
    let mut i = 0
    while i < n {
        total = total + i
        i = i + 1
    }
    return total
}

check("compute_sum(5)", compute_sum(5), 10)
check("compute_sum(10)", compute_sum(10), 45)
check("compute_sum(0)", compute_sum(0), 0)
check("compute_sum(1)", compute_sum(1), 0)

// Function with multiple unused bindings
@pure fn only_result(a, b) {
    let x = a + 1
    let y = b + 2
    let z = a * b
    return a + b
}

check("only_result(3,4)", only_result(3, 4), 7)
check("only_result(0,0)", only_result(0, 0), 0)
check("only_result(10,20)", only_result(10, 20), 30)

// Function where all lets are used (nothing should be removed)
@pure fn all_used(a, b) {
    let sum = a + b
    let product = a * b
    return sum + product
}

check("all_used(2,3)", all_used(2, 3), 11)
check("all_used(1,1)", all_used(1, 1), 3)

println("")

// ================================================================
//  SECTION 2: Side-effecting initializers are preserved
// ================================================================

println("--- Section 2: Side-effect preservation ---")

// println inside a let init is a side effect -- should be kept
let mut side_effect_called = false

fn track_side_effect() {
    side_effect_called = true
    return 42
}

// The let is unused but its init has side effects
@pure fn has_side_effect(n) {
    let result = n * 2
    return result
}

check("has_side_effect(5)", has_side_effect(5), 10)

// Pure computation -- safe to remove
@pure fn pure_unused(n) {
    let temp = n * n + n + 1
    let also_unused = n - 1
    return n
}

check("pure_unused(7)", pure_unused(7), 7)
check("pure_unused(0)", pure_unused(0), 0)

println("")

// ================================================================
//  SECTION 3: Nested scopes -- while/if blocks
// ================================================================

println("--- Section 3: Nested scope DCE ---")

@pure fn nested_unused(n) {
    let mut result = 0
    let mut i = 0
    while i < n {
        let temp = i * i
        result = result + i
        i = i + 1
    }
    return result
}

check("nested_unused(4)", nested_unused(4), 6)
check("nested_unused(0)", nested_unused(0), 0)

// Unused in if branch
@pure fn if_unused(n) {
    if n > 0 {
        let positive_flag = true
        return n * 2
    } else {
        let negative_flag = false
        return 0
    }
}

check("if_unused(5)", if_unused(5), 10)
check("if_unused(-1)", if_unused(-1), 0)

println("")

// ================================================================
//  SECTION 4: Mixed used/unused bindings
// ================================================================

println("--- Section 4: Mixed used/unused ---")

@pure fn mixed_bindings(a, b, c) {
    let sum = a + b + c
    let unused1 = a * 100
    let diff = a - b
    let unused2 = b * 200
    return sum + diff
}

check("mixed_bindings(1,2,3)", mixed_bindings(1, 2, 3), 5)
check("mixed_bindings(10,5,3)", mixed_bindings(10, 5, 3), 23)

// Chain of lets where only last is used
@pure fn chain_lets(n) {
    let a = n + 1
    let b = a + 1
    let c = b + 1
    return c
}

check("chain_lets(0)", chain_lets(0), 3)
check("chain_lets(10)", chain_lets(10), 13)

println("")

// ================================================================
//  SECTION 5: DCE should NOT remove used mut bindings
// ================================================================

println("--- Section 5: Mut bindings that ARE used ---")

@pure fn accumulate(n) {
    let mut acc = 0
    let mut i = 1
    while i <= n {
        acc = acc + i
        i = i + 1
    }
    return acc
}

check("accumulate(5)", accumulate(5), 15)
check("accumulate(100)", accumulate(100), 5050)

// Fibonacci -- all bindings used
@pure fn fib_iter(n) {
    if n <= 1 { return n }
    let mut a = 0
    let mut b = 1
    let mut i = 2
    while i <= n {
        let next = a + b
        a = b
        b = next
        i = i + 1
    }
    return b
}

check("fib_iter(0)", fib_iter(0), 0)
check("fib_iter(1)", fib_iter(1), 1)
check("fib_iter(10)", fib_iter(10), 55)
check("fib_iter(20)", fib_iter(20), 6765)

println("")

// ================================================================
//  SECTION 6: Existing M24 DCE (post-return) still works
// ================================================================

println("--- Section 6: Existing DCE compatibility ---")

@pure fn dead_after_return(n) {
    return n * 2
    let dead = n * 3
    return dead
}

check("dead_after_return(5)", dead_after_return(5), 10)

println("")

// ================================================================
//  SUMMARY
// ================================================================

println("===============================================================")
println("  DCE extended total: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("===============================================================")

if fail_count > 0 {
    println("SOME TESTS FAILED")
}
