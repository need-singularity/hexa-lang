// ═══════════════════════════════════════════════════════════
//  test_const_fold_ext.hexa — M975/M976 constant folding extensions
//  ROI id=5, P2, effect 2x
//
//  Tests:
//   M975: string concat folding  "a" + "b" → "ab"
//   M976: len() folding           len("abc") → 3, len([1,2,3]) → 3
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA test_const_fold_ext — M975/M976 const folding")
println("═══════════════════════════════════════════════════════")
println("")

// ────────────────────────────────────────────────────────────
//  SECTION 1: M975 — String concat folding
//  "hello" + " " + "world" → "hello world" at compile time
// ────────────────────────────────────────────────────────────
println("--- M975: string concat folding ---")

@pure fn concat_two() {
    return "hello" + " world"
}

check("concat_two", concat_two(), "hello world")

@pure fn concat_three() {
    return "a" + "b" + "c"
}

check("concat_three", concat_three(), "abc")

@pure fn concat_empty() {
    return "" + "hello" + ""
}

check("concat_empty prefix/suffix", concat_empty(), "hello")

@pure fn concat_spaces() {
    return "hello" + " " + "world" + "!"
}

check("concat_spaces", concat_spaces(), "hello world!")

@pure fn concat_nested() {
    let x = "foo" + "bar"
    return x
}

check("concat_nested let", concat_nested(), "foobar")

// ────────────────────────────────────────────────────────────
//  SECTION 2: M976 — len() folding on string literals
//  len("abc") → 3 at compile time
// ────────────────────────────────────────────────────────────
println("")
println("--- M976: len() string literal folding ---")

@pure fn len_string_3() {
    return len("abc")
}

check("len_string_3", len_string_3(), 3)

@pure fn len_string_0() {
    return len("")
}

check("len_string_0", len_string_0(), 0)

@pure fn len_string_hello() {
    return len("hello")
}

check("len_string_hello", len_string_hello(), 5)

// ────────────────────────────────────────────────────────────
//  SECTION 3: M976 — len() folding on array literals
//  len([1,2,3]) → 3 at compile time
// ────────────────────────────────────────────────────────────
println("")
println("--- M976: len() array literal folding ---")

@pure fn len_array_3() {
    return len([1, 2, 3])
}

check("len_array_3", len_array_3(), 3)

@pure fn len_array_0() {
    return len([])
}

check("len_array_0", len_array_0(), 0)

@pure fn len_array_5() {
    return len([10, 20, 30, 40, 50])
}

check("len_array_5", len_array_5(), 5)

@pure fn len_array_1() {
    return len([42])
}

check("len_array_1", len_array_1(), 1)

// ────────────────────────────────────────────────────────────
//  SECTION 4: Combined — len + concat in expressions
// ────────────────────────────────────────────────────────────
println("")
println("--- Combined: len + string concat ---")

@pure fn len_plus_concat() {
    return len("ab") + len("cde")
}

check("len_plus_concat", len_plus_concat(), 5)

@pure fn len_of_array_elems() {
    return len([1, 2]) + len([3, 4, 5])
}

check("len_of_array_elems", len_of_array_elems(), 5)

// ────────────────────────────────────────────────────────────
//  Summary
// ────────────────────────────────────────────────────────────
println("")
println("═══════════════════════════════════════════════════════")
println("  RESULT: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("═══════════════════════════════════════════════════════")
