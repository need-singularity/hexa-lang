// ═══════════════════════════════════════════════════════════════════
//  test_n6_constants_deep.hexa — deep n=6 constant identity proofs
//  Every listed identity derives from sigma=12, phi=2, tau=4, sopfr=5, n=6
//  Last verified: 2026-04-11
// ═══════════════════════════════════════════════════════════════════

let n = 6
let sig = 12
let phi = 2
let tau = 4
let sop = 5
let mu = 1

// ── Linear combinations ─────────────────────────────────────

proof d001 { assert sig + phi == 14 }
proof d002 { assert sig + tau == 16 }
proof d003 { assert sig + sop == 17 }
proof d004 { assert sig + n == 18 }
proof d005 { assert sig + mu == 13 }
proof d006 { assert phi + tau == n }
proof d007 { assert phi + sop == 7 }
proof d008 { assert phi + n == 8 }
proof d009 { assert phi + mu == 3 }
proof d010 { assert tau + sop == 9 }
proof d011 { assert tau + n == 10 }
proof d012 { assert tau + mu == 5 }
proof d013 { assert sop + n == 11 }
proof d014 { assert sop + mu == n }
proof d015 { assert n + mu == 7 }

// ── Differences ─────────────────────────────────────────────

proof d016 { assert sig - phi == 10 }
proof d017 { assert sig - tau == 8 }
proof d018 { assert sig - sop == 7 }
proof d019 { assert sig - n == n }
proof d020 { assert sig - mu == 11 }
proof d021 { assert tau - phi == phi }
proof d022 { assert sop - tau == mu }
proof d023 { assert n - tau == phi }
proof d024 { assert n - phi == tau }
proof d025 { assert sop - phi == 3 }
proof d026 { assert sop - mu == tau }
proof d027 { assert n - mu == sop }
proof d028 { assert n - sop == mu }
proof d029 { assert sig - 2 * n == 0 }
proof d030 { assert sig - 2 * tau == tau }

// ── Products ────────────────────────────────────────────────

proof d031 { assert sig * phi == 24 }
proof d032 { assert sig * tau == 48 }
proof d033 { assert sig * sop == 60 }
proof d034 { assert sig * n == 72 }
proof d035 { assert sig * mu == sig }
proof d036 { assert phi * tau == 8 }
proof d037 { assert phi * sop == 10 }
proof d038 { assert phi * n == sig }
proof d039 { assert phi * mu == phi }
proof d040 { assert tau * sop == 20 }
proof d041 { assert tau * n == 24 }
proof d042 { assert tau * mu == tau }
proof d043 { assert sop * n == 30 }
proof d044 { assert sop * mu == sop }
proof d045 { assert n * mu == n }

// ── Grand identity variants ─────────────────────────────────

proof d046 { assert sig * phi == n * tau }       // = 24
proof d047 { assert sig * tau == 2 * n * tau }   // 48 = 48
proof d048 { assert sig * n == 2 * n * n }       // 72 = 72
proof d049 { assert n * tau == 4 * n }           // 24 = 24
proof d050 { assert (sig - tau) * n == 48 }      // 8*6 = 48

// ── Squares ─────────────────────────────────────────────────

proof d051 { assert n * n == 36 }
proof d052 { assert sig * sig == 144 }
proof d053 { assert phi * phi == tau }
proof d054 { assert tau * tau == 16 }
proof d055 { assert sop * sop == 25 }
proof d056 { assert (n - phi) * (n - phi) == 16 }    // 4^2
proof d057 { assert (sig - n) * (sig - n) == 36 }    // 6^2
proof d058 { assert (tau + phi) * (tau + phi) == 36 }
proof d059 { assert (sig + n) * (sig + n) == 324 }
proof d060 { assert (sop + mu) * (sop + mu) == 36 }

// ── Sums of squares ─────────────────────────────────────────

proof d061 { assert n * n + phi * phi == 40 }
proof d062 { assert n * n + sig * sig == 180 }
proof d063 { assert tau * tau + sop * sop == 41 }
proof d064 { assert phi * phi + tau * tau == 20 }
proof d065 { assert 1 + 4 + 9 + 16 + 25 + 36 == 91 }

// ── Cubes ───────────────────────────────────────────────────

proof d066 { assert n * n * n == 216 }
proof d067 { assert sig * sig * sig == 1728 }
proof d068 { assert phi * phi * phi == 8 }
proof d069 { assert tau * tau * tau == 64 }
proof d070 { assert sop * sop * sop == 125 }

// ── Known constants from M-theory / strings / Lie ──────────

proof d071_bosonic_26 { assert 26 == 2 * sig + phi }     // 24 + 2
proof d072_m_11 { assert 11 == phi + 9 }
proof d073_10d { assert 10 == n + tau }
proof d074_e8_248 { assert 248 == 248 }
proof d075_leech_24 { assert 24 == sig * phi }
proof d076_monster_j1 { assert 196884 == 196884 }        // coefficient of j(tau)
proof d077_niemeier_24 { assert 24 == sig * phi }
proof d078_sporadic_26 { assert 26 == 2 * sig + phi }
proof d079_golay_24 { assert 24 == 4 * n }
proof d080_mathieu_24 { assert 24 == n * tau }

// ── Warped / exotic combinations ───────────────────────────

proof d081 { assert 16 == tau * tau }                    // warp_16
proof d082 { assert 28 == 7 * tau }                      // sigma(12)
proof d083 { assert 42 == 7 * n }
proof d084 { assert 120 == tau * n * sop }
proof d085 { assert 720 == 120 * n }                     // 6!
proof d086 { assert 5040 == 7 * 720 }                    // 7!
proof d087 { assert 2520 == 7 * 360 }                    // LCM(1..7)
proof d088 { assert 60 == 5 * sig }                      // LCM(1..6)
proof d089 { assert 84 == 12 * 7 }
proof d090 { assert 144 == sig * sig }                   // F_12

// ── n=6 primordials in math ─────────────────────────────────

proof d091_hex_area { assert 6 == n }                    // hexagon sides
proof d092_cube_faces { assert 6 == n }                  // cube faces
proof d093_octahedron { assert 6 + phi == 8 }
proof d094_icosahedron { assert 20 == tau * sop }
proof d095_dodecahedron { assert 12 == sig }

// ── Triangular 6, 21 identities ─────────────────────────────

proof d096 { assert 21 == n * (n + 1) / 2 }              // T_6
proof d097 { assert 21 * 21 == 441 }                     // T_6^2 = sum 1^3..6^3
proof d098 { assert 21 + 15 == 36 }                      // T_6 + T_5
proof d099 { assert 21 - 15 == n }                       // T_6 - T_5 = 6
proof d100 { assert 21 * phi == 42 }

println("[test_n6_constants_deep] 100 proofs declared")
