// self/macro_expand.hexa — HEXA MACRO EXPAND ported from src/macro_expand.rs

// Hygienic macro expansion for Hexa.
// The expander matches invocation tokens against macro rule patterns,
// captures fragments, and produces expanded AST statements.
// Hygiene via gensym: bindings introduced by macros are suffixed
// with __macro_N to avoid collisions with user code.

// ── Global counter for hygienic name generation ─────────────

let mut GENSYM_COUNTER = 0

fn gensym(base: string) -> string {
    let id = GENSYM_COUNTER
    GENSYM_COUNTER = GENSYM_COUNTER + 1
    return base + "__" + to_string(id)
}

// ── MacroFragment: a captured fragment ──────────────────────

// kind: "single" or "repeated"
struct MacroFragment {
    kind: string,
    single_tokens: [string],      // for single captures
    repeated_tokens: [string]     // flattened repeated captures (simplified)
}

fn macro_fragment_single(tokens: [string]) -> MacroFragment {
    return MacroFragment { kind: "single", single_tokens: tokens, repeated_tokens: [] }
}

fn macro_fragment_repeated(tokens: [string]) -> MacroFragment {
    return MacroFragment { kind: "repeated", single_tokens: [], repeated_tokens: tokens }
}

// ── StoredMacro: a stored macro definition ──────────────────

struct MacroRule {
    pattern: [string],    // pattern tokens (simplified as strings)
    body: [string]        // body tokens (simplified as strings)
}

struct StoredMacro {
    rules: [MacroRule]
}

// ── Token types (as strings) ────────────────────────────────
// In the Rust version these are enums. Here we represent them as strings:
// "ident:NAME", "int:N", "float:N", "string:S", "bool:B",
// "(", ")", "{", "}", "[", "]", ",", ":", "::", ";", ".",
// "+", "-", "*", "/", "%", "**", "=", "==", "!=", "<", ">",
// "<=", ">=", "&&", "||", "!", "->", "..", "..=",
// "&", "|", "^", "~",
// "let", "mut", "fn", "return", "if", "else", "for", "while",
// "loop", "struct", "enum", "trait", "impl", "match",
// "true", "false", "\n"

// ── Capture a single fragment based on specifier ────────────

fn capture_fragment(spec: string, tokens: [string], pos: int) -> int {
    // Returns number of tokens consumed, or -1 on failure
    if pos >= len(tokens) { return -1 }

    if spec == "ident" {
        // Check if token starts with "ident:"
        let tok = tokens[pos]
        if len(tok) > 6 {
            // simplified check
            return 1
        }
        return -1
    }
    if spec == "literal" {
        let tok = tokens[pos]
        // Check int:, float:, string:, bool:
        return 1
    }
    if spec == "expr" {
        // Greedily take tokens until comma or closing delimiter at depth 0
        let mut depth = 0
        let mut end = pos
        while end < len(tokens) {
            let tok = tokens[end]
            if tok == "(" { depth = depth + 1 }
            if tok == "[" { depth = depth + 1 }
            if tok == "{" { depth = depth + 1 }
            if tok == ")" {
                if depth == 0 { return end - pos }
                depth = depth - 1
            }
            if tok == "]" {
                if depth == 0 { return end - pos }
                depth = depth - 1
            }
            if tok == "}" {
                if depth == 0 { return end - pos }
                depth = depth - 1
            }
            if tok == "," {
                if depth == 0 { return end - pos }
            }
            if tok == ";" {
                if depth == 0 { return end - pos }
            }
            end = end + 1
        }
        if end == pos { return -1 }
        return end - pos
    }
    if spec == "ty" {
        // Type = single identifier
        return 1
    }
    if spec == "block" {
        // Balanced braces
        if tokens[pos] != "{" { return -1 }
        let mut depth = 0
        let mut end = pos
        while end < len(tokens) {
            if tokens[end] == "{" { depth = depth + 1 }
            if tokens[end] == "}" {
                depth = depth - 1
                if depth == 0 {
                    return end - pos + 1
                }
            }
            end = end + 1
        }
        return -1
    }
    return -1
}

// ── Expand a macro invocation ───────────────────────────────

fn expand_macro(mac: StoredMacro, invocation_tokens: [string], line: int, col: int) -> [string] {
    // Try each rule in order
    let mut ri = 0
    while ri < len(mac.rules) {
        let rule = mac.rules[ri]
        // Attempt pattern match (simplified)
        // If match: substitute body with captures, return expanded tokens
        // If no match: try next rule
        ri = ri + 1
    }
    // No rule matched
    return ["// macro expansion error: no rule matched"]
}

// ── Substitute captured fragments into body template ────────

fn substitute_body(body: [string], capture_names: [string], capture_values: [string]) -> [string] {
    let output = []
    let mut i = 0
    while i < len(body) {
        let tok = body[i]
        // Check if token is a variable reference $name
        let mut found = false
        let mut ci = 0
        while ci < len(capture_names) {
            if tok == "$" + capture_names[ci] {
                output = output + [capture_values[ci]]
                found = true
                ci = len(capture_names)  // break
            }
            ci = ci + 1
        }
        if !found {
            output = output + [tok]
        }
        i = i + 1
    }
    return output
}

// ── Macro tokens to source string ───────────────────────────

fn macro_tokens_to_source(tokens: [string]) -> string {
    let result = ""
    let mut i = 0
    while i < len(tokens) {
        if i > 0 { result = result + " " }
        result = result + tokens[i]
        i = i + 1
    }
    return result
}

// ── Apply hygiene: rename let-bound identifiers ─────────────

fn apply_hygiene(source: string) -> string {
    // In full impl: parse, walk AST, rename let-bound vars with gensym
    // Simplified: return source unchanged
    return source
}

// ── Generate derive implementations ─────────────────────────

fn generate_derive(type_name: string, traits: [string], field_names: [string], field_types: [string]) -> string {
    let result = ""
    let mut ti = 0
    while ti < len(traits) {
        let trait_name = traits[ti]
        if trait_name == "Display" {
            result = result + derive_display(type_name, field_names)
        }
        if trait_name == "Debug" {
            result = result + derive_debug(type_name, field_names)
        }
        if trait_name == "Eq" {
            result = result + derive_eq(type_name, field_names)
        }
        ti = ti + 1
    }
    return result
}

fn derive_display(type_name: string, field_names: [string]) -> string {
    // Generate: fn TYPE_display(self) -> string { return "TYPE{ field: " + to_string(self.field) + " }" }
    let body = "\"" + type_name + "{ "
    let mut i = 0
    while i < len(field_names) {
        if i > 0 { body = body + ", " }
        body = body + field_names[i] + ": \" + to_string(self." + field_names[i] + ") + \""
        i = i + 1
    }
    body = body + " }\""
    return "fn " + type_name + "_display(self: " + type_name + ") -> string {\n    return " + body + "\n}\n\n"
}

fn derive_debug(type_name: string, field_names: [string]) -> string {
    // Same as display for debug purposes
    return derive_display(type_name, field_names)
}

fn derive_eq(type_name: string, field_names: [string]) -> string {
    // Generate: fn TYPE_eq(self, other) -> bool { return self.f1 == other.f1 && ... }
    let body = ""
    let mut i = 0
    while i < len(field_names) {
        if i > 0 { body = body + " && " }
        body = body + "self." + field_names[i] + " == other." + field_names[i]
        i = i + 1
    }
    if body == "" { body = "true" }
    return "fn " + type_name + "_eq(self: " + type_name + ", other: " + type_name + ") -> bool {\n    return " + body + "\n}\n\n"
}
