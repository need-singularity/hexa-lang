// self/macro_expand.hexa — HEXA MACRO_EXPAND ported from src/macro_expand.rs
// Hygienic macro expansion for Hexa.
// Matches invocation tokens against macro rule patterns, captures fragments,
// and produces expanded AST statements. Hygiene via gensym suffixing.

// ── Global gensym counter ───────────────────────────────────

let _gensym_counter = 0

fn gensym(base: string) -> string {
    let id = _gensym_counter
    _gensym_counter = _gensym_counter + 1
    return base + "__" + to_string(id)
}

// ── Macro fragment types ────────────────────────────────────

struct MacroFragment {
    kind: string,
    tokens: string,
    repeated: string
}

fn macro_fragment_single(tokens: string) -> MacroFragment {
    return MacroFragment { kind: "single", tokens: tokens, repeated: "" }
}

fn macro_fragment_repeated(repeated: string) -> MacroFragment {
    return MacroFragment { kind: "repeated", tokens: "", repeated: repeated }
}

// ── Stored macro definition ─────────────────────────────────

struct StoredMacro {
    rules: string
}

struct MacroRule {
    pattern: string,
    body: string
}

// ── Token types for macro expansion ─────────────────────────

struct MacroToken {
    kind: string,
    value: string
}

fn macro_token_new(kind: string, value: string) -> MacroToken {
    return MacroToken { kind: kind, value: value }
}

// ── Macro expansion ─────────────────────────────────────────

fn expand_macro(mac: StoredMacro, invocation_tokens: string, line: int, col: int) -> string {
    // Try each rule against invocation tokens
    // Returns expanded source string or "ERROR:message"
    let rules = string_split(mac.rules, "|||")
    let i = 0
    while i < len(rules) {
        let rule = rules[i]
        let parts = string_split(rule, "=>")
        if len(parts) >= 2 {
            let pattern = string_trim(parts[0])
            let body = string_trim(parts[1])
            let captures = match_pattern(pattern, invocation_tokens)
            if len(captures) > 0 {
                let expanded = substitute_body(body, captures)
                return expanded
            }
        }
        i = i + 1
    }
    return "ERROR:no macro rule matched the invocation"
}

// ── Pattern matching ────────────────────────────────────────

fn match_pattern(pattern: string, tokens: string) -> string {
    // Returns captures as "name=value;name2=value2" or "" on failure
    let pat_parts = string_split(pattern, " ")
    let tok_parts = string_split(tokens, " ")
    let captures = ""
    let tok_pos = 0

    let i = 0
    while i < len(pat_parts) {
        let pat = string_trim(pat_parts[i])
        if len(pat) == 0 {
            i = i + 1
            continue
        }

        // $name:spec -- capture a fragment
        if string_starts_with(pat, "$") {
            let colon_pos = string_find(pat, ":")
            let name = ""
            if colon_pos > 0 {
                name = string_slice(pat, 1, colon_pos)
            } else {
                name = string_slice(pat, 1, len(pat))
            }
            if tok_pos < len(tok_parts) {
                let entry = name + "=" + tok_parts[tok_pos]
                if len(captures) > 0 {
                    captures = captures + ";" + entry
                } else {
                    captures = entry
                }
                tok_pos = tok_pos + 1
            } else {
                return ""
            }
        } else {
            // Literal token match
            if tok_pos >= len(tok_parts) { return "" }
            if pat != tok_parts[tok_pos] { return "" }
            tok_pos = tok_pos + 1
        }
        i = i + 1
    }
    if len(captures) == 0 { return "matched" }
    return captures
}

// ── Capture fragment by specifier ───────────────────────────

fn capture_fragment(spec: string, tokens: string, pos: int) -> string {
    let tok_parts = string_split(tokens, " ")
    if pos >= len(tok_parts) { return "" }

    match spec {
        "ident" => {
            // Single identifier token
            return tok_parts[pos]
        }
        "literal" => {
            return tok_parts[pos]
        }
        "expr" => {
            // Greedily take tokens until comma or closing delimiter at depth 0
            let depth = 0
            let end = pos
            let result = ""
            while end < len(tok_parts) {
                let tok = tok_parts[end]
                if tok == "(" || tok == "[" || tok == "{" { depth = depth + 1 }
                if tok == ")" || tok == "]" || tok == "}" {
                    if depth == 0 { end = len(tok_parts) }
                    else { depth = depth - 1 }
                }
                if tok == "," {
                    if depth == 0 { end = len(tok_parts) }
                }
                if end < len(tok_parts) {
                    if len(result) > 0 { result = result + " " + tok }
                    else { result = tok }
                    end = end + 1
                }
            }
            return result
        }
        "ty" => {
            return tok_parts[pos]
        }
        "block" => {
            // Capture balanced braces
            if tok_parts[pos] != "{" { return "" }
            let depth = 0
            let end = pos
            let result = ""
            while end < len(tok_parts) {
                let tok = tok_parts[end]
                if tok == "{" { depth = depth + 1 }
                if tok == "}" {
                    depth = depth - 1
                    if depth == 0 {
                        result = result + " }"
                        return string_trim(result)
                    }
                }
                if len(result) > 0 { result = result + " " + tok }
                else { result = tok }
                end = end + 1
            }
            return result
        }
        _ => {
            return tok_parts[pos]
        }
    }
}

// ── Body substitution ───────────────────────────────────────

fn substitute_body(body: string, captures: string) -> string {
    let result = body
    let entries = string_split(captures, ";")
    let i = 0
    while i < len(entries) {
        let entry = entries[i]
        let eq_pos = string_find(entry, "=")
        if eq_pos > 0 {
            let name = string_slice(entry, 0, eq_pos)
            let value = string_slice(entry, eq_pos + 1, len(entry))
            let placeholder = "$" + name
            result = string_replace(result, placeholder, value)
        }
        i = i + 1
    }
    return result
}

// ── Find repetition count ───────────────────────────────────

fn find_repetition_count(body: string, captures: string) -> int {
    // Find the first repeated capture and return its length
    let entries = string_split(captures, ";")
    let i = 0
    while i < len(entries) {
        let entry = entries[i]
        let eq_pos = string_find(entry, "=")
        if eq_pos > 0 {
            let value = string_slice(entry, eq_pos + 1, len(entry))
            // Repeated values stored as "v1|v2|v3"
            if string_find(value, "|") >= 0 {
                let parts = string_split(value, "|")
                return len(parts)
            }
        }
        i = i + 1
    }
    return 0
}

// ── Hygiene: rename let-bindings ────────────────────────────

fn apply_hygiene(source: string) -> string {
    let lines = string_split(source, "\n")
    let renames = ""
    let result = ""
    let i = 0
    while i < len(lines) {
        let line = lines[i]
        let trimmed = string_trim(line)

        if string_starts_with(trimmed, "let ") {
            let rest = string_slice(trimmed, 4, len(trimmed))
            let eq_pos = string_find(rest, "=")
            if eq_pos > 0 {
                let var_name = string_trim(string_slice(rest, 0, eq_pos))
                let new_name = gensym(var_name)
                line = string_replace(line, var_name, new_name)
                if len(renames) > 0 {
                    renames = renames + ";" + var_name + "=" + new_name
                } else {
                    renames = var_name + "=" + new_name
                }
            }
        } else {
            // Apply existing renames to this line
            let entries = string_split(renames, ";")
            let j = 0
            while j < len(entries) {
                let entry = entries[j]
                let eq_pos = string_find(entry, "=")
                if eq_pos > 0 {
                    let old_name = string_slice(entry, 0, eq_pos)
                    let new_name = string_slice(entry, eq_pos + 1, len(entry))
                    line = string_replace(line, old_name, new_name)
                }
                j = j + 1
            }
        }

        if i > 0 { result = result + "\n" + line }
        else { result = line }
        i = i + 1
    }
    return result
}

// ── Token to source conversion ──────────────────────────────

fn macro_token_to_source(kind: string, value: string) -> string {
    match kind {
        "ident" => { return value }
        "int" => { return value }
        "float" => { return value }
        "string" => { return "\"" + value + "\"" }
        "bool" => { return value }
        "lparen" => { return "(" }
        "rparen" => { return ")" }
        "lbrace" => { return "{" }
        "rbrace" => { return "}" }
        "lbracket" => { return "[" }
        "rbracket" => { return "]" }
        "comma" => { return "," }
        "colon" => { return ":" }
        "coloncolon" => { return "::" }
        "semicolon" => { return ";" }
        "dot" => { return "." }
        "plus" => { return "+" }
        "minus" => { return "-" }
        "star" => { return "*" }
        "slash" => { return "/" }
        "percent" => { return "%" }
        "power" => { return "**" }
        "eq" => { return "=" }
        "eqeq" => { return "==" }
        "noteq" => { return "!=" }
        "lt" => { return "<" }
        "gt" => { return ">" }
        "lteq" => { return "<=" }
        "gteq" => { return ">=" }
        "and" => { return "&&" }
        "or" => { return "||" }
        "not" => { return "!" }
        "arrow" => { return "->" }
        "dotdot" => { return ".." }
        "dotdoteq" => { return "..=" }
        "bitand" => { return "&" }
        "bitor" => { return "|" }
        "bitxor" => { return "^" }
        "bitnot" => { return "~" }
        "let" => { return "let" }
        "mut" => { return "mut" }
        "fn" => { return "fn" }
        "return" => { return "return" }
        "if" => { return "if" }
        "else" => { return "else" }
        "for" => { return "for" }
        "while" => { return "while" }
        "loop" => { return "loop" }
        "struct" => { return "struct" }
        "enum" => { return "enum" }
        "match" => { return "match" }
        "true" => { return "true" }
        "false" => { return "false" }
        "newline" => { return "\n" }
        _ => { return value }
    }
}

fn macro_tokens_to_source(tokens: string) -> string {
    // tokens is space-separated "kind:value" pairs
    let parts = string_split(tokens, " ")
    let result = ""
    let i = 0
    while i < len(parts) {
        let tok = parts[i]
        let colon_pos = string_find(tok, ":")
        if colon_pos > 0 {
            let kind = string_slice(tok, 0, colon_pos)
            let value = string_slice(tok, colon_pos + 1, len(tok))
            let src = macro_token_to_source(kind, value)
            if len(result) > 0 { result = result + " " + src }
            else { result = src }
        }
        i = i + 1
    }
    return result
}

// ── Derive generation ───────────────────────────────────────

fn generate_derive_display(type_name: string, fields: string) -> string {
    let field_list = string_split(fields, ",")
    let body_parts = ""
    let i = 0
    while i < len(field_list) {
        let f = string_trim(field_list[i])
        if len(f) > 0 {
            let part = "\"" + f + ": \" + to_string(self." + f + ")"
            if len(body_parts) > 0 {
                body_parts = body_parts + " + \", \" + " + part
            } else {
                body_parts = part
            }
        }
        i = i + 1
    }
    if len(body_parts) == 0 {
        return "fn " + type_name + "_display(self) -> string {\n    return \"" + type_name + "{}\"\n}"
    }
    return "fn " + type_name + "_display(self) -> string {\n    return \"" + type_name + "{ \" + " + body_parts + " + \" }\"\n}"
}

fn generate_derive_eq(type_name: string, fields: string) -> string {
    let field_list = string_split(fields, ",")
    let comparisons = ""
    let i = 0
    while i < len(field_list) {
        let f = string_trim(field_list[i])
        if len(f) > 0 {
            let cmp = "self." + f + " == other." + f
            if len(comparisons) > 0 {
                comparisons = comparisons + " && " + cmp
            } else {
                comparisons = cmp
            }
        }
        i = i + 1
    }
    if len(comparisons) == 0 { comparisons = "true" }
    return "fn " + type_name + "_eq(self, other) -> bool {\n    return " + comparisons + "\n}"
}

fn generate_derive(type_name: string, trait_name: string, fields: string) -> string {
    match trait_name {
        "Display" => { return generate_derive_display(type_name, fields) }
        "Debug" => { return generate_derive_display(type_name, fields) }
        "Eq" => { return generate_derive_eq(type_name, fields) }
        _ => { return "// ERROR: unknown derive trait: " + trait_name }
    }
}
