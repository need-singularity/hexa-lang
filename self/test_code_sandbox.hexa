// ═══════════════════════════════════════════════════════════════════
//  test_code_sandbox.hexa — Code Sandbox Executor (ML #69) 검증
//
//  검증:
//    1. 빈 프로그램 → ok
//    2. let + return literal
//    3. binop add 1+2=3
//    4. 변수 업데이트 (let/asn)
//    5. if/else 분기
//    6. while 루프 sum 1..=10 = 55
//    7. println stdout 캡처
//    8. 중첩 표현식 ((2+3)*4)=20
//    9. exec timeout → timeout
//   10. denied call (exec builtin) → denied
//   11. denied op (unknown op) → denied
//   12. undefined var → err
//   13. 결정적 실행: 동일 입력 2회 동일 출력
//   14. div by zero 안전
//   15-17. allowlist/denylist helpers
//   18. unary neg
//   19. allowlist builtin abs
//   20. step counter nonzero
//
//  실행: ./hexa self/test_code_sandbox.hexa
// ═══════════════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

// ═══════════════════════════════════════════════════════════════════
//  Inline core (self/ml/code_sandbox.hexa)
// ═══════════════════════════════════════════════════════════════════

fn cs_tag_ok()      { return "ok" }
fn cs_tag_err()     { return "err" }
fn cs_tag_timeout() { return "timeout" }
fn cs_tag_denied()  { return "denied" }

fn cs_lit_int(v)       { return #{"tag": "int", "ival": v} }
fn cs_lit_str(v)       { return #{"tag": "str", "sval": v} }
fn cs_var(name)        { return #{"tag": "var", "sval": name} }
fn cs_bin(op, a, b)    { return #{"tag": "bin", "op": op, "left": a, "right": b} }
fn cs_un(op, a)        { return #{"tag": "un", "op": op, "left": a} }
fn cs_call(fname, a)   { return #{"tag": "call", "fname": fname, "args": a} }
fn cs_let(name, e)     { return #{"tag": "let", "name": name, "expr": e} }
fn cs_asn(name, e)     { return #{"tag": "asn", "name": name, "expr": e} }
fn cs_if(c, t, el)     { return #{"tag": "if", "expr": c, "then": t, "else": el} }
fn cs_while(c, b)      { return #{"tag": "while", "expr": c, "body": b} }
fn cs_ret(e)           { return #{"tag": "ret", "expr": e} }
fn cs_exp(e)           { return #{"tag": "exp", "expr": e} }

fn cs_new_sandbox(max_steps) {
    return #{
        "max_steps": max_steps,
        "steps": 0,
        "vars_k": [],
        "vars_v": [],
        "stdout_buf": [],
        "returned": 0,
        "ret_val": 0,
        "err_msg": "",
        "status": "ok"
    }
}

fn cs_var_lookup_found(sb, name) {
    let n = len(sb["vars_k"])
    let mut i = n - 1
    while i >= 0 {
        if sb["vars_k"][i] == name { return 1 }
        i = i - 1
    }
    return 0
}

fn cs_var_lookup_value(sb, name) {
    let n = len(sb["vars_k"])
    let mut i = n - 1
    while i >= 0 {
        if sb["vars_k"][i] == name { return sb["vars_v"][i] }
        i = i - 1
    }
    return 0
}

fn cs_var_set(sb, name, val) {
    let mut s = sb
    let n = len(s["vars_k"])
    let mut i = 0
    let mut updated = 0
    while i < n {
        if s["vars_k"][i] == name {
            s["vars_v"][i] = val
            updated = 1
            i = n
        } else {
            i = i + 1
        }
    }
    if updated == 0 {
        s["vars_k"] = s["vars_k"] + [name]
        s["vars_v"] = s["vars_v"] + [val]
    }
    return s
}

fn cs_var_declare(sb, name, val) {
    let mut s = sb
    s["vars_k"] = s["vars_k"] + [name]
    s["vars_v"] = s["vars_v"] + [val]
    return s
}

fn cs_stdout_append(sb, val) {
    let mut s = sb
    s["stdout_buf"] = s["stdout_buf"] + [val]
    return s
}

fn cs_stdout_text(sb) {
    let buf = sb["stdout_buf"]
    let n = len(buf)
    let mut out = ""
    let mut i = 0
    while i < n {
        out = out + buf[i]
        i = i + 1
    }
    return out
}

fn cs_allowed_op(op) {
    if op == "add" { return true }
    if op == "sub" { return true }
    if op == "mul" { return true }
    if op == "div" { return true }
    if op == "mod" { return true }
    if op == "eq"  { return true }
    if op == "ne"  { return true }
    if op == "lt"  { return true }
    if op == "gt"  { return true }
    if op == "le"  { return true }
    if op == "ge"  { return true }
    if op == "and" { return true }
    if op == "or"  { return true }
    if op == "neg" { return true }
    if op == "not" { return true }
    return false
}

fn cs_allowed_call(fname) {
    if fname == "print"    { return true }
    if fname == "println"  { return true }
    if fname == "len"      { return true }
    if fname == "str_cast" { return true }
    if fname == "int_cast" { return true }
    if fname == "abs"      { return true }
    if fname == "min"      { return true }
    if fname == "max"      { return true }
    return false
}

fn cs_denied_call(fname) {
    if fname == "exec"       { return true }
    if fname == "read_file"  { return true }
    if fname == "write_file" { return true }
    if fname == "http_get"   { return true }
    if fname == "http_post"  { return true }
    if fname == "env_var"    { return true }
    if fname == "exit"       { return true }
    if fname == "spawn"      { return true }
    return false
}

fn cs_result_ok(v, out, steps) {
    return #{"status": "ok", "value": v, "stdout": out, "steps": steps, "error": ""}
}
fn cs_result_err(msg, out, steps) {
    return #{"status": "err", "value": 0, "stdout": out, "steps": steps, "error": msg}
}
fn cs_result_timeout(out, steps) {
    return #{"status": "timeout", "value": 0, "stdout": out, "steps": steps, "error": "step limit exceeded"}
}
fn cs_result_denied(reason, out, steps) {
    return #{"status": "denied", "value": 0, "stdout": out, "steps": steps, "error": reason}
}

fn cs_do_bin(op, a, b) {
    if op == "add" { return a + b }
    if op == "sub" { return a - b }
    if op == "mul" { return a * b }
    if op == "div" {
        if b == 0 { return 0 }
        return a / b
    }
    if op == "mod" {
        if b == 0 { return 0 }
        return a % b
    }
    if op == "eq" {
        if a == b { return 1 }
        return 0
    }
    if op == "ne" {
        if a != b { return 1 }
        return 0
    }
    if op == "lt" {
        if a < b { return 1 }
        return 0
    }
    if op == "gt" {
        if a > b { return 1 }
        return 0
    }
    if op == "le" {
        if a <= b { return 1 }
        return 0
    }
    if op == "ge" {
        if a >= b { return 1 }
        return 0
    }
    if op == "and" {
        if a != 0 {
            if b != 0 { return 1 }
        }
        return 0
    }
    if op == "or" {
        if a != 0 { return 1 }
        if b != 0 { return 1 }
        return 0
    }
    return 0
}

fn cs_do_un(op, a) {
    if op == "neg" { return 0 - a }
    if op == "not" {
        if a == 0 { return 1 }
        return 0
    }
    return 0
}

fn cs_do_call(sb, fname, argvals) {
    let mut s = sb
    if fname == "print" {
        let n = len(argvals)
        let mut i = 0
        while i < n {
            s = cs_stdout_append(s, str(argvals[i]))
            i = i + 1
        }
        s["_call_ret"] = 0
        return s
    }
    if fname == "println" {
        let n = len(argvals)
        let mut i = 0
        while i < n {
            s = cs_stdout_append(s, str(argvals[i]))
            i = i + 1
        }
        s = cs_stdout_append(s, "\n")
        s["_call_ret"] = 0
        return s
    }
    if fname == "len" {
        if len(argvals) == 0 { s["_call_ret"] = 0; return s }
        s["_call_ret"] = len(argvals[0])
        return s
    }
    if fname == "str_cast" {
        if len(argvals) == 0 { s["_call_ret"] = ""; return s }
        s["_call_ret"] = str(argvals[0])
        return s
    }
    if fname == "int_cast" {
        if len(argvals) == 0 { s["_call_ret"] = 0; return s }
        s["_call_ret"] = to_int(argvals[0])
        return s
    }
    if fname == "abs" {
        if len(argvals) == 0 { s["_call_ret"] = 0; return s }
        let v = argvals[0]
        if v < 0 { s["_call_ret"] = 0 - v; return s }
        s["_call_ret"] = v
        return s
    }
    if fname == "min" {
        if len(argvals) < 2 { s["_call_ret"] = 0; return s }
        let a = argvals[0]
        let b = argvals[1]
        if a < b { s["_call_ret"] = a; return s }
        s["_call_ret"] = b
        return s
    }
    if fname == "max" {
        if len(argvals) < 2 { s["_call_ret"] = 0; return s }
        let a = argvals[0]
        let b = argvals[1]
        if a > b { s["_call_ret"] = a; return s }
        s["_call_ret"] = b
        return s
    }
    s["_call_ret"] = 0
    return s
}

fn cs_tick(sb) {
    let mut s = sb
    s["steps"] = s["steps"] + 1
    if s["steps"] > s["max_steps"] {
        s["status"] = "timeout"
    }
    return s
}

fn cs_eval_expr(sb, e) {
    let mut s = cs_tick(sb)
    if s["status"] != "ok" {
        s["_eval_ret"] = 0
        return s
    }
    let tag = e["tag"]
    if tag == "int" {
        s["_eval_ret"] = e["ival"]
        return s
    }
    if tag == "str" {
        s["_eval_ret"] = e["sval"]
        return s
    }
    if tag == "var" {
        let name = e["sval"]
        if cs_var_lookup_found(s, name) == 0 {
            s["status"] = "err"
            s["err_msg"] = "undefined var: " + name
            s["_eval_ret"] = 0
            return s
        }
        s["_eval_ret"] = cs_var_lookup_value(s, name)
        return s
    }
    if tag == "bin" {
        let op = e["op"]
        if cs_allowed_op(op) == false {
            s["status"] = "denied"
            s["err_msg"] = "denied op: " + op
            s["_eval_ret"] = 0
            return s
        }
        s = cs_eval_expr(s, e["left"])
        if s["status"] != "ok" {
            s["_eval_ret"] = 0
            return s
        }
        let lv = s["_eval_ret"]
        s = cs_eval_expr(s, e["right"])
        if s["status"] != "ok" {
            s["_eval_ret"] = 0
            return s
        }
        let rv = s["_eval_ret"]
        s["_eval_ret"] = cs_do_bin(op, lv, rv)
        return s
    }
    if tag == "un" {
        let op = e["op"]
        if cs_allowed_op(op) == false {
            s["status"] = "denied"
            s["err_msg"] = "denied op: " + op
            s["_eval_ret"] = 0
            return s
        }
        s = cs_eval_expr(s, e["left"])
        if s["status"] != "ok" {
            s["_eval_ret"] = 0
            return s
        }
        let iv = s["_eval_ret"]
        s["_eval_ret"] = cs_do_un(op, iv)
        return s
    }
    if tag == "call" {
        let fname = e["fname"]
        if cs_allowed_call(fname) == false {
            s["status"] = "denied"
            s["err_msg"] = "denied call: " + fname
            s["_eval_ret"] = 0
            return s
        }
        let raw_args = e["args"]
        let mut argvals = []
        let mut i = 0
        let n = len(raw_args)
        while i < n {
            s = cs_eval_expr(s, raw_args[i])
            if s["status"] != "ok" {
                s["_eval_ret"] = 0
                return s
            }
            argvals = argvals + [s["_eval_ret"]]
            i = i + 1
        }
        s = cs_do_call(s, fname, argvals)
        s["_eval_ret"] = s["_call_ret"]
        return s
    }
    s["status"] = "err"
    s["err_msg"] = "unknown expr tag: " + tag
    s["_eval_ret"] = 0
    return s
}

fn cs_exec_stmt(sb, stmt) {
    let mut s = cs_tick(sb)
    if s["status"] != "ok" { return s }
    if s["returned"] != 0 { return s }
    let tag = stmt["tag"]
    if tag == "let" {
        s = cs_eval_expr(s, stmt["expr"])
        if s["status"] != "ok" { return s }
        s = cs_var_declare(s, stmt["name"], s["_eval_ret"])
        return s
    }
    if tag == "asn" {
        s = cs_eval_expr(s, stmt["expr"])
        if s["status"] != "ok" { return s }
        if cs_var_lookup_found(s, stmt["name"]) == 0 {
            s["status"] = "err"
            s["err_msg"] = "assign to undeclared: " + stmt["name"]
            return s
        }
        s = cs_var_set(s, stmt["name"], s["_eval_ret"])
        return s
    }
    if tag == "if" {
        s = cs_eval_expr(s, stmt["expr"])
        if s["status"] != "ok" { return s }
        if s["_eval_ret"] != 0 {
            s = cs_exec_block(s, stmt["then"])
        } else {
            s = cs_exec_block(s, stmt["else"])
        }
        return s
    }
    if tag == "while" {
        let mut guard = 0
        let hard_cap = s["max_steps"]
        while guard < hard_cap {
            if s["status"] != "ok" { return s }
            if s["returned"] != 0 { return s }
            s = cs_eval_expr(s, stmt["expr"])
            if s["status"] != "ok" { return s }
            if s["_eval_ret"] == 0 { return s }
            s = cs_exec_block(s, stmt["body"])
            guard = guard + 1
        }
        s["status"] = "timeout"
        s["err_msg"] = "while loop cap"
        return s
    }
    if tag == "ret" {
        s = cs_eval_expr(s, stmt["expr"])
        if s["status"] != "ok" { return s }
        s["ret_val"] = s["_eval_ret"]
        s["returned"] = 1
        return s
    }
    if tag == "exp" {
        s = cs_eval_expr(s, stmt["expr"])
        return s
    }
    s["status"] = "err"
    s["err_msg"] = "unknown stmt tag: " + tag
    return s
}

fn cs_exec_block(sb, stmts) {
    let mut s = sb
    let n = len(stmts)
    let mut i = 0
    while i < n {
        if s["status"] != "ok" { return s }
        if s["returned"] != 0 { return s }
        s = cs_exec_stmt(s, stmts[i])
        i = i + 1
    }
    return s
}

fn cs_run(sb, program) {
    let s = cs_exec_block(sb, program)
    let out = cs_stdout_text(s)
    let status = s["status"]
    let steps = s["steps"]
    if status == "timeout" {
        return cs_result_timeout(out, steps)
    }
    if status == "denied" {
        return cs_result_denied(s["err_msg"], out, steps)
    }
    if status == "err" {
        return cs_result_err(s["err_msg"], out, steps)
    }
    return cs_result_ok(s["ret_val"], out, steps)
}

// ═══════════════════════════════════════════════════════════════════
//  Tests
// ═══════════════════════════════════════════════════════════════════

// Test 1: empty program
let r1 = cs_run(cs_new_sandbox(1000), [])
check("#1 empty program → ok", r1["status"] == "ok")

// Test 2: let + return literal
let prog2 = [
    cs_let("x", cs_lit_int(42)),
    cs_ret(cs_var("x"))
]
let r2 = cs_run(cs_new_sandbox(1000), prog2)
check("#2 let + ret literal", r2["status"] == "ok" && r2["value"] == 42)

// Test 3: binop add
let prog3 = [
    cs_ret(cs_bin("add", cs_lit_int(1), cs_lit_int(2)))
]
let r3 = cs_run(cs_new_sandbox(1000), prog3)
check("#3 binop add 1+2=3", r3["value"] == 3)

// Test 4: variable update (let + asn)
let prog4 = [
    cs_let("x", cs_lit_int(10)),
    cs_asn("x", cs_bin("add", cs_var("x"), cs_lit_int(5))),
    cs_ret(cs_var("x"))
]
let r4 = cs_run(cs_new_sandbox(1000), prog4)
check("#4 let+asn x=10→15", r4["value"] == 15)

// Test 5: if/else branch
let prog5 = [
    cs_let("x", cs_lit_int(3)),
    cs_if(
        cs_bin("gt", cs_var("x"), cs_lit_int(0)),
        [cs_ret(cs_lit_int(100))],
        [cs_ret(cs_lit_int(200))]
    )
]
let r5 = cs_run(cs_new_sandbox(1000), prog5)
check("#5 if/else branch → 100", r5["value"] == 100)

// Test 6: while loop — sum 1..=10 = 55
let prog6 = [
    cs_let("i", cs_lit_int(1)),
    cs_let("s", cs_lit_int(0)),
    cs_while(
        cs_bin("le", cs_var("i"), cs_lit_int(10)),
        [
            cs_asn("s", cs_bin("add", cs_var("s"), cs_var("i"))),
            cs_asn("i", cs_bin("add", cs_var("i"), cs_lit_int(1)))
        ]
    ),
    cs_ret(cs_var("s"))
]
let r6 = cs_run(cs_new_sandbox(10000), prog6)
check("#6 while sum 1..=10=55", r6["value"] == 55)

// Test 7: stdout capture via println / print
let prog7 = [
    cs_exp(cs_call("println", [cs_lit_str("hi")])),
    cs_exp(cs_call("print", [cs_lit_str("end")]))
]
let r7 = cs_run(cs_new_sandbox(1000), prog7)
check("#7 stdout capture contains hi+end",
    r7["status"] == "ok" && r7["stdout"] == "hi\nend")

// Test 8: nested expr ((2+3)*4)=20
let prog8 = [
    cs_ret(cs_bin("mul", cs_bin("add", cs_lit_int(2), cs_lit_int(3)), cs_lit_int(4)))
]
let r8 = cs_run(cs_new_sandbox(1000), prog8)
check("#8 nested (2+3)*4=20", r8["value"] == 20)

// Test 9: exec timeout — tight step budget on big loop
let prog9 = [
    cs_let("i", cs_lit_int(0)),
    cs_while(
        cs_bin("lt", cs_var("i"), cs_lit_int(1000000)),
        [cs_asn("i", cs_bin("add", cs_var("i"), cs_lit_int(1)))]
    ),
    cs_ret(cs_var("i"))
]
let r9 = cs_run(cs_new_sandbox(100), prog9)
check("#9 exec timeout on tight budget", r9["status"] == "timeout")

// Test 10: denied call (exec builtin attempt)
let prog10 = [
    cs_exp(cs_call("exec", [cs_lit_str("rm -rf /")]))
]
let r10 = cs_run(cs_new_sandbox(1000), prog10)
check("#10 denied call: exec blocked", r10["status"] == "denied")

// Test 11: denied op (unknown op like bitshift)
let prog11 = [
    cs_ret(cs_bin("shl", cs_lit_int(1), cs_lit_int(3)))
]
let r11 = cs_run(cs_new_sandbox(1000), prog11)
check("#11 denied op: shl blocked", r11["status"] == "denied")

// Test 12: undefined var → err
let prog12 = [
    cs_ret(cs_var("nope"))
]
let r12 = cs_run(cs_new_sandbox(1000), prog12)
check("#12 undefined var → err", r12["status"] == "err")

// Test 13: deterministic — same input, same output twice
let prog13 = [
    cs_let("a", cs_lit_int(7)),
    cs_let("b", cs_lit_int(13)),
    cs_ret(cs_bin("mul", cs_var("a"), cs_var("b")))
]
let r13a = cs_run(cs_new_sandbox(1000), prog13)
let r13b = cs_run(cs_new_sandbox(1000), prog13)
check("#13 deterministic run",
    r13a["value"] == r13b["value"] && r13a["value"] == 91 &&
    r13a["steps"] == r13b["steps"])

// Test 14: div by zero safe (returns 0, no crash)
let prog14 = [
    cs_ret(cs_bin("div", cs_lit_int(10), cs_lit_int(0)))
]
let r14 = cs_run(cs_new_sandbox(1000), prog14)
check("#14 div by zero safe", r14["status"] == "ok" && r14["value"] == 0)

// Test 15–17: helper functions
check("#15 allowed_op add=true, shl=false",
    cs_allowed_op("add") == true && cs_allowed_op("shl") == false)
check("#16 allowed_call println=true, exec=false",
    cs_allowed_call("println") == true && cs_allowed_call("exec") == false)
check("#17 denied_call exec=true, println=false",
    cs_denied_call("exec") == true && cs_denied_call("println") == false)

// Test 18: unary neg
let prog18 = [cs_ret(cs_un("neg", cs_lit_int(5)))]
let r18 = cs_run(cs_new_sandbox(1000), prog18)
check("#18 unary neg -5", r18["value"] == 0 - 5)

// Test 19: allowlist builtin abs
let prog19 = [cs_ret(cs_call("abs", [cs_lit_int(0 - 9)]))]
let r19 = cs_run(cs_new_sandbox(1000), prog19)
check("#19 call abs(-9)=9", r19["value"] == 9)

// Test 20: step counter monotone nonzero
check("#20 steps tracked nonzero", r6["steps"] > 30)

println("")
println("═══════════════════════════════════════════════════")
println("Code Sandbox: " + str(pass_count) + " PASS / " + str(fail_count) + " FAIL")
println("═══════════════════════════════════════════════════")
