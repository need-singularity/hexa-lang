// ═══════════════════════════════════════════════════════════════
//  Test 31: KV store/get roundtrip
// ═══════════════════════════════════════════════════════════════
let _ = mac_kv_init(2, 8, 4)
let test_k = [1.0, 2.0, 3.0, 4.0]
let test_v = [5.0, 6.0, 7.0, 8.0]
let _ = mac_kv_store(0, 0, test_k, test_v)
let got_k = mac_kv_get_key(0, 0)
let got_v = mac_kv_get_val(0, 0)
let mut kv_rt_ok = true
let mut i = 0

while i < 4 {
    if t_abs(got_k[i] - test_k[i]) > 1.0e-9 { kv_rt_ok = false }
    if t_abs(got_v[i] - test_v[i]) > 1.0e-9 { kv_rt_ok = false }
}
check("T91 KV store/get roundtrip", kv_rt_ok)

// Store at layer 1, pos 3
let test_k2 = [10.0, 20.0, 30.0, 40.0]
let test_v2 = [50.0, 60.0, 70.0, 80.0]
let _ = mac_kv_store(1, 3, test_k2, test_v2)
let got_k2 = mac_kv_get_key(1, 3)
let mut kv_rt2_ok = true
let mut i = 0

while i < 4 {
    if t_abs(got_k2[i] - test_k2[i]) > 1.0e-9 { kv_rt2_ok = false }
}
check("T92 KV store/get layer=1 pos=3", kv_rt2_ok)

// Original store at (0,0) should still be intact
let got_k_orig = mac_kv_get_key(0, 0)
let mut kv_orig_ok = true
let mut i = 0

while i < 4 {
    if t_abs(got_k_orig[i] - test_k[i]) > 1.0e-9 { kv_orig_ok = false }
}
check("T93 KV store isolation between layers", kv_orig_ok)

// ═══════════════════════════════════════════════════════════════
//  Summary
// ═══════════════════════════════════════════════════════════════
println("")
println("===================================================================")
println("  Results: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
println("===================================================================")
if fail_count == 0 {
    println("ALL PASS")
} else {
    println("SOME TESTS FAILED")
}
println(to_string(pass_count) + " passed")
