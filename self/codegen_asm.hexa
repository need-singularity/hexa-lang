// ═══════════════════════════════════════════════════════════
//  codegen_asm.hexa — HEXA → ARM64 Assembly 코드 생성
//  의존: as + ld (macOS 빌트인, gcc 불필요)
//  .hexa → tokenize → parse → .s → as → ld → 네이티브 바이너리
// ═══════════════════════════════════════════════════════════

fn codegen_asm(ast) {
    let mut out = ""
    out = out + "// Generated by HEXA compiler\n"
    out = out + ".global _main\n"
    out = out + ".align 4\n\n"

    // Collect functions and main code
    let mut fn_code = ""
    let mut main_code = ""
    let mut data_section = ""
    let mut str_count = 0

    let mut i = 0
    while i < len(ast) {
        let k = ast[i].kind
        if k == "FnDecl" {
            fn_code = fn_code + gen_asm_fn(ast[i])
        } else {
            main_code = main_code + gen_asm_stmt(ast[i], 0)
        }
        i = i + 1
    }

    // Functions
    out = out + fn_code + "\n"

    // Main
    out = out + "_main:\n"
    out = out + "    stp x29, x30, [sp, #-16]!\n"
    out = out + "    mov x29, sp\n"
    out = out + main_code
    out = out + "    mov x0, #0\n"
    out = out + "    ldp x29, x30, [sp], #16\n"
    out = out + "    ret\n"

    // _hexa_println helper (write syscall)
    out = out + "\n_hexa_print_int:\n"
    out = out + "    // Print integer in x0 to stdout\n"
    out = out + "    stp x29, x30, [sp, #-16]!\n"
    out = out + "    mov x29, sp\n"
    out = out + "    sub sp, sp, #32\n"
    out = out + "    mov x1, sp\n"         // buffer
    out = out + "    add x1, x1, #20\n"    // end of buffer
    out = out + "    mov x2, #0\n"         // length counter
    out = out + "    cmp x0, #0\n"
    out = out + "    b.ge 1f\n"
    out = out + "    neg x0, x0\n"         // handle negative
    out = out + "1:  mov x3, #10\n"
    out = out + "2:  udiv x4, x0, x3\n"    // x4 = x0 / 10
    out = out + "    msub x5, x4, x3, x0\n" // x5 = x0 % 10
    out = out + "    add x5, x5, #48\n"    // ASCII digit
    out = out + "    sub x1, x1, #1\n"
    out = out + "    strb w5, [x1]\n"
    out = out + "    add x2, x2, #1\n"
    out = out + "    mov x0, x4\n"
    out = out + "    cbnz x0, 2b\n"
    out = out + "    // Write: syscall(4, 1, buf, len)  -- macOS write\n"
    out = out + "    mov x0, #1\n"         // fd = stdout
    out = out + "    // x1 already points to start\n"
    out = out + "    // x2 already has length\n"
    out = out + "    mov x16, #4\n"        // SYS_write
    out = out + "    svc #0x80\n"
    out = out + "    // newline\n"
    out = out + "    sub sp, sp, #16\n"
    out = out + "    mov w3, #10\n"        // newline char
    out = out + "    strb w3, [sp]\n"
    out = out + "    mov x0, #1\n"
    out = out + "    mov x1, sp\n"
    out = out + "    mov x2, #1\n"
    out = out + "    mov x16, #4\n"
    out = out + "    svc #0x80\n"
    out = out + "    add sp, sp, #16\n"
    out = out + "    add sp, sp, #32\n"
    out = out + "    ldp x29, x30, [sp], #16\n"
    out = out + "    ret\n"

    return out
}

fn gen_asm_fn(node) {
    let name = node.name
    let mut out = "_" + name + ":\n"
    out = out + "    stp x29, x30, [sp, #-16]!\n"
    out = out + "    mov x29, sp\n"
    // Allocate stack for locals (params + local vars)
    let n_params = len(node.params)
    let stack_size = (n_params + 8) * 8
    out = out + "    sub sp, sp, #" + to_string(stack_size) + "\n"
    // Store params
    let mut pi = 0
    while pi < n_params {
        out = out + "    str x" + to_string(pi) + ", [x29, #-" + to_string((pi+1)*8) + "]\n"
        pi = pi + 1
    }
    // Body
    let mut bi = 0
    while bi < len(node.body) {
        out = out + gen_asm_stmt(node.body[bi], n_params)
        bi = bi + 1
    }
    out = out + "    mov x0, #0\n"  // default return
    out = out + "    add sp, sp, #" + to_string(stack_size) + "\n"
    out = out + "    ldp x29, x30, [sp], #16\n"
    out = out + "    ret\n\n"
    return out
}

fn gen_asm_stmt(node, n_params) {
    let k = node.kind

    if k == "ExprStmt" {
        let expr = node.left
        if type_of(expr) == "string" { return "" }
        if expr.kind == "Call" {
            let callee = expr.left
            if type_of(callee) != "string" && callee.kind == "Ident" && callee.name == "println" {
                if len(expr.args) > 0 {
                    let mut out = gen_asm_expr(expr.args[0], n_params)
                    out = out + "    bl _hexa_print_int\n"
                    return out
                }
            }
            return gen_asm_expr(expr, n_params)
        }
        if expr.kind == "IfExpr" {
            return gen_asm_if(expr, n_params)
        }
        return gen_asm_expr(expr, n_params)
    }

    if k == "ReturnStmt" {
        if type_of(node.left) != "string" {
            let out = gen_asm_expr(node.left, n_params)
            return out + "    add sp, sp, #" + to_string((n_params+8)*8) + "\n    ldp x29, x30, [sp], #16\n    ret\n"
        }
        return "    mov x0, #0\n    add sp, sp, #" + to_string((n_params+8)*8) + "\n    ldp x29, x30, [sp], #16\n    ret\n"
    }

    return "    // " + k + "\n"
}

fn gen_asm_expr(node, n_params) {
    let k = node.kind
    if k == "IntLit" {
        return "    mov x0, #" + node.value + "\n"
    }
    if k == "Ident" {
        // Load from stack (param lookup)
        return "    // load " + node.name + "\n"
    }
    if k == "BinOp" {
        let mut out = gen_asm_expr(node.left, n_params)
        out = out + "    stp x0, xzr, [sp, #-16]!\n"  // push left
        out = out + gen_asm_expr(node.right, n_params)
        out = out + "    ldp x1, xzr, [sp], #16\n"     // pop left into x1
        // x1 = left, x0 = right
        let op = node.op
        if op == "+" { return out + "    add x0, x1, x0\n" }
        if op == "-" { return out + "    sub x0, x1, x0\n" }
        if op == "*" { return out + "    mul x0, x1, x0\n" }
        if op == "/" { return out + "    sdiv x0, x1, x0\n" }
        if op == "<=" {
            return out + "    cmp x1, x0\n    cset x0, le\n"
        }
        if op == "<" {
            return out + "    cmp x1, x0\n    cset x0, lt\n"
        }
        return out
    }
    if k == "Call" {
        let callee = node.left
        if type_of(callee) != "string" && callee.kind == "Ident" {
            let mut out = ""
            // Evaluate args into x0, x1, ...
            let mut ai = 0
            while ai < len(node.args) {
                out = out + gen_asm_expr(node.args[ai], n_params)
                if ai < len(node.args) - 1 {
                    out = out + "    stp x0, xzr, [sp, #-16]!\n"
                }
                ai = ai + 1
            }
            // Pop args into registers (reverse order)
            let mut ri = len(node.args) - 2
            while ri >= 0 {
                out = out + "    mov x" + to_string(ri + 1) + ", x0\n"
                out = out + "    ldp x0, xzr, [sp], #16\n"
                ri = ri - 1
            }
            return out + "    bl _" + callee.name + "\n"
        }
        return ""
    }
    return "    // expr:" + k + "\n"
}

fn gen_asm_if(node, n_params) {
    // Simple if: if cond { return val }
    let mut out = gen_asm_expr(node.cond, n_params)
    out = out + "    cbz x0, 1f\n"
    let mut ti = 0
    while ti < len(node.then_body) {
        out = out + gen_asm_stmt(node.then_body[ti], n_params)
        ti = ti + 1
    }
    out = out + "1:\n"
    return out
}

println("=== HEXA → ARM64 Assembly Generator ===")
