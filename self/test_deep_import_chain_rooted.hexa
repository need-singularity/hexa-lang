// self/test_deep_import_chain_rooted.hexa — ROI #149 regression test (repo-rooted form).
//
// Same as test_deep_import_chain but uses `use "self/..."` prefix form, which
// is the style used by real deployment targets (edge_server, ml drivers, etc.).
//
// The old (stage0 April 14) flatten_imports.hexa resolver only supports
// sibling-name form (`use "chain_mod_f"`) and silently drops path-prefixed uses,
// causing "silent exit" when transitively imported functions are unavailable.
//
// Expected: same output as test_deep_import_chain.

use "self/chain_mod_f"

fn main() {
    println("deep import chain (rooted): begin")
    chain_fn_f()
    println("deep import chain (rooted): end")
}

main()
