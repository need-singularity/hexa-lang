// self/lsp.hexa — HEXA LSP ported from src/lsp.rs

// LSP server for HEXA-LANG.
// Speaks JSON-RPC over stdin/stdout with Content-Length framing.
// Supports: initialize/shutdown/exit, textDocument/didOpen, didChange,
// completion, definition, hover, rename, semanticTokens/full.

// ── JSON Value type ──────────────────────────────────────────

struct JsonValue {
    kind: string,       // "null", "bool", "number", "str", "array", "object"
    bool_val: bool,
    num_val: float,
    str_val: string,
    array_val: [string], // simplified
    obj_keys: [string],
    obj_vals: [string]
}

fn json_null() -> JsonValue {
    return JsonValue { kind: "null", bool_val: false, num_val: 0.0, str_val: "", array_val: [], obj_keys: [], obj_vals: [] }
}

fn json_bool(b: bool) -> JsonValue {
    return JsonValue { kind: "bool", bool_val: b, num_val: 0.0, str_val: "", array_val: [], obj_keys: [], obj_vals: [] }
}

fn json_number(n: float) -> JsonValue {
    return JsonValue { kind: "number", bool_val: false, num_val: n, str_val: "", array_val: [], obj_keys: [], obj_vals: [] }
}

fn json_str(s: string) -> JsonValue {
    return JsonValue { kind: "str", bool_val: false, num_val: 0.0, str_val: s, array_val: [], obj_keys: [], obj_vals: [] }
}

fn json_value_to_json(self: JsonValue) -> string {
    if self.kind == "null" { return "null" }
    if self.kind == "bool" {
        if self.bool_val { return "true" }
        return "false"
    }
    if self.kind == "number" {
        return to_string(self.num_val)
    }
    if self.kind == "str" {
        return "\"" + escape_json_str(self.str_val) + "\""
    }
    return "null"
}

fn escape_json_str(s: string) -> string {
    let out = ""
    let chars = s.chars()
    let total = len(chars)
    let mut i = 0
    while i < total {
        let c = to_string(chars[i])
        if c == "\"" { out = out + "\\\"" }
        else if c == "\\" { out = out + "\\\\" }
        else if c == "\n" { out = out + "\\n" }
        else if c == "\r" { out = out + "\\r" }
        else if c == "\t" { out = out + "\\t" }
        else { out = out + c }
        i = i + 1
    }
    return out
}

