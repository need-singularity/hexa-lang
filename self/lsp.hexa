// ── Message framing ──────────────────────────────────────

fn read_message(input: string) -> string {
    // Parse Content-Length header then read body
    // Simplified: in real impl, reads from stdin BufReader
    return input
}

fn send_message(body: string) -> string {
    let msg = "Content-Length: " + to_string(len(body)) + "\r\n\r\n" + body
    return msg
}

// ── Response builders ──────────────────────────────────────

fn make_response(id: string, result: string) -> string {
    return "{\"jsonrpc\":\"2.0\",\"id\":" + id + ",\"result\":" + result + "}"
}

fn make_notification(method: string, params: string) -> string {
    return "{\"jsonrpc\":\"2.0\",\"method\":\"" + method + "\",\"params\":" + params + "}"
}

