// ── Hover handler ──────────────────────────────────────

fn keyword_doc(kw: string) -> string {
    if kw == "if" { return "Conditional branch: `if cond { ... } else { ... }`" }
    if kw == "fn" { return "Function declaration: `fn name(params) -> Ret { ... }`" }
    if kw == "let" { return "Variable binding: `let name: Type = value`" }
    if kw == "struct" { return "Struct declaration: `struct Name { field: Type, ... }`" }
    if kw == "match" { return "Pattern matching: `match expr { pat => body, ... }`" }
    if kw == "for" { return "Iterator loop: `for x in collection { ... }`" }
    if kw == "while" { return "Conditional loop: `while cond { ... }`" }
    if kw == "return" { return "Return a value from the current function" }
    if kw == "spawn" { return "Spawn concurrent execution: `spawn { ... }`" }
    if kw == "proof" { return "Formal proof block: `proof name { ... }`" }
    if kw == "comptime" { return "Compile-time evaluation: `comptime { ... }`" }
    if kw == "trait" { return "Trait declaration: `trait Name { fn method(...) -> Ret }`" }
    if kw == "impl" { return "Implementation block: `impl Trait for Type { ... }`" }
    if kw == "enum" { return "Enum declaration: `enum Name { Variant, ... }`" }
    if kw == "effect" { return "Declare an algebraic effect: `effect Name { ... }`" }
    return ""
}

fn builtin_doc(name: string) -> string {
    if name == "print" { return "fn print(value: any) — Print value without newline" }
    if name == "println" { return "fn println(value: any) — Print value with newline" }
    if name == "len" { return "fn len(collection: any) -> int — Get collection length" }
    if name == "type_of" { return "fn type_of(value: any) -> string — Get runtime type name" }
    if name == "sigma" { return "fn sigma(n: int) -> int — Sum of divisors" }
    if name == "phi" { return "fn phi(n: int) -> int — Euler's totient function" }
    if name == "tau" { return "fn tau(n: int) -> int — Number of divisors" }
    if name == "sqrt" { return "fn sqrt(x: float) -> float — Square root" }
    if name == "pow" { return "fn pow(base: float, exp: float) -> float — Power" }
    return ""
}

// ── Go-to-definition ──────────────────────────────────────

fn handle_definition(uri: string, source: string, line: int, character: int) -> string {
    let word = word_at_position(source, line, character)
    if word == "" { return "null" }
    // In full impl: look up symbol table and return Location JSON
    return "null"
}

// ── Hover ──────────────────────────────────────────────────

fn handle_hover(source: string, line: int, character: int) -> string {
    let word = word_at_position(source, line, character)
    if word == "" { return "null" }
    // Check keyword docs
    let doc = keyword_doc(word)
    if doc != "" {
        return "{\"contents\":{\"kind\":\"markdown\",\"value\":\"**keyword** `" + word + "`\\n\\n" + doc + "\"}}"
    }
    // Check builtin docs
    let bdoc = builtin_doc(word)
    if bdoc != "" {
        return "{\"contents\":{\"kind\":\"markdown\",\"value\":\"**builtin**\\n\\n```\\n" + bdoc + "\\n```\"}}"
    }
    return "null"
}

