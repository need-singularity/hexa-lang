// ── Hover handler ──────────────────────────────────────

fn keyword_doc(kw: string) -> string {
    if kw == "if" { return "Conditional branch: `if cond { ... } else { ... }`" }
    if kw == "fn" { return "Function declaration: `fn name(params) -> Ret { ... }`" }
    if kw == "let" { return "Variable binding: `let name: Type = value`" }
    if kw == "struct" { return "Struct declaration: `struct Name { field: Type, ... }`" }
    if kw == "match" { return "Pattern matching: `match expr { pat => body, ... }`" }
    if kw == "for" { return "Iterator loop: `for x in collection { ... }`" }
    if kw == "while" { return "Conditional loop: `while cond { ... }`" }
    if kw == "return" { return "Return a value from the current function" }
    if kw == "spawn" { return "Spawn concurrent execution: `spawn { ... }`" }
    if kw == "proof" { return "Formal proof block: `proof name { ... }`" }
    if kw == "comptime" { return "Compile-time evaluation: `comptime { ... }`" }
    if kw == "trait" { return "Trait declaration: `trait Name { fn method(...) -> Ret }`" }
    if kw == "impl" { return "Implementation block: `impl Trait for Type { ... }`" }
    if kw == "enum" { return "Enum declaration: `enum Name { Variant, ... }`" }
    if kw == "effect" { return "Declare an algebraic effect: `effect Name { ... }`" }
    return ""
}

fn builtin_doc(name: string) -> string {
    if name == "print" { return "fn print(value: any) — Print value without newline" }
    if name == "println" { return "fn println(value: any) — Print value with newline" }
    if name == "len" { return "fn len(collection: any) -> int — Get collection length" }
    if name == "type_of" { return "fn type_of(value: any) -> string — Get runtime type name" }
    if name == "sigma" { return "fn sigma(n: int) -> int — Sum of divisors" }
    if name == "phi" { return "fn phi(n: int) -> int — Euler's totient function" }
    if name == "tau" { return "fn tau(n: int) -> int — Number of divisors" }
    if name == "sqrt" { return "fn sqrt(x: float) -> float — Square root" }
    if name == "pow" { return "fn pow(base: float, exp: float) -> float — Power" }
    return ""
}

// ── Go-to-definition ──────────────────────────────────────

fn handle_definition(uri: string, source: string, line: int, character: int) -> string {
    let word = word_at_position(source, line, character)
    if word == "" { return "null" }
    // In full impl: look up symbol table and return Location JSON
    return "null"
}

// ── Hover ──────────────────────────────────────────────────

fn handle_hover(source: string, line: int, character: int) -> string {
    let word = word_at_position(source, line, character)
    if word == "" { return "null" }
    // Check keyword docs
    let doc = keyword_doc(word)
    if doc != "" {
        return "{\"contents\":{\"kind\":\"markdown\",\"value\":\"**keyword** `" + word + "`\\n\\n" + doc + "\"}}"
    }
    // Check builtin docs
    let bdoc = builtin_doc(word)
    if bdoc != "" {
        return "{\"contents\":{\"kind\":\"markdown\",\"value\":\"**builtin**\\n\\n```\\n" + bdoc + "\\n```\"}}"
    }
    return "null"
}

// ── Rename ──────────────────────────────────────────────────

fn handle_rename(uri: string, source: string, line: int, character: int, new_name: string) -> string {
    let word = word_at_position(source, line, character)
    if word == "" { return "null" }
    // In full impl: find all references and return WorkspaceEdit
    return "null"
}

// ── Server capabilities ──────────────────────────────────

fn build_semantic_tokens_legend() -> string {
    let types = get_semantic_token_types()
    let mods = get_semantic_token_modifiers()
    let mut type_parts = []
    for t in types {
        type_parts.push("\"" + t + "\"")
    }
    let mut mod_parts = []
    for m in mods {
        mod_parts.push("\"" + m + "\"")
    }
    return "{\"tokenTypes\":[" + join(type_parts, ",") + "],\"tokenModifiers\":[" + join(mod_parts, ",") + "]}"
}

fn build_capabilities() -> string {
    let legend = build_semantic_tokens_legend()
    return "{" +
        "\"textDocumentSync\":1," +
        "\"completionProvider\":{\"triggerCharacters\":[\".\",\":\",\"@\"]}," +
        "\"hoverProvider\":true," +
        "\"definitionProvider\":true," +
        "\"renameProvider\":true," +
        "\"semanticTokensProvider\":{" +
            "\"legend\":" + legend + "," +
            "\"full\":true" +
        "}" +
    "}"
}

// ── JSON-RPC field extraction (minimal) ──────────────────
// Extract a string value for a given key from a JSON object string.
// Handles simple cases: "key":"value" and "key":number

fn json_get_string(json: string, key: string) -> string {
    let search = "\"" + key + "\":"
    let idx = json.index_of(search)
    if idx < 0 { return "" }
    let after = json.substring(idx + len(search), len(json))
    let trimmed = after.trim()
    if len(trimmed) == 0 { return "" }
    let first_chars = trimmed.chars()
    if to_string(first_chars[0]) == "\"" {
        // String value — find closing quote (skip escapes)
        let mut i = 1
        let mut result_parts = []
        let tlen = len(first_chars)
        while i < tlen {
            let c = first_chars[i]
            if c == '\\' && (i + 1) < tlen {
                result_parts.push(to_string(first_chars[i + 1]))
                i = i + 2
            } else if c == '"' {
                return join(result_parts, "")
            } else {
                result_parts.push(to_string(c))
                i = i + 1
            }
        }
        return join(result_parts, "")
    }
    // Numeric or other — collect until , } or whitespace
    let mut i = 0
    let mut val_parts = []
    let tlen = len(first_chars)
    while i < tlen {
        let c = first_chars[i]
        if c == ',' || c == '}' || c == ' ' || c == '\n' || c == '\r' {
            return join(val_parts, "")
        }
        val_parts.push(to_string(c))
        i = i + 1
    }
    return join(val_parts, "")
}

// ── Document store ──────────────────────────────────────────
// In-memory map of URI -> source text for open documents.

let mut doc_store = #{}

fn store_document(uri: string, text: string) {
    doc_store[uri] = text
}

fn get_document(uri: string) -> string {
    if has_key(doc_store, uri) {
        return doc_store[uri]
    }
    return ""
}

// ── Main LSP loop ──────────────────────────────────────────

fn run_lsp() {
    // Read JSON-RPC messages from stdin, dispatch, write responses to stdout.
    // Content-Length framing per LSP spec.
    let mut running = true
    while running {
        // Read Content-Length header
        let header = readline()
        if header == "" {
            running = false
        } else {
            // Parse Content-Length
            let hdr_trimmed = header.trim()
            if hdr_trimmed.starts_with("Content-Length:") {
                let len_str = hdr_trimmed.substring(15, len(hdr_trimmed)).trim()
                let content_len = to_int(len_str)
                // Skip blank line after headers
                let blank = readline()
                // Read body
                let body = input(content_len)
                // Dispatch
                let method = json_get_string(body, "method")
                let id = json_get_string(body, "id")

                if method == "initialize" {
                    let caps = build_capabilities()
                    let result = "{\"capabilities\":" + caps + ",\"serverInfo\":{\"name\":\"hexa-lsp\",\"version\":\"0.1.0\"}}"
                    let resp = make_response(id, result)
                    print(send_message(resp))
                } else if method == "initialized" {
                    // No response needed
                } else if method == "shutdown" {
                    let resp = make_response(id, "null")
                    print(send_message(resp))
                } else if method == "exit" {
                    running = false
                } else if method == "textDocument/didOpen" {
                    // Extract uri and text from params.textDocument
                    let uri = json_get_string(body, "uri")
                    let text = json_get_string(body, "text")
                    store_document(uri, text)
                    // Publish diagnostics
                    let diags = diagnose(text)
                    let notif = make_notification("textDocument/publishDiagnostics", "{\"uri\":\"" + escape_json_str(uri) + "\",\"diagnostics\":[]}")
                    print(send_message(notif))
                } else if method == "textDocument/didChange" {
                    let uri = json_get_string(body, "uri")
                    let text = json_get_string(body, "text")
                    if text != "" {
                        store_document(uri, text)
                    }
                } else if method == "textDocument/hover" {
                    let uri = json_get_string(body, "uri")
                    let source = get_document(uri)
                    let line_str = json_get_string(body, "line")
                    let char_str = json_get_string(body, "character")
                    let result = handle_hover(source, to_int(line_str), to_int(char_str))
                    let resp = make_response(id, result)
                    print(send_message(resp))
                } else if method == "textDocument/definition" {
                    let uri = json_get_string(body, "uri")
                    let source = get_document(uri)
                    let line_str = json_get_string(body, "line")
                    let char_str = json_get_string(body, "character")
                    let result = handle_definition(uri, source, to_int(line_str), to_int(char_str))
                    let resp = make_response(id, result)
                    print(send_message(resp))
                } else if method == "textDocument/semanticTokens/full" {
                    let uri = json_get_string(body, "uri")
                    let source = get_document(uri)
                    let result = handle_semantic_tokens_full(source)
                    let resp = make_response(id, result)
                    print(send_message(resp))
                } else {
                    // Unknown method — if it has an id, respond with method-not-found
                    if id != "" {
                        let resp = make_response(id, "null")
                        print(send_message(resp))
                    }
                }
            }
        }
    }
}

// ── Script entry ──────────────────────────────────────────
// When this file is executed by stage0 (e.g. `hexa lsp` forwards to
// `build/hexa_stage0 self/lsp.hexa`), enter the LSP loop immediately.
// Safe to top-level since run_lsp() reads stdin and returns only on EOF/exit.
run_lsp()
