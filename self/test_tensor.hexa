// ─────────────────────────────────────────────────────
// Section 1: Native builtins (tensor, tensor_zeros, tensor_fill)
// ─────────────────────────────────────────────────────
println("")
println("-- 1. Native Creation --")

let t1 = tensor([1.0, 2.0, 3.0])
check("tensor([1,2,3]) type", type_of(t1), "tensor")
check("tensor([1,2,3]) len", len(t1), 3)
check_approx("tensor([1,2,3])[0]", t1[0], 1.0, 0.001)
check_approx("tensor([1,2,3])[2]", t1[2], 3.0, 0.001)

let tz = tensor_zeros(5)
check("tensor_zeros(5) type", type_of(tz), "tensor")
check("tensor_zeros(5) len", len(tz), 5)
check_approx("tensor_zeros(5)[0]", tz[0], 0.0, 0.001)

let tf = tensor_fill(4, 7.5)
check("tensor_fill(4,7.5) type", type_of(tf), "tensor")
check_approx("tensor_fill(4,7.5)[3]", tf[3], 7.5, 0.001)

// Negative indexing
check_approx("tensor[-1]", t1[-1], 3.0, 0.001)
check_approx("tensor[-2]", t1[-2], 2.0, 0.001)

// ─────────────────────────────────────────────────────
// Section 2: Accessors
// ─────────────────────────────────────────────────────
println("")
println("-- 2. Accessors --")

let sh = tensor_shape(t1)
check("tensor_shape len", len(sh), 1)
check("tensor_shape[0]", sh[0], 3)

let data = tensor_data(t1)
check("tensor_data type", type_of(data), "array")
check("tensor_data len", len(data), 3)
check_approx("tensor_data[0]", data[0], 1.0, 0.001)

check("tensor_size", tensor_size(t1), 3)

// ─────────────────────────────────────────────────────
// Section 3: Creation helpers
// ─────────────────────────────────────────────────────
println("")
println("-- 3. Creation Helpers --")

let to = tensor_ones(4)
check("tensor_ones type", type_of(to), "tensor")
check("tensor_ones len", len(to), 4)
check_approx("tensor_ones[0]", to[0], 1.0, 0.001)
check_approx("tensor_ones[3]", to[3], 1.0, 0.001)

let tzl = tensor_zeros_like(t1)
check("zeros_like type", type_of(tzl), "tensor")
check("zeros_like len", len(tzl), 3)
check_approx("zeros_like[0]", tzl[0], 0.0, 0.001)

let tol = tensor_ones_like(tf)
check("ones_like len", len(tol), 4)
check_approx("ones_like[0]", tol[0], 1.0, 0.001)

let tc = tensor_clone(t1)
check("clone type", type_of(tc), "tensor")
check_approx("clone[0]", tc[0], 1.0, 0.001)
check_approx("clone[2]", tc[2], 3.0, 0.001)

fn _double_idx(i) { return i * 2.0 }
let tff = tensor_from_fn(5, _double_idx)
check("from_fn type", type_of(tff), "tensor")
check("from_fn len", len(tff), 5)
check_approx("from_fn[0]", tff[0], 0.0, 0.001)
check_approx("from_fn[3]", tff[3], 6.0, 0.001)

// ─────────────────────────────────────────────────────
// Section 4: Arithmetic
// ─────────────────────────────────────────────────────
println("")
println("-- 4. Arithmetic --")

let a = tensor([1.0, 2.0, 3.0])
let b = tensor([4.0, 5.0, 6.0])

let add_r = tensor_add(a, b)
check("add type", type_of(add_r), "tensor")
check_approx("add[0]", add_r[0], 5.0, 0.001)
check_approx("add[2]", add_r[2], 9.0, 0.001)

let sub_r = tensor_sub(b, a)
check("sub type", type_of(sub_r), "tensor")
check_approx("sub[0]", sub_r[0], 3.0, 0.001)
check_approx("sub[2]", sub_r[2], 3.0, 0.001)

let mul_r = tensor_mul(a, b)
check("mul type", type_of(mul_r), "tensor")
check_approx("mul[0]", mul_r[0], 4.0, 0.001)
check_approx("mul[1]", mul_r[1], 10.0, 0.001)
