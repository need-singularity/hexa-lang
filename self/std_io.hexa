// self/std_io.hexa — HEXA IO ported from src/std_io.rs
//
// Provides:
//   io_stdin()                    — read one line from stdin
//   io_read_lines(path)           — read file as array of lines
//   io_write_bytes(path, bytes)   — write byte array to file
//   io_pipe(cmd)                  — run shell command, capture output
//   io_tempfile()                 — create temp file, return path
//   io_buffered_reader(path)      — open buffered reader handle
//   io_reader_next(reader)        — read next line (void when EOF)

// Global reader counter
let _io_next_reader_id = 1
let _io_readers = []

// -- io_stdin() -> string --

fn io_stdin() -> string {
    // Reads one line from standard input
    // In self-hosted mode, delegates to builtin
    return __builtin_io_stdin()
}

// -- io_read_lines(path) -> [string] --

fn io_read_lines(path) -> [string] {
    let content = fs_read(path)
    return string_split(content, "\n")
}

// -- io_write_bytes(path, bytes) --

fn io_write_bytes(path, bytes) {
    // Convert byte array to string and write
    let s = ""
    let i = 0
    while i < len(bytes) {
        s = s + chr(bytes[i])
        i = i + 1
    }
    fs_write(path, s)
}

// -- io_pipe(cmd) -> string --

fn io_pipe(cmd) -> string {
    // Execute shell command and capture output
    return __builtin_io_pipe(cmd)
}

// -- io_tempfile() -> string --

fn io_tempfile() -> string {
    let id = _io_next_reader_id
    _io_next_reader_id = _io_next_reader_id + 1
    let path = "/tmp/hexa_tmp_" + to_string(id)
    fs_write(path, "")
    return path
}

// -- Buffered reader --

struct BufferedReader {
    id: int,
    path: string,
    lines: [string],
    pos: int
}

fn io_buffered_reader(path) -> BufferedReader {
    let id = _io_next_reader_id
    _io_next_reader_id = _io_next_reader_id + 1
    let content = fs_read(path)
    let lines = string_split(content, "\n")
    let reader = BufferedReader {
        id: id,
        path: path,
        lines: lines,
        pos: 0
    }
    return reader
}

fn io_reader_next(reader) {
    if reader.pos >= len(reader.lines) {
        return void
    }
    let line = reader.lines[reader.pos]
    reader.pos = reader.pos + 1
    return line
}
