// ═══════════════════════════════════════════════════════════════
//  test_dynamic_ntk_rope.hexa — Dynamic NTK RoPE verification (#136)
//
//  Tests (35):
//    T1  base_freqs correct length
//    T2  base_freqs monotonically decreasing
//    T3  base_freqs first element close to 1.0
//    T4  rope_embed correct length
//    T5  rope_embed cos^2 + sin^2 = 1
//    T6  rope_apply preserves norm (rotation)
//    T7  rope_apply at pos=0 is identity-like
//    T8  linear_freqs smaller than base (scale > 1)
//    T9  linear_freqs equal to base at scale=1
//    T10 ntk_base larger than original base
//    T11 ntk_freqs high-freq preserved better than linear
//    T12 dynamic_alpha = 1 when seq_len <= max
//    T13 dynamic_alpha > 1 when seq_len > max
//    T14 dynamic_freqs = base_freqs when within range
//    T15 dynamic_freqs differ when seq exceeds max
//    T16 dynamic_embed works at pos 0
//    T17 yarn_wavelength increases with dimension index
//    T18 yarn_ramp returns 0 for low wavelength
//    T19 yarn_ramp returns 1 for high wavelength
//    T20 yarn_freqs blend between base and ntk
//    T21 yarn_attn_scale = 1 for scale <= 1
//    T22 yarn_attn_scale > 1 for large scale
//    T23 length_scale = 1 within trained range
//    T24 length_scale > 1 beyond trained range
//    T25 apply_length_scale divides scores
//    T26 freq_adjust multiplies correctly
//    T27 band_adjust applies different scales
//    T28 progressive_scale = 1 at step 0
//    T29 progressive_scale = target at end
//    T30 progressive_scale midpoint correct
//    T31 progressive_freqs = base at step 0
//    T32 compare_methods returns 5 values
//    T33 compare_methods base distortion = 0
//    T34 dot product correctness
//    T35 orthogonality after rotation at different positions
//
//  Run: cargo run --release -- self/test_dynamic_ntk_rope.hexa
// ═══════════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx(a, b, eps) { return fabs(a - b) < eps }

// ── inlined math helpers from dynamic_ntk_rope.hexa ────────────

fn ntk_abs(x) {
    if x < 0.0 { return 0.0 - x }
    return x
}

fn ntk_sqrt(x) {
    if x <= 0.0 { return 0.0 }
    let mut g = x / 2.0
    if g < 1.0 { g = 1.0 }
    let mut _i = 0

    while _i < 40 {
        g = (g + x / g) / 2.0
    }
    return g
}

fn ntk_exp(x) {
    let mut v = x
    if v > 20.0 { v = 20.0 }
    if v < -20.0 { v = -20.0 }
    let mut result = 1.0
    let mut term = 1.0
    let mut i = 1

    while i < 35 {
        term = term * v / to_float(i)
        result = result + term
    }
    if result < 0.0 { return 0.0 }
    return result
}

fn ntk_log(x) {
    if x <= 0.0 { return -20.0 }
    let mut y = 0.0
    if x > 1.0 { y = 1.0 }
    if x > 10.0 { y = 2.3 }
    if x > 100.0 { y = 4.6 }
    if x > 1000.0 { y = 6.9 }
    if x > 10000.0 { y = 9.2 }
    if x < 1.0 { y = -1.0 }
    if x < 0.1 { y = -2.3 }
    if x < 0.01 { y = -4.6 }
    let mut _i = 0

    while _i < 50 {
        let ey = ntk_exp(y)
        if ey < 1.0e-15 { y = y + 1.0 } else {
            y = y - (ey - x) / ey
        }
    }
    return y
}

fn ntk_pow(base, exp_val) {
    if base <= 0.0 { return 0.0 }
    return ntk_exp(exp_val * ntk_log(base))
}

fn ntk_sin(x) {
    let pi = 3.141592653589793
    let mut v = x
    let mut _i = 0

    while _i < 20 {
        if v > pi { v = v - 2.0 * pi }
        if v < 0.0 - pi { v = v + 2.0 * pi }
    }
    let mut result = 0.0
    let mut term = v
    let mut i = 0

    while i < 15 {
        result = result + term
        let n = 2 * i + 2
        term = 0.0 - term * v * v / to_float(n * (n + 1))
    }
    return result
}

fn ntk_cos(x) {
    let pi = 3.141592653589793
    let mut v = x
    let mut _i = 0

    while _i < 20 {
        if v > pi { v = v - 2.0 * pi }
        if v < 0.0 - pi { v = v + 2.0 * pi }
    }
    let mut result = 0.0
    let mut term = 1.0
    let mut i = 0

    while i < 15 {
        result = result + term
        let n = 2 * i + 1
        term = 0.0 - term * v * v / to_float(n * (n + 1))
    }
    return result
}

fn ntk_zeros(n) {
    let mut v = []
    let mut _i = 0

    while _i < n { v = v + [0.0] }
    return v
}

fn ntk_min_f(a, b) {
    if a < b { return a }
    return b
}

fn ntk_max_f(a, b) {
    if a > b { return a }
    return b
}

// ── inlined core functions from dynamic_ntk_rope.hexa ──────────

fn rope_base_freqs(dim, base) {
    let half = dim / 2
    let mut freqs = ntk_zeros(half)
    let mut i = 0

    while i < half {
        let exponent = 2.0 * to_float(i) / to_float(dim)
        freqs[i] = 1.0 / ntk_pow(base, exponent)
    }
    return freqs
}

fn rope_embed(pos, freqs) {
    let half = len(freqs)
    let dim = half * 2
    let mut out = ntk_zeros(dim)
    let p = to_float(pos)
    let mut i = 0

    while i < half {
        let angle = p * freqs[i]
        out[2 * i] = ntk_cos(angle)
        out[2 * i + 1] = ntk_sin(angle)
    }
    return out
}

fn rope_apply(x, cos_sin) {
    let half = len(x) / 2
    let mut out = ntk_zeros(len(x))
    let mut i = 0

    while i < half {
        let c = cos_sin[2 * i]
        let s = cos_sin[2 * i + 1]
        let x0 = x[2 * i]
        let x1 = x[2 * i + 1]
        out[2 * i] = x0 * c - x1 * s
        out[2 * i + 1] = x0 * s + x1 * c
    }
    return out
}

fn rope_linear_freqs(dim, base, scale_factor) {
    let raw = rope_base_freqs(dim, base)
    let half = len(raw)
    let mut freqs = ntk_zeros(half)
    let mut i = 0

    while i < half {
        freqs[i] = raw[i] / scale_factor
    }
    return freqs
}

fn rope_ntk_base(base, alpha, dim) {
    let exponent = to_float(dim) / (to_float(dim) - 2.0)
    return base * ntk_pow(alpha, exponent)
}

fn rope_ntk_freqs(dim, base, alpha) {
    let new_base = rope_ntk_base(base, alpha, dim)
    return rope_base_freqs(dim, new_base)
}

fn rope_dynamic_alpha(seq_len, max_trained_len) {
    if seq_len <= max_trained_len { return 1.0 }
    return to_float(seq_len) / to_float(max_trained_len)
}

fn rope_dynamic_freqs(dim, base, seq_len, max_trained_len) {
    let alpha = rope_dynamic_alpha(seq_len, max_trained_len)
    if alpha <= 1.0 {
        return rope_base_freqs(dim, base)
    }
    return rope_ntk_freqs(dim, base, alpha)
}

fn rope_dynamic_embed(pos, dim, base, max_trained_len) {
    let alpha = rope_dynamic_alpha(pos + 1, max_trained_len)
    let freqs = rope_dynamic_freqs(dim, base, pos + 1, max_trained_len)
    return rope_embed(pos, freqs)
}

fn yarn_wavelength(dim, base, i) {
    let pi = 3.141592653589793
    let exponent = 2.0 * to_float(i) / to_float(dim)
    let theta = 1.0 / ntk_pow(base, exponent)
    if theta < 1.0e-15 { return 1.0e15 }
    return 2.0 * pi / theta
}

fn yarn_ramp(wavelength, beta_fast, beta_slow, max_len) {
    let low = to_float(max_len) / to_float(beta_fast)
    let high = to_float(max_len) / to_float(beta_slow)
    if high <= low { return 1.0 }
    let r = (wavelength - low) / (high - low)
    if r < 0.0 { return 0.0 }
    if r > 1.0 { return 1.0 }
    return r
}

fn yarn_freqs(dim, base, alpha, beta_fast, beta_slow, max_len) {
    let base_f = rope_base_freqs(dim, base)
    let ntk_f = rope_ntk_freqs(dim, base, alpha)
    let half = len(base_f)
    let mut freqs = ntk_zeros(half)
    let mut i = 0

    while i < half {
        let wl = yarn_wavelength(dim, base, i)
        let r = yarn_ramp(wl, beta_fast, beta_slow, max_len)
        freqs[i] = (1.0 - r) * ntk_f[i] + r * base_f[i]
    }
    return freqs
}

fn yarn_attn_scale(scale_factor) {
    if scale_factor <= 1.0 { return 1.0 }
    return ntk_sqrt(1.0 + 0.1 * ntk_log(scale_factor))
}

fn rope_length_scale(seq_len, max_trained_len) {
    if seq_len <= max_trained_len { return 1.0 }
    let ratio = to_float(seq_len) / to_float(max_trained_len)
    return ntk_sqrt(ratio)
}

fn rope_apply_length_scale(scores, temp) {
    let n = len(scores)
    let mut out = ntk_zeros(n)
    let mut i = 0

    while i < n {
        out[i] = scores[i] / temp
    }
    return out
}

fn rope_freq_adjust(freqs, adjustments) {
    let n = len(freqs)
    let mut out = ntk_zeros(n)
    let mut i = 0

    while i < n {
        out[i] = freqs[i] * adjustments[i]
    }
    return out
}

fn rope_band_adjust(freqs, split_idx, low_scale, high_scale) {
    let n = len(freqs)
    let mut out = ntk_zeros(n)
    let mut i = 0

    while i < n {
        if i < split_idx {
            out[i] = freqs[i] * low_scale
        } else {
            out[i] = freqs[i] * high_scale
        }
    }
    return out
}

fn rope_progressive_scale(step, warmup_steps, target_scale) {
    if step >= warmup_steps { return target_scale }
    if warmup_steps <= 0 { return target_scale }
    let progress = to_float(step) / to_float(warmup_steps)
    return 1.0 + progress * (target_scale - 1.0)
}

fn rope_progressive_freqs(dim, base, step, warmup_steps, target_scale) {
    let scale = rope_progressive_scale(step, warmup_steps, target_scale)
    if scale <= 1.0 { return rope_base_freqs(dim, base) }
    return rope_ntk_freqs(dim, base, scale)
}

fn rope_freq_distortion(method_freqs, base_freqs) {
    let n = len(method_freqs)
    let mut mse = 0.0
    let mut i = 0

    while i < n {
        let diff = method_freqs[i] - base_freqs[i]
        mse = mse + diff * diff
    }
    return mse / to_float(n)
}

fn rope_compare_methods(dim, base, seq_len, max_trained_len) {
    let base_f = rope_base_freqs(dim, base)
    let scale = to_float(seq_len) / to_float(max_trained_len)
    let alpha = ntk_max_f(scale, 1.0)
    let d_base = 0.0
    let linear_f = rope_linear_freqs(dim, base, ntk_max_f(scale, 1.0))
    let d_linear = rope_freq_distortion(linear_f, base_f)
    let ntk_f = rope_ntk_freqs(dim, base, alpha)
    let d_ntk = rope_freq_distortion(ntk_f, base_f)
    let dyn_f = rope_dynamic_freqs(dim, base, seq_len, max_trained_len)
    let d_dyn = rope_freq_distortion(dyn_f, base_f)
    let yarn_f = yarn_freqs(dim, base, alpha, 32, 1, max_trained_len)
    let d_yarn = rope_freq_distortion(yarn_f, base_f)
    return [d_base, d_linear, d_ntk, d_dyn, d_yarn]
}

fn rope_dot(a, b) {
    let n = len(a)
    let mut s = 0.0
    let mut i = 0

    while i < n {
        s = s + a[i] * b[i]
    }
    return s
}

fn rope_norm(v) {
    return ntk_sqrt(rope_dot(v, v))
}

// ═══════════════════════════════════════════════════════════════
//  TESTS
// ═══════════════════════════════════════════════════════════════

let DIM = 16
let BASE = 10000.0
let MAX_LEN = 2048

// ── 1. Base RoPE ──────────────────────────────────────────────

// T1: base_freqs correct length
let bf = rope_base_freqs(DIM, BASE)
check("T1 base_freqs length = dim/2", len(bf) == DIM / 2)

// T2: base_freqs monotonically decreasing
let mut mono = true
let mut i = 1

while i < len(bf) {
    if bf[i] >= bf[i - 1] { mono = false }
}
check("T2 base_freqs monotonically decreasing", mono)

// T3: base_freqs first element close to 1.0
check("T3 base_freqs[0] close to 1.0", fabs(bf[0] - 1.0) < 0.01)

// T4: rope_embed correct length
let emb = rope_embed(10, bf)
check("T4 rope_embed length = dim", len(emb) == DIM)

// T5: rope_embed cos^2 + sin^2 = 1 for each pair
let mut cs_ok = true
let mut i = 0

while i < (DIM / 2) {
    let c = emb[2 * i]
    let s = emb[2 * i + 1]
    if fabs(c * c + s * s - 1.0) > 0.01 { cs_ok = false }
}
check("T5 cos^2 + sin^2 = 1 for all pairs", cs_ok)

// T6: rope_apply preserves norm (rotation is norm-preserving)
let test_vec = [1.0, 0.0, 0.5, 0.5, 0.3, 0.7, 0.2, 0.8, 1.0, 0.0, 0.5, 0.5, 0.3, 0.7, 0.2, 0.8]
let rot_vec = rope_apply(test_vec, emb)
let norm_before = rope_norm(test_vec)
let norm_after = rope_norm(rot_vec)
check("T6 rotation preserves norm", fabs(norm_before - norm_after) < 0.01)

// T7: rope_apply at pos=0 is identity-like (cos=1, sin=0)
let emb0 = rope_embed(0, bf)
let rot0 = rope_apply(test_vec, emb0)
let mut id_ok = true
let mut i = 0

while i < DIM {
    if fabs(rot0[i] - test_vec[i]) > 0.01 { id_ok = false }
}
check("T7 rotation at pos=0 is identity", id_ok)

// ── 2. Linear Interpolation ──────────────────────────────────

// T8: linear_freqs smaller than base when scale > 1
let lf = rope_linear_freqs(DIM, BASE, 4.0)
let mut lin_smaller = true
let mut i = 0

while i < len(lf) {
    if lf[i] > bf[i] + 0.001 { lin_smaller = false }
}
check("T8 linear_freqs <= base_freqs (scale=4)", lin_smaller)

// T9: linear_freqs equal to base at scale=1
let lf1 = rope_linear_freqs(DIM, BASE, 1.0)
let mut lin_eq = true
let mut i = 0

while i < len(lf1) {
    if fabs(lf1[i] - bf[i]) > 0.001 { lin_eq = false }
}
check("T9 linear_freqs = base_freqs at scale=1", lin_eq)

// ── 3. NTK-aware Interpolation ────────────────────────────────

// T10: ntk_base larger than original base
let nb = rope_ntk_base(BASE, 4.0, DIM)
check("T10 ntk_base > original base", nb > BASE)

// T11: NTK preserves high-freq better than linear
// High freq = first element (index 0), should be closer to base
let nf = rope_ntk_freqs(DIM, BASE, 4.0)
let diff_ntk_0 = fabs(nf[0] - bf[0])
let diff_lin_0 = fabs(lf[0] - bf[0])
check("T11 NTK high-freq closer to base than linear", diff_ntk_0 < diff_lin_0)

// ── 4. Dynamic NTK ────────────────────────────────────────────

// T12: dynamic_alpha = 1 when seq_len <= max
let alpha_in = rope_dynamic_alpha(1024, MAX_LEN)
check("T12 dynamic_alpha=1 within range", fabs(alpha_in - 1.0) < 0.001)

// T13: dynamic_alpha > 1 when seq_len > max
let alpha_out = rope_dynamic_alpha(4096, MAX_LEN)
check("T13 dynamic_alpha > 1 beyond range", alpha_out > 1.0)

// T14: dynamic_freqs = base_freqs within range
let df_in = rope_dynamic_freqs(DIM, BASE, 1024, MAX_LEN)
let mut dyn_eq = true
let mut i = 0

while i < len(df_in) {
    if fabs(df_in[i] - bf[i]) > 0.001 { dyn_eq = false }
}
check("T14 dynamic_freqs = base_freqs within range", dyn_eq)

// T15: dynamic_freqs differ when seq exceeds max
let df_out = rope_dynamic_freqs(DIM, BASE, 8192, MAX_LEN)
let mut dyn_diff = false
let mut i = 0

while i < len(df_out) {
    if fabs(df_out[i] - bf[i]) > 0.001 { dyn_diff = true }
}
check("T15 dynamic_freqs differ beyond range", dyn_diff)

// T16: dynamic_embed works at pos 0
let de0 = rope_dynamic_embed(0, DIM, BASE, MAX_LEN)
check("T16 dynamic_embed at pos=0 length correct", len(de0) == DIM)

// ── 5. YaRN ──────────────────────────────────────────────────

// T17: yarn_wavelength increases with dimension index
let wl0 = yarn_wavelength(DIM, BASE, 0)
let wl3 = yarn_wavelength(DIM, BASE, 3)
check("T17 wavelength increases with dim index", wl3 > wl0)

// T18: yarn_ramp returns 0 for very low wavelength
let r_low = yarn_ramp(0.1, 32, 1, MAX_LEN)
check("T18 yarn_ramp = 0 for low wavelength", fabs(r_low) < 0.01)

// T19: yarn_ramp returns 1 for very high wavelength
let r_high = yarn_ramp(100000.0, 32, 1, MAX_LEN)
check("T19 yarn_ramp = 1 for high wavelength", fabs(r_high - 1.0) < 0.01)

// T20: yarn_freqs are between base and NTK
let yf = yarn_freqs(DIM, BASE, 4.0, 32, 1, MAX_LEN)
let mut yarn_between = true
let mut i = 0

while i < len(yf) {
    let lo = ntk_min_f(bf[i], nf[i])
    let hi = ntk_max_f(bf[i], nf[i])
    if yf[i] < lo - 0.01 { yarn_between = false }
    if yf[i] > hi + 0.01 { yarn_between = false }
}
check("T20 yarn_freqs between base and NTK", yarn_between)

// T21: yarn_attn_scale = 1 for scale <= 1
let yas1 = yarn_attn_scale(1.0)
check("T21 yarn_attn_scale=1 for scale=1", fabs(yas1 - 1.0) < 0.001)

// T22: yarn_attn_scale > 1 for large scale
let yas4 = yarn_attn_scale(4.0)
check("T22 yarn_attn_scale > 1 for scale=4", yas4 > 1.0)

// ── 6. Length Scaling ─────────────────────────────────────────

// T23: length_scale = 1 within trained range
let ls_in = rope_length_scale(1024, MAX_LEN)
check("T23 length_scale=1 within range", fabs(ls_in - 1.0) < 0.001)

// T24: length_scale > 1 beyond trained range
let ls_out = rope_length_scale(8192, MAX_LEN)
check("T24 length_scale > 1 beyond range", ls_out > 1.0)

// T25: apply_length_scale divides scores correctly
let scores = [4.0, 8.0, 2.0, 6.0]
let scaled = rope_apply_length_scale(scores, 2.0)
check("T25 length_scale divides scores", fabs(scaled[0] - 2.0) < 0.01)

// ── 7. Frequency Adjustment ──────────────────────────────────

// T26: freq_adjust multiplies correctly
let adj = [2.0, 0.5, 1.0, 3.0, 1.0, 0.5, 2.0, 1.0]
let adjusted = rope_freq_adjust(bf, adj)
check("T26 freq_adjust[0] = 2x base", fabs(adjusted[0] - bf[0] * 2.0) < 0.001)

// T27: band_adjust applies different scales to bands
let band_adj = rope_band_adjust(bf, 4, 2.0, 0.5)
let mut band_ok = true
let mut i = 0

while i < 4 {
    if fabs(band_adj[i] - bf[i] * 2.0) > 0.001 { band_ok = false }
}
let mut i = 4

while i < len(bf) {
    if fabs(band_adj[i] - bf[i] * 0.5) > 0.001 { band_ok = false }
}
check("T27 band_adjust low=2x high=0.5x", band_ok)

// ── 8. Progressive Extension ──────────────────────────────────

// T28: progressive_scale = 1 at step 0
let ps0 = rope_progressive_scale(0, 1000, 4.0)
check("T28 progressive_scale=1 at step=0", fabs(ps0 - 1.0) < 0.001)

// T29: progressive_scale = target at end
let ps_end = rope_progressive_scale(1000, 1000, 4.0)
check("T29 progressive_scale=target at warmup end", fabs(ps_end - 4.0) < 0.001)

// T30: progressive_scale at midpoint
let ps_mid = rope_progressive_scale(500, 1000, 4.0)
check("T30 progressive_scale midpoint=2.5", fabs(ps_mid - 2.5) < 0.01)

// T31: progressive_freqs = base at step 0
let pf0 = rope_progressive_freqs(DIM, BASE, 0, 1000, 4.0)
let mut prog_eq = true
let mut i = 0

while i < len(pf0) {
    if fabs(pf0[i] - bf[i]) > 0.001 { prog_eq = false }
}
check("T31 progressive_freqs = base at step=0", prog_eq)

// ── 9. Comparison Utility ─────────────────────────────────────

// T32: compare_methods returns 5 values
let cmp = rope_compare_methods(DIM, BASE, 8192, MAX_LEN)
check("T32 compare_methods returns 5 values", len(cmp) == 5)

// T33: compare_methods base distortion = 0
check("T33 base distortion = 0", fabs(cmp[0]) < 0.0001)

// ── Extra: dot product and rotation ───────────────────────────

// T34: dot product correctness
let va = [1.0, 2.0, 3.0, 4.0]
let vb = [2.0, 0.0, 1.0, 0.5]
let dp = rope_dot(va, vb)
check("T34 dot product = 7.0", fabs(dp - 7.0) < 0.01)

// T35: rotation decorrelates at different positions
// Two vectors rotated at different positions should have lower dot product
let emb5 = rope_embed(5, bf)
let emb50 = rope_embed(50, bf)
let r5 = rope_apply(test_vec, emb5)
let r50 = rope_apply(test_vec, emb50)
let dp_same = rope_dot(r5, r5)
let dp_diff = fabs(rope_dot(r5, r50))
check("T35 different pos rotations decorrelate", dp_diff < dp_same)

// ═══════════════════════════════════════════════════════════════
println("")
println("=== dynamic_ntk_rope test summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
