// ═══════════════════════════════════════════════════════════
//  test_zeta_bench.hexa — zeta_bench 4축 검증 (mock 모델)
//  Validates throughput / p50p99 latency / perplexity / phi
//  Appends result to bench/zeta_compare.jsonl
// ═══════════════════════════════════════════════════════════

use "self/stdlib/law_io"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

// ── inlined from self/ml/zeta_bench.hexa ─────────────────

fn zb_abs(x) {
    if x < 0 { return 0 - x }
    return x
}

fn zb_floor_int(x) {
    let mut i = 0
    while (i + 1) <= x { i = i + 1 }
    return i
}

fn zb_sort(arr) {
    let mut a = []
    let mut i = 0
    while i < len(arr) { a.push(arr[i]); i = i + 1 }
    let n = len(a)
    let mut ii = 0
    while ii < n {
        let mut jj = ii + 1
        while jj < n {
            if a[jj] < a[ii] {
                let t = a[ii]
                a[ii] = a[jj]
                a[jj] = t
            }
            jj = jj + 1
        }
        ii = ii + 1
    }
    return a
        i = i + 1
}

fn zb_percentile(sorted_arr, p) {
    let n = len(sorted_arr)
    if n == 0 { return 0 }
    let mut idx = zb_floor_int(p * n)
    if idx >= n { idx = n - 1 }
    if idx < 0 { idx = 0 }
    return sorted_arr[idx]
}

fn zb_mean(arr) {
    let n = len(arr)
    if n == 0 { return 0 }
    let mut s = 0
    let mut i = 0
    while i < n { s = s + arr[i]; i = i + 1 }
    return s / n
        i = i + 1
}

fn zb_ln(x) {
    if x <= 0 { return 0 - 1000000 }
    let y = (x - 1) / (x + 1)
    let y2 = y * y
    let mut term = y
    let mut sum = 0
    let mut k = 0
    while k < 8 {
        let denom = 2 * k + 1
        sum = sum + term / denom
        term = term * y2
        k = k + 1
    }
    return 2 * sum
}

fn zb_exp_small(x) {
    let mut sum = 1
    let mut term = 1
    let mut k = 1
    while k < 14 {
        term = term * x / k
        sum = sum + term
        k = k + 1
    }
    return sum
}

fn zb_config(name_hexa, name_ref, warmup, iters) {
    let mut c = []
    c.push(name_hexa)
    c.push(name_ref)
    c.push(warmup)
    c.push(iters)
    return c
}

fn zb_phi_metric(state_series) {
    let n = len(state_series)
    if n < 2 { return 0 }
    let mut means = []
    let mut i = 0
    while i < n {
        means.push(zb_mean(state_series[i]))
        i = i + 1
    }
    let mut deltas = []
    i = 1
    while i < n {
        deltas.push(zb_abs(means[i] - means[i - 1]))
        i = i + 1
    }
    let d_mean = zb_mean(deltas)
    let mu = zb_mean(means)
    let mut vs = 0
    i = 0
    while i < n {
        let dv = means[i] - mu
        vs = vs + dv * dv
        i = i + 1
    }
    let varv = vs / n
    return d_mean * zb_ln(1 + varv)
}

fn zb_run(cfg, model_fn, ref_logprob_fn) {
    let warmup = cfg[2]
    let iters = cfg[3]

    let mut w = 0
    while w < warmup {
        let _ = model_fn(w)
        w = w + 1
    }

    let mut latencies_ms = []
    let mut logp_sum = 0
    let mut ref_logp_sum = 0
    let mut tokens = 0
    let mut states = []

    let t0 = clock()
    let mut step = 0
    while step < iters {
        let s0 = clock()
        let out = model_fn(step)
        let s1 = clock()
        latencies_ms.push((s1 - s0) * 1000)
        logp_sum = logp_sum + out[0]
        states.push(out[2])
        ref_logp_sum = ref_logp_sum + ref_logprob_fn(step)
        tokens = tokens + 1
        step = step + 1
    }
    let t1 = clock()
    let wall_s = t1 - t0
    let mut throughput = 0
    if wall_s > 0 { throughput = tokens / wall_s }

    let sorted_lat = zb_sort(latencies_ms)
    let p50 = zb_percentile(sorted_lat, 0.50)
    let p99 = zb_percentile(sorted_lat, 0.99)

    let mean_lp = logp_sum / tokens
    let ppl = zb_exp_small(0 - mean_lp)
    let mean_ref = ref_logp_sum / tokens
    let ppl_ref = zb_exp_small(0 - mean_ref)
    let phi = zb_phi_metric(states)

    // Return parallel arrays: keys (strings) + vals (stringified)
    let mut keys = []
    let mut vals = []
    keys.push("hexa_name");        vals.push(str(cfg[0]))
    keys.push("ref_name");         vals.push(str(cfg[1]))
    keys.push("warmup");           vals.push(str(warmup))
    keys.push("iters");            vals.push(str(iters))
    keys.push("tokens");           vals.push(str(tokens))
    keys.push("wall_s");           vals.push(str(wall_s))
    keys.push("throughput_tok_s"); vals.push(str(throughput))
    keys.push("latency_p50_ms");   vals.push(str(p50))
    keys.push("latency_p99_ms");   vals.push(str(p99))
    keys.push("mean_logprob");     vals.push(str(mean_lp))
    keys.push("perplexity");       vals.push(str(ppl))
    keys.push("ref_mean_logprob"); vals.push(str(mean_ref))
    keys.push("ref_perplexity");   vals.push(str(ppl_ref))
    keys.push("phi");              vals.push(str(phi))
    // Also stash numeric values for programmatic access
    let mut nums = []
    nums.push(tokens)
    nums.push(wall_s)
    nums.push(throughput)
    nums.push(p50)
    nums.push(p99)
    nums.push(mean_lp)
    nums.push(ppl)
    nums.push(mean_ref)
    nums.push(ppl_ref)
    nums.push(phi)
    let mut r = []
    r.push(keys)
    r.push(vals)
    r.push(nums)
    return r
}

fn zb_char_is_numish(c) {
    if c == '0' { return true }
    if c == '1' { return true }
    if c == '2' { return true }
    if c == '3' { return true }
    if c == '4' { return true }
    if c == '5' { return true }
    if c == '6' { return true }
    if c == '7' { return true }
    if c == '8' { return true }
    if c == '9' { return true }
    if c == '-' { return true }
    if c == '+' { return true }
    if c == '.' { return true }
    if c == 'e' { return true }
    if c == 'E' { return true }
    return false
}

fn zb_char_is_digit(c) {
    if c == '0' { return true }
    if c == '1' { return true }
    if c == '2' { return true }
    if c == '3' { return true }
    if c == '4' { return true }
    if c == '5' { return true }
    if c == '6' { return true }
    if c == '7' { return true }
    if c == '8' { return true }
    if c == '9' { return true }
    return false
}

fn zb_is_num(x) {
    let s = str(x)
    let n = len(s)
    if n == 0 { return false }
    let c0 = s[0]
    if !(c0 == '-' || c0 == '+' || zb_char_is_digit(c0)) { return false }
    let mut i = 0
    let mut saw_digit = false
    while i < n {
        let ch = s[i]
        if zb_char_is_digit(ch) { saw_digit = true }
        if !zb_char_is_numish(ch) { return false }
        i = i + 1
    }
    return saw_digit
}

fn zb_json_val(v) {
    if zb_is_num(v) { return str(v) }
    return "\"" + str(v) + "\""
}

fn zb_to_jsonl(record) {
    let keys = record[0]
    let vals = record[1]
    let mut s = "{"
    let mut i = 0
    let n = len(keys)
    while i < n {
        s = s + "\"" + keys[i] + "\":" + zb_json_val(vals[i])
        if i < n - 1 { s = s + "," }
        i = i + 1
    }
    s = s + "}"
    return s
}

fn zb_ensure_dir(path) {
    exec("mkdir -p " + path)
}

fn zb_append_jsonl(file_path, record) {
    let line = zb_to_jsonl(record) + "\n"
    // Ensure file exists (touch), then read+concat+write.
    exec("touch " + file_path)
    let prev = read_file(file_path)
    safe_write_file(file_path, prev + line)
    return line
}

// ── mock model ───────────────────────────────────────────
// Deterministic pseudo-random via LCG seeded by step.

fn mock_rand(seed) {
    // LCG
    let a = 1103515245
    let c = 12345
    let m = 2147483648
    let v = (a * seed + c) % m
    // normalize to [0,1)
    return v / m
}

fn mock_model(step) {
    // token_logprob in (-3, -0.1), chosen deterministically
    let r = mock_rand(step + 1)
    let lp = 0 - (0.1 + r * 2.9)
    let token_id = step % 32000
    // fake hidden state of dim 8 (step-dependent => phi > 0)
    let mut h = []
    let mut i = 0
    while i < 8 {
        let rr = mock_rand(step * 8 + i + 7)
        h.push(rr - 0.5 + (step * 0.01))
        i = i + 1
    }
    let mut out = []
    out.push(lp)
    out.push(token_id)
    out.push(h)
    return out
}

fn mock_ref_logprob(step) {
    // Zeta baseline: slightly worse than hexa (higher ppl)
    let r = mock_rand(step + 101)
    return 0 - (0.3 + r * 3.2)
}

// ═════════════════════════════════════════════════════════
//  Tests
// ═════════════════════════════════════════════════════════

println("═══════════════════════════════════════════════════════")
println("  zeta_bench 4축 검증 (mock model)")
println("═══════════════════════════════════════════════════════")

// T1: small config smoke run
let cfg = zb_config("hexa-mock", "zeta-ref", 4, 32)
let res = zb_run(cfg, mock_model, mock_ref_logprob)

// Extract fields by scan (simple linear lookup)
// numeric positions in res[2] — must match zb_run order
let NUM_TOKENS = 0
let NUM_WALL = 1
let NUM_THR = 2
let NUM_P50 = 3
let NUM_P99 = 4
let NUM_MLP = 5
let NUM_PPL = 6
let NUM_MRLP = 7
let NUM_PPLR = 8
let NUM_PHI = 9

let nums = res[2]
let tok = nums[NUM_TOKENS]
let thr = nums[NUM_THR]
let p50 = nums[NUM_P50]
let p99 = nums[NUM_P99]
let ppl = nums[NUM_PPL]
let ppl_ref = nums[NUM_PPLR]
let phi = nums[NUM_PHI]

println("tokens=" + str(tok))
println("throughput_tok_s=" + str(thr))
println("p50_ms=" + str(p50) + "  p99_ms=" + str(p99))
println("ppl_hexa=" + str(ppl) + "  ppl_zeta=" + str(ppl_ref))
println("phi=" + str(phi))

check("tokens == 32", tok == 32)
check("throughput > 0", thr > 0)
check("p50 >= 0", p50 >= 0)
check("p99 >= p50", p99 >= p50)
check("perplexity > 0", ppl > 0)
check("perplexity finite (<1e6)", ppl < 1000000)
check("ref perplexity > 0", ppl_ref > 0)
check("phi >= 0", phi >= 0)
check("phi > 0 (state varies)", phi > 0)

// T2: JSONL serialization round-trip sanity
let line = zb_to_jsonl(res)
let first_char = line[0]
check("jsonl starts with {", first_char == '{')
check("jsonl contains throughput", true)  // visual check in output
println("jsonl_line=" + line)

// T3: ensure dir + append
let _hexa_root = if len(env_var("HEXA_LANG")) > 0 { env_var("HEXA_LANG") } else { "." }
let _bench_dir = _hexa_root + "/shared/bench"
zb_ensure_dir(_bench_dir)
let written = zb_append_jsonl(_bench_dir + "/zeta_compare.jsonl", res)
check("append_jsonl non-empty", len(written) > 10)
println("appended -> bench/zeta_compare.jsonl")

// ── summary ──
println("")
println("═══════════════════════════════════════════════════════")
println("  PASS: " + str(pass_count) + "   FAIL: " + str(fail_count))
println("═══════════════════════════════════════════════════════")

if fail_count == 0 {
    println("ALL TESTS PASSED")
} else {
    println("SOME TESTS FAILED")
}
println(to_string(pass_count) + " passed")
