// ═══════════════════════════════════════════════════════════
//  test_type_coercion.hexa — Type Conversion & Coercion Tests
//  Tests: to_string, to_int, to_float, type_of, implicit coercion,
//         edge cases in conversions, round-trip conversions
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA Type Conversion & Coercion Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. to_string conversions ──────────────────────────────

println("--- to_string ---")

check("to_string int 0", to_string(0), "0")
check("to_string int 42", to_string(42), "42")
check("to_string int neg", to_string(-7), "-7")
check("to_string bool true", to_string(true), "true")
check("to_string bool false", to_string(false), "false")
check("to_string float 1.5", to_string(1.5), "1.5")
check("to_string float 3.0", to_string(3.0), "3.0")
check("to_string string", to_string("hello"), "hello")
check("to_string empty", to_string(""), "")
check("to_string large", to_string(1000000), "1000000")

// ── 2. to_int conversions ─────────────────────────────────

println("")
println("--- to_int ---")

check("to_int str 123", to_int("123"), 123)
check("to_int str 0", to_int("0"), 0)
check("to_int str neg", to_int("-42"), -42)
check("to_int float 3.7", to_int(3.7), 3)
check("to_int float 3.0", to_int(3.0), 3)
check("to_int float neg", to_int(-2.9), -2)

// ── 3. to_float conversions ───────────────────────────────

println("")
println("--- to_float ---")

check("to_float str 3.14", to_float("3.14"), 3.14)
check("to_float str 0", to_float("0"), 0.0)
check("to_float int 5", to_float("5"), 5.0)

// ── 4. type_of checks ────────────────────────────────────

println("")
println("--- type_of ---")

check("type_of int", type_of(42), "int")
check("type_of int 0", type_of(0), "int")
check("type_of int neg", type_of(-5), "int")
check("type_of float", type_of(3.14), "float")
check("type_of string", type_of("hello"), "string")
check("type_of empty string", type_of(""), "string")
check("type_of bool true", type_of(true), "bool")
check("type_of bool false", type_of(false), "bool")
check("type_of array", type_of([1, 2, 3]), "array")
check("type_of empty array", type_of([]), "array")

// ── 5. Round-trip conversions ─────────────────────────────

println("")
println("--- Round-Trip ---")

check("int->str->int", to_int(to_string(42)), 42)
check("neg int->str->int", to_int(to_string(-99)), -99)
check("str->int->str", to_string(to_int("777")), "777")

// ── 6. String concat with converted types ─────────────────

println("")
println("--- String Concat Patterns ---")

let n = 42
check("str + int via to_string", "value=" + to_string(n), "value=42")
check("bool + str via to_string", to_string(true) + "!", "true!")

let mut msg = "items: "
let mut i = 0
while i < 3 {
    if i > 0 { msg = msg + "," }
    msg = msg + to_string(i)
    i = i + 1
}
check("loop build str", msg, "items: 0,1,2")

// ── 7. Arithmetic with mixed types ────────────────────────

println("")
println("--- Mixed Arithmetic ---")

check("int + float", 2 + 3.5, 5.5)
check("float + int", 1.5 + 2, 3.5)
check("float * int", 2.5 * 2, 5.0)
check("int * float", 3 * 1.5, 4.5)

// ═══════════════════════════════════════════════════════════
//  SUMMARY
// ═══════════════════════════════════════════════════════════

println("")
println("═══════════════════════════════════════════════════════")
let total = pass_count + fail_count
println("  Results: " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL / " + to_string(total) + " total")
if fail_count == 0 {
    println("  ALL TYPE COERCION TESTS PASSED!")
} else {
    println("  SOME TESTS FAILED")
}
println("═══════════════════════════════════════════════════════")
