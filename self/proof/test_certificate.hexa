// ═══════════════════════════════════════════════════════════
//  self/proof/test_certificate.hexa — T10 self-tests (3 cases)
//
//  Run:
//      ./hexa run self/proof/test_certificate.hexa
//
//  Happy path : issue → propagate → verify returns VERIFY_OK
//  Forged     : tamper the hash, verify returns VERIFY_HASH_MISMATCH
//  No mapping : issue with an unknown predicate, status = NO_MAPPING
// ═══════════════════════════════════════════════════════════

use "certificate"

fn proof_cert_report(name, ok) {
    if ok { println("  PASS " + name) }
    else  { println("  FAIL " + name) }
}

fn proof_cert_test_happy() {
    println("[T1] happy: issue(bounded, x, Add) -> propagate(Store) -> verify")
    let c0 = issue_certificate("bounded", "x", "Add")
    let issued_ok = c0["status"] == "ISSUED"
    proof_cert_report("issued-status", issued_ok)
    let c1 = propagate_certificate(c0, "Store")
    let prop_ok = c1["status"] == "PROPAGATED"
    proof_cert_report("propagated-status", prop_ok)
    // Bucket after Store (idx 7) must be "issue" (0..11).
    let bucket_ok = c1["bucket"] == "issue"
    proof_cert_report("bucket=issue-after-Store", bucket_ok)
    let v = verify_certificate(c1)
    let verify_ok = v == "VERIFY_OK"
    proof_cert_report("verify-ok", verify_ok)
}

fn proof_cert_test_forged() {
    println("[T2] forged: tamper hash -> verify detects mismatch")
    let c0 = issue_certificate("no_div_zero", "d", "Div")
    // tamper: produce a new dict with a mutated hash but identical rest.
    let tampered = #{
        "predicate": c0["predicate"],
        "target":    c0["target"],
        "bucket":    c0["bucket"],
        "status":    c0["status"],
        "hash":      c0["hash"] + 1
    }
    let v = verify_certificate(tampered)
    let detected = v == "VERIFY_HASH_MISMATCH"
    proof_cert_report("hash-tamper-detected", detected)
    // Sanity: the original must still verify.
    let v0 = verify_certificate(c0)
    let untouched_ok = v0 == "VERIFY_OK"
    proof_cert_report("untouched-verify-ok", untouched_ok)
}

fn proof_cert_test_no_mapping() {
    println("[T3] no-mapping: unknown predicate -> NO_MAPPING")
    let c = issue_certificate("definitely_not_a_predicate", "y", "Add")
    let status_ok = c["status"] == "NO_MAPPING"
    proof_cert_report("status-no-mapping", status_ok)
    let v = verify_certificate(c)
    let verify_tag_ok = v == "VERIFY_NO_MAPPING"
    proof_cert_report("verify-no-mapping-tag", verify_tag_ok)
    // Inverse mapping sanity — Phi is in the 24 opcodes but NOT in the
    // 12-row mapping, so the partial inverse returns the none sentinel.
    let p = opcode_to_predicate("Phi")
    let none_ok = p == "__NONE__"
    proof_cert_report("opcode_to_predicate(Phi)=none", none_ok)
}

fn proof_cert_test_bucket_split() {
    // Secondary sanity: Egyptian split 12+8+4 = 24. Not counted in
    // the primary 3 self-tests but prints bucket coverage for ops 0..23.
    println("[T4] bucket-split (Egyptian 1/2 + 1/3 + 1/6): issue/propagate/verify counts")
    let ops = [
        "Add","Sub","Mul","Div","Mod","Neg",
        "Load","Store","Alloc","Free","Copy","Move",
        "Jump","Branch","Call","Return","Phi","Switch",
        "Assert","Assume","Invariant","LifetimeStart","LifetimeEnd","OwnershipTransfer"
    ]
    let mut n_issue = 0
    let mut n_prop  = 0
    let mut n_verify = 0
    let mut i = 0
    while i < len(ops) {
        let b = bucket_assign(ops[i])
        if b == "issue"     { n_issue = n_issue + 1 }
        if b == "propagate" { n_prop  = n_prop  + 1 }
        if b == "verify"    { n_verify = n_verify + 1 }
        i = i + 1
    }
    let total = n_issue + n_prop + n_verify
    println("  counts: issue=" + to_string(n_issue) + " propagate=" + to_string(n_prop) + " verify=" + to_string(n_verify) + " total=" + to_string(total))
    let egypt_ok = (n_issue == 12) && (n_prop == 8) && (n_verify == 4) && (total == 24)
    proof_cert_report("egyptian-1/2+1/3+1/6=24", egypt_ok)
}

fn proof_cert_main() {
    println("=== T10 proof certificate self-tests ===")
    proof_cert_test_happy()
    proof_cert_test_forged()
    proof_cert_test_no_mapping()
    proof_cert_test_bucket_split()
    println("=== done ===")
}

proof_cert_main()
