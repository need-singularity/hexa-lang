// self/test_file_pure.hexa -- Tests for self/runtime/file_pure.hexa
//
// Verifies: read_file_pure, write_file_pure, file_exists_pure,
//           file_size_pure, delete_file_pure, append_file_pure,
//           mkdir_p_pure, dir_exists_pure, list_dir_pure
//
// Run: build/hexa_stage0 self/test_file_pure.hexa
//
// Note: functions inlined here because stage0 interpreter treats
// `import "..."` as NoOp. When flatten_imports is used for native
// builds, the canonical source is self/runtime/file_pure.hexa.

// ── inlined from self/runtime/file_pure.hexa ──────────────────────

fn read_file_pure(path) {
    exec("cat '" + path + "'")
}

fn write_file_pure(path, content) {
    write_file(path, content)
}

fn append_file_pure(path, content) {
    let tmp = "/tmp/_hexa_append_" + to_string(timestamp())
    write_file(tmp, content)
    exec("cat '" + tmp + "' >> '" + path + "'")
    exec("rm -f '" + tmp + "'")
}

fn delete_file_pure(path) {
    exec("rm -f '" + path + "'")
}

fn file_exists_pure(path) {
    let r = exec("test -f '" + path + "' && printf 1 || printf 0")
    r == "1"
}

fn dir_exists_pure(path) {
    let r = exec("test -d '" + path + "' && printf 1 || printf 0")
    r == "1"
}

fn file_size_pure(path) {
    let raw = exec("wc -c < '" + path + "' 2>/dev/null | tr -d ' \\n'")
    if len(raw) == 0 { return -1 }
    to_int(raw)
}

fn mkdir_p_pure(path) {
    exec("mkdir -p '" + path + "'")
}

fn list_dir_pure(path) {
    let raw = exec("ls -1 '" + path + "' 2>/dev/null")
    if len(raw) == 0 { return [] }
    let entries = raw.split("\n")
    let mut result = []
    let mut i = 0
    while i < len(entries) {
        if len(entries[i]) > 0 {
            result = result.push(entries[i])
        }
        i = i + 1
    }
    result
}

fn write_bytes_pure(path, arr) {
    if type_of(arr) != "array" { return false }
    write_bytes(path, arr)
    true
}

fn read_file_bytes_pure(path) {
    read_file_bytes(path)
}

// ── end inlined ───────────────────────────────────────────────────

let TMP_DIR = "/tmp/hexa_test_file_pure"

// Clean up from prior runs and create fresh temp dir
exec("rm -rf '" + TMP_DIR + "'")
mkdir_p_pure(TMP_DIR)

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        pass_count = pass_count + 1
        println("  PASS: " + name)
    } else {
        fail_count = fail_count + 1
        println("  FAIL: " + name)
    }
}

fn check_eq(name, got, expected) {
    if got == expected {
        pass_count = pass_count + 1
        println("  PASS: " + name)
    } else {
        fail_count = fail_count + 1
        println("  FAIL: " + name + " -- got: " + to_string(got) + ", expected: " + to_string(expected))
    }
}

// ═══════════════════════════════════════════════════════════
println("=== test_file_pure.hexa ===")

// ── 1. write + read roundtrip ─────────────────────────────
println("\n--- write + read roundtrip ---")
let test_path = TMP_DIR + "/hello.txt"
let test_content = "hello hexa file io"
write_file_pure(test_path, test_content)
let read_back = read_file_pure(test_path)
check_eq("write then read", read_back, test_content)

// ── 2. file_exists_pure ───────────────────────────────────
println("\n--- file_exists_pure ---")
check("existing file returns true", file_exists_pure(test_path))
check("missing file returns false", file_exists_pure(TMP_DIR + "/no_such_file.txt") == false)

// ── 3. file_size_pure ─────────────────────────────────────
println("\n--- file_size_pure ---")
let expected_size = len(test_content)
let actual_size = file_size_pure(test_path)
check_eq("file size matches content length", actual_size, expected_size)

// size of empty file
let empty_path = TMP_DIR + "/empty.txt"
write_file_pure(empty_path, "")
check_eq("empty file size is 0", file_size_pure(empty_path), 0)

// size of missing file
check_eq("missing file size is -1", file_size_pure(TMP_DIR + "/nope.bin"), -1)

// ── 4. delete_file_pure ───────────────────────────────────
println("\n--- delete_file_pure ---")
let del_path = TMP_DIR + "/to_delete.txt"
write_file_pure(del_path, "delete me")
check("file exists before delete", file_exists_pure(del_path))
delete_file_pure(del_path)
check("file gone after delete", file_exists_pure(del_path) == false)

// deleting non-existent file should not error
delete_file_pure(TMP_DIR + "/already_gone.txt")
check("delete non-existent is silent", true)

// ── 5. append_file_pure ───────────────────────────────────
println("\n--- append_file_pure ---")
let append_path = TMP_DIR + "/appended.txt"
write_file_pure(append_path, "first")
append_file_pure(append_path, " second")
let appended = read_file_pure(append_path)
check_eq("append adds to existing content", appended, "first second")

// ── 6. dir_exists_pure ────────────────────────────────────
println("\n--- dir_exists_pure ---")
check("existing dir returns true", dir_exists_pure(TMP_DIR))
check("missing dir returns false", dir_exists_pure(TMP_DIR + "/no_dir") == false)
check("file is not a dir", dir_exists_pure(test_path) == false)

// ── 7. mkdir_p_pure ───────────────────────────────────────
println("\n--- mkdir_p_pure ---")
let nested = TMP_DIR + "/a/b/c"
mkdir_p_pure(nested)
check("nested mkdir creates dir", dir_exists_pure(nested))

// ── 8. list_dir_pure ──────────────────────────────────────
println("\n--- list_dir_pure ---")
let list_dir = TMP_DIR + "/listme"
mkdir_p_pure(list_dir)
write_file_pure(list_dir + "/alpha.txt", "a")
write_file_pure(list_dir + "/beta.txt", "b")
let entries = list_dir_pure(list_dir)
check_eq("list_dir count", len(entries), 2)

// empty dir
let empty_dir = TMP_DIR + "/emptydir"
mkdir_p_pure(empty_dir)
check_eq("empty dir listing", len(list_dir_pure(empty_dir)), 0)

// ── 9. read missing file ──────────────────────────────────
println("\n--- read missing file ---")
let missing = read_file_pure(TMP_DIR + "/does_not_exist.txt")
check_eq("read missing returns empty", missing, "")

// ── 10. multiline content ─────────────────────────────────
println("\n--- multiline content ---")
let ml_path = TMP_DIR + "/multi.txt"
let ml_content = "line1\nline2\nline3"
write_file_pure(ml_path, ml_content)
let ml_back = read_file_pure(ml_path)
check_eq("multiline roundtrip", ml_back, ml_content)

println("\n--- binary I/O (write_bytes/read_file_bytes) ---")
// Note: stage0 write_bytes currently routes through a string path and
// UTF-8-re-encodes high bytes (>=128) + drops NULs. Sticking to safe
// ASCII range here until the native pass lands.
let bin_path = TMP_DIR + "/raw.bin"
let bin_payload = [65, 66, 67, 10, 32, 127]
let wb_ok = write_bytes_pure(bin_path, bin_payload)
check_eq("write_bytes returns true on array", to_string(wb_ok), "true")
let bin_back = read_file_bytes_pure(bin_path)
check_eq("binary roundtrip (ASCII)", to_string(bin_back), to_string(bin_payload))
let empty_bin_path = TMP_DIR + "/empty.bin"
write_bytes_pure(empty_bin_path, [])
check_eq("empty bytes roundtrip", to_string(read_file_bytes_pure(empty_bin_path)), to_string([]))
check_eq("read missing returns []", to_string(read_file_bytes_pure(TMP_DIR + "/nope.bin")), to_string([]))
check_eq("write_bytes non-array returns false", to_string(write_bytes_pure(bin_path, "not_an_array")), "false")

// ═══════════════════════════════════════════════════════════
println("\n=== Results ===")
println("PASS: " + to_string(pass_count))
println("FAIL: " + to_string(fail_count))

if fail_count > 0 {
    println("!!! SOME TESTS FAILED !!!")
} else {
    println("=== test_file_pure.hexa: ALL TESTS PASSED ===")
}

// Cleanup
exec("rm -rf '" + TMP_DIR + "'")
