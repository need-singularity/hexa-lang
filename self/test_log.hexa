// self/test_log.hexa — S-NEW-LOG acceptance smoke
//
// Self-contained: inline the threshold/format helpers. Validates level
// gating + ISO8601 prefix shape, without filesystem capture (we exercise
// the call paths and rely on PASS-not-crash for level<threshold).

let mut pass_count = 0
let mut total_count = 0
let mut failed_name = ""

fn check(name, cond) {
    total_count = total_count + 1
    if cond {
        pass_count = pass_count + 1
    } else {
        if failed_name == "" { failed_name = name }
        println("FAIL " + name)
    }
}

// ── inline mirror ──────────────────────────────────────────────────────

let mut _log_threshold = 1
fn _level_to_int(level) {
    if level == "debug" { return 0 }
    if level == "info"  { return 1 }
    if level == "warn"  { return 2 }
    if level == "error" { return 3 }
    return 1
}
fn log_set_level(level) { _log_threshold = _level_to_int(level) }

fn would_emit(level) -> bool {
    let lvl = _level_to_int(level)
    if lvl < _log_threshold { return false }
    return true
}

fn now_iso() {
    return exec("date -u +%Y-%m-%dT%H:%M:%SZ").trim()
}

// ── tests ──────────────────────────────────────────────────────────────

fn main() {
    // default threshold = info: debug suppressed, info/warn/error pass
    check("default debug suppressed", would_emit("debug") == false)
    check("default info ok", would_emit("info"))
    check("default warn ok", would_emit("warn"))
    check("default error ok", would_emit("error"))

    // set to debug → all emit
    log_set_level("debug")
    check("debug-set debug emits", would_emit("debug"))
    check("debug-set info emits", would_emit("info"))

    // set to error → only error emits
    log_set_level("error")
    check("error-set debug suppressed", would_emit("debug") == false)
    check("error-set info suppressed", would_emit("info") == false)
    check("error-set warn suppressed", would_emit("warn") == false)
    check("error-set error emits", would_emit("error"))

    // unknown level falls back to info threshold
    log_set_level("garbage")
    check("garbage-set is info", _log_threshold == 1)

    // ISO ts shape: YYYY-MM-DDTHH:MM:SSZ (20 chars, has T and Z, has -)
    let ts = now_iso()
    check("iso ts length 20", len(ts) == 20)
    check("iso ts has T at idx 10", ts[10] == 'T')
    check("iso ts ends Z", ts[19] == 'Z')

    println("PASS " + to_string(pass_count) + "/" + to_string(total_count))
    if failed_name != "" {
        println("first fail: " + failed_name)
        exit(1)
    }
}
