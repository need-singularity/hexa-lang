// ═══════════════════════════════════════════════════════════════════
//  test_datetime_pure.hexa — coverage for self/runtime/datetime_pure
//
//  40+ tests: leap years, month lengths, day-of-week, epoch↔ymd
//  round-trip, hms split, ISO 8601 format + parse.
// ═══════════════════════════════════════════════════════════════════

import "runtime/datetime_pure.hexa"

let mut pass = 0
let mut fail = 0

fn check(name, cond) {
    if cond {
        pass = pass + 1
    } else {
        println("[FAIL] " + name)
        fail = fail + 1
    }
}

println("═══ datetime_pure test suite ═══")

// ── leap year ──────────────────────────────────────────────────────
check("is_leap 2000", is_leap_year_pure(2000))
check("is_leap 2004", is_leap_year_pure(2004))
check("is_leap 1900 NOT", !is_leap_year_pure(1900))
check("is_leap 2100 NOT", !is_leap_year_pure(2100))
check("is_leap 2024", is_leap_year_pure(2024))
check("is_leap 2023 NOT", !is_leap_year_pure(2023))
check("is_leap 1970 NOT", !is_leap_year_pure(1970))

// ── days in month ──────────────────────────────────────────────────
check("Jan 31", days_in_month_pure(2024, 1) == 31)
check("Feb 28 non-leap", days_in_month_pure(2023, 2) == 28)
check("Feb 29 leap", days_in_month_pure(2024, 2) == 29)
check("Feb 28 century non-leap", days_in_month_pure(1900, 2) == 28)
check("Feb 29 quad-cent leap", days_in_month_pure(2000, 2) == 29)
check("Apr 30", days_in_month_pure(2024, 4) == 30)
check("Dec 31", days_in_month_pure(2024, 12) == 31)

// ── day of week — known anchors ────────────────────────────────────
// 1970-01-01 was a Thursday (4)
check("1970-01-01 Thu", day_of_week_pure(1970, 1, 1) == 4)
// 2000-01-01 was a Saturday (6)
check("2000-01-01 Sat", day_of_week_pure(2000, 1, 1) == 6)
// 2024-01-01 was a Monday (1)
check("2024-01-01 Mon", day_of_week_pure(2024, 1, 1) == 1)
// 2026-04-16 (today) is Thursday (4)
check("2026-04-16 Thu", day_of_week_pure(2026, 4, 16) == 4)
// 1776-07-04 was a Thursday (4)
check("1776-07-04 Thu", day_of_week_pure(1776, 7, 4) == 4)

// ── days since epoch ───────────────────────────────────────────────
check("epoch 1970-01-01 = 0", days_since_epoch_pure(1970, 1, 1) == 0)
check("epoch 1970-01-02 = 1", days_since_epoch_pure(1970, 1, 2) == 1)
check("epoch 1970-02-01 = 31", days_since_epoch_pure(1970, 2, 1) == 31)
check("epoch 1971-01-01 = 365", days_since_epoch_pure(1971, 1, 1) == 365)
check("epoch 1972-01-01 = 730", days_since_epoch_pure(1972, 1, 1) == 730)
check("epoch 1973-01-01 = 1096", days_since_epoch_pure(1973, 1, 1) == 1096)
// 2000-01-01: 30 years → 7 leap (72,76,80,84,88,92,96) = 30*365+7 = 10957
check("epoch 2000-01-01 = 10957", days_since_epoch_pure(2000, 1, 1) == 10957)
// 2024-01-01: known 19723
check("epoch 2024-01-01 = 19723", days_since_epoch_pure(2024, 1, 1) == 19723)
// pre-epoch
check("epoch 1969-12-31 = -1", days_since_epoch_pure(1969, 12, 31) == -1)
check("epoch 1969-12-01 = -31", days_since_epoch_pure(1969, 12, 1) == -31)
check("epoch 1969-01-01 = -365", days_since_epoch_pure(1969, 1, 1) == -365)

// ── epoch_to_ymd ───────────────────────────────────────────────────
let r0 = epoch_to_ymd_pure(0)
check("0 sec → 1970-01-01 Y", r0[0] == 1970)
check("0 sec → 1970-01-01 M", r0[1] == 1)
check("0 sec → 1970-01-01 D", r0[2] == 1)

let r1 = epoch_to_ymd_pure(86400)      // 1 day after epoch
check("86400 sec → 1970-01-02 D", r1[2] == 2)

let r2 = epoch_to_ymd_pure(946684800)  // 2000-01-01
check("946684800 → 2000 Y", r2[0] == 2000)
check("946684800 → 01 M", r2[1] == 1)
check("946684800 → 01 D", r2[2] == 1)

let r3 = epoch_to_ymd_pure(1704067200) // 2024-01-01
check("1704067200 → 2024 Y", r3[0] == 2024)
check("1704067200 → 01 M", r3[1] == 1)
check("1704067200 → 01 D", r3[2] == 1)

// ── epoch_to_hms ───────────────────────────────────────────────────
let h0 = epoch_to_hms_pure(0)
check("hms(0) = 0,0,0", h0[0] == 0 && h0[1] == 0 && h0[2] == 0)

let h1 = epoch_to_hms_pure(3661)       // 1h 1m 1s
check("hms(3661) = 1,1,1", h1[0] == 1 && h1[1] == 1 && h1[2] == 1)

let h2 = epoch_to_hms_pure(86399)      // 23:59:59
check("hms(86399) = 23,59,59", h2[0] == 23 && h2[1] == 59 && h2[2] == 59)

let h3 = epoch_to_hms_pure(86400)      // next-day midnight → 0,0,0
check("hms(86400) wraps to 0,0,0", h3[0] == 0 && h3[1] == 0 && h3[2] == 0)

// ── round-trip: ymd_hms ↔ epoch ────────────────────────────────────
let rt1 = ymd_hms_to_epoch_pure(2024, 4, 16, 12, 30, 45)
let rt1_ymd = epoch_to_ymd_pure(rt1)
let rt1_hms = epoch_to_hms_pure(rt1)
check("rt 2024-04-16 Y", rt1_ymd[0] == 2024)
check("rt 2024-04-16 M", rt1_ymd[1] == 4)
check("rt 2024-04-16 D", rt1_ymd[2] == 16)
check("rt 12:30:45 H", rt1_hms[0] == 12)
check("rt 12:30:45 M", rt1_hms[1] == 30)
check("rt 12:30:45 S", rt1_hms[2] == 45)

// ── ISO 8601 format ────────────────────────────────────────────────
let f1 = format_iso8601_pure(2024, 4, 16, 12, 30, 45)
check("iso format 2024-04-16T12:30:45Z", f1 == "2024-04-16T12:30:45Z")

let f2 = format_iso8601_pure(1970, 1, 1, 0, 0, 0)
check("iso format epoch", f2 == "1970-01-01T00:00:00Z")

let f3 = format_iso8601_pure(9999, 12, 31, 23, 59, 59)
check("iso format far future", f3 == "9999-12-31T23:59:59Z")

// ── ISO 8601 parse ─────────────────────────────────────────────────
let p1 = parse_iso8601_pure("2024-04-16T12:30:45Z")
check("iso parse Y", p1[0] == 2024)
check("iso parse M", p1[1] == 4)
check("iso parse D", p1[2] == 16)
check("iso parse H", p1[3] == 12)
check("iso parse M2", p1[4] == 30)
check("iso parse S", p1[5] == 45)

let p2 = parse_iso8601_pure("2024-04-16 12:30:45")  // space separator
check("iso parse space-sep", p2[0] == 2024 && p2[2] == 16)

let p3 = parse_iso8601_pure("invalid string")
check("iso parse bad = -1", p3[0] == -1)

let p4 = parse_iso8601_pure("2024-13-01T00:00:00Z") // bad month
check("iso parse bad month", p4[0] == -1)

// ── format ↔ parse round-trip ──────────────────────────────────────
let s_rt = format_iso8601_pure(2026, 4, 16, 23, 15, 7)
let p_rt = parse_iso8601_pure(s_rt)
check("iso rt Y", p_rt[0] == 2026)
check("iso rt M", p_rt[1] == 4)
check("iso rt D", p_rt[2] == 16)
check("iso rt HH", p_rt[3] == 23)
check("iso rt MM", p_rt[4] == 15)
check("iso rt SS", p_rt[5] == 7)

// ── summary ────────────────────────────────────────────────────────
println("═══════════════════════════════════════════════════════")
println("  PASS: " + to_string(pass))
println("  FAIL: " + to_string(fail))
if fail == 0 {
    println("[ALL PASS] datetime_pure verified")
} else {
    println("[FAIL] datetime_pure has " + to_string(fail) + " failures")
}
