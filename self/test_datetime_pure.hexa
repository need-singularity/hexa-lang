// ═══════════════════════════════════════════════════════════════════
//  test_datetime_pure.hexa — coverage for self/runtime/datetime_pure
//
//  40+ tests: leap years, month lengths, day-of-week, epoch<->ymd
//  round-trip, hms split, ISO 8601 format + parse.
// ═══════════════════════════════════════════════════════════════════

// ── INLINED from runtime/datetime_pure.hexa ──

@pure
fn is_leap_year_impl(year) {
    if (year % 4) != 0 { return false }
    if (year % 100) != 0 { return true }
    if (year % 400) != 0 { return false }
    return true
}

pub fn is_leap_year_pure(year) {
    return is_leap_year_impl(year)
}

@pure
fn days_in_month_impl(year, month) {
    if month == 1  { return 31 }
    if month == 3  { return 31 }
    if month == 5  { return 31 }
    if month == 7  { return 31 }
    if month == 8  { return 31 }
    if month == 10 { return 31 }
    if month == 12 { return 31 }
    if month == 4  { return 30 }
    if month == 6  { return 30 }
    if month == 9  { return 30 }
    if month == 11 { return 30 }
    if month == 2 {
        if is_leap_year_impl(year) { return 29 }
        return 28
    }
    return 0
}

pub fn days_in_month_pure(year, month) {
    return days_in_month_impl(year, month)
}

@pure
fn day_of_week_impl(year, month, day) {
    let mut y = year
    let mut m = month
    if m < 3 {
        m = m + 12
        y = y - 1
    }
    let k = y % 100
    let j = y / 100
    let h_raw = day + (13 * (m + 1)) / 5 + k + k / 4 + j / 4 + 5 * j
    let h = h_raw % 7
    let dow = (h + 6) % 7
    return dow
}

pub fn day_of_week_pure(year, month, day) {
    return day_of_week_impl(year, month, day)
}

@pure
fn days_since_epoch_impl(year, month, day) {
    let mut total = 0
    if year >= 1970 {
        let mut y = 1970
        while y < year {
            if is_leap_year_impl(y) { total = total + 366 } else { total = total + 365 }
            y = y + 1
        }
    } else {
        let mut y = year
        while y < 1970 {
            if is_leap_year_impl(y) { total = total - 366 } else { total = total - 365 }
            y = y + 1
        }
    }
    let mut m = 1
    while m < month {
        total = total + days_in_month_impl(year, m)
        m = m + 1
    }
    return total + (day - 1)
}

pub fn days_since_epoch_pure(year, month, day) {
    return days_since_epoch_impl(year, month, day)
}

@pure
fn epoch_to_ymd_impl(secs) {
    let mut days = secs / 86400
    if secs < 0 && (secs % 86400) != 0 {
        days = days - 1
    }
    let mut year = 1970
    if days >= 0 {
        let mut acc = 0
        while true {
            let dly = if is_leap_year_impl(year) { 366 } else { 365 }
            if acc + dly > days { break }
            acc = acc + dly
            year = year + 1
        }
        let mut rem = days - acc
        let mut month = 1
        while month <= 12 {
            let dim = days_in_month_impl(year, month)
            if rem < dim { break }
            rem = rem - dim
            month = month + 1
        }
        let day = rem + 1
        let result = []
        return result.push(year).push(month).push(day)
    } else {
        let mut acc = 0
        while acc > days {
            year = year - 1
            let dly = if is_leap_year_impl(year) { 366 } else { 365 }
            acc = acc - dly
        }
        let mut rem = days - acc
        let mut month = 1
        while month <= 12 {
            let dim = days_in_month_impl(year, month)
            if rem < dim { break }
            rem = rem - dim
            month = month + 1
        }
        let day = rem + 1
        let result = []
        return result.push(year).push(month).push(day)
    }
}

pub fn epoch_to_ymd_pure(secs) {
    return epoch_to_ymd_impl(secs)
}

@pure
fn epoch_to_hms_impl(secs) {
    let mut s = secs % 86400
    if s < 0 { s = s + 86400 }
    let h = s / 3600
    let m = (s % 3600) / 60
    let ss = s % 60
    let result = []
    return result.push(h).push(m).push(ss)
}

pub fn epoch_to_hms_pure(secs) {
    return epoch_to_hms_impl(secs)
}

@pure
fn ymd_hms_to_epoch_impl(y, m, d, hh, mm, ss) {
    let days = days_since_epoch_impl(y, m, d)
    return days * 86400 + hh * 3600 + mm * 60 + ss
}

pub fn ymd_hms_to_epoch_pure(y, m, d, hh, mm, ss) {
    return ymd_hms_to_epoch_impl(y, m, d, hh, mm, ss)
}

@pure
fn pad2_impl(n) {
    if n < 0 || n >= 100 { return to_string(n) }
    if n < 10 { return "0" + to_string(n) }
    return to_string(n)
}

@pure
fn pad4_impl(n) {
    if n < 0 || n >= 10000 { return to_string(n) }
    if n < 10    { return "000" + to_string(n) }
    if n < 100   { return "00"  + to_string(n) }
    if n < 1000  { return "0"   + to_string(n) }
    return to_string(n)
}

@pure
fn format_iso8601_impl(y, m, d, hh, mm, ss) {
    return pad4_impl(y) + "-" + pad2_impl(m) + "-" + pad2_impl(d)
         + "T" + pad2_impl(hh) + ":" + pad2_impl(mm) + ":" + pad2_impl(ss) + "Z"
}

pub fn format_iso8601_pure(y, m, d, hh, mm, ss) {
    return format_iso8601_impl(y, m, d, hh, mm, ss)
}

@pure
fn dt_is_digit(c) {
    let code = char_code(c, 0)
    return code >= 48 && code <= 57
}

@pure
fn dt_take_int(s, start, length) {
    let n = len(s)
    if start + length > n { return -1 }
    let mut acc = 0
    let mut i = 0
    while i < length {
        let c = s.substring(start + i, start + i + 1)
        if !dt_is_digit(c) { return -1 }
        let d = char_code(c, 0) - 48
        acc = acc * 10 + d
        i = i + 1
    }
    return acc
}

@pure
fn parse_iso8601_impl(s) {
    let bad = []
    let bad6 = bad.push(-1).push(-1).push(-1).push(-1).push(-1).push(-1)
    if len(s) < 19 { return bad6 }
    let y = dt_take_int(s, 0, 4)
    if y < 0 { return bad6 }
    if s.substring(4, 5) != "-" { return bad6 }
    let mo = dt_take_int(s, 5, 2)
    if mo < 1 || mo > 12 { return bad6 }
    if s.substring(7, 8) != "-" { return bad6 }
    let d = dt_take_int(s, 8, 2)
    if d < 1 || d > 31 { return bad6 }
    let sep = s.substring(10, 11)
    if sep != "T" && sep != " " { return bad6 }
    let hh = dt_take_int(s, 11, 2)
    if hh < 0 || hh > 23 { return bad6 }
    if s.substring(13, 14) != ":" { return bad6 }
    let mm = dt_take_int(s, 14, 2)
    if mm < 0 || mm > 59 { return bad6 }
    if s.substring(16, 17) != ":" { return bad6 }
    let ss = dt_take_int(s, 17, 2)
    if ss < 0 || ss > 60 { return bad6 }
    let result = []
    return result.push(y).push(mo).push(d).push(hh).push(mm).push(ss)
}

pub fn parse_iso8601_pure(s) {
    return parse_iso8601_impl(s)
}

// ── END INLINED ──

let mut pass = 0
let mut fail = 0

fn check(name, cond) {
    if cond {
        pass = pass + 1
    } else {
        println("[FAIL] " + name)
        fail = fail + 1
    }
}

println("=== datetime_pure test suite ===")

// ── leap year ──
check("is_leap 2000", is_leap_year_pure(2000))
check("is_leap 2004", is_leap_year_pure(2004))
check("is_leap 1900 NOT", !is_leap_year_pure(1900))
check("is_leap 2100 NOT", !is_leap_year_pure(2100))
check("is_leap 2024", is_leap_year_pure(2024))
check("is_leap 2023 NOT", !is_leap_year_pure(2023))
check("is_leap 1970 NOT", !is_leap_year_pure(1970))

// ── days in month ──
check("Jan 31", days_in_month_pure(2024, 1) == 31)
check("Feb 28 non-leap", days_in_month_pure(2023, 2) == 28)
check("Feb 29 leap", days_in_month_pure(2024, 2) == 29)
check("Feb 28 century non-leap", days_in_month_pure(1900, 2) == 28)
check("Feb 29 quad-cent leap", days_in_month_pure(2000, 2) == 29)
check("Apr 30", days_in_month_pure(2024, 4) == 30)
check("Dec 31", days_in_month_pure(2024, 12) == 31)

// ── day of week ──
check("1970-01-01 Thu", day_of_week_pure(1970, 1, 1) == 4)
check("2000-01-01 Sat", day_of_week_pure(2000, 1, 1) == 6)
check("2024-01-01 Mon", day_of_week_pure(2024, 1, 1) == 1)
check("2026-04-16 Thu", day_of_week_pure(2026, 4, 16) == 4)
check("1776-07-04 Thu", day_of_week_pure(1776, 7, 4) == 4)

// ── days since epoch ──
check("epoch 1970-01-01 = 0", days_since_epoch_pure(1970, 1, 1) == 0)
check("epoch 1970-01-02 = 1", days_since_epoch_pure(1970, 1, 2) == 1)
check("epoch 1970-02-01 = 31", days_since_epoch_pure(1970, 2, 1) == 31)
check("epoch 1971-01-01 = 365", days_since_epoch_pure(1971, 1, 1) == 365)
check("epoch 1972-01-01 = 730", days_since_epoch_pure(1972, 1, 1) == 730)
check("epoch 1973-01-01 = 1096", days_since_epoch_pure(1973, 1, 1) == 1096)
check("epoch 2000-01-01 = 10957", days_since_epoch_pure(2000, 1, 1) == 10957)
check("epoch 2024-01-01 = 19723", days_since_epoch_pure(2024, 1, 1) == 19723)
check("epoch 1969-12-31 = -1", days_since_epoch_pure(1969, 12, 31) == -1)
check("epoch 1969-12-01 = -31", days_since_epoch_pure(1969, 12, 1) == -31)
check("epoch 1969-01-01 = -365", days_since_epoch_pure(1969, 1, 1) == -365)

// ── epoch_to_ymd ──
let r0 = epoch_to_ymd_pure(0)
check("0 sec -> 1970-01-01 Y", r0[0] == 1970)
check("0 sec -> 1970-01-01 M", r0[1] == 1)
check("0 sec -> 1970-01-01 D", r0[2] == 1)

let r1 = epoch_to_ymd_pure(86400)
check("86400 sec -> 1970-01-02 D", r1[2] == 2)

let r2 = epoch_to_ymd_pure(946684800)
check("946684800 -> 2000 Y", r2[0] == 2000)
check("946684800 -> 01 M", r2[1] == 1)
check("946684800 -> 01 D", r2[2] == 1)

let r3 = epoch_to_ymd_pure(1704067200)
check("1704067200 -> 2024 Y", r3[0] == 2024)
check("1704067200 -> 01 M", r3[1] == 1)
check("1704067200 -> 01 D", r3[2] == 1)

// ── epoch_to_hms ──
let h0 = epoch_to_hms_pure(0)
check("hms(0) = 0,0,0", h0[0] == 0 && h0[1] == 0 && h0[2] == 0)

let h1 = epoch_to_hms_pure(3661)
check("hms(3661) = 1,1,1", h1[0] == 1 && h1[1] == 1 && h1[2] == 1)

let h2 = epoch_to_hms_pure(86399)
check("hms(86399) = 23,59,59", h2[0] == 23 && h2[1] == 59 && h2[2] == 59)

let h3 = epoch_to_hms_pure(86400)
check("hms(86400) wraps to 0,0,0", h3[0] == 0 && h3[1] == 0 && h3[2] == 0)

// ── round-trip: ymd_hms <-> epoch ──
let rt1 = ymd_hms_to_epoch_pure(2024, 4, 16, 12, 30, 45)
let rt1_ymd = epoch_to_ymd_pure(rt1)
let rt1_hms = epoch_to_hms_pure(rt1)
check("rt 2024-04-16 Y", rt1_ymd[0] == 2024)
check("rt 2024-04-16 M", rt1_ymd[1] == 4)
check("rt 2024-04-16 D", rt1_ymd[2] == 16)
check("rt 12:30:45 H", rt1_hms[0] == 12)
check("rt 12:30:45 M", rt1_hms[1] == 30)
check("rt 12:30:45 S", rt1_hms[2] == 45)

// ── ISO 8601 format ──
let f1 = format_iso8601_pure(2024, 4, 16, 12, 30, 45)
check("iso format 2024-04-16T12:30:45Z", f1 == "2024-04-16T12:30:45Z")

let f2 = format_iso8601_pure(1970, 1, 1, 0, 0, 0)
check("iso format epoch", f2 == "1970-01-01T00:00:00Z")

let f3 = format_iso8601_pure(9999, 12, 31, 23, 59, 59)
check("iso format far future", f3 == "9999-12-31T23:59:59Z")

// ── ISO 8601 parse ──
let p1 = parse_iso8601_pure("2024-04-16T12:30:45Z")
check("iso parse Y", p1[0] == 2024)
check("iso parse M", p1[1] == 4)
check("iso parse D", p1[2] == 16)
check("iso parse H", p1[3] == 12)
check("iso parse M2", p1[4] == 30)
check("iso parse S", p1[5] == 45)

let p2 = parse_iso8601_pure("2024-04-16 12:30:45")
check("iso parse space-sep", p2[0] == 2024 && p2[2] == 16)

let p3 = parse_iso8601_pure("invalid string")
check("iso parse bad = -1", p3[0] == -1)

let p4 = parse_iso8601_pure("2024-13-01T00:00:00Z")
check("iso parse bad month", p4[0] == -1)

// ── format <-> parse round-trip ──
let s_rt = format_iso8601_pure(2026, 4, 16, 23, 15, 7)
let p_rt = parse_iso8601_pure(s_rt)
check("iso rt Y", p_rt[0] == 2026)
check("iso rt M", p_rt[1] == 4)
check("iso rt D", p_rt[2] == 16)
check("iso rt HH", p_rt[3] == 23)
check("iso rt MM", p_rt[4] == 15)
check("iso rt SS", p_rt[5] == 7)

// ── summary ──
println("===================================================")
println("  PASS: " + to_string(pass))
println("  FAIL: " + to_string(fail))
if fail == 0 {
    println("[ALL PASS] datetime_pure verified")
} else {
    println("[FAIL] datetime_pure has " + to_string(fail) + " failures")
}
