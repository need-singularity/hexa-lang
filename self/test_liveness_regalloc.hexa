// self/test_liveness_regalloc.hexa — ROI #185
//
// Scaffold test for self/codegen/liveness_regalloc.hexa.
//
// Exercises a 5-instruction SSA block end-to-end:
//     v0 = load     (produces v0 — placeholder initial value)
//     v1 = load     (produces v1 — placeholder initial value)
//     v2 = add v0, v1
//     v3 = mul v2, v0    ; v0 lives through here
//     v4 = sub v3, v2    ; v2 lives through here
//
// Verifies:
//   1) scan_def_use surfaces every def and every operand use.
//   2) build_intervals yields one interval per VID with the right
//      [start, end_pos] window.
//   3) allocate_linear with k=3 regs fits all five values without
//      spilling (distinct live ranges don't overlap more than 3 deep).
//   4) allocate_linear with k=2 regs forces at least one spill.
//   5) The spill heuristic picks a long-lived, cold interval first —
//      we verify by rigging a 6-instruction block where a cold long-
//      lived value competes with a hot short-lived value for 1 reg.
//
// Run: build/hexa_stage0 self/test_liveness_regalloc.hexa
//
// stage0 compiles per-file, so we inline the types and the entire
// allocator body. They are a 1:1 copy of self/codegen/liveness_regalloc.hexa
// — the production source of truth. When either file changes, mirror
// the edit in the other.

// ═══════════════════════════════════════════════════════════════
//  Inlined module (mirror of self/codegen/liveness_regalloc.hexa)
// ═══════════════════════════════════════════════════════════════

struct LR {
    value: int,
    start: int,
    end_pos: int,
    uses: int
}

fn lr_new(value: int, start: int, end_pos: int, uses: int) -> LR {
    return LR {
        value: value,
        start: start,
        end_pos: end_pos,
        uses: uses
    }
}

struct RegallocResult {
    vids: [int],
    tags: [int],
    vals: [int],
    used_regs: [int],
    stack_bytes: int,
    spill_count: int
}

fn scan_def_use(block_instrs: [[int]]) -> [[int]] {
    let mut def_vids = []
    let mut def_idx = []
    let mut use_vids = []
    let mut use_idx = []
    let mut i = 0
    while i < len(block_instrs) {
        let instr = block_instrs[i]
        if len(instr) > 0 {
            let result = instr[0]
            if result >= 0 {
                def_vids.push(result)
                def_idx.push(i)
            }
            let mut j = 1
            while j < len(instr) {
                let op = instr[j]
                if op >= 0 {
                    use_vids.push(op)
                    use_idx.push(i)
                }
                j = j + 1
            }
        }
        i = i + 1
    }
    return [def_vids, def_idx, use_vids, use_idx]
}

fn build_intervals(block_instrs: [[int]]) -> [LR] {
    let defuse = scan_def_use(block_instrs)
    let def_vids = defuse[0]
    let def_idx = defuse[1]
    let use_vids = defuse[2]
    let use_idx = defuse[3]

    let mut intervals = []
    let mut i = 0
    while i < len(def_vids) {
        let vid = def_vids[i]
        let start = def_idx[i]
        let mut end_pos = start
        let mut uses = 0
        let mut j = 0
        while j < len(use_vids) {
            if use_vids[j] == vid {
                if use_idx[j] > end_pos { end_pos = use_idx[j] }
                uses = uses + 1
            }
            j = j + 1
        }
        intervals.push(lr_new(vid, start, end_pos, uses))
        i = i + 1
    }
    return intervals
}

fn lr_contains(arr: [int], val: int) -> bool {
    let mut i = 0
    while i < len(arr) {
        if arr[i] == val { return true }
        i = i + 1
    }
    return false
}

fn lr_remove_at(arr: [int], idx: int) -> [int] {
    let mut out = []
    let mut i = 0
    while i < len(arr) {
        if i != idx { out.push(arr[i]) }
        i = i + 1
    }
    return out
}

fn spill_pick(active_end: [int], active_uses: [int], new_end: int, new_uses: int) -> int {
    let mut best_score = new_end * 100 / (1 + new_uses)
    let mut best_idx = -1
    let mut i = 0
    while i < len(active_end) {
        let score = active_end[i] * 100 / (1 + active_uses[i])
        if score > best_score {
            best_score = score
            best_idx = i
        }
        i = i + 1
    }
    return best_idx
}

fn allocate_linear(intervals: [LR], regs: [int]) -> RegallocResult {
    let k = len(regs)

    let mut sorted = []
    let mut consumed = []
    let n = len(intervals)
    let mut t = 0
    while t < n { consumed.push(0); t = t + 1 }
    let mut ordered = 0
    while ordered < n {
        let mut best = -1
        let mut s = 0
        while s < n {
            if consumed[s] == 0 {
                if best < 0 { best = s }
                else if intervals[s].start < intervals[best].start { best = s }
            }
            s = s + 1
        }
        sorted.push(intervals[best])
        let mut new_consumed = []
        let mut cc = 0
        while cc < n {
            if cc == best { new_consumed.push(1) }
            else { new_consumed.push(consumed[cc]) }
            cc = cc + 1
        }
        consumed = new_consumed
        ordered = ordered + 1
    }

    let mut out_vids = []
    let mut out_tags = []
    let mut out_vals = []
    let mut used_regs = []
    let mut stack_off = 0
    let mut spill_count = 0

    let mut active_regidx = []
    let mut active_end = []
    let mut active_uses = []
    let mut active_vid = []

    let mut free_regs = []
    let mut fi = k - 1
    while fi >= 0 {
        free_regs.push(fi)
        fi = fi - 1
    }

    let mut i = 0
    while i < len(sorted) {
        let iv = sorted[i]

        let mut j = 0
        while j < len(active_end) {
            if active_end[j] < iv.start {
                free_regs.push(active_regidx[j])
                active_regidx = lr_remove_at(active_regidx, j)
                active_end = lr_remove_at(active_end, j)
                active_uses = lr_remove_at(active_uses, j)
                active_vid = lr_remove_at(active_vid, j)
            } else {
                j = j + 1
            }
        }

        if len(active_regidx) < k {
            let top = len(free_regs) - 1
            let reg_idx = free_regs[top]
            free_regs = lr_remove_at(free_regs, top)

            let reg = regs[reg_idx]
            out_vids.push(iv.value)
            out_tags.push(0)
            out_vals.push(reg)
            if !lr_contains(used_regs, reg) { used_regs.push(reg) }

            active_regidx.push(reg_idx)
            active_end.push(iv.end_pos)
            active_uses.push(iv.uses)
            active_vid.push(iv.value)
        } else {
            let evict = spill_pick(active_end, active_uses, iv.end_pos, iv.uses)
            if evict < 0 {
                stack_off = stack_off - 8
                out_vids.push(iv.value)
                out_tags.push(1)
                out_vals.push(stack_off)
                spill_count = spill_count + 1
            } else {
                let victim_vid = active_vid[evict]
                let victim_regidx = active_regidx[evict]

                stack_off = stack_off - 8
                let mut ri = 0
                let mut new_tags = []
                let mut new_vals = []
                while ri < len(out_vids) {
                    if out_vids[ri] == victim_vid {
                        new_tags.push(1)
                        new_vals.push(stack_off)
                    } else {
                        new_tags.push(out_tags[ri])
                        new_vals.push(out_vals[ri])
                    }
                    ri = ri + 1
                }
                out_tags = new_tags
                out_vals = new_vals
                spill_count = spill_count + 1

                let reg = regs[victim_regidx]
                out_vids.push(iv.value)
                out_tags.push(0)
                out_vals.push(reg)
                if !lr_contains(used_regs, reg) { used_regs.push(reg) }

                let mut new_ar = []
                let mut new_ae = []
                let mut new_au = []
                let mut new_av = []
                let mut ai = 0
                while ai < len(active_regidx) {
                    if ai == evict {
                        new_ar.push(victim_regidx)
                        new_ae.push(iv.end_pos)
                        new_au.push(iv.uses)
                        new_av.push(iv.value)
                    } else {
                        new_ar.push(active_regidx[ai])
                        new_ae.push(active_end[ai])
                        new_au.push(active_uses[ai])
                        new_av.push(active_vid[ai])
                    }
                    ai = ai + 1
                }
                active_regidx = new_ar
                active_end = new_ae
                active_uses = new_au
                active_vid = new_av
            }
        }
        i = i + 1
    }

    let mut stack_bytes = 0
    if stack_off < 0 {
        stack_bytes = (0 - stack_off + 15) / 16 * 16
    }

    return RegallocResult {
        vids: out_vids,
        tags: out_tags,
        vals: out_vals,
        used_regs: used_regs,
        stack_bytes: stack_bytes,
        spill_count: spill_count
    }
}

fn regalloc_lookup_vid(vids: [int], vid: int) -> int {
    let mut i = 0
    while i < len(vids) {
        if vids[i] == vid { return i }
        i = i + 1
    }
    return -1
}

// ═══════════════════════════════════════════════════════════════
//  Test driver
// ═══════════════════════════════════════════════════════════════

let mut pass_count = 1
let mut fail_count = 1
pass_count = 0
fail_count = 0

fn check_int(name, got, expected) {
    if got == expected {
        println("[PASS] " + name + " = " + to_string(got))
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " expected " + to_string(expected)
            + ", got " + to_string(got))
        fail_count = fail_count + 1
    }
}

fn check_ge(name, got, min_val) {
    if got >= min_val {
        println("[PASS] " + name + " = " + to_string(got) + " >= " + to_string(min_val))
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " expected >= " + to_string(min_val)
            + ", got " + to_string(got))
        fail_count = fail_count + 1
    }
}

fn check_bool_true(name, got) {
    if got {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " expected true")
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  liveness_regalloc scaffold — ROI #185")
println("═══════════════════════════════════════════════════════")

// ── Build the 5-instruction example IR ──
// Each row: [result_vid, op_vid_1, ...].
let mut block = []
// v0 = load
let mut r0 = []
r0.push(0)
block.push(r0)
// v1 = load
let mut r1 = []
r1.push(1)
block.push(r1)
// v2 = add v0, v1
let mut r2 = []
r2.push(2); r2.push(0); r2.push(1)
block.push(r2)
// v3 = mul v2, v0
let mut r3 = []
r3.push(3); r3.push(2); r3.push(0)
block.push(r3)
// v4 = sub v3, v2
let mut r4 = []
r4.push(4); r4.push(3); r4.push(2)
block.push(r4)

check_int("block instrs", len(block), 5)

// ── T1: scan_def_use ──
let defuse = scan_def_use(block)
let def_vids = defuse[0]
let use_vids = defuse[2]
check_int("scan def count", len(def_vids), 5)
// Uses: v0(2x in add,mul), v1(1x in add), v2(2x in mul,sub), v3(1x in sub) = 6
check_int("scan use count", len(use_vids), 6)

// ── T2: build_intervals ──
let ivs = build_intervals(block)
check_int("interval count", len(ivs), 5)

// v0: start=0, end=3 (used in mul@idx3), uses=2
let iv0 = ivs[0]
check_int("v0 start", iv0.start, 0)
check_int("v0 end_pos", iv0.end_pos, 3)
check_int("v0 uses", iv0.uses, 2)

// v1: start=1, end=2 (used in add@idx2), uses=1
let iv1 = ivs[1]
check_int("v1 start", iv1.start, 1)
check_int("v1 end_pos", iv1.end_pos, 2)
check_int("v1 uses", iv1.uses, 1)

// v2: start=2, end=4 (used in sub@idx4), uses=2
let iv2 = ivs[2]
check_int("v2 start", iv2.start, 2)
check_int("v2 end_pos", iv2.end_pos, 4)
check_int("v2 uses", iv2.uses, 2)

// v3: start=3, end=4, uses=1
let iv3 = ivs[3]
check_int("v3 start", iv3.start, 3)
check_int("v3 end_pos", iv3.end_pos, 4)
check_int("v3 uses", iv3.uses, 1)

// v4: start=4, end=4, uses=0
let iv4 = ivs[4]
check_int("v4 start", iv4.start, 4)
check_int("v4 end_pos", iv4.end_pos, 4)
check_int("v4 uses", iv4.uses, 0)

// ── T3: allocate_linear with k=3 — no spill ──
let mut regs3 = []
regs3.push(10); regs3.push(11); regs3.push(12)
let r_k3 = allocate_linear(ivs, regs3)
check_int("k=3 vids assigned", len(r_k3.vids), 5)
check_int("k=3 spills", r_k3.spill_count, 0)
check_int("k=3 stack bytes", r_k3.stack_bytes, 0)
// Every VID must resolve to a REG tag.
let mut k3_reg_count = 0
let mut ti = 0
while ti < len(r_k3.tags) {
    if r_k3.tags[ti] == 0 { k3_reg_count = k3_reg_count + 1 }
    ti = ti + 1
}
check_int("k=3 all REG", k3_reg_count, 5)
// At least 3 distinct physical regs used (since at least 3 lifetimes overlap).
check_ge("k=3 used_regs count", len(r_k3.used_regs), 3)

// ── T4: allocate_linear with k=2 — forced spill ──
// At instruction 3 (mul v2, v0), v0/v1-expired/v2/v3 coexist → v0 and
// v2 are live + v3 is newly defined = 3 > 2 regs.
let mut regs2 = []
regs2.push(20); regs2.push(21)
let r_k2 = allocate_linear(ivs, regs2)
check_int("k=2 vids assigned", len(r_k2.vids), 5)
check_ge("k=2 spills", r_k2.spill_count, 1)
check_ge("k=2 stack bytes", r_k2.stack_bytes, 16)

// ── T5: spill heuristic — cold long-lived beats hot short-lived ──
// Build a second synthetic block where we rig:
//   cold = v0 defined at 0, used once at idx 5 (long, cold)
//   hot  = v1 defined at 1, used 3 times at idx 2,3,4 (short, hot)
//   v2   = start at 2 competing for 1 reg with hot
// k=1 means exactly one value fits — spill_pick should prefer cold
// (long + cold = highest score) over hot.
let mut cold_ivs = []
cold_ivs.push(lr_new(0, 0, 5, 1))    // cold long-lived
cold_ivs.push(lr_new(1, 1, 4, 3))    // hot short-lived
cold_ivs.push(lr_new(2, 2, 3, 1))    // filler

let mut regs1 = []
regs1.push(30)
let r_spill = allocate_linear(cold_ivs, regs1)
// v0 starts first, takes the single reg. When v1 arrives at idx 1,
// spill_pick compares: v0 score = 5*100/(1+1)=250, v1 score =
// 4*100/(1+3)=100. v0 wins → v0 evicted to stack, v1 takes the reg.
let idx_v0 = regalloc_lookup_vid(r_spill.vids, 0)
let idx_v1 = regalloc_lookup_vid(r_spill.vids, 1)
check_bool_true("v0 found", idx_v0 >= 0)
check_bool_true("v1 found", idx_v1 >= 0)
// v0 should end up on the stack (evicted), v1 on the register.
check_int("spill-heuristic: cold v0 on stack", r_spill.tags[idx_v0], 1)
check_int("spill-heuristic: hot v1 in reg", r_spill.tags[idx_v1], 0)

// ── Summary ──
println("")
println("═══════════════════════════════════════════════════════")
println("  liveness_regalloc: " + to_string(pass_count) + " pass, "
    + to_string(fail_count) + " fail")
println("═══════════════════════════════════════════════════════")
if fail_count > 0 {
    println("FAIL")
} else {
    println("ALL PASS")
}
