// ═══════════════════════════════════════════════════════════
//  test_error_handling.hexa — Try/Catch/Throw Error Handling Tests
//  Tests: basic try/catch, throw, nested, propagation, in loops,
//         error recovery, partial computation, function throws
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA Error Handling Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Try/catch with no error ────────────────────────────

println("--- Basic Try/Catch ---")

let mut r1 = 0
try {
    r1 = 42
} catch e {
    r1 = -1
}
check("try no error", r1, 42)

// ── 2. Catch a thrown error ───────────────────────────────

let mut r2 = 0
try {
    throw "boom"
    r2 = 99
} catch e {
    r2 = -1
}
check("throw caught", r2, -1)

// ── 3. Error stops execution in try block ─────────────────

let mut r3 = 0
try {
    r3 = r3 + 10
    r3 = r3 + 20
    throw "stop"
    r3 = r3 + 100
} catch e {
    r3 = r3 + 1
}
check("partial compute + catch", r3, 31)

// ── 4. Function that throws ───────────────────────────────

println("")
println("--- Function Throws ---")

fn safe_div(a, b) {
    if b == 0 {
        throw "division by zero"
    }
    return a / b
}

let mut r4 = 0
try {
    r4 = safe_div(10, 2)
} catch e {
    r4 = -1
}
check("safe_div(10,2)", r4, 5)

let mut r5 = 0
try {
    r5 = safe_div(10, 0)
} catch e {
    r5 = -1
}
check("safe_div(10,0)", r5, -1)

fn must_positive(x) {
    if x <= 0 {
        throw "must be positive"
    }
    return x
}

let mut r6 = 0
try {
    r6 = must_positive(5)
} catch e {
    r6 = -1
}
check("must_positive(5)", r6, 5)

let mut r7 = 0
try {
    r7 = must_positive(-3)
} catch e {
    r7 = -1
}
check("must_positive(-3)", r7, -1)

// ── 5. Nested try/catch ───────────────────────────────────

println("")
println("--- Nested Try/Catch ---")

let mut r8 = ""
try {
    try {
        throw "inner"
    } catch e {
        r8 = "inner caught"
    }
} catch e {
    r8 = "outer caught"
}
check("nested inner catch", r8, "inner caught")

// Inner throw propagates to outer
let mut r9 = ""
try {
    try {
        throw "level 1"
    } catch e {
        throw "level 2"
    }
} catch e {
    r9 = "outer"
}
check("nested propagation", r9, "outer")

// ── 6. Try/catch in loop ──────────────────────────────────

println("")
println("--- Try/Catch in Loop ---")

let mut errors = 0
let mut successes = 0
let mut i = 0

while i < 5 {
    try {
        if i == 2 || i == 4 {
            throw "bad"
        }
        successes = successes + 1
    } catch e {
        errors = errors + 1
    }
}
check("loop errors", errors, 2)
check("loop successes", successes, 3)

// ── 7. Accumulation with error handling ───────────────────

println("")
println("--- Error Recovery Pattern ---")

fn parse_int_safe(s) {
    if s == "abc" {
        throw "not a number"
    }
    return to_int(s)
}

let inputs = ["1", "2", "abc", "4", "5"]
let mut total = 0
let mut parse_errors = 0
for inp in inputs {
    try {
        total = total + parse_int_safe(inp)
    } catch e {
        parse_errors = parse_errors + 1
    }
}
check("parse total", total, 12)
check("parse errors", parse_errors, 1)

// ── 8. Try/catch as guard pattern ─────────────────────────

println("")
println("--- Guard Pattern ---")

fn validated_age(age) {
    if age < 0 { throw "negative age" }
    if age > 150 { throw "unreasonable age" }
    return age
}

fn try_validate(age) {
    let mut result = -1
    try {
        result = validated_age(age)
    } catch e {
        result = -1
    }
    return result
}

check("validate 25", try_validate(25), 25)
check("validate -5", try_validate(-5), -1)
check("validate 200", try_validate(200), -1)
check("validate 0", try_validate(0), 0)
check("validate 150", try_validate(150), 150)

// ── 9. Multiple catch patterns ────────────────────────────

println("")
println("--- Multiple Throws ---")

fn process(code) {
    if code == 0 { throw "zero" }
    if code < 0 { throw "negative" }
    return code * 10
}

let mut results = []
for c in [-1, 0, 1, 2, -5] {
    try {
        results.push(process(c))
    } catch e {
        results.push(-1)
    }
}
check("multi[0]", results[0], -10)
check("multi[1]", results[1], -1)
check("multi[2]", results[2], 0)
check("multi[3]", results[3], -1)
check("multi[4]", results[4], 10)

// ── 10. Resource cleanup pattern ──────────────────────────

println("")
println("--- Cleanup Pattern ---")

let mut log = []
let mut cleanup_ran = false

try {
    log.push("start")
    log.push("work")
    throw "error"
    log.push("never")
} catch e {
    log.push("caught")
}
log.push("cleanup")
cleanup_ran = true

check("log len", len(log), 4)
check("log[0]", log[0], "start")
check("log[1]", log[1], "work")
check("log[2]", log[2], "caught")
check("log[3]", log[3], "cleanup")
check("cleanup ran", cleanup_ran, true)

// ═══════════════════════════════════════════════════════════
//  SUMMARY
// ═══════════════════════════════════════════════════════════

println("")
println("═══════════════════════════════════════════════════════")
let total_tests = pass_count + fail_count
println("  Results: " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL / " + to_string(total_tests) + " total")
if fail_count == 0 {
    println("  ALL ERROR HANDLING TESTS PASSED!")
} else {
    println("  SOME TESTS FAILED")
}
println("═══════════════════════════════════════════════════════")
