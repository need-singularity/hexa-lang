// self/runtime_hi.hexa — M1-lite probe + M1 full file-layer SSOT
// (hxa-20260423-003)
//
// ── M1-lite (str domain — 완료) ──
// 첫 5개 hi-layer 함수를 `.hexa` 로 재구현한 증명 파일.
// docs/runtime_audit_20260423.md §3 — pad_left/pad_right/repeat/center/lines.
// rt_str_* 는 tool/extract_runtime_hi.sh 로 runtime_hi_gen.c 에 static 으로
// emit 되어 runtime.c 에 #include 됨. codegen 은 rt_str_* 직접 디스패치.
//
// ── M1 full · file domain (Step 3 land — hxa-20260423-003) ──
// runtime.c 의 hexa_read_file/hexa_write_file/hexa_file_exists/hexa_read_file_bytes/
// hexa_read_bytes_at/hexa_write_bytes{,_v,_append,_append_v}/hexa_file_size/
// hexa_read_lines/hexa_delete_file/hexa_append_file (12개) 이 rt_file_* +
// rt_read_lines + rt_delete_file + rt_append_file 로 hand-port + hexa_* 가
// shim 으로 재작성됨 (M1-lite Step 3 equivalent).
// Step 4 (.hexa SSOT extract) 는 file I/O 가 libc-level (fopen/fread/fwrite/
// access/unlink) 이라 `.hexa` primitive 로 합성 불가 — 해당 도메인 에서
// hand-port C 가 영구 SSOT 이며, 본 파일은 이 사실을 기록 하는 목적.
// Step 5 (codegen flip to rt_file_*) 는 다음 세션 (위험 무-관 / 단순 rename).

// ── split (runtime.c L3194 대응 — O(n*m) substring scan, arena-only) ──
fn rt_str_split(s: string, delim: string) -> [string] {
    let mut out = []
    if len(delim) == 0 {
        out.push(s)
        return out
    }
    let dlen = len(delim)
    let mut start = 0
    let mut i = 0
    while i <= len(s) - dlen {
        if s.substring(i, i + dlen) == delim {
            out.push(s.substring(start, i))
            start = i + dlen
            i = start
        } else {
            i = i + 1
        }
    }
    out.push(s.substring(start, len(s)))
    return out
}

// ── lines (runtime.c L3363) — "\n" delimiter wrapper ────────────────
fn rt_str_lines(s: string) -> [string] {
    return rt_str_split(s, "\n")
}

// ── pad_left / pad_right (runtime.c L3588, L3611) ───────────────────
// Multi-char pad iteration: ceil((width-slen)/plen) repeats of the pad.
// Returns s unchanged if already >= width, or pad is empty.
fn rt_str_pad_left(s: string, width: int, pad: string) -> string {
    let slen = len(s)
    let plen = len(pad)
    if slen >= width { return s }
    if plen == 0 { return s }
    let pad_total = width - slen
    let mut iters = pad_total / plen
    if iters * plen < pad_total { iters = iters + 1 }
    let mut parts = []
    let mut i = 0
    while i < iters {
        parts.push(pad)
        i = i + 1
    }
    parts.push(s)
    return parts.join("")
}

fn rt_str_pad_right(s: string, width: int, pad: string) -> string {
    let slen = len(s)
    let plen = len(pad)
    if slen >= width { return s }
    if plen == 0 { return s }
    let pad_total = width - slen
    let mut iters = pad_total / plen
    if iters * plen < pad_total { iters = iters + 1 }
    let mut parts = []
    parts.push(s)
    let mut i = 0
    while i < iters {
        parts.push(pad)
        i = i + 1
    }
    return parts.join("")
}

// ── repeat (runtime.c L3561) — count<=0 → "" ──────────────────────
fn rt_str_repeat(s: string, count: int) -> string {
    if count <= 0 { return "" }
    let mut parts = []
    let mut i = 0
    while i < count {
        parts.push(s)
        i = i + 1
    }
    return parts.join("")
}

// ── center (runtime.c L3622) — pad both sides, odd remainder → right ─
fn rt_str_center(s: string, width: int, pad: string) -> string {
    let slen = len(s)
    let plen = len(pad)
    if slen >= width { return s }
    if plen == 0 { return s }
    let total_pad = width - slen
    let left_pad = total_pad / 2
    let right_pad = total_pad - left_pad
    let mut li = left_pad / plen
    if li * plen < left_pad { li = li + 1 }
    let mut ri = right_pad / plen
    if ri * plen < right_pad { ri = ri + 1 }
    let mut parts = []
    let mut i = 0
    while i < li {
        parts.push(pad)
        i = i + 1
    }
    parts.push(s)
    let mut j = 0
    while j < ri {
        parts.push(pad)
        j = j + 1
    }
    return parts.join("")
}

// ── M1-lite smoke probe (main은 exit 0, functions 존재 증명) ────────
// 실제 대사(cutover) 는 다음 세션. 이 파일 자체는 stage0 컴파일 검증용.
// 호출부 없이도 hexa_v2 가 각 함수를 HexaVal-반환형으로 emit 하는지 확인.
fn runtime_hi_selftest() -> int {
    let a = rt_str_pad_left("7", 3, "0")       // "007"
    let b = rt_str_pad_right("7", 3, "0")      // "700"
    let c = rt_str_repeat("ab", 3)             // "ababab"
    let d = rt_str_center("hi", 6, "-")        // "--hi--"
    let e = rt_str_lines("a\nb\nc")            // ["a","b","c"]
    if a == "007" && b == "700" && c == "ababab" && d == "--hi--" && len(e) == 3 {
        return 0
    }
    return 1
}

fn main() {
    let rc = runtime_hi_selftest()
    if rc == 0 {
        println("runtime_hi: selftest OK")
    } else {
        println("runtime_hi: selftest FAIL")
        exit(1)
    }
}
