// ═══════════════════════════════════════════════════════════════════
//  self/ml/homomorphic_inference.hexa — Homomorphic Inference (#284)
//
//  Forward-pass on encrypted inputs using a polynomial network.
//  CKKS and related FHE schemes natively support add / multiply on
//  packed real vectors but NOT non-polynomial ops like ReLU.  We
//  therefore replace activation with a quadratic approximation:
//
//      ReLU(z) ≈ 0.125 z² + 0.5 z + 0.25        (CryptoNets-style)
//      σ(z)    ≈ 0.5 + 0.197 z − 0.004 z³       (optional sigmoid)
//
//  Encryption is simulated as a (shift, scale, nonce) triple so we
//  can verify enc/dec round-trips and demonstrate homomorphic
//  add/mul invariants.  The network forward pass is identical on
//  plaintext and ciphertext vectors.
//
//  API:
//    hom_encrypt(vec, shift, scale, seed) -> CT
//    hom_decrypt(ct)                      -> [float]
//    hom_add(a, b)                        -> CT
//    hom_scale(ct, c)                     -> CT
//    hom_mul(a, b)                        -> CT
//    hom_poly_relu(ct)                    -> CT
//    hom_poly_sigmoid(ct)                 -> CT
//    hom_linear(W, b, vec)                -> [float]
//    hom_forward(W1, b1, W2, b2, vec)     -> [float]
//    hom_ct_linear(W, b, ct)              -> CT
//    hom_ct_forward(W1, b1, W2, b2, ct)   -> CT
//    hom_round_trip_error(vec, shift, scale, seed) -> float
//
//  AI-NATIVE attrs:
//    @pure
// ═══════════════════════════════════════════════════════════════════

fn hom_zeros_f(n) {
    let mut v = []
    let mut _i = 0

    while _i < n { v = v + [0.0] }
    return v
}

fn hom_abs(inp) { if inp < 0.0 { return 0.0 - inp } return inp }

fn hom_max0(inp) { if inp < 0.0 { return 0.0 } return inp }

fn hom_lcg(state) {
    return (state * 1103515245 + 12345) % 2147483648
}

// ═══════════════════════════════════════════════════════════════════
//  Ciphertext representation:
//    #{ "data": [float] (blinded), "shift": float, "scale": float, "nonce": int }
//
//  enc:  d_i = (x_i + shift) * scale + small_nonce_noise
//  dec:  x_i = d_i / scale - shift  (nonce cancels under add/mul because
//                                    we track shift/scale explicitly)
// ═══════════════════════════════════════════════════════════════════
fn hom_encrypt(vec, shift, scale, seed) {
    let n = len(vec)
    let mut data = hom_zeros_f(n)
    let mut state = seed
    if state <= 0 { state = 1 }
    let mut i = 0

    while i < n {
        state = hom_lcg(state)
        if state <= 0 { state = 1 }
        let noise = (to_float(state) / 2147483648.0 - 0.5) * 1.0e-9
        data[i] = (vec[i] + shift) * scale + noise
    }
    return #{
        "data": data,
        "shift": shift,
        "scale": scale,
        "nonce": state
    }
}

fn hom_decrypt(ct) {
    let data = ct["data"]
    let shift = ct["shift"]
    let scale = ct["scale"]
    let n = len(data)
    let mut out = hom_zeros_f(n)
    let mut i = 0

    while i < n { out[i] = data[i] / scale - shift }
    return out
}

// ═══════════════════════════════════════════════════════════════════
//  Homomorphic add: only valid when scale is aligned.  If shifts
//  differ we rebalance.  We keep the simpler invariant scale_a == scale_b.
// ═══════════════════════════════════════════════════════════════════
fn hom_add(a, b) {
    let da = a["data"]
    let db = b["data"]
    let n = len(da)
    let mut out = hom_zeros_f(n)
    let mut i = 0

    while i < n { out[i] = da[i] + db[i] }
    return #{
        "data": out,
        "shift": a["shift"] + b["shift"],
        "scale": a["scale"],
        "nonce": a["nonce"]
    }
}

// ═══════════════════════════════════════════════════════════════════
//  Scalar multiply  c * ct  (shift absorbed linearly)
// ═══════════════════════════════════════════════════════════════════
fn hom_scale(ct, c) {
    let d = ct["data"]
    let n = len(d)
    let mut out = hom_zeros_f(n)
    let mut i = 0

    while i < n { out[i] = d[i] * c }
    return #{
        "data": out,
        "shift": ct["shift"] * c,
        "scale": ct["scale"],
        "nonce": ct["nonce"]
    }
}

// ═══════════════════════════════════════════════════════════════════
//  Add a plaintext scalar bias s to every slot
// ═══════════════════════════════════════════════════════════════════
fn hom_add_plain(ct, s) {
    let d = ct["data"]
    let scale = ct["scale"]
    let n = len(d)
    let mut out = hom_zeros_f(n)
    let mut i = 0

    while i < n { out[i] = d[i] + s * scale }
    return #{
        "data": out,
        "shift": ct["shift"],
        "scale": scale,
        "nonce": ct["nonce"]
    }
}

// ═══════════════════════════════════════════════════════════════════
//  Ciphertext × ciphertext (element-wise) — rescaled to match inputs
//  (CKKS "rescale after mult" so scale stays bounded)
// ═══════════════════════════════════════════════════════════════════
fn hom_mul(a, b) {
    let da = a["data"]
    let db = b["data"]
    let sa = a["scale"]
    let sb = b["scale"]
    let sha = a["shift"]
    let shb = b["shift"]
    let n = len(da)
    let mut out = hom_zeros_f(n)
    let mut i = 0

    while i < n {
        let va = da[i] / sa - sha
        let vb = db[i] / sb - shb
        // Product plaintext then re-encode at scale sa (canonical scale)
        out[i] = va * vb * sa
    }
    return #{
        "data": out,
        "shift": 0.0,
        "scale": sa,
        "nonce": a["nonce"]
    }
}

// ═══════════════════════════════════════════════════════════════════
//  Polynomial ReLU approximation (CryptoNets)
//      f(z) = 0.125 z² + 0.5 z + 0.25
//  Implementable with only add/mul.
// ═══════════════════════════════════════════════════════════════════
fn hom_poly_relu(ct) {
    let sq = hom_mul(ct, ct)
    let term1 = hom_scale(sq, 0.125)
    let term2 = hom_scale(ct, 0.5)
    let sum12 = hom_add(term1, term2)
    return hom_add_plain(sum12, 0.25)
}

// Plain version for comparison
@pure
fn hom_poly_relu_plain(vec) {
    let n = len(vec)
    let mut out = hom_zeros_f(n)
    let mut i = 0

    while i < n {
        let z = vec[i]
        out[i] = 0.125 * z * z + 0.5 * z + 0.25
    }
    return out
}

// ═══════════════════════════════════════════════════════════════════
//  Polynomial sigmoid   σ(z) ≈ 0.5 + 0.197·z - 0.004·z³
// ═══════════════════════════════════════════════════════════════════
@pure
fn hom_poly_sigmoid_plain(vec) {
    let n = len(vec)
    let mut out = hom_zeros_f(n)
    let mut i = 0

    while i < n {
        let z = vec[i]
        let z3 = z * z * z
        out[i] = 0.5 + 0.197 * z - 0.004 * z3
    }
    return out
}

// ═══════════════════════════════════════════════════════════════════
//  Plaintext linear layer  y = W x + b
// ═══════════════════════════════════════════════════════════════════
@pure
fn hom_linear(W, b, vec) {
    let K = len(W)
    let D = len(vec)
    let mut out = hom_zeros_f(K)
    let mut k = 0

    while k < K {
        let mut s = b[k]
        let mut j = 0

        while j < D { s = s + W[k][j] * vec[j] }
        out[k] = s
    }
    return out
}

// ═══════════════════════════════════════════════════════════════════
//  Plaintext two-layer forward (polynomial activation)
// ═══════════════════════════════════════════════════════════════════
@pure
fn hom_forward(W1, b1, W2, b2, vec) {
    let h = hom_linear(W1, b1, vec)
    let h_act = hom_poly_relu_plain(h)
    return hom_linear(W2, b2, h_act)
}

// ═══════════════════════════════════════════════════════════════════
//  Ciphertext linear layer.  W and b are plaintext weights.
//    y_k = Σ_j W[k,j] · x_j + b_k
//  Packed ct holds one slot per feature; we "rotate" by materialising
//  scalar contributions.  For simplicity we return an unpacked
//  vector-ct (one slot per output).
// ═══════════════════════════════════════════════════════════════════
fn hom_ct_linear(W, b, ct) {
    let K = len(W)
    let D = len(W[0])
    let scale = ct["scale"]
    let data = ct["data"]
    let shift = ct["shift"]
    let mut out = hom_zeros_f(K)
    let mut k = 0

    while k < K {
        let mut s = 0.0
        let mut j = 0

        while j < D {
            // contribution: W[k,j] * (data_j / scale - shift) scaled back by 'scale'
            s = s + W[k][j] * data[j]
        }
        // s is in "scaled" space; add bias (b_k) * scale; remove shift term
        out[k] = s - scale * shift * 0.0 + b[k] * scale
        // subtract shift contribution if W row has non-zero sum
        let mut row_sum = 0.0
        let mut j = 0

        while j < D { row_sum = row_sum + W[k][j] }
        out[k] = out[k] - row_sum * shift * scale
    }
    return #{
        "data": out,
        "shift": 0.0,
        "scale": scale,
        "nonce": ct["nonce"]
    }
}

// ═══════════════════════════════════════════════════════════════════
//  Ciphertext forward pass
// ═══════════════════════════════════════════════════════════════════
fn hom_ct_forward(W1, b1, W2, b2, ct) {
    let h = hom_ct_linear(W1, b1, ct)
    let h_act = hom_poly_relu(h)
    return hom_ct_linear(W2, b2, h_act)
}

// ═══════════════════════════════════════════════════════════════════
//  Encryption round-trip error (L2)
// ═══════════════════════════════════════════════════════════════════
fn hom_round_trip_error(vec, shift, scale, seed) {
    let ct = hom_encrypt(vec, shift, scale, seed)
    let dec = hom_decrypt(ct)
    let n = len(vec)
    let mut err = 0.0
    let mut i = 0

    while i < n {
        let d = dec[i] - vec[i]
        err = err + d * d
    }
    return err
}


// -- end inlined --

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name)
        fail_count = fail_count + 1
    }
}

fn fabs_(inp) { if inp < 0.0 { return 0.0 - inp } return inp }
fn approx_(a, b, eps) { return fabs_(a - b) < eps }

fn vec_close(a, b, eps) {
    let n = len(a)
    if n != len(b) { return false }
    let mut i = 0

    while i < n {
        if fabs_(a[i] - b[i]) > eps { return false }
    }
    return true
}

println("=== Homomorphic Inference (#284) ===")

// ── T1 encryption round-trip ───────────────────────────────
let v1 = [1.0, 2.0, 3.0, 4.0]
let ct1 = hom_encrypt(v1, 2.0, 10.0, 42)
let dec1 = hom_decrypt(ct1)
check("T1 round-trip", vec_close(v1, dec1, 1.0e-6))

// ── T2 round-trip L2 error small ───────────────────────────
let err2 = hom_round_trip_error([0.5, -0.5, 1.5, -1.5], 1.0, 5.0, 7)
check("T2 L2 error ~0", err2 < 1.0e-8)

// ── T3 hom_add correctness ─────────────────────────────────
let a3 = hom_encrypt([1.0, 2.0], 0.0, 10.0, 1)
let b3 = hom_encrypt([3.0, 4.0], 0.0, 10.0, 2)
let sum3 = hom_add(a3, b3)
let dsum3 = hom_decrypt(sum3)
check("T3 hom_add[0]", approx_(dsum3[0], 4.0, 1.0e-4))
check("T3 hom_add[1]", approx_(dsum3[1], 6.0, 1.0e-4))

// ── T4 hom_scale correctness ───────────────────────────────
let s4 = hom_scale(a3, 2.5)
let ds4 = hom_decrypt(s4)
check("T4 scale[0]", approx_(ds4[0], 2.5, 1.0e-4))
check("T4 scale[1]", approx_(ds4[1], 5.0, 1.0e-4))

// ── T5 hom_mul element-wise ────────────────────────────────
let c5 = hom_encrypt([2.0, 3.0], 0.0, 4.0, 11)
let d5 = hom_encrypt([5.0, 6.0], 0.0, 4.0, 12)
let m5 = hom_mul(c5, d5)
let dm5 = hom_decrypt(m5)
check("T5 mul[0]", approx_(dm5[0], 10.0, 1.0e-3))
check("T5 mul[1]", approx_(dm5[1], 18.0, 1.0e-3))

// ── T6 poly relu plain approximates ReLU near 0 ────────────
let zs = [-2.0, -1.0, 0.0, 1.0, 2.0]
let ps = hom_poly_relu_plain(zs)
// At z=0 poly = 0.25, at z=1 poly = 0.125+0.5+0.25 = 0.875, at z=2 poly = 0.5+1+0.25 = 1.75
check("T6 poly(0)=0.25", approx_(ps[2], 0.25, 1.0e-6))
check("T6 poly(1)=0.875", approx_(ps[3], 0.875, 1.0e-6))
check("T6 poly(2)=1.75", approx_(ps[4], 1.75, 1.0e-6))

// ── T7 poly relu ciphertext ≈ plain ─────────────────────────
let ct7 = hom_encrypt([-1.0, 0.0, 1.0, 2.0], 0.0, 5.0, 21)
let cty7 = hom_poly_relu(ct7)
let dy7 = hom_decrypt(cty7)
let plain7 = hom_poly_relu_plain([-1.0, 0.0, 1.0, 2.0])
check("T7 ct poly_relu ≈ plain", vec_close(dy7, plain7, 1.0e-3))

// ── T8 poly sigmoid monotone around 0 ──────────────────────
let ss = hom_poly_sigmoid_plain([-1.0, 0.0, 1.0])
check("T8 sigmoid(0)=0.5", approx_(ss[1], 0.5, 1.0e-6))
check("T8 sigmoid monotone", ss[2] > ss[1] && ss[1] > ss[0])

// ── T9 plaintext forward matches expectation ────────────────
let W1 = [[1.0, 0.0], [0.0, 1.0]]
let b1 = [0.0, 0.0]
let W2 = [[1.0, 1.0]]
let b2 = [0.0]
let y_plain = hom_forward(W1, b1, W2, b2, [1.0, 2.0])
// h = [1, 2] -> poly_relu -> [0.875, 1.75] -> sum -> [2.625]
check("T9 plaintext forward", approx_(y_plain[0], 2.625, 1.0e-4))

// ── T10 ct_linear matches plaintext linear ──────────────────
let ct10 = hom_encrypt([1.0, 2.0], 0.5, 8.0, 99)
let y_ct_linear = hom_ct_linear(W1, b1, ct10)
let dy_lin = hom_decrypt(y_ct_linear)
let y_plain_lin = hom_linear(W1, b1, [1.0, 2.0])
check("T10 ct_linear ≈ plaintext", vec_close(dy_lin, y_plain_lin, 1.0e-3))

// ── T11 ct_forward matches plaintext forward ───────────────
let ct11 = hom_encrypt([1.0, 2.0], 0.0, 4.0, 55)
let y_ct = hom_ct_forward(W1, b1, W2, b2, ct11)
let dy_ct = hom_decrypt(y_ct)
check("T11 ct_forward ≈ plain", approx_(dy_ct[0], y_plain[0], 1.0e-2))

// ── T12 add-plain bias ─────────────────────────────────────
let p12 = hom_encrypt([1.0, 2.0, 3.0], 0.0, 4.0, 33)
let p12b = hom_add_plain(p12, 5.0)
let dp12b = hom_decrypt(p12b)
check("T12 add-plain[0]", approx_(dp12b[0], 6.0, 1.0e-4))
check("T12 add-plain[2]", approx_(dp12b[2], 8.0, 1.0e-4))

println("")
println("=== Homomorphic Inference summary ===")
println("PASS: " + str(pass_count))
println("FAIL: " + str(fail_count))
println("TOTAL: " + str(pass_count + fail_count))
