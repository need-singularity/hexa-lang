// ═══════════════════════════════════════════════════════════════════
//  test_length_generalization.hexa — Length Generalization tests
//
//  Validates:
//    1.  RoPE embed dimension correctness
//    2.  RoPE embed: position 0 has sin=0, cos=1 for all dims
//    3.  PI scale: within training length unchanged
//    4.  PI scale: beyond training length is scaled down
//    5.  PI RoPE: position encoding consistency
//    6.  YaRN: output dimension matches
//    7.  YaRN: temperature scaling applied
//    8.  Attention scale: within training = 1.0
//    9.  Attention scale: beyond training > 1.0
//   10.  Attention scale: monotonic
//   11.  Frequency separation: all dims classified
//   12.  Dynamic scale: within training = 1.0
//   13.  Dynamic scale: beyond training > 1.0
//   14.  Dynamic RoPE: dimension correctness
//   15.  Dot product: correctness
//   16.  Position encoding stability at long sequences
//
//  Run: ./hexa self/test_length_generalization.hexa
// ═══════════════════════════════════════════════════════════════════

import "ml/length_generalization.hexa"

let mut pass_count = 0
let mut fail_count = 0

fn check(name, cond) {
    if cond {
        println("PASS " + name)
        pass_count = pass_count + 1
    } else {
        println("FAIL " + name)
        fail_count = fail_count + 1
    }
}

fn fabs(x) { if x < 0.0 { return 0.0 - x } return x }
fn approx(a, b, eps) { return fabs(a - b) < eps }

// ═══════════ Tests ═════════════════════════════════════════════

fn main() {
    println("=== Length Generalization Tests ===")

    let dim = 8
    let base = 10000.0

    // --- Test 1: RoPE embed dimension ---
    let rope0 = lg_rope_embed(5, dim, base)
    check("RoPE dim matches", len(rope0) == dim)

    // --- Test 2: RoPE pos=0: sin(0)=0, cos(0)=1 ---
    let rope_z = lg_rope_embed(0, dim, base)
    let mut pos0_ok = true
    let half = dim / 2
    for i in 0..half {
        // sin component should be ~0
        if fabs(rope_z[2 * i]) > 0.01 { pos0_ok = false }
        // cos component should be ~1
        if fabs(rope_z[2 * i + 1] - 1.0) > 0.01 { pos0_ok = false }
    }
    check("RoPE pos=0 sin=0 cos=1", pos0_ok)

    // --- Test 3: PI scale within training unchanged ---
    let pi_in = lg_pi_scale(50, 100, 100)
    check("PI scale within train", approx(pi_in, 50.0, 0.001))

    // --- Test 4: PI scale beyond training ---
    let pi_out = lg_pi_scale(150, 100, 200)
    check("PI scale beyond train", approx(pi_out, 75.0, 0.001))

    // --- Test 5: PI RoPE consistency ---
    let pi_rope = lg_pi_rope(50, dim, base, 100, 200)
    check("PI RoPE dim matches", len(pi_rope) == dim)
    // At half the position, should give similar encoding
    let std_rope_25 = lg_rope_embed(25, dim, base)
    // PI(50, 100, 200) scales position to 25, so should match rope at pos 25
    let mut pi_close = true
    for i in 0..dim {
        if fabs(pi_rope[i] - std_rope_25[i]) > 0.1 { pi_close = false }
    }
    check("PI RoPE matches scaled position", pi_close)

    // --- Test 6: YaRN output dimension ---
    let yarn = lg_yarn_scale(50, dim, base, 100, 200, 1.0, 32.0)
    check("YaRN dim matches", len(yarn) == dim)

    // --- Test 7: YaRN values are finite ---
    let mut yarn_finite = true
    for i in 0..dim {
        if fabs(yarn[i]) > 100.0 { yarn_finite = false }
    }
    check("YaRN values finite", yarn_finite)

    // --- Test 8: Attention scale within training = 1.0 ---
    let as_in = lg_attention_scale(50, 100)
    check("Attn scale within train = 1.0", approx(as_in, 1.0, 0.001))

    // --- Test 9: Attention scale beyond training > 1.0 ---
    let as_out = lg_attention_scale(200, 100)
    check("Attn scale beyond train > 1.0", as_out > 1.0)

    // --- Test 10: Attention scale monotonic ---
    let as_150 = lg_attention_scale(150, 100)
    let as_300 = lg_attention_scale(300, 100)
    check("Attn scale monotonic", as_300 > as_150)

    // --- Test 11: Frequency separation covers all dims ---
    let freq_sep = lg_freq_separate(dim, base, 0.01)
    let n_high = len(freq_sep[0])
    let n_low = len(freq_sep[1])
    check("Freq sep covers all", n_high + n_low == half)

    // --- Test 12: Dynamic scale within training = 1.0 ---
    let ds_in = lg_dynamic_scale(50, 100)
    check("Dynamic scale within = 1.0", approx(ds_in, 1.0, 0.001))

    // --- Test 13: Dynamic scale beyond training ---
    let ds_out = lg_dynamic_scale(200, 100)
    check("Dynamic scale beyond = 2.0", approx(ds_out, 2.0, 0.001))

    // --- Test 14: Dynamic RoPE dimension ---
    let dr = lg_dynamic_rope(100, dim, base, 200, 100)
    check("Dynamic RoPE dim matches", len(dr) == dim)

    // --- Test 15: Dot product correctness ---
    let a = [1.0, 2.0, 3.0, 4.0]
    let b = [4.0, 3.0, 2.0, 1.0]
    let dp = lg_dot_product(a, b)
    // 1*4 + 2*3 + 3*2 + 4*1 = 20
    check("Dot product = 20", approx(dp, 20.0, 0.001))

    // --- Test 16: Position encoding stability ---
    // Embeddings at nearby positions should be similar (high dot product)
    let e100 = lg_rope_embed(100, dim, base)
    let e101 = lg_rope_embed(101, dim, base)
    let e200 = lg_rope_embed(200, dim, base)
    let dot_near = lg_dot_product(e100, e101)
    let dot_far = lg_dot_product(e100, e200)
    // Nearby positions should have higher similarity than distant ones
    check("Position stability: near > far", dot_near > dot_far)

    println("")
    println("length_generalization: " + to_string(pass_count) + " passed, " + to_string(fail_count) + " failed")
    if fail_count == 0 {
        println("ALL PASS")
    } else {
        println("FAILED")
    }
    println(to_string(pass_count) + " passed")
}

main()
