// ═══════════════════════════════════════════════════════════
//  codegen_c2.hexa — HexaVal 기반 C 코드 생성 (Phase 5)
//  runtime.c와 함께 사용: 문자열, 배열, Map 지원
// ═══════════════════════════════════════════════════════════

// bt-53: mangle user-level global identifiers that collide with runtime.c's
// internal enum values (TAG_INT, TAG_FLOAT, …, TAG_CLOSURE) and `main`. Without
// mangling, `let TAG_INT = 0` emits `HexaVal TAG_INT;` at file scope, which
// collides with runtime.c's `enum { TAG_INT=0, … }` (same ordinary namespace).
// Reserved names get `u_` prefix at every global-decl and reference site.
fn _hexa_name_is_reserved(s) {
    if s == "TAG_INT" { return true }
    if s == "TAG_FLOAT" { return true }
    if s == "TAG_BOOL" { return true }
    if s == "TAG_STR" { return true }
    if s == "TAG_VOID" { return true }
    if s == "TAG_ARRAY" { return true }
    if s == "TAG_MAP" { return true }
    if s == "TAG_FN" { return true }
    if s == "TAG_CHAR" { return true }
    if s == "TAG_CLOSURE" { return true }
    if s == "main" { return true }
    // C2 Step 2 (2026-04-16): C stdlib math names that collide with user-
    // defined wrappers. `fn fabs(x)` in .hexa source would emit
    // `HexaVal fabs(HexaVal x)` at file scope, conflicting with math.h's
    // `double fabs(double)` once runtime.c's `#include <math.h>` pulls in
    // the libc prototype. Mangling to `u_fabs` at both decl and call sites
    // sidesteps this without forcing every test file to rename its helper.
    if s == "fabs" { return true }
    if s == "fabsf" { return true }
    // stdlib.h: div_t div(int, int)
    if s == "div" { return true }
    // math.h Bessel functions: double y0(double), y1(double), j0(double), j1(double)
    if s == "y0" { return true }
    if s == "y1" { return true }
    if s == "j0" { return true }
    if s == "j1" { return true }
    // math.h functions that conflict with user-defined hexa names
    if s == "log" { return true }
    if s == "log2" { return true }
    if s == "log10" { return true }
    if s == "log1p" { return true }
    if s == "exp" { return true }
    if s == "exp2" { return true }
    if s == "expm1" { return true }
    if s == "sqrt" { return true }
    if s == "cbrt" { return true }
    if s == "hypot" { return true }
    if s == "pow" { return true }
    if s == "ceil" { return true }
    if s == "floor" { return true }
    if s == "round" { return true }
    if s == "trunc" { return true }
    if s == "abs" { return true }
    if s == "sin" { return true }
    if s == "cos" { return true }
    if s == "tan" { return true }
    if s == "asin" { return true }
    if s == "acos" { return true }
    if s == "atan" { return true }
    if s == "atan2" { return true }
    if s == "sinh" { return true }
    if s == "cosh" { return true }
    if s == "tanh" { return true }
    if s == "fmax" { return true }
    if s == "fmin" { return true }
    if s == "fma" { return true }
    if s == "erf" { return true }
    if s == "erfc" { return true }
    if s == "gamma" { return true }
    if s == "lgamma" { return true }
    if s == "tgamma" { return true }
    // string.h functions
    if s == "strchr" { return true }
    if s == "strrchr" { return true }
    if s == "strstr" { return true }
    if s == "strcmp" { return true }
    if s == "strncmp" { return true }
    if s == "strcpy" { return true }
    if s == "strncpy" { return true }
    if s == "memcpy" { return true }
    if s == "memcmp" { return true }
    if s == "memset" { return true }
    // stdio.h / stdlib.h functions
    if s == "printf" { return true }
    if s == "fprintf" { return true }
    if s == "sprintf" { return true }
    if s == "snprintf" { return true }
    if s == "scanf" { return true }
    if s == "fopen" { return true }
    if s == "fclose" { return true }
    if s == "fread" { return true }
    if s == "fwrite" { return true }
    // FIX-A 2nd batch (2026-04-19): stdlib.h `void abort(void) __attribute__((noreturn))`
    // collides with anima/training/launch_alm_r11_{a,b,c}.hexa `fn abort(code, msg)`.
    // User's 2-arg wrapper prints msg then exits — mangle to `u_abort` at decl+call sites.
    if s == "abort" { return true }
    // main() formal param names — codegen emits `int main(int argc, char** argv)`.
    // User top-level `let argv = args()` would otherwise shadow the param, causing
    // HexaVal-vs-char** type errors throughout the main body (anima-core/hub.hexa).
    if s == "argv" { return true }
    if s == "argc" { return true }
    // C type keywords that conflict with user-defined hexa names
    if s == "int" { return true }
    if s == "float" { return true }
    if s == "double" { return true }
    if s == "char" { return true }
    if s == "void" { return true }
    if s == "long" { return true }
    if s == "short" { return true }
    if s == "static" { return true }
    if s == "struct" { return true }
    if s == "enum" { return true }
    if s == "union" { return true }
    if s == "const" { return true }
    if s == "extern" { return true }
    if s == "return" { return true }
    if s == "if" { return true }
    if s == "else" { return true }
    if s == "while" { return true }
    if s == "for" { return true }
    if s == "break" { return true }
    if s == "continue" { return true }
    if s == "switch" { return true }
    if s == "case" { return true }
    if s == "default" { return true }
    if s == "sizeof" { return true }
    if s == "typedef" { return true }
    if s == "register" { return true }
    if s == "volatile" { return true }
    if s == "auto" { return true }
    if s == "goto" { return true }
    // runtime fn-shim variables that clash with user-defined functions
    if s == "matvec" { return true }
    if s == "parse_float" { return true }
    if s == "env" { return true }
    // 2026-04-27: errno is a MACRO in <sys/errno.h> (`#define errno (*__error())`).
    // User-defined `fn _classify(path, errno, syscall)` (hive sandbox_deny_enrich)
    // gets parameter substituted to `(*__error())` at preprocessor stage → arg
    // type mismatch + link fail. Mangling to u_errno at decl+ref sides side-
    // steps the macro expansion. Same class: any libc ERRNO macro identifier.
    if s == "errno" { return true }
    return false
}

fn _hexa_mangle_ident(name) {
    if type_of(name) != "string" { return name }
    if _hexa_name_is_reserved(name) { return "u_" + name }
    return name
}

// ═══════════════════════════════════════════════════════════════════
// P7-7 rt_target routing — SSOT mirror of self/codegen/rt_symbols.hexa.
// Inlined because codegen_c2.hexa is a flatten-monolith (use directives
// are comments per tool/flatten_imports.hexa:9). Keep entries byte-
// for-byte in sync with self/codegen/rt_symbols.hexa.
//
// Flip knob: cg_rt_target() = "c" (legacy hexa_*) | "rt" (rt_*_v via abi
// wrappers). Current default "c" preserves all existing behavior — the
// helper returns exactly the same literal the prior inline `return "hexa_*"`
// form produced. Activation (Step C) is a single-line edit below.
// ═══════════════════════════════════════════════════════════════════

fn cg_rt_target() { return "c" }

fn cg_math_sym(name) {
    if cg_rt_target() == "rt" {
        if name == "abs"   { return "rt_math_abs_v" }
        if name == "sqrt"  { return "rt_math_sqrt_v" }
        if name == "floor" { return "rt_math_floor_v" }
        if name == "ceil"  { return "rt_math_ceil_v" }
        if name == "round" { return "rt_math_round_v" }
        if name == "pow"   { return "rt_math_pow_v" }
        if name == "min"   { return "rt_math_min_v" }
        if name == "max"   { return "rt_math_max_v" }
        if name == "sin"   { return "rt_math_sin_v" }
        if name == "cos"   { return "rt_math_cos_v" }
        if name == "tan"   { return "rt_math_tan_v" }
        if name == "asin"  { return "rt_math_asin_v" }
        if name == "acos"  { return "rt_math_acos_v" }
        if name == "atan"  { return "rt_math_atan_v" }
        if name == "atan2" { return "rt_math_atan2_v" }
        if name == "log"   { return "rt_math_log_v" }
        if name == "exp"   { return "rt_math_exp_v" }
        if name == "tanh"  { return "rt_math_tanh_v" }
        return ""
    }
    if name == "abs"   { return "hexa_math_abs" }
    if name == "sqrt"  { return "hexa_math_sqrt" }
    if name == "floor" { return "hexa_math_floor" }
    if name == "ceil"  { return "hexa_math_ceil" }
    if name == "round" { return "hexa_math_round" }
    if name == "pow"   { return "hexa_math_pow" }
    if name == "min"   { return "hexa_math_min" }
    if name == "max"   { return "hexa_math_max" }
    if name == "sin"   { return "hexa_math_sin" }
    if name == "cos"   { return "hexa_math_cos" }
    if name == "tan"   { return "hexa_math_tan" }
    if name == "asin"  { return "hexa_math_asin" }
    if name == "acos"  { return "hexa_math_acos" }
    if name == "atan"  { return "hexa_math_atan" }
    if name == "atan2" { return "hexa_math_atan2" }
    if name == "log"   { return "hexa_math_log" }
    if name == "exp"   { return "hexa_math_exp" }
    if name == "tanh"  { return "hexa_math_tanh" }
    return ""
}

fn cg_string_sym(name) {
    if cg_rt_target() == "rt" {
        if name == "str_concat"      { return "rt_str_concat_v" }
        if name == "str_contains"    { return "rt_str_contains_v" }
        if name == "str_eq"          { return "rt_str_eq_v" }
        if name == "str_substring"   { return "rt_str_substring_v" }
        if name == "str_slice"       { return "rt_str_slice_v" }
        if name == "str_trim"        { return "rt_str_trim_v" }
        if name == "str_trim_start"  { return "rt_str_trim_start_v" }
        if name == "str_trim_end"    { return "rt_str_trim_end_v" }
        if name == "str_replace"     { return "rt_str_replace_v" }
