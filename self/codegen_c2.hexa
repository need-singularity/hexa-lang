// ═══════════════════════════════════════════════════════════
//  codegen_c2.hexa — HexaVal 기반 C 코드 생성 (Phase 5)
//  runtime.c와 함께 사용: 문자열, 배열, Map 지원
// ═══════════════════════════════════════════════════════════

// bt-53: mangle user-level global identifiers that collide with runtime.c's
// internal enum values (TAG_INT, TAG_FLOAT, …, TAG_CLOSURE) and `main`. Without
// mangling, `let TAG_INT = 0` emits `HexaVal TAG_INT;` at file scope, which
// collides with runtime.c's `enum { TAG_INT=0, … }` (same ordinary namespace).
// Reserved names get `u_` prefix at every global-decl and reference site.
fn _hexa_name_is_reserved(s) {
    if s == "TAG_INT" { return true }
    if s == "TAG_FLOAT" { return true }
    if s == "TAG_BOOL" { return true }
    if s == "TAG_STR" { return true }
    if s == "TAG_VOID" { return true }
    if s == "TAG_ARRAY" { return true }
    if s == "TAG_MAP" { return true }
    if s == "TAG_FN" { return true }
    if s == "TAG_CHAR" { return true }
    if s == "TAG_CLOSURE" { return true }
    if s == "main" { return true }
    return false
}

fn _hexa_mangle_ident(name) {
    if type_of(name) != "string" { return name }
    if _hexa_name_is_reserved(name) { return "u_" + name }
    return name
}

fn codegen_c2(ast) {
    // Use arrays to avoid O(n²) string concatenation
    let mut parts = []
    parts = parts.push("// Generated by HEXA self-host compiler\n")
    parts = parts.push("#include \"runtime.c\"\n\n")

    // ── C3: collect known global names for closure free-var analysis ──
    _known_fn_globals = []
    _known_nonlocal_names = []
    _lambda_counter = 0
    _lambda_def_parts = []
    _ic_counter = 0
    _ic_def_parts = []
    let mut _gi = 0
    while _gi < len(ast) {
        let _gk = ast[_gi].kind
        if _gk == "FnDecl" || _gk == "ExternFnDecl" || _gk == "PureFnDecl" || _gk == "OptimizeFnStmt" {
            _known_fn_globals = _known_fn_globals.push(ast[_gi].name)
            _known_nonlocal_names = _known_nonlocal_names.push(ast[_gi].name)
        } else if _gk == "StructDecl" {
            // Struct constructors are C functions
            _known_fn_globals = _known_fn_globals.push(ast[_gi].name)
            _known_nonlocal_names = _known_nonlocal_names.push(ast[_gi].name)
        } else if _gk == "EnumDecl" {
            _known_nonlocal_names = _known_nonlocal_names.push(ast[_gi].name)
        } else if _gk == "ComptimeConst" {
            _known_nonlocal_names = _known_nonlocal_names.push(ast[_gi].name)
        } else if _gk == "LetMutStmt" || _gk == "LetStmt" {
            _known_nonlocal_names = _known_nonlocal_names.push(ast[_gi].name)
        }
        _gi = _gi + 1
    }

    // Collect sections as arrays, join at end
    let mut fwd_parts = []
    let mut global_parts = []
    let mut fn_parts = []
    let mut main_parts = []

    // Track extern fn declarations for call codegen
    let mut extern_fns = []

    let mut i = 0
    while i < len(ast) {
        let k = ast[i].kind
        if k == "FnDecl" {
            fwd_parts = fwd_parts.push(gen2_fn_forward(ast[i]) + "\n")
            fn_parts = fn_parts.push(gen2_fn_decl(ast[i]) + "\n\n")
        } else if k == "ExternFnDecl" {
            // Generate extern FFI wrapper
            extern_fns = extern_fns.push(ast[i].name)
            let ew = gen2_extern_wrapper(ast[i])
            global_parts = global_parts.push(ew.global)
            fwd_parts = fwd_parts.push(ew.forward + "\n")
            fn_parts = fn_parts.push(ew.fn_code + "\n\n")
            main_parts = main_parts.push(ew.init)
        } else if k == "StructDecl" {
            fn_parts = fn_parts.push(gen2_struct_decl(ast[i]) + "\n\n")
        } else if k == "EnumDecl" {
            fn_parts = fn_parts.push(gen2_enum_decl(ast[i]) + "\n")
        } else if k == "ImplBlock" {
            let ib = gen2_impl_block(ast[i])
            fwd_parts = fwd_parts.push(ib.forward)
            fn_parts = fn_parts.push(ib.fn_code)
        } else if k == "PureFnDecl" {
            // Treat pure fn same as regular fn
            fwd_parts = fwd_parts.push(gen2_fn_forward(ast[i]) + "\n")
            fn_parts = fn_parts.push(gen2_fn_decl(ast[i]) + "\n\n")
        } else if k == "ComptimeConst" {
            // Treat comptime const as global constant
            global_parts = global_parts.push("HexaVal " + ast[i].name + ";\n")
            if type_of(ast[i].left) != "string" {
                main_parts = main_parts.push("    " + ast[i].name + " = " + gen2_expr(ast[i].left) + ";\n")
            } else {
                main_parts = main_parts.push("    " + ast[i].name + " = hexa_void();\n")
            }
        } else if k == "OptimizeFnStmt" {
            // Optimization hint — skip
        } else if k == "TraitDecl" {
            // Skip
        } else if k == "ImportStmt" || k == "UseStmt" {
            eprintln("[codegen_c2] WARNING: import/use not fully resolved: " + ast[i].name)
            main_parts = main_parts.push("    /* import: " + ast[i].name + " */\n")
        } else if k == "LetMutStmt" || k == "LetStmt" {
            // bt-53: mangle `TAG_INT`/`main`/… global names to avoid collision
            // with runtime.c's enum constants at link time.
            let _user_name = _hexa_mangle_ident(ast[i].name)
            // ROI #43: @thread_local → _Thread_local C storage class
            let _tls_val = ast[i].value
            let _is_tls = false
            if type_of(_tls_val) == "string" {
                if _tls_val == "thread_local" {
                    _is_tls = true
                }
            }
            if _is_tls {
                global_parts = global_parts.push("_Thread_local HexaVal " + _user_name + ";\n")
            } else {
                global_parts = global_parts.push("HexaVal " + _user_name + ";\n")
            }
            if type_of(ast[i].left) != "string" {
                main_parts = main_parts.push("    " + _user_name + " = " + gen2_expr(ast[i].left) + ";\n")
            } else {
                main_parts = main_parts.push("    " + _user_name + " = hexa_void();\n")
            }
        } else {
            main_parts = main_parts.push(gen2_stmt(ast[i], 1))
        }
        i = i + 1
    }

    // Join all sections (single pass)
    parts = parts.push(fwd_parts.join(""))
    parts = parts.push("\n")
    parts = parts.push(global_parts.join(""))
    parts = parts.push("\n")
    // rt#37: emit inline-cache slots as file-scope statics before fn bodies.
    parts = parts.push(_ic_def_parts.join(""))
    parts = parts.push("\n")
    // C3: emit lambda definitions (static C fns with __env first param)
    parts = parts.push(_lambda_def_parts.join(""))
    parts = parts.push(fn_parts.join(""))
    parts = parts.push("int main() {\n")
    parts = parts.push(main_parts.join(""))
    parts = parts.push("    return 0;\n}\n")
    return parts.join("")
}

// C2-attr: check if a FnDecl node has a specific attr in node.value
fn gen2_has_attr(node, target) {
    let v = node.value
    if type_of(v) != "string" { return false }
    if v == "" { return false }
    let chars = v.chars()
    let total = len(chars)
    let mut i2 = 0
    let mut cur = ""
    while i2 < total {
        let c = to_string(chars[i2])
        if c == "," {
            if cur == target { return true }
            cur = ""
        } else {
            cur = cur + c
        }
        i2 = i2 + 1
    }
    if cur == target { return true }
    return false
}

// Check if a FnDecl node has @inline_always attribute
fn gen2_has_inline_always(node) {
    if type_of(node.value) != "string" { return false }
    if node.value == "" { return false }
    let attrs = node.value
    let chars = attrs.chars()
    let total = len(chars)
    let mut i = 0
    let mut cur = ""
    while i < total {
        let c = to_string(chars[i])
        if c == "," {
            if cur == "inline_always" { return true }
            cur = ""
        } else {
            cur = cur + c
        }
        i = i + 1
    }
    if cur == "inline_always" { return true }
    return false
}

fn gen2_fn_forward(node) {
    let has_restrict = gen2_has_attr(node, "restrict")
    let mut params = []
    let mut i = 0
    while i < len(node.params) {
        if has_restrict {
            // Emit restrict qualifier for noalias optimization
            params = params.push("HexaVal __restrict " + node.params[i].name)
        } else {
            params = params.push("HexaVal " + node.params[i].name)
        }
        i = i + 1
    }
    let p = params.join(", ")
    if p == "" { p = "void" }
    let mut prefix = ""
    if gen2_has_inline_always(node) { prefix = "static inline " }
    return prefix + "HexaVal " + _hexa_mangle_ident(node.name) + "(" + p + ");"
}

// ── @specialize codegen: type-specialized fast path ─────────
// If a FnDecl has @specialize in attrs and has >= 1 param, generate
// a type-check branch at entry that skips tag checks for the dominant type.
fn gen2_has_specialize(node) {
    let attrs = node.value
    if type_of(attrs) != "string" { return false }
    if attrs == "specialize" { return true }
    if contains(attrs, "specialize") { return true }
    return false
}

fn gen2_specialize_guard(node) {
    // Generate C code for type-specialized fast path on first param
    if len(node.params) == 0 { return "" }
    let p0 = node.params[0].name
    let mut out = ""
    out = out + "    /* @specialize: inline cache type guard */\n"
    out = out + "    if (" + p0 + ".tag == TAG_INT) {\n"
    out = out + "        /* monomorphic int fast-path: skip tag checks */\n"
    out = out + "        int64_t __spec_" + p0 + " = " + p0 + ".i;\n"
    out = out + "        (void)__spec_" + p0 + "; /* hint for optimizer */\n"
    out = out + "    }\n"
    return out
}

fn gen2_fn_decl(node) {
    let has_restrict = gen2_has_attr(node, "restrict")
    let has_flatten = gen2_has_attr(node, "flatten")
    let mut params = []
    let mut i = 0
    while i < len(node.params) {
        if has_restrict {
            // @restrict: C restrict qualifier for noalias vectorization
            params = params.push("HexaVal __restrict " + node.params[i].name)
        } else {
            params = params.push("HexaVal " + node.params[i].name)
        }
        i = i + 1
    }
    let p = params.join(", ")
    if p == "" { p = "void" }
    // Check for @stack_alloc attr
    let mut has_stack_alloc = false
    if type_of(node.value) == "string" && node.value != "" {
        let _sa_attrs = node.value
        // Simple check: contains "stack_alloc"
        if _sa_attrs == "stack_alloc" || _sa_attrs == "optimize,stack_alloc" || _sa_attrs == "stack_alloc,optimize" {
            has_stack_alloc = true
        }
        // More general: check if any comma-separated segment matches
        let _sa_chars = _sa_attrs.chars()
        let _sa_len = len(_sa_chars)
        let mut _sa_cur = ""
        let mut _sa_ci = 0
        while _sa_ci < _sa_len {
            let _sa_ch = to_string(_sa_chars[_sa_ci])
            if _sa_ch == "," {
                if _sa_cur == "stack_alloc" { has_stack_alloc = true }
                _sa_cur = ""
            } else {
                _sa_cur = _sa_cur + _sa_ch
            }
            _sa_ci = _sa_ci + 1
        }
        if _sa_cur == "stack_alloc" { has_stack_alloc = true }
    }
    // bt 72: per-function shadow handling via hoisting. Seed declared-names
    // with params so `let x` where x is a param emits as assignment.
    _gen2_declared_names = []
    let mut _pi = 0
    while _pi < len(node.params) {
        _gen2_declared_names = _gen2_declared_names.push(node.params[_pi].name)
        _pi = _pi + 1
    }
    // Collect all LetStmt names (with duplicates).
    let all_names = _gen2_collect_lets(node.body, [])
    let mut _hoisted = []
    let mut hoists = []
    let mut ii = 0
    while ii < len(all_names) {
        let nm = all_names[ii]
        let mut already = _gen2_has_decl(nm)
        let mut jj = 0
        while jj < len(_hoisted) {
            if _hoisted[jj] == nm { already = true }
            jj = jj + 1
        }
        if !already {
            let mut cnt = 0
            let mut kk = 0
            while kk < len(all_names) {
                if all_names[kk] == nm { cnt = cnt + 1 }
                kk = kk + 1
            }
            if cnt > 1 {
                _hoisted = _hoisted.push(nm)
                _gen2_declared_names = _gen2_declared_names.push(nm)
                hoists = hoists.push("    HexaVal " + nm + " = hexa_void();\n")
            }
        }
        ii = ii + 1
    }
    let mut chunks = []
    if has_flatten {
        // @flatten (SROA): emit comment marking struct decomposition intent
        chunks = chunks.push("/* @flatten: SROA — struct params decomposed to scalars */\n")
    }
    // bt-53: mangle user fn name to avoid collision with runtime.c's `main`
    // and enum constants at link time.
    let _fn_name = _hexa_mangle_ident(node.name)
    let mut prefix = ""
    if gen2_has_inline_always(node) { prefix = "static inline " }
    chunks = chunks.push(prefix + "HexaVal " + _fn_name + "(" + p + ") {\n")
    // @specialize: emit type-specialized guard at entry (inside fn body)
    if gen2_has_specialize(node) {
        chunks = chunks.push(gen2_specialize_guard(node))
    }
    // bt 72: emit hoisted declarations at fn top
    let mut hj = 0
    while hj < len(hoists) {
        chunks = chunks.push(hoists[hj])
        hj = hj + 1
    }
    if has_stack_alloc {
        chunks = chunks.push("    /* @stack_alloc: bounded arrays use alloca */\n")
    }
    let mut bi = 0
    while bi < len(node.body) {
        if has_stack_alloc {
            chunks = chunks.push(gen2_stmt_stack_alloc(node.body[bi], 1))
        } else {
            chunks = chunks.push(gen2_stmt(node.body[bi], 1))
        }
        bi = bi + 1
    }
    chunks = chunks.push("    return hexa_void();\n}\n")
    return chunks.join("")
}

// gen2_stmt_stack_alloc — same as gen2_stmt but LetMutStmt with empty array
// uses alloca-based stack allocation instead of heap
fn gen2_stmt_stack_alloc(node, depth) {
    let pad = gen2_indent(depth)
    let k = node.kind
    if k == "LetMutStmt" {
        if type_of(node.left) != "string" && node.left.kind == "ArrayLit" {
            // @stack_alloc: emit stack-based array via alloca
            return pad + "/* @stack_alloc */ HexaVal " + node.name + " = hexa_stack_array(1024);\n"
        }
    }
    return gen2_stmt(node, depth)
}

// ── Extern FFI wrapper generation ────────────────────────
// Returns a map with: global, forward, impl, init
//
// G3: Float argument support — when any param has type Float, generates a
// typed C wrapper so the C compiler puts doubles in SIMD registers (d0-d7)
// instead of integer registers (x0-x7) on ARM64.
//
// Example: extern fn foo(a: Int, b: Float) -> Int  generates:
//   typedef int64_t (*__ffi_ftyp_foo)(int64_t, double);
//   HexaVal foo(HexaVal a, HexaVal b) {
//       int64_t __r = ((__ffi_ftyp_foo)__ffi_sym_foo)(a.i, b.f);
//       return hexa_int(__r);
//   }
//
// For Cocoa NSRect: @symbol("objc_msgSend") extern fn send_rect(obj, sel, x: Float, y: Float, w: Float, h: Float) -> *Void
//   typedef int64_t (*__ffi_ftyp_send_rect)(int64_t, int64_t, double, double, double, double);
//   — C compiler puts ptr args in x0-x1 and doubles in d0-d3 automatically.

fn gen2_extern_ret_kind(ret_type) {
    if ret_type == "Void" || ret_type == "void" || ret_type == "" { return "0" }
    if ret_type == "Int" || ret_type == "int" { return "1" }
    if ret_type == "Float" || ret_type == "float" { return "2" }
    if ret_type == "Bool" || ret_type == "bool" { return "3" }
    return "4" // pointer types
}

// Map a hexa param type to a C type for the typed FFI typedef
fn gen2_ffi_c_type(typ) {
    if typ == "Float" || typ == "float" { return "double" }
    return "int64_t" // Int, Bool, pointers, *Void, untyped — all as int64_t
}

// Map a hexa return type to the C return type
fn gen2_ffi_c_ret_type(ret_type) {
    if ret_type == "Void" || ret_type == "void" || ret_type == "" { return "void" }
    if ret_type == "Float" || ret_type == "float" { return "double" }
    return "int64_t"
}

// Check if any param has Float type — determines if typed dispatch is needed
fn gen2_has_float_param(params) {
    let mut i = 0
    while i < len(params) {
        let t = params[i].value
        if t == "Float" || t == "float" { return 1 }
        i = i + 1
    }
    return 0
}

// Marshal a HexaVal arg to the correct C type for typed FFI call
fn gen2_ffi_marshal_arg(param_name, param_type) {
    if param_type == "Float" || param_type == "float" {
        return "(" + param_name + ".tag==TAG_FLOAT?" + param_name + ".f:(double)" + param_name + ".i)"
    }
    // For int/pointer/untyped: extract as int64_t
    return "(" + param_name + ".tag==TAG_INT?" + param_name + ".i:(int64_t)" + param_name + ".f)"
}

// Wrap the raw C return value back into HexaVal
fn gen2_ffi_wrap_ret(ret_type, var_name) {
    if ret_type == "Void" || ret_type == "void" || ret_type == "" {
        return "hexa_void()"
    }
    if ret_type == "Float" || ret_type == "float" {
        return "hexa_float(" + var_name + ")"
    }
    if ret_type == "Bool" || ret_type == "bool" {
        return "hexa_bool(" + var_name + " != 0)"
    }
    return "hexa_int(" + var_name + ")"
}

// ── P4-3: Static FFI — extern fn → C declaration (compile-time linking) ──
// Instead of dlsym-based wrappers, generates direct C extern declarations.
// Used when linking against C libraries at compile time.

// Map Hexa type annotation to C type for static FFI declarations
fn gen2_static_c_type(typ) {
    if typ == "i64" || typ == "Int" || typ == "int" { return "long long" }
    if typ == "i32" { return "int" }
    if typ == "f64" || typ == "Float" || typ == "float" { return "double" }
    if typ == "f32" { return "float" }
    if typ == "str" || typ == "Str" || typ == "String" { return "char*" }
    if typ == "bool" || typ == "Bool" { return "int" }
    if typ == "void" || typ == "Void" || typ == "" { return "void" }
    if typ == "*Void" || typ == "Ptr" { return "void*" }
    // Unknown type — pass through as-is (user-defined C type)
    return typ
}

// Generate a C extern function declaration for static linking
// extern fn foo(x: Int, y: Float) -> Int
//   → extern long long foo(long long x, double y);
fn gen2_extern_static_decl(node) {
    let name = node.name
    let ret_type = node.ret_type

    // Use @symbol alias if present, otherwise use the Hexa name
    let mut c_name = node.value
    if c_name == "" { c_name = name }

    // Map return type
    let c_ret = gen2_static_c_type(ret_type)

    // Map parameter types
    let mut c_params = []
    let mut i = 0
    while i < len(node.params) {
        let p = node.params[i]
        let c_typ = gen2_static_c_type(p.value)
        if c_typ == "void" {
            // Untyped param — default to long long
            c_params = c_params.push("long long " + p.name)
        } else {
            c_params = c_params.push(c_typ + " " + p.name)
        }
        i = i + 1
    }

    let params_str = c_params.join(", ")
    let mut sig = params_str
    if sig == "" { sig = "void" }

    // Build the declaration
    let mut parts = []

    // If @link("lib") is set, emit a comment noting the library
    if node.op != "" {
        parts = parts.push("// link: -l" + node.op + "\n")
    }

    parts = parts.push("extern " + c_ret + " " + c_name + "(" + sig + ");\n")
    return parts.join("")
}

// Collect required #include headers based on extern fn types
fn gen2_extern_includes(ast) {
    let mut needs_stdio = 0
    let mut needs_stdlib = 0
    let mut needs_string = 0
    let mut needs_math = 0
    let mut has_extern = 0

    let mut i = 0
    while i < len(ast) {
        if ast[i].kind == "ExternFnDecl" {
            has_extern = 1
            // Check @link for common libraries
            if ast[i].op == "m" || ast[i].op == "libm" {
                needs_math = 1
            }
            // Check param/return types for string usage
            let mut j = 0
            while j < len(ast[i].params) {
                let t = ast[i].params[j].value
                if t == "str" || t == "Str" || t == "String" {
                    needs_string = 1
                }
                j = j + 1
            }
            let rt = ast[i].ret_type
            if rt == "str" || rt == "Str" || rt == "String" {
                needs_string = 1
            }
        }
        i = i + 1
    }

    if has_extern == 0 { return "" }

    let mut includes = []
    includes = includes.push("#include <stdint.h>\n")
    if needs_math == 1 {
        includes = includes.push("#include <math.h>\n")
    }
    if needs_string == 1 {
        includes = includes.push("#include <string.h>\n")
    }
    return includes.join("")
}

// Generate all static FFI declarations for an AST
fn gen2_static_ffi_block(ast) {
    let includes = gen2_extern_includes(ast)
    let mut decls = []
    let mut i = 0
    while i < len(ast) {
        if ast[i].kind == "ExternFnDecl" {
            decls = decls.push(gen2_extern_static_decl(ast[i]))
        }
        i = i + 1
    }
    if len(decls) == 0 { return "" }
    let mut parts = []
    if includes != "" {
        parts = parts.push(includes)
    }
    parts = parts.push("\n// ── FFI declarations ──\n")
    parts = parts.push(decls.join(""))
    parts = parts.push("\n")
    return parts.join("")
}

fn gen2_extern_wrapper(node) {
    let name = node.name
    let nargs = len(node.params)
    let ret_type = node.ret_type

    // Resolve @symbol("c_name") alias — use node.value if set, else node.name
    let mut c_sym = node.value
    if c_sym == "" { c_sym = name }

    // Global: symbol pointer
    let global = "static void* __ffi_sym_" + name + " = NULL;\n"

    // Forward declaration (hexa wrapper takes HexaVal args)
    let mut fwd_params = []
    let mut fi = 0
    while fi < nargs {
        fwd_params = fwd_params.push("HexaVal " + node.params[fi].name)
        fi = fi + 1
    }
    let fwd_p = fwd_params.join(", ")
    let mut sig_p = fwd_p
    if sig_p == "" { sig_p = "void" }
    let forward = "HexaVal " + name + "(" + sig_p + ");"

    let has_float = gen2_has_float_param(node.params)

    // perf: chunks.push + join — avoid O(n²) string concat
    let mut impl_parts = []

    if has_float == 1 || nargs > 0 {
        // ── G3: Typed dispatch — generate a typedef + direct typed call ──
        // This ensures the C compiler puts float args in SIMD registers (d0-d7)
        // and integer/pointer args in GPRs (x0-x7) on ARM64.

        // Build typedef: e.g. typedef int64_t (*__ffi_ftyp_foo)(int64_t, double, double);
        let c_ret = gen2_ffi_c_ret_type(ret_type)
        let mut typedef_params = []
        let mut ti = 0
        while ti < nargs {
            typedef_params = typedef_params.push(gen2_ffi_c_type(node.params[ti].value))
            ti = ti + 1
        }
        let td_p = typedef_params.join(", ")
        let mut td_sig = td_p
        if td_sig == "" { td_sig = "void" }

        impl_parts = impl_parts.push("typedef " + c_ret + " (*__ffi_ftyp_" + name + ")(" + td_sig + ");\n")
        impl_parts = impl_parts.push("HexaVal " + name + "(" + sig_p + ") {\n")

        // Marshal each arg to its native C type
        let mut call_args = []
        let mut ci = 0
        while ci < nargs {
            call_args = call_args.push(gen2_ffi_marshal_arg(node.params[ci].name, node.params[ci].value))
            ci = ci + 1
        }
        let call_str = call_args.join(", ")

        if ret_type == "Void" || ret_type == "void" || ret_type == "" {
            impl_parts = impl_parts.push("    ((__ffi_ftyp_" + name + ")__ffi_sym_" + name + ")(" + call_str + ");\n")
            impl_parts = impl_parts.push("    return hexa_void();\n")
        } else {
            impl_parts = impl_parts.push("    " + c_ret + " __r = ((__ffi_ftyp_" + name + ")__ffi_sym_" + name + ")(" + call_str + ");\n")
            impl_parts = impl_parts.push("    return " + gen2_ffi_wrap_ret(ret_type, "__r") + ";\n")
        }
        impl_parts = impl_parts.push("}\n")
    } else {
        // 0-arg function — use simple hexa_extern_call
        impl_parts = impl_parts.push("HexaVal " + name + "(" + sig_p + ") {\n")
        impl_parts = impl_parts.push("    return hexa_extern_call(__ffi_sym_" + name + ", NULL, 0, " + gen2_extern_ret_kind(ret_type) + ");\n")
        impl_parts = impl_parts.push("}\n")
    }
    let impl_code = impl_parts.join("")

    // Init: dlopen + dlsym in main() — use @symbol C name and @link library
    let mut lib_arg = "NULL"
    if node.op != "" {
        lib_arg = "\"" + node.op + "\""
    }
    let init = "    __ffi_sym_" + name + " = hexa_ffi_dlsym(hexa_ffi_dlopen(" + lib_arg + "), \"" + c_sym + "\");\n"

    return #{
        "global": global, "forward": forward, "fn_code": impl_code, "init": init,
        "kind": "", "name": "", "value": "", "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

fn gen2_indent(n) {
    // perf: chunks.push + join — avoid O(n²) string concat
    let mut parts = []
    let mut i = 0
    while i < n {
        parts = parts.push("    ")
        i = i + 1
    }
    return parts.join("")
}

// bt 72: per-function set of C identifiers already declared. Hexa permits
// `let x = ...` shadow-rebind in the same block; C forbids it. gen2_fn_decl
// pre-scans the body and hoists any name declared >1 times to the function
// top as `HexaVal x = hexa_void();`, then LetStmt emits as plain assignment.
let mut _gen2_declared_names = []

fn _gen2_has_decl(name) {
    let n = len(_gen2_declared_names)
    let mut i = 0
    while i < n {
        if _gen2_declared_names[i] == name { return true }
        i = i + 1
    }
    return false
}

fn _gen2_collect_lets_stmt(node, names) {
    if type_of(node) == "string" { return names }
    let sk = node.kind
    if sk == "LetStmt" || sk == "LetMutStmt" {
        names = names.push(node.name)
    }
    if type_of(node.then_body) != "string" { names = _gen2_collect_lets(node.then_body, names) }
    if type_of(node.else_body) != "string" { names = _gen2_collect_lets(node.else_body, names) }
    if type_of(node.body) != "string" { names = _gen2_collect_lets(node.body, names) }
    if type_of(node.arms) != "string" {
        let mut ai = 0
        while ai < len(node.arms) {
            let arm = node.arms[ai]
            if type_of(arm) != "string" && type_of(arm.body) != "string" {
                names = _gen2_collect_lets(arm.body, names)
            }
            ai = ai + 1
        }
    }
    // ExprStmt-wrapped IfExpr/MatchExpr used as a statement
    if sk == "ExprStmt" && type_of(node.left) != "string" {
        names = _gen2_collect_lets_stmt(node.left, names)
    }
    return names
}

fn _gen2_collect_lets(stmts, names) {
    if type_of(stmts) == "string" { return names }
    let mut i = 0
    while i < len(stmts) {
        names = _gen2_collect_lets_stmt(stmts[i], names)
        i = i + 1
    }
    return names
}

fn gen2_stmt(node, depth) {
    let pad = gen2_indent(depth)
    let k = node.kind

    if k == "LetStmt" || k == "LetMutStmt" {
        let init = "hexa_void()"
        if type_of(node.left) != "string" {
            init = gen2_expr(node.left)
        }
        // M975: register promotion — if value == "__reg_promote__", emit `register`
        if k == "LetMutStmt" && node.value == "__reg_promote__" {
            return pad + "register HexaVal " + node.name + " = " + init + "; /* reg-promoted */\n"
        }
        // bt 72: if this name was hoisted (or matches a param), emit plain
        // assignment to avoid C "redefinition" errors from shadow semantics.
        if _gen2_has_decl(node.name) {
            return pad + node.name + " = " + init + ";\n"
        }
        return pad + "HexaVal " + node.name + " = " + init + ";\n"
    }

    if k == "ConstStmt" {
        return pad + "HexaVal " + node.name + " = " + gen2_expr(node.left) + ";\n"
    }

    if k == "AssignStmt" {
        // Index assignment: arr[i] = val or map["key"] = val → polymorphic
        if type_of(node.left) != "string" && node.left.kind == "Index" {
            let container = gen2_expr(node.left.left)
            let idx = gen2_expr(node.left.right)
            let val = gen2_expr(node.right)
            return pad + container + " = hexa_index_set(" + container + ", " + idx + ", " + val + ");\n"
        }
        // Field assignment: obj.field = val
        if type_of(node.left) != "string" && node.left.kind == "Field" {
            let obj = gen2_expr(node.left.left)
            let field = node.left.name
            let val = gen2_expr(node.right)
            return pad + obj + " = hexa_map_set(" + obj + ", \"" + field + "\", " + val + ");\n"
        }
        return pad + gen2_expr(node.left) + " = " + gen2_expr(node.right) + ";\n"
    }

    if k == "CompoundAssign" {
        let lhs = gen2_expr(node.left)
        let rhs = gen2_expr(node.right)
        let op = node.op
        if op == "+=" {
            return pad + lhs + " = hexa_add(" + lhs + ", " + rhs + ");\n"
        }
        if op == "-=" {
            return pad + lhs + " = hexa_int((" + lhs + ").i - (" + rhs + ").i);\n"
        }
        if op == "*=" {
            return pad + lhs + " = hexa_int((" + lhs + ").i * (" + rhs + ").i);\n"
        }
        if op == "/=" {
            return pad + lhs + " = hexa_int((" + lhs + ").i / (" + rhs + ").i);\n"
        }
        if op == "%=" {
            return pad + lhs + " = hexa_int((" + lhs + ").i % (" + rhs + ").i);\n"
        }
        return pad + "/* compound " + op + " */\n"
    }

    if k == "ReturnStmt" {
        if type_of(node.left) != "string" {
            return pad + "return " + gen2_expr(node.left) + ";\n"
        }
        return pad + "return hexa_void();\n"
    }

    if k == "ExprStmt" {
        let expr = node.left
        if type_of(expr) == "string" { return "" }
        if expr.kind == "MatchExpr" {
            return gen2_match_stmt(expr, depth)
        }
        if expr.kind == "IfExpr" {
            let mut chunks = []
            chunks = chunks.push(pad + "if (hexa_truthy(" + gen2_expr(expr.cond) + ")) {\n")
            let mut ti = 0
            while ti < len(expr.then_body) {
                chunks = chunks.push(gen2_stmt(expr.then_body[ti], depth + 1))
                ti = ti + 1
            }
            chunks = chunks.push(pad + "}")
            if type_of(expr.else_body) != "string" && len(expr.else_body) > 0 {
                chunks = chunks.push(" else {\n")
                let mut ei = 0
                while ei < len(expr.else_body) {
                    chunks = chunks.push(gen2_stmt(expr.else_body[ei], depth + 1))
                    ei = ei + 1
                }
                chunks = chunks.push(pad + "}")
            }
            chunks = chunks.push("\n")
            return chunks.join("")
        }
        return pad + gen2_expr(expr) + ";\n"
    }

    if k == "WhileStmt" {
        let mut chunks = []
        chunks = chunks.push(pad + "while (hexa_truthy(" + gen2_expr(node.cond) + ")) {\n")
        let mut wi = 0
        while wi < len(node.body) {
            chunks = chunks.push(gen2_stmt(node.body[wi], depth + 1))
            wi = wi + 1
        }
        chunks = chunks.push(pad + "}\n")
        return chunks.join("")
    }

    if k == "ForStmt" {
        let iter = node.iter_expr
        if type_of(iter) != "string" && iter.kind == "Range" {
            let s = gen2_expr(iter.left)
            let e = gen2_expr(iter.right)
            let mut chunks = []
            chunks = chunks.push(pad + "for (HexaVal " + node.name + " = " + s + "; " + node.name + ".i < (" + e + ").i; " + node.name + ".i++) {\n")
            let mut fi = 0
            while fi < len(node.body) {
                chunks = chunks.push(gen2_stmt(node.body[fi], depth + 1))
                fi = fi + 1
            }
            chunks = chunks.push(pad + "}\n")
            return chunks.join("")
        }
        // General for-in: iterate over array or map (map → keys, Python-style).
        // hexa_iter_get dispatches on tag at runtime so both work without codegen knowing the type.
        let iter_c = gen2_expr(iter)
        let mut chunks = []
        chunks = chunks.push(pad + "{\n")
        let pad2 = gen2_indent(depth + 1)
        chunks = chunks.push(pad2 + "HexaVal __iter_arr = " + iter_c + ";\n")
        chunks = chunks.push(pad2 + "for (int __fi = 0; __fi < hexa_len(__iter_arr); __fi++) {\n")
        let pad3 = gen2_indent(depth + 2)
        chunks = chunks.push(pad3 + "HexaVal " + node.name + " = hexa_iter_get(__iter_arr, __fi);\n")
        let mut fi = 0
        while fi < len(node.body) {
            chunks = chunks.push(gen2_stmt(node.body[fi], depth + 2))
            fi = fi + 1
        }
        chunks = chunks.push(pad2 + "}\n")
        chunks = chunks.push(pad + "}\n")
        return chunks.join("")
    }

    if k == "BreakStmt" {
        return pad + "break;\n"
    }

    if k == "ContinueStmt" {
        return pad + "continue;\n"
    }

    if k == "ThrowStmt" {
        if type_of(node.left) != "string" {
            return pad + "hexa_throw(" + gen2_expr(node.left) + ");\n"
        }
        return pad + "hexa_throw(hexa_str(\"error\"));\n"
    }

    if k == "TryCatchStmt" || k == "TryCatch" {
        // Parser stores: left=try_body, right=catch_body, name=catch_var
        let try_body = node.left
        let catch_body = node.right
        let catch_var = node.name
        let mut chunks = []
        chunks = chunks.push(pad + "{\n")
        let pad2 = gen2_indent(depth + 1)
        chunks = chunks.push(pad2 + "jmp_buf __jb; HexaVal __err = hexa_void();\n")
        chunks = chunks.push(pad2 + "if (setjmp(__jb) == 0) {\n")
        chunks = chunks.push(pad2 + "    __hexa_try_push(&__jb);\n")
        if type_of(try_body) != "string" {
            let mut ti = 0
            while ti < len(try_body) {
                chunks = chunks.push(gen2_stmt(try_body[ti], depth + 2))
                ti = ti + 1
            }
        }
        chunks = chunks.push(pad2 + "    __hexa_try_pop();\n")
        chunks = chunks.push(pad2 + "} else {\n")
        chunks = chunks.push(pad2 + "    __err = __hexa_last_error();\n")
        if catch_var != "" && catch_var != "_" {
            chunks = chunks.push(pad2 + "    HexaVal " + catch_var + " = __err;\n")
        }
        if type_of(catch_body) != "string" {
            let mut ci = 0
            while ci < len(catch_body) {
                chunks = chunks.push(gen2_stmt(catch_body[ci], depth + 2))
                ci = ci + 1
            }
        }
        chunks = chunks.push(pad2 + "}\n")
        chunks = chunks.push(pad + "}\n")
        return chunks.join("")
    }

    // ── Match statement (MatchExpr used as statement) ────────
    if k == "MatchExpr" {
        return gen2_match_stmt(node, depth)
    }

    // ── LoopStmt → while(1) { body } ──────────────────────
    if k == "LoopStmt" {
        let mut chunks = []
        chunks = chunks.push(pad + "while (1) {\n")
        let mut li = 0
        while li < len(node.body) {
            chunks = chunks.push(gen2_stmt(node.body[li], depth + 1))
            li = li + 1
        }
        chunks = chunks.push(pad + "}\n")
        return chunks.join("")
    }

    // ── ComptimeConst → treat as const (compile-time folding not yet implemented) ──
    if k == "ComptimeConst" {
        return pad + "HexaVal " + node.name + " = " + gen2_expr(node.left) + ";\n"
    }

    // ── OptimizeFnStmt → skip (optimization hint only) ──
    if k == "OptimizeFnStmt" {
        return ""
    }

    eprintln("[codegen_c2] ERROR: unhandled statement kind: " + k)
    return pad + "fprintf(stderr, \"CODEGEN ERROR: unhandled stmt kind: " + k + "\\n\"); exit(1);\n"
}

fn c_escape(s) {
    // Escape special chars for C string literals
    // to_string() handles char type values from CharLit AST nodes
    // Must do backslash first to avoid double-escaping
    let mut out = to_string(s).replace("\\", "\\\\")
    out = out.replace("\"", "\\\"")
    out = out.replace("\n", "\\n")
    out = out.replace("\r", "\\r")
    out = out.replace("\t", "\\t")
    return out
}

// Builtin method dispatch used by user-impl fallback chain. `obj_expr` is
// an already-stringified C expression (typically a temp name like "__mr").
// Returns a C expression string. Mirrors the hardcoded method list in the
// Call-on-Field branch below. Kept in sync manually.
fn gen2_method_builtin(obj_expr, method, args) {
    if method == "push" {
        return "hexa_array_push(" + obj_expr + ", " + gen2_expr(args[0]) + ")"
    }
    if method == "len" {
        return "hexa_int(hexa_len(" + obj_expr + "))"
    }
    if method == "chars" {
        return "hexa_str_chars(" + obj_expr + ")"
    }
    if method == "contains" {
        return "hexa_bool(hexa_str_contains(" + obj_expr + ", " + gen2_expr(args[0]) + "))"
    }
    if method == "join" {
        return "hexa_str_join(" + obj_expr + ", " + gen2_expr(args[0]) + ")"
    }
    if method == "to_upper" {
        return "hexa_str_to_upper(" + obj_expr + ")"
    }
    if method == "to_lower" {
        return "hexa_str_to_lower(" + obj_expr + ")"
    }
    if method == "split" {
        return "hexa_str_split(" + obj_expr + ", " + gen2_expr(args[0]) + ")"
    }
    if method == "trim" {
        return "hexa_str_trim(" + obj_expr + ")"
    }
    if method == "replace" {
        return "hexa_str_replace(" + obj_expr + ", " + gen2_expr(args[0]) + ", " + gen2_expr(args[1]) + ")"
    }
    if method == "repeat" {
        return "hexa_str_repeat(" + obj_expr + ", " + gen2_expr(args[0]) + ")"
    }
    if method == "starts_with" {
        return "hexa_bool(hexa_str_starts_with(" + obj_expr + ", " + gen2_expr(args[0]) + "))"
    }
    if method == "ends_with" {
        return "hexa_bool(hexa_str_ends_with(" + obj_expr + ", " + gen2_expr(args[0]) + "))"
    }
    if method == "substring" {
        return "hexa_str_substring(" + obj_expr + ", " + gen2_expr(args[0]) + ", " + gen2_expr(args[1]) + ")"
    }
    if method == "index_of" {
        return "hexa_int(hexa_str_index_of(" + obj_expr + ", " + gen2_expr(args[0]) + "))"
    }
    // ── Map methods ──
    if method == "keys" {
        return "hexa_map_keys(" + obj_expr + ")"
    }
    if method == "values" {
        return "hexa_map_values(" + obj_expr + ")"
    }
    if method == "contains_key" {
        return "hexa_bool(hexa_map_contains_key(" + obj_expr + ", " + gen2_expr(args[0]) + ".s))"
    }
    if method == "remove" {
        return "hexa_map_remove(" + obj_expr + ", " + gen2_expr(args[0]) + ".s)"
    }
    if method == "pop" {
        return "hexa_array_pop(" + obj_expr + ")"
    }
    if method == "reverse" {
        return "hexa_array_reverse(" + obj_expr + ")"
    }
    if method == "sort" {
        return "hexa_array_sort(" + obj_expr + ")"
    }
    // bt 55 — in-place array length shrink; caller must reassign.
    if method == "truncate" {
        return "hexa_array_truncate(" + obj_expr + ", " + gen2_expr(args[0]) + ")"
    }
    eprintln("[codegen_c2] ERROR: unknown builtin method: " + method)
    return "(fprintf(stderr, \"CODEGEN ERROR: unknown builtin method: " + method + "\\n\"), exit(1), hexa_void())"
}

fn gen2_expr(node) {
    let k = node.kind

    if k == "IntLit" { return "hexa_int(" + node.value + ")" }
    if k == "FloatLit" { return "hexa_float(" + node.value + ")" }
    if k == "BoolLit" {
        if node.value == "true" { return "hexa_bool(1)" }
        return "hexa_bool(0)"
    }
    if k == "StringLit" { return "hexa_str(\"" + c_escape(node.value) + "\")" }
    if k == "CharLit" {
        // Runtime uses TAG_STR for chars (hexa_str_chars returns single-char strings)
        // so char literals must also be TAG_STR for hexa_eq to work
        return "hexa_str(\"" + c_escape(node.value) + "\")"
    }
    // bt-53: mangle reserved runtime names (TAG_INT etc.) so references match
    // the mangled global declarations emitted at LetStmt/FnDecl sites.
    if k == "Ident" { return _hexa_mangle_ident(node.name) }

    if k == "BinOp" {
        let l = gen2_expr(node.left)
        let r = gen2_expr(node.right)
        let op = node.op
        // Int arithmetic
        if op == "+" {
            return "hexa_add(" + l + ", " + r + ")"
        }
        if op == "-" { return "hexa_int((" + l + ").i - (" + r + ").i)" }
        if op == "*" { return "hexa_int((" + l + ").i * (" + r + ").i)" }
        if op == "/" { return "hexa_int((" + l + ").i / (" + r + ").i)" }
        if op == "%" { return "hexa_int((" + l + ").i % (" + r + ").i)" }
        // Comparisons
        if op == "==" { return "hexa_eq(" + l + ", " + r + ")" }
        if op == "!=" { return "hexa_bool(!hexa_truthy(hexa_eq(" + l + ", " + r + ")))" }
        if op == "<" { return "hexa_bool((" + l + ").i < (" + r + ").i)" }
        if op == ">" { return "hexa_bool((" + l + ").i > (" + r + ").i)" }
        if op == "<=" { return "hexa_bool((" + l + ").i <= (" + r + ").i)" }
        if op == ">=" { return "hexa_bool((" + l + ").i >= (" + r + ").i)" }
        if op == "&&" { return "hexa_bool(hexa_truthy(" + l + ") && hexa_truthy(" + r + "))" }
        if op == "||" { return "hexa_bool(hexa_truthy(" + l + ") || hexa_truthy(" + r + "))" }
        if op == "??" { return "hexa_null_coal(" + l + ", " + r + ")" }
        eprintln("[codegen_c2] ERROR: unhandled binary operator: " + op)
        return "(fprintf(stderr, \"CODEGEN ERROR: unhandled binop: " + op + "\\n\"), exit(1), hexa_void())"
    }

    if k == "UnaryOp" {
        if node.op == "-" { return "hexa_int(-(" + gen2_expr(node.left) + ").i)" }
        if node.op == "!" { return "hexa_bool(!hexa_truthy(" + gen2_expr(node.left) + "))" }
        eprintln("[codegen_c2] ERROR: unhandled unary operator: " + node.op)
        return "(fprintf(stderr, \"CODEGEN ERROR: unhandled unary op: " + node.op + "\\n\"), exit(1), hexa_void())"
    }

    // ── Field access: obj.field → hexa_map_get_ic(obj, "field", &ic) ──
    // rt#37: each call site gets a unique static HexaIC slot, emitted as a
    // file-scope global so it survives across calls within the same binary.
    if k == "Field" {
        let obj = gen2_expr(node.left)
        let field = node.name
        let id = _ic_counter
        _ic_counter = _ic_counter + 1
        let slot = "__hexa_ic_" + to_string(id)
        _ic_def_parts = _ic_def_parts.push("static HexaIC " + slot + " = {0};\n")
        return "hexa_map_get_ic(" + obj + ", \"" + field + "\", &" + slot + ")"
    }

    // ── Struct init: Name { f1: v1, f2: v2 } → constructor call ──
    if k == "StructInit" {
        let name = node.name
        let mut arg_strs = []
        let mut si = 0
        while si < len(node.fields) {
            arg_strs = arg_strs.push(gen2_expr(node.fields[si].left))
            si = si + 1
        }
        return name + "(" + arg_strs.join(", ") + ")"
    }

    if k == "Call" {
        let callee = node.left
        if type_of(callee) != "string" && callee.kind == "Ident" {
            let name = callee.name
            // Built-in mappings
            if name == "println" {
                if len(node.args) > 0 {
                    return "hexa_println(" + gen2_expr(node.args[0]) + ")"
                }
                return "(printf(\"\\n\"), hexa_void())"
            }
            if name == "print" {
                if len(node.args) > 0 {
                    return "(hexa_print_val(" + gen2_expr(node.args[0]) + "), hexa_void())"
                }
                return "hexa_void()"
            }
            if name == "len" {
                return "hexa_int(hexa_len(" + gen2_expr(node.args[0]) + "))"
            }
            if name == "to_string" {
                return "hexa_to_string(" + gen2_expr(node.args[0]) + ")"
            }
