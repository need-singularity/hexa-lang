// ═══════════════════════════════════════════════════════════
//  codegen_c2.hexa — HexaVal 기반 C 코드 생성 (Phase 5)
//  runtime.c와 함께 사용: 문자열, 배열, Map 지원
// ═══════════════════════════════════════════════════════════

fn codegen_c2(ast) {
    let mut out = ""
    out = out + "// Generated by HEXA self-host compiler\n"
    out = out + "#include \"runtime.c\"\n\n"

    // Forward declarations
    let mut fwd = ""
    let mut globals = ""
    let mut fn_code = ""
    let mut main_code = ""

    let mut i = 0
    while i < len(ast) {
        let k = ast[i].kind
        if k == "FnDecl" {
            fwd = fwd + gen2_fn_forward(ast[i]) + "\n"
            fn_code = fn_code + gen2_fn_decl(ast[i]) + "\n\n"
        } else if k == "StructDecl" {
            fn_code = fn_code + gen2_struct_decl(ast[i]) + "\n\n"
        } else if k == "EnumDecl" {
            fn_code = fn_code + gen2_enum_decl(ast[i]) + "\n"
        } else if k == "TraitDecl" || k == "ImplBlock" {
            // Skip other type declarations
        } else if k == "LetMutStmt" {
            // Top-level mutable → declare as C global, init in main
            globals = globals + "HexaVal " + ast[i].name + ";\n"
            if type_of(ast[i].left) != "string" {
                main_code = main_code + "    " + ast[i].name + " = " + gen2_expr(ast[i].left) + ";\n"
            } else {
                main_code = main_code + "    " + ast[i].name + " = hexa_void();\n"
            }
        } else {
            main_code = main_code + gen2_stmt(ast[i], 1)
        }
        i = i + 1
    }

    out = out + fwd + "\n"
    out = out + globals + "\n"
    out = out + fn_code
    out = out + "int main() {\n"
    out = out + main_code
    out = out + "    return 0;\n}\n"
    return out
}

fn gen2_fn_forward(node) {
    let mut params = []
    let mut i = 0
    while i < len(node.params) {
        params = params.push("HexaVal " + node.params[i].name)
        i = i + 1
    }
    let p = params.join(", ")
    if p == "" { p = "void" }
    return "HexaVal " + node.name + "(" + p + ");"
}

fn gen2_fn_decl(node) {
    let mut params = []
    let mut i = 0
    while i < len(node.params) {
        params = params.push("HexaVal " + node.params[i].name)
        i = i + 1
    }
    let p = params.join(", ")
    if p == "" { p = "void" }
    let mut out = "HexaVal " + node.name + "(" + p + ") {\n"
    let mut bi = 0
    while bi < len(node.body) {
        out = out + gen2_stmt(node.body[bi], 1)
        bi = bi + 1
    }
    out = out + "    return hexa_void();\n}\n"
    return out
}

fn gen2_indent(n) {
    let mut s = ""
    let mut i = 0
    while i < n {
        s = s + "    "
        i = i + 1
    }
    return s
}

fn gen2_stmt(node, depth) {
    let pad = gen2_indent(depth)
    let k = node.kind

    if k == "LetStmt" || k == "LetMutStmt" {
        let init = "hexa_void()"
        if type_of(node.left) != "string" {
            init = gen2_expr(node.left)
        }
        return pad + "HexaVal " + node.name + " = " + init + ";\n"
    }

    if k == "ConstStmt" {
        return pad + "HexaVal " + node.name + " = " + gen2_expr(node.left) + ";\n"
    }

    if k == "AssignStmt" {
        // Array index assignment: arr[i] = val → hexa_array_set
        if type_of(node.left) != "string" && node.left.kind == "Index" {
            let arr = gen2_expr(node.left.left)
            let idx = gen2_expr(node.left.right)
            let val = gen2_expr(node.right)
            return pad + arr + " = hexa_array_set(" + arr + ", (" + idx + ").i, " + val + ");\n"
        }
        // Field assignment: obj.field = val
        if type_of(node.left) != "string" && node.left.kind == "Field" {
            let obj = gen2_expr(node.left.left)
            let field = node.left.name
            let val = gen2_expr(node.right)
            return pad + obj + " = hexa_map_set(" + obj + ", hexa_str(\"" + field + "\"), " + val + ");\n"
        }
        return pad + gen2_expr(node.left) + " = " + gen2_expr(node.right) + ";\n"
    }

    if k == "CompoundAssign" {
        let lhs = gen2_expr(node.left)
        let rhs = gen2_expr(node.right)
        let op = node.op
        if op == "+=" {
            return pad + lhs + " = hexa_add(" + lhs + ", " + rhs + ");\n"
        }
        if op == "-=" {
            return pad + lhs + " = hexa_int((" + lhs + ").i - (" + rhs + ").i);\n"
        }
        if op == "*=" {
            return pad + lhs + " = hexa_int((" + lhs + ").i * (" + rhs + ").i);\n"
        }
        if op == "/=" {
            return pad + lhs + " = hexa_int((" + lhs + ").i / (" + rhs + ").i);\n"
        }
        if op == "%=" {
            return pad + lhs + " = hexa_int((" + lhs + ").i % (" + rhs + ").i);\n"
        }
        return pad + "/* compound " + op + " */\n"
    }

    if k == "ReturnStmt" {
        if type_of(node.left) != "string" {
            return pad + "return " + gen2_expr(node.left) + ";\n"
        }
        return pad + "return hexa_void();\n"
    }

    if k == "ExprStmt" {
        let expr = node.left
        if type_of(expr) == "string" { return "" }
        if expr.kind == "MatchExpr" {
            return gen2_match_stmt(expr, depth)
        }
        if expr.kind == "IfExpr" {
            let mut out = pad + "if (hexa_truthy(" + gen2_expr(expr.cond) + ")) {\n"
            let mut ti = 0
            while ti < len(expr.then_body) {
                out = out + gen2_stmt(expr.then_body[ti], depth + 1)
                ti = ti + 1
            }
            out = out + pad + "}"
            if type_of(expr.else_body) != "string" && len(expr.else_body) > 0 {
                out = out + " else {\n"
                let mut ei = 0
                while ei < len(expr.else_body) {
                    out = out + gen2_stmt(expr.else_body[ei], depth + 1)
                    ei = ei + 1
                }
                out = out + pad + "}"
            }
            return out + "\n"
        }
        return pad + gen2_expr(expr) + ";\n"
    }

    if k == "WhileStmt" {
        let mut out = pad + "while (hexa_truthy(" + gen2_expr(node.cond) + ")) {\n"
        let mut wi = 0
        while wi < len(node.body) {
            out = out + gen2_stmt(node.body[wi], depth + 1)
            wi = wi + 1
        }
        return out + pad + "}\n"
    }

    if k == "ForStmt" {
        let iter = node.iter_expr
        if type_of(iter) != "string" && iter.kind == "Range" {
            let s = gen2_expr(iter.left)
            let e = gen2_expr(iter.right)
            let mut out = pad + "for (HexaVal " + node.name + " = " + s + "; " + node.name + ".i < (" + e + ").i; " + node.name + ".i++) {\n"
            let mut fi = 0
            while fi < len(node.body) {
                out = out + gen2_stmt(node.body[fi], depth + 1)
                fi = fi + 1
            }
            return out + pad + "}\n"
        }
        // General for-in: iterate over array
        let iter_c = gen2_expr(iter)
        let mut out = pad + "{\n"
        let pad2 = gen2_indent(depth + 1)
        out = out + pad2 + "HexaVal __iter_arr = " + iter_c + ";\n"
        out = out + pad2 + "for (int __fi = 0; __fi < hexa_len(__iter_arr); __fi++) {\n"
        let pad3 = gen2_indent(depth + 2)
        out = out + pad3 + "HexaVal " + node.name + " = hexa_array_get(__iter_arr, __fi);\n"
        let mut fi = 0
        while fi < len(node.body) {
            out = out + gen2_stmt(node.body[fi], depth + 2)
            fi = fi + 1
        }
        out = out + pad2 + "}\n"
        out = out + pad + "}\n"
        return out
    }

    if k == "BreakStmt" {
        return pad + "break;\n"
    }

    if k == "ContinueStmt" {
        return pad + "continue;\n"
    }

    if k == "ThrowStmt" {
        if type_of(node.left) != "string" {
            return pad + "hexa_throw(" + gen2_expr(node.left) + ");\n"
        }
        return pad + "hexa_throw(hexa_str(\"error\"));\n"
    }

    if k == "TryCatchStmt" || k == "TryCatch" {
        // Parser stores: left=try_body, right=catch_body, name=catch_var
        let try_body = node.left
        let catch_body = node.right
        let catch_var = node.name
        let mut out = pad + "{\n"
        let pad2 = gen2_indent(depth + 1)
        out = out + pad2 + "jmp_buf __jb; HexaVal __err = hexa_void();\n"
        out = out + pad2 + "if (setjmp(__jb) == 0) {\n"
        out = out + pad2 + "    __hexa_try_push(&__jb);\n"
        if type_of(try_body) != "string" {
            let mut ti = 0
            while ti < len(try_body) {
                out = out + gen2_stmt(try_body[ti], depth + 2)
                ti = ti + 1
            }
        }
        out = out + pad2 + "    __hexa_try_pop();\n"
        out = out + pad2 + "} else {\n"
        out = out + pad2 + "    __err = __hexa_last_error();\n"
        if catch_var != "" && catch_var != "_" {
            out = out + pad2 + "    HexaVal " + catch_var + " = __err;\n"
        }
        if type_of(catch_body) != "string" {
            let mut ci = 0
            while ci < len(catch_body) {
                out = out + gen2_stmt(catch_body[ci], depth + 2)
                ci = ci + 1
            }
        }
        out = out + pad2 + "}\n"
        out = out + pad + "}\n"
        return out
    }

    // ── Match statement (MatchExpr used as statement) ────────
    if k == "MatchExpr" {
        return gen2_match_stmt(node, depth)
    }

    return pad + "/* " + k + " */\n"
}

fn c_escape(s) {
    // Escape special chars for C string literals
    // to_string() handles char type values from CharLit AST nodes
    // Must do backslash first to avoid double-escaping
    let mut out = to_string(s).replace("\\", "\\\\")
    out = out.replace("\"", "\\\"")
    out = out.replace("\n", "\\n")
    out = out.replace("\r", "\\r")
    out = out.replace("\t", "\\t")
    return out
}

fn gen2_expr(node) {
    let k = node.kind

    if k == "IntLit" { return "hexa_int(" + node.value + ")" }
    if k == "FloatLit" { return "hexa_float(" + node.value + ")" }
    if k == "BoolLit" {
        if node.value == "true" { return "hexa_bool(1)" }
        return "hexa_bool(0)"
    }
    if k == "StringLit" { return "hexa_str(\"" + c_escape(node.value) + "\")" }
    if k == "CharLit" {
        // Runtime uses TAG_STR for chars (hexa_str_chars returns single-char strings)
        // so char literals must also be TAG_STR for hexa_eq to work
        return "hexa_str(\"" + c_escape(node.value) + "\")"
    }
    if k == "Ident" { return node.name }

    if k == "BinOp" {
        let l = gen2_expr(node.left)
        let r = gen2_expr(node.right)
        let op = node.op
        // Int arithmetic
        if op == "+" {
            return "hexa_add(" + l + ", " + r + ")"
        }
        if op == "-" { return "hexa_int((" + l + ").i - (" + r + ").i)" }
        if op == "*" { return "hexa_int((" + l + ").i * (" + r + ").i)" }
        if op == "/" { return "hexa_int((" + l + ").i / (" + r + ").i)" }
        if op == "%" { return "hexa_int((" + l + ").i % (" + r + ").i)" }
        // Comparisons
        if op == "==" { return "hexa_eq(" + l + ", " + r + ")" }
        if op == "!=" { return "hexa_bool(!hexa_truthy(hexa_eq(" + l + ", " + r + ")))" }
        if op == "<" { return "hexa_bool((" + l + ").i < (" + r + ").i)" }
        if op == ">" { return "hexa_bool((" + l + ").i > (" + r + ").i)" }
        if op == "<=" { return "hexa_bool((" + l + ").i <= (" + r + ").i)" }
        if op == ">=" { return "hexa_bool((" + l + ").i >= (" + r + ").i)" }
        if op == "&&" { return "hexa_bool(hexa_truthy(" + l + ") && hexa_truthy(" + r + "))" }
        if op == "||" { return "hexa_bool(hexa_truthy(" + l + ") || hexa_truthy(" + r + "))" }
        return "/* binop " + op + " */"
    }

    if k == "UnaryOp" {
        if node.op == "-" { return "hexa_int(-(" + gen2_expr(node.left) + ").i)" }
        if node.op == "!" { return "hexa_bool(!hexa_truthy(" + gen2_expr(node.left) + "))" }
        return "/* unary */"
    }

    // ── Field access: obj.field → hexa_map_get(obj, "field") ──
    if k == "Field" {
        let obj = gen2_expr(node.left)
        let field = node.name
        return "hexa_map_get(" + obj + ", \"" + field + "\")"
    }

    // ── Struct init: Name { f1: v1, f2: v2 } → constructor call ──
    if k == "StructInit" {
        let name = node.name
        let mut arg_strs = []
        let mut si = 0
        while si < len(node.fields) {
            arg_strs = arg_strs.push(gen2_expr(node.fields[si].left))
            si = si + 1
        }
        return name + "(" + arg_strs.join(", ") + ")"
    }

    if k == "Call" {
        let callee = node.left
        if type_of(callee) != "string" && callee.kind == "Ident" {
            let name = callee.name
            // Built-in mappings
            if name == "println" {
                if len(node.args) > 0 {
                    return "hexa_println(" + gen2_expr(node.args[0]) + ")"
                }
                return "(printf(\"\\n\"), hexa_void())"
            }
            if name == "print" {
                if len(node.args) > 0 {
                    return "(hexa_print_val(" + gen2_expr(node.args[0]) + "), hexa_void())"
                }
                return "hexa_void()"
            }
            if name == "len" {
                return "hexa_int(hexa_len(" + gen2_expr(node.args[0]) + "))"
            }
            if name == "to_string" {
                return "hexa_to_string(" + gen2_expr(node.args[0]) + ")"
            }
            if name == "type_of" {
                return "hexa_type_of(" + gen2_expr(node.args[0]) + ")"
            }
            // Math built-ins (1-arg, float result via C math.h)
            if name == "sqrt" {
                return "hexa_sqrt(" + gen2_expr(node.args[0]) + ")"
            }
            if name == "floor" {
                return "hexa_floor(" + gen2_expr(node.args[0]) + ")"
            }
            if name == "ceil" {
                return "hexa_ceil(" + gen2_expr(node.args[0]) + ")"
            }
            if name == "abs" {
                return "hexa_abs(" + gen2_expr(node.args[0]) + ")"
            }
            if name == "round" {
                let a = gen2_expr(node.args[0])
                return "hexa_int((int64_t)round(" + a + ".tag==TAG_FLOAT?" + a + ".f:(double)" + a + ".i))"
            }
            // ln / log / log10 / exp — physics-critical (Boltzmann, Shannon, Landauer)
            if name == "ln" || name == "log" {
                let a = gen2_expr(node.args[0])
                return "hexa_float(log(" + a + ".tag==TAG_FLOAT?" + a + ".f:(double)" + a + ".i))"
            }
            if name == "log10" {
                let a = gen2_expr(node.args[0])
                return "hexa_float(log10(" + a + ".tag==TAG_FLOAT?" + a + ".f:(double)" + a + ".i))"
            }
            if name == "exp" {
                let a = gen2_expr(node.args[0])
                return "hexa_float(exp(" + a + ".tag==TAG_FLOAT?" + a + ".f:(double)" + a + ".i))"
            }
            // Trig built-ins
            if name == "sin" {
                let a = gen2_expr(node.args[0])
                return "hexa_float(sin(" + a + ".tag==TAG_FLOAT?" + a + ".f:(double)" + a + ".i))"
            }
            if name == "cos" {
                let a = gen2_expr(node.args[0])
                return "hexa_float(cos(" + a + ".tag==TAG_FLOAT?" + a + ".f:(double)" + a + ".i))"
            }
            // Math built-ins (2-arg)
            if name == "pow" {
                return "hexa_pow(" + gen2_expr(node.args[0]) + ", " + gen2_expr(node.args[1]) + ")"
            }
            if name == "to_float" {
                let a = gen2_expr(node.args[0])
                return "hexa_float(" + a + ".tag==TAG_FLOAT?" + a + ".f:(double)" + a + ".i)"
            }
            // Character / string classification builtins
            if name == "is_alpha" {
                let a = gen2_expr(node.args[0])
                return "hexa_bool((" + a + ".tag==TAG_STR && " + a + ".s && isalpha((unsigned char)" + a + ".s[0])) || (" + a + ".tag==TAG_CHAR && isalpha((unsigned char)" + a + ".i)))"
            }
            if name == "is_digit" {
                let a = gen2_expr(node.args[0])
                return "hexa_bool((" + a + ".tag==TAG_STR && " + a + ".s && isdigit((unsigned char)" + a + ".s[0])) || (" + a + ".tag==TAG_CHAR && isdigit((unsigned char)" + a + ".i)))"
            }
            if name == "is_alphanumeric" {
                let a = gen2_expr(node.args[0])
                return "hexa_bool((" + a + ".tag==TAG_STR && " + a + ".s && isalnum((unsigned char)" + a + ".s[0])) || (" + a + ".tag==TAG_CHAR && isalnum((unsigned char)" + a + ".i)))"
            }
            if name == "file_exists" {
                let a = gen2_expr(node.args[0])
                return "hexa_bool(access(" + a + ".s, F_OK) == 0)"
            }
            if name == "format" {
                // format(template, args...) -> hexa_format_n with array of args
                let mut fmt_args = "hexa_array_new()"
                let mut fi = 1
                while fi < len(node.args) {
                    fmt_args = "hexa_array_push(" + fmt_args + ", " + gen2_expr(node.args[fi]) + ")"
                    fi = fi + 1
                }
                return "hexa_format_n(" + gen2_expr(node.args[0]) + ", " + fmt_args + ")"
            }
            if name == "eprintln" {
                if len(node.args) > 0 {
                    return "(hexa_eprint_val(" + gen2_expr(node.args[0]) + "), fprintf(stderr, \"\\n\"), hexa_void())"
                }
                return "(fprintf(stderr, \"\\n\"), hexa_void())"
            }
            if name == "args" {
                return "hexa_args()"
            }
            if name == "exec" {
                return "hexa_exec(" + gen2_expr(node.args[0]) + ")"
            }
            if name == "to_int" {
                let a = gen2_expr(node.args[0])
                return "hexa_int((" + a + ".tag==TAG_FLOAT?(int64_t)" + a + ".f:" + a + ".tag==TAG_STR?atoll(" + a + ".s):" + a + ".i))"
            }
            if name == "min" {
                let a = gen2_expr(node.args[0])
                let b = gen2_expr(node.args[1])
                return "hexa_int((" + a + ").i < (" + b + ").i ? (" + a + ").i : (" + b + ").i)"
            }
            if name == "max" {
                let a = gen2_expr(node.args[0])
                let b = gen2_expr(node.args[1])
                return "hexa_int((" + a + ").i > (" + b + ").i ? (" + a + ").i : (" + b + ").i)"
            }
            if name == "read_file" {
                return "hexa_read_file(" + gen2_expr(node.args[0]) + ")"
            }
            if name == "write_file" {
                return "hexa_write_file(" + gen2_expr(node.args[0]) + ", " + gen2_expr(node.args[1]) + ")"
            }
            // User function call
            let mut arg_strs = []
            let mut ai = 0
            while ai < len(node.args) {
                arg_strs = arg_strs.push(gen2_expr(node.args[ai]))
                ai = ai + 1
            }
            return name + "(" + arg_strs.join(", ") + ")"
        }
        // Method call: obj.method(args)
        if type_of(callee) != "string" && callee.kind == "Field" {
            let obj = gen2_expr(callee.left)
            let method = callee.name
            if method == "push" {
                return "hexa_array_push(" + obj + ", " + gen2_expr(node.args[0]) + ")"
            }
            if method == "len" {
                return "hexa_int(hexa_len(" + obj + "))"
            }
            if method == "chars" {
                return "hexa_str_chars(" + obj + ")"
            }
            if method == "contains" {
                return "hexa_bool(hexa_str_contains(" + obj + ", " + gen2_expr(node.args[0]) + "))"
            }
            if method == "join" {
                return "hexa_str_join(" + obj + ", " + gen2_expr(node.args[0]) + ")"
            }
            if method == "to_upper" {
                return "hexa_str_to_upper(" + obj + ")"
            }
            if method == "to_lower" {
                return "hexa_str_to_lower(" + obj + ")"
            }
            if method == "split" {
                return "hexa_str_split(" + obj + ", " + gen2_expr(node.args[0]) + ")"
            }
            if method == "trim" {
                return "hexa_str_trim(" + obj + ")"
            }
            if method == "replace" {
                return "hexa_str_replace(" + obj + ", " + gen2_expr(node.args[0]) + ", " + gen2_expr(node.args[1]) + ")"
            }
            if method == "repeat" {
                return "hexa_str_repeat(" + obj + ", " + gen2_expr(node.args[0]) + ")"
            }
            if method == "starts_with" {
                return "hexa_bool(hexa_str_starts_with(" + obj + ", " + gen2_expr(node.args[0]) + "))"
            }
            if method == "ends_with" {
                return "hexa_bool(hexa_str_ends_with(" + obj + ", " + gen2_expr(node.args[0]) + "))"
            }
            if method == "substring" {
                return "hexa_str_substring(" + obj + ", " + gen2_expr(node.args[0]) + ", " + gen2_expr(node.args[1]) + ")"
            }
            if method == "index_of" {
                return "hexa_int(hexa_str_index_of(" + obj + ", " + gen2_expr(node.args[0]) + "))"
            }
            if method == "pop" {
                return "hexa_array_pop(" + obj + ")"
            }
            if method == "reverse" {
                return "hexa_array_reverse(" + obj + ")"
            }
            if method == "sort" {
                return "hexa_array_sort(" + obj + ")"
            }
            return "/* method." + method + " */"
        }
        return "/* indirect call */"
    }

    if k == "Array" {
        let mut out = "hexa_array_new()"
        let mut ai = 0
        while ai < len(node.items) {
            out = "hexa_array_push(" + out + ", " + gen2_expr(node.items[ai]) + ")"
            ai = ai + 1
        }
        return out
    }

    if k == "Index" {
        return "hexa_array_get(" + gen2_expr(node.left) + ", (" + gen2_expr(node.right) + ").i)"
    }

    // ── Enum path: Color::Red → hexa_int(N) ──────────────────
    if k == "EnumPath" {
        let ename = node.name
        let vname = node.value
        return ename + "_" + vname
    }

    // ── Match expression (value-producing) ──────────────────
    if k == "MatchExpr" {
        return gen2_match_expr(node)
    }

    // ── Lambda / closure ────────────────────────────────────
    if k == "Lambda" {
        return gen2_lambda_expr(node)
    }

    // ── Tuple → Array ─────────────────────────────────────
    if k == "Tuple" || k == "TupleLit" {
        let mut out = "hexa_array_new()"
        let items = node.items
        if type_of(items) != "string" {
            let mut ti = 0
            while ti < len(items) {
                out = "hexa_array_push(" + out + ", " + gen2_expr(items[ti]) + ")"
                ti = ti + 1
            }
        }
        return out
    }

    // ── Map literal → hexa_map_new + set ──────────────────
    if k == "MapLit" {
        let mut out = "hexa_map_new()"
        if type_of(node.items) != "string" {
            let mut mi = 0
            while mi < len(node.items) {
                let entry = node.items[mi]
                out = "hexa_map_set(" + out + ", " + gen2_expr(entry.left) + ", " + gen2_expr(entry.right) + ")"
                mi = mi + 1
            }
        }
        return out
    }

    // ── Negation of float ──────────────────────────────────
    if k == "NegFloat" {
        return "hexa_float(-(" + gen2_expr(node.left) + ").f)"
    }

    // ── Wildcard (used in patterns) ─────────────────────────
    if k == "Wildcard" {
        return "/* wildcard */"
    }

    return "/* expr:" + k + " */"
}

fn gen2_struct_decl(node) {
    // Generate a constructor function: StructName(field1, field2, ...) -> HexaVal map
    let name = node.name
    let mut params = []
    let mut body = "    HexaVal __s = hexa_map_new();\n"
    let mut i = 0
    while i < len(node.fields) {
        let f = node.fields[i]
        params = params.push("HexaVal " + f.name)
        body = body + "    __s = hexa_map_set(__s, \"" + f.name + "\", " + f.name + ");\n"
        i = i + 1
    }
    let p = params.join(", ")
    if p == "" { p = "void" }
    return "HexaVal " + name + "(" + p + ") {\n" + body + "    return __s;\n}\n"
}

// ═══════════════════════════════════════════════════════════
//  Enum codegen — tagged integer #define constants
// ═══════════════════════════════════════════════════════════

fn gen2_enum_decl(node) {
    let name = node.name
    let mut out = "// enum " + name + "\n"
    let mut i = 0
    while i < len(node.variants) {
        let v = node.variants[i]
        out = out + "#define " + name + "_" + v.name + " hexa_int(" + to_string(i) + ")\n"
        i = i + 1
    }
    return out
}

// ═══════════════════════════════════════════════════════════
//  Match statement — generate if-else chain
// ═══════════════════════════════════════════════════════════

fn gen2_match_stmt(node, depth) {
    let pad = gen2_indent(depth)
    let scrutinee = gen2_expr(node.left)

    // Store scrutinee in temp to avoid re-evaluation
    let mut out = pad + "{\n"
    let pad2 = gen2_indent(depth + 1)
    out = out + pad2 + "HexaVal __match_val = " + scrutinee + ";\n"

    let mut ai = 0
    while ai < len(node.arms) {
        let arm = node.arms[ai]
        let pat = arm.left
        let is_wildcard = (type_of(pat) != "string" && pat.kind == "Wildcard")

        if is_wildcard {
            // Default arm — always matches
            if ai > 0 {
                out = out + " else {\n"
            } else {
                out = out + pad2 + "{\n"
            }
        } else {
            let cond = gen2_match_cond(pat, "__match_val")
            if ai == 0 {
                out = out + pad2 + "if (" + cond + ") {\n"
            } else {
                out = out + " else if (" + cond + ") {\n"
            }
        }

        // Arm body
        let mut bi = 0
        while bi < len(arm.body) {
            out = out + gen2_stmt(arm.body[bi], depth + 2)
            bi = bi + 1
        }
        out = out + pad2 + "}"
        ai = ai + 1
    }
    out = out + "\n" + pad + "}\n"
    return out
}

fn gen2_match_cond(pat, scrutinee_var) {
    if type_of(pat) == "string" {
        return "1"
    }
    let k = pat.kind
    if k == "Wildcard" {
        return "1"
    }
    if k == "IntLit" {
        return "hexa_truthy(hexa_eq(" + scrutinee_var + ", hexa_int(" + pat.value + ")))"
    }
    if k == "FloatLit" {
        return "hexa_truthy(hexa_eq(" + scrutinee_var + ", hexa_float(" + pat.value + ")))"
    }
    if k == "StringLit" {
        return "hexa_truthy(hexa_eq(" + scrutinee_var + ", hexa_str(\"" + c_escape(pat.value) + "\")))"
    }
    if k == "BoolLit" {
        if pat.value == "true" {
            return "hexa_truthy(hexa_eq(" + scrutinee_var + ", hexa_bool(1)))"
        }
        return "hexa_truthy(hexa_eq(" + scrutinee_var + ", hexa_bool(0)))"
    }
    if k == "EnumPath" {
        let enum_const = pat.name + "_" + pat.value
        return "hexa_truthy(hexa_eq(" + scrutinee_var + ", " + enum_const + "))"
    }
    // Fallback: compare with the expression
    return "hexa_truthy(hexa_eq(" + scrutinee_var + ", " + gen2_expr(pat) + "))"
}

// ═══════════════════════════════════════════════════════════
//  Match expression (value-producing) — uses ternary chain
// ═══════════════════════════════════════════════════════════

fn gen2_match_expr(node) {
    let scrutinee = gen2_expr(node.left)
    // Build a nested ternary: (cond1 ? val1 : (cond2 ? val2 : default))
    // For simplicity, wrap in a compound expression using GCC ({...})
    // Instead, just produce the ternary chain
    let arms = node.arms
    return gen2_match_ternary(arms, scrutinee, 0)
}

fn gen2_match_ternary(arms, scrutinee_c, idx) {
    if idx >= len(arms) {
        return "hexa_void()"
    }
    let arm = arms[idx]
    let pat = arm.left
    let is_wildcard = (type_of(pat) != "string" && pat.kind == "Wildcard")

    // Get the value from the arm body (last expr)
    let val = gen2_arm_value(arm.body)

    if is_wildcard || idx == len(arms) - 1 {
        if is_wildcard {
            return val
        }
        let cond = gen2_match_cond(pat, scrutinee_c)
        return "(" + cond + " ? " + val + " : hexa_void())"
    }

    let cond = gen2_match_cond(pat, scrutinee_c)
    let rest = gen2_match_ternary(arms, scrutinee_c, idx + 1)
    return "(" + cond + " ? " + val + " : " + rest + ")"
}

fn gen2_arm_value(body) {
    if type_of(body) == "string" || len(body) == 0 {
        return "hexa_void()"
    }
    // Use the last statement's expression as the value
    let last = body[len(body) - 1]
    if last.kind == "ExprStmt" {
        return gen2_expr(last.left)
    }
    if last.kind == "ReturnStmt" {
        if type_of(last.left) != "string" {
            return gen2_expr(last.left)
        }
    }
    return "hexa_void()"
}

// ═══════════════════════════════════════════════════════════
//  Lambda / closure codegen
//  Non-capturing: generate a static C function
//  Capturing: generate closure struct + function
// ═══════════════════════════════════════════════════════════

let mut _lambda_counter = 0
let mut _lambda_defs = ""

fn gen2_lambda_expr(node) {
    let id = _lambda_counter
    _lambda_counter = _lambda_counter + 1
    let fn_name = "__hexa_lambda_" + to_string(id)

    // Build parameter list
    let mut params = []
    let mut pi = 0
    while pi < len(node.params) {
        params = params.push("HexaVal " + node.params[pi])
        pi = pi + 1
    }
    let p = params.join(", ")
    if p == "" { p = "void" }

    // Build function body
    let mut body_c = ""
    let lbody = node.left
    if type_of(lbody) != "string" {
        if type_of(lbody) == "array" {
            // Block body
            let mut bi = 0
            while bi < len(lbody) {
                body_c = body_c + gen2_stmt(lbody[bi], 1)
                bi = bi + 1
            }
        } else {
            // Single expression body — return it
            body_c = "    return " + gen2_expr(lbody) + ";\n"
        }
    }

    // Emit the function definition (will be placed before main)
    let fn_def = "HexaVal " + fn_name + "(" + p + ") {\n" + body_c + "    return hexa_void();\n}\n\n"
    _lambda_defs = _lambda_defs + fn_def

    // Return a reference to the function
    // For now, lambdas are represented as function pointers cast to HexaVal
    // Using the int field to store the function pointer (non-capturing only)
    return "(HexaVal){.tag=TAG_INT, .i=(int64_t)(uintptr_t)&" + fn_name + "}"
}

// Override codegen_c2 to include lambda definitions
fn codegen_c2_full(ast) {
    _lambda_counter = 0
    _lambda_defs = ""

    let mut out = ""
    out = out + "// Generated by HEXA self-host compiler\n"
    out = out + "#include \"runtime.c\"\n\n"

    // Forward declarations
    let mut fwd = ""
    let mut fn_code = ""
    let mut main_code = ""

    let mut i = 0
    while i < len(ast) {
        let k = ast[i].kind
        if k == "FnDecl" {
            fwd = fwd + gen2_fn_forward(ast[i]) + "\n"
            fn_code = fn_code + gen2_fn_decl(ast[i]) + "\n\n"
        } else if k == "StructDecl" {
            fn_code = fn_code + gen2_struct_decl(ast[i]) + "\n\n"
        } else if k == "EnumDecl" {
            fn_code = fn_code + gen2_enum_decl(ast[i]) + "\n"
        } else if k == "TraitDecl" || k == "ImplBlock" {
            // Skip
        } else {
            main_code = main_code + gen2_stmt(ast[i], 1)
        }
        i = i + 1
    }

    out = out + fwd + "\n"
    // Insert lambda definitions before user functions
    out = out + _lambda_defs
    out = out + fn_code
    out = out + "int main() {\n"
    out = out + main_code
    out = out + "    return 0;\n}\n"
    return out
}

println("=== HEXA → C (HexaVal runtime) Code Generator ===")
