            }
            // `.byte_at(i)` — alias of char_code_at: raw byte value (0-255) at
            // byte index i, or -1 if out of range. Matches interpreter
            // self/hexa_full.hexa:16148-16156. Required for cross-language
            // hash compatibility (hxa-20260425-byteAt-builtin).
            if method == "byte_at" {
                return cg_string_sym("str_char_code_at") + "(" + obj + ", " + gen2_expr(node.args[0]) + ")"
            }
            // ── Map methods ──
            if method == "keys" {
                return "hexa_map_keys(" + obj + ")"
            }
            if method == "values" {
                return "hexa_map_values(" + obj + ")"
            }
            if method == "contains_key" {
                return "hexa_bool(hexa_map_contains_key(" + obj + ", hexa_to_cstring(" + gen2_expr(node.args[0]) + ")))"
            }
            if method == "has_key" {
                return "hexa_bool(hexa_map_contains_key(" + obj + ", hexa_to_cstring(" + gen2_expr(node.args[0]) + ")))"
            }
            if method == "remove" {
                return "hexa_map_remove(" + obj + ", hexa_to_cstring(" + gen2_expr(node.args[0]) + "))"
            }
            if method == "get" {
                return "hexa_map_get(" + obj + ", hexa_to_cstring(" + gen2_expr(node.args[0]) + "))"
            }
            if method == "set" {
                return "hexa_map_set(" + obj + ", hexa_to_cstring(" + gen2_expr(node.args[0]) + "), " + gen2_expr(node.args[1]) + ")"
            }
            if method == "pop" {
                return "hexa_array_pop(" + obj + ")"
            }
            if method == "reverse" {
                return "hexa_array_reverse(" + obj + ")"
            }
            if method == "sort" {
                return "hexa_array_sort(" + obj + ")"
            }
            // bt 55 — in-place array length shrink; caller must reassign.
            if method == "truncate" {
                return "hexa_array_truncate(" + obj + ", " + gen2_expr(node.args[0]) + ")"
            }
            // T33-rebuild fallback batch — missing host-backed methods that
            // were previously hitting the unhandled-method error path. Added
            // while unblocking the interp rebuild regression (task #5).
            if method == "push_nostat" {
                return "hexa_array_push_nostat(" + obj + ", " + gen2_expr(node.args[0]) + ")"
            }
            if method == "trim_start" {
                return cg_string_sym("str_trim_start") + "(" + obj + ")"
            }
            if method == "trim_end" {
                return cg_string_sym("str_trim_end") + "(" + obj + ")"
            }
            // String bytes — UTF-8 byte array. runtime.c hexa_str_bytes
            // mirrors interpreter self/hexa_full.hexa:15074-15079.
            if method == "bytes" {
                return cg_string_sym("str_bytes") + "(" + obj + ")"
            }
            // String lines — split on '\n'. runtime.c hexa_str_lines
            // delegates to hexa_str_split.
            if method == "lines" {
                return cg_string_sym("str_lines") + "(" + obj + ")"
            }
            if method == "slice" {
                return "hexa_array_slice(" + obj + ", " + gen2_expr(node.args[0]) + ", " + gen2_expr(node.args[1]) + ")"
            }
            if method == "slice_fast" {
                return "hexa_array_slice_fast(" + obj + ", " + gen2_expr(node.args[0]) + ", " + gen2_expr(node.args[1]) + ")"
            }
            if method == "to_string" {
                return "hexa_to_string(" + obj + ")"
            }
            if method == "parse_int" {
                return cg_string_sym("str_parse_int") + "(" + obj + ")"
            }
            if method == "parse_float" {
                return cg_string_sym("str_parse_float") + "(" + obj + ")"
            }
            if method == "pad_left" {
                return "hexa_pad_left(" + obj + ", " + gen2_expr(node.args[0]) + ")"
            }
            // Last-resort fallback — route anything unhandled through
            // gen2_method_builtin which has the comprehensive array method
            // dispatch (map/filter/fold/any/all/count/find/flat_map/enumerate
            // + many others). Without this, user-type path works via line 3479
            // but the bare inline path below hits CODEGEN ERROR for any
            // array-side method we missed. Matches line 2237+ coverage.
            let fallback = gen2_method_builtin(obj, method, node.args)
            if len(fallback) > 0 { return fallback }
            eprintln("[codegen_c2] ERROR: unhandled method call: " + method)
            return "(fprintf(stderr, \"CODEGEN ERROR: unhandled method: " + method + "\\n\"), exit(1), hexa_void())"
        }
        // Indirect call: callee is an arbitrary expression evaluating to a
        // closure (TAG_CLOSURE) or raw fn (TAG_FN). Dispatch via hexa_callN.
        let cexpr = gen2_expr(callee)
        let nargs = len(node.args)
        let mut cargs = []
        let mut ci = 0
        while ci < nargs {
            let _ca = node.args[ci]
            if type_of(_ca) != "string" && _ca.kind == "Ident" && _is_known_fn_global(_ca.name) {
                // Wrap function name as TAG_FN value for first-class fn passing
                cargs.push("hexa_fn_new((void*)" + _hexa_mangle_ident(_ca.name) + ", 0)")
            } else {
                cargs.push(gen2_expr(_ca))
            }
            ci = ci + 1
        }
        if nargs == 0 { return "hexa_call0(" + cexpr + ")" }
        if nargs == 1 { return "hexa_call1(" + cexpr + ", " + cargs[0] + ")" }
        if nargs == 2 { return "hexa_call2(" + cexpr + ", " + cargs.join(", ") + ")" }
        if nargs == 3 { return "hexa_call3(" + cexpr + ", " + cargs.join(", ") + ")" }
        if nargs == 4 { return "hexa_call4(" + cexpr + ", " + cargs.join(", ") + ")" }
        eprintln("[codegen_c2] ERROR: indirect call arity " + to_string(nargs) + " unsupported (max 4)")
        return "(fprintf(stderr, \"CODEGEN ERROR: indirect call arity %d unsupported\\n\", " + to_string(nargs) + "), exit(1), hexa_void())"
    }

    if k == "Array" {
        let mut out = "hexa_array_new()"
        let mut ai = 0
        while ai < len(node.items) {
            out = "hexa_array_push(" + out + ", " + gen2_expr(node.items[ai]) + ")"
            ai = ai + 1
        }
        return out
    }

    if k == "Index" {
        return "hexa_index_get(" + gen2_expr(node.left) + ", " + gen2_expr(node.right) + ")"
    }

    // ── Enum path: Color::Red → hexa_int(N) ──────────────────
    if k == "EnumPath" {
        let ename = node.name
        let vname = node.value
        return ename + "_" + vname
    }

    // ── If expression (value-producing ternary) ──────────────
    if k == "IfExpr" {
        let c = gen2_expr(node.cond)
        // Extract value from then_body (last ExprStmt)
        let mut t_val = "hexa_void()"
        if type_of(node.then_body) != "string" && len(node.then_body) > 0 {
            let t_last = node.then_body[len(node.then_body) - 1]
            if type_of(t_last) != "string" && t_last.kind == "ExprStmt" && type_of(t_last.left) != "string" {
                t_val = gen2_expr(t_last.left)
            }
        }
        let mut e_val = "hexa_void()"
        if type_of(node.else_body) != "string" && len(node.else_body) > 0 {
            let e_last = node.else_body[len(node.else_body) - 1]
            if type_of(e_last) != "string" && e_last.kind == "ExprStmt" && type_of(e_last.left) != "string" {
                e_val = gen2_expr(e_last.left)
            }
        }
        return "(hexa_truthy(" + c + ") ? " + t_val + " : " + e_val + ")"
    }

    // ── Match expression (value-producing) ──────────────────
    if k == "MatchExpr" {
        return gen2_match_expr(node)
    }

    // ── Lambda / closure ────────────────────────────────────
    if k == "Lambda" {
        return gen2_lambda_expr(node)
    }

    // ── Tuple → Array ─────────────────────────────────────
    if k == "Tuple" || k == "TupleLit" {
        let mut out = "hexa_array_new()"
        let items = node.items
        if type_of(items) != "string" {
            let mut ti = 0
            while ti < len(items) {
                out = "hexa_array_push(" + out + ", " + gen2_expr(items[ti]) + ")"
                ti = ti + 1
            }
        }
        return out
    }

    // ── Map literal → hexa_map_new + set ──────────────────
    if k == "MapLit" {
        let mut out = "hexa_map_new()"
        if type_of(node.items) != "string" {
            let mut mi = 0
            while mi < len(node.items) {
                let entry = node.items[mi]
                // hexa_map_set takes const char* key — extract raw string for StringLit keys
                let mut key_c = gen2_expr(entry.left)
                if type_of(entry.left) != "string" && entry.left.kind == "StringLit" {
                    key_c = "\"" + c_escape(entry.left.value) + "\""
                }
                out = "hexa_map_set(" + out + ", " + key_c + ", " + gen2_expr(entry.right) + ")"
                mi = mi + 1
            }
        }
        return out
    }

    // ── Negation of float ──────────────────────────────────
    if k == "NegFloat" {
        return "hexa_float(-HX_FLOAT(" + gen2_expr(node.left) + "))"
    }

    // ── Wildcard (used in patterns) ─────────────────────────
    if k == "Wildcard" {
        return "/* wildcard */"
    }

    // ── Slice expr: arr[s:e], arr[:e], arr[s:], arr[:] ─────
    // Parser shape: left=arr, right=start ("" if missing), cond=end ("" if missing)
    if k == "Slice" {
        let arr_c = gen2_expr(node.left)
        let mut s_c = "hexa_int(0)"
        if type_of(node.right) != "string" {
            s_c = gen2_expr(node.right)
        }
        let mut e_c = "hexa_int(hexa_len(" + arr_c + "))"
        if type_of(node.cond) != "string" {
            e_c = gen2_expr(node.cond)
        }
        return "hexa_array_slice(" + arr_c + ", " + s_c + ", " + e_c + ")"
    }

    // `0..5` / `0..=5` / `0..10 step 2` at expression position — evaluate to
    // int array via runtime. ForStmt has its own fast path at line 1888;
    // this handles the general `let r = 0..n` / `(0..n).map(...)` case.
    if k == "Range" {
        let start_c = gen2_expr(node.left)
        let end_c = gen2_expr(node.right)
        let step_c = if type_of(node.cond) != "string" { gen2_expr(node.cond) } else { "hexa_void()" }
        let incl = if node.value == "inclusive" { "1" } else { "0" }
        return "hexa_range_array(" + start_c + ", " + end_c + ", " + step_c + ", " + incl + ")"
    }
    if k == "" { return "hexa_map_new()" }
    eprintln("[codegen_c2] ERROR: unhandled expression kind: " + k)
    return "(fprintf(stderr, \"CODEGEN ERROR: unhandled expr kind: " + k + "\\n\"), exit(1), hexa_void())"
}

// ═══════════════════════════════════════════════════════════
//  Escape Analysis — stack allocation codegen (ROI id=19)
//  For objects that don't escape their function scope,
//  generate stack-allocated structs instead of heap maps.
// ═══════════════════════════════════════════════════════════

// Generate stack-allocated struct initialization (instead of hexa_map_new)
// Stack-promoted vars use a local C struct on the stack frame.
fn gen2_stack_alloc_struct(var_name, fields) {
    let mut parts = []
    parts.push("    // [escape-analysis] stack-promoted: " + var_name + "\n")
    parts.push("    HexaVal " + var_name + " = hexa_map_new(); // stack-eligible\n")
    let mut i = 0
    while i < len(fields) {
        let f = fields[i]
        parts.push("    " + var_name + " = hexa_map_set(" + var_name + ", \"" + f + "\", hexa_void());\n")
        i = i + 1
    }
    return parts.join("")
}

// Generate a stack-allocated array (fixed-size, no heap)
fn gen2_stack_alloc_array(var_name, size_hint) {
    let mut parts = []
    parts.push("    // [escape-analysis] stack array: " + var_name + " (size hint: " + to_string(size_hint) + ")\n")
    parts.push("    HexaVal " + var_name + " = hexa_array_new();\n")
    return parts.join("")
}

// ═══════════════════════════════════════════════════════════
//  @vectorize — SIMD codegen helpers (ROI id=24)
//  Generates SIMD intrinsic code for vectorized loops.
//  Target: platform-agnostic (SSE/AVX on x86, NEON on ARM)
// ═══════════════════════════════════════════════════════════

// Generate SIMD loop preamble: determine vector width and alignment
fn gen2_simd_preamble(arr_name, width) {
    let mut parts = []
    parts.push("    // [vectorize] SIMD preamble (width=" + to_string(width) + ")\n")
    parts.push("    int64_t __simd_len = hexa_array_len(" + arr_name + ");\n")
    parts.push("    int64_t __simd_vec_iters = __simd_len / " + to_string(width) + ";\n")
    parts.push("    int64_t __simd_remainder = __simd_len % " + to_string(width) + ";\n")
    return parts.join("")
}

// Generate SIMD vectorized loop body for arr[i] = arr[i] op scalar
fn gen2_simd_loop(arr_name, op, scalar_expr, width) {
    let mut parts = []
    parts.push("    // [vectorize] SIMD loop: " + arr_name + "[i] = " + arr_name + "[i] " + op + " scalar\n")
    parts.push("    for (int64_t __vi = 0; __vi < __simd_vec_iters; __vi++) {\n")
    let mut lane = 0
    while lane < width {
        let idx = "__vi * " + to_string(width) + " + " + to_string(lane)
        parts.push("        hexa_array_set(" + arr_name + ", " + idx + ", hexa_int(HX_INT(hexa_array_get(" + arr_name + ", " + idx + ")) " + op + " HX_INT(" + scalar_expr + ")));\n")
        lane = lane + 1
    }
    parts.push("    }\n")
    // Scalar remainder loop
    parts.push("    // [vectorize] scalar remainder\n")
    parts.push("    for (int64_t __ri = __simd_vec_iters * " + to_string(width) + "; __ri < __simd_len; __ri++) {\n")
    parts.push("        hexa_array_set(" + arr_name + ", __ri, hexa_int(HX_INT(hexa_array_get(" + arr_name + ", __ri)) " + op + " HX_INT(" + scalar_expr + ")));\n")
    parts.push("    }\n")
    return parts.join("")
}

// Generate SoA struct constructor: splits AoS into field-parallel arrays
fn gen2_soa_struct_decl(name, fields) {
    let mut parts = []
    parts.push("// [soa] " + name + " — field-parallel layout\n")
    parts.push("HexaVal " + name + "_soa_new(HexaVal __count) {\n")
    parts.push("    HexaVal __soa = hexa_map_new();\n")
    let mut i = 0
    while i < len(fields) {
        let f = fields[i]
        parts.push("    __soa = hexa_map_set(__soa, \"" + f + "s\", hexa_array_new());\n")
        i = i + 1
    }
    parts.push("    return __soa;\n")
    parts.push("}\n")
    return parts.join("")
}

// T33-rebuild: forward declaration for the constructor emitted by
// gen2_struct_decl. Mirrors the `Name(params)` signature so forward-references
// (return Val(...) called before struct Val's body) type-check without
// dropping to K&R implicit-int.
fn gen2_struct_forward(node) {
    let name = node.name
    let nfields = len(node.fields)
    if nfields == 0 {
        return "HexaVal " + name + "(void);"
    }
    let mut params = []
    let mut fi = 0
    while fi < nfields {
        params.push("HexaVal " + node.fields[fi].name)
        fi = fi + 1
    }
    return "HexaVal " + name + "(" + params.join(", ") + ");"
}

fn gen2_struct_decl(node) {
    // Generate a constructor function: StructName(field1, field2, ...) -> HexaVal map
    let name = node.name

    // rt 32-G Phase 0: `Val` is the interpreter's hot tagged-value carrier
    // (~3.37M constructions per d64 200-step run). Route its constructor to
    // the flat-struct primitive hexa_valstruct_new_v instead of hexa_map_new
    // + N map_set. All other struct names fall through to the legacy path.
    // Field order MUST match self/hexa_full.hexa `struct Val` (12 fields).
    if name == "Val" && len(node.fields) == 12 {
        let mut vs_params = []
        let mut vs_args = []
        let mut vi = 0
        while vi < len(node.fields) {
            let fname = node.fields[vi].name
            vs_params.push("HexaVal " + fname)
            vs_args.push(fname)
            vi = vi + 1
        }
        return "HexaVal " + name + "(" + vs_params.join(", ") + ") {\n    return hexa_valstruct_new_v(" + vs_args.join(", ") + ");\n}\n"
    }

    // rt 32-A: struct constructor fast-path. Instead of emitting:
    //     HexaVal __s = hexa_map_new();
    //     __s = hexa_map_set(__s, "__type__", ...);
    //     __s = hexa_map_set(__s, "field_i", field_i);  // ×N
    // emit a single bulk call:
    //     static const char* const _k[] = {"f0","f1",...};
    //     HexaVal _v[] = {f0, f1, ...};
    //     return hexa_struct_pack_map("Name", N, _k, _v);
    // which pre-sizes the hash table once (no rehash) and batch-inserts.
    let mut params = []
    let mut keys_parts = []
    let mut vals_parts = []
    let nfields = len(node.fields)
    let mut i = 0
    while i < nfields {
        let f = node.fields[i]
        params.push("HexaVal " + f.name)
        if i > 0 {
            keys_parts.push(", ")
            vals_parts.push(", ")
        }
        keys_parts.push("\"" + f.name + "\"")
        vals_parts.push(f.name)
        i = i + 1
    }
    let p = params.join(", ")
    let mut p_sig = p
    if p_sig == "" { p_sig = "void" }
    let mut body = ""
    // Handle zero-field structs: still need valid array syntax.
    if nfields == 0 {
        body = "    return hexa_struct_pack_map(\"" + name + "\", 0, (const char* const*)0, (const HexaVal*)0);\n"
    } else {
        let ks_line = "    static const char* const _k[] = {" + keys_parts.join("") + "};\n"
        let vs_line = "    HexaVal _v[] = {" + vals_parts.join("") + "};\n"
        let call_line = "    return hexa_struct_pack_map(\"" + name + "\", " + to_string(nfields) + ", _k, _v);\n"
        body = ks_line + vs_line + call_line
    }
    return "HexaVal " + name + "(" + p_sig + ") {\n" + body + "}\n"
}

// ═══════════════════════════════════════════════════════════
//  @cache_line aligned struct codegen — 64B boundary alignment
//  When a struct has @cache_line attr (in node.value), emit
//  __attribute__((aligned(64))) on the constructor and padding.
// ═══════════════════════════════════════════════════════════

fn gen2_struct_decl_aligned(node) {
    let name = node.name
    let mut params = []
    let mut body_parts = []
    // Emit aligned struct comment
    body_parts.push("    // @cache_line: 64B aligned\n")
    body_parts.push("    HexaVal __s __attribute__((aligned(64))) = hexa_map_new();\n")
    body_parts.push("    __s = hexa_map_set(__s, \"__type__\", hexa_str(\"" + name + "\"));\n")
    // Add padding marker for hot fields
    body_parts.push("    __s = hexa_map_set(__s, \"__cache_line__\", hexa_int(64));\n")
    let mut i = 0
    while i < len(node.fields) {
        let f = node.fields[i]
        params.push("HexaVal " + f.name)
        body_parts.push("    __s = hexa_map_set(__s, \"" + f.name + "\", " + f.name + ");\n")
        i = i + 1
    }
    let p = params.join(", ")
    if p == "" { p = "void" }
    return "HexaVal " + name + "(" + p + ") {\n" + body_parts.join("") + "    return __s;\n}\n"
}

// ═══════════════════════════════════════════════════════════
//  @branch_predict codegen — __builtin_expect for if-conditions
//  Wraps if-conditions with __builtin_expect(cond, 1) (likely)
//  or __builtin_expect(cond, 0) (unlikely) based on hints.
// ═══════════════════════════════════════════════════════════

fn gen2_branch_predict_cond(cond_expr) {
    // Wrap condition with __builtin_expect(cond, 1) — assume likely path
    return "__builtin_expect(hexa_truthy(" + gen2_expr(cond_expr) + "), 1)"
}

fn gen2_branch_unlikely_cond(cond_expr) {
    return "__builtin_expect(hexa_truthy(" + gen2_expr(cond_expr) + "), 0)"
}

// ═══════════════════════════════════════════════════════════
//  @bitfield codegen helper — bit-packing access macros
//  Generates mask/shift accessors for packed bool fields.
// ═══════════════════════════════════════════════════════════

fn gen2_bitfield_accessor(struct_name, field_name, bit_offset) {
    let mask = "((1ULL << 1) - 1)"
    let getter = "#define " + struct_name + "_get_" + field_name + "(v) ((HX_INT(v) >> " + to_string(bit_offset) + ") & " + mask + ")\n"
    let setter = "#define " + struct_name + "_set_" + field_name + "(v, b) ((v) = HX_MAKE_INT((HX_INT(v) & ~(" + mask + " << " + to_string(bit_offset) + ")) | (((b) & " + mask + ") << " + to_string(bit_offset) + "))))\n"
    return getter + setter
}

// ═══════════════════════════════════════════════════════════
//  Enum codegen — tagged integer #define constants
// ═══════════════════════════════════════════════════════════

fn gen2_enum_decl(node) {
    let name = node.name
    let vc = len(node.variants)
    // @compact enum: compute minimum bits for tag
    let tag_bits = gen2_min_bits(vc)
    // perf: chunks.push + join — avoid O(n^2) string concat
    let mut parts = []
    parts.push("// enum " + name + " (" + to_string(vc) + " variants, " + to_string(tag_bits) + " tag bit(s))\n")
    // For compact enums with <= 255 variants, use uint8_t mask comment
    if tag_bits < 8 {
        parts.push("// @compact: tag fits in " + to_string(tag_bits) + " bit(s), mask=0x" + gen2_hex_mask(tag_bits) + "\n")
    }
    let mut i = 0
    while i < vc {
        let v = node.variants[i]
        parts.push("#define " + name + "_" + v.name + " hexa_int(" + to_string(i) + ")\n")
        i = i + 1
    }
    return parts.join("")
}

fn gen2_min_bits(count) {
    if count <= 1 { return 1 }
    let mut bits = 0
    let mut v = count - 1
    while v > 0 {
        bits = bits + 1
        v = v / 2
    }
    return bits
}

fn gen2_hex_mask(bits) {
    if bits == 1 { return "01" }
    if bits == 2 { return "03" }
    if bits == 3 { return "07" }
    if bits == 4 { return "0f" }
    if bits == 5 { return "1f" }
    if bits == 6 { return "3f" }
    if bits == 7 { return "7f" }
    return "ff"
}

// ═══════════════════════════════════════════════════════════
//  Match statement — generate if-else chain
// ═══════════════════════════════════════════════════════════

fn gen2_match_stmt(node, depth) {
    let pad = gen2_indent(depth)
    let scrutinee = gen2_expr(node.left)

    // Store scrutinee in temp to avoid re-evaluation
    let mut chunks = []
    chunks.push(pad + "{\n")
    let pad2 = gen2_indent(depth + 1)
    chunks.push(pad2 + "HexaVal __match_val = " + scrutinee + ";\n")

    let mut ai = 0
    while ai < len(node.arms) {
        let arm = node.arms[ai]
        let pat = arm.left
        let is_wildcard = (type_of(pat) != "string" && pat.kind == "Wildcard")

        if is_wildcard {
            // Default arm — always matches
            if ai > 0 {
                chunks.push(" else {\n")
            } else {
                chunks.push(pad2 + "{\n")
            }
        } else {
            let cond = gen2_match_cond(pat, "__match_val")
            if ai == 0 {
                chunks.push(pad2 + "if (" + cond + ") {\n")
            } else {
                chunks.push(" else if (" + cond + ") {\n")
            }
        }

        // Arm body
        let mut bi = 0
        while bi < len(arm.body) {
            chunks.push(gen2_stmt(arm.body[bi], depth + 2))
            bi = bi + 1
        }
        chunks.push(pad2 + "}")
        ai = ai + 1
    }
    chunks.push("\n" + pad + "}\n")
    return chunks.join("")
}

fn gen2_match_cond(pat, scrutinee_var) {
    if type_of(pat) == "string" {
        return "1"
    }
    let k = pat.kind
    if k == "Wildcard" {
        return "1"
    }
    if k == "IntLit" {
        return "hexa_truthy(hexa_eq(" + scrutinee_var + ", hexa_int(" + pat.value + ")))"
    }
    if k == "FloatLit" {
        return "hexa_truthy(hexa_eq(" + scrutinee_var + ", hexa_float(" + pat.value + ")))"
    }
    if k == "StringLit" {
        return "hexa_truthy(hexa_eq(" + scrutinee_var + ", hexa_str(\"" + c_escape(pat.value) + "\")))"
    }
    if k == "BoolLit" {
        if pat.value == "true" {
            return "hexa_truthy(hexa_eq(" + scrutinee_var + ", hexa_bool(1)))"
        }
        return "hexa_truthy(hexa_eq(" + scrutinee_var + ", hexa_bool(0)))"
    }
    if k == "EnumPath" {
        let enum_const = pat.name + "_" + pat.value
        return "hexa_truthy(hexa_eq(" + scrutinee_var + ", " + enum_const + "))"
    }
    // Fallback: compare with the expression
    return "hexa_truthy(hexa_eq(" + scrutinee_var + ", " + gen2_expr(pat) + "))"
}

// ═══════════════════════════════════════════════════════════
//  Match expression (value-producing) — uses ternary chain
// ═══════════════════════════════════════════════════════════

fn gen2_match_expr(node) {
    let scrutinee = gen2_expr(node.left)
    // Build a nested ternary: (cond1 ? val1 : (cond2 ? val2 : default))
    // For simplicity, wrap in a compound expression using GCC ({...})
    // Instead, just produce the ternary chain
    let arms = node.arms
    return gen2_match_ternary(arms, scrutinee, 0)
}

fn gen2_match_ternary(arms, scrutinee_c, idx) {
    if idx >= len(arms) {
        return "hexa_void()"
    }
    let arm = arms[idx]
    let pat = arm.left
    let is_wildcard = (type_of(pat) != "string" && pat.kind == "Wildcard")

    // Get the value from the arm body (last expr)
    let val = gen2_arm_value(arm.body)

    if is_wildcard || idx == len(arms) - 1 {
        if is_wildcard {
            return val
        }
        let cond = gen2_match_cond(pat, scrutinee_c)
        return "(" + cond + " ? " + val + " : hexa_void())"
    }

    let cond = gen2_match_cond(pat, scrutinee_c)
    let rest = gen2_match_ternary(arms, scrutinee_c, idx + 1)
    return "(" + cond + " ? " + val + " : " + rest + ")"
}

fn gen2_arm_value(body) {
    if type_of(body) == "string" || len(body) == 0 {
        return "hexa_void()"
    }
    // Use the last statement's expression as the value
    let last = body[len(body) - 1]
    if last.kind == "ExprStmt" {
        return gen2_expr(last.left)
    }
    if last.kind == "ReturnStmt" {
        if type_of(last.left) != "string" {
            return gen2_expr(last.left)
        }
    }
    return "hexa_void()"
}

// ═══════════════════════════════════════════════════════════
//  Lambda / closure codegen
//  Non-capturing: generate a static C function
//  Capturing: generate closure struct + function
// ═══════════════════════════════════════════════════════════

// ── Method registry for ImplBlock (P2-6 struct method dispatch) ──
// Entries are [method_name, type_name] pairs. Populated during ImplBlock
// codegen, consumed by Call-on-Field codegen to emit runtime-dispatched
// mangled calls (Type__method) guarded by hexa_is_type().
let mut _method_registry = []

fn _method_registry_lookup(name) {
    let mut out = []
    let mut i = 0
    while i < len(_method_registry) {
        let e = _method_registry[i]
        if e[0] == name {
            out.push(e[1])
        }
        i = i + 1
    }
    return out
}

// Emit one C function per impl method using mangled name Type__method.
// Returns a map with `forward` and `fn_code` strings and registers each
// method into `_method_registry`.
fn gen2_impl_block(node) {
    let type_n = node.target
    let mut fwd_chunks = []
    let mut fn_chunks = []
    let methods = node.methods
    let mut mi = 0
    while mi < len(methods) {
        let m = methods[mi]
        let mangled = type_n + "__" + m.name
        // Register method for dispatch
        _method_registry.push([m.name, type_n])
        // Build param list (self + extras)
        let mut params = []
        let mut pi = 0
        while pi < len(m.params) {
            params.push("HexaVal " + m.params[pi].name)
            pi = pi + 1
        }
        let p = params.join(", ")
        if p == "" { p = "void" }
        fwd_chunks.push("HexaVal " + mangled + "(" + p + ");\n")
        // Body
        let mut body_chunks = []
        body_chunks.push("HexaVal " + mangled + "(" + p + ") {\n")
        let mut bi = 0
        while bi < len(m.body) {
            body_chunks.push(gen2_stmt(m.body[bi], 1))
            bi = bi + 1
        }
        body_chunks.push("    return hexa_void();\n}\n\n")
        fn_chunks.push(body_chunks.join(""))
        mi = mi + 1
    }
    return #{
        "forward": fwd_chunks.join(""),
        "fn_code": fn_chunks.join("")
    }
}

let mut _lambda_counter = 0
// perf: use array accumulator — avoid O(n²) string concat for lambda defs
let mut _lambda_def_parts = []
// FIX-B (T33 aliasing follow-up, 2026-04-19): per-lambda param-signature
// slots. Was `_lambda_fwd_parts` module-array push — same T33-class freelist
// aliasing that bit `_ic_def_parts` (fcf275f4) and `_strlit_def_parts`
// (rt#32-SL) — first element / string literals occasionally eaten under
// arena reuse, producing "xa_sl_2 = hexa_str(..)" garbage lines and missing
// lambda fwd decls. Fix = counter-driven regeneration: store `p` per slot,
// emit `HexaVal __hexa_lambda_i(p);\n` in a `while i < _lambda_counter`
// loop at codegen emit time. Module-level accumulator deleted. Mirrored in
// self/native/hexa_cc.c.
let mut _lambda_fwd_sigs = []

// Normalize a lambda/fn parameter entry to the bare identifier name.
// `fn(x)` parser produces Param {name:"x", value:typ} objects; `|x|` parser
// produces bare strings. Both paths funnel into gen2_lambda_expr /
// gen2_collect_free — without normalization the Param-object branch
// stringifies as "<value>" and param names leak as "free vars" at call sites.
fn _lambda_param_name(p) {
    if type_of(p) == "string" { return p }
    return to_string(p.name)
}

// ── rt#37: Inline cache for field access ─────────────────
// Each `obj.field` emits a unique `static HexaIC __hexa_ic_N` slot and a
// `hexa_map_get_ic(obj, "field", &__hexa_ic_N)` call. The slot is zero-
// initialized; on first call it caches (keys_ptr, len, idx) and every
// subsequent monomorphic hit skips the strcmp-chain in hexa_map_get.
//
// The native-C codegen (self/native/hexa_cc.c and codegen_c2_v2.c) honors
// HEXA_IC_DISABLE=1 at codegen time for A/B benchmarking. This .hexa mirror
// is kept in sync but always emits IC — hexa_v2 is the active backend.
let mut _ic_counter = 0

// ── ComptimeConst const-fold table ───────────────────────
// `comptime const X = expr` is folded at codegen time to a literal AST node.
// Both arrays MUST be reset at the start of every codegen invocation
// (codegen_c2 / codegen_c2_full) — see T0 lesson on _ic_def_parts.
//
// _comptime_const_names: parallel array of folded const names (strings)
// _comptime_const_nodes: parallel array of folded literal nodes
//
// On Ident lookup in gen2_expr, if name appears here, the corresponding
// folded literal is inlined via recursive gen2_expr() — turning
// `comptime const TAU = 2 * 3.14` followed by `print(TAU + 1)` into
// `hexa_add(hexa_float(6.28), hexa_int(1))` at codegen time.
let mut _comptime_const_names = []
let mut _comptime_const_nodes = []

// ── M4: String literal deduplication ────────────────────
// Each unique string literal gets a single `static const char*` + cached
// HexaVal at file scope. Repeated uses reference the cached HexaVal instead
// of calling hexa_str() (which does strlen+hash+intern) every time.
// _strlit_keys: unique escaped string values (parallel with _strlit_ids)
// _strlit_ids:  C identifier suffix for each (index number)
let mut _strlit_keys = []
let mut _strlit_ids = []
// rt#32-SL: _strlit_def_parts removed — decls regenerated by _strlit_counter
// loop at emit time (mirror of fcf275f4 IC fix).
let mut _strlit_counter = 0

// Look up a comptime-const folded literal by name.
// Returns the literal node on hit, or "" (string) on miss.
fn _lookup_comptime_const(name) {
    let mut i = 0
    while i < len(_comptime_const_names) {
        if _comptime_const_names[i] == name {
            return _comptime_const_nodes[i]
        }
        i = i + 1
    }
    return ""
}

// M4: Get or register a deduplicated string literal. Returns C expression
// referencing the cached static HexaVal (e.g. "__hexa_sl_0").
// `escaped` is the already-C-escaped string content (without quotes).
fn _strlit_dedup(escaped) {
    let mut i = 0
    while i < len(_strlit_keys) {
        if _strlit_keys[i] == escaped {
            return "__hexa_sl_" + to_string(_strlit_ids[i])
        }
        i = i + 1
    }
    // New unique literal — register
    let id = _strlit_counter
    _strlit_counter = _strlit_counter + 1
    _strlit_keys.push(escaped)
    _strlit_ids.push(id)
    let varname = "__hexa_sl_" + to_string(id)
    // rt#32-SL: no push into _strlit_def_parts — decls emitted via
    // deterministic _strlit_counter loop in codegen_c2 main emit path.
    return varname
}

// Build a literal AST node for the const-fold result. We construct minimal
// nodes inline (rather than calling parser helpers) to avoid cross-module
// import dependencies.
fn _make_int_lit_node(val_str) {
    return #{
        "kind": "IntLit", "name": "", "value": val_str, "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

fn _make_float_lit_node(val_str) {
    return #{
        "kind": "FloatLit", "name": "", "value": val_str, "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

fn _make_bool_lit_node(b) {
    let v = if b { "true" } else { "false" }
    return #{
        "kind": "BoolLit", "name": "", "value": v, "op": "",
        "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
        "params": "", "body": "", "args": "", "fields": "", "items": "",
        "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
        "target": "", "trait_name": "", "methods": ""
    }
}

// Extract numeric value as float (safe for mixed int/float arithmetic).
fn _cf_as_float(lit) {
    if lit.kind == "FloatLit" { return to_float(lit.value) }
    return to_float(to_string(to_int(lit.value)))
}

// Compile-time evaluator. Returns a literal AST node on success
// (kind ∈ {IntLit, FloatLit, StringLit, BoolLit}), or "" (string) on failure.
//
// Supported folds:
//   - terminal literals: IntLit, FloatLit, StringLit, BoolLit (returned as-is)
//   - Ident → looked up in comptime-const table (inlines folded value)
//   - UnaryOp("-", const) → negation (int/float)
//   - UnaryOp("!", BoolLit) → logical not
//   - BinOp(+, -, *, /, %) on numeric literals → arithmetic (int+int → int,
//     either side float → float; / and % only int)
//   - BinOp(==, !=, <, >, <=, >=) on numeric/string/bool literals → BoolLit
//   - BinOp(&&, ||) with short-circuit on bool literals
//   - IfExpr(BoolLit cond) → evaluates chosen branch at comptime
//   - Call(abs|min|max|sqrt|floor|ceil) with literal args → numeric literal
// All other expressions return "" — caller falls back to runtime emission.
fn comptime_eval(node) {
    if type_of(node) == "string" { return "" }
    let k = node.kind
    if k == "IntLit" { return node }
    if k == "FloatLit" { return node }
    if k == "StringLit" { return node }
    if k == "BoolLit" { return node }
    if k == "Ident" {
        return _lookup_comptime_const(node.name)
    }
    if k == "UnaryOp" {
        let op = node.op
        let v = comptime_eval(node.left)
        if type_of(v) == "string" { return "" }
        if op == "-" {
            if v.kind == "IntLit" {
                let i = -to_int(v.value)
                return _make_int_lit_node(to_string(i))
            }
            if v.kind == "FloatLit" {
                let f = -to_float(v.value)
                return _make_float_lit_node(to_string(f))
            }
            return ""
        }
        if op == "!" {
            if v.kind == "BoolLit" {
                return _make_bool_lit_node(v.value != "true")
            }
            return ""
        }
        return ""
    }
    if k == "BinOp" {
        let op = node.op
        // Short-circuit logical operators — evaluate LHS first.
        if op == "&&" {
            let ll = comptime_eval(node.left)
            if type_of(ll) == "string" { return "" }
            if ll.kind != "BoolLit" { return "" }
            if ll.value != "true" { return _make_bool_lit_node(false) }
            let rr = comptime_eval(node.right)
            if type_of(rr) == "string" { return "" }
            if rr.kind != "BoolLit" { return "" }
            return _make_bool_lit_node(rr.value == "true")
        }
        if op == "||" {
            let ll = comptime_eval(node.left)
            if type_of(ll) == "string" { return "" }
            if ll.kind != "BoolLit" { return "" }
            if ll.value == "true" { return _make_bool_lit_node(true) }
            let rr = comptime_eval(node.right)
            if type_of(rr) == "string" { return "" }
            if rr.kind != "BoolLit" { return "" }
            return _make_bool_lit_node(rr.value == "true")
        }
        let l = comptime_eval(node.left)
        if type_of(l) == "string" { return "" }
        let r = comptime_eval(node.right)
        if type_of(r) == "string" { return "" }
        let lk = l.kind
        let rk = r.kind
        // Comparison operators: fold when operands agree in category.
        if op == "==" || op == "!=" || op == "<" || op == ">" || op == "<=" || op == ">=" {
            // String comparison (== / != only — lexicographic folds skipped
            // because hexa's int comparison on strings is not guaranteed).
            if lk == "StringLit" && rk == "StringLit" {
                if op == "==" { return _make_bool_lit_node(l.value == r.value) }
                if op == "!=" { return _make_bool_lit_node(l.value != r.value) }
                return ""
            }
            if lk == "BoolLit" && rk == "BoolLit" {
                if op == "==" { return _make_bool_lit_node(l.value == r.value) }
                if op == "!=" { return _make_bool_lit_node(l.value != r.value) }
                return ""
            }
            let l_num = lk == "IntLit" || lk == "FloatLit"
            let r_num = rk == "IntLit" || rk == "FloatLit"
            if !l_num || !r_num { return "" }
            // Mixed int/float → compare as float.
            let mixed = lk == "FloatLit" || rk == "FloatLit"
            if mixed {
                let lf = _cf_as_float(l)
                let rf = _cf_as_float(r)
                if op == "==" { return _make_bool_lit_node(lf == rf) }
                if op == "!=" { return _make_bool_lit_node(lf != rf) }
                if op == "<"  { return _make_bool_lit_node(lf < rf) }
                if op == ">"  { return _make_bool_lit_node(lf > rf) }
                if op == "<=" { return _make_bool_lit_node(lf <= rf) }
                if op == ">=" { return _make_bool_lit_node(lf >= rf) }
                return ""
            }
            let li_c = to_int(l.value)
            let ri_c = to_int(r.value)
            if op == "==" { return _make_bool_lit_node(li_c == ri_c) }
            if op == "!=" { return _make_bool_lit_node(li_c != ri_c) }
            if op == "<"  { return _make_bool_lit_node(li_c < ri_c) }
            if op == ">"  { return _make_bool_lit_node(li_c > ri_c) }
            if op == "<=" { return _make_bool_lit_node(li_c <= ri_c) }
            if op == ">=" { return _make_bool_lit_node(li_c >= ri_c) }
            return ""
        }
        // String concat via +.
        if op == "+" && lk == "StringLit" && rk == "StringLit" {
            return #{
                "kind": "StringLit", "name": "", "value": l.value + r.value, "op": "",
                "left": "", "right": "", "cond": "", "then_body": "", "else_body": "",
                "params": "", "body": "", "args": "", "fields": "", "items": "",
                "variants": "", "arms": "", "iter_expr": "", "ret_type": "",
                "target": "", "trait_name": "", "methods": ""
            }
        }
        // Only numeric operands fold for arithmetic below.
        if lk != "IntLit" && lk != "FloatLit" { return "" }
        if rk != "IntLit" && rk != "FloatLit" { return "" }
        let is_float = lk == "FloatLit" || rk == "FloatLit"
        if is_float {
            // Float arithmetic: + - * / supported, % not.
            let lf = _cf_as_float(l)
            let rf = _cf_as_float(r)
            if op == "+" { return _make_float_lit_node(to_string(lf + rf)) }
            if op == "-" { return _make_float_lit_node(to_string(lf - rf)) }
            if op == "*" { return _make_float_lit_node(to_string(lf * rf)) }
            if op == "/" {
                if rf == 0.0 { return "" }
                return _make_float_lit_node(to_string(lf / rf))
            }
            return ""
        }
        // Pure int arithmetic.
        let li = to_int(l.value)
        let ri = to_int(r.value)
        if op == "+" { return _make_int_lit_node(to_string(li + ri)) }
        if op == "-" { return _make_int_lit_node(to_string(li - ri)) }
        if op == "*" { return _make_int_lit_node(to_string(li * ri)) }
        if op == "/" {
            if ri == 0 { return "" }
            return _make_int_lit_node(to_string(li / ri))
        }
        if op == "%" {
            if ri == 0 { return "" }
            return _make_int_lit_node(to_string(li % ri))
        }
        // G40: bitwise comptime fold — & | ^ only (no native << >> in host)
        if op == "&" { return _make_int_lit_node(to_string(li & ri)) }
        if op == "|" { return _make_int_lit_node(to_string((li + ri) - (li & ri))) }
        if op == "^" { return _make_int_lit_node(to_string(li ^ ri)) }
        return ""
    }
    // IfExpr with a comptime-foldable condition → fold to chosen branch value.
    // Branches are stmt arrays; we only extract the last ExprStmt's expr,
    // matching codegen's runtime IfExpr shape. Silent-skip on mismatch.
    if k == "IfExpr" {
        let c = comptime_eval(node.cond)
        if type_of(c) == "string" { return "" }
        if c.kind != "BoolLit" { return "" }
        let pick_true = c.value == "true"
        let body = if pick_true { node.then_body } else { node.else_body }
        if type_of(body) == "string" { return "" }
        if len(body) == 0 { return "" }
        let last = body[len(body) - 1]
        if type_of(last) == "string" { return "" }
        if last.kind != "ExprStmt" { return "" }
        if type_of(last.left) == "string" { return "" }
        return comptime_eval(last.left)
    }
    // Call(name, args) — fold a small whitelist of pure builtins.
    if k == "Call" {
        let fname = node.name
        if type_of(node.args) == "string" { return "" }
        let nargs = len(node.args)
        // Single-arg numeric builtins.
        if nargs == 1 {
            let a = comptime_eval(node.args[0])
            if type_of(a) == "string" { return "" }
            let ak = a.kind
            if ak != "IntLit" && ak != "FloatLit" { return "" }
            if fname == "abs" {
                if ak == "IntLit" {
                    let iv = to_int(a.value)
                    let ar = if iv < 0 { -iv } else { iv }
                    return _make_int_lit_node(to_string(ar))
                }
                // Float abs — emit float literal; negative sign handled via subtract.
                let fv = to_float(a.value)
                let fr = if fv < 0.0 { 0.0 - fv } else { fv }
                return _make_float_lit_node(to_string(fr))
            }
            if fname == "sqrt" {
                // sqrt of negatives undefined → silent skip.
                let fv2 = _cf_as_float(a)
                if fv2 < 0.0 { return "" }
                // Hexa has no native sqrt folder; skip unless input is a
                // perfect small square. This keeps us conservative.
                if ak == "IntLit" {
                    let iv2 = to_int(a.value)
                    // Check up to 10_000² for exact int squares.
                    let mut s = 0
                    while s * s < iv2 && s < 10000 { s = s + 1 }
                    if s * s == iv2 {
                        // Still emit as float per runtime contract (hexa_sqrt → float).
                        return _make_float_lit_node(to_string(to_float(to_string(s))))
                    }
                    return ""
                }
                return ""
            }
            if fname == "floor" || fname == "ceil" {
                // runtime returns Int. For int input, identity; for float, fold.
                if ak == "IntLit" { return _make_int_lit_node(a.value) }
                // FloatLit → skip (no int-cast builtin in this evaluator;
                // conservative to avoid platform-dependent rounding).
                return ""
            }
            return ""
        }
        // Two-arg numeric builtins: min / max.
        if nargs == 2 && (fname == "min" || fname == "max") {
            let a1 = comptime_eval(node.args[0])
            if type_of(a1) == "string" { return "" }
            let a2 = comptime_eval(node.args[1])
            if type_of(a2) == "string" { return "" }
            let k1 = a1.kind
            let k2 = a2.kind
            let n1 = k1 == "IntLit" || k1 == "FloatLit"
            let n2 = k2 == "IntLit" || k2 == "FloatLit"
            if !n1 || !n2 { return "" }
            // Int-int preserves int; otherwise float.
            if k1 == "IntLit" && k2 == "IntLit" {
                let v1 = to_int(a1.value)
                let v2 = to_int(a2.value)
                let pick = if fname == "min" { v1 < v2 } else { v1 > v2 }
                let out = if pick { v1 } else { v2 }
                return _make_int_lit_node(to_string(out))
            }
            let f1 = _cf_as_float(a1)
            let f2 = _cf_as_float(a2)
            let pickf = if fname == "min" { f1 < f2 } else { f1 > f2 }
            let outf = if pickf { f1 } else { f2 }
            return _make_float_lit_node(to_string(outf))
        }
        return ""
    }
    return ""
}

// Register a comptime-const folded literal in the lookup table.
// `value_node` is the folded literal returned by comptime_eval.
fn _register_comptime_const(name, value_node) {
    _comptime_const_names.push(name)
    _comptime_const_nodes.push(value_node)
}

// ── C3: Closure capture support ──────────────────────────
// `_known_fn_globals`: names callable as direct C functions (FnDecl, extern,
//   pure fn, struct constructors). Call-by-name uses direct C call for these.
// `_known_nonlocal_names`: superset — also top-level lets, enums, comptime.
//   Free-variable analysis excludes these names from capture (they're
//   referenced by C name, not by closure env).
let mut _known_fn_globals = []
let mut _known_nonlocal_names = []

// ── ROI-23: 64-bucket hash sets for O(1) avg lookup ─────────
// Same pattern as interpreter.hexa env_cache / memo_cache.
let mut _known_fn_globals_set = []   // 64 buckets; each bucket is [name, ...]
let mut _known_nonlocal_set = []     // 64 buckets; each bucket is [name, ...]

// ── STRUCTURAL-2 Phase B: known-int type propagation ────────
// Immutable `let` variables whose initializer is IntLit or int-only BinOp
// are tracked here. gen2_expr BinOp uses this to bypass hexa_add/sub/mul/
// div/mod boxing and emit direct `.i` arithmetic.
// Excludes: mut variables (re-assignable), fn params (caller may pass float).
let mut _known_int_set = []          // 64 buckets; each bucket is [name, ...]

// ── STRUCTURAL-3: known-float type propagation ──────────────
// Parallel to known-int: immutable `let` with FloatLit or float-only BinOp
// initializers. gen2_expr BinOp uses this to emit direct `double` arithmetic
// via `hexa_float(HX_FLOAT(L) OP HX_FLOAT(R))`, bypassing hexa_add/sub/mul/
// div runtime tag dispatch. Critical for training loops (99% float ops).
let mut _known_float_set = []        // 64 buckets; each bucket is [name, ...]

fn _known_hash(key) {
    let mut h = 0
    let mut ci = 0
    let n = len(key)
    while ci < n {
        h = (h * 31 + char_code(key, ci)) % 64
        ci = ci + 1
    }
    let mut b = h
    while b < 0 { b = b + 64 }
    return b % 64
}

fn _known_set_init() {
    let mut fg = []
    let mut nl = []
    let mut i = 0
    while i < 64 {
        fg.push([])
        nl.push([])
        i = i + 1
    }
    _known_fn_globals_set = fg
    _known_nonlocal_set = nl
    // STRUCTURAL-2 Phase B: reset known-int set alongside other sets
    _known_int_set_init()
    // STRUCTURAL-3: reset known-float set alongside other sets
    _known_float_set_init()
}

fn _known_fn_globals_add(name) {
    let b = _known_hash(name)
    _known_fn_globals_set[b] = _known_fn_globals_set[b].push(name)
}

fn _known_nonlocal_add(name) {
    let b = _known_hash(name)
    _known_nonlocal_set[b] = _known_nonlocal_set[b].push(name)
}

fn _is_known_fn_global(name) {
    if len(_known_fn_globals_set) != 64 { return false }
    let b = _known_hash(name)
    let bucket = _known_fn_globals_set[b]
    let mut i = 0
    while i < len(bucket) {
        if bucket[i] == name { return true }
        i = i + 1
    }
    return false
}

fn _is_known_nonlocal(name) {
    if len(_known_nonlocal_set) != 64 { return false }
    let b = _known_hash(name)
    let bucket = _known_nonlocal_set[b]
    let mut i = 0
    while i < len(bucket) {
        if bucket[i] == name { return true }
        i = i + 1
    }
    return false
}

// Back-compat alias used below in free-var analysis.
fn _is_known_global(name) { return _is_known_nonlocal(name) }

// ── STRUCTURAL-2 Phase B: known-int set helpers ─────────────
fn _known_int_set_init() {
    let mut ki = []
    let mut i = 0
    while i < 64 {
        ki.push([])
        i = i + 1
    }
    _known_int_set = ki
}

// ── STRUCTURAL-3: known-float set helpers (parallel to int set) ──
fn _known_float_set_init() {
    let mut kf = []
    let mut i = 0
    while i < 64 {
        kf.push([])
        i = i + 1
    }
    _known_float_set = kf
}

fn _known_float_add(name) {
    let b = _known_hash(name)
    _known_float_set[b] = _known_float_set[b].push(name)
}

fn _is_known_float_name(name) {
    if len(_known_float_set) != 64 { return false }
    let b = _known_hash(name)
    let bucket = _known_float_set[b]
    let mut i = 0
    while i < len(bucket) {
        if bucket[i] == name { return true }
        i = i + 1
    }
    return false
}

fn _known_int_add(name) {
    let b = _known_hash(name)
    _known_int_set[b] = _known_int_set[b].push(name)
}

fn _is_known_int_name(name) {
    if len(_known_int_set) != 64 { return false }
    let b = _known_hash(name)
    let bucket = _known_int_set[b]
    let mut i = 0
    while i < len(bucket) {
        if bucket[i] == name { return true }
        i = i + 1
    }
    return false
}

// Check if an AST node is provably TAG_INT at codegen time:
//   - IntLit → always int
//   - Ident in _known_int_set → immutable let with int initializer
fn _is_known_int(node) {
    if type_of(node) == "string" { return false }
    if node.kind == "IntLit" { return true }
    if node.kind == "Ident" { return _is_known_int_name(node.name) }
    return false
}

// Check if an initializer expression is int-only (for LetStmt registration).
// Covers: IntLit, int BinOp (recursive), Ident that is already known-int,
// UnaryOp - on int.
fn _is_int_init_expr(node) {
    if type_of(node) == "string" { return false }
    let k = node.kind
    if k == "IntLit" { return true }
    if k == "Ident" { return _is_known_int_name(node.name) }
    if k == "BinOp" {
        let op = node.op
        if op == "+" || op == "-" || op == "*" || op == "/" || op == "%" {
            return _is_int_init_expr(node.left) && _is_int_init_expr(node.right)
        }
        return false
    }
    if k == "UnaryOp" {
        if node.op == "-" { return _is_int_init_expr(node.left) }
        return false
    }
    return false
}

// Check if an AST node is provably TAG_FLOAT at codegen time:
//   - FloatLit → always float
//   - Ident in _known_float_set → immutable let with float initializer
fn _is_known_float(node) {
    if type_of(node) == "string" { return false }
    if node.kind == "FloatLit" { return true }
    if node.kind == "Ident" { return _is_known_float_name(node.name) }
    return false
}

// Check if an initializer expression is float-only (for LetStmt registration).
// Covers: FloatLit, float BinOp (recursive), Ident that is already known-float,
// UnaryOp - on float. Mixed int+float promotes to float (C semantics).
fn _is_float_init_expr(node) {
    if type_of(node) == "string" { return false }
    let k = node.kind
    if k == "FloatLit" { return true }
    if k == "Ident" { return _is_known_float_name(node.name) }
    if k == "BinOp" {
        let op = node.op
        if op == "+" || op == "-" || op == "*" || op == "/" || op == "%" {
            let lf = _is_float_init_expr(node.left)
            let rf = _is_float_init_expr(node.right)
            if lf && rf { return true }
            if lf && _is_int_init_expr(node.right) { return true }
            if rf && _is_int_init_expr(node.left) { return true }
        }
        return false
    }
    if k == "UnaryOp" {
        if node.op == "-" { return _is_float_init_expr(node.left) }
        return false
    }
    return false
}

// C2: Emit a C boolean expression for a while-loop condition.
// For comparison ops (< > <= >= == !=), avoids hexa_truthy(hexa_cmp_*())
// double-dispatch.  When both operands are known-int, emits raw C comparison
// on HX_INT() directly (zero runtime overhead).  For && / || / !, recurses.
// Falls back to hexa_truthy(gen2_expr(...)) for anything else.
fn _gen2_while_cond(node) {
    if type_of(node) == "string" { return "hexa_truthy(" + gen2_expr(node) + ")" }
    let k = node.kind
    if k == "BinOp" {
        let op = node.op
        // Ordered comparisons
        if op == "<" || op == ">" || op == "<=" || op == ">=" {
            let li = _is_known_int(node.left)
            let ri = _is_known_int(node.right)
            if li && ri {
                // Both operands provably TAG_INT — raw C compare, no runtime call
                let l = gen2_expr(node.left)
                let r = gen2_expr(node.right)
                return "(HX_INT(" + l + ") " + op + " HX_INT(" + r + "))"
            }
            // STRUCTURAL-3: known-float comparison in while-cond
            let lf = _is_known_float(node.left)
            let rf = _is_known_float(node.right)
            if lf && rf {
                let l = gen2_expr(node.left)
                let r = gen2_expr(node.right)
                return "(HX_FLOAT(" + l + ") " + op + " HX_FLOAT(" + r + "))"
            }
            // General case — hexa_cmp_* returns hexa_bool(); extract .b directly
            let l = gen2_expr(node.left)
            let r = gen2_expr(node.right)
            if op == "<" { return "HX_BOOL(hexa_cmp_lt(" + l + ", " + r + "))" }
            if op == ">" { return "HX_BOOL(hexa_cmp_gt(" + l + ", " + r + "))" }
            if op == "<=" { return "HX_BOOL(hexa_cmp_le(" + l + ", " + r + "))" }
            return "HX_BOOL(hexa_cmp_ge(" + l + ", " + r + "))"
        }
        // Equality
        if op == "==" {
            let li = _is_known_int(node.left)
            let ri = _is_known_int(node.right)
            if li && ri {
                let l = gen2_expr(node.left)
                let r = gen2_expr(node.right)
                return "(HX_INT(" + l + ") == HX_INT(" + r + "))"
            }
            // STRUCTURAL-3: known-float equality in while-cond
            let lf = _is_known_float(node.left)
            let rf = _is_known_float(node.right)
            if lf && rf {
                let l = gen2_expr(node.left)
                let r = gen2_expr(node.right)
                return "(HX_FLOAT(" + l + ") == HX_FLOAT(" + r + "))"
            }
            return "hexa_truthy(hexa_eq(" + gen2_expr(node.left) + ", " + gen2_expr(node.right) + "))"
        }
        if op == "!=" {
            let li = _is_known_int(node.left)
            let ri = _is_known_int(node.right)
            if li && ri {
                let l = gen2_expr(node.left)
                let r = gen2_expr(node.right)
                return "(HX_INT(" + l + ") != HX_INT(" + r + "))"
            }
            // STRUCTURAL-3: known-float inequality in while-cond
            let lf = _is_known_float(node.left)
            let rf = _is_known_float(node.right)
            if lf && rf {
                let l = gen2_expr(node.left)
                let r = gen2_expr(node.right)
                return "(HX_FLOAT(" + l + ") != HX_FLOAT(" + r + "))"
            }
            return "(!hexa_truthy(hexa_eq(" + gen2_expr(node.left) + ", " + gen2_expr(node.right) + ")))"
        }
        // Logical connectives — recurse into sub-conditions
        if op == "&&" {
            return "(" + _gen2_while_cond(node.left) + " && " + _gen2_while_cond(node.right) + ")"
        }
        if op == "||" {
            return "(" + _gen2_while_cond(node.left) + " || " + _gen2_while_cond(node.right) + ")"
        }
    }
    if k == "UnaryOp" {
        if node.op == "!" {
            return "(!" + _gen2_while_cond(node.left) + ")"
        }
    }
    // Fallback: general expression — use hexa_truthy as before
    return "hexa_truthy(" + gen2_expr(node) + ")"
}

// Builtin names that are never captured (resolved at codegen in gen2_expr Call).
fn _is_builtin_name(name) {
    if name == "println" { return true }
    if name == "print" { return true }
    if name == "eprintln" { return true }
    if name == "eprint" { return true }
    if name == "len" { return true }
    if name == "to_string" { return true }
    if name == "type_of" { return true }
    if name == "split" { return true }
    if name == "sqrt" { return true }
    if name == "floor" { return true }
    if name == "ceil" { return true }
    if name == "abs" { return true }
    if name == "round" { return true }
    if name == "ln" { return true }
    if name == "log" { return true }
    if name == "log10" { return true }
    if name == "exp" { return true }
    if name == "sin" { return true }
    if name == "cos" { return true }
    if name == "pow" { return true }
    if name == "to_float" { return true }
    if name == "to_int" { return true }
    if name == "min" { return true }
    if name == "max" { return true }
    if name == "format" { return true }
    if name == "args" { return true }
    if name == "argv" { return true }
    if name == "real_args" { return true }
    if name == "script_path" { return true }
    if name == "exec" { return true }
    if name == "exec_with_status" { return true }
    if name == "read_file" { return true }
    if name == "write_file" { return true }
    if name == "write_bytes" { return true }
    if name == "write_bytes_v" { return true }
    if name == "read_file_bytes" { return true }
    // P4-stream builtins (pread / append / native file_size).
    if name == "read_bytes_at" { return true }
    if name == "write_bytes_append" { return true }
    if name == "write_bytes_append_v" { return true }
    if name == "file_size_native" { return true }
    if name == "net_listen" { return true }
    if name == "net_accept" { return true }
    if name == "net_close" { return true }
    if name == "net_connect" { return true }
    if name == "net_read" { return true }
    if name == "net_read_n" { return true }
    if name == "net_set_timeout" { return true }
    if name == "net_write" { return true }
    if name == "file_exists" { return true }
    if name == "is_alpha" { return true }
    if name == "is_digit" { return true }
    if name == "is_alphanumeric" { return true }
    // FIX-A (Anima serving unblock, 2026-04-18)
    if name == "time_ms" { return true }
    if name == "byte_len" { return true }
    if name == "dict_keys" { return true }
    // FIX-A (Anima serving unblock, 2026-04-19)
    if name == "append" { return true }
    if name == "u_floor" { return true }
    // FIX-A (Anima ML eval unblock, 2026-04-19): 8 tensor/ML fallback builtins.
    if name == "tensor_zeros" { return true }
    if name == "tensor_slice" { return true }
    if name == "tensor_add" { return true }
    if name == "tensor_dot" { return true }
    if name == "tensor_mul_scalar" { return true }
    if name == "rms_norm" { return true }
    if name == "softmax" { return true }
    if name == "matmul" { return true }
    // FIX-A 2nd batch (2026-04-19): tensor_ones + swiglu_vec
    if name == "tensor_ones" { return true }
    if name == "swiglu_vec" { return true }
    // FIX-A (Anima stdlib unblock, 2026-04-19): 10 cross-project builtins
    if name == "read_stdin" { return true }
    if name == "sleep_s" { return true }
    if name == "now_monotonic_s" { return true }
    if name == "mono_ns" { return true }
    if name == "utc_iso_now" { return true }
    if name == "utc_compact_now" { return true }
    if name == "to_bool" { return true }
    if name == "http_get" { return true }
    if name == "json_parse" { return true }
    if name == "json_decode" { return true }
    if name == "json_stringify" { return true }
    if name == "json_encode" { return true }
    if name == "true" { return true }
    if name == "false" { return true }
    return false
}

// Append `name` to `list` if not already present.
fn _add_unique(list, name) {
    let mut i = 0
    while i < len(list) {
        if list[i] == name { return list }
        i = i + 1
    }
    return list.push(name)
}

// Walk an AST node/array and collect free-variable names.
// `bound` is a list of identifier names currently in scope (params + locals).
// Returns an array of free-variable names (unique, order-preserved).
fn gen2_collect_free(node, bound, out) {
    if type_of(node) == "string" { return out }
    if type_of(node) == "array" {
        // Statement / body list — local bindings extend `bound` as we go.
        let mut local = bound
        let mut result = out
        let mut i = 0
        while i < len(node) {
            let s = node[i]
            if type_of(s) != "string" {
                let sk = s.kind
                if sk == "LetStmt" || sk == "LetMutStmt" {
                    // RHS evaluated under current `local` (name not yet bound).
                    if type_of(s.left) != "string" {
                        result = gen2_collect_free(s.left, local, result)
                    }
                    local.push(s.name)
                } else if sk == "ForStmt" || sk == "ForInStmt" {
                    if type_of(s.left) != "string" {
                        result = gen2_collect_free(s.left, local, result)
                    }
                    let body_local = local.push(s.name)
                    if type_of(s.body) == "array" {
                        result = gen2_collect_free(s.body, body_local, result)
                    }
                } else if sk == "ForDestructStmt" {
                    // G43: iter_expr is free, destruct names are bound in body
                    if type_of(s.iter_expr) != "string" {
                        result = gen2_collect_free(s.iter_expr, local, result)
                    }
                    let mut fd_local = local
                    if type_of(s.params) == "array" {
                        let mut _fdi = 0
                        while _fdi < len(s.params) {
                            fd_local.push(s.params[_fdi])
                            _fdi = _fdi + 1
                        }
                    }
                    if type_of(s.body) == "array" {
                        result = gen2_collect_free(s.body, fd_local, result)
                    }
                } else {
                    result = gen2_collect_free(s, local, result)
                }
            }
            i = i + 1
        }
        return result
    }

    let k = node.kind
    if k == "IntLit" || k == "FloatLit" || k == "StringLit" || k == "BoolLit" || k == "CharLit" || k == "Wildcard" {
        return out
    }
    if k == "Ident" {
        let name = node.name
        if _is_known_global(name) { return out }
        if _is_builtin_name(name) { return out }
        // Bound?
        let mut bi = 0
        while bi < len(bound) {
            if bound[bi] == name { return out }
            bi = bi + 1
        }
        return _add_unique(out, name)
    }
    if k == "Lambda" {
        // Nested lambda: its params shadow, but its free vars in the current
        // scope are also free in the enclosing scope (unless bound here).
        // FIX-A (2026-04-19): normalize param entries (Param obj or string).
        let mut inner_bound = bound
        let mut pi = 0
        while pi < len(node.params) {
            inner_bound.push(_lambda_param_name(node.params[pi]))
            pi = pi + 1
        }
        return gen2_collect_free(node.left, inner_bound, out)
    }

    // Generic recursion — cover common fields.
    let mut result = out
    if type_of(node.left) != "string" {
        result = gen2_collect_free(node.left, bound, result)
    }
    if type_of(node.right) != "string" {
        result = gen2_collect_free(node.right, bound, result)
    }
    if type_of(node.cond) != "string" {
        result = gen2_collect_free(node.cond, bound, result)
    }
    if type_of(node.then_body) != "string" {
        result = gen2_collect_free(node.then_body, bound, result)
    }
    if type_of(node.else_body) != "string" {
        result = gen2_collect_free(node.else_body, bound, result)
    }
    if type_of(node.body) != "string" {
        result = gen2_collect_free(node.body, bound, result)
    }
    if type_of(node.args) == "array" {
        let mut ai = 0
        while ai < len(node.args) {
            result = gen2_collect_free(node.args[ai], bound, result)
            ai = ai + 1
        }
    }
    if type_of(node.items) == "array" {
        let mut ii = 0
        while ii < len(node.items) {
            result = gen2_collect_free(node.items[ii], bound, result)
            ii = ii + 1
        }
    }
    if type_of(node.arms) == "array" {
        let mut mi = 0
        while mi < len(node.arms) {
            let arm = node.arms[mi]
            if type_of(arm.body) == "array" {
                result = gen2_collect_free(arm.body, bound, result)
            }
            mi = mi + 1
        }
    }
    // Call target: if Ident and not builtin/global, it's a free reference too.
    // (handled via node.left above when callee is stored there)
    return result
}

fn gen2_lambda_expr(node) {
    let id = _lambda_counter
    _lambda_counter = _lambda_counter + 1
    let fn_name = "__hexa_lambda_" + to_string(id)

    // ── Free variable analysis ───────────────────────────
    // `bound` starts with the lambda's own params.
    // FIX-A (2026-04-19): `fn(x){}` parser emits Param objects with .name,
    // `|x|` parser emits bare strings — normalize here so free-var compare
    // against Ident names actually matches (and param doesn't leak as free).
    let mut bound = []
    let mut pi = 0
    while pi < len(node.params) {
        bound.push(_lambda_param_name(node.params[pi]))
        pi = pi + 1
    }
    let free_vars = gen2_collect_free(node.left, bound, [])
    let arity = len(node.params)

    // Build parameter list. All lambdas take __env as first param (even
    // non-capturing ones) so the runtime hexa_callN dispatch ABI is uniform.
    let mut params = []
    params.push("HexaVal __env")
    pi = 0
    while pi < len(node.params) {
        params.push("HexaVal " + _lambda_param_name(node.params[pi]))
        pi = pi + 1
    }
    let p = params.join(", ")
    if p == "" { p = "void" }

    // Emit env unpack prologue.
    let mut body_parts = []
    if len(free_vars) > 0 {
        let mut fi = 0
        while fi < len(free_vars) {
            body_parts.push("    HexaVal " + free_vars[fi] + " = hexa_array_get(__env, " + to_string(fi) + ");\n")
            fi = fi + 1
        }
    }

    // Build function body — perf: chunks.push + join — avoid O(n²) string concat
    let lbody = node.left
    if type_of(lbody) != "string" {
        if type_of(lbody) == "array" {
            // Block body
            let mut bi = 0
            while bi < len(lbody) {
                body_parts.push(gen2_stmt(lbody[bi], 1))
                bi = bi + 1
            }
        } else {
            // Single expression body — return it
            body_parts.push("    return " + gen2_expr(lbody) + ";\n")
        }
    }

    // Emit the function definition (placed before main)
    // FIX-B (2026-04-19): store param-sig in per-slot array; fwd decls emitted
    // deterministically in a `while i < _lambda_counter` loop at codegen emit
    // time (mirror of fcf275f4 IC fix, rt#32-SL strlit fix). Pushing the full
    // decl string here triggered T33-class freelist aliasing — first element
    // eaten, strings truncated in output C. Slot index == `id`.
    _lambda_fwd_sigs.push(p)
    // FIX-C (2026-04-19): route fn_def through a local array + .join("")
    // instead of chained `+` concats. `hexa_str_concat` arena-allocates under
    // HEXA_VAL_ARENA (default ON); when gen2_lambda_expr returns via
    // __hexa_fn_arena_return, the arena scope pops and the arena-backed
    // fn_def stored inside module-level _lambda_def_parts becomes dangling,
    // letting later allocations stomp lambda bodies — producing fragments
    // like `tr("exaVal __hexa_sl_6;` / `exaVal __hexa_sl_4;` in emitted C
    // (repro: train_v14.hexa). `hexa_str_join` uses `malloc` directly
    // (runtime.c:3293) so the joined result escapes the arena and survives
    // the scope pop. Complements c461f60a (_lambda_fwd_sigs counter-driven
    // regen): here the payload is too large to regenerate from captured
    // state because body emission has side effects on
    // _lambda_counter/_ic_counter/_strlit_counter (nested lambdas, IC slots,
    // string literals) that must not re-run.
    let mut _fn_def_parts = []
    _fn_def_parts.push("HexaVal ")
    _fn_def_parts.push(fn_name)
    _fn_def_parts.push("(")
    _fn_def_parts.push(p)
    _fn_def_parts.push(") {\n")
    let mut _bpi = 0
    while _bpi < len(body_parts) {
        _fn_def_parts.push(body_parts[_bpi])
        _bpi = _bpi + 1
    }
    _fn_def_parts.push("    return hexa_void();\n}\n\n")
    let fn_def = _fn_def_parts.join("")
    _lambda_def_parts.push(fn_def)

    // Construct the closure value at the callsite.
    if len(free_vars) == 0 {
        // Non-capturing: still emit as TAG_CLOSURE for uniform call dispatch,
        // with an empty env.
        return "hexa_closure_new((void*)&" + fn_name + ", " + to_string(arity) + ", hexa_array_new())"
    }
    // Capturing: build env array of current values in free_vars order.
    let mut env_expr = "hexa_array_new()"
    let mut fi = 0
    while fi < len(free_vars) {
        env_expr = "hexa_array_push(" + env_expr + ", " + free_vars[fi] + ")"
        fi = fi + 1
    }
    return "hexa_closure_new((void*)&" + fn_name + ", " + to_string(arity) + ", " + env_expr + ")"
}

// Override codegen_c2 to include lambda definitions
fn codegen_c2_full(ast) {
    _lambda_counter = 0
    _lambda_def_parts = []
    _lambda_fwd_sigs = []
    _method_registry = []
    _known_fn_globals = []
    _known_nonlocal_names = []
    _known_set_init()
    _ic_counter = 0
    // rt#32-SL: string literal dedup table reset — mirror codegen_c2's reset.
    _strlit_keys = []
    _strlit_ids = []
    _strlit_counter = 0
    // 2026-04-18 use-resolver dedup table — mirror codegen_c2's reset.
    _resolved_modules = []
    _resolve_caller_dir_inited = false
    _resolve_caller_dir = ""
    // ComptimeConst const-fold table — T0 lesson: must reset in BOTH
    // codegen_c2 and codegen_c2_full to avoid stale fold from prior call.
    _comptime_const_names = []
    _comptime_const_nodes = []

    // ── Pass 0: collect known global names for closure free-var analysis ──
    let mut gi = 0
    while gi < len(ast) {
        let gk = ast[gi].kind
        if gk == "FnDecl" || gk == "ExternFnDecl" || gk == "PureFnDecl" || gk == "OptimizeFnStmt" {
            _known_fn_globals.push(ast[gi].name)
            _known_nonlocal_names.push(ast[gi].name)
            _known_fn_globals_add(ast[gi].name)
            _known_nonlocal_add(ast[gi].name)
        } else if gk == "StructDecl" {
            _known_fn_globals.push(ast[gi].name)
            _known_nonlocal_names.push(ast[gi].name)
            _known_fn_globals_add(ast[gi].name)
            _known_nonlocal_add(ast[gi].name)
        } else if gk == "EnumDecl" {
            _known_nonlocal_names.push(ast[gi].name)
            _known_nonlocal_add(ast[gi].name)
        } else if gk == "ComptimeConst" || gk == "ConstStmt" {
            // Comptime constants fold at codegen — treat as non-capturable name
            _known_nonlocal_names.push(ast[gi].name)
            _known_nonlocal_add(ast[gi].name)
        } else if gk == "LetMutStmt" || gk == "LetStmt" {
            _known_nonlocal_names.push(ast[gi].name)
            _known_nonlocal_add(ast[gi].name)
        } else if gk == "ImportStmt" || gk == "UseStmt" {
            // 2026-04-18: pre-register imported fn/struct names — mirror
            // codegen_c2 Pass-0 addition. Emit pass later produces extern decls.
            _resolve_use_register_names(ast[gi].name)
        }
        gi = gi + 1
    }

    // Collect sections as arrays, join at end (avoid O(n²) concat)
    let mut fwd_parts = []
    let mut global_parts = []
    let mut fn_parts = []
    // init_parts: global variable initialization only (LetMutStmt, LetStmt,
    // ComptimeConst, ExternFnDecl dlopen). Kept in sync with codegen_c2.
    let mut init_parts = []
    // main_parts: module-level expression statements (tests, assertions, etc.)
    let mut main_parts = []
    // T23: see codegen_c2 — kept in sync (T0 lesson on fold table).
    let mut has_user_main = false
    // T34: see codegen_c2 branch above — kept in sync.
    let mut has_explicit_main_call = false

    let mut i = 0
    while i < len(ast) {
        let k = ast[i].kind
        if k == "FnDecl" {
            if ast[i].name == "main" { has_user_main = true }
            fwd_parts.push(gen2_fn_forward(ast[i]) + "\n")
            fn_parts.push(gen2_fn_decl(ast[i]) + "\n\n")
        } else if k == "ExternFnDecl" {
            let ew = gen2_extern_wrapper(ast[i])
            global_parts.push(ew.global)
            fwd_parts.push(ew.forward + "\n")
            fn_parts.push(ew.fn_code + "\n\n")
            init_parts.push(ew.init)
        } else if k == "StructDecl" {
            // T33-rebuild: emit a forward declaration so the generated
            // constructor (Name(field1, ..., fieldN) -> HexaVal) can be
            // called before its definition — otherwise implicit-int K&R
            // fallback causes "conflicting types for 'Name'" at link time.
            fwd_parts.push(gen2_struct_forward(ast[i]) + "\n")
            fn_parts.push(gen2_struct_decl(ast[i]) + "\n\n")
        } else if k == "EnumDecl" {
            fn_parts.push(gen2_enum_decl(ast[i]) + "\n")
        } else if k == "ImplBlock" {
            let ib = gen2_impl_block(ast[i])
            fwd_parts.push(ib.forward)
            fn_parts.push(ib.fn_code)
        } else if k == "PureFnDecl" {
            // Treat pure fn same as regular fn
            fwd_parts.push(gen2_fn_forward(ast[i]) + "\n")
            fn_parts.push(gen2_fn_decl(ast[i]) + "\n\n")
        } else if k == "ComptimeConst" || k == "ConstStmt" {
            // Same comptime fold as codegen_c2 (kept in sync — T0 lesson).
            // ConstStmt added 2026-04-26 — see codegen_c2 above for rationale.
            let _cc_folded2 = comptime_eval(ast[i].left)
            if type_of(_cc_folded2) != "string" {
                _register_comptime_const(ast[i].name, _cc_folded2)
            } else {
                global_parts.push("HexaVal " + ast[i].name + ";\n")
                if type_of(ast[i].left) != "string" {
                    init_parts.push("    " + ast[i].name + " = " + gen2_expr(ast[i].left) + ";\n")
                } else {
                    init_parts.push("    " + ast[i].name + " = hexa_void();\n")
                }
            }
        } else if k == "OptimizeFnStmt" {
            // Optimization hint — skip
        } else if k == "TraitDecl" {
            // Skip
        } else if k == "InvariantDecl" {
            // T3 declarative @invariant DSL — codegen no-op.
            // 정적 분석은 self/invariant_check.hexa 가 별도 단계로 수행.
        } else if k == "ImportStmt" || k == "UseStmt" {
            // 2026-04-18 root fix: same path as codegen_c2 — see detailed
            // comment there. _resolve_use_emit also registers imported fn
            // names into _known_fn_globals so call sites downstream resolve.
            let _use_fwd2 = _resolve_use_emit(ast[i].name)
            if len(_use_fwd2) > 0 {
                fwd_parts.push(_use_fwd2)
            } else {
                main_parts.push("    /* import: " + ast[i].name + " */\n")
            }
        } else if k == "LetMutStmt" || k == "LetStmt" {
            // bt-53: mangle reserved runtime names (TAG_INT etc.)
            let _user_name2 = _hexa_mangle_ident(ast[i].name)
            // STRUCTURAL-2 Phase B: register global immutable let with int init
            if k == "LetStmt" && type_of(ast[i].left) != "string" {
                if _is_int_init_expr(ast[i].left) {
                    _known_int_add(ast[i].name)
                }
                // STRUCTURAL-3: register global immutable let with float init
                if _is_float_init_expr(ast[i].left) {
                    _known_float_add(ast[i].name)
                }
            }
            // ROI #43: @thread_local → _Thread_local C storage class
            let _tls_val2 = ast[i].value
            let _is_tls2 = false
            if type_of(_tls_val2) == "string" {
                if _tls_val2 == "thread_local" {
                    _is_tls2 = true
                }
            }
            if _is_tls2 {
                global_parts.push("_Thread_local HexaVal " + _user_name2 + ";\n")
            } else {
                global_parts.push("HexaVal " + _user_name2 + ";\n")
            }
            // hxa-20260423-005: initialize in program order (main_parts) —
            // mirrors the codegen_c2 branch fix. Prevents let-init hoist
            // from scheduling e.g. `ks = dict_keys(d)` before d's entries
            // are populated.
            if type_of(ast[i].left) != "string" {
                main_parts.push("    " + _user_name2 + " = " + gen2_expr(ast[i].left) + ";\n")
            } else {
                main_parts.push("    " + _user_name2 + " = hexa_void();\n")
            }
        } else {
            // T34: detect top-level `main()` ExprStmt → suppress auto-call below.
            let _tls_stmt2 = ast[i]
            if _tls_stmt2.kind == "ExprStmt" && type_of(_tls_stmt2.left) != "string" {
                let _tls_expr2 = _tls_stmt2.left
                if _tls_expr2.kind == "Call" && type_of(_tls_expr2.left) != "string" {
                    let _tls_callee2 = _tls_expr2.left
                    if _tls_callee2.kind == "Ident" && _tls_callee2.name == "main" {
                        has_explicit_main_call = true
                    }
                }
            }
            main_parts.push(gen2_stmt(ast[i], 1))
        }
        i = i + 1
    }

    let mut out_parts = []
    out_parts.push("// Generated by HEXA self-host compiler\n")
    out_parts.push("#include \"runtime.c\"\n\n")
    out_parts.push(fwd_parts.join(""))
    out_parts.push("\n")
    out_parts.push(global_parts.join(""))
    out_parts.push("\n")
    // rt#32-SL: emit string literal static slots + init function (mirror of
    // codegen_c2 main emit path). Deterministic loop from _strlit_counter.
    let mut _sl_def_i_full = 0
    while _sl_def_i_full < _strlit_counter {
        out_parts.push("static HexaVal __hexa_sl_" + to_string(_sl_def_i_full) + ";\n")
        _sl_def_i_full = _sl_def_i_full + 1
    }
    if len(_strlit_keys) > 0 {
        out_parts.push("static void __hexa_strlit_init(void) {\n")
        let mut _sli_full = 0
        while _sli_full < len(_strlit_keys) {
            out_parts.push("    __hexa_sl_" + to_string(_strlit_ids[_sli_full]) + " = hexa_str(\"" + _strlit_keys[_sli_full] + "\");\n")
            _sli_full = _sli_full + 1
        }
        out_parts.push("}\n")
    }
    // rt#37: emit inline-cache slots as file-scope statics before fn bodies.
    let mut _ic_i_full = 0
    while _ic_i_full < _ic_counter {
        out_parts.push("static HexaIC __hexa_ic_" + to_string(_ic_i_full) + " = {0};\n")
        _ic_i_full = _ic_i_full + 1
    }
    out_parts.push("\n")
    // FIX-B (2026-04-19): counter-driven lambda fwd decl emission (mirror of
    // fcf275f4 IC fix). Replaces `_lambda_fwd_parts.join("")` T33 aliasing.
    let mut _lfw_i_full = 0
    while _lfw_i_full < _lambda_counter {
        out_parts.push("HexaVal __hexa_lambda_" + to_string(_lfw_i_full) + "(" + _lambda_fwd_sigs[_lfw_i_full] + ");\n")
        _lfw_i_full = _lfw_i_full + 1
    }
    // Insert lambda definitions before user functions
    // FIX-C (2026-04-19): counter-driven per-slot read — see codegen_c2 note.
    let mut _ldp_i_full = 0
    while _ldp_i_full < _lambda_counter {
        out_parts.push(_lambda_def_parts[_ldp_i_full])
        _ldp_i_full = _ldp_i_full + 1
    }
    out_parts.push(fn_parts.join(""))
    // T3 fix: emit `int main(int argc, char** argv)` + hexa_set_args.
    out_parts.push("int main(int argc, char** argv) {\n")
    out_parts.push("    hexa_set_args(argc, argv);\n")
    if len(_strlit_keys) > 0 {
        out_parts.push("    __hexa_strlit_init();\n")
    }
    out_parts.push(init_parts.join(""))
    out_parts.push(main_parts.join(""))
    if has_user_main && !has_explicit_main_call { out_parts.push("    u_main();\n") }
    out_parts.push("    fflush(stdout); fflush(stderr);\n    return 0;\n}\n")
    // ─── NEXUS_CERT=1 cert emission (opt-in) ───────────────────────
    // Proof certificate sidecar — emit one JSON-Line per recognized
    // IR-opcode-like node into `.certificates/<module>.cert.jsonl`.
    // Off by default; triggered by `NEXUS_CERT=1` in env. Output is
    // side-channel only: the returned C source is unchanged.
    // See self/proof/certificate.hexa for the cert schema + hash fn.
    let _nc = env_var("NEXUS_CERT")
    if type_of(_nc) == "string" && _nc == "1" {
        _nexus_cert_emit(ast)
    }
    return out_parts.join("")
}

// ─── NEXUS_CERT cert emission helpers ─────────────────────────────
// We intentionally inline a minimal copy of the cert schema here
// rather than `use "proof/certificate"` — codegen_c2 must remain
// dependency-free for the P5 fixpoint; the emitted .jsonl is
// verified by tool/ossify.hexa which DOES import the proof module.
fn _nexus_cert_hash_str(s) {
    let cs = s.chars()
    let n = len(cs)
    let mut h = 5381
    let mut i = 0
    while i < n {
        let ord = len(to_string(cs[i])) + i
        h = (h * 33) + ord
        if h > 2147483000 { h = h % 2147483000 }
        i = i + 1
    }
    return h
}

fn _nexus_cert_bucket(op) {
    // Egyptian 12/8/4 over the 24 opcodes — mirror self/proof/certificate.hexa.
    if op == "Add" || op == "Sub" || op == "Mul" || op == "Div" || op == "Mod" || op == "Neg" { return "issue" }
    if op == "Load" || op == "Store" || op == "Alloc" || op == "Free" || op == "Copy" || op == "Move" { return "issue" }
    if op == "Jump" || op == "Branch" || op == "Call" || op == "Return" || op == "Phi" || op == "Switch" || op == "Assert" || op == "Assume" { return "propagate" }
    if op == "Invariant" || op == "LifetimeStart" || op == "LifetimeEnd" || op == "OwnershipTransfer" { return "verify" }
    return "issue"
}

fn _nexus_cert_pred_for(op) {
    if op == "Add"    { return "bounded" }
    if op == "Sub"    { return "monotone" }
    if op == "Mul"    { return "nonneg" }
    if op == "Div"    { return "no_div_zero" }
    if op == "Mod"    { return "mod_nonneg" }
    if op == "Neg"    { return "sign_flip" }
    if op == "Load"   { return "no_alias" }
    if op == "Store"  { return "no_leak" }
    if op == "Alloc"  { return "lifetime_valid" }
    if op == "Jump"   { return "loop_term" }
    if op == "Assert" { return "assert_holds" }
    if op == "Invariant" { return "invariant_holds" }
    return "bounded"
}

// Map a BinaryOp.op string to one of the 24 IR opcode names (or "").
fn _nexus_cert_binop_to_ir(binop) {
    if binop == "+" { return "Add" }
    if binop == "-" { return "Sub" }
    if binop == "*" { return "Mul" }
    if binop == "/" { return "Div" }
    if binop == "%" { return "Mod" }
    return ""
}

// Walk one statement/expression node collecting synthetic cert rows.
// Best-effort shallow walk — we only recognize top-level FnDecl bodies
// and the obvious arithmetic BinaryOp cases. Good enough for a v0
// jsonl; ossify verify just re-hashes the emitted lines.
fn _nexus_cert_walk_expr(node, target, rows) {
    if type_of(node) == "string" { return rows }
    let k = node.kind
    if k == "BinaryOp" {
        let op_ir = _nexus_cert_binop_to_ir(node.op)
        if op_ir != "" {
            rows.push([op_ir, target])
        }
        rows = _nexus_cert_walk_expr(node.left,  target, rows)
        rows = _nexus_cert_walk_expr(node.right, target, rows)
    }
    return rows
}

fn _nexus_cert_walk_stmt(node, target, rows) {
    if type_of(node) == "string" { return rows }
    let k = node.kind
    if k == "LetStmt" || k == "LetMutStmt" {
        rows.push(["Store", node.name])
        rows = _nexus_cert_walk_expr(node.value, node.name, rows)
    } else if k == "AssignStmt" {
        rows.push(["Store", target])
        rows = _nexus_cert_walk_expr(node.value, target, rows)
    } else if k == "CallExpr" {
        rows.push(["Call", target])
    } else if k == "ReturnStmt" {
        rows.push(["Return", target])
        rows = _nexus_cert_walk_expr(node.value, target, rows)
    } else if k == "BinaryOp" {
        rows = _nexus_cert_walk_expr(node, target, rows)
    }
    return rows
}

fn _nexus_cert_module_name() {
    // Best-effort: derive from args()[2] (the .hexa being compiled);
    // fall back to "module" if unavailable.
    let av = args()
    if type_of(av) == "string" || len(av) < 3 { return "module" }
    let path = av[2]
    if type_of(path) != "string" { return "module" }
    // strip directory
    let mut i = len(path) - 1
    let mut slash = -1
    while i >= 0 {
        let ch = path.substring(i, i + 1)
        if ch == "/" { slash = i; i = -1 } else { i = i - 1 }
    }
    let base = if slash >= 0 { path.substring(slash + 1, len(path)) } else { path }
    // strip .hexa suffix
    let bn = len(base)
    if bn >= 5 && base.substring(bn - 5, bn) == ".hexa" {
        return base.substring(0, bn - 5)
    }
    return base
}

fn _nexus_cert_emit(ast) {
    let mut rows = []
    let mut i = 0
    while i < len(ast) {
        let node = ast[i]
        let k = node.kind
        if k == "FnDecl" || k == "PureFnDecl" || k == "AsyncFnDecl" {
            let fn_name = to_string(node.name)
            // issue cert for the fn entry
            rows.push(["Alloc", fn_name])
            let body = node.body
            if type_of(body) != "string" {
                let mut j = 0
                while j < len(body) {
                    rows = _nexus_cert_walk_stmt(body[j], fn_name, rows)
                    j = j + 1
                }
            }
        }
        i = i + 1
    }
    // build jsonl
    let mut lines = []
    let mut ri = 0
    while ri < len(rows) {
        let op     = rows[ri][0]
        let target = rows[ri][1]
        let pred   = _nexus_cert_pred_for(op)
        let bucket = _nexus_cert_bucket(op)
        let status = "ISSUED"
        let canonical = pred + "|" + target + "|" + bucket + "|" + status
        let h = _nexus_cert_hash_str(canonical)
        let line = "{\"predicate\":\"" + pred + "\",\"target\":\"" + target + "\",\"opcode\":\"" + op + "\",\"bucket\":\"" + bucket + "\",\"status\":\"" + status + "\",\"hash\":" + to_string(h) + "}"
        lines.push(line)
        ri = ri + 1
    }
    // ensure dir exists, then write file.
    exec("mkdir -p .certificates")
    let mname = _nexus_cert_module_name()
    let path = ".certificates/" + mname + ".cert.jsonl"
    let body = lines.join("\n") + "\n"
    write_file(path, body)
    eprintln("[nexus_cert] wrote " + to_string(len(lines)) + " cert(s) → " + path)
}

// ═══════════════════════════════════════════════════════════
//  .hxi emit — Separate Compilation v0 (M0)
//
//  Line-based module interface file. Lists public decls only —
//  fn signatures, struct field types, extern symbols, top-level
//  lets, enum names. No fn bodies, no struct methods body, no
//  comptime resolution.
//
//  Schema v0:
//      hxi v0
//      src_bytes <N>
//      fn <name>(<pname>:<ptype>,...)-><ret>
//      struct <name>(<fname>:<ftype>,...)
//      enum <name>
//      extern <name>(...)-><ret> [@symbol=<s>] [@link=<l>]
//      let <name>:<type>           (type="_" when unresolved)
//      let_mut <name>:<type>
//      comptime <name>
//
//  See: docs/separate-compilation-design.md
// ═══════════════════════════════════════════════════════════

fn _hxi_params_str(params) {
    if type_of(params) == "string" { return "" }
    let mut parts = []
    let mut i = 0
    while i < len(params) {
        let p = params[i]
        let vt = to_string(p.value)
        let t = if vt == "" { "_" } else { vt }
        parts.push(to_string(p.name) + ":" + t)
        i = i + 1
    }
    return parts.join(",")
}

fn _hxi_fn_line(node) {
    let ret = to_string(node.ret_type)
    let ret_s = if ret == "" { "void" } else { ret }
    return "fn " + to_string(node.name) + "(" + _hxi_params_str(node.params) + ")->" + ret_s
}

fn _hxi_struct_line(node) {
    let fields = node.fields
    if type_of(fields) == "string" {
        return "struct " + to_string(node.name) + "()"
    }
    let mut parts = []
    let mut i = 0
    while i < len(fields) {
        let f = fields[i]
        let vt = to_string(f.value)
        let t = if vt == "" { "_" } else { vt }
        parts.push(to_string(f.name) + ":" + t)
        i = i + 1
    }
    return "struct " + to_string(node.name) + "(" + parts.join(",") + ")"
}

fn _hxi_extern_line(node) {
    let ret = to_string(node.ret_type)
    let ret_s = if ret == "" { "void" } else { ret }
    let sym = to_string(node.value)
    let link = to_string(node.op)
    let mut line = "extern " + to_string(node.name) + "(" + _hxi_params_str(node.params) + ")->" + ret_s
    if sym != "" { line = line + " @symbol=" + sym }
    if link != "" { line = line + " @link=" + link }
    return line
}

fn _hxi_let_line(node, mutable) {
    let prefix = if mutable { "let_mut " } else { "let " }
    return prefix + to_string(node.name) + ":_"
}

fn emit_hxi(ast, src_bytes) {
    let mut lines = []
    lines.push("hxi v0")
    lines.push("src_bytes " + to_string(src_bytes))
    let mut i = 0
    while i < len(ast) {
        let node = ast[i]
        let k = node.kind
        if k == "FnDecl" {
            lines.push(_hxi_fn_line(node))
        } else if k == "PureFnDecl" {
            lines.push(_hxi_fn_line(node))
        } else if k == "AsyncFnDecl" {
            lines.push(_hxi_fn_line(node))
        } else if k == "StructDecl" {
            lines.push(_hxi_struct_line(node))
        } else if k == "EnumDecl" {
            lines.push("enum " + to_string(node.name))
        } else if k == "ExternFnDecl" {
            lines.push(_hxi_extern_line(node))
        } else if k == "LetStmt" {
            lines.push(_hxi_let_line(node, false))
        } else if k == "LetMutStmt" {
            lines.push(_hxi_let_line(node, true))
        } else if k == "ComptimeConst" {
            lines.push("comptime " + to_string(node.name))
        }
        i = i + 1
    }
    return lines.join("\n") + "\n"
}

// Banner moved to gen2_full_program() invocation site — printing at
// module-load time pollutes interpreter output for every `hexa run`.
// println("=== HEXA → C (HexaVal runtime) Code Generator ===")
