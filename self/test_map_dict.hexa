// ═══════════════════════════════════════════════════════════
//  test_map_dict.hexa — HashMap / Dictionary Operation Tests
//  Tests: creation, get, set, delete, iterate, keys, values,
//         contains_key, len, nested maps, map patterns, edge cases
// ═══════════════════════════════════════════════════════════

let mut pass_count = 0
let mut fail_count = 0

fn check(name, actual, expected) {
    if to_string(actual) == to_string(expected) {
        println("[PASS] " + name)
        pass_count = pass_count + 1
    } else {
        println("[FAIL] " + name + " — expected: " + to_string(expected) + ", got: " + to_string(actual))
        fail_count = fail_count + 1
    }
}

println("═══════════════════════════════════════════════════════")
println("  HEXA Map / Dictionary Tests")
println("═══════════════════════════════════════════════════════")
println("")

// ── 1. Empty map ──────────────────────────────────────────

println("--- Empty Map ---")

let e = #{}
check("empty map len", len(e), 0)
check("empty contains_key", e.contains_key("x"), false)

// ── 2. Literal creation & access ──────────────────────────

println("")
println("--- Literal Creation ---")

let m1 = #{"a": 1, "b": 2, "c": 3}
check("literal get a", m1["a"], 1)
check("literal get b", m1["b"], 2)
check("literal get c", m1["c"], 3)
check("literal len", len(m1), 3)

let m2 = #{"name": "hexa", "version": "2.0"}
check("string val name", m2["name"], "hexa")
check("string val version", m2["version"], "2.0")

// ── 3. Mutable insert & update ────────────────────────────

println("")
println("--- Mutable Insert & Update ---")

let mut m3 = #{}
m3["x"] = 10
check("insert x", m3["x"], 10)
check("after insert len", len(m3), 1)

m3["y"] = 20
m3["z"] = 30
check("insert y", m3["y"], 20)
check("insert z", m3["z"], 30)
check("after 3 inserts len", len(m3), 3)

m3["x"] = 99
check("update x", m3["x"], 99)
check("update preserves len", len(m3), 3)

// ── 4. contains_key ───────────────────────────────────────

println("")
println("--- Contains Key ---")

let m4 = #{"hello": 1, "world": 2}
check("contains_key hello", m4.contains_key("hello"), true)
check("contains_key world", m4.contains_key("world"), true)
check("contains_key missing", m4.contains_key("foo"), false)
check("contains_key empty str", m4.contains_key(""), false)

// ── 5. keys() and values() ───────────────────────────────

println("")
println("--- Keys & Values ---")

let m5 = #{"p": 10, "q": 20, "r": 30}
let ks = m5.keys()
check("keys len", len(ks), 3)

let vs = m5.values()
check("values len", len(vs), 3)

let mut val_sum = 0
for v in m5.values() {
    val_sum = val_sum + v
}
check("values sum", val_sum, 60)

// ── 6. Nested maps ───────────────────────────────────────

println("")
println("--- Nested Maps ---")

let nested = #{"outer": #{"inner": 42}}
check("nested access", nested["outer"]["inner"], 42)

let deep = #{"a": #{"b": #{"c": #{"d": 99}}}}
check("deep nested 4 levels", deep["a"]["b"]["c"]["d"], 99)

let mut mn = #{"sub": #{}}
mn["sub"]["key"] = "value"
check("nested mut set", mn["sub"]["key"], "value")

// ── 7. Map with different value types ─────────────────────

println("")
println("--- Mixed Value Types ---")

let mixed = #{"int": 42, "str": "hello", "bool": true, "float": 3.14}
check("mixed int", mixed["int"], 42)
check("mixed str", mixed["str"], "hello")
check("mixed bool", mixed["bool"], true)

// ── 8. Map with array values ─────────────────────────────

println("")
println("--- Map with Array Values ---")

let arr_map = #{"nums": [1, 2, 3], "letters": ["a", "b"]}
check("map arr len nums", len(arr_map["nums"]), 3)
check("map arr [0]", arr_map["nums"][0], 1)
check("map arr letters[1]", arr_map["letters"][1], "b")

// ── 9. Building map dynamically ──────────────────────────

println("")
println("--- Dynamic Build ---")

let mut freq = #{}
let words = ["apple", "banana", "apple", "cherry", "banana", "apple"]
for w in words {
    if freq.contains_key(w) {
        freq[w] = freq[w] + 1
    } else {
        freq[w] = 1
    }
}
check("freq apple", freq["apple"], 3)
check("freq banana", freq["banana"], 2)
check("freq cherry", freq["cherry"], 1)
check("freq len", len(freq), 3)

// ── 10. Map as function argument ─────────────────────────

println("")
println("--- Map as Argument ---")

fn map_sum_values(m) {
    let mut total = 0
    for v in m.values() {
        total = total + v
    }
    return total
}

let scores = #{"math": 90, "science": 85, "english": 95}
check("fn map sum", map_sum_values(scores), 270)

fn map_has_all_keys(m, keys) {
    for k in keys {
        if m.contains_key(k) == false {
            return false
        }
    }
    return true
}
check("has all keys yes", map_has_all_keys(scores, ["math", "science"]), true)
check("has all keys no", map_has_all_keys(scores, ["math", "art"]), false)

// ═══════════════════════════════════════════════════════════
//  SUMMARY
// ═══════════════════════════════════════════════════════════

println("")
println("═══════════════════════════════════════════════════════")
let total = pass_count + fail_count
println("  Results: " + to_string(pass_count) + " PASS / " + to_string(fail_count) + " FAIL / " + to_string(total) + " total")
if fail_count == 0 {
    println("  ALL MAP/DICT TESTS PASSED!")
} else {
    println("  SOME TESTS FAILED")
}
println("═══════════════════════════════════════════════════════")
